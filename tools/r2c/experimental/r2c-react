  prototype <args...>
EOF
}

maybe_exec_stage3() {
  cmd_name="$1"
  shift
  case "$cmd_name" in
    help|-h|--help|status|frontend|static-surface|semantic-surface|codegen-surface|discover-truth-routes|capture-truth|compare-truth|exec-route-matrix|compare-truth-matrix|native-gui-bundle|native-gui-runtime|run-native-gui|render-compare|render-compare-matrix|replay-hit-inspector|compile)
      ;;
    *)
      return 1
      ;;
  esac
  if [ "${R2C_REACT_NO_STAGE3_HANDOFF:-0}" = "1" ]; then
    return 1
  fi
  if [ ! -f "$bridge_env" ]; then
    return 1
  fi
  # shellcheck disable=SC1090
  . "$bridge_env"
  if [ -n "${CHENG_BOOTSTRAP_STAGE3:-}" ] && "$CHENG_BOOTSTRAP_STAGE3" r2c-react help >/dev/null 2>&1; then
    exec "$CHENG_BOOTSTRAP_STAGE3" r2c-react "$cmd_name" "$@"
  fi
  return 1
}

read_flag() {
  key="$1"
  default_value="$2"
  shift 2
  while [ "$#" -gt 0 ]; do
    case "$1" in
      "$key")
        shift
        if [ "$#" -gt 0 ]; then
          printf '%s\n' "$1"
          return 0
        fi
        ;;
      "$key":*)
        printf '%s\n' "${1#"$key:"}"
        return 0
        ;;
      "$key"=*)
        printf '%s\n' "${1#"$key="}"
        return 0
        ;;
    esac
    shift
  done
  printf '%s\n' "$default_value"
}

abs_path() {
  base="$1"
  target="$2"
  node -e 'const path=require("node:path"); console.log(path.resolve(process.argv[1], process.argv[2]));' "$base" "$target"
}

