require_live_controller_cmd() {
  command_name="$1"
  echo "r2c-react: $command_name now requires the live Cheng controller; use artifacts/bootstrap/cheng.stage3 r2c-react $command_name ..." >&2
  return 1
}

exec_surface_cmd() {
  echo "r2c-react: exec-surface is retired; exec snapshot now comes from native-gui-bundle / exec-route-matrix mainline." >&2
  return 1
}

native_gui_runtime_cmd() {
  runtime_contract_raw="$(read_flag --runtime-contract "" "$@")"
  if [ -z "$runtime_contract_raw" ]; then
    runtime_contract_raw="$(read_flag --runtime-contract-path "" "$@")"
  fi
  if [ -z "$runtime_contract_raw" ]; then
    echo "r2c-react: native-gui-runtime missing --runtime-contract" >&2
    return 1
  fi
  runtime_contract_path="$(abs_path "$PWD" "$runtime_contract_raw")"
  if [ ! -f "$runtime_contract_path" ]; then
    echo "r2c-react: native-gui-runtime missing runtime contract: $runtime_contract_path" >&2
    return 1
  fi
  runtime_exe_raw="$(read_flag --compiled-runtime-exe "" "$@")"
  if [ -n "$runtime_exe_raw" ]; then
    runtime_exe_path="$(abs_path "$PWD" "$runtime_exe_raw")"
  else
    runtime_exe_path="$(dirname "$runtime_contract_path")/native_gui_runtime_compiled_main"
  fi
  if [ ! -f "$runtime_exe_path" ]; then
    echo "r2c-react: native-gui-runtime missing compiled runtime exe: $runtime_exe_path" >&2
    return 1
  fi
  exec "$runtime_exe_path" "$@"
}

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

case "$cmd" in
  help|-h|--help)
    usage
    exit 0
    ;;
  status)
    status_cmd "$@"
    exit $?
    ;;
esac

maybe_exec_stage3 "$cmd" "$@" || true

case "$cmd" in
  help|-h|--help)
    usage
    ;;
  status)
    status_cmd "$@"
    ;;
  frontend)
    require_live_controller_cmd frontend
    ;;
  static-surface)
    require_live_controller_cmd static-surface
    ;;
  semantic-surface)
    require_live_controller_cmd semantic-surface
    ;;
  codegen-surface)
    require_live_controller_cmd codegen-surface
    ;;
  exec-surface)
    exec_surface_cmd
    ;;
  native-gui-bundle)
    require_live_controller_cmd native-gui-bundle
    ;;
  native-gui-runtime)
    native_gui_runtime_cmd "$@"
    ;;
  run-native-gui)
    require_live_controller_cmd run-native-gui
    ;;
  render-compare)
    require_live_controller_cmd render-compare
    ;;
  render-compare-matrix)
    require_live_controller_cmd render-compare-matrix
    ;;
  replay-hit-inspector)
    require_live_controller_cmd replay-hit-inspector
    ;;
  exec-route-matrix)
    require_live_controller_cmd exec-route-matrix
    ;;
  compare-truth)
    require_live_controller_cmd compare-truth
    ;;
  compare-truth-matrix)
    require_live_controller_cmd compare-truth-matrix
    ;;
  compile)
    require_live_controller_cmd compile
    ;;
  discover-truth-routes)
    require_live_controller_cmd discover-truth-routes
    ;;
  capture-truth)
    require_live_controller_cmd capture-truth
    ;;
  prototype)
    exec python3 "$exp_root/r2c-react.py" "$@"
    ;;
  *)
    echo "r2c-react: unknown subcommand: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
