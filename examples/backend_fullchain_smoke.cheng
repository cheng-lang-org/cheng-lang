@importc("puts")
fn cPuts(s: cstring): int32

fn sumTo(n: int32): int32 =
    var acc: int32 = 0
    var i: int32 = 0
    while i < n:
        acc = acc + i
        i = i + 1
    return acc

fn main() =
    let got: int32 = sumTo(128)
    if got == 8128:
        cPuts("fullspec ok")
        return
    cPuts("fullspec fail")
