import std/system
import std/seqs as seqs
import std/strutils as strutil
import std/strformat as strfmt
import std/json as json
import std/parseutils as parseutils
import std/strings

fn main() =
    let fmtParts: str[] = ["cheng", "-", "lang"]
    let formatted: str = strfmt.fmt(fmtParts)
    var root: json.JsonNode = json.newJObject()
    root["name"] = json.newJString("cheng")
    var parsed: int32 = 0
    let parsedCount: int32 = parseutils.parseInt32("128kb", parsed)
    echo("format=" + formatted)
    echo("name=" + json.getStr(root["name"], ""))
    echo("upper=" + strutil.toUpperAscii("ok"))
    echo("parsed=" + intToStr(parsed) + "/" + intToStr(parsedCount))
    echo("string_json ok")
