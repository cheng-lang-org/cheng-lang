import std/system
import std/strutils as strutil
import std/json as json
import std/parseutils as parseutils
import std/strings

fn main() =
    var fmtParts: str[]
    add(fmtParts, "cheng")
    add(fmtParts, "-")
    add(fmtParts, "lang")
    let formatted: str = Fmt(fmtParts)
    assert(formatted == "cheng-lang", "fmt")
    let jsonName = "cheng"
    var root: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(root, "name", jsonName)
    var parsed: int32
    let parsedCount: int32 = parseutils.ParseInt32("128kb", parsed)
    let nameNode: json.JsonNode = root["name"]
    var gotName: str
    let jsonFound: bool = json.JsonNodeTryGetStr(nameNode, gotName)
    let rendered = json.Pretty(root, 2)
    let upperText = strutil.ToUpperAscii("ok")
    let parsedOk: bool = parsed == 128
    let parsedCountOk: bool = parsedCount == 3
    assert(jsonFound, "jsonFound")
    assert(gotName == jsonName, "json")
    assert(rendered == "{\"name\":\"cheng\"}", "pretty")
    assert(upperText == "OK", "upper")
    assert(parsedOk, "parsed")
    assert(parsedCountOk, "parsedCount")
    echo("string_json ok")
