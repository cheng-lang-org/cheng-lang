import std/system
import std/result
import std/rawbytes
import std/net/ipaddr as ipaddr
import std/net/stream/bufferstream as bufferstream
import std/strutils as strutil

fn main() =
    let ipRes: Result[ipaddr.IpAddr] = ipaddr.parseIpAddr("127.0.0.1")
    assert(IsOk(ipRes), "example ip parse")

    var stream: bufferstream.BufferStream = bufferstream.newBufferStream()
    let writeRes: Result[int32] = bufferstream.write(stream, bytesFromString("udp-ok"))
    assert(IsOk(writeRes), "example buffer write")
    let readRes: Result[Bytes] = bufferstream.read(stream, 64)
    assert(IsOk(readRes), "example buffer read")

    echo("ip=127.0.0.1")
    echo(strutil.Join(["buffer=", bytesToString(Value(readRes))], ""))
    echo("net_io ok")
