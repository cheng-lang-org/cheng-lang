import std/system
import std/result
import std/seqs
import std/rawbytes
import std/strings
import std/strutils as strutil

fn main() =
    var nums: int32[]
    seqs.add(nums, 3)
    seqs.add(nums, 5)
    let valueRes: Result[int32] = Ok[int32](7)
    let payload: Bytes = bytesFromString("ok")
    echo(strutil.Join(["seq=", intToStr(nums.len)], ""))
    echo(strutil.Join(["result=", intToStr(Value(valueRes))], ""))
    echo(strutil.Join(["bytes=", bytesToString(payload)], ""))
    echo("foundation ok")
