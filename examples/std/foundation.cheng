import std/system
import std/result
import std/seqs
import std/rawbytes
import std/strings

fn main() =
    var nums: int32[]
    seqs.add(nums, 3)
    seqs.add(nums, 5)
    let valueRes: Result[int32] = Ok[int32](7)
    let payload: Bytes = bytesFromString("ok")
    echo("seq=" + intToStr(nums.len))
    echo("result=" + intToStr(Value(valueRes)))
    echo("bytes=" + bytesToString(payload))
    echo("foundation ok")
