import std/system
import std/os
import std/strutils as strutil

fn main() =
    let tmpRoot: str = getEnvDefault("EXAMPLE_STD_TMPDIR", "artifacts/examples_std_file_io")
    createDir(tmpRoot)
    let filePath: str = joinPath(tmpRoot, "example.txt")
    writeFile(filePath, "example-data")
    let captureArgs: str[] = ["example-capture"]
    var captureEnv: str[]
    let captureRes: ExecCmdResult = execFileCapture("/bin/echo", captureArgs, captureEnv, "", false, 5)
    echo("read=" + readFile(filePath))
    echo("capture=" + strutil.strip(execCmdResultOutput(captureRes)))
    removeFile(filePath)
    removeDir(tmpRoot)
    echo("file_io ok")
