import std/buffer
import std/rawbytes

fn main(): int32 =
    var buf: buffer.ByteBuffer = buffer.newByteBuffer()
    let first: rawbytes.Bytes = rawbytes.bytesFromString("ab")
    let second: rawbytes.Bytes = rawbytes.bytesFromString("cd")
    buffer.appendBytes(buf, first)
    buffer.appendBytes(buf, second)
    buffer.appendByte(buf, int32('e'))
    let out: rawbytes.Bytes = buffer.toBytes(buf)
    if rawbytes.bytesLen(out) != 5:
        return 1
    if rawbytes.bytesToString(out) != "abcde":
        return 2
    return 0
