import std/seqs
import std/strings
import std/tables_compat as tables

fn main(): int32 =
    var values: seq_string = newSeq_string(0, 0)
    addPtr_string(&values, "a")
    addPtr_string(&values, "b")
    setStringAt(&values, 1, "c")
    insert(&values, "d", 1)
    delete(&values, 0)

    if values.len != 2:
        return 1
    if !streq(getStringAtPtr(&values, 0), "d"):
        return 2
    if !streq(getStringAtPtr(&values, 1), "c"):
        return 3

    freeSeqPtr_string(&values)

    var dict: tables.Table[str] = tables.TableInit[str](8)
    tables.TablePut[str](dict, "k", "v1")
    tables.TablePut[str](dict, "k", "v2")
    if !tables.TableHas[str](dict, "k"):
        return 4
    if !streq(tables.TableGet[str](dict, "k"), "v2"):
        return 5
    tables.arcReleaseTableString(dict)
    return 0
