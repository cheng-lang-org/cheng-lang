import std/system

type
    Counter =
        value: int32
    Holder =
        inner: Counter

fn main(): int32 =
    var xs: int32[3]
    xs.len = 3
    xs[0] = 1
    xs[1] = 2
    xs[2] = 3
    if xs.len != 3:
        return 1
    let holder: Holder = Holder(inner: Counter(value: 7))
    if holder.inner.value != 7:
        return 2
    puts(cstring("dot cstring contract"))
    return 0
