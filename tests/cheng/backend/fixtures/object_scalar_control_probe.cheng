type
    Box =
        value: int32

fn setWhole(box: var Box, value: int32) =
    box = Box(value: value)

fn setField(box: var Box, value: int32) =
    box.value = value

fn main(): int32 =
    var a: Box
    setWhole(a, 7)
    if a.value != 7:
        return 1
    var b: Box
    setField(b, 9)
    if b.value != 9:
        return 2
    return 0
