import std/strutils as strutil
import cheng/core/backend/primary_object_plan as pobj

fn main(): int32 =
    var plan: pobj.PrimaryObjectPlan
    plan.targetTriple = "arm64-apple-darwin"
    plan.objectFormat = "macho"
    plan.entrySymbol = "_main"
    add(plan.itemIds, 100000)
    add(plan.symbolNames, "_main")
    add(plan.functionWordOffsets, 0)
    add(plan.functionWordCounts, 2)
    add(plan.functionBodyKinds, "cold_body_ir_codegen")
    add(plan.instructionWords, 1)
    add(plan.instructionWords, 2)
    add(plan.relocSourceItemIds, 200000)
    add(plan.relocWordOffsets, 0)
    add(plan.relocTargetSymbols, "_callee")

    var facts = ""
    var err = ""
    let ok = pobj.PrimaryObjectPlanColdCsgV2FactsInto(plan,
                                                       "arm64-apple-darwin",
                                                       "macho",
                                                       facts,
                                                       err)
    assert(!ok, " csg v2 writer reloc source contract: bad source item must fail")
    assert(strutil.Contains(err, "reloc source item missing"),
           " csg v2 writer reloc source contract: missing source reason")
    assert(len(facts) == 0, " csg v2 writer reloc source contract: no facts on failure")
    return 0
