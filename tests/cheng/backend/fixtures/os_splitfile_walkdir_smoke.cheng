import std/os

fn main(): int32 =
    let info: SplitFileResult = splitFile("alpha/beta.txt")
    if info.dir != "alpha":
        return 1
    if info.name != "beta":
        return 2
    if info.ext != ".txt":
        return 3
    if parentDir("alpha/beta.txt") != "alpha":
        return 4
    if relativePath("alpha/beta.txt", "alpha") != "beta.txt":
        return 5
    let items: seq_WalkDirEntry = walkDir("")
    if items.len != 0:
        return 6
    return 0
