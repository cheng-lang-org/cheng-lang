type Inner =
    x: int32
    y: int32

type Outer =
    inner: Inner
    label: int32

fn makeInner(x: int32, y: int32): Inner =
    return Inner(x: x, y: y)

fn main(): int32 =
    let inner: Inner = makeInner(10, 20)
    var outer: Outer
    outer.inner = inner
    outer.label = 5
    return outer.inner.x + outer.inner.y + outer.label - 35
