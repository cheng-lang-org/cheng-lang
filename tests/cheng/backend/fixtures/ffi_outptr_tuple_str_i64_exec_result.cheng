@importc("cheng_exec_cmd_ex")
@ffi_out_ptrs(arg3)
fn cheng_exec_cmd_ex(command: cstring, workingDir: cstring, mergeStderr: int32): tuple[str, int64]

type
    ExecCmdResult =
        output: str
        exitCode: int32

fn main(): int32 =
    let (output1, exitCode64): tuple[str, int64] = cheng_exec_cmd_ex("", "", 0)
    let result: ExecCmdResult = ExecCmdResult(output: output1, exitCode: int32(exitCode64))
    return result.exitCode
