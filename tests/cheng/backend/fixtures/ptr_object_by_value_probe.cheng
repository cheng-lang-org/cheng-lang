import std/rawbytes

fn dataLen(data: rawbytes.Bytes): int32 =
    return rawbytes.bytesLen(data)

fn main(): int32 =
    let directLen: int32 = dataLen(rawbytes.bytesFromString("ab"))
    if directLen != 2:
        return 1
    let bytes: rawbytes.Bytes = rawbytes.bytesFromString("cd")
    let localLen: int32 = dataLen(bytes)
    if localLen != 2:
        return 2
    return 0
