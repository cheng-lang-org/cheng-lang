@importc("cheng_ffi_raw_new_i32")
@ffi_handle
fn rawHandleNewI32(value: int32): uint64

@importc("cheng_ffi_raw_get_i32")
@ffi_handle
fn rawHandleGetI32(handle: uint64): int32

@importc("cheng_ffi_raw_add_i32")
@ffi_handle
fn rawHandleAddI32(handle: uint64, delta: int32): int32

@importc("cheng_ffi_raw_release_i32")
@ffi_handle
fn rawHandleReleaseI32(handle: uint64): int32

fn main(): int32 =
    let h0: uint64 = rawHandleNewI32(40)
    if h0 == uint64(0):
        return 1
    if rawHandleGetI32(h0) != 40:
        return 2
    if rawHandleAddI32(h0, 2) != 42:
        return 3
    if rawHandleGetI32(h0) != 42:
        return 4
    if rawHandleReleaseI32(h0) != 0:
        return 5
    return 0
