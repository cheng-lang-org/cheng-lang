import stage1/lexer
import stage1/parser
import stage1/ast
import stage1/token

fn findFirstStrLit(n: ast.AstNodeId): ast.AstNodeId =
    if !ast.astNodeIdValid(n):
        return ast.astInvalidNodeId()
    if ast.astNodeKind(n) == ast.nkStrLit:
        return n
    for i in 0..<ast.astKidCount(n):
        let found: ast.AstNodeId = findFirstStrLit(ast.astKidAt(n, i))
        if ast.astNodeIdValid(found):
            return found
    return ast.astInvalidNodeId()

fn main(): int32 =
    let src: str = "fn main(): int32 =\n    let s: str = \"ab\"\n    return len(s)\n"
    var tokens: token.Token[]
    var diags: lexer.Diagnostic[]
    if !lexer.lexInto(src, "mem", &tokens, &diags):
        return 1
    if diags.len != 0:
        return 2
    var sawStringTok: bool = false
    for i in 0..<tokens.len:
        let t: token.Token = tokens[i]
        if t.kind == token.tkString:
            sawStringTok = true
            if token.tokenLexeme(t) != "ab":
                return 3
            break
    if !sawStringTok:
        return 4
    let root: ast.AstNodeId = parser.parseModuleWithDiagnosticsId(tokens, "mem", &diags)
    if diags.len != 0:
        return 5
    let lit: ast.AstNodeId = findFirstStrLit(root)
    if !ast.astNodeIdValid(lit):
        return 6
    if ast.astNodeStrVal(lit) != "ab":
        return 7
    token.freeSeq_Token(tokens)
    if ast.astNodeStrVal(lit) != "ab":
        return 8
    return 0
