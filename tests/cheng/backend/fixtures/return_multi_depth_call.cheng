fn add(a: int32, b: int32): int32 =
    return a + b

fn doubleAdd(a: int32, b: int32, c: int32, d: int32): int32 =
    return add(a, b) + add(c, d)

fn tripleAdd(a: int32, b: int32, c: int32, d: int32,
             e: int32, f: int32): int32 =
    return doubleAdd(a, b, c, d) + add(e, f)

fn main(): int32 =
    return tripleAdd(1, 2, 3, 4, 5, 6) - 21
