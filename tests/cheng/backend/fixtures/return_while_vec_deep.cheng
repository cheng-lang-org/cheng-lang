import std/cmdline

fn main(): int32 =
    var i: int32
    var acc: int32
    var n: int32 = cmdline.argCount()
    if n < 64:
        n = 64
    while i < n:
        let a: int32 = i + 1
        let b: int32 = i + 2
        let c: int32 = i + 3
        let d: int32 = i + 4
        # Keep a left-deep associative tree so loop-vector rebalance has work.
        acc = (((a + b) + c) + d) + acc
        i = i + 4
    return acc & 255
