fn add64(a: int64, b: int64): int64 =
    return a + b

fn mul64(a: int64, b: int64): int64 =
    return a * b

fn sub64(a: int64, b: int64): int64 =
    return a - b

fn main(): int32 =
    let s: int64 = add64(100, 200)
    let m: int64 = mul64(s, 2)
    let r: int64 = sub64(m, 600)
    return int32(r)
