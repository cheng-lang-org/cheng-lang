fn and64(a: int64, b: int64): int64 =
    return a & b

fn or64(a: int64, b: int64): int64 =
    return a | b

fn xor64(a: int64, b: int64): int64 =
    return a ^ b

fn shl64(a: int64, b: int64): int64 =
    return a << b

fn asr64(a: int64, b: int64): int64 =
    return a >> b

fn main(): int32 =
    let v1: int64 = and64(255, 15)
    let v2: int64 = or64(1, 4)
    let v3: int64 = xor64(7, 3)
    let v4: int64 = shl64(1, 3)
    let v5: int64 = asr64(64, 2)
    let sum: int64 = v1 + v2 + v3 + v4 + v5
    return int32(sum - 101)
