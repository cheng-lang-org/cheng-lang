import std/seqs

type
    Row = ref
        values: str[]
        count: int32

fn buildRow(seed: str, n: int32): Row =
    var row: Row
    new row
    add(row.values, seed)
    for i in 0..<n:
        add(row.values, "x")
    row.count = row.values.len
    return row

fn main(): int32 =
    let row: Row = buildRow("head", 256)
    if row.values.len != 257:
        return 1
    if row.values[0] != "head":
        return 2
    if row.count != 257:
        return 3
    return row.count - 257
