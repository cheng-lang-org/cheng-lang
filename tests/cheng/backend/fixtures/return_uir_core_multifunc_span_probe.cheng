import backend/uir/uir_internal/uir_core_types
import std/result

fn stmtConstValue(blk: UirBlockId, idx: int32): int32 =
    let st: UirStmtId = uirCoreBlockStmtAt(blk, idx)
    return int32(uirCoreExprConstValueOf(uirCoreStmtExprOf(st)))

fn checkBlock(blk: UirBlockId, expectLen: int32, v0: int32, v1: int32, v2: int32): int32 =
    if uirCoreBlockStmtsLen(blk) != expectLen:
        return 1
    if expectLen > 0 && stmtConstValue(blk, 0) != v0:
        return 2
    if expectLen > 1 && stmtConstValue(blk, 1) != v1:
        return 3
    if expectLen > 2 && stmtConstValue(blk, 2) != v2:
        return 4
    return 0

fn main(): int32 =
    let mod = uirCoreNewModule("arm64-apple-darwin")
    let retTy: UirCoreType = uirCoreTypeI32()

    let f0 = uirCoreNewFunc("f0", retTy)
    let stmts0: UirStmtId[] = [
        uirCoreStmtExpr(uirCoreConstI64(11)),
        uirCoreStmtExpr(uirCoreConstI64(12))
    ]
    let b0 = uirCoreBlockWithStmts("entry", stmts0, uirCoreTermRet(uirCoreConstI64(0)))
    uirCoreAddBlock(f0, b0)
    uirCoreAddFunc(mod, f0)

    let f1 = uirCoreNewFunc("f1", retTy)
    let stmts1: UirStmtId[] = [
        uirCoreStmtExpr(uirCoreConstI64(21)),
        uirCoreStmtExpr(uirCoreConstI64(22)),
        uirCoreStmtExpr(uirCoreConstI64(23))
    ]
    let b1 = uirCoreBlockWithStmts("entry", stmts1, uirCoreTermRet(uirCoreConstI64(0)))
    uirCoreAddBlock(f1, b1)
    uirCoreAddFunc(mod, f1)

    let f2 = uirCoreNewFunc("f2", retTy)
    let stmts2: UirStmtId[] = [
        uirCoreStmtExpr(uirCoreConstI64(31))
    ]
    let b2 = uirCoreBlockWithStmts("entry", stmts2, uirCoreTermRet(uirCoreConstI64(0)))
    uirCoreAddBlock(f2, b2)
    uirCoreAddFunc(mod, f2)

    let vres: Result[bool] = uirCoreValidateModule(mod)
    if ! IsOk[bool](vres):
        return 10
    if uirCoreModuleFuncsLen(mod) != 3:
        return 11

    let got0 = uirCoreFuncBlockAt(uirCoreModuleFuncAt(mod, 0), 0)
    let got1 = uirCoreFuncBlockAt(uirCoreModuleFuncAt(mod, 1), 0)
    let got2 = uirCoreFuncBlockAt(uirCoreModuleFuncAt(mod, 2), 0)

    let c0: int32 = checkBlock(got0, 2, 11, 12, 0)
    if c0 != 0:
        return 20 + c0
    let c1: int32 = checkBlock(got1, 3, 21, 22, 23)
    if c1 != 0:
        return 30 + c1
    let c2: int32 = checkBlock(got2, 1, 31, 0, 0)
    if c2 != 0:
        return 40 + c2

    return 0
