import std/rawbytes

type
    Box =
        data: ptr
        len: int32

fn setWhole(box: var Box, data: ptr, len: int32) =
    box = Box(data: data, len: len)

fn main(): int32 =
    var box: Box
    let bytes: rawbytes.Bytes = rawbytes.bytesFromString("ab")
    setWhole(box, bytes.data, bytes.len)
    if box.len != 2:
        return 1
    if box.data == nil:
        return 2
    return 0
