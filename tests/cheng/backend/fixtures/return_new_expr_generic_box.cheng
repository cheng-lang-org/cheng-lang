type
    Box[T] = ref
        value: T

fn main(): int32 =
    let a: Box[int32] = new(Box[int32])
    if a == nil:
        return 1
    a.value = 9

    let b: Box[int32] = new(Box[int32])
    if b == nil:
        return 2
    b.value = a.value + 1
    if b.value != 10:
        return 3
    return 0
