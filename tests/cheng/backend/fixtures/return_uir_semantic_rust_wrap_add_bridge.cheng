import std/result
import std/os
import std/strutils
import backend/uir/uir_semantic_lowering
import backend/uir/uir_semantic_types

fn main(): int32 =
    var semMod: UirSemanticModuleV1 = uirSemanticModuleV1New("rust", "arm64-apple-darwin")
    semMod.sourceTag = "rust_wrap_add"
    semMod.semanticTablesPath = "tests/cheng/backend/fixtures/rust_wrap_add.semantic.txt"
    var opts: UirSemanticCompileOptionsV1 = uirSemanticCompileOptionsV1Default()
    opts.outputPath = "chengcache/return_uir_semantic_rust_wrap_add_bridge.o"
    opts.allowRustLlvmFallback = false
    let compileRes: Result[UirSemanticCompileResultV1] = uirCompileSemanticModuleV1(semMod, opts)
    if !IsOk[UirSemanticCompileResultV1](compileRes):
        return 21
    let out: UirSemanticCompileResultV1 = compileRes.value
    if !out.ok:
        return 22
    if out.objectBytes.len <= 0:
        return 23
    if len(out.reportText) <= 0:
        return 24
    if !strutils.contains(out.reportText, "const_values=1"):
        return 26
    if !strutils.contains(out.reportText, "func_abi=2"):
        return 27
    if !strutils.contains(out.reportText, "call_abi=1"):
        return 28
    if !os.fileExists(opts.outputPath):
        return 25
    return 0
