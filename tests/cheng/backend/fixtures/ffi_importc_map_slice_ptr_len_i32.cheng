@importc("cheng_abi_sum_ptr_len_i32")
@ffi_map(ptr = arg0, len = arg1)
fn cheng_abi_sum_ptr_len_i32(xs: int32[]): int32

fn main(): int32 =
    let xs: int32[] = [10, 20, 12]
    if cheng_abi_sum_ptr_len_i32(xs) != 42:
        return 1
    let empty: int32[] = []
    if cheng_abi_sum_ptr_len_i32(empty) != 0:
        return 2
    return 0
