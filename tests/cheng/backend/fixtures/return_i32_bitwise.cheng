fn andFn(a: int32, b: int32): int32 =
    return a & b

fn orFn(a: int32, b: int32): int32 =
    return a | b

fn xorFn(a: int32, b: int32): int32 =
    return a ^ b

fn shlFn(a: int32, b: int32): int32 =
    return a << b

fn asrFn(a: int32, b: int32): int32 =
    return a >> b

fn main(): int32 =
    let v1: int32 = andFn(15, 7)
    let v2: int32 = orFn(1, 4)
    let v3: int32 = xorFn(7, 3)
    let v4: int32 = shlFn(1, 3)
    let v5: int32 = asrFn(16, 2)
    return v1 + v2 + v3 + v4 + v5 - 42
