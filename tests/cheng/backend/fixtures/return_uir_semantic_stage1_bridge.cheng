import std/result
import std/os
import backend/uir/uir_semantic_stage1
import backend/uir/uir_semantic_lowering
import backend/uir/uir_semantic_types

fn main(): int32 =
    let module: UirSemanticModuleV1 =
        uirSemanticModuleV1FromStage1File("tests/cheng/backend/fixtures/return_add.cheng", "arm64-apple-darwin")
    let options: UirSemanticCompileOptionsV1 = uirSemanticCompileOptionsV1Default()
    options.outputPath = "chengcache/return_uir_semantic_stage1_bridge.o"
    let compileRes: Result[UirSemanticCompileResultV1] = uirCompileSemanticModuleV1(module, options)
    if !IsOk[UirSemanticCompileResultV1](compileRes):
        return 11
    let out: UirSemanticCompileResultV1 = compileRes.value
    if !out.ok:
        return 12
    if out.objectBytes.len <= 0:
        return 13
    if len(out.reportText) <= 0:
        return 14
    if !os.fileExists(options.outputPath):
        return 15
    return 0
