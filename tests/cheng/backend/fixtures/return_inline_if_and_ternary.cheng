fn clampNonNeg(x: int32): int32 =
    if x < 0: return 0
    return x

fn ternaryRightAssoc(flag: bool): int32 =
    return flag ? 7 : false ? 9 : 0

fn main(): int32 =
    if clampNonNeg(-7) != 0: return 1
    if clampNonNeg(5) != 5: return 2
    if (1 < 2 ? 7 : 9) != 7: return 3
    if ternaryRightAssoc(false) != 0: return 4
    return 0
