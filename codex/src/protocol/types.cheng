type
    CodexTurn =
        promptText: str
        commandText: str
        outputText: str
        assistantText: str
        exitCode: int32 = -1
        approved: bool

    CodexSession =
        sessionId: str
        title: str
        cwd: str
        createdAt: int64
        updatedAt: int64
        lastExitCode: int32 = -1
        turns: CodexTurn[]

    CodexExecRequest =
        sessionId: str
        title: str
        cwd: str
        promptText: str
        commandText: str
        autoApprove: bool

    CodexExecResult =
        ok: bool
        exitCode: int32 = -1
        outputText: str
        assistantText: str

    CodexSessionSummary =
        sessionId: str
        title: str
        cwd: str
        updatedAt: int64
        lastExitCode: int32 = -1
        turnCount: int32

    CodexPluginSpec =
        name: str
        path: str
        enabled: bool

    CodexMcpServerSpec =
        name: str
        transportKind: str
        launchCommand: str
        cwd: str
        url: str
        bearerTokenEnvVar: str
        enabled: bool

    CodexTurnInput =
        threadId: str
        promptText: str
        commandText: str
        stdinText: str
        autoApprove: bool

    CodexTurnEvent =
        kind: str
        text: str
        toolCallId: str
        toolName: str
        toolInput: str
        toolOutput: str
        exitCode: int32 = -1
        elapsedMs: int64
        details: str

    CodexToolCall =
        callId: str
        name: str
        input: str
        output: str
        exitCode: int32 = -1
        durationMs: int64
        approved: bool

    CodexApprovalRequest =
        requestId: str
        toolName: str
        toolInput: str
        reason: str
        createdAt: int64

    CodexApprovalDecision =
        requestId: str
        approved: bool
        decidedAt: int64

    CodexSkillSpec =
        name: str
        kind: str
        path: str
        config: str
        enabled: bool

    CodexConfigSnapshot =
        home: str
        modelName: str
        autoApprove: bool
        maxTurns: int32 = 256
        shellCommand: str = "/bin/sh"
        sandboxEnabled: bool
        skillNames: str[]
        pluginNames: str[]
        mcpServerNames: str[]
