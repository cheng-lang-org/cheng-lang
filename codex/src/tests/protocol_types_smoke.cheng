import std/os
import std/result
import std/times
import std/strings
import std/strutils as strutil
import cheng/codex/protocol/types

fn codexTestPrint(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn main(): int32 =
    let now = times.EpochTimeSeconds()
    let cwd = os.GetCurrentDir()

    # ---- CodexSession ----
    var session: types.CodexSession
    session.sessionId = "proto-test-session"
    session.title = "Protocol Types Test"
    session.cwd = cwd
    session.createdAt = now
    session.updatedAt = now
    session.lastExitCode = -1

    assert(session.sessionId == "proto-test-session", "protocol: session id")
    assert(session.title == "Protocol Types Test", "protocol: session title")
    assert(session.cwd == cwd, "protocol: session cwd")
    assert(session.createdAt == now, "protocol: session created at")
    assert(session.updatedAt == now, "protocol: session updated at")
    assert(session.lastExitCode == -1, "protocol: session default last exit code")

    # ---- CodexTurn ----
    var turn: types.CodexTurn
    turn.promptText = "list files"
    turn.commandText = "ls -la"
    turn.outputText = "total 16"
    turn.assistantText = "command ok rc=0"
    turn.exitCode = 0
    turn.approved = true

    assert(turn.promptText == "list files", "protocol: turn prompt")
    assert(turn.commandText == "ls -la", "protocol: turn command")
    assert(turn.outputText == "total 16", "protocol: turn output")
    assert(turn.assistantText == "command ok rc=0", "protocol: turn assistant")
    assert(turn.exitCode == 0, "protocol: turn exit code")
    assert(turn.approved, "protocol: turn approved")
    assert(types.CodexTurn().exitCode == -1, "protocol: turn default exit code -1")

    # Append turn to session
    add(session.turns, turn)
    assert(session.turns.len == 1, "protocol: session turn count after append")
    assert(session.turns[0].commandText == "ls -la", "protocol: session turn[0] command")

    # Append second turn
    var turn2: types.CodexTurn
    turn2.promptText = "check disk"
    turn2.commandText = "df -h"
    turn2.outputText = "Filesystem  Size  Used Avail"
    turn2.assistantText = "command ok rc=0"
    turn2.exitCode = 0
    turn2.approved = true
    add(session.turns, turn2)
    assert(session.turns.len == 2, "protocol: session turn count 2")
    assert(session.turns[1].promptText == "check disk", "protocol: session turn[1] prompt")

    # ---- CodexExecRequest ----
    var req: types.CodexExecRequest
    req.sessionId = "exec-req-1"
    req.title = "Exec Request Test"
    req.cwd = "/tmp"
    req.promptText = "run echo"
    req.commandText = "echo hello"
    req.autoApprove = true

    assert(req.sessionId == "exec-req-1", "protocol: exec request session id")
    assert(req.title == "Exec Request Test", "protocol: exec request title")
    assert(req.cwd == "/tmp", "protocol: exec request cwd")
    assert(req.promptText == "run echo", "protocol: exec request prompt")
    assert(req.commandText == "echo hello", "protocol: exec request command")
    assert(req.autoApprove, "protocol: exec request auto approve")

    # ---- CodexExecResult ----
    var result: types.CodexExecResult
    result.ok = true
    result.exitCode = 0
    result.outputText = "hello"
    result.assistantText = "command ok rc=0"

    assert(result.ok, "protocol: exec result ok")
    assert(result.exitCode == 0, "protocol: exec result exit code")
    assert(result.outputText == "hello", "protocol: exec result output")
    assert(result.assistantText == "command ok rc=0", "protocol: exec result assistant")
    assert(types.CodexExecResult().exitCode == -1, "protocol: exec result default exit code -1")

    # ---- CodexSessionSummary ----
    var summary: types.CodexSessionSummary
    summary.sessionId = "summary-1"
    summary.title = "Summary Test"
    summary.cwd = "/tmp"
    summary.updatedAt = now
    summary.lastExitCode = 0
    summary.turnCount = 5

    assert(summary.sessionId == "summary-1", "protocol: summary id")
    assert(summary.title == "Summary Test", "protocol: summary title")
    assert(summary.cwd == "/tmp", "protocol: summary cwd")
    assert(summary.updatedAt == now, "protocol: summary updated at")
    assert(summary.lastExitCode == 0, "protocol: summary last exit code")
    assert(summary.turnCount == 5, "protocol: summary turn count")
    assert(types.CodexSessionSummary().lastExitCode == -1, "protocol: summary default exit code -1")

    # ---- CodexPluginSpec ----
    var plugin: types.CodexPluginSpec
    plugin.name = "test-plugin"
    plugin.path = "/opt/test-plugin"
    plugin.enabled = true

    assert(plugin.name == "test-plugin", "protocol: plugin name")
    assert(plugin.path == "/opt/test-plugin", "protocol: plugin path")
    assert(plugin.enabled, "protocol: plugin enabled")

    # Default disabled
    var pluginDefault: types.CodexPluginSpec
    pluginDefault.name = "disabled-plugin"
    assert(!pluginDefault.enabled, "protocol: plugin default disabled")

    # ---- CodexMcpServerSpec ----
    var mcp: types.CodexMcpServerSpec
    mcp.name = "test-mcp"
    mcp.transportKind = "stdio"
    mcp.launchCommand = "echo test"
    mcp.cwd = "/tmp"
    mcp.url = "http://localhost:8080"
    mcp.bearerTokenEnvVar = "TOKEN"
    mcp.enabled = true

    assert(mcp.name == "test-mcp", "protocol: mcp name")
    assert(mcp.transportKind == "stdio", "protocol: mcp transport kind")
    assert(mcp.launchCommand == "echo test", "protocol: mcp launch command")
    assert(mcp.cwd == "/tmp", "protocol: mcp cwd")
    assert(mcp.url == "http://localhost:8080", "protocol: mcp url")
    assert(mcp.bearerTokenEnvVar == "TOKEN", "protocol: mcp bearer token env var")
    assert(mcp.enabled, "protocol: mcp enabled")

    # Default disabled
    var mcpDefault: types.CodexMcpServerSpec
    mcpDefault.name = "mcp-default"
    assert(!mcpDefault.enabled, "protocol: mcp default disabled")

    codexTestPrint("protocol_types_smoke ok")
    return 0
