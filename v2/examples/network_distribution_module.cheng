// Formal network-distribution module for source manifest and rule-pack publication.
topology SourceSync = lsmr_tree(domain=source_manifest, fanout=luoshu9, repair=passive_anti_entropy, dispersal=none, priority=urgent, addressing=lsmr_path, depth=4)
topology RuleSync = lsmr_tree(domain=rule_pack, fanout=luoshu9, repair=passive_anti_entropy, dispersal=ida(k=5,n=9), priority=bulk, addressing=lsmr_path, depth=4)
topology CompilerSync = lsmr_tree(domain=compiler_rule_pack, fanout=luoshu9, repair=passive_anti_entropy, dispersal=none, priority=background, addressing=lsmr_path, depth=4)
publish_source_manifest(topology=SourceSync, package=pkg://cheng/v2)
publish_rule_pack(topology=RuleSync, pack=optimizer_rules)
publish_compiler_rule_pack(topology=CompilerSync, pack=compiler_rules)
route_lsmr_tree(topology=RuleSync)
disperse_ida_fragments(topology=RuleSync)
exchange_anti_entropy_signature(topology=CompilerSync, signature=ganzhi_merkle_v1)
repair_from_signature_gap(topology=CompilerSync, signature=ganzhi_merkle_v1)
