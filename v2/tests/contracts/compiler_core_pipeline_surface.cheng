fn hasManifestPath(bundle: mresolve.SourceManifestBundle, path: str): bool =
    for i in 0..<bundle.filePaths.len:
        if bundle.filePaths[i] == path:
            return true
    return false

fn hasCompileKeyLine(bundle: rart.ReleaseArtifactBundle, line: str): bool =
    return rart.releaseArtifactCompileKeyHasLine(bundle, line)

fn hasExecOpKind(plan: clow.LowUirCompilerCorePlan, startIdx: int32, endIdx: int32, kind: str): bool =
    for i in startIdx..<endIdx:
        if plan.opKinds[i] == kind:
            return true
    return false

fn findLabelIndex(labels: str[], label: str): int32 =
    for i in 0..<labels.len:
        if labels[i] == label:
            return i
    return -1

fn parseCompilerCoreProgramTextStrict(sourcePath: str, text: str): ccore.CompilerCoreProgram =
    var parsed: parser.ParsedV2Source
    if !parser.tryParseV2SourceText(sourcePath, text, parsed):
        panic("v2 compiler core pipeline surface: failed to parse " + sourcePath)
    return parsed.compilerCoreProgram

fn buildCompilerCoreReferenceFixture(): cpipe.CompilerCorePipelineBundle =
    let depText =
        "module dep\n" +
        "const buildVersion = \"dep\"\n" +
        "type\n" +
        "    ErrorCode = enum\n" +
        "        Ok = 0\n" +
        "        Fail = 1\n" +
        "fn helper(text: str): str =\n" +
        "    return text\n"
    let mainText =
        "module main\n" +
        "import fixture/dep as dep\n" +
        "const localVersion = \"main\"\n" +
        "type\n" +
        "    Pair = object\n" +
        "        left: str\n" +
        "fn readGlobal(): str =\n" +
        "    return localVersion\n" +
        "fn readField(pair: Pair): str =\n" +
        "    return pair.left\n" +
        "fn useRefs(argc: int32, values: str[]): str =\n" +
        "    let local = argc\n" +
        "    dep.helper(values[0])\n" +
        "    local = local\n" +
        "    if dep.Ok == 0:\n" +
        "        pair.left\n" +
        "    return dep.buildVersion\n"
    var merged = ccore.newCompilerCoreProgram()
    ccore.appendCompilerCoreProgram(merged,
                                    parseCompilerCoreProgramTextStrict("src/fixture/dep.cheng", depText))
    ccore.appendCompilerCoreProgram(merged,
                                    parseCompilerCoreProgramTextStrict("src/fixture/main.cheng", mainText))
    return cpipe.compileCompilerCoreProgram(merged)

fn buildCompilerCoreRecordFixture(): cpipe.CompilerCorePipelineBundle =
    let text =
        "module record\n" +
        "type\n" +
        "    Pair = object\n" +
        "        left: str\n" +
        "        right: int32\n" +
        "fn makePair(text: str): Pair =\n" +
        "    return Pair(left: text, right: 7)\n" +
        "fn clearPair(): Pair =\n" +
        "    var out: Pair\n" +
        "    out.left = \"x\"\n" +
        "    return out\n" +
        "fn readLeft(pair: Pair): str =\n" +
        "    return pair.left\n"
    return cpipe.compileCompilerCoreProgram(parseCompilerCoreProgramTextStrict("src/fixture/record.cheng", text))

fn buildCompilerCoreGenericRecordFixture(): cpipe.CompilerCorePipelineBundle =
    let text =
        "module generic_record\n" +
        "type\n" +
        "    Maybe[T] = object\n" +
        "        has: bool\n" +
        "        value: T\n" +
        "fn makeMaybe(value: int32): Maybe[int32] =\n" +
        "    return Maybe[int32](has: true, value: value)\n"
    return cpipe.compileCompilerCoreProgram(parseCompilerCoreProgramTextStrict("src/fixture/generic_record.cheng", text))

fn findExprReferenceIndex(graph: cgraph.HighUirCompilerCoreGraph,
                          exprKind: str,
                          primaryText: str,
                          referenceKind: str): int32 =
    for i in 0..<graph.exprKinds.len:
        if graph.exprKinds[i] == exprKind &&
           graph.exprPrimaryTexts[i] == primaryText &&
           graph.exprReferenceKinds[i] == referenceKind:
            return i
    return -1

fn graphTypeConstructorText(graph: cgraph.HighUirCompilerCoreGraph, exprId: int32): str =
    if exprId < 0:
        return ""
    if graph.exprKinds[exprId] == "name_ref" &&
       graph.exprReferenceKinds[exprId] == "name" &&
       (graph.exprReferenceTargetKinds[exprId] == "type" ||
        graph.exprReferenceTargetKinds[exprId] == "type_param"):
        return graph.exprPrimaryTexts[exprId]
    if graph.exprKinds[exprId] == "index" && graph.exprChildCounts[exprId] == 2:
        let baseExprId = graph.exprChildIds[graph.exprChildStarts[exprId]]
        let argExprId = graph.exprChildIds[graph.exprChildStarts[exprId] + 1]
        let baseText = graphTypeConstructorText(graph, baseExprId)
        let argText = graphTypeConstructorText(graph, argExprId)
        if len(baseText) <= 0 || len(argText) <= 0:
            return ""
        return baseText + "[" + argText + "]"
    return ""

fn findTypeConstructorCallExpr(graph: cgraph.HighUirCompilerCoreGraph, typeName: str): int32 =
    for i in 0..<graph.exprKinds.len:
        if graph.exprKinds[i] != "call" || graph.exprChildCounts[i] <= 0:
            continue
        let calleeExprId = graph.exprChildIds[graph.exprChildStarts[i]]
        if graphTypeConstructorText(graph, calleeExprId) == typeName:
            return i
    return -1

fn directIdentityI32(x: int32): int32 =
    return x

fn directNegI32(x: int32): int32 =
    return -x

fn directAddI32(x: int32, y: int32): int32 =
    return x + y

fn directEqI32(x: int32, y: int32): bool =
    return x == y

fn directLocalAliasI32(x: int32): int32 =
    let alias = x
    return alias

fn directIfElseEqI32(x: int32, y: int32): int32 =
    if x == y:
        return 1
    else:
        return 0

fn directCall2I32(x: int32, y: int32): int32 =
    return directAddI32(x, y)

fn directAliasCall2I32(x: int32, y: int32): int32 =
    let left = x
    return directAddI32(left, y)

fn directPickSecond3(a: int32, b: int32, c: int32): int32 =
    return b

fn directCall3Mixed(y: int32): int32 =
    return directPickSecond3(7, y, 9)

fn directAliasCall3Mixed(y: int32): int32 =
    let alias = y
    return directPickSecond3(7, alias, 9)

fn directPickFourth4(a: int32, b: int32, c: int32, d: int32): int32 =
    return d

fn directCall4Mixed(y: int32): int32 =
    return directPickFourth4(7, 8, y, 10)

@importc("abs")
fn directExternAbs(x: int32): int32

fn directExternAbsWrap(x: int32): int32 =
    return directExternAbs(x)

fn directVoid3(a: int32, b: int32, c: int32): void =
    return

fn directCall3VoidMixed(y: int32): void =
    directVoid3(7, y, 9)

fn directVoid4(a: int32, b: int32, c: int32, d: int32): void =
    return

fn directAliasCall4VoidMixed(y: int32): void =
    let alias = y
    directVoid4(7, 8, alias, 10)

fn directVoid2(a: int32, b: int32): void =
    return

fn directNestedVoidSecondArg(y: int32): void =
    directVoid2(directIdentityI32(7), y)

fn directZeroBytesLocal(): Bytes =
    var out: Bytes
    out.data = nil
    out.len = 0
    return out

fn directBufferToBytes(buf: buffer.ByteBuffer): Bytes =
    return buf.data

fn directReturnBytesParam(value: Bytes): Bytes =
    return value

fn directReturnStrSeqParam(values: str[]): str[] =
    return values

fn directBufferLenViaField(buf: buffer.ByteBuffer): int32 =
    return bytesLen(buf.data)

fn directWrapZeroBytesAsBuffer(): buffer.ByteBuffer =
    var out: buffer.ByteBuffer
    out.data = directZeroBytesLocal()
    return out

fn directIsEmptyViaCall(buf: buffer.ByteBuffer): bool =
    return directBufferLenViaField(buf) <= 0

fn directReaderFromBytes(buf: bytes.ByteBuffer): bytes.ByteReader =
    var out: bytes.ByteReader
    out.buf = buf
    out.pos = 0
    return out

fn directCanReadLike(r: bytes.ByteReader, count: int32): bool =
    return r.pos + count <= r.buf.len

fn directVersionText(): str =
    return "v2.direct.version"

fn directLiteralStrArgSink(text: str): int32 =
    return 0

fn directCallLiteralStr(): int32 =
    return directLiteralStrArgSink("v2.literal.arg")

fn directLiteralStrVoidSink(text: str): void =
    return

fn directCallLiteralStrVoid(): void =
    directLiteralStrVoidSink("v2.literal.arg")

fn directElemSizeInt32(): int32 =
    return int32(sizeof(int32))

fn directElemSizeInt64(): int32 =
    return int32(sizeof(int64))

fn directElemSizeUint8(): int32 =
    return int32(sizeof(uint8))

@importc("cheng_file_exists")
fn directProbeFileExistsRaw(path: cstring): int32

fn directNestedReadFileText(path: str): str =
    return bytes.bytesReadFileAll(system.strToCStringTemp(path))

fn directNestedFileExists(path: str): bool =
    return directProbeFileExistsRaw(system.strToCStringTemp(path)) != 0

fn directGetCurrentDirWrap(): str =
    return system.getCurrentDir()

fn directBytesReadFileAllWrap(path: cstring): str =
    return bytes.bytesReadFileAll(path)

fn directCmdlineHasArgs(): bool =
    return cmdline.paramCount() > 0

fn directCurrentCompilerPathLike(): str =
    return os.absolutePath(cmdline.programName())

fn directWriteTextLike(text: str): void =
    os.write(os.get_stdout(), text)

fn main(): int32 =
    let target = mtarget.machineTargetContract().firstClassTargets[0]
    let sourcePath = "v2/src/tooling/cheng_v2.cheng"
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    let bundle = cpipe.compileCompilerCoreSourceClosure(sourcePath)
    let manifest = mresolve.resolveCompilerCoreSourceManifest(sourcePath)
    let machine = mpipeline.lowerCompilerCorePlanToMachine(bundle.lowPlan, target)
    let image = oimg.writeObjImage(machine)
    let objFile = ofile.buildObjFile(machine)
    let artifact = rart.buildReleaseArtifact(sourcePath, "exe", target)
    let refFixture = buildCompilerCoreReferenceFixture()
    let recordFixture = buildCompilerCoreRecordFixture()
    let genericRecordFixture = buildCompilerCoreGenericRecordFixture()
    assert(bundle.version == "v2.driver.compiler_core_pipeline.v1", "v2 compiler core pipeline version")
    assert(parsed.compilerCoreProgram.topLevelKinds.len > 0, "v2 compiler core entry parse count")
    assert(bundle.program.modules.len <= 1, "v2 compiler core module count bounded")
    assert(bundle.program.imports.len > 0, "v2 compiler core import count")
    assert(bundle.program.routines.len > 0, "v2 compiler core routine count")
    assert(bundle.program.routineParams.len > 0, "v2 compiler core routine param count")
    assert(bundle.program.stmts.len > 0, "v2 compiler core stmt count")
    assert(bundle.program.exprs.len > 0, "v2 compiler core expr count")
    assert(bundle.lowPlan.itemIds.len > 0, "v2 compiler core low_uir item count")
    assert(bundle.lowPlan.canonicalOps[0] == "compiler_import_bind", "v2 compiler core first canonical op")
    assert(bundle.lowPlan.importCategories[0] == "stdlib", "v2 compiler core first import category")
    assert(bundle.lowPlan.labels[0] == "std/cmdline", "v2 compiler core first label")
    assert(bundle.lowPlan.labels[bundle.lowPlan.labels.len - 1] == "main", "v2 compiler core last label")
    assert(bundle.lowPlan.executableAstReady[bundle.lowPlan.labels.len - 1], "v2 compiler core main ast ready")
    assert(bundle.lowPlan.canonicalOps[bundle.lowPlan.labels.len - 1] == "compiler_fn_exec", "v2 compiler core main executable op")
    assert(bundle.lowPlan.returnTypeTexts[bundle.lowPlan.labels.len - 1] == "int32", "v2 compiler core main return type")
    assert(bundle.lowPlan.paramCounts[bundle.lowPlan.labels.len - 1] == 1, "v2 compiler core main param count")
    assert(bundle.facts.stmtKindSets[bundle.facts.itemIds.len - 1] != "", "v2 compiler core main stmt kind set")
    assert(bundle.facts.exprKindSets[bundle.facts.itemIds.len - 1] != "", "v2 compiler core main expr kind set")
    assert(bundle.facts.stmtSemanticSets[bundle.facts.itemIds.len - 1] != "", "v2 compiler core main stmt semantic set")
    assert(bundle.facts.exprSemanticSets[bundle.facts.itemIds.len - 1] != "", "v2 compiler core main expr semantic set")
    assert(bundle.highGraph.paramNames.len == bundle.program.routineParams.len, "v2 compiler core high_uir param soa count")
    assert(bundle.highGraph.localNames.len == bundle.program.locals.len, "v2 compiler core high_uir local soa count")
    assert(bundle.highGraph.stmtKinds.len == bundle.program.stmts.len, "v2 compiler core high_uir stmt soa count")
    assert(bundle.highGraph.exprKinds.len == bundle.program.exprs.len, "v2 compiler core high_uir expr soa count")
    assert(bundle.highGraph.stmtDetailTexts.len == bundle.program.stmts.len, "v2 compiler core high_uir stmt detail count")
    assert(bundle.highGraph.exprDetailTexts.len == bundle.program.exprs.len, "v2 compiler core high_uir expr detail count")
    assert(bundle.highGraph.exprReferenceKinds.len == bundle.program.exprs.len, "v2 compiler core high_uir expr reference count")
    assert(bundle.highGraph.exprChildArgNames.len == bundle.program.exprChildIds.len, "v2 compiler core high_uir expr child arg name count")
    assert(bundle.lowPlan.stmtKindSets[bundle.lowPlan.labels.len - 1] != "", "v2 compiler core main low_uir stmt kind set")
    assert(bundle.lowPlan.exprKindSets[bundle.lowPlan.labels.len - 1] != "", "v2 compiler core main low_uir expr kind set")
    assert(bundle.lowPlan.stmtSemanticSets[bundle.lowPlan.labels.len - 1] != "", "v2 compiler core main low_uir stmt semantic set")
    assert(bundle.lowPlan.exprSemanticSets[bundle.lowPlan.labels.len - 1] != "", "v2 compiler core main low_uir expr semantic set")
    assert(bundle.lowPlan.exprReferenceKinds.len == bundle.program.exprs.len, "v2 compiler core main low_uir expr reference count")
    assert(bundle.lowPlan.routineOpCounts[bundle.lowPlan.labels.len - 1] > 0, "v2 compiler core main exec op count")
    assert(bundle.lowPlan.routineOpHashes[bundle.lowPlan.labels.len - 1] != "", "v2 compiler core main exec op hash")
    let mainOpStart = bundle.lowPlan.routineOpStarts[bundle.lowPlan.labels.len - 1]
    let mainOpEnd = mainOpStart + bundle.lowPlan.routineOpCounts[bundle.lowPlan.labels.len - 1]
    assert(hasExecOpKind(bundle.lowPlan, mainOpStart, mainOpEnd, "call"), "v2 compiler core main has call op")
    assert(hasExecOpKind(bundle.lowPlan, mainOpStart, mainOpEnd, "jump_if_false"), "v2 compiler core main has conditional branch op")
    assert(cfacts.compilerCoreExecutableAstItemCount(bundle.facts) >= 3, "v2 compiler core executable ast routine count")
    assert(cfacts.compilerCoreExecutableParamCount(bundle.facts) >= 1, "v2 compiler core executable param count")
    assert(cfacts.compilerCoreExecutableStmtCount(bundle.facts) >= 14, "v2 compiler core executable stmt count")
    assert(cfacts.compilerCoreExecutableExprCount(bundle.facts) >= 26, "v2 compiler core executable expr count")
    assert(refFixture.facts.exprReferenceKinds.len == refFixture.program.exprs.len, "v2 compiler core fixture facts expr reference count")
    assert(refFixture.highGraph.exprReferenceKinds.len == refFixture.program.exprs.len, "v2 compiler core fixture high expr reference count")
    assert(refFixture.lowPlan.exprReferenceKinds.len == refFixture.program.exprs.len, "v2 compiler core fixture low expr reference count")
    assert(recordFixture.highGraph.exprChildArgNames.len == recordFixture.program.exprChildIds.len, "v2 compiler core record fixture high arg name count")
    let paramExprIdx = findExprReferenceIndex(refFixture.highGraph, "name_ref", "argc", "param")
    assert(paramExprIdx >= 0, "v2 compiler core fixture param reference")
    assert(refFixture.lowPlan.exprReferenceKinds[paramExprIdx] == "param", "v2 compiler core fixture low param reference")
    let localExprIdx = findExprReferenceIndex(refFixture.highGraph, "name_ref", "local", "local")
    assert(localExprIdx >= 0, "v2 compiler core fixture local reference")
    let globalExprIdx = findExprReferenceIndex(refFixture.highGraph, "name_ref", "localVersion", "global")
    assert(globalExprIdx >= 0, "v2 compiler core fixture global reference")
    let importExprIdx = findExprReferenceIndex(refFixture.highGraph, "name_ref", "dep", "import_visible")
    assert(importExprIdx >= 0, "v2 compiler core fixture import visible reference")
    let importRoutineExprIdx = findExprReferenceIndex(refFixture.highGraph, "field", "helper", "import_field_routine")
    assert(importRoutineExprIdx >= 0, "v2 compiler core fixture import field routine reference")
    assert(refFixture.lowPlan.exprReferenceTexts[importRoutineExprIdx] == "dep.helper", "v2 compiler core fixture low import field routine text")
    let importGlobalExprIdx = findExprReferenceIndex(refFixture.highGraph, "field", "buildVersion", "import_field_global")
    assert(importGlobalExprIdx >= 0, "v2 compiler core fixture import field global reference")
    let importEnumExprIdx = findExprReferenceIndex(refFixture.highGraph, "field", "Ok", "import_field_enum")
    assert(importEnumExprIdx >= 0, "v2 compiler core fixture import field enum reference")
    let fieldAccessExprIdx = findExprReferenceIndex(refFixture.highGraph, "field", "left", "field_access")
    assert(fieldAccessExprIdx >= 0, "v2 compiler core fixture field access reference")
    let indexExprIdx = findExprReferenceIndex(refFixture.highGraph, "index", "", "index_access")
    assert(indexExprIdx >= 0, "v2 compiler core fixture index reference")
    let callExprIdx = findExprReferenceIndex(refFixture.highGraph, "call", "", "call")
    assert(callExprIdx >= 0, "v2 compiler core fixture call reference")
    let useRefsIdx = findLabelIndex(refFixture.lowPlan.labels, "useRefs")
    assert(useRefsIdx >= 0, "v2 compiler core fixture useRefs index")
    assert(parser.findText(refFixture.lowPlan.exprSemanticSets[useRefsIdx], "field:import_field_routine") >= 0, "v2 compiler core fixture expr semantic import routine")
    assert(parser.findText(refFixture.lowPlan.exprSemanticSets[useRefsIdx], "field:import_field_enum") >= 0, "v2 compiler core fixture expr semantic import enum")
    assert(parser.findText(refFixture.lowPlan.exprSemanticSets[useRefsIdx], "index:index_access") >= 0, "v2 compiler core fixture expr semantic index")
    let recordCtorExprIdx = findTypeConstructorCallExpr(recordFixture.highGraph, "Pair")
    assert(recordCtorExprIdx >= 0, "v2 compiler core record fixture type constructor expr")
    assert(recordFixture.highGraph.exprChildArgNames[recordFixture.highGraph.exprChildStarts[recordCtorExprIdx] + 1] == "left", "v2 compiler core record fixture first arg name")
    assert(recordFixture.highGraph.exprChildArgNames[recordFixture.highGraph.exprChildStarts[recordCtorExprIdx] + 2] == "right", "v2 compiler core record fixture second arg name")
    let makePairIdx = findLabelIndex(recordFixture.lowPlan.labels, "makePair")
    assert(makePairIdx >= 0, "v2 compiler core record fixture makePair index")
    let makePairOpStart = recordFixture.lowPlan.routineOpStarts[makePairIdx]
    let makePairOpEnd = makePairOpStart + recordFixture.lowPlan.routineOpCounts[makePairIdx]
    assert(hasExecOpKind(recordFixture.lowPlan, makePairOpStart, makePairOpEnd, "make_record"), "v2 compiler core record fixture make_record op")
    let clearPairIdx = findLabelIndex(recordFixture.lowPlan.labels, "clearPair")
    assert(clearPairIdx >= 0, "v2 compiler core record fixture clearPair index")
    let clearPairOpStart = recordFixture.lowPlan.routineOpStarts[clearPairIdx]
    let clearPairOpEnd = clearPairOpStart + recordFixture.lowPlan.routineOpCounts[clearPairIdx]
    assert(hasExecOpKind(recordFixture.lowPlan, clearPairOpStart, clearPairOpEnd, "store_local_field"), "v2 compiler core record fixture store_local_field op")
    let readLeftIdx = findLabelIndex(recordFixture.lowPlan.labels, "readLeft")
    assert(readLeftIdx >= 0, "v2 compiler core record fixture readLeft index")
    let readLeftOpStart = recordFixture.lowPlan.routineOpStarts[readLeftIdx]
    let readLeftOpEnd = readLeftOpStart + recordFixture.lowPlan.routineOpCounts[readLeftIdx]
    assert(hasExecOpKind(recordFixture.lowPlan, readLeftOpStart, readLeftOpEnd, "load_field"), "v2 compiler core record fixture load_field op")
    let genericCtorExprIdx = findTypeConstructorCallExpr(genericRecordFixture.highGraph, "Maybe[int32]")
    assert(genericCtorExprIdx >= 0, "v2 compiler core generic record fixture type constructor expr")
    let genericTypeParamExprIdx = findExprReferenceIndex(genericRecordFixture.highGraph, "name_ref", "T", "name")
    assert(genericTypeParamExprIdx >= 0, "v2 compiler core generic record fixture type param expr")
    assert(genericRecordFixture.highGraph.exprReferenceTargetKinds[genericTypeParamExprIdx] == "type_param", "v2 compiler core generic record fixture type param target kind")
    let makeMaybeIdx = findLabelIndex(genericRecordFixture.lowPlan.labels, "makeMaybe")
    assert(makeMaybeIdx >= 0, "v2 compiler core generic record fixture makeMaybe index")
    let makeMaybeOpStart = genericRecordFixture.lowPlan.routineOpStarts[makeMaybeIdx]
    let makeMaybeOpEnd = makeMaybeOpStart + genericRecordFixture.lowPlan.routineOpCounts[makeMaybeIdx]
    assert(hasExecOpKind(genericRecordFixture.lowPlan, makeMaybeOpStart, makeMaybeOpEnd, "make_record"), "v2 compiler core generic record fixture make_record op")
    assert(manifest.packageId == "pkg://cheng/v2", "v2 compiler core manifest package id")
    assert(manifest.filePaths.len > 0, "v2 compiler core manifest file count")
    assert(hasManifestPath(manifest, "v2/cheng-package.toml"), "v2 compiler core manifest package root")
    assert(hasManifestPath(manifest, "v2/src/tooling/cheng_v2.cheng"), "v2 compiler core manifest entry")
    assert(hasManifestPath(manifest, "v2/src/tooling/cheng_tooling_v2.cheng"), "v2 compiler core manifest tooling entry")
    assert(hasManifestPath(manifest, "v2/src/compiler/driver/runtime_provider_object_v2.cheng"), "v2 compiler core manifest runtime provider object")
    assert(hasManifestPath(manifest, "v2/src/compiler/driver/system_link_plan_v2.cheng"), "v2 compiler core manifest system link plan")
    assert(hasManifestPath(manifest, "v2/src/runtime/core_runtime_v2.cheng"), "v2 compiler core manifest core runtime provider")
    assert(hasManifestPath(manifest, "v2/src/runtime/compiler_core_runtime_v2.cheng"), "v2 compiler core manifest compiler runtime provider")
    assert(hasManifestPath(manifest, "src/std/cmdline.cheng"), "v2 compiler core manifest std cmdline")
    assert(hasManifestPath(manifest, "src/std/os.cheng"), "v2 compiler core manifest std os")
    assert(hasManifestPath(manifest, "src/std/system.cheng"), "v2 compiler core manifest std system")
    assert(machine.moduleKind == "compiler_core", "v2 compiler core machine module kind")
    assert(machine.itemIds.len > 0, "v2 compiler core machine item count")
    assert(machine.callSymbolNames[0] != "", "v2 compiler core first runtime target")
    let printUsageMachineIdx = findLabelIndex(bundle.lowPlan.labels, "printUsage")
    assert(printUsageMachineIdx >= 0, "v2 compiler core machine printUsage index")
    assert(machine.metadataOperandModes[printUsageMachineIdx] == "exec_plan_payload", "v2 compiler core machine executable payload mode")
    assert(parser.findText(machine.localPayloadTexts[printUsageMachineIdx], "exec_op_count=") >= 0, "v2 compiler core machine executable payload count")
    assert(parser.findText(machine.localPayloadTexts[printUsageMachineIdx], "exec_op_hash=") >= 0, "v2 compiler core machine executable payload hash")
    assert(parser.findText(machine.localPayloadTexts[printUsageMachineIdx], "op.0=") >= 0, "v2 compiler core machine executable payload first op")
    let stackAlignMachineIdx = findLabelIndex(bundle.lowPlan.labels, "machineTargetStackAlignBytes")
    assert(stackAlignMachineIdx >= 0, "v2 compiler core machine stack align helper index")
    assert(machine.metadataOperandModes[stackAlignMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct exec payload mode")
    assert(machine.callSymbolNames[stackAlignMachineIdx] == "", "v2 compiler core machine direct exec call symbol cleared")
    assert(machine.instructionWordHex[stackAlignMachineIdx] == "a9bf7bfd;910003fd;52800200;a8c17bfd;d65f03c0", "v2 compiler core machine direct exec words")
    let identityMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directIdentityI32")
    assert(identityMachineIdx >= 0, "v2 compiler core machine direct identity index")
    assert(machine.metadataOperandModes[identityMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct identity payload mode")
    assert(machine.callSymbolNames[identityMachineIdx] == "", "v2 compiler core machine direct identity call symbol cleared")
    assert(machine.instructionWordHex[identityMachineIdx] == "a9bf7bfd;910003fd;a8c17bfd;d65f03c0", "v2 compiler core machine direct identity words")
    let negMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directNegI32")
    assert(negMachineIdx >= 0, "v2 compiler core machine direct neg index")
