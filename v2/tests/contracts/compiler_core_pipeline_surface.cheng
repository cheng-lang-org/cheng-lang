    assert(hasCompileKeyLine(artifact, "system_link.provider.1.module=runtime/core_runtime_v2"), "v2 compiler core compile key core provider")
    assert(hasCompileKeyLine(artifact, "system_link.missing_reason.0=program_entry_exec_plan_missing"), "v2 compiler core compile key entry exec blocker")
    assert(hasCompileKeyLine(artifact, "system_link.missing_reason.1=program_local_payload_exec_plan_missing"), "v2 compiler core compile key local payload exec blocker")
    assert(hasCompileKeyLine(artifact, "native_link.provider.0=runtime/compiler_core_runtime_v2"), "v2 compiler core compile key compiler runtime provider")
    assert(hasCompileKeyLine(artifact, "native_link_runtime_target_count=" + intToStr(artifact.runtimeTargetCount)), "v2 compiler core compile key runtime target count")
    assert(hasCompileKeyLine(artifact, "compiler_core.item." + intToStr(bundle.lowPlan.labels.len - 1) + ".op=compiler_fn_exec"), "v2 compiler core compile key executable op")
    assert(hasCompileKeyLine(artifact, "compiler_core.item." + intToStr(bundle.lowPlan.labels.len - 1) + ".ast_ready=1"), "v2 compiler core compile key executable ast ready")
    assert(hasCompileKeyLine(artifact, "compiler_core.item." + intToStr(bundle.lowPlan.labels.len - 1) + ".exec_op_count=" + intToStr(bundle.lowPlan.routineOpCounts[bundle.lowPlan.labels.len - 1])), "v2 compiler core compile key executable op count")
    assert(hasCompileKeyLine(artifact, "compiler_core.item." + intToStr(bundle.lowPlan.labels.len - 1) + ".exec_op_hash=" + bundle.lowPlan.routineOpHashes[bundle.lowPlan.labels.len - 1]), "v2 compiler core compile key executable op hash")
    return 0
