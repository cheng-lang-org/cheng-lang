import std/system
import std/cmdline as cmdline
import std/os as os
import std/rawbytes
import std/bytes as bytes
import std/buffer as buffer
import compiler/frontend/v2_source_parser as parser
import compiler/driver/compiler_core_pipeline_v2 as cpipe
import compiler/driver/manifest_resolver_v2 as mresolve
import compiler/semantic_facts/compiler_core_facts_v2 as cfacts
import compiler/low_uir/compiler_core_lowering_v2 as clow
import compiler/machine/machine_pipeline_v2 as mpipeline
import compiler/machine/target_contract as mtarget
import compiler/obj/obj_image_v2 as oimg
import compiler/obj/obj_file_v2 as ofile
import compiler/driver/release_artifact_v2 as rart

fn hasManifestPath(bundle: mresolve.SourceManifestBundle, path: str): bool =
    for i in 0..<bundle.filePaths.len:
        if bundle.filePaths[i] == path:
            return true
    return false

fn hasCompileKeyLine(bundle: rart.ReleaseArtifactBundle, line: str): bool =
    return rart.releaseArtifactCompileKeyHasLine(bundle, line)

fn hasExecOpKind(plan: clow.LowUirCompilerCorePlan, startIdx: int32, endIdx: int32, kind: str): bool =
    for i in startIdx..<endIdx:
        if plan.opKinds[i] == kind:
            return true
    return false

fn findLabelIndex(labels: str[], label: str): int32 =
    for i in 0..<labels.len:
        if labels[i] == label:
            return i
    return -1

fn directIdentityI32(x: int32): int32 =
    return x

fn directNegI32(x: int32): int32 =
    return -x

fn directAddI32(x: int32, y: int32): int32 =
    return x + y

fn directEqI32(x: int32, y: int32): bool =
    return x == y

fn directLocalAliasI32(x: int32): int32 =
    let alias = x
    return alias

fn directIfElseEqI32(x: int32, y: int32): int32 =
    if x == y:
        return 1
    else:
        return 0

fn directCall2I32(x: int32, y: int32): int32 =
    return directAddI32(x, y)

fn directAliasCall2I32(x: int32, y: int32): int32 =
    let left = x
    return directAddI32(left, y)

fn directPickSecond3(a: int32, b: int32, c: int32): int32 =
    return b

fn directCall3Mixed(y: int32): int32 =
    return directPickSecond3(7, y, 9)

fn directAliasCall3Mixed(y: int32): int32 =
    let alias = y
    return directPickSecond3(7, alias, 9)

fn directPickFourth4(a: int32, b: int32, c: int32, d: int32): int32 =
    return d

fn directCall4Mixed(y: int32): int32 =
    return directPickFourth4(7, 8, y, 10)

@importc("abs")
fn directExternAbs(x: int32): int32

fn directExternAbsWrap(x: int32): int32 =
    return directExternAbs(x)

@importc("cheng_fread")
fn directExternFread4(ptrArg: ptr, size: int64, count: int64, stream: ptr): int32

fn directExternFread4Wrap(ptrArg: ptr, size: int64, count: int64, stream: ptr): int32 =
    return directExternFread4(ptrArg, size, count, stream)

@importc("free")
fn directExternFree(p: ptr): void

fn directExternFreeWrap(p: ptr): void =
    directExternFree(p)

fn directAliasVoidCallPtr(p: ptr): void =
    let q = p
    directExternFree(q)

fn directVoid3(a: int32, b: int32, c: int32): void =
    return

fn directCall3VoidMixed(y: int32): void =
    directVoid3(7, y, 9)

fn directVoid4(a: int32, b: int32, c: int32, d: int32): void =
    return

fn directAliasCall4VoidMixed(y: int32): void =
    let alias = y
    directVoid4(7, 8, alias, 10)

fn directVoid2(a: int32, b: int32): void =
    return

fn directNestedVoidSecondArg(y: int32): void =
    directVoid2(directIdentityI32(7), y)

fn directDropOnlyVoid(argc: int32, argv: ptr): void =
    argc
    argv

fn directZeroBytesLocal(): Bytes =
    var out: Bytes
    out.data = nil
    out.len = 0
    return out

fn directBufferToBytes(buf: buffer.ByteBuffer): Bytes =
    return buf.data

fn directReturnBytesParam(value: Bytes): Bytes =
    return value

fn directReturnStrSeqParam(values: str[]): str[] =
    return values

fn directBufferLenViaField(buf: buffer.ByteBuffer): int32 =
    return bytesLen(buf.data)

fn directWrapZeroBytesAsBuffer(): buffer.ByteBuffer =
    var out: buffer.ByteBuffer
    out.data = directZeroBytesLocal()
    return out

fn directIsEmptyViaCall(buf: buffer.ByteBuffer): bool =
    return directBufferLenViaField(buf) <= 0

fn directReaderFromBytes(buf: bytes.ByteBuffer): bytes.ByteReader =
    var out: bytes.ByteReader
    out.buf = buf
    out.pos = 0
    return out

fn directCanReadLike(r: bytes.ByteReader, count: int32): bool =
    return r.pos + count <= r.buf.len

fn directVersionText(): str =
    return "v2.direct.version"

fn directLiteralStrArgSink(text: str): int32 =
    return 0

fn directCallLiteralStr(): int32 =
    return directLiteralStrArgSink("v2.literal.arg")

fn directLiteralStrVoidSink(text: str): void =
    return

fn directCallLiteralStrVoid(): void =
    directLiteralStrVoidSink("v2.literal.arg")

fn directElemSizeInt32(): int32 =
    return int32(sizeof(int32))

fn directElemSizeInt64(): int32 =
    return int32(sizeof(int64))

fn directElemSizeUint8(): int32 =
    return int32(sizeof(uint8))

@importc("cheng_file_exists")
fn directProbeFileExistsRaw(path: cstring): int32

fn directNestedReadFileText(path: str): str =
    return bytes.bytesReadFileAll(system.strToCStringTemp(path))

fn directNestedFileExists(path: str): bool =
    return directProbeFileExistsRaw(system.strToCStringTemp(path)) != 0

fn directFallbackPrimary4(a: ptr, b: int32, c: int32, d: int32): ptr =
    return nil

fn directFallbackSecondary4(a: ptr, b: int32, c: int32, d: int32): ptr =
    return a

fn directFallbackPtr4(a: ptr, b: int32, c: int32, d: int32): ptr =
    let found = directFallbackPrimary4(a, b, c, d)
    if found != nil:
        return found
    return directFallbackSecondary4(a, b, c, d)

fn directGetCurrentDirWrap(): str =
    return system.getCurrentDir()

fn directBytesReadFileAllWrap(path: cstring): str =
    return bytes.bytesReadFileAll(path)

fn directCmdlineHasArgs(): bool =
    return cmdline.paramCount() > 0

fn directCurrentCompilerPathLike(): str =
    return os.absolutePath(cmdline.programName())

fn directWriteTextLike(text: str): void =
    os.write(os.get_stdout(), text)

fn main(): int32 =
    let target = mtarget.machineTargetContract().firstClassTargets[0]
    let sourcePath = "v2/src/tooling/cheng_v2.cheng"
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    let bundle = cpipe.compileCompilerCoreSourceClosure(sourcePath)
    let manifest = mresolve.resolveCompilerCoreSourceManifest(sourcePath)
    let machine = mpipeline.lowerCompilerCorePlanToMachine(bundle.lowPlan, target)
    let image = oimg.writeObjImage(machine)
    let objFile = ofile.buildObjFile(machine)
    let artifact = rart.buildReleaseArtifact(sourcePath, "exe", target)
    assert(bundle.version == "v2.driver.compiler_core_pipeline.v1", "v2 compiler core pipeline version")
    assert(parsed.compilerCoreProgram.topLevelKinds.len > 0, "v2 compiler core entry parse count")
    assert(bundle.program.modules.len <= 1, "v2 compiler core module count bounded")
    assert(bundle.program.imports.len > 0, "v2 compiler core import count")
    assert(bundle.program.routines.len > 0, "v2 compiler core routine count")
    assert(bundle.program.routineParams.len > 0, "v2 compiler core routine param count")
    assert(bundle.program.stmts.len > 0, "v2 compiler core stmt count")
    assert(bundle.program.exprs.len > 0, "v2 compiler core expr count")
    assert(bundle.lowPlan.itemIds.len > 0, "v2 compiler core low_uir item count")
    assert(bundle.lowPlan.canonicalOps[0] == "compiler_import_bind", "v2 compiler core first canonical op")
    assert(bundle.lowPlan.importCategories[0] == "stdlib", "v2 compiler core first import category")
    assert(bundle.lowPlan.labels[0] == "std/cmdline", "v2 compiler core first label")
    assert(bundle.lowPlan.labels[bundle.lowPlan.labels.len - 1] == "main", "v2 compiler core last label")
    assert(bundle.lowPlan.executableAstReady[bundle.lowPlan.labels.len - 1], "v2 compiler core main ast ready")
    assert(bundle.lowPlan.canonicalOps[bundle.lowPlan.labels.len - 1] == "compiler_fn_exec", "v2 compiler core main executable op")
    assert(bundle.lowPlan.returnTypeTexts[bundle.lowPlan.labels.len - 1] == "int32", "v2 compiler core main return type")
    assert(bundle.lowPlan.paramCounts[bundle.lowPlan.labels.len - 1] == 1, "v2 compiler core main param count")
    assert(bundle.lowPlan.routineOpCounts[bundle.lowPlan.labels.len - 1] > 0, "v2 compiler core main exec op count")
    assert(bundle.lowPlan.routineOpHashes[bundle.lowPlan.labels.len - 1] != "", "v2 compiler core main exec op hash")
    let mainOpStart = bundle.lowPlan.routineOpStarts[bundle.lowPlan.labels.len - 1]
    let mainOpEnd = mainOpStart + bundle.lowPlan.routineOpCounts[bundle.lowPlan.labels.len - 1]
    assert(hasExecOpKind(bundle.lowPlan, mainOpStart, mainOpEnd, "call"), "v2 compiler core main has call op")
    assert(hasExecOpKind(bundle.lowPlan, mainOpStart, mainOpEnd, "jump_if_false"), "v2 compiler core main has conditional branch op")
    assert(cfacts.compilerCoreExecutableAstItemCount(bundle.facts) >= 3, "v2 compiler core executable ast routine count")
    assert(cfacts.compilerCoreExecutableParamCount(bundle.facts) >= 1, "v2 compiler core executable param count")
    assert(cfacts.compilerCoreExecutableStmtCount(bundle.facts) >= 14, "v2 compiler core executable stmt count")
    assert(cfacts.compilerCoreExecutableExprCount(bundle.facts) >= 26, "v2 compiler core executable expr count")
    assert(manifest.packageId == "pkg://cheng/v2", "v2 compiler core manifest package id")
    assert(manifest.filePaths.len > 0, "v2 compiler core manifest file count")
    assert(hasManifestPath(manifest, "v2/cheng-package.toml"), "v2 compiler core manifest package root")
    assert(hasManifestPath(manifest, "v2/src/tooling/cheng_v2.cheng"), "v2 compiler core manifest entry")
    assert(hasManifestPath(manifest, "v2/src/tooling/cheng_tooling_v2.cheng"), "v2 compiler core manifest tooling entry")
    assert(hasManifestPath(manifest, "v2/src/compiler/driver/runtime_provider_object_v2.cheng"), "v2 compiler core manifest runtime provider object")
    assert(hasManifestPath(manifest, "v2/src/compiler/driver/system_link_plan_v2.cheng"), "v2 compiler core manifest system link plan")
    assert(hasManifestPath(manifest, "v2/src/runtime/core_runtime_v2.cheng"), "v2 compiler core manifest core runtime provider")
    assert(hasManifestPath(manifest, "v2/src/runtime/compiler_core_runtime_v2.cheng"), "v2 compiler core manifest compiler runtime provider")
    assert(hasManifestPath(manifest, "src/std/cmdline.cheng"), "v2 compiler core manifest std cmdline")
    assert(hasManifestPath(manifest, "src/std/os.cheng"), "v2 compiler core manifest std os")
    assert(hasManifestPath(manifest, "src/std/system.cheng"), "v2 compiler core manifest std system")
    assert(machine.moduleKind == "compiler_core", "v2 compiler core machine module kind")
    assert(machine.itemIds.len > 0, "v2 compiler core machine item count")
    assert(machine.callSymbolNames[0] != "", "v2 compiler core first runtime target")
    let printUsageMachineIdx = findLabelIndex(bundle.lowPlan.labels, "printUsage")
    assert(printUsageMachineIdx >= 0, "v2 compiler core machine printUsage index")
    assert(machine.metadataOperandModes[printUsageMachineIdx] == "exec_plan_payload", "v2 compiler core machine executable payload mode")
    assert(parser.findText(machine.localPayloadTexts[printUsageMachineIdx], "exec_op_count=") >= 0, "v2 compiler core machine executable payload count")
    assert(parser.findText(machine.localPayloadTexts[printUsageMachineIdx], "exec_op_hash=") >= 0, "v2 compiler core machine executable payload hash")
    assert(parser.findText(machine.localPayloadTexts[printUsageMachineIdx], "op.0=") >= 0, "v2 compiler core machine executable payload first op")
    let stackAlignMachineIdx = findLabelIndex(bundle.lowPlan.labels, "machineTargetStackAlignBytes")
    assert(stackAlignMachineIdx >= 0, "v2 compiler core machine stack align helper index")
    assert(machine.metadataOperandModes[stackAlignMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct exec payload mode")
    assert(machine.callSymbolNames[stackAlignMachineIdx] == "", "v2 compiler core machine direct exec call symbol cleared")
    assert(machine.instructionWordHex[stackAlignMachineIdx] == "a9bf7bfd;910003fd;52800200;a8c17bfd;d65f03c0", "v2 compiler core machine direct exec words")
    let identityMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directIdentityI32")
    assert(identityMachineIdx >= 0, "v2 compiler core machine direct identity index")
    assert(machine.metadataOperandModes[identityMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct identity payload mode")
    assert(machine.callSymbolNames[identityMachineIdx] == "", "v2 compiler core machine direct identity call symbol cleared")
    assert(machine.instructionWordHex[identityMachineIdx] == "a9bf7bfd;910003fd;a8c17bfd;d65f03c0", "v2 compiler core machine direct identity words")
    let negMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directNegI32")
    assert(negMachineIdx >= 0, "v2 compiler core machine direct neg index")
    assert(machine.metadataOperandModes[negMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct neg payload mode")
    assert(machine.callSymbolNames[negMachineIdx] == "", "v2 compiler core machine direct neg call symbol cleared")
    assert(machine.instructionWordHex[negMachineIdx] == "a9bf7bfd;910003fd;4b0003e0;a8c17bfd;d65f03c0", "v2 compiler core machine direct neg words")
    let addMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directAddI32")
    assert(addMachineIdx >= 0, "v2 compiler core machine direct add index")
    assert(machine.metadataOperandModes[addMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct add payload mode")
    assert(machine.callSymbolNames[addMachineIdx] == "", "v2 compiler core machine direct add call symbol cleared")
    assert(machine.instructionWordHex[addMachineIdx] == "a9bf7bfd;910003fd;0b010000;a8c17bfd;d65f03c0", "v2 compiler core machine direct add words")
    let eqMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directEqI32")
    assert(eqMachineIdx >= 0, "v2 compiler core machine direct eq index")
    assert(machine.metadataOperandModes[eqMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct eq payload mode")
    assert(machine.callSymbolNames[eqMachineIdx] == "", "v2 compiler core machine direct eq call symbol cleared")
    assert(machine.instructionWordHex[eqMachineIdx] == "a9bf7bfd;910003fd;6b01001f;54000060;52800000;14000002;52800020;a8c17bfd;d65f03c0", "v2 compiler core machine direct eq words")
    let localAliasMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directLocalAliasI32")
    assert(localAliasMachineIdx >= 0, "v2 compiler core machine direct local alias index")
    assert(machine.metadataOperandModes[localAliasMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct local alias payload mode")
    assert(machine.callSymbolNames[localAliasMachineIdx] == "", "v2 compiler core machine direct local alias call symbol cleared")
    assert(machine.instructionWordHex[localAliasMachineIdx] == "a9bf7bfd;910003fd;a8c17bfd;d65f03c0", "v2 compiler core machine direct local alias words")
    let ifElseMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directIfElseEqI32")
    assert(ifElseMachineIdx >= 0, "v2 compiler core machine direct if else index")
    assert(machine.metadataOperandModes[ifElseMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct if else payload mode")
    assert(machine.callSymbolNames[ifElseMachineIdx] == "", "v2 compiler core machine direct if else call symbol cleared")
    assert(machine.instructionWordHex[ifElseMachineIdx] == "a9bf7bfd;910003fd;6b01001f;54000041;52800020;14000001;52800000;a8c17bfd;d65f03c0", "v2 compiler core machine direct if else words")
    let directCall2MachineIdx = findLabelIndex(bundle.lowPlan.labels, "directCall2I32")
    assert(directCall2MachineIdx >= 0, "v2 compiler core machine direct call2 index")
    assert(machine.metadataOperandModes[directCall2MachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct call2 payload mode")
    assert(machine.callSymbolNames[directCall2MachineIdx] != "", "v2 compiler core machine direct call2 call symbol present")
    assert(machine.instructionWordHex[directCall2MachineIdx] == "a9bf7bfd;910003fd;94000000;a8c17bfd;d65f03c0", "v2 compiler core machine direct call2 words")
    let directAliasCall2MachineIdx = findLabelIndex(bundle.lowPlan.labels, "directAliasCall2I32")
    assert(directAliasCall2MachineIdx >= 0, "v2 compiler core machine direct alias call2 index")
    assert(machine.metadataOperandModes[directAliasCall2MachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct alias call2 payload mode")
    assert(machine.callSymbolNames[directAliasCall2MachineIdx] != "", "v2 compiler core machine direct alias call2 call symbol present")
    assert(machine.instructionWordHex[directAliasCall2MachineIdx] == "a9bf7bfd;910003fd;94000000;a8c17bfd;d65f03c0", "v2 compiler core machine direct alias call2 words")
    let directCall3MachineIdx = findLabelIndex(bundle.lowPlan.labels, "directCall3Mixed")
    assert(directCall3MachineIdx >= 0, "v2 compiler core machine direct call3 index")
    assert(machine.metadataOperandModes[directCall3MachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct call3 payload mode")
    assert(machine.callSymbolNames[directCall3MachineIdx] != "", "v2 compiler core machine direct call3 call symbol present")
    assert(machine.instructionWordHex[directCall3MachineIdx] == "a9bf7bfd;910003fd;aa0003e9;528000e0;aa0903e1;52800122;94000000;a8c17bfd;d65f03c0", "v2 compiler core machine direct call3 words")
    let directAliasCall3MachineIdx = findLabelIndex(bundle.lowPlan.labels, "directAliasCall3Mixed")
    assert(directAliasCall3MachineIdx >= 0, "v2 compiler core machine direct alias call3 index")
    assert(machine.metadataOperandModes[directAliasCall3MachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct alias call3 payload mode")
    assert(machine.callSymbolNames[directAliasCall3MachineIdx] != "", "v2 compiler core machine direct alias call3 call symbol present")
    assert(machine.instructionWordHex[directAliasCall3MachineIdx] == "a9bf7bfd;910003fd;aa0003e9;528000e0;aa0903e1;52800122;94000000;a8c17bfd;d65f03c0", "v2 compiler core machine direct alias call3 words")
    let directCall4MachineIdx = findLabelIndex(bundle.lowPlan.labels, "directCall4Mixed")
    assert(directCall4MachineIdx >= 0, "v2 compiler core machine direct call4 index")
    assert(machine.metadataOperandModes[directCall4MachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct call4 payload mode")
    assert(machine.callSymbolNames[directCall4MachineIdx] != "", "v2 compiler core machine direct call4 call symbol present")
    assert(machine.instructionWordHex[directCall4MachineIdx] == "a9bf7bfd;910003fd;aa0003e9;528000e0;52800101;aa0903e2;52800143;94000000;a8c17bfd;d65f03c0", "v2 compiler core machine direct call4 words")
    let directExternAbsMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directExternAbsWrap")
    assert(directExternAbsMachineIdx >= 0, "v2 compiler core machine direct extern abs index")
    assert(machine.metadataOperandModes[directExternAbsMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct extern abs payload mode")
    assert(machine.callSymbolNames[directExternAbsMachineIdx] == mpipeline.machineLibcSymbolName(target, "abs"), "v2 compiler core machine direct extern abs call symbol")
    assert(machine.instructionWordHex[directExternAbsMachineIdx] == "a9bf7bfd;910003fd;94000000;a8c17bfd;d65f03c0", "v2 compiler core machine direct extern abs words")
    let directExternFread4MachineIdx = findLabelIndex(bundle.lowPlan.labels, "directExternFread4Wrap")
    assert(directExternFread4MachineIdx >= 0, "v2 compiler core machine direct extern fread4 index")
    assert(machine.metadataOperandModes[directExternFread4MachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct extern fread4 payload mode")
    assert(machine.callSymbolNames[directExternFread4MachineIdx] == mpipeline.machineLibcSymbolName(target, "cheng_fread"), "v2 compiler core machine direct extern fread4 call symbol")
    assert(machine.instructionWordHex[directExternFread4MachineIdx] == "a9bf7bfd;910003fd;94000000;a8c17bfd;d65f03c0", "v2 compiler core machine direct extern fread4 words")
    let directExternFreeMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directExternFreeWrap")
    assert(directExternFreeMachineIdx >= 0, "v2 compiler core machine direct extern free index")
    assert(machine.metadataOperandModes[directExternFreeMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct extern free payload mode")
    assert(machine.callSymbolNames[directExternFreeMachineIdx] == mpipeline.machineLibcSymbolName(target, "free"), "v2 compiler core machine direct extern free call symbol")
    assert(machine.instructionWordHex[directExternFreeMachineIdx] == "a9bf7bfd;910003fd;94000000;52800000;a8c17bfd;d65f03c0", "v2 compiler core machine direct extern free words")
    let directAliasVoidMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directAliasVoidCallPtr")
    assert(directAliasVoidMachineIdx >= 0, "v2 compiler core machine direct alias void call index")
    assert(machine.metadataOperandModes[directAliasVoidMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct alias void call payload mode")
    assert(machine.callSymbolNames[directAliasVoidMachineIdx] == mpipeline.machineLibcSymbolName(target, "free"), "v2 compiler core machine direct alias void call symbol")
    assert(machine.instructionWordHex[directAliasVoidMachineIdx] == "a9bf7bfd;910003fd;94000000;52800000;a8c17bfd;d65f03c0", "v2 compiler core machine direct alias void call words")
    let directCall3VoidMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directCall3VoidMixed")
    assert(directCall3VoidMachineIdx >= 0, "v2 compiler core machine direct call3 void index")
    assert(machine.metadataOperandModes[directCall3VoidMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct call3 void payload mode")
    assert(machine.callSymbolNames[directCall3VoidMachineIdx] != "", "v2 compiler core machine direct call3 void call symbol present")
    assert(machine.instructionWordHex[directCall3VoidMachineIdx] == "a9bf7bfd;910003fd;aa0003e9;528000e0;aa0903e1;52800122;94000000;52800000;a8c17bfd;d65f03c0", "v2 compiler core machine direct call3 void words")
    let directAliasCall4VoidMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directAliasCall4VoidMixed")
    assert(directAliasCall4VoidMachineIdx >= 0, "v2 compiler core machine direct alias call4 void index")
    assert(machine.metadataOperandModes[directAliasCall4VoidMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct alias call4 void payload mode")
    assert(machine.callSymbolNames[directAliasCall4VoidMachineIdx] != "", "v2 compiler core machine direct alias call4 void call symbol present")
    assert(machine.instructionWordHex[directAliasCall4VoidMachineIdx] == "a9bf7bfd;910003fd;528000e0;52800101;aa0003e2;52800143;94000000;52800000;a8c17bfd;d65f03c0", "v2 compiler core machine direct alias call4 void words")
    let directNestedVoidSecondArgMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directNestedVoidSecondArg")
    assert(directNestedVoidSecondArgMachineIdx >= 0, "v2 compiler core machine direct nested void second arg index")
    assert(machine.metadataOperandModes[directNestedVoidSecondArgMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct nested void second arg payload mode")
    assert(parser.findText(machine.callSymbolNames[directNestedVoidSecondArgMachineIdx], ";") >= 0, "v2 compiler core machine direct nested void second arg call symbols present")
    assert(machine.functionRelocCounts[directNestedVoidSecondArgMachineIdx] == 2, "v2 compiler core machine direct nested void second arg reloc count")
    assert(machine.instructionWordHex[directNestedVoidSecondArgMachineIdx] == "a9bf7bfd;910003fd;d10043ff;aa0003e1;f90003e1;528000e0;94000000;f94003e1;910043ff;94000000;52800000;a8c17bfd;d65f03c0", "v2 compiler core machine direct nested void second arg words")
    let dropOnlyMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directDropOnlyVoid")
    assert(dropOnlyMachineIdx >= 0, "v2 compiler core machine direct drop only index")
    assert(machine.metadataOperandModes[dropOnlyMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct drop only payload mode")
    let nestedReadMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directNestedReadFileText")
    assert(nestedReadMachineIdx >= 0, "v2 compiler core machine direct nested read text index")
    assert(machine.metadataOperandModes[nestedReadMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct nested read text payload mode")
    assert(machine.callSymbolNames[nestedReadMachineIdx] != "", "v2 compiler core machine direct nested read text call symbols present")
    assert(machine.instructionWordHex[nestedReadMachineIdx] == "a9bf7bfd;910003fd;94000000;94000000;a8c17bfd;d65f03c0", "v2 compiler core machine direct nested read text words")
    let nestedExistsMachineIdx = findLabelIndex(bundle.lowPlan.labels, "directNestedFileExists")
    assert(nestedExistsMachineIdx >= 0, "v2 compiler core machine direct nested exists index")
    assert(machine.metadataOperandModes[nestedExistsMachineIdx] == "direct_exec_no_payload", "v2 compiler core machine direct nested exists payload mode")
