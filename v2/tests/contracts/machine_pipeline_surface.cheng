import std/system
import compiler/machine/target_contract as mtarget
import compiler/machine/machine_pipeline_v2 as mpipeline

fn main(): int32 =
    let target = mtarget.machineTargetContract().firstClassTargets[0]
    let bundle = mpipeline.sampleNetworkDistributionMachineModule(target)
    assert(bundle.version == "v2.machine_pipeline.v1", "v2 machine pipeline version")
    assert(bundle.moduleKind == "network_distribution", "v2 machine module kind")
    assert(bundle.architecture == "aarch64", "v2 machine architecture")
    assert(bundle.objFormat == "macho", "v2 machine obj format")
    assert(bundle.regalloc == "linear_scan_deterministic", "v2 machine regalloc")
    assert(bundle.textSectionName == "__TEXT,__text", "v2 machine text section")
    assert(bundle.callRelocationKind == "ARM64_RELOC_BRANCH26", "v2 machine call relocation")
    assert(bundle.itemIds.len == 7, "v2 machine function count")
    assert(bundle.symbolNames[0] == "_cheng_v2_network_distribution_publish_source_manifest_0", "v2 machine first symbol")
    assert(bundle.callSymbolNames[4] == "_runtime_network_distribution_v2_disperse_ida_fragments", "v2 machine call symbol")
    assert(bundle.frameSizes[4] == 32, "v2 machine coded dispersal frame size")
    assert(bundle.frameSizes[6] == 48, "v2 machine background signature frame size")
    assert(bundle.instructionWordHex[0] == "a9bf7bfd;910003fd;94000000;a8c17bfd;d65f03c0", "v2 machine stub words")
    return 0
