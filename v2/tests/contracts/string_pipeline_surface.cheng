import std/system
import compiler/driver/string_pipeline_v2 as pipe

fn main(): int32 =
    let bundle = pipe.sampleStringPipeline()
    assert(bundle.version == "v2.driver.string_pipeline.v1", "v2 string pipeline version")
    assert(pipe.stringPipelineExprCount(bundle) == 14, "v2 string pipeline expr count")
    assert(pipe.stringPipelineFactCount(bundle) == 14, "v2 string pipeline fact count")
    assert(bundle.highGraph.exprIds.len == 14, "v2 string pipeline high count")
    assert(bundle.lowPlan.exprIds.len == 14, "v2 string pipeline low count")
    assert(bundle.facts.highOps[0] == "str_eq", "v2 string pipeline eq high op")
    assert(bundle.facts.highOps[2] == "str_concat", "v2 string pipeline concat high op")
    assert(bundle.highGraph.opNames[4] == "str_slice_view", "v2 string pipeline slice high op")
    assert(bundle.lowPlan.canonicalOps[9] == "str_to_owned", "v2 string pipeline dollar low op")
    assert(bundle.lowPlan.runtimeTargets[2] == "runtime/strings_v2.+", "v2 string pipeline concat runtime")
    assert(bundle.lowPlan.runtimeTargets[4] == "runtime/strings_v2.__cheng_slice_string", "v2 string pipeline slice runtime")
    assert(bundle.lowPlan.runtimeTargets[5] == "runtime/strings_v2.__cheng_string_contains_char", "v2 string pipeline char contains runtime")
    assert(bundle.lowPlan.runtimeTargets[10] == "runtime/strings_v2.StrBuilder", "v2 string pipeline builder init runtime")
    assert(bundle.lowPlan.runtimeTargets[13] == "runtime/strings_v2.finish", "v2 string pipeline builder finish runtime")
    return 0
