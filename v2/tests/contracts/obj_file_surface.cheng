import std/system
import compiler/machine/target_contract as mtarget
import compiler/obj/obj_file_v2 as ofile

fn main(): int32 =
    let target = mtarget.machineTargetContract().firstClassTargets[0]
    let file = ofile.sampleNetworkDistributionObjFile(target)
    assert(file.version == "v2.obj_file.v1", "v2 obj file version")
    assert(file.format == "macho", "v2 obj file format")
    assert(file.headerByteCount == 288, "v2 obj file header bytes")
    assert(file.regionNames.len == 6, "v2 obj file region count")
    assert(file.regionNames[0] == "header", "v2 obj file header region")
    assert(file.regionNames[1] == "text", "v2 obj file text region")
    assert(file.regionNames[5] == "strtab", "v2 obj file strtab region")
    assert(file.fileByteCount > 288, "v2 obj file byte count")
    assert(len(file.filePrefixHex) == 64, "v2 obj file prefix hex width")
    assert(file.fileCid != "", "v2 obj file cid")
    return 0
