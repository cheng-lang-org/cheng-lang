import std/system
import compiler/frontend/string_surface_contract as surface
import compiler/frontend/string_lowering_contract as flower
import compiler/low_uir/string_ops_contract as sops

fn main(): int32 =
    let s = surface.stringSurfaceContract()
    let l = flower.stringLoweringContract()
    let o = sops.lowUirStringOpsContract()

    assert(s.operatorStyle == "symbol_first", "v2 string operator style")
    assert(s.symbolForms.len >= 8, "v2 string symbol form count")
    assert(s.searchAlgorithm == "two_way_bytes", "v2 string surface algorithm")
    assert(l.phase == "surface_lowering", "v2 string lowering phase")
    assert(l.builderCallModel == "dot_lowered_to_free_fn", "v2 string builder call model")
    assert(flower.hasStringLoweringRule("a == b"), "v2 string lowering eq symbol")
    assert(flower.hasStringLoweringRule("a != b"), "v2 string lowering ne symbol")
    assert(flower.hasStringLoweringRule("a + b"), "v2 string lowering add symbol")
    assert(flower.hasStringLoweringRule("s[i]"), "v2 string lowering index symbol")
    assert(flower.hasStringLoweringRule("c in s"), "v2 string lowering char contains")
    assert(flower.hasStringLoweringRule("$s"), "v2 string lowering dollar")
    assert(flower.hasStringLoweringRule("s.contains(sub)"), "v2 string lowering contains sugar")
    assert(flower.stringLoweringRuntimeTarget("a + b") == "runtime/strings_v2.+", "v2 string lowering add target")
    assert(flower.stringLoweringRuntimeTarget("s[i]") == "runtime/strings_v2.[]", "v2 string lowering index target")
    assert(flower.stringLoweringRuntimeTarget("s[a..<b]") == "runtime/strings_v2.__cheng_slice_string", "v2 string lowering slice target")
    assert(flower.stringLoweringRuntimeTarget("c in s") == "runtime/strings_v2.__cheng_string_contains_char", "v2 string lowering char target")
    assert(flower.stringLoweringRuntimeTarget("builder.finish()") == "runtime/strings_v2.finish", "v2 string lowering finish target")
    assert(o.noHiddenRope, "v2 low_uir string rope policy")
    assert(o.noHiddenMethodDispatch, "v2 low_uir string dispatch policy")
    assert(sops.hasLowUirStringOp("str_ne"), "v2 low_uir string ne op")
    assert(sops.hasLowUirStringOp("str_index"), "v2 low_uir string index op")
    assert(sops.hasLowUirStringOp("str_contains_char"), "v2 low_uir string contains char op")
    assert(sops.hasLowUirStringOp("str_to_owned"), "v2 low_uir string to owned op")
    assert(sops.hasLowUirStringOp("str_contains"), "v2 low_uir string contains op")
    assert(sops.lowUirStringOpRuntimeTarget("str_concat") == "runtime/strings_v2.+", "v2 low_uir string concat target")
    assert(sops.lowUirStringOpRuntimeTarget("str_index") == "runtime/strings_v2.[]", "v2 low_uir string index target")
    assert(sops.lowUirStringOpRuntimeTarget("str_to_owned") == "runtime/strings_v2.$", "v2 low_uir string to owned target")
    assert(sops.lowUirStringOpRuntimeTarget("str_builder_append_byte") == "runtime/strings_v2.appendByte", "v2 low_uir string append byte target")
    assert(l.rules.len >= 12, "v2 string lowering rule count")
    assert(o.canonicalOps.len >= 14, "v2 low_uir string op count")
    return 0
