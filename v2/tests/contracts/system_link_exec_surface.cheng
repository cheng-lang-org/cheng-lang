import std/system
import compiler/machine/target_contract as mtarget
import compiler/driver/system_link_exec_v2 as sexec

fn main(): int32 =
    let target = mtarget.machineTargetContract().firstClassTargets[0]
    let bundle = sexec.buildSystemLinkExec("v2/src/tooling/cheng_v2.cheng",
                                           "exe",
                                           target,
                                           "v2/artifacts/tests/compiler_core_system_link_exec_surface")
    assert(bundle.version == "v2.system_link_exec.v1", "v2 system link exec version")
    assert(bundle.moduleKind == "compiler_core", "v2 system link exec module kind")
    assert(bundle.linkerFlavor == "ld64", "v2 system link exec linker flavor")
    assert(bundle.linkerPath == "/usr/bin/ld", "v2 system link exec linker path")
    assert(bundle.sdkName == "macosx", "v2 system link exec sdk name")
    assert(bundle.systemLibraries.len == 1, "v2 system link exec system library count")
    assert(bundle.systemLibraries[0] == "System", "v2 system link exec system library")
    assert(bundle.providerModules.len == 2, "v2 system link exec provider module count")
    assert(bundle.providerModules[0] == "runtime/compiler_core_runtime_v2", "v2 system link exec compiler provider")
    assert(bundle.providerModules[1] == "runtime/core_runtime_v2", "v2 system link exec core provider")
    assert(bundle.entryRequired, "v2 system link exec entry required")
    assert(bundle.entrySymbol != "", "v2 system link exec entry symbol")
    assert(bundle.outputPath == "compiler_core_system_link_exec_surface", "v2 system link exec output path basename")
    assert(bundle.primaryObjPath == "compiler_core_system_link_exec_surface.primary.o", "v2 system link exec primary obj basename")
    assert(bundle.outputPresent, "v2 system link exec output present")
    assert(bundle.outputByteCount > 0, "v2 system link exec output byte count")
    assert(bundle.outputFileCid != "", "v2 system link exec output cid")
    assert(sexec.systemLinkExecOk(bundle), "v2 system link exec ok")
    return 0
