import std/system
import compiler/machine/target_contract as mtarget
import compiler/driver/runtime_provider_object_v2 as rpobj
import compiler/frontend/v2_source_parser as parser

fn main(): int32 =
    let target = mtarget.machineTargetContract().firstClassTargets[0]
    let coreProvider = rpobj.materializeRuntimeProviderObject("runtime/core_runtime_v2", target)
    let compilerProvider = rpobj.materializeRuntimeProviderObject("runtime/compiler_core_runtime_v2", target)
    let providers = rpobj.materializeRuntimeProviderObjects(["runtime/core_runtime_v2",
                                                             "runtime/compiler_core_runtime_v2"],
                                                            target)
    assert(coreProvider.version == "v2.runtime_provider_object.v1", "v2 runtime provider object version")
    assert(coreProvider.modulePath == "runtime/core_runtime_v2", "v2 runtime provider core module")
    assert(coreProvider.sourcePath == "v2/src/runtime/core_runtime_v2.cheng", "v2 runtime provider core source")
    assert(coreProvider.targetTriple == target, "v2 runtime provider core target")
    assert(coreProvider.sourceKind == "cheng_module", "v2 runtime provider core source kind")
    assert(coreProvider.compileMode == "machine_obj", "v2 runtime provider core compile mode")
    assert(coreProvider.executionModel == "native_trace_stub", "v2 runtime provider core execution model")
    assert(coreProvider.traceSymbol == "puts", "v2 runtime provider core trace symbol")
    assert(coreProvider.runtimeTargets.len == 1, "v2 runtime provider core target count")
    assert(coreProvider.runtimeTargets[0] == "builtin.len", "v2 runtime provider core runtime target")
    assert(coreProvider.runtimeSymbols[0] == "_builtin_len", "v2 runtime provider core runtime symbol")
    assert(parser.findText(coreProvider.objectText, "provider_symbol_count=1") >= 0, "v2 runtime provider core provider symbol count")
    assert(parser.findText(coreProvider.objectText, "provider_symbol.0=_builtin_len") >= 0, "v2 runtime provider core provider symbol")
    assert(coreProvider.sourceManifestCid != "", "v2 runtime provider core manifest cid")
    assert(coreProvider.objImageVersion == "v2.obj_image.v1", "v2 runtime provider core obj image version")
    assert(coreProvider.objImageCid != "", "v2 runtime provider core obj image cid")
    assert(coreProvider.objFileVersion == "v2.obj_file.v1", "v2 runtime provider core obj file version")
    assert(coreProvider.objFileCid != "", "v2 runtime provider core obj file cid")
    assert(coreProvider.objFileByteCount > 0, "v2 runtime provider core obj file bytes")
    assert(parser.findText(coreProvider.objectText, "compile_input_count=1") >= 0, "v2 runtime provider core compile input count")
    assert(compilerProvider.modulePath == "runtime/compiler_core_runtime_v2", "v2 runtime provider compiler module")
    assert(compilerProvider.sourcePath == "v2/src/runtime/compiler_core_native_provider.c", "v2 runtime provider compiler source")
    assert(compilerProvider.sourceKind == "native_c_source", "v2 runtime provider compiler source kind")
    assert(compilerProvider.compileMode == "external_cc_obj", "v2 runtime provider compiler compile mode")
    assert(compilerProvider.executionModel == "native_command_argv_bridge", "v2 runtime provider compiler execution model")
    assert(compilerProvider.traceSymbol == "runtime_compiler_core_argv_entry", "v2 runtime provider compiler trace symbol")
    assert(compilerProvider.runtimeTargets.len == 1, "v2 runtime provider compiler target count")
    assert(compilerProvider.runtimeTargets[0] == "runtime/compiler_core.argv_entry", "v2 runtime provider compiler runtime target")
    assert(compilerProvider.runtimeSymbols[0] == "_runtime_compiler_core_argv_entry", "v2 runtime provider compiler runtime symbol")
    assert(parser.findText(compilerProvider.objectText, "provider_symbol_count=1") >= 0, "v2 runtime provider compiler provider symbol count")
    assert(parser.findText(compilerProvider.objectText, "provider_symbol.0=_runtime_compiler_core_argv_entry") >= 0, "v2 runtime provider compiler provider symbol")
    assert(compilerProvider.sourceManifestCid != "", "v2 runtime provider compiler manifest cid")
    assert(compilerProvider.objImageCid != "", "v2 runtime provider compiler obj image cid")
    assert(compilerProvider.objFileCid != "", "v2 runtime provider compiler obj file cid")
    assert(compilerProvider.objFileByteCount > 0, "v2 runtime provider compiler object bytes")
    assert(compilerProvider.objectText != "", "v2 runtime provider compiler object text")
    assert(parser.findText(compilerProvider.objectText, "compile_input_count=5") >= 0, "v2 runtime provider compiler compile input count")
    assert(parser.findText(compilerProvider.objectText, "compile_input.1.path=v2/src/runtime/compiler_core_native_dispatch.c") >= 0, "v2 runtime provider compiler dispatch source tracked")
    assert(parser.findText(compilerProvider.objectText, "compile_input.2.path=v2/src/runtime/compiler_core_native_dispatch.h") >= 0, "v2 runtime provider compiler dispatch header tracked")
    assert(parser.findText(compilerProvider.objectText, "compile_input.3.path=v2/bootstrap/cheng_v2c_tooling.c") >= 0, "v2 runtime provider compiler tooling source tracked")
    assert(parser.findText(compilerProvider.objectText, "compile_input.4.path=v2/bootstrap/cheng_v2c_tooling.h") >= 0, "v2 runtime provider compiler tooling header tracked")
    assert(providers.len == 2, "v2 runtime provider materialize list count")
    assert(providers[0].modulePath == "runtime/core_runtime_v2", "v2 runtime provider materialize list first")
    assert(providers[1].modulePath == "runtime/compiler_core_runtime_v2", "v2 runtime provider materialize list second")
    return 0
