import std/system
import compiler/machine/target_contract as mtarget
import compiler/machine/machine_pipeline_v2 as mpipeline
import compiler/obj/obj_file_v2 as ofile
import compiler/driver/release_artifact_v2 as rart
import compiler/driver/system_link_plan_v2 as slink

fn main(): int32 =
    let target = mtarget.machineTargetContract().firstClassTargets[0]
    let machine = mpipeline.sampleNetworkDistributionMachineModule(target)
    let objFile = ofile.buildObjFile(machine)
    let nativeLink = rart.buildNativeLinkPlan(machine, "exe", target)
    let plan = slink.buildSystemLinkPlan(machine, objFile, "exe", nativeLink.providerModules, [], [], [])
    assert(plan.version == "v2.system_link_plan.v1", "v2 system link plan version")
    assert(plan.linkerFlavor == "ld64", "v2 system link plan linker flavor")
    assert(plan.outputKind == "executable", "v2 system link plan output kind")
    assert(plan.primaryObjFileCid == objFile.fileCid, "v2 system link plan primary obj file cid")
    assert(plan.providerModules.len == 2, "v2 system link plan provider modules")
    assert(plan.providerSourcePaths[0] == "v2/src/runtime/core_runtime_v2.cheng", "v2 system link plan core provider source")
    assert(plan.providerSourcePaths[1] == "v2/src/runtime/network_distribution_runtime_v2.cheng", "v2 system link plan network provider source")
    assert(plan.providerManifestCids[0] != "", "v2 system link plan core provider manifest cid")
    assert(plan.providerManifestCids[1] != "", "v2 system link plan network provider manifest cid")
    assert(plan.providerObjFileCids[0] != "", "v2 system link plan core provider obj file cid")
    assert(plan.providerObjFileCids[1] != "", "v2 system link plan network provider obj file cid")
    assert(plan.providerObjFileByteCounts[0] > 0, "v2 system link plan core provider obj file bytes")
    assert(plan.providerObjFileByteCounts[1] > 0, "v2 system link plan network provider obj file bytes")
    assert(plan.entryRequired, "v2 system link plan exe entry required")
    assert(plan.entrySymbol == "", "v2 system link plan network entry absent")
    assert(!plan.entryPresent, "v2 system link plan entry absent flag")
    assert(plan.missingReasons.len == 2, "v2 system link plan honest blockers")
    assert(plan.missingReasons[0] == "program_entry_symbol_missing", "v2 system link plan entry blocker")
    assert(plan.missingReasons[1] == "system_link_execution_missing", "v2 system link plan execution blocker")
    assert(plan.planCid != "", "v2 system link plan cid")
    return 0
