import compiler/low_uir/pipeline_contract as pipeline

fn hasPass(name: str): bool =
    let c = pipeline.lowUirPipelineContract()
    for i in 0..<c.passOrder.len:
        if c.passOrder[i] == name:
            return true
    return false

fn main(): int32 =
    let c = pipeline.lowUirPipelineContract()
    if c.parallelUnit != "function_task":
        return 1
    if c.mergeMode != "stable_declaration_order":
        return 2
    if !hasPass("ssu"):
        return 3
    if !hasPass("ssa"):
        return 4
    if !hasPass("late_vectorize"):
        return 5
    if pipeline.lowUirRequiredCoreCount() < 5:
        return 6
    return 0
