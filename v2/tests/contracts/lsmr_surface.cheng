import std/system
import compiler/driver/lsmr_v2 as lsmr
import runtime/lsmr_contract_v2 as lcontract

fn main(): int32 =
    let cid = "499128e86e4bf16650ba638299a0f91638a6c5edcc0f3e2674d4785b89632900"
    let contract = lcontract.lsmrRuntimeContract()
    let address = lsmr.lsmrAddressFromCid(cid, 4)
    let routePlan = lsmr.buildLsmrRoutePlan(cid, 4, "urgent", "none")
    assert(contract.version == "v2.runtime.lsmr_contract.v1", "v2 lsmr contract version")
    assert(contract.addressingMode == "lsmr_path", "v2 lsmr addressing mode")
    assert(contract.addressBinding == "content_bound_address", "v2 lsmr address binding")
    assert(contract.distanceMetric == "per_level_manhattan", "v2 lsmr distance metric")
    assert(contract.routePlanModel == "canonical_multipath_set", "v2 lsmr route plan model")
    assert(contract.rootPublisherDigit == 5, "v2 lsmr root digit")
    assert(address.version == "v2.runtime.lsmr_address.v1", "v2 lsmr address version")
    assert(address.canonicalText == "2/5/7/4", "v2 lsmr address text")
    assert(routePlan.version == "v2.runtime.lsmr_route_plan.v1", "v2 lsmr route plan version")
    assert(routePlan.sourceAddress.canonicalText == "5/5/5/5", "v2 lsmr source address")
    assert(routePlan.targetAddress.canonicalText == "2/5/7/4", "v2 lsmr target address")
    assert(routePlan.totalDistance == 5, "v2 lsmr total distance")
    assert(routePlan.pathTexts.len == 4, "v2 lsmr path count")
    assert(routePlan.pathTexts[0] == "5/5/5/5 -> 7/5/5/5 -> 2/5/5/5 -> 2/5/7/5 -> 2/5/7/3 -> 2/5/7/4", "v2 lsmr canonical first path")
    assert(routePlan.pathTexts[3] == "5/5/5/5 -> 9/5/5/5 -> 2/5/5/5 -> 2/5/7/5 -> 2/5/7/9 -> 2/5/7/4", "v2 lsmr canonical last path")
    return 0
