import std/system
import compiler/driver/network_distribution_pipeline_v2 as npipe

fn main(): int32 =
    let bundle = npipe.sampleNetworkDistributionPipeline()
    assert(bundle.version == "v2.driver.network_distribution_pipeline.v1", "v2 network pipeline version")
    assert(bundle.program.topologies.len == 3, "v2 network pipeline topology count")
    assert(bundle.program.ops.len == 7, "v2 network pipeline op count")
    assert(bundle.facts.opIds.len == 7, "v2 network pipeline fact count")
    assert(bundle.highGraph.opIds.len == 7, "v2 network pipeline high count")
    assert(bundle.lowPlan.opIds.len == 7, "v2 network pipeline low count")
    assert(bundle.lowPlan.canonicalOps[0] == "publish_source_manifest", "v2 network publish source op")
    assert(bundle.lowPlan.addressingModes[0] == "lsmr_path", "v2 network addressing lowering")
    assert(bundle.lowPlan.topologyDepths[0] == 4, "v2 network depth lowering")
    assert(bundle.lowPlan.runtimeTargets[4] == "runtime/network_distribution_v2.disperse_ida_fragments", "v2 network disperse runtime")
    assert(bundle.lowPlan.dispersalModes[4] == "ida(k=5,n=9)", "v2 network dispersal lowering")
    assert(bundle.lowPlan.priorityClasses[6] == "background", "v2 network priority lowering")
    assert(bundle.lowPlan.addressBindings[0] == "content_bound_address", "v2 network address binding lowering")
    assert(bundle.lowPlan.distanceMetrics[0] == "per_level_manhattan", "v2 network distance lowering")
    assert(bundle.lowPlan.routePlanModels[0] == "canonical_multipath_set", "v2 network route plan lowering")
    assert(bundle.lowPlan.antiEntropySignatureKinds[5] == "ganzhi_merkle_v1", "v2 network signature lowering")
    assert(bundle.lowPlan.topologyCanonicalForms[1] == "topology(domain=rule_pack,fanout=luoshu9,repair=passive_anti_entropy,dispersal=ida(k=5,n=9),priority=bulk,addressing=lsmr_path,depth=4)", "v2 network topology lowering")
    return 0
