import std/system
import compiler/frontend/network_distribution_surface_contract as nsurface
import compiler/frontend/network_distribution_surface_ir_v2 as nsurf
import compiler/semantic_facts/network_distribution_facts_v2 as nfacts
import runtime/network_distribution_runtime_v2 as nrun

fn main(): int32 =
    let contract = nsurface.networkDistributionSurfaceContract()
    let program = nsurf.sampleNetworkDistributionProgram()
    let facts = nfacts.buildNetworkDistributionFacts(program)
    let runtime = nrun.networkDistributionRuntimeContract()
    assert(contract.version == "v2.network_distribution_surface.v2", "v2 network surface version")
    assert(contract.builtinOperations.len == 7, "v2 network builtin op count")
    assert(contract.allowedDomains.len == 4, "v2 network domain count")
    assert(contract.allowedAddressingModes[0] == "lsmr_path", "v2 network addressing mode")
    assert(contract.fixedPriorityMappings[1] == "bulk=coded_bulk_dispersal", "v2 network bulk mapping")
    assert(contract.fixedAddressBindings[0] == "lsmr_path=content_bound_address", "v2 network address binding")
    assert(contract.fixedDistanceMetrics[0] == "lsmr_path=per_level_manhattan", "v2 network distance metric")
    assert(contract.fixedRoutePlanModels[0] == "lsmr_path=canonical_multipath_set", "v2 network route plan model")
    assert(nsurface.networkDistributionOperationCount() == 7, "v2 network operation count helper")
    assert(program.topologies.len == 3, "v2 network sample topology count")
    assert(program.ops.len == 7, "v2 network sample op count")
    assert(program.topologies[1].depth == 4, "v2 network topology depth")
    assert(nsurf.topologyCanonicalForm(program.topologies[1]) == "topology(domain=rule_pack,fanout=luoshu9,repair=passive_anti_entropy,dispersal=ida(k=5,n=9),priority=bulk,addressing=lsmr_path,depth=4)", "v2 network topology canonical form")
    assert(nsurf.networkPriorityTransport("background") == "passive_anti_entropy", "v2 network background mapping")
    assert(facts.transportModes[4] == "coded_bulk_dispersal", "v2 network ida transport")
    assert(facts.addressingModes[0] == "lsmr_path", "v2 network addressing fact")
    assert(facts.topologyDepths[4] == 4, "v2 network depth fact")
    assert(facts.addressBindings[1] == "content_bound_address", "v2 network address binding fact")
    assert(facts.distanceMetrics[1] == "per_level_manhattan", "v2 network distance fact")
    assert(facts.routePlanModels[1] == "canonical_multipath_set", "v2 network route plan fact")
    assert(facts.antiEntropySignatureKinds[5] == "ganzhi_merkle_v1", "v2 network signature fact")
    assert(runtime.version == "v2.runtime.network_distribution.v2", "v2 network runtime version")
    assert(runtime.allowedSignatureKinds[1] == "ganzhi_merkle_v1", "v2 network signature runtime surface")
    assert(runtime.addressingMode == "lsmr_path", "v2 network runtime addressing surface")
    assert(runtime.routePlanModel == "canonical_multipath_set", "v2 network runtime route plan surface")
    return 0
