import std/system
import bootstrap/selfhost_contract as selfhost
import bootstrap/unimaker_stage1_bootstrap as stage1

fn main(): int32 =
    let c = selfhost.selfhostContract()
    let bundle = stage1.bootstrapPipeline()
    assert(c.version == "v2.selfhost.v4", "v2 selfhost contract version")
    assert(c.stages.len == 3, "v2 selfhost stage count")
    assert(c.proofKeys.len == 5, "v2 selfhost proof key count")
    assert(c.currentStatus == "subset_stage0_stage1_stage2_fixed_point", "v2 selfhost current status")
    assert(c.proofInvariants.len == 6, "v2 selfhost proof invariant count")
    assert(bundle.program.decls.len == 5, "v2 stage1 bootstrap decl count")
    assert(bundle.lowPlan.runtimeTargets[0] == "runtime/unimaker.verify_asset_contract", "v2 stage1 bootstrap asset runtime")
    assert(bundle.lowPlan.runtimeTargets[4] == "runtime/unimaker.register_evolve_site", "v2 stage1 bootstrap evolve runtime")
    return 0
