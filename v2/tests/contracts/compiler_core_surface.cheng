import std/system
import compiler/frontend/compiler_core_surface_contract as cfront
import compiler/frontend/v2_source_parser as parser

fn hasImport(program: parser.CompilerCoreProgram, path: str, alias: str): bool =
    for i in 0..<program.imports.len:
        if program.imports[i].modulePath == path && program.imports[i].alias == alias:
            return true
    return false

fn hasRoutine(program: parser.CompilerCoreProgram, name: str): bool =
    for i in 0..<program.routines.len:
        if program.routines[i].name == name:
            return true
    return false

fn findRoutine(program: parser.CompilerCoreProgram, name: str): int32 =
    for i in 0..<program.routines.len:
        if program.routines[i].name == name:
            return i
    return -1

fn hasExprKind(program: parser.CompilerCoreProgram,
               startExpr: int32,
               endExpr: int32,
               kind: str,
               primaryText: str): bool =
    for i in startExpr..<endExpr:
        if program.exprs[i].kind == kind &&
           (len(primaryText) == 0 || program.exprs[i].primaryText == primaryText):
            return true
    return false

fn hasStmtKind(program: parser.CompilerCoreProgram,
               startStmt: int32,
               endStmt: int32,
               kind: str): bool =
    for i in startStmt..<endStmt:
        if program.stmts[i].kind == kind:
            return true
    return false

fn main(): int32 =
    let contract = cfront.compilerCoreSurfaceContract()
    let entry = parser.parseV2SourceFileStrict("v2/src/tooling/cheng_v2.cheng")
    let tooling = parser.parseV2SourceFileStrict("v2/src/tooling/cheng_tooling_v2.cheng")
    let cmdline = parser.parseV2SourceFileStrict("src/std/cmdline.cheng")
    let os = parser.parseV2SourceFileStrict("src/std/os.cheng")
    let strings = parser.parseV2SourceFileStrict("v2/src/runtime/strings_v2.cheng")
    assert(contract.version == "v2.compiler_core_surface.v1", "v2 compiler core surface version")
    assert(contract.topLevelForms.len == 8, "v2 compiler core top-level form count")
    assert(contract.blockKinds.len == 5, "v2 compiler core block kind count")
    assert(contract.importStyle == "normalized_module_path_optional_alias", "v2 compiler core import style")
    assert(contract.routineNameStyle == "identifier_or_backtick_operator", "v2 compiler core routine naming")
    assert(contract.executableAstStorage == "stmt_expr_soa_subset", "v2 compiler core executable ast storage")
    assert(contract.executableAstCoverage == "routine_body_subset", "v2 compiler core executable ast coverage")
    assert(contract.stableTopLevelOrder, "v2 compiler core stable top-level order")
    assert(entry.surfaceKinds.len == 1, "v2 entry compiler core surface count")
    assert(entry.compilerCoreProgram.routines.len == 4, "v2 entry routine count")
    assert(entry.compilerCoreProgram.routineParams.len == 1, "v2 entry routine param count")
    assert(entry.compilerCoreProgram.locals.len == 2, "v2 entry local count")
    assert(entry.compilerCoreProgram.stmts.len >= 14, "v2 entry stmt count")
    assert(entry.compilerCoreProgram.exprs.len >= 26, "v2 entry expr count")
    let printUsageIdx = findRoutine(entry.compilerCoreProgram, "printUsage")
    let printStatusIdx = findRoutine(entry.compilerCoreProgram, "printStatus")
    let mainIdx = findRoutine(entry.compilerCoreProgram, "main")
    assert(printUsageIdx >= 0, "v2 entry has printUsage routine")
    assert(printStatusIdx >= 0, "v2 entry has printStatus routine")
    assert(mainIdx >= 0, "v2 entry has main routine")
    assert(entry.compilerCoreProgram.routines[printUsageIdx].executableAstReady, "v2 entry printUsage ast ready")
    assert(entry.compilerCoreProgram.routines[printStatusIdx].executableAstReady, "v2 entry printStatus ast ready")
    assert(entry.compilerCoreProgram.routines[mainIdx].executableAstReady, "v2 entry main ast ready")
    assert(entry.compilerCoreProgram.routines[mainIdx].returnTypeText == "int32", "v2 entry main return type")
    assert(hasStmtKind(entry.compilerCoreProgram,
                       entry.compilerCoreProgram.routines[printUsageIdx].stmtStart,
                       entry.compilerCoreProgram.routines[printUsageIdx].stmtStart + entry.compilerCoreProgram.routines[printUsageIdx].stmtCount,
                       "for_range"),
           "v2 entry printUsage has for-range stmt")
    assert(hasStmtKind(entry.compilerCoreProgram,
                       entry.compilerCoreProgram.routines[mainIdx].stmtStart,
                       entry.compilerCoreProgram.routines[mainIdx].stmtStart + entry.compilerCoreProgram.routines[mainIdx].stmtCount,
                       "if"),
           "v2 entry main has if stmt")
    assert(hasExprKind(entry.compilerCoreProgram,
                       0,
                       entry.compilerCoreProgram.exprs.len,
                       "if_expr",
                       ""),
           "v2 entry has if-expression expr")
    assert(hasExprKind(entry.compilerCoreProgram,
                       0,
                       entry.compilerCoreProgram.exprs.len,
                       "binary",
                       "||"),
           "v2 entry has or expr")
    assert(hasExprKind(entry.compilerCoreProgram,
                       0,
                       entry.compilerCoreProgram.exprs.len,
                       "index",
                       ""),
           "v2 entry has index expr")
    assert(tooling.surfaceKinds.len == 1, "v2 tooling compiler core surface count")
    assert(tooling.surfaceKinds[0] == "compiler_core", "v2 tooling compiler core surface kind")
    assert(tooling.compilerCoreProgram.version == "v2.frontend.compiler_core_surface_ir.v1", "v2 tooling compiler core ir version")
    assert(tooling.compilerCoreProgram.imports.len >= 46, "v2 tooling compiler core import count")
    assert(tooling.compilerCoreProgram.typeBlocks.len == 1, "v2 tooling compiler core type block count")
    assert(tooling.compilerCoreProgram.routines.len >= 50, "v2 tooling compiler core routine count")
    assert(hasImport(tooling.compilerCoreProgram, "std/cmdline", "cmdline"), "v2 tooling std cmdline import")
    assert(hasImport(tooling.compilerCoreProgram, "std/os", ""), "v2 tooling std os import")
    assert(hasImport(tooling.compilerCoreProgram, "std/bytes", ""), "v2 tooling std bytes import")
    assert(hasImport(tooling.compilerCoreProgram, "std/rawbytes", "rawbytes"), "v2 tooling std rawbytes import")
    assert(hasImport(tooling.compilerCoreProgram, "compiler/driver/system_link_exec_v2", "sexec"), "v2 tooling system link exec import")
    assert(tooling.compilerCoreProgram.routines[0].name == "printLine", "v2 tooling first routine name")
    assert(tooling.compilerCoreProgram.routines[0].bodyLines[0] == "os.writeLine(os.get_stdout(), text)", "v2 tooling first routine body")
    assert(tooling.compilerCoreProgram.routines[tooling.compilerCoreProgram.routines.len - 1].name == "main", "v2 tooling last routine name")
    assert(hasRoutine(tooling.compilerCoreProgram, "currentCompilerPath"), "v2 tooling current compiler helper")
    assert(hasRoutine(tooling.compilerCoreProgram, "buildStageArtifacts"), "v2 tooling stage artifact helper")
    assert(hasRoutine(tooling.compilerCoreProgram, "runStageSelfhostHost"), "v2 tooling stage selfhost host routine")
    assert(hasRoutine(tooling.compilerCoreProgram, "runToolingSelfhostHost"), "v2 tooling tooling selfhost host routine")
    assert(tooling.compilerCoreProgram.topLevelKinds[0] == "import", "v2 tooling first top-level kind")
    assert(tooling.compilerCoreProgram.topLevelKinds.len >= 97, "v2 tooling top-level count")
    assert(tooling.compilerCoreProgram.topLevelKinds[tooling.compilerCoreProgram.topLevelKinds.len - 1] == "fn", "v2 tooling last top-level kind")
    assert(cmdline.surfaceKinds.len == 1, "v2 cmdline compiler core surface count")
    assert(cmdline.compilerCoreProgram.modules.len == 1, "v2 cmdline module count")
    assert(cmdline.compilerCoreProgram.imports.len == 2, "v2 cmdline import count")
    assert(cmdline.compilerCoreProgram.routines.len == 39, "v2 cmdline routine count")
    assert(cmdline.compilerCoreProgram.topLevelKinds.len == 42, "v2 cmdline top-level count")
    assert(cmdline.compilerCoreProgram.modules[0].name == "cmdline", "v2 cmdline module name")
    assert(cmdline.compilerCoreProgram.routines[0].kind == "importc_fn", "v2 cmdline first routine kind")
    assert(cmdline.compilerCoreProgram.routines[0].name == "__cheng_rt_paramCount", "v2 cmdline first routine name")
    assert(os.surfaceKinds.len == 1, "v2 os compiler core surface count")
    assert(os.compilerCoreProgram.imports.len == 7, "v2 os import count")
    assert(os.compilerCoreProgram.typeBlocks.len == 10, "v2 os type block count")
    assert(os.compilerCoreProgram.constDecls.len == 5, "v2 os const count")
    assert(os.compilerCoreProgram.varDecls.len == 1, "v2 os var count")
    assert(os.compilerCoreProgram.routines.len == 145, "v2 os routine count")
    assert(os.compilerCoreProgram.topLevelKinds.len == 168, "v2 os top-level count")
    assert(os.compilerCoreProgram.constDecls[0].label == "osOpenWriteOnly", "v2 os first const label")
    assert(os.compilerCoreProgram.routines[13].kind == "importc_fn", "v2 os importc routine kind")
    assert(strings.surfaceKinds.len == 1, "v2 strings compiler core surface count")
    assert(strings.surfaceKinds[0] == "compiler_core", "v2 strings compiler core surface kind")
    assert(strings.compilerCoreProgram.imports.len == 3, "v2 strings import count")
    assert(strings.compilerCoreProgram.typeBlocks.len == 1, "v2 strings type block count")
    assert(strings.compilerCoreProgram.routines.len == 31, "v2 strings routine count")
    assert(strings.compilerCoreProgram.routines[0].name == "stringRuntimeContract", "v2 strings first routine name")
    assert(strings.compilerCoreProgram.routines[7].name == "`==`", "v2 strings eq operator name")
    assert(strings.compilerCoreProgram.routines[9].name == "`[]`", "v2 strings index operator name")
    assert(strings.compilerCoreProgram.routines[30].name == "`$`", "v2 strings dollar operator name")
    let stringsRuntimeIdx = findRoutine(strings.compilerCoreProgram, "stringRuntimeContract")
    assert(stringsRuntimeIdx >= 0, "v2 strings runtime contract routine exists")
    assert(strings.compilerCoreProgram.routines[stringsRuntimeIdx].executableAstReady, "v2 strings runtime contract ast ready")
    assert(strings.compilerCoreProgram.stmts.len > 0, "v2 strings stmt count")
    assert(strings.compilerCoreProgram.exprs.len > 0, "v2 strings expr count")
    assert(hasStmtKind(strings.compilerCoreProgram, 0, strings.compilerCoreProgram.stmts.len, "assign"), "v2 strings has assign stmt")
    assert(hasStmtKind(strings.compilerCoreProgram, 0, strings.compilerCoreProgram.stmts.len, "while"), "v2 strings has while stmt")
    assert(hasExprKind(strings.compilerCoreProgram, 0, strings.compilerCoreProgram.exprs.len, "binary", "!="), "v2 strings has not-eq expr")
    assert(hasExprKind(strings.compilerCoreProgram, 0, strings.compilerCoreProgram.exprs.len, "binary", "*"), "v2 strings has mul expr")
    assert(hasExprKind(strings.compilerCoreProgram, 0, strings.compilerCoreProgram.exprs.len, "unary", "!"), "v2 strings has unary not expr")
    return 0
