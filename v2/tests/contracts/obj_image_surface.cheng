import std/system
import compiler/machine/target_contract as mtarget
import compiler/driver/identity_v2 as ident
import compiler/machine/machine_pipeline_v2 as mpipeline
import compiler/obj/obj_image_v2 as oimg

fn main(): int32 =
    let target = mtarget.machineTargetContract().firstClassTargets[0]
    let image = oimg.sampleNetworkDistributionObjImage(target)
    assert(image.version == "v2.obj_image.v1", "v2 obj image version")
    assert(image.format == "macho", "v2 obj image format")
    assert(image.sectionNames.len == 5, "v2 obj image section count")
    assert(image.sectionNames[0] == "__TEXT,__text", "v2 obj text section")
    assert(image.sectionNames[1] == "__TEXT,__cstring", "v2 obj cstring section")
    assert(image.symbolNames.len == 21, "v2 obj symbol count")
    assert(image.relocationOffsets.len == 7, "v2 obj reloc count")
    assert(image.relocationKinds[0] == "ARM64_RELOC_BRANCH26", "v2 obj reloc kind")
    assert(image.sectionSizes[0] == 140, "v2 obj text size")
    assert(image.metadataPayloads[6] != "", "v2 obj metadata payload")
    assert(image.imageCid == ident.sha256HexText(image.imageText), "v2 obj image hash")
    return 0
