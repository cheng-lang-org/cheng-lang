import std/system
import compiler/driver/release_artifact_v2 as rart
import bootstrap/tooling_stage1_bootstrap as stage1

fn main(): int32 =
    let manifest = stage1.bootstrapSourceManifest()
    let pipeline = stage1.bootstrapNetworkPipeline()
    let release = stage1.bootstrapReleaseArtifact()
    assert(stage1.bootstrapExamplesRoot() == "v2/examples", "v2 tooling stage1 root")
    assert(stage1.bootstrapNetworkSource() == "v2/examples/network_distribution_module.cheng", "v2 tooling stage1 source")
    assert(stage1.bootstrapTargetTriple() == "arm64-apple-darwin", "v2 tooling stage1 target")
    assert(stage1.bootstrapReleaseEmitKind() == "exe", "v2 tooling stage1 emit kind")
    assert(manifest.version == "v2.source_manifest.v1", "v2 tooling stage1 manifest version")
    assert(manifest.filePaths.len == 3, "v2 tooling stage1 manifest file count")
    assert(manifest.manifestCid == "87c5f1cbf168886c33f121750dd99f89cf6a2bdd5416982a10d013915f3d40a8", "v2 tooling stage1 manifest cid")
    assert(pipeline.version == "v2.driver.network_distribution_pipeline.v1", "v2 tooling stage1 pipeline version")
    assert(pipeline.program.topologies.len == 3, "v2 tooling stage1 topology count")
    assert(pipeline.lowPlan.canonicalOps[0] == "publish_source_manifest", "v2 tooling stage1 first op")
    assert(release.version == "v2.release_artifact.v2", "v2 tooling stage1 release version")
    assert(release.manifestCid == manifest.manifestCid, "v2 tooling stage1 release manifest root")
    assert(rart.releaseArtifactCompileKeyHasLine(release, "manifest_cid=" + manifest.manifestCid), "v2 tooling stage1 release compile key manifest")
    assert(release.machinePipelineVersion == "v2.machine_pipeline.v1", "v2 tooling stage1 machine pipeline version")
    assert(release.objImageVersion == "v2.obj_image.v1", "v2 tooling stage1 obj image version")
    assert(release.objImageCid != "", "v2 tooling stage1 obj image cid")
    assert(rart.releaseArtifactCompileKeyHasLine(release, "network.entry.6.signature=ganzhi_merkle_v1"), "v2 tooling stage1 signature coverage")
    return 0
