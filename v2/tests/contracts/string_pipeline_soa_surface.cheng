import std/system
import compiler/driver/string_pipeline_v2 as pipe

fn main(): int32 =
    let bundle = pipe.sampleStringPipeline()
    let n = bundle.highGraph.exprIds.len
    assert(n == bundle.highGraph.opNames.len, "v2 string high graph op len")
    assert(n == bundle.highGraph.runtimeTargets.len, "v2 string high graph runtime len")
    assert(n == bundle.highGraph.resultKinds.len, "v2 string high graph result len")
    assert(n == bundle.highGraph.allocationModes.len, "v2 string high graph alloc len")
    assert(n == bundle.highGraph.zeroCopyFacts.len, "v2 string high graph zero copy len")
    assert(n == bundle.highGraph.leftTexts.len, "v2 string high graph left len")
    assert(n == bundle.highGraph.rightTexts.len, "v2 string high graph right len")
    assert(n == bundle.highGraph.builderNames.len, "v2 string high graph builder len")
    assert(n == bundle.highGraph.charValues.len, "v2 string high graph char len")
    assert(n == bundle.highGraph.intArg0.len, "v2 string high graph int0 len")
    assert(n == bundle.highGraph.intArg1.len, "v2 string high graph int1 len")
    assert(n == bundle.highGraph.byteValues.len, "v2 string high graph byte len")
    assert(n == bundle.lowPlan.canonicalOps.len, "v2 string low plan op len")
    assert(n == bundle.lowPlan.runtimeTargets.len, "v2 string low plan runtime len")
    assert(n == bundle.lowPlan.resultKinds.len, "v2 string low plan result len")
    assert(n == bundle.lowPlan.allocationModes.len, "v2 string low plan alloc len")
    assert(n == bundle.lowPlan.effectClasses.len, "v2 string low plan effect len")
    assert(n == bundle.lowPlan.zeroCopyFacts.len, "v2 string low plan zero copy len")
    for i in 0..<n:
        assert(bundle.highGraph.exprIds[i] == i, "v2 string high graph id sequence")
        assert(bundle.lowPlan.exprIds[i] == i, "v2 string low plan id sequence")
    return 0
