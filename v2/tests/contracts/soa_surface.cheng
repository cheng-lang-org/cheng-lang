import compiler/high_uir/graph_contract as huir
import compiler/driver/surface_contract as surface

fn main(): int32 =
    let graph = huir.highUirGraphContract()
    if graph.storageModel != "soa_index":
        return 1
    if !graph.indexOnly:
        return 2
    if graph.indexKinds.len < 4:
        return 3
    if !surface.v2HasIndexOnlySoa():
        return 4
    return 0
