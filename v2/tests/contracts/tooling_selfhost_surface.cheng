import std/system
import bootstrap/tooling_selfhost_contract as tooling

fn main(): int32 =
    let c = tooling.toolingSelfhostContract()
    assert(c.version == "v2.tooling_selfhost.v1", "v2 tooling selfhost version")
    assert(c.stage0Tool == "v2/bootstrap/cheng_v2c", "v2 tooling selfhost stage0 tool")
    assert(c.stage1Entry == "bootstrap/tooling_stage1_bootstrap", "v2 tooling selfhost stage1 entry")
    assert(c.stage2Goal == "tooling_network_selfhost_closure", "v2 tooling selfhost stage2 goal")
    assert(c.currentStatus == "stage0_stage1_stage2_tooling_fixed_point", "v2 tooling selfhost current status")
    assert(c.proofCommand == "make -C v2/bootstrap tooling-selfhost", "v2 tooling selfhost proof command")
    assert(c.proofRoot == "v2/examples", "v2 tooling selfhost proof root")
    assert(c.proofSource == "v2/examples/network_distribution_module.cheng", "v2 tooling selfhost proof source")
    assert(c.proofTarget == "arm64-apple-darwin", "v2 tooling selfhost proof target")
    assert(c.stages.len == 3, "v2 tooling selfhost stage count")
    assert(c.proofKeys.len == 10, "v2 tooling selfhost proof key count")
    assert(c.proofKeys[4] == "obj_image_cid", "v2 tooling selfhost obj image key")
    assert(c.proofKeys[5] == "lsmr_addressing_mode", "v2 tooling selfhost lsmr addressing key")
    assert(c.proofKeys[8] == "lsmr_route_plan_model", "v2 tooling selfhost lsmr route plan key")
    assert(c.proofInvariants.len == 20, "v2 tooling selfhost invariant count")
    assert(c.proofInvariants[4] == "checked_in_release_artifact_output == tests/contracts/tooling_release_artifact.expected", "v2 tooling release artifact invariant")
    assert(c.proofInvariants[5] == "checked_in_network_selfhost_output == tests/contracts/network_selfhost.expected", "v2 tooling network report invariant")
    assert(c.proofInvariants[6] == "checked_in_tooling_selfhost_output == tests/contracts/tooling_selfhost.expected", "v2 tooling selfhost report invariant")
    assert(c.proofInvariants[7] == "release_manifest_cid == source_manifest_cid", "v2 tooling release manifest invariant")
    assert(c.proofInvariants[8] == "lsmr_addressing_mode == lsmr_path", "v2 tooling lsmr addressing invariant")
    assert(c.proofInvariants[11] == "lsmr_route_plan_model == canonical_multipath_set", "v2 tooling lsmr route plan invariant")
    assert(c.proofInvariants[16] == "compile_key_canonical_multipath_covered == 1", "v2 tooling multipath coverage invariant")
    assert(c.proofInvariants[17] == "machine_pipeline_obj_image_release_artifact_are_fixed", "v2 tooling machine obj invariant")
    assert(c.proofInvariants[19] == "random_gossip_fallback_present == 0", "v2 tooling fallback invariant")
    return 0
