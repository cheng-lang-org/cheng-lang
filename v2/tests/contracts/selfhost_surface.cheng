import std/system
import bootstrap/selfhost_contract as selfhost

fn main(): int32 =
    let c = selfhost.selfhostContract()
    assert(c.version == "v2.selfhost.v4", "v2 selfhost version")
    assert(c.stage0Tool == "v2/bootstrap/cheng_v2c", "v2 selfhost stage0 tool")
    assert(c.stage1Entry == "bootstrap/unimaker_stage1_bootstrap", "v2 selfhost stage1 entry")
    assert(c.proofCommand == "make -C v2/bootstrap selfhost", "v2 selfhost proof command")
    assert(c.proofSource == "v2/examples/unimaker_robot_node.cheng", "v2 selfhost proof source")
    assert(c.proofInvariants[0] == "stage0_pipeline_hash == stage1_pipeline_hash", "v2 selfhost pipeline hash invariant")
    assert(c.proofInvariants[1] == "stage1_pipeline_hash == stage2_pipeline_hash", "v2 selfhost stage2 hash invariant")
    assert(c.proofInvariants[2] == "generated_stage1 == generated_stage2", "v2 selfhost fixed point invariant")
    assert(c.proofInvariants[3] == "generated_stage1 == src/bootstrap/unimaker_stage1_bootstrap.cheng", "v2 selfhost stage1 source invariant")
    assert(c.proofInvariants[4] == "checked_in_stage1_emit_c_output == tests/contracts/selfhost_stage1_exec.expected", "v2 selfhost stage1 exec invariant")
    assert(c.proofInvariants[5] == "bootstrap_tree_manifest_is_deterministic", "v2 selfhost manifest invariant")
    return 0
