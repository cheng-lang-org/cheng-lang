import std/system
import compiler/driver/unimaker_pipeline_v2 as upipe

fn main(): int32 =
    let bundle = upipe.sampleUnimakerPipeline()
    assert(bundle.version == "v2.driver.unimaker_pipeline.v1", "v2 unimaker pipeline version")
    assert(bundle.program.decls.len == 5, "v2 unimaker pipeline decl count")
    assert(bundle.facts.declIds.len == 5, "v2 unimaker pipeline fact count")
    assert(bundle.highGraph.declIds.len == 5, "v2 unimaker pipeline high count")
    assert(bundle.lowPlan.declIds.len == 5, "v2 unimaker pipeline low count")
    assert(bundle.facts.highOps[0] == "asset_contract_def", "v2 unimaker asset high op")
    assert(bundle.facts.highOps[2] == "ganzhi_state_def", "v2 unimaker ganzhi high op")
    assert(bundle.facts.highOps[3] == "hardware_callback_def", "v2 unimaker callback high op")
    assert(bundle.lowPlan.runtimeTargets[1] == "runtime/unimaker.spawn_actor", "v2 unimaker actor runtime")
    assert(bundle.lowPlan.runtimeTargets[2] == "runtime/unimaker.register_ganzhi_state", "v2 unimaker state runtime")
    assert(bundle.lowPlan.runtimeTargets[4] == "runtime/unimaker.register_evolve_site", "v2 unimaker evolve runtime")
    return 0
