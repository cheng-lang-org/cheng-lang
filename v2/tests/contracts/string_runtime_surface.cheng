import std/system
import runtime/strings_v2 as v2str

fn main(): int32 =
    let contract = v2str.stringRuntimeContract()
    assert(contract.version == "v2.runtime.strings.v1", "v2 strings runtime version")
    assert(contract.operatorStyle == "symbol_first", "v2 strings runtime operator style")
    assert(contract.searchAlgorithm == "two_way_bytes", "v2 strings runtime algorithm")
    assert(contract.symbolFunctions.len >= 5, "v2 strings runtime symbol count")
    assert(contract.loweringHelpers.len >= 4, "v2 strings runtime helper count")
    assert(("cheng" == "cheng"), "v2 strings == true")
    assert(("cheng" != "cheng-lang"), "v2 strings != true")
    assert(!("cheng" != "cheng"), "v2 strings != false")
    assert(("cheng"[1] == 'h'), "v2 strings []")
    assert(v2str.startsWith("cheng-lang", "cheng"), "v2 strings startsWith")
    assert(v2str.endsWith("cheng-lang", "lang"), "v2 strings endsWith")
    assert(v2str.sliceView("abcdef", 1, 4) == "bcd", "v2 strings zero copy slice")
    assert(v2str.__cheng_slice_string("abcdef", 1, 4, true) == "bcd", "v2 strings slice helper exclusive")
    assert(v2str.__cheng_slice_string("abcdef", 1, 3, false) == "bcd", "v2 strings slice helper inclusive")
    assert((("abc" + "def") == "abcdef"), "v2 strings +")
    assert((v2str.__cheng_concat_str("ab", "cd") == "abcd"), "v2 strings concat helper")
    assert(v2str.find("cheng-lang", "") == 0, "v2 strings empty needle")
    assert(v2str.find("aaaaaaab", "aaab") == 4, "v2 strings periodic two way")
    assert(v2str.find("abcxabcdabxabcdabcdabcy", "abcdabcy") == 15, "v2 strings non periodic two way")
    assert(v2str.contains("cheng-lang", "lang"), "v2 strings contains")
    assert(v2str.contains("cheng", 'h'), "v2 strings contains char")
    assert(v2str.__cheng_string_contains_char("cheng", 'e'), "v2 strings contains char helper")
    assert(v2str.__cheng_string_contains_str("cheng-lang", "lang"), "v2 strings contains str helper")
    let name = "cheng"
    assert(($name) == "cheng", "v2 strings dollar")

    var builder: v2str.StrBuilder = v2str.StrBuilder(2)
    v2str.append(builder, "ab")
    v2str.append(builder, "cd")
    v2str.appendByte(builder, uint8(33))
    let built = v2str.finish(builder)
    assert(built == "abcd!", "v2 strings builder finish")
    assert(builder.cap == 0, "v2 strings builder moved")
    return 0
