import std/system
import compiler/driver/surface_contract as surface
import compiler/frontend/v2_source_parser as parser

fn main(): int32 =
    let contract = surface.v2SurfaceContract()
    let entry = parser.parseV2SourceFileStrict("v2/src/tooling/cheng_v2.cheng")
    assert(contract.devEntry == "cheng_v2", "v2 dev entry name")
    assert(contract.toolingEntry == "cheng_tooling_v2", "v2 tooling entry name")
    assert(entry.surfaceKinds.len == 1, "v2 dev entry compiler core surface count")
    assert(entry.surfaceKinds[0] == "compiler_core", "v2 dev entry compiler core surface kind")
    assert(entry.compilerCoreProgram.imports.len == 4, "v2 dev entry import count")
    assert(entry.compilerCoreProgram.routines.len == 4, "v2 dev entry routine count")
    assert(entry.compilerCoreProgram.topLevelKinds.len == 8, "v2 dev entry top-level count")
    assert(entry.compilerCoreProgram.imports[3].modulePath == "tooling/cheng_tooling_v2", "v2 dev entry tooling import path")
    assert(entry.compilerCoreProgram.imports[3].alias == "tooling", "v2 dev entry tooling import alias")
    assert(entry.compilerCoreProgram.routines[3].name == "main", "v2 dev entry main routine name")
    assert(entry.compilerCoreProgram.routines[3].bodyLines[10] == "return tooling.main()", "v2 dev entry forwards to tooling main")
    return 0
