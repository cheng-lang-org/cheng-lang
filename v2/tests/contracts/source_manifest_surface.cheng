import std/system
import compiler/frontend/v2_source_parser as parser
import compiler/driver/manifest_resolver_v2 as manifest
import compiler/driver/identity_v2 as ident

fn hasTopology(bundle: manifest.SourceManifestBundle, topology: str): bool =
    for i in 0..<bundle.topologyCanonicalForms.len:
        if bundle.topologyCanonicalForms[i] == topology:
            return true
    return false

fn main(): int32 =
    let topologySource = parser.parseV2SourceFileStrict("v2/examples/topology_code_sync.cheng")
    let networkSource = parser.parseV2SourceFileStrict("v2/examples/network_distribution_module.cheng")
    let bundle = manifest.resolveSourceManifest("v2/examples")
    assert(bundle.version == "v2.source_manifest.v1", "v2 source manifest version")
    assert(bundle.packageId == "pkg://cheng/v2", "v2 source manifest package")
    assert(bundle.filePaths.len == 3, "v2 source manifest file count")
    assert(bundle.fileTopologyRefs[0] == "CompilerSync;RuleSync;SourceSync", "v2 source manifest topology refs")
    assert(bundle.topologyCanonicalForms.len == 4, "v2 source manifest topology count")
    assert(hasTopology(bundle, "topology(domain=source_manifest,fanout=luoshu9,repair=passive_anti_entropy,dispersal=none,priority=urgent,addressing=lsmr_path,depth=4)"), "v2 source manifest source topology")
    assert(hasTopology(bundle, "topology(domain=compiler_rule_pack,fanout=luoshu9,repair=passive_anti_entropy,dispersal=none,priority=background,addressing=lsmr_path,depth=4)"), "v2 source manifest compiler topology")
    assert(bundle.manifestCid == ident.sha256HexText(bundle.manifestText), "v2 source manifest cid")
    assert(topologySource.networkProgram.topologies.len == 1, "v2 topology example topology count")
    assert(networkSource.networkProgram.ops.len == 7, "v2 network example op count")
    return 0
