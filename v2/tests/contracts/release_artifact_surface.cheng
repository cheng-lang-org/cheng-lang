import std/system
import std/strings as strings
import compiler/driver/release_artifact_v2 as rart
import compiler/driver/manifest_resolver_v2 as manifest
import compiler/machine/target_contract as mtarget
import compiler/driver/identity_v2 as ident

fn main(): int32 =
    let target = mtarget.machineTargetContract().firstClassTargets[0]
    let examplesManifest = manifest.resolveSourceManifest("v2/examples")
    let topologyBundle = rart.buildReleaseArtifact("v2/examples/topology_code_sync.cheng", "exe", target)
    let networkBundle = rart.buildReleaseArtifact("v2/examples/network_distribution_module.cheng", "exe", target)
    assert(topologyBundle.version == "v2.release_artifact.v2", "v2 release artifact version")
    assert(topologyBundle.moduleKind == "topology", "v2 topology release module kind")
    assert(topologyBundle.objFormat == "macho", "v2 topology release obj format")
    assert(topologyBundle.machinePipelineVersion == "v2.machine_pipeline.v1", "v2 topology machine pipeline version")
    assert(topologyBundle.objImageVersion == "v2.obj_image.v1", "v2 topology obj image version")
    assert(rart.releaseArtifactCompileKeyHasLine(topologyBundle, "network_topology_count=1"), "v2 topology compile key topology count")
    assert(rart.releaseArtifactCompileKeyHasLine(topologyBundle, "network.topology.0=topology(domain=source_manifest,fanout=luoshu9,repair=passive_anti_entropy,dispersal=none,priority=urgent,addressing=lsmr_path,depth=4)"), "v2 topology compile key canonical form")
    assert(topologyBundle.manifestCid == examplesManifest.manifestCid, "v2 topology release manifest root")
    assert(networkBundle.moduleKind == "network_distribution", "v2 network release module kind")
    assert(networkBundle.manifestCid == examplesManifest.manifestCid, "v2 network release manifest root")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "manifest_cid=" + examplesManifest.manifestCid), "v2 network compile key manifest root")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "machine_pipeline_version=v2.machine_pipeline.v1"), "v2 network compile key machine pipeline")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "obj_image_version=v2.obj_image.v1"), "v2 network compile key obj image")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "obj_file_version=v2.obj_file.v1"), "v2 network compile key obj file")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "system_link_plan_version=v2.system_link_plan.v1"), "v2 network compile key system link version")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "system_link.provider.0.module=runtime/core_runtime_v2"), "v2 network compile key core provider")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "system_link.provider.1.module=runtime/network_distribution_runtime_v2"), "v2 network compile key network provider")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "system_link.missing_reason.1=system_link_execution_missing"), "v2 network compile key system link blocker")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "network_topology_count=3"), "v2 network compile key topology count")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "network.entry.0.addressing=lsmr_path"), "v2 network compile key addressing")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "network.entry.0.depth=4"), "v2 network compile key depth")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "network.entry.0.address_binding=content_bound_address"), "v2 network compile key address binding")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "network.entry.0.distance_metric=per_level_manhattan"), "v2 network compile key distance metric")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "network.entry.4.dispersal=ida(k=5,n=9)"), "v2 network compile key ida")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "network.entry.6.priority=background"), "v2 network compile key priority")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "network.entry.6.signature=ganzhi_merkle_v1"), "v2 network compile key signature")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "network.entry.1.route_path_count="), "v2 network compile key multipath count")
    assert(rart.releaseArtifactCompileKeyHasLine(networkBundle, "network.entry.1.route.0="), "v2 network compile key multipath path")
    assert(networkBundle.objImageCid != "", "v2 network obj image cid")
    assert(networkBundle.objFileCid != "", "v2 network obj file cid")
    assert(networkBundle.objFileByteCount > 0, "v2 network obj file byte count")
    assert(networkBundle.systemLinkPlanVersion == "v2.system_link_plan.v1", "v2 network system link plan version")
    assert(networkBundle.systemLinkPlanCid != "", "v2 network system link plan cid")
    assert(!networkBundle.systemLinkReady, "v2 network system link honest blocker")
    assert(networkBundle.systemLinkMissingReasonCount == 2, "v2 network system link missing reasons")
    assert(strings.contains(networkBundle.systemLinkPlanText, "provider_module.0.object_materialized=1"), "v2 network provider object materialized")
    assert(networkBundle.objSectionCount >= 4, "v2 network obj section count")
    assert(networkBundle.objRelocCount == networkBundle.networkEntryCount, "v2 network obj reloc count")
    assert(networkBundle.compileKey == ident.sha256HexText(networkBundle.compileKeyText), "v2 network compile key hash")
    return 0
