import std/system
import compiler/frontend/unimaker_surface_contract as usurface
import compiler/frontend/unimaker_surface_ir_v2 as usurf

fn main(): int32 =
    let contract = usurface.unimakerSurfaceContract()
    let program = usurf.sampleUnimakerSurfaceProgram()
    assert(contract.stateModel == "actor_owned_state_plus_crdt_snapshot", "v2 unimaker state model")
    assert(contract.codeIdentity == "source_files_plus_content_addressed_manifest", "v2 unimaker code identity")
    assert(usurface.unimakerDeclarationCount() == 5, "v2 unimaker declaration count")
    assert(usurface.unimakerAnnotationCount() >= 5, "v2 unimaker annotation count")
    assert(usurface.unimakerBuiltinTypeCount() >= 4, "v2 unimaker builtin type count")
    assert(contract.coreDeclarations[3] == "topology", "v2 unimaker topology surface")
    assert(program.decls.len == 5, "v2 unimaker sample decl count")
    assert(program.decls[0].kind == "asset_decl", "v2 unimaker asset decl")
    assert(program.decls[2].annotation == "@ganzhi", "v2 unimaker ganzhi state")
    assert(program.decls[3].annotation == "@nfc_callback", "v2 unimaker nfc callback")
    assert(program.decls[4].annotation == "@evolve", "v2 unimaker evolve decl")
    return 0
