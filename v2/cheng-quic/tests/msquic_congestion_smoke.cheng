# MsQuic congestion smoke test(manual).

import std/result
import cheng/quic/tests/congestion_bridge_test
import cheng/quic/tests/congestion_pacing_test
import cheng/quic/tests/congestion_strategy_test
import cheng/quic/tests/congestion_validation_test
import cheng/quic/tests/test_ack_tracker_model
import cheng/quic/tests/test_flow_control
import cheng/quic/tests/test_loss_detection_model
import cheng/quic/tests/test_newreno
fn runMsQuicCongestionSmoke(): Result[bool] =
    let ackTrackerRes: Result[bool] = runAckTrackerModelTest()
    if IsErr(ackTrackerRes):
        return ackTrackerRes
    let lossRes: Result[bool] = runLossDetectionModelTest()
    if IsErr(lossRes):
        return lossRes
    let flowRes: Result[bool] = runFlowControlTest()
    if IsErr(flowRes):
        return flowRes
    let newrenoRes: Result[bool] = runNewRenoTest()
    if IsErr(newrenoRes):
        return newrenoRes
    let validationRes: Result[bool] = runCongestionValidationTest()
    if IsErr(validationRes):
        return validationRes
    let strategyRes: Result[bool] = runCongestionStrategyTest()
    if IsErr(strategyRes):
        return strategyRes
    let bridgeRes: Result[bool] = runCongestionBridgeTest()
    if IsErr(bridgeRes):
        return bridgeRes
    let pacingRes: Result[bool] = runCongestionPacingTest()
    if IsErr(pacingRes):
        return pacingRes
    return Ok[bool](true)
