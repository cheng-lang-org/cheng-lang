# MsQuic protocol smoke test(manual).

import std/result
import cheng/quic/protocol/protocol_core
import cheng/quic/protocol/tls_core
import cheng/quic/tests/crypto_stream_test
import cheng/quic/tests/connection_handshake_test
import cheng/quic/tests/test_connection_migration
import cheng/quic/tests/key_update_test
fn runMsQuicProtocolSmoke(): Result[bool] =
    var ctx: MsQuicProtocolContext = initMsQuicProtocolContext()
    let startRes: Result[bool] = msquicProtocolStart(ctx)
    if IsErr(startRes):
        return Err[bool](Error(startRes))
    msquicProtocolFinish(ctx, true)
    if ctx.state != MsQuicProtoReady:
        return Err[bool]("smoke: protocol ! ready")
    var session: MsQuicTlsSession = initMsQuicTlsSession()
    let sessStart: Result[bool] = msquicTlsSessionStart(session)
    if IsErr(sessStart):
        return Err[bool](Error(sessStart))
    msquicTlsSessionFinish(session, true)
    let summary: str = msquicTlsSessionSummary(session)
    if len(summary) <= 0:
        return Err[bool]("smoke: protocol summary empty")
    let cryptoRes: Result[bool] = runCryptoStreamTest()
    if IsErr(cryptoRes):
        return cryptoRes
    let connRes: Result[bool] = runConnectionHandshakeTest()
    if IsErr(connRes):
        return connRes
    let keyRes: Result[bool] = runKeyUpdateTest()
    if IsErr(keyRes):
        return keyRes
    let migRes: Result[bool] = runConnectionMigrationTest()
    if IsErr(migRes):
        return migRes
    return Ok[bool](true)
