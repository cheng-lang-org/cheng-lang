# MsQuic TLS smoke test(manual).

import std/result
import cheng/quic/tls/mod
import cheng/quic/tests/tls_handshake_test
import cheng/quic/tests/tls_x509_test
import cheng/quic/tests/tls13_handshake_flow_test
import cheng/quic/tests/tls13_crypto_stream_test
import cheng/quic/tests/tls13_0rtt_test
import cheng/quic/tests/tls_revocation_test
import cheng/quic/tests/test_tls_params
import cheng/quic/tests/tls_security_audit_test
import cheng/quic/tests/tls13_aead_test
fn runMsQuicTlsSmoke(): Result[bool] =
    var bp: MsQuicTlsBlueprint = initMsQuicTlsBlueprint()
    let startRes: Result[bool] = msquicTlsHandshakeStart(bp)
    if IsErr(startRes):
        return Err[bool](Error(startRes))
    msquicTlsHandshakeFinish(bp, true)
    if msquicTlsBlueprintState(bp) != MsQuicTlsReady:
        return Err[bool]("smoke: tls ! ready")
    var cfg: MsQuicTlsConfig = msquicTlsBlueprintConfig(bp)
    cfg.allowInsecure = true
    let audit: MsQuicTlsAudit = msquicTlsAuditConfig(cfg)
    if audit.ok:
        return Err[bool]("smoke: tls audit expected warnings")
    let summary: str = msquicTlsSummary(cfg, bp.stats)
    if len(summary) <= 0:
        return Err[bool]("smoke: tls summary empty")
    let handshakeRes: Result[bool] = runTlsHandshakeTest()
    if IsErr(handshakeRes):
        return Err[bool]("tls_smoke: handshake: " + Error(handshakeRes))
    let x509Res: Result[bool] = runTlsX509Test()
    if IsErr(x509Res):
        return Err[bool]("tls_smoke: x509: " + Error(x509Res))
    let flowRes: Result[bool] = runTls13HandshakeFlowTest()
    if IsErr(flowRes):
        return Err[bool]("tls_smoke: flow: " + Error(flowRes))
    let cryptoRes: Result[bool] = runTls13CryptoStreamTest()
    if IsErr(cryptoRes):
        return Err[bool]("tls_smoke: crypto_stream: " + Error(cryptoRes))
    let zeroRes: Result[bool] = runTls13ZeroRttTest()
    if IsErr(zeroRes):
        return Err[bool]("tls_smoke: zero_rtt: " + Error(zeroRes))
    let revRes: Result[bool] = runTlsRevocationTest()
    if IsErr(revRes):
        return Err[bool]("tls_smoke: revocation: " + Error(revRes))
    let auditRes: Result[bool] = runTlsSecurityAuditTest()
    if IsErr(auditRes):
        return Err[bool]("tls_smoke: security_audit: " + Error(auditRes))
    let paramRes: Result[bool] = runTlsParamTest()
    if IsErr(paramRes):
        return Err[bool]("tls_smoke: params: " + Error(paramRes))
    let aeadRes: Result[bool] = runTls13AeadTest()
    if IsErr(aeadRes):
        return Err[bool]("tls_smoke: aead: " + Error(aeadRes))
    return Ok[bool](true)
