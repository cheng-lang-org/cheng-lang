# MsQuic focused verify runner(fast).

import std/result
import cheng/quic/tests/msquic_transport_smoke
import cheng/quic/tests/msquic_validation_smoke
import cheng/quic/tests/msquic_api_smoke
import cheng/quic/tests/msquic_platform_smoke
import cheng/quic/tests/msquic_tls_smoke
import cheng/quic/tests/msquic_protocol_smoke
import cheng/quic/tests/msquic_congestion_smoke
import cheng/quic/tests/msquic_driver_smoke
fn runMsQuicVerify(): Result[bool] =
    echo("[msquic] verify: transport smoke")
    let transportRes: Result[bool] = runMsQuicTransportSmoke()
    if ! transportRes.ok:
        return transportRes
    echo("[msquic] verify: validation smoke")
    let validationRes: Result[bool] = runMsQuicValidationSmoke()
    if ! validationRes.ok:
        return validationRes
    echo("[msquic] verify: api smoke")
    let apiRes: Result[bool] = runMsQuicApiSmoke()
    if ! apiRes.ok:
        return apiRes
    echo("[msquic] verify: platform smoke")
    let platformRes: Result[bool] = runMsQuicPlatformSmoke()
    if ! platformRes.ok:
        return platformRes
    echo("[msquic] verify: tls smoke")
    let tlsRes: Result[bool] = runMsQuicTlsSmoke()
    if ! tlsRes.ok:
        return tlsRes
    echo("[msquic] verify: protocol smoke")
    let protocolRes: Result[bool] = runMsQuicProtocolSmoke()
    if ! protocolRes.ok:
        return protocolRes
    echo("[msquic] verify: congestion smoke")
    let congestionRes: Result[bool] = runMsQuicCongestionSmoke()
    if ! congestionRes.ok:
        return congestionRes
    echo("[msquic] verify: driver smoke")
    let driverRes: Result[bool] = runMsQuicDriverSmoke()
    if ! driverRes.ok:
        return driverRes
    return Ok[bool](true)

fn main(): int32 =
    echo("[msquic] verify runner start")
    let res: Result[bool] = runMsQuicVerify()
    if ! res.ok:
        echo("msquic verify failed")
        echo(Error(res))
        return 1
    echo("msquic verify ok")
    return 0
