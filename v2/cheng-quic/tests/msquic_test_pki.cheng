# MsQuic transport test PKI bridge.

import std/result
import cheng/quic/msquictransport_full
import cheng/quic/tls/test_pki

fn msquicTestConfigureTransportTls(t: var MsQuicTransport): Result[bool] =
    let policyRes = msquicMakeLocalhostTlsPolicy()
    if IsErr(policyRes):
        return Err[bool](Error(policyRes))
    return setMsQuicTransportTlsPolicy(t, Value(policyRes))
