# MsQuic API smoke test(manual).

import std/result
import cheng/quic/api/mod
import cheng/quic/tests/api_ffi_loader_test
import cheng/quic/tests/api_ffi_test
import cheng/quic/tests/api_hotpath_bench
import cheng/quic/tests/api_hotpath_test
import cheng/quic/tests/api_platform_bridge_test
import cheng/quic/tests/api_release_docs_test
import cheng/quic/tests/api_runtime_bridge_test
import cheng/quic/tests/api_tls_bridge_test
import cheng/quic/tests/test_api_settings
import cheng/quic/tests/test_api_events
import cheng/quic/tests/test_api_params
import cheng/quic/tests/test_conn_stream_params
import cheng/quic/tests/test_listener_config_params
fn runMsQuicApiSmoke(): Result[bool] =
    var api: MsQuicApi = initMsQuicApi()
    var settings: MsQuicSettings = msquicApiSettings(api)
    let setRes: Result[bool] = msquicSettingsSetMaxDatagram(settings, 1400)
    if IsErr(setRes):
        return Err[bool](Error(setRes))
    let applyRes: Result[bool] = msquicApiSetSettings(api, settings)
    if IsErr(applyRes):
        return Err[bool](Error(applyRes))
    msquicApiConnOpened(api, 1)
    msquicApiStreamOpened(api, 1, 10)
    msquicApiRecordSend(api, 1, 64)
    msquicApiRecordRecv(api, 1, 32)
    msquicApiStreamClosed(api, 1, 10)
    msquicApiConnClosed(api, 1)
    let diag: MsQuicDiagnostics = msquicApiDiagnostics(api)
    if diag.count <= 0:
        return Err[bool]("smoke: msquic diagnostics missing")
    if msquicApiEventCount(api) <= 0:
        return Err[bool]("smoke: msquic events missing")
    let notes: str = msquicApiReleaseNotes()
    if len(notes) <= 0:
        return Err[bool]("smoke: msquic release notes empty")
    let settingsRes: Result[bool] = runApiSettingsTest()
    if IsErr(settingsRes):
        return settingsRes
    let listenerRes: Result[bool] = runListenerConfigParamTest()
    if IsErr(listenerRes):
        return listenerRes
    let connRes: Result[bool] = runConnStreamParamTest()
    if IsErr(connRes):
        return connRes
    let eventsRes: Result[bool] = runApiEventsTest()
    if IsErr(eventsRes):
        return eventsRes
    let hotpathRes: Result[bool] = runApiHotpathTest()
    if IsErr(hotpathRes):
        return hotpathRes
    let benchRes: Result[bool] = runApiHotpathBench()
    if IsErr(benchRes):
        return benchRes
    let runtimeRes: Result[bool] = runApiRuntimeBridgeTest()
    if IsErr(runtimeRes):
        return runtimeRes
    let ffiLoaderRes: Result[bool] = runApiFfiLoaderTest()
    if IsErr(ffiLoaderRes):
        return ffiLoaderRes
    let ffiRes: Result[bool] = runApiFfiTest()
    if IsErr(ffiRes):
        return ffiRes
    let releaseRes: Result[bool] = runApiReleaseDocsTest()
    if IsErr(releaseRes):
        return releaseRes
    let platformRes: Result[bool] = runApiPlatformBridgeTest()
    if IsErr(platformRes):
        return platformRes
    let tlsBridgeRes: Result[bool] = runApiTlsBridgeTest()
    if IsErr(tlsBridgeRes):
        return tlsBridgeRes
    let paramsRes: Result[bool] = runApiParamsTest()
    if IsErr(paramsRes):
        return paramsRes
    return Ok[bool](true)
