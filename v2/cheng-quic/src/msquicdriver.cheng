# MsQuic driver(pure Cheng, in-process).

import std/result
import cheng/quic/msquicruntime
type
    MsQuicDriver =
        runtime: MsQuicRuntime
        started: bool
        lastError: str

fn initMsQuicDriver(): MsQuicDriver =
    MsQuicDriver(
        runtime: initMsQuicRuntime(),
        started: false,
        lastError: ""
    )

fn msquicDriverSettings(d: var MsQuicDriver): MsQuicSettings =
    msquicRuntimeSettings(d.runtime)

fn setMsQuicDriverSettings(d: var MsQuicDriver, settings: MsQuicSettings): Result[bool] =
    let setRes: Result[bool] = setMsQuicRuntimeSettings(d.runtime, settings)
    if IsErr(setRes):
        d.lastError = Error(setRes)
        return Err[bool](d.lastError)
    d.lastError = ""
    return Ok[bool](true)

fn msquicDriverLastError(d: MsQuicDriver): str =
    d.lastError

fn startMsQuicDriver(d: var MsQuicDriver): Result[bool] =
    if d.started:
        return Ok[bool](true)
    d.started = true
    return Ok[bool](true)

fn stopMsQuicDriver(d: var MsQuicDriver) =
    d.started = false

fn msquicDriverRunning(d: MsQuicDriver): bool =
    d.started

fn msquicDriverAllocConnectionId(d: var MsQuicDriver): int64 =
    return msquicAllocConnectionId(d.runtime)
