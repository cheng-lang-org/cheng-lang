# Local MultiAddress implementation for Cheng-QUIC.
#
# This module intentionally avoids std/multiformats/multiaddress so ZRPC
# no-pointer std policy does not pull non-exempt std crypto chains.

import std/result
import std/strings as ustrings
import std/rawbytes

type
    Protocol =
        name: str
        code: int64
        size: int32 # bytes; 0 = no value, -1 = length-prefixed text

    MultiAddress =
        raw: str
        data: Bytes

    SegmentRead =
        seg: str
        next: int32

    HostPortPair =
        host: str
        port: str

const
    quicAddrTagMagic = 0x51
    quicAddrKindUnknown = 0
    quicAddrKindMsQuic = 1
    quicAddrKindQuic = 2
    quicAddrKindQuicTls = 3

var
    protoIp4: Protocol = Protocol(name: "ip4", code: 0x04, size: 4)
    protoIp6: Protocol = Protocol(name: "ip6", code: 0x29, size: 16)
    protoIp6Zone: Protocol = Protocol(name: "ip6zone", code: 0x2A, size: -1)
    protoDccp: Protocol = Protocol(name: "dccp", code: 0x21, size: 2)
    protoSctp: Protocol = Protocol(name: "sctp", code: 0x84, size: 2)
    protoUdt: Protocol = Protocol(name: "udt", code: 0x012D, size: 0)
    protoUtp: Protocol = Protocol(name: "utp", code: 0x012E, size: 0)
    protoTcp: Protocol = Protocol(name: "tcp", code: 0x06, size: 2)
    protoUdp: Protocol = Protocol(name: "udp", code: 0x0111, size: 2)
    protoDns: Protocol = Protocol(name: "dns", code: 0x35, size: -1)
    protoDns4: Protocol = Protocol(name: "dns4", code: 0x36, size: -1)
    protoDns6: Protocol = Protocol(name: "dns6", code: 0x37, size: -1)
    protoDnsAddr: Protocol = Protocol(name: "dnsaddr", code: 0x38, size: -1)
    protoUnix: Protocol = Protocol(name: "unix", code: 0x0190, size: -1)
    protoHttp: Protocol = Protocol(name: "http", code: 0x01E0, size: 0)
    protoHttps: Protocol = Protocol(name: "https", code: 0x01BB, size: 0)
    protoTls: Protocol = Protocol(name: "tls", code: 0x01C0, size: 0)
    protoQuic: Protocol = Protocol(name: "quic", code: 0x01CC, size: 0)
    protoQuicV1: Protocol = Protocol(name: "quic-v1", code: 0x01CD, size: 0)
    protoWebtransport: Protocol = Protocol(name: "webtransport", code: 0x01D1, size: 0)
    protoCerthash: Protocol = Protocol(name: "certhash", code: 0x01D2, size: -1)
    protoWs: Protocol = Protocol(name: "ws", code: 0x01DD, size: 0)
    protoWss: Protocol = Protocol(name: "wss", code: 0x01DE, size: 0)
    protoP2pCircuit: Protocol = Protocol(name: "p2p-circuit", code: 0x0122, size: 0)
    protoP2pWebsocketStar: Protocol = Protocol(name: "p2p-websocket-star", code: 0x01DF, size: 0)
    protoP2pWebrtcStar: Protocol = Protocol(name: "p2p-webrtc-star", code: 0x0113, size: 0)
    protoP2pWebrtcDirect: Protocol = Protocol(name: "p2p-webrtc-direct", code: 0x0114, size: 0)
    protoWebrtcDirect: Protocol = Protocol(name: "webrtc-direct", code: 0x0118, size: 0)
    protoOnion: Protocol = Protocol(name: "onion", code: 0x01BC, size: -1)
    protoOnion3: Protocol = Protocol(name: "onion3", code: 0x01BD, size: -1)
    protoIpfs: Protocol = Protocol(name: "ipfs", code: 0xE3, size: -1)
    protoP2p: Protocol = Protocol(name: "p2p", code: 0x01A5, size: -1)

fn memoryProtocol(): Protocol =
    return Protocol(name: "memory", code: 0x0309, size: -1)

fn protoByName(name: str): Result[Protocol] =
    if name == "ip4": return Ok[Protocol](Protocol(name: "ip4", code: 0x04, size: 4))
    if name == "ip6": return Ok[Protocol](Protocol(name: "ip6", code: 0x29, size: 16))
    if name == "ip6zone": return Ok[Protocol](Protocol(name: "ip6zone", code: 0x2A, size: -1))
    if name == "dccp": return Ok[Protocol](Protocol(name: "dccp", code: 0x21, size: 2))
    if name == "sctp": return Ok[Protocol](Protocol(name: "sctp", code: 0x84, size: 2))
    if name == "udt": return Ok[Protocol](Protocol(name: "udt", code: 0x012D, size: 0))
    if name == "utp": return Ok[Protocol](Protocol(name: "utp", code: 0x012E, size: 0))
    if name == "tcp": return Ok[Protocol](Protocol(name: "tcp", code: 0x06, size: 2))
    if name == "udp": return Ok[Protocol](Protocol(name: "udp", code: 0x0111, size: 2))
    if name == "dns": return Ok[Protocol](Protocol(name: "dns", code: 0x35, size: -1))
    if name == "dns4": return Ok[Protocol](Protocol(name: "dns4", code: 0x36, size: -1))
    if name == "dns6": return Ok[Protocol](Protocol(name: "dns6", code: 0x37, size: -1))
    if name == "dnsaddr": return Ok[Protocol](Protocol(name: "dnsaddr", code: 0x38, size: -1))
    if name == "unix": return Ok[Protocol](Protocol(name: "unix", code: 0x0190, size: -1))
    if name == "http": return Ok[Protocol](Protocol(name: "http", code: 0x01E0, size: 0))
    if name == "https": return Ok[Protocol](Protocol(name: "https", code: 0x01BB, size: 0))
    if name == "tls": return Ok[Protocol](Protocol(name: "tls", code: 0x01C0, size: 0))
    if name == "quic": return Ok[Protocol](Protocol(name: "quic", code: 0x01CC, size: 0))
    if name == "quic-v1": return Ok[Protocol](Protocol(name: "quic-v1", code: 0x01CD, size: 0))
    if name == "webtransport": return Ok[Protocol](Protocol(name: "webtransport", code: 0x01D1, size: 0))
    if name == "certhash": return Ok[Protocol](Protocol(name: "certhash", code: 0x01D2, size: -1))
    if name == "ws": return Ok[Protocol](Protocol(name: "ws", code: 0x01DD, size: 0))
    if name == "wss": return Ok[Protocol](Protocol(name: "wss", code: 0x01DE, size: 0))
    if name == "p2p-circuit": return Ok[Protocol](Protocol(name: "p2p-circuit", code: 0x0122, size: 0))
    if name == "p2p-websocket-star": return Ok[Protocol](Protocol(name: "p2p-websocket-star", code: 0x01DF, size: 0))
    if name == "p2p-webrtc-star": return Ok[Protocol](Protocol(name: "p2p-webrtc-star", code: 0x0113, size: 0))
    if name == "p2p-webrtc-direct": return Ok[Protocol](Protocol(name: "p2p-webrtc-direct", code: 0x0114, size: 0))
    if name == "webrtc-direct": return Ok[Protocol](Protocol(name: "webrtc-direct", code: 0x0118, size: 0))
    if name == "onion": return Ok[Protocol](Protocol(name: "onion", code: 0x01BC, size: -1))
    if name == "onion3": return Ok[Protocol](Protocol(name: "onion3", code: 0x01BD, size: -1))
    if name == "ipfs": return Ok[Protocol](Protocol(name: "ipfs", code: 0xE3, size: -1))
    if name == "p2p": return Ok[Protocol](Protocol(name: "p2p", code: 0x01A5, size: -1))
    if name == "memory": return Ok[Protocol](memoryProtocol())
    return Err[Protocol]("multiaddress: unknown protocol")

fn protoByCode(code: int64): Result[Protocol] =
    if code == 0x04: return Ok[Protocol](Protocol(name: "ip4", code: 0x04, size: 4))
    if code == 0x29: return Ok[Protocol](Protocol(name: "ip6", code: 0x29, size: 16))
    if code == 0x2A: return Ok[Protocol](Protocol(name: "ip6zone", code: 0x2A, size: -1))
    if code == 0x21: return Ok[Protocol](Protocol(name: "dccp", code: 0x21, size: 2))
    if code == 0x84: return Ok[Protocol](Protocol(name: "sctp", code: 0x84, size: 2))
    if code == 0x012D: return Ok[Protocol](Protocol(name: "udt", code: 0x012D, size: 0))
    if code == 0x012E: return Ok[Protocol](Protocol(name: "utp", code: 0x012E, size: 0))
    if code == 0x06: return Ok[Protocol](Protocol(name: "tcp", code: 0x06, size: 2))
    if code == 0x0111: return Ok[Protocol](Protocol(name: "udp", code: 0x0111, size: 2))
    if code == 0x35: return Ok[Protocol](Protocol(name: "dns", code: 0x35, size: -1))
    if code == 0x36: return Ok[Protocol](Protocol(name: "dns4", code: 0x36, size: -1))
    if code == 0x37: return Ok[Protocol](Protocol(name: "dns6", code: 0x37, size: -1))
    if code == 0x38: return Ok[Protocol](Protocol(name: "dnsaddr", code: 0x38, size: -1))
    if code == 0x0190: return Ok[Protocol](Protocol(name: "unix", code: 0x0190, size: -1))
    if code == 0x01E0: return Ok[Protocol](Protocol(name: "http", code: 0x01E0, size: 0))
    if code == 0x01BB: return Ok[Protocol](Protocol(name: "https", code: 0x01BB, size: 0))
    if code == 0x01C0: return Ok[Protocol](Protocol(name: "tls", code: 0x01C0, size: 0))
    if code == 0x01CC: return Ok[Protocol](Protocol(name: "quic", code: 0x01CC, size: 0))
    if code == 0x01CD: return Ok[Protocol](Protocol(name: "quic-v1", code: 0x01CD, size: 0))
    if code == 0x01D1: return Ok[Protocol](Protocol(name: "webtransport", code: 0x01D1, size: 0))
    if code == 0x01D2: return Ok[Protocol](Protocol(name: "certhash", code: 0x01D2, size: -1))
    if code == 0x01DD: return Ok[Protocol](Protocol(name: "ws", code: 0x01DD, size: 0))
    if code == 0x01DE: return Ok[Protocol](Protocol(name: "wss", code: 0x01DE, size: 0))
    if code == 0x0122: return Ok[Protocol](Protocol(name: "p2p-circuit", code: 0x0122, size: 0))
    if code == 0x01DF: return Ok[Protocol](Protocol(name: "p2p-websocket-star", code: 0x01DF, size: 0))
    if code == 0x0113: return Ok[Protocol](Protocol(name: "p2p-webrtc-star", code: 0x0113, size: 0))
    if code == 0x0114: return Ok[Protocol](Protocol(name: "p2p-webrtc-direct", code: 0x0114, size: 0))
    if code == 0x0118: return Ok[Protocol](Protocol(name: "webrtc-direct", code: 0x0118, size: 0))
    if code == 0x01BC: return Ok[Protocol](Protocol(name: "onion", code: 0x01BC, size: -1))
    if code == 0x01BD: return Ok[Protocol](Protocol(name: "onion3", code: 0x01BD, size: -1))
    if code == 0xE3: return Ok[Protocol](Protocol(name: "ipfs", code: 0xE3, size: -1))
    if code == 0x01A5: return Ok[Protocol](Protocol(name: "p2p", code: 0x01A5, size: -1))
    if code == 0x0309: return Ok[Protocol](memoryProtocol())
    return Err[Protocol]("multiaddress: unknown protocol")

fn readSegment(text: str, start: int32): Result[SegmentRead] =
    if start >= len(text):
        return Err[SegmentRead]("multiaddress: trailing slash")
    var i: int32 = start
    while i < len(text) && text[i] != '/':
        i = i + 1
    let seg: str = ustrings.sliceBytes(text, start, i - start)
    let next: int32 = if i < len(text) && text[i] == '/': i + 1 else: i
    var out: SegmentRead
    out.seg = seg
    out.next = next
    return Ok[SegmentRead](out)

fn parseUIntRange(text: str, start: int32, count: int32): Result[int32] =
    if count <= 0:
        return Err[int32]("multiaddress: empty number")
    var value: int32 = 0
    for i in 0..<count:
        let c: char = text[start + i]
        if c < '0' || c > '9':
            return Err[int32]("multiaddress: invalid number")
        value = value * 10 + (int32(c) - int32('0'))
    return Ok[int32](value)

fn parsePort(text: str): Result[Bytes] =
    let valueRes: Result[int32] = parseUIntRange(text, 0, len(text))
    if IsErr(valueRes):
        return Err[Bytes](ErrorText(valueRes))
    let value: int32 = Value(valueRes)
    if value < 0 || value > 65535:
        return Err[Bytes]("multiaddress: invalid port")
    var out: Bytes = bytesAlloc(2)
    bytesSet(out, 0, (value >> 8) & 255)
    bytesSet(out, 1, value & 255)
    return Ok[Bytes](out)

fn parseIPv4(text: str): Result[Bytes] =
    var out: Bytes = bytesAlloc(4)
    var start: int32 = 0
    var parts: int32 = 0
    for i in 0..len(text):
        if i == len(text) || text[i] == '.':
            let count: int32 = i - start
            let partRes: Result[int32] = parseUIntRange(text, start, count)
            if IsErr(partRes):
                return Err[Bytes](ErrorText(partRes))
            let value: int32 = Value(partRes)
            if value < 0 || value > 255:
                return Err[Bytes]("multiaddress: ip4 out of range")
            if parts >= 4:
                return Err[Bytes]("multiaddress: ip4 parts")
            bytesSet(out, parts, value)
            parts = parts + 1
            start = i + 1
    if parts != 4:
        return Err[Bytes]("multiaddress: ip4 parts")
    return Ok[Bytes](out)

fn hexValue(c: char): int32 =
    if c >= '0' && c <= '9':
        return int32(c) - int32('0')
    if c >= 'a' && c <= 'f':
        return 10 + (int32(c) - int32('a'))
    if c >= 'A' && c <= 'F':
        return 10 + (int32(c) - int32('A'))
    return -1

fn parseHexSegment(text: str, start: int32, count: int32): Result[int32] =
    if count <= 0 || count > 4:
        return Err[int32]("multiaddress: ip6 part length")
    var value: int32 = 0
    for i in 0..<count:
        let v: int32 = hexValue(text[start + i])
        if v < 0:
            return Err[int32]("multiaddress: ip6 invalid hex")
        value = (value << 4) + v
    return Ok[int32](value)

fn quicWriteHextet(buf: var Bytes, idx: int32, value: int32) =
    bytesSet(buf, idx * 2, (value >> 8) & 255)
    bytesSet(buf, idx * 2 + 1, value & 255)

fn parseIPv6(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Err[Bytes]("multiaddress: ip6 empty")
    var head: Bytes = bytesAlloc(16)
    var tail: Bytes = bytesAlloc(16)
    var headCount: int32 = 0
    var tailCount: int32 = 0
    var seenCompress: bool = false
    var i: int32 = 0
    var segmentStart: int32 = 0
    while i <= len(text):
        let atEnd: bool = i == len(text)
        let isColon: bool = (! atEnd) && text[i] == ':'
        if atEnd || isColon:
            if i == segmentStart:
                if isColon && i + 1 < len(text) && text[i + 1] == ':':
                    if seenCompress:
                        return Err[Bytes]("multiaddress: ip6 multiple ::")
                    seenCompress = true
                    i = i + 1
                    segmentStart = i + 1
                else:
                    if atEnd && seenCompress:
                        break
                    return Err[Bytes]("multiaddress: ip6 empty part")
            else:
                let partRes: Result[int32] = parseHexSegment(text, segmentStart, i - segmentStart)
                if IsErr(partRes):
                    return Err[Bytes](ErrorText(partRes))
                let value: int32 = Value(partRes)
                if ! seenCompress:
                    if headCount >= 8:
                        return Err[Bytes]("multiaddress: ip6 parts")
                    quicWriteHextet(head, headCount, value)
                    headCount = headCount + 1
                else:
                    if tailCount >= 8:
                        return Err[Bytes]("multiaddress: ip6 parts")
                    quicWriteHextet(tail, tailCount, value)
                    tailCount = tailCount + 1
                if isColon && i + 1 < len(text) && text[i + 1] == ':':
                    if seenCompress:
                        return Err[Bytes]("multiaddress: ip6 multiple ::")
                    seenCompress = true
                    i = i + 1
                segmentStart = i + 1
        i = i + 1
    if ! seenCompress:
        if headCount != 8:
            return Err[Bytes]("multiaddress: ip6 parts")
        return Ok[Bytes](head)
    if headCount + tailCount > 8:
        return Err[Bytes]("multiaddress: ip6 parts")
    var out: Bytes = bytesAlloc(16)
    for j in 0..<headCount:
        bytesSet(out, j * 2, bytesGet(head, j * 2))
        bytesSet(out, j * 2 + 1, bytesGet(head, j * 2 + 1))
    let zeros: int32 = 8 - headCount - tailCount
    for k in 0..<tailCount:
        let outIdx: int32 = headCount + zeros + k
        bytesSet(out, outIdx * 2, bytesGet(tail, k * 2))
        bytesSet(out, outIdx * 2 + 1, bytesGet(tail, k * 2 + 1))
    return Ok[Bytes](out)

fn splitHostPort(text: str): Result[HostPortPair] =
    if len(text) <= 0:
        return Err[HostPortPair]("multiaddress: empty host:port")
    if text[0] == '[':
        var close: int32 = 1
        while close < len(text) && text[close] != ']':
            close = close + 1
        if close >= len(text) || close + 1 >= len(text) || text[close + 1] != ':':
            return Err[HostPortPair]("multiaddress: invalid ipv6 host:port")
        var out: HostPortPair
        out.host = ustrings.sliceBytes(text, 1, close - 1)
        out.port = ustrings.sliceBytes(text, close + 2, len(text) - (close + 2))
        return Ok[HostPortPair](out)
    var colon: int32 = -1
    for i in 0..<len(text):
        if text[i] == ':':
            colon = i
    if colon <= 0 || colon >= len(text) - 1:
        return Err[HostPortPair]("multiaddress: invalid host:port")
    var out2: HostPortPair
    out2.host = ustrings.sliceBytes(text, 0, colon)
    out2.port = ustrings.sliceBytes(text, colon + 1, len(text) - (colon + 1))
    return Ok[HostPortPair](out2)

fn parseProtocolValue(proto: Protocol, value: str): Result[Bytes] =
    if proto.code == 0x04:
        return parseIPv4(value)
    if proto.code == 0x29:
        return parseIPv6(value)
    if proto.code == 0x06 || proto.code == 0x0111 ||
       proto.code == 0x21 || proto.code == 0x84:
        return parsePort(value)
    if len(value) <= 0:
        return Err[Bytes]("multiaddress: empty value")
    return Ok[Bytes](bytesFromString(value))

fn parseMultiAddress(text: str): Result[MultiAddress] =
    if len(text) <= 0:
        return Err[MultiAddress]("multiaddress: empty")
    if text[0] != '/':
        return Err[MultiAddress]("multiaddress: must start with '/'")
    var idx: int32 = 1
    while idx < len(text):
        let segRes: Result[SegmentRead] = readSegment(text, idx)
        if IsErr(segRes):
            return Err[MultiAddress](ErrorText(segRes))
        let seg: SegmentRead = Value(segRes)
        let protoRes: Result[Protocol] = protoByName(seg.seg)
        if IsErr(protoRes):
            return Err[MultiAddress](ErrorText(protoRes))
        let proto: Protocol = Value(protoRes)
        idx = seg.next
        if proto.size == 0:
            continue
        if idx >= len(text):
            return Err[MultiAddress]("multiaddress: missing value")
        let valSegRes: Result[SegmentRead] = readSegment(text, idx)
        if IsErr(valSegRes):
            return Err[MultiAddress](ErrorText(valSegRes))
        let valSeg: SegmentRead = Value(valSegRes)
        let valueBytesRes: Result[Bytes] = parseProtocolValue(proto, valSeg.seg)
        if IsErr(valueBytesRes):
            return Err[MultiAddress](ErrorText(valueBytesRes))
        let valueBytes: Bytes = Value(valueBytesRes)
        if proto.size > 0 && bytesLen(valueBytes) != proto.size:
            return Err[MultiAddress]("multiaddress: size mismatch")
        idx = valSeg.next
    var out: MultiAddress
    out.raw = text
    out.data = bytesFromString(text)
    return Ok[MultiAddress](out)

fn parseMultiAddressBytes(data: Bytes): Result[MultiAddress] =
    if bytesLen(data) <= 0:
        return Err[MultiAddress]("multiaddress: empty")
    let text: str = bytesToString(data)
    let parsedRes: Result[MultiAddress] = parseMultiAddress(text)
    if IsErr(parsedRes):
        return Err[MultiAddress](ErrorText(parsedRes))
    var out: MultiAddress = Value(parsedRes)
    out.data = data
    return Ok[MultiAddress](out)

fn quicMultiAddressToString(addr: MultiAddress): str =
    if len(addr.raw) > 0:
        return addr.raw
    if bytesLen(addr.data) > 0:
        return bytesToString(addr.data)
    return ""

fn quicMultiAddressToBytes(addr: MultiAddress): Bytes =
    if bytesLen(addr.data) > 0:
        return addr.data
    if len(addr.raw) <= 0:
        return emptyBytes()
    return bytesFromString(addr.raw)

fn makeInprocMultiAddress(kind: int32, port: int32): MultiAddress =
    var safeKind: int32 = kind
    if safeKind < quicAddrKindMsQuic || safeKind > quicAddrKindQuicTls:
        safeKind = quicAddrKindMsQuic
    var safePort: int32 = port
    if safePort < 0:
        safePort = 0
    if safePort > 65535:
        safePort = 65535
    var out: MultiAddress
    out.raw = ""
    out.data = bytesAlloc(4)
    bytesSet(out.data, 0, quicAddrTagMagic)
    bytesSet(out.data, 1, safeKind)
    bytesSet(out.data, 2, (safePort >> 8) & 0xff)
    bytesSet(out.data, 3, safePort & 0xff)
    return out

fn bytesContains(haystack: Bytes, needle: Bytes): bool =
    let hayLen: int32 = bytesLen(haystack)
    let needleLen: int32 = bytesLen(needle)
    if hayLen <= 0 || needleLen <= 0 || needleLen > hayLen:
        return false
    for i in 0..<(hayLen - needleLen + 1):
        var same: bool = true
        for j in 0..<needleLen:
            if bytesGet(haystack, i + j) != bytesGet(needle, j):
                same = false
                break
        if same:
            return true
    return false

fn quicMultiAddressKind(addr: MultiAddress): int32 =
    if bytesLen(addr.data) >= 2 && bytesGet(addr.data, 0) == quicAddrTagMagic:
        return bytesGet(addr.data, 1)
    let data: Bytes = quicMultiAddressToBytes(addr)
    if bytesContains(data, bytesFromString("/quic-v1/tls")):
        return quicAddrKindQuicTls
    if bytesContains(data, bytesFromString("/quic-v1")):
        return quicAddrKindMsQuic
    if bytesContains(data, bytesFromString("/quic")):
        return quicAddrKindQuic
    return quicAddrKindUnknown

fn quicMultiAddressPort(addr: MultiAddress): int32 =
    if bytesLen(addr.data) >= 4 && bytesGet(addr.data, 0) == quicAddrTagMagic:
        return (bytesGet(addr.data, 2) << 8) | bytesGet(addr.data, 3)
    return 0
