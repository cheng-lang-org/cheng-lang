import std/system
import std/result
import std/rawbytes
import std/seqs as seqops
import std/strings
import std/strutils as strutils
import cheng/quic/chain/types
import cheng/quic/chain/content_address
import cheng/quic/chain/lsmr

fn chainDispersalFieldMod(value: int32): int32 =
    var out = value % 257
    if out < 0:
        out = out + 257
    return out

fn chainDispersalFieldMul(a: int32, b: int32): int32 =
    return chainDispersalFieldMod(a * b)

fn chainDispersalFieldPow(base: int32, exponent: int32): int32 =
    var out: int32 = 1
    for i in 0..<exponent:
        out = chainDispersalFieldMul(out, base)
    return out

fn chainDispersalFieldInv(value: int32): int32 =
    if chainDispersalFieldMod(value) == 0:
        panic("chain dispersal: zero has no inverse")
    return chainDispersalFieldPow(chainDispersalFieldMod(value), 255)

fn chainDispersalListText(values: int32[]): str =
    var out: str = ""
    for i in 0..<values.len:
        if i > 0:
            out = out + ","
        out = out + intToStr(values[i])
    return out

fn chainDispersalParseNonNegativeInt32(text: str): Result[int32] =
    let trimmed = strutils.strip(text)
    if strings.len(trimmed) == 0:
        return Err[int32]("chain dispersal: invalid fragment value")
    var value: int32 = 0
    for i in 0..<strings.len(trimmed):
        let ch = trimmed[i]
        if ch < '0' || ch > '9':
            return Err[int32]("chain dispersal: invalid fragment value")
        value = value * 10 + (int32(ch) - int32('0'))
    return Ok[int32](value)

fn chainDispersalParseValueText(text: str): Result[int32[]] =
    var out: int32[] = []
    if strings.len(text) == 0:
        return Ok(out)
    let parts = strutils.split(text, ',')
    for i in 0..<parts.len:
        let valueRes = chainDispersalParseNonNegativeInt32(parts[i])
        if IsErr(valueRes):
            return Err(ErrorText(valueRes))
        let value = Value(valueRes)
        if value < 0 || value > 256:
            return Err("chain dispersal: fragment value out of field range")
        seqops.add(out, value)
    return Ok(out)

fn chainDispersalVandermondeValue(x: int32, column: int32): int32 =
    return chainDispersalFieldPow(x, column)

fn chainDispersalPlanCanonicalText(plan: ChainDispersalPlan): str =
    var out: str = ""
    out = out + "version=" + plan.version + "\n"
    out = out + "payload_cid=" + plan.payloadCid + "\n"
    out = out + "payload_len=" + intToStr(plan.payloadLen) + "\n"
    out = out + "data_shard_count=" + intToStr(plan.dataShardCount) + "\n"
    out = out + "total_shard_count=" + intToStr(plan.totalShardCount) + "\n"
    for i in 0..<plan.fragmentDigits.len:
        out = out + "fragment." + intToStr(i) + ".digit=" + intToStr(plan.fragmentDigits[i]) + "\n"
        out = out + "fragment." + intToStr(i) + ".x=" + intToStr(plan.fragmentXValues[i]) + "\n"
        out = out + "fragment." + intToStr(i) + ".values=" + plan.fragmentValueTexts[i] + "\n"
    return out

fn chainDispersalPlanCid(plan: ChainDispersalPlan): str =
    return chainCidFromText(chainDispersalPlanCanonicalText(plan))

fn chainDispersalFragmentPos(plan: ChainDispersalPlan, digit: int32): int32 =
    for i in 0..<plan.fragmentDigits.len:
        if plan.fragmentDigits[i] == digit:
            return i
    return -1

fn chainDispersalUniqueShardPoses(plan: ChainDispersalPlan, needCount: int32): Result[int32[]] =
    var out: int32[]
    var seenXValues: int32[]
    out = []
    seenXValues = []
    for i in 0..<plan.fragmentXValues.len:
        if strings.len(plan.fragmentValueTexts[i]) == 0:
            continue
        var duplicate = false
        for j in 0..<seenXValues.len:
            if seenXValues[j] == plan.fragmentXValues[i]:
                duplicate = true
                break
        if duplicate:
            continue
        seqops.add(seenXValues, plan.fragmentXValues[i])
        seqops.add(out, i)
        if out.len >= needCount:
            return Ok(out)
    return Err("chain dispersal: insufficient unique fragments")

fn chainDispersalSolveCoefficients(xs: int32[], ys: int32[]): Result[int32[]] =
    let k = xs.len
    if k == 0 || ys.len != k:
        return Err("chain dispersal: invalid linear system")
    let cols = k + 1
    var aug: int32[]
    aug = []
    for row in 0..<k:
        for col in 0..<k:
            seqops.add(aug, chainDispersalVandermondeValue(xs[row], col))
        seqops.add(aug, chainDispersalFieldMod(ys[row]))
    for pivotCol in 0..<k:
        var pivotRow = -1
        for row in pivotCol..<k:
            if aug[row * cols + pivotCol] != 0:
                pivotRow = row
                break
        if pivotRow < 0:
            return Err("chain dispersal: singular shard matrix")
        if pivotRow != pivotCol:
            for col in 0..<cols:
                let swapIdx = pivotCol * cols + col
                let pivotIdx = pivotRow * cols + col
                let tmp = aug[swapIdx]
                aug[swapIdx] = aug[pivotIdx]
                aug[pivotIdx] = tmp
        let pivotInv = chainDispersalFieldInv(aug[pivotCol * cols + pivotCol])
        for col in pivotCol..<cols:
            aug[pivotCol * cols + col] = chainDispersalFieldMul(aug[pivotCol * cols + col], pivotInv)
        for row in 0..<k:
            if row == pivotCol:
                continue
            let factor = aug[row * cols + pivotCol]
            if factor == 0:
                continue
            for col in pivotCol..<cols:
                aug[row * cols + col] = chainDispersalFieldMod(
                    aug[row * cols + col] - chainDispersalFieldMul(factor, aug[pivotCol * cols + col]))
    var out: int32[] = []
    for row in 0..<k:
        seqops.add(out, chainDispersalFieldMod(aug[row * cols + k]))
    return Ok(out)

fn chainDisperseText(text: str, dataShardCount: int32, totalShardCount: int32): Result[ChainDispersalPlan] =
    if dataShardCount <= 0 || totalShardCount < dataShardCount:
        return Err[ChainDispersalPlan]("chain dispersal: invalid shard counts")
    let payload = bytesFromString(text)
    let payloadLen = bytesLen(payload)
    let blockCount = payloadLen == 0 ? 0 : (payloadLen + dataShardCount - 1) / dataShardCount
    var fragmentValues: str[]
    fragmentValues = []
    for shardIdx in 0..<totalShardCount:
        seqops.add(fragmentValues, "")
    for blockIdx in 0..<blockCount:
        for shardIdx in 0..<totalShardCount:
            let x = shardIdx + 1
            var value: int32 = 0
            for coeffIdx in 0..<dataShardCount:
                let payloadPos = blockIdx * dataShardCount + coeffIdx
                let coeff = payloadPos < payloadLen ? bytesGet(payload, payloadPos) : 0
                value = chainDispersalFieldMod(value + chainDispersalFieldMul(coeff, chainDispersalVandermondeValue(x, coeffIdx)))
            if strings.len(fragmentValues[shardIdx]) > 0:
                fragmentValues[shardIdx] = fragmentValues[shardIdx] + ","
            fragmentValues[shardIdx] = fragmentValues[shardIdx] + intToStr(value)
    var out = emptyChainDispersalPlan()
    out.payloadCid = chainCidFromText(text)
    out.payloadLen = payloadLen
    out.dataShardCount = dataShardCount
    out.totalShardCount = totalShardCount
    for shardIdx in 0..<totalShardCount:
        seqops.add(out.fragmentDigits, chainLsmrDigitAt(shardIdx))
        seqops.add(out.fragmentXValues, shardIdx + 1)
        seqops.add(out.fragmentValueTexts, fragmentValues[shardIdx])
    return Ok(out)

fn chainDispersalSubset(plan: ChainDispersalPlan, digits: int32[]): ChainDispersalPlan =
    var out = emptyChainDispersalPlan()
    out.payloadCid = plan.payloadCid
    out.payloadLen = plan.payloadLen
    out.dataShardCount = plan.dataShardCount
    out.totalShardCount = digits.len
    for i in 0..<digits.len:
        for j in 0..<plan.fragmentDigits.len:
            if plan.fragmentDigits[j] == digits[i]:
                seqops.add(out.fragmentDigits, plan.fragmentDigits[j])
                seqops.add(out.fragmentXValues, plan.fragmentXValues[j])
                seqops.add(out.fragmentValueTexts, plan.fragmentValueTexts[j])
                break
    return out

fn chainRecoverText(plan: ChainDispersalPlan): Result[str] =
    let k = plan.dataShardCount
    if k <= 0 || plan.fragmentDigits.len < k || plan.fragmentXValues.len < k || plan.fragmentValueTexts.len < k:
        return Err[str]("chain dispersal: insufficient fragments")
    let shardPosesRes = chainDispersalUniqueShardPoses(plan, k)
    if IsErr(shardPosesRes):
        return Err[str](ErrorText(shardPosesRes))
    let shardPoses = Value(shardPosesRes)
    var valueCount: int32 = -1
    for i in 0..<shardPoses.len:
        let valuesRes = chainDispersalParseValueText(plan.fragmentValueTexts[shardPoses[i]])
        if IsErr(valuesRes):
            return Err(ErrorText(valuesRes))
        let values = Value(valuesRes)
        if valueCount < 0:
            valueCount = values.len
        elif valueCount != values.len:
            return Err[str]("chain dispersal: inconsistent fragment lengths")
    let outBytes = bytesAlloc(plan.payloadLen)
    for blockIdx in 0..<valueCount:
        var xs: int32[]
        var ys: int32[]
        xs = []
        ys = []
        for i in 0..<shardPoses.len:
            let valuesRes = chainDispersalParseValueText(plan.fragmentValueTexts[shardPoses[i]])
            if IsErr(valuesRes):
                return Err(ErrorText(valuesRes))
            let values = Value(valuesRes)
            seqops.add(xs, plan.fragmentXValues[shardPoses[i]])
            seqops.add(ys, values[blockIdx])
        let coeffsRes = chainDispersalSolveCoefficients(xs, ys)
        if IsErr(coeffsRes):
            return Err(ErrorText(coeffsRes))
        let coeffs = Value(coeffsRes)
        for coeffIdx in 0..<coeffs.len:
            let payloadPos = blockIdx * k + coeffIdx
            if payloadPos >= plan.payloadLen:
                break
            if coeffs[coeffIdx] < 0 || coeffs[coeffIdx] > 255:
                return Err[str]("chain dispersal: recovered value outside byte range")
            bytesSet(outBytes, payloadPos, coeffs[coeffIdx])
    let outText = bytesToString(outBytes)
    if chainCidFromText(outText) != plan.payloadCid:
        return Err[str]("chain dispersal: payload cid mismatch")
    return Ok(outText)
