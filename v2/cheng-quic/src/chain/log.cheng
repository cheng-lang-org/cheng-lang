import std/system
import std/result
import std/os
import std/seqs as seqops
import std/strings
import std/strutils as strutils
import cheng/quic/chain/types
import cheng/quic/chain/codec
import cheng/quic/chain/content_address
import cheng/quic/chain/consensus
import cheng/quic/chain/anti_entropy
import cheng/quic/chain/lsmr

fn chainDir(rootDir: str): str =
    return os.joinPath(rootDir, "chain")

fn chainEventLogPath(rootDir: str): str =
    return os.joinPath(chainDir(rootDir), "events.log")

fn chainOpenAppend(path: str): os.File =
    return os.c_fopen(strToCStringTemp(path), "a")

fn chainAppendLine(path: str, line: str): bool =
    let f = chainOpenAppend(path)
    if f == nil:
        return false
    os.writeLine(f, line)
    os.close(f)
    return true

fn chainAccountKey(account: str, assetId: str): str =
    return assetId + "|" + account

fn chainEventPos(index: ChainIndex, eventCid: str): int32 =
    for i in 0..<index.eventCids.len:
        if index.eventCids[i] == eventCid:
            return i
    return -1

fn chainAccountPos(index: ChainIndex, key: str): int32 =
    for i in 0..<index.accountKeys.len:
        if index.accountKeys[i] == key:
            return i
    return -1

fn chainEnsureAccount(index: var ChainIndex, key: str): int32 =
    let existing = chainAccountPos(index, key)
    if existing >= 0:
        return existing
    seqops.add(index.accountKeys, key)
    seqops.add(index.accountHeads, "")
    seqops.add(index.balances, int64(0))
    seqops.add(index.clockEpochs, 0)
    seqops.add(index.clockGanzhi, 0)
    seqops.add(index.diverged, false)
    return index.accountKeys.len - 1

fn chainAccountHead(index: ChainIndex, key: str): str =
    let pos = chainAccountPos(index, key)
    if pos < 0:
        return ""
    return index.accountHeads[pos]

fn chainAccountClockValue(index: ChainIndex, key: str): int64 =
    let pos = chainAccountPos(index, key)
    if pos < 0:
        return 0
    return chainClockValue(index.clockEpochs[pos], index.clockGanzhi[pos])

fn chainAccountBalance(index: ChainIndex, key: str): int64 =
    let pos = chainAccountPos(index, key)
    if pos < 0:
        return 0
    return index.balances[pos]

fn chainAccountDiverged(index: ChainIndex, key: str): bool =
    let pos = chainAccountPos(index, key)
    if pos < 0:
        return false
    return index.diverged[pos]

fn chainMarkDiverged(index: var ChainIndex, key: str) =
    let pos = chainEnsureAccount(index, key)
    index.diverged[pos] = true

fn chainSeenClockValue(index: ChainIndex): int64 =
    var out: int64 = 0
    for i in 0..<index.clockEpochs.len:
        let value = chainClockValue(index.clockEpochs[i], index.clockGanzhi[i])
        if value > out:
            out = value
    return out

fn chainStoreEventText(store: ChainStoreConfig, eventText: str): Result[str] =
    return chainStorePutText(store, eventText)

fn chainValidateBodyCid(ev: ChainEvent): bool =
    return ev.bodyCid == chainBodyCidText(ev)

fn chainCloneStrArray(values: str[]): str[] =
    var out: str[]
    out = []
    for i in 0..<values.len:
        seqops.add(out, values[i])
    return out

fn chainCloneInt32Array(values: int32[]): int32[] =
    var out: int32[]
    out = []
    for i in 0..<values.len:
        seqops.add(out, values[i])
    return out

fn chainCloneInt64Array(values: int64[]): int64[] =
    var out: int64[]
    out = []
    for i in 0..<values.len:
        seqops.add(out, values[i])
    return out

fn chainCloneBoolArray(values: bool[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<values.len:
        seqops.add(out, values[i])
    return out

fn chainCloneIndex(index: ChainIndex): ChainIndex =
    return ChainIndex(
        eventCids: chainCloneStrArray(index.eventCids),
        eventKinds: chainCloneStrArray(index.eventKinds),
        logOffsets: chainCloneInt32Array(index.logOffsets),
        accountKeys: chainCloneStrArray(index.accountKeys),
        accountHeads: chainCloneStrArray(index.accountHeads),
        balances: chainCloneInt64Array(index.balances),
        clockEpochs: chainCloneInt32Array(index.clockEpochs),
        clockGanzhi: chainCloneInt32Array(index.clockGanzhi),
        diverged: chainCloneBoolArray(index.diverged),
        stateTreeDepth: index.stateTreeDepth,
        stateTreeDirty: true,
        stateTree: emptyLsmrBaguaPrefixTree()
    )

fn chainWriteIndex(out: var ChainIndex, index: ChainIndex) =
    out.eventCids = chainCloneStrArray(index.eventCids)
    out.eventKinds = chainCloneStrArray(index.eventKinds)
    out.logOffsets = chainCloneInt32Array(index.logOffsets)
    out.accountKeys = chainCloneStrArray(index.accountKeys)
    out.accountHeads = chainCloneStrArray(index.accountHeads)
    out.balances = chainCloneInt64Array(index.balances)
    out.clockEpochs = chainCloneInt32Array(index.clockEpochs)
    out.clockGanzhi = chainCloneInt32Array(index.clockGanzhi)
    out.diverged = chainCloneBoolArray(index.diverged)
    out.stateTreeDepth = index.stateTreeDepth
    out.stateTreeDirty = index.stateTreeDirty
    out.stateTree = index.stateTree

fn chainRebuildStateTree(index: var ChainIndex, depth: int32) =
    if depth <= 0:
        panic("chain log: invalid lsmr state tree depth")
    index.stateTreeDepth = depth
    index.stateTreeDirty = false
    index.stateTree = chainLsmrBuildIndexStateTree(index, depth)

fn chainApplyEvent(index: var ChainIndex, ev: ChainEvent, eventCid: str, logOffset: int32): Result[bool] =
    let decisionRes = chainConsensusApply(index, ev, eventCid, logOffset)
    if IsErr(decisionRes):
        return Err[bool](ErrorText(decisionRes))
    return Ok[bool](Value(decisionRes).applied)

fn chainAppendPersistedEvent(store: ChainStoreConfig,
                             logPath: str,
                             index: var ChainIndex,
                             ev: ChainEvent,
                             sourcePeer: str,
                             lsmrDepth: int32): Result[str] =
    let eventCid = chainEventCid(ev)
    if strings.len(eventCid) == 0:
        return Err[str]("chain persist: empty event cid")
    if chainEventPos(index, eventCid) >= 0:
        return Ok[str](eventCid)
    var nextIndex = chainCloneIndex(index)
    let applyRes = chainApplyEvent(nextIndex, ev, eventCid, index.eventCids.len)
    if IsErr(applyRes):
        return Err[str](ErrorText(applyRes))
    if ! Value(applyRes):
        return Err[str]("chain persist: consensus rejected event")
    chainRebuildStateTree(nextIndex, lsmrDepth)
    let eventText = chainEventCanonicalText(ev)
    let storedCidRes = chainStoreEventText(store, eventText)
    if IsErr(storedCidRes):
        return Err[str](ErrorText(storedCidRes))
    if Value(storedCidRes) != eventCid:
        return Err[str]("chain persist: stored cid mismatch")
    chainStoreCreateDirAll(os.parentDir(logPath))
    let journal = ChainJournalEntry(
        version: chainJournalVersion(),
        kind: "append",
        eventCid: eventCid,
        sourcePeer: sourcePeer,
        tick: ev.tick
    )
    if ! chainAppendLine(logPath, chainJournalText(journal)):
        return Err[str]("chain persist: append log failed")
    chainWriteIndex(index, nextIndex)
    return Ok[str](eventCid)

fn chainReplayAtDepth(rootDir: str, lsmrDepth: int32): Result[ChainIndex] =
    var out: ChainIndex
    let replayRes = chainReplayAtDepthInto(out, rootDir, lsmrDepth)
    if IsErr(replayRes):
        return Err[ChainIndex](ErrorText(replayRes))
    return Ok[ChainIndex](out)

fn chainReplayAtDepthInto(out: var ChainIndex, rootDir: str, lsmrDepth: int32): Result[bool] =
    let rootAbs = os.absolutePath(rootDir)
    let store = initChainStore(rootAbs)
    let logPath = chainEventLogPath(rootAbs)
    var rebuilt = newChainIndex()
    if ! os.fileExists(logPath):
        chainRebuildStateTree(rebuilt, lsmrDepth)
        chainWriteIndex(out, rebuilt)
        return Ok[bool](true)
    let text = os.readFile(logPath)
    if strings.len(text) == 0:
        chainRebuildStateTree(rebuilt, lsmrDepth)
        chainWriteIndex(out, rebuilt)
        return Ok[bool](true)
    let lines = strutils.split(text, '\n')
    var lineOffset: int32 = 0
    for i in 0..<lines.len:
        let line = strutils.strip(lines[i])
        if strings.len(line) == 0:
            continue
        let journalRes = chainJournalEntryFromText(line)
        if IsErr(journalRes):
            return Err[bool](ErrorText(journalRes))
        let eventText = chainStoreGetText(store, Value(journalRes).eventCid)
        if strings.len(eventText) == 0:
            return Err[bool]("chain replay: missing event block")
        let eventRes = chainEventFromText(eventText)
        if IsErr(eventRes):
            return Err[bool](ErrorText(eventRes))
        let applyRes = chainApplyEvent(rebuilt, Value(eventRes), Value(journalRes).eventCid, lineOffset)
        if IsErr(applyRes):
            return Err[bool](ErrorText(applyRes))
        if ! Value(applyRes):
            return Err[bool]("chain replay: consensus rejected journal event")
        lineOffset = lineOffset + 1
    chainRebuildStateTree(rebuilt, lsmrDepth)
    chainWriteIndex(out, rebuilt)
    return Ok[bool](true)

fn chainReplay(rootDir: str): Result[ChainIndex] =
    return chainReplayAtDepth(rootDir, defaultChainNodeConfig().lsmrDepth)

fn chainAccountState(index: ChainIndex, account: str, assetId: str): AccountState =
    let key = chainAccountKey(account, assetId)
    let pos = chainAccountPos(index, key)
    if pos < 0:
        return emptyAccountState(key)
    return AccountState(
        key: key,
        headCid: index.accountHeads[pos],
        balance: index.balances[pos],
        clockEpoch: index.clockEpochs[pos],
        clockGanzhi: index.clockGanzhi[pos],
        diverged: index.diverged[pos]
    )

fn chainAdvertisePayload(index: ChainIndex): str =
    return chainAntiEntropyAdvertisePayload(index)

fn chainAdvertisedEventCids(payload: str): str[] =
    return chainAntiEntropyAdvertisedEventCids(payload)
