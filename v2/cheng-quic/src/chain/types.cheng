    )

fn emptyLsmrLocationProofDecision(): LsmrLocationProofDecision =
    return LsmrLocationProofDecision(
        version: chainLsmrLocationProofVersion(),
        accepted: false,
        distinctWitnessCount: 0,
        distinctSectorCount: 0,
        reason: "",
        decisionCid: ""
    )

fn emptyChainDispersalPlan(): ChainDispersalPlan =
    var out: ChainDispersalPlan
    out.version = chainDispersalVersion()
    out.payloadCid = ""
    out.payloadLen = 0
    out.dataShardCount = 0
    out.totalShardCount = 0
    out.fragmentDigits = []
    out.fragmentXValues = []
    out.fragmentValueTexts = []
    return out

fn emptyChainBroadcastPlan(): ChainBroadcastPlan =
    var out: ChainBroadcastPlan
    out.version = chainBroadcastVersion()
    out.rootAddressText = ""
    out.depth = 0
    out.targetCount = 0
    out.payloadCid = ""
    out.payloadLen = 0
    out.dataShardCount = 0
    out.totalShardCount = 0
    out.treeCid = ""
    out.dispersalCid = ""
    out.branchDigits = []
    out.branchTargetCounts = []
    out.branchTargetTexts = []
    out.branchPathTexts = []
    out.branchFragmentStarts = []
    out.branchFragmentCounts = []
    out.fragmentDigits = []
    out.fragmentXValues = []
    out.fragmentValueTexts = []
    out.planCid = ""
    return out

fn emptyChainAntiEntropySignature(): ChainAntiEntropySignature =
    return ChainAntiEntropySignature(version: chainAntiEntropyVersion(),
                                     stampEpoch: 0,
                                     stampGanzhi: 0,
                                     eventCount: 0,
                                     accountCount: 0,
                                     eventSetCid: "",
                                     headSetCid: "",
                                     stateForestCid: "",
                                     stateTreeCid: "",
                                     stateTreeNodeCount: 0,
                                     stateTreeEntryCount: 0,
                                     edgeTreeCid: "",
                                     edgeTreeNodeCount: 0,
                                     edgeTreeEntryCount: 0,
                                     regionalTreeCid: "",
                                     regionalTreeNodeCount: 0,
                                     regionalTreeEntryCount: 0,
                                     globalTreeCid: "",
                                     globalTreeNodeCount: 0,
                                     globalTreeEntryCount: 0,
                                     signatureCid: "")

fn emptyChainAntiEntropyPlan(): ChainAntiEntropyPlan =
    var out: ChainAntiEntropyPlan
    out.version = chainAntiEntropyVersion()
    out.signaturesEqual = false
    out.localSignatureCid = ""
    out.remoteSignatureCid = ""
    out.localEventCount = 0
    out.remoteEventCount = 0
    out.wantStateSubtrees = []
    out.wantEventCids = []
    out.provideEventCids = []
    return out

fn emptyChainAntiEntropyStateLayerSummary(): ChainAntiEntropyStateLayerSummary =
    return ChainAntiEntropyStateLayerSummary(
        layer: "",
        treeCid: "",
        nodeCount: 0,
        entryCount: 0
    )

fn emptyChainAntiEntropyStateRootSummary(): ChainAntiEntropyStateRootSummary =
    return ChainAntiEntropyStateRootSummary(
        layer: "",
        bagua: "",
        nodeCid: "",
        entryDescCount: 0
    )

fn emptyChainAntiEntropyStateSubtree(): ChainAntiEntropyStateSubtree =
    var out: ChainAntiEntropyStateSubtree
    out.version = chainAntiEntropyVersion()
    out.layer = ""
    out.bagua = ""
    out.prefixText = ""
    out.nodeCid = ""
    out.nodeDepth = 0
