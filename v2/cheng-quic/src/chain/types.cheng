fn emptyChainConsensusDecision(): ChainConsensusDecision =
    return ChainConsensusDecision(version: chainConsensusVersion(),
                                  eventCid: "",
                                  accepted: false,
                                  applied: false,
                                  reason: "",
                                  orderKey: "",
                                  fromKey: "",
                                  toKey: "")

fn emptyChainEvent(): ChainEvent =
    return ChainEvent(
        version: chainEventVersion(),
        kind: "",
        assetId: "",
        fromAccount: "",
        toAccount: "",
        amount: 0,
        authorPeer: "",
        counterpartyPeer: "",
        fromParentCid: "",
        toParentCid: "",
        epoch: 0,
        ganzhiIndex: 0,
        stem: 0,
        branch: 0,
        spaceSlot: 0,
        tick: 0,
        bodyCid: ""
    )

fn emptyChainJournalEntry(): ChainJournalEntry =
    return ChainJournalEntry(
        version: chainJournalVersion(),
        kind: "append",
        eventCid: "",
        sourcePeer: "",
        tick: 0
    )

fn emptyChainFrame(kind: str): ChainFrame =
    return ChainFrame(
        version: chainFrameVersion(),
        kind: kind,
        nodeId: "",
        peerId: "",
        assetId: "",
        fromAccount: "",
        toAccount: "",
        amount: 0,
        eventCid: "",
        fromParentCid: "",
        toParentCid: "",
        epoch: 0,
        ganzhiIndex: 0,
        spaceSlot: 0,
        tick: 0,
        payloadText: ""
    )

fn emptyAccountState(key: str): AccountState =
    return AccountState(
        key: key,
        headCid: "",
        balance: 0,
        clockEpoch: 0,
        clockGanzhi: 0,
        diverged: false
    )

fn newChainIndex(): ChainIndex =
    var out: ChainIndex
    out.eventCids = []
    out.eventKinds = []
    out.logOffsets = []
    out.accountKeys = []
    out.accountHeads = []
    out.balances = []
    out.clockEpochs = []
    out.clockGanzhi = []
    out.diverged = []
    out.stateTreeDepth = 4
    out.stateTreeDirty = false
    out.stateTree = emptyLsmrBaguaPrefixTree()
    return out

fn defaultChainNodeConfig(): ChainNodeConfig =
    return ChainNodeConfig(
        rootDir: "./artifacts/cheng-chain-node",
        nodeId: "node-local",
        listenAddrText: chainDefaultListenAddrText(),
        maxFrameBytes: 1_048_576,
        lsmrDepth: 4
    )
