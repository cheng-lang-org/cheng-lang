import cheng/quic/multiaddress
import cheng/quic/msquictransport_native

type
    LsmrAddress =
        version: str
        depth: int32
        digits: int32[]
        text: str

    LsmrRoutePlan =
        version: str
        sourceAddressText: str
        targetAddressText: str
        depth: int32
        hopCount: int32
        pathTexts: str[]
        firstHopDigits: int32[]
        routeCid: str

    LsmrMulticastTree =
        version: str
        rootAddressText: str
        depth: int32
        targetCount: int32
        branchDigits: int32[]
        branchTargetCounts: int32[]
        branchTargetTexts: str[]
        branchPathTexts: str[]
        pathCounts: int32[]
        routeCid: str

    LsmrBaguaPrefixEntry =
        version: str
        key: str
        bagua: str
        resolutionLevel: int32
        addressText: str
        prefixText: str
        valueCid: str
        entryCid: str

    LsmrBaguaPrefixTree =
        version: str
        entryCount: int32
        nodeCount: int32
        nodeBaguas: str[]
        nodePrefixes: str[]
        nodeDepths: int32[]
        nodeResolutionLevels: int32[]
        nodeChildStarts: int32[]
        nodeChildCounts: int32[]
        nodeEntryStarts: int32[]
        nodeEntryCounts: int32[]
        nodeEntryDescCounts: int32[]
        nodeCids: str[]
        childDigits: int32[]
        childNodePoses: int32[]
        entryKeys: str[]
        entryBaguas: str[]
        entryResolutionLevels: int32[]
        entryAddressTexts: str[]
        entryPrefixTexts: str[]
        entryValueCids: str[]
        entryCids: str[]
        treeCid: str

    LsmrLocalityCid =
        version: str
        key: str
        bagua: str
        resolutionLevel: int32
        layer: str
        addressText: str
        prefixText: str
        localityHash: str
        contentCid: str
        cidText: str

    LsmrStateCell =
        version: str
        key: str
        bagua: str
        resolutionLevel: int32
        layer: str
        addressText: str
        prefixText: str
        contentCid: str
        localityHash: str
        localityCid: str

    LsmrStateLayerForest =
        version: str
        edgeTree: LsmrBaguaPrefixTree
        regionalTree: LsmrBaguaPrefixTree
        globalTree: LsmrBaguaPrefixTree
        edgeEntryCount: int32
        regionalEntryCount: int32
        globalEntryCount: int32
        edgeNodeCount: int32
        regionalNodeCount: int32
        globalNodeCount: int32
        localOpCount: int32
        regionalBatchCount: int32
        globalAnchorCount: int32
        forestCid: str

    LsmrPubSubTopic =
        version: str
        centerAddressText: str
        depth: int32
        resolutionLevel: int32
        layer: str
        baguaMode: str
        scopePrefixText: str
        semanticFingerprint: str
        topicCid: str

    LsmrPubSubSubscription =
        version: str
        nodeId: str
        addressText: str
        bagua: str
        barrierMode: str
        topicCid: str

    LsmrPubSubEnvelope =
        version: str
        topicCid: str
        payloadKind: str
        payloadCid: str
        payloadSummary: str
        envelopeCid: str

    LsmrPubSubPlan =
        version: str
        topicCid: str
        envelopeCid: str
        subscriberCount: int32
        branchCount: int32
        branchDigits: int32[]
        branchNodeCounts: int32[]
        branchNodeIds: str[]
        branchAddressTexts: str[]
        branchDeliveryPhases: str[]
        branchRouteCids: str[]
        planCid: str

    LsmrCsgSubgraph =
        version: str
        graphKey: str
        nodeIds: str[]
        nodeKinds: str[]
        nodeCapabilities: str[]
        nodeTexts: str[]
        edgeFromIds: str[]
        edgeToIds: str[]
        edgeKinds: str[]
        graphCid: str

    LsmrCsgDelta =
        version: str
        baseGraphCid: str
        subgraphCid: str
        nodeCount: int32
        edgeCount: int32
        deltaCid: str

    LsmrCsgBarrierFilter =
        version: str
        layer: str
        mode: str
        allowedCapabilities: str[]
        deniedCapabilities: str[]
        filterCid: str

    LsmrCsgFilterDecision =
        version: str
        accepted: bool
        reason: str
        acceptedNodeCount: int32
        deniedNodeIds: str[]
        decisionCid: str

    LsmrLocationWitness =
        version: str
        claimantNodeId: str
        claimantAddressText: str
        witnessNodeId: str
        witnessAddressText: str
        routeCid: str
        routeHopCount: int32
        sectorDigit: int32
        sharedPrefixDepth: int32
        rttBucket: int32
        witnessCid: str

    LsmrLocationProof =
        version: str
        claimantNodeId: str
        claimantAddressText: str
        depth: int32
        epoch: int32
        nonce: str
        witnessNodeIds: str[]
        witnessAddressTexts: str[]
        witnessRouteCids: str[]
        witnessHopCounts: int32[]
        witnessSectorDigits: int32[]
        witnessSharedPrefixDepths: int32[]
        witnessRttBuckets: int32[]
        proofCid: str

    LsmrLocationProofDecision =
        version: str
        accepted: bool
        distinctWitnessCount: int32
        distinctSectorCount: int32
        reason: str
        decisionCid: str

    ChainDispersalPlan =
        version: str
        payloadCid: str
        payloadLen: int32
        dataShardCount: int32
        totalShardCount: int32
        fragmentDigits: int32[]
        fragmentXValues: int32[]
        fragmentValueTexts: str[]

    ChainBroadcastPlan =
        version: str
        rootAddressText: str
        depth: int32
        targetCount: int32
        payloadCid: str
        payloadLen: int32
        dataShardCount: int32
        totalShardCount: int32
        treeCid: str
        dispersalCid: str
        branchDigits: int32[]
        branchTargetCounts: int32[]
        branchTargetTexts: str[]
        branchPathTexts: str[]
        branchFragmentStarts: int32[]
        branchFragmentCounts: int32[]
        fragmentDigits: int32[]
        fragmentXValues: int32[]
        fragmentValueTexts: str[]
        planCid: str

    ChainAntiEntropySignature =
        version: str
        stampEpoch: int32
        stampGanzhi: int32
        eventCount: int32
        accountCount: int32
        eventSetCid: str
        headSetCid: str
        stateForestCid: str
        stateTreeCid: str
        stateTreeNodeCount: int32
        stateTreeEntryCount: int32
        edgeTreeCid: str
        edgeTreeNodeCount: int32
        edgeTreeEntryCount: int32
        regionalTreeCid: str
        regionalTreeNodeCount: int32
        regionalTreeEntryCount: int32
        globalTreeCid: str
        globalTreeNodeCount: int32
        globalTreeEntryCount: int32
        signatureCid: str

    ChainAntiEntropyPlan =
        version: str
        signaturesEqual: bool
        localSignatureCid: str
        remoteSignatureCid: str
        localEventCount: int32
        remoteEventCount: int32
        wantStateSubtrees: str[]
        wantEventCids: str[]
        provideEventCids: str[]

    ChainAntiEntropyStateLayerSummary =
        layer: str
        treeCid: str
        nodeCount: int32
        entryCount: int32

    ChainAntiEntropyStateRootSummary =
        layer: str
        bagua: str
        nodeCid: str
        entryDescCount: int32

    ChainAntiEntropyStateSubtree =
        version: str
        layer: str
        bagua: str
        prefixText: str
        nodeCid: str
        nodeDepth: int32
        entryDescCount: int32
        childDigits: int32[]
        childNodeCids: str[]
        childEntryDescCounts: int32[]
        entryKeys: str[]
        entryHeadCids: str[]
        entryBalances: int64[]
        entryClockEpochs: int32[]
        entryClockGanzhi: int32[]
        entryDiverged: bool[]
        entryStateCids: str[]

    ChainConsensusDecision =
        version: str
        eventCid: str
        accepted: bool
        applied: bool
        reason: str
        orderKey: str
        fromKey: str
        toKey: str

    GanzhiStamp =
        epoch: int32
        ganzhiIndex: int32
        stem: int32
        branch: int32

    ChainEvent =
        version: str
        kind: str
        assetId: str
        fromAccount: str
        toAccount: str
        amount: int64
        authorPeer: str
        counterpartyPeer: str
        fromParentCid: str
        toParentCid: str
        epoch: int32
        ganzhiIndex: int32
        stem: int32
        branch: int32
        spaceSlot: int32
        tick: int64
        bodyCid: str

    ChainJournalEntry =
        version: str
        kind: str
        eventCid: str
        sourcePeer: str
        tick: int64

    ChainFrame =
        version: str
        kind: str
        nodeId: str
        peerId: str
        assetId: str
        fromAccount: str
        toAccount: str
        amount: int64
        eventCid: str
        fromParentCid: str
        toParentCid: str
        epoch: int32
        ganzhiIndex: int32
        spaceSlot: int32
        tick: int64
        payloadText: str

    ChainNodeConfig =
        rootDir: str
        nodeId: str
        listenAddrText: str
        maxFrameBytes: int32
        lsmrDepth: int32

    ChainStoreConfig =
        root: str
        blocksDir: str

    AccountState =
        key: str
        headCid: str
        balance: int64
        clockEpoch: int32
        clockGanzhi: int32
        diverged: bool

    ChainIndex =
        eventCids: str[]
        eventKinds: str[]
        logOffsets: int32[]
        accountKeys: str[]
        accountHeads: str[]
        balances: int64[]
        clockEpochs: int32[]
        clockGanzhi: int32[]
        diverged: bool[]
        stateTreeDepth: int32
        stateTreeDirty: bool
        stateTree: LsmrBaguaPrefixTree

    ChainNode =
        cfg: ChainNodeConfig
        store: ChainStoreConfig
        logPath: str
        index: ChainIndex
        lsmrAddress: LsmrAddress
        transport: MsQuicTransport
        listenAddr: MultiAddress
        transportReady: bool
        running: bool
        seenEpoch: int32
        seenGanzhi: int32

fn chainLsmrVersion(): str =
    return "cheng.chain.lsmr.v1"

fn chainLsmrBaguaPrefixVersion(): str =
    return "cheng.chain.lsmr_bagua_prefix.v1"

fn chainLsmrStorageVersion(): str =
    return "cheng.chain.lsmr_storage.v1"

fn chainLsmrPubSubVersion(): str =
    return "cheng.chain.lsmr_pubsub.v1"

fn chainLsmrCsgVersion(): str =
    return "cheng.chain.lsmr_csg.v1"

fn chainLsmrLocationProofVersion(): str =
    return "cheng.chain.lsmr_location_proof.v1"

fn chainDispersalVersion(): str =
    return "cheng.chain.dispersal.v1"

fn chainBroadcastVersion(): str =
    return "cheng.chain.broadcast.v1"

fn chainAntiEntropyVersion(): str =
    return "cheng.chain.anti_entropy.v1"

fn chainConsensusVersion(): str =
    return "cheng.chain.consensus.v1"

fn chainEventVersion(): str =
    return "cheng.chain.event.v1"

fn chainJournalVersion(): str =
    return "cheng.chain.journal.v1"

fn chainFrameVersion(): str =
    return "cheng.chain.frame.v1"

fn chainDefaultListenAddrText(): str =
    return "/ip4/127.0.0.1/udp/0/quic-v1"

fn emptyGanzhiStamp(): GanzhiStamp =
    return GanzhiStamp(epoch: 0, ganzhiIndex: 0, stem: 0, branch: 0)

fn emptyLsmrAddress(): LsmrAddress =
    var out: LsmrAddress
    out.version = chainLsmrVersion()
    out.depth = 0
    out.digits = []
    out.text = ""
    return out

fn emptyLsmrRoutePlan(): LsmrRoutePlan =
    var out: LsmrRoutePlan
    out.version = chainLsmrVersion()
    out.sourceAddressText = ""
    out.targetAddressText = ""
    out.depth = 0
    out.hopCount = 0
    out.pathTexts = []
    out.firstHopDigits = []
    out.routeCid = ""
    return out

fn emptyLsmrMulticastTree(): LsmrMulticastTree =
    var out: LsmrMulticastTree
    out.version = chainLsmrVersion()
    out.rootAddressText = ""
    out.depth = 0
    out.targetCount = 0
    out.branchDigits = []
    out.branchTargetCounts = []
    out.branchTargetTexts = []
    out.branchPathTexts = []
    out.pathCounts = []
    out.routeCid = ""
    return out

fn emptyLsmrBaguaPrefixEntry(): LsmrBaguaPrefixEntry =
    return LsmrBaguaPrefixEntry(
        version: chainLsmrBaguaPrefixVersion(),
        key: "",
        bagua: "",
        resolutionLevel: 0,
        addressText: "",
        prefixText: "",
        valueCid: "",
        entryCid: ""
    )

fn emptyLsmrBaguaPrefixTree(): LsmrBaguaPrefixTree =
    var out: LsmrBaguaPrefixTree
    out.version = chainLsmrBaguaPrefixVersion()
    out.entryCount = 0
    out.nodeCount = 0
    out.nodeBaguas = []
    out.nodePrefixes = []
    out.nodeDepths = []
    out.nodeResolutionLevels = []
    out.nodeChildStarts = []
    out.nodeChildCounts = []
    out.nodeEntryStarts = []
    out.nodeEntryCounts = []
    out.nodeEntryDescCounts = []
    out.nodeCids = []
    out.childDigits = []
    out.childNodePoses = []
    out.entryKeys = []
    out.entryBaguas = []
    out.entryResolutionLevels = []
    out.entryAddressTexts = []
    out.entryPrefixTexts = []
    out.entryValueCids = []
    out.entryCids = []
    out.treeCid = ""
    return out

fn emptyLsmrLocalityCid(): LsmrLocalityCid =
    return LsmrLocalityCid(
        version: chainLsmrStorageVersion(),
        key: "",
        bagua: "",
        resolutionLevel: 0,
        layer: "",
        addressText: "",
        prefixText: "",
        localityHash: "",
        contentCid: "",
        cidText: ""
    )

fn emptyLsmrStateCell(): LsmrStateCell =
    return LsmrStateCell(
        version: chainLsmrStorageVersion(),
        key: "",
        bagua: "",
        resolutionLevel: 0,
        layer: "",
        addressText: "",
        prefixText: "",
        contentCid: "",
        localityHash: "",
        localityCid: ""
    )

fn emptyLsmrStateLayerForest(): LsmrStateLayerForest =
    return LsmrStateLayerForest(
        version: chainLsmrStorageVersion(),
        edgeTree: emptyLsmrBaguaPrefixTree(),
        regionalTree: emptyLsmrBaguaPrefixTree(),
        globalTree: emptyLsmrBaguaPrefixTree(),
        edgeEntryCount: 0,
        regionalEntryCount: 0,
        globalEntryCount: 0,
        edgeNodeCount: 0,
        regionalNodeCount: 0,
        globalNodeCount: 0,
        localOpCount: 0,
        regionalBatchCount: 0,
        globalAnchorCount: 0,
        forestCid: ""
    )

