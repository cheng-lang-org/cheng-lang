    )

fn emptyLsmrPubSubPlan(): LsmrPubSubPlan =
    return LsmrPubSubPlan(
        version: chainLsmrPubSubVersion(),
        topicCid: "",
        envelopeCid: "",
        subscriberCount: 0,
        branchCount: 0,
        branchDigits: [],
        branchNodeCounts: [],
        branchNodeIds: [],
        branchAddressTexts: [],
        branchDeliveryPhases: [],
        branchRouteCids: [],
        planCid: ""
    )

fn emptyLsmrCsgSubgraph(): LsmrCsgSubgraph =
    return LsmrCsgSubgraph(
        version: chainLsmrCsgVersion(),
        graphKey: "",
        nodeIds: [],
        nodeKinds: [],
        nodeCapabilities: [],
        nodeTexts: [],
        edgeFromIds: [],
        edgeToIds: [],
        edgeKinds: [],
        graphCid: ""
    )

fn emptyLsmrCsgDelta(): LsmrCsgDelta =
    return LsmrCsgDelta(
        version: chainLsmrCsgVersion(),
        baseGraphCid: "",
        subgraphCid: "",
        nodeCount: 0,
        edgeCount: 0,
        deltaCid: ""
    )

fn emptyLsmrCsgBarrierFilter(): LsmrCsgBarrierFilter =
    return LsmrCsgBarrierFilter(
        version: chainLsmrCsgVersion(),
        layer: "",
        mode: "",
        allowedCapabilities: [],
        deniedCapabilities: [],
        filterCid: ""
    )

fn emptyLsmrCsgFilterDecision(): LsmrCsgFilterDecision =
    return LsmrCsgFilterDecision(
        version: chainLsmrCsgVersion(),
        accepted: false,
        reason: "",
        acceptedNodeCount: 0,
        deniedNodeIds: [],
        decisionCid: ""
    )

fn emptyLsmrLocationWitness(): LsmrLocationWitness =
    return LsmrLocationWitness(
        version: chainLsmrLocationProofVersion(),
        claimantNodeId: "",
        claimantAddressText: "",
        witnessNodeId: "",
        witnessAddressText: "",
        routeCid: "",
        routeHopCount: 0,
        sectorDigit: 0,
        sharedPrefixDepth: 0,
        rttBucket: 0,
        witnessCid: ""
    )

fn emptyLsmrLocationProof(): LsmrLocationProof =
    return LsmrLocationProof(
        version: chainLsmrLocationProofVersion(),
        claimantNodeId: "",
        claimantAddressText: "",
        depth: 0,
        epoch: 0,
        nonce: "",
        witnessNodeIds: [],
        witnessAddressTexts: [],
        witnessRouteCids: [],
        witnessHopCounts: [],
        witnessSectorDigits: [],
        witnessSharedPrefixDepths: [],
        witnessRttBuckets: [],
