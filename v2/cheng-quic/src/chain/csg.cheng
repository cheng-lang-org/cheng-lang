import std/result
import std/seqs as seqops
import std/strings
import cheng/quic/chain/types
import cheng/quic/chain/codec
import cheng/quic/chain/content_address

fn chainLsmrCsgNodeLess(aId: str, aKind: str, bId: str, bKind: str): bool =
    if aId != bId:
        return chainLexLess(aId, bId)
    return chainLexLess(aKind, bKind)

fn chainLsmrCsgEdgeLess(aFrom: str, aTo: str, aKind: str,
                        bFrom: str, bTo: str, bKind: str): bool =
    if aFrom != bFrom:
        return chainLexLess(aFrom, bFrom)
    if aTo != bTo:
        return chainLexLess(aTo, bTo)
    return chainLexLess(aKind, bKind)

fn chainLsmrCsgSortNodes(nodeIds: var str[],
                         nodeKinds: var str[],
                         nodeCapabilities: var str[],
                         nodeTexts: var str[]) =
    for i in 1..<nodeIds.len:
        let nodeId = nodeIds[i]
        let nodeKind = nodeKinds[i]
        let nodeCapability = nodeCapabilities[i]
        let nodeText = nodeTexts[i]
        var j = i - 1
        while j >= 0 && chainLsmrCsgNodeLess(nodeId, nodeKind, nodeIds[j], nodeKinds[j]):
            nodeIds[j + 1] = nodeIds[j]
            nodeKinds[j + 1] = nodeKinds[j]
            nodeCapabilities[j + 1] = nodeCapabilities[j]
            nodeTexts[j + 1] = nodeTexts[j]
            j = j - 1
        nodeIds[j + 1] = nodeId
        nodeKinds[j + 1] = nodeKind
        nodeCapabilities[j + 1] = nodeCapability
        nodeTexts[j + 1] = nodeText

fn chainLsmrCsgSortEdges(edgeFromIds: var str[],
                         edgeToIds: var str[],
                         edgeKinds: var str[]) =
    for i in 1..<edgeFromIds.len:
        let edgeFrom = edgeFromIds[i]
        let edgeTo = edgeToIds[i]
        let edgeKind = edgeKinds[i]
        var j = i - 1
        while j >= 0 && chainLsmrCsgEdgeLess(edgeFrom, edgeTo, edgeKind,
                                             edgeFromIds[j], edgeToIds[j], edgeKinds[j]):
            edgeFromIds[j + 1] = edgeFromIds[j]
            edgeToIds[j + 1] = edgeToIds[j]
            edgeKinds[j + 1] = edgeKinds[j]
            j = j - 1
        edgeFromIds[j + 1] = edgeFrom
        edgeToIds[j + 1] = edgeTo
        edgeKinds[j + 1] = edgeKind

fn chainLsmrCsgFindNodePos(nodeIds: str[], nodeId: str): int32 =
    for i in 0..<nodeIds.len:
        if nodeIds[i] == nodeId:
            return i
    return -1

fn chainLsmrCsgSubgraphCanonicalText(graph: LsmrCsgSubgraph): str =
    var out: str = ""
    out = out + "version=" + graph.version + "\n"
    out = out + "graph_key=" + graph.graphKey + "\n"
    out = out + "node_count=" + intToStr(graph.nodeIds.len) + "\n"
    for i in 0..<graph.nodeIds.len:
        out = out + "node." + intToStr(i) + ".id=" + graph.nodeIds[i] + "\n"
        out = out + "node." + intToStr(i) + ".kind=" + graph.nodeKinds[i] + "\n"
        out = out + "node." + intToStr(i) + ".cap=" + graph.nodeCapabilities[i] + "\n"
        out = out + "node." + intToStr(i) + ".text=" + graph.nodeTexts[i] + "\n"
    out = out + "edge_count=" + intToStr(graph.edgeFromIds.len) + "\n"
    for i in 0..<graph.edgeFromIds.len:
        out = out + "edge." + intToStr(i) + ".from=" + graph.edgeFromIds[i] + "\n"
        out = out + "edge." + intToStr(i) + ".to=" + graph.edgeToIds[i] + "\n"
        out = out + "edge." + intToStr(i) + ".kind=" + graph.edgeKinds[i] + "\n"
    return out

fn chainLsmrBuildCsgSubgraph(graphKey: str,
                             nodeIds: str[],
                             nodeKinds: str[],
                             nodeCapabilities: str[],
                             nodeTexts: str[],
                             edgeFromIds: str[],
                             edgeToIds: str[],
                             edgeKinds: str[]): Result[LsmrCsgSubgraph] =
    if strings.len(graphKey) == 0:
        return Err[LsmrCsgSubgraph]("chain csg: missing graph key")
    if nodeIds.len != nodeKinds.len ||
       nodeIds.len != nodeCapabilities.len ||
       nodeIds.len != nodeTexts.len:
        return Err[LsmrCsgSubgraph]("chain csg: node column mismatch")
    if edgeFromIds.len != edgeToIds.len || edgeFromIds.len != edgeKinds.len:
        return Err[LsmrCsgSubgraph]("chain csg: edge column mismatch")
    var out = emptyLsmrCsgSubgraph()
    out.graphKey = graphKey
    out.nodeIds = nodeIds
    out.nodeKinds = nodeKinds
    out.nodeCapabilities = nodeCapabilities
    out.nodeTexts = nodeTexts
    out.edgeFromIds = edgeFromIds
    out.edgeToIds = edgeToIds
    out.edgeKinds = edgeKinds
    chainLsmrCsgSortNodes(out.nodeIds, out.nodeKinds, out.nodeCapabilities, out.nodeTexts)
    for i in 0..<out.nodeIds.len:
        if strings.len(out.nodeIds[i]) == 0:
            return Err[LsmrCsgSubgraph]("chain csg: empty node id")
        if strings.len(out.nodeKinds[i]) == 0 || strings.len(out.nodeCapabilities[i]) == 0:
            return Err[LsmrCsgSubgraph]("chain csg: incomplete node")
        if i > 0 && out.nodeIds[i] == out.nodeIds[i - 1]:
            return Err[LsmrCsgSubgraph]("chain csg: duplicate node id=" + out.nodeIds[i])
    chainLsmrCsgSortEdges(out.edgeFromIds, out.edgeToIds, out.edgeKinds)
    for i in 0..<out.edgeFromIds.len:
        if strings.len(out.edgeFromIds[i]) == 0 || strings.len(out.edgeToIds[i]) == 0 || strings.len(out.edgeKinds[i]) == 0:
            return Err[LsmrCsgSubgraph]("chain csg: incomplete edge")
        if chainLsmrCsgFindNodePos(out.nodeIds, out.edgeFromIds[i]) < 0:
            return Err[LsmrCsgSubgraph]("chain csg: unknown edge from=" + out.edgeFromIds[i])
        if chainLsmrCsgFindNodePos(out.nodeIds, out.edgeToIds[i]) < 0:
            return Err[LsmrCsgSubgraph]("chain csg: unknown edge to=" + out.edgeToIds[i])
    out.graphCid = chainCidFromText(chainLsmrCsgSubgraphCanonicalText(out))
    return Ok[LsmrCsgSubgraph](out)

fn chainLsmrCsgDeltaCanonicalText(delta: LsmrCsgDelta): str =
    return "version=" + delta.version + "\n" +
           "base_graph_cid=" + delta.baseGraphCid + "\n" +
           "subgraph_cid=" + delta.subgraphCid + "\n" +
           "node_count=" + intToStr(delta.nodeCount) + "\n" +
           "edge_count=" + intToStr(delta.edgeCount) + "\n"

fn chainLsmrCsgDeltaFromSubgraph(baseGraphCid: str, subgraph: LsmrCsgSubgraph): LsmrCsgDelta =
    var out = emptyLsmrCsgDelta()
    out.baseGraphCid = baseGraphCid
    out.subgraphCid = subgraph.graphCid
    out.nodeCount = subgraph.nodeIds.len
    out.edgeCount = subgraph.edgeFromIds.len
    out.deltaCid = chainCidFromText(chainLsmrCsgDeltaCanonicalText(out))
    return out

fn chainLsmrCsgBarrierFilterCanonicalText(filter: LsmrCsgBarrierFilter): str =
    var out: str = ""
    out = out + "version=" + filter.version + "\n"
    out = out + "layer=" + filter.layer + "\n"
    out = out + "mode=" + filter.mode + "\n"
    out = out + "allow_count=" + intToStr(filter.allowedCapabilities.len) + "\n"
    for i in 0..<filter.allowedCapabilities.len:
        out = out + "allow." + intToStr(i) + "=" + filter.allowedCapabilities[i] + "\n"
    out = out + "deny_count=" + intToStr(filter.deniedCapabilities.len) + "\n"
    for i in 0..<filter.deniedCapabilities.len:
        out = out + "deny." + intToStr(i) + "=" + filter.deniedCapabilities[i] + "\n"
    return out

fn chainLsmrCsgPushUniqueText(values: var str[], value: str) =
    for i in 0..<values.len:
        if values[i] == value:
            return
    seqops.add(values, value)

fn chainLsmrDefaultCsgBarrierFilter(layer: str, mode: str): LsmrCsgBarrierFilter =
    var out = emptyLsmrCsgBarrierFilter()
    out.layer = layer
    out.mode = mode
    seqops.add(out.deniedCapabilities, "ptr_write")
    seqops.add(out.deniedCapabilities, "rawmem_write")
    seqops.add(out.deniedCapabilities, "importc")
    seqops.add(out.deniedCapabilities, "fs_write")
    seqops.add(out.deniedCapabilities, "net_admin")
    seqops.add(out.allowedCapabilities, "pure")
    seqops.add(out.allowedCapabilities, "read")
    seqops.add(out.allowedCapabilities, "emit")
    seqops.add(out.allowedCapabilities, "route")
    seqops.add(out.allowedCapabilities, "merge")
    seqops.add(out.allowedCapabilities, "sensor")
    if layer == "regional" || layer == "global":
        seqops.add(out.allowedCapabilities, "regional_batch")
    if layer == "global":
        seqops.add(out.allowedCapabilities, "global_anchor")
    out.filterCid = chainCidFromText(chainLsmrCsgBarrierFilterCanonicalText(out))
    return out

fn chainLsmrCsgCapabilityIn(values: str[], value: str): bool =
    for i in 0..<values.len:
        if values[i] == value:
            return true
    return false

fn chainLsmrCsgFilterDecisionCanonicalText(decision: LsmrCsgFilterDecision): str =
    var out: str = ""
    out = out + "version=" + decision.version + "\n"
    out = out + "accepted=" + (decision.accepted ? "1" : "0") + "\n"
    out = out + "reason=" + decision.reason + "\n"
    out = out + "accepted_node_count=" + intToStr(decision.acceptedNodeCount) + "\n"
    out = out + "denied_count=" + intToStr(decision.deniedNodeIds.len) + "\n"
    for i in 0..<decision.deniedNodeIds.len:
        out = out + "denied." + intToStr(i) + "=" + decision.deniedNodeIds[i] + "\n"
    return out

fn chainLsmrApplyCsgBarrierFilter(filter: LsmrCsgBarrierFilter,
                                  subgraph: LsmrCsgSubgraph): LsmrCsgFilterDecision =
    var out = emptyLsmrCsgFilterDecision()
    out.accepted = true
    out.reason = "ok"
    out.acceptedNodeCount = subgraph.nodeIds.len
    for i in 0..<subgraph.nodeIds.len:
        let capability = subgraph.nodeCapabilities[i]
        if chainLsmrCsgCapabilityIn(filter.deniedCapabilities, capability):
            out.accepted = false
            out.reason = "denied capability " + capability
            chainLsmrCsgPushUniqueText(out.deniedNodeIds, subgraph.nodeIds[i])
            continue
        if filter.mode == "gen" &&
           filter.allowedCapabilities.len > 0 &&
           ! chainLsmrCsgCapabilityIn(filter.allowedCapabilities, capability):
            out.accepted = false
            out.reason = "unsupported capability " + capability + " for layer " + filter.layer
            chainLsmrCsgPushUniqueText(out.deniedNodeIds, subgraph.nodeIds[i])
        if filter.mode == "gen":
            for edgePos in 0..<subgraph.edgeFromIds.len:
                if subgraph.edgeFromIds[edgePos] != subgraph.nodeIds[i]:
                    continue
                if subgraph.edgeKinds[edgePos] == "unsafe_write":
                    out.accepted = false
                    out.reason = "unsafe edge from " + subgraph.nodeIds[i]
                    chainLsmrCsgPushUniqueText(out.deniedNodeIds, subgraph.nodeIds[i])
        if out.accepted:
            continue
    out.decisionCid = chainCidFromText(chainLsmrCsgFilterDecisionCanonicalText(out))
    return out
