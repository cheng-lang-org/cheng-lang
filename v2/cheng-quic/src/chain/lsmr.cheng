import std/system
import std/seqs as seqops
import std/strings
import std/strutils as strutils
import cheng/quic/chain/types
import cheng/quic/chain/codec
import cheng/quic/chain/content_address

fn chainLsmrIntAbs(value: int32): int32 =
    if value < 0:
        return 0 - value
    return value

fn chainLsmrDigitOrder(): int32[] =
    var out: int32[]
    out = []
    seqops.add(out, 8)
    seqops.add(out, 1)
    seqops.add(out, 6)
    seqops.add(out, 3)
    seqops.add(out, 5)
    seqops.add(out, 7)
    seqops.add(out, 4)
    seqops.add(out, 9)
    seqops.add(out, 2)
    return out

fn chainLsmrDigitAt(slot: int32): int32 =
    let digits = chainLsmrDigitOrder()
    if slot < 0 || slot >= digits.len:
        panic("chain lsmr: invalid slot")
    return digits[slot]

fn chainLsmrDigitValid(digit: int32): bool =
    let digits = chainLsmrDigitOrder()
    for i in 0..<digits.len:
        if digits[i] == digit:
            return true
    return false

fn chainLsmrDigitX(digit: int32): int32 =
    if digit == 8 || digit == 3 || digit == 4:
        return -1
    if digit == 1 || digit == 5 || digit == 9:
        return 0
    if digit == 6 || digit == 7 || digit == 2:
        return 1
    panic("chain lsmr: invalid digit")

fn chainLsmrDigitY(digit: int32): int32 =
    if digit == 8 || digit == 1 || digit == 6:
        return -1
    if digit == 3 || digit == 5 || digit == 7:
        return 0
    if digit == 4 || digit == 9 || digit == 2:
        return 1
    panic("chain lsmr: invalid digit")

fn chainLsmrDigitDistance(fromDigit: int32, toDigit: int32): int32 =
    return chainLsmrIntAbs(chainLsmrDigitX(fromDigit) - chainLsmrDigitX(toDigit)) +
           chainLsmrIntAbs(chainLsmrDigitY(fromDigit) - chainLsmrDigitY(toDigit))

fn chainLsmrAddressText(digits: int32[]): str =
    var out: str = ""
    for i in 0..<digits.len:
        if i > 0:
            out = out + "/"
        out = out + intToStr(digits[i])
    return out

fn chainLsmrAddressFromText(text: str): LsmrAddress =
    let parts = strutils.split(strutils.strip(text), '/')
    if parts.len <= 0:
        panic("chain lsmr: empty address text")
    var digits: int32[]
    digits = []
    for i in 0..<parts.len:
        let digit = chainLsmrParseDigitText(parts[i])
        if ! chainLsmrDigitValid(digit):
            panic("chain lsmr: invalid address text")
        seqops.add(digits, digit)
    return chainLsmrAddressFromDigits(digits)

fn chainLsmrAddressFromDigits(digits: int32[]): LsmrAddress =
    if digits.len <= 0:
        panic("chain lsmr: empty address digits")
    var out = emptyLsmrAddress()
    out.depth = digits.len
    for i in 0..<digits.len:
        if ! chainLsmrDigitValid(digits[i]):
            panic("chain lsmr: invalid address digit")
        seqops.add(out.digits, digits[i])
    out.text = chainLsmrAddressText(out.digits)
    return out

fn chainLsmrDigitPathText(pathDigits: int32[]): str =
    var out: str = ""
    for i in 0..<pathDigits.len:
        if i > 0:
            out = out + ">"
        out = out + intToStr(pathDigits[i])
    return out

fn chainLsmrPushUniqueDigit(values: var int32[], digit: int32) =
    for i in 0..<values.len:
        if values[i] == digit:
            return
    seqops.add(values, digit)

fn chainLsmrPushUniqueText(values: var str[], value: str) =
    for i in 0..<values.len:
        if values[i] == value:
            return
    seqops.add(values, value)

fn chainLsmrSortDigits(values: var int32[]) =
    for i in 1..<values.len:
        let value = values[i]
        var j = i - 1
        while j >= 0 && values[j] > value:
            values[j + 1] = values[j]
            j = j - 1
        values[j + 1] = value

fn chainLsmrSortTexts(values: var str[]) =
    for i in 1..<values.len:
        let value = values[i]
        var j = i - 1
        while j >= 0 && chainLexLess(value, values[j]):
            values[j + 1] = values[j]
            j = j - 1
        values[j + 1] = value

fn chainLsmrBaguaOrder(): str[] =
    var out: str[]
    out = []
    seqops.add(out, "qian")
    seqops.add(out, "dui")
    seqops.add(out, "li")
    seqops.add(out, "zhen")
    seqops.add(out, "xun")
    seqops.add(out, "kan")
    seqops.add(out, "gen")
    seqops.add(out, "kun")
    return out

fn chainLsmrBaguaPos(bagua: str): int32 =
    let order = chainLsmrBaguaOrder()
    for i in 0..<order.len:
        if order[i] == bagua:
            return i
    panic("chain lsmr: invalid bagua")

fn chainLsmrBaguaValid(bagua: str): bool =
    let order = chainLsmrBaguaOrder()
    for i in 0..<order.len:
        if order[i] == bagua:
            return true
    return false

fn chainLsmrBaguaFromDigit(digit: int32): str =
    if digit == 1:
        return "kan"
    if digit == 2:
        return "kun"
    if digit == 3:
        return "zhen"
    if digit == 4:
        return "xun"
    if digit == 6:
        return "qian"
    if digit == 7:
        return "dui"
    if digit == 8:
        return "gen"
    if digit == 9:
        return "li"
    panic("chain lsmr: center digit has no bagua")

fn chainLsmrBaguaFromSeed(seed: str, depth: int32): str =
    let address = chainLsmrAddressFromSeed(seed, depth)
    for i in 0..<address.digits.len:
        if address.digits[i] != 5:
            return chainLsmrBaguaFromDigit(address.digits[i])
    let fallback = chainLsmrAddressFromSeed("bagua|" + seed, 1)
    for i in 0..<fallback.digits.len:
        if fallback.digits[i] != 5:
            return chainLsmrBaguaFromDigit(fallback.digits[i])
    panic("chain lsmr: unable to derive bagua")

fn chainLsmrPrefixTextFromDigits(digits: int32[], prefixDepth: int32): str =
    if prefixDepth < 0 || prefixDepth > digits.len:
        panic("chain lsmr: invalid prefix depth")
    var out: str = ""
    for i in 0..<prefixDepth:
        if i > 0:
            out = out + "/"
        out = out + intToStr(digits[i])
    return out

fn chainLsmrPrefixDepth(prefixText: str): int32 =
    if strings.len(prefixText) == 0:
        return 0
    return strutils.split(prefixText, '/').len

fn chainLsmrParentPrefixText(prefixText: str): str =
    if strings.len(prefixText) == 0:
        return ""
    let parts = strutils.split(prefixText, '/')
    if parts.len <= 1:
        return ""
    var out: str = ""
    for i in 0..<(parts.len - 1):
        if i > 0:
            out = out + "/"
        out = out + parts[i]
    return out

fn chainLsmrChildPrefixText(prefixText: str, digit: int32): str =
    if ! chainLsmrDigitValid(digit):
        panic("chain lsmr: invalid child digit")
    if strings.len(prefixText) == 0:
        return intToStr(digit)
    return prefixText + "/" + intToStr(digit)

fn chainLsmrParseDigitText(text: str): int32 =
    let trimmed = strutils.strip(text)
    if strings.len(trimmed) != 1:
        panic("chain lsmr: invalid digit text")
    let ch = trimmed[0]
    if ch < '1' || ch > '9':
        panic("chain lsmr: invalid digit text")
    return int32(ch) - int32('0')

fn chainLsmrLastPrefixDigit(prefixText: str): int32 =
    if strings.len(prefixText) == 0:
        panic("chain lsmr: empty prefix")
    let parts = strutils.split(prefixText, '/')
    return chainLsmrParseDigitText(parts[parts.len - 1])

fn chainLsmrPrefixContains(parentPrefix: str, childPrefix: str): bool =
    if strings.len(parentPrefix) == 0:
        return true
    if parentPrefix == childPrefix:
        return true
    return strutils.startsWith(childPrefix, parentPrefix + "/")

fn chainLsmrNodeLess(aBagua: str, aPrefix: str, bBagua: str, bPrefix: str): bool =
    let aPos = chainLsmrBaguaPos(aBagua)
    let bPos = chainLsmrBaguaPos(bBagua)
    if aPos != bPos:
        return aPos < bPos
    let aDepth = chainLsmrPrefixDepth(aPrefix)
    let bDepth = chainLsmrPrefixDepth(bPrefix)
    if aDepth != bDepth:
        return aDepth < bDepth
    return chainLexLess(aPrefix, bPrefix)

fn chainLsmrSortNodeKeys(baguas: var str[], prefixes: var str[]) =
    for i in 1..<baguas.len:
        let bagua = baguas[i]
        let prefix = prefixes[i]
        var j = i - 1
        while j >= 0 && chainLsmrNodeLess(bagua, prefix, baguas[j], prefixes[j]):
            baguas[j + 1] = baguas[j]
            prefixes[j + 1] = prefixes[j]
            j = j - 1
        baguas[j + 1] = bagua
        prefixes[j + 1] = prefix

fn chainLsmrFindSortedNodePos(baguas: str[], prefixes: str[], bagua: str, prefix: str): int32 =
    var left: int32 = 0
    var right: int32 = baguas.len - 1
    while left <= right:
        let mid = left + ((right - left) / 2)
        if baguas[mid] == bagua && prefixes[mid] == prefix:
            return mid
        if chainLsmrNodeLess(baguas[mid], prefixes[mid], bagua, prefix):
            left = mid + 1
        else:
            right = mid - 1
    return -1

fn chainLsmrCollectUniqueNodeKey(baguas: var str[], prefixes: var str[], bagua: str, prefix: str) =
    for i in 0..<baguas.len:
        if baguas[i] == bagua && prefixes[i] == prefix:
            return
    seqops.add(baguas, bagua)
    seqops.add(prefixes, prefix)

fn chainLsmrBaguaPrefixEntryLess(a: LsmrBaguaPrefixEntry, b: LsmrBaguaPrefixEntry): bool =
    let aPos = chainLsmrBaguaPos(a.bagua)
    let bPos = chainLsmrBaguaPos(b.bagua)
    if aPos != bPos:
        return aPos < bPos
    let aDepth = chainLsmrPrefixDepth(a.prefixText)
    let bDepth = chainLsmrPrefixDepth(b.prefixText)
    if aDepth != bDepth:
        return aDepth < bDepth
    if a.prefixText != b.prefixText:
        return chainLexLess(a.prefixText, b.prefixText)
    if a.key != b.key:
        return chainLexLess(a.key, b.key)
    return chainLexLess(a.entryCid, b.entryCid)

fn chainLsmrSortBaguaPrefixEntries(entries: var LsmrBaguaPrefixEntry[]) =
    for i in 1..<entries.len:
        let value = entries[i]
        var j = i - 1
        while j >= 0 && chainLsmrBaguaPrefixEntryLess(value, entries[j]):
            entries[j + 1] = entries[j]
            j = j - 1
        entries[j + 1] = value

fn chainLsmrSortChildRefs(digits: var int32[], nodePoses: var int32[]) =
    for i in 1..<digits.len:
        let digit = digits[i]
        let nodePos = nodePoses[i]
        var j = i - 1
        while j >= 0 && digits[j] > digit:
            digits[j + 1] = digits[j]
            nodePoses[j + 1] = nodePoses[j]
            j = j - 1
        digits[j + 1] = digit
        nodePoses[j + 1] = nodePos

fn chainLsmrHexNibble(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch - '0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch - 'a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch - 'A')
    panic("chain lsmr: invalid cid hex")

fn chainLsmrHexByte(text: str, pairIdx: int32): int32 =
    let offset = pairIdx * 2
    if offset + 1 >= strings.len(text):
        panic("chain lsmr: cid too short")
    return chainLsmrHexNibble(text[offset]) * 16 + chainLsmrHexNibble(text[offset + 1])

fn chainLsmrAddressFromCid(cid: str, depth: int32): LsmrAddress =
    if depth <= 0:
        panic("chain lsmr: invalid depth")
    var out = emptyLsmrAddress()
    out.depth = depth
    for i in 0..<depth:
        seqops.add(out.digits, chainLsmrDigitAt(chainLsmrHexByte(cid, i) % 9))
    out.text = chainLsmrAddressText(out.digits)
    return out

fn chainLsmrAddressFromSeed(seed: str, depth: int32): LsmrAddress =
    return chainLsmrAddressFromCid(chainCidFromText(seed), depth)

fn chainLsmrStateLayerForResolution(resolutionLevel: int32): str =
    if resolutionLevel <= 0:
        panic("chain lsmr: invalid resolution level")
    if resolutionLevel <= 1:
        return "global"
    if resolutionLevel == 2:
        return "regional"
    return "edge"

fn chainLsmrLocalitySortI64(values: var int64[]) =
    for i in 1..<values.len:
        let value = values[i]
        var j = i - 1
        while j >= 0 && values[j] > value:
            values[j + 1] = values[j]
            j = j - 1
        values[j + 1] = value

fn chainLsmrLocalityHash(text: str): str =
    var tokenHashes: int64[]
    tokenHashes = []
    var tokenHash: int64 = 17
    var tokenLen: int32 = 0
    let textLen = strings.len(text)
    for i in 0..textLen:
        let ch = i < textLen ? text[i] : ' '
        var lower = ch
        if lower >= 'A' && lower <= 'Z':
            lower = chr (int32(lower) + 32)
        let alpha = (lower >= 'a' && lower <= 'z')
        let digit = (lower >= '0' && lower <= '9')
        if alpha || digit:
            tokenHash = (tokenHash * 131 + int64(int32(lower))) % 2147483629
            tokenLen = tokenLen + 1
        elif tokenLen > 0:
            seqops.add(tokenHashes, tokenHash)
            tokenHash = 17
            tokenLen = 0
    if tokenHashes.len <= 0:
        return "00000000000000000000000000000000"
    chainLsmrLocalitySortI64(tokenHashes)
    var sig: str = "count=" + intToStr(tokenHashes.len) + "\n"
    let take = tokenHashes.len < 4 ? tokenHashes.len : 4
    for i in 0..<take:
        sig = sig + "min." + intToStr(i) + "=" + int64ToStr(tokenHashes[i]) + "\n"
    return strings.sliceBytes(chainCidFromText("lshv1|" + sig), 0, 32)

fn chainLsmrLocalityCidCanonicalText(locality: LsmrLocalityCid): str =
    return "version=" + locality.version + "\n" +
           "key=" + locality.key + "\n" +
           "bagua=" + locality.bagua + "\n" +
           "resolution_level=" + intToStr(locality.resolutionLevel) + "\n" +
           "layer=" + locality.layer + "\n" +
           "address=" + locality.addressText + "\n" +
           "prefix=" + locality.prefixText + "\n" +
           "locality_hash=" + locality.localityHash + "\n" +
           "content_cid=" + locality.contentCid + "\n"

fn chainLsmrLocalityCidFromParts(key: str,
                                 address: LsmrAddress,
                                 bagua: str,
                                 resolutionLevel: int32,
                                 contentCid: str,
                                 localityHash: str): LsmrLocalityCid =
    if ! chainLsmrBaguaValid(bagua):
        panic("chain lsmr: invalid locality cid bagua")
    if resolutionLevel <= 0 || resolutionLevel > address.depth:
        panic("chain lsmr: invalid locality cid resolution")
    let prefixText = chainLsmrPrefixTextFromDigits(address.digits, resolutionLevel)
    var out = emptyLsmrLocalityCid()
    out.key = key
    out.bagua = bagua
    out.resolutionLevel = resolutionLevel
    out.layer = chainLsmrStateLayerForResolution(resolutionLevel)
    out.addressText = address.text
    out.prefixText = prefixText
    out.localityHash = localityHash
    out.contentCid = contentCid
    out.cidText = chainCidFromText(chainLsmrLocalityCidCanonicalText(out))
    return out

fn chainLsmrLocalityCidFromText(key: str,
                                address: LsmrAddress,
                                bagua: str,
                                resolutionLevel: int32,
                                contentText: str): LsmrLocalityCid =
    return chainLsmrLocalityCidFromParts(key,
                                         address,
                                         bagua,
                                         resolutionLevel,
                                         chainCidFromText(contentText),
                                         chainLsmrLocalityHash(contentText))

fn chainLsmrStateCellFromText(key: str,
                              address: LsmrAddress,
                              bagua: str,
                              resolutionLevel: int32,
                              contentText: str): LsmrStateCell =
    let locality = chainLsmrLocalityCidFromText(key, address, bagua, resolutionLevel, contentText)
    var out = emptyLsmrStateCell()
    out.key = key
    out.bagua = bagua
    out.resolutionLevel = resolutionLevel
    out.layer = locality.layer
    out.addressText = locality.addressText
    out.prefixText = locality.prefixText
    out.contentCid = locality.contentCid
    out.localityHash = locality.localityHash
    out.localityCid = locality.cidText
    return out

fn chainLsmrStateCellPrefixEntry(cell: LsmrStateCell): LsmrBaguaPrefixEntry =
    let address = chainLsmrAddressFromDigits(chainLsmrAddressFromText(cell.addressText).digits)
    return chainLsmrBaguaPrefixEntryFromCid(cell.key,
                                            address,
                                            cell.bagua,
                                            cell.resolutionLevel,
                                            cell.contentCid)

fn chainLsmrStateLayerForestCanonicalText(forest: LsmrStateLayerForest): str =
    return "version=" + forest.version + "\n" +
           "edge_tree_cid=" + forest.edgeTree.treeCid + "\n" +
           "regional_tree_cid=" + forest.regionalTree.treeCid + "\n" +
           "global_tree_cid=" + forest.globalTree.treeCid + "\n" +
           "edge_entry_count=" + intToStr(forest.edgeEntryCount) + "\n" +
           "regional_entry_count=" + intToStr(forest.regionalEntryCount) + "\n" +
           "global_entry_count=" + intToStr(forest.globalEntryCount) + "\n" +
           "edge_node_count=" + intToStr(forest.edgeNodeCount) + "\n" +
           "regional_node_count=" + intToStr(forest.regionalNodeCount) + "\n" +
           "global_node_count=" + intToStr(forest.globalNodeCount) + "\n" +
           "local_op_count=" + intToStr(forest.localOpCount) + "\n" +
           "regional_batch_count=" + intToStr(forest.regionalBatchCount) + "\n" +
           "global_anchor_count=" + intToStr(forest.globalAnchorCount) + "\n"

fn chainLsmrBuildStateLayerForest(cells: LsmrStateCell[]): LsmrStateLayerForest =
    var edgeEntries: LsmrBaguaPrefixEntry[]
    var regionalEntries: LsmrBaguaPrefixEntry[]
    var globalEntries: LsmrBaguaPrefixEntry[]
    edgeEntries = []
    regionalEntries = []
    globalEntries = []
    for i in 0..<cells.len:
        let entry = chainLsmrStateCellPrefixEntry(cells[i])
        if cells[i].layer == "edge":
            seqops.add(edgeEntries, entry)
        elif cells[i].layer == "regional":
            seqops.add(regionalEntries, entry)
        elif cells[i].layer == "global":
            seqops.add(globalEntries, entry)
        else:
            panic("chain lsmr: invalid state layer")
    var out = emptyLsmrStateLayerForest()
    out.edgeTree = chainLsmrBuildBaguaPrefixTree(edgeEntries)
    out.regionalTree = chainLsmrBuildBaguaPrefixTree(regionalEntries)
    out.globalTree = chainLsmrBuildBaguaPrefixTree(globalEntries)
    out.edgeEntryCount = out.edgeTree.entryCount
    out.regionalEntryCount = out.regionalTree.entryCount
    out.globalEntryCount = out.globalTree.entryCount
    out.edgeNodeCount = out.edgeTree.nodeCount
    out.regionalNodeCount = out.regionalTree.nodeCount
    out.globalNodeCount = out.globalTree.nodeCount
    out.localOpCount = out.edgeEntryCount
    out.regionalBatchCount = out.regionalEntryCount
    out.globalAnchorCount = out.globalEntryCount
    out.forestCid = chainCidFromText(chainLsmrStateLayerForestCanonicalText(out))
    return out

fn chainLsmrBaguaPrefixEntryCanonicalText(entry: LsmrBaguaPrefixEntry): str =
    return "version=" + entry.version + "\n" +
           "key=" + entry.key + "\n" +
           "bagua=" + entry.bagua + "\n" +
           "resolution_level=" + intToStr(entry.resolutionLevel) + "\n" +
           "address=" + entry.addressText + "\n" +
           "prefix=" + entry.prefixText + "\n" +
           "value_cid=" + entry.valueCid + "\n"

fn chainLsmrBaguaPrefixEntryFromCid(key: str,
                                    address: LsmrAddress,
                                    bagua: str,
                                    resolutionLevel: int32,
                                    valueCid: str): LsmrBaguaPrefixEntry =
    if ! chainLsmrBaguaValid(bagua):
        panic("chain lsmr: invalid bagua prefix entry")
    if resolutionLevel <= 0 || resolutionLevel > address.depth:
        panic("chain lsmr: invalid bagua resolution level")
    var out = emptyLsmrBaguaPrefixEntry()
    out.key = key
    out.bagua = bagua
    out.resolutionLevel = resolutionLevel
    out.addressText = address.text
    out.prefixText = chainLsmrPrefixTextFromDigits(address.digits, resolutionLevel)
    out.valueCid = valueCid
    out.entryCid = chainCidFromText(chainLsmrBaguaPrefixEntryCanonicalText(out))
    return out

fn chainLsmrBaguaPrefixEntryFromText(key: str,
                                     address: LsmrAddress,
                                     bagua: str,
                                     resolutionLevel: int32,
                                     valueText: str): LsmrBaguaPrefixEntry =
    return chainLsmrBaguaPrefixEntryFromCid(key,
                                            address,
                                            bagua,
                                            resolutionLevel,
                                            chainCidFromText(valueText))

fn chainLsmrNeighborDigits(digit: int32): int32[] =
    var out: int32[]
    out = []
    let digits = chainLsmrDigitOrder()
    for i in 0..<digits.len:
        if chainLsmrDigitDistance(digit, digits[i]) == 1:
            seqops.add(out, digits[i])
    chainLsmrSortDigits(out)
    return out

fn chainLsmrCollectShortestPaths(currentDigit: int32,
                                 targetDigit: int32,
                                 pathDigits: int32[],
                                 outTexts: var str[]) =
    if currentDigit == targetDigit:
        seqops.add(outTexts, chainLsmrDigitPathText(pathDigits))
        return
    let currentDistance = chainLsmrDigitDistance(currentDigit, targetDigit)
    let neighbors = chainLsmrNeighborDigits(currentDigit)
    for i in 0..<neighbors.len:
        let nextDigit = neighbors[i]
        if chainLsmrDigitDistance(nextDigit, targetDigit) != currentDistance - 1:
            continue
        var nextPath = pathDigits
        seqops.add(nextPath, nextDigit)
        chainLsmrCollectShortestPaths(nextDigit, targetDigit, nextPath, outTexts)

fn chainLsmrShortestPathTexts(fromDigit: int32, toDigit: int32): str[] =
    var out: str[]
    out = []
    if ! chainLsmrDigitValid(fromDigit) || ! chainLsmrDigitValid(toDigit):
        panic("chain lsmr: invalid route digit")
    var pathDigits: int32[]
    pathDigits = []
    seqops.add(pathDigits, fromDigit)
    chainLsmrCollectShortestPaths(fromDigit, toDigit, pathDigits, out)
    chainLsmrSortTexts(out)
    return out

fn chainLsmrFirstHopDigit(pathText: str): int32 =
    let parts = strutils.split(pathText, '>')
    if parts.len <= 1:
        return chainLsmrParseDigitText(parts[0])
    return chainLsmrParseDigitText(parts[1])

fn chainLsmrAppendRouteSegment(prefix: str, segment: str): str =
    if strings.len(prefix) == 0:
        return segment
    return prefix + "/" + segment

fn chainLsmrRoutePlanCanonicalText(plan: LsmrRoutePlan): str =
    var out: str = ""
    out = out + "version=" + plan.version + "\n"
    out = out + "source=" + plan.sourceAddressText + "\n"
    out = out + "target=" + plan.targetAddressText + "\n"
    out = out + "depth=" + intToStr(plan.depth) + "\n"
    out = out + "hop_count=" + intToStr(plan.hopCount) + "\n"
    out = out + "path_count=" + intToStr(plan.pathTexts.len) + "\n"
    for i in 0..<plan.pathTexts.len:
        out = out + "path." + intToStr(i) + "=" + plan.pathTexts[i] + "\n"
    for i in 0..<plan.firstHopDigits.len:
        out = out + "first_hop." + intToStr(i) + "=" + intToStr(plan.firstHopDigits[i]) + "\n"
    return out

fn chainLsmrRoutePlanFromAddresses(sourceAddress: LsmrAddress, targetAddress: LsmrAddress): LsmrRoutePlan =
    if sourceAddress.depth <= 0 || sourceAddress.depth != targetAddress.depth:
        panic("chain lsmr: route plan depth mismatch")
    let depth = sourceAddress.depth
    var out = emptyLsmrRoutePlan()
    out.sourceAddressText = sourceAddress.text
    out.targetAddressText = targetAddress.text
    out.depth = depth
    seqops.add(out.pathTexts, "")
    for i in 0..<depth:
        let srcDigit = sourceAddress.digits[i]
        let dstDigit = targetAddress.digits[i]
        var levelTexts: str[]
        levelTexts = []
        if srcDigit == dstDigit:
            seqops.add(levelTexts, intToStr(srcDigit))
        else:
            levelTexts = chainLsmrShortestPathTexts(srcDigit, dstDigit)
            out.hopCount = out.hopCount + chainLsmrDigitDistance(srcDigit, dstDigit)
            for j in 0..<levelTexts.len:
                chainLsmrPushUniqueDigit(out.firstHopDigits, chainLsmrFirstHopDigit(levelTexts[j]))
        var nextRoutes: str[]
        nextRoutes = []
        for j in 0..<out.pathTexts.len:
            for k in 0..<levelTexts.len:
                seqops.add(nextRoutes, chainLsmrAppendRouteSegment(out.pathTexts[j], "L" + intToStr(i) + ":" + levelTexts[k]))
        out.pathTexts = nextRoutes
    chainLsmrSortDigits(out.firstHopDigits)
    chainLsmrSortTexts(out.pathTexts)
    out.routeCid = chainCidFromText(chainLsmrRoutePlanCanonicalText(out))
    return out

fn chainLsmrRoutePlan(sourceSeed: str, targetSeed: str, depth: int32): LsmrRoutePlan =
    let sourceAddress = chainLsmrAddressFromSeed(sourceSeed, depth)
    let targetAddress = chainLsmrAddressFromSeed(targetSeed, depth)
    return chainLsmrRoutePlanFromAddresses(sourceAddress, targetAddress)

fn chainLsmrMulticastTreeCanonicalText(tree: LsmrMulticastTree): str =
    var out: str = ""
    out = out + "version=" + tree.version + "\n"
    out = out + "root=" + tree.rootAddressText + "\n"
    out = out + "depth=" + intToStr(tree.depth) + "\n"
    out = out + "target_count=" + intToStr(tree.targetCount) + "\n"
    out = out + "branch_count=" + intToStr(tree.branchDigits.len) + "\n"
    for i in 0..<tree.branchDigits.len:
        out = out + "branch." + intToStr(i) + ".digit=" + intToStr(tree.branchDigits[i]) + "\n"
        out = out + "branch." + intToStr(i) + ".target_count=" + intToStr(tree.branchTargetCounts[i]) + "\n"
        out = out + "branch." + intToStr(i) + ".path_count=" + intToStr(tree.pathCounts[i]) + "\n"
        out = out + "branch." + intToStr(i) + ".targets=" + tree.branchTargetTexts[i] + "\n"
        out = out + "branch." + intToStr(i) + ".paths=" + tree.branchPathTexts[i] + "\n"
    return out

fn chainLsmrTreeBranchPos(tree: LsmrMulticastTree, digit: int32): int32 =
    for i in 0..<tree.branchDigits.len:
        if tree.branchDigits[i] == digit:
            return i
    return -1

fn chainLsmrEnsureTreeBranch(tree: var LsmrMulticastTree, digit: int32): int32 =
    let existing = chainLsmrTreeBranchPos(tree, digit)
    if existing >= 0:
        return existing
    seqops.add(tree.branchDigits, digit)
    seqops.add(tree.branchTargetCounts, 0)
    seqops.add(tree.branchTargetTexts, "")
    seqops.add(tree.branchPathTexts, "")
    seqops.add(tree.pathCounts, 0)
    return tree.branchDigits.len - 1

fn chainLsmrSortTreeBranches(tree: var LsmrMulticastTree) =
    for i in 1..<tree.branchDigits.len:
        let digit = tree.branchDigits[i]
        let targetCount = tree.branchTargetCounts[i]
        let targetText = tree.branchTargetTexts[i]
        let pathText = tree.branchPathTexts[i]
        let pathCount = tree.pathCounts[i]
        var j = i - 1
        while j >= 0 && tree.branchDigits[j] > digit:
            tree.branchDigits[j + 1] = tree.branchDigits[j]
            tree.branchTargetCounts[j + 1] = tree.branchTargetCounts[j]
            tree.branchTargetTexts[j + 1] = tree.branchTargetTexts[j]
            tree.branchPathTexts[j + 1] = tree.branchPathTexts[j]
            tree.pathCounts[j + 1] = tree.pathCounts[j]
            j = j - 1
        tree.branchDigits[j + 1] = digit
        tree.branchTargetCounts[j + 1] = targetCount
        tree.branchTargetTexts[j + 1] = targetText
        tree.branchPathTexts[j + 1] = pathText
        tree.pathCounts[j + 1] = pathCount

fn chainLsmrPathFirstHopDigit(pathText: str): int32 =
    let levelParts = strutils.split(pathText, '/')
    for i in 0..<levelParts.len:
        let levelPart = strutils.strip(levelParts[i])
        let colonPos = strings.find(levelPart, ":")
        if colonPos < 0:
            continue
        let digitPath = strings.sliceBytes(levelPart, colonPos + 1, strings.len(levelPart) - colonPos - 1)
        let hopParts = strutils.split(digitPath, '>')
        if hopParts.len <= 1:
            continue
        return chainLsmrParseDigitText(hopParts[1])
    return 5

fn chainLsmrCanonicalFirstHopDigit(plan: LsmrRoutePlan): int32 =
    if plan.firstHopDigits.len <= 0:
        return 5
    return plan.firstHopDigits[0]

fn chainLsmrCanonicalPathText(plan: LsmrRoutePlan): str =
    let firstHop = chainLsmrCanonicalFirstHopDigit(plan)
    for i in 0..<plan.pathTexts.len:
        if chainLsmrPathFirstHopDigit(plan.pathTexts[i]) == firstHop:
            return plan.pathTexts[i]
    if plan.pathTexts.len <= 0:
        return ""
    return plan.pathTexts[0]

fn chainLsmrMulticastBranchDigit(rootAddress: LsmrAddress, targetAddress: LsmrAddress): int32 =
    if rootAddress.depth <= 0 || rootAddress.depth != targetAddress.depth:
        panic("chain lsmr: multicast branch depth mismatch")
    for i in 0..<rootAddress.depth:
        if rootAddress.digits[i] != targetAddress.digits[i]:
            return targetAddress.digits[i]
    return rootAddress.digits[rootAddress.depth - 1]

fn chainLsmrBuildMulticastTreeFromAddresses(rootAddress: LsmrAddress, targetAddresses: LsmrAddress[]): LsmrMulticastTree =
    var out = emptyLsmrMulticastTree()
    out.rootAddressText = rootAddress.text
    out.depth = rootAddress.depth
    for i in 0..<targetAddresses.len:
        let plan = chainLsmrRoutePlanFromAddresses(rootAddress, targetAddresses[i])
        let firstHop = chainLsmrMulticastBranchDigit(rootAddress, targetAddresses[i])
        let pathText = chainLsmrCanonicalPathText(plan)
        let pos = chainLsmrEnsureTreeBranch(out, firstHop)
        out.targetCount = out.targetCount + 1
        out.branchTargetCounts[pos] = out.branchTargetCounts[pos] + 1
        out.pathCounts[pos] = out.pathCounts[pos] + 1
        if strings.len(out.branchTargetTexts[pos]) == 0:
            out.branchTargetTexts[pos] = targetAddresses[i].text
        else:
            out.branchTargetTexts[pos] = out.branchTargetTexts[pos] + "," + targetAddresses[i].text
        if strings.len(pathText) > 0:
            if strings.len(out.branchPathTexts[pos]) == 0:
                out.branchPathTexts[pos] = pathText
            else:
                out.branchPathTexts[pos] = out.branchPathTexts[pos] + "," + pathText
    chainLsmrSortTreeBranches(out)
    out.routeCid = chainCidFromText(chainLsmrMulticastTreeCanonicalText(out))
    return out

fn chainLsmrBuildMulticastTree(rootSeed: str, targetSeeds: str[], depth: int32): LsmrMulticastTree =
    let rootAddress = chainLsmrAddressFromSeed(rootSeed, depth)
    var uniqueTargetSeeds: str[]
    uniqueTargetSeeds = []
    for i in 0..<targetSeeds.len:
        chainLsmrPushUniqueText(uniqueTargetSeeds, targetSeeds[i])
    chainLsmrSortTexts(uniqueTargetSeeds)
    var targetAddresses: LsmrAddress[]
    targetAddresses = []
    for i in 0..<uniqueTargetSeeds.len:
        seqops.add(targetAddresses, chainLsmrAddressFromSeed(uniqueTargetSeeds[i], depth))
    return chainLsmrBuildMulticastTreeFromAddresses(rootAddress, targetAddresses)

fn chainLsmrDistanceBetweenSeeds(sourceSeed: str, targetSeed: str, depth: int32): int32 =
    let sourceAddress = chainLsmrAddressFromSeed(sourceSeed, depth)
    let targetAddress = chainLsmrAddressFromSeed(targetSeed, depth)
    var out: int32 = 0
    for i in 0..<depth:
        out = out + chainLsmrDigitDistance(sourceAddress.digits[i], targetAddress.digits[i])
    return out

fn chainLsmrBaguaPrefixNodeCanonicalText(tree: LsmrBaguaPrefixTree, nodePos: int32): str =
    var out: str = ""
    out = out + "version=" + tree.version + "\n"
    out = out + "bagua=" + tree.nodeBaguas[nodePos] + "\n"
    out = out + "prefix=" + tree.nodePrefixes[nodePos] + "\n"
    out = out + "depth=" + intToStr(tree.nodeDepths[nodePos]) + "\n"
    out = out + "resolution_level=" + intToStr(tree.nodeResolutionLevels[nodePos]) + "\n"
    out = out + "child_count=" + intToStr(tree.nodeChildCounts[nodePos]) + "\n"
    out = out + "entry_count=" + intToStr(tree.nodeEntryCounts[nodePos]) + "\n"
    out = out + "entry_desc_count=" + intToStr(tree.nodeEntryDescCounts[nodePos]) + "\n"
    let childStart = tree.nodeChildStarts[nodePos]
    let childCount = tree.nodeChildCounts[nodePos]
    for i in 0..<childCount:
        let childPos = childStart + i
        out = out + "child." + intToStr(i) + ".digit=" + intToStr(tree.childDigits[childPos]) + "\n"
        out = out + "child." + intToStr(i) + ".cid=" + tree.nodeCids[tree.childNodePoses[childPos]] + "\n"
    let entryStart = tree.nodeEntryStarts[nodePos]
    let entryCount = tree.nodeEntryCounts[nodePos]
    for i in 0..<entryCount:
        let pos = entryStart + i
        out = out + "entry." + intToStr(i) + ".key=" + tree.entryKeys[pos] + "\n"
        out = out + "entry." + intToStr(i) + ".value_cid=" + tree.entryValueCids[pos] + "\n"
        out = out + "entry." + intToStr(i) + ".entry_cid=" + tree.entryCids[pos] + "\n"
    return out

fn chainLsmrBaguaPrefixTreeCanonicalText(tree: LsmrBaguaPrefixTree): str =
    var out: str = ""
    out = out + "version=" + tree.version + "\n"
    out = out + "entry_count=" + intToStr(tree.entryCount) + "\n"
    out = out + "node_count=" + intToStr(tree.nodeCount) + "\n"
    var rootCount: int32 = 0
    for i in 0..<tree.nodeCount:
        if tree.nodeDepths[i] == 0:
            rootCount = rootCount + 1
    out = out + "root_count=" + intToStr(rootCount) + "\n"
    var rootPos: int32 = 0
    for i in 0..<tree.nodeCount:
        if tree.nodeDepths[i] != 0:
            continue
        out = out + "root." + intToStr(rootPos) + ".bagua=" + tree.nodeBaguas[i] + "\n"
        out = out + "root." + intToStr(rootPos) + ".cid=" + tree.nodeCids[i] + "\n"
        rootPos = rootPos + 1
    for i in 0..<tree.nodeCount:
        out = out + "node." + intToStr(i) + ".bagua=" + tree.nodeBaguas[i] + "\n"
        out = out + "node." + intToStr(i) + ".prefix=" + tree.nodePrefixes[i] + "\n"
        out = out + "node." + intToStr(i) + ".cid=" + tree.nodeCids[i] + "\n"
    return out

fn chainLsmrBuildBaguaPrefixTree(entries: LsmrBaguaPrefixEntry[]): LsmrBaguaPrefixTree =
    var sortedEntries = entries
    chainLsmrSortBaguaPrefixEntries(sortedEntries)
    var nodeBaguas: str[]
    var nodePrefixes: str[]
    nodeBaguas = []
    nodePrefixes = []
    for i in 0..<sortedEntries.len:
        let entry = sortedEntries[i]
        if ! chainLsmrBaguaValid(entry.bagua):
            panic("chain lsmr: invalid bagua tree entry")
        if entry.resolutionLevel != chainLsmrPrefixDepth(entry.prefixText):
            panic("chain lsmr: entry prefix depth mismatch")
        chainLsmrCollectUniqueNodeKey(nodeBaguas, nodePrefixes, entry.bagua, "")
        if strings.len(entry.prefixText) > 0:
            let parts = strutils.split(entry.prefixText, '/')
            var currentPrefix: str = ""
            for j in 0..<parts.len:
                if j > 0:
                    currentPrefix = currentPrefix + "/"
                currentPrefix = currentPrefix + parts[j]
                chainLsmrCollectUniqueNodeKey(nodeBaguas, nodePrefixes, entry.bagua, currentPrefix)
    chainLsmrSortNodeKeys(nodeBaguas, nodePrefixes)
    var out = emptyLsmrBaguaPrefixTree()
    out.entryCount = sortedEntries.len
    out.nodeCount = nodeBaguas.len
    for i in 0..<nodeBaguas.len:
        seqops.add(out.nodeBaguas, nodeBaguas[i])
        seqops.add(out.nodePrefixes, nodePrefixes[i])
        seqops.add(out.nodeDepths, chainLsmrPrefixDepth(nodePrefixes[i]))
        seqops.add(out.nodeResolutionLevels, chainLsmrPrefixDepth(nodePrefixes[i]))
        seqops.add(out.nodeChildStarts, 0)
        seqops.add(out.nodeChildCounts, 0)
        seqops.add(out.nodeEntryStarts, 0)
        seqops.add(out.nodeEntryCounts, 0)
        seqops.add(out.nodeEntryDescCounts, 0)
        seqops.add(out.nodeCids, "")
    for nodePos in 0..<out.nodeCount:
        out.nodeEntryStarts[nodePos] = out.entryKeys.len
        for entryPos in 0..<sortedEntries.len:
            let entry = sortedEntries[entryPos]
            if entry.bagua == out.nodeBaguas[nodePos] &&
               chainLsmrPrefixContains(out.nodePrefixes[nodePos], entry.prefixText):
                out.nodeEntryDescCounts[nodePos] = out.nodeEntryDescCounts[nodePos] + 1
            if entry.bagua != out.nodeBaguas[nodePos] || entry.prefixText != out.nodePrefixes[nodePos]:
                continue
            seqops.add(out.entryKeys, entry.key)
            seqops.add(out.entryBaguas, entry.bagua)
            seqops.add(out.entryResolutionLevels, entry.resolutionLevel)
            seqops.add(out.entryAddressTexts, entry.addressText)
            seqops.add(out.entryPrefixTexts, entry.prefixText)
            seqops.add(out.entryValueCids, entry.valueCid)
            seqops.add(out.entryCids, entry.entryCid)
        out.nodeEntryCounts[nodePos] = out.entryKeys.len - out.nodeEntryStarts[nodePos]
        var childDigits: int32[]
        var childNodePoses: int32[]
        childDigits = []
        childNodePoses = []
        for childPos in 0..<out.nodeCount:
            if out.nodeBaguas[childPos] != out.nodeBaguas[nodePos]:
                continue
            if out.nodeDepths[childPos] != out.nodeDepths[nodePos] + 1:
                continue
            if chainLsmrParentPrefixText(out.nodePrefixes[childPos]) != out.nodePrefixes[nodePos]:
                continue
            seqops.add(childDigits, chainLsmrLastPrefixDigit(out.nodePrefixes[childPos]))
            seqops.add(childNodePoses, childPos)
        chainLsmrSortChildRefs(childDigits, childNodePoses)
        out.nodeChildStarts[nodePos] = out.childDigits.len
        for i in 0..<childDigits.len:
            seqops.add(out.childDigits, childDigits[i])
            seqops.add(out.childNodePoses, childNodePoses[i])
        out.nodeChildCounts[nodePos] = childDigits.len
    var maxDepth: int32 = 0
    for i in 0..<out.nodeDepths.len:
        if out.nodeDepths[i] > maxDepth:
            maxDepth = out.nodeDepths[i]
    var depth: int32 = maxDepth
    while depth >= 0:
        for nodePos in 0..<out.nodeCount:
            if out.nodeDepths[nodePos] != depth:
                continue
            out.nodeCids[nodePos] = chainCidFromText(chainLsmrBaguaPrefixNodeCanonicalText(out, nodePos))
        depth = depth - 1
    out.treeCid = chainCidFromText(chainLsmrBaguaPrefixTreeCanonicalText(out))
    return out

fn chainLsmrBaguaTreeNodePos(tree: LsmrBaguaPrefixTree, bagua: str, prefixText: str): int32 =
    return chainLsmrFindSortedNodePos(tree.nodeBaguas, tree.nodePrefixes, bagua, prefixText)

fn chainLsmrBaguaTreeNodeChildDigits(tree: LsmrBaguaPrefixTree, bagua: str, prefixText: str): int32[] =
    var out: int32[]
    out = []
    let nodePos = chainLsmrBaguaTreeNodePos(tree, bagua, prefixText)
    if nodePos < 0:
        return out
    let childStart = tree.nodeChildStarts[nodePos]
    let childCount = tree.nodeChildCounts[nodePos]
    for i in 0..<childCount:
        seqops.add(out, tree.childDigits[childStart + i])
    return out

fn chainLsmrBaguaTreeNodeEntryCids(tree: LsmrBaguaPrefixTree, bagua: str, prefixText: str): str[] =
    var out: str[]
    out = []
    let nodePos = chainLsmrBaguaTreeNodePos(tree, bagua, prefixText)
    if nodePos < 0:
        return out
    let entryStart = tree.nodeEntryStarts[nodePos]
    let entryCount = tree.nodeEntryCounts[nodePos]
    for i in 0..<entryCount:
        seqops.add(out, tree.entryCids[entryStart + i])
    return out

fn chainLsmrIndexStateTreeDepth(index: ChainIndex): int32 =
    if index.stateTreeDepth > 0:
        return index.stateTreeDepth
    return 4

fn chainLsmrIndexStateEntries(index: ChainIndex, depth: int32): LsmrBaguaPrefixEntry[] =
    var out: LsmrBaguaPrefixEntry[]
    out = []
    for i in 0..<index.accountKeys.len:
        let state = AccountState(
            key: index.accountKeys[i],
            headCid: index.accountHeads[i],
            balance: index.balances[i],
            clockEpoch: index.clockEpochs[i],
            clockGanzhi: index.clockGanzhi[i],
            diverged: index.diverged[i]
        )
        let address = chainLsmrAddressFromSeed(state.key, depth)
        let entry = chainLsmrBaguaPrefixEntryFromCid(state.key,
                                                     address,
                                                     chainLsmrBaguaFromSeed(state.key, depth),
                                                     depth,
                                                     chainAccountStateCid(state))
        seqops.add(out, entry)
    return out

fn chainLsmrIndexStateCells(index: ChainIndex, depth: int32): LsmrStateCell[] =
    var out: LsmrStateCell[]
    out = []
    for i in 0..<index.accountKeys.len:
        let state = AccountState(
            key: index.accountKeys[i],
            headCid: index.accountHeads[i],
            balance: index.balances[i],
            clockEpoch: index.clockEpochs[i],
            clockGanzhi: index.clockGanzhi[i],
            diverged: index.diverged[i]
        )
        let address = chainLsmrAddressFromSeed(state.key, depth)
        let contentText = chainAccountStateCanonicalText(state)
        let edgeCell = chainLsmrStateCellFromText(state.key,
                                                  address,
                                                  chainLsmrBaguaFromSeed(state.key, depth),
                                                  depth,
                                                  contentText)
        seqops.add(out, edgeCell)
        if depth >= 2:
            seqops.add(out, chainLsmrStateCellFromText(state.key,
                                                address,
                                                edgeCell.bagua,
                                                2,
                                                contentText))
        seqops.add(out, chainLsmrStateCellFromText(state.key,
                                            address,
                                            edgeCell.bagua,
                                            1,
                                            contentText))
    return out

fn chainLsmrBuildIndexStateLayerForest(index: ChainIndex, depth: int32): LsmrStateLayerForest =
    if depth <= 0:
        panic("chain lsmr: invalid layer forest depth")
    return chainLsmrBuildStateLayerForest(chainLsmrIndexStateCells(index, depth))

fn chainLsmrBuildIndexStateTree(index: ChainIndex, depth: int32): LsmrBaguaPrefixTree =
    if depth <= 0:
        panic("chain lsmr: invalid state tree depth")
    let entries = chainLsmrIndexStateEntries(index, depth)
    let tree = chainLsmrBuildBaguaPrefixTree(entries)
    return tree

fn chainLsmrEffectiveIndexStateTree(index: ChainIndex): LsmrBaguaPrefixTree =
    let depth = chainLsmrIndexStateTreeDepth(index)
    var out: LsmrBaguaPrefixTree = index.stateTree
    if index.stateTreeDirty ||
       index.stateTreeDepth != depth ||
       index.stateTree.entryCount != index.accountKeys.len:
        out = chainLsmrBuildIndexStateTree(index, depth)
    return out
