import std/result
import std/seqs as seqops
import std/strings
import cheng/quic/chain/types
import cheng/quic/chain/codec
import cheng/quic/chain/content_address
import cheng/quic/chain/lsmr
import cheng/quic/chain/csg

fn chainLsmrPubSubBaguaModeValid(mode: str): bool =
    return mode == "zhen" ||
           mode == "xun" ||
           mode == "gen" ||
           mode == "dui" ||
           mode == "li" ||
           mode == "kun"

fn chainLsmrPubSubScopeDepth(topic: LsmrPubSubTopic): int32 =
    if topic.layer == "global":
        return 0
    if topic.layer == "regional":
        return 1
    if topic.depth <= 1:
        return 1
    return topic.depth - 1

fn chainLsmrPubSubSharedPrefixDepth(left: LsmrAddress, right: LsmrAddress): int32 =
    if left.depth != right.depth:
        panic("chain pubsub: depth mismatch")
    var out: int32 = 0
    for i in 0..<left.depth:
        if left.digits[i] != right.digits[i]:
            return out
        out = out + 1
    return out

fn chainLsmrPubSubAddressBagua(address: LsmrAddress, seed: str): str =
    for i in 0..<address.digits.len:
        if address.digits[i] != 5:
            return chainLsmrBaguaFromDigit(address.digits[i])
    return chainLsmrBaguaFromSeed(seed, address.depth)

fn chainLsmrPubSubTopicCanonicalText(topic: LsmrPubSubTopic): str =
    return "version=" + topic.version + "\n" +
           "center_address=" + topic.centerAddressText + "\n" +
           "depth=" + intToStr(topic.depth) + "\n" +
           "resolution_level=" + intToStr(topic.resolutionLevel) + "\n" +
           "layer=" + topic.layer + "\n" +
           "bagua_mode=" + topic.baguaMode + "\n" +
           "scope_prefix=" + topic.scopePrefixText + "\n" +
           "semantic_fingerprint=" + topic.semanticFingerprint + "\n"

fn chainLsmrPubSubTopicFromAddress(centerAddress: LsmrAddress,
                                   resolutionLevel: int32,
                                   baguaMode: str,
                                   semanticText: str): Result[LsmrPubSubTopic] =
    if ! chainLsmrPubSubBaguaModeValid(baguaMode):
        return Err[LsmrPubSubTopic]("chain pubsub: invalid bagua mode")
    if resolutionLevel <= 0 || resolutionLevel > centerAddress.depth:
        return Err[LsmrPubSubTopic]("chain pubsub: invalid resolution level")
    var out = emptyLsmrPubSubTopic()
    out.centerAddressText = centerAddress.text
    out.depth = centerAddress.depth
    out.resolutionLevel = resolutionLevel
    out.layer = chainLsmrStateLayerForResolution(resolutionLevel)
    out.baguaMode = baguaMode
    let scopeDepth = chainLsmrPubSubScopeDepth(out)
    out.scopePrefixText = chainLsmrPrefixTextFromDigits(centerAddress.digits, scopeDepth)
    out.semanticFingerprint = chainLsmrLocalityHash(semanticText)
    out.topicCid = chainCidFromText(chainLsmrPubSubTopicCanonicalText(out))
    return Ok[LsmrPubSubTopic](out)

fn chainLsmrPubSubTopicFromSeed(centerSeed: str,
                                depth: int32,
                                resolutionLevel: int32,
                                baguaMode: str,
                                semanticText: str): Result[LsmrPubSubTopic] =
    return chainLsmrPubSubTopicFromAddress(chainLsmrAddressFromSeed(centerSeed, depth),
                                           resolutionLevel,
                                           baguaMode,
                                           semanticText)

fn chainLsmrPubSubSubscriptionCanonicalText(sub: LsmrPubSubSubscription): str =
    return "version=" + sub.version + "\n" +
           "node_id=" + sub.nodeId + "\n" +
           "address=" + sub.addressText + "\n" +
           "bagua=" + sub.bagua + "\n" +
           "barrier_mode=" + sub.barrierMode + "\n" +
           "topic_cid=" + sub.topicCid + "\n"

fn chainLsmrPubSubSubscription(nodeId: str,
                               address: LsmrAddress,
                               barrierMode: str,
                               topicCid: str): LsmrPubSubSubscription =
    var out = emptyLsmrPubSubSubscription()
    out.nodeId = nodeId
    out.addressText = address.text
    out.bagua = chainLsmrPubSubAddressBagua(address, nodeId)
    out.barrierMode = barrierMode
    out.topicCid = topicCid
    return out

fn chainLsmrPubSubEnvelopeCanonicalText(envelope: LsmrPubSubEnvelope): str =
    return "version=" + envelope.version + "\n" +
           "topic_cid=" + envelope.topicCid + "\n" +
           "payload_kind=" + envelope.payloadKind + "\n" +
           "payload_cid=" + envelope.payloadCid + "\n" +
           "payload_summary=" + envelope.payloadSummary + "\n"

fn chainLsmrPubSubEnvelope(topic: LsmrPubSubTopic,
                           payloadKind: str,
                           payloadCid: str,
                           payloadSummary: str): LsmrPubSubEnvelope =
    var out = emptyLsmrPubSubEnvelope()
    out.topicCid = topic.topicCid
    out.payloadKind = payloadKind
    out.payloadCid = payloadCid
    out.payloadSummary = payloadSummary
    out.envelopeCid = chainCidFromText(chainLsmrPubSubEnvelopeCanonicalText(out))
    return out

fn chainLsmrPubSubPlanBranchPos(plan: LsmrPubSubPlan, digit: int32): int32 =
    for i in 0..<plan.branchDigits.len:
        if plan.branchDigits[i] == digit:
            return i
    return -1

fn chainLsmrPubSubEnsureBranch(plan: var LsmrPubSubPlan, digit: int32): int32 =
    let pos = chainLsmrPubSubPlanBranchPos(plan, digit)
    if pos >= 0:
        return pos
    seqops.add(plan.branchDigits, digit)
    seqops.add(plan.branchNodeCounts, 0)
    seqops.add(plan.branchNodeIds, "")
    seqops.add(plan.branchAddressTexts, "")
    seqops.add(plan.branchDeliveryPhases, "")
    seqops.add(plan.branchRouteCids, "")
    return plan.branchDigits.len - 1

fn chainLsmrPubSubAppendCsv(target: var str, value: str) =
    if strings.len(target) == 0:
        target = value
    else:
        target = target + "," + value

fn chainLsmrPubSubSortBranches(plan: var LsmrPubSubPlan) =
    for i in 1..<plan.branchDigits.len:
        let digit = plan.branchDigits[i]
        let nodeCount = plan.branchNodeCounts[i]
        let nodeIds = plan.branchNodeIds[i]
        let addresses = plan.branchAddressTexts[i]
        let phases = plan.branchDeliveryPhases[i]
        let routeCid = plan.branchRouteCids[i]
        var j = i - 1
        while j >= 0 && plan.branchDigits[j] > digit:
            plan.branchDigits[j + 1] = plan.branchDigits[j]
            plan.branchNodeCounts[j + 1] = plan.branchNodeCounts[j]
            plan.branchNodeIds[j + 1] = plan.branchNodeIds[j]
            plan.branchAddressTexts[j + 1] = plan.branchAddressTexts[j]
            plan.branchDeliveryPhases[j + 1] = plan.branchDeliveryPhases[j]
            plan.branchRouteCids[j + 1] = plan.branchRouteCids[j]
            j = j - 1
        plan.branchDigits[j + 1] = digit
        plan.branchNodeCounts[j + 1] = nodeCount
        plan.branchNodeIds[j + 1] = nodeIds
        plan.branchAddressTexts[j + 1] = addresses
        plan.branchDeliveryPhases[j + 1] = phases
        plan.branchRouteCids[j + 1] = routeCid

fn chainLsmrPubSubDeliveryPhase(topic: LsmrPubSubTopic,
                                centerAddress: LsmrAddress,
                                subscriberAddress: LsmrAddress): str =
    if centerAddress.text == subscriberAddress.text:
        return "kun"
    if topic.layer == "global":
        return "li"
    return "dui"

fn chainLsmrPubSubEligible(topic: LsmrPubSubTopic,
                           centerAddress: LsmrAddress,
                           subscriberAddress: LsmrAddress): bool =
    if subscriberAddress.depth != centerAddress.depth:
        return false
    let scopeDepth = chainLsmrPubSubScopeDepth(topic)
    if scopeDepth <= 0:
        return true
    let subscriberPrefix = chainLsmrPrefixTextFromDigits(subscriberAddress.digits, scopeDepth)
    return subscriberPrefix == topic.scopePrefixText

fn chainLsmrPubSubPlanCanonicalText(plan: LsmrPubSubPlan): str =
    var out: str = ""
    out = out + "version=" + plan.version + "\n"
    out = out + "topic_cid=" + plan.topicCid + "\n"
    out = out + "envelope_cid=" + plan.envelopeCid + "\n"
    out = out + "subscriber_count=" + intToStr(plan.subscriberCount) + "\n"
    out = out + "branch_count=" + intToStr(plan.branchCount) + "\n"
    for i in 0..<plan.branchDigits.len:
        out = out + "branch." + intToStr(i) + ".digit=" + intToStr(plan.branchDigits[i]) + "\n"
        out = out + "branch." + intToStr(i) + ".node_count=" + intToStr(plan.branchNodeCounts[i]) + "\n"
        out = out + "branch." + intToStr(i) + ".node_ids=" + plan.branchNodeIds[i] + "\n"
        out = out + "branch." + intToStr(i) + ".addresses=" + plan.branchAddressTexts[i] + "\n"
        out = out + "branch." + intToStr(i) + ".phases=" + plan.branchDeliveryPhases[i] + "\n"
        out = out + "branch." + intToStr(i) + ".route_cids=" + plan.branchRouteCids[i] + "\n"
    return out

fn chainLsmrBuildPubSubPlan(topic: LsmrPubSubTopic,
                            envelope: LsmrPubSubEnvelope,
                            subscriptions: LsmrPubSubSubscription[]): Result[LsmrPubSubPlan] =
    if envelope.topicCid != topic.topicCid:
        return Err[LsmrPubSubPlan]("chain pubsub: envelope topic mismatch")
    let centerAddress = chainLsmrAddressFromText(topic.centerAddressText)
    var out = emptyLsmrPubSubPlan()
    out.topicCid = topic.topicCid
    out.envelopeCid = envelope.envelopeCid
    var branchBestHops: int32[]
    branchBestHops = []
    for i in 0..<subscriptions.len:
        if subscriptions[i].topicCid != topic.topicCid:
            continue
        let subAddress = chainLsmrAddressFromText(subscriptions[i].addressText)
        if ! chainLsmrPubSubEligible(topic, centerAddress, subAddress):
            continue
        let route = chainLsmrRoutePlanFromAddresses(centerAddress, subAddress)
        let branchDigit = chainLsmrMulticastBranchDigit(centerAddress, subAddress)
        let deliveryPhase = chainLsmrPubSubDeliveryPhase(topic, centerAddress, subAddress)
        let branchPos = chainLsmrPubSubEnsureBranch(out, branchDigit)
        while branchBestHops.len < out.branchDigits.len:
            seqops.add(branchBestHops, -1)
        if topic.baguaMode == "xun":
            let bestHop = branchBestHops[branchPos]
            if bestHop >= 0 && route.hopCount > bestHop:
                continue
            if bestHop >= 0 && route.hopCount == bestHop && strings.len(out.branchAddressTexts[branchPos]) > 0 &&
               ! chainLexLess(subscriptions[i].addressText, out.branchAddressTexts[branchPos]):
                continue
            branchBestHops[branchPos] = route.hopCount
            out.branchNodeCounts[branchPos] = 1
            out.branchNodeIds[branchPos] = subscriptions[i].nodeId
            out.branchAddressTexts[branchPos] = subscriptions[i].addressText
            out.branchDeliveryPhases[branchPos] = deliveryPhase
            out.branchRouteCids[branchPos] = route.routeCid
            continue
        out.branchNodeCounts[branchPos] = out.branchNodeCounts[branchPos] + 1
        chainLsmrPubSubAppendCsv(out.branchNodeIds[branchPos], subscriptions[i].nodeId)
        chainLsmrPubSubAppendCsv(out.branchAddressTexts[branchPos], subscriptions[i].addressText)
        chainLsmrPubSubAppendCsv(out.branchDeliveryPhases[branchPos], deliveryPhase)
        chainLsmrPubSubAppendCsv(out.branchRouteCids[branchPos], route.routeCid)
    for i in 0..<out.branchNodeCounts.len:
        out.subscriberCount = out.subscriberCount + out.branchNodeCounts[i]
    out.branchCount = out.branchDigits.len
    chainLsmrPubSubSortBranches(out)
    out.planCid = chainCidFromText(chainLsmrPubSubPlanCanonicalText(out))
    return Ok[LsmrPubSubPlan](out)

fn chainLsmrPubSubCsgDecision(topic: LsmrPubSubTopic,
                              subscription: LsmrPubSubSubscription,
                              subgraph: LsmrCsgSubgraph): LsmrCsgFilterDecision =
    let barrierMode = strings.len(subscription.barrierMode) > 0 ? subscription.barrierMode : topic.baguaMode
    let filter = chainLsmrDefaultCsgBarrierFilter(topic.layer, barrierMode)
    return chainLsmrApplyCsgBarrierFilter(filter, subgraph)
