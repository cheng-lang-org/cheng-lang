# MsQuic TLS blueprint (no-pointer bridge).

import std/result
import std/strings
import std/rawbytes
import std/tls/x509
import cheng/quic/tls/common

type
    MsQuicTlsBlueprint =
        config: MsQuicTlsConfig
        state: MsQuicTlsState
        stats: MsQuicTlsStats
        lastError: str
        trustRoots: X509CertList

fn initMsQuicTlsBlueprint(): MsQuicTlsBlueprint =
    MsQuicTlsBlueprint(
        config: initMsQuicTlsConfig(),
        state: MsQuicTlsIdle,
        stats: initMsQuicTlsStats(),
        lastError: "",
        trustRoots: initX509CertList()
    )

fn msquicTlsBlueprintConfig(bp: var MsQuicTlsBlueprint): MsQuicTlsConfig =
    return bp.config

fn msquicTlsBlueprintState(bp: var MsQuicTlsBlueprint): MsQuicTlsState =
    return bp.state

fn msquicTlsBlueprintSetConfig(bp: var MsQuicTlsBlueprint, cfg: MsQuicTlsConfig) =
    bp.config = cfg

fn msquicTlsBlueprintLastError(bp: var MsQuicTlsBlueprint): str =
    return bp.lastError

fn msquicTlsBlueprintSetTrustRoots(bp: var MsQuicTlsBlueprint, roots: var X509CertList) =
    bp.trustRoots = roots

fn msquicTlsBlueprintVerifyPeerDerAt(
    bp: var MsQuicTlsBlueprint,
    leafDer: Bytes,
    intermediates: var X509CertList,
    now: int64
): Result[bool] =
    if bp.config.allowInsecure:
        return Ok[bool](true)
    if bp.trustRoots.count <= 0:
        return Err[bool]("msquic tls: trust roots missing")

    var leaf: X509Certificate = initX509Certificate()
    let leafRes: Result[bool] = x509ParseCertificateInto(leaf, leafDer)
    if IsErr(leafRes):
        return Err[bool](Error(leafRes))

    let chainRes: Result[bool] = x509VerifyChain(leaf, intermediates, bp.trustRoots, now)
    if IsErr(chainRes):
        return Err[bool](Error(chainRes))

    if len(bp.config.serverName) > 0:
        if ! x509VerifyHostname(leaf, bp.config.serverName):
            return Err[bool]("msquic tls: hostname mismatch")

    return Ok[bool](true)

fn msquicTlsHandshakeStart(bp: var MsQuicTlsBlueprint): Result[bool] =
    if bp.state == MsQuicTlsHandshaking:
        return Err[bool]("msquic tls: handshake already in progress")
    bp.state = MsQuicTlsHandshaking
    return Ok[bool](true)

fn msquicTlsHandshakeFinish(bp: var MsQuicTlsBlueprint, ok: bool) =
    if ok:
        bp.state = MsQuicTlsReady
        msquicTlsStatsNoteHandshake(bp.stats)
        bp.lastError = ""
    else:
        bp.state = MsQuicTlsFailed
        msquicTlsStatsNoteFailure(bp.stats)
        bp.lastError = "msquic tls: handshake failed"

fn msquicTlsReset(bp: var MsQuicTlsBlueprint) =
    bp.state = MsQuicTlsIdle
    bp.lastError = ""
