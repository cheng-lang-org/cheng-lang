# MsQuic TLS security audit(minimal).

import std/result
import std/strings
import cheng/quic/tls/common
import cheng/quic/platform/common
type
    MsQuicTlsAudit =
        ok: bool
        warnings: int32
        message: str

fn initMsQuicTlsAudit(): MsQuicTlsAudit =
    MsQuicTlsAudit(ok: true, warnings: 0, message: "")

fn msquicTlsAuditConfig(cfg: MsQuicTlsConfig): MsQuicTlsAudit =
    var audit: MsQuicTlsAudit = initMsQuicTlsAudit()
    if cfg.allowInsecure:
        audit.ok = false
        audit.warnings = audit.warnings + 1
        audit.message = "tls: insecure mode enabled"
    if cfg.version == MsQuicTls12:
        if len(audit.message) > 0:
            audit.message = audit.message + "; "
        audit.warnings = audit.warnings + 1
        audit.message = audit.message + "tls: legacy version"
    return audit

fn msquicTlsAuditSummary(audit: MsQuicTlsAudit): str =
    if audit.ok && audit.warnings == 0:
        return "tls audit ok"
    var out: str = "tls audit warnings="
    out = out + msquicPlatformIntToString(audit.warnings)
    if len(audit.message) > 0:
        out = out + " "
        out = out + audit.message
    return out
