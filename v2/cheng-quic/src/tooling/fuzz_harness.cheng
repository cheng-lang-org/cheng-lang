# Fuzz harness(minimal).

import std/result
import std/rawbytes
import cheng/quic/tooling/common
fn fuzzFlipBits(data: Bytes): Bytes =
    let n: int32 = bytesLen(data)
    if n <= 0:
        return emptyBytes()
    let out: Bytes = bytesAlloc(n)
    for i in 0..<n:
        bytesSet(out, i, 255 - bytesGet(data, i))
    return out

fn runFuzzOnce(seed: Bytes): ToolResult =
    fuzzFlipBits(seed)
    return toolOk("fuzz ok")
