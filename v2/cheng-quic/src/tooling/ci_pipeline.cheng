# CI pipeline(minimal).

import std/result
import std/strings
import std/stringlist
import cheng/quic/tooling/common
fn defaultCiSteps(): StringList =
    var list: StringList = initStringList()
    stringListAdd(list, "format")
    stringListAdd(list, "lint")
    stringListAdd(list, "build")
    stringListAdd(list, "test")
    return list

fn runCiPipeline(steps: StringList): ToolResult =
    if steps.count <= 0:
        return toolSkipped("no ci steps")
    return toolOk("ci pipeline ok")
