# Release pipeline(minimal).

import std/strings
import std/stringlist
import cheng/quic/tooling/common
fn defaultReleaseSteps(): StringList =
    var list: StringList = initStringList()
    stringListAdd(list, "build")
    stringListAdd(list, "test")
    stringListAdd(list, "package")
    return list

fn runReleasePipeline(steps: StringList): ToolResult =
    if steps.count <= 0:
        return toolSkipped("no release steps")
    return toolOk("release pipeline ok")
