# Performance CI pipeline(minimal).

import std/strings
import std/stringlist
import cheng/quic/tooling/common
fn defaultPerfCiSteps(): StringList =
    var list: StringList = initStringList()
    stringListAdd(list, "bench")
    stringListAdd(list, "perf-check")
    return list

fn runPerfCiPipeline(steps: StringList): ToolResult =
    if steps.count <= 0:
        return toolSkipped("no perf steps")
    return toolOk("perf pipeline ok")
