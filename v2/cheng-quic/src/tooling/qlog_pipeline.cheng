# Qlog pipeline(minimal).

import std/strings
import cheng/quic/tooling/common
import cheng/quic/tooling/export_sink
fn qlogPipelineRun(text: str): ToolResult =
    if len(text) <= 0:
        return toolSkipped("qlog pipeline empty")
    exportSinkStore("qlog", text)
    return toolOk("qlog pipeline ok")
