# Tool catalog(minimal).

import std/result
import std/strings
import cheng/quic/tooling/common
const
    maxTools = 32

type
    ToolHandler = fn(): ToolResult

    ToolEntry =
        name: str
        description: str
        handler: ToolHandler
        hasHandler: bool

    ToolCatalog =
        count: int32
        items: ToolEntry[maxTools]

fn initToolCatalog(): ToolCatalog =
    ToolCatalog(count: 0)

fn toolCatalogHas(cat: var ToolCatalog, name: str): bool =
    if name == nil || name == "":
        return false
    for i in 0..<cat.count:
        if (cat.items[i].name ==  name):
            return true
    return false

fn toolCatalogAdd(cat: var ToolCatalog, name: str, description: str, handler: ToolHandler): Result[bool] =
    if name == nil || name == "":
        return Err[bool]("tool: empty name")
    if toolCatalogHas(cat, name):
        return Ok[bool](true)
    if cat.count >= maxTools:
        return Err[bool]("tool: catalog full")
    cat.items[cat.count] = ToolEntry(name: name, description: description, handler: handler, hasHandler: true)
    cat.count = cat.count + 1
    return Ok[bool](true)

fn toolCatalogAddNoop(cat: var ToolCatalog, name: str, description: str): Result[bool] =
    if name == nil || name == "":
        return Err[bool]("tool: empty name")
    if toolCatalogHas(cat, name):
        return Ok[bool](true)
    if cat.count >= maxTools:
        return Err[bool]("tool: catalog full")
    cat.items[cat.count] = ToolEntry(name: name, description: description, handler: ToolHandler(nil), hasHandler: false)
    cat.count = cat.count + 1
    return Ok[bool](true)

fn toolCatalogList(cat: ToolCatalog): str =
    if cat.count <= 0:
        return ""
    var out: str = ""
    for i in 0..<cat.count:
        var line: str = cat.items[i].name
        if cat.items[i].description != nil && cat.items[i].description != "":
            line = line + ":"
            line = line + cat.items[i].description
        if out == nil || out == "":
            out = line
        else:
            out = out + "\n"
            out = out + line
    return out

fn toolCatalogRun(cat: ToolCatalog, name: str): Result[ToolResult] =
    if name == nil || name == "":
        return Err[ToolResult]("tool: empty name")
    for i in 0..<cat.count:
        let entry: ToolEntry = cat.items[i]
        if (entry.name ==  name):
            if ! entry.hasHandler:
                return Ok[ToolResult](toolSkipped("no handler"))
            let handler: ToolHandler = entry.handler
            return Ok[ToolResult](handler())
    return Err[ToolResult]("tool: ! found")
