# Performance pipeline(minimal).

import std/strings
import cheng/quic/tooling/common
import cheng/quic/tooling/export_sink
fn perfPipelineRun(text: str): ToolResult =
    if len(text) <= 0:
        return toolSkipped("perf pipeline empty")
    exportSinkStore("perf", text)
    return toolOk("perf pipeline ok")
