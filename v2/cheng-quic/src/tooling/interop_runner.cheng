# Interop runner(minimal).

import std/result
import cheng/quic/tooling/common
import cheng/quic/tooling/test_catalog
var
    interopCatalog: InteropCatalog = initInteropCatalog()

fn setInteropCatalog(cat: InteropCatalog) =
    interopCatalog = cat

fn registerInteropTest(name: str, description: str, handler: InteropTestHandler): Result[bool] =
    return interopCatalogAdd(interopCatalog, name, description, handler)

fn registerInteropTestNoop(name: str, description: str): Result[bool] =
    return interopCatalogAddNoop(interopCatalog, name, description)

fn listInteropTests(): str =
    return interopCatalogList(interopCatalog)

fn runInteropTest(name: str): Result[ToolResult] =
    return interopCatalogRun(interopCatalog, name)

fn runInteropAll(): Result[ToolResult] =
    if interopCatalog.count <= 0:
        return Ok[ToolResult](toolSkipped("no tests"))
    for i in 0..<interopCatalog.count:
        let entry: InteropTest = interopCatalog.items[i]
        if entry.hasHandler:
            let handler: InteropTestHandler = entry.handler
            let res: ToolResult = handler()
            if ! toolResultOk(res):
                return Ok[ToolResult](res)
    return Ok[ToolResult](toolOk("all tests ok"))
