# CUBIC congestion control model.

import cheng/quic/congestion/common
type
    CubicModel =
        hasHadCongestionEvent: bool
        isInRecovery: bool
        isInPersistentCongestion: bool
        timeOfLastAckValid: bool

        initialWindowPackets: int32
        sendIdleTimeoutMs: int32

        congestionWindow: int64
        prevCongestionWindow: int64
        slowStartThreshold: int64
        prevSlowStartThreshold: int64
        aimdWindow: int64
        prevAimdWindow: int64
        aimdAccumulator: int64

        bytesInFlight: int64
        bytesInFlightMax: int64
        lastSendAllowance: int64
        exemptions: int32

        timeOfLastAck: int64
        timeOfCongAvoidStart: int64
        kCubic: int64
        prevKCubic: int64
        windowPrior: int64
        prevWindowPrior: int64
        windowMax: int64
        prevWindowMax: int64
        windowLastMax: int64
        prevWindowLastMax: int64

        hyStartState: HyStartState
        hyStartAckCount: int64
        minRttInLastRound: int64
        minRttInCurrentRound: int64
        cssBaselineMinRtt: int64
        hyStartRoundEnd: int64
        cWndSlowStartGrowthDivisor: int64
        conservativeSlowStartRounds: int64

        recoverySentPacketNumber: int64
        datagramPayloadBytes: int64
        beta: float64
        cParam: float64
        kCubicSeconds: float64

fn cubicAbs(value: float64): float64 =
    if value < 0.0:
        return -value
    return value

fn cubicCbrt(value: float64): float64 =
    if value == 0.0:
        return 0.0
    var x: float64 = value
    var neg: bool = false
    if x < 0.0:
        x = -x
        neg = true
    var y: float64 = x
    for i in 0..<20:
        let denom: float64 = y * y
        if denom == 0.0:
            break
        y = (2.0 * y + x / denom) / 3.0
    if neg:
        return -y
    return y

fn cubicClampFloat(value: float64, minVal: float64, maxVal: float64): float64 =
    var v: float64 = value
    if v < minVal:
        v = minVal
    if v > maxVal:
        v = maxVal
    return v

fn cubicClampFloatToInt64(value: float64): int64 =
    if value <= 0.0:
        return 0
    let maxVal: float64 = float64(maxInt64Value)
    if value >= maxVal:
        return maxInt64Value
    return int64(value)

fn cubicMaxInt64(a: int64, b: int64): int64 =
    if a > b:
        return a
    return b

fn cubicMinInt64(a: int64, b: int64): int64 =
    if a < b:
        return a
    return b

fn cubicComputeMinCwnd(model: CubicModel): int64 =
    let twoPackets: int64 = model.datagramPayloadBytes * 2
    let minPackets: int64 = model.datagramPayloadBytes * int64(minCwndInMss)
    if twoPackets > minPackets:
        return twoPackets
    return minPackets

fn cubicSaturatingAdd(a: int64, b: int64): int64 =
    if b > 0 && a > maxInt64Value - b:
        return maxInt64Value
    return a + b

fn cubicUpdateKCubic(model: var CubicModel) =
    if model.cParam <= 0.0 || model.windowMax <= 0:
        model.kCubicSeconds = 0.0
        return
    let numerator: float64 = float64(model.windowMax) * (1.0 - model.beta)
    if numerator <= 0.0:
        model.kCubicSeconds = 0.0
        return
    model.kCubicSeconds = cubicCbrt(numerator / model.cParam)

fn cubicInit(
    initialWindowPackets: int32,
    datagramPayloadBytes: int32,
    sendIdleTimeoutMs: int32
): CubicModel =
    let initialWindowBytes: int64 = int64(datagramPayloadBytes) * int64(initialWindowPackets)
    CubicModel(
        hasHadCongestionEvent: false,
        isInRecovery: false,
        isInPersistentCongestion: false,
        timeOfLastAckValid: false,
        initialWindowPackets: initialWindowPackets,
        sendIdleTimeoutMs: sendIdleTimeoutMs,
        congestionWindow: initialWindowBytes,
        prevCongestionWindow: initialWindowBytes,
        slowStartThreshold: maxInt64Value,
        prevSlowStartThreshold: maxInt64Value,
        aimdWindow: initialWindowBytes,
        prevAimdWindow: initialWindowBytes,
        aimdAccumulator: 0,
        bytesInFlight: 0,
        bytesInFlightMax: initialWindowBytes / 2,
        lastSendAllowance: 0,
        exemptions: 0,
        timeOfLastAck: 0,
        timeOfCongAvoidStart: 0,
        kCubic: 0,
        prevKCubic: 0,
        windowPrior: initialWindowBytes,
        prevWindowPrior: initialWindowBytes,
        windowMax: initialWindowBytes,
        prevWindowMax: initialWindowBytes,
        windowLastMax: initialWindowBytes,
        prevWindowLastMax: initialWindowBytes,
        hyStartState: hyStartNotStarted,
        hyStartAckCount: 0,
        minRttInLastRound: 0,
        minRttInCurrentRound: maxInt64Value,
        cssBaselineMinRtt: 0,
        hyStartRoundEnd: 0,
        cWndSlowStartGrowthDivisor: 1,
        conservativeSlowStartRounds: 0,
        recoverySentPacketNumber: 0,
        datagramPayloadBytes: int64(datagramPayloadBytes),
        beta: 0.7,
        cParam: 0.4,
        kCubicSeconds: 0.0
    )

fn cubicEnterRecovery(model: var CubicModel, lostBytes: int64) =
    model.isInRecovery = true
    model.hasHadCongestionEvent = true
    if model.congestionWindow > lostBytes:
        model.congestionWindow = model.congestionWindow - lostBytes
    else:
        model.congestionWindow = minCwndInMss

fn cubicCanSend(model: CubicModel): bool =
    return model.bytesInFlight < model.congestionWindow || model.exemptions > 0

fn cubicSendAllowance(model: CubicModel): int64 =
    if model.congestionWindow > model.bytesInFlight:
        return model.congestionWindow - model.bytesInFlight
    return 0

fn cubicOnPacketSent(model: var CubicModel, bytes: int64, ackEliciting: bool) =
    if ackEliciting:
        model.bytesInFlight = cubicSaturatingAdd(model.bytesInFlight, bytes)
    if model.bytesInFlight > model.bytesInFlightMax:
        model.bytesInFlightMax = model.bytesInFlight

fn cubicOnDataAcked(model: var CubicModel, ack: AckEventSnapshot) =
    let acked: int64 = ack.ackedRetransmittableBytes
    if acked <= 0:
        return
    if model.bytesInFlight > acked:
        model.bytesInFlight = model.bytesInFlight - acked
    else:
        model.bytesInFlight = 0

    model.timeOfLastAck = ack.timeNow
    model.timeOfLastAckValid = true

    if model.isInRecovery && ack.largestAck > model.recoverySentPacketNumber:
        model.isInRecovery = false

    let minCwnd: int64 = cubicComputeMinCwnd(model)

    if model.congestionWindow < model.slowStartThreshold:
        model.congestionWindow = cubicSaturatingAdd(model.congestionWindow, acked)
        if model.congestionWindow >= model.slowStartThreshold:
            model.timeOfCongAvoidStart = ack.timeNow
            model.windowPrior = model.congestionWindow
            if model.congestionWindow > model.windowMax:
                model.windowMax = model.congestionWindow
            cubicUpdateKCubic(model)
    else:
        if model.timeOfCongAvoidStart == 0:
            model.timeOfCongAvoidStart = ack.timeNow
        var elapsedUs: int64 = 0
        if ack.timeNow > model.timeOfCongAvoidStart:
            elapsedUs = ack.timeNow - model.timeOfCongAvoidStart
        let t: float64 = float64(elapsedUs) / float64(microSecsInSec)
        let diff: float64 = t - model.kCubicSeconds
        let cubicTarget: float64 = float64(model.windowMax) + model.cParam * diff * diff * diff
        var renoInc: float64 = 0.0
        if model.congestionWindow == 0:
            renoInc = float64(model.datagramPayloadBytes)
        else:
            renoInc = float64(model.datagramPayloadBytes) * float64(acked) / float64(model.congestionWindow)
        let renoTarget: float64 = float64(model.congestionWindow) + renoInc
        let desired: float64 = if cubicTarget > renoTarget: cubicTarget else: renoTarget
        let bounded: float64 = cubicClampFloat(desired, float64(minCwnd), float64(maxInt64Value))
        model.congestionWindow = cubicClampFloatToInt64(bounded)

    if model.congestionWindow < minCwnd:
        model.congestionWindow = minCwnd

    if model.bytesInFlight > model.congestionWindow:
        model.bytesInFlight = model.congestionWindow
    if model.bytesInFlight > model.bytesInFlightMax:
        model.bytesInFlightMax = model.bytesInFlight

fn cubicOnDataLost(model: var CubicModel, loss: LossEventSnapshot) =
    let lostBytes: int64 = loss.retransmittableBytesLost
    if model.bytesInFlight > lostBytes:
        model.bytesInFlight = model.bytesInFlight - lostBytes
    else:
        model.bytesInFlight = 0

    model.isInRecovery = true
    model.hasHadCongestionEvent = true
    model.recoverySentPacketNumber = loss.largestSentPacketNumber

    model.windowLastMax = model.windowMax
    model.windowPrior = model.congestionWindow
    model.windowMax = cubicMaxInt64(model.congestionWindow, cubicComputeMinCwnd(model))

    let minCwnd: int64 = cubicComputeMinCwnd(model)
    var ssthresh: int64 = model.congestionWindow / 2
    if ssthresh < minCwnd:
        ssthresh = minCwnd
    model.slowStartThreshold = ssthresh
    model.congestionWindow = ssthresh

    cubicUpdateKCubic(model)
    model.bytesInFlight = cubicMinInt64(model.bytesInFlight, model.congestionWindow)

fn cubicOnProbeTimeout(model: var CubicModel) =
    let minCwnd: int64 = cubicComputeMinCwnd(model)
    var ssthresh: int64 = model.congestionWindow / 2
    if ssthresh < minCwnd:
        ssthresh = minCwnd
    model.slowStartThreshold = ssthresh
    model.congestionWindow = minCwnd
    model.bytesInFlight = cubicMinInt64(model.bytesInFlight, model.congestionWindow)
    model.isInRecovery = false
    cubicUpdateKCubic(model)

fn cubicBytesInFlight(model: CubicModel): int64 =
    return model.bytesInFlight
