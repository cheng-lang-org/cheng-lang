fn msquicConnectionOpenBidiStream(c: var MsQuicConnection): Result[MsQuicStream] =
    if ! c.open:
        return Err[MsQuicStream]("msquic: connection closed")
    if c.peerMaxStreamsBidi > 0 && c.nextBidiId >= c.peerMaxStreamsBidi:
        return Err[MsQuicStream]("msquic: bidi stream limit reached")
    let id: int64 = msquicStreamIdFromParts(c.nextBidiId, c.isClient, true)
    c.nextBidiId = c.nextBidiId + 1
    c.streamsOpened = c.streamsOpened + 1
    msquicConnectionTouch(c)
    return Ok[MsQuicStream](initMsQuicStream(id, true))

fn msquicConnectionOpenUniStream(c: var MsQuicConnection): Result[MsQuicStream] =
    if ! c.open:
        return Err[MsQuicStream]("msquic: connection closed")
    if c.peerMaxStreamsUni > 0 && c.nextUniId >= c.peerMaxStreamsUni:
        return Err[MsQuicStream]("msquic: uni stream limit reached")
    let id: int64 = msquicStreamIdFromParts(c.nextUniId, c.isClient, false)
    c.nextUniId = c.nextUniId + 1
    c.streamsOpened = c.streamsOpened + 1
    msquicConnectionTouch(c)
    return Ok[MsQuicStream](initMsQuicStream(id, false))

fn msquicConnectionClose(c: var MsQuicConnection) =
    c.open = false

fn msquicConnectionRecordPacketSent(c: var MsQuicConnection, bytes: int64) =
    if bytes > 0:
        c.bytesSent = c.bytesSent + bytes
    c.packetsSent = c.packetsSent + 1

fn msquicConnectionRecordPacketRecv(c: var MsQuicConnection, bytes: int64) =
    if bytes > 0:
        c.bytesRecv = c.bytesRecv + bytes
    c.packetsRecv = c.packetsRecv + 1

fn msquicConnectionRecordStreamOpened(c: var MsQuicConnection) =
    c.streamsOpened = c.streamsOpened + 1

fn msquicConnectionRecordStreamClosed(c: var MsQuicConnection) =
    c.streamsClosed = c.streamsClosed + 1

fn msquicConnectionUpdateNetworkStats(
    c: var MsQuicConnection,
    smoothedRttMs: int64,
    minRttMs: int64,
    rttVarMs: int64,
    maxRttMs: int64,
    bytesInFlight: int64,
    lostPackets: int64,
    pathMtu: int32,
    postedBytes: int64,
    idealBytes: int64,
    congestionWindow: int64,
    bandwidthOut: int64,
    deliveryRateOut: int64,
    bandwidthIn: int64,
    deliveryRateIn: int64
) =
    if smoothedRttMs >= 0:
        c.smoothedRttMs = smoothedRttMs
    if minRttMs >= 0:
        c.minRttMs = minRttMs
    if rttVarMs >= 0:
        c.rttVarMs = rttVarMs
    if maxRttMs >= 0:
        c.maxRttMs = maxRttMs
    if bytesInFlight >= 0:
        c.bytesInFlight = bytesInFlight
    if lostPackets >= 0:
        c.lostPackets = lostPackets
    if pathMtu >= 0:
        c.pathMtu = pathMtu
    if postedBytes >= 0:
        c.netPostedBytes = postedBytes
    if idealBytes >= 0:
        c.netIdealBytes = idealBytes
    if congestionWindow >= 0:
        c.netCongestionWindow = congestionWindow
    if bandwidthOut >= 0:
        c.netBandwidth = bandwidthOut
        c.netBandwidthOut = bandwidthOut
    if bandwidthIn >= 0:
        c.netBandwidthIn = bandwidthIn
    if deliveryRateOut >= 0:
        c.netDeliveryRateOut = deliveryRateOut
    if deliveryRateIn >= 0:
        c.netDeliveryRateIn = deliveryRateIn

fn msquicConnectionRecordSendRetransmittablePacket(c: var MsQuicConnection) =
    c.sendRetransmittablePackets = c.sendRetransmittablePackets + 1

fn msquicConnectionRecordSendSuspectedLostPacket(c: var MsQuicConnection) =
    c.sendSuspectedLostPackets = c.sendSuspectedLostPackets + 1

fn msquicConnectionRecordSendSpuriousLostPacket(c: var MsQuicConnection) =
    c.sendSpuriousLostPackets = c.sendSpuriousLostPackets + 1

fn msquicConnectionRecordSendCongestion(c: var MsQuicConnection) =
    c.sendCongestionCount = c.sendCongestionCount + 1

fn msquicConnectionRecordSendPersistentCongestion(c: var MsQuicConnection) =
    c.sendPersistentCongestionCount = c.sendPersistentCongestionCount + 1

fn msquicConnectionRecordSendEcnCongestion(c: var MsQuicConnection) =
    c.sendEcnCongestionCount = c.sendEcnCongestionCount + 1

fn msquicConnectionRecordSendStreamBytes(c: var MsQuicConnection, bytes: int64) =
    if bytes > 0:
        c.sendTotalStreamBytes = c.sendTotalStreamBytes + bytes

fn msquicConnectionRecordRecvReorderedPacket(c: var MsQuicConnection) =
    c.recvReorderedPackets = c.recvReorderedPackets + 1

fn msquicConnectionRecordRecvDroppedPacket(c: var MsQuicConnection) =
    c.recvDroppedPackets = c.recvDroppedPackets + 1

fn msquicConnectionRecordRecvDuplicatePacket(c: var MsQuicConnection) =
    c.recvDuplicatePackets = c.recvDuplicatePackets + 1

fn msquicConnectionRecordRecvDecryptionFailure(c: var MsQuicConnection) =
    c.recvDecryptionFailures = c.recvDecryptionFailures + 1

fn msquicConnectionRecordRecvValidAckFrame(c: var MsQuicConnection) =
    c.recvValidAckFrames = c.recvValidAckFrames + 1

fn msquicConnectionRecordRecvStreamBytes(c: var MsQuicConnection, bytes: int64) =
    if bytes > 0:
        c.recvTotalStreamBytes = c.recvTotalStreamBytes + bytes

fn msquicConnectionRecordTimingInitialFlightEnd(c: var MsQuicConnection, nowUs: int64) =
    if c.timingInitialFlightEndUs <= 0 && nowUs > 0:
        c.timingInitialFlightEndUs = nowUs

fn msquicConnectionRecordTimingHandshakeFlightEnd(c: var MsQuicConnection, nowUs: int64) =
    if c.timingHandshakeFlightEndUs <= 0 && nowUs > 0:
        c.timingHandshakeFlightEndUs = nowUs

fn msquicConnectionRecordHandshakeClientFlight1Bytes(c: var MsQuicConnection, bytes: int32) =
    if c.handshakeClientFlight1Bytes <= 0 && bytes > 0:
        c.handshakeClientFlight1Bytes = bytes

fn msquicConnectionRecordHandshakeServerFlight1Bytes(c: var MsQuicConnection, bytes: int32) =
    if c.handshakeServerFlight1Bytes <= 0 && bytes > 0:
        c.handshakeServerFlight1Bytes = bytes

fn msquicConnectionRecordHandshakeClientFlight2Bytes(c: var MsQuicConnection, bytes: int32) =
    if c.handshakeClientFlight2Bytes <= 0 && bytes > 0:
        c.handshakeClientFlight2Bytes = bytes

fn msquicConnectionRecordHandshakeHopLimitTtl(c: var MsQuicConnection, ttl: int32) =
    if c.handshakeHopLimitTtl <= 0 && ttl > 0:
        c.handshakeHopLimitTtl = ttl

fn msquicConnectionSettings(c: MsQuicConnection): MsQuicSettings =
    c.settings

fn msquicConnectionApplySettings(c: var MsQuicConnection, settings: MsQuicSettings): Result[bool] =
    let validRes: Result[bool] = validateMsQuicSettings(settings)
    if IsErr(validRes):
        return Err[bool](Error(validRes))
    c.settings = settings
    c.maxStreamsBidi = settings.maxStreamsBidi
    c.maxStreamsUni = settings.maxStreamsUni
    c.peerMaxStreamsBidi = settings.maxStreamsBidi
    c.peerMaxStreamsUni = settings.maxStreamsUni
    c.datagramReceiveEnabled = settings.allowDatagram
    c.datagramSendEnabled = settings.allowDatagram
    return Ok[bool](true)

fn msquicConnectionSetMaxStreamsBidi(c: var MsQuicConnection, value: int32): Result[bool] =
    if value < 0:
        return Err[bool]("msquic: maxStreamsBidi must be non-negative")
    c.maxStreamsBidi = value
    c.settings.maxStreamsBidi = value
    return Ok[bool](true)

fn msquicConnectionSetMaxStreamsUni(c: var MsQuicConnection, value: int32): Result[bool] =
    if value < 0:
        return Err[bool]("msquic: maxStreamsUni must be non-negative")
    c.maxStreamsUni = value
    c.settings.maxStreamsUni = value
    return Ok[bool](true)

fn msquicConnectionSetQuicVersion(c: var MsQuicConnection, version: int32) =
    c.quicVersion = version
    if c.originalQuicVersion <= 0:
        c.originalQuicVersion = version

