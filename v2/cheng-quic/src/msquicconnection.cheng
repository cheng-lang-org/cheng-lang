fn initMsQuicConnection(id: int64, localAddr: MultiAddress, remoteAddr: MultiAddress, settings: MsQuicSettings, isClient: bool): MsQuicConnection =
    let now: int64 = msquicNowMs()
    MsQuicConnection(
        id: id,
        localAddr: localAddr,
        remoteAddr: remoteAddr,
        isClient: isClient,
        open: true,
        createdAtMs: now,
        lastActiveMs: now,
        settings: settings,
        bytesSent: 0,
        bytesRecv: 0,
        packetsSent: 0,
        packetsRecv: 0,
        streamsOpened: 0,
        streamsClosed: 0,
        smoothedRttMs: 0,
        minRttMs: 0,
        rttVarMs: 0,
        maxRttMs: 0,
        bytesInFlight: 0,
        lostPackets: 0,
        sendSuspectedLostPackets: 0,
        sendRetransmittablePackets: 0,
        sendSpuriousLostPackets: 0,
        sendCongestionCount: 0,
        sendPersistentCongestionCount: 0,
        sendEcnCongestionCount: 0,
        sendTotalStreamBytes: 0,
        recvReorderedPackets: 0,
        recvDroppedPackets: 0,
        recvDuplicatePackets: 0,
        recvDecryptionFailures: 0,
        recvValidAckFrames: 0,
        recvTotalStreamBytes: 0,
        timingInitialFlightEndUs: 0,
        timingHandshakeFlightEndUs: 0,
        handshakeClientFlight1Bytes: 0,
        handshakeServerFlight1Bytes: 0,
        handshakeClientFlight2Bytes: 0,
        handshakeHopLimitTtl: 0,
        pathMtu: 0,
        netPostedBytes: 0,
        netIdealBytes: 0,
        netCongestionWindow: 0,
        netBandwidth: 0,
        netBandwidthOut: 0,
        netBandwidthIn: 0,
        netDeliveryRateOut: 0,
        netDeliveryRateIn: 0,
        maxStreamsBidi: settings.maxStreamsBidi,
        maxStreamsUni: settings.maxStreamsUni,
        peerMaxStreamsBidi: settings.maxStreamsBidi,
        peerMaxStreamsUni: settings.maxStreamsUni,
        nextBidiId: 0,
        nextUniId: 0,
        quicVersion: 0,
        originalQuicVersion: 0,
        previousQuicVersion: 0,
        versionNegotiation: false,
        statelessRetry: false,
        resumptionAttempted: false,
        resumptionSucceeded: false,
        compatibleVersionNegotiationAttempted: false,
        compatibleVersionNegotiationCompleted: false,
        keyUpdateCount: 0,
        destCidUpdateCount: 0,
        idealProcessor: 0,
        streamSchedulingScheme: QUIC_STREAM_SCHEDULING_SCHEME_FIFO,
        datagramReceiveEnabled: settings.allowDatagram,
        datagramSendEnabled: settings.allowDatagram,
        disable1RttEncryption: false,
        closeReasonPhrase: "",
        closeErrorCode: -1,
        closeFrameType: -1,
        closeAppError: false,
        shareUdpBinding: false,
        resumptionTicket: emptyBytes(),
        resumptionPsk: emptyBytes(),
        resumptionTicketAgeAdd: 0,
        resumptionTicketLifetimeSec: 0,
        resumptionTicketReceivedAtMs: 0,
        resumptionPskCipher: MsQuicCipherAes128Gcm,
        peerCertificateValid: false,
        localInterface: 0,
        cibirId: emptyBytes(),
        origDestCid: emptyBytes(),
        sendDscp: 0,
        closeAsync: false,
        tlsSecrets: initQuicTlsSecrets(),
        tlsHandshakeInfo: initQuicHandshakeInfo(),
        tlsNegotiatedAlpn: emptyBytes(),
        versionSettings: initQuicVersionSettings()
    )

fn msquicConnectionId(c: MsQuicConnection): int64 =
    c.id

fn msquicConnectionCreatedAtMs(c: MsQuicConnection): int64 =
    c.createdAtMs

fn msquicConnectionIsClient(c: MsQuicConnection): bool =
    c.isClient

fn msquicConnectionSetIsClient(c: var MsQuicConnection, isClient: bool) =
    c.isClient = isClient

fn msquicStreamIdIsBidi(streamId: int64): bool =
    return (streamId & 0x2) == 0

fn msquicStreamIdIsUni(streamId: int64): bool =
    return (streamId & 0x2) != 0

fn msquicStreamIdIsClientInitiated(streamId: int64): bool =
    return (streamId & 0x1) == 0

fn msquicStreamIdSequence(streamId: int64): int64 =
    if streamId < 0:
        return -1
    return streamId >> 2

fn msquicStreamIdFromParts(seq: int64, isClient: bool, bidi: bool): int64 =
    var out: int64 = seq << 2
    if ! bidi:
        out = out | 0x2
    if ! isClient:
        out = out | 0x1
    return out

fn msquicStreamIdIsLocalInitiated(c: MsQuicConnection, streamId: int64): bool =
    if msquicStreamIdIsClientInitiated(streamId):
        return c.isClient
    return ! c.isClient

fn msquicStreamIdIsPeerInitiated(c: MsQuicConnection, streamId: int64): bool =
    return ! msquicStreamIdIsLocalInitiated(c, streamId)

fn msquicConnectionIsOpen(c: MsQuicConnection): bool =
    c.open

fn msquicConnectionLocalAddr(c: MsQuicConnection): MultiAddress =
    c.localAddr

fn msquicConnectionRemoteAddr(c: MsQuicConnection): MultiAddress =
    c.remoteAddr

fn msquicConnectionSetLocalAddr(c: var MsQuicConnection, addr: MultiAddress) =
    c.localAddr = addr
    msquicConnectionTouch(c)

fn msquicConnectionSetRemoteAddr(c: var MsQuicConnection, addr: MultiAddress) =
    c.remoteAddr = addr
    msquicConnectionTouch(c)

fn msquicConnectionTouch(c: var MsQuicConnection) =
    c.lastActiveMs = msquicNowMs()

fn msquicConnectionIdleMs(c: MsQuicConnection): int64 =
    msquicNowMs() - c.lastActiveMs

