# MsQuic TLS X.509 verify test(DER chain + hostname).

import std/result
import std/strings
import std/rawbytes
import std/tls/x509
import std/crypto/bigint
import std/crypto/rsa
import cheng/quic/tests/x509_vectors
import cheng/quic/tls/blueprint
const
    # SHA256(modulus) from `openssl x509 -noout -modulus` (x509RootHex).
    x509RootModSha256Hex = "e74cc408670cb7b5bb4b142479f174f102993208d00afa381f3719b5b3c1e89b"
    # SHA256(signatureValue BIT STRING payload) from `openssl x509 -text` (x509LeafHex).
    x509LeafSigSha256Hex = "c4835cf9690ca2225107747d09b2638875f302b71bdb07771384dc5163ad30f0"
fn hexValue(c: char): int32 =
    if c >= '0' && c <= '9':
        return int32(c) - int32('0')
    if c >= 'a' && c <= 'f':
        return 10 + int32(c) - int32('a')
    if c >= 'A' && c <= 'F':
        return 10 + int32(c) - int32('A')
    return -1

fn hexDecode(text: str): Result[Bytes] =
    if len(text) % 2 != 0:
        return Err[Bytes]("tls: hex length must be even")
    let out: Bytes = bytesAlloc(len(text) / 2)
    var i: int32 = 0
    while i < len(text):
        let hi: int32 = hexValue(text[i])
        let lo: int32 = hexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes]("tls: invalid hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn runTlsX509Test(): Result[bool] =
    let rootDerRes: Result[Bytes] = hexDecode(x509RootHex)
    if IsErr(rootDerRes):
        return Err[bool]("tls_x509: decode root: " + Error(rootDerRes))
    let leafDerRes: Result[Bytes] = hexDecode(x509LeafHex)
    if IsErr(leafDerRes):
        return Err[bool]("tls_x509: decode leaf: " + Error(leafDerRes))
    let probeView: Bytes = bytesSliceView(Value(leafDerRes), 0, 16)
    let probeCopy: Bytes = bytesSlice(Value(leafDerRes), 0, 16)
    if ! bytesEqual(probeView, probeCopy):
        return Err[bool]("tls_x509: bytesSlice copy mismatch")
    var leafCert: X509Certificate = initX509Certificate()
    let leafCertRes: Result[bool] = x509ParseCertificateInto(leafCert, Value(leafDerRes))
    if IsErr(leafCertRes):
        return Err[bool]("tls_x509: parse leaf: " + Error(leafCertRes))
    if leafCert.sigAlg == X509SigUnknown:
        return Err[bool]("tls_x509: leaf signature algorithm unknown")
    if leafCert.publicKey.kind == X509KeyUnknown:
        return Err[bool]("tls_x509: leaf public key missing")
    if bytesLen(leafCert.tbs) <= 0:
        return Err[bool]("tls_x509: leaf tbs empty")
    if bytesLen(leafCert.signature) <= 0:
        return Err[bool]("tls_x509: leaf signature empty")
    let expectedLeafSigHashRes: Result[Bytes] = hexDecode(x509LeafSigSha256Hex)
    if IsErr(expectedLeafSigHashRes):
        return Err[bool]("tls_x509: decode leaf sig hash: " + Error(expectedLeafSigHashRes))
    let leafSigHash: Bytes = rsaHashSha256(leafCert.signature)
    if ! bytesEqual(leafSigHash, Value(expectedLeafSigHashRes)):
        return Err[bool]("tls_x509: leaf signature bytes mismatch")
    let sigBigRes: Result[BigInt] = bigFromBytes(leafCert.signature)
    if IsErr(sigBigRes):
        return Err[bool]("tls_x509: leaf signature bigint parse: " + Error(sigBigRes))
    let sigRoundtrip: Bytes = bigToBytes(Value(sigBigRes), bytesLen(leafCert.signature))
    if ! bytesEqual(sigRoundtrip, leafCert.signature):
        return Err[bool]("tls_x509: leaf signature bigint roundtrip mismatch")
    if leafCert.notBefore <= 0 || leafCert.notAfter <= 0:
        return Err[bool](
            "tls_x509: leaf validity empty notBefore=" + $(leafCert.notBefore)
            + " notAfter=" + $(leafCert.notAfter)
        )
    if bytesLen(leafCert.issuer) <= 0 || bytesLen(leafCert.subject) <= 0:
        return Err[bool](
            "tls_x509: leaf name empty issuerLen=" + $(bytesLen(leafCert.issuer))
            + " subjectLen=" + $(bytesLen(leafCert.subject))
        )
    if bytesEqual(leafCert.issuer, leafCert.subject):
        return Err[bool]("tls_x509: leaf parsed as self-signed")
    var roots: X509CertList = initX509CertList()
    let addRootRes: Result[bool] = x509CertListAddDer(roots, Value(rootDerRes))
    if IsErr(addRootRes):
        return Err[bool]("tls_x509: add root: " + Error(addRootRes))
    var rootCert: X509Certificate = initX509Certificate()
    let rootCertRes: Result[bool] = x509ParseCertificateInto(rootCert, Value(rootDerRes))
    if IsErr(rootCertRes):
        return Err[bool]("tls_x509: parse root: " + Error(rootCertRes))
    if rootCert.publicKey.kind != X509KeyRsa:
        return Err[bool]("tls_x509: root public key ! rsa")
    let expectedRootModHashRes: Result[Bytes] = hexDecode(x509RootModSha256Hex)
    if IsErr(expectedRootModHashRes):
        return Err[bool]("tls_x509: decode root mod hash: " + Error(expectedRootModHashRes))
    let modBytes: Bytes = bigToBytes(rootCert.publicKey.rsa.n, rootCert.publicKey.rsa.modLen)
    let modHash: Bytes = rsaHashSha256(modBytes)
    if ! bytesEqual(modHash, Value(expectedRootModHashRes)):
        return Err[bool]("tls_x509: root modulus hash mismatch")
    if leafCert.sigAlg != X509SigRsaSha256:
        return Err[bool]("tls_x509: expected rsa sha256 leaf")
    var rootPub: RsaBigPublicKey = RsaBigPublicKey(
        n: rootCert.publicKey.rsa.n,
        e: rootCert.publicKey.rsa.e,
        modBits: rootCert.publicKey.rsa.modBits,
        modLen: rootCert.publicKey.rsa.modLen
    )
    let modBytes2: Bytes = bigToBytes(rootPub.n, rootPub.modLen)
    let modHash2: Bytes = rsaHashSha256(modBytes2)
    if ! bytesEqual(modHash2, Value(expectedRootModHashRes)):
        return Err[bool]("tls_x509: root modulus hash mismatch (rootPub)")
    let sigBig: BigInt = Value(sigBigRes)
    let sigCount: int32 = sigBig.count
    let modCount: int32 = rootPub.n.count
    let sigMsw: int64 = if sigCount > 0: int64(sigBig.limbs[sigCount - 1]) else: int64(-1)
    let modMsw: int64 = if modCount > 0: int64(rootPub.n.limbs[modCount - 1]) else: int64(-1)
    let cmpBefore: int32 = bigCmp(sigBig, rootPub.n)
    if cmpBefore >= 0:
        return Err[bool](
            "tls_x509: signature >= modulus before verify cmp=" + $(cmpBefore)
            + " sigCount=" + $(sigCount)
            + " modCount=" + $(modCount)
            + " sigMsw=" + $(sigMsw)
            + " modMsw=" + $(modMsw)
            + " sigB0=" + $(bytesGet(leafCert.signature, 0))
            + " modB0=" + $(bytesGet(modBytes2, 0))
        )
    let directSigRes: Result[bool] = rsaVerifyPkcs1Diag(
        rootPub,
        leafCert.tbs,
        leafCert.signature,
        false
    )
    if IsErr(directSigRes):
        return Err[bool]("tls_x509: direct verify leaf: " + Error(directSigRes) + " cmpBefore=" + $(cmpBefore))
    var bp: MsQuicTlsBlueprint = initMsQuicTlsBlueprint()
    var cfg: MsQuicTlsConfig = msquicTlsBlueprintConfig(bp)
    cfg.serverName = "example.com"
    msquicTlsBlueprintSetConfig(bp, cfg)
    msquicTlsBlueprintSetTrustRoots(bp, roots)
    let now: int64 = leafCert.notBefore + 60
    var inters: X509CertList = initX509CertList()
    let verifyRes: Result[bool] = msquicTlsBlueprintVerifyPeerDerAt(bp, Value(leafDerRes), inters, now)
    if IsErr(verifyRes):
        return Err[bool]("tls_x509: verify leaf: " + Error(verifyRes))
    cfg.serverName = "bad.example.com"
    msquicTlsBlueprintSetConfig(bp, cfg)
    let badRes: Result[bool] = msquicTlsBlueprintVerifyPeerDerAt(bp, Value(leafDerRes), inters, now)
    if IsOk(badRes):
        return Err[bool]("tls: expected hostname mismatch")
    cfg.allowInsecure = true
    msquicTlsBlueprintSetConfig(bp, cfg)
    var emptyRoots: X509CertList = initX509CertList()
    msquicTlsBlueprintSetTrustRoots(bp, emptyRoots)
    let insecureRes: Result[bool] = msquicTlsBlueprintVerifyPeerDerAt(bp, Value(leafDerRes), inters, now)
    if IsErr(insecureRes):
        return Err[bool]("tls_x509: insecure verify leaf: " + Error(insecureRes))
    let pssRootDerRes: Result[Bytes] = hexDecode(x509PssRootHex)
    if IsErr(pssRootDerRes):
        return Err[bool]("tls_x509: decode pss root: " + Error(pssRootDerRes))
    let pssLeafDerRes: Result[Bytes] = hexDecode(x509PssLeafHex)
    if IsErr(pssLeafDerRes):
        return Err[bool]("tls_x509: decode pss leaf: " + Error(pssLeafDerRes))
    var pssLeafCert: X509Certificate = initX509Certificate()
    let pssLeafCertRes: Result[bool] = x509ParseCertificateInto(pssLeafCert, Value(pssLeafDerRes))
    if IsErr(pssLeafCertRes):
        return Err[bool]("tls_x509: parse pss leaf: " + Error(pssLeafCertRes))
    var pssRoots: X509CertList = initX509CertList()
    let addPssRes: Result[bool] = x509CertListAddDer(pssRoots, Value(pssRootDerRes))
    if IsErr(addPssRes):
        return Err[bool]("tls_x509: add pss root: " + Error(addPssRes))
    cfg.allowInsecure = false
    cfg.serverName = "pss.example.com"
    msquicTlsBlueprintSetConfig(bp, cfg)
    msquicTlsBlueprintSetTrustRoots(bp, pssRoots)
    let pssNow: int64 = pssLeafCert.notBefore + 60
    var pssInters: X509CertList = initX509CertList()
    let pssRes: Result[bool] = msquicTlsBlueprintVerifyPeerDerAt(bp, Value(pssLeafDerRes), pssInters, pssNow)
    if IsErr(pssRes):
        return Err[bool]("tls_x509: verify pss leaf: " + Error(pssRes))
    return Ok[bool](true)
