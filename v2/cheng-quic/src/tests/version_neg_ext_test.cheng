# MsQuic version negotiation extension test(manual).

import std/result
import std/rawbytes
import cheng/quic/inc/msquic_constants
import cheng/quic/inc/msquic_types
import cheng/quic/core/version_neg
fn runVersionNegotiationExtTest(): Result[bool] =
    let supported: QUIC_SUPPORTED_VERSIONS = msquicDefaultSupportedVersions()
    if supported.count != 4:
        return Err[bool]("version neg: supported list size mismatch")
    if ! msquicVersionListContains(supported, qUIC_VERSION_1_H):
        return Err[bool]("version neg: missing v1")
    if ! msquicVersionListContains(supported, qUIC_VERSION_2_H):
        return Err[bool]("version neg: missing v2")
    if ! msquicVersionListContains(supported, qUIC_VERSION_MS_1_H):
        return Err[bool]("version neg: missing ms1")
    if ! msquicVersionListContains(supported, qUIC_VERSION_DRAFT_29_H):
        return Err[bool]("version neg: missing draft29")
    if ! msquicVersionIsSupported(qUIC_VERSION_1_H):
        return Err[bool]("version neg: v1 ! supported")
    if msquicVersionIsSupported(123456):
        return Err[bool]("version neg: unexpected supported version")
    if ! msquicVersionIsReserved(qUIC_VERSION_RESERVED):
        return Err[bool]("version neg: reserved check failed")
    if ! msquicVersionNegotiationAreCompatible(qUIC_VERSION_MS_1_H, qUIC_VERSION_1_H):
        return Err[bool]("version neg: ms1 compatibility failed")
    if ! msquicVersionNegotiationAreCompatible(qUIC_VERSION_1_H, qUIC_VERSION_MS_1_H):
        return Err[bool]("version neg: v1 compatibility failed")
    if ! msquicVersionNegotiationAreCompatible(qUIC_VERSION_1_H, qUIC_VERSION_2_H):
        return Err[bool]("version neg: v2 compatibility failed")
    if msquicVersionNegotiationAreCompatible(qUIC_VERSION_2_H, qUIC_VERSION_1_H):
        return Err[bool]("version neg: unexpected reverse compatibility")

    let compatRes: Result[QUIC_SUPPORTED_VERSIONS] = msquicVersionNegotiationGenerateCompatibleList(qUIC_VERSION_1_H, supported)
    if IsErr(compatRes):
        return Err[bool](Error(compatRes))
    let compat: QUIC_SUPPORTED_VERSIONS = Value(compatRes)
    if compat.count != 3:
        return Err[bool]("version neg: compatible list size mismatch")
    if compat.versions[0] != qUIC_VERSION_1_H:
        return Err[bool]("version neg: compatible list missing original")
    if ! msquicVersionListContains(compat, qUIC_VERSION_2_H):
        return Err[bool]("version neg: compatible list missing v2")
    if ! msquicVersionListContains(compat, qUIC_VERSION_MS_1_H):
        return Err[bool]("version neg: compatible list missing ms1")
    if msquicVersionListContains(compat, qUIC_VERSION_DRAFT_29_H):
        return Err[bool]("version neg: unexpected draft29 compatibility")

    let serverEncRes: Result[Bytes] = msquicVersionNegotiationEncodeServerInfo(qUIC_VERSION_1_H, supported)
    if IsErr(serverEncRes):
        return Err[bool](Error(serverEncRes))
    let serverDecRes: Result[MsQuicVersionInfo] = msquicVersionNegotiationParseInfo(true, Value(serverEncRes))
    if IsErr(serverDecRes):
        return Err[bool](Error(serverDecRes))
    let serverInfo: MsQuicVersionInfo = Value(serverDecRes)
    if serverInfo.chosenVersion != qUIC_VERSION_1_H:
        return Err[bool]("version neg: server chosen version mismatch")
    if serverInfo.availableVersions.count != supported.count:
        return Err[bool]("version neg: server available count mismatch")

    let clientEncRes: Result[Bytes] = msquicVersionNegotiationEncodeClientInfo(qUIC_VERSION_1_H, supported)
    if IsErr(clientEncRes):
        return Err[bool](Error(clientEncRes))
    let clientDecRes: Result[MsQuicVersionInfo] = msquicVersionNegotiationParseInfo(false, Value(clientEncRes))
    if IsErr(clientDecRes):
        return Err[bool](Error(clientDecRes))
    let clientInfo: MsQuicVersionInfo = Value(clientDecRes)
    if clientInfo.chosenVersion != qUIC_VERSION_1_H:
        return Err[bool]("version neg: client chosen version mismatch")
    if clientInfo.availableVersions.count != compat.count:
        return Err[bool]("version neg: client available count mismatch")
    if ! msquicVersionListContains(clientInfo.availableVersions, qUIC_VERSION_2_H):
        return Err[bool]("version neg: client list missing v2")

    let shortBuf: Bytes = bytesAlloc(2)
    let shortRes: Result[MsQuicVersionInfo] = msquicVersionNegotiationParseInfo(false, shortBuf)
    if IsOk(shortRes):
        return Err[bool]("version neg: short buffer accepted")
    let onlyChosen: Bytes = bytesAlloc(4)
    let serverMissingRes: Result[MsQuicVersionInfo] = msquicVersionNegotiationParseInfo(true, onlyChosen)
    if IsOk(serverMissingRes):
        return Err[bool]("version neg: server missing list accepted")
    let badLen: Bytes = bytesAlloc(6)
    let badLenRes: Result[MsQuicVersionInfo] = msquicVersionNegotiationParseInfo(false, badLen)
    if IsOk(badLenRes):
        return Err[bool]("version neg: invalid length accepted")
    var vs: QUIC_VERSION_SETTINGS = initQuicVersionSettings()
    vs.enabled.count = 2
    vs.enabled.versions[0] = qUIC_VERSION_MS_1_H
    vs.enabled.versions[1] = qUIC_VERSION_1_H
    vs.defaultVersion = qUIC_VERSION_1_H
    var avail: QUIC_SUPPORTED_VERSIONS = initQuicSupportedVersions()
    avail.count = 2
    avail.versions[0] = qUIC_VERSION_1_H
    avail.versions[1] = qUIC_VERSION_MS_1_H
    let info: MsQuicVersionInfo = MsQuicVersionInfo(chosenVersion: qUIC_VERSION_1_H, availableVersions: avail)
    let okInfoRes: Result[bool] = msquicVersionNegotiationValidateInfo(qUIC_VERSION_1_H, info)
    if IsErr(okInfoRes):
        return Err[bool](Error(okInfoRes))
    let badInfo: MsQuicVersionInfo = MsQuicVersionInfo(chosenVersion: qUIC_VERSION_MS_1_H, availableVersions: avail)
    let badInfoRes: Result[bool] = msquicVersionNegotiationValidateInfo(qUIC_VERSION_1_H, badInfo)
    if IsOk(badInfoRes):
        return Err[bool]("version neg: chosen version mismatch accepted")
    let upgradeRes: Result[int32] = msquicVersionNegotiationServerUpgrade(qUIC_VERSION_1_H, vs, info)
    if IsErr(upgradeRes):
        return Err[bool](Error(upgradeRes))
    if Value(upgradeRes) != qUIC_VERSION_MS_1_H:
        return Err[bool]("version neg: server upgrade mismatch")
    let clientRes: Result[bool] = msquicVersionNegotiationClientCheck(info, vs, qUIC_VERSION_1_H, 0, false, false)
    if IsErr(clientRes):
        return Err[bool](Error(clientRes))
    if Value(clientRes):
        return Err[bool]("version neg: unexpected compat completion")
    let compatInfo: MsQuicVersionInfo = MsQuicVersionInfo(chosenVersion: qUIC_VERSION_MS_1_H, availableVersions: avail)
    let compatRes: Result[bool] = msquicVersionNegotiationClientCheck(compatInfo, vs, qUIC_VERSION_1_H, 0, false, true)
    if IsErr(compatRes):
        return Err[bool](Error(compatRes))
    if ! Value(compatRes):
        return Err[bool]("version neg: compat completion missing")
    let prevRes: Result[bool] = msquicVersionNegotiationClientCheck(info, vs, qUIC_VERSION_1_H, qUIC_VERSION_1_H, false, false)
    if IsOk(prevRes):
        return Err[bool]("version neg: previous version accepted")
    return Ok[bool](true)
