# MsQuic API FFI loader test(manual).

import std/result
import cheng/quic/api/ffi_loader
fn runApiFfiLoaderTest(): Result[bool] =
    var state: MsQuicFfiState = initMsQuicFfiState()
    if msquicFfiLoaded(state):
        return Err[bool]("ffi: expected unloaded")
    let loadRes: Result[bool] = msquicFfiLoad(state)
    if IsOk(loadRes):
        return Err[bool]("ffi: load should fail in minimal build")
    if msquicFfiLoaded(state):
        return Err[bool]("ffi: loader reported loaded")
    if len(state.lastError) <= 0:
        return Err[bool]("ffi: missing error message")
    msquicFfiUnload(state)
    return Ok[bool](true)
