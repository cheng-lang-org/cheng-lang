# MsQuic congestion bridge test(manual).

import std/result
import cheng/quic/congestion/common
import cheng/quic/congestion/controller
import cheng/quic/congestion/validation_suite
fn runCongestionBridgeTest(): Result[bool] =
    var controller: CongestionController = congestionControllerInit(caCubic, 1200, quicInitialWindowPackets)
    congestionControllerOnPacketSent(controller, 1200, true, false, 1000)
    let ack: AckEventSnapshot = initAckSnapshot(200000, 1, 1, 1200)
    congestionControllerOnAcked(controller, ack)
    let allowance: int64 = congestionControllerSendAllowance(controller, 200000)
    if allowance <= 0:
        return Err[bool]("bridge: cubic allowance ! positive")
    congestionControllerSwitchAlgorithm(controller, caBbr)
    congestionControllerOnPacketSent(controller, 1200, true, false, 300000)
    let ackBbr: AckEventSnapshot = initAckSnapshot(300000, 2, 2, 1200)
    congestionControllerOnAcked(controller, ackBbr)
    let loss: LossEventSnapshot = initLossSnapshot(3, 600)
    congestionControllerOnLost(controller, loss)
    if ! congestionControllerCanSend(controller):
        return Err[bool]("bridge: controller blocked after loss")
    return Ok[bool](true)
