# MsQuic connection handshake test(manual).

import std/result
import cheng/quic/protocol/tls_core
fn runConnectionHandshakeTest(): Result[bool] =
    var session: MsQuicTlsSession = initMsQuicTlsSession()
    let startRes: Result[bool] = msquicTlsSessionStart(session)
    if IsErr(startRes):
        return Err[bool](ErrorText(startRes))
    msquicTlsSessionFinish(session, true)
    if session.protocol.state != MsQuicProtoReady:
        return Err[bool]("handshake: protocol ! ready")
    let summary: str = msquicTlsSessionSummary(session)
    if len(summary) <= 0:
        return Err[bool]("handshake: summary empty")
    return Ok[bool](true)
