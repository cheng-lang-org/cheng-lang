# MsQuic TLS revocation test(manual).

import std/result
import std/rawbytes
import std/buffer
import std/strings
import std/crypto/minasn1
import std/crypto/sha256
import std/crypto/rsa
import std/tls/x509
const
    rsaPrivDerHex = ""
    rsaPubDerHex = "30818902818100c55e89745403b302dff6e2b9264804a80c8fcb50e30ee5d39f37556f903efffe0afeff89b79962a81fc205f4ec358b6648ead365a170d76d77ecc8c94c367926c4331518a1b8f921867f564100de6b0c1a0e7b3a1cb103a6ec86f113850249095def66d4938a37852e6ce2ed73cfed4dca8b16560c91a524c46f33d90e6049e10203010001"
    oidStackMax = 10

type
    OidValueNext =
        value: int64
        next: int32

fn hexValue(c: char): int32 =
    if c >= '0' && c <= '9':
        return int32(c) - int32('0')
    if c >= 'a' && c <= 'f':
        return 10 + int32(c) - int32('a')
    if c >= 'A' && c <= 'F':
        return 10 + int32(c) - int32('A')
    return -1

fn hexDecode(text: str): Result[Bytes] =
    if len(text) % 2 != 0:
        return Err[Bytes]("revocation: hex length must be even")
    let out: Bytes = bytesAlloc(len(text) / 2)
    var i: int32 = 0
    while i < len(text):
        let hi: int32 = hexValue(text[i])
        let lo: int32 = hexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes]("revocation: invalid hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn oidReadInt(text: str, start: int32): Result[OidValueNext] =
    if start < 0 || start >= len(text):
        return Err[OidValueNext]("revocation: oid truncated")
    var next: int32 = start
    var acc: int64 = 0
    var saw: bool = false
    for i in start..<len(text):
        let c: char = text[i]
        if c == '.':
            next = i
            break
        if c < '0' || c > '9':
            return Err[OidValueNext]("revocation: oid digit invalid")
        acc = acc * 10 + int64(int32(c) - int32('0'))
        saw = true
        next = i + 1
    if ! saw:
        return Err[OidValueNext]("revocation: oid empty arc")
    return Ok[OidValueNext](OidValueNext(value: acc, next: next))

fn oidEncode(text: str): Result[Bytes] =
    let arc0Res: Result[OidValueNext] = oidReadInt(text, 0)
    if IsErr(arc0Res):
        return Err[Bytes](ErrorText(arc0Res))
    let sep0: int32 = Value(arc0Res).next
    if sep0 >= len(text) || text[sep0] != '.':
        return Err[Bytes]("revocation: oid missing dot")
    let arc1Res: Result[OidValueNext] = oidReadInt(text, sep0 + 1)
    if IsErr(arc1Res):
        return Err[Bytes](ErrorText(arc1Res))
    let arc0: int64 = Value(arc0Res).value
    let arc1: int64 = Value(arc1Res).value
    if arc0 < 0 || arc0 > 2:
        return Err[Bytes]("revocation: oid arc0 out of range")
    if arc1 < 0 || arc1 > 39:
        return Err[Bytes]("revocation: oid arc1 out of range")
    var buf: ByteBuffer = newByteBuffer()
    appendByte(buf, int32(arc0 * 40 + arc1))
    var idx: int32 = Value(arc1Res).next
    while idx < len(text):
        if text[idx] != '.':
            return Err[Bytes]("revocation: oid separator invalid")
        let arcRes: Result[OidValueNext] = oidReadInt(text, idx + 1)
        if IsErr(arcRes):
            return Err[Bytes](ErrorText(arcRes))
        var v: int64 = Value(arcRes).value
        if v < 0:
            return Err[Bytes]("revocation: oid arc negative")
        var stack: int32[oidStackMax]
        var count: int32 = 0
        if v == 0:
            stack[count] = 0
            count = count + 1
        while v > 0:
            stack[count] = int32(v & 0x7f)
            count = count + 1
            v = v >> 7
        var j: int32 = count - 1
        while j >= 0:
            var b: int32 = stack[j]
            if j != 0:
                b = b | 0x80
            appendByte(buf, b)
            j = j - 1
        idx = Value(arcRes).next
    return Ok[Bytes](toBytes(buf))

fn encodeAlgId(oid: str): Result[Bytes] =
    let oidRes: Result[Bytes] = oidEncode(oid)
    if IsErr(oidRes):
        return Err[Bytes](ErrorText(oidRes))
    let oidTlv: Bytes = asn1EncodeOid(Value(oidRes))
    let nulTlv: Bytes = asn1EncodeNull()
    return Ok[Bytes](asn1EncodeSequence(bytesConcat(oidTlv, nulTlv)))

fn encodeEnumerated(value: int64): Bytes =
    return asn1EncodeTlv(0x0a, int64ToBytes(value))

fn encodeGeneralizedTime(text: str): Bytes =
    return asn1EncodeTlv(x509TagGeneralizedTime, bytesFromString(text))

fn buildName(commonName: str): Result[Bytes] =
    let oidRes: Result[Bytes] = oidEncode("2.5.4.3")
    if IsErr(oidRes):
        return Err[Bytes](ErrorText(oidRes))
    let oidTlv: Bytes = asn1EncodeOid(Value(oidRes))
    let nameTlv: Bytes = asn1EncodeTlv(0x0c, bytesFromString(commonName))
    let atv: Bytes = asn1EncodeSequence(bytesConcat(oidTlv, nameTlv))
    let rdn: Bytes = asn1EncodeTlv(0x31, atv)
    return Ok[Bytes](asn1EncodeSequence(rdn))

fn buildOcspResponse(
    issuerName: Bytes,
    issuerKeyDer: Bytes,
    leafSerial: Bytes,
    priv: var RsaBigPrivateKey,
    thisTime: str,
    nextTime: str
): Result[Bytes] =
    
    let sigAlgRes: Result[Bytes] = encodeAlgId(oidSha256WithRsa)
    if IsErr(sigAlgRes):
        return Err[Bytes](ErrorText(sigAlgRes))
    let hashAlgRes: Result[Bytes] = encodeAlgId(oidSha256)
    if IsErr(hashAlgRes):
        return Err[Bytes](ErrorText(hashAlgRes))
    let nameHash: Bytes = sha256Digest(issuerName)
    let keyHash: Bytes = sha256Digest(issuerKeyDer)
    let certId: Bytes = asn1EncodeSequence(
        bytesConcat(
            bytesConcat(
                bytesConcat(Value(hashAlgRes), asn1EncodeOctetString(nameHash)),
                asn1EncodeOctetString(keyHash)
            ),
            asn1EncodeInteger(leafSerial)
        )
    )
    let goodStatus: Bytes = bytesAlloc(2)
    bytesSet(goodStatus, 0, 0x80)
    bytesSet(goodStatus, 1, 0)
    let thisUpdate: Bytes = encodeGeneralizedTime(thisTime)
    let nextUpdate: Bytes = asn1EncodeTlv(0xa0, encodeGeneralizedTime(nextTime))
    let single: Bytes = asn1EncodeSequence(bytesConcat(bytesConcat(certId, goodStatus), bytesConcat(thisUpdate, nextUpdate)))
    let responses: Bytes = asn1EncodeSequence(single)
    let responderId: Bytes = asn1EncodeTlv(0xa1, issuerName)
    let producedAt: Bytes = encodeGeneralizedTime(thisTime)
    let responseData: Bytes = asn1EncodeSequence(bytesConcat(bytesConcat(responderId, producedAt), responses))
    let sigRes: Result[Bytes] = rsaBigSignPkcs1(priv, responseData, false)
    if IsErr(sigRes):
        return Err[Bytes](ErrorText(sigRes))
    let basic: Bytes = asn1EncodeSequence(bytesConcat(bytesConcat(responseData, Value(sigAlgRes)), asn1EncodeBitString(Value(sigRes))))
    let rbTypeRes: Result[Bytes] = oidEncode(oidOcspBasic)
    if IsErr(rbTypeRes):
        return Err[Bytes](ErrorText(rbTypeRes))
    let rbSeq: Bytes = asn1EncodeSequence(bytesConcat(asn1EncodeOid(Value(rbTypeRes)), asn1EncodeOctetString(basic)))
    let responseBytes: Bytes = asn1EncodeTlv(0xa0, rbSeq)
    let status: Bytes = encodeEnumerated(0)
    return Ok[Bytes](asn1EncodeSequence(bytesConcat(status, responseBytes)))

fn buildCrl(
    issuerName: Bytes,
    leafSerial: Bytes,
    priv: var RsaBigPrivateKey,
    thisTime: str,
    nextTime: str
): Result[Bytes] =
    
    let sigAlgRes: Result[Bytes] = encodeAlgId(oidSha256WithRsa)
    if IsErr(sigAlgRes):
        return Err[Bytes](ErrorText(sigAlgRes))
    let revokedEntry: Bytes = asn1EncodeSequence(
        bytesConcat(asn1EncodeInteger(leafSerial), encodeGeneralizedTime(thisTime))
    )
    let revokedList: Bytes = asn1EncodeSequence(revokedEntry)
    let tbs: Bytes = asn1EncodeSequence(
        bytesConcat(
            bytesConcat(Value(sigAlgRes), issuerName),
            bytesConcat(encodeGeneralizedTime(thisTime), bytesConcat(encodeGeneralizedTime(nextTime), revokedList))
        )
    )
    let sigRes: Result[Bytes] = rsaBigSignPkcs1(priv, tbs, false)
    if IsErr(sigRes):
        return Err[Bytes](ErrorText(sigRes))
    let sig: Bytes = asn1EncodeBitString(Value(sigRes))
    return Ok[Bytes](asn1EncodeSequence(bytesConcat(bytesConcat(tbs, Value(sigAlgRes)), sig)))

fn runTlsRevocationTest(): Result[bool] =
    let privRes: Result[Bytes] = hexDecode(rsaPrivDerHex)
    if IsErr(privRes):
        return Err[bool](ErrorText(privRes))
    let pubRes: Result[Bytes] = hexDecode(rsaPubDerHex)
    if IsErr(pubRes):
        return Err[bool](ErrorText(pubRes))
    let privKeyRes: Result[RsaBigPrivateKey] = rsaBigPrivateKeyFromBytes(Value(privRes))
    if IsErr(privKeyRes):
        return Err[bool](ErrorText(privKeyRes))
    let pubKeyRes: Result[RsaBigPublicKey] = rsaBigPublicKeyFromBytes(Value(pubRes))
    if IsErr(pubKeyRes):
        return Err[bool](ErrorText(pubKeyRes))
    let nameRes: Result[Bytes] = buildName("cheng-ocsp-ca")
    if IsErr(nameRes):
        return Err[bool](ErrorText(nameRes))
    let issuerName: Bytes = Value(nameRes)
    var issuer: X509Certificate = initX509Certificate()
    issuer.subject = issuerName
    issuer.publicKey.kind = X509KeyRsa
    issuer.publicKey.rsa = Value(pubKeyRes)
    var leaf: X509Certificate = initX509Certificate()
    leaf.issuer = issuerName
    let serialRes: Result[Bytes] = hexDecode("010203")
    if IsErr(serialRes):
        return Err[bool](ErrorText(serialRes))
    let serial: Bytes = Value(serialRes)
    leaf.serial = serial
    var roots: X509CertList = initX509CertList()
    x509CertListAdd(roots, issuer)
    var inters: X509CertList = initX509CertList()
    let now: int64 = 1767225600
    var privKey: RsaBigPrivateKey = Value(privKeyRes)
    let ocspRes: Result[Bytes] = buildOcspResponse(issuerName, Value(pubRes), serial, privKey, "20260101000000Z", "20270101000000Z")
    if IsErr(ocspRes):
        return Err[bool](ErrorText(ocspRes))
    let ocspCheck: Result[X509RevocationStatus] = x509VerifyOcspResponse(Value(ocspRes), leaf, issuer, now)
    if IsErr(ocspCheck):
        return Err[bool](ErrorText(ocspCheck))
    if Value(ocspCheck) != X509RevocationGood:
        return Err[bool]("revocation: ocsp status ! good")
    let crlRes: Result[Bytes] = buildCrl(issuerName, serial, privKey, "20260101000000Z", "20270101000000Z")
    if IsErr(crlRes):
        return Err[bool](ErrorText(crlRes))
    var crls: Bytes[x509MaxCrls]
    crls[0] = Value(crlRes)
    let revRes: Result[bool] = x509VerifyRevocation(leaf, inters, roots, emptyBytes(), crls, 1, now, X509RevocationStrict)
    if IsOk(revRes):
        return Err[bool]("revocation: expected crl revoked")
    return Ok[bool](true)
