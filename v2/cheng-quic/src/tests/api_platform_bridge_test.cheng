# MsQuic API platform bridge test(manual).

import std/result
import cheng/quic/api/platform_bridge
fn runApiPlatformBridgeTest(): Result[bool] =
    let mac: MsQuicPlatform = msquicPlatformFromString("macos")
    if mac != MsQuicPlatformMacos:
        return Err[bool]("platform: macos parse failed")
    let unknown: MsQuicPlatform = msquicPlatformFromString("plan9")
    if unknown != MsQuicPlatformUnknown:
        return Err[bool]("platform: unknown parse failed")
    let name: str = msquicPlatformToString(MsQuicPlatformLinux)
    if name != "linux":
        return Err[bool]("platform: toString failed")
    return Ok[bool](true)
