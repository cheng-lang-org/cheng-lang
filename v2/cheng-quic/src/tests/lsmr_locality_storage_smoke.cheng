import std/result
import std/seqs as seqops
import std/strings
import cheng/quic/chain/types
import cheng/quic/chain/lsmr

fn runLsmrLocalityStorageSmoke(): Result[bool] =
    let addrEdge = chainLsmrAddressFromDigits([5, 8, 1, 6])
    let addrRegional = chainLsmrAddressFromDigits([5, 1, 6])
    let addrGlobal = chainLsmrAddressFromDigits([5, 9])

    let edgeLocalityA = chainLsmrLocalityCidFromText("edge.sensor.alpha",
                                                     addrEdge,
                                                     "zhen",
                                                     4,
                                                     "temp=21 zone=edge alpha")
    let edgeLocalityB = chainLsmrLocalityCidFromText("edge.sensor.beta",
                                                     addrEdge,
                                                     "zhen",
                                                     4,
                                                     "alpha zone edge temp=21")
    let globalLocality = chainLsmrLocalityCidFromText("archive.asset.alpha",
                                                      addrGlobal,
                                                      "kun",
                                                      1,
                                                      "certificate archive anchor root")
    if edgeLocalityA.localityHash != edgeLocalityB.localityHash:
        return Err[bool]("lsmr locality storage: locality hash must ignore token order")
    if edgeLocalityA.localityHash == globalLocality.localityHash:
        return Err[bool]("lsmr locality storage: distinct semantic set collided")
    if edgeLocalityA.layer != "edge" || globalLocality.layer != "global":
        return Err[bool]("lsmr locality storage: layer mapping mismatch")

    var cells: LsmrStateCell[]
    cells = []
    seqops.add(cells,
        chainLsmrStateCellFromText("edge.sensor.alpha",
                                   addrEdge,
                                   "zhen",
                                   4,
                                   "temp=21 zone=edge alpha"))
    seqops.add(cells,
        chainLsmrStateCellFromText("edge.sensor.beta",
                                   chainLsmrAddressFromDigits([5, 8, 6, 3]),
                                   "xun",
                                   3,
                                   "temp=22 zone=edge beta"))
    seqops.add(cells,
        chainLsmrStateCellFromText("fog.route.alpha",
                                   addrRegional,
                                   "kan",
                                   2,
                                   "route=a batch=17"))
    seqops.add(cells,
        chainLsmrStateCellFromText("archive.asset.alpha",
                                   addrGlobal,
                                   "kun",
                                   1,
                                   "certificate archive anchor root"))
    let forest = chainLsmrBuildStateLayerForest(cells)
    if forest.edgeEntryCount != 2 || forest.regionalEntryCount != 1 || forest.globalEntryCount != 1:
        return Err[bool]("lsmr locality storage: layer entry count mismatch")
    if forest.localOpCount != 2 || forest.regionalBatchCount != 1 || forest.globalAnchorCount != 1:
        return Err[bool]("lsmr locality storage: layer metric mismatch")
    if strings.len(forest.edgeTree.treeCid) == 0 || strings.len(forest.regionalTree.treeCid) == 0 || strings.len(forest.globalTree.treeCid) == 0:
        return Err[bool]("lsmr locality storage: missing layer tree cid")

    var idx = newChainIndex()
    seqops.add(idx.accountKeys, "alice|cheng")
    seqops.add(idx.accountHeads, "cid-alice")
    seqops.add(idx.balances, 11)
    seqops.add(idx.clockEpochs, 0)
    seqops.add(idx.clockGanzhi, 1)
    seqops.add(idx.diverged, false)
    seqops.add(idx.accountKeys, "bob|cheng")
    seqops.add(idx.accountHeads, "cid-bob")
    seqops.add(idx.balances, 7)
    seqops.add(idx.clockEpochs, 0)
    seqops.add(idx.clockGanzhi, 2)
    seqops.add(idx.diverged, false)
    let indexForest = chainLsmrBuildIndexStateLayerForest(idx, 4)
    if indexForest.edgeEntryCount != 2 || indexForest.regionalEntryCount != 2 || indexForest.globalEntryCount != 2:
        return Err[bool]("lsmr locality storage: index layer projection mismatch")
    if strings.len(indexForest.forestCid) == 0:
        return Err[bool]("lsmr locality storage: missing forest cid")

    echo("lsmr_locality_storage_forest_cid=" + forest.forestCid)
    echo("lsmr_locality_storage_edge_tree=" + forest.edgeTree.treeCid)
    echo("lsmr_locality_storage_regional_tree=" + forest.regionalTree.treeCid)
    echo("lsmr_locality_storage_global_tree=" + forest.globalTree.treeCid)
    echo("lsmr_locality_storage_index_forest_cid=" + indexForest.forestCid)
    return Ok[bool](true)

fn main(): int32 =
    let res = runLsmrLocalityStorageSmoke()
    if IsErr(res):
        echo("lsmr locality storage smoke failed")
        echo(ErrorText(res))
        return 1
    echo("lsmr locality storage smoke ok")
    return 0
