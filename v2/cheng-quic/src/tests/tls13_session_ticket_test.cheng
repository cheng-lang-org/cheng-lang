# MsQuic TLS 1.3 new session ticket test(manual).

import std/result
import std/rawbytes
import cheng/quic/tls/handshake13
fn runTls13SessionTicketTest(): Result[bool] =
    var state: MsQuicTls13HandshakeState = initMsQuicTls13HandshakeState(TlsRoleClient)
    let ticket: Bytes = bytesFromString("ticket123")
    let nonce: Bytes = bytesFromString("n")
    let msgRes: Result[Bytes] = msquicTls13BuildNewSessionTicket(3600, 0, nonce, ticket)
    if IsErr(msgRes):
        return Err[bool](Error(msgRes))
    let feedRes: Result[int32] = msquicTls13HandshakeFeed(state, Value(msgRes))
    if IsErr(feedRes):
        return Err[bool](Error(feedRes))
    if ! state.newSessionTicketReceived:
        return Err[bool]("tls13: session ticket ! recorded")
    if ! bytesEqual(state.newSessionTicket, ticket):
        return Err[bool]("tls13: session ticket mismatch")
    if state.newSessionTicketLifetimeSec != 3600:
        return Err[bool]("tls13: ticket lifetime mismatch")
    return Ok[bool](true)
