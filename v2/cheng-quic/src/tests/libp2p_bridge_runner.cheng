# libp2p bridge standalone runner.

import std/result
import cheng/quic/tests/libp2p_bridge_smoke

fn main(): int32 =
    let res: Result[bool] = runLibp2pBridgeSmoke()
    if IsErr(res):
        echo("libp2p_bridge: fail: " + ErrorText(res))
        return 1
    echo("libp2p_bridge: transport_select=ok")
    echo("libp2p_bridge: connection_established=ok")
    return 0
