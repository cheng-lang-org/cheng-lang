# MsQuic API hotpath bench(manual).

import std/result
import cheng/quic/api/api_impl
fn runApiHotpathBench(): Result[bool] =
    var api: MsQuicApi = initMsQuicApi()
    for i in 0..<16:
        msquicApiRecordSend(api, 1, 1200)
    if msquicApiEventCount(api) != 16:
        return Err[bool]("bench: event count mismatch")
    return Ok[bool](true)
