# MsQuic tooling release pipeline test(manual).

import std/result
import cheng/quic/tooling/common
import cheng/quic/tooling/ci_pipeline
import cheng/quic/tooling/release_pipeline
import cheng/quic/tooling/trace_pipeline
fn runToolingReleasePipelineTest(): Result[bool] =
    let steps: StringList = defaultReleaseSteps()
    let relRes: ToolResult = runReleasePipeline(steps)
    if ! toolResultOk(relRes):
        return Err[bool]("tooling: release pipeline failed")
    let ciSteps: StringList = defaultCiSteps()
    let ciRes: ToolResult = runCiPipeline(ciSteps)
    if ! toolResultOk(ciRes):
        return Err[bool]("tooling: ci pipeline failed")
    let traceRes: ToolResult = tracePipelineRun("line1\\nline2")
    if ! toolResultOk(traceRes):
        return Err[bool]("tooling: trace pipeline failed")
    return Ok[bool](true)
