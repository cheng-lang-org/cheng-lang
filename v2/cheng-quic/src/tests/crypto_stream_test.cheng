# MsQuic CRYPTO stream reassembly test(manual).

import std/result
import std/rawbytes
import cheng/quic/core/crypto_stream
fn runCryptoStreamTest(): Result[bool] =
    var stream: MsQuicCryptoStream = initMsQuicCryptoStream()
    let hello: Bytes = bytesFromString("hello")
    let addRes: Result[bool] = msquicCryptoStreamAdd(stream, 0, hello)
    if IsErr(addRes):
        return Err[bool](Error(addRes))
    if msquicCryptoStreamAvailable(stream) != bytesLen(hello):
        return Err[bool]("crypto stream: contiguous length mismatch")
    let out: Bytes = msquicCryptoStreamConsume(stream, 16)
    if ! bytesEqual(out, hello):
        return Err[bool]("crypto stream: contiguous data mismatch")

    msquicCryptoStreamReset(stream)
    let world: Bytes = bytesFromString("world")
    let addRes2: Result[bool] = msquicCryptoStreamAdd(stream, 5, world)
    if IsErr(addRes2):
        return Err[bool](Error(addRes2))
    if msquicCryptoStreamAvailable(stream) != 0:
        return Err[bool]("crypto stream: out-of-order should ! flush")
    let addRes3: Result[bool] = msquicCryptoStreamAdd(stream, 0, hello)
    if IsErr(addRes3):
        return Err[bool](Error(addRes3))
    let combined: Bytes = msquicCryptoStreamConsume(stream, 32)
    if ! bytesEqual(combined, bytesFromString("helloworld")):
        return Err[bool]("crypto stream: out-of-order reassembly mismatch")

    msquicCryptoStreamReset(stream)
    let overlap: Bytes = bytesFromString("lo!!!")
    let addRes4: Result[bool] = msquicCryptoStreamAdd(stream, 3, overlap)
    if IsErr(addRes4):
        return Err[bool](Error(addRes4))
    let addRes5: Result[bool] = msquicCryptoStreamAdd(stream, 0, hello)
    if IsErr(addRes5):
        return Err[bool](Error(addRes5))
    let overlapOut: Bytes = msquicCryptoStreamConsume(stream, 32)
    if ! bytesEqual(overlapOut, bytesFromString("hello!!!")):
        return Err[bool]("crypto stream: overlap trim mismatch")
    return Ok[bool](true)
