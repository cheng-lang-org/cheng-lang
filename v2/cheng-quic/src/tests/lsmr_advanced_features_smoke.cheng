import std/result
import std/seqs as seqops
import cheng/quic/chain/types
import cheng/quic/chain/lsmr
import cheng/quic/chain/csg
import cheng/quic/chain/pubsub
import cheng/quic/chain/location_proof

fn smokeTextPos(values: str[], value: str): int32 =
    for i in 0..<values.len:
        if values[i] == value:
            return i
    return -1

fn runLsmrAdvancedFeaturesSmoke(): Result[bool] =
    let center = chainLsmrAddressFromDigits([5, 5, 5])
    let topicRes = chainLsmrPubSubTopicFromAddress(center, 2, "xun", "cheng csg delta route")
    if IsErr(topicRes):
        return Err[bool](ErrorText(topicRes))
    let topic = Value(topicRes)
    if topic.layer != "regional" || topic.scopePrefixText != "5":
        return Err[bool]("lsmr advanced: topic scope mismatch")

    let safeGraphRes = chainLsmrBuildCsgSubgraph(
        "cheng.delta.sync",
        ["root", "merge", "emit"],
        ["source", "rewrite", "sink"],
        ["read", "regional_batch", "emit"],
        ["load sensor state", "merge delta", "emit update"],
        ["root", "merge"],
        ["merge", "emit"],
        ["data", "emit"])
    if IsErr(safeGraphRes):
        return Err[bool](ErrorText(safeGraphRes))
    let safeGraph = Value(safeGraphRes)
    let safeDelta = chainLsmrCsgDeltaFromSubgraph("base_graph_cid", safeGraph)
    let envelope = chainLsmrPubSubEnvelope(topic, "csg_delta", safeDelta.deltaCid, "cheng ast delta")

    var subscriptions: LsmrPubSubSubscription[]
    subscriptions = []
    seqops.add(subscriptions, chainLsmrPubSubSubscription("node-center", center, "gen", topic.topicCid))
    seqops.add(subscriptions, chainLsmrPubSubSubscription("node-east-near",
                                                          chainLsmrAddressFromDigits([5, 8, 1]),
                                                          "gen",
                                                          topic.topicCid))
    seqops.add(subscriptions, chainLsmrPubSubSubscription("node-east-far",
                                                          chainLsmrAddressFromDigits([5, 8, 6]),
                                                          "gen",
                                                          topic.topicCid))
    seqops.add(subscriptions, chainLsmrPubSubSubscription("node-water",
                                                          chainLsmrAddressFromDigits([5, 1, 6]),
                                                          "gen",
                                                          topic.topicCid))
    seqops.add(subscriptions, chainLsmrPubSubSubscription("node-wood",
                                                          chainLsmrAddressFromDigits([5, 3, 4]),
                                                          "gen",
                                                          topic.topicCid))
    seqops.add(subscriptions, chainLsmrPubSubSubscription("node-outside",
                                                          chainLsmrAddressFromDigits([8, 1, 6]),
                                                          "gen",
                                                          topic.topicCid))
    let planRes = chainLsmrBuildPubSubPlan(topic, envelope, subscriptions)
    if IsErr(planRes):
        return Err[bool](ErrorText(planRes))
    let plan = Value(planRes)
    if plan.subscriberCount != 4 || plan.branchCount != 4:
        return Err[bool]("lsmr advanced: pubsub xun fanout mismatch")
    let eastBranch = chainLsmrPubSubPlanBranchPos(plan, 8)
    if eastBranch < 0 ||
       plan.branchNodeCounts[eastBranch] != 1 ||
       plan.branchAddressTexts[eastBranch] != "5/8/1":
        return Err[bool]("lsmr advanced: xun branch minimization mismatch")

    let safeDecision = chainLsmrPubSubCsgDecision(topic, subscriptions[1], safeGraph)
    if ! safeDecision.accepted || safeDecision.deniedNodeIds.len != 0:
        return Err[bool]("lsmr advanced: safe csg barrier mismatch")

    let unsafeGraphRes = chainLsmrBuildCsgSubgraph(
        "cheng.delta.unsafe",
        ["load", "mut"],
        ["source", "rewrite"],
        ["read", "rawmem_write"],
        ["load bytes", "raw pointer patch"],
        ["load"],
        ["mut"],
        ["unsafe_write"])
    if IsErr(unsafeGraphRes):
        return Err[bool](ErrorText(unsafeGraphRes))
    let unsafeDecision = chainLsmrPubSubCsgDecision(topic, subscriptions[1], Value(unsafeGraphRes))
    if unsafeDecision.accepted || smokeTextPos(unsafeDecision.deniedNodeIds, "mut") < 0:
        return Err[bool]("lsmr advanced: unsafe csg barrier missing")

    let claimant = chainLsmrAddressFromDigits([5, 8, 1])
    var witnesses: LsmrLocationWitness[]
    witnesses = []
    seqops.add(witnesses, chainLsmrLocationWitness("node-claim", claimant, "node-w1", chainLsmrAddressFromDigits([5, 1, 1]), 3))
    seqops.add(witnesses, chainLsmrLocationWitness("node-claim", claimant, "node-w2", chainLsmrAddressFromDigits([5, 6, 1]), 3))
    seqops.add(witnesses, chainLsmrLocationWitness("node-claim", claimant, "node-w3", chainLsmrAddressFromDigits([5, 3, 1]), 3))
    let proofRes = chainLsmrBuildLocationProof("node-claim", claimant, 42, "nonce-42", witnesses)
    if IsErr(proofRes):
        return Err[bool](ErrorText(proofRes))
    let proof = Value(proofRes)
    let proofDecision = chainLsmrVerifyLocationProof(proof)
    if ! proofDecision.accepted || proofDecision.distinctWitnessCount != 3 || proofDecision.distinctSectorCount != 3:
        return Err[bool]("lsmr advanced: location proof quorum mismatch")
    var badProof = proof
    badProof.witnessRttBuckets[0] = 99
    let badDecision = chainLsmrVerifyLocationProof(badProof)
    if badDecision.accepted:
        return Err[bool]("lsmr advanced: bad location proof accepted")

    echo("lsmr_advanced_topic_cid=" + topic.topicCid)
    echo("lsmr_advanced_plan_cid=" + plan.planCid)
    echo("lsmr_advanced_safe_graph_cid=" + safeGraph.graphCid)
    echo("lsmr_advanced_safe_delta_cid=" + safeDelta.deltaCid)
    echo("lsmr_advanced_location_proof_cid=" + proof.proofCid)
    echo("lsmr advanced features smoke ok")
    return Ok[bool](true)

fn main(): int32 =
    let res = runLsmrAdvancedFeaturesSmoke()
    if IsErr(res):
        echo("lsmr_advanced_features_smoke=fail " + ErrorText(res))
        return 1
    echo("lsmr_advanced_features_smoke=ok")
    return 0
