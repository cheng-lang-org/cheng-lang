# MsQuic TLS 1.3 0-RTT binder test(manual).

import std/result
import std/rawbytes
import cheng/quic/tls/handshake13
fn fillPatternBytes(length: int32, start: int32): Bytes =
    let out: Bytes = bytesAlloc(length)
    for i in 0..<length:
        bytesSet(out, i, (start + i) & 0xff)
    return out

fn runTls13ZeroRttTest(): Result[bool] =
    var client: MsQuicTls13HandshakeState = initMsQuicTls13HandshakeState(TlsRoleClient)
    let genRes: Result[bool] = msquicTls13HandshakeGenerateX25519(client)
    if IsErr(genRes):
        return Err[bool](Error(genRes))
    let random: Bytes = fillPatternBytes(32, 0x11)
    let pskIdentity: Bytes = bytesFromString("cheng-psk-id")
    let binderLen: int32 = msquicTls13HashLen(MsQuicCipherAes128Gcm)
    if binderLen <= 0:
        return Err[bool]("tls13: binder length invalid")
    let psk: Bytes = fillPatternBytes(binderLen, 0x22)
    let chRes: Result[Bytes] = msquicTls13BuildClientHelloWithPsk(
        client,
        random,
        "h3",
        "example.com",
        emptyBytes(),
        pskIdentity,
        psk,
        1234,
        1000,
        2000,
        MsQuicCipherAes128Gcm
    )
    if IsErr(chRes):
        return Err[bool](Error(chRes))
    let ch: Bytes = Value(chRes)
    let offRes: Result[TlsOffsetLength] = msquicTls13FindPskBinderOffset(ch)
    if IsErr(offRes):
        return Err[bool](Error(offRes))
    let off: TlsOffsetLength = Value(offRes)
    let binderRes: Result[Bytes] = msquicTls13ComputePskBinder(psk, MsQuicCipherAes128Gcm, ch, off.offset, off.length)
    if IsErr(binderRes):
        return Err[bool](Error(binderRes))
    let binder: Bytes = Value(binderRes)
    if bytesLen(binder) != off.length:
        return Err[bool]("tls13: binder length mismatch")
    for i in 0..<off.length:
        if bytesGet(ch, off.offset + i) != bytesGet(binder, i):
            return Err[bool]("tls13: binder mismatch")
    if bytesLen(ch) < 4:
        return Err[bool]("tls13: client hello truncated")
    let body: Bytes = bytesSlice(ch, 4, bytesLen(ch) - 4)
    var server: MsQuicTls13HandshakeState = initMsQuicTls13HandshakeState(TlsRoleServer)
    let parseRes: Result[bool] = msquicTls13ParseClientHello(server, body)
    if IsErr(parseRes):
        return Err[bool](Error(parseRes))
    if ! server.pskOffered:
        return Err[bool]("tls13: psk ! offered")
    if bytesLen(server.pskIdentity) <= 0:
        return Err[bool]("tls13: psk identity missing")
    if ! bytesEqual(server.pskIdentity, pskIdentity):
        return Err[bool]("tls13: psk identity mismatch")
    if bytesLen(server.pskBinder) != Value(offRes).length:
        return Err[bool]("tls13: psk binder length mismatch")
    return Ok[bool](true)
