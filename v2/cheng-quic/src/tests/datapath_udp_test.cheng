# MsQuic datapath UDP test(manual).

import std/result
import cheng/quic/platform/datapath_runtime
fn runDatapathUdpTest(): Result[bool] =
    var rt: MsQuicDatapathRuntime = initMsQuicDatapathRuntime()
    let idRes: Result[int32] = msquicDatapathAdd(rt, MsQuicDatapathBasic)
    if IsErr(idRes):
        return Err[bool](Error(idRes))
    let id: int32 = Value(idRes)
    let startRes: Result[bool] = msquicDatapathStart(rt, id)
    if IsErr(startRes):
        return Err[bool](Error(startRes))
    let sendRes: Result[bool] = msquicDatapathRecordSend(rt, id, 1200)
    if IsErr(sendRes):
        return Err[bool](Error(sendRes))
    let recvRes: Result[bool] = msquicDatapathRecordRecv(rt, id, 900)
    if IsErr(recvRes):
        return Err[bool](Error(recvRes))
    let summary: str = msquicDatapathSummary(rt, id)
    if len(summary) <= 0:
        return Err[bool]("datapath: summary empty")
    let stopRes: Result[bool] = msquicDatapathStop(rt, id)
    if IsErr(stopRes):
        return Err[bool](Error(stopRes))
    return Ok[bool](true)
