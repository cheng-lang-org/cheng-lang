# MsQuic fuzz smoke runner(manual).

import std/result
import std/rawbytes
import cheng/quic/tooling/common
import cheng/quic/tooling/fuzz_harness
fn runFuzzSmoke(): Result[bool] =
    let seed: Bytes = bytesFromString("msquic-fuzz")
    let res: ToolResult = runFuzzOnce(seed)
    if ! toolResultOk(res):
        return Err[bool]("fuzz: failed")
    return Ok[bool](true)
