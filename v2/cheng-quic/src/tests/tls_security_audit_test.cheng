# MsQuic TLS security audit test(manual).

import std/result
import cheng/quic/tls/common
import cheng/quic/tls/security_audit
fn runTlsSecurityAuditTest(): Result[bool] =
    var cfg: MsQuicTlsConfig = initMsQuicTlsConfig()
    cfg.allowInsecure = true
    cfg.version = MsQuicTls12
    let audit: MsQuicTlsAudit = msquicTlsAuditConfig(cfg)
    if audit.ok:
        return Err[bool]("tls audit: expected warnings")
    if audit.warnings <= 0:
        return Err[bool]("tls audit: warnings missing")
    let summary: str = msquicTlsAuditSummary(audit)
    if len(summary) <= 0:
        return Err[bool]("tls audit: summary empty")
    return Ok[bool](true)
