# MsQuic congestion validation test(manual).

import std/result
import cheng/quic/congestion/common
import cheng/quic/congestion/controller

fn validateController(algo: CongestionAlgorithm): Result[bool] =
    var c: CongestionController = congestionControllerInit(algo, 1200, quicInitialWindowPackets)
    if ! congestionControllerCanSend(c):
        return Err[bool]("congestion: cannot send at init")
    let window: int64 = congestionControllerWindowBytes(c)
    if window <= 0:
        return Err[bool]("congestion: invalid cwnd")
    let allowance0: int64 = congestionControllerSendAllowance(c, 1000)
    if allowance0 <= 0:
        return Err[bool]("congestion: invalid allowance")
    congestionControllerOnPacketSent(c, 1200, true, false, 1000)
    let allowance1: int64 = congestionControllerSendAllowance(c, 1000)
    if allowance1 < 0:
        return Err[bool]("congestion: negative allowance")
    return Ok[bool](true)

fn runCongestionValidationTest(): Result[bool] =
    let cubicRes: Result[bool] = validateController(caCubic)
    if IsErr(cubicRes):
        return Err[bool](Error(cubicRes))
    let bbrRes: Result[bool] = validateController(caBbr)
    if IsErr(bbrRes):
        return Err[bool](Error(bbrRes))
    return Ok[bool](true)
