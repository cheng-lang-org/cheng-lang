# MsQuic tooling misc test(manual).

import std/result
import std/strings
import cheng/quic/tooling/build_matrix
import cheng/quic/tooling/common
import cheng/quic/tooling/perf_ci_pipeline
import cheng/quic/tooling/perf_pipeline
import cheng/quic/tooling/qlog_pipeline
import cheng/quic/tooling/export_sink
import cheng/quic/tooling/export_sink_otel
import cheng/observability/otellogsservice
import cheng/quic/tooling/sample_tool
import cheng/quic/tooling/tool_catalog
fn sampleToolHandler(): ToolResult =
    return toolOk("tool handler ok")

var
    sinkHits: int32 = 0

fn testSinkHandler(kind: str, payload: str) =
    if len(kind) > 0 && len(payload) > 0:
        sinkHits = sinkHits + 1

fn runToolingMiscTest(): Result[bool] =
    var catalog: ToolCatalog = initToolCatalog()
    let addRes: Result[bool] = toolCatalogAdd(catalog, "sample", "sample tool", sampleToolHandler)
    if IsErr(addRes):
        return Err[bool](Error(addRes))
    let noopRes: Result[bool] = toolCatalogAddNoop(catalog, "noop", "noop tool")
    if IsErr(noopRes):
        return Err[bool](Error(noopRes))
    let list: str = toolCatalogList(catalog)
    if ! strContains(list, "sample"):
        return Err[bool]("tooling: catalog list missing sample")
    let runRes: Result[ToolResult] = toolCatalogRun(catalog, "sample")
    if IsErr(runRes):
        return Err[bool](Error(runRes))
    if ! toolResultOk(Value(runRes)):
        return Err[bool]("tooling: catalog run failed")
    let noopRun: Result[ToolResult] = toolCatalogRun(catalog, "noop")
    if IsErr(noopRun):
        return Err[bool](Error(noopRun))
    if Value(noopRun).status != ToolSkipped:
        return Err[bool]("tooling: noop tool ! skipped")
    let missingRes: Result[ToolResult] = toolCatalogRun(catalog, "missing")
    if IsOk(missingRes):
        return Err[bool]("tooling: missing tool unexpectedly ran")

    let help: str = sampleToolHelp()
    if ! strContains(help, "sample_tool"):
        return Err[bool]("tooling: sample tool help mismatch")
    let toolRes: ToolResult = sampleToolRun()
    if ! toolResultOk(toolRes):
        return Err[bool]("tooling: sample tool failed")

    var matrix: BuildMatrix = defaultBuildMatrix()
    if matrix.count <= 0:
        return Err[bool]("tooling: build matrix empty")
    let matrixList: str = buildMatrixList(matrix)
    if ! strContains(matrixList, "linux/amd64"):
        return Err[bool]("tooling: build matrix missing linux")
    let badMatrix: Result[bool] = buildMatrixAdd(matrix, "", "amd64")
    if IsOk(badMatrix):
        return Err[bool]("tooling: build matrix accepted empty os")

    let steps: StringList = defaultPerfCiSteps()
    let perfRes: ToolResult = runPerfCiPipeline(steps)
    if ! toolResultOk(perfRes):
        return Err[bool]("tooling: perf pipeline failed")
    exportSinkReset()
    exportSinkClearHandler()
    sinkHits = 0
    exportSinkSetHandler(testSinkHandler)
    let perfRun: ToolResult = perfPipelineRun("connections=1")
    if ! toolResultOk(perfRun):
        return Err[bool]("tooling: perf pipeline run failed")
    if len(exportSinkGet("perf")) <= 0:
        return Err[bool]("tooling: perf sink missing")
    if sinkHits <= 0:
        return Err[bool]("tooling: sink handler ! called")
    let perfSkip: ToolResult = perfPipelineRun("")
    if perfSkip.status != ToolSkipped:
        return Err[bool]("tooling: perf pipeline empty ! skipped")
    let qlogRun: ToolResult = qlogPipelineRun("{\"time\":0}")
    if ! toolResultOk(qlogRun):
        return Err[bool]("tooling: qlog pipeline run failed")
    if len(exportSinkGet("qlog")) <= 0:
        return Err[bool]("tooling: qlog sink missing")
    let qlogSkip: ToolResult = qlogPipelineRun("")
    if qlogSkip.status != ToolSkipped:
        return Err[bool]("tooling: qlog pipeline empty ! skipped")
    resetLogs()
    var cfg: OtelConfig = initOtelConfig()
    cfg.enabled = true
    setOtelConfig(cfg)
    exportSinkEnableOtelLogs()
    perfPipelineRun("connections=2")
    if logCount() <= 0:
        return Err[bool]("tooling: otel sink ! called")
    exportSinkDisableOtelLogs()
    return Ok[bool](true)
