# MsQuic datapath highperf test(manual).

import std/result
import cheng/quic/platform/datapath_highperf
fn runDatapathHighPerfTest(): Result[bool] =
    var cfg: MsQuicHighPerfConfig = initMsQuicHighPerfConfig()
    let badBatch: Result[bool] = msquicHighPerfSetBatch(cfg, 0)
    if IsOk(badBatch):
        return Err[bool]("highperf: accepted zero batch")
    let badRing: Result[bool] = msquicHighPerfSetRing(cfg, 0)
    if IsOk(badRing):
        return Err[bool]("highperf: accepted zero ring")
    let okBatch: Result[bool] = msquicHighPerfSetBatch(cfg, 64)
    if IsErr(okBatch):
        return Err[bool](ErrorText(okBatch))
    let okRing: Result[bool] = msquicHighPerfSetRing(cfg, 512)
    if IsErr(okRing):
        return Err[bool](ErrorText(okRing))
    msquicHighPerfEnable(cfg, true)
    let summary: str = msquicHighPerfSummary(cfg)
    if len(summary) <= 0:
        return Err[bool]("highperf: summary empty")
    return Ok[bool](true)
