# MsQuic protocol validation test(manual).

import std/result
import std/rawbytes
import cheng/quic/core/frame_model
import cheng/quic/core/packet_model
import cheng/quic/validation/protocol_validation
fn runProtocolValidationTest(): Result[bool] =
    var pkt: MsQuicPacket = initMsQuicPacket(1)
    let ping: MsQuicFrame = msquicFramePing()
    let data: MsQuicFrame = msquicFrameData(0, 0, bytesFromString("ok"))
    let addPing: Result[bool] = msquicPacketAddFrame(pkt, ping)
    if IsErr(addPing):
        return Err[bool](ErrorText(addPing))
    let addData: Result[bool] = msquicPacketAddFrame(pkt, data)
    if IsErr(addData):
        return Err[bool](ErrorText(addData))
    let validRes: Result[bool] = msquicValidatePacket(pkt)
    if IsErr(validRes):
        return Err[bool](ErrorText(validRes))
    let encoded = msquicPacketEncode(pkt)
    let bytesRes: Result[bool] = msquicValidatePacketBytes(encoded)
    if IsErr(bytesRes):
        return Err[bool](ErrorText(bytesRes))
    let badFrame: MsQuicFrame = msquicFrameData(-1, 0, bytesFromString("bad"))
    let badFrameRes: Result[bool] = msquicValidateFrame(badFrame)
    if IsOk(badFrameRes):
        return Err[bool]("protocol: invalid frame accepted")
    var badPkt: MsQuicPacket = initMsQuicPacket(-4)
    let badPktRes: Result[bool] = msquicValidatePacket(badPkt)
    if IsOk(badPktRes):
        return Err[bool]("protocol: invalid packet accepted")
    return Ok[bool](true)
