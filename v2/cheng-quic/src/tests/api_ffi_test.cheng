# MsQuic API FFI test(manual).

import std/result
import cheng/quic/api/api_impl
fn runApiFfiTest(): Result[bool] =
    var api: MsQuicApi = initMsQuicApi()
    if msquicFfiLoaded(api.ffi):
        return Err[bool]("ffi: expected unloaded")
    let loadRes: Result[bool] = msquicFfiLoad(api.ffi)
    if IsOk(loadRes):
        return Err[bool]("ffi: load should fail in minimal build")
    if msquicFfiLoaded(api.ffi):
        return Err[bool]("ffi: loaded after failure")
    msquicFfiUnload(api.ffi)
    return Ok[bool](true)
