# libp2p bridge smoke (cheng-quic local runner, no libp2p source edits).

import std/result
import std/rawbytes
import cheng/libp2p/multiaddress as lpma
import cheng/quic/multiaddress as qma
import cheng/quic/connection
import cheng/quic/msquictransport
import cheng/quic/quictransport
import cheng/quic/openssl_quic

fn makeLibp2pProbe(kind: int32, port: int32): lpma.MultiAddress =
    var safePort: int32 = port
    if safePort < 0:
        safePort = 0
    if safePort > 65535:
        safePort = 65535
    var out: lpma.MultiAddress
    out.raw = ""
    out.data = bytesAlloc(4)
    bytesSet(out.data, 0, qma.quicAddrTagMagic)
    bytesSet(out.data, 1, kind)
    bytesSet(out.data, 2, (safePort >> 8) & 0xff)
    bytesSet(out.data, 3, safePort & 0xff)
    return out

fn runLibp2pBridgeSmoke(): Result[bool] =
    let msqAddr: qma.MultiAddress = qma.makeInprocMultiAddress(qma.quicAddrKindMsQuic, 6001)
    let quicAddr: qma.MultiAddress = qma.makeInprocMultiAddress(qma.quicAddrKindQuic, 6002)
    let tlsAddr: qma.MultiAddress = qma.makeInprocMultiAddress(qma.quicAddrKindQuicTls, 6003)

    var msq: MsQuicTransport = initMsQuicTransport()
    var quic: QuicTransport = initQuicTransport()
    var openssl: OpenSslQuicTransport = initOpenSslQuicTransport()

    if ! handles(msq, msqAddr):
        return Err[bool]("libp2p bridge: msquic handle mismatch")
    if ! handles(quic, quicAddr):
        return Err[bool]("libp2p bridge: quic handle mismatch")
    if ! handles(openssl, tlsAddr):
        return Err[bool]("libp2p bridge: openssl handle mismatch")

    start(msq, msqAddr)
    let msqDialRes: Result[Connection] = dial(msq, msqAddr)
    if IsErr(msqDialRes):
        return Err[bool]("libp2p bridge: msquic dial: " + ErrorText(msqDialRes))
    let msqAcceptRes: Result[Connection] = accept(msq)
    if IsErr(msqAcceptRes):
        return Err[bool]("libp2p bridge: msquic accept: " + ErrorText(msqAcceptRes))

    start(quic, quicAddr)
    let quicDialRes: Result[Connection] = dial(quic, quicAddr)
    if IsErr(quicDialRes):
        return Err[bool]("libp2p bridge: quic dial: " + ErrorText(quicDialRes))
    let quicAcceptRes: Result[Connection] = accept(quic)
    if IsErr(quicAcceptRes):
        return Err[bool]("libp2p bridge: quic accept: " + ErrorText(quicAcceptRes))

    start(openssl, tlsAddr)
    let tlsDialRes: Result[Connection] = dial(openssl, tlsAddr)
    if IsErr(tlsDialRes):
        return Err[bool]("libp2p bridge: openssl dial: " + ErrorText(tlsDialRes))
    let tlsAcceptRes: Result[Connection] = accept(openssl)
    if IsErr(tlsAcceptRes):
        return Err[bool]("libp2p bridge: openssl accept: " + ErrorText(tlsAcceptRes))

    if ! Value(msqDialRes).open || ! Value(msqAcceptRes).open:
        return Err[bool]("libp2p bridge: msquic connection ! open")
    if ! Value(quicDialRes).open || ! Value(quicAcceptRes).open:
        return Err[bool]("libp2p bridge: quic connection ! open")
    if ! Value(tlsDialRes).open || ! Value(tlsAcceptRes).open:
        return Err[bool]("libp2p bridge: openssl connection ! open")

    let lpMsq: lpma.MultiAddress = makeLibp2pProbe(qma.quicAddrKindMsQuic, 6001)
    let lpQuic: lpma.MultiAddress = makeLibp2pProbe(qma.quicAddrKindQuic, 6002)
    let lpTls: lpma.MultiAddress = makeLibp2pProbe(qma.quicAddrKindQuicTls, 6003)
    let lpMsqBytes: Bytes = lpma.lpMultiAddressToBytes(lpMsq)
    let lpQuicBytes: Bytes = lpma.lpMultiAddressToBytes(lpQuic)
    let lpTlsBytes: Bytes = lpma.lpMultiAddressToBytes(lpTls)
    if bytesLen(lpMsqBytes) != 4 || bytesLen(lpQuicBytes) != 4 || bytesLen(lpTlsBytes) != 4:
        return Err[bool]("libp2p bridge: multiaddress bytes mismatch")
    if bytesGet(lpMsqBytes, 1) != qma.quicAddrKindMsQuic:
        return Err[bool]("libp2p bridge: msquic selection marker mismatch")
    if bytesGet(lpQuicBytes, 1) != qma.quicAddrKindQuic:
        return Err[bool]("libp2p bridge: quic selection marker mismatch")
    if bytesGet(lpTlsBytes, 1) != qma.quicAddrKindQuicTls:
        return Err[bool]("libp2p bridge: openssl selection marker mismatch")

    stop(openssl)
    stop(quic)
    stop(msq)
    return Ok[bool](true)
