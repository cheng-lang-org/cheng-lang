import std/system
import std/result
import std/rawbytes
import std/crypto/ecnist
import std/tls/x509
import cheng/quic/tls/test_pki

fn runQuicTlsTransportEcdsaSmoke(): Result[bool] =
    let policyRes = test_pki.msquicMakeLocalhostTlsPolicy()
    if IsErr(policyRes):
        return Err[bool](ErrorText(policyRes))
    let policy = Value(policyRes)
    if policy.certLeafKeyKind != X509KeyEcdsaP256:
        return Err[bool]("v2 quic transport ecdsa: policy key kind")
    if bytesLen(policy.certPrivateKey) != 32:
        return Err[bool]("v2 quic transport ecdsa: policy private key")
    echo("v2_quic_tls_transport_ecdsa_stage=policy_ok")

    var root: X509Certificate = initX509Certificate()
    let rootParseRes = x509ParseCertificateInto(root, policy.trustRoots[0])
    if IsErr(rootParseRes):
        return Err[bool](ErrorText(rootParseRes))
    if root.publicKey.kind != X509KeyEcdsaP256:
        return Err[bool]("v2 quic transport ecdsa: root key kind")
    echo("v2_quic_tls_transport_ecdsa_stage=root_parse_ok")
    let rootCaRes = x509VerifyCaConstraints(root)
    if IsErr(rootCaRes):
        return Err[bool](ErrorText(rootCaRes))
    echo("v2_quic_tls_transport_ecdsa_stage=root_constraints_ok")

    var leaf: X509Certificate = initX509Certificate()
    let leafParseRes = x509ParseCertificateInto(leaf, policy.certChain[0])
    if IsErr(leafParseRes):
        return Err[bool](ErrorText(leafParseRes))
    if leaf.publicKey.kind != X509KeyEcdsaP256:
        return Err[bool]("v2 quic transport ecdsa: leaf key kind")
    echo("v2_quic_tls_transport_ecdsa_stage=leaf_parse_ok")
    let leafConstraintRes = x509VerifyLeafConstraints(leaf)
    if IsErr(leafConstraintRes):
        return Err[bool](ErrorText(leafConstraintRes))
    echo("v2_quic_tls_transport_ecdsa_stage=leaf_constraints_ok")

    let derivedLeafPubRes = ecnist.ecdsaPublicKeyFromPrivateBytes(policy.certPrivateKey)
    if IsErr(derivedLeafPubRes):
        return Err[bool](ErrorText(derivedLeafPubRes))
    if ! bytesEqual(Value(derivedLeafPubRes), leaf.publicKey.ecdsaBytes):
        return Err[bool]("v2 quic transport ecdsa: derived pub key")
    echo("v2_quic_tls_transport_ecdsa_stage=derived_pub_ok")

    let msg = bytesFromString("v2 quic transport ecdsa sign verify")
    echo("v2_quic_tls_transport_ecdsa_stage=sign_begin")
    let signedMsgRes = ecnist.ecdsaSignBytes(policy.certPrivateKey, msg)
    if IsErr(signedMsgRes):
        return Err[bool](ErrorText(signedMsgRes))
    echo("v2_quic_tls_transport_ecdsa_stage=sign_ok")
    if ! ecnist.ecdsaVerifyTrustedBytes(leaf.publicKey.ecdsaBytes, msg, Value(signedMsgRes)):
        return Err[bool]("v2 quic transport ecdsa: direct sign verify")
    echo("v2_quic_tls_transport_ecdsa_stage=sign_verify_ok")

    let rawSigRes = x509DecodeEcdsaSignature(leaf.signature)
    if IsErr(rawSigRes):
        return Err[bool](ErrorText(rawSigRes))
    if bytesLen(Value(rawSigRes)) != 64:
        return Err[bool]("v2 quic transport ecdsa: raw signature len")
    echo("v2_quic_tls_transport_ecdsa_stage=cert_raw_signature_ok")

    var roots = initX509CertList()
    let addRootRes = x509CertListAdd(roots, root)
    if IsErr(addRootRes):
        return Err[bool](ErrorText(addRootRes))
    echo("v2_quic_tls_transport_ecdsa_stage=chain_begin")
    let chainRes = x509VerifyChain(leaf, initX509CertList(), roots, 1800000000)
    if IsErr(chainRes):
        return Err[bool](ErrorText(chainRes))
    if ! Value(chainRes):
        return Err[bool]("v2 quic transport ecdsa: x509 chain")
    echo("v2_quic_tls_transport_ecdsa_stage=chain_ok")
    return Ok[bool](true)

fn main(): int32 =
    let res = runQuicTlsTransportEcdsaSmoke()
    if IsErr(res):
        echo("v2 quic_tls_transport_ecdsa_smoke failed: " + ErrorText(res))
        return 1
    echo("v2 quic_tls_transport_ecdsa_smoke ok")
    return 0
