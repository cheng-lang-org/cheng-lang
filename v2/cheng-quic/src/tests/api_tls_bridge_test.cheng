# MsQuic API TLS bridge test(manual).

import std/result
import cheng/quic/api/tls_bridge
fn runApiTlsBridgeTest(): Result[bool] =
    var cfg: MsQuicApiTlsConfig = initMsQuicApiTlsConfig()
    let badAlpn: Result[bool] = msquicApiTlsSetAlpn(cfg, "")
    if IsOk(badAlpn):
        return Err[bool]("tls bridge: accepted empty ALPN")
    let okAlpn: Result[bool] = msquicApiTlsSetAlpn(cfg, "h3")
    if IsErr(okAlpn):
        return Err[bool](ErrorText(okAlpn))
    msquicApiTlsSetServerName(cfg, "example.com")
    msquicApiTlsSetInsecure(cfg, true)
    if ! cfg.insecureSkipVerify:
        return Err[bool]("tls bridge: insecure flag ! set")
    return Ok[bool](true)
