# MsQuic TLS handshake test(manual).

import std/result
import cheng/quic/tls/blueprint
fn runTlsHandshakeTest(): Result[bool] =
    var bp: MsQuicTlsBlueprint = initMsQuicTlsBlueprint()
    let startRes: Result[bool] = msquicTlsHandshakeStart(bp)
    if IsErr(startRes):
        return Err[bool](Error(startRes))
    msquicTlsHandshakeFinish(bp, false)
    if bp.state != MsQuicTlsFailed:
        return Err[bool]("tls: expected failed state")
    if bp.stats.failureCount <= 0:
        return Err[bool]("tls: failure count ! updated")
    msquicTlsReset(bp)
    if bp.state != MsQuicTlsIdle:
        return Err[bool]("tls: reset did ! return to idle")
    return Ok[bool](true)
