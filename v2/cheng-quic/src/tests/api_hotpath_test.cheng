# MsQuic API hotpath test(manual).

import std/result
import cheng/quic/api/api_impl
fn runApiHotpathTest(): Result[bool] =
    var api: MsQuicApi = initMsQuicApi()
    if ! msquicStatusOk(msquicApiStatus(api)):
        return Err[bool]("api: expected ok status")
    msquicApiConnOpened(api, 1)
    msquicApiStreamOpened(api, 1, 10)
    msquicApiRecordSend(api, 1, 1200)
    msquicApiRecordRecv(api, 1, 900)
    msquicApiStreamClosed(api, 1, 10)
    msquicApiConnClosed(api, 1)
    if msquicApiEventCount(api) < 6:
        return Err[bool]("api: missing events")
    let diag: MsQuicDiagnostics = msquicApiDiagnostics(api)
    if diag.count <= 0:
        return Err[bool]("api: diagnostics missing")
    if diag.errors != 0:
        return Err[bool]("api: unexpected diagnostics errors")
    msquicApiRecordErrorText(api, "hotpath error")
    if msquicApiStatus(api) != MsQuicStatusFailed:
        return Err[bool]("api: status ! failed after error")
    return Ok[bool](true)
