# MsQuic platform release validation test(manual).

import std/result
import cheng/quic/platform/release_validation
import cheng/quic/api/settings_model
fn runPlatformReleaseValidationTest(): Result[bool] =
    let okRes: Result[bool] = msquicReleaseValidatePlatform(MsQuicPlatformLinux)
    if IsErr(okRes):
        return Err[bool](ErrorText(okRes))
    let badRes: Result[bool] = msquicReleaseValidatePlatform(MsQuicPlatformUnknown)
    if IsOk(badRes):
        return Err[bool]("release: unsupported platform accepted")
    let settings: MsQuicSettings = msquicSettingsDefaults()
    let setRes: Result[bool] = msquicReleaseValidateSettings(settings)
    if IsErr(setRes):
        return Err[bool](ErrorText(setRes))
    let summary: str = msquicReleaseValidationSummary(MsQuicPlatformLinux, settings)
    if len(summary) <= 0:
        return Err[bool]("release: summary empty")
    return Ok[bool](true)
