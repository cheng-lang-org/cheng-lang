# MsQuic key update test(manual).

import std/result
import std/rawbytes
import cheng/quic/multiaddress
import cheng/quic/connection
import cheng/quic/msquicruntime
import cheng/quic/msquictransport_full
import cheng/quic/msquicconnection
fn fillPatternBytes(length: int32, start: int32): Bytes =
    let out: Bytes = bytesAlloc(length)
    for i in 0..<length:
        bytesSet(out, i, (start + i) & 0xff)
    return out

fn runKeyUpdateTest(): Result[bool] =
    let localRes: Result[MultiAddress] = parseMultiAddress("/ip4/127.0.0.1/udp/4003")
    if IsErr(localRes):
        return Err[bool](ErrorText(localRes))
    let remoteRes: Result[MultiAddress] = parseMultiAddress("/ip4/127.0.0.1/udp/4004")
    if IsErr(remoteRes):
        return Err[bool](ErrorText(remoteRes))
    let localAddr: MultiAddress = Value(localRes)
    let remoteAddr: MultiAddress = Value(remoteRes)

    var settings: MsQuicSettings = initMsQuicSettings()
    var connModel: MsQuicConnection = initMsQuicConnection(1, localAddr, remoteAddr, settings, true)
    let state: MsQuicConnState = initMsQuicConnState(connModel)
    var conn: Connection = newConnection(localAddr, remoteAddr, Outbound)
    let cids: MsQuicCidPair = msquicTransportInitCids(msQuicDefaultCidLen)
    if bytesLen(cids.a) <= 0 || bytesLen(cids.b) <= 0:
        return Err[bool]("key update: init cid failed")
    var entryIdx: int32 = -1
    for i in 0..<maxMsQuicConnections:
        if ! msquicConnections.items[i].active:
            entryIdx = i
            break
    if entryIdx < 0:
        return Err[bool]("key update: connection table full")
    clearMsQuicConnEntry(entryIdx)
    initMsQuicConnEntry(msquicConnections.items[entryIdx], conn, state, 0, settings, cids.a, cids.b)
    msquicConnections.items[entryIdx].active = false

    let cipher: MsQuicCipherSuite = MsQuicCipherAes128Gcm
    let hashLen: int32 = msquicTls13HashLen(cipher)
    if hashLen <= 0:
        return Err[bool]("key update: hash length invalid")
    let secret: Bytes = fillPatternBytes(hashLen, 0x10)
    let keyRes: Result[MsQuicKeySet] = msquicTransportBuildKeySet(secret, secret, cipher)
    if IsErr(keyRes):
        return Err[bool](ErrorText(keyRes))
    let baseKeys: MsQuicKeySet = Value(keyRes)

    let recvRes: Result[MsQuicKeySet] = msquicTransportUpdateRecvKeys(baseKeys)
    if IsErr(recvRes):
        return Err[bool](ErrorText(recvRes))
    if bytesEqual(Value(recvRes).recvSecret, baseKeys.recvSecret):
        return Err[bool]("key update: recv secret unchanged")

    msquicConnections.items[entryIdx].keysOneRtt = baseKeys
    msquicConnections.items[entryIdx].oneRttSendPhase = false
    let beforeSend: Bytes = msquicConnections.items[entryIdx].keysOneRtt.sendSecret
    let sendRes: Result[bool] = msquicTransportUpdateSendKeys(msquicConnections.items[entryIdx])
    if IsErr(sendRes):
        return Err[bool](ErrorText(sendRes))
    if ! Value(sendRes):
        return Err[bool]("key update: send update skipped")
    if ! msquicConnections.items[entryIdx].oneRttSendPhase:
        return Err[bool]("key update: send phase ! toggled")
    if bytesEqual(msquicConnections.items[entryIdx].keysOneRtt.sendSecret, beforeSend):
        return Err[bool]("key update: send secret unchanged")
    clearMsQuicConnEntry(entryIdx)
    return Ok[bool](true)
