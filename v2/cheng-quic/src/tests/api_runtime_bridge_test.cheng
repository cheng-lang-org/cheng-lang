# MsQuic API runtime bridge test(manual).

import std/result
import cheng/quic/api/runtime_bridge
import cheng/quic/api/settings_model
fn runApiRuntimeBridgeTest(): Result[bool] =
    var bridge: MsQuicRuntimeBridge = initMsQuicRuntimeBridge()
    var settings: MsQuicSettings = msquicRuntimeBridgeSettings(bridge)
    let setRes: Result[bool] = msquicSettingsSetMaxPending(settings, 8)
    if IsErr(setRes):
        return Err[bool](ErrorText(setRes))
    let applyRes: Result[bool] = msquicRuntimeBridgeSetSettings(bridge, settings)
    if IsErr(applyRes):
        return Err[bool](ErrorText(applyRes))
    let id1: int64 = msquicRuntimeBridgeAllocConnId(bridge)
    let id2: int64 = msquicRuntimeBridgeAllocConnId(bridge)
    if id2 <= id1:
        return Err[bool]("runtime bridge: conn id did ! advance")
    let s1: int64 = msquicRuntimeBridgeAllocStreamId(bridge)
    if s1 <= 0:
        return Err[bool]("runtime bridge: stream id invalid")
    return Ok[bool](true)
