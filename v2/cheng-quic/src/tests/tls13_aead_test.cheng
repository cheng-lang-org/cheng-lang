# MsQuic TLS 1.3 + AEAD round-trip test(manual).

import std/result
import std/rawbytes
import cheng/quic/tls/tls13
import std/crypto/chacha20poly1305
import std/crypto/aesgcm
fn buildNonce(iv: Bytes, packetNumber: int64): Result[Bytes] =
    if bytesLen(iv) != 12:
        return Err[Bytes]("tls13 test: invalid iv length")
    let nonce: Bytes = bytesSlice(iv, 0, bytesLen(iv))
    var pn: int64 = packetNumber
    var i: int32 = 0
    var idx: int32 = bytesLen(nonce) - 1
    while i < 8 && idx >= 0:
        let b: int32 = int32(pn & 0xff)
        bytesSet(nonce, idx, bytesGet(nonce, idx) ^ b)
        pn = pn >> 8
        idx = idx - 1
        i = i + 1
    return Ok[Bytes](nonce)

fn runTls13AeadTest(): Result[bool] =
    let pskText: str = "cheng-msquic-tls13-psk-32bytes!!"
    let psk: Bytes = bytesFromString(pskText)
    let kmClientRes: Result[MsQuicTls13KeyMaterial] = msquicTls13KeyMaterial(psk, psk, MsQuicCipherChacha20Poly1305, true)
    if IsErr(kmClientRes):
        return Err[bool](ErrorText(kmClientRes))
    let kmServerRes: Result[MsQuicTls13KeyMaterial] = msquicTls13KeyMaterial(psk, psk, MsQuicCipherChacha20Poly1305, false)
    if IsErr(kmServerRes):
        return Err[bool](ErrorText(kmServerRes))
    let kmClient: MsQuicTls13KeyMaterial = Value(kmClientRes)
    let kmServer: MsQuicTls13KeyMaterial = Value(kmServerRes)
    if bytesLen(kmClient.sendKey) != 32 || bytesLen(kmClient.sendIv) != 12:
        return Err[bool]("tls13 test: invalid client key sizes")
    if bytesLen(kmServer.recvKey) != 32 || bytesLen(kmServer.recvIv) != 12:
        return Err[bool]("tls13 test: invalid server key sizes")
    let nonceRes: Result[Bytes] = buildNonce(kmClient.sendIv, 42)
    if IsErr(nonceRes):
        return Err[bool](ErrorText(nonceRes))
    let keyRes: Result[ChaChaPolyKey] = intoChaChaPolyKey(kmClient.sendKey)
    if IsErr(keyRes):
        return Err[bool](ErrorText(keyRes))
    let nonceKeyRes: Result[ChaChaPolyNonce] = intoChaChaPolyNonce(Value(nonceRes))
    if IsErr(nonceKeyRes):
        return Err[bool](ErrorText(nonceKeyRes))
    let aad: Bytes = bytesFromString("aad")
    let plain: Bytes = bytesFromString("hello-msquic")
    let cipher: Bytes = bytesSlice(plain, 0, bytesLen(plain))
    var tag: ChaChaPolyTag
    let encRes: Result[bool] = encrypt(Value(keyRes), Value(nonceKeyRes), tag, cipher, aad)
    if IsErr(encRes):
        return Err[bool](ErrorText(encRes))
    let decKeyRes: Result[ChaChaPolyKey] = intoChaChaPolyKey(kmServer.recvKey)
    if IsErr(decKeyRes):
        return Err[bool](ErrorText(decKeyRes))
    let decNonceRes: Result[Bytes] = buildNonce(kmServer.recvIv, 42)
    if IsErr(decNonceRes):
        return Err[bool](ErrorText(decNonceRes))
    let decNonceKeyRes: Result[ChaChaPolyNonce] = intoChaChaPolyNonce(Value(decNonceRes))
    if IsErr(decNonceKeyRes):
        return Err[bool](ErrorText(decNonceKeyRes))
    let decRes: Result[bool] = decrypt(Value(decKeyRes), Value(decNonceKeyRes), tag, cipher, aad)
    if IsErr(decRes):
        return Err[bool](ErrorText(decRes))
    if ! bytesEqual(cipher, plain):
        return Err[bool]("tls13 test: round-trip mismatch")
    let aesKeyBytesRes: Result[Bytes] = msquicTls13HexDecode("00000000000000000000000000000000")
    if IsErr(aesKeyBytesRes):
        return Err[bool](ErrorText(aesKeyBytesRes))
    let aesNonceRes: Result[Bytes] = msquicTls13HexDecode("000000000000000000000000")
    if IsErr(aesNonceRes):
        return Err[bool](ErrorText(aesNonceRes))
    let ptRes: Result[Bytes] = msquicTls13HexDecode("00000000000000000000000000000000")
    if IsErr(ptRes):
        return Err[bool](ErrorText(ptRes))
    let ctRes: Result[Bytes] = msquicTls13HexDecode("0388dace60b6a392f328c2b971b2fe78")
    if IsErr(ctRes):
        return Err[bool](ErrorText(ctRes))
    let tagRes: Result[Bytes] = msquicTls13HexDecode("ab6e47d42cec13bdf53a67b21257bddf")
    if IsErr(tagRes):
        return Err[bool](ErrorText(tagRes))
    let keyObjRes: Result[AesGcmKey] = intoAesGcmKey(Value(aesKeyBytesRes))
    if IsErr(keyObjRes):
        return Err[bool](ErrorText(keyObjRes))
    let nonceObjRes: Result[AesGcmNonce] = intoAesGcmNonce(Value(aesNonceRes))
    if IsErr(nonceObjRes):
        return Err[bool](ErrorText(nonceObjRes))
    let aad2: Bytes = emptyBytes()
    let plain2: Bytes = Value(ptRes)
    let cipher2: Bytes = bytesSlice(plain2, 0, bytesLen(plain2))
    var tag2: AesGcmTag
    let encRes2: Result[bool] = aesGcmEncrypt(Value(keyObjRes), Value(nonceObjRes), tag2, cipher2, aad2)
    if IsErr(encRes2):
        return Err[bool](ErrorText(encRes2))
    if ! bytesEqual(cipher2, Value(ctRes)):
        return Err[bool]("tls13 test: aesgcm ciphertext mismatch")
    if ! bytesEqual(tag2.data, Value(tagRes)):
        return Err[bool]("tls13 test: aesgcm tag mismatch")
    let decRes2: Result[bool] = aesGcmDecrypt(Value(keyObjRes), Value(nonceObjRes), AesGcmTag(data: Value(tagRes)), cipher2, aad2)
    if IsErr(decRes2):
        return Err[bool](ErrorText(decRes2))
    if ! bytesEqual(cipher2, plain2):
        return Err[bool]("tls13 test: aesgcm round-trip mismatch")
    return Ok[bool](true)
