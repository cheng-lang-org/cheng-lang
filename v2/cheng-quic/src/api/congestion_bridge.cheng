# MsQuic congestion bridge(minimal).

import std/strings
import cheng/quic/congestion/common
fn msquicCongestionAlgorithmToString(algo: CongestionAlgorithm): str =
    if algo == caBbr:
        return "bbr"
    return "cubic"

fn msquicCongestionAlgorithmFromString(text: str): CongestionAlgorithm =
    if (text ==  "bbr"):
        return caBbr
    return caCubic
