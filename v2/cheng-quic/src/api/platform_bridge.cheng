# MsQuic platform bridge(minimal).

import cheng/quic/platform/common
type
    # Re-export the canonical platform enum defined in platform/common.
    #
    # The Cheng backend currently lowers enum fields into globals, so defining
    # a second enum with identical field names would cause a global symbol
    # conflict at compile time.
    MsQuicPlatform = MsQuicPlatformKind

fn msquicPlatformFromString(text: str): MsQuicPlatform =
    return msquicPlatformKindFromString(text)

fn msquicPlatformToString(p: MsQuicPlatform): str =
    return msquicPlatformKindToString(p)
