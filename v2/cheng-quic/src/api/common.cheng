# MsQuic API common definitions(minimal).

import std/buffer
import std/rawbytes
const
    msQuicApiVersion = "0.1"

type
    MsQuicStatus = enum
        MsQuicStatusOk = 0
        MsQuicStatusFailed = 1
        MsQuicStatusInvalidParam = 2
        MsQuicStatusNotSupported = 3

fn msquicStatusOk(status: MsQuicStatus): bool =
    return status == MsQuicStatusOk

fn msquicStatusFromBool(ok: bool): MsQuicStatus =
    if ok:
        return MsQuicStatusOk
    return MsQuicStatusFailed

fn msquicStatusToString(status: MsQuicStatus): str =
    if status == MsQuicStatusOk:
        return "ok"
    if status == MsQuicStatusInvalidParam:
        return "invalid_param"
    if status == MsQuicStatusNotSupported:
        return "not_supported"
    return "failed"

fn msquicIntToString(value: int64): str =
    if value == 0:
        return "0"
    var v: int64 = value
    var neg: bool = false
    if v < 0:
        neg = true
        v = -v
    var buf: ByteBuffer = newByteBuffer()
    while v > 0:
        let digit: int64 = v % 10
        appendByte(buf, int32('0') + int32(digit))
        v = v / 10
    let rev: Bytes = toBytes(buf)
    let extra: int32 = if neg: 1 else: 0
    let out: Bytes = bytesAlloc(bytesLen(rev) + extra)
    var i: int32 = 0
    if neg:
        bytesSet(out, 0, int32('-'))
        i = 1
    for j in 0..<bytesLen(rev):
        let srcIdx: int32 = bytesLen(rev) - 1 - j
        bytesSet(out, i + j, bytesGet(rev, srcIdx))
    return bytesToString(out)
