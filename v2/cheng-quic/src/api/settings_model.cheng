# MsQuic settings model(minimal).

import std/result
import std/strings
import cheng/quic/msquicruntime
import cheng/quic/inc/msquic_settings
import cheng/quic/inc/msquic_constants
import cheng/quic/api/common

fn msquicInt64ToInt32Clamped(value: int64): int32 =
    if value > 2147483647:
        return 2147483647
    if value < -2147483648:
        return -2147483648
    return int32(value)

fn msquicSettingsFromQuicSettings(settings: QUIC_SETTINGS): MsQuicSettings =
    var out: MsQuicSettings = initMsQuicSettings()
    if settings.isSet.maxBytesPerKey:
        out.maxBytesPerKey = settings.maxBytesPerKey
    if settings.isSet.handshakeIdleTimeoutMs:
        out.handshakeIdleTimeoutMs = settings.handshakeIdleTimeoutMs
    if settings.isSet.idleTimeoutMs:
        out.idleTimeoutMs = settings.idleTimeoutMs
    if settings.isSet.mtuDiscoverySearchCompleteTimeoutUs:
        out.mtuDiscoverySearchCompleteTimeoutUs = settings.mtuDiscoverySearchCompleteTimeoutUs
    if settings.isSet.tlsClientMaxSendBuffer:
        out.tlsClientMaxSendBuffer = settings.tlsClientMaxSendBuffer
    if settings.isSet.tlsServerMaxSendBuffer:
        out.tlsServerMaxSendBuffer = settings.tlsServerMaxSendBuffer
    if settings.isSet.streamRecvWindowDefault:
        out.streamRecvWindowDefault = settings.streamRecvWindowDefault
    if settings.isSet.streamRecvBufferDefault:
        out.streamRecvBufferDefault = settings.streamRecvBufferDefault
    if settings.isSet.connFlowControlWindow:
        out.connFlowControlWindow = settings.connFlowControlWindow
    if settings.isSet.maxWorkerQueueDelayUs:
        out.maxWorkerQueueDelayUs = settings.maxWorkerQueueDelayUs
    if settings.isSet.maxStatelessOperations:
        out.maxStatelessOperations = settings.maxStatelessOperations
    if settings.isSet.initialWindowPackets:
        out.initialWindowPackets = settings.initialWindowPackets
    if settings.isSet.sendIdleTimeoutMs:
        out.sendIdleTimeoutMs = int64(settings.sendIdleTimeoutMs)
    if settings.isSet.initialRttMs:
        out.initialRttMs = int64(settings.initialRttMs)
    if settings.isSet.maxAckDelayMs:
        out.maxAckDelayMs = int64(settings.maxAckDelayMs)
    if settings.isSet.disconnectTimeoutMs:
        out.disconnectTimeoutMs = settings.disconnectTimeoutMs
    if settings.isSet.keepAliveIntervalMs:
        out.keepAliveIntervalMs = int64(settings.keepAliveIntervalMs)
    if settings.isSet.peerBidiStreamCount:
        out.maxStreamsBidi = settings.peerBidiStreamCount
    if settings.isSet.peerUnidiStreamCount:
        out.maxStreamsUni = settings.peerUnidiStreamCount
    if settings.isSet.minimumMtu:
        out.minimumMtu = settings.minimumMtu
    if settings.isSet.maximumMtu:
        out.maximumMtu = settings.maximumMtu
        # Align with MsQuic's effective max UDP payload sizing in tests:
        # when maximum MTU is configured, treat it as the max datagram size.
        if settings.maximumMtu > 0:
            out.maxDatagram = settings.maximumMtu
    if settings.isSet.sendBufferingEnabled:
        out.sendBufferingEnabled = settings.sendBufferingEnabled
    if settings.isSet.pacingEnabled:
        out.pacingEnabled = settings.pacingEnabled
    if settings.isSet.migrationEnabled:
        out.migrationEnabled = settings.migrationEnabled
    if settings.isSet.datagramReceiveEnabled:
        out.allowDatagram = settings.datagramReceiveEnabled
    if settings.isSet.serverResumptionLevel:
        out.allow0Rtt = settings.serverResumptionLevel == QUIC_SERVER_RESUME_AND_ZERORTT
    if settings.isSet.maxBindingStatelessOperations:
        out.maxBindingStatelessOperations = settings.maxBindingStatelessOperations
    if settings.isSet.statelessOperationExpirationMs:
        out.statelessOperationExpirationMs = settings.statelessOperationExpirationMs
    if settings.isSet.maxOperationsPerDrain:
        out.maxOperationsPerDrain = settings.maxOperationsPerDrain
    if settings.isSet.mtuDiscoveryMissingProbeCount:
        out.mtuDiscoveryMissingProbeCount = settings.mtuDiscoveryMissingProbeCount
    if settings.isSet.destCidUpdateIdleTimeoutMs:
        out.destCidUpdateIdleTimeoutMs = settings.destCidUpdateIdleTimeoutMs
    if settings.isSet.eventSampleEvery:
        out.eventSampleEvery = settings.eventSampleEvery
    if settings.isSet.greaseQuicBitEnabled:
        out.greaseQuicBitEnabled = settings.greaseQuicBitEnabled
    if settings.isSet.versionNegotiationExtEnabled:
        out.versionNegotiationExtEnabled = settings.versionNegotiationExtEnabled
    if settings.isSet.ecnEnabled:
        out.ecnEnabled = settings.ecnEnabled
    if settings.isSet.hyStartEnabled:
        out.hyStartEnabled = settings.flags.hyStartEnabled
    if settings.isSet.encryptionOffloadAllowed:
        out.encryptionOffloadAllowed = settings.flags.encryptionOffloadAllowed
    if settings.isSet.reliableResetEnabled:
        out.reliableResetEnabled = settings.flags.reliableResetEnabled
    if settings.isSet.oneWayDelayEnabled:
        out.oneWayDelayEnabled = settings.flags.oneWayDelayEnabled
    if settings.isSet.netStatsEventEnabled:
        out.netStatsEventEnabled = settings.flags.netStatsEventEnabled
    if settings.isSet.streamMultiReceiveEnabled:
        out.streamMultiReceiveEnabled = settings.flags.streamMultiReceiveEnabled
    if settings.isSet.xdpEnabled:
        out.xdpEnabled = settings.flags.xdpEnabled
    if settings.isSet.qtipEnabled:
        out.qtipEnabled = settings.flags.qtipEnabled
    if settings.isSet.reservedRioEnabled:
        out.reservedRioEnabled = settings.flags.reservedRioEnabled
    if settings.isSet.streamRecvWindowBidiLocalDefault:
        out.streamRecvWindowBidiLocalDefault = settings.streamRecvWindowBidiLocalDefault
    if settings.isSet.streamRecvWindowBidiRemoteDefault:
        out.streamRecvWindowBidiRemoteDefault = settings.streamRecvWindowBidiRemoteDefault
    if settings.isSet.streamRecvWindowUnidiDefault:
        out.streamRecvWindowUnidiDefault = settings.streamRecvWindowUnidiDefault
    if settings.isSet.congestionControlAlgorithm:
        out.useBbr = settings.congestionControlAlgorithm == QUIC_CONGESTION_CONTROL_ALGORITHM_BBR
    return out

fn msquicSettingsToQuicSettings(settings: MsQuicSettings): QUIC_SETTINGS =
    var out: QUIC_SETTINGS = initQuicSettings()
    out.isSet.maxBytesPerKey = true
    out.maxBytesPerKey = settings.maxBytesPerKey
    out.isSet.handshakeIdleTimeoutMs = true
    out.handshakeIdleTimeoutMs = settings.handshakeIdleTimeoutMs
    out.isSet.idleTimeoutMs = true
    out.idleTimeoutMs = settings.idleTimeoutMs
    out.isSet.mtuDiscoverySearchCompleteTimeoutUs = true
    out.mtuDiscoverySearchCompleteTimeoutUs = settings.mtuDiscoverySearchCompleteTimeoutUs
    out.isSet.tlsClientMaxSendBuffer = true
    out.tlsClientMaxSendBuffer = settings.tlsClientMaxSendBuffer
    out.isSet.tlsServerMaxSendBuffer = true
    out.tlsServerMaxSendBuffer = settings.tlsServerMaxSendBuffer
    out.isSet.streamRecvWindowDefault = true
    out.streamRecvWindowDefault = settings.streamRecvWindowDefault
    out.isSet.streamRecvBufferDefault = true
    out.streamRecvBufferDefault = settings.streamRecvBufferDefault
    out.isSet.connFlowControlWindow = true
    out.connFlowControlWindow = settings.connFlowControlWindow
    out.isSet.maxWorkerQueueDelayUs = true
    out.maxWorkerQueueDelayUs = settings.maxWorkerQueueDelayUs
    out.isSet.maxStatelessOperations = true
    out.maxStatelessOperations = settings.maxStatelessOperations
    out.isSet.initialWindowPackets = true
    out.initialWindowPackets = settings.initialWindowPackets
    out.isSet.sendIdleTimeoutMs = true
    out.sendIdleTimeoutMs = msquicInt64ToInt32Clamped(settings.sendIdleTimeoutMs)
    out.isSet.initialRttMs = true
    out.initialRttMs = msquicInt64ToInt32Clamped(settings.initialRttMs)
    out.isSet.maxAckDelayMs = true
    out.maxAckDelayMs = msquicInt64ToInt32Clamped(settings.maxAckDelayMs)
    out.isSet.disconnectTimeoutMs = true
    out.disconnectTimeoutMs = settings.disconnectTimeoutMs
    out.isSet.keepAliveIntervalMs = true
    out.keepAliveIntervalMs = msquicInt64ToInt32Clamped(settings.keepAliveIntervalMs)
    out.isSet.peerBidiStreamCount = true
    out.peerBidiStreamCount = settings.maxStreamsBidi
    out.isSet.peerUnidiStreamCount = true
    out.peerUnidiStreamCount = settings.maxStreamsUni
    out.isSet.minimumMtu = true
    out.minimumMtu = settings.minimumMtu
    out.isSet.maximumMtu = true
    out.maximumMtu = settings.maximumMtu
    out.isSet.sendBufferingEnabled = true
    out.sendBufferingEnabled = settings.sendBufferingEnabled
    out.isSet.pacingEnabled = true
    out.pacingEnabled = settings.pacingEnabled
    out.isSet.migrationEnabled = true
    out.migrationEnabled = settings.migrationEnabled
    out.isSet.datagramReceiveEnabled = true
    out.datagramReceiveEnabled = settings.allowDatagram
    out.isSet.serverResumptionLevel = true
    if settings.allow0Rtt:
        out.serverResumptionLevel = QUIC_SERVER_RESUME_AND_ZERORTT
    else:
        out.serverResumptionLevel = QUIC_SERVER_RESUME_ONLY
    out.isSet.maxBindingStatelessOperations = true
    out.maxBindingStatelessOperations = settings.maxBindingStatelessOperations
    out.isSet.statelessOperationExpirationMs = true
    out.statelessOperationExpirationMs = settings.statelessOperationExpirationMs
    out.isSet.maxOperationsPerDrain = true
    out.maxOperationsPerDrain = settings.maxOperationsPerDrain
    out.isSet.mtuDiscoveryMissingProbeCount = true
    out.mtuDiscoveryMissingProbeCount = settings.mtuDiscoveryMissingProbeCount
    out.isSet.destCidUpdateIdleTimeoutMs = true
    out.destCidUpdateIdleTimeoutMs = settings.destCidUpdateIdleTimeoutMs
    out.isSet.eventSampleEvery = true
    out.eventSampleEvery = settings.eventSampleEvery
    out.isSet.greaseQuicBitEnabled = true
    out.greaseQuicBitEnabled = settings.greaseQuicBitEnabled
    out.isSet.versionNegotiationExtEnabled = true
    out.versionNegotiationExtEnabled = settings.versionNegotiationExtEnabled
    out.isSet.ecnEnabled = true
    out.ecnEnabled = settings.ecnEnabled
    out.isSet.hyStartEnabled = true
    out.flags.hyStartEnabled = settings.hyStartEnabled
    out.isSet.encryptionOffloadAllowed = true
    out.flags.encryptionOffloadAllowed = settings.encryptionOffloadAllowed
    out.isSet.reliableResetEnabled = true
    out.flags.reliableResetEnabled = settings.reliableResetEnabled
    out.isSet.oneWayDelayEnabled = true
    out.flags.oneWayDelayEnabled = settings.oneWayDelayEnabled
    out.isSet.netStatsEventEnabled = true
    out.flags.netStatsEventEnabled = settings.netStatsEventEnabled
    out.isSet.streamMultiReceiveEnabled = true
    out.flags.streamMultiReceiveEnabled = settings.streamMultiReceiveEnabled
    out.isSet.xdpEnabled = true
    out.flags.xdpEnabled = settings.xdpEnabled
    out.isSet.qtipEnabled = true
    out.flags.qtipEnabled = settings.qtipEnabled
    out.isSet.reservedRioEnabled = true
    out.flags.reservedRioEnabled = settings.reservedRioEnabled
    out.isSet.streamRecvWindowBidiLocalDefault = true
    out.streamRecvWindowBidiLocalDefault = settings.streamRecvWindowBidiLocalDefault
    out.isSet.streamRecvWindowBidiRemoteDefault = true
    out.streamRecvWindowBidiRemoteDefault = settings.streamRecvWindowBidiRemoteDefault
    out.isSet.streamRecvWindowUnidiDefault = true
    out.streamRecvWindowUnidiDefault = settings.streamRecvWindowUnidiDefault
    out.isSet.congestionControlAlgorithm = true
    if settings.useBbr:
        out.congestionControlAlgorithm = QUIC_CONGESTION_CONTROL_ALGORITHM_BBR
    else:
        out.congestionControlAlgorithm = QUIC_CONGESTION_CONTROL_ALGORITHM_CUBIC
    return out
fn msquicSettingsDefaults(): MsQuicSettings =
    return initMsQuicSettings()

fn msquicSettingsValidate(settings: var MsQuicSettings): Result[bool] =
    return validateMsQuicSettings(settings)

fn msquicSettingsSetMaxPending(settings: var MsQuicSettings, value: int32): Result[bool] =
    if value <= 0:
        return Err[bool]("msquic settings: maxPending must be positive")
    settings.maxPending = value
    return msquicSettingsValidate(settings)

fn msquicSettingsSetIdleTimeoutMs(settings: var MsQuicSettings, value: int64): Result[bool] =
    if value < 0:
        return Err[bool]("msquic settings: idleTimeoutMs must be non-negative")
    settings.idleTimeoutMs = value
    return Ok[bool](true)

fn msquicSettingsSetMaxDatagram(settings: var MsQuicSettings, value: int32): Result[bool] =
    if value < 0:
        return Err[bool]("msquic settings: maxDatagram must be non-negative")
    settings.maxDatagram = value
    return Ok[bool](true)

fn msquicSettingsSetMaxStreamsBidi(settings: var MsQuicSettings, value: int32): Result[bool] =
    if value < 0:
        return Err[bool]("msquic settings: maxStreamsBidi must be non-negative")
    settings.maxStreamsBidi = value
    return Ok[bool](true)

fn msquicSettingsSetMaxStreamsUni(settings: var MsQuicSettings, value: int32): Result[bool] =
    if value < 0:
        return Err[bool]("msquic settings: maxStreamsUni must be non-negative")
    settings.maxStreamsUni = value
    return Ok[bool](true)

fn msquicSettingsSetAllowDatagram(settings: var MsQuicSettings, enabled: bool) =
    settings.allowDatagram = enabled

fn msquicSettingsSetAllow0Rtt(settings: var MsQuicSettings, enabled: bool) =
    settings.allow0Rtt = enabled

fn msquicSettingsSetUseBbr(settings: var MsQuicSettings, enabled: bool) =
    settings.useBbr = enabled

fn msquicSettingsSummary(settings: MsQuicSettings): str =
    var out: str = "msquic settings"
    out = out + " maxPending="
    out = out + msquicIntToString(settings.maxPending)
    out = out + " idleTimeoutMs="
    out = out + msquicIntToString(settings.idleTimeoutMs)
    out = out + " maxDatagram="
    out = out + msquicIntToString(settings.maxDatagram)
    out = out + " maxStreamsBidi="
    out = out + msquicIntToString(settings.maxStreamsBidi)
    out = out + " maxStreamsUni="
    out = out + msquicIntToString(settings.maxStreamsUni)
    let allowDatagramText: str = if settings.allowDatagram: "true" else: "false"
    let allow0RttText: str = if settings.allow0Rtt: "true" else: "false"
    let useBbrText: str = if settings.useBbr: "true" else: "false"
    out = out + " allowDatagram="
    out = out + allowDatagramText
    out = out + " allow0Rtt="
    out = out + allow0RttText
    out = out + " useBbr="
    out = out + useBbrText
    return out
