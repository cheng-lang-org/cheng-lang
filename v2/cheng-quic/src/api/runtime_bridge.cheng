# MsQuic runtime bridge(minimal).

import std/result
import cheng/quic/msquicruntime
type
    MsQuicRuntimeBridge =
        runtime: MsQuicRuntime
        startedAtMs: int64

fn initMsQuicRuntimeBridge(): MsQuicRuntimeBridge =
    let rt: MsQuicRuntime = initMsQuicRuntime()
    MsQuicRuntimeBridge(runtime: rt, startedAtMs: msquicNowMs())

fn msquicRuntimeBridgeSettings(rb: MsQuicRuntimeBridge): MsQuicSettings =
    return msquicRuntimeSettings(rb.runtime)

fn msquicRuntimeBridgeSetSettings(rb: var MsQuicRuntimeBridge, settings: MsQuicSettings): Result[bool] =
    return setMsQuicRuntimeSettings(rb.runtime, settings)

fn msquicRuntimeBridgeAllocConnId(rb: var MsQuicRuntimeBridge): int64 =
    return msquicAllocConnectionId(rb.runtime)

fn msquicRuntimeBridgeAllocStreamId(rb: var MsQuicRuntimeBridge): int64 =
    return msquicAllocStreamId(rb.runtime)
