# MsQuic TLS parameter helpers(minimal).

import std/result
import std/rawbytes
import cheng/quic/inc/msquic_params
import cheng/quic/inc/msquic_crypto
import cheng/quic/inc/msquic_types
type
    MsQuicTlsParamState =
        handshake: QUIC_HANDSHAKE_INFO
        negotiatedAlpn: Bytes
        schannelAttribute: QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_W
        schannelAttributeEx: QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_EX_W
        schannelSecurityToken: QUIC_SCHANNEL_SECURITY_CONTEXT_TOKEN

fn initMsQuicTlsParamState(): MsQuicTlsParamState =
    MsQuicTlsParamState(
        handshake: initQuicHandshakeInfo(),
        negotiatedAlpn: emptyBytes(),
        schannelAttribute: initQuicSchannelContextAttribute(),
        schannelAttributeEx: initQuicSchannelContextAttributeEx(),
        schannelSecurityToken: initQuicSchannelSecurityContextToken()
    )

fn msquicTlsSetParamHandshakeInfo(state: var MsQuicTlsParamState, param: int32, info: QUIC_HANDSHAKE_INFO): Result[bool] =
    if param != qUIC_PARAM_TLS_HANDSHAKE_INFO:
        return Err[bool]("msquic tls param: unsupported handshake info")
    state.handshake = info
    return Ok[bool](true)

fn msquicTlsGetParamHandshakeInfo(state: MsQuicTlsParamState, param: int32): Result[QUIC_HANDSHAKE_INFO] =
    if param != qUIC_PARAM_TLS_HANDSHAKE_INFO:
        return Err[QUIC_HANDSHAKE_INFO]("msquic tls param: unsupported handshake info")
    return Ok[QUIC_HANDSHAKE_INFO](state.handshake)

fn msquicTlsSetParamBytes(state: var MsQuicTlsParamState, param: int32, data: Bytes): Result[bool] =
    if param != qUIC_PARAM_TLS_NEGOTIATED_ALPN:
        return Err[bool]("msquic tls param: unsupported bytes")
    if bytesLen(data) > 255:
        return Err[bool]("msquic tls param: negotiated alpn too long")
    state.negotiatedAlpn = data
    return Ok[bool](true)

fn msquicTlsGetParamBytes(state: MsQuicTlsParamState, param: int32): Result[Bytes] =
    if param != qUIC_PARAM_TLS_NEGOTIATED_ALPN:
        return Err[Bytes]("msquic tls param: unsupported bytes")
    return Ok[Bytes](state.negotiatedAlpn)

fn msquicTlsSetParamSchannelAttribute(state: var MsQuicTlsParamState, param: int32, attr: QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_W): Result[bool] =
    if param != qUIC_PARAM_TLS_SCHANNEL_CONTEXT_ATTRIBUTE_W:
        return Err[bool]("msquic tls param: unsupported schannel attribute")
    state.schannelAttribute = attr
    return Ok[bool](true)

fn msquicTlsGetParamSchannelAttribute(state: MsQuicTlsParamState, param: int32): Result[QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_W] =
    if param != qUIC_PARAM_TLS_SCHANNEL_CONTEXT_ATTRIBUTE_W:
        return Err[QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_W]("msquic tls param: unsupported schannel attribute")
    return Ok[QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_W](state.schannelAttribute)

fn msquicTlsSetParamSchannelAttributeEx(state: var MsQuicTlsParamState, param: int32, attr: QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_EX_W): Result[bool] =
    if param != qUIC_PARAM_TLS_SCHANNEL_CONTEXT_ATTRIBUTE_EX_W:
        return Err[bool]("msquic tls param: unsupported schannel attribute ex")
    if attr.bufferLength < 0:
        return Err[bool]("msquic tls param: invalid schannel buffer length")
    if attr.bufferLength != bytesLen(attr.buffer):
        return Err[bool]("msquic tls param: schannel buffer length mismatch")
    state.schannelAttributeEx = attr
    return Ok[bool](true)

fn msquicTlsGetParamSchannelAttributeEx(state: MsQuicTlsParamState, param: int32): Result[QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_EX_W] =
    if param != qUIC_PARAM_TLS_SCHANNEL_CONTEXT_ATTRIBUTE_EX_W:
        return Err[QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_EX_W]("msquic tls param: unsupported schannel attribute ex")
    return Ok[QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_EX_W](state.schannelAttributeEx)

fn msquicTlsSetParamSchannelSecurityToken(state: var MsQuicTlsParamState, param: int32, token: QUIC_SCHANNEL_SECURITY_CONTEXT_TOKEN): Result[bool] =
    if param != qUIC_PARAM_TLS_SCHANNEL_SECURITY_CONTEXT_TOKEN:
        return Err[bool]("msquic tls param: unsupported schannel security token")
    state.schannelSecurityToken = token
    return Ok[bool](true)

fn msquicTlsGetParamSchannelSecurityToken(state: MsQuicTlsParamState, param: int32): Result[QUIC_SCHANNEL_SECURITY_CONTEXT_TOKEN] =
    if param != qUIC_PARAM_TLS_SCHANNEL_SECURITY_CONTEXT_TOKEN:
        return Err[QUIC_SCHANNEL_SECURITY_CONTEXT_TOKEN]("msquic tls param: unsupported schannel security token")
    return Ok[QUIC_SCHANNEL_SECURITY_CONTEXT_TOKEN](state.schannelSecurityToken)
