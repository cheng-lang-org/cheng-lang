# MsQuic stream parameter helpers(minimal).

import std/result
import cheng/quic/msquicstream
import cheng/quic/inc/msquic_params
import cheng/quic/inc/msquic_settings
fn msquicStreamSetParamUint64(stream: var MsQuicStream, param: int32, value: int64): Result[bool] =
    if value < 0:
        return Err[bool]("msquic stream param: negative value")
    if param == qUIC_PARAM_STREAM_0RTT_LENGTH:
        return msquicStreamSetZeroRttLength(stream, value)
    if param == qUIC_PARAM_STREAM_IDEAL_SEND_BUFFER_SIZE:
        return msquicStreamSetIdealSendBufferSize(stream, value)
    if param == qUIC_PARAM_STREAM_RELIABLE_OFFSET:
        return msquicStreamSetReliableOffset(stream, value)
    if param == qUIC_PARAM_STREAM_ID:
        return Err[bool]("msquic stream param: stream id is read-only")
    return Err[bool]("msquic stream param: unsupported uint64")

fn msquicStreamGetParamUint64(stream: MsQuicStream, param: int32): Result[int64] =
    if param == qUIC_PARAM_STREAM_ID:
        return Ok[int64](msquicStreamId(stream))
    if param == qUIC_PARAM_STREAM_0RTT_LENGTH:
        return Ok[int64](msquicStreamZeroRttLength(stream))
    if param == qUIC_PARAM_STREAM_IDEAL_SEND_BUFFER_SIZE:
        return Ok[int64](msquicStreamIdealSendBufferSize(stream))
    if param == qUIC_PARAM_STREAM_RELIABLE_OFFSET:
        return Ok[int64](msquicStreamReliableOffset(stream))
    return Err[int64]("msquic stream param: unsupported uint64")

fn msquicStreamSetParamPriority(stream: var MsQuicStream, param: int32, value: int32): Result[bool] =
    if param != qUIC_PARAM_STREAM_PRIORITY:
        return Err[bool]("msquic stream param: unsupported priority")
    return msquicStreamSetPriority(stream, value)

fn msquicStreamGetParamPriority(stream: MsQuicStream, param: int32): Result[int32] =
    if param != qUIC_PARAM_STREAM_PRIORITY:
        return Err[int32]("msquic stream param: unsupported priority")
    return Ok[int32](msquicStreamPriority(stream))

fn msquicStreamGetParamStatistics(stream: MsQuicStream, param: int32): Result[QUIC_STREAM_STATISTICS] =
    if param != qUIC_PARAM_STREAM_STATISTICS:
        return Err[QUIC_STREAM_STATISTICS]("msquic stream param: unsupported statistics")
    let stats: QUIC_STREAM_STATISTICS = initQuicStreamStatistics()
    return Ok[QUIC_STREAM_STATISTICS](stats)
