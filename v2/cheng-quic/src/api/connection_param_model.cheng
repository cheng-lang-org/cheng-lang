# MsQuic connection parameter helpers(minimal).

import std/result
import std/rawbytes
import cheng/quic/msquicconnection
import cheng/quic/inc/msquic_crypto
import cheng/quic/inc/msquic_params
import cheng/quic/inc/msquic_types
import cheng/quic/inc/msquic_constants
import cheng/quic/inc/msquic_settings
import cheng/quic/api/settings_model
import cheng/quic/platform/address_bridge
fn msquicConnSetParamSettings(conn: var MsQuicConnection, param: int32, settings: QUIC_SETTINGS): Result[bool] =
    if param != qUIC_PARAM_CONN_SETTINGS:
        return Err[bool]("msquic conn param: unsupported settings")
    let mapped: MsQuicSettings = msquicSettingsFromQuicSettings(settings)
    return msquicConnectionApplySettings(conn, mapped)

fn msquicConnGetParamSettings(conn: MsQuicConnection, param: int32): Result[QUIC_SETTINGS] =
    if param != qUIC_PARAM_CONN_SETTINGS:
        return Err[QUIC_SETTINGS]("msquic conn param: unsupported settings")
    return Ok[QUIC_SETTINGS](msquicSettingsToQuicSettings(msquicConnectionSettings(conn)))

fn msquicConnSetParamAddr(conn: var MsQuicConnection, param: int32, addr: QUIC_ADDR): Result[bool] =
    let maddrRes: Result[MultiAddress] = msquicAddrToMultiAddress(addr)
    if IsErr(maddrRes):
        return Err[bool](ErrorText(maddrRes))
    let maddr: MultiAddress = Value(maddrRes)
    if param == qUIC_PARAM_CONN_LOCAL_ADDRESS:
        msquicConnectionSetLocalAddr(conn, maddr)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_REMOTE_ADDRESS:
        msquicConnectionSetRemoteAddr(conn, maddr)
        return Ok[bool](true)
    return Err[bool]("msquic conn param: unsupported addr")

fn msquicConnGetParamAddr(conn: MsQuicConnection, param: int32): Result[QUIC_ADDR] =
    if param == qUIC_PARAM_CONN_LOCAL_ADDRESS:
        return Ok[QUIC_ADDR](msquicAddrFromMultiAddress(msquicConnectionLocalAddr(conn)))
    if param == qUIC_PARAM_CONN_REMOTE_ADDRESS:
        return Ok[QUIC_ADDR](msquicAddrFromMultiAddress(msquicConnectionRemoteAddr(conn)))
    return Err[QUIC_ADDR]("msquic conn param: unsupported addr")

fn msquicConnSetParamInt(conn: var MsQuicConnection, param: int32, value: int32): Result[bool] =
    if param == qUIC_PARAM_CONN_QUIC_VERSION:
        msquicConnectionSetQuicVersion(conn, value)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_IDEAL_PROCESSOR:
        msquicConnectionSetIdealProcessor(conn, value)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_LOCAL_INTERFACE:
        if value < 0:
            return Err[bool]("msquic conn param: local interface must be non-negative")
        msquicConnectionSetLocalInterface(conn, value)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_SEND_DSCP:
        if value < 0 || value > 63:
            return Err[bool]("msquic conn param: dscp out of range")
        msquicConnectionSetSendDscp(conn, value)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_LOCAL_BIDI_STREAM_COUNT:
        return msquicConnectionSetMaxStreamsBidi(conn, value)
    if param == qUIC_PARAM_CONN_LOCAL_UNIDI_STREAM_COUNT:
        return msquicConnectionSetMaxStreamsUni(conn, value)
    if param == qUIC_PARAM_CONN_STREAM_SCHEDULING_SCHEME:
        if value < 0 || value >= int32(QUIC_STREAM_SCHEDULING_SCHEME_COUNT):
            return Err[bool]("msquic conn param: invalid scheduling scheme")
        msquicConnectionSetStreamSchedulingScheme(conn, QUIC_STREAM_SCHEDULING_SCHEME(value))
        return Ok[bool](true)
    return Err[bool]("msquic conn param: unsupported int")

fn msquicConnGetParamInt(conn: MsQuicConnection, param: int32): Result[int32] =
    if param == qUIC_PARAM_CONN_QUIC_VERSION:
        return Ok[int32](msquicConnectionQuicVersion(conn))
    if param == qUIC_PARAM_CONN_IDEAL_PROCESSOR:
        return Ok[int32](msquicConnectionIdealProcessor(conn))
    if param == qUIC_PARAM_CONN_LOCAL_INTERFACE:
        return Ok[int32](msquicConnectionLocalInterface(conn))
    if param == qUIC_PARAM_CONN_SEND_DSCP:
        return Ok[int32](msquicConnectionSendDscp(conn))
    if param == qUIC_PARAM_CONN_LOCAL_BIDI_STREAM_COUNT:
        return Ok[int32](conn.maxStreamsBidi)
    if param == qUIC_PARAM_CONN_LOCAL_UNIDI_STREAM_COUNT:
        return Ok[int32](conn.maxStreamsUni)
    if param == qUIC_PARAM_CONN_STREAM_SCHEDULING_SCHEME:
        return Ok[int32](int32(msquicConnectionStreamSchedulingScheme(conn)))
    return Err[int32]("msquic conn param: unsupported int")

fn msquicConnGetParamMaxStreamIds(conn: MsQuicConnection, param: int32): Result[QUIC_MAX_STREAM_IDS] =
    if param != qUIC_PARAM_CONN_MAX_STREAM_IDS:
        return Err[QUIC_MAX_STREAM_IDS]("msquic conn param: unsupported max stream ids")
    var out: QUIC_MAX_STREAM_IDS = initQuicMaxStreamIds()
    var bidi: int64 = int64(conn.maxStreamsBidi)
    if bidi < 0:
        bidi = 0
    var uni: int64 = int64(conn.maxStreamsUni)
    if uni < 0:
        uni = 0
    for i in 0..<maxQuicStreamIdTypes:
        let useUni: bool = (i & 0x2) != 0
        let maxCount: int64 = if useUni: uni else: bidi
        out.ids[i] = (maxCount << 2) | int64(i)
    return Ok[QUIC_MAX_STREAM_IDS](out)

fn msquicConnSetParamBool(conn: var MsQuicConnection, param: int32, enabled: bool): Result[bool] =
    if param == qUIC_PARAM_CONN_DATAGRAM_RECEIVE_ENABLED:
        msquicConnectionSetDatagramReceiveEnabled(conn, enabled)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_DATAGRAM_SEND_ENABLED:
        msquicConnectionSetDatagramSendEnabled(conn, enabled)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_DISABLE_1RTT_ENCRYPTION:
        msquicConnectionSetDisable1RttEncryption(conn, enabled)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_SHARE_UDP_BINDING:
        msquicConnectionSetShareUdpBinding(conn, enabled)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_PEER_CERTIFICATE_VALID:
        msquicConnectionSetPeerCertificateValid(conn, enabled)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_CLOSE_ASYNC:
        msquicConnectionSetCloseAsync(conn, enabled)
        return Ok[bool](true)
    return Err[bool]("msquic conn param: unsupported bool")

fn msquicConnGetParamBool(conn: MsQuicConnection, param: int32): Result[bool] =
    if param == qUIC_PARAM_CONN_DATAGRAM_RECEIVE_ENABLED:
        return Ok[bool](msquicConnectionDatagramReceiveEnabled(conn))
    if param == qUIC_PARAM_CONN_DATAGRAM_SEND_ENABLED:
        return Ok[bool](msquicConnectionDatagramSendEnabled(conn))
    if param == qUIC_PARAM_CONN_DISABLE_1RTT_ENCRYPTION:
        return Ok[bool](msquicConnectionDisable1RttEncryption(conn))
    if param == qUIC_PARAM_CONN_SHARE_UDP_BINDING:
        return Ok[bool](msquicConnectionShareUdpBinding(conn))
    if param == qUIC_PARAM_CONN_PEER_CERTIFICATE_VALID:
        return Ok[bool](msquicConnectionPeerCertificateValid(conn))
    if param == qUIC_PARAM_CONN_CLOSE_ASYNC:
        return Ok[bool](msquicConnectionCloseAsync(conn))
    return Err[bool]("msquic conn param: unsupported bool")

fn msquicConnSetParamBytes(conn: var MsQuicConnection, param: int32, data: Bytes): Result[bool] =
    if param == qUIC_PARAM_CONN_CLOSE_REASON_PHRASE:
        msquicConnectionSetCloseReasonPhrase(conn, bytesToString(data))
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_RESUMPTION_TICKET:
        msquicConnectionSetResumptionTicket(conn, data)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_CIBIR_ID:
        msquicConnectionSetCibirId(conn, data)
        return Ok[bool](true)
    if param == qUIC_PARAM_CONN_ORIG_DEST_CID:
        msquicConnectionSetOrigDestCid(conn, data)
        return Ok[bool](true)
    return Err[bool]("msquic conn param: unsupported bytes")

fn msquicConnGetParamBytes(conn: MsQuicConnection, param: int32): Result[Bytes] =
    if param == qUIC_PARAM_CONN_CLOSE_REASON_PHRASE:
        return Ok[Bytes](bytesFromString(msquicConnectionCloseReasonPhrase(conn)))
    if param == qUIC_PARAM_CONN_RESUMPTION_TICKET:
        return Ok[Bytes](msquicConnectionResumptionTicket(conn))
    if param == qUIC_PARAM_CONN_CIBIR_ID:
        return Ok[Bytes](msquicConnectionCibirId(conn))
    if param == qUIC_PARAM_CONN_ORIG_DEST_CID:
        return Ok[Bytes](msquicConnectionOrigDestCid(conn))
    if param == qUIC_PARAM_TLS_NEGOTIATED_ALPN:
        return Ok[Bytes](msquicConnectionTlsNegotiatedAlpn(conn))
    return Err[Bytes]("msquic conn param: unsupported bytes")

fn msquicConnSetParamTlsSecrets(conn: var MsQuicConnection, param: int32, secrets: QUIC_TLS_SECRETS): Result[bool] =
    if param != qUIC_PARAM_CONN_TLS_SECRETS:
        return Err[bool]("msquic conn param: unsupported tls secrets")
    if secrets.secretLength < 0 || secrets.secretLength > qUIC_TLS_SECRETS_MAX_SECRET_LEN:
        return Err[bool]("msquic conn param: invalid tls secret length")
    if secrets.secretLength > 0:
        if secrets.isSet.clientRandom && bytesLen(secrets.clientRandom) > secrets.secretLength:
            return Err[bool]("msquic conn param: client random too long")
        if secrets.isSet.clientEarlyTrafficSecret && bytesLen(secrets.clientEarlyTrafficSecret) > secrets.secretLength:
            return Err[bool]("msquic conn param: client early traffic secret too long")
        if secrets.isSet.clientHandshakeTrafficSecret && bytesLen(secrets.clientHandshakeTrafficSecret) > secrets.secretLength:
            return Err[bool]("msquic conn param: client handshake secret too long")
        if secrets.isSet.serverHandshakeTrafficSecret && bytesLen(secrets.serverHandshakeTrafficSecret) > secrets.secretLength:
            return Err[bool]("msquic conn param: server handshake secret too long")
        if secrets.isSet.clientTrafficSecret0 && bytesLen(secrets.clientTrafficSecret0) > secrets.secretLength:
            return Err[bool]("msquic conn param: client traffic secret too long")
        if secrets.isSet.serverTrafficSecret0 && bytesLen(secrets.serverTrafficSecret0) > secrets.secretLength:
            return Err[bool]("msquic conn param: server traffic secret too long")
    msquicConnectionSetTlsSecrets(conn, secrets)
    return Ok[bool](true)

fn msquicConnGetParamTlsSecrets(conn: MsQuicConnection, param: int32): Result[QUIC_TLS_SECRETS] =
    if param != qUIC_PARAM_CONN_TLS_SECRETS:
        return Err[QUIC_TLS_SECRETS]("msquic conn param: unsupported tls secrets")
    return Ok[QUIC_TLS_SECRETS](msquicConnectionTlsSecrets(conn))

fn msquicConnGetParamHandshakeInfo(conn: MsQuicConnection, param: int32): Result[QUIC_HANDSHAKE_INFO] =
    if param != qUIC_PARAM_TLS_HANDSHAKE_INFO:
        return Err[QUIC_HANDSHAKE_INFO]("msquic conn param: unsupported handshake info")
    return Ok[QUIC_HANDSHAKE_INFO](msquicConnectionTlsHandshakeInfo(conn))

fn msquicConnSetParamVersionSettings(conn: var MsQuicConnection, param: int32, settings: QUIC_VERSION_SETTINGS): Result[bool] =
    if param != qUIC_PARAM_CONN_VERSION_SETTINGS:
        return Err[bool]("msquic conn param: unsupported version settings")
    if settings.enabled.count < 0 || settings.enabled.count > maxQuicSupportedVersions:
        return Err[bool]("msquic conn param: invalid enabled version count")
    msquicConnectionSetVersionSettings(conn, settings)
    return Ok[bool](true)

fn msquicConnGetParamVersionSettings(conn: MsQuicConnection, param: int32): Result[QUIC_VERSION_SETTINGS] =
    if param != qUIC_PARAM_CONN_VERSION_SETTINGS:
        return Err[QUIC_VERSION_SETTINGS]("msquic conn param: unsupported version settings")
    return Ok[QUIC_VERSION_SETTINGS](msquicConnectionVersionSettings(conn))

fn msquicConnGetParamStatistics(conn: MsQuicConnection, param: int32): Result[QUIC_STATISTICS] =
    if param != qUIC_PARAM_CONN_STATISTICS && param != qUIC_PARAM_CONN_STATISTICS_PLAT:
        return Err[QUIC_STATISTICS]("msquic conn param: unsupported statistics")
    var stats: QUIC_STATISTICS = initQuicStatistics()
    stats.correlationId = msquicConnectionId(conn)
    stats.versionNegotiation = msquicConnectionVersionNegotiation(conn)
    stats.statelessRetry = msquicConnectionStatelessRetry(conn)
    stats.resumptionAttempted = msquicConnectionResumptionAttempted(conn)
    stats.resumptionSucceeded = msquicConnectionResumptionSucceeded(conn)
    stats.rttUs = int32(msquicConnectionSmoothedRttMs(conn) * 1000)
    stats.minRttUs = int32(msquicConnectionMinRttMs(conn) * 1000)
    stats.maxRttUs = int32(msquicConnectionMaxRttMs(conn) * 1000)
    stats.timing.start = msquicConnectionCreatedAtMs(conn) * 1000
    stats.timing.initialFlightEnd = msquicConnectionTimingInitialFlightEndUs(conn)
    stats.timing.handshakeFlightEnd = msquicConnectionTimingHandshakeFlightEndUs(conn)
    stats.handshake.clientFlight1Bytes = msquicConnectionHandshakeClientFlight1Bytes(conn)
    stats.handshake.serverFlight1Bytes = msquicConnectionHandshakeServerFlight1Bytes(conn)
    stats.handshake.clientFlight2Bytes = msquicConnectionHandshakeClientFlight2Bytes(conn)
    stats.send.pathMtu = msquicConnectionPathMtu(conn)
    stats.send.totalPackets = msquicConnectionPacketsSent(conn)
    stats.send.retransmittablePackets = msquicConnectionSendRetransmittablePackets(conn)
    stats.send.totalBytes = msquicConnectionBytesSent(conn)
    stats.send.totalStreamBytes = msquicConnectionSendTotalStreamBytes(conn)
    stats.send.suspectedLostPackets = msquicConnectionSendSuspectedLostPackets(conn)
    stats.send.spuriousLostPackets = msquicConnectionSendSpuriousLostPackets(conn)
    stats.send.congestionCount = msquicConnectionSendCongestionCount(conn)
    stats.send.persistentCongestionCount = msquicConnectionSendPersistentCongestionCount(conn)
    stats.recv.totalPackets = msquicConnectionPacketsRecv(conn)
    stats.recv.reorderedPackets = msquicConnectionRecvReorderedPackets(conn)
    stats.recv.droppedPackets = msquicConnectionRecvDroppedPackets(conn)
    stats.recv.duplicatePackets = msquicConnectionRecvDuplicatePackets(conn)
    stats.recv.totalBytes = msquicConnectionBytesRecv(conn)
    stats.recv.totalStreamBytes = msquicConnectionRecvTotalStreamBytes(conn)
    stats.recv.decryptionFailures = msquicConnectionRecvDecryptionFailures(conn)
    stats.recv.validAckFrames = msquicConnectionRecvValidAckFrames(conn)
    stats.misc.keyUpdateCount = msquicConnectionKeyUpdateCount(conn)
    return Ok[QUIC_STATISTICS](stats)

fn msquicConnGetParamStatisticsV2(conn: MsQuicConnection, param: int32): Result[QUIC_STATISTICS_V2] =
    if param != qUIC_PARAM_CONN_STATISTICS_V2 && param != qUIC_PARAM_CONN_STATISTICS_V2_PLAT:
        return Err[QUIC_STATISTICS_V2]("msquic conn param: unsupported statistics v2")
    var stats: QUIC_STATISTICS_V2 = initQuicStatisticsV2()
    stats.correlationId = msquicConnectionId(conn)
    stats.versionNegotiation = msquicConnectionVersionNegotiation(conn)
    stats.statelessRetry = msquicConnectionStatelessRetry(conn)
    stats.resumptionAttempted = msquicConnectionResumptionAttempted(conn)
    stats.resumptionSucceeded = msquicConnectionResumptionSucceeded(conn)
    stats.greaseBitNegotiated = false
    stats.ecnCapable = false
    stats.encryptionOffloaded = false
    stats.rttUs = int32(msquicConnectionSmoothedRttMs(conn) * 1000)
    stats.minRttUs = int32(msquicConnectionMinRttMs(conn) * 1000)
    stats.maxRttUs = int32(msquicConnectionMaxRttMs(conn) * 1000)
    stats.timingStart = msquicConnectionCreatedAtMs(conn) * 1000
    stats.timingInitialFlightEnd = msquicConnectionTimingInitialFlightEndUs(conn)
    stats.timingHandshakeFlightEnd = msquicConnectionTimingHandshakeFlightEndUs(conn)
    stats.handshakeClientFlight1Bytes = msquicConnectionHandshakeClientFlight1Bytes(conn)
    stats.handshakeServerFlight1Bytes = msquicConnectionHandshakeServerFlight1Bytes(conn)
    stats.handshakeClientFlight2Bytes = msquicConnectionHandshakeClientFlight2Bytes(conn)
    stats.sendPathMtu = msquicConnectionPathMtu(conn)
    stats.sendTotalPackets = msquicConnectionPacketsSent(conn)
    stats.sendRetransmittablePackets = msquicConnectionSendRetransmittablePackets(conn)
    stats.sendTotalBytes = msquicConnectionBytesSent(conn)
    stats.sendTotalStreamBytes = msquicConnectionSendTotalStreamBytes(conn)
    stats.sendSuspectedLostPackets = msquicConnectionSendSuspectedLostPackets(conn)
    stats.sendSpuriousLostPackets = msquicConnectionSendSpuriousLostPackets(conn)
    stats.sendCongestionCount = msquicConnectionSendCongestionCount(conn)
    stats.sendPersistentCongestionCount = msquicConnectionSendPersistentCongestionCount(conn)
    stats.recvTotalPackets = msquicConnectionPacketsRecv(conn)
    stats.recvReorderedPackets = msquicConnectionRecvReorderedPackets(conn)
    stats.recvDroppedPackets = msquicConnectionRecvDroppedPackets(conn)
    stats.recvDuplicatePackets = msquicConnectionRecvDuplicatePackets(conn)
    stats.recvTotalBytes = msquicConnectionBytesRecv(conn)
    stats.recvTotalStreamBytes = msquicConnectionRecvTotalStreamBytes(conn)
    stats.recvDecryptionFailures = msquicConnectionRecvDecryptionFailures(conn)
    stats.recvValidAckFrames = msquicConnectionRecvValidAckFrames(conn)
    stats.sendCongestionWindow = int32(msquicConnectionNetCongestionWindow(conn))
    stats.keyUpdateCount = msquicConnectionKeyUpdateCount(conn)
    stats.destCidUpdateCount = msquicConnectionDestCidUpdateCount(conn)
    stats.sendEcnCongestionCount = msquicConnectionSendEcnCongestionCount(conn)
    stats.handshakeHopLimitTTL = msquicConnectionHandshakeHopLimitTtl(conn)
    stats.rttVariance = int32(msquicConnectionRttVarMs(conn) * 1000)
    return Ok[QUIC_STATISTICS_V2](stats)

fn msquicConnGetParamNetworkStatistics(conn: MsQuicConnection, param: int32): Result[QUIC_NETWORK_STATISTICS] =
    if param != qUIC_PARAM_CONN_NETWORK_STATISTICS:
        return Err[QUIC_NETWORK_STATISTICS]("msquic conn param: unsupported network statistics")
    var stats: QUIC_NETWORK_STATISTICS = initQuicNetworkStatistics()
    stats.bytesInFlight = int32(msquicConnectionBytesInFlight(conn))
    stats.postedBytes = msquicConnectionNetPostedBytes(conn)
    stats.idealBytes = msquicConnectionNetIdealBytes(conn)
    stats.smoothedRttUs = msquicConnectionSmoothedRttMs(conn) * 1000
    stats.congestionWindow = int32(msquicConnectionNetCongestionWindow(conn))
    stats.bandwidth = msquicConnectionNetBandwidth(conn)
    stats.bandwidthOut = msquicConnectionNetBandwidthOut(conn)
    stats.bandwidthIn = msquicConnectionNetBandwidthIn(conn)
    stats.deliveryRateOut = msquicConnectionNetDeliveryRateOut(conn)
    stats.deliveryRateIn = msquicConnectionNetDeliveryRateIn(conn)
    return Ok[QUIC_NETWORK_STATISTICS](stats)
