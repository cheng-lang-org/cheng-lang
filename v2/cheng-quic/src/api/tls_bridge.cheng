# MsQuic TLS bridge(minimal).

import std/result
import std/strings
type
    MsQuicApiTlsConfig =
        alpn: str
        serverName: str
        insecureSkipVerify: bool

fn initMsQuicApiTlsConfig(): MsQuicApiTlsConfig =
    MsQuicApiTlsConfig(alpn: "h3", serverName: "", insecureSkipVerify: false)

fn msquicApiTlsSetAlpn(cfg: var MsQuicApiTlsConfig, alpn: str): Result[bool] =
    if len(alpn) <= 0:
        return Err[bool]("msquic tls: empty alpn")
    cfg.alpn = alpn
    return Ok[bool](true)

fn msquicApiTlsSetServerName(cfg: var MsQuicApiTlsConfig, serverName: str) =
    cfg.serverName = serverName

fn msquicApiTlsSetInsecure(cfg: var MsQuicApiTlsConfig, enabled: bool) =
    cfg.insecureSkipVerify = enabled
