# MsQuic configuration parameter helpers(minimal).

import std/result
import std/rawbytes
import cheng/quic/inc/msquic_params
import cheng/quic/inc/msquic_types
import cheng/quic/inc/msquic_settings
type
    MsQuicConfigurationState =
        settings: QUIC_SETTINGS
        ticketKeys: QUIC_TICKET_KEY_CONFIGS
        versionSettings: QUIC_VERSION_SETTINGS
        schannelAttribute: QUIC_SCHANNEL_CREDENTIAL_ATTRIBUTE_W

fn initMsQuicConfigurationState(): MsQuicConfigurationState =
    MsQuicConfigurationState(
        settings: initQuicSettings(),
        ticketKeys: initQuicTicketKeyConfigs(),
        versionSettings: initQuicVersionSettings(),
        schannelAttribute: initQuicSchannelCredentialAttribute()
    )

fn msquicConfigurationSetParamSettings(state: var MsQuicConfigurationState, param: int32, settings: QUIC_SETTINGS): Result[bool] =
    if param != qUIC_PARAM_CONFIGURATION_SETTINGS:
        return Err[bool]("msquic config param: unsupported settings")
    state.settings = settings
    return Ok[bool](true)

fn msquicConfigurationGetParamSettings(state: MsQuicConfigurationState, param: int32): Result[QUIC_SETTINGS] =
    if param != qUIC_PARAM_CONFIGURATION_SETTINGS:
        return Err[QUIC_SETTINGS]("msquic config param: unsupported settings")
    return Ok[QUIC_SETTINGS](state.settings)

fn msquicConfigurationSetParamTicketKeys(state: var MsQuicConfigurationState, param: int32, keys: QUIC_TICKET_KEY_CONFIGS): Result[bool] =
    if param != qUIC_PARAM_CONFIGURATION_TICKET_KEYS:
        return Err[bool]("msquic config param: unsupported ticket keys")
    if keys.count < 0 || keys.count > maxQuicTicketKeys:
        return Err[bool]("msquic config param: invalid ticket key count")
    for i in 0..<keys.count:
        let key: QUIC_TICKET_KEY_CONFIG = keys.keys[i]
        if key.secretLength != bytesLen(key.secret):
            return Err[bool]("msquic config param: ticket key secret length mismatch")
    state.ticketKeys = keys
    return Ok[bool](true)

fn msquicConfigurationGetParamTicketKeys(state: MsQuicConfigurationState, param: int32): Result[QUIC_TICKET_KEY_CONFIGS] =
    if param != qUIC_PARAM_CONFIGURATION_TICKET_KEYS:
        return Err[QUIC_TICKET_KEY_CONFIGS]("msquic config param: unsupported ticket keys")
    return Ok[QUIC_TICKET_KEY_CONFIGS](state.ticketKeys)

fn msquicConfigurationSetParamVersionSettings(state: var MsQuicConfigurationState, param: int32, settings: QUIC_VERSION_SETTINGS): Result[bool] =
    if param != qUIC_PARAM_CONFIGURATION_VERSION_SETTINGS:
        return Err[bool]("msquic config param: unsupported version settings")
    if settings.enabled.count < 0 || settings.enabled.count > maxQuicSupportedVersions:
        return Err[bool]("msquic config param: invalid enabled version count")
    state.versionSettings = settings
    return Ok[bool](true)

fn msquicConfigurationGetParamVersionSettings(state: MsQuicConfigurationState, param: int32): Result[QUIC_VERSION_SETTINGS] =
    if param != qUIC_PARAM_CONFIGURATION_VERSION_SETTINGS:
        return Err[QUIC_VERSION_SETTINGS]("msquic config param: unsupported version settings")
    return Ok[QUIC_VERSION_SETTINGS](state.versionSettings)

fn msquicConfigurationSetParamSchannelAttribute(state: var MsQuicConfigurationState, param: int32, attr: QUIC_SCHANNEL_CREDENTIAL_ATTRIBUTE_W): Result[bool] =
    if param != qUIC_PARAM_CONFIGURATION_SCHANNEL_CREDENTIAL_ATTRIBUTE_W:
        return Err[bool]("msquic config param: unsupported schannel attribute")
    state.schannelAttribute = attr
    return Ok[bool](true)

fn msquicConfigurationGetParamSchannelAttribute(state: MsQuicConfigurationState, param: int32): Result[QUIC_SCHANNEL_CREDENTIAL_ATTRIBUTE_W] =
    if param != qUIC_PARAM_CONFIGURATION_SCHANNEL_CREDENTIAL_ATTRIBUTE_W:
        return Err[QUIC_SCHANNEL_CREDENTIAL_ATTRIBUTE_W]("msquic config param: unsupported schannel attribute")
    return Ok[QUIC_SCHANNEL_CREDENTIAL_ATTRIBUTE_W](state.schannelAttribute)
