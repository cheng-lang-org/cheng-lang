# MsQuic diagnostics model(minimal).

import std/result
import std/strings
import std/times
import cheng/quic/api/common
const
    maxMsQuicDiagConnections = 64

type
    MsQuicConnDiagnostics =
        connId: int64
        bytesSent: int64
        bytesRecv: int64
        packetsSent: int64
        packetsRecv: int64
        streamsOpen: int32
        lastEventMs: int64
        active: bool

    MsQuicDiagnostics =
        count: int32
        conns: MsQuicConnDiagnostics[maxMsQuicDiagConnections]
        errors: int32
        lastError: str

fn initMsQuicConnDiagnostics(connId: int64): MsQuicConnDiagnostics =
    MsQuicConnDiagnostics(
        connId: connId,
        bytesSent: 0,
        bytesRecv: 0,
        packetsSent: 0,
        packetsRecv: 0,
        streamsOpen: 0,
        lastEventMs: epochTimeNs() / 1000000,
        active: true
    )

fn initMsQuicDiagnostics(): MsQuicDiagnostics =
    MsQuicDiagnostics(count: 0, errors: 0, lastError: "")

fn msquicDiagFind(diag: var MsQuicDiagnostics, connId: int64): int32 =
    for i in 0..<diag.count:
        if diag.conns[i].active && diag.conns[i].connId == connId:
            return i
    return -1

fn msquicDiagEnsure(diag: var MsQuicDiagnostics, connId: int64): Result[int32] =
    let idx: int32 = msquicDiagFind(diag, connId)
    if idx >= 0:
        return Ok[int32](idx)
    if diag.count >= maxMsQuicDiagConnections:
        return Err[int32]("msquic diag: connection list full")
    diag.conns[diag.count] = initMsQuicConnDiagnostics(connId)
    diag.count = diag.count + 1
    return Ok[int32](diag.count - 1)

fn msquicDiagConnOpen(diag: var MsQuicDiagnostics, connId: int64): Result[bool] =
    let idxRes: Result[int32] = msquicDiagEnsure(diag, connId)
    if IsErr(idxRes):
        return Err[bool](Error(idxRes))
    let idx: int32 = Value(idxRes)
    diag.conns[idx].active = true
    diag.conns[idx].lastEventMs = epochTimeNs() / 1000000
    return Ok[bool](true)

fn msquicDiagConnClose(diag: var MsQuicDiagnostics, connId: int64): Result[bool] =
    let idx: int32 = msquicDiagFind(diag, connId)
    if idx < 0:
        return Err[bool]("msquic diag: connection ! found")
    diag.conns[idx].active = false
    diag.conns[idx].lastEventMs = epochTimeNs() / 1000000
    return Ok[bool](true)

fn msquicDiagStreamOpen(diag: var MsQuicDiagnostics, connId: int64): Result[bool] =
    let idxRes: Result[int32] = msquicDiagEnsure(diag, connId)
    if IsErr(idxRes):
        return Err[bool](Error(idxRes))
    let idx: int32 = Value(idxRes)
    diag.conns[idx].streamsOpen = diag.conns[idx].streamsOpen + 1
    diag.conns[idx].lastEventMs = epochTimeNs() / 1000000
    return Ok[bool](true)

fn msquicDiagStreamClose(diag: var MsQuicDiagnostics, connId: int64): Result[bool] =
    let idx: int32 = msquicDiagFind(diag, connId)
    if idx < 0:
        return Err[bool]("msquic diag: connection ! found")
    if diag.conns[idx].streamsOpen > 0:
        diag.conns[idx].streamsOpen = diag.conns[idx].streamsOpen - 1
    diag.conns[idx].lastEventMs = epochTimeNs() / 1000000
    return Ok[bool](true)

fn msquicDiagRecordSend(diag: var MsQuicDiagnostics, connId: int64, bytes: int64) =
    let idxRes: Result[int32] = msquicDiagEnsure(diag, connId)
    if IsErr(idxRes):
        return
    let idx: int32 = Value(idxRes)
    if bytes > 0:
        diag.conns[idx].bytesSent = diag.conns[idx].bytesSent + bytes
    diag.conns[idx].packetsSent = diag.conns[idx].packetsSent + 1
    diag.conns[idx].lastEventMs = epochTimeNs() / 1000000

fn msquicDiagRecordRecv(diag: var MsQuicDiagnostics, connId: int64, bytes: int64) =
    let idxRes: Result[int32] = msquicDiagEnsure(diag, connId)
    if IsErr(idxRes):
        return
    let idx: int32 = Value(idxRes)
    if bytes > 0:
        diag.conns[idx].bytesRecv = diag.conns[idx].bytesRecv + bytes
    diag.conns[idx].packetsRecv = diag.conns[idx].packetsRecv + 1
    diag.conns[idx].lastEventMs = epochTimeNs() / 1000000

fn msquicDiagError(diag: var MsQuicDiagnostics, message: str) =
    diag.errors = diag.errors + 1
    diag.lastError = message

fn msquicDiagDump(diag: MsQuicDiagnostics): str =
    var out: str = "msquic diagnostics"
    out = out + " conns="
    out = out + msquicIntToString(diag.count)
    out = out + " errors="
    out = out + msquicIntToString(diag.errors)
    if len(diag.lastError) > 0:
        out = out + " lastError="
        out = out + diag.lastError
    return out
