# MsQuic core packet builder(pure Cheng, in-process).

import std/result
import cheng/quic/core/packet_model
type
    MsQuicPacketBuilder =
        maxSize: int32
        packet: MsQuicPacket

fn initMsQuicPacketBuilder(packetNumber: int64, maxSize: int32): MsQuicPacketBuilder =
    let size: int32 = if maxSize <= 0: 1200 else: maxSize
    MsQuicPacketBuilder(maxSize: size, packet: initMsQuicPacket(packetNumber))

fn msquicPacketBuilderAddFrame(b: var MsQuicPacketBuilder, frame: MsQuicFrame): Result[bool] =
    let sizeNow: int32 = msquicPacketSize(b.packet)
    let nextSize: int32 = sizeNow + msquicFrameSize(frame)
    if nextSize > b.maxSize:
        return Err[bool]("msquic packet: size exceeded")
    return msquicPacketAddFrame(b.packet, frame)

fn msquicPacketBuilderFinalize(b: MsQuicPacketBuilder): MsQuicPacket =
    return b.packet
