# QUIC variable-length integers(RFC 9000).

import std/result
import std/rawbytes
import std/buffer
const
    quicVarIntMax: int64 = 4611686018427387903

type
    QuicVarIntDecoded =
        value: int64
        next: int32

fn quicVarIntEncodedLen(value: int64): int32 =
    if value < 0:
        return 0
    if value <= 63:
        return 1
    if value <= 16383:
        return 2
    if value <= 1073741823:
        return 4
    if value <= quicVarIntMax:
        return 8
    return 0

fn quicVarIntEncode(value: int64): Result[Bytes] =
    let size: int32 = quicVarIntEncodedLen(value)
    if size <= 0:
        return Err[Bytes]("quic varint: value out of range")
    let out: Bytes = bytesAlloc(size)
    if size == 1:
        bytesSet(out, 0, int32(value))
        return Ok[Bytes](out)
    if size == 2:
        bytesSet(out, 0, 0x40 | int32((value >> 8) & 0x3f))
        bytesSet(out, 1, int32(value & 0xff))
        return Ok[Bytes](out)
    if size == 4:
        bytesSet(out, 0, 0x80 | int32((value >> 24) & 0x3f))
        bytesSet(out, 1, int32((value >> 16) & 0xff))
        bytesSet(out, 2, int32((value >> 8) & 0xff))
        bytesSet(out, 3, int32(value & 0xff))
        return Ok[Bytes](out)
    bytesSet(out, 0, 0xc0 | int32((value >> 56) & 0x3f))
    bytesSet(out, 1, int32((value >> 48) & 0xff))
    bytesSet(out, 2, int32((value >> 40) & 0xff))
    bytesSet(out, 3, int32((value >> 32) & 0xff))
    bytesSet(out, 4, int32((value >> 24) & 0xff))
    bytesSet(out, 5, int32((value >> 16) & 0xff))
    bytesSet(out, 6, int32((value >> 8) & 0xff))
    bytesSet(out, 7, int32(value & 0xff))
    return Ok[Bytes](out)

fn quicVarIntAppend(buf: var ByteBuffer, value: int64): Result[bool] =
    let encRes: Result[Bytes] = quicVarIntEncode(value)
    if IsErr(encRes):
        return Err[bool](Error(encRes))
    appendBytes(buf, Value(encRes))
    return Ok[bool](true)

fn quicVarIntDecode(data: Bytes, offset: int32): Result[QuicVarIntDecoded] =
    if offset < 0:
        return Err[QuicVarIntDecoded]("quic varint: negative offset")
    if offset >= bytesLen(data):
        return Err[QuicVarIntDecoded]("quic varint: truncated input")
    let first: int32 = bytesGet(data, offset)
    let tag: int32 = first >> 6
    var size: int32 = 8
    if tag == 0:
        size = 1
    elif tag == 1:
        size = 2
    elif tag == 2:
        size = 4
    if offset + size > bytesLen(data):
        return Err[QuicVarIntDecoded]("quic varint: truncated input")
    var value: int64 = int64(first & 0x3f)
    for i in 1..<size:
        value = (value << 8) | int64(bytesGet(data, offset + i))
    return Ok[QuicVarIntDecoded](QuicVarIntDecoded(value: value, next: offset + size))
