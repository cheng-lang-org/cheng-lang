# MsQuic core stream send implementation(pure Cheng, in-process).

import std/result
import std/rawbytes
import cheng/quic/core/connection_impl
import cheng/quic/core/frame_model
type
    MsQuicStreamSender =
        streamId: int64
        offset: int64
        closed: bool
        queuedBytes: int64
        maxData: int64
        finQueued: bool
        finOffset: int64

fn initMsQuicStreamSender(streamId: int64): MsQuicStreamSender =
    MsQuicStreamSender(
        streamId: streamId,
        offset: 0,
        closed: false,
        queuedBytes: 0,
        maxData: -1,
        finQueued: false,
        finOffset: -1
    )

fn msquicStreamSenderSend(sender: var MsQuicStreamSender, conn: var MsQuicConnImpl, data: Bytes): Result[bool] =
    if sender.closed:
        return Err[bool]("msquic stream: sender closed")
    let count: int64 = int64(bytesLen(data))
    if count <= 0:
        return Ok[bool](false)
    if sender.maxData >= 0 && sender.offset + count > sender.maxData:
        return Err[bool]("msquic stream: send window exceeded")
    let res: Result[bool] = msquicConnImplQueueData(conn, sender.streamId, sender.offset, data)
    if IsErr(res):
        return Err[bool](ErrorText(res))
    sender.offset = sender.offset + count
    sender.queuedBytes = sender.queuedBytes + count
    return Ok[bool](true)

fn msquicStreamSenderQueueFin(sender: var MsQuicStreamSender, conn: var MsQuicConnImpl): Result[bool] =
    if sender.closed:
        return Err[bool]("msquic stream: sender closed")
    if sender.finQueued:
        return Ok[bool](false)
    let frame: MsQuicFrame = msquicFrameData(sender.streamId, sender.offset, emptyBytes())
    frame.value = 1
    let res: Result[bool] = msquicConnImplQueueFrame(conn, frame)
    if IsErr(res):
        return Err[bool](ErrorText(res))
    sender.finQueued = true
    sender.finOffset = sender.offset
    sender.closed = true
    return Ok[bool](true)

fn msquicStreamSenderClose(sender: var MsQuicStreamSender) =
    sender.closed = true

fn msquicStreamSenderReset(sender: var MsQuicStreamSender, conn: var MsQuicConnImpl, errCode: int64): Result[bool] =
    let frame: MsQuicFrame = msquicFrameReset(sender.streamId, errCode)
    let res: Result[bool] = msquicConnImplQueueFrame(conn, frame)
    if IsErr(res):
        return Err[bool](ErrorText(res))
    sender.closed = true
    return Ok[bool](true)

fn msquicStreamSenderStopSending(sender: var MsQuicStreamSender, conn: var MsQuicConnImpl, errCode: int64): Result[bool] =
    let frame: MsQuicFrame = msquicFrameStopSending(sender.streamId, errCode)
    let res: Result[bool] = msquicConnImplQueueFrame(conn, frame)
    if IsErr(res):
        return Err[bool](ErrorText(res))
    return Ok[bool](true)
