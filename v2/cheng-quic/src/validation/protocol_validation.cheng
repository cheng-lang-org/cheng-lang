# MsQuic protocol validation helpers(packet/frame, minimal).

import std/result
import std/rawbytes
import cheng/quic/core/frame_model
import cheng/quic/core/packet_model
fn msquicFrameRequiresStream(kind: MsQuicFrameType): bool =
    if kind == FrameData || kind == FrameMaxStreamData || kind == FrameReset || kind == FrameStopSending:
        return true
    return false

fn msquicFrameAllowsData(kind: MsQuicFrameType): bool =
    if kind == FrameData || kind == FrameAck:
        return true
    return false

fn msquicFrameUsesOffset(kind: MsQuicFrameType): bool =
    if kind == FrameData || kind == FrameAck:
        return true
    return false

fn msquicFrameUsesValue(kind: MsQuicFrameType): bool =
    if kind == FrameAck || kind == FrameMaxData || kind == FrameMaxStreamData || kind == FrameReset || kind == FrameStopSending:
        return true
    return false

fn msquicFrameAckEliciting(kind: MsQuicFrameType): bool =
    if kind == FrameAck || kind == FramePadding || kind == FrameConnectionClose || kind == FrameConnectionCloseApp:
        return false
    return true

fn msquicValidateFrame(frame: MsQuicFrame): Result[bool] =
    if frame.streamId < 0:
        return Err[bool]("msquic validate: negative stream id")
    if frame.offset < 0:
        return Err[bool]("msquic validate: negative offset")
    if frame.value < 0:
        return Err[bool]("msquic validate: negative value")
    let needsStream: bool = msquicFrameRequiresStream(frame.kind)
    if ! needsStream && frame.streamId != 0:
        return Err[bool]("msquic validate: non-stream frame has stream id")
    if ! msquicFrameUsesOffset(frame.kind) && frame.offset != 0:
        return Err[bool]("msquic validate: unexpected offset")
    if ! msquicFrameUsesValue(frame.kind) && frame.value != 0:
        return Err[bool]("msquic validate: unexpected value")
    if ! msquicFrameAllowsData(frame.kind) && bytesLen(frame.data) > 0:
        return Err[bool]("msquic validate: unexpected frame data")
    return Ok[bool](true)

fn msquicValidatePacket(p: MsQuicPacket): Result[bool] =
    if p.number < 0:
        return Err[bool]("msquic validate: negative packet number")
    if p.framesCount < 0:
        return Err[bool]("msquic validate: negative frame count")
    if p.framesCount > msQuicMaxFramesPerPacket:
        return Err[bool]("msquic validate: frame count overflow")
    var hasAckEliciting: bool = false
    for i in 0..<p.framesCount:
        let frame: MsQuicFrame = p.frames[i]
        let frameRes: Result[bool] = msquicValidateFrame(frame)
        if IsErr(frameRes):
            return Err[bool](ErrorText(frameRes))
        if msquicFrameAckEliciting(frame.kind):
            hasAckEliciting = true
    if hasAckEliciting != p.ackEliciting:
        return Err[bool]("msquic validate: ack eliciting mismatch")
    return Ok[bool](true)

fn msquicValidatePacketBytes(data: Bytes): Result[bool] =
    let pktRes: Result[MsQuicPacket] = msquicPacketDecode(data)
    if IsErr(pktRes):
        return Err[bool](ErrorText(pktRes))
    return msquicValidatePacket(Value(pktRes))
