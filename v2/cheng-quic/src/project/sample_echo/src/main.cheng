# MsQuic sample echo(minimal, in-process).

import std/result
import std/rawbytes
import cheng/quic/core/frame_model
import cheng/quic/core/packet_model
import cheng/quic/validation/protocol_validation
fn runSampleEcho(): Result[bool] =
    var pkt: MsQuicPacket = initMsQuicPacket(1)
    let payload: Bytes = bytesFromString("echo")
    let frame: MsQuicFrame = msquicFrameData(0, 0, payload)
    let addRes: Result[bool] = msquicPacketAddFrame(pkt, frame)
    if IsErr(addRes):
        return Err[bool](Error(addRes))
    let validRes: Result[bool] = msquicValidatePacket(pkt)
    if IsErr(validRes):
        return Err[bool](Error(validRes))
    let encoded: Bytes = msquicPacketEncode(pkt)
    let decodedRes: Result[MsQuicPacket] = msquicPacketDecode(encoded)
    if IsErr(decodedRes):
        return Err[bool](Error(decodedRes))
    let decoded: MsQuicPacket = Value(decodedRes)
    if decoded.framesCount != 1:
        return Err[bool]("sample echo: frame count mismatch")
    return Ok[bool](true)
