# MsQuic platform matrix(minimal).

import std/strings
import cheng/quic/platform/common
const
    maxMsQuicPlatforms = 8

type
    MsQuicPlatformEntry =
        kind: MsQuicPlatformKind
        name: str
        supportsDatapath: bool
        supportsHighPerf: bool

    MsQuicPlatformMatrix =
        count: int32
        # NOTE: stage1 backend has known issues with `T[N]` when `T` is a composite type.
        # Use parallel primitive arrays for stable lowering.
        kinds: MsQuicPlatformKind[maxMsQuicPlatforms]
        names: str[maxMsQuicPlatforms]
        supportsDatapath: bool[maxMsQuicPlatforms]
        supportsHighPerf: bool[maxMsQuicPlatforms]

fn initMsQuicPlatformMatrix(): MsQuicPlatformMatrix =
    var matrix: MsQuicPlatformMatrix = MsQuicPlatformMatrix(count: 0)
    matrix.kinds[matrix.count] = MsQuicPlatformMacos
    matrix.names[matrix.count] = "macos"
    matrix.supportsDatapath[matrix.count] = true
    matrix.supportsHighPerf[matrix.count] = false
    matrix.count = matrix.count + 1
    matrix.kinds[matrix.count] = MsQuicPlatformLinux
    matrix.names[matrix.count] = "linux"
    matrix.supportsDatapath[matrix.count] = true
    matrix.supportsHighPerf[matrix.count] = true
    matrix.count = matrix.count + 1
    matrix.kinds[matrix.count] = MsQuicPlatformWindows
    matrix.names[matrix.count] = "windows"
    matrix.supportsDatapath[matrix.count] = true
    matrix.supportsHighPerf[matrix.count] = true
    matrix.count = matrix.count + 1
    return matrix

fn msquicPlatformMatrixHas(matrix: MsQuicPlatformMatrix, kind: MsQuicPlatformKind): bool =
    for i in 0..<matrix.count:
        if matrix.kinds[i] == kind:
            return true
    return false

fn msquicPlatformMatrixDescribe(matrix: MsQuicPlatformMatrix, kind: MsQuicPlatformKind): str =
    for i in 0..<matrix.count:
        if matrix.kinds[i] == kind:
            var out: str = matrix.names[i]
            if matrix.supportsHighPerf[i]:
                out = out + " highperf"
            else:
                out = out + " basic"
            return out
    return ""

fn msquicPlatformMatrixSupportsHighPerf(matrix: MsQuicPlatformMatrix, kind: MsQuicPlatformKind): bool =
    for i in 0..<matrix.count:
        if matrix.kinds[i] == kind:
            return matrix.supportsHighPerf[i]
    return false
