# MsQuic address bridge helpers(minimal).

import std/result
import std/rawbytes
import cheng/quic/multiaddress
import cheng/quic/inc/msquic_types
fn msquicAddrFromMultiAddress(addr: MultiAddress): QUIC_ADDR =
    return initQuicAddr(addr.data)

fn msquicAddrToMultiAddress(addr: QUIC_ADDR): Result[MultiAddress] =
    if bytesLen(addr.raw) <= 0:
        return Err[MultiAddress]("msquic addr: empty")
    return parseMultiAddressBytes(addr.raw)

fn msquicNewConnectionInfoFromAddrs(localAddr: MultiAddress, remoteAddr: MultiAddress): QUIC_NEW_CONNECTION_INFO =
    var info: QUIC_NEW_CONNECTION_INFO = initQuicNewConnectionInfo()
    info.localAddress = msquicAddrFromMultiAddress(localAddr)
    info.remoteAddress = msquicAddrFromMultiAddress(remoteAddr)
    return info
