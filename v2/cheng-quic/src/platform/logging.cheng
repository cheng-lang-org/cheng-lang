# MsQuic platform logging helpers(port scaffold).

type
    MsQuicLogLevel = enum
        MsQuicLogError = 0
        MsQuicLogWarn = 1
        MsQuicLogInfo = 2
        MsQuicLogVerbose = 3

var msquicLogLevel: MsQuicLogLevel = MsQuicLogWarn

fn msquicSetLogLevel(level: MsQuicLogLevel) =
    msquicLogLevel = level

fn msquicLogEnabled(level: MsQuicLogLevel): bool =
    return level <= msquicLogLevel

fn msquicLog(level: MsQuicLogLevel, message: str) =
    level
    message
