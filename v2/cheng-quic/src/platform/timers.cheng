# MsQuic platform timer helpers(port scaffold).

type
    MsQuicTimer =
        deadlineMs: int64
        active: bool

fn msquicTimerInit(): MsQuicTimer =
    return MsQuicTimer(deadlineMs: 0, active: false)

fn msquicTimerArm(timer: var MsQuicTimer, deadlineMs: int64) =
    timer.deadlineMs = deadlineMs
    timer.active = true

fn msquicTimerDisarm(timer: var MsQuicTimer) =
    timer.deadlineMs = 0
    timer.active = false

fn msquicTimerExpired(timer: MsQuicTimer, nowMs: int64): bool =
    if ! timer.active:
        return false
    return nowMs >= timer.deadlineMs
