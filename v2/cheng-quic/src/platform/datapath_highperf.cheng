# MsQuic high-performance datapath helpers(minimal).

import std/result
import std/strings
import cheng/quic/msquicruntime
import cheng/quic/platform/common
type
    MsQuicHighPerfConfig =
        enabled: bool
        batchSize: int32
        ringSize: int32

fn initMsQuicHighPerfConfig(): MsQuicHighPerfConfig =
    MsQuicHighPerfConfig(enabled: false, batchSize: 32, ringSize: 256)

fn msquicHighPerfEnable(cfg: var MsQuicHighPerfConfig, enabled: bool) =
    cfg.enabled = enabled

fn msquicHighPerfSetBatch(cfg: var MsQuicHighPerfConfig, batchSize: int32): Result[bool] =
    if batchSize <= 0:
        return Err[bool]("msquic highperf: batch size must be positive")
    cfg.batchSize = batchSize
    return Ok[bool](true)

fn msquicHighPerfSetRing(cfg: var MsQuicHighPerfConfig, ringSize: int32): Result[bool] =
    if ringSize <= 0:
        return Err[bool]("msquic highperf: ring size must be positive")
    cfg.ringSize = ringSize
    return Ok[bool](true)

fn msquicHighPerfSummary(cfg: MsQuicHighPerfConfig): str =
    var out: str = if cfg.enabled: "highperf on" else: "highperf off"
    out = out + " batch="
    out = out + msquicPlatformIntToString(cfg.batchSize)
    out = out + " ring="
    out = out + msquicPlatformIntToString(cfg.ringSize)
    return out

fn msquicHighPerfValidate(platform: MsQuicPlatformKind, settings: MsQuicSettings): Result[bool] =
    if ! (settings.xdpEnabled || settings.qtipEnabled || settings.reservedRioEnabled):
        return Ok[bool](true)
    if platform == MsQuicPlatformUnknown:
        return Err[bool]("msquic highperf: unknown platform")
    if platform == MsQuicPlatformMacos:
        return Err[bool]("msquic highperf: unsupported on macos")
    return Ok[bool](true)
