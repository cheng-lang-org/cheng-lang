# MsQuic platform random helpers(port scaffold).

import std/result
import std/rawbytes
import std/crypto/rand
fn msquicPlatformSeedRandom(seed: Bytes): bool =
    return setRandomSeed(seed)

fn msquicPlatformSeedRandomSystem(): Result[bool] =
    return randomSeedFromSystem()

fn msquicPlatformRandomBytes(length: int32): Result[Bytes] =
    return randomBytes(length)
