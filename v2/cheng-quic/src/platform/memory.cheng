# MsQuic platform memory helpers (no-pointer byte helpers).

import std/rawbytes

fn msquicAlloc(size: int32): Bytes =
    if size <= 0:
        return emptyBytes()
    return bytesAlloc(size)

fn msquicFree(p: var Bytes) =
    p = emptyBytes()

fn msquicRealloc(p: Bytes, size: int32): Bytes =
    if size <= 0:
        return emptyBytes()
    let out: Bytes = bytesAlloc(size)
    let copyLen: int32 = if bytesLen(p) < size: bytesLen(p) else: size
    for i in 0..<copyLen:
        bytesSet(out, i, bytesGet(p, i))
    return out

fn msquicMemcpy(dest: var Bytes, src: Bytes, size: int32) =
    if size <= 0:
        return
    if bytesLen(dest) < size:
        dest = msquicRealloc(dest, size)
    let copyLen: int32 = if bytesLen(src) < size: bytesLen(src) else: size
    for i in 0..<copyLen:
        bytesSet(dest, i, bytesGet(src, i))

fn msquicMemset(dest: var Bytes, val: int32, size: int32) =
    if size <= 0:
        return
    if bytesLen(dest) < size:
        dest = msquicRealloc(dest, size)
    for i in 0..<size:
        bytesSet(dest, i, val & 0xff)
