# MsQuic platform release validation(minimal).

import std/result
import std/strings
import cheng/quic/platform/platform_matrix
import cheng/quic/api/settings_model
fn msquicReleaseValidatePlatform(kind: MsQuicPlatformKind): Result[bool] =
    let matrix: MsQuicPlatformMatrix = initMsQuicPlatformMatrix()
    if ! msquicPlatformMatrixHas(matrix, kind):
        return Err[bool]("msquic release: unsupported platform")
    return Ok[bool](true)

fn msquicReleaseValidateSettings(settings: MsQuicSettings): Result[bool] =
    return msquicSettingsValidate(settings)

fn msquicReleaseValidationSummary(kind: MsQuicPlatformKind, settings: MsQuicSettings): str =
    var out: str = "msquic release"
    out = out + " platform="
    out = out + msquicPlatformKindToString(kind)
    out = out + " "
    out = out + msquicSettingsSummary(settings)
    return out
