# MsQuic platform lock helpers(port scaffold).

type
    MsQuicLock =
        locked: bool

fn msquicLockInit(): MsQuicLock =
    return MsQuicLock(locked: false)

fn msquicLockAcquire(lock: var MsQuicLock) =
    lock.locked = true

fn msquicLockRelease(lock: var MsQuicLock) =
    lock.locked = false

fn msquicLockIsLocked(lock: MsQuicLock): bool =
    return lock.locked
