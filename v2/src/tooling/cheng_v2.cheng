import std/cmdline as cmdline
import std/os
import compiler/driver/surface_contract as surface
import runtime/compiler_core_runtime_v2 as crun
import tooling/cheng_tooling_v2 as tooling

fn printLine(text: str) =
    os.writeLine(os.get_stdout(), text)

fn printUsage() =
    let lines = crun.compilerCoreRuntimeUsageLines()
    for i in 0..<lines.len:
        printLine(lines[i])

fn printStatus() =
    printLine("cheng_v2: tooling entry")
    printLine("track=" + crun.compilerCoreRuntimeContract().entryTrack)
    printLine("execution=" + crun.compilerCoreRuntimeContract().entryExecution)
    printLine("tooling_forwarded=1")
    printLine("tooling_entry=" + crun.compilerCoreRuntimeContract().toolingEntry)
    printLine("parallel=" + if surface.v2SurfaceContract().functionParallelism: "function_task" else: "disabled")
    printLine("soa_index_only=" + if surface.v2HasIndexOnlySoa(): "1" else: "0")
    printLine("infra_surface=1")

fn main(): int32 =
    if cmdline.paramCount() <= 0:
        printUsage()
        return 0
    let cmd = cmdline.paramStr(1)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        printUsage()
        return 0
    if cmd == "status":
        printStatus()
        return 0
    return tooling.main()
