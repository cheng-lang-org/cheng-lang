fn compilerCoreZrpcAbsolutePath(rootPath: str, sourcePath: str): str =
    return joinPath2(absolutePath(rootPath), sourcePath)

fn compilerCoreNormalizeProbeSourcePaths(program: var ccore.CompilerCoreProgram,
                                         normalizedSourcePath: str) =
    for i in 0..<program.topLevelSourcePaths.len:
        program.topLevelSourcePaths[i] = normalizedSourcePath

fn compilerCoreProbeFirstNoPointerViolation(rootPath: str, sourcePath: str): str =
    let absoluteSourcePath = compilerCoreZrpcAbsolutePath(rootPath, sourcePath)
    var parsed = parser.parseV2SourceFileStrict(absoluteSourcePath)
    if parsed.compilerCoreProgram.topLevelKinds.len <= 0:
        system.panic("zrpc: probe is not compiler_core source " + sourcePath)
    compilerCoreNormalizeProbeSourcePaths(parsed.compilerCoreProgram, sourcePath)
    return cffacts.compilerCoreFirstNoPointerViolation(parsed.compilerCoreProgram)

fn compilerCoreCycleFixtureEntryPath(rootPath: str): str =
    return joinPath2(absolutePath(rootPath),
                     "v2/tests/contracts/compiler_core_cycle_surface_fixture/src/cycle/main.cheng")

fn compilerCoreNoPointerClosureRoots(): str[] =
    var out: str[] = []
    add(out, "v2/src")
    add(out, "v2/examples")
    add(out, "v2/cheng-quic/src")
    add(out, "v2/cheng-quic/tests")
    return out

fn parsedHasSurfaceKind(parsed: parser.ParsedV2Source, kind: str): bool =
    for i in 0..<parsed.surfaceKinds.len:
        if parsed.surfaceKinds[i] == kind:
            return true
    return false

fn firstNoPointerViolationForParsedSource(sourcePath: str,
                                          sourceText: str,
                                          parsed: var parser.ParsedV2Source): str =
    if parsedHasSurfaceKind(parsed, "compiler_core"):
        compilerCoreNormalizeProbeSourcePaths(parsed.compilerCoreProgram, sourcePath)
    return npfacts.firstV2NoPointerViolation(sourcePath, sourceText, parsed)

fn v2ProbeFirstNoPointerViolation(rootPath: str, sourcePath: str): str =
    let absoluteSourcePath = compilerCoreZrpcAbsolutePath(rootPath, sourcePath)
    let sourceText = os.readFile(absoluteSourcePath)
    var parsed = parser.parseV2SourceTextStrict(absoluteSourcePath, sourceText)
    return firstNoPointerViolationForParsedSource(sourcePath, sourceText, parsed)

fn sortTextList(values: var str[]) =
    var i: int32 = 1
    while i < values.len:
        var j: int32 = i
        while j > 0 && cmp(values[j], values[j - 1]) < 0:
            let swap = values[j - 1]
            values[j - 1] = values[j]
            values[j] = swap
            j = j - 1
        i = i + 1

fn compilerCoreNoPointerClosureFiles(rootPath: str): str[] =
    let repoRoot = absolutePath(rootPath)
    let roots = compilerCoreNoPointerClosureRoots()
    var out: str[] = []
    for i in 0..<roots.len:
        let absRoot = joinPath2(repoRoot, roots[i])
        if !os.dirExists(absRoot):
            system.panic("verify-compiler-core-no-pointer-closure: missing root " + roots[i])
        let files = os.walkDirRec(absRoot)
        for j in 0..<files.len:
            if strings.hasSuffix(files[j], ".cheng"):
                add(out, os.relativePath(files[j], repoRoot))
    sortTextList(out)
    return out

fn resolveV2NoPointerPackageClosureManifest(rootPath: str,
                                            sourcePath: str): mresolve.SourceManifestBundle =
    let absoluteSourcePath = compilerCoreZrpcAbsolutePath(rootPath, sourcePath)
    let parsed = parser.parseV2SourceFileStrict(absoluteSourcePath)
    if parsedHasSurfaceKind(parsed, "compiler_core"):
        return mresolve.resolveCompilerCoreSourceManifest(absoluteSourcePath)
    let packageRoot = mresolve.findNearestPackageRoot(absoluteSourcePath)
    if len(packageRoot) <= 0:
        system.panic("verify-v2-no-pointer-package-closures: missing package root for " + sourcePath)
    let packageManifestPath = os.joinPath(packageRoot, "cheng-package.toml")
    var fullPaths: str[] = []
    if os.fileExists(packageManifestPath):
        ident.appendUnique(fullPaths, packageManifestPath)
    ident.appendUnique(fullPaths, absoluteSourcePath)
    return mresolve.buildSourceManifestFromPaths(".", mresolve.parsePackageId(packageRoot), fullPaths)

fn hasManifestClosurePath(bundle: mresolve.SourceManifestBundle, path: str): bool =
    for i in 0..<bundle.filePaths.len:
        if bundle.filePaths[i] == path:
            return true
    return false

fn findHighGraphItemIndex(graph: cgraph.HighUirCompilerCoreGraph,
                          topLevelKind: str,
                          label: str): int32 =
    for i in 0..<graph.labels.len:
        if graph.topLevelKinds[i] == topLevelKind && graph.labels[i] == label:
            return i
    return -1

fn graphItemExprReferenceCount(graph: cgraph.HighUirCompilerCoreGraph,
                               itemIdx: int32,
                               referenceKind: str): int32 =
    if itemIdx < 0:
        return -1
    let exprStart = graph.itemExprStarts[itemIdx]
    let exprCount = graph.exprCounts[itemIdx]
    var count: int32 = 0
    for i in 0..<exprCount:
        if graph.exprReferenceKinds[exprStart + i] == referenceKind:
            count = count + 1
    return count

fn graphItemParamTypeText(graph: cgraph.HighUirCompilerCoreGraph,
                          itemIdx: int32,
                          paramIdx: int32): str =
    if itemIdx < 0 || paramIdx < 0 || paramIdx >= graph.paramCounts[itemIdx]:
        return ""
    return graph.paramTypeTexts[graph.itemParamStarts[itemIdx] + paramIdx]

fn findProgramRoutineIndex(program: ccore.CompilerCoreProgram, label: str): int32 =
    for i in 0..<program.routines.len:
        if program.routines[i].name == label:
            return i
    return -1

fn findFactsItemIndex(facts: cffacts.CompilerCoreSemanticFacts,
                      topLevelKind: str,
                      label: str): int32 =
    for i in 0..<facts.itemIds.len:
        if facts.topLevelKinds[i] == topLevelKind && facts.topLevelLabels[i] == label:
            return i
    return -1

fn programRoutineExprReferenceCount(program: ccore.CompilerCoreProgram,
                                    facts: cffacts.CompilerCoreSemanticFacts,
                                    routineIdx: int32,
                                    referenceKind: str): int32 =
    if routineIdx < 0:
        return -1
    let decl = program.routines[routineIdx]
    var count: int32 = 0
    for i in 0..<decl.exprCount:
        if facts.exprReferenceKinds[decl.exprStart + i] == referenceKind:
            count = count + 1
    return count

fn programRoutineParamTypeText(program: ccore.CompilerCoreProgram,
                               routineIdx: int32,
                               paramIdx: int32): str =
    if routineIdx < 0:
        return ""
    let decl = program.routines[routineIdx]
    if paramIdx < 0 || paramIdx >= decl.paramCount:
        return ""
    return program.routineParams[decl.paramStart + paramIdx].typeText

fn runCompilerCommandOrPanic(compilerPath: str,
                             argv: str[],
                             workingDir: str,
                             label: str): str =
    let result = hostos.execFileCapture(compilerPath, argv, [], workingDir, true, 300)
    let output = os.execCmdResultOutput(result)
    if os.execCmdResultExitCode(result) != 0:
        if len(output) > 0:
            system.panic(label + "\n" + output)
        system.panic(label)
    return output

fn compareExpectedTextOrPanic(expectedPath: str, actualPath: str, label: str) =
    if !compareTextFiles(expectedPath, actualPath):
        system.panic(label)

