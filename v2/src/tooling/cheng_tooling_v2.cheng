fn taijiJsonEscape(text: str): str =
    var out: str = ""
    for i in 0..<len(text):
        let ch = text[i]
        if ch == '\\':
            out = out + "\\\\"
        elif ch == '"':
            out = out + "\\\""
        elif ch == '\n':
            out = out + "\\n"
        elif ch == '\r':
            out = out + "\\r"
        elif ch == '\t':
            out = out + "\\t"
        else:
            out = out + charToStr(ch)
    return out

fn taijiJsonQuote(text: str): str =
    return "\"" + taijiJsonEscape(text) + "\""

fn printLine(text: str) =
    os.writeLine(os.get_stdout(), text)

fn writeText(text: str) =
    os.write(os.get_stdout(), text)

fn readFlagDefault(key: str, defaultValue: str): str =
    return cmdline.readFlagOrDefault(key, defaultValue)

fn readIntFlagDefault(key: str, defaultValue: int32): int32 =
    return cmdline.readInt32FlagOrDefault(key, defaultValue)

fn readCidFlag(): str =
    return readFlagDefault("--cid", "")

fn createDirAll(path: str) =
    if len(path) == 0 || os.dirExists(path):
        return
    let parent = os.parentDir(path)
    if len(parent) > 0 && parent != path:
        createDirAll(parent)
    if !os.dirExists(path):
        os.createDir(path)

fn writeTextFile(path: str, text: str) =
    if len(path) <= 0:
        return
    let parent = os.parentDir(path)
    if len(parent) > 0:
        createDirAll(parent)
    os.writeFile(path, text)

fn joinPath2(left: str, right: str): str =
    return os.joinPath(left, right)

fn currentCompilerPath(): str =
    let raw = cmdline.programName()
    if len(raw) <= 0:
        return ""
    return os.absolutePath(raw)

fn absolutePath(path: str): str =
    if len(path) <= 0:
        return ""
    return os.absolutePath(path)

fn currentWorkingDir(): str =
    return os.getCurrentDir()

fn currentRepoRoot(): str =
    return currentWorkingDir()

fn textStartsWith(text: str, prefix: str): bool =
    if len(prefix) > len(text):
        return false
    for i in 0..<len(prefix):
        if text[i] != prefix[i]:
            return false
    return true

fn extractLineValue(text: str, key: str): str =
    let prefix = key + "="
    var start: int32 = 0
    var i: int32 = 0
    while i <= len(text):
        if i == len(text) || text[i] == '\n':
            let line = strings.sliceBytes(text, start, i - start)
            if len(line) >= len(prefix) && textStartsWith(line, prefix):
                return strings.sliceBytes(line, len(prefix), len(line) - len(prefix))
            start = i + 1
        i = i + 1
    return ""

fn countTextOccurrences(text: str, needle: str): int32 =
    if len(needle) <= 0 || len(text) < len(needle):
        return 0
    var out: int32 = 0
    for i in 0..<(len(text) - len(needle) + 1):
        if strings.sliceBytes(text, i, len(needle)) == needle:
            out = out + 1
    return out

fn parseInt32StrictOrZero(text: str): int32 =
    if len(text) <= 0:
        return 0
    var sign: int32 = 1
    var i: int32 = 0
    if text[0] == '+':
        i = 1
    elif text[0] == '-':
        sign = -1
        i = 1
    if i >= len(text):
        return 0
    var out: int32 = 0
    while i < len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return 0
        out = out * 10 + (int32(ch) - int32('0'))
        i = i + 1
    return out * sign

fn parsePlanInt32OrZero(planText: str, key: str): int32 =
    return parseInt32StrictOrZero(extractLineValue(planText, key))

fn countExternalCcProvidersFromPlanText(planText: str): int32 =
    return countTextOccurrences(planText, "compile_mode=external_cc_obj")

fn providerFieldForModuleFromPlanText(planText: str, moduleName: str, fieldName: str): str =
    if len(planText) <= 0 || len(moduleName) <= 0 || len(fieldName) <= 0:
        return ""
    let prefix = "provider_module."
    var start: int32 = 0
    var i: int32 = 0
    while i <= len(planText):
        if i == len(planText) || planText[i] == '\n':
            let line = strings.sliceBytes(planText, start, i - start)
            if textStartsWith(line, prefix):
                let nameMarker = ".name="
                let markerAt = parser.findText(line, nameMarker)
                if markerAt > len(prefix):
                    let indexText = strings.sliceBytes(line, len(prefix), markerAt - len(prefix))
                    let lineModule = strings.sliceBytes(line,
                                                        markerAt + len(nameMarker),
                                                        len(line) - (markerAt + len(nameMarker)))
                    if lineModule == moduleName:
                        return extractLineValue(planText,
                                                prefix + indexText + "." + fieldName)
            start = i + 1
        i = i + 1
    return ""

fn compilerCoreProviderSourceKind(planText: str): str =
    return providerFieldForModuleFromPlanText(planText,
                                              "runtime/compiler_core_runtime_v2",
                                              "source_kind")

fn compilerCoreProviderCompileMode(planText: str): str =
    return providerFieldForModuleFromPlanText(planText,
                                              "runtime/compiler_core_runtime_v2",
                                              "compile_mode")

fn compareTextFiles(leftPath: str, rightPath: str): bool =
    if !os.fileExists(leftPath) || !os.fileExists(rightPath):
        return false
    return os.readFile(leftPath) == os.readFile(rightPath)

fn compareBinaryFiles(leftPath: str, rightPath: str): bool =
    if !os.fileExists(leftPath) || !os.fileExists(rightPath):
        return false
    let left = bytes.readFileBytes(leftPath)
    let right = bytes.readFileBytes(rightPath)
    if left.len != right.len:
        return false
    for i in 0..<left.len:
        if bytes.bufByteAt(left, i) != bytes.bufByteAt(right, i):
            return false
    return true

