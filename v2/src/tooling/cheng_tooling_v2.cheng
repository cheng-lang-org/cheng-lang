fn taijiCompilerCoreLowUirDocument(sourcePath: str,
                                   sourceLabel: str,
                                   bundle: cpipe.CompilerCorePipelineBundle): TaijiDocument =
    var inputTypes: str[]
    var outputTypes: str[]
    var edgeKinds: str[]
    var edgeSources: int32[]
    var edgeTargets: int32[]
    var fields: str[]
    inputTypes = []
    outputTypes = []
    edgeKinds = []
    edgeSources = []
    edgeTargets = []
    fields = []
    for i in 0..<bundle.lowPlan.itemIds.len:
        add(inputTypes, taijiCompilerCoreInputTypes(bundle, i))
        add(outputTypes, taijiCompilerCoreOutputTypes(bundle, i))
        if i > 0:
            add(edgeKinds, "sequence_next")
            add(edgeSources, bundle.lowPlan.itemIds[i - 1])
            add(edgeTargets, bundle.lowPlan.itemIds[i])
    let baguaAnnotations = lowbagua.annotateLowUirNodes("compiler_core",
                                                        bundle.lowPlan.itemIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.bindingScopes,
                                                        bundle.lowPlan.runtimeTargets)
    let baguaMatrix = bcore.buildMatrix(bundle.lowPlan.itemIds, baguaAnnotations)
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.low_uir_graph.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("compiler_core")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("storage_model", jsonQuote("soa_index_only")))
    add(fields, jsonFieldRaw("node_ids", jsonIntArray(bundle.lowPlan.itemIds)))
    add(fields, jsonFieldRaw("op_names", jsonStringArray(bundle.lowPlan.canonicalOps)))
    appendBaguaNodeFields(fields, baguaAnnotations, baguaMatrix)
    appendBaguaLowUirPassHintFields(fields, baguaAnnotations)
    add(fields, jsonFieldRaw("input_types", jsonRawArray(inputTypes)))
    add(fields, jsonFieldRaw("output_types", jsonRawArray(outputTypes)))
    add(fields, jsonFieldRaw("effect_classes", jsonStringArray(bundle.lowPlan.effectClasses)))
    add(fields, jsonFieldRaw("proof_domains", jsonStringArray(bundle.lowPlan.proofDomains)))
    add(fields, jsonFieldRaw("binding_scopes", jsonStringArray(bundle.lowPlan.bindingScopes)))
    add(fields, jsonFieldRaw("runtime_targets", jsonStringArray(bundle.lowPlan.runtimeTargets)))
    add(fields, jsonFieldRaw("edge_kinds", jsonStringArray(edgeKinds)))
    add(fields, jsonFieldRaw("edge_sources", jsonIntArray(edgeSources)))
    add(fields, jsonFieldRaw("edge_targets", jsonIntArray(edgeTargets)))
    return taijiDocument(jsonObject(fields))

fn taijiStringPhaseTraceDocument(sourcePath: str,
                                 sourceLabel: str,
                                 bundle: spipe.StringPipelineBundle): TaijiDocument =
    var events: str[]
    var fields: str[]
    var proofDomains: str[]
    var bindingScopes: str[]
    events = []
    fields = []
    proofDomains = []
    bindingScopes = []
    for i in 0..<bundle.lowPlan.exprIds.len:
        add(proofDomains, taijiStringProofDomain(bundle, i))
        add(bindingScopes, bundle.lowPlan.allocationModes[i])
    let baguaAnnotations = lowbagua.annotateLowUirNodes("string",
                                                        bundle.lowPlan.exprIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        proofDomains,
                                                        bindingScopes,
                                                        bundle.lowPlan.runtimeTargets)
    for i in 0..<bundle.lowPlan.exprIds.len:
        let tag = stringBaguaTag(bundle.lowPlan.canonicalOps[i])
        validateBaguaPhaseLowering(bundle.lowPlan.exprIds,
                                   baguaAnnotations,
                                   bundle.lowPlan.exprIds[i],
                                   "string",
                                   tag.reason,
                                   phasePlaneForTag(tag),
                                   "string_phase|" + bundle.lowPlan.canonicalOps[i])
        add(events,
            jsonInlineObject([jsonInlineFieldRaw("event_id", intToStr(i)),
                              jsonInlineFieldRaw("state_bits", jsonQuote(tag.stateBits)),
                              jsonInlineFieldRaw("trigram", jsonQuote(tag.trigram)),
                              jsonInlineFieldRaw("phase", jsonQuote(tag.phase)),
                              jsonInlineFieldRaw("plane", jsonQuote(phasePlaneForTag(tag))),
                              jsonInlineFieldRaw("cell_row", intToStr(phaseCellRowForTag(tag))),
                              jsonInlineFieldRaw("cell_col", intToStr(phaseCellColForTag(tag))),
                              jsonInlineFieldRaw("source_node_id", intToStr(bundle.lowPlan.exprIds[i])),
                              jsonInlineFieldRaw("low_uir_node_id", intToStr(bundle.lowPlan.exprIds[i])),
                              jsonInlineFieldRaw("reason", jsonQuote(tag.reason))]))
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.phase_space_trace.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("string")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("trace_model", jsonQuote("bagua_v1")))
    add(fields, jsonFieldRaw("events", jsonRawArray(events)))
    return taijiDocument(jsonObject(fields))

