fn runPublishCompilerRulePack(): int32 =
    let sourcePath = readFlagDefault("--in", "v2/examples/network_distribution_module.cheng")
    let outPath = readFlagDefault("--out", "v2/artifacts/network/compiler_rule_pack.txt")
