    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_compile_key_depth_covered",
                                   "stage2_tooling_compile_key_depth_covered")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_compile_key_address_binding_covered",
                                   "stage2_tooling_compile_key_address_binding_covered")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_compile_key_distance_metric_covered",
                                   "stage2_tooling_compile_key_distance_metric_covered")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_compile_key_priority_covered",
                                   "stage2_tooling_compile_key_priority_covered")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_compile_key_dispersal_covered",
                                   "stage2_tooling_compile_key_dispersal_covered")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_compile_key_signature_covered",
                                   "stage2_tooling_compile_key_signature_covered")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_compile_key_canonical_multipath_covered",
                                   "stage2_tooling_compile_key_canonical_multipath_covered")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_release_manifest_matches_source_manifest",
                                   "stage2_tooling_release_manifest_matches_source_manifest")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_random_gossip_fallback_present",
                                   "stage2_tooling_random_gossip_fallback_present")
    printLine("stage1_external_cc_provider_count=" + intToStr(stage1.externalCcProviderCount))
    printLine("stage2_external_cc_provider_count=" + intToStr(stage2.externalCcProviderCount))
    printLine("stage3_external_cc_provider_count=" + intToStr(stage3.externalCcProviderCount))
    printLine("compiler_core_provider_source_kind=" + stage2.compilerCoreProviderSourceKind)
    printLine("compiler_core_provider_compile_mode=" + stage2.compilerCoreProviderCompileMode)
    printLine("compiler_core_dispatch_provider_removed=" + if noExternalCProvider: "1" else: "0")
    printLine("emit_c_used_after_stage0=0")
    return ok ? 0 : 1

fn printUsage() =
    printLine("cheng_tooling_v2")
    printLine("usage: cheng_tooling_v2 <command>")
    printLine("")
    printLine("commands:")
    printLine("  help                         show this message")
    printLine("  surface                      print the frozen v2 surface summary")
    printLine("  passes                       print the fixed low_uir pipeline order")
    printLine("  contracts                    print key contract markers")
    printLine("  strings                      print the string surface contract")
    printLine("  string-pipeline              print the sample end-to-end string pipeline")
    printLine("  infra                        print the Unimaker language surface contract")
    printLine("  infra-pipeline               print the sample Unimaker pipeline")
    printLine("  network-surface              print the topology/network-distribution surface")
    printLine("  network-pipeline             print the sample topology/network pipeline")
    printLine("  selfhost                     print the subset selfhost bootstrap contract")
    printLine("  stage-selfhost-host          build stage1 -> stage2 -> stage3 native closure")
    printLine("  tooling-selfhost-host        run the native tooling selfhost orchestration")
    printLine("  tooling-selfhost-check       verify tooling stage0 -> stage1 -> stage2 fixed-point closure")
    printLine("  program-selfhost-check       verify ordinary programs are built and run by a Cheng-produced compiler")
    printLine("  lsmr-address                 emit a deterministic LSMR address from a content cid")
    printLine("  lsmr-route-plan             emit a deterministic canonical LSMR multipath route plan")
    printLine("  outline-parse                emit an outline parse for a compiler_core source")
    printLine("  machine-plan                 emit a deterministic machine plan for a source")
    printLine("  obj-image                    emit a deterministic object image for a source")
    printLine("  obj-file                     emit a deterministic object-file byte layout for a source")
    printLine("  system-link-plan             emit a deterministic native system-link plan for a source")
    printLine("  system-link-exec             materialize object files and invoke the deterministic system linker")
    printLine("  resolve-manifest             resolve a deterministic source manifest")
    printLine("  publish-source-manifest      emit a source manifest artifact")
    printLine("  publish-rule-pack            emit a rule-pack artifact")
    printLine("  publish-compiler-rule-pack   emit a compiler rule-pack artifact")
    printLine("  verify-network-selfhost      verify manifest + topology + rule-pack closure")
    printLine("  verify-compiler-core-zrpc-surface verify compiler_core no-pointer surface probes")
    printLine("  verify-v2-no-pointer-surface verify v2 no-pointer probes across compiler_core/unimaker/topology/network")
    printLine("  verify-v2-no-pointer-package-closures verify real v2 package entry closures stay zero-rawptr")
    printLine("  verify-compiler-core-no-pointer-closure verify v2 production closure stays zero-rawptr")
    printLine("  verify-compiler-core-cycle-surface verify compiler_core cyclic import and zero-forward-decl surface")
    printLine("  release-compile              emit a deterministic release artifact spec")
    printLine("  dump-ast                     emit a Taiji-UIR AST graph json")
    printLine("  dump-low-uir                 emit a Taiji-UIR typed low_uir graph json")
    printLine("  dump-exec-plan               emit compiler_core Low-UIR exec ops for one label")
    printLine("  trace-phase-space            emit a Taiji-UIR bagua phase-space trace json")
    printLine("  emit-proof-obligations       emit Taiji-UIR proof obligation tasks json")
    printLine("  taiji-seed-set               materialize the phase-1 Taiji-UIR seed dataset")

