@importc("driver_c_join_path2_bridge")
fn joinPath2Bridge(left: str, right: str): str

@importc("driver_c_program_absolute_path_bridge")
fn programAbsolutePathBridge(): str

@importc("driver_c_absolute_path_bridge")
