fn printLine(text: str) =
    os.writeLine(os.get_stdout(), text)

fn writeText(text: str) =
    os.write(os.get_stdout(), text)

fn readFlagDefault(key: str, defaultValue: str): str =
    return cmdline.readFlagOrDefault(key, defaultValue)

fn readIntFlagDefault(key: str, defaultValue: int32): int32 =
    return cmdline.readInt32FlagOrDefault(key, defaultValue)

fn createDirAll(path: str) =
    createDirAllBridge(path)

fn writeTextFile(path: str, text: str) =
    writeTextFileBridge(path, text)

fn joinPath2(left: str, right: str): str =
    return joinPath2Bridge(left, right)

fn currentCompilerPath(): str =
    return programAbsolutePathBridge()

fn absolutePath(path: str): str =
    return absolutePathBridge(path)

fn currentWorkingDir(): str =
    return currentWorkingDirBridge()

fn compareTextFiles(leftPath: str, rightPath: str): bool =
    return compareTextFilesBridge(leftPath, rightPath)

fn compareBinaryFiles(leftPath: str, rightPath: str): bool =
    return compareBinaryFilesBridge(leftPath, rightPath)

fn runCompilerCommandOrPanic(compilerPath: str,
                             argv: str[],
                             workingDir: str,
                             label: str): str =
    return execFileCaptureOrPanicBridge(compilerPath, argv, workingDir, label)

fn compareExpectedTextOrPanic(expectedPath: str, actualPath: str, label: str) =
    compareTextFilesOrPanicBridge(expectedPath, actualPath, label)

fn parsePlanInt32OrZero(planText: str, key: str): int32 =
    return parsePlanInt32OrZeroBridge(planText, key)

fn countExternalCcProvidersFromPlanText(planText: str): int32 =
    return countExternalCcProvidersBridge(planText)

fn providerFieldForModuleFromPlanText(planText: str, moduleName: str, fieldName: str): str =
    return providerFieldForModuleFromPlanTextBridge(planText, moduleName, fieldName)

fn stageReleasePath(stageDir: str): str =
    return joinPath2(stageDir, "release.txt")

fn stageSystemLinkPlanPath(stageDir: str): str =
    return joinPath2(stageDir, "system_link_plan.txt")

fn stageSystemLinkExecPath(stageDir: str): str =
    return joinPath2(stageDir, "system_link_exec.txt")

fn stageBinaryPath(stageDir: str, binaryName: str): str =
    return joinPath2(stageDir, binaryName)

fn stageRootDir(outDir: str): str =
    return joinPath2(outDir, "stages")

fn stageNamedDir(outDir: str, stageName: str): str =
    return joinPath2(stageRootDir(outDir), stageName)

fn stage2ToolingDirPath(outDir: str): str =
    return joinPath2(outDir, "stage2_tooling_selfhost")

fn stage2ToolingReportPath(outDir: str): str =
    return joinPath2(stage2ToolingDirPath(outDir), "tooling_selfhost_host.txt")

fn toolingSelfhostPath(outDir: str, fileName: str): str =
    return joinPath2(outDir, fileName)

fn buildStageArtifacts(compilerPath: str,
                       sourcePath: str,
                       targetTriple: str,
                       stageDir: str,
                       binaryName: str): NativeStageArtifacts =
    createDirAll(stageDir)
    let releasePath = stageReleasePath(stageDir)
    let systemLinkPlanPath = stageSystemLinkPlanPath(stageDir)
    let systemLinkExecPath = stageSystemLinkExecPath(stageDir)
    let binaryPath = stageBinaryPath(stageDir, binaryName)
    let workingDir = currentWorkingDir()
    let releaseArgv = ["release-compile", "--in", sourcePath, "--emit", "exe", "--target", targetTriple, "--out", releasePath]
    let releaseOutput = runCompilerCommandOrPanic(compilerPath, releaseArgv, workingDir, "stage-selfhost-host release-compile failed")
    writeTextFile(releasePath, releaseOutput)
    let systemLinkPlanArgv = ["system-link-plan", "--in", sourcePath, "--emit", "exe", "--target", targetTriple, "--out", systemLinkPlanPath]
    let systemLinkPlanOutput = runCompilerCommandOrPanic(compilerPath, systemLinkPlanArgv, workingDir, "stage-selfhost-host system-link-plan failed")
    writeTextFile(systemLinkPlanPath, systemLinkPlanOutput)
    let systemLinkExecArgv = ["system-link-exec", "--in", sourcePath, "--emit", "exe", "--target", targetTriple, "--out", binaryPath, "--report-out", systemLinkExecPath]
    let systemLinkExecOutput = runCompilerCommandOrPanic(compilerPath, systemLinkExecArgv, workingDir, "stage-selfhost-host system-link-exec failed")
    writeTextFile(systemLinkExecPath, systemLinkExecOutput)
    let compilerCoreProviderSourceKind = compilerCoreProviderSourceKindBridge(systemLinkPlanOutput)
    let compilerCoreProviderCompileMode = compilerCoreProviderCompileModeBridge(systemLinkPlanOutput)
    var out: NativeStageArtifacts
    out.compilerPath = compilerPath
    out.releasePath = releasePath
    out.systemLinkPlanPath = systemLinkPlanPath
    out.systemLinkExecPath = systemLinkExecPath
    out.binaryPath = binaryPath
    out.binaryCid = sexec.readFileSha256Hex(binaryPath)
    out.outputFileCid = sexec.extractLineValue(systemLinkExecOutput, "output_file_cid")
    out.externalCcProviderCount = countExternalCcProvidersFromPlanText(systemLinkPlanOutput)
    out.compilerCoreProviderSourceKind = compilerCoreProviderSourceKind
    out.compilerCoreProviderCompileMode = compilerCoreProviderCompileMode
    return out

fn printUsage() =
    printLine("cheng_tooling_v2")
    printLine("usage: cheng_tooling_v2 <command>")
    printLine("")
    printLine("commands:")
    printLine("  help                         show this message")
    printLine("  surface                      print the frozen v2 surface summary")
    printLine("  passes                       print the fixed low_uir pipeline order")
    printLine("  contracts                    print key contract markers")
    printLine("  strings                      print the string surface contract")
    printLine("  string-pipeline              print the sample end-to-end string pipeline")
    printLine("  infra                        print the Unimaker language surface contract")
    printLine("  infra-pipeline               print the sample Unimaker pipeline")
    printLine("  network-surface              print the topology/network-distribution surface")
    printLine("  network-pipeline             print the sample topology/network pipeline")
    printLine("  selfhost                     print the subset selfhost bootstrap contract")
    printLine("  stage-selfhost-host          build stage1 -> stage2 -> stage3 native closure")
    printLine("  tooling-selfhost-host        run the native tooling selfhost orchestration")
    printLine("  lsmr-address                 emit a deterministic LSMR address from a content cid")
    printLine("  lsmr-route-plan             emit a deterministic canonical LSMR multipath route plan")
    printLine("  outline-parse                emit an outline parse for a compiler_core source")
    printLine("  machine-plan                 emit a deterministic machine plan for a source")
    printLine("  obj-image                    emit a deterministic object image for a source")
    printLine("  obj-file                     emit a deterministic object-file byte layout for a source")
    printLine("  system-link-plan             emit a deterministic native system-link plan for a source")
    printLine("  system-link-exec             materialize object files and invoke the deterministic system linker")
    printLine("  resolve-manifest             resolve a deterministic source manifest")
    printLine("  publish-source-manifest      emit a source manifest artifact")
    printLine("  publish-rule-pack            emit a rule-pack artifact")
    printLine("  publish-compiler-rule-pack   emit a compiler rule-pack artifact")
    printLine("  verify-network-selfhost      verify manifest + topology + rule-pack closure")
    printLine("  release-compile              emit a deterministic release artifact spec")

