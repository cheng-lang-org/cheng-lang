    return cmdline.cliParam1Eq("help")

fn cmdIsHelpShortOrWord(): bool =
    if cmdIsHelpShort():
        return returnTrue()
    else:
        return cmdIsHelpWord()

fn cmdIsHelp(): bool =
    if cmdIsHelpLong():
        return returnTrue()
    else:
        return cmdIsHelpShortOrWord()

