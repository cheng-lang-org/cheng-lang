    let depth = readIntFlagDefault("--depth", 4)
    let priorityClass = readFlagDefault("--priority", "urgent")
    let dispersalMode = readFlagDefault("--dispersal", "none")
    if isEmptyText(cid):
        return printMissingCidAndFail()
    else:
        return writeLsmrRoutePlanZero(cid, depth, priorityClass, dispersalMode)

