fn taijiStringPhaseTraceDocument(sourcePath: str,
                                 sourceLabel: str,
                                 bundle: spipe.StringPipelineBundle): TaijiDocument =
    var events: str[]
    var fields: str[]
    var proofDomains: str[]
    var bindingScopes: str[]
    events = []
    fields = []
    proofDomains = []
    bindingScopes = []
    for i in 0..<bundle.lowPlan.exprIds.len:
        add(proofDomains, taijiStringProofDomain(bundle, i))
        add(bindingScopes, bundle.lowPlan.allocationModes[i])
    let baguaAnnotations = lowbagua.annotateLowUirNodes("string",
                                                        bundle.lowPlan.exprIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        proofDomains,
                                                        bindingScopes,
                                                        bundle.lowPlan.runtimeTargets)
    for i in 0..<bundle.lowPlan.exprIds.len:
        let tag = stringBaguaTag(bundle.lowPlan.canonicalOps[i])
        validateBaguaPhaseLowering(bundle.lowPlan.exprIds,
                                   baguaAnnotations,
                                   bundle.lowPlan.exprIds[i],
                                   "string",
                                   tag.reason,
                                   phasePlaneForTag(tag),
                                   "string_phase|" + bundle.lowPlan.canonicalOps[i])
        add(events,
            jsonInlineObject([jsonInlineFieldRaw("event_id", intToStr(i)),
                              jsonInlineFieldRaw("state_bits", jsonQuote(tag.stateBits)),
                              jsonInlineFieldRaw("trigram", jsonQuote(tag.trigram)),
                              jsonInlineFieldRaw("phase", jsonQuote(tag.phase)),
                              jsonInlineFieldRaw("plane", jsonQuote(phasePlaneForTag(tag))),
                              jsonInlineFieldRaw("cell_row", intToStr(phaseCellRowForTag(tag))),
                              jsonInlineFieldRaw("cell_col", intToStr(phaseCellColForTag(tag))),
                              jsonInlineFieldRaw("source_node_id", intToStr(bundle.lowPlan.exprIds[i])),
                              jsonInlineFieldRaw("low_uir_node_id", intToStr(bundle.lowPlan.exprIds[i])),
                              jsonInlineFieldRaw("reason", jsonQuote(tag.reason))]))
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.phase_space_trace.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("string")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("trace_model", jsonQuote("bagua_v1")))
    add(fields, jsonFieldRaw("events", jsonRawArray(events)))
    return taijiDocument(jsonObject(fields))

fn taijiUnimakerPhaseTraceDocument(sourcePath: str,
                                   sourceLabel: str,
                                   bundle: upipe.UnimakerPipelineBundle): TaijiDocument =
    var events: str[]
    var fields: str[]
    events = []
    fields = []
    let baguaAnnotations = lowbagua.annotateLowUirNodes("unimaker",
                                                        bundle.lowPlan.declIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.networkModes,
                                                        bundle.lowPlan.runtimeTargets)
    for i in 0..<bundle.lowPlan.declIds.len:
        let tag = unimakerBaguaTag(bundle.lowPlan.canonicalOps[i])
        let reason = bundle.lowPlan.canonicalOps[i] + "|" + bundle.lowPlan.networkModes[i]
        validateBaguaPhaseLowering(bundle.lowPlan.declIds,
                                   baguaAnnotations,
                                   bundle.lowPlan.declIds[i],
                                   "unimaker",
                                   reason,
                                   phasePlaneForTag(tag),
                                   "unimaker_phase|" + bundle.lowPlan.canonicalOps[i])
        add(events,
            jsonInlineObject([jsonInlineFieldRaw("event_id", intToStr(i)),
                              jsonInlineFieldRaw("state_bits", jsonQuote(tag.stateBits)),
                              jsonInlineFieldRaw("trigram", jsonQuote(tag.trigram)),
                              jsonInlineFieldRaw("phase", jsonQuote(tag.phase)),
                              jsonInlineFieldRaw("plane", jsonQuote(phasePlaneForTag(tag))),
                              jsonInlineFieldRaw("cell_row", intToStr(phaseCellRowForTag(tag))),
                              jsonInlineFieldRaw("cell_col", intToStr(phaseCellColForTag(tag))),
                              jsonInlineFieldRaw("source_node_id", intToStr(bundle.lowPlan.declIds[i])),
                              jsonInlineFieldRaw("low_uir_node_id", intToStr(bundle.lowPlan.declIds[i])),
                              jsonInlineFieldRaw("reason", jsonQuote(reason))]))
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.phase_space_trace.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("unimaker")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("trace_model", jsonQuote("bagua_v1")))
    add(fields, jsonFieldRaw("events", jsonRawArray(events)))
    return taijiDocument(jsonObject(fields))

fn taijiNetworkPhaseTraceDocument(sourcePath: str,
                                  sourceLabel: str,
                                  bundle: npipe.NetworkDistributionPipelineBundle): TaijiDocument =
    var events: str[]
    var fields: str[]
    var effectClasses: str[]
    events = []
    fields = []
    effectClasses = []
    for i in 0..<bundle.lowPlan.opIds.len:
        add(effectClasses, taijiNetworkEffectClass(bundle.lowPlan.canonicalOps[i]))
    let baguaAnnotations = lowbagua.annotateLowUirNodes("network_distribution",
                                                        bundle.lowPlan.opIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.addressBindings,
                                                        bundle.lowPlan.runtimeTargets)
    for i in 0..<bundle.lowPlan.opIds.len:
        let tag = networkBaguaTag(bundle.lowPlan.canonicalOps[i])
        let reason = bundle.lowPlan.canonicalOps[i] + "|" + bundle.lowPlan.proofDomains[i]
        validateBaguaPhaseLowering(bundle.lowPlan.opIds,
                                   baguaAnnotations,
                                   bundle.lowPlan.opIds[i],
                                   "network_distribution",
                                   reason,
                                   phasePlaneForTag(tag),
                                   "network_phase|" + bundle.lowPlan.canonicalOps[i])
        add(events,
            jsonInlineObject([jsonInlineFieldRaw("event_id", intToStr(i)),
                              jsonInlineFieldRaw("state_bits", jsonQuote(tag.stateBits)),
                              jsonInlineFieldRaw("trigram", jsonQuote(tag.trigram)),
                              jsonInlineFieldRaw("phase", jsonQuote(tag.phase)),
                              jsonInlineFieldRaw("plane", jsonQuote(phasePlaneForTag(tag))),
                              jsonInlineFieldRaw("cell_row", intToStr(phaseCellRowForTag(tag))),
                              jsonInlineFieldRaw("cell_col", intToStr(phaseCellColForTag(tag))),
                              jsonInlineFieldRaw("source_node_id", intToStr(bundle.lowPlan.opIds[i])),
                              jsonInlineFieldRaw("low_uir_node_id", intToStr(bundle.lowPlan.opIds[i])),
                              jsonInlineFieldRaw("reason", jsonQuote(reason))]))
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.phase_space_trace.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("network_distribution")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("trace_model", jsonQuote("bagua_v1")))
    add(fields, jsonFieldRaw("events", jsonRawArray(events)))
    return taijiDocument(jsonObject(fields))

fn taijiCompilerCorePhaseTraceDocument(sourcePath: str,
