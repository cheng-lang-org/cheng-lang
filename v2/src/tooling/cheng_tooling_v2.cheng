type
    NativeStageArtifacts =
        compilerPath: str
        releasePath: str
        systemLinkPlanPath: str
        systemLinkExecPath: str
        binaryPath: str
        binaryCid: str
        outputFileCid: str
        externalCcProviderCount: int32
        compilerCoreProviderSourceKind: str
        compilerCoreProviderCompileMode: str

@importc("driver_c_write_text_file_bridge")
fn writeTextFileBridge(path: str, text: str)

@importc("driver_c_compare_text_files_bridge")
