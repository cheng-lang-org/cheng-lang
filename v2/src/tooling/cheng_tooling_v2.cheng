fn taijiJsonEscape(text: str): str =
    var out: str = ""
    for i in 0..<len(text):
        let ch = text[i]
        if ch == '\\':
            out = out + "\\\\"
        elif ch == '"':
            out = out + "\\\""
        elif ch == '\n':
            out = out + "\\n"
        elif ch == '\r':
            out = out + "\\r"
        elif ch == '\t':
            out = out + "\\t"
        else:
            out = out + charToStr(ch)
    return out

fn taijiJsonQuote(text: str): str =
    return "\"" + taijiJsonEscape(text) + "\""

fn printLine(text: str) =
    os.writeLine(os.get_stdout(), text)

fn writeText(text: str) =
    os.write(os.get_stdout(), text)

