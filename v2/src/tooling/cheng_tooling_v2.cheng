fn dispatchCommandAfterLsmrRoutePlan(): int32 =
    if cmdIsOutlineParse():
        return runOutlineParse()
    else:
        return dispatchCommandAfterOutlineParse()

fn dispatchCommandAfterOutlineParse(): int32 =
    if cmdIsMachinePlan():
        return runMachinePlan()
    else:
        return dispatchCommandAfterMachinePlan()

fn dispatchCommandAfterMachinePlan(): int32 =
    if cmdIsObjImage():
        return runObjImage()
    else:
        return dispatchCommandAfterObjImage()

fn dispatchCommandAfterObjImage(): int32 =
    if cmdIsObjFile():
        return runObjFile()
    else:
        return dispatchCommandAfterObjFile()

fn dispatchCommandAfterObjFile(): int32 =
    if cmdIsSystemLinkPlan():
        return runSystemLinkPlan()
    else:
        return dispatchCommandAfterSystemLinkPlan()

fn dispatchCommandAfterSystemLinkPlan(): int32 =
    if cmdIsSystemLinkExec():
        return runSystemLinkExec()
    else:
        return dispatchCommandAfterSystemLinkExec()

fn dispatchCommandAfterSystemLinkExec(): int32 =
    if cmdIsResolveManifest():
        return runResolveManifest()
    else:
        return dispatchCommandAfterResolveManifest()

fn dispatchCommandAfterResolveManifest(): int32 =
    if cmdIsPublishSourceManifest():
        return runPublishSourceManifest()
    else:
        return dispatchCommandAfterPublishSourceManifest()

fn dispatchCommandAfterPublishSourceManifest(): int32 =
    if cmdIsPublishRulePack():
        return runPublishRulePack()
    else:
        return dispatchCommandAfterPublishRulePack()

fn dispatchCommandAfterPublishRulePack(): int32 =
    if cmdIsPublishCompilerRulePack():
        return runPublishCompilerRulePack()
    else:
        return dispatchCommandAfterPublishCompilerRulePack()

fn dispatchCommandAfterPublishCompilerRulePack(): int32 =
    if cmdIsVerifyNetworkSelfhost():
        return runVerifyNetworkSelfhost()
    else:
        return dispatchCommandAfterVerifyNetworkSelfhost()

fn dispatchCommandAfterVerifyNetworkSelfhost(): int32 =
    if cmdIsReleaseCompile():
        return runReleaseCompile()
    else:
        return printUsageFail()

fn dispatchCommandAfterPasses(): int32 =
    if cmdIsContracts():
        return printContractsZero()
    else:
        return dispatchCommandAfterContracts()

fn dispatchCommandAfterSurface(): int32 =
    if cmdIsPasses():
        return printPassesZero()
    else:
        return dispatchCommandAfterPasses()

fn dispatchCommand(): int32 =
    if cmdIsHelp():
        return printUsageZero()
    else:
        return dispatchCommandAfterHelp()

fn dispatchCommandAfterHelp(): int32 =
    if cmdIsSurface():
        return printSurfaceZero()
    else:
        return dispatchCommandAfterSurface()

fn mainNeedsUsage(): bool =
    return cmdline.paramCount() <= 0

fn main(): int32 =
    if mainNeedsUsage():
        return printUsageZero()
    else:
        return dispatchCommand()
