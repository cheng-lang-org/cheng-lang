    printUsage()
    return 1

fn dispatchCommandLegacy(cmd: str): int32 =
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        return printUsageZero()
    if cmd == "surface":
        printSurface()
        return 0
    if cmd == "passes":
        printPasses()
        return 0
    if cmd == "contracts":
        printContracts()
        return 0
    if cmd == "strings":
        printStrings()
        return 0
    if cmd == "string-pipeline":
        printStringPipeline()
        return 0
    if cmd == "infra":
        printInfrastructure()
        return 0
    if cmd == "infra-pipeline":
        printInfrastructurePipeline()
        return 0
    if cmd == "network-surface":
        printNetworkSurface()
        return 0
    if cmd == "network-pipeline":
        printNetworkPipeline()
        return 0
    if cmd == "selfhost":
        printSelfhost()
        return 0
    if cmd == "stage-selfhost-host":
        return runStageSelfhostHost()
    if cmd == "tooling-selfhost-host":
        return runToolingSelfhostHost()
    if cmd == "tooling-selfhost-check":
        return runToolingSelfhostCheck()
    if cmd == "program-selfhost-check":
        return runProgramSelfhostCheck()
    if cmd == "lsmr-address":
        return runLsmrAddress()
    if cmd == "lsmr-route-plan":
        return runLsmrRoutePlan()
    if cmd == "outline-parse":
        return runOutlineParse()
    if cmd == "machine-plan":
        return runMachinePlan()
    if cmd == "obj-image":
        return runObjImage()
    if cmd == "obj-file":
        return runObjFile()
    if cmd == "system-link-plan":
        return runSystemLinkPlan()
    if cmd == "system-link-exec":
        return runSystemLinkExec()
    if cmd == "resolve-manifest":
        return runResolveManifest()
    if cmd == "publish-source-manifest":
        return runPublishSourceManifest()
    if cmd == "publish-rule-pack":
        return runPublishRulePack()
    if cmd == "publish-compiler-rule-pack":
        return runPublishCompilerRulePack()
    if cmd == "verify-network-selfhost":
        return runVerifyNetworkSelfhost()
    if cmd == "verify-compiler-core-zrpc-surface":
        return runVerifyCompilerCoreZrpcSurface()
    if cmd == "verify-v2-no-pointer-surface":
        return runVerifyV2NoPointerSurface()
    if cmd == "verify-v2-no-pointer-package-closures":
        return runVerifyV2NoPointerPackageClosures()
    if cmd == "verify-compiler-core-no-pointer-closure":
        return runVerifyCompilerCoreNoPointerClosure()
    if cmd == "verify-compiler-core-cycle-surface":
        return runVerifyCompilerCoreCycleSurface()
    if cmd == "release-compile":
        return runReleaseCompile()
    if cmd == "dump-ast":
        return runDumpAst()
    if cmd == "dump-low-uir":
        return runDumpLowUir()
    if cmd == "dump-exec-plan":
        return runDumpExecPlan()
    if cmd == "trace-phase-space":
        return runTracePhaseSpace()
    if cmd == "emit-proof-obligations":
        return runEmitProofObligations()
    if cmd == "taiji-seed-set":
        return runTaijiSeedSet()
    printUsage()
    return 1

fn dispatchCommandParam1(): int32 =
    return dispatchCommandLegacy(cmdline.paramStr(1))

