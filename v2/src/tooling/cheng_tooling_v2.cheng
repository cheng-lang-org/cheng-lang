fn jsonCompactObject(fields: str[]): str =
    return "{" + joinTextList(fields, ", ") + "}"

fn networkBundleFromSource(sourcePath: str): npipe.NetworkDistributionPipelineBundle =
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    return npipe.compileNetworkDistributionProgram(parsed.networkProgram)

fn machineBundleFromSource(sourcePath: str, targetTriple: str): mpipeline.MachineModuleBundle =
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        let bundle = npipe.compileNetworkDistributionProgram(parsed.networkProgram)
        return mpipeline.lowerNetworkDistributionPlanToMachine(bundle.lowPlan, targetTriple)
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        let bundle = cpipe.compileCompilerCoreSourceClosure(sourcePath)
        return mpipeline.lowerCompilerCorePlanToMachine(bundle.lowPlan, targetTriple, sourcePath)
    let bundle = upipe.compileUnimakerSurfaceProgram(parsed.unimakerProgram)
    return mpipeline.lowerUnimakerPlanToMachine(bundle.lowPlan, targetTriple)

fn buildCompilerCoreOutlineText(sourcePath: str): str =
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    let program = parsed.compilerCoreProgram
    var lines: str[]
    lines = []
    add(lines, "compiler_core_version=" + program.version)
    add(lines, "source=" + sourcePath)
    add(lines, "module_count=" + intToStr(program.modules.len))
    add(lines, "import_count=" + intToStr(program.imports.len))
    add(lines, "type_block_count=" + intToStr(program.typeBlocks.len))
    add(lines, "const_count=" + intToStr(program.constDecls.len))
    add(lines, "var_count=" + intToStr(program.varDecls.len))
    add(lines, "routine_count=" + intToStr(program.routines.len))
    add(lines, "top_level_count=" + intToStr(program.topLevelKinds.len))
    for i in 0..<program.modules.len:
        add(lines, "module." + intToStr(i) + ".name=" + program.modules[i].name)
        add(lines, "module." + intToStr(i) + ".header=" + program.modules[i].headerText)
    for i in 0..<program.imports.len:
        add(lines, "import." + intToStr(i) + ".path=" + program.imports[i].modulePath)
        add(lines, "import." + intToStr(i) + ".alias=" + program.imports[i].alias)
    for i in 0..<program.typeBlocks.len:
        add(lines, "type." + intToStr(i) + ".header=" + program.typeBlocks[i].headerText)
        add(lines, "type." + intToStr(i) + ".body_line_count=" + intToStr(program.typeBlocks[i].bodyLines.len))
    for i in 0..<program.constDecls.len:
        add(lines, "const." + intToStr(i) + ".label=" + program.constDecls[i].label)
        add(lines, "const." + intToStr(i) + ".header=" + program.constDecls[i].headerText)
        add(lines, "const." + intToStr(i) + ".body_line_count=" + intToStr(program.constDecls[i].bodyLines.len))
    for i in 0..<program.varDecls.len:
        add(lines, "var." + intToStr(i) + ".label=" + program.varDecls[i].label)
        add(lines, "var." + intToStr(i) + ".header=" + program.varDecls[i].headerText)
        add(lines, "var." + intToStr(i) + ".body_line_count=" + intToStr(program.varDecls[i].bodyLines.len))
    for i in 0..<program.routines.len:
        add(lines, "routine." + intToStr(i) + ".kind=" + program.routines[i].kind)
        add(lines, "routine." + intToStr(i) + ".name=" + program.routines[i].name)
        add(lines, "routine." + intToStr(i) + ".signature=" + program.routines[i].signatureText)
        add(lines, "routine." + intToStr(i) + ".body_line_count=" + intToStr(program.routines[i].bodyLines.len))
        var firstBodyLine: str = ""
        if program.routines[i].bodyLines.len > 0:
            firstBodyLine = program.routines[i].bodyLines[0]
        add(lines, "routine." + intToStr(i) + ".first_body_line=" + firstBodyLine)
    return mresolve.joinLines(lines)

fn buildSourceManifestArtifactText(bundle: mresolve.SourceManifestBundle): str =
    return bundle.manifestText + "\nmanifest_cid=" + bundle.manifestCid + "\n"

fn buildNetworkArtifactText(bundle: npipe.NetworkDistributionPipelineBundle,
                            requiredDomain: str,
                            artifactVersion: str): str =
    return ndident.buildPublishedNetworkArtifactText(bundle, requiredDomain, artifactVersion)

fn hasCanonicalOp(bundle: npipe.NetworkDistributionPipelineBundle, opName: str): bool =
    for i in 0..<bundle.lowPlan.canonicalOps.len:
        if bundle.lowPlan.canonicalOps[i] == opName:
            return true
    return false

fn verifyPriorityMappings(bundle: npipe.NetworkDistributionPipelineBundle): bool =
    for i in 0..<bundle.facts.priorityClasses.len:
        let expected = nsurf.networkPriorityTransport(bundle.facts.priorityClasses[i])
        if bundle.facts.transportModes[i] != expected:
            return false
    return true

fn canonicalOpCountForDomain(bundle: npipe.NetworkDistributionPipelineBundle, domain: str): int32 =
    var count: int32 = 0
    for i in 0..<bundle.facts.networkDomains.len:
        if bundle.facts.networkDomains[i] == domain:
            count = count + 1
    return count

fn releaseCompileKeyCoversNetworkBundle(releaseBundle: rart.ReleaseArtifactBundle,
                                        networkBundle: npipe.NetworkDistributionPipelineBundle): bool =
    for i in 0..<networkBundle.program.topologies.len:
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.topology." + intToStr(i) + "=" +
                                                  nsurf.topologyCanonicalForm(networkBundle.program.topologies[i])):
            return false
    for i in 0..<networkBundle.lowPlan.opIds.len:
        let binding = ndident.bindNetworkOpToLsmr(networkBundle, releaseBundle.manifestCid, i)
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".topology=" +
                                                  networkBundle.lowPlan.topologyCanonicalForms[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".addressing=" +
                                                  networkBundle.lowPlan.addressingModes[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".depth=" +
                                                  intToStr(networkBundle.lowPlan.topologyDepths[i])):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".address_binding=" +
                                                  networkBundle.lowPlan.addressBindings[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".distance_metric=" +
                                                  networkBundle.lowPlan.distanceMetrics[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".priority=" +
                                                  networkBundle.lowPlan.priorityClasses[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".dispersal=" +
                                                  networkBundle.lowPlan.dispersalModes[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".signature=" +
                                                  networkBundle.lowPlan.antiEntropySignatureKinds[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".content_cid=" +
                                                  binding.contentCid):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".source_address=" +
                                                  binding.sourceAddressText):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".target_address=" +
                                                  binding.targetAddressText):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".route_plan_cid=" +
                                                  binding.routePlanCid):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".route_path_count=" +
                                                  intToStr(binding.routePathCount)):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".total_distance=" +
                                                  intToStr(binding.totalDistance)):
            return false
        for j in 0..<binding.routePathCount:
            let pathLine = "path." + intToStr(j) + "="
            if parser.findText(binding.routePlanText, pathLine) < 0:
                return false
            let start = parser.findText(binding.routePlanText, pathLine)
            var stop = start
            while stop < len(binding.routePlanText) && binding.routePlanText[stop] != '\n':
                stop = stop + 1
            let rawLine = strings.sliceBytes(binding.routePlanText, start, stop - start)
            if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                      "network.entry." + intToStr(i) + ".route." + intToStr(j) +
                                                      "=" + strings.sliceBytes(rawLine, len(pathLine), len(rawLine) - len(pathLine))):
                return false
    return true

