fn jsonCompactObject(fields: str[]): str =
    return "{" + joinTextList(fields, ", ") + "}"

fn networkBundleFromSource(sourcePath: str): npipe.NetworkDistributionPipelineBundle =
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    return npipe.compileNetworkDistributionProgram(parsed.networkProgram)

fn machineBundleFromSource(sourcePath: str, targetTriple: str): mpipeline.MachineModuleBundle =
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        let bundle = npipe.compileNetworkDistributionProgram(parsed.networkProgram)
        return mpipeline.lowerNetworkDistributionPlanToMachine(bundle.lowPlan, targetTriple)
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        let bundle = cpipe.compileCompilerCoreSourceClosure(sourcePath)
        return mpipeline.lowerCompilerCorePlanToMachine(bundle.lowPlan, targetTriple, sourcePath)
    let bundle = upipe.compileUnimakerSurfaceProgram(parsed.unimakerProgram)
    return mpipeline.lowerUnimakerPlanToMachine(bundle.lowPlan, targetTriple)

fn buildCompilerCoreOutlineText(sourcePath: str): str =
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    let program = parsed.compilerCoreProgram
    var lines: str[]
    lines = []
    add(lines, "compiler_core_version=" + program.version)
    add(lines, "source=" + sourcePath)
    add(lines, "module_count=" + intToStr(program.modules.len))
    add(lines, "import_count=" + intToStr(program.imports.len))
    add(lines, "type_block_count=" + intToStr(program.typeBlocks.len))
    add(lines, "const_count=" + intToStr(program.constDecls.len))
    add(lines, "var_count=" + intToStr(program.varDecls.len))
    add(lines, "routine_count=" + intToStr(program.routines.len))
    add(lines, "top_level_count=" + intToStr(program.topLevelKinds.len))
    for i in 0..<program.modules.len:
        add(lines, "module." + intToStr(i) + ".name=" + program.modules[i].name)
        add(lines, "module." + intToStr(i) + ".header=" + program.modules[i].headerText)
    for i in 0..<program.imports.len:
        add(lines, "import." + intToStr(i) + ".path=" + program.imports[i].modulePath)
        add(lines, "import." + intToStr(i) + ".alias=" + program.imports[i].alias)
    for i in 0..<program.typeBlocks.len:
        add(lines, "type." + intToStr(i) + ".header=" + program.typeBlocks[i].headerText)
        add(lines, "type." + intToStr(i) + ".body_line_count=" + intToStr(program.typeBlocks[i].bodyLines.len))
    for i in 0..<program.constDecls.len:
        add(lines, "const." + intToStr(i) + ".label=" + program.constDecls[i].label)
        add(lines, "const." + intToStr(i) + ".header=" + program.constDecls[i].headerText)
        add(lines, "const." + intToStr(i) + ".body_line_count=" + intToStr(program.constDecls[i].bodyLines.len))
    for i in 0..<program.varDecls.len:
        add(lines, "var." + intToStr(i) + ".label=" + program.varDecls[i].label)
        add(lines, "var." + intToStr(i) + ".header=" + program.varDecls[i].headerText)
        add(lines, "var." + intToStr(i) + ".body_line_count=" + intToStr(program.varDecls[i].bodyLines.len))
    for i in 0..<program.routines.len:
        add(lines, "routine." + intToStr(i) + ".kind=" + program.routines[i].kind)
        add(lines, "routine." + intToStr(i) + ".name=" + program.routines[i].name)
        add(lines, "routine." + intToStr(i) + ".signature=" + program.routines[i].signatureText)
        add(lines, "routine." + intToStr(i) + ".body_line_count=" + intToStr(program.routines[i].bodyLines.len))
        var firstBodyLine: str = ""
        if program.routines[i].bodyLines.len > 0:
            firstBodyLine = program.routines[i].bodyLines[0]
        add(lines, "routine." + intToStr(i) + ".first_body_line=" + firstBodyLine)
    return mresolve.joinLines(lines)

fn buildSourceManifestArtifactText(bundle: mresolve.SourceManifestBundle): str =
    return bundle.manifestText + "\nmanifest_cid=" + bundle.manifestCid + "\n"

fn buildNetworkArtifactText(bundle: npipe.NetworkDistributionPipelineBundle,
                            requiredDomain: str,
                            artifactVersion: str): str =
    return ndident.buildPublishedNetworkArtifactText(bundle, requiredDomain, artifactVersion)

fn hasCanonicalOp(bundle: npipe.NetworkDistributionPipelineBundle, opName: str): bool =
    for i in 0..<bundle.lowPlan.canonicalOps.len:
        if bundle.lowPlan.canonicalOps[i] == opName:
            return true
    return false

fn verifyPriorityMappings(bundle: npipe.NetworkDistributionPipelineBundle): bool =
    for i in 0..<bundle.facts.priorityClasses.len:
        let expected = nsurf.networkPriorityTransport(bundle.facts.priorityClasses[i])
        if bundle.facts.transportModes[i] != expected:
            return false
    return true

fn canonicalOpCountForDomain(bundle: npipe.NetworkDistributionPipelineBundle, domain: str): int32 =
    var count: int32 = 0
    for i in 0..<bundle.facts.networkDomains.len:
        if bundle.facts.networkDomains[i] == domain:
            count = count + 1
    return count

fn releaseCompileKeyCoversNetworkBundle(releaseBundle: rart.ReleaseArtifactBundle,
                                        networkBundle: npipe.NetworkDistributionPipelineBundle): bool =
    for i in 0..<networkBundle.program.topologies.len:
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.topology." + intToStr(i) + "=" +
                                                  nsurf.topologyCanonicalForm(networkBundle.program.topologies[i])):
            return false
    for i in 0..<networkBundle.lowPlan.opIds.len:
        let binding = ndident.bindNetworkOpToLsmr(networkBundle, releaseBundle.manifestCid, i)
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".topology=" +
                                                  networkBundle.lowPlan.topologyCanonicalForms[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".addressing=" +
                                                  networkBundle.lowPlan.addressingModes[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".depth=" +
                                                  intToStr(networkBundle.lowPlan.topologyDepths[i])):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".address_binding=" +
                                                  networkBundle.lowPlan.addressBindings[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".distance_metric=" +
                                                  networkBundle.lowPlan.distanceMetrics[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".priority=" +
                                                  networkBundle.lowPlan.priorityClasses[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".dispersal=" +
                                                  networkBundle.lowPlan.dispersalModes[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".signature=" +
                                                  networkBundle.lowPlan.antiEntropySignatureKinds[i]):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".content_cid=" +
                                                  binding.contentCid):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".source_address=" +
                                                  binding.sourceAddressText):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".target_address=" +
                                                  binding.targetAddressText):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".route_plan_cid=" +
                                                  binding.routePlanCid):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".route_path_count=" +
                                                  intToStr(binding.routePathCount)):
            return false
        if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                  "network.entry." + intToStr(i) + ".total_distance=" +
                                                  intToStr(binding.totalDistance)):
            return false
        for j in 0..<binding.routePathCount:
            let pathLine = "path." + intToStr(j) + "="
            if parser.findText(binding.routePlanText, pathLine) < 0:
                return false
            let start = parser.findText(binding.routePlanText, pathLine)
            var stop = start
            while stop < len(binding.routePlanText) && binding.routePlanText[stop] != '\n':
                stop = stop + 1
            let rawLine = strings.sliceBytes(binding.routePlanText, start, stop - start)
            if !rart.releaseArtifactCompileKeyHasLine(releaseBundle,
                                                      "network.entry." + intToStr(i) + ".route." + intToStr(j) +
                                                      "=" + strings.sliceBytes(rawLine, len(pathLine), len(rawLine) - len(pathLine))):
                return false
    return true

fn runToolingSelfhostCheck(): int32 =
    let program = toolingProgramFromFlags()
    let stage1Text = toolingEmitStage1ModuleText(program)
    let stage1Program = toolingParseStage1ProgramText(stage1Text)
    let stage2Text = toolingEmitStage1ModuleText(stage1Program)
    let stage2Program = toolingParseStage1ProgramText(stage2Text)
    let stage0Result = toolingBuildStageResult(program)
    let stage1Result = toolingBuildStageResult(stage1Program)
    let stage2Result = toolingBuildStageResult(stage2Program)
    let stage0Stage1Equal = toolingStageResultsEqual(stage0Result, stage1Result)
    let stage1Stage2Equal = toolingStageResultsEqual(stage1Result, stage2Result)
    let stage1Stage2SourceEqual = stage1Text == stage2Text
    printLine("tooling_selfhost_stage0_hash=" + uint64HexLower16(stage0Result.stageHash))
    printLine("tooling_selfhost_stage1_hash=" + uint64HexLower16(stage1Result.stageHash))
    printLine("tooling_selfhost_stage2_hash=" + uint64HexLower16(stage2Result.stageHash))
    printLine("tooling_selfhost_proof_target=" + program.targetTriple)
    printLine("tooling_selfhost_stage0_stage1_equal=" + if stage0Stage1Equal: "1" else: "0")
    printLine("tooling_selfhost_stage1_stage2_equal=" + if stage1Stage2Equal: "1" else: "0")
    printLine("tooling_selfhost_stage1_stage2_source_equal=" + if stage1Stage2SourceEqual: "1" else: "0")
    if !stage0Result.report.ok:
        printLine("tooling_selfhost_ok=0")
        printLine("reason=" + stage0Result.report.reason)
        return 1
    printLine("tooling_selfhost_source_manifest_cid=" + stage0Result.report.sourceManifestCid)
    printLine("tooling_selfhost_rule_pack_cid=" + stage0Result.report.rulePackCid)
    printLine("tooling_selfhost_compiler_rule_pack_cid=" + stage0Result.report.compilerRulePackCid)
    printLine("tooling_selfhost_release_compile_key=" + stage0Result.report.releaseCompileKey)
    printLine("tooling_selfhost_obj_image_cid=" + stage0Result.report.objImageCid)
    printLine("tooling_selfhost_obj_section_count=" + intToStr(stage0Result.report.objSectionCount))
    printLine("tooling_selfhost_obj_symbol_count=" + intToStr(stage0Result.report.objSymbolCount))
    printLine("tooling_selfhost_obj_reloc_count=" + intToStr(stage0Result.report.objRelocCount))
    printLine("tooling_selfhost_topology_count=" + intToStr(stage0Result.report.topologyCount))
    printLine("tooling_selfhost_rule_pack_entry_count=" + intToStr(stage0Result.report.rulePackEntryCount))
    printLine("tooling_selfhost_compiler_rule_pack_entry_count=" + intToStr(stage0Result.report.compilerRulePackEntryCount))
    printLine("tooling_selfhost_priority_mapping_fixed=" + if stage0Result.report.lsmrPriorityMappingFixed: "1" else: "0")
    printLine("tooling_selfhost_lsmr_addressing_mode=" + stage0Result.report.lsmrAddressingMode)
    printLine("tooling_selfhost_lsmr_address_binding=" + stage0Result.report.lsmrAddressBinding)
    printLine("tooling_selfhost_lsmr_distance_metric=" + stage0Result.report.lsmrDistanceMetric)
    printLine("tooling_selfhost_lsmr_route_plan_model=" + stage0Result.report.lsmrRoutePlanModel)
    printLine("tooling_selfhost_compile_key_topology_covered=" + if stage0Result.report.compileKeyTopologyCovered: "1" else: "0")
    printLine("tooling_selfhost_compile_key_addressing_covered=" + if stage0Result.report.compileKeyAddressingCovered: "1" else: "0")
    printLine("tooling_selfhost_compile_key_depth_covered=" + if stage0Result.report.compileKeyDepthCovered: "1" else: "0")
    printLine("tooling_selfhost_compile_key_address_binding_covered=" + if stage0Result.report.compileKeyAddressBindingCovered: "1" else: "0")
    printLine("tooling_selfhost_compile_key_distance_metric_covered=" + if stage0Result.report.compileKeyDistanceMetricCovered: "1" else: "0")
    printLine("tooling_selfhost_compile_key_priority_covered=" + if stage0Result.report.compileKeyPriorityCovered: "1" else: "0")
    printLine("tooling_selfhost_compile_key_dispersal_covered=" + if stage0Result.report.compileKeyDispersalCovered: "1" else: "0")
    printLine("tooling_selfhost_compile_key_signature_covered=" + if stage0Result.report.compileKeySignatureCovered: "1" else: "0")
    printLine("tooling_selfhost_compile_key_canonical_multipath_covered=" + if stage0Result.report.compileKeyCanonicalMultipathCovered: "1" else: "0")
    printLine("tooling_selfhost_release_manifest_matches_source_manifest=" + if stage0Result.report.releaseManifestMatchesSourceManifest: "1" else: "0")
    printLine("tooling_selfhost_random_gossip_fallback_present=" + if stage0Result.report.randomGossipFallbackPresent: "1" else: "0")
    let ok = stage0Stage1Equal && stage1Stage2Equal && stage1Stage2SourceEqual
    printLine("tooling_selfhost_ok=" + if ok: "1" else: "0")
    return ok ? 0 : 1

fn runProgramSelfhostCheck(): int32 =
    let compilerPath = absolutePath(readFlagDefault("--compiler", currentCompilerPath()))
    let outDir = absolutePath(readFlagDefault("--out-dir", "v2/artifacts/full_selfhost/program_selfhost"))
    let targetTriple = readFlagDefault("--target", "arm64-apple-darwin")
    let compilerSource = "v2/src/tooling/cheng_v2.cheng"
    let lsmrAdvancedSource = "v2/cheng-quic/src/tests/lsmr_advanced_features_smoke.cheng"
    let chainStateSource = "v2/cheng-quic/src/tests/chain_state_tree_sync_smoke.cheng"
    let quicTlsEcdsaSource = "v2/cheng-quic/src/tests/quic_tls_transport_ecdsa_smoke.cheng"
    let msquicChainSource = "v2/cheng-quic/src/tests/msquic_chain_smoke.cheng"
    let chainNodeSource = "v2/cheng-quic/src/project/chain_node.cheng"
    let quicTlsEcdsaPrefixes = ["v2_quic_tls_transport_ecdsa_stage="]
    let msquicChainPrefixes = ["msquic_chain_smoke_alg_stage=",
                               "msquic_chain_smoke_stage=",
                               "msquic_native_dial_stage=",
                               "msquic_native_client_hello_stage=",
                               "msquic_native_server_flight_stage=",
                               "msquic_tls13_cert_verify_stage=",
                               "msquic_tls13_parse_stage=",
                               "msquic_native_client_finished_stage=",
                               "msquic_transport_dial_stage="]
    let stagesDir = joinPath2(outDir, "stages")
    let stage1Dir = joinPath2(stagesDir, "cheng_v2.stage1")
    let stage2Dir = joinPath2(stagesDir, "cheng_v2.stage2")
    let stage3Dir = joinPath2(stagesDir, "cheng_v2.stage3")
    let programsDir = joinPath2(outDir, "programs")
    let lsmrAdvancedBinary = joinPath2(programsDir, "lsmr_advanced_features_smoke_bin")
    let lsmrAdvancedStdoutPath = joinPath2(programsDir, "lsmr_advanced_features_smoke.stdout")
    let chainStateBinary = joinPath2(programsDir, "chain_state_tree_sync_smoke_bin")
    let chainStateStdoutPath = joinPath2(programsDir, "chain_state_tree_sync_smoke.stdout")
    let quicTlsEcdsaBinary = joinPath2(programsDir, "quic_tls_transport_ecdsa_smoke_bin")
    let quicTlsEcdsaStdoutPath = joinPath2(programsDir, "quic_tls_transport_ecdsa_smoke.stdout")
    let quicTlsEcdsaReportPath = joinPath2(programsDir, "quic_tls_transport_ecdsa_smoke.report.txt")
    let msquicChainBinary = joinPath2(programsDir, "msquic_chain_smoke_bin")
    let msquicChainStdoutPath = joinPath2(programsDir, "msquic_chain_smoke.stdout")
    let msquicChainReportPath = joinPath2(programsDir, "msquic_chain_smoke.report.txt")
    let chainNodeBinary = joinPath2(programsDir, "chain_node_bin")
    let chainNodeZeroRoot = joinPath2(programsDir, "chain_node_zero_root")
    let chainNodeMintRoot = joinPath2(programsDir, "chain_node_mint_root")
    let chainNodeProcessStdoutPath = joinPath2(programsDir, "chain_node_process_smoke.stdout")
    removeTree(outDir)
    createDirAll(stage1Dir)
    createDirAll(stage2Dir)
    createDirAll(stage3Dir)
    createDirAll(programsDir)
    removeTree(chainNodeZeroRoot)
    removeTree(chainNodeMintRoot)

    let stage1 = buildStageArtifacts(compilerPath, compilerSource, targetTriple, stage1Dir, "cheng_v2")
    let stage2 = buildStageArtifacts(stage1.binaryPath, compilerSource, targetTriple, stage2Dir, "cheng_v2")
    let stage3 = buildStageArtifacts(stage2.binaryPath, compilerSource, targetTriple, stage3Dir, "cheng_v2")
    let releaseEqual = compareTextFiles(stage2.releasePath, stage3.releasePath)
    let planEqual = compareTextFiles(stage2.systemLinkPlanPath, stage3.systemLinkPlanPath)
    let execEqual = compareTextFiles(stage2.systemLinkExecPath, stage3.systemLinkExecPath)
    let binaryEqual = compareBinaryFiles(stage2.binaryPath, stage3.binaryPath)
    let outputCidEqual = stage2.outputFileCid == stage3.outputFileCid
    let noExternalCProvider = stage1.externalCcProviderCount == 0 &&
                              stage2.externalCcProviderCount == 0 &&
                              stage3.externalCcProviderCount == 0 &&
                              stage2.compilerCoreProviderSourceKind == "cheng_module" &&
                              stage2.compilerCoreProviderCompileMode == "machine_obj"
    var quicTlsEcdsaStageTotal: int32 = 0
    var msquicChainStageTotal: int32 = 0

    buildProgramBinaryOrPanic(stage2.binaryPath,
                              lsmrAdvancedSource,
                              targetTriple,
                              lsmrAdvancedBinary,
                              "program selfhost: lsmr advanced smoke compile failed")
    let lsmrAdvancedStdout = runBinaryCaptureOrPanic(lsmrAdvancedBinary,
                                                     [],
                                                     "program selfhost: lsmr advanced smoke run failed",
                                                     toolingProgramRunTimeoutDefaultSec)
    writeTextFile(lsmrAdvancedStdoutPath, lsmrAdvancedStdout)
    compareExpectedTextOrPanic("v2/tests/contracts/lsmr_advanced_features_smoke.expected",
                               lsmrAdvancedStdoutPath,
                               "program selfhost: lsmr advanced smoke mismatch")
    let lsmrAdvancedOk = true

    buildProgramBinaryOrPanic(stage2.binaryPath,
                              chainStateSource,
                              targetTriple,
                              chainStateBinary,
                              "program selfhost: chain state tree sync smoke compile failed")
    let chainStateStdout = runBinaryCaptureOrPanic(chainStateBinary,
                                                   [],
                                                   "program selfhost: chain state tree sync smoke run failed",
                                                   toolingProgramRunTimeoutDefaultSec)
    writeTextFile(chainStateStdoutPath, chainStateStdout)
    compareExpectedTextOrPanic("v2/tests/contracts/chain_state_tree_sync_smoke.expected",
                               chainStateStdoutPath,
                               "program selfhost: chain state tree sync smoke mismatch")
    let chainStateOk = true

    buildProgramBinaryOrPanic(stage2.binaryPath,
                              quicTlsEcdsaSource,
                              targetTriple,
                              quicTlsEcdsaBinary,
                              "program selfhost: quic tls transport ecdsa smoke compile failed")
    let quicTlsEcdsaStdout = runBinaryCaptureOrPanic(quicTlsEcdsaBinary,
                                                     [],
                                                     "program selfhost: quic tls transport ecdsa smoke run failed",
                                                     toolingProgramRunTimeoutNetworkSmokeSec)
    writeTextFile(quicTlsEcdsaStdoutPath, quicTlsEcdsaStdout)
    compareExpectedTextOrPanic("v2/tests/contracts/quic_tls_transport_ecdsa_smoke.expected",
                               quicTlsEcdsaStdoutPath,
                               "program selfhost: quic tls transport ecdsa smoke mismatch")
    writeTextFile(quicTlsEcdsaReportPath,
                  buildNetworkSmokeReportText("quic_tls_transport_ecdsa_smoke",
                                              quicTlsEcdsaStdoutPath,
                                              quicTlsEcdsaPrefixes,
                                              quicTlsEcdsaStdout,
                                              quicTlsEcdsaStageTotal))
    let quicTlsEcdsaOk = true

    buildProgramBinaryOrPanic(stage2.binaryPath,
                              msquicChainSource,
                              targetTriple,
                              msquicChainBinary,
                              "program selfhost: msquic chain smoke compile failed")
    let msquicChainStdout = runBinaryCaptureOrPanic(msquicChainBinary,
                                                    [],
                                                    "program selfhost: msquic chain smoke run failed",
                                                    toolingProgramRunTimeoutNetworkSmokeSec)
    writeTextFile(msquicChainStdoutPath, msquicChainStdout)
    compareExpectedTextOrPanic("v2/tests/contracts/msquic_chain_smoke.expected",
                               msquicChainStdoutPath,
                               "program selfhost: msquic chain smoke mismatch")
    writeTextFile(msquicChainReportPath,
                  buildNetworkSmokeReportText("msquic_chain_smoke",
                                              msquicChainStdoutPath,
                                              msquicChainPrefixes,
                                              msquicChainStdout,
                                              msquicChainStageTotal))
    let msquicChainOk = true

    buildProgramBinaryOrPanic(stage2.binaryPath,
                              chainNodeSource,
                              targetTriple,
                              chainNodeBinary,
                              "program selfhost: chain node compile failed")
    let chainNodeBuildOk = true

    let chainNodeZeroBalanceStdout = runBinaryCaptureOrPanic(chainNodeBinary,
                                                             ["balance",
                                                              "--root", chainNodeZeroRoot,
                                                              "--node-id", "program-selfhost-zero",
                                                              "--account", "alice",
                                                              "--asset", "cheng"],
                                                             "program selfhost: chain node zero balance failed",
                                                             toolingProgramRunTimeoutChainNodeSec)
    let chainNodeZeroBalance = extractLineValue(chainNodeZeroBalanceStdout, "balance")
    let chainNodeZeroBalanceOk = chainNodeZeroBalance == "0"
    if !chainNodeZeroBalanceOk:
        system.panic("program selfhost: chain node zero balance mismatch")

    let chainNodeMintStdout = runBinaryCaptureOrPanic(chainNodeBinary,
                                                      ["mint",
                                                       "--root", chainNodeMintRoot,
                                                       "--node-id", "program-selfhost-mint",
                                                       "--account", "alice",
                                                       "--asset", "cheng",
                                                       "--amount", "11"],
                                                      "program selfhost: chain node mint failed",
                                                      toolingProgramRunTimeoutChainNodeSec)
    let chainNodeMintEventCid = extractLineValue(chainNodeMintStdout, "event_cid")
    let chainNodeMintOk = len(chainNodeMintEventCid) > 0
    if !chainNodeMintOk:
        system.panic("program selfhost: chain node mint output missing event_cid")

    let chainNodeAfterMintBalanceStdout = runBinaryCaptureOrPanic(chainNodeBinary,
                                                                  ["balance",
                                                                   "--root", chainNodeMintRoot,
                                                                   "--node-id", "program-selfhost-mint",
                                                                   "--account", "alice",
                                                                   "--asset", "cheng"],
                                                                  "program selfhost: chain node minted balance failed",
                                                                  toolingProgramRunTimeoutChainNodeSec)
    let chainNodeAfterMintBalance = extractLineValue(chainNodeAfterMintBalanceStdout, "balance")
    let chainNodeAfterMintBalanceOk = chainNodeAfterMintBalance == "11"
    if !chainNodeAfterMintBalanceOk:
        system.panic("program selfhost: chain node minted balance mismatch")

    let chainNodeProcessStdout = runChainNodeProcessSmokeCaptureOrPanic(chainNodeBinary,
                                                                        programsDir,
                                                                        "program selfhost: chain node process smoke failed")
    writeTextFile(chainNodeProcessStdoutPath, chainNodeProcessStdout)
    compareExpectedTextOrPanic("v2/tests/contracts/chain_node_process_smoke.expected",
                               chainNodeProcessStdoutPath,
                               "program selfhost: chain node process smoke mismatch")
    let chainNodeProcessSyncOutput = extractLineValue(chainNodeProcessStdout, "sync_output")
    let chainNodeProcessBalanceOutput = extractLineValue(chainNodeProcessStdout, "balance_output")
    let chainNodeProcessServerOutput = extractLineValue(chainNodeProcessStdout, "server_output")
    let chainNodeProcessOk = len(chainNodeProcessSyncOutput) > 0 &&
                             len(chainNodeProcessBalanceOutput) > 0 &&
                             len(chainNodeProcessServerOutput) > 0
    if !chainNodeProcessOk:
        system.panic("program selfhost: chain node process smoke output missing required line")

    let ok = releaseEqual &&
             planEqual &&
             execEqual &&
             binaryEqual &&
             outputCidEqual &&
             noExternalCProvider &&
             lsmrAdvancedOk &&
             chainStateOk &&
             quicTlsEcdsaOk &&
             msquicChainOk &&
             chainNodeBuildOk &&
             chainNodeZeroBalanceOk &&
             chainNodeMintOk &&
             chainNodeAfterMintBalanceOk &&
             chainNodeProcessOk
    printLine("program_selfhost_ok=" + if ok: "1" else: "0")
    printLine("compiler=" + compilerPath)
    printLine("stage1_binary_cid=" + stage1.binaryCid)
    printLine("stage2_binary_cid=" + stage2.binaryCid)
    printLine("stage3_binary_cid=" + stage3.binaryCid)
    printLine("stage2_stage3_release_equal=" + if releaseEqual: "1" else: "0")
    printLine("stage2_stage3_system_link_plan_equal=" + if planEqual: "1" else: "0")
    printLine("stage2_stage3_system_link_exec_equal=" + if execEqual: "1" else: "0")
    printLine("stage2_stage3_binary_equal=" + if binaryEqual: "1" else: "0")
    printLine("stage2_stage3_output_file_cid_equal=" + if outputCidEqual: "1" else: "0")
    printLine("stage1_external_cc_provider_count=" + intToStr(stage1.externalCcProviderCount))
    printLine("stage2_external_cc_provider_count=" + intToStr(stage2.externalCcProviderCount))
    printLine("stage3_external_cc_provider_count=" + intToStr(stage3.externalCcProviderCount))
    printLine("compiler_core_provider_source_kind=" + stage2.compilerCoreProviderSourceKind)
    printLine("compiler_core_provider_compile_mode=" + stage2.compilerCoreProviderCompileMode)
    printLine("stage2_lsmr_advanced_smoke_ok=1")
    printLine("stage2_chain_state_tree_sync_smoke_ok=1")
    printLine("stage2_quic_tls_transport_ecdsa_smoke_ok=1")
    printLine("stage2_quic_tls_transport_ecdsa_report_version=v2_network_smoke_report_v1")
    printLine("stage2_quic_tls_transport_ecdsa_report_path=" + quicTlsEcdsaReportPath)
    printLine("stage2_quic_tls_transport_ecdsa_stage_total=" + intToStr(quicTlsEcdsaStageTotal))
    printLine("stage2_msquic_chain_smoke_ok=1")
    printLine("stage2_msquic_chain_report_version=v2_network_smoke_report_v1")
    printLine("stage2_msquic_chain_report_path=" + msquicChainReportPath)
    printLine("stage2_msquic_chain_stage_total=" + intToStr(msquicChainStageTotal))
    printLine("stage2_chain_node_build_ok=1")
    printLine("stage2_chain_node_zero_balance=" + chainNodeZeroBalance)
    printLine("stage2_chain_node_mint_event_cid_present=" + if chainNodeMintOk: "1" else: "0")
    printLine("stage2_chain_node_balance_after_mint=" + chainNodeAfterMintBalance)
    printLine("stage2_chain_node_process_smoke_ok=" + if chainNodeProcessOk: "1" else: "0")
    printLine("stage2_chain_node_process_shell_orchestration=0")
    printLine("stage2_program_runtime_bridge_shell_exec_used=0")
    printLine("stage2_chain_node_sync_once_output=" + chainNodeProcessSyncOutput)
    printLine("stage2_chain_node_sync_balance_output=" + chainNodeProcessBalanceOutput)
    printLine("stage2_chain_node_serve_once_output=" + chainNodeProcessServerOutput)
    return ok ? 0 : 1

fn isEmptyText(text: str): bool =
    return len(text) == 0

fn printMissingCid(): void =
    printLine("missing --cid")

fn printMissingCidAndFail(): int32 =
    printMissingCid()
    return 1

fn writeLsmrAddressArtifact(cid: str, depth: int32): void =
    writeText(lsmr.buildLsmrAddressArtifactText(cid, depth))

fn writeLsmrAddressZero(cid: str, depth: int32): int32 =
    writeLsmrAddressArtifact(cid, depth)
    return 0

fn runLsmrAddressDepth(): int32 =
    return readIntFlagDefault("--depth", 4)

fn writeLsmrAddressZeroFlipped(depth: int32, cid: str): int32 =
    return writeLsmrAddressZero(cid, depth)

fn runLsmrAddressPresent(cid: str): int32 =
    return writeLsmrAddressZeroFlipped(runLsmrAddressDepth(), cid)

fn runLsmrAddressWithCid(cid: str): int32 =
    if isEmptyText(cid):
        return printMissingCidAndFail()
    else:
        return runLsmrAddressPresent(cid)

fn writeLsmrRoutePlanArtifact(cid: str, depth: int32, priorityClass: str, dispersalMode: str): void =
    writeText(lsmr.buildLsmrRoutePlanArtifactText(cid, depth, priorityClass, dispersalMode))

fn writeLsmrRoutePlanZero(cid: str, depth: int32, priorityClass: str, dispersalMode: str): int32 =
    writeLsmrRoutePlanArtifact(cid, depth, priorityClass, dispersalMode)
    return 0

fn runLsmrRoutePlanDepth(): int32 =
    return readIntFlagDefault("--depth", 4)

fn runLsmrRoutePlanPriority(): str =
    return readFlagDefault("--priority", "urgent")

fn runLsmrRoutePlanDispersal(): str =
    return readFlagDefault("--dispersal", "none")

fn writeLsmrRoutePlanZeroFlipped(dispersalMode: str, priorityClass: str, depth: int32, cid: str): int32 =
    return writeLsmrRoutePlanZero(cid, depth, priorityClass, dispersalMode)

fn runLsmrRoutePlanWithPriority(priorityClass: str, depth: int32, cid: str): int32 =
    return writeLsmrRoutePlanZeroFlipped(runLsmrRoutePlanDispersal(), priorityClass, depth, cid)

fn runLsmrRoutePlanWithDepth(depth: int32, cid: str): int32 =
    return runLsmrRoutePlanWithPriority(runLsmrRoutePlanPriority(), depth, cid)

fn runLsmrRoutePlanPresent(cid: str): int32 =
    return runLsmrRoutePlanWithDepth(runLsmrRoutePlanDepth(), cid)

fn runLsmrRoutePlanWithCid(cid: str): int32 =
    if isEmptyText(cid):
        return printMissingCidAndFail()
    else:
        return runLsmrRoutePlanPresent(cid)

fn runLsmrAddress(): int32 =
    return runLsmrAddressWithCid(readCidFlag())

fn runLsmrRoutePlan(): int32 =
    return runLsmrRoutePlanWithCid(readCidFlag())

