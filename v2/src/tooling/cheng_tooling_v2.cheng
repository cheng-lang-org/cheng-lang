fn runSystemLinkExec(): int32 =
    let sourcePath = readFlagDefault("--in", "v2/src/tooling/cheng_tooling_v2.cheng")
    let emitKind = readFlagDefault("--emit", "exe")
    let targetTriple = readFlagDefault("--target", mtarget.machineTargetContract().firstClassTargets[0])
    let outPath = readFlagDefault("--out", "")
    let reportOut = readFlagDefault("--report-out", "")
    let bundle = sexec.buildSystemLinkExec(sourcePath, emitKind, targetTriple, outPath)
