fn runVerifyNetworkSelfhost(): int32 =
    let root = readFlagDefault("--root", "v2/examples")
    let sourcePath = readFlagDefault("--in", "v2/examples/network_distribution_module.cheng")
    let manifestBundle = mresolve.resolveSourceManifest(root)
    let networkBundle = networkBundleFromSource(sourcePath)
    let releaseBundle = rart.buildReleaseArtifact(sourcePath, "exe", mtarget.machineTargetContract().firstClassTargets[0])
    let rulePackOpCount = canonicalOpCountForDomain(networkBundle, "rule_pack")
    let compilerRulePackOpCount = canonicalOpCountForDomain(networkBundle, "compiler_rule_pack")
    let hasPublishSourceManifestOp = hasCanonicalOp(networkBundle, "publish_source_manifest")
    let hasPublishRulePackOp = hasCanonicalOp(networkBundle, "publish_rule_pack")
    let hasPublishCompilerRulePackOp = hasCanonicalOp(networkBundle, "publish_compiler_rule_pack")
    if manifestBundle.topologyCanonicalForms.len <= 0:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_topology_canonical_form")
        return 1
    if !verifyPriorityMappings(networkBundle):
        printLine("network_selfhost_ok=0")
        printLine("reason=priority_mapping_mismatch")
        return 1
    if !hasPublishSourceManifestOp:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_publish_ops")
        return 1
    if !hasPublishRulePackOp:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_publish_ops")
        return 1
    if !hasPublishCompilerRulePackOp:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_publish_ops")
        return 1
    if rulePackOpCount <= 0:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_rule_pack_domain_ops")
        return 1
    if compilerRulePackOpCount <= 0:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_compiler_rule_pack_domain_ops")
        return 1
    if releaseBundle.moduleKind != "network_distribution":
        printLine("network_selfhost_ok=0")
        printLine("reason=release_artifact_wrong_module_kind")
        return 1
    if releaseBundle.manifestCid != manifestBundle.manifestCid:
        printLine("network_selfhost_ok=0")
        printLine("reason=release_manifest_mismatch")
        return 1
    if !releaseCompileKeyCoversNetworkBundle(releaseBundle, networkBundle):
        printLine("network_selfhost_ok=0")
        printLine("reason=compile_key_missing_network_fields")
        return 1
    if !releaseBundle.nativeLinkClosureOk:
        printLine("network_selfhost_ok=0")
        printLine("reason=native_link_closure_unresolved")
        return 1
    let rulePackText = buildNetworkArtifactText(networkBundle, "rule_pack", "v2.rule_pack.v1")
    let compilerRulePackText = buildNetworkArtifactText(networkBundle, "compiler_rule_pack", "v2.compiler_rule_pack.v1")
    printLine("network_selfhost_ok=1")
    printLine("source_manifest_cid=" + manifestBundle.manifestCid)
    printLine("rule_pack_cid=" + ident.sha256HexText(rulePackText))
    printLine("compiler_rule_pack_cid=" + ident.sha256HexText(compilerRulePackText))
    printLine("release_compile_key=" + releaseBundle.compileKey)
    printLine("obj_image_cid=" + releaseBundle.objImageCid)
    printLine("obj_section_count=" + intToStr(releaseBundle.objSectionCount))
    printLine("obj_symbol_count=" + intToStr(releaseBundle.objSymbolCount))
    printLine("obj_reloc_count=" + intToStr(releaseBundle.objRelocCount))
    printLine("link_plan_cid=" + releaseBundle.linkPlanCid)
    printLine("runtime_target_count=" + intToStr(releaseBundle.runtimeTargetCount))
    printLine("runtime_unresolved_count=" + intToStr(releaseBundle.runtimeUnresolvedCount))
    printLine("native_link_closure_ok=1")
    printLine("topology_count=" + intToStr(manifestBundle.topologyCanonicalForms.len))
    printLine("rule_pack_entry_count=" + intToStr(rulePackOpCount))
    printLine("compiler_rule_pack_entry_count=" + intToStr(compilerRulePackOpCount))
    printLine("publish_source_manifest_present=1")
    printLine("publish_rule_pack_present=1")
    printLine("publish_compiler_rule_pack_present=1")
    printLine("lsmr_priority_mapping_fixed=1")
    printLine("lsmr_addressing_mode=" + lcontract.lsmrRuntimeContract().addressingMode)
    printLine("lsmr_address_binding=" + lcontract.lsmrRuntimeContract().addressBinding)
    printLine("lsmr_distance_metric=" + lcontract.lsmrRuntimeContract().distanceMetric)
    printLine("lsmr_route_plan_model=" + lcontract.lsmrRuntimeContract().routePlanModel)
    printLine("compile_key_topology_covered=1")
    printLine("compile_key_addressing_covered=1")
    printLine("compile_key_depth_covered=1")
    printLine("compile_key_address_binding_covered=1")
    printLine("compile_key_distance_metric_covered=1")
    printLine("compile_key_priority_covered=1")
    printLine("compile_key_dispersal_covered=1")
    printLine("compile_key_signature_covered=1")
    printLine("compile_key_canonical_multipath_covered=1")
    printLine("release_manifest_matches_source_manifest=1")
    printLine("random_gossip_fallback_present=0")
    return 0

fn runVerifyCompilerCoreZrpcSurface(): int32 =
    let rootPath = readFlagDefault("--root", ".")
    let outPath = readFlagDefault("--out", "")
    let specs = compilerCoreZrpcProbeSpecs()
    var lines: str[] = []
    var ok: bool = true
    var passCount: int32 = 0
    var failCount: int32 = 0
    var mismatchCount: int32 = 0
    add(lines, "zrpc_surface_version=v1")
    add(lines, "sample_count=" + intToStr(specs.len))
    for i in 0..<specs.len:
        let violation = compilerCoreProbeFirstNoPointerViolation(rootPath, specs[i].sourcePath)
        let actualPass = len(violation) <= 0
        let sampleOk = actualPass == specs[i].expectPass
        if actualPass:
            passCount = passCount + 1
        else:
            failCount = failCount + 1
        if !sampleOk:
            mismatchCount = mismatchCount + 1
            ok = false
        add(lines, "sample." + intToStr(i) + ".id=" + specs[i].sampleId)
        add(lines, "sample." + intToStr(i) + ".path=" + specs[i].sourcePath)
        add(lines, "sample." + intToStr(i) + ".expected=" + if specs[i].expectPass: "pass" else: "fail")
        add(lines, "sample." + intToStr(i) + ".actual=" + if actualPass: "pass" else: "fail")
        add(lines, "sample." + intToStr(i) + ".ok=" + if sampleOk: "1" else: "0")
        add(lines, "sample." + intToStr(i) + ".reason=" + if actualPass: "" else: violation)
    add(lines, "pass_count=" + intToStr(passCount))
    add(lines, "fail_count=" + intToStr(failCount))
    add(lines, "mismatch_count=" + intToStr(mismatchCount))
    add(lines, "zrpc_surface_ok=" + if ok: "1" else: "0")
    let text = mresolve.joinLines(lines)
    writeOptionalTextFile(outPath, text)
    writeText(text + "\n")
    return if ok: 0 else: 1

