fn defaultSourceManifestOut(sourcePath: str): str =
    let parts = os.splitFile(sourcePath)
    return os.joinPath("v2/artifacts/release", parts.name + ".source_manifest.txt")

fn runResolveManifest(): int32 =
    let sourcePath = readFlagDefault("--in", "")
    let root = readFlagDefault("--root", "v2/examples")
    let outPath = readFlagDefault("--out", "")
    var bundle: mresolve.SourceManifestBundle
    if len(sourcePath) > 0:
        bundle = mresolve.resolveCompilerCoreSourceManifest(sourcePath)
    else:
        bundle = mresolve.resolveSourceManifest(root)
    let text = buildSourceManifestArtifactText(bundle)
    if len(outPath) > 0:
        writeTextFile(outPath, text)
    writeText(text)
    return 0

