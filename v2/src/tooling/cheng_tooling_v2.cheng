    writeText(lsmr.buildLsmrRoutePlanArtifactText(cid, depth, priorityClass, dispersalMode))

fn writeLsmrRoutePlanZero(cid: str, depth: int32, priorityClass: str, dispersalMode: str): int32 =
    writeLsmrRoutePlanArtifact(cid, depth, priorityClass, dispersalMode)
    return 0

fn runLsmrAddress(): int32 =
    let cid = readFlagDefault("--cid", "")
    let depth = readIntFlagDefault("--depth", 4)
