fn edgeKindIndex(edgeKindOrder: str[], edgeKind: str): int32 =
    for i in 0..<edgeKindOrder.len:
        if edgeKindOrder[i] == edgeKind:
            return i
    return -1

fn edgePlanePairCounts(lowNodeIdsRaw: str,
                       lowPlanesRaw: str,
                       edgeNodeIdsRaw: str,
                       targetPlanesRaw: str,
                       planeOrder: str[]): int32[] =
    let lowNodeIds = jsonArrayIntValues(lowNodeIdsRaw)
    let lowPlanes = jsonArrayStringValues(lowPlanesRaw)
    let edgeNodeIds = jsonArrayIntValues(edgeNodeIdsRaw)
    let targetPlanes = jsonArrayStringValues(targetPlanesRaw)
    if lowNodeIds.len != lowPlanes.len:
        system.panic("taiji: low_uir plane map length mismatch")
    if edgeNodeIds.len != targetPlanes.len:
        system.panic("taiji: validated edge plane length mismatch")
    var out: int32[]
    out = []
    for i in 0..<planeOrder.len * planeOrder.len:
        add(out, 0)
    for i in 0..<edgeNodeIds.len:
        var sourcePlane: str = ""
        for j in 0..<lowNodeIds.len:
            if lowNodeIds[j] == edgeNodeIds[i]:
                sourcePlane = lowPlanes[j]
                break
        if len(sourcePlane) <= 0:
            system.panic("taiji: missing low_uir plane for edge node " + intToStr(edgeNodeIds[i]))
        let leftIdx = planeIndex(planeOrder, sourcePlane)
        let rightIdx = planeIndex(planeOrder, targetPlanes[i])
        if leftIdx < 0 || rightIdx < 0:
            system.panic("taiji: unknown plane pair " + sourcePlane + " -> " + targetPlanes[i])
        out[leftIdx * planeOrder.len + rightIdx] = out[leftIdx * planeOrder.len + rightIdx] + 1
    return out

fn semanticEdgeFamilyCounts(lowNodeIds: int32[],
                            lowPlanes: str[],
                            edgeNodeIds: int32[],
                            targetPlanes: str[],
                            edgeKinds: str[],
                            edgeKindOrder: str[],
                            planeOrder: str[]): int32[] =
    if lowNodeIds.len != lowPlanes.len:
        system.panic("taiji: low_uir plane map length mismatch")
    if edgeNodeIds.len != targetPlanes.len || edgeNodeIds.len != edgeKinds.len:
        system.panic("taiji: semantic edge family length mismatch")
    let planePairCount = planeOrder.len * planeOrder.len
    var out: int32[]
    out = []
    for i in 0..<edgeKindOrder.len * planePairCount:
        add(out, 0)
    for i in 0..<edgeNodeIds.len:
        let nodeIdx = baguaAnnotationIndexForNode(lowNodeIds, edgeNodeIds[i])
        if nodeIdx < 0:
            system.panic("taiji: missing low_uir plane for semantic edge node " + intToStr(edgeNodeIds[i]))
        let edgeKindIdx = edgeKindIndex(edgeKindOrder, edgeKinds[i])
        let leftIdx = planeIndex(planeOrder, lowPlanes[nodeIdx])
        let rightIdx = planeIndex(planeOrder, targetPlanes[i])
        if edgeKindIdx < 0 || leftIdx < 0 || rightIdx < 0:
            system.panic("taiji: unknown semantic edge family " + edgeKinds[i] + "|" + lowPlanes[nodeIdx] + "->" + targetPlanes[i])
        let familyIdx = edgeKindIdx * planePairCount + leftIdx * planeOrder.len + rightIdx
        out[familyIdx] = out[familyIdx] + 1
    return out

fn repeatStringArray(value: str, count: int32): str[] =
    var out: str[]
    out = []
    for i in 0..<count:
        add(out, value)
    return out

fn prefixStringArray(values: str[], prefix: str): str[] =
    var out: str[]
    out = []
    for i in 0..<values.len:
        add(out, prefix + values[i])
    return out

fn semanticProofFamilyPrefix(assumption: str): str =
    for i in 0..<len(assumption):
        if assumption[i] == '|':
            return srun.sliceView(assumption, 0, i)
    system.panic("taiji: missing semantic proof family prefix in assumption " + assumption)

fn semanticProofFamilyLastDotSegment(assumption: str): str =
    var lastDot = -1
    for i in 0..<len(assumption):
        if assumption[i] == '.':
            lastDot = i
    if lastDot < 0 || lastDot + 1 >= len(assumption):
        system.panic("taiji: missing semantic proof family tail in assumption " + assumption)
    return srun.sliceView(assumption, lastDot + 1, len(assumption))

fn semanticPhaseEdgeKind(sourceKind: str, reason: str): str =
    if sourceKind == "string":
        return "lowers_to"
    if sourceKind == "compiler_core":
        return "lowers_to/compiler_core/" + semanticProofFamilyPrefix(reason)
    if sourceKind == "unimaker":
        return "lowers_to/unimaker/" + semanticProofFamilyPrefix(reason)
    if sourceKind == "network_distribution":
        return "lowers_to/network_distribution/" + semanticProofFamilyPrefix(reason)
    system.panic("taiji: unsupported semantic phase source kind " + sourceKind)

fn semanticPhaseEdgeKinds(reasons: str[], sourceKind: str): str[] =
    var out: str[]
    out = []
    for i in 0..<reasons.len:
        add(out, semanticPhaseEdgeKind(sourceKind, reasons[i]))
    return out

fn semanticProofEdgeKind(proofKind: str, sourceKind: str, assumption: str): str =
    if proofKind == "effect" && sourceKind == "compiler_core":
        return "gates/effect/compiler_core/" + semanticProofFamilyPrefix(assumption)
    if proofKind == "effect" && sourceKind == "unimaker":
        return "gates/effect/unimaker/" + semanticProofFamilyLastDotSegment(assumption)
    if proofKind == "effect" && sourceKind == "network_distribution":
        return "gates/effect/network_distribution/" + semanticProofFamilyLastDotSegment(assumption)
    if proofKind == "effect":
        return "gates/effect/" + sourceKind
    if proofKind == "layout" && sourceKind == "compiler_core":
        return "gates/layout/compiler_core/" + semanticProofFamilyPrefix(assumption)
    if proofKind == "layout" && sourceKind == "network_distribution":
        return "gates/layout/network_distribution/" + semanticProofFamilyPrefix(assumption)
    if proofKind == "layout":
        return "gates/layout/" + sourceKind
    if proofKind == "bounds":
        return "gates/bounds/" + sourceKind
    if proofKind == "ownership" && sourceKind == "unimaker":
        return "gates/ownership/unimaker/" + assumption
    if proofKind == "ownership" && sourceKind == "network_distribution":
        return "gates/ownership/network_distribution/" + assumption
    if proofKind == "ownership":
        return "gates/ownership/" + sourceKind
    return "gates/" + proofKind

fn semanticProofEdgeKinds(proofKinds: str[], assumptions: str[], sourceKind: str): str[] =
    if proofKinds.len != assumptions.len:
        system.panic("taiji: semantic proof edge kind length mismatch")
    var out: str[]
    out = []
    for i in 0..<proofKinds.len:
        add(out, semanticProofEdgeKind(proofKinds[i], sourceKind, assumptions[i]))
    return out

fn addCountVectors(left: int32[], right: int32[]): int32[] =
    if left.len != right.len:
        system.panic("taiji: count vector length mismatch")
    var out: int32[]
    out = []
    for i in 0..<left.len:
        add(out, left[i] + right[i])
    return out

fn countLiteralOccurrences(text: str, needle: str): int32 =
    if len(needle) <= 0 || len(text) < len(needle):
        return 0
    var out: int32 = 0
    var i: int32 = 0
    while i + len(needle) <= len(text):
        let window = srun.sliceView(text, i, i + len(needle))
        if window == needle:
            out = out + 1
            i = i + len(needle)
        else:
            i = i + 1
    return out

fn jsonInlineCountObject(keys: str[], counts: int32[]): str =
    var fields: str[]
    fields = []
    for i in 0..<keys.len:
        add(fields, jsonInlineFieldRaw(keys[i], intToStr(counts[i])))
    return jsonInlineObject(fields)

fn countQuotedNames(rawArray: str, names: str[]): int32[] =
    var out: int32[]
    out = []
    for i in 0..<names.len:
        add(out, countLiteralOccurrences(rawArray, jsonQuote(names[i])))
    return out

fn countTrueValues(rawArray: str): int32 =
    return countLiteralOccurrences(rawArray, "true")

fn taijiSeedProfilePath(outDir: str, sampleId: str): str =
    return taijiSeedSamplePath(outDir, sampleId, "taiji_profile_report.json")

fn taijiProfileDocument(sourcePath: str,
                        sourceLabel: str,
                        sourceKind: str,
                        astDoc: TaijiDocument,
                        lowDoc: TaijiDocument,
                        traceDoc: TaijiDocument,
                        proofDoc: TaijiDocument): TaijiDocument =
    let passHintGroupOrder = ["none", "cfg_proof", "layout_sroa", "side_effect_ordering", "loop_vector_worklist"]
    let planeOrder = ["P1=乾坤", "P2=坎离", "P3=艮兑", "P4=震巽"]
    let trigramOrder = ["乾", "坤", "坎", "离", "艮", "兑", "震", "巽"]
    let trigramAsciiOrder = ["qian", "kun", "kan", "li", "gen", "dui", "zhen", "xun"]
    let proofKindOrder = ["effect", "alias", "bounds", "layout", "ownership"]
    let astNodeIds = jsonDocFieldRaw(astDoc.text, "node_ids")
    let lowNodeIds = jsonDocFieldRaw(lowDoc.text, "node_ids")
    let lowPlanes = jsonDocFieldRaw(lowDoc.text, "bagua_plane")
    let phaseEvents = jsonDocFieldRaw(traceDoc.text, "event_ids")
    let phaseLowUirNodeIds = jsonDocFieldRaw(traceDoc.text, "low_uir_node_ids")
    let phasePlanes = jsonDocFieldRaw(traceDoc.text, "plane")
    let phaseTrigrams = jsonDocFieldRaw(traceDoc.text, "trigrams")
    let proofTasks = jsonDocFieldRaw(proofDoc.text, "task_ids")
    let proofTargets = jsonDocFieldRaw(proofDoc.text, "targets")
    let proofKinds = jsonDocFieldRaw(proofDoc.text, "kinds")
    let proofGatePlanes = jsonDocFieldRaw(proofDoc.text, "bagua_gate_plane")
    let proofCheckerResults = jsonDocFieldRaw(proofDoc.text, "checker_results")
    let passHintGroups = jsonDocFieldRaw(lowDoc.text, "bagua_pass_hint_group")
    let astMatrixCounts = jsonDocFieldRaw(astDoc.text, "bagua_matrix_counts")
    let astMatrixWeights = jsonDocFieldRaw(astDoc.text, "bagua_matrix_weights")
    let lowMatrixCounts = jsonDocFieldRaw(lowDoc.text, "bagua_matrix_counts")
    let lowMatrixWeights = jsonDocFieldRaw(lowDoc.text, "bagua_matrix_weights")
    let lowPlaneCounts = countQuotedNames(lowPlanes, planeOrder)
    let phasePlaneCounts = countQuotedNames(phasePlanes, planeOrder)
    let passHintGroupCounts = countQuotedNames(passHintGroups, passHintGroupOrder)
    let passHintFlagCounts = [countTrueValues(jsonDocFieldRaw(lowDoc.text, "bagua_pass_hint_cfg_proof")),
                              countTrueValues(jsonDocFieldRaw(lowDoc.text, "bagua_pass_hint_layout_sroa")),
                              countTrueValues(jsonDocFieldRaw(lowDoc.text, "bagua_pass_hint_side_effect_ordering")),
                              countTrueValues(jsonDocFieldRaw(lowDoc.text, "bagua_pass_hint_loop_vector_worklist"))]
    let phaseTrigramTextCounts = countQuotedNames(phaseTrigrams, trigramOrder)
    let phaseTrigramAsciiCounts = countQuotedNames(phaseTrigrams, trigramAsciiOrder)
    let phaseTrigramCounts = [phaseTrigramTextCounts[0] + phaseTrigramAsciiCounts[0],
                              phaseTrigramTextCounts[1] + phaseTrigramAsciiCounts[1],
                              phaseTrigramTextCounts[2] + phaseTrigramAsciiCounts[2],
                              phaseTrigramTextCounts[3] + phaseTrigramAsciiCounts[3],
                              phaseTrigramTextCounts[4] + phaseTrigramAsciiCounts[4],
                              phaseTrigramTextCounts[5] + phaseTrigramAsciiCounts[5],
                              phaseTrigramTextCounts[6] + phaseTrigramAsciiCounts[6],
                              phaseTrigramTextCounts[7] + phaseTrigramAsciiCounts[7]]
    let proofKindCounts = countQuotedNames(proofKinds, proofKindOrder)
    let proofGatePlaneCounts = countQuotedNames(proofGatePlanes, planeOrder)
    let proofFailCount = countLiteralOccurrences(proofCheckerResults, jsonQuote("fail"))
    let validatedLowersToCount = countTopLevelCsvParts(phaseEvents)
    let validatedGatesCount = countTopLevelCsvParts(proofTasks)
    let planePairKeys = planePairOrder(planeOrder)
    let phaseEdgePlanePairCounts = edgePlanePairCounts(lowNodeIds,
                                                       lowPlanes,
                                                       phaseLowUirNodeIds,
                                                       phasePlanes,
                                                       planeOrder)
    let proofEdgePlanePairCounts = edgePlanePairCounts(lowNodeIds,
                                                       lowPlanes,
                                                       proofTargets,
                                                       proofGatePlanes,
                                                       planeOrder)
    let validatedEdgePlanePairCounts = addCountVectors(phaseEdgePlanePairCounts, proofEdgePlanePairCounts)
    var fields: str[]
    fields = []
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.profile_report.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote(sourceKind)))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("ast_cid", jsonQuote(astDoc.cid)))
    add(fields, jsonFieldRaw("low_uir_cid", jsonQuote(lowDoc.cid)))
    add(fields, jsonFieldRaw("bagua_trace_cid", jsonQuote(traceDoc.cid)))
    add(fields, jsonFieldRaw("proof_task_cid", jsonQuote(proofDoc.cid)))
    add(fields, jsonFieldRaw("ast_node_count", intToStr(countTopLevelCsvParts(astNodeIds))))
    add(fields, jsonFieldRaw("low_uir_node_count", intToStr(countTopLevelCsvParts(lowNodeIds))))
    add(fields, jsonFieldRaw("phase_event_count", intToStr(countTopLevelCsvParts(phaseEvents))))
    add(fields, jsonFieldRaw("proof_task_count", intToStr(countTopLevelCsvParts(proofTasks))))
    add(fields, jsonFieldRaw("ast_bagua_matrix_counts", astMatrixCounts))
    add(fields, jsonFieldRaw("ast_bagua_matrix_weights", astMatrixWeights))
    add(fields, jsonFieldRaw("low_uir_bagua_matrix_counts", lowMatrixCounts))
    add(fields, jsonFieldRaw("low_uir_bagua_matrix_weights", lowMatrixWeights))
    add(fields, jsonFieldRaw("bpi_validation_scope",
                             jsonInlineObject([jsonInlineFieldRaw("phase", jsonQuote("lowers_to")),
                                               jsonInlineFieldRaw("proof", jsonQuote("gates"))])))
    add(fields, jsonFieldRaw("validated_lowers_to_count", intToStr(validatedLowersToCount)))
    add(fields, jsonFieldRaw("validated_gates_count", intToStr(validatedGatesCount)))
    add(fields, jsonFieldRaw("validated_edge_count", intToStr(validatedLowersToCount + validatedGatesCount)))
    add(fields, jsonFieldRaw("validated_edge_kind_counts",
                             jsonInlineObject([jsonInlineFieldRaw("lowers_to", intToStr(validatedLowersToCount)),
                                               jsonInlineFieldRaw("gates", intToStr(validatedGatesCount))])))
    add(fields, jsonFieldRaw("low_uir_plane_counts", jsonInlineCountObject(planeOrder, lowPlaneCounts)))
    add(fields, jsonFieldRaw("phase_target_plane_counts", jsonInlineCountObject(planeOrder, phasePlaneCounts)))
    add(fields, jsonFieldRaw("proof_gate_plane_counts", jsonInlineCountObject(planeOrder, proofGatePlaneCounts)))
    add(fields, jsonFieldRaw("phase_edge_plane_pair_counts",
                             jsonInlineCountObject(planePairKeys, phaseEdgePlanePairCounts)))
    add(fields, jsonFieldRaw("proof_edge_plane_pair_counts",
                             jsonInlineCountObject(planePairKeys, proofEdgePlanePairCounts)))
    add(fields, jsonFieldRaw("validated_edge_plane_pair_counts",
                             jsonInlineCountObject(planePairKeys, validatedEdgePlanePairCounts)))
    add(fields, jsonFieldRaw("low_uir_pass_hint_group_counts",
                             jsonInlineCountObject(passHintGroupOrder, passHintGroupCounts)))
    add(fields, jsonFieldRaw("low_uir_pass_hint_flag_counts",
                             jsonInlineObject([jsonInlineFieldRaw("cfg_proof", intToStr(passHintFlagCounts[0])),
                                               jsonInlineFieldRaw("layout_sroa", intToStr(passHintFlagCounts[1])),
                                               jsonInlineFieldRaw("side_effect_ordering", intToStr(passHintFlagCounts[2])),
                                               jsonInlineFieldRaw("loop_vector_worklist", intToStr(passHintFlagCounts[3]))])))
    add(fields, jsonFieldRaw("phase_trigram_counts", jsonInlineCountObject(trigramOrder, phaseTrigramCounts)))
    add(fields, jsonFieldRaw("proof_kind_counts", jsonInlineCountObject(proofKindOrder, proofKindCounts)))
    add(fields, jsonFieldRaw("proof_fail_count", intToStr(proofFailCount)))
    return taijiDocument(jsonObject(fields))

fn jsonNestedIntArrays(flatValues: int32[], bucketStarts: int32[], bucketCounts: int32[]): str =
    var buckets: str[]
    buckets = []
    for i in 0..<bucketCounts.len:
        var values: int32[]
        values = []
        let start = bucketStarts[i]
        for j in 0..<bucketCounts[i]:
            add(values, flatValues[start + j])
        add(buckets, jsonIntArray(values))
    return jsonRawArray(buckets)

fn jsonNestedStringArrays(flatValues: str[], bucketStarts: int32[], bucketCounts: int32[]): str =
    var buckets: str[]
    buckets = []
    for i in 0..<bucketCounts.len:
        var values: str[]
        values = []
        let start = bucketStarts[i]
        for j in 0..<bucketCounts[i]:
            add(values, flatValues[start + j])
        add(buckets, jsonStringArray(values))
    return jsonRawArray(buckets)

fn appendBaguaNodeFields(fields: var str[],
                         annotations: bcore.BaguaAnnotation[],
                         matrix: bcore.BaguaMatrix) =
    add(fields, jsonFieldRaw("bagua_upper", jsonStringArray(bcore.annotationUppers(annotations))))
    add(fields, jsonFieldRaw("bagua_lower", jsonStringArray(bcore.annotationLowers(annotations))))
    add(fields, jsonFieldRaw("bagua_plane", jsonStringArray(bcore.annotationPlanes(annotations))))
    add(fields, jsonFieldRaw("bagua_cell_row", jsonIntArray(bcore.annotationCellRows(annotations))))
    add(fields, jsonFieldRaw("bagua_cell_col", jsonIntArray(bcore.annotationCellCols(annotations))))
    add(fields, jsonFieldRaw("bagua_lower_family", jsonStringArray(lmatrix.annotationLowerFamilies(annotations))))
    add(fields, jsonFieldRaw("bagua_lower_preserve_cfg", jsonBoolArray(lmatrix.annotationPreserveCfgFlags(annotations))))
    add(fields, jsonFieldRaw("bagua_lower_requires_proof", jsonBoolArray(lmatrix.annotationRequiresProofFlags(annotations))))
    add(fields, jsonFieldRaw("bagua_lower_emits_side_effect", jsonBoolArray(lmatrix.annotationEmitsSideEffectFlags(annotations))))
    add(fields, jsonFieldRaw("bagua_lower_can_vectorize", jsonBoolArray(lmatrix.annotationCanVectorizeFlags(annotations))))
    add(fields, jsonFieldRaw("bagua_matrix_counts", jsonIntArray(matrix.counts)))
    add(fields, jsonFieldRaw("bagua_matrix_weights", jsonIntArray(matrix.weights)))
    add(fields, jsonFieldRaw("bagua_matrix_node_ids",
                             jsonNestedIntArrays(matrix.flatNodeIds, matrix.bucketStarts, matrix.counts)))
    add(fields, jsonFieldRaw("bagua_matrix_stable_hashes",
                             jsonNestedStringArrays(matrix.flatStableHashes, matrix.bucketStarts, matrix.counts)))

fn appendBaguaLowUirPassHintFields(fields: var str[],
                                   annotations: bcore.BaguaAnnotation[]) =
    add(fields, jsonFieldRaw("bagua_pass_hint_group", jsonStringArray(lmatrix.annotationPassHintGroups(annotations))))
    add(fields, jsonFieldRaw("bagua_pass_hint_cfg_proof", jsonBoolArray(lmatrix.annotationPassHintCfgProofFlags(annotations))))
    add(fields, jsonFieldRaw("bagua_pass_hint_layout_sroa", jsonBoolArray(lmatrix.annotationPassHintLayoutSroaFlags(annotations))))
    add(fields, jsonFieldRaw("bagua_pass_hint_side_effect_ordering",
                             jsonBoolArray(lmatrix.annotationPassHintSideEffectOrderingFlags(annotations))))
    add(fields, jsonFieldRaw("bagua_pass_hint_loop_vector_worklist",
                             jsonBoolArray(lmatrix.annotationPassHintLoopVectorWorklistFlags(annotations))))

fn phasePlaneForTag(tag: TaijiBaguaTag): str =
    return bcore.guaPlane(tag.trigram)

fn phaseCellRowForTag(tag: TaijiBaguaTag): int32 =
    return bcore.guaIndex(tag.trigram)

fn phaseCellColForTag(tag: TaijiBaguaTag): int32 =
    return bcore.guaIndex(tag.trigram)

fn proofGateCell(annotation: bcore.BaguaAnnotation): str =
    return bcore.baguaCellText(annotation.cellRow, annotation.cellCol)

fn baguaAnnotationIndexForNode(nodeIds: int32[], targetNodeId: int32): int32 =
    for i in 0..<nodeIds.len:
        if nodeIds[i] == targetNodeId:
            return i
    return -1

fn requireBaguaAllowedEdge(kind: str, leftPlane: str, rightPlane: str, context: str) =
    if !bcore.allowEdge(kind, leftPlane, rightPlane):
        let familyId = bcore.edgeFamilyId(kind, leftPlane, rightPlane)
        system.panic("taiji: bpi edge violation kind=" + kind +
              " left=" + leftPlane +
              " right=" + rightPlane +
              " family=" + familyId +
              " context=" + context)

fn validateBaguaPhaseLowering(nodeIds: int32[],
                              annotations: bcore.BaguaAnnotation[],
                              lowNodeId: int32,
                              sourceKind: str,
                              reason: str,
                              phasePlane: str,
                              context: str) =
    let idx = baguaAnnotationIndexForNode(nodeIds, lowNodeId)
    if idx < 0:
        system.panic("taiji: missing bpi phase node for " + context)
    requireBaguaAllowedEdge(semanticPhaseEdgeKind(sourceKind, reason), annotations[idx].plane, phasePlane, context)

fn validateBaguaProofGate(nodeIds: int32[],
                          annotations: bcore.BaguaAnnotation[],
                          lowNodeId: int32,
                          proofKind: str,
                          sourceKind: str,
                          assumption: str,
                          gatePlane: str,
                          context: str) =
    let idx = baguaAnnotationIndexForNode(nodeIds, lowNodeId)
    if idx < 0:
        system.panic("taiji: missing bpi proof node for " + context)
    requireBaguaAllowedEdge(semanticProofEdgeKind(proofKind, sourceKind, assumption), annotations[idx].plane, gatePlane, context)

fn sourceKindForPathOrSample(sourcePath: str, builtInSample: str): str =
    if builtInSample == "string":
        return "string"
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        return "network_distribution"
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        return "compiler_core"
    if parsed.unimakerProgram.decls.len > 0:
        return "unimaker"
    system.panic("taiji: unsupported source surface for " + sourcePath)

fn taijiRequireSourcePath(): str =
    let sourcePath = readFlagDefault("--in", "")
    if len(sourcePath) <= 0:
        system.panic("taiji: missing --in")
    return sourcePath

fn taijiSampleName(): str =
    return readFlagDefault("--sample", "")

fn taijiBuiltInStringSourcePath(): str =
    return "v2/src/compiler/frontend/string_surface_ir_v2.cheng#sampleStringSurfaceProgram"

fn taijiBuiltInStringSourceLabel(): str =
    return "sampleStringSurfaceProgram"

fn taijiResolveSourcePath(sampleName: str): str =
    if sampleName == "string":
        return taijiBuiltInStringSourcePath()
    return taijiRequireSourcePath()

fn taijiResolveSourceLabel(sourcePath: str, sampleName: str): str =
    if sampleName == "string":
        return taijiBuiltInStringSourceLabel()
    return sourceLabelFromPath(sourcePath)

fn taijiOutputPathOrEmpty(): str =
    return readFlagDefault("--out", "")

fn taijiSeedOutDir(): str =
    return readFlagDefault("--out-dir", "v2/artifacts/bootstrap/taiji_seed")

fn taijiSeedManifestPath(outDir: str): str =
    return joinPath2(outDir, "taiji_seed_manifest.jsonl")

fn taijiSeedSemanticEdgeCatalogPath(outDir: str): str =
    return joinPath2(outDir, "taiji_bpi_semantic_edge_catalog.json")

fn taijiSeedSampleDir(outDir: str, sampleId: str): str =
    return joinPath2(outDir, sampleId)

fn taijiSeedSamplePath(outDir: str, sampleId: str, fileName: str): str =
    return joinPath2(taijiSeedSampleDir(outDir, sampleId), fileName)

fn taijiSeedSpecs(): TaijiSeedSpec[] =
    var out: TaijiSeedSpec[]
    out = []
    add(out, taijiSeedSpec("handwritten_core.compiler_core_pipeline_surface",
                           "handwritten_core",
                           "compiler_core",
                           "v2/tests/contracts/compiler_core_pipeline_surface.cheng",
                           "compiler_core_pipeline_surface",
                           ""))
    add(out, taijiSeedSpec("handwritten_core.compiler_core_surface",
                           "handwritten_core",
                           "compiler_core",
                           "v2/tests/contracts/compiler_core_surface.cheng",
                           "compiler_core_surface",
                           ""))
    add(out, taijiSeedSpec("handwritten_core.source_manifest_surface",
                           "handwritten_core",
                           "compiler_core",
                           "v2/tests/contracts/source_manifest_surface.cheng",
                           "source_manifest_surface",
                           ""))
    add(out, taijiSeedSpec("handwritten_core.tooling_selfhost_surface",
                           "handwritten_core",
                           "compiler_core",
                           "v2/tests/contracts/tooling_selfhost_surface.cheng",
                           "tooling_selfhost_surface",
                           ""))
    add(out, taijiSeedSpec("handwritten_core.machine_pipeline_surface",
                           "handwritten_core",
                           "compiler_core",
                           "v2/tests/contracts/machine_pipeline_surface.cheng",
                           "machine_pipeline_surface",
                           ""))
    add(out, taijiSeedSpec("handwritten_core.system_link_exec_surface",
                           "handwritten_core",
                           "compiler_core",
                           "v2/tests/contracts/system_link_exec_surface.cheng",
                           "system_link_exec_surface",
                           ""))
    add(out, taijiSeedSpec("contract_sample.string_surface_sample",
                           "contract_sample",
                           "string",
                           taijiBuiltInStringSourcePath(),
                           taijiBuiltInStringSourceLabel(),
                           "string"))
    add(out, taijiSeedSpec("contract_sample.unimaker_robot_node",
                           "contract_sample",
                           "unimaker",
                           "v2/examples/unimaker_robot_node.cheng",
                           "unimaker_robot_node",
                           ""))
    add(out, taijiSeedSpec("contract_sample.network_distribution_module",
                           "contract_sample",
                           "network_distribution",
                           "v2/examples/network_distribution_module.cheng",
                           "network_distribution_module",
                           ""))
    add(out, taijiSeedSpec("compiler_observation.cheng_tooling_v2",
                           "compiler_observation",
                           "compiler_core",
                           "v2/src/tooling/cheng_tooling_v2.cheng",
                           "cheng_tooling_v2",
                           ""))
    return out

fn taijiStringAstDocument(sourcePath: str,
                          sourceLabel: str,
                          program: sir.StringSurfaceProgram): TaijiDocument =
    var nodeIds: int32[]
    var nodeKinds: str[]
    var nodeLabels: str[]
    var nodeTypeIndexes: int32[]
    var edgeKinds: str[]
    var edgeSources: int32[]
    var edgeTargets: int32[]
    var fields: str[]
    nodeIds = []
    nodeKinds = []
    nodeLabels = []
    nodeTypeIndexes = []
    edgeKinds = []
    edgeSources = []
    edgeTargets = []
    fields = []
    for i in 0..<program.exprs.len:
        add(nodeIds, i)
        add(nodeKinds, program.exprs[i].surfaceForm)
        add(nodeLabels, sir.stringSurfaceExprSummary(program.exprs[i]))
        add(nodeTypeIndexes, 0)
        if i > 0:
            add(edgeKinds, "sequence_next")
            add(edgeSources, i - 1)
            add(edgeTargets, i)
    let baguaAnnotations = astbagua.annotateAstNodes("string", nodeIds, nodeKinds, nodeLabels)
    let baguaMatrix = bcore.buildMatrix(nodeIds, baguaAnnotations)
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.ast_graph.v0")))
    add(fields, jsonFieldRaw("graph_kind", jsonQuote("surface_ast")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("string")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("storage_model", jsonQuote("soa_index_only")))
    add(fields, jsonFieldRaw("node_ids", jsonIntArray(nodeIds)))
    add(fields, jsonFieldRaw("node_kinds", jsonStringArray(nodeKinds)))
    add(fields, jsonFieldRaw("node_labels", jsonStringArray(nodeLabels)))
    appendBaguaNodeFields(fields, baguaAnnotations, baguaMatrix)
    add(fields, jsonFieldRaw("node_type_indexes", jsonIntArray(nodeTypeIndexes)))
    add(fields, jsonFieldRaw("type_table", jsonStringArray(["string_expr"])))
    add(fields, jsonFieldRaw("edge_kinds", jsonStringArray(edgeKinds)))
    add(fields, jsonFieldRaw("edge_sources", jsonIntArray(edgeSources)))
    add(fields, jsonFieldRaw("edge_targets", jsonIntArray(edgeTargets)))
    return taijiDocument(jsonObject(fields))

fn taijiUnimakerTypeIndex(kind: str): int32 =
    if kind == "asset_decl":
        return 0
    if kind == "actor_decl":
        return 1
    if kind == "ganzhi_state_decl":
        return 2
    if kind == "hardware_callback_decl":
        return 3
    return 4

fn taijiUnimakerAstDocument(sourcePath: str,
                            sourceLabel: str,
                            program: uir.UnimakerSurfaceProgram): TaijiDocument =
    var nodeIds: int32[]
    var nodeKinds: str[]
    var nodeLabels: str[]
    var nodeTypeIndexes: int32[]
    var edgeKinds: str[]
    var edgeSources: int32[]
    var edgeTargets: int32[]
    var fields: str[]
    nodeIds = []
    nodeKinds = []
    nodeLabels = []
    nodeTypeIndexes = []
    edgeKinds = []
    edgeSources = []
    edgeTargets = []
    fields = []
    for i in 0..<program.decls.len:
        add(nodeIds, i)
        add(nodeKinds, program.decls[i].kind)
        add(nodeLabels, uir.unimakerSurfaceDeclSummary(program.decls[i]))
        add(nodeTypeIndexes, taijiUnimakerTypeIndex(program.decls[i].kind))
        if i > 0:
            add(edgeKinds, "sequence_next")
            add(edgeSources, i - 1)
            add(edgeTargets, i)
    let baguaAnnotations = astbagua.annotateAstNodes("unimaker", nodeIds, nodeKinds, nodeLabels)
    let baguaMatrix = bcore.buildMatrix(nodeIds, baguaAnnotations)
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.ast_graph.v0")))
    add(fields, jsonFieldRaw("graph_kind", jsonQuote("surface_ast")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("unimaker")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("storage_model", jsonQuote("soa_index_only")))
    add(fields, jsonFieldRaw("node_ids", jsonIntArray(nodeIds)))
    add(fields, jsonFieldRaw("node_kinds", jsonStringArray(nodeKinds)))
    add(fields, jsonFieldRaw("node_labels", jsonStringArray(nodeLabels)))
    appendBaguaNodeFields(fields, baguaAnnotations, baguaMatrix)
    add(fields, jsonFieldRaw("node_type_indexes", jsonIntArray(nodeTypeIndexes)))
    add(fields, jsonFieldRaw("type_table", jsonStringArray(["asset_decl",
                                                            "actor_decl",
                                                            "ganzhi_state_decl",
                                                            "hardware_callback_decl",
                                                            "evolve_decl"])))
    add(fields, jsonFieldRaw("edge_kinds", jsonStringArray(edgeKinds)))
    add(fields, jsonFieldRaw("edge_sources", jsonIntArray(edgeSources)))
    add(fields, jsonFieldRaw("edge_targets", jsonIntArray(edgeTargets)))
    return taijiDocument(jsonObject(fields))

fn taijiNetworkAstDocument(sourcePath: str,
                           sourceLabel: str,
                           program: nsurf.NetworkDistributionProgram): TaijiDocument =
    var nodeIds: int32[]
    var nodeKinds: str[]
    var nodeLabels: str[]
    var nodeTypeIndexes: int32[]
    var edgeKinds: str[]
    var edgeSources: int32[]
    var edgeTargets: int32[]
    var topologyIds: int32[]
    var fields: str[]
    nodeIds = []
    nodeKinds = []
    nodeLabels = []
    nodeTypeIndexes = []
    edgeKinds = []
    edgeSources = []
    edgeTargets = []
    topologyIds = []
    fields = []
    for i in 0..<program.topologies.len:
        add(nodeIds, i)
        add(topologyIds, i)
        add(nodeKinds, "topology_decl")
        add(nodeLabels, nsurf.topologyCanonicalForm(program.topologies[i]))
        add(nodeTypeIndexes, 0)
        if i > 0:
            add(edgeKinds, "topology_next")
            add(edgeSources, i - 1)
            add(edgeTargets, i)
    let opBase = program.topologies.len
    for i in 0..<program.ops.len:
        let opNodeId = opBase + i
        add(nodeIds, opNodeId)
        add(nodeKinds, "network_op")
        add(nodeLabels, nsurf.networkDistributionOpSummary(program.ops[i]))
        add(nodeTypeIndexes, 1)
        if i > 0:
            add(edgeKinds, "op_next")
            add(edgeSources, opBase + i - 1)
            add(edgeTargets, opNodeId)
        for j in 0..<program.topologies.len:
            if program.topologies[j].name == program.ops[i].topologyRef:
                add(edgeKinds, "op_topology_ref")
                add(edgeSources, opNodeId)
                add(edgeTargets, j)
                break
    let baguaAnnotations = astbagua.annotateAstNodes("network_distribution", nodeIds, nodeKinds, nodeLabels)
    let baguaMatrix = bcore.buildMatrix(nodeIds, baguaAnnotations)
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.ast_graph.v0")))
    add(fields, jsonFieldRaw("graph_kind", jsonQuote("surface_ast")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("network_distribution")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("storage_model", jsonQuote("soa_index_only")))
    add(fields, jsonFieldRaw("node_ids", jsonIntArray(nodeIds)))
    add(fields, jsonFieldRaw("node_kinds", jsonStringArray(nodeKinds)))
    add(fields, jsonFieldRaw("node_labels", jsonStringArray(nodeLabels)))
    appendBaguaNodeFields(fields, baguaAnnotations, baguaMatrix)
    add(fields, jsonFieldRaw("node_type_indexes", jsonIntArray(nodeTypeIndexes)))
    add(fields, jsonFieldRaw("type_table", jsonStringArray(["topology_decl", "network_op"])))
    add(fields, jsonFieldRaw("edge_kinds", jsonStringArray(edgeKinds)))
    add(fields, jsonFieldRaw("edge_sources", jsonIntArray(edgeSources)))
    add(fields, jsonFieldRaw("edge_targets", jsonIntArray(edgeTargets)))
    return taijiDocument(jsonObject(fields))

fn taijiCompilerCoreTopLevelTypeIndex(kind: str): int32 =
    if kind == "module":
        return 0
    if kind == "import":
        return 1
    if kind == "type":
        return 2
    if kind == "const":
        return 3
    if kind == "var":
        return 4
    if kind == "importc_fn":
        return 5
    if kind == "iterator":
        return 7
    return 6

fn taijiCompilerCoreAstDocument(sourcePath: str,
                                sourceLabel: str,
                                program: ccore.CompilerCoreProgram): TaijiDocument =
    var nodeIds: int32[]
    var nodeKinds: str[]
    var nodeLabels: str[]
    var nodeTypeIndexes: int32[]
    var edgeKinds: str[]
    var edgeSources: int32[]
    var edgeTargets: int32[]
    var fields: str[]
    var moduleIdx: int32 = 0
    var importIdx: int32 = 0
    var typeIdx: int32 = 0
    var constIdx: int32 = 0
    var varIdx: int32 = 0
    var routineIdx: int32 = 0
    var routineNodeIds: int32[]
    nodeIds = []
    nodeKinds = []
    nodeLabels = []
    nodeTypeIndexes = []
    edgeKinds = []
    edgeSources = []
    edgeTargets = []
    fields = []
    routineNodeIds = []
    let topLevelBase = 0
    let paramBase = program.topLevelKinds.len
    let localBase = paramBase + program.routineParams.len
    let stmtBase = localBase + program.locals.len
    let exprBase = stmtBase + program.stmts.len
    for i in 0..<program.topLevelKinds.len:
        let kind = program.topLevelKinds[i]
        add(nodeIds, topLevelBase + i)
        add(nodeKinds, kind)
        add(nodeTypeIndexes, taijiCompilerCoreTopLevelTypeIndex(kind))
        if kind == "module":
            add(nodeLabels, program.modules[moduleIdx].headerText)
            moduleIdx = moduleIdx + 1
        elif kind == "import":
            add(nodeLabels, program.imports[importIdx].modulePath)
            importIdx = importIdx + 1
        elif kind == "type":
            add(nodeLabels, program.typeBlocks[typeIdx].headerText)
            typeIdx = typeIdx + 1
        elif kind == "const":
            add(nodeLabels, program.constDecls[constIdx].headerText)
            constIdx = constIdx + 1
        elif kind == "var":
            add(nodeLabels, program.varDecls[varIdx].headerText)
            varIdx = varIdx + 1
        else:
            add(nodeLabels, program.routines[routineIdx].signatureText)
            add(routineNodeIds, i)
            routineIdx = routineIdx + 1
        if i > 0:
            add(edgeKinds, "top_level_next")
            add(edgeSources, i - 1)
            add(edgeTargets, i)
    for i in 0..<program.routineParams.len:
        add(nodeIds, paramBase + i)
        add(nodeKinds, "param_decl")
        add(nodeLabels, program.routineParams[i].name + ":" + program.routineParams[i].typeText)
        add(nodeTypeIndexes, 8)
    for i in 0..<program.locals.len:
        add(nodeIds, localBase + i)
        add(nodeKinds, "local_decl")
        add(nodeLabels, program.locals[i].name + ":" + program.locals[i].typeText)
        add(nodeTypeIndexes, 9)
    for i in 0..<program.stmts.len:
        add(nodeIds, stmtBase + i)
        add(nodeKinds, "stmt_node")
        add(nodeLabels, program.stmts[i].kind + "|" + program.stmts[i].primaryText)
        add(nodeTypeIndexes, 10)
    for i in 0..<program.exprs.len:
        add(nodeIds, exprBase + i)
        add(nodeKinds, "expr_node")
        add(nodeLabels, program.exprs[i].kind + "|" + program.exprs[i].primaryText)
        add(nodeTypeIndexes, 11)
    for i in 0..<program.routines.len:
        let routineNodeId = routineNodeIds[i]
        let routine = program.routines[i]
        for j in 0..<routine.paramCount:
            add(edgeKinds, "routine_param")
            add(edgeSources, routineNodeId)
            add(edgeTargets, paramBase + routine.paramStart + j)
        for j in 0..<routine.localCount:
            add(edgeKinds, "routine_local")
            add(edgeSources, routineNodeId)
            add(edgeTargets, localBase + routine.localStart + j)
        for j in 0..<routine.stmtCount:
            add(edgeKinds, "routine_stmt")
            add(edgeSources, routineNodeId)
            add(edgeTargets, stmtBase + routine.stmtStart + j)
        for j in 0..<routine.exprCount:
            add(edgeKinds, "routine_expr")
            add(edgeSources, routineNodeId)
            add(edgeTargets, exprBase + routine.exprStart + j)
    for i in 0..<program.stmts.len:
        let stmt = program.stmts[i]
        for j in 0..<stmt.childCount:
            add(edgeKinds, "stmt_child")
            add(edgeSources, stmtBase + i)
            add(edgeTargets, stmtBase + program.stmtChildIds[stmt.childStart + j])
        for j in 0..<stmt.elseChildCount:
            add(edgeKinds, "stmt_else_child")
            add(edgeSources, stmtBase + i)
            add(edgeTargets, stmtBase + program.stmtChildIds[stmt.elseChildStart + j])
    for i in 0..<program.exprs.len:
        let expr = program.exprs[i]
        for j in 0..<expr.childCount:
            add(edgeKinds, "expr_child")
            add(edgeSources, exprBase + i)
            add(edgeTargets, exprBase + program.exprChildIds[expr.childStart + j])
    let baguaAnnotations = astbagua.annotateAstNodes("compiler_core", nodeIds, nodeKinds, nodeLabels)
    let baguaMatrix = bcore.buildMatrix(nodeIds, baguaAnnotations)
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.ast_graph.v0")))
    add(fields, jsonFieldRaw("graph_kind", jsonQuote("surface_ast")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("compiler_core")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("storage_model", jsonQuote("soa_index_only")))
    add(fields, jsonFieldRaw("node_ids", jsonIntArray(nodeIds)))
    add(fields, jsonFieldRaw("node_kinds", jsonStringArray(nodeKinds)))
    add(fields, jsonFieldRaw("node_labels", jsonStringArray(nodeLabels)))
    appendBaguaNodeFields(fields, baguaAnnotations, baguaMatrix)
    add(fields, jsonFieldRaw("node_type_indexes", jsonIntArray(nodeTypeIndexes)))
    add(fields, jsonFieldRaw("type_table", jsonStringArray(["module_decl",
                                                            "import_decl",
                                                            "type_block",
                                                            "const_decl",
                                                            "var_decl",
                                                            "importc_fn_decl",
                                                            "fn_decl",
                                                            "iterator_decl",
                                                            "param_decl",
                                                            "local_decl",
                                                            "stmt_node",
                                                            "expr_node"])))
    add(fields, jsonFieldRaw("edge_kinds", jsonStringArray(edgeKinds)))
    add(fields, jsonFieldRaw("edge_sources", jsonIntArray(edgeSources)))
    add(fields, jsonFieldRaw("edge_targets", jsonIntArray(edgeTargets)))
    return taijiDocument(jsonObject(fields))

fn taijiCompilerCoreInputTypes(bundle: cpipe.CompilerCorePipelineBundle, idx: int32): str =
    let kind = bundle.lowPlan.topLevelKinds[idx]
    if kind == "import":
        return singleTypeRow("module_path")
    if bundle.lowPlan.executableAstReady[idx]:
        return jsonStringArray(["params=" + intToStr(bundle.lowPlan.paramCounts[idx]),
                                "locals=" + intToStr(bundle.lowPlan.localCounts[idx]),
                                "stmts=" + intToStr(bundle.lowPlan.stmtCounts[idx]),
                                "exprs=" + intToStr(bundle.lowPlan.exprCounts[idx])])
    return singleTypeRow("outline_meta")

fn taijiCompilerCoreOutputTypes(bundle: cpipe.CompilerCorePipelineBundle, idx: int32): str =
    if len(bundle.lowPlan.returnTypeTexts[idx]) > 0:
        return singleTypeRow(bundle.lowPlan.returnTypeTexts[idx])
    return singleTypeRow(bundle.lowPlan.topLevelKinds[idx])

fn taijiNetworkInputTypes(bundle: npipe.NetworkDistributionPipelineBundle, idx: int32): str =
    return jsonStringArray(["addressing=" + bundle.lowPlan.addressingModes[idx],
                            "depth=" + intToStr(bundle.lowPlan.topologyDepths[idx]),
                            "topology=" + bundle.program.ops[idx].topologyRef])

fn taijiNetworkOutputTypes(bundle: npipe.NetworkDistributionPipelineBundle, idx: int32): str =
    return singleTypeRow(bundle.lowPlan.identityScopes[idx])

fn taijiNetworkEffectClass(opName: str): str =
    if opName == "publish_source_manifest" || opName == "publish_rule_pack" || opName == "publish_compiler_rule_pack":
        return "network_publish"
    if opName == "route_lsmr_tree":
        return "network_route"
    if opName == "disperse_ida_fragments":
        return "network_dispersal"
    if opName == "exchange_anti_entropy_signature":
        return "network_merge"
    return "network_repair"

fn taijiUnimakerInputTypes(bundle: upipe.UnimakerPipelineBundle, idx: int32): str =
    return jsonStringArray([bundle.program.decls[idx].kind,
                            "network_mode=" + bundle.lowPlan.networkModes[idx],
                            "capability=" + bundle.lowPlan.capabilityKinds[idx]])

fn taijiUnimakerOutputTypes(bundle: upipe.UnimakerPipelineBundle, idx: int32): str =
    return singleTypeRow("unit")

fn taijiStringProofDomain(bundle: spipe.StringPipelineBundle, idx: int32): str =
    let opName = bundle.lowPlan.canonicalOps[idx]
    if opName == "str_index" || opName == "str_slice_view":
        return "bounds"
    if opName == "str_concat" || opName == "str_to_owned" || opName == "str_builder_finish":
        return "ownership"
    if opName == "str_builder_init" || opName == "str_builder_append" || opName == "str_builder_append_byte":
        return "builder_state"
    return "pure_compare"

fn taijiStringLowUirDocument(sourcePath: str,
                             sourceLabel: str,
                             bundle: spipe.StringPipelineBundle): TaijiDocument =
    var inputTypes: str[]
    var outputTypes: str[]
    var proofDomains: str[]
    var bindingScopes: str[]
    var edgeKinds: str[]
    var edgeSources: int32[]
    var edgeTargets: int32[]
    var fields: str[]
    inputTypes = []
    outputTypes = []
    proofDomains = []
    bindingScopes = []
    edgeKinds = []
    edgeSources = []
    edgeTargets = []
    fields = []
    for i in 0..<bundle.lowPlan.exprIds.len:
        add(inputTypes, stringInputTypeRow(bundle.lowPlan.canonicalOps[i]))
        add(outputTypes, singleTypeRow(bundle.lowPlan.resultKinds[i]))
        add(proofDomains, taijiStringProofDomain(bundle, i))
        add(bindingScopes, bundle.lowPlan.allocationModes[i])
        if i > 0:
            add(edgeKinds, "sequence_next")
            add(edgeSources, bundle.lowPlan.exprIds[i - 1])
            add(edgeTargets, bundle.lowPlan.exprIds[i])
    let baguaAnnotations = lowbagua.annotateLowUirNodes("string",
                                                        bundle.lowPlan.exprIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        proofDomains,
                                                        bindingScopes,
                                                        bundle.lowPlan.runtimeTargets)
    let baguaMatrix = bcore.buildMatrix(bundle.lowPlan.exprIds, baguaAnnotations)
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.low_uir_graph.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("string")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("storage_model", jsonQuote("soa_index_only")))
    add(fields, jsonFieldRaw("node_ids", jsonIntArray(bundle.lowPlan.exprIds)))
    add(fields, jsonFieldRaw("op_names", jsonStringArray(bundle.lowPlan.canonicalOps)))
    appendBaguaNodeFields(fields, baguaAnnotations, baguaMatrix)
    appendBaguaLowUirPassHintFields(fields, baguaAnnotations)
    add(fields, jsonFieldRaw("input_types", jsonRawArray(inputTypes)))
    add(fields, jsonFieldRaw("output_types", jsonRawArray(outputTypes)))
    add(fields, jsonFieldRaw("effect_classes", jsonStringArray(bundle.lowPlan.effectClasses)))
    add(fields, jsonFieldRaw("proof_domains", jsonStringArray(proofDomains)))
    add(fields, jsonFieldRaw("binding_scopes", jsonStringArray(bindingScopes)))
    add(fields, jsonFieldRaw("runtime_targets", jsonStringArray(bundle.lowPlan.runtimeTargets)))
    add(fields, jsonFieldRaw("edge_kinds", jsonStringArray(edgeKinds)))
    add(fields, jsonFieldRaw("edge_sources", jsonIntArray(edgeSources)))
    add(fields, jsonFieldRaw("edge_targets", jsonIntArray(edgeTargets)))
    return taijiDocument(jsonObject(fields))

fn taijiUnimakerLowUirDocument(sourcePath: str,
                               sourceLabel: str,
                               bundle: upipe.UnimakerPipelineBundle): TaijiDocument =
    var inputTypes: str[]
