fn taijiStringProofDocument(sourcePath: str,
                            sourceLabel: str,
                            bundle: spipe.StringPipelineBundle): TaijiProofArtifact =
    var tasks: str[]
    var fields: str[]
    var allPass: bool = true
    tasks = []
    fields = []
    let contract = sops.lowUirStringOpsContract()
    let baguaAnnotations = lowbagua.annotateLowUirNodes("string",
                                                        bundle.lowPlan.exprIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.allocationModes,
                                                        bundle.lowPlan.runtimeTargets)
    var taskId: int32 = 0
    for i in 0..<bundle.lowPlan.exprIds.len:
        let opIdx = sops.findLowUirStringOp(bundle.lowPlan.canonicalOps[i])
        let contractOp = contract.canonicalOps[opIdx]
        let gatePlane = baguaAnnotations[i].plane
        let gateCell = proofGateCell(baguaAnnotations[i])
        let effectPass = bundle.lowPlan.runtimeTargets[i] == contractOp.runtimeTarget &&
                         bundle.lowPlan.effectClasses[i] == contractOp.effectClass
        validateBaguaProofGate(bundle.lowPlan.exprIds,
                               baguaAnnotations,
                               bundle.lowPlan.exprIds[i],
                               "effect",
                               "string",
                               "runtime_target 与 effect_class 必须和 canonical op 一致",
                               gatePlane,
                               "string_proof|" + bundle.lowPlan.canonicalOps[i] + "|effect")
        allPass = allPass && effectPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("effect")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.exprIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("runtime_target 与 effect_class 必须和 canonical op 一致")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("runtime_target=" + contractOp.runtimeTarget +
                                                                                ", effect_class=" + contractOp.effectClass)),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if effectPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let aliasPass = !bundle.lowPlan.zeroCopyFacts[i] ||
                        bundle.lowPlan.allocationModes[i] == "none" ||
                        bundle.lowPlan.allocationModes[i] == "borrow_view"
        validateBaguaProofGate(bundle.lowPlan.exprIds,
                               baguaAnnotations,
                               bundle.lowPlan.exprIds[i],
                               "alias",
                               "string",
                               "zero_copy=1 时只能保持无分配或借用视图",
                               gatePlane,
                               "string_proof|" + bundle.lowPlan.canonicalOps[i] + "|alias")
        allPass = allPass && aliasPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("alias")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.exprIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("zero_copy=1 时只能保持无分配或借用视图")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("allocation_mode in [none, borrow_view]")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if aliasPass: "pass" else: "fail"))]))
        taskId = taskId + 1
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.proof_tasks.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("string")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("tasks", jsonRawArray(tasks)))
    return taijiProofArtifact(jsonObject(fields), allPass)

fn taijiUnimakerProofDocument(sourcePath: str,
                              sourceLabel: str,
                              bundle: upipe.UnimakerPipelineBundle): TaijiProofArtifact =
    var tasks: str[]
    var fields: str[]
    var allPass: bool = true
    tasks = []
    fields = []
    let contract = uops.lowUirUnimakerOpsContract()
    let baguaAnnotations = lowbagua.annotateLowUirNodes("unimaker",
                                                        bundle.lowPlan.declIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.networkModes,
                                                        bundle.lowPlan.runtimeTargets)
    var taskId: int32 = 0
    for i in 0..<bundle.lowPlan.declIds.len:
        let opIdx = uops.findLowUirUnimakerOp(bundle.lowPlan.canonicalOps[i])
        let contractOp = contract.canonicalOps[opIdx]
        let gatePlane = baguaAnnotations[i].plane
        let gateCell = proofGateCell(baguaAnnotations[i])
        let effectPass = bundle.lowPlan.runtimeTargets[i] == contractOp.runtimeTarget &&
                         bundle.lowPlan.effectClasses[i] == contractOp.effectClass &&
                         bundle.lowPlan.proofDomains[i] == contractOp.proofDomain
        validateBaguaProofGate(bundle.lowPlan.declIds,
                               baguaAnnotations,
                               bundle.lowPlan.declIds[i],
                               "effect",
                               "unimaker",
                               "runtime/effect/proof 必须和 canonical op 一致",
                               gatePlane,
                               "unimaker_proof|" + bundle.lowPlan.canonicalOps[i] + "|effect")
        allPass = allPass && effectPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("effect")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.declIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("runtime/effect/proof 必须和 canonical op 一致")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("runtime_target=" + contractOp.runtimeTarget)),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if effectPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let opName = bundle.lowPlan.canonicalOps[i]
        let capabilityPass =
            (opName == "hardware_callback_def" && bundle.lowPlan.capabilityKinds[i] == "nfc") ||
            (opName == "evolve_site_def" && bundle.lowPlan.capabilityKinds[i] == "npu") ||
            ((opName == "asset_contract_def" || opName == "actor_def" || opName == "ganzhi_state_def") &&
             bundle.lowPlan.capabilityKinds[i] == "none")
        validateBaguaProofGate(bundle.lowPlan.declIds,
                               baguaAnnotations,
                               bundle.lowPlan.declIds[i],
                               "ownership",
                               "unimaker",
                               "能力类型必须与声明形状对应",
                               gatePlane,
                               "unimaker_proof|" + bundle.lowPlan.canonicalOps[i] + "|ownership")
        allPass = allPass && capabilityPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("ownership")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.declIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("能力类型必须与声明形状对应")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("capability 与 decl kind 精确匹配")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if capabilityPass: "pass" else: "fail"))]))
        taskId = taskId + 1
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.proof_tasks.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("unimaker")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("tasks", jsonRawArray(tasks)))
    return taijiProofArtifact(jsonObject(fields), allPass)

fn taijiNetworkProofDocument(sourcePath: str,
                             sourceLabel: str,
                             bundle: npipe.NetworkDistributionPipelineBundle): TaijiProofArtifact =
    var tasks: str[]
    var fields: str[]
    var allPass: bool = true
    tasks = []
    fields = []
    let contract = nops.lowUirNetworkDistributionOpsContract()
    let effectClasses = bundle.lowPlan.priorityClasses
    let baguaAnnotations = lowbagua.annotateLowUirNodes("network_distribution",
                                                        bundle.lowPlan.opIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.addressBindings,
                                                        bundle.lowPlan.runtimeTargets)
    var taskId: int32 = 0
    for i in 0..<bundle.lowPlan.opIds.len:
        let opIdx = nops.findLowUirNetworkDistributionOp(bundle.lowPlan.canonicalOps[i])
        let contractOp = contract.canonicalOps[opIdx]
        let gatePlane = baguaAnnotations[i].plane
        let gateCell = proofGateCell(baguaAnnotations[i])
        let effectPass = bundle.lowPlan.runtimeTargets[i] == contractOp.runtimeTarget &&
                         bundle.lowPlan.proofDomains[i] == contractOp.proofDomain
        validateBaguaProofGate(bundle.lowPlan.opIds,
                               baguaAnnotations,
                               bundle.lowPlan.opIds[i],
                               "effect",
                               "network_distribution",
                               "runtime/proof 必须和 canonical op 一致",
                               gatePlane,
                               "network_proof|" + bundle.lowPlan.canonicalOps[i] + "|effect")
        allPass = allPass && effectPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("effect")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.opIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("runtime/proof 必须和 canonical op 一致")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("runtime_target=" + contractOp.runtimeTarget)),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if effectPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let layoutPass = bundle.lowPlan.addressingModes[i] != "lsmr_path" ||
                         (bundle.lowPlan.addressBindings[i] == "content_bound_address" &&
                          bundle.lowPlan.distanceMetrics[i] == "per_level_manhattan" &&
                          bundle.lowPlan.routePlanModels[i] == "canonical_multipath_set")
        validateBaguaProofGate(bundle.lowPlan.opIds,
                               baguaAnnotations,
                               bundle.lowPlan.opIds[i],
                               "layout",
                               "network_distribution",
                               bundle.lowPlan.canonicalOps[i] + "|" + bundle.lowPlan.addressingModes[i],
                               gatePlane,
                               "network_proof|" + bundle.lowPlan.canonicalOps[i] + "|layout")
        allPass = allPass && layoutPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("layout")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.opIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("lsmr_path 必须绑定 canonical addressing lane")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("address_binding/content_bound_address + per_level_manhattan + canonical_multipath_set")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if layoutPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let ownershipPass = bundle.lowPlan.canonicalOps[i] != "exchange_anti_entropy_signature" &&
                            bundle.lowPlan.canonicalOps[i] != "repair_from_signature_gap" ?
            true :
            len(bundle.lowPlan.antiEntropySignatureKinds[i]) > 0
        validateBaguaProofGate(bundle.lowPlan.opIds,
                               baguaAnnotations,
                               bundle.lowPlan.opIds[i],
                               "ownership",
                               "network_distribution",
                               bundle.lowPlan.canonicalOps[i],
                               gatePlane,
                               "network_proof|" + bundle.lowPlan.canonicalOps[i] + "|ownership")
        allPass = allPass && ownershipPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("ownership")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.opIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("签名相关操作必须声明 anti-entropy signature kind")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("anti_entropy_signature_kind != empty")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if ownershipPass: "pass" else: "fail"))]))
        taskId = taskId + 1
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.proof_tasks.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("network_distribution")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("tasks", jsonRawArray(tasks)))
    return taijiProofArtifact(jsonObject(fields), allPass)

fn taijiCompilerCoreProofDocument(sourcePath: str,
                                  sourceLabel: str,
                                  bundle: cpipe.CompilerCorePipelineBundle): TaijiProofArtifact =
    var tasks: str[]
    var fields: str[]
    var allPass: bool = true
    tasks = []
    fields = []
    let contract = cops.lowUirCompilerCoreOpsContract()
    let baguaAnnotations = lowbagua.annotateLowUirNodes("compiler_core",
                                                        bundle.lowPlan.itemIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.bindingScopes,
                                                        bundle.lowPlan.runtimeTargets)
    var taskId: int32 = 0
    for i in 0..<bundle.lowPlan.itemIds.len:
        let opIdx = cops.findLowUirCompilerCoreOp(bundle.lowPlan.canonicalOps[i])
        let contractOp = contract.canonicalOps[opIdx]
        let gatePlane = baguaAnnotations[i].plane
        let gateCell = proofGateCell(baguaAnnotations[i])
        let layoutAssumption = bundle.lowPlan.canonicalOps[i] + "|" + bundle.lowPlan.topLevelKinds[i]
        let effectAssumption = bundle.lowPlan.canonicalOps[i] + "|" + contractOp.proofDomain
        let layoutPass = bundle.lowPlan.bindingScopes[i] != ""
        validateBaguaProofGate(bundle.lowPlan.itemIds,
                               baguaAnnotations,
                               bundle.lowPlan.itemIds[i],
                               "layout",
                               "compiler_core",
                               layoutAssumption,
                               gatePlane,
                               "compiler_core_proof|" + bundle.lowPlan.canonicalOps[i] + "|layout")
        allPass = allPass && layoutPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("layout")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.itemIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote(layoutAssumption)),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("binding_scope_non_empty")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if layoutPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let effectPass = bundle.lowPlan.runtimeTargets[i] == contractOp.runtimeTarget &&
                         bundle.lowPlan.effectClasses[i] == contractOp.effectClass &&
                         bundle.lowPlan.proofDomains[i] == contractOp.proofDomain &&
                         bundle.lowPlan.bindingScopes[i] == contractOp.bindingScope
        validateBaguaProofGate(bundle.lowPlan.itemIds,
                               baguaAnnotations,
                               bundle.lowPlan.itemIds[i],
                               "effect",
                               "compiler_core",
                               effectAssumption,
                               gatePlane,
                               "compiler_core_proof|" + bundle.lowPlan.canonicalOps[i] + "|effect")
        allPass = allPass && effectPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("effect")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.itemIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote(effectAssumption)),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("binding_scope=" + contractOp.bindingScope)),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if effectPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let boundsPass = !bundle.lowPlan.executableAstReady[i] ||
                         bundle.lowPlan.routineOpStarts[i] + bundle.lowPlan.routineOpCounts[i] <= bundle.lowPlan.opKinds.len
        validateBaguaProofGate(bundle.lowPlan.itemIds,
                               baguaAnnotations,
                               bundle.lowPlan.itemIds[i],
                               "bounds",
                               "compiler_core",
                               "executable_ast_ready",
                               gatePlane,
                               "compiler_core_proof|" + bundle.lowPlan.canonicalOps[i] + "|bounds")
        allPass = allPass && boundsPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("bounds")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.itemIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("可执行条目必须落在 Low-UIR op SoA 边界内")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("routine_op_start + routine_op_count <= opKinds.len")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if boundsPass: "pass" else: "fail"))]))
        taskId = taskId + 1
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.proof_tasks.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("compiler_core")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("tasks", jsonRawArray(tasks)))
    return taijiProofArtifact(jsonObject(fields), allPass)

fn taijiAstDocument(sourcePath: str, sourceLabel: str, sampleName: str): TaijiDocument =
    if sampleName == "string":
        return taijiStringAstDocument(sourcePath, sourceLabel, sir.sampleStringSurfaceProgram())
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        return taijiNetworkAstDocument(sourcePath, sourceLabel, parsed.networkProgram)
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        return taijiCompilerCoreAstDocument(sourcePath,
                                            sourceLabel,
                                            cpipe.compileCompilerCoreSourceClosure(sourcePath).program)
    if parsed.unimakerProgram.decls.len > 0:
        return taijiUnimakerAstDocument(sourcePath, sourceLabel, parsed.unimakerProgram)
    system.panic("taiji: unsupported ast export source")

fn taijiLowUirDocument(sourcePath: str, sourceLabel: str, sampleName: str): TaijiDocument =
    if sampleName == "string":
        return taijiStringLowUirDocument(sourcePath, sourceLabel, spipe.sampleStringPipeline())
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        return taijiNetworkLowUirDocument(sourcePath,
                                          sourceLabel,
                                          npipe.compileNetworkDistributionProgram(parsed.networkProgram))
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        return taijiCompilerCoreLowUirDocument(sourcePath,
                                               sourceLabel,
                                               cpipe.compileCompilerCoreSourceClosure(sourcePath))
    if parsed.unimakerProgram.decls.len > 0:
        return taijiUnimakerLowUirDocument(sourcePath,
                                           sourceLabel,
                                           upipe.compileUnimakerSurfaceProgram(parsed.unimakerProgram))
    system.panic("taiji: unsupported low_uir export source")

fn taijiPhaseTraceDocument(sourcePath: str, sourceLabel: str, sampleName: str): TaijiDocument =
    if sampleName == "string":
        return taijiStringPhaseTraceDocument(sourcePath, sourceLabel, spipe.sampleStringPipeline())
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        return taijiNetworkPhaseTraceDocument(sourcePath,
                                              sourceLabel,
                                              npipe.compileNetworkDistributionProgram(parsed.networkProgram))
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        return taijiCompilerCorePhaseTraceDocument(sourcePath,
                                                   sourceLabel,
                                                   cpipe.compileCompilerCoreSourceClosure(sourcePath))
    if parsed.unimakerProgram.decls.len > 0:
        return taijiUnimakerPhaseTraceDocument(sourcePath,
                                               sourceLabel,
                                               upipe.compileUnimakerSurfaceProgram(parsed.unimakerProgram))
    system.panic("taiji: unsupported phase trace source")

fn taijiProofDocument(sourcePath: str, sourceLabel: str, sampleName: str): TaijiProofArtifact =
    if sampleName == "string":
        return taijiStringProofDocument(sourcePath, sourceLabel, spipe.sampleStringPipeline())
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        return taijiNetworkProofDocument(sourcePath,
                                         sourceLabel,
                                         npipe.compileNetworkDistributionProgram(parsed.networkProgram))
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        return taijiCompilerCoreProofDocument(sourcePath,
                                              sourceLabel,
                                              cpipe.compileCompilerCoreSourceClosure(sourcePath))
    if parsed.unimakerProgram.decls.len > 0:
        return taijiUnimakerProofDocument(sourcePath,
                                          sourceLabel,
                                          upipe.compileUnimakerSurfaceProgram(parsed.unimakerProgram))
    system.panic("taiji: unsupported proof source")

fn taijiExecPlanDocument(sourcePath: str, label: str, sampleName: str): TaijiDocument =
    if sampleName == "string":
        system.panic("taiji: dump-exec-plan only supports compiler_core source")
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.compilerCoreProgram.topLevelKinds.len <= 0:
        system.panic("taiji: dump-exec-plan only supports compiler_core source")
    let bundle = cpipe.compileCompilerCoreSourceClosure(sourcePath)
    var itemIdx: int32 = -1
    for i in 0..<bundle.lowPlan.labels.len:
        if bundle.lowPlan.labels[i] == label:
            itemIdx = i
            break
    if itemIdx < 0:
        system.panic("taiji: missing compiler_core exec label " + label)
    if !bundle.lowPlan.executableAstReady[itemIdx]:
        system.panic("taiji: label is not executable " + label)
    return taijiDocument("source_path=" + sourcePath + "\n" +
                         "label=" + label + "\n" +
                         "item_id=" + intToStr(bundle.lowPlan.itemIds[itemIdx]) + "\n" +
                         mpipeline.compilerCoreRoutineExecPlanText(bundle.lowPlan, itemIdx))

fn runDumpAst(): int32 =
    let sampleName = taijiSampleName()
    let sourcePath = taijiResolveSourcePath(sampleName)
    let sourceLabel = taijiResolveSourceLabel(sourcePath, sampleName)
    let outPath = taijiOutputPathOrEmpty()
    let doc = taijiAstDocument(sourcePath, sourceLabel, sampleName)
    writeOptionalTextFile(outPath, doc.text)
    writeText(doc.text + "\n")
    return 0

fn runDumpLowUir(): int32 =
    let sampleName = taijiSampleName()
    let sourcePath = taijiResolveSourcePath(sampleName)
    let sourceLabel = taijiResolveSourceLabel(sourcePath, sampleName)
    let outPath = taijiOutputPathOrEmpty()
    let doc = taijiLowUirDocument(sourcePath, sourceLabel, sampleName)
    writeOptionalTextFile(outPath, doc.text)
    writeText(doc.text + "\n")
    return 0

fn runDumpExecPlan(): int32 =
    let sampleName = taijiSampleName()
    let sourcePath = taijiResolveSourcePath(sampleName)
    let label = readFlagDefault("--label", "")
    if len(label) <= 0:
        system.panic("taiji: missing --label")
    let outPath = taijiOutputPathOrEmpty()
    let doc = taijiExecPlanDocument(sourcePath, label, sampleName)
    writeOptionalTextFile(outPath, doc.text)
    writeText(doc.text + "\n")
    return 0

fn runTracePhaseSpace(): int32 =
    let sampleName = taijiSampleName()
    let sourcePath = taijiResolveSourcePath(sampleName)
    let sourceLabel = taijiResolveSourceLabel(sourcePath, sampleName)
    let outPath = taijiOutputPathOrEmpty()
    let doc = taijiPhaseTraceDocument(sourcePath, sourceLabel, sampleName)
    writeOptionalTextFile(outPath, doc.text)
    writeText(doc.text + "\n")
    return 0

fn runEmitProofObligations(): int32 =
    let sampleName = taijiSampleName()
    let sourcePath = taijiResolveSourcePath(sampleName)
    let sourceLabel = taijiResolveSourceLabel(sourcePath, sampleName)
    let outPath = taijiOutputPathOrEmpty()
    let proof = taijiProofDocument(sourcePath, sourceLabel, sampleName)
    writeOptionalTextFile(outPath, proof.text)
    writeText(proof.text + "\n")
    return if proof.allPass: 0 else: 1

fn taijiSeedManifestLine(spec: TaijiSeedSpec,
                         astDoc: TaijiDocument,
                         lowDoc: TaijiDocument,
                         traceDoc: TaijiDocument,
                         proofDoc: TaijiDocument,
                         profileDoc: TaijiDocument): str =
    return jsonInlineObject([jsonInlineFieldRaw("sample_id", jsonQuote(spec.sampleId)),
                             jsonInlineFieldRaw("source_path", jsonQuote(spec.sourcePath)),
                             jsonInlineFieldRaw("source_kind", jsonQuote(spec.sourceKind)),
                             jsonInlineFieldRaw("ast_cid", jsonQuote(astDoc.cid)),
                             jsonInlineFieldRaw("low_uir_cid", jsonQuote(lowDoc.cid)),
                             jsonInlineFieldRaw("bagua_trace_cid", jsonQuote(traceDoc.cid)),
                             jsonInlineFieldRaw("proof_task_cid", jsonQuote(proofDoc.cid)),
                             jsonInlineFieldRaw("profile_report_cid", jsonQuote(profileDoc.cid)),
                             jsonInlineFieldRaw("gate_class", jsonQuote(spec.gateClass))])

fn updateSemanticEdgeFamilyCounts(familyTotalCounts: var int32[],
                                  familySampleCounts: var int32[],
                                  familySampleHits: var int32[],
                                  sampleIdx: int32,
                                  familyCounts: int32[],
                                  sampleCount: int32) =
    if familyTotalCounts.len != familyCounts.len || familySampleCounts.len != familyCounts.len:
        system.panic("taiji: semantic edge family total length mismatch")
    for familyIdx in 0..<familyCounts.len:
        let count = familyCounts[familyIdx]
        if count <= 0:
            continue
        familyTotalCounts[familyIdx] = familyTotalCounts[familyIdx] + count
        let hitIdx = familyIdx * sampleCount + sampleIdx
        if familySampleHits[hitIdx] == 0:
            familySampleHits[hitIdx] = 1
            familySampleCounts[familyIdx] = familySampleCounts[familyIdx] + 1

fn taijiSemanticEdgeCatalogDocument(specs: TaijiSeedSpec[],
                                    sampleLabels: str[],
                                    familyTotalCounts: int32[],
                                    familySampleCounts: int32[],
                                    familySampleHits: int32[]): TaijiDocument =
    let edgeKindOrder = semanticEdgeKindOrder()
    let planeOrder = ["P1=乾坤", "P2=坎离", "P3=艮兑", "P4=震巽"]
    let planePairKeys = planePairOrder(planeOrder)
    let gateClassOrder = ["handwritten_core", "contract_sample", "compiler_observation"]
    let sourceKindOrder = ["string", "unimaker", "network_distribution", "compiler_core"]
    if sampleLabels.len != specs.len:
        system.panic("taiji: semantic edge catalog sample label length mismatch")
    let planePairCount = planePairKeys.len
    let familyCount = edgeKindOrder.len * planePairCount
    if familyTotalCounts.len != familyCount ||
       familySampleCounts.len != familyCount ||
       familySampleHits.len != familyCount * specs.len:
        system.panic("taiji: semantic edge catalog family vector length mismatch")
    var validatedEdgeCount: int32 = 0
    var nonzeroFamilyCount: int32 = 0
    var sampleRows: str[]
    var familyRows: str[]
    var fields: str[]
    sampleRows = []
    familyRows = []
    fields = []
    for i in 0..<specs.len:
        add(sampleRows,
            jsonInlineObject([jsonInlineFieldRaw("slot", intToStr(i)),
                              jsonInlineFieldRaw("source_label", jsonQuote(sampleLabels[i])),
                              jsonInlineFieldRaw("source_kind", jsonQuote(specs[i].sourceKind)),
                              jsonInlineFieldRaw("gate_class", jsonQuote(specs[i].gateClass))]))
    for edgeKindIdx in 0..<edgeKindOrder.len:
        for leftIdx in 0..<planeOrder.len:
            for rightIdx in 0..<planeOrder.len:
                let pairIdx = leftIdx * planeOrder.len + rightIdx
                let familyIdx = edgeKindIdx * planePairCount + pairIdx
                let totalCount = familyTotalCounts[familyIdx]
                if totalCount > 0:
                    nonzeroFamilyCount = nonzeroFamilyCount + 1
                validatedEdgeCount = validatedEdgeCount + totalCount
                var sampleSlots: int32[]
                var gateClassCounts: int32[]
                var sourceKindCounts: int32[]
                sampleSlots = []
                gateClassCounts = [0, 0, 0]
                sourceKindCounts = [0, 0, 0, 0]
                for sampleIdx in 0..<specs.len:
                    let hitIdx = familyIdx * specs.len + sampleIdx
                    if familySampleHits[hitIdx] == 0:
                        continue
                    add(sampleSlots, sampleIdx)
                    let gateClassIdx = planeIndex(gateClassOrder, specs[sampleIdx].gateClass)
                    let sourceKindIdx = planeIndex(sourceKindOrder, specs[sampleIdx].sourceKind)
                    if gateClassIdx < 0 || sourceKindIdx < 0:
                        system.panic("taiji: semantic edge catalog sample class mismatch")
                    gateClassCounts[gateClassIdx] = gateClassCounts[gateClassIdx] + 1
                    sourceKindCounts[sourceKindIdx] = sourceKindCounts[sourceKindIdx] + 1
                add(familyRows,
                    jsonInlineObject([jsonInlineFieldRaw("family_id",
                                                         jsonQuote(edgeKindOrder[edgeKindIdx] + "|" +
                                                                   planePairKeys[pairIdx])),
                                      jsonInlineFieldRaw("edge_kind", jsonQuote(edgeKindOrder[edgeKindIdx])),
                                      jsonInlineFieldRaw("source_plane", jsonQuote(planeOrder[leftIdx])),
                                      jsonInlineFieldRaw("target_plane", jsonQuote(planeOrder[rightIdx])),
                                      jsonInlineFieldRaw("orthogonal",
                                                         if bcore.isOrthogonal(planeOrder[leftIdx],
                                                                               planeOrder[rightIdx]):
                                                             "true"
                                                         else:
                                                             "false"),
                                      jsonInlineFieldRaw("allowed",
                                                         if bcore.allowEdge(edgeKindOrder[edgeKindIdx],
                                                                            planeOrder[leftIdx],
                                                                            planeOrder[rightIdx]):
                                                             "true"
                                                         else:
                                                             "false"),
                                      jsonInlineFieldRaw("total_count", intToStr(totalCount)),
                                      jsonInlineFieldRaw("sample_count", intToStr(familySampleCounts[familyIdx])),
                                      jsonInlineFieldRaw("sample_slots", jsonIntArray(sampleSlots)),
                                      jsonInlineFieldRaw("gate_class_counts",
                                                         jsonInlineCountObject(gateClassOrder, gateClassCounts)),
                                      jsonInlineFieldRaw("source_kind_counts",
                                                         jsonInlineCountObject(sourceKindOrder, sourceKindCounts))]))
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.bpi_semantic_edge_catalog.v1")))
    add(fields, jsonFieldRaw("bpi_validation_scope",
                             jsonInlineObject([jsonInlineFieldRaw("phase", jsonQuote("lowers_to")),
                                               jsonInlineFieldRaw("proof", jsonQuote("gates"))])))
    add(fields, jsonFieldRaw("sample_count", intToStr(specs.len)))
    add(fields, jsonFieldRaw("family_count", intToStr(familyCount)))
    add(fields, jsonFieldRaw("nonzero_family_count", intToStr(nonzeroFamilyCount)))
    add(fields, jsonFieldRaw("validated_edge_count", intToStr(validatedEdgeCount)))
    add(fields, jsonFieldRaw("edge_kind_order", jsonStringArray(edgeKindOrder)))
    add(fields, jsonFieldRaw("plane_pair_order", jsonStringArray(planePairKeys)))
    add(fields, jsonFieldRaw("samples", jsonRawArray(sampleRows)))
    add(fields, jsonFieldRaw("families", jsonRawArray(familyRows)))
    return taijiDocument(jsonObject(fields))

fn runTaijiSeedSet(): int32 =
    let outDir = taijiSeedOutDir()
    createDirAll(outDir)
    let manifestPath = taijiSeedManifestPath(outDir)
    let catalogPath = taijiSeedSemanticEdgeCatalogPath(outDir)
    let specs = taijiSeedSpecs()
    let edgeKindOrder = semanticEdgeKindOrder()
    let planeOrder = ["P1=乾坤", "P2=坎离", "P3=艮兑", "P4=震巽"]
    let planePairKeys = planePairOrder(planeOrder)
    var manifestLines: str[]
    var sampleLabels: str[]
    var familyTotalCounts: int32[]
    var familySampleCounts: int32[]
    var familySampleHits: int32[]
    manifestLines = []
    sampleLabels = []
    familyTotalCounts = []
    familySampleCounts = []
    familySampleHits = []
    var handwrittenCount: int32 = 0
    var contractCount: int32 = 0
    var observationCount: int32 = 0
    for i in 0..<edgeKindOrder.len * planePairKeys.len:
        add(familyTotalCounts, 0)
        add(familySampleCounts, 0)
    for i in 0..<edgeKindOrder.len * planePairKeys.len * specs.len:
        add(familySampleHits, 0)
    for i in 0..<specs.len:
        let spec = specs[i]
        let sampleDir = taijiSeedSampleDir(outDir, spec.sampleId)
        createDirAll(sampleDir)
        let astDoc = taijiAstDocument(spec.sourcePath, spec.sourceLabel, spec.builtInSample)
        let lowDoc = taijiLowUirDocument(spec.sourcePath, spec.sourceLabel, spec.builtInSample)
        let traceDoc = taijiPhaseTraceDocument(spec.sourcePath, spec.sourceLabel, spec.builtInSample)
        let proof = taijiProofDocument(spec.sourcePath, spec.sourceLabel, spec.builtInSample)
        if !proof.allPass:
            system.panic("taiji: proof obligations failed for " + spec.sampleId)
        let proofDoc = taijiDocument(proof.text)
        let profileDoc = taijiProfileDocument(spec.sourcePath,
                                              spec.sourceLabel,
                                              spec.sourceKind,
                                              astDoc,
                                              lowDoc,
                                              traceDoc,
                                              proofDoc)
        let lowNodeIds = jsonArrayIntValues(jsonDocFieldRaw(lowDoc.text, "node_ids"))
        let lowPlanes = jsonArrayStringValues(jsonDocFieldRaw(lowDoc.text, "bagua_plane"))
        let phaseEdgeNodeIds = jsonArrayIntValues(jsonDocFieldRaw(traceDoc.text, "low_uir_node_ids"))
        let phaseTargetPlanes = jsonArrayStringValues(jsonDocFieldRaw(traceDoc.text, "plane"))
        let phaseEdgeKinds = semanticPhaseEdgeKinds(jsonArrayStringValues(jsonDocFieldRaw(traceDoc.text, "reasons")),
                                                    spec.sourceKind)
        let proofEdgeNodeIds = jsonArrayIntValues(jsonDocFieldRaw(proofDoc.text, "targets"))
        let proofTargetPlanes = jsonArrayStringValues(jsonDocFieldRaw(proofDoc.text, "bagua_gate_plane"))
        let proofEdgeKinds = semanticProofEdgeKinds(jsonArrayStringValues(jsonDocFieldRaw(proofDoc.text, "kinds")),
                                                    jsonArrayStringValues(jsonDocFieldRaw(proofDoc.text, "assumptions")),
                                                    spec.sourceKind)
        let phaseFamilyCounts = semanticEdgeFamilyCounts(lowNodeIds,
                                                         lowPlanes,
                                                         phaseEdgeNodeIds,
                                                         phaseTargetPlanes,
                                                         phaseEdgeKinds,
                                                         edgeKindOrder,
                                                         planeOrder)
        let proofFamilyCounts = semanticEdgeFamilyCounts(lowNodeIds,
                                                         lowPlanes,
                                                         proofEdgeNodeIds,
                                                         proofTargetPlanes,
                                                         proofEdgeKinds,
                                                         edgeKindOrder,
                                                         planeOrder)
        writeTextFile(taijiSeedSamplePath(outDir, spec.sampleId, "taiji_ast_graph.json"), astDoc.text)
        writeTextFile(taijiSeedSamplePath(outDir, spec.sampleId, "taiji_low_uir_graph.json"), lowDoc.text)
        writeTextFile(taijiSeedSamplePath(outDir, spec.sampleId, "taiji_bagua_trace.json"), traceDoc.text)
        writeTextFile(taijiSeedSamplePath(outDir, spec.sampleId, "taiji_proof_tasks.json"), proofDoc.text)
        writeTextFile(taijiSeedProfilePath(outDir, spec.sampleId), profileDoc.text)
        add(manifestLines, taijiSeedManifestLine(spec, astDoc, lowDoc, traceDoc, proofDoc, profileDoc))
        add(sampleLabels, spec.sourceLabel)
        updateSemanticEdgeFamilyCounts(familyTotalCounts,
                                       familySampleCounts,
                                       familySampleHits,
                                       i,
                                       phaseFamilyCounts,
                                       specs.len)
        updateSemanticEdgeFamilyCounts(familyTotalCounts,
                                       familySampleCounts,
                                       familySampleHits,
                                       i,
                                       proofFamilyCounts,
                                       specs.len)
        if spec.gateClass == "handwritten_core":
            handwrittenCount = handwrittenCount + 1
        elif spec.gateClass == "contract_sample":
            contractCount = contractCount + 1
        else:
            observationCount = observationCount + 1
    let manifestText = joinTextList(manifestLines, "\n")
    let catalogDoc = taijiSemanticEdgeCatalogDocument(specs,
                                                      sampleLabels,
                                                      familyTotalCounts,
                                                      familySampleCounts,
                                                      familySampleHits)
    writeTextFile(manifestPath, manifestText)
    writeTextFile(catalogPath, catalogDoc.text)
    printLine("taiji_seed_ok=1")
    printLine("seed_count=" + intToStr(specs.len))
    printLine("handwritten_core_count=" + intToStr(handwrittenCount))
    printLine("contract_sample_count=" + intToStr(contractCount))
    printLine("compiler_observation_count=" + intToStr(observationCount))
    printLine("manifest_path=" + manifestPath)
    printLine("manifest_cid=" + ident.sha256HexText(manifestText))
    printLine("semantic_edge_catalog_path=" + catalogPath)
    printLine("semantic_edge_catalog_cid=" + catalogDoc.cid)
    return 0

fn stageReleasePath(stageDir: str): str =
    return joinPath2(stageDir, "release.txt")

fn stageSystemLinkPlanPath(stageDir: str): str =
    return joinPath2(stageDir, "system_link_plan.txt")

fn stageSystemLinkExecPath(stageDir: str): str =
    return joinPath2(stageDir, "system_link_exec.txt")

fn stageBinaryPath(stageDir: str, binaryName: str): str =
    return joinPath2(stageDir, binaryName)

fn stageRootDir(outDir: str): str =
    return joinPath2(outDir, "stages")

fn stageNamedDir(outDir: str, stageName: str): str =
    return joinPath2(stageRootDir(outDir), stageName)

fn stage2ToolingDirPath(outDir: str): str =
    return joinPath2(outDir, "stage2_tooling_selfhost")

fn stage2ToolingReportPath(outDir: str): str =
    return joinPath2(stage2ToolingDirPath(outDir), "tooling_selfhost_host.txt")

fn toolingSelfhostPath(outDir: str, fileName: str): str =
    return joinPath2(outDir, fileName)

fn buildStageArtifacts(compilerPath: str,
                       sourcePath: str,
                       targetTriple: str,
                       stageDir: str,
                       binaryName: str): NativeStageArtifacts =
    createDirAll(stageDir)
    let releasePath = stageReleasePath(stageDir)
    let systemLinkPlanPath = stageSystemLinkPlanPath(stageDir)
    let systemLinkExecPath = stageSystemLinkExecPath(stageDir)
    let binaryPath = stageBinaryPath(stageDir, binaryName)
    let workingDir = currentWorkingDir()
    let releaseArgv = ["release-compile", "--in", sourcePath, "--emit", "exe", "--target", targetTriple, "--out", releasePath]
    let releaseOutput = runCompilerCommandOrPanic(compilerPath, releaseArgv, workingDir, "stage-selfhost-host release-compile failed")
    writeTextFile(releasePath, releaseOutput)
    let systemLinkPlanArgv = ["system-link-plan", "--in", sourcePath, "--emit", "exe", "--target", targetTriple, "--out", systemLinkPlanPath]
    let systemLinkPlanOutput = runCompilerCommandOrPanic(compilerPath, systemLinkPlanArgv, workingDir, "stage-selfhost-host system-link-plan failed")
    writeTextFile(systemLinkPlanPath, systemLinkPlanOutput)
    let systemLinkExecArgv = ["system-link-exec", "--in", sourcePath, "--emit", "exe", "--target", targetTriple, "--out", binaryPath, "--report-out", systemLinkExecPath]
    let systemLinkExecOutput = runCompilerCommandOrPanic(compilerPath, systemLinkExecArgv, workingDir, "stage-selfhost-host system-link-exec failed")
    writeTextFile(systemLinkExecPath, systemLinkExecOutput)
    let compilerCoreProviderSourceKind = compilerCoreProviderSourceKind(systemLinkPlanOutput)
    let compilerCoreProviderCompileMode = compilerCoreProviderCompileMode(systemLinkPlanOutput)
    var out: NativeStageArtifacts
    out.compilerPath = compilerPath
    out.releasePath = releasePath
    out.systemLinkPlanPath = systemLinkPlanPath
    out.systemLinkExecPath = systemLinkExecPath
    out.binaryPath = binaryPath
    out.binaryCid = sexec.readFileSha256Hex(binaryPath)
    out.outputFileCid = sexec.extractLineValue(systemLinkExecOutput, "output_file_cid")
    out.externalCcProviderCount = countExternalCcProvidersFromPlanText(systemLinkPlanOutput)
    out.compilerCoreProviderSourceKind = compilerCoreProviderSourceKind
    out.compilerCoreProviderCompileMode = compilerCoreProviderCompileMode
    return out

fn readRequiredLineValue(text: str, key: str, label: str): str =
    let value = extractLineValue(text, key)
    if len(value) <= 0:
        system.panic(label + key)
    return value

fn uint64HexDigitLower(value: uint64): str =
    let digit = int32(value & uint64(15))
    if digit < 10:
        return charToStr(char(int32('0') + digit))
    return charToStr(char(int32('a') + (digit - 10)))

fn uint64HexLower16(value: uint64): str =
    var out: str = ""
    var shift: int32 = 60
    while shift >= 0:
        out = out + uint64HexDigitLower(value >> uint64(shift))
        shift = shift - 4
    return out

fn fnv1a64UpdateText(seed: uint64, text: str): uint64 =
    var out = seed
    for i in 0..<len(text):
        out = out ^ uint64(int32(text[i]))
        out = out * uint64(1099511628211)
    return out

fn toolingNormalizeRepoPath(raw: str, repoRoot: str): str =
    if len(raw) <= 0:
        system.panic("missing input path")
    let abs = absolutePath(raw)
    if len(abs) <= 0:
        system.panic("missing normalized path")
    if len(repoRoot) > 0 && textStartsWith(abs, repoRoot):
        if len(abs) == len(repoRoot):
            return abs
        if len(abs) > len(repoRoot) && abs[len(repoRoot)] == '/':
            return strings.sliceBytes(abs, len(repoRoot) + 1, len(abs) - len(repoRoot) - 1)
    return abs

fn toolingProgramFromFlags(): ToolingBootstrapProgram =
    let repoRoot = currentRepoRoot()
    let rootRaw = readFlagDefault("--root", "v2/examples")
    let sourceRaw = readFlagDefault("--in", "v2/examples/network_distribution_module.cheng")
    let targetRaw = readFlagDefault("--target", "arm64-apple-darwin")
    let emitRaw = readFlagDefault("--emit", "exe")
    let rootPath = toolingNormalizeRepoPath(rootRaw, repoRoot)
    let sourcePath = toolingNormalizeRepoPath(sourceRaw, repoRoot)
    if !os.dirExists(rootPath):
        system.panic("tooling selfhost: missing root " + rootPath)
    if !os.fileExists(sourcePath):
        system.panic("tooling selfhost: missing source " + sourcePath)
    var out: ToolingBootstrapProgram
    out.rootPath = rootPath
    out.sourcePath = sourcePath
    out.targetTriple = targetRaw
    out.emitKind = emitRaw
    return out

fn toolingChengLiteralEscape(text: str): str =
    var out: str = "\""
    for i in 0..<len(text):
        let ch = text[i]
        if ch == '\\':
            out = out + "\\\\"
        elif ch == '"':
            out = out + "\\\""
        elif ch == '\n':
            out = out + "\\n"
        else:
            out = out + charToStr(ch)
    out = out + "\""
    return out

fn toolingEmitStage1ModuleText(program: ToolingBootstrapProgram): str =
    var lines: str[] = []
    add(lines, "import compiler/driver/manifest_resolver_v2 as manifest")
    add(lines, "import compiler/driver/release_artifact_v2 as rart")
    add(lines, "import compiler/driver/network_distribution_pipeline_v2 as npipe")
    add(lines, "import compiler/frontend/v2_source_parser as parser")
    add(lines, "")
    add(lines, "fn bootstrapExamplesRoot(): str =")
    add(lines, "    return " + toolingChengLiteralEscape(program.rootPath))
    add(lines, "")
    add(lines, "fn bootstrapNetworkSource(): str =")
    add(lines, "    return " + toolingChengLiteralEscape(program.sourcePath))
    add(lines, "")
    add(lines, "fn bootstrapTargetTriple(): str =")
    add(lines, "    return " + toolingChengLiteralEscape(program.targetTriple))
    add(lines, "")
    add(lines, "fn bootstrapReleaseEmitKind(): str =")
    add(lines, "    return " + toolingChengLiteralEscape(program.emitKind))
    add(lines, "")
    add(lines, "fn bootstrapSourceManifest(): manifest.SourceManifestBundle =")
    add(lines, "    return manifest.resolveSourceManifest(bootstrapExamplesRoot())")
    add(lines, "")
    add(lines, "fn bootstrapNetworkPipeline(): npipe.NetworkDistributionPipelineBundle =")
    add(lines, "    let parsed = parser.parseV2SourceFileStrict(bootstrapNetworkSource())")
    add(lines, "    return npipe.compileNetworkDistributionProgram(parsed.networkProgram)")
    add(lines, "")
    add(lines, "fn bootstrapReleaseArtifact(): rart.ReleaseArtifactBundle =")
    add(lines, "    return rart.buildReleaseArtifact(bootstrapNetworkSource(), bootstrapReleaseEmitKind(), bootstrapTargetTriple())")
    return mresolve.joinLines(lines)

fn toolingParseStage1ReturnString(line: str): str =
    let trimmed = trimAsciiWhitespace(line)
    if !textStartsWith(trimmed, "return "):
        return ""
    let raw = trimAsciiWhitespace(strings.sliceBytes(trimmed, len("return "), len(trimmed) - len("return ")))
    if len(raw) < 2 || raw[0] != '"' || raw[len(raw) - 1] != '"':
        return ""
    var out: str = ""
    var i: int32 = 1
    while i < len(raw) - 1:
        let ch = raw[i]
        if ch == '\\' && i + 1 < len(raw) - 1:
            let esc = raw[i + 1]
            if esc == 'n':
                out = out + "\n"
            else:
                out = out + charToStr(esc)
            i = i + 2
        else:
            out = out + charToStr(ch)
            i = i + 1
    return out

fn toolingParseStage1ProgramText(text: str): ToolingBootstrapProgram =
    var currentFn: str = ""
    var rootPath: str = ""
    var sourcePath: str = ""
    var targetTriple: str = ""
    var emitKind: str = ""
    var lineStart: int32 = 0
    for i in 0..len(text):
        if i == len(text) || text[i] == '\n':
            let line = trimAsciiWhitespace(strings.sliceBytes(text, lineStart, i - lineStart))
            if textStartsWith(line, "fn bootstrapExamplesRoot(): str ="):
                currentFn = "bootstrapExamplesRoot"
            elif textStartsWith(line, "fn bootstrapNetworkSource(): str ="):
                currentFn = "bootstrapNetworkSource"
            elif textStartsWith(line, "fn bootstrapTargetTriple(): str ="):
                currentFn = "bootstrapTargetTriple"
            elif textStartsWith(line, "fn bootstrapReleaseEmitKind(): str ="):
                currentFn = "bootstrapReleaseEmitKind"
            elif textStartsWith(line, "return "):
                let value = toolingParseStage1ReturnString(line)
                if currentFn == "bootstrapExamplesRoot":
                    rootPath = value
                elif currentFn == "bootstrapNetworkSource":
                    sourcePath = value
                elif currentFn == "bootstrapTargetTriple":
                    targetTriple = value
                elif currentFn == "bootstrapReleaseEmitKind":
                    emitKind = value
            lineStart = i + 1
    if len(rootPath) <= 0 || len(sourcePath) <= 0 || len(targetTriple) <= 0 || len(emitKind) <= 0:
        system.panic("tooling selfhost: incomplete stage1 bootstrap module")
    var out: ToolingBootstrapProgram
    out.rootPath = rootPath
    out.sourcePath = sourcePath
    out.targetTriple = targetTriple
    out.emitKind = emitKind
    return out

fn toolingBuildNetworkSelfhostReport(rootPath: str, sourcePath: str, targetTriple: str): NetworkSelfhostReport =
    let manifestBundle = mresolve.resolveSourceManifest(rootPath)
    let networkBundle = networkBundleFromSource(sourcePath)
    let releaseBundle = rart.buildReleaseArtifact(sourcePath, "exe", targetTriple)
    let rulePackOpCount = canonicalOpCountForDomain(networkBundle, "rule_pack")
    let compilerRulePackOpCount = canonicalOpCountForDomain(networkBundle, "compiler_rule_pack")
    let hasPublishSourceManifestOp = hasCanonicalOp(networkBundle, "publish_source_manifest")
    let hasPublishRulePackOp = hasCanonicalOp(networkBundle, "publish_rule_pack")
    let hasPublishCompilerRulePackOp = hasCanonicalOp(networkBundle, "publish_compiler_rule_pack")
    var out: NetworkSelfhostReport
    out.ok = false
    if manifestBundle.topologyCanonicalForms.len <= 0:
        out.reason = "missing_topology_canonical_form"
        return out
    if !verifyPriorityMappings(networkBundle):
        out.reason = "priority_mapping_mismatch"
        return out
    if !hasPublishSourceManifestOp || !hasPublishRulePackOp || !hasPublishCompilerRulePackOp:
        out.reason = "missing_publish_ops"
        return out
    if rulePackOpCount <= 0:
        out.reason = "missing_rule_pack_domain_ops"
        return out
    if compilerRulePackOpCount <= 0:
        out.reason = "missing_compiler_rule_pack_domain_ops"
        return out
    if releaseBundle.moduleKind != "network_distribution":
        out.reason = "release_artifact_wrong_module_kind"
        return out
    if releaseBundle.manifestCid != manifestBundle.manifestCid:
        out.reason = "release_manifest_mismatch"
        return out
    if !releaseCompileKeyCoversNetworkBundle(releaseBundle, networkBundle):
        out.reason = "compile_key_missing_network_fields"
        return out
    if !releaseBundle.nativeLinkClosureOk:
        out.reason = "native_link_closure_unresolved"
        return out
    out.ok = true
    out.reason = ""
    out.sourceManifestText = buildSourceManifestArtifactText(manifestBundle)
    out.sourceManifestCid = manifestBundle.manifestCid
    out.rulePackText = buildNetworkArtifactText(networkBundle, "rule_pack", "v2.rule_pack.v1")
    out.rulePackCid = ident.sha256HexText(out.rulePackText)
    out.compilerRulePackText = buildNetworkArtifactText(networkBundle, "compiler_rule_pack", "v2.compiler_rule_pack.v1")
    out.compilerRulePackCid = ident.sha256HexText(out.compilerRulePackText)
    out.releaseArtifactText = releaseBundle.artifactText + "\n"
    out.releaseCompileKey = releaseBundle.compileKey
    out.objImageCid = releaseBundle.objImageCid
    out.objSectionCount = releaseBundle.objSectionCount
    out.objSymbolCount = releaseBundle.objSymbolCount
    out.objRelocCount = releaseBundle.objRelocCount
    out.linkPlanCid = releaseBundle.linkPlanCid
    out.runtimeTargetCount = releaseBundle.runtimeTargetCount
    out.runtimeUnresolvedCount = releaseBundle.runtimeUnresolvedCount
    out.nativeLinkClosureOk = releaseBundle.nativeLinkClosureOk
    out.topologyCount = manifestBundle.topologyCanonicalForms.len
    out.rulePackEntryCount = rulePackOpCount
    out.compilerRulePackEntryCount = compilerRulePackOpCount
    out.compileKeyTopologyCovered = true
    out.compileKeyAddressingCovered = true
    out.compileKeyDepthCovered = true
    out.compileKeyAddressBindingCovered = true
    out.compileKeyDistanceMetricCovered = true
    out.compileKeyPriorityCovered = true
    out.compileKeyDispersalCovered = true
    out.compileKeySignatureCovered = true
    out.compileKeyCanonicalMultipathCovered = true
    out.releaseManifestMatchesSourceManifest = true
    out.lsmrPriorityMappingFixed = true
    out.lsmrAddressingMode = lcontract.lsmrRuntimeContract().addressingMode
    out.lsmrAddressBinding = lcontract.lsmrRuntimeContract().addressBinding
    out.lsmrDistanceMetric = lcontract.lsmrRuntimeContract().distanceMetric
    out.lsmrRoutePlanModel = lcontract.lsmrRuntimeContract().routePlanModel
    out.randomGossipFallbackPresent = false
    return out

fn toolingBuildStageResult(program: ToolingBootstrapProgram): ToolingSelfhostStageResult =
    var out: ToolingSelfhostStageResult
    out.report = toolingBuildNetworkSelfhostReport(program.rootPath, program.sourcePath, program.targetTriple)
    if !out.report.ok:
        return out
    out.sourceManifestText = out.report.sourceManifestText
    out.rulePackText = out.report.rulePackText
    out.compilerRulePackText = out.report.compilerRulePackText
    out.releaseArtifactText = out.report.releaseArtifactText
    var hash: uint64 = uint64(1469598103934665603)
    hash = fnv1a64UpdateText(hash, "v2.bootstrap.tooling_stage1.v1")
    hash = fnv1a64UpdateText(hash, program.rootPath)
    hash = fnv1a64UpdateText(hash, program.sourcePath)
    hash = fnv1a64UpdateText(hash, program.targetTriple)
    hash = fnv1a64UpdateText(hash, program.emitKind)
    hash = fnv1a64UpdateText(hash, out.report.sourceManifestCid)
    hash = fnv1a64UpdateText(hash, out.report.rulePackCid)
    hash = fnv1a64UpdateText(hash, out.report.compilerRulePackCid)
    hash = fnv1a64UpdateText(hash, out.report.releaseCompileKey)
    hash = fnv1a64UpdateText(hash, out.report.objImageCid)
    out.stageHash = hash
    return out

fn toolingStageResultsEqual(left: ToolingSelfhostStageResult, right: ToolingSelfhostStageResult): bool =
    if !left.report.ok || !right.report.ok:
        return false
    return left.sourceManifestText == right.sourceManifestText &&
           left.rulePackText == right.rulePackText &&
           left.compilerRulePackText == right.compilerRulePackText &&
           left.releaseArtifactText == right.releaseArtifactText &&
           left.report.sourceManifestCid == right.report.sourceManifestCid &&
           left.report.rulePackCid == right.report.rulePackCid &&
           left.report.compilerRulePackCid == right.report.compilerRulePackCid &&
           left.report.releaseCompileKey == right.report.releaseCompileKey &&
           left.report.objImageCid == right.report.objImageCid &&
           left.stageHash == right.stageHash

fn removeTree(path: str) =
    if len(path) <= 0:
        return
    if os.fileExists(path):
        let _ = os.removeFile(path)
        return
    if !os.dirExists(path):
        return
    let entries = os.walkDir(path)
    for i in 0..<entries.len:
        let childPath = os.walkDirEntryPath(entries[i])
        if os.dirExists(childPath):
            removeTree(childPath)
        elif os.fileExists(childPath):
            let _ = os.removeFile(childPath)
    os.removeDir(path)

fn buildProgramBinaryOrPanic(compilerPath: str,
                             sourcePath: str,
                             targetTriple: str,
                             binaryPath: str,
                             label: str) =
    let workingDir = currentWorkingDir()
    let argv = ["system-link-exec", "--in", sourcePath, "--emit", "exe", "--target", targetTriple, "--out", binaryPath]
    let _ = runCompilerCommandOrPanic(compilerPath, argv, workingDir, label)

const toolingProgramRunTimeoutDefaultSec: int32 = 30
const toolingProgramRunTimeoutNetworkSmokeSec: int32 = 60
const toolingProgramRunTimeoutChainNodeSec: int32 = 10

fn runBinaryCaptureOrPanic(binaryPath: str,
                           argv: str[],
                           label: str,
                           timeoutSeconds: int32): str =
    let result = hostos.execFileCapture(binaryPath, argv, [], currentWorkingDir(), true, timeoutSeconds)
    let output = os.execCmdResultOutput(result)
    if os.execCmdResultExitCode(result) != 0:
        system.panic(label + "\n" + output)
    return output

const toolingProcessRunning: int32 = -2147483000

fn toolingAllocateLoopbackUdpPortOrPanic(label: str): int32 =
    let fd = os.udpBindFdBridge("127.0.0.1", 0, 0)
    if fd < 0:
        system.panic(label + "\nfailed to allocate loopback udp port")
    let port = os.udpBoundPortBridge(fd, 0)
    let _ = os.udpCloseFd(fd)
    if port <= 0:
        system.panic(label + "\nfailed to read allocated loopback udp port")
    return port

fn toolingLastNonEmptyLine(text: str): str =
    var out = ""
    var start = 0
    var i = 0
    while i <= len(text):
        if i == len(text) || text[i] == '\n':
            let line = strutils.strip(strings.sliceBytes(text, start, i - start))
            if len(line) > 0:
                out = line
            start = i + 1
        i = i + 1
    return out

fn toolingClosePipeFd(fd: var int32) =
    if fd >= 0:
        hostos.ptyClose(fd)
        fd = -1

fn toolingDrainPipeOutput(readFd: var int32, out: var str, timeoutMs: int32) =
    if readFd < 0:
        return
    var waitMs = timeoutMs
    while readFd >= 0:
        let readRes = hostos.fdReadWait(readFd, 65536, waitMs)
        let chunk = readRes[0]
        let eof = readRes[1]
        if len(chunk) > 0:
            out = out + chunk
            waitMs = 0
            continue
        if eof:
            toolingClosePipeFd(readFd)
        break

fn toolingSpawnedProcessPoll(pid: var int64,
                             readFd: var int32,
                             out: var str): int32 =
    if pid <= 0:
        return 0
    toolingDrainPipeOutput(readFd, out, 0)
    let waitRes = hostos.ptyWait(pid)
    let waitStatus = waitRes[0]
    if waitStatus == 1:
        let exitCode = waitRes[1]
        toolingDrainPipeOutput(readFd, out, 0)
        pid = 0
        return exitCode
    if waitStatus < 0:
        toolingDrainPipeOutput(readFd, out, 0)
        pid = 0
        return -1
    return toolingProcessRunning

fn toolingSpawnedProcessKill(pid: var int64,
                             readFd: var int32,
                             writeFd: var int32,
                             out: var str) =
    toolingClosePipeFd(writeFd)
    if pid > 0:
        let _ = hostos.processSignal(pid, 15)
        os.sleepMs(100)
        let _ = hostos.processSignal(pid, 9)
        let _wait = hostos.ptyWait(pid)
        pid = 0
    toolingDrainPipeOutput(readFd, out, 0)
    toolingClosePipeFd(readFd)

fn toolingSpawnedProcessWaitOrPanic(pid: var int64,
                                    readFd: var int32,
                                    writeFd: var int32,
                                    out: var str,
                                    timeoutMs: int32,
                                    label: str): int32 =
    var remaining = timeoutMs
    while true:
        let status = toolingSpawnedProcessPoll(pid, readFd, out)
        if status != toolingProcessRunning:
            toolingClosePipeFd(writeFd)
            toolingDrainPipeOutput(readFd, out, 0)
            toolingClosePipeFd(readFd)
            return status
        if remaining <= 0:
            toolingSpawnedProcessKill(pid, readFd, writeFd, out)
            system.panic(label + "\nserve-once timeout\n" + out)
        os.sleepMs(20)
        remaining = remaining - 20

fn runChainNodeProcessSmokeCaptureOrPanic(chainNodeBinary: str,
                                          programsDir: str,
                                          label: str): str =
    let serverRoot = joinPath2(programsDir, "chain_node_process_server_root")
    let clientRoot = joinPath2(programsDir, "chain_node_process_client_root")
    let serverLog = joinPath2(programsDir, "chain_node_process_server.stdout")
    let syncLog = joinPath2(programsDir, "chain_node_process_client_sync.stdout")
    removeTree(serverRoot)
    removeTree(clientRoot)
    removeTree(serverLog)
    removeTree(syncLog)
    let port = toolingAllocateLoopbackUdpPortOrPanic(label)
    let listen = "/ip4/127.0.0.1/udp/" + intToStr(port) + "/quic-v1"
    let _mintStdout = runBinaryCaptureOrPanic(chainNodeBinary,
                                              ["mint",
                                               "--root", serverRoot,
                                               "--node-id", "server",
                                               "--account", "alice",
                                               "--asset", "cheng",
                                               "--amount", "11"],
                                              label + "\nmint failed",
                                              toolingProgramRunTimeoutChainNodeSec)
    let serverSpawn = hostos.execFilePipeSpawn(chainNodeBinary,
                                           ["serve-once",
                                            "--root", serverRoot,
                                            "--node-id", "server",
                                            "--listen", listen],
                                           [],
                                           currentWorkingDir())
    if !serverSpawn[0]:
        system.panic(label + "\nserve-once spawn failed")
    var serverReadFd = serverSpawn[1]
    var serverWriteFd = serverSpawn[2]
    var serverPid = serverSpawn[3]
    var serverOutput = ""
    toolingClosePipeFd(serverWriteFd)
    os.sleepMs(1000)
    let serverEarlyStatus = toolingSpawnedProcessPoll(serverPid, serverReadFd, serverOutput)
    writeTextFile(serverLog, serverOutput)
    if serverEarlyStatus != toolingProcessRunning:
        toolingSpawnedProcessKill(serverPid, serverReadFd, serverWriteFd, serverOutput)
        writeTextFile(serverLog, serverOutput)
        system.panic(label + "\nserve-once exited before sync\n" + serverOutput)
    let syncResult = hostos.execFileCapture(chainNodeBinary,
                                        ["sync-once",
                                         "--root", clientRoot,
                                         "--node-id", "client",
                                         "--peer", listen],
                                        [],
                                        currentWorkingDir(),
                                        true,
                                        90)
    let syncOutput = os.execCmdResultOutput(syncResult)
    writeTextFile(syncLog, syncOutput)
    if os.execCmdResultExitCode(syncResult) != 0:
        toolingSpawnedProcessKill(serverPid, serverReadFd, serverWriteFd, serverOutput)
        writeTextFile(serverLog, serverOutput)
        system.panic(label + "\nsync-once failed\n" + syncOutput + "\n" + serverOutput)
    let balanceResult = hostos.execFileCapture(chainNodeBinary,
                                           ["balance",
                                            "--root", clientRoot,
                                            "--node-id", "client",
                                            "--account", "alice",
                                            "--asset", "cheng"],
                                           [],
                                           currentWorkingDir(),
                                           true,
                                           10)
    let balanceOutput = os.execCmdResultOutput(balanceResult)
    if os.execCmdResultExitCode(balanceResult) != 0:
        toolingSpawnedProcessKill(serverPid, serverReadFd, serverWriteFd, serverOutput)
        writeTextFile(serverLog, serverOutput)
        system.panic(label + "\nbalance failed\n" + balanceOutput + "\n" + serverOutput)
    let serverExitCode = toolingSpawnedProcessWaitOrPanic(serverPid,
                                                          serverReadFd,
                                                          serverWriteFd,
                                                          serverOutput,
                                                          60000,
                                                          label)
    writeTextFile(serverLog, serverOutput)
    if serverExitCode != 0:
        system.panic(label + "\nserve-once failed\n" + serverOutput)
    let syncOut = toolingLastNonEmptyLine(syncOutput)
    let balanceOut = toolingLastNonEmptyLine(balanceOutput)
    let serverOut = toolingLastNonEmptyLine(serverOutput)
    if len(syncOut) <= 0 || len(balanceOut) <= 0 || len(serverOut) <= 0:
        system.panic(label + "\nmissing chain-node process smoke output\n" +
                     "sync=" + syncOutput + "\n" +
                     "balance=" + balanceOutput + "\n" +
                     "server=" + serverOutput)
    var out = ""
    out = out + "chain_node_process_smoke_stage=mint_ok\n"
    out = out + "chain_node_process_smoke_stage=sync_ok\n"
    out = out + "chain_node_process_smoke_stage=balance_ok\n"
    out = out + "sync_output=" + syncOut + "\n"
    out = out + "balance_output=" + balanceOut + "\n"
    out = out + "server_output=" + serverOut + "\n"
    out = out + "chain_node_process_smoke=ok\n"
    return out

fn printRequiredPrefixedLineValue(text: str, sourceKey: str, outputKey: str) =
    let value = readRequiredLineValue(text, sourceKey, "missing required tooling selfhost value ")
    printLine(outputKey + "=" + value)

fn runToolingSelfhostHost(): int32 =
    let compilerPath = absolutePath(readFlagDefault("--compiler", currentCompilerPath()))
    let outDir = absolutePath(readFlagDefault("--out-dir", "v2/artifacts/full_selfhost/tooling_selfhost"))
    let rootRaw = "v2/examples"
    let sourceRaw = "v2/examples/network_distribution_module.cheng"
    let targetRaw = "arm64-apple-darwin"
    let workingDir = currentWorkingDir()
    createDirAll(outDir)
    let sourceManifestStdout = toolingSelfhostPath(outDir, "source_manifest.stdout")
    let sourceManifestFile = toolingSelfhostPath(outDir, "source_manifest.txt")
    let rulePackStdout = toolingSelfhostPath(outDir, "rule_pack.stdout")
    let rulePackFile = toolingSelfhostPath(outDir, "rule_pack.txt")
    let compilerRulePackStdout = toolingSelfhostPath(outDir, "compiler_rule_pack.stdout")
    let compilerRulePackFile = toolingSelfhostPath(outDir, "compiler_rule_pack.txt")
    let releaseStdout = toolingSelfhostPath(outDir, "release_artifact.stdout")
    let releaseFile = toolingSelfhostPath(outDir, "release_artifact.txt")
    let networkSelfhostFile = toolingSelfhostPath(outDir, "network_selfhost.txt")
    let toolingSelfhostCheckFile = toolingSelfhostPath(outDir, "tooling_selfhost_check.txt")

    let sourceManifestArgv = ["publish-source-manifest", "--root", rootRaw, "--out", sourceManifestFile]
    let sourceManifestText = runCompilerCommandOrPanic(compilerPath,
                                                       sourceManifestArgv,
                                                       workingDir,
                                                       "tooling selfhost host: source manifest failed")
    writeTextFile(sourceManifestStdout, sourceManifestText)
    compareExpectedTextOrPanic("v2/tests/contracts/tooling_source_manifest.expected",
                               sourceManifestStdout,
                               "tooling selfhost host: source manifest stdout mismatch")
    compareExpectedTextOrPanic("v2/tests/contracts/tooling_source_manifest.expected",
                               sourceManifestFile,
                               "tooling selfhost host: source manifest file mismatch")

    let rulePackArgv = ["publish-rule-pack", "--in", sourceRaw, "--out", rulePackFile]
    let rulePackText = runCompilerCommandOrPanic(compilerPath,
                                                 rulePackArgv,
                                                 workingDir,
                                                 "tooling selfhost host: rule pack failed")
    writeTextFile(rulePackStdout, rulePackText)
    compareExpectedTextOrPanic("v2/tests/contracts/tooling_rule_pack.expected",
                               rulePackStdout,
                               "tooling selfhost host: rule pack stdout mismatch")
    compareExpectedTextOrPanic("v2/tests/contracts/tooling_rule_pack.expected",
                               rulePackFile,
                               "tooling selfhost host: rule pack file mismatch")

    let compilerRulePackArgv = ["publish-compiler-rule-pack", "--in", sourceRaw, "--out", compilerRulePackFile]
    let compilerRulePackText = runCompilerCommandOrPanic(compilerPath,
                                                         compilerRulePackArgv,
                                                         workingDir,
                                                         "tooling selfhost host: compiler rule pack failed")
    writeTextFile(compilerRulePackStdout, compilerRulePackText)
    compareExpectedTextOrPanic("v2/tests/contracts/tooling_compiler_rule_pack.expected",
                               compilerRulePackStdout,
                               "tooling selfhost host: compiler rule pack stdout mismatch")
    compareExpectedTextOrPanic("v2/tests/contracts/tooling_compiler_rule_pack.expected",
                               compilerRulePackFile,
                               "tooling selfhost host: compiler rule pack file mismatch")

    let releaseArgv = ["release-compile", "--in", sourceRaw, "--emit", "exe", "--target", targetRaw, "--out", releaseFile]
    let releaseText = runCompilerCommandOrPanic(compilerPath,
                                                releaseArgv,
                                                workingDir,
                                                "tooling selfhost host: release compile failed")
    writeTextFile(releaseStdout, releaseText)
    compareExpectedTextOrPanic("v2/tests/contracts/tooling_release_artifact.expected",
                               releaseStdout,
                               "tooling selfhost host: release stdout mismatch")
    compareExpectedTextOrPanic("v2/tests/contracts/tooling_release_artifact.expected",
                               releaseFile,
                               "tooling selfhost host: release file mismatch")

    let networkSelfhostArgv = ["verify-network-selfhost", "--root", rootRaw, "--in", sourceRaw]
    let networkSelfhostText = runCompilerCommandOrPanic(compilerPath,
                                                        networkSelfhostArgv,
                                                        workingDir,
                                                        "tooling selfhost host: network selfhost failed")
    writeTextFile(networkSelfhostFile, networkSelfhostText)
    compareExpectedTextOrPanic("v2/tests/contracts/network_selfhost.expected",
                               networkSelfhostFile,
                               "tooling selfhost host: network selfhost mismatch")

    let toolingSelfhostCheckArgv = ["tooling-selfhost-check", "--root", rootRaw, "--in", sourceRaw]
    let toolingSelfhostCheckText = runCompilerCommandOrPanic(compilerPath,
                                                             toolingSelfhostCheckArgv,
                                                             workingDir,
                                                             "tooling selfhost host: tooling-selfhost-check failed")
    writeTextFile(toolingSelfhostCheckFile, toolingSelfhostCheckText)
    compareExpectedTextOrPanic("v2/tests/contracts/tooling_selfhost.expected",
                               toolingSelfhostCheckFile,
                               "tooling selfhost host: tooling-selfhost-check mismatch")

    printLine("tooling_selfhost_host_ok=1")
    printLine("compiler=" + compilerPath)
    writeText(toolingSelfhostCheckText)
    return 0

fn runStageSelfhostHost(): int32 =
    let compilerPath = absolutePath(readFlagDefault("--compiler", currentCompilerPath()))
    let outDir = absolutePath(readFlagDefault("--out-dir", "v2/artifacts/full_selfhost"))
    let targetTriple = readFlagDefault("--target", "arm64-apple-darwin")
    let sourceRaw = "v2/src/tooling/cheng_v2.cheng"
    let workingDir = currentWorkingDir()
    let stage1Dir = stageNamedDir(outDir, "cheng_v2.stage1")
    let stage2Dir = stageNamedDir(outDir, "cheng_v2.stage2")
    let stage3Dir = stageNamedDir(outDir, "cheng_v2.stage3")
    let stage2ToolingDir = stage2ToolingDirPath(outDir)
    let stage2ToolingReport = stage2ToolingReportPath(outDir)
    createDirAll(stage1Dir)
    createDirAll(stage2Dir)
    createDirAll(stage3Dir)
    let stage1 = buildStageArtifacts(compilerPath, sourceRaw, targetTriple, stage1Dir, "cheng_v2")
    let stage2 = buildStageArtifacts(stage1.binaryPath, sourceRaw, targetTriple, stage2Dir, "cheng_v2")
    let stage3 = buildStageArtifacts(stage2.binaryPath, sourceRaw, targetTriple, stage3Dir, "cheng_v2")
    let releaseEqual = compareTextFiles(stage2.releasePath, stage3.releasePath)
    let planEqual = compareTextFiles(stage2.systemLinkPlanPath, stage3.systemLinkPlanPath)
    let execEqual = compareTextFiles(stage2.systemLinkExecPath, stage3.systemLinkExecPath)
    let binaryEqual = compareBinaryFiles(stage2.binaryPath, stage3.binaryPath)
    let outputCidEqual = stage2.outputFileCid == stage3.outputFileCid
    let noExternalCProvider = stage1.externalCcProviderCount == 0 &&
                              stage2.externalCcProviderCount == 0 &&
                              stage3.externalCcProviderCount == 0 &&
                              stage2.compilerCoreProviderSourceKind == "cheng_module" &&
                              stage2.compilerCoreProviderCompileMode == "machine_obj"
    let toolingSelfhostArgv = ["tooling-selfhost-host", "--compiler", stage2.binaryPath, "--out-dir", stage2ToolingDir]
    let toolingSelfhostText = runCompilerCommandOrPanic(stage2.binaryPath,
                                                        toolingSelfhostArgv,
                                                        workingDir,
                                                        "full selfhost: stage2 tooling selfhost failed")
    writeTextFile(stage2ToolingReport, toolingSelfhostText)
    let stage2ToolingOk = extractLineValue(toolingSelfhostText, "tooling_selfhost_host_ok") == "1"
    let ok = releaseEqual &&
             planEqual &&
             execEqual &&
             binaryEqual &&
             outputCidEqual &&
             stage2ToolingOk &&
             noExternalCProvider
    printLine("full_selfhost_ok=" + if ok: "1" else: "0")
    printLine("compiler=" + compilerPath)
    printLine("stage1_binary_cid=" + stage1.binaryCid)
    printLine("stage2_binary_cid=" + stage2.binaryCid)
    printLine("stage3_binary_cid=" + stage3.binaryCid)
    printLine("stage2_stage3_release_equal=" + if releaseEqual: "1" else: "0")
    printLine("stage2_stage3_system_link_plan_equal=" + if planEqual: "1" else: "0")
    printLine("stage2_stage3_system_link_exec_equal=" + if execEqual: "1" else: "0")
    printLine("stage2_stage3_binary_equal=" + if binaryEqual: "1" else: "0")
    printLine("stage2_stage3_output_file_cid_equal=" + if outputCidEqual: "1" else: "0")
    printLine("stage2_tooling_selfhost_ok=" + if stage2ToolingOk: "1" else: "0")
    printRequiredPrefixedLineValue(toolingSelfhostText, "tooling_selfhost_proof_target", "stage2_tooling_proof_target")
    printRequiredPrefixedLineValue(toolingSelfhostText, "tooling_selfhost_stage0_hash", "stage2_tooling_stage0_hash")
    printRequiredPrefixedLineValue(toolingSelfhostText, "tooling_selfhost_stage1_hash", "stage2_tooling_stage1_hash")
    printRequiredPrefixedLineValue(toolingSelfhostText, "tooling_selfhost_stage2_hash", "stage2_tooling_stage2_hash")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_stage0_stage1_equal",
                                   "stage2_tooling_stage0_stage1_equal")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_stage1_stage2_equal",
                                   "stage2_tooling_stage1_stage2_equal")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_stage1_stage2_source_equal",
                                   "stage2_tooling_stage1_stage2_source_equal")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_source_manifest_cid",
                                   "stage2_tooling_source_manifest_cid")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_rule_pack_cid",
                                   "stage2_tooling_rule_pack_cid")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_compiler_rule_pack_cid",
                                   "stage2_tooling_compiler_rule_pack_cid")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_release_compile_key",
                                   "stage2_tooling_release_compile_key")
    printRequiredPrefixedLineValue(toolingSelfhostText,
