    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_compile_key_topology_covered",
                                   "stage2_tooling_compile_key_topology_covered")
    printRequiredPrefixedLineValue(toolingSelfhostText,
                                   "tooling_selfhost_compile_key_addressing_covered",
