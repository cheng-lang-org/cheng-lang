    return taijiDocument(jsonObject(fields))

fn taijiStringProofDocument(sourcePath: str,
                            sourceLabel: str,
                            bundle: spipe.StringPipelineBundle): TaijiProofArtifact =
    var tasks: str[]
    var fields: str[]
    var allPass: bool = true
    tasks = []
    fields = []
    let contract = sops.lowUirStringOpsContract()
    let baguaAnnotations = lowbagua.annotateLowUirNodes("string",
                                                        bundle.lowPlan.exprIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.allocationModes,
                                                        bundle.lowPlan.runtimeTargets)
    var taskId: int32 = 0
    for i in 0..<bundle.lowPlan.exprIds.len:
        let opIdx = sops.findLowUirStringOp(bundle.lowPlan.canonicalOps[i])
        let contractOp = contract.canonicalOps[opIdx]
        let gatePlane = baguaAnnotations[i].plane
        let gateCell = proofGateCell(baguaAnnotations[i])
        let effectPass = bundle.lowPlan.runtimeTargets[i] == contractOp.runtimeTarget &&
                         bundle.lowPlan.effectClasses[i] == contractOp.effectClass
        validateBaguaProofGate(bundle.lowPlan.exprIds,
                               baguaAnnotations,
                               bundle.lowPlan.exprIds[i],
                               "effect",
                               "string",
                               "runtime_target 与 effect_class 必须和 canonical op 一致",
                               gatePlane,
                               "string_proof|" + bundle.lowPlan.canonicalOps[i] + "|effect")
        allPass = allPass && effectPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("effect")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.exprIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("runtime_target 与 effect_class 必须和 canonical op 一致")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("runtime_target=" + contractOp.runtimeTarget +
                                                                                ", effect_class=" + contractOp.effectClass)),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if effectPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let aliasPass = !bundle.lowPlan.zeroCopyFacts[i] ||
                        bundle.lowPlan.allocationModes[i] == "none" ||
                        bundle.lowPlan.allocationModes[i] == "borrow_view"
        validateBaguaProofGate(bundle.lowPlan.exprIds,
                               baguaAnnotations,
                               bundle.lowPlan.exprIds[i],
                               "alias",
                               "string",
                               "zero_copy=1 时只能保持无分配或借用视图",
                               gatePlane,
                               "string_proof|" + bundle.lowPlan.canonicalOps[i] + "|alias")
        allPass = allPass && aliasPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("alias")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.exprIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("zero_copy=1 时只能保持无分配或借用视图")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("allocation_mode in [none, borrow_view]")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if aliasPass: "pass" else: "fail"))]))
        taskId = taskId + 1
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.proof_tasks.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("string")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("tasks", jsonRawArray(tasks)))
    return taijiProofArtifact(jsonObject(fields), allPass)

fn taijiUnimakerProofDocument(sourcePath: str,
                              sourceLabel: str,
                              bundle: upipe.UnimakerPipelineBundle): TaijiProofArtifact =
    var tasks: str[]
    var fields: str[]
    var allPass: bool = true
    tasks = []
    fields = []
    let contract = uops.lowUirUnimakerOpsContract()
    let baguaAnnotations = lowbagua.annotateLowUirNodes("unimaker",
                                                        bundle.lowPlan.declIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.networkModes,
                                                        bundle.lowPlan.runtimeTargets)
    var taskId: int32 = 0
    for i in 0..<bundle.lowPlan.declIds.len:
        let opIdx = uops.findLowUirUnimakerOp(bundle.lowPlan.canonicalOps[i])
        let contractOp = contract.canonicalOps[opIdx]
        let gatePlane = baguaAnnotations[i].plane
        let gateCell = proofGateCell(baguaAnnotations[i])
        let effectPass = bundle.lowPlan.runtimeTargets[i] == contractOp.runtimeTarget &&
                         bundle.lowPlan.effectClasses[i] == contractOp.effectClass &&
                         bundle.lowPlan.proofDomains[i] == contractOp.proofDomain
        validateBaguaProofGate(bundle.lowPlan.declIds,
                               baguaAnnotations,
                               bundle.lowPlan.declIds[i],
                               "effect",
                               "unimaker",
                               "runtime/effect/proof 必须和 canonical op 一致",
                               gatePlane,
                               "unimaker_proof|" + bundle.lowPlan.canonicalOps[i] + "|effect")
        allPass = allPass && effectPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("effect")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.declIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("runtime/effect/proof 必须和 canonical op 一致")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("runtime_target=" + contractOp.runtimeTarget)),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if effectPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let opName = bundle.lowPlan.canonicalOps[i]
        let capabilityPass =
            (opName == "hardware_callback_def" && bundle.lowPlan.capabilityKinds[i] == "nfc") ||
            (opName == "evolve_site_def" && bundle.lowPlan.capabilityKinds[i] == "npu") ||
            ((opName == "asset_contract_def" || opName == "actor_def" || opName == "ganzhi_state_def") &&
             bundle.lowPlan.capabilityKinds[i] == "none")
        validateBaguaProofGate(bundle.lowPlan.declIds,
                               baguaAnnotations,
                               bundle.lowPlan.declIds[i],
                               "ownership",
                               "unimaker",
                               "能力类型必须与声明形状对应",
                               gatePlane,
                               "unimaker_proof|" + bundle.lowPlan.canonicalOps[i] + "|ownership")
        allPass = allPass && capabilityPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("ownership")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.declIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("能力类型必须与声明形状对应")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("capability 与 decl kind 精确匹配")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if capabilityPass: "pass" else: "fail"))]))
        taskId = taskId + 1
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.proof_tasks.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("unimaker")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("tasks", jsonRawArray(tasks)))
    return taijiProofArtifact(jsonObject(fields), allPass)

fn taijiNetworkProofDocument(sourcePath: str,
                             sourceLabel: str,
                             bundle: npipe.NetworkDistributionPipelineBundle): TaijiProofArtifact =
    var tasks: str[]
    var fields: str[]
    var allPass: bool = true
    tasks = []
    fields = []
    let contract = nops.lowUirNetworkDistributionOpsContract()
    let effectClasses = bundle.lowPlan.priorityClasses
    let baguaAnnotations = lowbagua.annotateLowUirNodes("network_distribution",
                                                        bundle.lowPlan.opIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.addressBindings,
                                                        bundle.lowPlan.runtimeTargets)
    var taskId: int32 = 0
    for i in 0..<bundle.lowPlan.opIds.len:
        let opIdx = nops.findLowUirNetworkDistributionOp(bundle.lowPlan.canonicalOps[i])
        let contractOp = contract.canonicalOps[opIdx]
        let gatePlane = baguaAnnotations[i].plane
        let gateCell = proofGateCell(baguaAnnotations[i])
        let effectPass = bundle.lowPlan.runtimeTargets[i] == contractOp.runtimeTarget &&
                         bundle.lowPlan.proofDomains[i] == contractOp.proofDomain
        validateBaguaProofGate(bundle.lowPlan.opIds,
                               baguaAnnotations,
                               bundle.lowPlan.opIds[i],
                               "effect",
                               "network_distribution",
                               "runtime/proof 必须和 canonical op 一致",
                               gatePlane,
                               "network_proof|" + bundle.lowPlan.canonicalOps[i] + "|effect")
        allPass = allPass && effectPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("effect")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.opIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("runtime/proof 必须和 canonical op 一致")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("runtime_target=" + contractOp.runtimeTarget)),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if effectPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let layoutPass = bundle.lowPlan.addressingModes[i] != "lsmr_path" ||
                         (bundle.lowPlan.addressBindings[i] == "content_bound_address" &&
                          bundle.lowPlan.distanceMetrics[i] == "per_level_manhattan" &&
                          bundle.lowPlan.routePlanModels[i] == "canonical_multipath_set")
        validateBaguaProofGate(bundle.lowPlan.opIds,
                               baguaAnnotations,
                               bundle.lowPlan.opIds[i],
                               "layout",
                               "network_distribution",
                               bundle.lowPlan.canonicalOps[i] + "|" + bundle.lowPlan.addressingModes[i],
                               gatePlane,
                               "network_proof|" + bundle.lowPlan.canonicalOps[i] + "|layout")
        allPass = allPass && layoutPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("layout")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.opIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("lsmr_path 必须绑定 canonical addressing lane")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("address_binding/content_bound_address + per_level_manhattan + canonical_multipath_set")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if layoutPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let ownershipPass = bundle.lowPlan.canonicalOps[i] != "exchange_anti_entropy_signature" &&
                            bundle.lowPlan.canonicalOps[i] != "repair_from_signature_gap" ?
            true :
            len(bundle.lowPlan.antiEntropySignatureKinds[i]) > 0
        validateBaguaProofGate(bundle.lowPlan.opIds,
                               baguaAnnotations,
                               bundle.lowPlan.opIds[i],
                               "ownership",
                               "network_distribution",
                               bundle.lowPlan.canonicalOps[i],
                               gatePlane,
                               "network_proof|" + bundle.lowPlan.canonicalOps[i] + "|ownership")
        allPass = allPass && ownershipPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("ownership")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.opIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("签名相关操作必须声明 anti-entropy signature kind")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("anti_entropy_signature_kind != empty")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if ownershipPass: "pass" else: "fail"))]))
        taskId = taskId + 1
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.proof_tasks.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("network_distribution")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("tasks", jsonRawArray(tasks)))
    return taijiProofArtifact(jsonObject(fields), allPass)

fn taijiCompilerCoreProofDocument(sourcePath: str,
                                  sourceLabel: str,
                                  bundle: cpipe.CompilerCorePipelineBundle): TaijiProofArtifact =
    var tasks: str[]
    var fields: str[]
    var allPass: bool = true
    tasks = []
    fields = []
    let contract = cops.lowUirCompilerCoreOpsContract()
    let baguaAnnotations = lowbagua.annotateLowUirNodes("compiler_core",
                                                        bundle.lowPlan.itemIds,
                                                        bundle.lowPlan.canonicalOps,
                                                        bundle.lowPlan.effectClasses,
                                                        bundle.lowPlan.proofDomains,
                                                        bundle.lowPlan.bindingScopes,
                                                        bundle.lowPlan.runtimeTargets)
    var taskId: int32 = 0
    for i in 0..<bundle.lowPlan.itemIds.len:
        let opIdx = cops.findLowUirCompilerCoreOp(bundle.lowPlan.canonicalOps[i])
        let contractOp = contract.canonicalOps[opIdx]
        let gatePlane = baguaAnnotations[i].plane
        let gateCell = proofGateCell(baguaAnnotations[i])
        let layoutAssumption = bundle.lowPlan.canonicalOps[i] + "|" + bundle.lowPlan.topLevelKinds[i]
        let effectAssumption = bundle.lowPlan.canonicalOps[i] + "|" + contractOp.proofDomain
        let layoutPass = bundle.lowPlan.bindingScopes[i] != ""
        validateBaguaProofGate(bundle.lowPlan.itemIds,
                               baguaAnnotations,
                               bundle.lowPlan.itemIds[i],
                               "layout",
                               "compiler_core",
                               layoutAssumption,
                               gatePlane,
                               "compiler_core_proof|" + bundle.lowPlan.canonicalOps[i] + "|layout")
        allPass = allPass && layoutPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("layout")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.itemIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote(layoutAssumption)),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("binding_scope_non_empty")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if layoutPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let effectPass = bundle.lowPlan.runtimeTargets[i] == contractOp.runtimeTarget &&
                         bundle.lowPlan.effectClasses[i] == contractOp.effectClass &&
                         bundle.lowPlan.proofDomains[i] == contractOp.proofDomain &&
                         bundle.lowPlan.bindingScopes[i] == contractOp.bindingScope
        validateBaguaProofGate(bundle.lowPlan.itemIds,
                               baguaAnnotations,
                               bundle.lowPlan.itemIds[i],
                               "effect",
                               "compiler_core",
                               effectAssumption,
                               gatePlane,
                               "compiler_core_proof|" + bundle.lowPlan.canonicalOps[i] + "|effect")
        allPass = allPass && effectPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("effect")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.itemIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote(effectAssumption)),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("binding_scope=" + contractOp.bindingScope)),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if effectPass: "pass" else: "fail"))]))
        taskId = taskId + 1
        let boundsPass = !bundle.lowPlan.executableAstReady[i] ||
                         bundle.lowPlan.routineOpStarts[i] + bundle.lowPlan.routineOpCounts[i] <= bundle.lowPlan.opKinds.len
        validateBaguaProofGate(bundle.lowPlan.itemIds,
                               baguaAnnotations,
                               bundle.lowPlan.itemIds[i],
                               "bounds",
                               "compiler_core",
                               "executable_ast_ready",
                               gatePlane,
                               "compiler_core_proof|" + bundle.lowPlan.canonicalOps[i] + "|bounds")
        allPass = allPass && boundsPass
        add(tasks,
            jsonInlineObject([jsonInlineFieldRaw("task_id", intToStr(taskId)),
                              jsonInlineFieldRaw("kind", jsonQuote("bounds")),
                              jsonInlineFieldRaw("target_node", intToStr(bundle.lowPlan.itemIds[i])),
                              jsonInlineFieldRaw("assumptions", jsonQuote("可执行条目必须落在 Low-UIR op SoA 边界内")),
                              jsonInlineFieldRaw("expected_invariant", jsonQuote("routine_op_start + routine_op_count <= opKinds.len")),
                              jsonInlineFieldRaw("bagua_gate_plane", jsonQuote(gatePlane)),
                              jsonInlineFieldRaw("bagua_gate_cell", jsonQuote(gateCell)),
                              jsonInlineFieldRaw("checker_result", jsonQuote(if boundsPass: "pass" else: "fail"))]))
        taskId = taskId + 1
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.proof_tasks.v0")))
    add(fields, jsonFieldRaw("source_kind", jsonQuote("compiler_core")))
    add(fields, jsonFieldRaw("source_path", jsonQuote(sourcePath)))
    add(fields, jsonFieldRaw("source_label", jsonQuote(sourceLabel)))
    add(fields, jsonFieldRaw("tasks", jsonRawArray(tasks)))
    return taijiProofArtifact(jsonObject(fields), allPass)

fn taijiAstDocument(sourcePath: str, sourceLabel: str, sampleName: str): TaijiDocument =
    if sampleName == "string":
        return taijiStringAstDocument(sourcePath, sourceLabel, sir.sampleStringSurfaceProgram())
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        return taijiNetworkAstDocument(sourcePath, sourceLabel, parsed.networkProgram)
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        return taijiCompilerCoreAstDocument(sourcePath,
                                            sourceLabel,
                                            cpipe.compileCompilerCoreSourceClosure(sourcePath).program)
    if parsed.unimakerProgram.decls.len > 0:
        return taijiUnimakerAstDocument(sourcePath, sourceLabel, parsed.unimakerProgram)
    system.panic("taiji: unsupported ast export source")

fn taijiLowUirDocument(sourcePath: str, sourceLabel: str, sampleName: str): TaijiDocument =
    if sampleName == "string":
        return taijiStringLowUirDocument(sourcePath, sourceLabel, spipe.sampleStringPipeline())
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        return taijiNetworkLowUirDocument(sourcePath,
                                          sourceLabel,
                                          npipe.compileNetworkDistributionProgram(parsed.networkProgram))
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        return taijiCompilerCoreLowUirDocument(sourcePath,
                                               sourceLabel,
                                               cpipe.compileCompilerCoreSourceClosure(sourcePath))
    if parsed.unimakerProgram.decls.len > 0:
        return taijiUnimakerLowUirDocument(sourcePath,
                                           sourceLabel,
                                           upipe.compileUnimakerSurfaceProgram(parsed.unimakerProgram))
    system.panic("taiji: unsupported low_uir export source")

fn taijiPhaseTraceDocument(sourcePath: str, sourceLabel: str, sampleName: str): TaijiDocument =
    if sampleName == "string":
        return taijiStringPhaseTraceDocument(sourcePath, sourceLabel, spipe.sampleStringPipeline())
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        return taijiNetworkPhaseTraceDocument(sourcePath,
                                              sourceLabel,
                                              npipe.compileNetworkDistributionProgram(parsed.networkProgram))
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        return taijiCompilerCorePhaseTraceDocument(sourcePath,
                                                   sourceLabel,
                                                   cpipe.compileCompilerCoreSourceClosure(sourcePath))
    if parsed.unimakerProgram.decls.len > 0:
        return taijiUnimakerPhaseTraceDocument(sourcePath,
                                               sourceLabel,
                                               upipe.compileUnimakerSurfaceProgram(parsed.unimakerProgram))
    system.panic("taiji: unsupported phase trace source")

fn taijiProofDocument(sourcePath: str, sourceLabel: str, sampleName: str): TaijiProofArtifact =
    if sampleName == "string":
        return taijiStringProofDocument(sourcePath, sourceLabel, spipe.sampleStringPipeline())
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        return taijiNetworkProofDocument(sourcePath,
                                         sourceLabel,
                                         npipe.compileNetworkDistributionProgram(parsed.networkProgram))
    if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        return taijiCompilerCoreProofDocument(sourcePath,
                                              sourceLabel,
                                              cpipe.compileCompilerCoreSourceClosure(sourcePath))
    if parsed.unimakerProgram.decls.len > 0:
        return taijiUnimakerProofDocument(sourcePath,
                                          sourceLabel,
                                          upipe.compileUnimakerSurfaceProgram(parsed.unimakerProgram))
    system.panic("taiji: unsupported proof source")

fn taijiExecPlanDocument(sourcePath: str, label: str, sampleName: str): TaijiDocument =
    if sampleName == "string":
        system.panic("taiji: dump-exec-plan only supports compiler_core source")
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    if parsed.compilerCoreProgram.topLevelKinds.len <= 0:
        system.panic("taiji: dump-exec-plan only supports compiler_core source")
    let bundle = cpipe.compileCompilerCoreSourceClosure(sourcePath)
    var itemIdx: int32 = -1
    for i in 0..<bundle.lowPlan.labels.len:
        if bundle.lowPlan.labels[i] == label:
            itemIdx = i
            break
    if itemIdx < 0:
        system.panic("taiji: missing compiler_core exec label " + label)
    if !bundle.lowPlan.executableAstReady[itemIdx]:
        system.panic("taiji: label is not executable " + label)
    return taijiDocument("source_path=" + sourcePath + "\n" +
                         "label=" + label + "\n" +
                         "item_id=" + intToStr(bundle.lowPlan.itemIds[itemIdx]) + "\n" +
                         mpipeline.compilerCoreRoutineExecPlanText(bundle.lowPlan, itemIdx))

fn runDumpAst(): int32 =
    let sampleName = taijiSampleName()
    let sourcePath = taijiResolveSourcePath(sampleName)
    let sourceLabel = taijiResolveSourceLabel(sourcePath, sampleName)
    let outPath = taijiOutputPathOrEmpty()
    let doc = taijiAstDocument(sourcePath, sourceLabel, sampleName)
    writeOptionalTextFile(outPath, doc.text)
    writeText(doc.text + "\n")
    return 0

fn runDumpLowUir(): int32 =
    let sampleName = taijiSampleName()
    let sourcePath = taijiResolveSourcePath(sampleName)
    let sourceLabel = taijiResolveSourceLabel(sourcePath, sampleName)
    let outPath = taijiOutputPathOrEmpty()
    let doc = taijiLowUirDocument(sourcePath, sourceLabel, sampleName)
    writeOptionalTextFile(outPath, doc.text)
    writeText(doc.text + "\n")
    return 0

fn runDumpExecPlan(): int32 =
    let sampleName = taijiSampleName()
    let sourcePath = taijiResolveSourcePath(sampleName)
    let label = readFlagDefault("--label", "")
    if len(label) <= 0:
        system.panic("taiji: missing --label")
    let outPath = taijiOutputPathOrEmpty()
    let doc = taijiExecPlanDocument(sourcePath, label, sampleName)
    writeOptionalTextFile(outPath, doc.text)
    writeText(doc.text + "\n")
    return 0

fn runTracePhaseSpace(): int32 =
    let sampleName = taijiSampleName()
    let sourcePath = taijiResolveSourcePath(sampleName)
    let sourceLabel = taijiResolveSourceLabel(sourcePath, sampleName)
    let outPath = taijiOutputPathOrEmpty()
    let doc = taijiPhaseTraceDocument(sourcePath, sourceLabel, sampleName)
    writeOptionalTextFile(outPath, doc.text)
    writeText(doc.text + "\n")
    return 0

fn runEmitProofObligations(): int32 =
    let sampleName = taijiSampleName()
    let sourcePath = taijiResolveSourcePath(sampleName)
    let sourceLabel = taijiResolveSourceLabel(sourcePath, sampleName)
    let outPath = taijiOutputPathOrEmpty()
    let proof = taijiProofDocument(sourcePath, sourceLabel, sampleName)
    writeOptionalTextFile(outPath, proof.text)
    writeText(proof.text + "\n")
    return if proof.allPass: 0 else: 1

fn taijiSeedManifestLine(spec: TaijiSeedSpec,
                         astDoc: TaijiDocument,
                         lowDoc: TaijiDocument,
                         traceDoc: TaijiDocument,
                         proofDoc: TaijiDocument,
                         profileDoc: TaijiDocument): str =
    return jsonInlineObject([jsonInlineFieldRaw("sample_id", jsonQuote(spec.sampleId)),
                             jsonInlineFieldRaw("source_path", jsonQuote(spec.sourcePath)),
                             jsonInlineFieldRaw("source_kind", jsonQuote(spec.sourceKind)),
                             jsonInlineFieldRaw("ast_cid", jsonQuote(astDoc.cid)),
                             jsonInlineFieldRaw("low_uir_cid", jsonQuote(lowDoc.cid)),
                             jsonInlineFieldRaw("bagua_trace_cid", jsonQuote(traceDoc.cid)),
                             jsonInlineFieldRaw("proof_task_cid", jsonQuote(proofDoc.cid)),
                             jsonInlineFieldRaw("profile_report_cid", jsonQuote(profileDoc.cid)),
                             jsonInlineFieldRaw("gate_class", jsonQuote(spec.gateClass))])

fn updateSemanticEdgeFamilyCounts(familyTotalCounts: var int32[],
                                  familySampleCounts: var int32[],
                                  familySampleHits: var int32[],
                                  sampleIdx: int32,
                                  familyCounts: int32[],
                                  sampleCount: int32) =
    if familyTotalCounts.len != familyCounts.len || familySampleCounts.len != familyCounts.len:
        system.panic("taiji: semantic edge family total length mismatch")
    for familyIdx in 0..<familyCounts.len:
        let count = familyCounts[familyIdx]
        if count <= 0:
            continue
        familyTotalCounts[familyIdx] = familyTotalCounts[familyIdx] + count
        let hitIdx = familyIdx * sampleCount + sampleIdx
        if familySampleHits[hitIdx] == 0:
            familySampleHits[hitIdx] = 1
            familySampleCounts[familyIdx] = familySampleCounts[familyIdx] + 1

fn taijiSemanticEdgeCatalogDocument(specs: TaijiSeedSpec[],
                                    sampleLabels: str[],
                                    familyTotalCounts: int32[],
                                    familySampleCounts: int32[],
                                    familySampleHits: int32[]): TaijiDocument =
    let edgeKindOrder = semanticEdgeKindOrder()
    let planeOrder = ["P1=乾坤", "P2=坎离", "P3=艮兑", "P4=震巽"]
    let planePairKeys = planePairOrder(planeOrder)
    let gateClassOrder = ["handwritten_core", "contract_sample", "compiler_observation"]
    let sourceKindOrder = ["string", "unimaker", "network_distribution", "compiler_core"]
    if sampleLabels.len != specs.len:
        system.panic("taiji: semantic edge catalog sample label length mismatch")
    let planePairCount = planePairKeys.len
    let familyCount = edgeKindOrder.len * planePairCount
    if familyTotalCounts.len != familyCount ||
       familySampleCounts.len != familyCount ||
       familySampleHits.len != familyCount * specs.len:
        system.panic("taiji: semantic edge catalog family vector length mismatch")
    var validatedEdgeCount: int32 = 0
    var nonzeroFamilyCount: int32 = 0
    var sampleRows: str[]
    var familyRows: str[]
    var fields: str[]
    sampleRows = []
    familyRows = []
    fields = []
    for i in 0..<specs.len:
        add(sampleRows,
            jsonInlineObject([jsonInlineFieldRaw("slot", intToStr(i)),
                              jsonInlineFieldRaw("source_label", jsonQuote(sampleLabels[i])),
                              jsonInlineFieldRaw("source_kind", jsonQuote(specs[i].sourceKind)),
                              jsonInlineFieldRaw("gate_class", jsonQuote(specs[i].gateClass))]))
    for edgeKindIdx in 0..<edgeKindOrder.len:
        for leftIdx in 0..<planeOrder.len:
            for rightIdx in 0..<planeOrder.len:
                let pairIdx = leftIdx * planeOrder.len + rightIdx
                let familyIdx = edgeKindIdx * planePairCount + pairIdx
                let totalCount = familyTotalCounts[familyIdx]
                if totalCount > 0:
                    nonzeroFamilyCount = nonzeroFamilyCount + 1
                validatedEdgeCount = validatedEdgeCount + totalCount
                var sampleSlots: int32[]
                var gateClassCounts: int32[]
                var sourceKindCounts: int32[]
                sampleSlots = []
                gateClassCounts = [0, 0, 0]
                sourceKindCounts = [0, 0, 0, 0]
                for sampleIdx in 0..<specs.len:
                    let hitIdx = familyIdx * specs.len + sampleIdx
                    if familySampleHits[hitIdx] == 0:
                        continue
                    add(sampleSlots, sampleIdx)
                    let gateClassIdx = planeIndex(gateClassOrder, specs[sampleIdx].gateClass)
                    let sourceKindIdx = planeIndex(sourceKindOrder, specs[sampleIdx].sourceKind)
                    if gateClassIdx < 0 || sourceKindIdx < 0:
                        system.panic("taiji: semantic edge catalog sample class mismatch")
                    gateClassCounts[gateClassIdx] = gateClassCounts[gateClassIdx] + 1
                    sourceKindCounts[sourceKindIdx] = sourceKindCounts[sourceKindIdx] + 1
                add(familyRows,
                    jsonInlineObject([jsonInlineFieldRaw("family_id",
                                                         jsonQuote(edgeKindOrder[edgeKindIdx] + "|" +
                                                                   planePairKeys[pairIdx])),
                                      jsonInlineFieldRaw("edge_kind", jsonQuote(edgeKindOrder[edgeKindIdx])),
                                      jsonInlineFieldRaw("source_plane", jsonQuote(planeOrder[leftIdx])),
                                      jsonInlineFieldRaw("target_plane", jsonQuote(planeOrder[rightIdx])),
                                      jsonInlineFieldRaw("orthogonal",
                                                         if bcore.isOrthogonal(planeOrder[leftIdx],
                                                                               planeOrder[rightIdx]):
                                                             "true"
                                                         else:
                                                             "false"),
                                      jsonInlineFieldRaw("allowed",
                                                         if bcore.allowEdge(edgeKindOrder[edgeKindIdx],
                                                                            planeOrder[leftIdx],
                                                                            planeOrder[rightIdx]):
                                                             "true"
                                                         else:
                                                             "false"),
                                      jsonInlineFieldRaw("total_count", intToStr(totalCount)),
                                      jsonInlineFieldRaw("sample_count", intToStr(familySampleCounts[familyIdx])),
                                      jsonInlineFieldRaw("sample_slots", jsonIntArray(sampleSlots)),
                                      jsonInlineFieldRaw("gate_class_counts",
                                                         jsonInlineCountObject(gateClassOrder, gateClassCounts)),
                                      jsonInlineFieldRaw("source_kind_counts",
                                                         jsonInlineCountObject(sourceKindOrder, sourceKindCounts))]))
    add(fields, jsonFieldRaw("version", jsonQuote("taiji.bpi_semantic_edge_catalog.v1")))
    add(fields, jsonFieldRaw("bpi_validation_scope",
                             jsonInlineObject([jsonInlineFieldRaw("phase", jsonQuote("lowers_to")),
                                               jsonInlineFieldRaw("proof", jsonQuote("gates"))])))
    add(fields, jsonFieldRaw("sample_count", intToStr(specs.len)))
    add(fields, jsonFieldRaw("family_count", intToStr(familyCount)))
    add(fields, jsonFieldRaw("nonzero_family_count", intToStr(nonzeroFamilyCount)))
    add(fields, jsonFieldRaw("validated_edge_count", intToStr(validatedEdgeCount)))
    add(fields, jsonFieldRaw("edge_kind_order", jsonStringArray(edgeKindOrder)))
    add(fields, jsonFieldRaw("plane_pair_order", jsonStringArray(planePairKeys)))
    add(fields, jsonFieldRaw("samples", jsonRawArray(sampleRows)))
    add(fields, jsonFieldRaw("families", jsonRawArray(familyRows)))
    return taijiDocument(jsonObject(fields))

fn runTaijiSeedSet(): int32 =
    let outDir = taijiSeedOutDir()
    createDirAll(outDir)
    let manifestPath = taijiSeedManifestPath(outDir)
    let catalogPath = taijiSeedSemanticEdgeCatalogPath(outDir)
    let specs = taijiSeedSpecs()
    let edgeKindOrder = semanticEdgeKindOrder()
    let planeOrder = ["P1=乾坤", "P2=坎离", "P3=艮兑", "P4=震巽"]
    let planePairKeys = planePairOrder(planeOrder)
    var manifestLines: str[]
    var sampleLabels: str[]
    var familyTotalCounts: int32[]
    var familySampleCounts: int32[]
    var familySampleHits: int32[]
    manifestLines = []
    sampleLabels = []
    familyTotalCounts = []
    familySampleCounts = []
    familySampleHits = []
    var handwrittenCount: int32 = 0
    var contractCount: int32 = 0
    var observationCount: int32 = 0
    for i in 0..<edgeKindOrder.len * planePairKeys.len:
        add(familyTotalCounts, 0)
        add(familySampleCounts, 0)
    for i in 0..<edgeKindOrder.len * planePairKeys.len * specs.len:
        add(familySampleHits, 0)
    for i in 0..<specs.len:
        let spec = specs[i]
        let sampleDir = taijiSeedSampleDir(outDir, spec.sampleId)
        createDirAll(sampleDir)
        let astDoc = taijiAstDocument(spec.sourcePath, spec.sourceLabel, spec.builtInSample)
        let lowDoc = taijiLowUirDocument(spec.sourcePath, spec.sourceLabel, spec.builtInSample)
        let traceDoc = taijiPhaseTraceDocument(spec.sourcePath, spec.sourceLabel, spec.builtInSample)
        let proof = taijiProofDocument(spec.sourcePath, spec.sourceLabel, spec.builtInSample)
        if !proof.allPass:
            system.panic("taiji: proof obligations failed for " + spec.sampleId)
        let proofDoc = taijiDocument(proof.text)
        let profileDoc = taijiProfileDocument(spec.sourcePath,
                                              spec.sourceLabel,
                                              spec.sourceKind,
                                              astDoc,
                                              lowDoc,
                                              traceDoc,
                                              proofDoc)
        let lowNodeIds = jsonArrayIntValues(jsonDocFieldRaw(lowDoc.text, "node_ids"))
        let lowPlanes = jsonArrayStringValues(jsonDocFieldRaw(lowDoc.text, "bagua_plane"))
        let phaseEdgeNodeIds = jsonArrayIntValues(jsonDocFieldRaw(traceDoc.text, "low_uir_node_ids"))
        let phaseTargetPlanes = jsonArrayStringValues(jsonDocFieldRaw(traceDoc.text, "plane"))
        let phaseEdgeKinds = semanticPhaseEdgeKinds(jsonArrayStringValues(jsonDocFieldRaw(traceDoc.text, "reasons")),
                                                    spec.sourceKind)
        let proofEdgeNodeIds = jsonArrayIntValues(jsonDocFieldRaw(proofDoc.text, "targets"))
        let proofTargetPlanes = jsonArrayStringValues(jsonDocFieldRaw(proofDoc.text, "bagua_gate_plane"))
        let proofEdgeKinds = semanticProofEdgeKinds(jsonArrayStringValues(jsonDocFieldRaw(proofDoc.text, "kinds")),
                                                    jsonArrayStringValues(jsonDocFieldRaw(proofDoc.text, "assumptions")),
                                                    spec.sourceKind)
        let phaseFamilyCounts = semanticEdgeFamilyCounts(lowNodeIds,
                                                         lowPlanes,
                                                         phaseEdgeNodeIds,
                                                         phaseTargetPlanes,
                                                         phaseEdgeKinds,
                                                         edgeKindOrder,
                                                         planeOrder)
        let proofFamilyCounts = semanticEdgeFamilyCounts(lowNodeIds,
                                                         lowPlanes,
                                                         proofEdgeNodeIds,
                                                         proofTargetPlanes,
                                                         proofEdgeKinds,
                                                         edgeKindOrder,
                                                         planeOrder)
        writeTextFile(taijiSeedSamplePath(outDir, spec.sampleId, "taiji_ast_graph.json"), astDoc.text)
        writeTextFile(taijiSeedSamplePath(outDir, spec.sampleId, "taiji_low_uir_graph.json"), lowDoc.text)
        writeTextFile(taijiSeedSamplePath(outDir, spec.sampleId, "taiji_bagua_trace.json"), traceDoc.text)
        writeTextFile(taijiSeedSamplePath(outDir, spec.sampleId, "taiji_proof_tasks.json"), proofDoc.text)
        writeTextFile(taijiSeedProfilePath(outDir, spec.sampleId), profileDoc.text)
        add(manifestLines, taijiSeedManifestLine(spec, astDoc, lowDoc, traceDoc, proofDoc, profileDoc))
        add(sampleLabels, spec.sourceLabel)
        updateSemanticEdgeFamilyCounts(familyTotalCounts,
                                       familySampleCounts,
                                       familySampleHits,
                                       i,
                                       phaseFamilyCounts,
                                       specs.len)
        updateSemanticEdgeFamilyCounts(familyTotalCounts,
                                       familySampleCounts,
                                       familySampleHits,
                                       i,
                                       proofFamilyCounts,
                                       specs.len)
        if spec.gateClass == "handwritten_core":
            handwrittenCount = handwrittenCount + 1
        elif spec.gateClass == "contract_sample":
            contractCount = contractCount + 1
        else:
            observationCount = observationCount + 1
    let manifestText = joinTextList(manifestLines, "\n")
    let catalogDoc = taijiSemanticEdgeCatalogDocument(specs,
                                                      sampleLabels,
                                                      familyTotalCounts,
                                                      familySampleCounts,
                                                      familySampleHits)
    writeTextFile(manifestPath, manifestText)
    writeTextFile(catalogPath, catalogDoc.text)
    printLine("taiji_seed_ok=1")
    printLine("seed_count=" + intToStr(specs.len))
    printLine("handwritten_core_count=" + intToStr(handwrittenCount))
    printLine("contract_sample_count=" + intToStr(contractCount))
    printLine("compiler_observation_count=" + intToStr(observationCount))
    printLine("manifest_path=" + manifestPath)
    printLine("manifest_cid=" + ident.sha256HexText(manifestText))
    printLine("semantic_edge_catalog_path=" + catalogPath)
    printLine("semantic_edge_catalog_cid=" + catalogDoc.cid)
    return 0

fn parsePlanInt32OrZero(planText: str, key: str): int32 =
    return parsePlanInt32OrZeroBridge(planText, key)

fn countExternalCcProvidersFromPlanText(planText: str): int32 =
    return countExternalCcProvidersBridge(planText)

fn providerFieldForModuleFromPlanText(planText: str, moduleName: str, fieldName: str): str =
    return providerFieldForModuleFromPlanTextBridge(planText, moduleName, fieldName)

fn stageReleasePath(stageDir: str): str =
    return joinPath2(stageDir, "release.txt")

fn stageSystemLinkPlanPath(stageDir: str): str =
    return joinPath2(stageDir, "system_link_plan.txt")

fn stageSystemLinkExecPath(stageDir: str): str =
    return joinPath2(stageDir, "system_link_exec.txt")

fn stageBinaryPath(stageDir: str, binaryName: str): str =
    return joinPath2(stageDir, binaryName)

fn stageRootDir(outDir: str): str =
    return joinPath2(outDir, "stages")

fn stageNamedDir(outDir: str, stageName: str): str =
    return joinPath2(stageRootDir(outDir), stageName)

fn stage2ToolingDirPath(outDir: str): str =
    return joinPath2(outDir, "stage2_tooling_selfhost")

fn stage2ToolingReportPath(outDir: str): str =
    return joinPath2(stage2ToolingDirPath(outDir), "tooling_selfhost_host.txt")

fn toolingSelfhostPath(outDir: str, fileName: str): str =
    return joinPath2(outDir, fileName)

fn buildStageArtifacts(compilerPath: str,
                       sourcePath: str,
                       targetTriple: str,
                       stageDir: str,
                       binaryName: str): NativeStageArtifacts =
    createDirAll(stageDir)
    let releasePath = stageReleasePath(stageDir)
    let systemLinkPlanPath = stageSystemLinkPlanPath(stageDir)
    let systemLinkExecPath = stageSystemLinkExecPath(stageDir)
    let binaryPath = stageBinaryPath(stageDir, binaryName)
    let workingDir = currentWorkingDir()
    let releaseArgv = ["release-compile", "--in", sourcePath, "--emit", "exe", "--target", targetTriple, "--out", releasePath]
    let releaseOutput = runCompilerCommandOrPanic(compilerPath, releaseArgv, workingDir, "stage-selfhost-host release-compile failed")
    writeTextFile(releasePath, releaseOutput)
    let systemLinkPlanArgv = ["system-link-plan", "--in", sourcePath, "--emit", "exe", "--target", targetTriple, "--out", systemLinkPlanPath]
    let systemLinkPlanOutput = runCompilerCommandOrPanic(compilerPath, systemLinkPlanArgv, workingDir, "stage-selfhost-host system-link-plan failed")
    writeTextFile(systemLinkPlanPath, systemLinkPlanOutput)
    let systemLinkExecArgv = ["system-link-exec", "--in", sourcePath, "--emit", "exe", "--target", targetTriple, "--out", binaryPath, "--report-out", systemLinkExecPath]
    let systemLinkExecOutput = runCompilerCommandOrPanic(compilerPath, systemLinkExecArgv, workingDir, "stage-selfhost-host system-link-exec failed")
    writeTextFile(systemLinkExecPath, systemLinkExecOutput)
    let compilerCoreProviderSourceKind = compilerCoreProviderSourceKindBridge(systemLinkPlanOutput)
    let compilerCoreProviderCompileMode = compilerCoreProviderCompileModeBridge(systemLinkPlanOutput)
    var out: NativeStageArtifacts
    out.compilerPath = compilerPath
    out.releasePath = releasePath
    out.systemLinkPlanPath = systemLinkPlanPath
    out.systemLinkExecPath = systemLinkExecPath
    out.binaryPath = binaryPath
    out.binaryCid = sexec.readFileSha256Hex(binaryPath)
    out.outputFileCid = sexec.extractLineValue(systemLinkExecOutput, "output_file_cid")
    out.externalCcProviderCount = countExternalCcProvidersFromPlanText(systemLinkPlanOutput)
    out.compilerCoreProviderSourceKind = compilerCoreProviderSourceKind
    out.compilerCoreProviderCompileMode = compilerCoreProviderCompileMode
    return out

