fn runVerifyNetworkSelfhost(): int32 =
    let root = readFlagDefault("--root", "v2/examples")
    let sourcePath = readFlagDefault("--in", "v2/examples/network_distribution_module.cheng")
    let manifestBundle = mresolve.resolveSourceManifest(root)
    let networkBundle = networkBundleFromSource(sourcePath)
    let releaseBundle = rart.buildReleaseArtifact(sourcePath, "exe", mtarget.machineTargetContract().firstClassTargets[0])
    let rulePackOpCount = canonicalOpCountForDomain(networkBundle, "rule_pack")
    let compilerRulePackOpCount = canonicalOpCountForDomain(networkBundle, "compiler_rule_pack")
    let hasPublishSourceManifestOp = hasCanonicalOp(networkBundle, "publish_source_manifest")
    let hasPublishRulePackOp = hasCanonicalOp(networkBundle, "publish_rule_pack")
    let hasPublishCompilerRulePackOp = hasCanonicalOp(networkBundle, "publish_compiler_rule_pack")
    if manifestBundle.topologyCanonicalForms.len <= 0:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_topology_canonical_form")
        return 1
    if !verifyPriorityMappings(networkBundle):
        printLine("network_selfhost_ok=0")
        printLine("reason=priority_mapping_mismatch")
        return 1
    if !hasPublishSourceManifestOp:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_publish_ops")
        return 1
    if !hasPublishRulePackOp:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_publish_ops")
        return 1
    if !hasPublishCompilerRulePackOp:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_publish_ops")
        return 1
    if rulePackOpCount <= 0:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_rule_pack_domain_ops")
        return 1
    if compilerRulePackOpCount <= 0:
        printLine("network_selfhost_ok=0")
        printLine("reason=missing_compiler_rule_pack_domain_ops")
        return 1
    if releaseBundle.moduleKind != "network_distribution":
        printLine("network_selfhost_ok=0")
        printLine("reason=release_artifact_wrong_module_kind")
        return 1
    if releaseBundle.manifestCid != manifestBundle.manifestCid:
        printLine("network_selfhost_ok=0")
        printLine("reason=release_manifest_mismatch")
        return 1
    if !releaseCompileKeyCoversNetworkBundle(releaseBundle, networkBundle):
        printLine("network_selfhost_ok=0")
        printLine("reason=compile_key_missing_network_fields")
        return 1
    if !releaseBundle.nativeLinkClosureOk:
        printLine("network_selfhost_ok=0")
        printLine("reason=native_link_closure_unresolved")
        return 1
    let rulePackText = buildNetworkArtifactText(networkBundle, "rule_pack", "v2.rule_pack.v1")
    let compilerRulePackText = buildNetworkArtifactText(networkBundle, "compiler_rule_pack", "v2.compiler_rule_pack.v1")
    printLine("network_selfhost_ok=1")
    printLine("source_manifest_cid=" + manifestBundle.manifestCid)
    printLine("rule_pack_cid=" + ident.sha256HexText(rulePackText))
    printLine("compiler_rule_pack_cid=" + ident.sha256HexText(compilerRulePackText))
    printLine("release_compile_key=" + releaseBundle.compileKey)
    printLine("obj_image_cid=" + releaseBundle.objImageCid)
    printLine("obj_section_count=" + intToStr(releaseBundle.objSectionCount))
    printLine("obj_symbol_count=" + intToStr(releaseBundle.objSymbolCount))
    printLine("obj_reloc_count=" + intToStr(releaseBundle.objRelocCount))
    printLine("link_plan_cid=" + releaseBundle.linkPlanCid)
    printLine("runtime_target_count=" + intToStr(releaseBundle.runtimeTargetCount))
    printLine("runtime_unresolved_count=" + intToStr(releaseBundle.runtimeUnresolvedCount))
    printLine("native_link_closure_ok=1")
    printLine("topology_count=" + intToStr(manifestBundle.topologyCanonicalForms.len))
    printLine("rule_pack_entry_count=" + intToStr(rulePackOpCount))
    printLine("compiler_rule_pack_entry_count=" + intToStr(compilerRulePackOpCount))
    printLine("publish_source_manifest_present=1")
    printLine("publish_rule_pack_present=1")
    printLine("publish_compiler_rule_pack_present=1")
    printLine("lsmr_priority_mapping_fixed=1")
    printLine("lsmr_addressing_mode=" + lcontract.lsmrRuntimeContract().addressingMode)
    printLine("lsmr_address_binding=" + lcontract.lsmrRuntimeContract().addressBinding)
    printLine("lsmr_distance_metric=" + lcontract.lsmrRuntimeContract().distanceMetric)
    printLine("lsmr_route_plan_model=" + lcontract.lsmrRuntimeContract().routePlanModel)
    printLine("compile_key_topology_covered=1")
    printLine("compile_key_addressing_covered=1")
    printLine("compile_key_depth_covered=1")
    printLine("compile_key_address_binding_covered=1")
    printLine("compile_key_distance_metric_covered=1")
    printLine("compile_key_priority_covered=1")
    printLine("compile_key_dispersal_covered=1")
    printLine("compile_key_signature_covered=1")
    printLine("compile_key_canonical_multipath_covered=1")
    printLine("release_manifest_matches_source_manifest=1")
    printLine("random_gossip_fallback_present=0")
    return 0

fn defaultReleaseOut(sourcePath: str, emitKind: str): str =
    let parts = os.splitFile(sourcePath)
    return os.joinPath("v2/artifacts/release", parts.name + "." + emitKind + ".artifact.txt")

fn runReleaseCompile(): int32 =
    let sourcePath = readFlagDefault("--in", "v2/examples/network_distribution_module.cheng")
    let emitKind = readFlagDefault("--emit", "exe")
    let targetTriple = readFlagDefault("--target", mtarget.machineTargetContract().firstClassTargets[0])
    let outPath = readFlagDefault("--out", defaultReleaseOut(sourcePath, emitKind))
    let bundle = rart.buildReleaseArtifact(sourcePath, emitKind, targetTriple)
    writeTextFile(outPath, bundle.artifactText + "\n")
    writeText(bundle.artifactText + "\n")
    return 0

fn printUsageZero(): int32 =
    printUsage()
    return 0

fn returnTrue(): bool =
    return true

fn cmdIsHelpLong(): bool =
    return cmdline.cliParam1Eq("--help")

fn cmdIsHelpShort(): bool =
    return cmdline.cliParam1Eq("-h")

fn cmdIsHelpWord(): bool =
    return cmdline.cliParam1Eq("help")

fn cmdIsHelpShortOrWord(): bool =
    if cmdIsHelpShort():
        return returnTrue()
    else:
        return cmdIsHelpWord()

fn cmdIsHelp(): bool =
    if cmdIsHelpLong():
        return returnTrue()
    else:
        return cmdIsHelpShortOrWord()

fn cmdIsSurface(): bool =
    return cmdline.cliParam1Eq("surface")

fn cmdIsPasses(): bool =
    return cmdline.cliParam1Eq("passes")

fn cmdIsContracts(): bool =
    return cmdline.cliParam1Eq("contracts")

fn cmdIsStrings(): bool =
    return cmdline.cliParam1Eq("strings")

fn cmdIsStringPipeline(): bool =
    return cmdline.cliParam1Eq("string-pipeline")

fn cmdIsInfrastructure(): bool =
    return cmdline.cliParam1Eq("infra")

fn cmdIsInfrastructurePipeline(): bool =
    return cmdline.cliParam1Eq("infra-pipeline")

fn cmdIsNetworkSurface(): bool =
    return cmdline.cliParam1Eq("network-surface")

fn cmdIsNetworkPipeline(): bool =
    return cmdline.cliParam1Eq("network-pipeline")

fn cmdIsSelfhost(): bool =
    return cmdline.cliParam1Eq("selfhost")

fn cmdIsStageSelfhostHost(): bool =
    return cmdline.cliParam1Eq("stage-selfhost-host")

fn cmdIsToolingSelfhostHost(): bool =
    return cmdline.cliParam1Eq("tooling-selfhost-host")

fn cmdIsLsmrAddress(): bool =
    return cmdline.cliParam1Eq("lsmr-address")

fn cmdIsLsmrRoutePlan(): bool =
    return cmdline.cliParam1Eq("lsmr-route-plan")

fn cmdIsOutlineParse(): bool =
    return cmdline.cliParam1Eq("outline-parse")

fn cmdIsMachinePlan(): bool =
    return cmdline.cliParam1Eq("machine-plan")

fn cmdIsObjImage(): bool =
    return cmdline.cliParam1Eq("obj-image")

fn cmdIsObjFile(): bool =
    return cmdline.cliParam1Eq("obj-file")

fn cmdIsSystemLinkPlan(): bool =
    return cmdline.cliParam1Eq("system-link-plan")

fn cmdIsSystemLinkExec(): bool =
    return cmdline.cliParam1Eq("system-link-exec")

fn cmdIsResolveManifest(): bool =
    return cmdline.cliParam1Eq("resolve-manifest")

fn cmdIsPublishSourceManifest(): bool =
    return cmdline.cliParam1Eq("publish-source-manifest")

fn cmdIsPublishRulePack(): bool =
    return cmdline.cliParam1Eq("publish-rule-pack")

fn cmdIsPublishCompilerRulePack(): bool =
    return cmdline.cliParam1Eq("publish-compiler-rule-pack")

fn cmdIsVerifyNetworkSelfhost(): bool =
    return cmdline.cliParam1Eq("verify-network-selfhost")

fn cmdIsReleaseCompile(): bool =
    return cmdline.cliParam1Eq("release-compile")

fn printSurfaceZero(): int32 =
    printSurface()
    return 0

fn printPassesZero(): int32 =
    printPasses()
    return 0

fn printContractsZero(): int32 =
    printContracts()
    return 0

fn printStringsZero(): int32 =
    printStrings()
    return 0

fn printStringPipelineZero(): int32 =
    printStringPipeline()
    return 0

fn printInfrastructureZero(): int32 =
    printInfrastructure()
    return 0

fn printInfrastructurePipelineZero(): int32 =
    printInfrastructurePipeline()
    return 0

fn printNetworkSurfaceZero(): int32 =
    printNetworkSurface()
    return 0

fn printNetworkPipelineZero(): int32 =
    printNetworkPipeline()
    return 0

fn printSelfhostZero(): int32 =
    printSelfhost()
    return 0

fn printUsageFail(): int32 =
    printUsage()
    return 1

fn dispatchCommandLegacy(cmd: str): int32 =
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        return printUsageZero()
    if cmd == "surface":
        printSurface()
        return 0
    if cmd == "passes":
        printPasses()
        return 0
    if cmd == "contracts":
        printContracts()
        return 0
    if cmd == "strings":
        printStrings()
        return 0
    if cmd == "string-pipeline":
        printStringPipeline()
        return 0
    if cmd == "infra":
        printInfrastructure()
        return 0
    if cmd == "infra-pipeline":
        printInfrastructurePipeline()
        return 0
    if cmd == "network-surface":
        printNetworkSurface()
        return 0
    if cmd == "network-pipeline":
        printNetworkPipeline()
        return 0
    if cmd == "selfhost":
        printSelfhost()
        return 0
    if cmd == "stage-selfhost-host":
        return runStageSelfhostHost()
    if cmd == "tooling-selfhost-host":
        return runToolingSelfhostHost()
    if cmd == "lsmr-address":
        return runLsmrAddress()
    if cmd == "lsmr-route-plan":
        return runLsmrRoutePlan()
    if cmd == "outline-parse":
        return runOutlineParse()
    if cmd == "machine-plan":
        return runMachinePlan()
    if cmd == "obj-image":
        return runObjImage()
    if cmd == "obj-file":
        return runObjFile()
    if cmd == "system-link-plan":
        return runSystemLinkPlan()
    if cmd == "system-link-exec":
        return runSystemLinkExec()
    if cmd == "resolve-manifest":
        return runResolveManifest()
    if cmd == "publish-source-manifest":
        return runPublishSourceManifest()
    if cmd == "publish-rule-pack":
        return runPublishRulePack()
    if cmd == "publish-compiler-rule-pack":
        return runPublishCompilerRulePack()
    if cmd == "verify-network-selfhost":
        return runVerifyNetworkSelfhost()
    if cmd == "release-compile":
        return runReleaseCompile()
    printUsage()
    return 1

fn dispatchCommandParam1(): int32 =
    return dispatchCommandLegacy(cmdline.paramStr(1))

fn dispatchCommandAfterContracts(): int32 =
    if cmdIsStrings():
        return printStringsZero()
    else:
        return dispatchCommandAfterStrings()

fn dispatchCommandAfterStrings(): int32 =
    if cmdIsStringPipeline():
        return printStringPipelineZero()
    else:
        return dispatchCommandAfterStringPipeline()

fn dispatchCommandAfterStringPipeline(): int32 =
    if cmdIsInfrastructure():
        return printInfrastructureZero()
    else:
        return dispatchCommandAfterInfrastructure()

fn dispatchCommandAfterInfrastructure(): int32 =
    if cmdIsInfrastructurePipeline():
        return printInfrastructurePipelineZero()
    else:
        return dispatchCommandAfterInfrastructurePipeline()

fn dispatchCommandAfterInfrastructurePipeline(): int32 =
    if cmdIsNetworkSurface():
        return printNetworkSurfaceZero()
    else:
        return dispatchCommandAfterNetworkSurface()

fn dispatchCommandAfterNetworkSurface(): int32 =
    if cmdIsNetworkPipeline():
        return printNetworkPipelineZero()
    else:
        return dispatchCommandAfterNetworkPipeline()

fn dispatchCommandAfterNetworkPipeline(): int32 =
    if cmdIsSelfhost():
        return printSelfhostZero()
    else:
        return dispatchCommandAfterSelfhost()

fn dispatchCommandAfterSelfhost(): int32 =
    if cmdIsStageSelfhostHost():
        return runStageSelfhostHost()
    else:
        return dispatchCommandAfterStageSelfhostHost()

fn dispatchCommandAfterStageSelfhostHost(): int32 =
    if cmdIsToolingSelfhostHost():
        return runToolingSelfhostHost()
    else:
        return dispatchCommandAfterToolingSelfhostHost()

fn dispatchCommandAfterToolingSelfhostHost(): int32 =
