    let c = pipeline.lowUirPipelineContract()
    printLine("low_uir_pipeline=" + c.version)
    for i in 0..<c.passOrder.len:
        printLine(intToStr(i) + ":" + c.passOrder[i])

fn printContracts() =
    let s = surface.v2SurfaceContract()
    printLine("dev_entry=" + s.devEntry)
    printLine("tooling_entry=" + s.toolingEntry)
    printLine("function_parallelism=" + if s.functionParallelism: "1" else: "0")
    printLine("deterministic_merge=" + if s.deterministicMerge: "1" else: "0")
    printLine("soa_index_only=" + if surface.v2HasIndexOnlySoa(): "1" else: "0")

fn printStrings() =
    let c = sfront.stringSurfaceContract()
    let p = sir.sampleStringSurfaceProgram()
    let f = sffacts.buildStringSemanticFacts(p)
    let l = slower.stringLoweringContract()
    let o = sops.lowUirStringOpsContract()
    let r = srun.stringRuntimeContract()
    printLine("string_surface=" + c.version)
    printLine("surface_ir_version=" + p.version)
    printLine("lowering_version=" + l.version)
    printLine("facts_version=" + f.version)
    printLine("runtime_version=" + r.version)
    printLine("value_model=" + c.valueModel)
    printLine("abi_boundary_type=" + c.abiBoundaryType)
    printLine("operator_style=" + c.operatorStyle)
    printLine("search_algorithm=" + c.searchAlgorithm)
    printLine("concat_strategy=" + c.concatStrategy)
    printLine("zero_copy_slice=" + if c.zeroCopySlice: "1" else: "0")
    printLine("comparison_fast_path=" + c.comparisonFastPath)
    printLine("builder_call_model=" + l.builderCallModel)
    printLine("surface_ir_exprs=" + intToStr(p.exprs.len))
