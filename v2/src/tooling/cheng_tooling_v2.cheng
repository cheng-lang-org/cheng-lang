fn runVerifyCompilerCoreNoPointerClosure(): int32 =
    let rootPath = readFlagDefault("--root", ".")
    let outPath = readFlagDefault("--out", "")
    let roots = compilerCoreNoPointerClosureRoots()
    let sourcePaths = compilerCoreNoPointerClosureFiles(rootPath)
    var checkedPaths: str[] = []
    var checkedCompilerCoreCount: int32 = 0
    var checkedLineSurfaceCount: int32 = 0
    var violationCount: int32 = 0
    var firstViolationPath: str = ""
    var firstViolationReason: str = ""
    for i in 0..<sourcePaths.len:
        let absoluteSourcePath = compilerCoreZrpcAbsolutePath(rootPath, sourcePaths[i])
        let sourceText = os.readFile(absoluteSourcePath)
        var parsed: parser.ParsedV2Source
        if !parser.tryParseV2SourceText(absoluteSourcePath, sourceText, parsed):
            add(checkedPaths, sourcePaths[i])
            violationCount = violationCount + 1
            if len(firstViolationPath) <= 0:
                firstViolationPath = sourcePaths[i]
                firstViolationReason = "v2 no-pointer closure: unsupported mixed surface in " + sourcePaths[i]
            continue
        if !parser.sourceHasRecognizedSurface(parsed):
            add(checkedPaths, sourcePaths[i])
            violationCount = violationCount + 1
            if len(firstViolationPath) <= 0:
                firstViolationPath = sourcePaths[i]
                firstViolationReason = "v2 no-pointer closure: no v2 surface recognized in " + sourcePaths[i]
            continue
        if parsedHasSurfaceKind(parsed, "compiler_core"):
            checkedCompilerCoreCount = checkedCompilerCoreCount + 1
        else:
            checkedLineSurfaceCount = checkedLineSurfaceCount + 1
        add(checkedPaths, sourcePaths[i])
        let violation = firstNoPointerViolationForParsedSource(sourcePaths[i], sourceText, parsed)
        if len(violation) > 0:
            violationCount = violationCount + 1
            if len(firstViolationPath) <= 0:
                firstViolationPath = sourcePaths[i]
                firstViolationReason = violation
    if checkedPaths.len <= 0 && len(firstViolationReason) <= 0:
        firstViolationReason = "no v2 files checked"
    let manifestText = joinTextList(checkedPaths, "\n")
    let ok = checkedPaths.len > 0 && violationCount == 0
    var lines: str[] = []
    add(lines, "compiler_core_no_pointer_closure_version=v2")
    add(lines, "root_count=" + intToStr(roots.len))
    for i in 0..<roots.len:
        add(lines, "root." + intToStr(i) + "=" + roots[i])
    add(lines, "closure_file_count=" + intToStr(sourcePaths.len))
    add(lines, "checked_file_count=" + intToStr(checkedPaths.len))
    add(lines, "checked_compiler_core_file_count=" + intToStr(checkedCompilerCoreCount))
    add(lines, "checked_compiler_core_surface_file_count=" + intToStr(checkedCompilerCoreCount))
    add(lines, "checked_line_surface_file_count=" + intToStr(checkedLineSurfaceCount))
    add(lines, "closure_manifest_cid=" + ident.sha256HexText(manifestText))
    add(lines, "violation_count=" + intToStr(violationCount))
    add(lines, "first_violation_path=" + firstViolationPath)
    add(lines, "first_violation_reason=" + firstViolationReason)
    add(lines, "no_pointer_closure_ok=" + if ok: "1" else: "0")
    let text = mresolve.joinLines(lines)
    writeOptionalTextFile(outPath, text)
    writeText(text + "\n")
    return if ok: 0 else: 1

fn runVerifyV2NoPointerPackageClosures(): int32 =
    let rootPath = readFlagDefault("--root", ".")
    let outPath = readFlagDefault("--out", "")
    let repoRoot = absolutePath(rootPath)
    let specs = v2NoPointerPackageClosureSpecs()
    var lines: str[] = []
    var okCount: int32 = 0
    add(lines, "v2_no_pointer_package_closures_version=v1")
    add(lines, "case_count=" + intToStr(specs.len))
    for i in 0..<specs.len:
        let manifest = resolveV2NoPointerPackageClosureManifest(rootPath, specs[i].sourcePath)
        let entryAbsolutePath = compilerCoreZrpcAbsolutePath(rootPath, specs[i].sourcePath)
        let packageRoot = mresolve.findNearestPackageRoot(entryAbsolutePath)
        let packageManifestAbsolutePath = os.joinPath(packageRoot, "cheng-package.toml")
        let packageManifestPath =
            os.fileExists(packageManifestAbsolutePath)
            ? os.relativePath(packageManifestAbsolutePath, repoRoot)
            : ""
        var checkedFileCount: int32 = 0
        var checkedCompilerCoreCount: int32 = 0
        var checkedLineSurfaceCount: int32 = 0
        var violationCount: int32 = 0
        var firstViolationPath: str = ""
        var firstViolationReason: str = ""
        for pathIdx in 0..<manifest.filePaths.len:
            if !strings.hasSuffix(manifest.filePaths[pathIdx], ".cheng"):
                continue
            let absolutePath = compilerCoreZrpcAbsolutePath(rootPath, manifest.filePaths[pathIdx])
            let sourceText = os.readFile(absolutePath)
            var parsed: parser.ParsedV2Source
            if !parser.tryParseV2SourceText(absolutePath, sourceText, parsed):
                checkedFileCount = checkedFileCount + 1
                violationCount = violationCount + 1
                if len(firstViolationPath) <= 0:
                    firstViolationPath = manifest.filePaths[pathIdx]
                    firstViolationReason = "v2 no-pointer package closure: unsupported mixed surface in " +
                                           manifest.filePaths[pathIdx]
                continue
            if !parser.sourceHasRecognizedSurface(parsed):
                checkedFileCount = checkedFileCount + 1
                violationCount = violationCount + 1
                if len(firstViolationPath) <= 0:
                    firstViolationPath = manifest.filePaths[pathIdx]
                    firstViolationReason = "v2 no-pointer package closure: no v2 surface recognized in " +
                                           manifest.filePaths[pathIdx]
                continue
            checkedFileCount = checkedFileCount + 1
            if parsedHasSurfaceKind(parsed, "compiler_core"):
                checkedCompilerCoreCount = checkedCompilerCoreCount + 1
            else:
                checkedLineSurfaceCount = checkedLineSurfaceCount + 1
            let violation = firstNoPointerViolationForParsedSource(manifest.filePaths[pathIdx], sourceText, parsed)
            if len(violation) > 0:
                violationCount = violationCount + 1
                if len(firstViolationPath) <= 0:
                    firstViolationPath = manifest.filePaths[pathIdx]
                    firstViolationReason = violation
        let hasPackageManifest = len(packageManifestPath) > 0 && hasManifestClosurePath(manifest, packageManifestPath)
        let hasEntrySource = hasManifestClosurePath(manifest, specs[i].sourcePath)
        let caseOk = checkedFileCount > 0 && hasPackageManifest && hasEntrySource && violationCount == 0
        if caseOk:
            okCount = okCount + 1
        add(lines, "case." + intToStr(i) + ".id=" + specs[i].sampleId)
        add(lines, "case." + intToStr(i) + ".path=" + specs[i].sourcePath)
        add(lines, "case." + intToStr(i) + ".closure_file_count=" + intToStr(manifest.filePaths.len))
        add(lines, "case." + intToStr(i) + ".checked_file_count=" + intToStr(checkedFileCount))
        add(lines, "case." + intToStr(i) + ".checked_compiler_core_surface_file_count=" + intToStr(checkedCompilerCoreCount))
        add(lines, "case." + intToStr(i) + ".checked_line_surface_file_count=" + intToStr(checkedLineSurfaceCount))
        add(lines, "case." + intToStr(i) + ".closure_manifest_cid=" + manifest.manifestCid)
        add(lines, "case." + intToStr(i) + ".package_manifest_path=" + packageManifestPath)
        add(lines, "case." + intToStr(i) + ".package_manifest_present=" + if hasPackageManifest: "1" else: "0")
        add(lines, "case." + intToStr(i) + ".entry_source_present=" + if hasEntrySource: "1" else: "0")
        add(lines, "case." + intToStr(i) + ".violation_count=" + intToStr(violationCount))
        add(lines, "case." + intToStr(i) + ".first_violation_path=" + firstViolationPath)
        add(lines, "case." + intToStr(i) + ".first_violation_reason=" + firstViolationReason)
        add(lines, "case." + intToStr(i) + ".ok=" + if caseOk: "1" else: "0")
    let ok = okCount == specs.len
    add(lines, "ok_count=" + intToStr(okCount))
    add(lines, "v2_no_pointer_package_closures_ok=" + if ok: "1" else: "0")
    let text = mresolve.joinLines(lines)
    writeOptionalTextFile(outPath, text)
    writeText(text + "\n")
    return if ok: 0 else: 1

fn runVerifyCompilerCoreCycleSurface(): int32 =
    let rootPath = readFlagDefault("--root", ".")
    let outPath = readFlagDefault("--out", "")
    let entryPath = compilerCoreCycleFixtureEntryPath(rootPath)
    let manifest = mresolve.resolveCompilerCoreSourceManifest(entryPath)
    let bundle = cpipe.compileCompilerCoreSourceClosure(entryPath)
    let entryIdx = findProgramRoutineIndex(bundle.program, "entry")
    let makeAIdx = findProgramRoutineIndex(bundle.program, "makeA")
    let takeAIdx = findProgramRoutineIndex(bundle.program, "takeA")
    let roundTripIdx = findProgramRoutineIndex(bundle.program, "roundTrip")
    let makeBIdx = findProgramRoutineIndex(bundle.program, "makeB")
    let takeBIdx = findProgramRoutineIndex(bundle.program, "takeB")
    let entryItemIdx = findFactsItemIndex(bundle.facts, "fn", "entry")
    let makeAItemIdx = findFactsItemIndex(bundle.facts, "fn", "makeA")
    let roundTripItemIdx = findFactsItemIndex(bundle.facts, "fn", "roundTrip")
    var lines: str[] = []
    var ok: bool = true
    var hasPackage: bool = false
    var hasMain: bool = false
    var hasA: bool = false
    var hasB: bool = false
    var hasNoise: bool = false
    var entryAstReadyText: str = "0"
    var makeAAstReadyText: str = "0"
    var roundTripAstReadyText: str = "0"
    var makeAReturnText: str = ""
    var hasPackageText: str = "0"
    var hasMainText: str = "0"
    var hasAText: str = "0"
    var hasBText: str = "0"
    var hasNoiseText: str = "0"
    var okText: str = "1"
    hasPackage = hasManifestClosurePath(manifest,
                                        "v2/tests/contracts/compiler_core_cycle_surface_fixture/cheng-package.toml")
    hasMain = hasManifestClosurePath(manifest,
                                     "v2/tests/contracts/compiler_core_cycle_surface_fixture/src/cycle/main.cheng")
    hasA = hasManifestClosurePath(manifest,
                                  "v2/tests/contracts/compiler_core_cycle_surface_fixture/src/cycle/a.cheng")
    hasB = hasManifestClosurePath(manifest,
                                  "v2/tests/contracts/compiler_core_cycle_surface_fixture/src/cycle/b.cheng")
    hasNoise = hasManifestClosurePath(manifest,
                                      "v2/tests/contracts/compiler_core_cycle_surface_fixture/src/cycle/noise.cheng")
    if entryIdx >= 0 && bundle.program.routines[entryIdx].executableAstReady:
        entryAstReadyText = "1"
    if makeAIdx >= 0 && bundle.program.routines[makeAIdx].executableAstReady:
        makeAAstReadyText = "1"
    if roundTripIdx >= 0 && bundle.program.routines[roundTripIdx].executableAstReady:
        roundTripAstReadyText = "1"
    if makeAItemIdx >= 0:
        makeAReturnText = bundle.facts.returnTypeTexts[makeAItemIdx]
    if hasPackage:
        hasPackageText = "1"
    if hasMain:
        hasMainText = "1"
    if hasA:
        hasAText = "1"
    if hasB:
        hasBText = "1"
    if hasNoise:
        hasNoiseText = "1"
    add(lines, "cycle_surface_version=v1")
    add(lines, "manifest_file_count=" + intToStr(manifest.filePaths.len))
    add(lines, "manifest.has.package=" + hasPackageText)
    add(lines, "manifest.has.main=" + hasMainText)
    add(lines, "manifest.has.a=" + hasAText)
    add(lines, "manifest.has.b=" + hasBText)
    add(lines, "manifest.has.noise=" + hasNoiseText)
    add(lines, "routine_count=" + intToStr(bundle.program.routines.len))
    add(lines, "entry.ast_ready=" + entryAstReadyText)
    add(lines, "makeA.ast_ready=" + makeAAstReadyText)
    add(lines, "roundTrip.ast_ready=" + roundTripAstReadyText)
    add(lines, "makeA.param0=" + programRoutineParamTypeText(bundle.program, makeAIdx, 0))
    add(lines, "makeA.return=" + makeAReturnText)
    add(lines, "roundTrip.param0=" + programRoutineParamTypeText(bundle.program, roundTripIdx, 0))
    add(lines, "entry.import_field_routine_refs=" +
        intToStr(programRoutineExprReferenceCount(bundle.program, bundle.facts, entryIdx, "import_field_routine")))
    add(lines, "takeA.import_field_routine_refs=" +
        intToStr(programRoutineExprReferenceCount(bundle.program, bundle.facts, takeAIdx, "import_field_routine")))
    add(lines, "roundTrip.import_field_routine_refs=" +
        intToStr(programRoutineExprReferenceCount(bundle.program, bundle.facts, roundTripIdx, "import_field_routine")))
    if manifest.filePaths.len != 4 ||
       !hasPackage ||
       !hasMain ||
       !hasA ||
       !hasB ||
       hasNoise ||
       entryIdx < 0 || makeAIdx < 0 || takeAIdx < 0 || roundTripIdx < 0 ||
       makeBIdx < 0 || takeBIdx < 0 || entryItemIdx < 0 || makeAItemIdx < 0 || roundTripItemIdx < 0 ||
       !bundle.program.routines[entryIdx].executableAstReady ||
       !bundle.program.routines[makeAIdx].executableAstReady ||
       !bundle.program.routines[roundTripIdx].executableAstReady ||
       programRoutineParamTypeText(bundle.program, makeAIdx, 0) != "b.BBox" ||
       bundle.facts.returnTypeTexts[makeAItemIdx] != "ABox" ||
       programRoutineParamTypeText(bundle.program, roundTripIdx, 0) != "a.ABox" ||
       programRoutineExprReferenceCount(bundle.program, bundle.facts, entryIdx, "import_field_routine") != 3 ||
       programRoutineExprReferenceCount(bundle.program, bundle.facts, takeAIdx, "import_field_routine") != 1 ||
       programRoutineExprReferenceCount(bundle.program, bundle.facts, roundTripIdx, "import_field_routine") != 1:
        ok = false
    if !ok:
        okText = "0"
    add(lines, "cycle_surface_ok=" + okText)
    let text = mresolve.joinLines(lines)
    writeOptionalTextFile(outPath, text)
    writeText(text + "\n")
    if ok:
        return 0
    return 1

fn defaultReleaseOut(sourcePath: str, emitKind: str): str =
    let parts = os.splitFile(sourcePath)
    return os.joinPath("v2/artifacts/release", parts.name + "." + emitKind + ".artifact.txt")

fn runReleaseCompile(): int32 =
    let sourcePath = readFlagDefault("--in", "v2/examples/network_distribution_module.cheng")
    let emitKind = readFlagDefault("--emit", "exe")
    let targetTriple = readFlagDefault("--target", mtarget.machineTargetContract().firstClassTargets[0])
    let outPath = readFlagDefault("--out", defaultReleaseOut(sourcePath, emitKind))
    let bundle = rart.buildReleaseArtifact(sourcePath, emitKind, targetTriple)
    writeTextFile(outPath, bundle.artifactText + "\n")
    writeText(bundle.artifactText + "\n")
    return 0

