    var out: TaijiBaguaTag
    out.trigram = trigram
    out.stateBits = stateBits
    out.phase = phase
    out.reason = reason
    return out

fn joinTextList(values: str[], sep: str): str =
    var out: str = ""
    for i in 0..<values.len:
        if i > 0:
            out = out + sep
        out = out + values[i]
    return out

fn collectPrefixedLineValues(text: str, prefix: str): str[] =
    var out: str[] = []
    var start: int32 = 0
    var i: int32 = 0
    while i <= len(text):
        if i == len(text) || text[i] == '\n':
            let line = strings.sliceBytes(text, start, i - start)
            if len(line) >= len(prefix) && textStartsWith(line, prefix):
                add(out, strings.sliceBytes(line, len(prefix), len(line) - len(prefix)))
            start = i + 1
        i = i + 1
    return out

fn prefixedLineKey(prefix: str): str =
    if len(prefix) > 0 && prefix[len(prefix) - 1] == '=':
        return strings.sliceBytes(prefix, 0, len(prefix) - 1)
    return prefix

fn buildNetworkSmokeReportText(smoke: str,
                               stdoutPath: str,
                               prefixes: str[],
                               stdoutText: str,
                               outStageTotal: var int32): str =
    var lines: str[] = []
    outStageTotal = 0
    add(lines, "v2_network_smoke_report_v1")
    add(lines, "smoke=" + smoke)
    add(lines, "stdout_path=" + stdoutPath)
    add(lines, "prefix_count=" + intToStr(prefixes.len))
    for i in 0..<prefixes.len:
        let stages = collectPrefixedLineValues(stdoutText, prefixes[i])
        var stagesText = "-"
        if stages.len > 0:
            stagesText = joinTextList(stages, ",")
        outStageTotal = outStageTotal + stages.len
        add(lines, "prefix." + intToStr(i) + ".name=" + prefixedLineKey(prefixes[i]))
        add(lines, "prefix." + intToStr(i) + ".count=" + intToStr(stages.len))
        add(lines, "prefix." + intToStr(i) + ".stages=" + stagesText)
    add(lines, "stage_total=" + intToStr(outStageTotal))
    add(lines, "ok=1")
    return joinTextList(lines, "\n") + "\n"

fn jsonEscape(text: str): str =
    var out: str = ""
    for i in 0..<len(text):
        let ch = text[i]
        if ch == '\\':
            out = out + "\\\\"
        elif ch == '"':
            out = out + "\\\""
        elif ch == '\n':
            out = out + "\\n"
        elif ch == '\r':
            out = out + "\\r"
        elif ch == '\t':
            out = out + "\\t"
        else:
            out = out + charToStr(ch)
    return out

fn jsonQuote(text: str): str =
    return "\"" + jsonEscape(text) + "\""

fn jsonRawArray(values: str[]): str =
    return "[" + joinTextList(values, ", ") + "]"

fn jsonStringArray(values: str[]): str =
    var parts: str[]
    parts = []
    for i in 0..<values.len:
        add(parts, jsonQuote(values[i]))
    return jsonRawArray(parts)

fn jsonIntArray(values: int32[]): str =
    var parts: str[]
    parts = []
    for i in 0..<values.len:
        add(parts, intToStr(values[i]))
    return jsonRawArray(parts)

fn jsonBoolArray(values: bool[]): str =
    var parts: str[]
    parts = []
    for i in 0..<values.len:
        add(parts, if values[i]: "true" else: "false")
    return jsonRawArray(parts)

fn jsonFieldRaw(key: str, rawValue: str): str =
    return "  " + jsonQuote(key) + ": " + rawValue

fn jsonObject(fields: str[]): str =
    if fields.len <= 0:
        return "{}"
    return "{\n" + joinTextList(fields, ",\n") + "\n}"

fn emptyTypeRow(): str =
    return "[]"

fn singleTypeRow(value: str): str =
    return jsonStringArray([value])

fn pairTypeRow(left: str, right: str): str =
    return jsonStringArray([left, right])

fn tripleTypeRow(a: str, b: str, c: str): str =
    return jsonStringArray([a, b, c])

fn ensureTypeIndex(typeTable: var str[], typeText: str): int32 =
    for i in 0..<typeTable.len:
        if typeTable[i] == typeText:
            return i
    add(typeTable, typeText)
    return typeTable.len - 1

fn sourceLabelFromPath(sourcePath: str): str =
    let parts = os.splitFile(sourcePath)
    return parts.name

fn writeOptionalTextFile(outPath: str, text: str) =
    if len(outPath) > 0:
        writeTextFile(outPath, text)

fn compilerCoreTopLevelIsRoutine(kind: str): bool =
    return kind != "module" &&
           kind != "import" &&
           kind != "type" &&
           kind != "const" &&
           kind != "var"

fn compilerCoreRoutineIndexForTopLevel(program: cpipe.CompilerCorePipelineBundle, topLevelIndex: int32): int32 =
    var routineIdx: int32 = 0
    for i in 0..<program.program.topLevelKinds.len:
        if !compilerCoreTopLevelIsRoutine(program.program.topLevelKinds[i]):
            continue
        if i == topLevelIndex:
            return routineIdx
        routineIdx = routineIdx + 1
    return -1

fn stringInputTypeRow(opName: str): str =
    if opName == "str_eq" || opName == "str_ne" || opName == "str_concat" || opName == "str_contains" ||
       opName == "str_starts_with" || opName == "str_ends_with":
        return pairTypeRow("str", "str")
    if opName == "str_index":
        return pairTypeRow("str", "int32")
    if opName == "str_slice_view":
        return tripleTypeRow("str", "int32", "int32")
    if opName == "str_builder_init":
        return singleTypeRow("int32")
    if opName == "str_builder_append":
        return pairTypeRow("builder", "str")
    if opName == "str_builder_append_byte":
        return pairTypeRow("builder", "uint8")
    if opName == "str_builder_finish":
        return singleTypeRow("builder")
    return singleTypeRow("str")

fn stringBaguaTag(opName: str): TaijiBaguaTag =
    if opName == "str_builder_init":
        return taijiBaguaTag("坤", "000", "分配", "builder 初始化并建立缓冲空间")
    if opName == "str_builder_append" || opName == "str_builder_append_byte" || opName == "str_builder_finish" ||
       opName == "str_concat" || opName == "str_to_owned":
        return taijiBaguaTag("离", "101", "写入", "字符串写入、拼接或提交结果")
    if opName == "str_slice_view" || opName == "str_len" || opName == "str_index":
        return taijiBaguaTag("坎", "010", "读取", "字符串视图、索引或长度查询")
    return taijiBaguaTag("乾", "111", "计算", "纯比较或纯代数式字符串判断")

fn unimakerBaguaTag(opName: str): TaijiBaguaTag =
    if opName == "ganzhi_state_def":
        return taijiBaguaTag("坤", "000", "建模", "状态空间落位到 ganzhi 存储")
    if opName == "hardware_callback_def":
        return taijiBaguaTag("巽", "011", "事件注入", "外部硬件回调进入运行时")
    if opName == "evolve_site_def":
        return taijiBaguaTag("震", "100", "触发", "演化站点触发计算与调度")
    return taijiBaguaTag("乾", "111", "计算", "纯声明式能力绑定")

fn networkBaguaTag(opName: str): TaijiBaguaTag =
    if opName == "publish_source_manifest" || opName == "publish_rule_pack" ||
       opName == "publish_compiler_rule_pack" || opName == "disperse_ida_fragments":
        return taijiBaguaTag("离", "101", "写入", "网络内容发布或分发写回")
    if opName == "route_lsmr_tree":
        return taijiBaguaTag("坎", "010", "路由读取", "读取拓扑并生成路由路径")
    if opName == "exchange_anti_entropy_signature":
        return taijiBaguaTag("兑", "110", "流合并", "签名交换与流式合并")
    return taijiBaguaTag("艮", "001", "修复缓冲", "签名缺口修复进入阻塞与补洞阶段")

fn compilerCoreBaguaTag(opName: str): TaijiBaguaTag =
    if opName == "compiler_module_decl" || opName == "compiler_type_block" ||
       opName == "compiler_const_decl" || opName == "compiler_var_decl":
        return taijiBaguaTag("坤", "000", "建模", "编译器对象与布局落位")
    if opName == "compiler_import_bind":
        return taijiBaguaTag("兑", "110", "导入合流", "导入绑定把外部模块流入当前作用域")
    if opName == "compiler_importc_fn_decl":
        return taijiBaguaTag("巽", "011", "外部接入", "外部 ABI 声明进入编译环境")
    return taijiBaguaTag("乾", "111", "控制流计算", "例程执行或大纲计算")

fn jsonInlineFieldRaw(key: str, rawValue: str): str =
    return jsonQuote(key) + ": " + rawValue

fn jsonInlineObject(fields: str[]): str =
    return "{" + joinTextList(fields, ", ") + "}"

fn taijiDocument(text: str): TaijiDocument =
    var out: TaijiDocument
    out.text = text
    out.cid = ident.sha256HexText(text)
    return out

fn startsWithText(text: str, prefix: str): bool =
    if len(prefix) > len(text):
        return false
    for i in 0..<len(prefix):
        if text[i] != prefix[i]:
            return false
    return true

fn trimTrailingComma(text: str): str =
    if len(text) > 0 && text[len(text) - 1] == ',':
        return srun.sliceView(text, 0, len(text) - 1)
    return text

fn jsonDocFieldRaw(text: str, key: str): str =
    let prefix = "  " + jsonQuote(key) + ": "
    var lineStart: int32 = 0
    for i in 0..len(text):
        if i == len(text) || text[i] == '\n':
            let line = srun.sliceView(text, lineStart, i)
            if startsWithText(line, prefix):
                return trimTrailingComma(srun.sliceView(line, len(prefix), len(line)))
            lineStart = i + 1
    system.panic("taiji: missing json field " + key)

fn stripOuterArray(raw: str): str =
    if len(raw) >= 2 && raw[0] == '[' && raw[len(raw) - 1] == ']':
        return srun.sliceView(raw, 1, len(raw) - 1)
    return raw

fn trimAsciiWhitespace(text: str): str =
    var start: int32 = 0
    var stop: int32 = len(text)
    while start < stop && (text[start] == ' ' || text[start] == '\t' || text[start] == '\r' || text[start] == '\n'):
        start = start + 1
    while stop > start && (text[stop - 1] == ' ' || text[stop - 1] == '\t' || text[stop - 1] == '\r' || text[stop - 1] == '\n'):
        stop = stop - 1
    return srun.sliceView(text, start, stop)

fn countTopLevelCsvParts(raw: str): int32 =
    let text = stripOuterArray(raw)
    if len(text) <= 0:
        return 0
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var inString: bool = false
    var haveToken: bool = false
    var count: int32 = 0
    var i: int32 = 0
    while i < len(text):
        let ch = text[i]
        if inString:
            if ch == '\\' && i + 1 < len(text):
                i = i + 2
                haveToken = true
                continue
            if ch == '"':
                inString = false
            haveToken = true
            i = i + 1
            continue
        if ch == '"':
            inString = true
            haveToken = true
            i = i + 1
            continue
        if ch == '(':
            depthParen = depthParen + 1
            haveToken = true
        elif ch == ')':
            depthParen = depthParen - 1
            haveToken = true
        elif ch == '[':
            depthBracket = depthBracket + 1
            haveToken = true
        elif ch == ']':
            depthBracket = depthBracket - 1
            haveToken = true
        elif ch == '{':
            depthBrace = depthBrace + 1
            haveToken = true
        elif ch == '}':
            depthBrace = depthBrace - 1
            haveToken = true
        elif ch == ',' && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            count = count + 1
            haveToken = false
        elif ch != ' ' && ch != '\t' && ch != '\r' && ch != '\n':
            haveToken = true
        i = i + 1
    if haveToken:
        return count + 1
    return count

fn topLevelArrayParts(raw: str): str[] =
    let text = stripOuterArray(raw)
    var out: str[]
    out = []
    if len(text) <= 0:
        return out
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var inString: bool = false
    var partStart: int32 = 0
    var i: int32 = 0
    while i < len(text):
        let ch = text[i]
        if inString:
            if ch == '\\' && i + 1 < len(text):
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            i = i + 1
            continue
        if ch == '(':
            depthParen = depthParen + 1
        elif ch == ')':
            depthParen = depthParen - 1
        elif ch == '[':
            depthBracket = depthBracket + 1
        elif ch == ']':
            depthBracket = depthBracket - 1
        elif ch == '{':
            depthBrace = depthBrace + 1
        elif ch == '}':
            depthBrace = depthBrace - 1
        elif ch == ',' && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            let part = trimAsciiWhitespace(srun.sliceView(text, partStart, i))
            if len(part) > 0:
                add(out, part)
            partStart = i + 1
        i = i + 1
    let tail = trimAsciiWhitespace(srun.sliceView(text, partStart, len(text)))
    if len(tail) > 0:
        add(out, tail)
    return out

fn parseDecimalInt32(text: str): int32 =
    let raw = trimAsciiWhitespace(text)
    if len(raw) <= 0:
        system.panic("taiji: empty int32 text")
    var start: int32 = 0
    var sign: int32 = 1
    if raw[0] == '-':
        sign = -1
        start = 1
    if start >= len(raw):
        system.panic("taiji: malformed int32 text " + raw)
    var value: int32 = 0
    for i in start..<len(raw):
        let ch = raw[i]
        if ch < '0' || ch > '9':
            system.panic("taiji: non-decimal int32 text " + raw)
        value = value * 10 + int32(ch) - int32('0')
    return value * sign

fn jsonArrayIntValues(raw: str): int32[] =
    let parts = topLevelArrayParts(raw)
    var out: int32[]
    out = []
    for i in 0..<parts.len:
        add(out, parseDecimalInt32(parts[i]))
    return out

fn jsonArrayStringValues(raw: str): str[] =
    let parts = topLevelArrayParts(raw)
    var out: str[]
    out = []
    for i in 0..<parts.len:
        let text = trimAsciiWhitespace(parts[i])
        if len(text) < 2 || text[0] != '"' || text[len(text) - 1] != '"':
            system.panic("taiji: malformed json string array item " + text)
        add(out, srun.sliceView(text, 1, len(text) - 1))
    return out

fn jsonCountObjectValue(raw: str, key: str): int32 =
    let needle = jsonQuote(key) + ":"
    var i: int32 = 0
    while i + len(needle) <= len(raw):
        let window = srun.sliceView(raw, i, i + len(needle))
        if window == needle:
            var start = i + len(needle)
            while start < len(raw) &&
                  (raw[start] == ' ' || raw[start] == '\t' || raw[start] == '\r' || raw[start] == '\n'):
                start = start + 1
            var stop = start
            while stop < len(raw) && raw[stop] != ',' && raw[stop] != '}':
                stop = stop + 1
            return parseDecimalInt32(trimAsciiWhitespace(srun.sliceView(raw, start, stop)))
        i = i + 1
    system.panic("taiji: missing json count key " + key)

fn jsonCountObjectValues(raw: str, keys: str[]): int32[] =
    var out: int32[]
    out = []
    for i in 0..<keys.len:
        add(out, jsonCountObjectValue(raw, keys[i]))
    return out

fn planeIndex(planeOrder: str[], plane: str): int32 =
    for i in 0..<planeOrder.len:
        if planeOrder[i] == plane:
            return i
    return -1

fn planePairOrder(planeOrder: str[]): str[] =
    var out: str[]
    out = []
    for i in 0..<planeOrder.len:
        for j in 0..<planeOrder.len:
            add(out, planeOrder[i] + "->" + planeOrder[j])
    return out

