import std/seqs

type
    ToolingSelfhostContract =
        version: str
        stages: str[]
        proofKeys: str[]
        stage0Tool: str
        stage1Entry: str
        stage2Goal: str
        currentStatus: str
        proofCommand: str
        proofRoot: str
        proofSource: str
        proofTarget: str
        proofInvariants: str[]

fn toolingSelfhostContract(): ToolingSelfhostContract =
    var out: ToolingSelfhostContract
    out.version = "v2.tooling_selfhost.v1"
    out.stages = []
    add(out.stages, "host_bootstrap")
    add(out.stages, "cheng_stage1_tooling")
    add(out.stages, "cheng_stage2_tooling")
    out.proofKeys = []
    add(out.proofKeys, "source_manifest_cid")
    add(out.proofKeys, "rule_pack_cid")
    add(out.proofKeys, "compiler_rule_pack_cid")
    add(out.proofKeys, "release_compile_key")
    add(out.proofKeys, "obj_image_cid")
    add(out.proofKeys, "lsmr_addressing_mode")
    add(out.proofKeys, "lsmr_address_binding")
    add(out.proofKeys, "lsmr_distance_metric")
    add(out.proofKeys, "lsmr_route_plan_model")
    add(out.proofKeys, "tooling_selfhost_stage_hash")
    out.stage0Tool = "v2/bootstrap/cheng_v2c"
    out.stage1Entry = "bootstrap/tooling_stage1_bootstrap"
    out.stage2Goal = "tooling_network_selfhost_closure"
    out.currentStatus = "stage0_stage1_stage2_tooling_fixed_point"
    out.proofCommand = "make -C v2/bootstrap tooling-selfhost"
    out.proofRoot = "v2/examples"
    out.proofSource = "v2/examples/network_distribution_module.cheng"
    out.proofTarget = "arm64-apple-darwin"
    out.proofInvariants = []
    add(out.proofInvariants, "stage0_stage_hash == stage1_stage_hash")
    add(out.proofInvariants, "stage1_stage_hash == stage2_stage_hash")
    add(out.proofInvariants, "generated_stage1 == generated_stage2")
    add(out.proofInvariants, "generated_stage1 == src/bootstrap/tooling_stage1_bootstrap.cheng")
    add(out.proofInvariants, "checked_in_release_artifact_output == tests/contracts/tooling_release_artifact.expected")
    add(out.proofInvariants, "checked_in_network_selfhost_output == tests/contracts/network_selfhost.expected")
    add(out.proofInvariants, "checked_in_tooling_selfhost_output == tests/contracts/tooling_selfhost.expected")
    add(out.proofInvariants, "release_manifest_cid == source_manifest_cid")
    add(out.proofInvariants, "lsmr_addressing_mode == lsmr_path")
    add(out.proofInvariants, "lsmr_address_binding == content_bound_address")
    add(out.proofInvariants, "lsmr_distance_metric == per_level_manhattan")
    add(out.proofInvariants, "lsmr_route_plan_model == canonical_multipath_set")
    add(out.proofInvariants, "compile_key_addressing_covered == 1")
    add(out.proofInvariants, "compile_key_depth_covered == 1")
    add(out.proofInvariants, "compile_key_address_binding_covered == 1")
    add(out.proofInvariants, "compile_key_distance_metric_covered == 1")
    add(out.proofInvariants, "compile_key_canonical_multipath_covered == 1")
    add(out.proofInvariants, "machine_pipeline_obj_image_release_artifact_are_fixed")
    add(out.proofInvariants, "source_manifest_rule_pack_compiler_rule_pack_release_compile_key_are_fixed")
    add(out.proofInvariants, "random_gossip_fallback_present == 0")
    return out
