import std/seqs
import compiler/frontend/unimaker_surface_ir_v2 as usurf
import compiler/driver/unimaker_pipeline_v2 as upipe

fn bootstrapSurfaceProgram(): usurf.UnimakerSurfaceProgram =
    var out: usurf.UnimakerSurfaceProgram = usurf.newUnimakerSurfaceProgram()
    add(out.decls, usurf.assetDecl("UniToken", "value: u64 | value > 0"))
    add(out.decls, usurf.actorDecl("RobotNode", "actor RobotNode(location_hash: HashRef[Point3D])"))
    add(out.decls, usurf.ganzhiStateDecl("global_map", "state global_map: Map[HashRef[Point3D], Point3D]"))
    add(out.decls, usurf.callbackDecl("on_asset_tap", "fn on_asset_tap(card_data: bytes) -> Result[UniToken, Error]"))
    add(out.decls, usurf.evolveDecl("process_vision", "fn process_vision(image: PolarTensor[u8]) -> Action", "target=npu metric=memory_footprint"))
    return out

fn bootstrapPipeline(): upipe.UnimakerPipelineBundle =
    return upipe.compileUnimakerSurfaceProgram(bootstrapSurfaceProgram())
