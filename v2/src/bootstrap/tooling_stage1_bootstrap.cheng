import compiler/driver/manifest_resolver_v2 as manifest
import compiler/driver/release_artifact_v2 as rart
import compiler/driver/network_distribution_pipeline_v2 as npipe
import compiler/frontend/v2_source_parser as parser

fn bootstrapExamplesRoot(): str =
    return "v2/examples"

fn bootstrapNetworkSource(): str =
    return "v2/examples/network_distribution_module.cheng"

fn bootstrapTargetTriple(): str =
    return "arm64-apple-darwin"

fn bootstrapReleaseEmitKind(): str =
    return "exe"

fn bootstrapSourceManifest(): manifest.SourceManifestBundle =
    return manifest.resolveSourceManifest(bootstrapExamplesRoot())

fn bootstrapNetworkPipeline(): npipe.NetworkDistributionPipelineBundle =
    let parsed = parser.parseV2SourceFileStrict(bootstrapNetworkSource())
    return npipe.compileNetworkDistributionProgram(parsed.networkProgram)

fn bootstrapReleaseArtifact(): rart.ReleaseArtifactBundle =
    return rart.buildReleaseArtifact(bootstrapNetworkSource(), bootstrapReleaseEmitKind(), bootstrapTargetTriple())
