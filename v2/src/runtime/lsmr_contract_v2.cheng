import std/seqs

type
    LsmrRuntimeContract =
        version: str
        addressingMode: str
        addressBinding: str
        distanceMetric: str
        cellLayout: str
        routePlanModel: str
        rootPublisherDigit: int32
    LsmrAddressIdentity =
        version: str
        depth: int32
        canonicalText: str
    LsmrRoutePlanIdentity =
        version: str
        canonicalText: str
        canonicalCid: str

fn lsmrRuntimeContract(): LsmrRuntimeContract =
    var out: LsmrRuntimeContract
    out.version = "v2.runtime.lsmr.v1"
    out.addressingMode = "lsmr_path"
    out.addressBinding = "content_bound_address"
    out.distanceMetric = "per_level_manhattan"
    out.cellLayout = "[8,1,6;3,5,7;4,9,2]"
    out.routePlanModel = "canonical_multipath_set"
    out.rootPublisherDigit = 5
    return out

fn lsmrAddressIdentityVersion(): str =
    return "v2.runtime.lsmr_address.v1"

fn lsmrRoutePlanIdentityVersion(): str =
    return "v2.runtime.lsmr_route_plan.v1"
