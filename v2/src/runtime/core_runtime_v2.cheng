import std/seqs

type
    CoreRuntimeContract =
        version: str
        services: str[]
        providerSourceKind: str
        providerCompileMode: str
        providerSourcePath: str
        executionModel: str
        traceSymbol: str

fn coreRuntimeContract(): CoreRuntimeContract =
    var out: CoreRuntimeContract
    out.version = "v2.runtime.core.v1"
    out.services = []
    add(out.services, "builtin.len")
    out.providerSourceKind = "cheng_module"
    out.providerCompileMode = "machine_obj"
    out.providerSourcePath = "v2/src/runtime/core_runtime_v2.cheng"
    out.executionModel = "native_trace_stub"
    out.traceSymbol = "puts"
    return out

fn coreRuntimeTargets(): str[] =
    return coreRuntimeContract().services
