import std/system
import std/rawmem_support
import std/seqs

type
    StringRuntimeContract =
        version: str
        operatorStyle: str
        searchAlgorithm: str
        comparisonKernel: str
        concatStrategy: str
        builderStorage: str
        builderGrowth: str
        builderFinish: str
        zeroCopySlice: bool
        symbolFunctions: str[]
        loweringHelpers: str[]
        providerSourceKind: str
        providerCompileMode: str
        providerSourcePath: str
        executionModel: str
        traceSymbol: str
    MaximalSuffixState =
        split: int32
        period: int32
    StrBuilder =
        storage: str
        len: int32
        cap: int32

fn stringRuntimeContract(): StringRuntimeContract =
    var out: StringRuntimeContract
    out.version = "v2.runtime.strings.v1"
    out.operatorStyle = "symbol_first"
    out.searchAlgorithm = "two_way_bytes"
    out.comparisonKernel = "cmpmem"
    out.concatStrategy = "allocate_once"
    out.builderStorage = "owned_str_buffer"
    out.builderGrowth = "power_of_two"
    out.builderFinish = "move_owned_buffer"
    out.zeroCopySlice = true
    out.symbolFunctions = []
    add(out.symbolFunctions, "==")
    add(out.symbolFunctions, "!=")
    add(out.symbolFunctions, "+")
    add(out.symbolFunctions, "[]")
    add(out.symbolFunctions, "$")
    out.loweringHelpers = []
    add(out.loweringHelpers, "__cheng_concat_str")
    add(out.loweringHelpers, "__cheng_slice_string")
    add(out.loweringHelpers, "__cheng_string_contains_char")
    add(out.loweringHelpers, "__cheng_string_contains_str")
    out.providerSourceKind = "cheng_module"
    out.providerCompileMode = "machine_obj"
    out.providerSourcePath = "v2/src/runtime/strings_v2.cheng"
    out.executionModel = "native_trace_stub"
    out.traceSymbol = "puts"
    return out

fn stringRuntimeLines(): str[] =
    let c = stringRuntimeContract()
    var out: str[]
    out = []
    add(out, "runtime_version=" + c.version)
    add(out, "operator_style=" + c.operatorStyle)
    add(out, "search_algorithm=" + c.searchAlgorithm)
    add(out, "comparison_kernel=" + c.comparisonKernel)
    add(out, "concat_strategy=" + c.concatStrategy)
    add(out, "builder_storage=" + c.builderStorage)
    add(out, "builder_growth=" + c.builderGrowth)
    add(out, "builder_finish=" + c.builderFinish)
    add(out, "symbol_functions=" + intToStr(c.symbolFunctions.len))
    add(out, "lowering_helpers=" + intToStr(c.loweringHelpers.len))
    add(out, "zero_copy_slice=" + if c.zeroCopySlice: "1" else: "0")
    return out

fn stringRuntimeTargets(): str[] =
    var out: str[]
    out = []
    add(out, "runtime/strings_v2.==")
    add(out, "runtime/strings_v2.!=")
    add(out, "runtime/strings_v2.[]")
    add(out, "runtime/strings_v2.startsWith")
    add(out, "runtime/strings_v2.endsWith")
    add(out, "runtime/strings_v2.__cheng_slice_string")
    add(out, "runtime/strings_v2.+")
    add(out, "runtime/strings_v2.find")
    add(out, "runtime/strings_v2.__cheng_string_contains_str")
    add(out, "runtime/strings_v2.__cheng_string_contains_char")
    add(out, "runtime/strings_v2.$")
    add(out, "runtime/strings_v2.StrBuilder")
    add(out, "runtime/strings_v2.append")
    add(out, "runtime/strings_v2.appendByte")
    add(out, "runtime/strings_v2.finish")
    return out

fn maxInt32(a: int32, b: int32): int32 =
    if a > b:
        return a
    return b

fn byteAtUnchecked(text: str, index: int32): uint8 =
    return load(rawmem_support.rawmemPtrAdd(strDataPtr(text), index))

fn bytesEq(leftPtr: ptr, rightPtr: ptr, count: int32): bool =
    if count <= 0:
        return true
    if leftPtr == rightPtr:
        return true
    if leftPtr == nil || rightPtr == nil:
        return false
    return cmpMem(leftPtr, rightPtr, int64(count)) == 0

fn rangeEq(left: str, leftStart: int32, right: str, rightStart: int32, count: int32): bool =
    if count <= 0:
        return true
    if leftStart < 0 || rightStart < 0:
        return false
    let leftLen: int32 = strLenFast(left)
    let rightLen: int32 = strLenFast(right)
    if leftStart + count > leftLen || rightStart + count > rightLen:
        return false
    let leftPtr: ptr = rawmem_support.rawmemPtrAdd(strDataPtr(left), leftStart)
    let rightPtr: ptr = rawmem_support.rawmemPtrAdd(strDataPtr(right), rightStart)
    return bytesEq(leftPtr, rightPtr, count)

fn eq(left: str, right: str): bool =
    let leftLen: int32 = strLenFast(left)
    let rightLen: int32 = strLenFast(right)
    if leftLen != rightLen:
        return false
    if leftLen <= 0:
        return true
    let leftPtr: ptr = strDataPtr(left)
    let rightPtr: ptr = strDataPtr(right)
    if leftPtr == rightPtr:
        return true
    return bytesEq(leftPtr, rightPtr, leftLen)

fn `==`(left: str, right: str): bool =
    return eq(left, right)

fn `!=`(left: str, right: str): bool =
    return !eq(left, right)

fn `[]`(text: str, index: int32): char =
    if index < 0 || index >= strLenFast(text):
        return char(0)
    if strDataPtr(text) == nil:
        return char(0)
    return char(byteAtUnchecked(text, index))

fn startsWith(text: str, prefix: str): bool =
    let textLen: int32 = strLenFast(text)
    let prefixLen: int32 = strLenFast(prefix)
    if prefixLen <= 0:
        return true
    if prefixLen > textLen:
        return false
    return rangeEq(text, 0, prefix, 0, prefixLen)

fn endsWith(text: str, suffix: str): bool =
    let textLen: int32 = strLenFast(text)
    let suffixLen: int32 = strLenFast(suffix)
    if suffixLen <= 0:
        return true
    if suffixLen > textLen:
        return false
    return rangeEq(text, textLen - suffixLen, suffix, 0, suffixLen)

fn sliceView(text: str, startInclusive: int32, stopExclusive: int32): str =
    let n: int32 = strLenFast(text)
    if n <= 0:
        return strEmpty()
    var start0: int32 = startInclusive
    var stop0: int32 = stopExclusive
    if start0 < 0:
        start0 = 0
    if stop0 < start0:
        stop0 = start0
    if start0 >= n:
        return strEmpty()
    if stop0 > n:
        stop0 = n
    return strSubView(text, start0, stop0 - start0)

fn concat(left: str, right: str): str =
    let leftLen: int32 = strLenFast(left)
    let rightLen: int32 = strLenFast(right)
    let totalLen: int32 = leftLen + rightLen
    if totalLen <= 0:
        return strEmpty()
    let out: str = newStringAlloc(totalLen)
    let outPtr: ptr = strDataPtr(out)
    if outPtr == nil:
        return strEmpty()
    if leftLen > 0:
        rawmem_support.rawmemCopy(outPtr, strDataPtr(left), leftLen)
    if rightLen > 0:
        rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(outPtr, leftLen), strDataPtr(right), rightLen)
    rawmem_support.rawmemWriteI8(outPtr, totalLen, int8(0))
    return out

fn `+`(left: str, right: str): str =
    return concat(left, right)

fn __cheng_concat_str(left: str, right: str): str =
    return left + right

fn __cheng_slice_string(text: str, start: int32, stop: int32, exclusive: bool): str =
    let stopExclusive: int32 = exclusive ? stop : (stop + 1)
    return sliceView(text, start, stopExclusive)

fn maximalSuffixForward(pattern: str): MaximalSuffixState =
    var out: MaximalSuffixState
    out.split = -1
    out.period = 1
    let m: int32 = strLenFast(pattern)
    if m <= 1:
        return out
    var ms: int32 = -1
    var j: int32 = 0
    var k: int32 = 1
    var p: int32 = 1
    while j + k < m:
        let a: uint8 = byteAtUnchecked(pattern, j + k)
        let b: uint8 = byteAtUnchecked(pattern, ms + k)
        if a < b:
            j = j + k
            k = 1
            p = j - ms
        elif a == b:
            if k != p:
                k = k + 1
            else:
                j = j + p
                k = 1
        else:
            ms = j
            j = ms + 1
            k = 1
            p = 1
    out.split = ms
    out.period = p
    return out

fn maximalSuffixReverse(pattern: str): MaximalSuffixState =
    var out: MaximalSuffixState
    out.split = -1
    out.period = 1
    let m: int32 = strLenFast(pattern)
    if m <= 1:
        return out
    var ms: int32 = -1
    var j: int32 = 0
    var k: int32 = 1
    var p: int32 = 1
    while j + k < m:
        let a: uint8 = byteAtUnchecked(pattern, j + k)
        let b: uint8 = byteAtUnchecked(pattern, ms + k)
        if a > b:
            j = j + k
            k = 1
            p = j - ms
        elif a == b:
            if k != p:
                k = k + 1
            else:
                j = j + p
                k = 1
        else:
            ms = j
            j = ms + 1
            k = 1
            p = 1
    out.split = ms
    out.period = p
    return out

fn find(text: str, pattern: str): int32 =
    let textLen: int32 = strLenFast(text)
    let patternLen: int32 = strLenFast(pattern)
    if patternLen <= 0:
        return 0
    if patternLen > textLen:
        return -1

    let forward = maximalSuffixForward(pattern)
    let reverse = maximalSuffixReverse(pattern)

    var split: int32 = forward.split
    var period: int32 = forward.period
    if reverse.split > split:
        split = reverse.split
        period = reverse.period

    var memoryReset: int32 = 0
    if !rangeEq(pattern, 0, pattern, period, split + 1):
        period = maxInt32(split + 1, patternLen - split - 1) + 1
        memoryReset = 0
    else:
        memoryReset = patternLen - period

    var memory: int32 = 0
    var textPos: int32 = 0
    while textPos <= textLen - patternLen:
        var k: int32 = maxInt32(split + 1, memory)
        while k < patternLen && byteAtUnchecked(pattern, k) == byteAtUnchecked(text, textPos + k):
            k = k + 1
        if k < patternLen:
            textPos = textPos + (k - split)
            memory = 0
            continue
        k = split + 1
        while k > memory && byteAtUnchecked(pattern, k - 1) == byteAtUnchecked(text, textPos + k - 1):
            k = k - 1
        if k <= memory:
            return textPos
        textPos = textPos + period
        memory = memoryReset
    return -1

fn contains(text: str, pattern: str): bool =
    return find(text, pattern) >= 0

fn contains(text: str, value: char): bool =
    let n: int32 = strLenFast(text)
    var i: int32 = 0
    while i < n:
        if text[i] == value:
            return true
        i = i + 1
    return false

fn __cheng_string_contains_char(text: str, value: char): bool =
    return contains(text, value)

fn __cheng_string_contains_str(text: str, pattern: str): bool =
    return contains(text, pattern)

fn nextBuilderCap(currentCap: int32, requiredCap: int32): int32 =
    var cap: int32 = currentCap
    if cap < 8:
        cap = 8
    while cap < requiredCap:
        cap = cap * 2
    return cap

fn StrBuilder(initialCap: int32): StrBuilder =
    var out: StrBuilder
    out.storage = strEmpty()
    out.len = 0
    out.cap = 0
    if initialCap <= 0:
        return out
    out.storage = newStringAlloc(initialCap)
    if strDataPtr(out.storage) == nil:
        out.storage = strEmpty()
        return out
    out.cap = initialCap
    rawmem_support.rawmemWriteI8(strDataPtr(out.storage), 0, int8(0))
    return out

fn ensureCap(builder: var StrBuilder, additional: int32) =
    if additional <= 0:
        return
    let requiredCap: int32 = builder.len + additional
    if requiredCap <= builder.cap && (requiredCap == 0 || strDataPtr(builder.storage) != nil):
        return
    let nextCap: int32 = nextBuilderCap(builder.cap, requiredCap)
    let nextStorage: str = newStringAlloc(nextCap)
    let nextPtr: ptr = strDataPtr(nextStorage)
    if nextPtr == nil:
        panic("v2 strings builder alloc failed")
    if builder.len > 0:
        rawmem_support.rawmemCopy(nextPtr, strDataPtr(builder.storage), builder.len)
    rawmem_support.rawmemWriteI8(nextPtr, builder.len, int8(0))
    builder.storage = nextStorage
    builder.cap = nextCap

fn append(builder: var StrBuilder, text: str) =
    let textLen: int32 = strLenFast(text)
    if textLen <= 0:
        return
    ensureCap(builder, textLen)
    let dstPtr: ptr = strDataPtr(builder.storage)
    rawmem_support.rawmemCopy(rawmem_support.rawmemPtrAdd(dstPtr, builder.len), strDataPtr(text), textLen)
    builder.len = builder.len + textLen
    rawmem_support.rawmemWriteI8(dstPtr, builder.len, int8(0))

fn appendByte(builder: var StrBuilder, value: uint8) =
    ensureCap(builder, 1)
    let dstPtr: ptr = strDataPtr(builder.storage)
    rawmem_support.rawmemWriteI8(dstPtr, builder.len, int8(value))
    builder.len = builder.len + 1
    rawmem_support.rawmemWriteI8(dstPtr, builder.len, int8(0))

fn finish(builder: var StrBuilder): str =
    if builder.len <= 0:
        builder.storage = strEmpty()
        builder.cap = 0
        return strEmpty()
    var out: str = builder.storage
    builder.storage = strEmpty()
    builder.cap = 0
    out.len = builder.len
    builder.len = 0
    if strDataPtr(out) != nil:
        rawmem_support.rawmemWriteI8(strDataPtr(out), out.len, int8(0))
    return out

fn `$`(text: str): str =
    return newStringCopy(strDataPtr(text), strLenFast(text))
