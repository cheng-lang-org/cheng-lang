import std/system
import std/seqs

@importc("driver_c_str_clone_bridge")
fn strCloneBridge(text: str): str

@importc("driver_c_str_eq_bridge")
fn strEqBridge(left: str, right: str): bool

@importc("driver_c_str_has_prefix_bridge")
fn strHasPrefixBridge(text: str, prefix: str): bool

@importc("driver_c_str_contains_char_bridge")
fn strContainsCharBridge(text: str, value: int32): bool

@importc("driver_c_str_get_at_bridge")
fn strGetAtBridge(text: str, index: int32): int32

@importc("driver_c_str_concat_bridge")
fn strConcatBridge(left: str, right: str): str

@importc("driver_c_char_to_str_bridge")
fn charToStrBridge(value: int32): str

type
    StringRuntimeContract =
        version: str
        operatorStyle: str
        searchAlgorithm: str
        comparisonKernel: str
        concatStrategy: str
        builderStorage: str
        builderGrowth: str
        builderFinish: str
        zeroCopySlice: bool
        symbolFunctions: str[]
        loweringHelpers: str[]
        providerSourceKind: str
        providerCompileMode: str
        providerSourcePath: str
        executionModel: str
        traceSymbol: str
    MaximalSuffixState =
        split: int32
        period: int32
    StrBuilder =
        storage: str
        len: int32
        cap: int32

fn stringRuntimeContract(): StringRuntimeContract =
    var out: StringRuntimeContract
    out.version = "v2.runtime.strings.v1"
    out.operatorStyle = "symbol_first"
    out.searchAlgorithm = "two_way_bytes"
    out.comparisonKernel = "bridge_index_eq"
    out.concatStrategy = "allocate_once"
    out.builderStorage = "owned_str_value"
    out.builderGrowth = "logical_power_of_two"
    out.builderFinish = "move_owned_value"
    out.zeroCopySlice = true
    out.symbolFunctions = []
    seqs.add(out.symbolFunctions, "==")
    seqs.add(out.symbolFunctions, "!=")
    seqs.add(out.symbolFunctions, "+")
    seqs.add(out.symbolFunctions, "[]")
    seqs.add(out.symbolFunctions, "$")
    out.loweringHelpers = []
    seqs.add(out.loweringHelpers, "__cheng_concat_str")
    seqs.add(out.loweringHelpers, "__cheng_slice_string")
    seqs.add(out.loweringHelpers, "__cheng_string_contains_char")
    seqs.add(out.loweringHelpers, "__cheng_string_contains_str")
    out.providerSourceKind = "cheng_module"
    out.providerCompileMode = "machine_obj"
    out.providerSourcePath = "v2/src/runtime/strings_v2.cheng"
    out.executionModel = "native_trace_stub"
    out.traceSymbol = "puts"
    return out

fn stringRuntimeLines(): str[] =
    let c = stringRuntimeContract()
    var out: str[]
    out = []
    seqs.add(out, "runtime_version=" + c.version)
    seqs.add(out, "operator_style=" + c.operatorStyle)
    seqs.add(out, "search_algorithm=" + c.searchAlgorithm)
    seqs.add(out, "comparison_kernel=" + c.comparisonKernel)
    seqs.add(out, "concat_strategy=" + c.concatStrategy)
    seqs.add(out, "builder_storage=" + c.builderStorage)
    seqs.add(out, "builder_growth=" + c.builderGrowth)
    seqs.add(out, "builder_finish=" + c.builderFinish)
    seqs.add(out, "symbol_functions=" + intToStr(c.symbolFunctions.len))
    seqs.add(out, "lowering_helpers=" + intToStr(c.loweringHelpers.len))
    seqs.add(out, "zero_copy_slice=" + if c.zeroCopySlice: "1" else: "0")
    return out

fn stringRuntimeTargets(): str[] =
    var out: str[]
    out = []
    seqs.add(out, "runtime/strings_v2.==")
    seqs.add(out, "runtime/strings_v2.!=")
    seqs.add(out, "runtime/strings_v2.[]")
    seqs.add(out, "runtime/strings_v2.startsWith")
    seqs.add(out, "runtime/strings_v2.endsWith")
    seqs.add(out, "runtime/strings_v2.__cheng_slice_string")
    seqs.add(out, "runtime/strings_v2.+")
    seqs.add(out, "runtime/strings_v2.find")
    seqs.add(out, "runtime/strings_v2.__cheng_string_contains_str")
    seqs.add(out, "runtime/strings_v2.__cheng_string_contains_char")
    seqs.add(out, "runtime/strings_v2.$")
    seqs.add(out, "runtime/strings_v2.StrBuilder")
    seqs.add(out, "runtime/strings_v2.append")
    seqs.add(out, "runtime/strings_v2.appendByte")
    seqs.add(out, "runtime/strings_v2.finish")
    return out

fn maxInt32(a: int32, b: int32): int32 =
    if a > b:
        return a
    return b

fn byteAtUnchecked(text: str, index: int32): uint8 =
    return uint8(strGetAtBridge(text, index) & 255)

fn rangeEq(left: str, leftStart: int32, right: str, rightStart: int32, count: int32): bool =
    if count <= 0:
        return true
    if leftStart < 0 || rightStart < 0:
        return false
    let leftLen: int32 = strLenFast(left)
    let rightLen: int32 = strLenFast(right)
    if leftStart + count > leftLen || rightStart + count > rightLen:
        return false
    var i: int32 = 0
    while i < count:
        if byteAtUnchecked(left, leftStart + i) != byteAtUnchecked(right, rightStart + i):
            return false
        i = i + 1
    return true

fn eq(left: str, right: str): bool =
    return strEqBridge(left, right)

fn `==`(left: str, right: str): bool =
    return eq(left, right)

fn `!=`(left: str, right: str): bool =
    return !eq(left, right)

fn `[]`(text: str, index: int32): char =
    if index < 0 || index >= strLenFast(text):
        return char(0)
    return char(strGetAtBridge(text, index) & 255)

fn startsWith(text: str, prefix: str): bool =
    return strHasPrefixBridge(text, prefix)

fn endsWith(text: str, suffix: str): bool =
    let textLen: int32 = strLenFast(text)
    let suffixLen: int32 = strLenFast(suffix)
    if suffixLen <= 0:
        return true
    if suffixLen > textLen:
        return false
    return rangeEq(text, textLen - suffixLen, suffix, 0, suffixLen)

fn sliceView(text: str, startInclusive: int32, stopExclusive: int32): str =
    let n: int32 = strLenFast(text)
    if n <= 0:
        return strEmpty()
    var start0: int32 = startInclusive
    var stop0: int32 = stopExclusive
    if start0 < 0:
        start0 = 0
    if stop0 < start0:
        stop0 = start0
    if start0 >= n:
        return strEmpty()
    if stop0 > n:
        stop0 = n
    return strSubView(text, start0, stop0 - start0)

fn concat(left: str, right: str): str =
    return strConcatBridge(left, right)

fn `+`(left: str, right: str): str =
    return concat(left, right)

fn __cheng_concat_str(left: str, right: str): str =
    return left + right

fn __cheng_slice_string(text: str, start: int32, stop: int32, exclusive: bool): str =
    let stopExclusive: int32 = exclusive ? stop : (stop + 1)
    return sliceView(text, start, stopExclusive)

fn maximalSuffixForward(pattern: str): MaximalSuffixState =
    var out: MaximalSuffixState
    out.split = -1
    out.period = 1
    let m: int32 = strLenFast(pattern)
    if m <= 1:
        return out
    var ms: int32 = -1
    var j: int32 = 0
    var k: int32 = 1
    var p: int32 = 1
    while j + k < m:
        let a: uint8 = byteAtUnchecked(pattern, j + k)
        let b: uint8 = byteAtUnchecked(pattern, ms + k)
        if a < b:
            j = j + k
            k = 1
            p = j - ms
        elif a == b:
            if k != p:
                k = k + 1
            else:
                j = j + p
                k = 1
        else:
            ms = j
            j = ms + 1
            k = 1
            p = 1
    out.split = ms
    out.period = p
    return out

fn maximalSuffixReverse(pattern: str): MaximalSuffixState =
    var out: MaximalSuffixState
    out.split = -1
    out.period = 1
    let m: int32 = strLenFast(pattern)
    if m <= 1:
        return out
    var ms: int32 = -1
    var j: int32 = 0
    var k: int32 = 1
    var p: int32 = 1
    while j + k < m:
        let a: uint8 = byteAtUnchecked(pattern, j + k)
        let b: uint8 = byteAtUnchecked(pattern, ms + k)
        if a > b:
            j = j + k
            k = 1
            p = j - ms
        elif a == b:
            if k != p:
                k = k + 1
            else:
                j = j + p
                k = 1
        else:
            ms = j
            j = ms + 1
            k = 1
            p = 1
    out.split = ms
    out.period = p
    return out

fn find(text: str, pattern: str): int32 =
    let textLen: int32 = strLenFast(text)
    let patternLen: int32 = strLenFast(pattern)
    if patternLen <= 0:
        return 0
    if patternLen > textLen:
        return -1

    let forward = maximalSuffixForward(pattern)
    let reverse = maximalSuffixReverse(pattern)

    var split: int32 = forward.split
    var period: int32 = forward.period
    if reverse.split > split:
        split = reverse.split
        period = reverse.period

    var memoryReset: int32 = 0
    if !rangeEq(pattern, 0, pattern, period, split + 1):
        period = maxInt32(split + 1, patternLen - split - 1) + 1
        memoryReset = 0
    else:
        memoryReset = patternLen - period

    var memory: int32 = 0
    var textPos: int32 = 0
    while textPos <= textLen - patternLen:
        var k: int32 = maxInt32(split + 1, memory)
        while k < patternLen && byteAtUnchecked(pattern, k) == byteAtUnchecked(text, textPos + k):
            k = k + 1
        if k < patternLen:
            textPos = textPos + (k - split)
            memory = 0
            continue
        k = split + 1
        while k > memory && byteAtUnchecked(pattern, k - 1) == byteAtUnchecked(text, textPos + k - 1):
            k = k - 1
        if k <= memory:
            return textPos
        textPos = textPos + period
        memory = memoryReset
    return -1

fn contains(text: str, pattern: str): bool =
    return find(text, pattern) >= 0

fn contains(text: str, value: char): bool =
    return strContainsCharBridge(text, int32(value))

fn __cheng_string_contains_char(text: str, value: char): bool =
    return contains(text, value)

fn __cheng_string_contains_str(text: str, pattern: str): bool =
    return contains(text, pattern)

fn nextBuilderCap(currentCap: int32, requiredCap: int32): int32 =
    var cap: int32 = currentCap
    if cap < 8:
        cap = 8
    while cap < requiredCap:
        cap = cap * 2
    return cap

fn StrBuilder(initialCap: int32): StrBuilder =
    var out: StrBuilder
    out.storage = strEmpty()
    out.len = 0
    out.cap = 0
    if initialCap > 0:
        out.cap = nextBuilderCap(0, initialCap)
    return out

fn ensureCap(builder: var StrBuilder, additional: int32) =
    if additional <= 0:
        return
    let requiredCap: int32 = builder.len + additional
    if requiredCap <= builder.cap:
        return
    builder.cap = nextBuilderCap(builder.cap, requiredCap)

fn append(builder: var StrBuilder, text: str) =
    let textLen: int32 = strLenFast(text)
    if textLen <= 0:
        return
    ensureCap(builder, textLen)
    builder.storage = strConcatBridge(builder.storage, text)
    builder.len = builder.len + textLen

fn appendByte(builder: var StrBuilder, value: uint8) =
    ensureCap(builder, 1)
    builder.storage = strConcatBridge(builder.storage, charToStrBridge(int32(value)))
    builder.len = builder.len + 1

fn finish(builder: var StrBuilder): str =
    let out = builder.storage
    builder.storage = strEmpty()
    builder.len = 0
    builder.cap = 0
    return out

fn `$`(text: str): str =
    return strCloneBridge(text)
