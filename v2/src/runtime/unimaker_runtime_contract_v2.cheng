import std/seqs
import std/system

type
    UnimakerRuntimeContract =
        version: str
        actorRuntime: str
        stateModel: str
        codeIdentity: str
        capabilityModel: str
        evolveMode: str
        services: str[]
        providerSourceKind: str
        providerCompileMode: str
        providerSourcePath: str
        executionModel: str
        traceSymbol: str

fn unimakerRuntimeContract(): UnimakerRuntimeContract =
    var out: UnimakerRuntimeContract
    out.version = "v2.runtime.unimaker.v1"
    out.actorRuntime = "actor_mailbox_plus_hash_addressing"
    out.stateModel = "actor_owned_state_plus_crdt_snapshot"
    out.codeIdentity = "source_files_plus_content_addressed_manifest"
    out.capabilityModel = "typed_capability_plus_effect_gate"
    out.evolveMode = "offline_candidate_generation"
    out.services = []
    add(out.services, "runtime/unimaker.verify_asset_contract")
    add(out.services, "runtime/unimaker.spawn_actor")
    add(out.services, "runtime/unimaker.register_ganzhi_state")
    add(out.services, "runtime/unimaker.bind_nfc_callback")
    add(out.services, "runtime/unimaker.register_evolve_site")
    add(out.services, "runtime/unimaker.resolve_hashref")
    out.providerSourceKind = "cheng_module"
    out.providerCompileMode = "machine_obj"
    out.providerSourcePath = "v2/src/runtime/unimaker_runtime_contract_v2.cheng"
    out.executionModel = "native_trace_stub"
    out.traceSymbol = "puts"
    return out

fn unimakerRuntimeLines(): str[] =
    let c = unimakerRuntimeContract()
    var out: str[]
    out = []
    add(out, "runtime_version=" + c.version)
    add(out, "actor_runtime=" + c.actorRuntime)
    add(out, "state_model=" + c.stateModel)
    add(out, "code_identity=" + c.codeIdentity)
    add(out, "capability_model=" + c.capabilityModel)
    add(out, "evolve_mode=" + c.evolveMode)
    add(out, "service_count=" + intToStr(c.services.len))
    return out

fn unimakerRuntimeTargets(): str[] =
    return unimakerRuntimeContract().services
