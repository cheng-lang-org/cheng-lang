import std/seqs

type
    AbiBridgeContract =
        version: str
        supportedAnnotations: str[]
        normalizedEdges: str[]
        generatedSurfaces: str[]

fn abiBridgeContract(): AbiBridgeContract =
    var out: AbiBridgeContract
    out.version = "v2.abi_bridge.v1"
    out.supportedAnnotations = []
    add(out.supportedAnnotations, "@exportc")
    add(out.supportedAnnotations, "@ffi_map")
    add(out.supportedAnnotations, "@ffi_out_ptrs")
    add(out.supportedAnnotations, "@ffi_handle")
    out.normalizedEdges = []
    add(out.normalizedEdges, "slice_to_ptr_len")
    add(out.normalizedEdges, "outptr_to_tuple")
    add(out.normalizedEdges, "handle_slot_mapping")
    add(out.normalizedEdges, "borrow_bridge")
    out.generatedSurfaces = []
    add(out.generatedSurfaces, "c_export_surface")
    add(out.generatedSurfaces, "c_import_surface")
    add(out.generatedSurfaces, "mobile_embed_surface")
    return out

fn abiBridgeAnnotationCount(): int32 =
    let c = abiBridgeContract()
    return c.supportedAnnotations.len
