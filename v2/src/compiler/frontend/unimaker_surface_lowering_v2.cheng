import compiler/frontend/unimaker_surface_ir_v2 as usurf
import compiler/semantic_facts/unimaker_facts_v2 as ufacts
import compiler/high_uir/unimaker_graph_v2 as uhigh

fn lowerUnimakerSurfaceProgramToHighUir(program: usurf.UnimakerSurfaceProgram,
                                        facts: ufacts.UnimakerSemanticFacts): uhigh.HighUirUnimakerGraph =
    var graph: uhigh.HighUirUnimakerGraph = uhigh.newHighUirUnimakerGraph()
    for i in 0..<program.decls.len:
        uhigh.appendHighUirUnimakerDecl(graph,
                                        facts.declIds[i],
                                        facts.highOps[i],
                                        facts.proofDomains[i],
                                        facts.runtimeBindings[i],
                                        facts.effectClasses[i],
                                        facts.networkModes[i],
                                        facts.capabilityKinds[i],
                                        facts.networkDomains[i],
                                        facts.topologyRefs[i],
                                        facts.transportModes[i],
                                        facts.repairModes[i],
                                        facts.dispersalModes[i],
                                        facts.priorityClasses[i],
                                        facts.identityScopes[i],
                                        facts.antiEntropySignatureKinds[i],
                                        program.decls[i])
    return graph

fn lowerSampleUnimakerSurfaceProgramToHighUir(): uhigh.HighUirUnimakerGraph =
    let program = usurf.sampleUnimakerSurfaceProgram()
    let facts = ufacts.buildUnimakerSemanticFacts(program)
    return lowerUnimakerSurfaceProgramToHighUir(program, facts)
