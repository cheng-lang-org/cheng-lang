import std/seqs

type
    FrontendContract =
        version: str
        phases: str[]
        outputs: str[]
        requiresNoPointerPolicy: bool
        requiresOwnershipProof: bool

fn frontendContract(): FrontendContract =
    var out: FrontendContract
    out.version = "v2.frontend.v2"
    out.phases = []
    add(out.phases, "lex")
    add(out.phases, "parse")
    add(out.phases, "import_graph")
    add(out.phases, "name_resolution")
    add(out.phases, "type_resolution")
    add(out.phases, "contract_resolution")
    add(out.phases, "capability_check")
    add(out.phases, "network_binding")
    add(out.phases, "surface_lowering")
    add(out.phases, "trait_resolution")
    add(out.phases, "ownership")
    add(out.phases, "monomorphization")
    out.outputs = []
    add(out.outputs, "semantic_facts")
    add(out.outputs, "high_uir_graph")
    add(out.outputs, "unimaker_surface_graph")
    out.requiresNoPointerPolicy = true
    out.requiresOwnershipProof = true
    return out

fn frontendPhaseCount(): int32 =
    let c = frontendContract()
    return c.phases.len
