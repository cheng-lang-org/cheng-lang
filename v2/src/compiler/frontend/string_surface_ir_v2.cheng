import std/seqs
import std/system

type
    StringSurfaceExpr =
        surfaceForm: str
        leftText: str
        rightText: str
        builderName: str
        charValue: char
        intArg0: int32
        intArg1: int32
        byteValue: uint8
    StringSurfaceProgram =
        version: str
        exprs: StringSurfaceExpr[]

fn emptyStringSurfaceExpr(surfaceForm: str): StringSurfaceExpr =
    var out: StringSurfaceExpr
    out.surfaceForm = surfaceForm
    out.leftText = ""
    out.rightText = ""
    out.builderName = ""
    out.charValue = char(0)
    out.intArg0 = 0
    out.intArg1 = 0
    out.byteValue = uint8(0)
    return out

fn surfaceEq(leftText: str, rightText: str): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("a == b")
    out.leftText = leftText
    out.rightText = rightText
    return out

fn surfaceNe(leftText: str, rightText: str): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("a != b")
    out.leftText = leftText
    out.rightText = rightText
    return out

fn surfaceAdd(leftText: str, rightText: str): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("a + b")
    out.leftText = leftText
    out.rightText = rightText
    return out

fn surfaceIndex(text: str, index: int32): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("s[i]")
    out.leftText = text
    out.intArg0 = index
    return out

fn surfaceLen(text: str): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("s.len")
    out.leftText = text
    return out

fn surfaceSlice(text: str, startInclusive: int32, stopExclusive: int32): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("s[a..<b]")
    out.leftText = text
    out.intArg0 = startInclusive
    out.intArg1 = stopExclusive
    return out

fn surfaceContainsChar(text: str, value: char): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("c in s")
    out.leftText = text
    out.charValue = value
    return out

fn surfaceContainsStr(text: str, sub: str): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("sub in s")
    out.leftText = text
    out.rightText = sub
    return out

fn surfaceStartsWith(text: str, prefix: str): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("s.startsWith(prefix)")
    out.leftText = text
    out.rightText = prefix
    return out

fn surfaceEndsWith(text: str, suffix: str): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("s.endsWith(suffix)")
    out.leftText = text
    out.rightText = suffix
    return out

fn surfaceToOwned(text: str): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("$s")
    out.leftText = text
    return out

fn surfaceBuilderInit(builderName: str, cap: int32): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("StrBuilder(cap)")
    out.builderName = builderName
    out.intArg0 = cap
    return out

fn surfaceBuilderAppend(builderName: str, text: str): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("builder.append(str)")
    out.builderName = builderName
    out.rightText = text
    return out

fn surfaceBuilderAppendByte(builderName: str, value: uint8): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("builder.appendByte(u8)")
    out.builderName = builderName
    out.byteValue = value
    return out

fn surfaceBuilderFinish(builderName: str): StringSurfaceExpr =
    var out: StringSurfaceExpr = emptyStringSurfaceExpr("builder.finish()")
    out.builderName = builderName
    return out

fn stringSurfaceExprSummary(expr: StringSurfaceExpr): str =
    if expr.surfaceForm == "a == b" || expr.surfaceForm == "a != b" || expr.surfaceForm == "a + b":
        return expr.leftText + " | " + expr.surfaceForm + " | " + expr.rightText
    if expr.surfaceForm == "s[i]":
        return expr.leftText + " | " + expr.surfaceForm + " | " + intToStr(expr.intArg0)
    if expr.surfaceForm == "s.len":
        return expr.leftText + " | " + expr.surfaceForm
    if expr.surfaceForm == "s[a..<b]":
        return expr.leftText + " | " + expr.surfaceForm + " | " + intToStr(expr.intArg0) + "," + intToStr(expr.intArg1)
    if expr.surfaceForm == "c in s":
        return expr.leftText + " | " + expr.surfaceForm + " | " + charToStr(expr.charValue)
    if expr.surfaceForm == "sub in s" || expr.surfaceForm == "s.startsWith(prefix)" || expr.surfaceForm == "s.endsWith(suffix)":
        return expr.leftText + " | " + expr.surfaceForm + " | " + expr.rightText
    if expr.surfaceForm == "$s":
        return "$ | " + expr.leftText
    if expr.surfaceForm == "StrBuilder(cap)":
        return expr.builderName + " | init | " + intToStr(expr.intArg0)
    if expr.surfaceForm == "builder.append(str)":
        return expr.builderName + " | append | " + expr.rightText
    if expr.surfaceForm == "builder.appendByte(u8)":
        return expr.builderName + " | appendByte | " + intToStr(int32(expr.byteValue))
    if expr.surfaceForm == "builder.finish()":
        return expr.builderName + " | finish"
    return expr.surfaceForm

fn newStringSurfaceProgram(): StringSurfaceProgram =
    var out: StringSurfaceProgram
    out.version = "v2.frontend.string_surface_ir.v1"
    out.exprs = []
    return out

fn sampleStringSurfaceProgram(): StringSurfaceProgram =
    var out: StringSurfaceProgram = newStringSurfaceProgram()
    add(out.exprs, surfaceEq("lhs", "rhs"))
    add(out.exprs, surfaceNe("lhs", "rhs"))
    add(out.exprs, surfaceAdd("prefix", "suffix"))
    add(out.exprs, surfaceIndex("text", 1))
    add(out.exprs, surfaceSlice("text", 2, 5))
    add(out.exprs, surfaceContainsChar("text", 'x'))
    add(out.exprs, surfaceContainsStr("text", "needle"))
    add(out.exprs, surfaceStartsWith("text", "pre"))
    add(out.exprs, surfaceEndsWith("text", "suf"))
    add(out.exprs, surfaceToOwned("text"))
    add(out.exprs, surfaceBuilderInit("b0", 16))
    add(out.exprs, surfaceBuilderAppend("b0", "chunk"))
    add(out.exprs, surfaceBuilderAppendByte("b0", uint8(33)))
    add(out.exprs, surfaceBuilderFinish("b0"))
    return out

fn stringSurfaceExprCount(program: StringSurfaceProgram): int32 =
    return program.exprs.len
