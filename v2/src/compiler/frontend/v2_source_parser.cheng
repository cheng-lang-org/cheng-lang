import std/os
import std/strutils as strutils
import std/strings as strings
import std/system
import compiler/frontend/compiler_core_surface_ir_v2 as ccore
import compiler/frontend/unimaker_surface_ir_v2 as usurf
import compiler/frontend/network_distribution_surface_ir_v2 as nsurf
import compiler/driver/module_path_v2 as mpath
import compiler/driver/identity_v2 as ident

type
    ParsedV2Source =
        version: str
        sourcePath: str
        compilerCoreProgram: ccore.CompilerCoreProgram
        unimakerProgram: usurf.UnimakerSurfaceProgram
        networkProgram: nsurf.NetworkDistributionProgram
        surfaceKinds: str[]

fn sliceRange(text: str, start: int32, stopExclusive: int32): str =
    if stopExclusive <= start:
        return ""
    return strings.sliceBytes(text, start, stopExclusive - start)

fn findChar(text: str, target: char): int32 =
    for i in 0..<len(text):
        if text[i] == target:
            return i
    return -1

fn findLastChar(text: str, target: char): int32 =
    var i: int32 = len(text) - 1
    while i >= 0:
        if text[i] == target:
            return i
        i = i - 1
    return -1

fn findText(text: str, sub: str): int32 =
    let n = len(text)
    let m = len(sub)
    if m == 0:
        return 0
    if m > n:
        return -1
    var i: int32 = 0
    while i + m <= n:
        var matched: bool = true
        var j: int32 = 0
        while j < m:
            if text[i + j] != sub[j]:
                matched = false
                break
            j = j + 1
        if matched:
            return i
        i = i + 1
    return -1

fn isNameChar(ch: char): bool =
    return (ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') || (ch >= '0' && ch <= '9') || ch == '_'

fn parseNameAfterPrefix(line: str, prefix: str): str =
    var start: int32 = len(prefix)
    while start < len(line) && (line[start] == ' ' || line[start] == '\t'):
        start = start + 1
    var stop: int32 = start
    while stop < len(line) && isNameChar(line[stop]):
        stop = stop + 1
    return sliceRange(line, start, stop)

fn parseIntStrict(raw: str): int32 =
    let text = strutils.strip(raw)
    if len(text) == 0:
        system.panicStr("v2 source parser: expected integer")
    return compilerIntLiteralValue(text)

fn extractNamedValue(body: str, key: str): str =
    let pattern = key + "="
    let idx = findText(body, pattern)
    if idx < 0:
        return ""
    var start: int32 = idx + len(pattern)
    while start < len(body) && (body[start] == ' ' || body[start] == '\t'):
        start = start + 1
    var stop: int32 = start
    var depth: int32 = 0
    while stop < len(body):
        let ch = body[stop]
        if ch == '(':
            depth = depth + 1
        elif ch == ')':
            if depth == 0:
                break
            depth = depth - 1
        elif ch == ',' && depth == 0:
            break
        stop = stop + 1
    return strutils.strip(sliceRange(body, start, stop))

fn parseTopologyDispersal(raw: str, outDispersal: var str, outK: var int32, outN: var int32) =
    let text = strutils.strip(raw)
    outDispersal = ""
    outK = 0
    outN = 0
    if text == "none":
        outDispersal = "none"
        return
    if !(strutils.startsWith(text, "ida(") && len(text) > 5 && text[len(text) - 1] == ')'):
        system.panicStr("v2 source parser: unsupported topology dispersal " + text)
    let inner = sliceRange(text, 4, len(text) - 1)
    outDispersal = "ida"
    outK = parseIntStrict(extractNamedValue(inner, "k"))
    outN = parseIntStrict(extractNamedValue(inner, "n"))

fn parseCallBody(line: str, prefix: str): str =
    if !strutils.startsWith(line, prefix + "("):
        return ""
    if len(line) < len(prefix) + 2 || line[len(line) - 1] != ')':
        system.panicStr("v2 source parser: malformed call " + line)
    return sliceRange(line, len(prefix) + 1, len(line) - 1)

fn parseUnimakerLine(program: var usurf.UnimakerSurfaceProgram, line: str): bool =
    if strutils.startsWith(line, "asset "):
        let name = parseNameAfterPrefix(line, "asset ")
        let colonIdx = findChar(line, ':')
        let contractText = if colonIdx >= 0: strutils.strip(sliceRange(line, colonIdx + 1, len(line))) else: ""
        add(program.decls, usurf.assetDecl(name, contractText))
        return true
    if strutils.startsWith(line, "actor "):
        let name = parseNameAfterPrefix(line, "actor ")
        add(program.decls, usurf.actorDecl(name, line))
        return true
    if strutils.startsWith(line, "@ganzhi state "):
        let name = parseNameAfterPrefix(line, "@ganzhi state ")
        add(program.decls, usurf.ganzhiStateDecl(name, sliceRange(line, len("@ganzhi "), len(line))))
        return true
    if strutils.startsWith(line, "@nfc_callback fn "):
        let name = parseNameAfterPrefix(line, "@nfc_callback fn ")
        add(program.decls, usurf.callbackDecl(name, sliceRange(line, len("@nfc_callback "), len(line))))
        return true
    if strutils.startsWith(line, "@evolve("):
        let closeIdx = findChar(line, ')')
        let fnIdx = findText(line, "fn ")
        if closeIdx < 0 || fnIdx < 0:
            system.panicStr("v2 source parser: malformed evolve declaration")
        let targetText = strutils.strip(sliceRange(line, len("@evolve("), closeIdx))
        let name = parseNameAfterPrefix(sliceRange(line, fnIdx, len(line)), "fn ")
        add(program.decls, usurf.evolveDecl(name, sliceRange(line, fnIdx, len(line)), targetText))
        return true
    return false

fn parseTopologyLine(program: var nsurf.NetworkDistributionProgram, line: str): bool =
    if !strutils.startsWith(line, "topology "):
        return false
    let name = parseNameAfterPrefix(line, "topology ")
    let bodyIdx = findText(line, "lsmr_tree(")
    if bodyIdx < 0 || line[len(line) - 1] != ')':
        system.panicStr("v2 source parser: malformed topology declaration")
    let body = sliceRange(line, bodyIdx + len("lsmr_tree("), len(line) - 1)
    let domain = extractNamedValue(body, "domain")
    let fanout = extractNamedValue(body, "fanout")
    let repair = extractNamedValue(body, "repair")
    let dispersalRaw = extractNamedValue(body, "dispersal")
    let priority = extractNamedValue(body, "priority")
    let addressing = extractNamedValue(body, "addressing")
    let depthRaw = extractNamedValue(body, "depth")
    if len(addressing) == 0:
        system.panicStr("v2 source parser: topology addressing is required")
    if len(depthRaw) == 0:
        system.panicStr("v2 source parser: topology depth is required")
    var dispersal: str = ""
    let depth = parseIntStrict(depthRaw)
    var idaK: int32 = 0
    var idaN: int32 = 0
    parseTopologyDispersal(dispersalRaw, dispersal, idaK, idaN)
    add(program.topologies, nsurf.topologyDecl(name, domain, fanout, repair, dispersal, priority, addressing, depth, idaK, idaN))
    return true

fn parseNetworkOpLine(program: var nsurf.NetworkDistributionProgram, line: str): bool =
    var body = parseCallBody(line, "publish_source_manifest")
    if len(body) > 0:
        add(program.ops, nsurf.publishSourceManifest(extractNamedValue(body, "topology"), extractNamedValue(body, "package")))
        return true
    body = parseCallBody(line, "publish_rule_pack")
    if len(body) > 0:
        add(program.ops, nsurf.publishRulePack(extractNamedValue(body, "topology"), extractNamedValue(body, "pack")))
        return true
    body = parseCallBody(line, "publish_compiler_rule_pack")
    if len(body) > 0:
        add(program.ops, nsurf.publishCompilerRulePack(extractNamedValue(body, "topology"), extractNamedValue(body, "pack")))
        return true
    body = parseCallBody(line, "route_lsmr_tree")
    if len(body) > 0:
        add(program.ops, nsurf.routeLsmrTree(extractNamedValue(body, "topology")))
        return true
    body = parseCallBody(line, "disperse_ida_fragments")
    if len(body) > 0:
        add(program.ops, nsurf.disperseIdaFragments(extractNamedValue(body, "topology")))
        return true
    body = parseCallBody(line, "exchange_anti_entropy_signature")
    if len(body) > 0:
        add(program.ops, nsurf.exchangeAntiEntropySignature(extractNamedValue(body, "topology"), extractNamedValue(body, "signature")))
        return true
    body = parseCallBody(line, "repair_from_signature_gap")
    if len(body) > 0:
        add(program.ops, nsurf.repairFromSignatureGap(extractNamedValue(body, "topology"), extractNamedValue(body, "signature")))
        return true
    return false

fn leadingIndentWidth(line: str): int32 =
    var out: int32 = 0
    while out < len(line) && (line[out] == ' ' || line[out] == '\t'):
        out = out + 1
    return out

fn trimInlineComment(rawLine: str): str =
    var inString: bool = false
    var inChar: bool = false
    var i: int32 = 0
    while i < len(rawLine):
        let ch = rawLine[i]
        if inString:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            i = i + 1
            continue
        if ch == '\'':
            inChar = true
            i = i + 1
            continue
        if ch == '#':
            return strutils.strip(sliceRange(rawLine, 0, i))
        i = i + 1
    return strutils.strip(rawLine)

fn isBlankOrCommentLine(rawLine: str): bool =
    let line = trimInlineComment(rawLine)
    return len(line) == 0 || strutils.startsWith(line, "//")

fn compilerTextHasOpenDelimiters(text: str): bool =
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var inString: bool = false
    var inChar: bool = false
    var i: int32 = 0
    while i < len(text):
        let ch = text[i]
        if inString:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            i = i + 1
            continue
        if ch == '\'':
            inChar = true
            i = i + 1
            continue
        if ch == '(':
            depthParen = depthParen + 1
        elif ch == ')':
            depthParen = depthParen - 1
        elif ch == '[':
            depthBracket = depthBracket + 1
        elif ch == ']':
            depthBracket = depthBracket - 1
        elif ch == '{':
            depthBrace = depthBrace + 1
        elif ch == '}':
            depthBrace = depthBrace - 1
        i = i + 1
    return inString || inChar || depthParen > 0 || depthBracket > 0 || depthBrace > 0

fn compilerTextHasOpenTernary(text: str): bool =
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var inString: bool = false
    var inChar: bool = false
    var ternaryDepth: int32 = 0
    var i: int32 = 0
    while i < len(text):
        let ch = text[i]
        if inString:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            i = i + 1
            continue
        if ch == '\'':
            inChar = true
            i = i + 1
            continue
        if ch == '(':
            depthParen = depthParen + 1
            i = i + 1
            continue
        if ch == ')':
            depthParen = depthParen - 1
            i = i + 1
            continue
        if ch == '[':
            depthBracket = depthBracket + 1
            i = i + 1
            continue
        if ch == ']':
            depthBracket = depthBracket - 1
            i = i + 1
            continue
        if ch == '{':
            depthBrace = depthBrace + 1
            i = i + 1
            continue
        if ch == '}':
            depthBrace = depthBrace - 1
            i = i + 1
            continue
        if depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            if ch == '?':
                ternaryDepth = ternaryDepth + 1
                i = i + 1
                continue
            if ternaryDepth > 0 && startsWithAt(text, i, " else:"):
                if i + len(" else:") >= len(text):
                    return true
                ternaryDepth = ternaryDepth - 1
                i = i + len(" else:")
                continue
            if ternaryDepth > 0 && ch == ':':
                if i + 1 >= len(text):
                    return true
                ternaryDepth = ternaryDepth - 1
                i = i + 1
                continue
        i = i + 1
    return ternaryDepth > 0

fn compilerExprNeedsContinuation(text: str): bool =
    let trimmed = strutils.strip(text)
    if len(trimmed) == 0:
        return false
    if compilerTextHasOpenDelimiters(trimmed):
        return true
    if compilerTextHasOpenTernary(trimmed):
        return true
    if strings.endsWith(trimmed, "||") ||
       strings.endsWith(trimmed, "&&") ||
       strings.endsWith(trimmed, "==") ||
       strings.endsWith(trimmed, "!=") ||
       strings.endsWith(trimmed, "<=") ||
       strings.endsWith(trimmed, ">=") ||
       strings.endsWith(trimmed, "<<") ||
       strings.endsWith(trimmed, ">>"):
        return true
    let last = trimmed[len(trimmed) - 1]
    return last == '(' || last == '[' || last == '{' ||
           last == ',' || last == '?' || last == '=' ||
           last == '+' || last == '-' || last == '*' ||
           last == '/' || last == '%' || last == '|' ||
           last == '&' || last == '^' || last == '<' ||
           last == '>'

fn compilerHeaderNeedsContinuation(line: str, requireColon: bool): bool =
    if compilerExprNeedsContinuation(line):
        return true
    if requireColon:
        return findTopLevelToken(line, ":", 0) < 0
    return false

fn collectCompilerLogicalLine(bodyLines: str[],
                              startIdx: int32,
                              initialLine: str,
                              requireColon: bool,
                              outNextIdx: var int32): str =
    var line = initialLine
    outNextIdx = startIdx + 1
    while compilerHeaderNeedsContinuation(line, requireColon):
        if outNextIdx >= bodyLines.len:
            system.panicStr("v2 source parser: unterminated continued statement " + line)
        let nextLine = trimInlineComment(bodyLines[outNextIdx])
        outNextIdx = outNextIdx + 1
        if len(nextLine) == 0:
            continue
        line = line + " " + nextLine
    return line

fn isCompilerReturnStmtLine(line: str): bool =
    line == "return" || strutils.startsWith(line, "return ")

fn parseCompilerImportLine(line: str): ccore.CompilerCoreImportDecl =
    let raw = strutils.strip(sliceRange(line, len("import "), len(line)))
    let aliasMarker = " as "
    let aliasIdx = findText(raw, aliasMarker)
    if aliasIdx < 0:
        return ccore.compilerCoreImportDecl(raw, "")
    let modulePath = strutils.strip(sliceRange(raw, 0, aliasIdx))
    let alias = strutils.strip(sliceRange(raw, aliasIdx + len(aliasMarker), len(raw)))
    return ccore.compilerCoreImportDecl(modulePath, alias)

fn parseCompilerRoutineName(line: str, prefix: str): str =
    let tail = strutils.strip(sliceRange(line, len(prefix), len(line)))
    if len(tail) == 0:
        system.panicStr("v2 source parser: missing compiler routine name")
    if tail[0] == '`':
        var stop: int32 = 1
        while stop < len(tail) && tail[stop] != '`':
            stop = stop + 1
        if stop >= len(tail):
            system.panicStr("v2 source parser: unterminated backtick routine name")
        return sliceRange(tail, 0, stop + 1)
    var stop: int32 = 0
    while stop < len(tail) && isNameChar(tail[stop]):
        stop = stop + 1
    return sliceRange(tail, 0, stop)

fn parseCompilerDeclLabel(line: str, prefix: str, defaultLabel: str): str =
    let tail = strutils.strip(sliceRange(line, len(prefix), len(line)))
    if len(tail) == 0:
        return defaultLabel
    var stop: int32 = 0
    while stop < len(tail) && isNameChar(tail[stop]):
        stop = stop + 1
    if stop <= 0:
        return defaultLabel
    return sliceRange(tail, 0, stop)

fn parseCompilerBlockDeclLabel(bodyLines: str[], defaultLabel: str): str =
    for i in 0..<bodyLines.len:
        let line = trimInlineComment(bodyLines[i])
        if isBlankOrCommentLine(line):
            continue
        var stop: int32 = 0
        while stop < len(line) && isNameChar(line[stop]):
            stop = stop + 1
        if stop > 0:
            return sliceRange(line, 0, stop)
    return defaultLabel

fn parseCompilerValueBindingLabel(line: str): str =
    let trimmed = trimInlineComment(line)
    var stop: int32 = 0
    while stop < len(trimmed) && isNameChar(trimmed[stop]):
        stop = stop + 1
    if stop <= 0:
        system.panicStr("v2 source parser: malformed compiler value binding " + trimmed)
    return sliceRange(trimmed, 0, stop)

fn compilerCoreDefaultOwnerModulePath(sourcePath: str): str =
    return mpath.defaultOwnerModulePathForSourcePath(sourcePath)

fn inlineRoutineBodyLine(line: str): str =
    let trimmed = trimInlineComment(line)
    let eqIdx = findLastChar(trimmed, '=')
    if eqIdx < 0:
        return ""
    return strutils.strip(sliceRange(trimmed, eqIdx + 1, len(trimmed)))

fn lineEndsWithAssign(line: str): bool =
    let trimmed = trimInlineComment(line)
    return len(trimmed) > 0 && trimmed[len(trimmed) - 1] == '='

fn routineSignatureEndsWithAssign(signatureText: str): bool =
    let lines = strutils.split(signatureText, '\n')
    var idx: int32 = len(lines) - 1
    while idx >= 0:
        if !isBlankOrCommentLine(lines[idx]):
            return lineEndsWithAssign(lines[idx])
        idx = idx - 1
    return false

fn joinLineParts(lines: str[]): str =
    var out: str = ""
    for i in 0..<lines.len:
        if i > 0:
            out = out + "\n"
        out = out + lines[i]
    return out

fn joinPrefixedLineParts(prefixLines: str[], lines: str[]): str =
    var out: str[]
    out = []
    for i in 0..<prefixLines.len:
        add(out, prefixLines[i])
    for i in 0..<lines.len:
        add(out, lines[i])
    return joinLineParts(out)

fn annotationLinesContainImportc(lines: str[]): bool =
    for i in 0..<lines.len:
        if strutils.startsWith(lines[i], "@importc"):
            return true
    return false

fn lineStartsCompilerTopLevelDecl(line: str): bool =
    return (len(line) > 0 && line[0] == '@') ||
           strutils.startsWith(line, "module ") ||
           strutils.startsWith(line, "importc fn ") ||
           strutils.startsWith(line, "import ") ||
           line == "type" ||
           line == "const" ||
           strutils.startsWith(line, "const ") ||
           line == "var" ||
           strutils.startsWith(line, "var ") ||
           strutils.startsWith(line, "fn ") ||
           strutils.startsWith(line, "iterator ")

fn collectOutlineBlockLines(rawLines: str[], startIdx: int32, outBodyLines: var str[]): int32 =
    outBodyLines = []
    var idx: int32 = startIdx
    var baseIndent: int32 = -1
    while idx < rawLines.len:
        let rawLine = rawLines[idx]
        if isBlankOrCommentLine(rawLine):
            if baseIndent >= 0:
                add(outBodyLines, strutils.strip(rawLine))
            idx = idx + 1
            continue
        let indent = leadingIndentWidth(rawLine)
        if baseIndent < 0:
            if indent <= 0:
                break
            baseIndent = indent
        if indent < baseIndent:
            break
        add(outBodyLines, sliceRange(rawLine, baseIndent, len(rawLine)))
        idx = idx + 1
    return idx

fn collectRoutineSignatureAndBody(rawLines: str[],
                                  startIdx: int32,
                                  prefixLines: str[],
                                  allowHeaderOnly: bool,
                                  outSignatureText: var str,
                                  outBodyLines: var str[]): int32 =
    var signatureLines: str[]
    signatureLines = []
    let firstLine = strutils.strip(rawLines[startIdx])
    add(signatureLines, firstLine)
    let inlineBody = inlineRoutineBodyLine(firstLine)
    if len(inlineBody) > 0:
        outSignatureText = joinPrefixedLineParts(prefixLines, signatureLines)
        outBodyLines = []
        add(outBodyLines, inlineBody)
        return startIdx + 1
    if lineEndsWithAssign(firstLine):
        outSignatureText = joinPrefixedLineParts(prefixLines, signatureLines)
        return collectOutlineBlockLines(rawLines, startIdx + 1, outBodyLines)
    var idx: int32 = startIdx + 1
    while idx < rawLines.len:
        let rawLine = rawLines[idx]
        if isBlankOrCommentLine(rawLine):
            if allowHeaderOnly:
                outSignatureText = joinPrefixedLineParts(prefixLines, signatureLines)
                outBodyLines = []
                return idx
            system.panicStr("v2 source parser: blank or comment inside compiler routine header")
        let line = strutils.strip(rawLine)
        if leadingIndentWidth(rawLine) <= 0:
            if allowHeaderOnly && lineStartsCompilerTopLevelDecl(line):
                outSignatureText = joinPrefixedLineParts(prefixLines, signatureLines)
                outBodyLines = []
                return idx
            if lineEndsWithAssign(line):
                add(signatureLines, line)
                idx = idx + 1
                outSignatureText = joinPrefixedLineParts(prefixLines, signatureLines)
                return collectOutlineBlockLines(rawLines, idx, outBodyLines)
            if allowHeaderOnly:
                outSignatureText = joinPrefixedLineParts(prefixLines, signatureLines)
                outBodyLines = []
                return idx
            system.panicStr("v2 source parser: unterminated compiler routine header")
        add(signatureLines, line)
        idx = idx + 1
        if lineEndsWithAssign(line):
            outSignatureText = joinPrefixedLineParts(prefixLines, signatureLines)
            return collectOutlineBlockLines(rawLines, idx, outBodyLines)
    if allowHeaderOnly:
        outSignatureText = joinPrefixedLineParts(prefixLines, signatureLines)
        outBodyLines = []
        return idx
    system.panicStr("v2 source parser: unterminated compiler routine header")

fn startsWithAt(text: str, start: int32, pattern: str): bool =
    if start < 0 || start + len(pattern) > len(text):
        return false
    return sliceRange(text, start, start + len(pattern)) == pattern

fn skipSpaces(text: str, idx: var int32) =
    while idx < len(text) && (text[idx] == ' ' || text[idx] == '\t'):
        idx = idx + 1

fn isDigitChar(ch: char): bool =
    return ch >= '0' && ch <= '9'

fn compilerIntDigitValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn compilerIntDigitsEnd(text: str, start: int32, base: int32): int32 =
    var idx: int32 = start
    var sawDigit: bool = false
    var prevUnderscore: bool = false
    while idx < len(text):
        let digit = compilerIntDigitValue(text[idx])
        if digit >= 0 && digit < base:
            sawDigit = true
            prevUnderscore = false
            idx = idx + 1
            continue
        if text[idx] == '_':
            if !sawDigit || prevUnderscore:
                return -1
            prevUnderscore = true
            idx = idx + 1
            continue
        break
    if !sawDigit || prevUnderscore:
        return -1
    return idx

fn compilerIntLiteralEnd(text: str, start: int32): int32 =
    if start >= len(text) || !isDigitChar(text[start]):
        return -1
    if text[start] == '0' && start + 1 < len(text):
        let marker = text[start + 1]
        if marker == 'x' || marker == 'X':
            return compilerIntDigitsEnd(text, start + 2, 16)
        if marker == 'b' || marker == 'B':
            return compilerIntDigitsEnd(text, start + 2, 2)
        if marker == 'o' || marker == 'O':
            return compilerIntDigitsEnd(text, start + 2, 8)
    return compilerIntDigitsEnd(text, start, 10)

fn compilerFloatLiteralEnd(text: str, start: int32): int32 =
    let intEnd = compilerIntDigitsEnd(text, start, 10)
    if intEnd < 0 || intEnd + 1 >= len(text) || text[intEnd] != '.' || !isDigitChar(text[intEnd + 1]):
        return -1
    return compilerIntDigitsEnd(text, intEnd + 1, 10)

fn isCompilerIntLiteralText(text: str): bool =
    return len(text) > 0 && compilerIntLiteralEnd(text, 0) == len(text)

fn isCompilerFloatLiteralText(text: str): bool =
    return len(text) > 0 && compilerFloatLiteralEnd(text, 0) == len(text)

fn compilerIntLiteralValue(text: str): int32 =
    let trimmed = strutils.strip(text)
    if !isCompilerIntLiteralText(trimmed):
        system.panicStr("v2 source parser: malformed integer literal " + trimmed)
    var base: int32 = 10
    var start: int32 = 0
    if len(trimmed) >= 2 && trimmed[0] == '0':
        let marker = trimmed[1]
        if marker == 'x' || marker == 'X':
            base = 16
            start = 2
        elif marker == 'b' || marker == 'B':
            base = 2
            start = 2
        elif marker == 'o' || marker == 'O':
            base = 8
            start = 2
    var value: int64 = 0
    for i in start..<len(trimmed):
        if trimmed[i] == '_':
            continue
        let digit = compilerIntDigitValue(trimmed[i])
        if digit < 0 || digit >= base:
            system.panicStr("v2 source parser: malformed integer literal " + trimmed)
        value = value * int64(base) + int64(digit)
        if value > int64(2147483647):
            system.panicStr("v2 source parser: int literal out of int32 range " + trimmed)
    return int32(value)

fn parseNameToken(text: str, idx: var int32): str =
    skipSpaces(text, idx)
    let start = idx
    if idx < len(text) && ((text[idx] >= 'a' && text[idx] <= 'z') ||
                           (text[idx] >= 'A' && text[idx] <= 'Z') ||
                           text[idx] == '_'):
        idx = idx + 1
        while idx < len(text) && isNameChar(text[idx]):
            idx = idx + 1
        return sliceRange(text, start, idx)
    return ""

fn normalizeCompilerArrowFieldText(text: str): str =
    var out: str = ""
    var inString: bool = false
    var inChar: bool = false
    var i: int32 = 0
    while i < len(text):
        let ch = text[i]
        if inString:
            if ch == '\\' && i + 1 < len(text):
                out = out + sliceRange(text, i, i + 2)
                i = i + 2
                continue
            out = out + sliceRange(text, i, i + 1)
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\' && i + 1 < len(text):
                out = out + sliceRange(text, i, i + 2)
                i = i + 2
                continue
            out = out + sliceRange(text, i, i + 1)
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            out = out + sliceRange(text, i, i + 1)
            i = i + 1
            continue
        if ch == '\'':
            inChar = true
            out = out + sliceRange(text, i, i + 1)
            i = i + 1
            continue
        if ch == '-' && i + 1 < len(text) && text[i + 1] == '>':
            out = out + "."
            i = i + 2
            continue
        out = out + sliceRange(text, i, i + 1)
        i = i + 1
    return out

fn findMatchingDelimiter(text: str,
                         openIdx: int32,
                         openCh: char,
                         closeCh: char): int32 =
    var depth: int32 = 0
    var i: int32 = openIdx
    var inString: bool = false
    var inChar: bool = false
    while i < len(text):
        let ch = text[i]
        if inString:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            i = i + 1
            continue
        if ch == '\'':
            inChar = true
            i = i + 1
            continue
        if ch == openCh:
            depth = depth + 1
        elif ch == closeCh:
            depth = depth - 1
            if depth == 0:
                return i
        i = i + 1
    return -1

fn hasSingleOuterParens(text: str): bool =
    let trimmed = strutils.strip(text)
    if len(trimmed) < 2 || trimmed[0] != '(' || trimmed[len(trimmed) - 1] != ')':
        return false
    return findMatchingDelimiter(trimmed, 0, '(', ')') == len(trimmed) - 1

fn splitTopLevelSegments(text: str, sep: char): str[] =
    var out: str[]
    out = []
    var start: int32 = 0
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var inString: bool = false
    var inChar: bool = false
    var i: int32 = 0
    while i < len(text):
        let ch = text[i]
        if inString:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
        elif ch == '\'':
            inChar = true
        elif ch == '(':
            depthParen = depthParen + 1
        elif ch == ')':
            depthParen = depthParen - 1
        elif ch == '[':
            depthBracket = depthBracket + 1
        elif ch == ']':
            depthBracket = depthBracket - 1
        elif ch == '{':
            depthBrace = depthBrace + 1
        elif ch == '}':
            depthBrace = depthBrace - 1
        elif ch == sep && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            add(out, strutils.strip(sliceRange(text, start, i)))
            start = i + 1
        i = i + 1
    add(out, strutils.strip(sliceRange(text, start, len(text))))
    return out

fn findLastTopLevelBinary(text: str, pattern: str): int32 =
    var out: int32 = -1
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var inString: bool = false
    var inChar: bool = false
    var i: int32 = 0
    while i + len(pattern) <= len(text):
        let ch = text[i]
        if inString:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            i = i + 1
            continue
        if ch == '\'':
            inChar = true
            i = i + 1
            continue
        if ch == '(':
            depthParen = depthParen + 1
            i = i + 1
            continue
        if ch == ')':
            depthParen = depthParen - 1
            i = i + 1
            continue
        if ch == '[':
            depthBracket = depthBracket + 1
            i = i + 1
            continue
        if ch == ']':
            depthBracket = depthBracket - 1
            i = i + 1
            continue
        if ch == '{':
            depthBrace = depthBrace + 1
            i = i + 1
            continue
        if ch == '}':
            depthBrace = depthBrace - 1
            i = i + 1
            continue
        if depthParen == 0 && depthBracket == 0 && depthBrace == 0 &&
           startsWithAt(text, i, pattern):
            out = i
            i = i + len(pattern)
            continue
        i = i + 1
    return out

fn findTopLevelToken(text: str, pattern: str, startIdx: int32): int32 =
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var inString: bool = false
    var inChar: bool = false
    var i: int32 = startIdx
    while i + len(pattern) <= len(text):
        let ch = text[i]
        if inString:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            i = i + 1
            continue
        if ch == '\'':
            inChar = true
            i = i + 1
            continue
        if ch == '(':
            depthParen = depthParen + 1
            i = i + 1
            continue
        if ch == ')':
            depthParen = depthParen - 1
            i = i + 1
            continue
        if ch == '[':
            depthBracket = depthBracket + 1
            i = i + 1
            continue
        if ch == ']':
            depthBracket = depthBracket - 1
            i = i + 1
            continue
        if ch == '{':
            depthBrace = depthBrace + 1
            i = i + 1
            continue
        if ch == '}':
            depthBrace = depthBrace - 1
            i = i + 1
            continue
        if depthParen == 0 && depthBracket == 0 && depthBrace == 0 &&
           startsWithAt(text, i, pattern):
            return i
        i = i + 1
    return -1

fn findLastTopLevelAssign(text: str): int32 =
    var out: int32 = -1
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var inString: bool = false
    var inChar: bool = false
    var i: int32 = 0
    while i < len(text):
        let ch = text[i]
        if inString:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            i = i + 1
            continue
        if ch == '\'':
            inChar = true
            i = i + 1
            continue
        if ch == '(':
            depthParen = depthParen + 1
            i = i + 1
            continue
        if ch == ')':
            depthParen = depthParen - 1
            i = i + 1
            continue
        if ch == '[':
            depthBracket = depthBracket + 1
            i = i + 1
            continue
        if ch == ']':
            depthBracket = depthBracket - 1
            i = i + 1
            continue
        if ch == '{':
            depthBrace = depthBrace + 1
            i = i + 1
            continue
        if ch == '}':
            depthBrace = depthBrace - 1
            i = i + 1
            continue
        if ch == '=' &&
           depthParen == 0 &&
           depthBracket == 0 &&
           depthBrace == 0 &&
           !(i > 0 && (text[i - 1] == '=' || text[i - 1] == '!' || text[i - 1] == '<' || text[i - 1] == '>')) &&
           !(i + 1 < len(text) && text[i + 1] == '='):
            out = i
        i = i + 1
    return out

fn stripTopLevelDefaultValueText(text: str): str =
    let eqIdx = findLastTopLevelAssign(text)
    if eqIdx < 0:
        return strutils.strip(text)
    return strutils.strip(sliceRange(text, 0, eqIdx))

fn findTopLevelTernarySplit(text: str,
                            outQuestionIdx: var int32,
                            outThenEndIdx: var int32,
                            outElseStartIdx: var int32): bool =
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var inString: bool = false
    var inChar: bool = false
    var seenQuestion: bool = false
    var nestedTernaryDepth: int32 = 0
    var i: int32 = 0
    outQuestionIdx = -1
    outThenEndIdx = -1
    outElseStartIdx = -1
    while i < len(text):
        let ch = text[i]
        if inString:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            i = i + 1
            continue
        if ch == '\'':
            inChar = true
            i = i + 1
            continue
        if ch == '(':
            depthParen = depthParen + 1
            i = i + 1
            continue
        if ch == ')':
            depthParen = depthParen - 1
            i = i + 1
            continue
        if ch == '[':
            depthBracket = depthBracket + 1
            i = i + 1
            continue
        if ch == ']':
            depthBracket = depthBracket - 1
            i = i + 1
            continue
        if ch == '{':
            depthBrace = depthBrace + 1
            i = i + 1
            continue
        if ch == '}':
            depthBrace = depthBrace - 1
            i = i + 1
            continue
        if depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            if !seenQuestion && ch == '?':
                seenQuestion = true
                outQuestionIdx = i
                i = i + 1
                continue
            if seenQuestion:
                if ch == '?':
                    nestedTernaryDepth = nestedTernaryDepth + 1
                    i = i + 1
                    continue
                if startsWithAt(text, i, " else:"):
                    if nestedTernaryDepth == 0:
                        outThenEndIdx = i
                        outElseStartIdx = i + len(" else:")
                        return true
                    nestedTernaryDepth = nestedTernaryDepth - 1
                    i = i + len(" else:")
                    continue
                if ch == ':':
                    if nestedTernaryDepth == 0:
                        outThenEndIdx = i
                        outElseStartIdx = i + 1
                        return true
                    nestedTernaryDepth = nestedTernaryDepth - 1
                i = i + 1
                continue
        i = i + 1
    return false

fn parseCompilerIfExpr(program: var ccore.CompilerCoreProgram, text: str): int32 =
    let trimmed = strutils.strip(text)
    if !strutils.startsWith(trimmed, "if "):
        return -1
    let colonIdx = findTopLevelToken(trimmed, ":", 0)
    let elifIdx = findTopLevelToken(trimmed, " elif ", colonIdx + 1)
    let elseIdx = findTopLevelToken(trimmed, " else:", colonIdx + 1)
    var branchIdx: int32 = elseIdx
    var elseText: str = ""
    if elifIdx >= 0 && (elseIdx < 0 || elifIdx < elseIdx):
        branchIdx = elifIdx
        elseText = "if " + strutils.strip(sliceRange(trimmed, elifIdx + len(" elif "), len(trimmed)))
    elif elseIdx >= 0:
        elseText = strutils.strip(sliceRange(trimmed, elseIdx + len(" else:"), len(trimmed)))
    if colonIdx < 0 || branchIdx < 0 || branchIdx <= colonIdx:
        system.panicStr("v2 source parser: unsupported compiler if-expression " + trimmed)
    let condText = strutils.strip(sliceRange(trimmed, len("if "), colonIdx))
    let thenText = strutils.strip(sliceRange(trimmed, colonIdx + 1, branchIdx))
    let condExpr = parseCompilerExprText(program, condText)
    let thenExpr = parseCompilerExprText(program, thenText)
    let elseExpr = parseCompilerExprText(program, elseText)
    return ccore.appendCompilerCoreExpr(program, "if_expr", "", "", [condExpr, thenExpr, elseExpr])

fn compilerWrapIfExprBranchText(text: str): str =
    let trimmed = strutils.strip(text)
    if strutils.startsWith(trimmed, "if "):
        return "(" + trimmed + ")"
    return trimmed

fn collectCompilerIfExprTailText(bodyLines: str[],
                                 headerText: str,
                                 startIdx: int32,
                                 outNextIdx: var int32,
                                 outText: var str): bool =
    outNextIdx = startIdx
    outText = ""
    let header = strutils.strip(headerText)
    if len(header) <= 0 || header[len(header) - 1] != ':':
        return false
    if !strutils.startsWith(header, "if ") && !strutils.startsWith(header, "elif "):
        return false
    let prefixLen = strutils.startsWith(header, "if ") ? len("if ") else: len("elif ")
    let condText = strutils.strip(sliceRange(header, prefixLen, len(header) - 1))
    var thenLines: str[]
    outNextIdx = collectOutlineBlockLines(bodyLines, startIdx, thenLines)
    var thenText: str = ""
    if !parseCompilerExprBlockText(thenLines, thenText):
        return false
    while outNextIdx < bodyLines.len && isBlankOrCommentLine(bodyLines[outNextIdx]):
        outNextIdx = outNextIdx + 1
    if outNextIdx >= bodyLines.len:
        return false
    let branchLine = trimInlineComment(bodyLines[outNextIdx])
    var elseText: str = ""
    if branchLine == "else:":
        var elseLines: str[]
        outNextIdx = collectOutlineBlockLines(bodyLines, outNextIdx + 1, elseLines)
        if !parseCompilerExprBlockText(elseLines, elseText):
            return false
    elif strutils.startsWith(branchLine, "elif "):
        if !collectCompilerIfExprTailText(bodyLines, branchLine, outNextIdx + 1, outNextIdx, elseText):
            return false
    else:
        return false
    outText = "if " + condText + ": " +
              compilerWrapIfExprBranchText(thenText) +
              " else: " +
              compilerWrapIfExprBranchText(elseText)
    return true

fn collectCompilerIfExprBlockText(lines: str[],
                                  startIdx: int32,
                                  outNextIdx: var int32,
                                  outText: var str): bool =
    outNextIdx = startIdx
    outText = ""
    var idx = startIdx
    while idx < lines.len && isBlankOrCommentLine(lines[idx]):
        idx = idx + 1
    if idx >= lines.len:
        return false
    let header = trimInlineComment(lines[idx])
    if leadingIndentWidth(lines[idx]) > 0 || len(header) <= 0 || header[len(header) - 1] != ':':
        return false
    if !strutils.startsWith(header, "if ") && !strutils.startsWith(header, "elif "):
        return false
    let prefixLen = strutils.startsWith(header, "if ") ? len("if ") else: len("elif ")
    let condText = strutils.strip(sliceRange(header, prefixLen, len(header) - 1))
    var thenLines: str[]
    idx = collectOutlineBlockLines(lines, idx + 1, thenLines)
    var thenText: str = ""
    if !parseCompilerExprBlockText(thenLines, thenText):
        return false
    while idx < lines.len && isBlankOrCommentLine(lines[idx]):
        idx = idx + 1
    if idx >= lines.len || leadingIndentWidth(lines[idx]) > 0:
        return false
    let branchLine = trimInlineComment(lines[idx])
    var elseText: str = ""
    if branchLine == "else:":
        var elseLines: str[]
        idx = collectOutlineBlockLines(lines, idx + 1, elseLines)
        if !parseCompilerExprBlockText(elseLines, elseText):
            return false
    elif strutils.startsWith(branchLine, "elif "):
        if !collectCompilerIfExprBlockText(lines, idx, idx, elseText):
            return false
    else:
        return false
    outNextIdx = idx
    outText = "if " + condText + ": " +
              compilerWrapIfExprBranchText(thenText) +
              " else: " +
              compilerWrapIfExprBranchText(elseText)
    return true

fn parseCompilerExprBlockText(lines: str[], outText: var str): bool =
    outText = ""
    var firstIdx: int32 = -1
    var lastIdx: int32 = -1
    for i in 0..<lines.len:
        if isBlankOrCommentLine(lines[i]):
            continue
        if firstIdx < 0:
            firstIdx = i
        lastIdx = i
    if firstIdx < 0:
        return false
    if firstIdx == lastIdx && leadingIndentWidth(lines[firstIdx]) == 0:
        outText = strutils.strip(trimInlineComment(lines[firstIdx]))
        return len(outText) > 0
    var exprLines: str[] = []
    for i in firstIdx..lastIdx:
        add(exprLines, lines[i])
    var nextIdx: int32 = 0
    if !collectCompilerIfExprBlockText(exprLines, 0, nextIdx, outText):
        return false
    while nextIdx < exprLines.len:
        if !isBlankOrCommentLine(exprLines[nextIdx]):
            return false
        nextIdx = nextIdx + 1
    return len(outText) > 0

fn compilerCoreUnaryDetail(opText: str): str =
    if opText == "!":
        return "not"
    if opText == "-":
        return "neg"
    if opText == "&":
        return "addr_of"
    system.panicStr("v2 source parser: unsupported compiler unary op " + opText)

fn compilerCoreBinaryDetail(opText: str): str =
    if opText == "||":
        return "logical_or"
    if opText == "&&":
        return "logical_and"
    if opText == "|":
        return "bitwise_or"
    if opText == "^":
        return "bitwise_xor"
    if opText == "&":
        return "bitwise_and"
    if opText == "==":
        return "eq"
    if opText == "!=":
        return "ne"
    if opText == "<=":
        return "le"
    if opText == ">=":
        return "ge"
    if opText == "<":
        return "lt"
    if opText == ">":
        return "gt"
    if opText == "<<":
        return "shift_left"
    if opText == ">>":
        return "shift_right"
    if opText == "+":
        return "add"
    if opText == "-":
        return "sub"
    if opText == "*":
        return "mul"
    if opText == "/":
        return "div"
    if opText == "%":
        return "mod"
    system.panicStr("v2 source parser: unsupported compiler binary op " + opText)

fn parseCompilerNamedArg(text: str, outName: var str, outValueText: var str): bool =
    let trimmed = strutils.strip(text)
    var idx: int32 = 0
    let name = parseNameToken(trimmed, idx)
    if len(name) <= 0:
        return false
    skipSpaces(trimmed, idx)
    if idx >= len(trimmed):
        return false
    if trimmed[idx] == '=':
        if idx + 1 < len(trimmed) && trimmed[idx + 1] == '=':
            return false
    elif trimmed[idx] != ':':
        return false
    outName = name
    outValueText = strutils.strip(sliceRange(trimmed, idx + 1, len(trimmed)))
    return len(outValueText) > 0

fn isCompilerSpacePrimaryStart(c: char): bool =
    return isAlphaChar(c) || c == '_' || isDigitChar(c) || c == '"' || c == '\'' ||
           c == '!' || c == '-' || c == '&'

fn compilerStringLiteralEnd(text: str, start: int32): int32 =
    var idx = start + 1
    while idx < len(text):
        if text[idx] == '\\':
            idx = idx + 2
            continue
        if text[idx] == '"':
            return idx + 1
        idx = idx + 1
    return -1

fn compilerCharLiteralEnd(text: str, start: int32): int32 =
    var idx = start + 1
    while idx < len(text):
        if text[idx] == '\\':
            idx = idx + 2
            continue
        if text[idx] == '\'':
            return idx + 1
        idx = idx + 1
    return -1

fn parseCompilerSpaceAtomEnd(text: str, start: int32): int32 =
    var idx = start
    if idx >= len(text):
        return -1
    if text[idx] == '!' || text[idx] == '-' || text[idx] == '&':
        return parseCompilerSpaceAtomEnd(text, idx + 1)
    if text[idx] == '"':
        idx = compilerStringLiteralEnd(text, idx)
        if idx < 0:
            return -1
    elif text[idx] == '\'':
        idx = compilerCharLiteralEnd(text, idx)
        if idx < 0:
            return -1
    elif isDigitChar(text[idx]):
        let floatEnd = compilerFloatLiteralEnd(text, idx)
        idx = floatEnd >= 0 ? floatEnd else: compilerIntLiteralEnd(text, idx)
        if idx < 0:
            return -1
    else:
        let name = parseNameToken(text, idx)
        if len(name) <= 0:
            return -1
    while idx < len(text):
        if text[idx] == '-' && idx + 1 < len(text) && text[idx + 1] == '>':
            idx = idx + 2
            let field = parseNameToken(text, idx)
            if len(field) <= 0:
                return -1
            continue
        if text[idx] == '.':
            idx = idx + 1
            let field = parseNameToken(text, idx)
            if len(field) <= 0:
                return -1
            continue
        if text[idx] == '(':
            let closeIdx = findMatchingDelimiter(text, idx, '(', ')')
            if closeIdx < 0:
                return -1
            idx = closeIdx + 1
            continue
        if text[idx] == '[':
            let closeIdx = findMatchingDelimiter(text, idx, '[', ']')
            if closeIdx < 0:
                return -1
            idx = closeIdx + 1
            continue
        if text[idx] == '?':
            idx = idx + 1
            continue
        break
    return idx

fn parseCompilerCallishExpr(program: var ccore.CompilerCoreProgram, text: str): int32 =
    let trimmed = strutils.strip(normalizeCompilerArrowFieldText(text))
    if len(trimmed) == 0:
        system.panicStr("v2 source parser: empty compiler expression in " + text)
    if hasSingleOuterParens(trimmed):
        let inner = strutils.strip(sliceRange(trimmed, 1, len(trimmed) - 1))
        if len(inner) > 0:
            let parts = splitTopLevelSegments(inner, ',')
            if parts.len > 1:
                var childIds: int32[]
                childIds = []
                for i in 0..<parts.len:
                    if len(strutils.strip(parts[i])) == 0:
                        system.panicStr("v2 source parser: empty tuple item in " + trimmed)
                    add(childIds, parseCompilerExprText(program, parts[i]))
                return ccore.appendCompilerCoreExpr(program, "tuple_lit", "", "", childIds)
        return parseCompilerExprText(program, inner)
    if trimmed == "true" || trimmed == "false":
        return ccore.appendCompilerCoreExpr(program, "bool_lit", trimmed, "", [])
    if trimmed == "nil":
        return ccore.appendCompilerCoreExpr(program, "nil_lit", "", "", [])
    if trimmed[0] == '"':
        return ccore.appendCompilerCoreExpr(program, "str_lit", trimmed, "", [])
    if trimmed[0] == '\'':
        let charEnd = compilerCharLiteralEnd(trimmed, 0)
        if charEnd == len(trimmed):
            return ccore.appendCompilerCoreExpr(program, "char_lit", trimmed, "", [])
    if isCompilerFloatLiteralText(trimmed):
        return ccore.appendCompilerCoreExpr(program, "float_lit", trimmed, "", [])
    if trimmed[0] == '[' && trimmed[len(trimmed) - 1] == ']' &&
       findMatchingDelimiter(trimmed, 0, '[', ']') == len(trimmed) - 1:
        let inner = strutils.strip(sliceRange(trimmed, 1, len(trimmed) - 1))
        var childIds: int32[]
        childIds = []
        if len(inner) > 0:
            let parts = splitTopLevelSegments(inner, ',')
            for i in 0..<parts.len:
                if len(strutils.strip(parts[i])) == 0:
                    system.panicStr("v2 source parser: empty array item in " + trimmed)
                add(childIds, parseCompilerExprText(program, parts[i]))
        return ccore.appendCompilerCoreExpr(program, "array_lit", "", "", childIds)
    if trimmed[0] == '{' && trimmed[len(trimmed) - 1] == '}' &&
       findMatchingDelimiter(trimmed, 0, '{', '}') == len(trimmed) - 1:
        let inner = strutils.strip(sliceRange(trimmed, 1, len(trimmed) - 1))
        var childIds: int32[]
        var childArgNames: str[]
        childIds = []
        childArgNames = []
        if len(inner) > 0:
            let parts = splitTopLevelSegments(inner, ',')
            for i in 0..<parts.len:
                var fieldName: str = ""
                var valueText: str = ""
                if len(strutils.strip(parts[i])) == 0:
                    system.panicStr("v2 source parser: empty record item in " + trimmed)
                if !parseCompilerNamedArg(parts[i], fieldName, valueText):
                    system.panicStr("v2 source parser: malformed compiler record literal " + trimmed)
                add(childIds, parseCompilerExprText(program, valueText))
                add(childArgNames, fieldName)
        return ccore.appendCompilerCoreExprWithArgNames(program,
                                                        "record_lit",
                                                        inner,
                                                        "",
                                                        childIds,
                                                        childArgNames)
    if isCompilerIntLiteralText(trimmed):
        return ccore.appendCompilerCoreExpr(program, "int_lit", trimmed, "", [])
    var idx: int32 = 0
    let baseName = parseNameToken(trimmed, idx)
    if len(baseName) == 0:
        system.panicStr("v2 source parser: unsupported compiler expression " + trimmed)
    var exprId = ccore.appendCompilerCoreExpr(program, "name_ref", baseName, "", [])
    while true:
        let beforeSpaces = idx
        skipSpaces(trimmed, idx)
        let hadSpaces = idx > beforeSpaces
        if idx >= len(trimmed):
            break
        if trimmed[idx] == '-' && idx + 1 < len(trimmed) && trimmed[idx + 1] == '>':
            idx = idx + 2
            let field = parseNameToken(trimmed, idx)
            if len(field) == 0:
                system.panicStr("v2 source parser: missing arrow field name in expression " + trimmed)
            exprId = ccore.appendCompilerCoreExpr(program, "field", field, "", [exprId])
            continue
        if trimmed[idx] == '.':
            idx = idx + 1
            let field = parseNameToken(trimmed, idx)
            if len(field) == 0:
                system.panicStr("v2 source parser: missing field name in expression " + trimmed)
            exprId = ccore.appendCompilerCoreExpr(program, "field", field, "", [exprId])
            continue
        if trimmed[idx] == '(':
            let closeIdx = findMatchingDelimiter(trimmed, idx, '(', ')')
            if closeIdx < 0:
                system.panicStr("v2 source parser: unterminated call expression " + trimmed)
            let argText = strutils.strip(sliceRange(trimmed, idx + 1, closeIdx))
            var childIds: int32[]
            var childArgNames: str[]
            childIds = [exprId]
            childArgNames = [""]
            if len(argText) > 0:
                let argParts = splitTopLevelSegments(argText, ',')
                for i in 0..<argParts.len:
                    var argName: str = ""
                    var argValueText: str = ""
                    if len(strutils.strip(argParts[i])) == 0:
                        system.panicStr("v2 source parser: empty call arg in " + trimmed)
                    if parseCompilerNamedArg(argParts[i], argName, argValueText):
                        add(childIds, parseCompilerExprText(program, argValueText))
                        add(childArgNames, argName)
                    else:
                        add(childIds, parseCompilerExprText(program, argParts[i]))
                        add(childArgNames, "")
            exprId = ccore.appendCompilerCoreExprWithArgNames(program,
                                                              "call",
                                                              "",
                                                              "",
                                                              childIds,
                                                              childArgNames)
            idx = closeIdx + 1
            continue
        if trimmed[idx] == '[':
            let closeIdx = findMatchingDelimiter(trimmed, idx, '[', ']')
            if closeIdx < 0:
                system.panicStr("v2 source parser: unterminated index expression " + trimmed)
            let indexText = strutils.strip(sliceRange(trimmed, idx + 1, closeIdx))
            if len(indexText) == 0:
                exprId = ccore.appendCompilerCoreExpr(program, "suffix_ctor", "[]", "", [exprId])
                idx = closeIdx + 1
                continue
            let indexExpr = parseCompilerExprText(program, indexText)
            exprId = ccore.appendCompilerCoreExpr(program, "index", "", "", [exprId, indexExpr])
            idx = closeIdx + 1
            continue
        if hadSpaces && isCompilerSpacePrimaryStart(trimmed[idx]):
            let atomEnd = parseCompilerSpaceAtomEnd(trimmed, idx)
            if atomEnd < 0:
                system.panicStr("v2 source parser: malformed compiler space call " + trimmed)
            let atomText = sliceRange(trimmed, idx, atomEnd)
            let argExpr = parseCompilerCallishExpr(program, atomText)
            exprId = ccore.appendCompilerCoreExprWithArgNames(program,
                                                              "call",
                                                              "",
                                                              "",
                                                              [exprId, argExpr],
                                                              ["", ""])
            idx = atomEnd
            continue
        system.panicStr("v2 source parser: unsupported compiler postfix expression " + trimmed)
    return exprId

fn parseCompilerExprText(program: var ccore.CompilerCoreProgram, text: str): int32 =
    let trimmed = strutils.strip(normalizeCompilerArrowFieldText(text))
    var ternaryQuestionIdx: int32 = -1
    var ternaryThenEndIdx: int32 = -1
    var ternaryElseStartIdx: int32 = -1
    if len(trimmed) == 0:
        system.panicStr("v2 source parser: empty compiler expression in " + text)
    if strutils.startsWith(trimmed, "if "):
        return parseCompilerIfExpr(program, trimmed)
    if findTopLevelTernarySplit(trimmed, ternaryQuestionIdx, ternaryThenEndIdx, ternaryElseStartIdx) &&
       ternaryQuestionIdx > 0 && ternaryThenEndIdx > ternaryQuestionIdx &&
       ternaryElseStartIdx > ternaryThenEndIdx:
        let condExpr = parseCompilerExprText(program, sliceRange(trimmed, 0, ternaryQuestionIdx))
        let thenExpr = parseCompilerExprText(program, sliceRange(trimmed, ternaryQuestionIdx + 1, ternaryThenEndIdx))
        let elseExpr = parseCompilerExprText(program, sliceRange(trimmed, ternaryElseStartIdx, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "if_expr", "", "", [condExpr, thenExpr, elseExpr])
    if hasSingleOuterParens(trimmed):
        let inner = strutils.strip(sliceRange(trimmed, 1, len(trimmed) - 1))
        if len(inner) > 0:
            let parts = splitTopLevelSegments(inner, ',')
            if parts.len > 1:
                var childIds: int32[]
                childIds = []
                for i in 0..<parts.len:
                    if len(strutils.strip(parts[i])) == 0:
                        system.panicStr("v2 source parser: empty tuple item in " + trimmed)
                    add(childIds, parseCompilerExprText(program, parts[i]))
                return ccore.appendCompilerCoreExpr(program, "tuple_lit", "", "", childIds)
    if trimmed[0] == '!':
        let child = parseCompilerExprText(program, sliceRange(trimmed, 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "unary", "!", compilerCoreUnaryDetail("!"), [child])
    if trimmed[0] == '-' && len(trimmed) > 1:
        let child = parseCompilerExprText(program, sliceRange(trimmed, 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "unary", "-", compilerCoreUnaryDetail("-"), [child])
    if trimmed[0] == '&' && len(trimmed) > 1:
        let child = parseCompilerExprText(program, sliceRange(trimmed, 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "unary", "&", compilerCoreUnaryDetail("&"), [child])
    let orIdx = findLastTopLevelBinary(trimmed, "||")
    if orIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, orIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, orIdx + 2, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "||", compilerCoreBinaryDetail("||"), [left, right])
    let andIdx = findLastTopLevelBinary(trimmed, "&&")
    if andIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, andIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, andIdx + 2, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "&&", compilerCoreBinaryDetail("&&"), [left, right])
    let bitOrIdx = findLastTopLevelBinary(trimmed, "|")
    if bitOrIdx >= 0 &&
       !startsWithAt(trimmed, bitOrIdx, "||") &&
       !(bitOrIdx > 0 && trimmed[bitOrIdx - 1] == '|'):
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, bitOrIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, bitOrIdx + 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "|", compilerCoreBinaryDetail("|"), [left, right])
    let bitXorIdx = findLastTopLevelBinary(trimmed, "^")
    if bitXorIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, bitXorIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, bitXorIdx + 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "^", compilerCoreBinaryDetail("^"), [left, right])
    let bitAndIdx = findLastTopLevelBinary(trimmed, "&")
    if bitAndIdx >= 0 &&
       !startsWithAt(trimmed, bitAndIdx, "&&") &&
       !(bitAndIdx > 0 && trimmed[bitAndIdx - 1] == '&'):
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, bitAndIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, bitAndIdx + 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "&", compilerCoreBinaryDetail("&"), [left, right])
    let eqIdx = findLastTopLevelBinary(trimmed, "==")
    if eqIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, eqIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, eqIdx + 2, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "==", compilerCoreBinaryDetail("=="), [left, right])
    let neIdx = findLastTopLevelBinary(trimmed, "!=")
    if neIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, neIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, neIdx + 2, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "!=", compilerCoreBinaryDetail("!="), [left, right])
    let leIdx = findLastTopLevelBinary(trimmed, "<=")
    if leIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, leIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, leIdx + 2, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "<=", compilerCoreBinaryDetail("<="), [left, right])
    let geIdx = findLastTopLevelBinary(trimmed, ">=")
    if geIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, geIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, geIdx + 2, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", ">=", compilerCoreBinaryDetail(">="), [left, right])
    let ltIdx = findLastTopLevelBinary(trimmed, "<")
    if ltIdx >= 0 && !startsWithAt(trimmed, ltIdx, "<=") && !startsWithAt(trimmed, ltIdx, "<<") &&
       !(ltIdx > 0 && trimmed[ltIdx - 1] == '<') &&
       !(ltIdx + 1 < len(trimmed) && trimmed[ltIdx + 1] == '.'):
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, ltIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, ltIdx + 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "<", compilerCoreBinaryDetail("<"), [left, right])
    let gtIdx = findLastTopLevelBinary(trimmed, ">")
    if gtIdx >= 0 && !startsWithAt(trimmed, gtIdx, ">=") && !startsWithAt(trimmed, gtIdx, ">>") &&
       !(gtIdx > 0 && (trimmed[gtIdx - 1] == '>' || trimmed[gtIdx - 1] == '-')):
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, gtIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, gtIdx + 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", ">", compilerCoreBinaryDetail(">"), [left, right])
    let shlIdx = findLastTopLevelBinary(trimmed, "<<")
    if shlIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, shlIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, shlIdx + 2, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "<<", compilerCoreBinaryDetail("<<"), [left, right])
    let shrIdx = findLastTopLevelBinary(trimmed, ">>")
    if shrIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, shrIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, shrIdx + 2, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", ">>", compilerCoreBinaryDetail(">>"), [left, right])
    let addIdx = findLastTopLevelBinary(trimmed, "+")
    if addIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, addIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, addIdx + 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "+", compilerCoreBinaryDetail("+"), [left, right])
    let subIdx = findLastTopLevelBinary(trimmed, "-")
    if subIdx > 0 && !(subIdx + 1 < len(trimmed) && trimmed[subIdx + 1] == '>'):
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, subIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, subIdx + 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "-", compilerCoreBinaryDetail("-"), [left, right])
    let mulIdx = findLastTopLevelBinary(trimmed, "*")
    if mulIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, mulIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, mulIdx + 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "*", compilerCoreBinaryDetail("*"), [left, right])
    let divIdx = findLastTopLevelBinary(trimmed, "/")
    if divIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, divIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, divIdx + 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "/", compilerCoreBinaryDetail("/"), [left, right])
    let modIdx = findLastTopLevelBinary(trimmed, "%")
    if modIdx >= 0:
        let left = parseCompilerExprText(program, sliceRange(trimmed, 0, modIdx))
        let right = parseCompilerExprText(program, sliceRange(trimmed, modIdx + 1, len(trimmed)))
        return ccore.appendCompilerCoreExpr(program, "binary", "%", compilerCoreBinaryDetail("%"), [left, right])
    return parseCompilerCallishExpr(program, trimmed)

fn parseRoutineParamSignatureText(signatureText: str, decl: var ccore.CompilerCoreRoutineDecl, program: var ccore.CompilerCoreProgram) =
    let flat = strutils.replace(signatureText, "\n", " ")
    let openIdx = findChar(flat, '(')
    let closeIdx = findLastChar(flat, ')')
    if openIdx < 0 || closeIdx < openIdx:
        return
    decl.paramStart = program.routineParams.len
    decl.paramCount = 0
    let paramsText = strutils.strip(sliceRange(flat, openIdx + 1, closeIdx))
    if len(paramsText) > 0:
        let parts = splitTopLevelSegments(paramsText, ',')
        for i in 0..<parts.len:
            let part = strutils.strip(parts[i])
            if len(part) == 0:
                continue
            let colonIdx = findChar(part, ':')
            var nameText: str = part
            var typeText: str = ""
            if colonIdx >= 0:
                nameText = strutils.strip(sliceRange(part, 0, colonIdx))
                typeText = stripTopLevelDefaultValueText(sliceRange(part, colonIdx + 1, len(part)))
            let trimmedType = strutils.strip(typeText)
            let nameIsVar = strutils.startsWith(nameText, "var ")
            let typeIsVar = strutils.startsWith(trimmedType, "var ")
            if nameIsVar && typeIsVar:
                system.panicStr("v2 source parser: duplicate var marker in routine param " + part)
            let kind = if nameIsVar || typeIsVar: "var_param" else: "value_param"
            var finalName: str = nameText
            var finalType: str = typeText
            if nameIsVar:
                finalName = strutils.strip(sliceRange(nameText, len("var "), len(nameText)))
            if typeIsVar:
                finalType = strutils.strip(sliceRange(trimmedType, len("var "), len(trimmedType)))
            discard ccore.appendCompilerCoreRoutineParam(program,
                                                         ccore.compilerCoreRoutineParam(finalName,
                                                                                        finalType,
                                                                                        kind))
            decl.paramCount = decl.paramCount + 1
    let retSlice = sliceRange(flat, closeIdx + 1, len(flat))
    let colonIdx = findChar(retSlice, ':')
    if colonIdx >= 0:
        decl.returnTypeText = stripTopLevelDefaultValueText(sliceRange(retSlice, colonIdx + 1, len(retSlice)))

fn parseForRangeHeader(line: str, outName: var str, outStartExpr: var str, outStopExpr: var str, outInclusive: var str): bool =
    if !strutils.startsWith(line, "for ") || line[len(line) - 1] != ':':
        return false
    let body = strutils.strip(sliceRange(line, len("for "), len(line) - 1))
    let inIdx = findText(body, " in ")
    if inIdx < 0:
        return false
    outName = strutils.strip(sliceRange(body, 0, inIdx))
    let rangeText = strutils.strip(sliceRange(body, inIdx + len(" in "), len(body)))
    let exclIdx = findTopLevelToken(rangeText, "..<", 0)
    if exclIdx >= 0:
        outStartExpr = strutils.strip(sliceRange(rangeText, 0, exclIdx))
        outStopExpr = strutils.strip(sliceRange(rangeText, exclIdx + 3, len(rangeText)))
        outInclusive = "exclusive"
        return true
    let inclIdx = findTopLevelToken(rangeText, "..", 0)
    if inclIdx >= 0:
        outStartExpr = strutils.strip(sliceRange(rangeText, 0, inclIdx))
        outStopExpr = strutils.strip(sliceRange(rangeText, inclIdx + 2, len(rangeText)))
        outInclusive = "inclusive"
        return true
    return false

fn compilerCoreNameInUse(program: ccore.CompilerCoreProgram, name: str): bool =
    for i in 0..<program.routineParams.len:
        if program.routineParams[i].name == name:
            return true
    for i in 0..<program.locals.len:
        if program.locals[i].name == name:
            return true
    return false

fn compilerCoreFreshSyntheticLocalName(program: ccore.CompilerCoreProgram, prefix: str): str =
    var idx: int32 = program.locals.len
    while true:
        let candidate = prefix + intToStr(idx)
        if !compilerCoreNameInUse(program, candidate):
            return candidate
        idx = idx + 1

fn compilerCoreBuildCaseMatchExpr(program: var ccore.CompilerCoreProgram,
                                  selectorName: str,
                                  patternText: str): int32 =
    let parts = splitTopLevelSegments(patternText, ',')
    var outExprId: int32 = -1
    for i in 0..<parts.len:
        let part = strutils.strip(parts[i])
        if len(part) == 0:
            continue
        let lhsExpr = ccore.appendCompilerCoreExpr(program, "name_ref", selectorName, "", [])
        let rhsExpr = parseCompilerExprText(program, part)
        let eqExpr = ccore.appendCompilerCoreExpr(program,
                                                  "binary",
                                                  "==",
                                                  compilerCoreBinaryDetail("=="),
                                                  [lhsExpr, rhsExpr])
        if outExprId < 0:
            outExprId = eqExpr
        else:
            outExprId = ccore.appendCompilerCoreExpr(program,
                                                     "binary",
                                                     "||",
                                                     compilerCoreBinaryDetail("||"),
                                                     [outExprId, eqExpr])
    if outExprId < 0:
        system.panicStr("v2 source parser: empty case pattern list " + patternText)
    return outExprId

fn parseCompilerCaseStmt(program: var ccore.CompilerCoreProgram,
                         bodyLines: str[],
                         startIdx: int32,
                         outNextIdx: var int32,
                         outStmtIds: var int32[]): bool =
    let rawLine = bodyLines[startIdx]
    var headerNextIdx: int32 = startIdx + 1
    let line = collectCompilerLogicalLine(bodyLines,
                                          startIdx,
                                          trimInlineComment(rawLine),
                                          false,
                                          headerNextIdx)
    if !strutils.startsWith(line, "case "):
        return false
    var selectorText = strutils.strip(sliceRange(line, len("case "), len(line)))
    if len(selectorText) > 0 && selectorText[len(selectorText) - 1] == ':':
        selectorText = strutils.strip(sliceRange(selectorText, 0, len(selectorText) - 1))
    if len(selectorText) == 0:
        return false
    var caseLines: str[]
    outNextIdx = collectOutlineBlockLines(bodyLines, headerNextIdx, caseLines)
    if caseLines.len == 0:
        return false

    let selectorName = compilerCoreFreshSyntheticLocalName(program, "__compiler_case_value_")
    let selectorExprId = parseCompilerExprText(program, selectorText)
    discard ccore.appendCompilerCoreLocal(program,
                                          ccore.compilerCoreLocalDecl(selectorName,
                                                                     "",
                                                                     "let",
                                                                     selectorExprId))
    let localDeclStmtId = ccore.appendCompilerCoreStmt(program, "let", selectorName, "", selectorExprId, -1, [], [])

    var branchCondExprIds: int32[]
    var branchBodyStarts: int32[]
    var branchBodyCounts: int32[]
    var branchBodyFlat: int32[]
    var elseStmtIds: int32[]
    var sawElse: bool = false
    var idx: int32 = 0
    while idx < caseLines.len:
        let branchRaw = caseLines[idx]
        let branchLine = trimInlineComment(branchRaw)
        if isBlankOrCommentLine(branchRaw):
            idx = idx + 1
            continue
        if leadingIndentWidth(branchRaw) > 0:
            return false
        if strutils.startsWith(branchLine, "of "):
            if sawElse:
                return false
            let colonIdx = findTopLevelToken(branchLine, ":", 0)
            if colonIdx < 0:
                return false
            let patternText = strutils.strip(sliceRange(branchLine, len("of "), colonIdx))
            let inlineBodyText = strutils.strip(sliceRange(branchLine, colonIdx + 1, len(branchLine)))
            var branchStmtIds: int32[]
            if len(inlineBodyText) == 0:
                var branchBodyLines: str[]
                idx = collectOutlineBlockLines(caseLines, idx + 1, branchBodyLines)
                if !parseCompilerStmtLines(program, branchBodyLines, branchStmtIds):
                    return false
            else:
                let branchBodyLines = [inlineBodyText]
                if !parseCompilerStmtLines(program, branchBodyLines, branchStmtIds):
                    return false
                idx = idx + 1
            add(branchCondExprIds, compilerCoreBuildCaseMatchExpr(program, selectorName, patternText))
            add(branchBodyStarts, branchBodyFlat.len)
            add(branchBodyCounts, branchStmtIds.len)
            for j in 0..<branchStmtIds.len:
                add(branchBodyFlat, branchStmtIds[j])
            continue
        if strutils.startsWith(branchLine, "else:"):
            if sawElse:
                return false
            sawElse = true
            let inlineElseText = strutils.strip(sliceRange(branchLine, len("else:"), len(branchLine)))
            if len(inlineElseText) == 0:
                var elseLines: str[]
                idx = collectOutlineBlockLines(caseLines, idx + 1, elseLines)
                if !parseCompilerStmtLines(program, elseLines, elseStmtIds):
                    return false
            else:
                let elseLines = [inlineElseText]
                if !parseCompilerStmtLines(program, elseLines, elseStmtIds):
                    return false
                idx = idx + 1
            continue
        return false

    if branchCondExprIds.len == 0:
        return false

    var tailElseIds: int32[]
    tailElseIds = elseStmtIds
    var branchIdx: int32 = branchCondExprIds.len - 1
    while branchIdx >= 0:
        var branchStmtIds: int32[]
        let bodyStart = branchBodyStarts[branchIdx]
        let bodyCount = branchBodyCounts[branchIdx]
        for j in 0..<bodyCount:
            add(branchStmtIds, branchBodyFlat[bodyStart + j])
        let ifStmtId = ccore.appendCompilerCoreStmt(program,
                                                    "if",
                                                    "",
                                                    "",
                                                    branchCondExprIds[branchIdx],
                                                    -1,
                                                    branchStmtIds,
                                                    tailElseIds)
        tailElseIds = [ifStmtId]
        branchIdx = branchIdx - 1

    outStmtIds = [localDeclStmtId]
    add(outStmtIds, tailElseIds[0])
    return true

fn parseCompilerIfStmtChain(program: var ccore.CompilerCoreProgram,
                            bodyLines: str[],
                            startIdx: int32,
                            outNextIdx: var int32,
                            outStmtId: var int32): bool =
    let rawLine = bodyLines[startIdx]
    var headerNextIdx: int32 = startIdx + 1
    let line = collectCompilerLogicalLine(bodyLines,
                                          startIdx,
                                          trimInlineComment(rawLine),
                                          true,
                                          headerNextIdx)
    if !(strutils.startsWith(line, "if ") || strutils.startsWith(line, "elif ")):
        return false
    let colonIdx = findTopLevelToken(line, ":", 0)
    if colonIdx < 0:
        return false
    var keywordLen: int32 = len("elif ")
    if strutils.startsWith(line, "if "):
        keywordLen = len("if ")
    let condText = strutils.strip(sliceRange(line, keywordLen, colonIdx))
    let inlineThenText = strutils.strip(sliceRange(line, colonIdx + 1, len(line)))
    var thenStmtIds: int32[]
    var nextIdx: int32 = startIdx + 1
    if len(inlineThenText) == 0:
        var thenLines: str[]
        let collected = collectOutlineBlockLines(bodyLines, headerNextIdx, thenLines)
        if !parseCompilerStmtLines(program, thenLines, thenStmtIds):
            return false
        nextIdx = collected
    else:
        let thenLines = [inlineThenText]
        if !parseCompilerStmtLines(program, thenLines, thenStmtIds):
            return false
    var elseStmtIds: int32[]
    elseStmtIds = []
    outNextIdx = nextIdx
    if outNextIdx < bodyLines.len:
        let elseRaw = bodyLines[outNextIdx]
        let elseLine = trimInlineComment(elseRaw)
        if leadingIndentWidth(elseRaw) == 0 && strutils.startsWith(elseLine, "else:"):
            let inlineElseText = strutils.strip(sliceRange(elseLine, len("else:"), len(elseLine)))
            if len(inlineElseText) == 0:
                var elseLines: str[]
                outNextIdx = collectOutlineBlockLines(bodyLines, outNextIdx + 1, elseLines)
                if !parseCompilerStmtLines(program, elseLines, elseStmtIds):
                    return false
            else:
                let elseLines = [inlineElseText]
                if !parseCompilerStmtLines(program, elseLines, elseStmtIds):
                    return false
                outNextIdx = outNextIdx + 1
        elif leadingIndentWidth(elseRaw) == 0 && strutils.startsWith(elseLine, "elif "):
            var nestedStmtId: int32 = -1
            if !parseCompilerIfStmtChain(program, bodyLines, outNextIdx, outNextIdx, nestedStmtId):
                return false
            add(elseStmtIds, nestedStmtId)
    
    let condExpr = parseCompilerExprText(program, condText)
    outStmtId = ccore.appendCompilerCoreStmt(program, "if", "", "", condExpr, -1, thenStmtIds, elseStmtIds)
    return true

fn parseCompilerStmtLines(program: var ccore.CompilerCoreProgram,
                          bodyLines: str[],
                          outStmtIds: var int32[]): bool =
    outStmtIds = []
    var idx: int32 = 0
    while idx < bodyLines.len:
        let rawLine = bodyLines[idx]
        if isBlankOrCommentLine(rawLine):
            idx = idx + 1
            continue
        if leadingIndentWidth(rawLine) > 0:
            return false
        var nextIdx: int32 = idx + 1
        let line = collectCompilerLogicalLine(bodyLines,
                                              idx,
                                              trimInlineComment(rawLine),
                                              false,
                                              nextIdx)
        if isCompilerReturnStmtLine(line):
            var exprText = strutils.strip(sliceRange(line, len("return"), len(line)))
            var exprId: int32 = -1
            if len(exprText) > 0 &&
               strutils.startsWith(exprText, "if ") &&
               exprText[len(exprText) - 1] == ':' &&
               nextIdx < bodyLines.len &&
               leadingIndentWidth(bodyLines[nextIdx]) > 0:
                if !collectCompilerIfExprTailText(bodyLines, exprText, nextIdx, nextIdx, exprText):
                    return false
            elif len(exprText) <= 0 && nextIdx < bodyLines.len && leadingIndentWidth(bodyLines[nextIdx]) > 0:
                var exprLines: str[]
                nextIdx = collectOutlineBlockLines(bodyLines, nextIdx, exprLines)
                if !parseCompilerExprBlockText(exprLines, exprText):
                    return false
            if len(exprText) > 0:
                exprId = parseCompilerExprText(program, exprText)
            add(outStmtIds, ccore.appendCompilerCoreStmt(program, "return", "", "", exprId, -1, [], []))
            idx = nextIdx
            continue
        if line == "break":
            add(outStmtIds, ccore.appendCompilerCoreStmt(program, "break", "", "", -1, -1, [], []))
            idx = nextIdx
            continue
        if line == "continue":
            add(outStmtIds, ccore.appendCompilerCoreStmt(program, "continue", "", "", -1, -1, [], []))
            idx = nextIdx
            continue
        if strutils.startsWith(line, "let ") || strutils.startsWith(line, "var "):
            let kind = if strutils.startsWith(line, "let "): "let" else: "var"
            let tail = strutils.strip(sliceRange(line, len(kind) + 1, len(line)))
            let eqIdx = findLastTopLevelAssign(tail)
            let lhs = eqIdx >= 0 ? strutils.strip(sliceRange(tail, 0, eqIdx)) : tail
            let colonIdx = findTopLevelToken(lhs, ":", 0)
            var nameText: str = lhs
            var typeText: str = ""
            if colonIdx >= 0:
                nameText = strutils.strip(sliceRange(lhs, 0, colonIdx))
                typeText = stripTopLevelDefaultValueText(sliceRange(lhs, colonIdx + 1, len(lhs)))
            var initExprId: int32 = -1
            if eqIdx >= 0:
                var rhs = strutils.strip(sliceRange(tail, eqIdx + 1, len(tail)))
                if len(rhs) > 0 &&
                   strutils.startsWith(rhs, "if ") &&
                   rhs[len(rhs) - 1] == ':' &&
                   nextIdx < bodyLines.len &&
                   leadingIndentWidth(bodyLines[nextIdx]) > 0:
                    if !collectCompilerIfExprTailText(bodyLines, rhs, nextIdx, nextIdx, rhs):
                        return false
                elif len(rhs) <= 0 && nextIdx < bodyLines.len && leadingIndentWidth(bodyLines[nextIdx]) > 0:
                    var exprLines: str[]
                    nextIdx = collectOutlineBlockLines(bodyLines, nextIdx, exprLines)
                    if !parseCompilerExprBlockText(exprLines, rhs):
                        return false
                initExprId = parseCompilerExprText(program, rhs)
            discard ccore.appendCompilerCoreLocal(program,
                                                  ccore.compilerCoreLocalDecl(nameText,
                                                                             typeText,
                                                                             kind,
                                                                             initExprId))
            add(outStmtIds, ccore.appendCompilerCoreStmt(program, kind, nameText, "", initExprId, -1, [], []))
            idx = nextIdx
            continue
        if strutils.startsWith(line, "case "):
            var caseStmtIds: int32[]
            if !parseCompilerCaseStmt(program, bodyLines, idx, idx, caseStmtIds):
                return false
            for i in 0..<caseStmtIds.len:
                add(outStmtIds, caseStmtIds[i])
            continue
        if strutils.startsWith(line, "if ") || strutils.startsWith(line, "elif "):
            var ifStmtId: int32 = -1
            if !parseCompilerIfStmtChain(program, bodyLines, idx, idx, ifStmtId):
                return false
            add(outStmtIds, ifStmtId)
            continue
        if strutils.startsWith(line, "while ") && line[len(line) - 1] == ':':
            let condText = strutils.strip(sliceRange(line, len("while "), len(line) - 1))
            var childLines: str[]
            idx = collectOutlineBlockLines(bodyLines, idx + 1, childLines)
            var childStmtIds: int32[]
            if !parseCompilerStmtLines(program, childLines, childStmtIds):
                return false
            let condExpr = parseCompilerExprText(program, condText)
            add(outStmtIds, ccore.appendCompilerCoreStmt(program, "while", "", "", condExpr, -1, childStmtIds, []))
            continue
        var iterName: str = ""
        var rangeStartText: str = ""
        var rangeStopText: str = ""
        var rangeKind: str = ""
        if parseForRangeHeader(line, iterName, rangeStartText, rangeStopText, rangeKind):
            var childLines: str[]
            idx = collectOutlineBlockLines(bodyLines, idx + 1, childLines)
            var childStmtIds: int32[]
            if !parseCompilerStmtLines(program, childLines, childStmtIds):
                return false
            let startExpr = parseCompilerExprText(program, rangeStartText)
            let stopExpr = parseCompilerExprText(program, rangeStopText)
            discard ccore.appendCompilerCoreLocal(program,
                                                  ccore.compilerCoreLocalDecl(iterName,
                                                                             "int32",
                                                                             "loop_index",
                                                                             -1))
            add(outStmtIds, ccore.appendCompilerCoreStmt(program, "for_range", iterName, rangeKind, startExpr, stopExpr, childStmtIds, []))
            continue
        let assignIdx = findLastTopLevelAssign(line)
        if assignIdx >= 0:
            let lhsText = strutils.strip(sliceRange(line, 0, assignIdx))
            var rhsText = strutils.strip(sliceRange(line, assignIdx + 1, len(line)))
            if len(rhsText) > 0 &&
               strutils.startsWith(rhsText, "if ") &&
               rhsText[len(rhsText) - 1] == ':' &&
               nextIdx < bodyLines.len &&
               leadingIndentWidth(bodyLines[nextIdx]) > 0:
                if !collectCompilerIfExprTailText(bodyLines, rhsText, nextIdx, nextIdx, rhsText):
                    return false
            if len(lhsText) == 0 || len(rhsText) == 0:
                if len(lhsText) == 0 || nextIdx >= bodyLines.len || leadingIndentWidth(bodyLines[nextIdx]) <= 0:
                    return false
                var exprLines: str[]
                nextIdx = collectOutlineBlockLines(bodyLines, nextIdx, exprLines)
                if !parseCompilerExprBlockText(exprLines, rhsText):
                    return false
                if len(rhsText) == 0:
                    return false
            let lhsExpr = parseCompilerExprText(program, lhsText)
            let rhsExpr = parseCompilerExprText(program, rhsText)
            let lhsKind = program.exprs[lhsExpr].kind
            if lhsKind != "name_ref" && lhsKind != "field" && lhsKind != "index":
                return false
            add(outStmtIds, ccore.appendCompilerCoreStmt(program, "assign", "", "", lhsExpr, rhsExpr, [], []))
            idx = nextIdx
            continue
        let exprId = parseCompilerExprText(program, line)
        add(outStmtIds, ccore.appendCompilerCoreStmt(program, "expr_stmt", "", "", exprId, -1, [], []))
        idx = nextIdx
    return true

fn populateCompilerRoutineExecutableAst(program: var ccore.CompilerCoreProgram,
                                        decl: var ccore.CompilerCoreRoutineDecl): bool =
    let paramLen = program.routineParams.len
    let localLen = program.locals.len
    let stmtLen = program.stmts.len
    let stmtChildLen = program.stmtChildIds.len
    let exprLen = program.exprs.len
    let exprChildLen = program.exprChildIds.len
    parseRoutineParamSignatureText(decl.signatureText, decl, program)
    decl.localStart = program.locals.len
    decl.localCount = 0
    decl.stmtStart = program.stmts.len
    decl.stmtCount = 0
    decl.exprStart = program.exprs.len
    decl.exprCount = 0
    var stmtIds: int32[]
    if routineSignatureEndsWithAssign(decl.signatureText):
        var exprText: str = ""
        if !parseCompilerExprBlockText(decl.bodyLines, exprText):
            ccore.truncateCompilerCoreProgramAst(program,
                                                paramLen,
                                                localLen,
                                                stmtLen,
                                                stmtChildLen,
                                                exprLen,
                                                exprChildLen)
            decl.returnTypeText = ""
            decl.paramStart = 0
            decl.paramCount = 0
            decl.localStart = 0
            decl.localCount = 0
            decl.stmtStart = 0
            decl.stmtCount = 0
            decl.exprStart = 0
            decl.exprCount = 0
            decl.executableAstReady = false
            return false
        let exprId = parseCompilerExprText(program, exprText)
        stmtIds = [ccore.appendCompilerCoreStmt(program, "return", "", "", exprId, -1, [], [])]
    elif !parseCompilerStmtLines(program, decl.bodyLines, stmtIds):
        ccore.truncateCompilerCoreProgramAst(program,
                                            paramLen,
                                            localLen,
                                            stmtLen,
                                            stmtChildLen,
                                            exprLen,
                                            exprChildLen)
        decl.returnTypeText = ""
        decl.paramStart = 0
        decl.paramCount = 0
        decl.localStart = 0
        decl.localCount = 0
        decl.stmtStart = 0
        decl.stmtCount = 0
        decl.exprStart = 0
        decl.exprCount = 0
        decl.executableAstReady = false
        return false
    decl.localCount = program.locals.len - decl.localStart
    decl.stmtCount = program.stmts.len - decl.stmtStart
    decl.exprCount = program.exprs.len - decl.exprStart
    decl.executableAstReady = true
    return true

fn populateCompilerValueDeclExecutableAst(program: var ccore.CompilerCoreProgram,
                                          decl: var ccore.CompilerCoreValueDecl): bool =
    let paramLen = program.routineParams.len
    let localLen = program.locals.len
    let stmtLen = program.stmts.len
    let stmtChildLen = program.stmtChildIds.len
    let exprLen = program.exprs.len
    let exprChildLen = program.exprChildIds.len
    decl.stmtStart = program.stmts.len
    decl.stmtCount = 0
    decl.exprStart = program.exprs.len
    decl.exprCount = 0
    let trimmedHeader = trimInlineComment(decl.headerText)
    let assignIdx = findLastTopLevelAssign(trimmedHeader)
    if assignIdx < 0:
        ccore.truncateCompilerCoreProgramAst(program,
                                            paramLen,
                                            localLen,
                                            stmtLen,
                                            stmtChildLen,
                                            exprLen,
                                            exprChildLen)
        decl.stmtStart = 0
        decl.stmtCount = 0
        decl.exprStart = 0
        decl.exprCount = 0
        decl.executableAstReady = false
        return false
    var exprLines: str[] = []
    let inlineBody = strutils.strip(sliceRange(trimmedHeader, assignIdx + 1, len(trimmedHeader)))
    if len(inlineBody) > 0:
        exprLines = [inlineBody]
        for i in 0..<decl.bodyLines.len:
            add(exprLines, decl.bodyLines[i])
    else:
        exprLines = decl.bodyLines
    var exprText: str = ""
    if !parseCompilerExprBlockText(exprLines, exprText):
        ccore.truncateCompilerCoreProgramAst(program,
                                            paramLen,
                                            localLen,
                                            stmtLen,
                                            stmtChildLen,
                                            exprLen,
                                            exprChildLen)
        decl.stmtStart = 0
        decl.stmtCount = 0
        decl.exprStart = 0
        decl.exprCount = 0
        decl.executableAstReady = false
        return false
    let exprId = parseCompilerExprText(program, exprText)
    let stmtIds = [ccore.appendCompilerCoreStmt(program, "return", "", "", exprId, -1, [], [])]
    decl.stmtStart = stmtIds[0]
    decl.stmtCount = stmtIds.len
    decl.exprStart = exprLen
    decl.exprCount = program.exprs.len - exprLen
    decl.executableAstReady = true
    return true

fn appendCompilerValueBlockDecls(program: var ccore.CompilerCoreProgram,
                                 kind: str,
                                 bodyLines: str[]): bool =
    var idx: int32 = 0
    while idx < bodyLines.len:
        if isBlankOrCommentLine(bodyLines[idx]):
            idx = idx + 1
            continue
        if leadingIndentWidth(bodyLines[idx]) > 0:
            return false
        let headerText = trimInlineComment(bodyLines[idx])
        var declBodyLines: str[] = []
        idx = idx + 1
        while idx < bodyLines.len:
            if isBlankOrCommentLine(bodyLines[idx]):
                add(declBodyLines, bodyLines[idx])
                idx = idx + 1
                continue
            let trimmed = trimInlineComment(bodyLines[idx])
            if leadingIndentWidth(bodyLines[idx]) <= 0 &&
               len(trimmed) > 0 &&
               isNameChar(trimmed[0]):
                break
            add(declBodyLines, bodyLines[idx])
            idx = idx + 1
        var decl = ccore.compilerCoreValueDecl(parseCompilerValueBindingLabel(headerText),
                                               headerText,
                                               declBodyLines)
        discard populateCompilerValueDeclExecutableAst(program, decl)
        if kind == "const":
            ccore.appendCompilerCoreConstDecl(program, decl)
        else:
            ccore.appendCompilerCoreVarDecl(program, decl)
    return true

fn tryParseCompilerCoreSourceText(sourcePath: str, text: str, out: var ParsedV2Source): bool =
    let rawLines = strutils.split(text, '\n')
    var program = ccore.newCompilerCoreProgram()
    var pendingAnnotations: str[]
    pendingAnnotations = []
    var idx: int32 = 0
    while idx < rawLines.len:
        let rawLine = rawLines[idx]
        let line = strutils.strip(rawLine)
        if isBlankOrCommentLine(rawLine):
            idx = idx + 1
            continue
        if leadingIndentWidth(rawLine) > 0:
            return false
        if len(line) > 0 && line[0] == '@':
            add(pendingAnnotations, line)
            idx = idx + 1
            continue
        if line == "module" || strutils.startsWith(line, "module "):
            if pendingAnnotations.len > 0:
                return false
            let name = parseCompilerDeclLabel(line, "module ", "module")
            ccore.appendCompilerCoreModule(program, ccore.compilerCoreModuleDecl(name, line))
            idx = idx + 1
            continue
        if strutils.startsWith(line, "import "):
            if pendingAnnotations.len > 0:
                return false
            ccore.appendCompilerCoreImport(program, parseCompilerImportLine(line))
            idx = idx + 1
            continue
        if line == "type":
            if pendingAnnotations.len > 0:
                return false
            var bodyLines: str[]
            idx = collectOutlineBlockLines(rawLines, idx + 1, bodyLines)
            ccore.appendCompilerCoreTypeBlock(program, ccore.compilerCoreTypeBlock("type", bodyLines))
            continue
        if line == "const" || strutils.startsWith(line, "const "):
            if pendingAnnotations.len > 0:
                return false
            var bodyLines: str[]
            bodyLines = []
            var nextIdx: int32 = idx + 1
            if line == "const":
                nextIdx = collectOutlineBlockLines(rawLines, idx + 1, bodyLines)
                if !appendCompilerValueBlockDecls(program, "const", bodyLines):
                    return false
            else:
                var decl = ccore.compilerCoreValueDecl(parseCompilerDeclLabel(line, "const ", "const"),
                                                       line,
                                                       bodyLines)
                discard populateCompilerValueDeclExecutableAst(program, decl)
                ccore.appendCompilerCoreConstDecl(program, decl)
            idx = nextIdx
            continue
        if line == "var" || strutils.startsWith(line, "var "):
            if pendingAnnotations.len > 0:
                return false
            var bodyLines: str[]
            bodyLines = []
            var nextIdx: int32 = idx + 1
            if line == "var":
                nextIdx = collectOutlineBlockLines(rawLines, idx + 1, bodyLines)
                if !appendCompilerValueBlockDecls(program, "var", bodyLines):
                    return false
            else:
                var decl = ccore.compilerCoreValueDecl(parseCompilerDeclLabel(line, "var ", "var"),
                                                       line,
                                                       bodyLines)
                discard populateCompilerValueDeclExecutableAst(program, decl)
                ccore.appendCompilerCoreVarDecl(program, decl)
            idx = nextIdx
            continue
        if strutils.startsWith(line, "importc fn "):
            let name = parseCompilerRoutineName(line, "importc fn ")
            let signatureText = joinPrefixedLineParts(pendingAnnotations, [line])
            var decl = ccore.compilerCoreRoutineDecl("importc_fn", name, signatureText, [])
            parseRoutineParamSignatureText(signatureText, decl, program)
            ccore.appendCompilerCoreRoutine(program, decl)
            pendingAnnotations = []
            idx = idx + 1
            continue
        if strutils.startsWith(line, "fn ") || strutils.startsWith(line, "iterator "):
            var baseKind: str = "fn"
            if strutils.startsWith(line, "iterator "):
                baseKind = "iterator"
            let allowHeaderOnly = annotationLinesContainImportc(pendingAnnotations)
            var kind: str = baseKind
            var name: str = ""
            if kind == "iterator":
                name = parseCompilerRoutineName(line, "iterator ")
            else:
                name = parseCompilerRoutineName(line, "fn ")
            var signatureText: str = ""
            var bodyLines: str[]
            idx = collectRoutineSignatureAndBody(rawLines,
                                                idx,
                                                pendingAnnotations,
                                                allowHeaderOnly,
                                                signatureText,
                                                bodyLines)
            if allowHeaderOnly && bodyLines.len == 0:
                kind = "importc_fn"
            var decl = ccore.compilerCoreRoutineDecl(kind, name, signatureText, bodyLines)
            if kind == "importc_fn":
                parseRoutineParamSignatureText(signatureText, decl, program)
            else:
                discard populateCompilerRoutineExecutableAst(program, decl)
            ccore.appendCompilerCoreRoutine(program, decl)
            pendingAnnotations = []
            continue
        return false
    if pendingAnnotations.len > 0:
        return false
    if !ccore.compilerCoreHasTopLevel(program):
        return false
    let defaultOwnerModule = compilerCoreDefaultOwnerModulePath(sourcePath)
    for i in 0..<program.topLevelSourcePaths.len:
        if len(program.topLevelSourcePaths[i]) == 0:
            program.topLevelSourcePaths[i] = sourcePath
    for i in 0..<program.topLevelOwnerModules.len:
        if len(program.topLevelOwnerModules[i]) == 0:
            program.topLevelOwnerModules[i] = defaultOwnerModule
    out = newParsedV2Source(sourcePath)
    out.compilerCoreProgram = program
    ident.appendUnique(out.surfaceKinds, "compiler_core")
    return true

fn newParsedV2Source(sourcePath: str): ParsedV2Source =
    var out: ParsedV2Source
    out.version = "v2.frontend.source_parser.v1"
    out.sourcePath = sourcePath
    out.compilerCoreProgram = ccore.newCompilerCoreProgram()
    out.unimakerProgram = usurf.newUnimakerSurfaceProgram()
    out.networkProgram = nsurf.newNetworkDistributionProgram()
    out.surfaceKinds = []
    return out

fn sourceHasRecognizedSurface(parsed: ParsedV2Source): bool =
    return ccore.compilerCoreHasTopLevel(parsed.compilerCoreProgram) ||
           parsed.unimakerProgram.decls.len > 0 ||
           parsed.networkProgram.topologies.len > 0 ||
           parsed.networkProgram.ops.len > 0

fn tryParseV2SourceText(sourcePath: str, text: str, out: var ParsedV2Source): bool =
    var parsed = newParsedV2Source(sourcePath)
    let lines = strutils.split(text, '\n')
    var hadRecognized: bool = false
    for i in 0..<lines.len:
        let line = strutils.strip(lines[i])
        if len(line) == 0 || strutils.startsWith(line, "//") || strutils.startsWith(line, "#"):
            continue
        if parseUnimakerLine(parsed.unimakerProgram, line):
            ident.appendUnique(parsed.surfaceKinds, "unimaker")
            hadRecognized = true
            continue
        if parseTopologyLine(parsed.networkProgram, line):
            ident.appendUnique(parsed.surfaceKinds, "topology")
            hadRecognized = true
            continue
        if parseNetworkOpLine(parsed.networkProgram, line):
            ident.appendUnique(parsed.surfaceKinds, "network_distribution")
            hadRecognized = true
            continue
        if hadRecognized:
            return false
    if hadRecognized:
        out = parsed
        return true
    return tryParseCompilerCoreSourceText(sourcePath, text, out)

fn tryParseV2SourceFile(path: str, out: var ParsedV2Source): bool =
    return tryParseV2SourceText(path, os.readFile(path), out)

fn parseV2SourceTextStrict(sourcePath: str, text: str): ParsedV2Source =
    var out: ParsedV2Source
    if !tryParseV2SourceText(sourcePath, text, out):
        system.panicStr("v2 source parser: unsupported mixed surface in " + sourcePath)
    if !sourceHasRecognizedSurface(out):
        system.panicStr("v2 source parser: no v2 surface recognized in " + sourcePath)
    return out

fn parseV2SourceFileStrict(path: str): ParsedV2Source =
    return parseV2SourceTextStrict(path, os.readFile(path))
