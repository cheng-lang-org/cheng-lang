import std/seqs
import std/system

type
    TopologyDecl =
        name: str
        domain: str
        fanout: str
        repair: str
        dispersal: str
        priority: str
        addressing: str
        depth: int32
        idaK: int32
        idaN: int32
    NetworkDistributionOp =
        opName: str
        topologyRef: str
        subjectName: str
        signatureKind: str
    NetworkDistributionProgram =
        version: str
        topologies: TopologyDecl[]
        ops: NetworkDistributionOp[]

fn emptyTopologyDecl(name: str): TopologyDecl =
    var out: TopologyDecl
    out.name = name
    out.domain = ""
    out.fanout = ""
    out.repair = ""
    out.dispersal = ""
    out.priority = ""
    out.addressing = ""
    out.depth = 0
    out.idaK = 0
    out.idaN = 0
    return out

fn topologyDecl(name: str,
                domain: str,
                fanout: str,
                repair: str,
                dispersal: str,
                priority: str,
                addressing: str,
                depth: int32,
                idaK: int32,
                idaN: int32): TopologyDecl =
    var out: TopologyDecl = emptyTopologyDecl(name)
    out.domain = domain
    out.fanout = fanout
    out.repair = repair
    out.dispersal = dispersal
    out.priority = priority
    out.addressing = addressing
    out.depth = depth
    out.idaK = idaK
    out.idaN = idaN
    return out

fn emptyNetworkDistributionOp(opName: str): NetworkDistributionOp =
    var out: NetworkDistributionOp
    out.opName = opName
    out.topologyRef = ""
    out.subjectName = ""
    out.signatureKind = ""
    return out

fn publishSourceManifest(topologyRef: str, packageName: str): NetworkDistributionOp =
    var out: NetworkDistributionOp = emptyNetworkDistributionOp("publish_source_manifest")
    out.topologyRef = topologyRef
    out.subjectName = packageName
    return out

fn publishRulePack(topologyRef: str, packName: str): NetworkDistributionOp =
    var out: NetworkDistributionOp = emptyNetworkDistributionOp("publish_rule_pack")
    out.topologyRef = topologyRef
    out.subjectName = packName
    return out

fn publishCompilerRulePack(topologyRef: str, packName: str): NetworkDistributionOp =
    var out: NetworkDistributionOp = emptyNetworkDistributionOp("publish_compiler_rule_pack")
    out.topologyRef = topologyRef
    out.subjectName = packName
    return out

fn routeLsmrTree(topologyRef: str): NetworkDistributionOp =
    var out: NetworkDistributionOp = emptyNetworkDistributionOp("route_lsmr_tree")
    out.topologyRef = topologyRef
    out.subjectName = topologyRef
    return out

fn disperseIdaFragments(topologyRef: str): NetworkDistributionOp =
    var out: NetworkDistributionOp = emptyNetworkDistributionOp("disperse_ida_fragments")
    out.topologyRef = topologyRef
    out.subjectName = topologyRef
    return out

fn exchangeAntiEntropySignature(topologyRef: str, signatureKind: str): NetworkDistributionOp =
    var out: NetworkDistributionOp = emptyNetworkDistributionOp("exchange_anti_entropy_signature")
    out.topologyRef = topologyRef
    out.subjectName = topologyRef
    out.signatureKind = signatureKind
    return out

fn repairFromSignatureGap(topologyRef: str, signatureKind: str): NetworkDistributionOp =
    var out: NetworkDistributionOp = emptyNetworkDistributionOp("repair_from_signature_gap")
    out.topologyRef = topologyRef
    out.subjectName = topologyRef
    out.signatureKind = signatureKind
    return out

fn canonicalDispersalText(topology: TopologyDecl): str =
    if topology.dispersal == "ida":
        return "ida(k=" + intToStr(topology.idaK) + ",n=" + intToStr(topology.idaN) + ")"
    return topology.dispersal

fn topologyAddressBinding(topology: TopologyDecl): str =
    return topology.addressing == "lsmr_path" ? "content_bound_address" : ""

fn topologyDistanceMetric(topology: TopologyDecl): str =
    return topology.addressing == "lsmr_path" ? "per_level_manhattan" : ""

fn topologyMultipathModel(topology: TopologyDecl): str =
    return topology.addressing == "lsmr_path" ? "canonical_multipath_set" : ""

fn topologyCanonicalForm(topology: TopologyDecl): str =
    return "topology(domain=" + topology.domain +
           ",fanout=" + topology.fanout +
           ",repair=" + topology.repair +
           ",dispersal=" + canonicalDispersalText(topology) +
           ",priority=" + topology.priority +
           ",addressing=" + topology.addressing +
           ",depth=" + intToStr(topology.depth) + ")"

fn networkPriorityTransport(priority: str): str =
    if priority == "urgent":
        return "deterministic_tree_push"
    if priority == "bulk":
        return "coded_bulk_dispersal"
    if priority == "background":
        return "passive_anti_entropy"
    return ""

fn networkDistributionOpSummary(op: NetworkDistributionOp): str =
    var out: str = op.opName + " | " + op.topologyRef
    if len(op.subjectName) > 0:
        out = out + " | " + op.subjectName
    if len(op.signatureKind) > 0:
        out = out + " | " + op.signatureKind
    return out

fn newNetworkDistributionProgram(): NetworkDistributionProgram =
    var out: NetworkDistributionProgram
    out.version = "v2.frontend.network_distribution_surface_ir.v1"
    out.topologies = []
    out.ops = []
    return out

fn sampleNetworkDistributionProgram(): NetworkDistributionProgram =
    var out: NetworkDistributionProgram = newNetworkDistributionProgram()
    add(out.topologies, topologyDecl("SourceSync", "source_manifest", "luoshu9", "passive_anti_entropy", "none", "urgent", "lsmr_path", 4, 0, 0))
    add(out.topologies, topologyDecl("RuleSync", "rule_pack", "luoshu9", "passive_anti_entropy", "ida", "bulk", "lsmr_path", 4, 5, 9))
    add(out.topologies, topologyDecl("CompilerSync", "compiler_rule_pack", "luoshu9", "passive_anti_entropy", "none", "background", "lsmr_path", 4, 0, 0))
    add(out.ops, publishSourceManifest("SourceSync", "pkg://cheng/v2"))
    add(out.ops, publishRulePack("RuleSync", "optimizer_rules"))
    add(out.ops, publishCompilerRulePack("CompilerSync", "compiler_rules"))
    add(out.ops, routeLsmrTree("RuleSync"))
    add(out.ops, disperseIdaFragments("RuleSync"))
    add(out.ops, exchangeAntiEntropySignature("CompilerSync", "ganzhi_merkle_v1"))
    add(out.ops, repairFromSignatureGap("CompilerSync", "ganzhi_merkle_v1"))
    return out
