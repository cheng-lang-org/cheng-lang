import compiler/frontend/compiler_core_surface_ir_v2 as ccore
import compiler/semantic_facts/compiler_core_facts_v2 as cfacts
import compiler/high_uir/compiler_core_graph_v2 as cgraph

fn lowerCompilerCoreProgramToHighUir(program: ccore.CompilerCoreProgram,
                                     facts: cfacts.CompilerCoreSemanticFacts): cgraph.HighUirCompilerCoreGraph =
    var out: cgraph.HighUirCompilerCoreGraph = cgraph.newHighUirCompilerCoreGraph()
    var moduleIdx: int32 = 0
    var typeIdx: int32 = 0
    var constIdx: int32 = 0
    var varIdx: int32 = 0
    var routineIdx: int32 = 0
    for i in 0..<facts.itemIds.len:
        var signatureText: str = ""
        var bodyText: str = ""
        var astSlice = cgraph.newHighUirCompilerCoreAstSlice()
        if facts.topLevelKinds[i] == "module":
            signatureText = program.modules[moduleIdx].headerText
            moduleIdx = moduleIdx + 1
        elif facts.topLevelKinds[i] == "type":
            signatureText = program.typeBlocks[typeIdx].headerText
            bodyText = cgraph.compilerCoreJoinBodyLines(program.typeBlocks[typeIdx].bodyLines)
            typeIdx = typeIdx + 1
        elif facts.topLevelKinds[i] == "const":
            let decl = program.constDecls[constIdx]
            signatureText = decl.headerText
            bodyText = cgraph.compilerCoreJoinBodyLines(decl.bodyLines)
            if facts.executableAstReady[i]:
                astSlice = cgraph.appendHighUirCompilerCoreRoutineAst(out,
                                                                      program,
                                                                      facts,
                                                                      ccore.compilerCoreValueDeclAsRoutineDecl(decl))
            constIdx = constIdx + 1
        elif facts.topLevelKinds[i] == "var":
            let decl = program.varDecls[varIdx]
            signatureText = decl.headerText
            bodyText = cgraph.compilerCoreJoinBodyLines(decl.bodyLines)
            if facts.executableAstReady[i]:
                astSlice = cgraph.appendHighUirCompilerCoreRoutineAst(out,
                                                                      program,
                                                                      facts,
                                                                      ccore.compilerCoreValueDeclAsRoutineDecl(decl))
            varIdx = varIdx + 1
        elif facts.topLevelKinds[i] != "import":
            let decl = program.routines[routineIdx]
            signatureText = decl.signatureText
            bodyText = cgraph.compilerCoreJoinBodyLines(decl.bodyLines)
            astSlice = cgraph.appendHighUirCompilerCoreRoutineAst(out, program, facts, decl)
            routineIdx = routineIdx + 1
        cgraph.appendHighUirCompilerCoreItem(out,
                                             facts.itemIds[i],
                                             facts.highOps[i],
                                             facts.proofDomains[i],
                                             facts.effectClasses[i],
                                             facts.bindingScopes[i],
                                             facts.importPaths[i],
                                             facts.importTargetModulePaths[i],
                                             facts.importAliases[i],
                                             facts.importCategories[i],
                                             signatureText,
                                             facts.signatureHashes[i],
                                             bodyText,
                                             facts.bodyLineCounts[i],
                                             facts.bodyHashes[i],
                                             facts.executableAstReady[i],
                                             facts.returnTypeTexts[i],
                                             facts.paramCounts[i],
                                             facts.localCounts[i],
                                             facts.stmtCounts[i],
                                             facts.exprCounts[i],
                                             facts.stmtKindSets[i],
                                             facts.exprKindSets[i],
                                             facts.stmtSemanticSets[i],
                                             facts.exprSemanticSets[i],
                                             astSlice.paramStart,
                                             astSlice.localStart,
                                             astSlice.stmtStart,
                                             astSlice.exprStart,
                                             facts.topLevelKinds[i],
                                             facts.topLevelLabels[i],
                                             facts.importcSymbolTexts[i],
                                             i < len(program.topLevelOwnerModules) ? program.topLevelOwnerModules[i] else: "",
                                             i < len(program.topLevelSourcePaths) ? program.topLevelSourcePaths[i] else: "")
    return out
