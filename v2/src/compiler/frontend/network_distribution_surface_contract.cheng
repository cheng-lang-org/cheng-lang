import std/seqs

type
    NetworkDistributionSurfaceContract =
        version: str
        topologyForm: str
        builtinOperations: str[]
        allowedDomains: str[]
        allowedFanouts: str[]
        allowedAddressingModes: str[]
        allowedRepairs: str[]
        allowedDispersals: str[]
        allowedPriorities: str[]
        fixedPriorityMappings: str[]
        fixedAddressBindings: str[]
        fixedDistanceMetrics: str[]
        fixedRoutePlanModels: str[]

fn networkDistributionSurfaceContract(): NetworkDistributionSurfaceContract =
    var out: NetworkDistributionSurfaceContract
    out.version = "v2.network_distribution_surface.v2"
    out.topologyForm = "topology(name)=lsmr_tree(domain, fanout, repair, dispersal, priority, addressing, depth)"
    out.builtinOperations = []
    add(out.builtinOperations, "publish_source_manifest")
    add(out.builtinOperations, "publish_rule_pack")
    add(out.builtinOperations, "publish_compiler_rule_pack")
    add(out.builtinOperations, "route_lsmr_tree")
    add(out.builtinOperations, "disperse_ida_fragments")
    add(out.builtinOperations, "exchange_anti_entropy_signature")
    add(out.builtinOperations, "repair_from_signature_gap")
    out.allowedDomains = []
    add(out.allowedDomains, "source_manifest")
    add(out.allowedDomains, "ast_delta")
    add(out.allowedDomains, "rule_pack")
    add(out.allowedDomains, "compiler_rule_pack")
    out.allowedFanouts = []
    add(out.allowedFanouts, "luoshu9")
    out.allowedAddressingModes = []
    add(out.allowedAddressingModes, "lsmr_path")
    out.allowedRepairs = []
    add(out.allowedRepairs, "passive_anti_entropy")
    out.allowedDispersals = []
    add(out.allowedDispersals, "none")
    add(out.allowedDispersals, "ida(k,n)")
    out.allowedPriorities = []
    add(out.allowedPriorities, "urgent")
    add(out.allowedPriorities, "bulk")
    add(out.allowedPriorities, "background")
    out.fixedPriorityMappings = []
    add(out.fixedPriorityMappings, "urgent=deterministic_tree_push")
    add(out.fixedPriorityMappings, "bulk=coded_bulk_dispersal")
    add(out.fixedPriorityMappings, "background=passive_anti_entropy")
    out.fixedAddressBindings = []
    add(out.fixedAddressBindings, "lsmr_path=content_bound_address")
    out.fixedDistanceMetrics = []
    add(out.fixedDistanceMetrics, "lsmr_path=per_level_manhattan")
    out.fixedRoutePlanModels = []
    add(out.fixedRoutePlanModels, "lsmr_path=canonical_multipath_set")
    return out

fn networkDistributionOperationCount(): int32 =
    let c = networkDistributionSurfaceContract()
    return c.builtinOperations.len
