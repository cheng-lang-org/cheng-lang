import std/system
import compiler/frontend/string_surface_ir_v2 as surf
import compiler/semantic_facts/string_facts_v2 as sfacts
import compiler/high_uir/string_graph_v2 as hstr

fn lowerStringSurfaceProgramToHighUir(program: surf.StringSurfaceProgram,
                                      facts: sfacts.StringSemanticFacts): hstr.HighUirStringGraph =
    if program.exprs.len != facts.factIds.len:
        panic("v2 string lowering: surface/facts count mismatch")
    var graph: hstr.HighUirStringGraph = hstr.newHighUirStringGraph()
    for i in 0..<program.exprs.len:
        hstr.appendHighUirStringExpr(graph,
                                     facts.factIds[i],
                                     facts.highOps[i],
                                     facts.runtimeTargets[i],
                                     facts.resultKinds[i],
                                     facts.allocationModes[i],
                                     facts.zeroCopyFacts[i],
                                     program.exprs[i])
    return graph

fn lowerSampleStringSurfaceProgramToHighUir(): hstr.HighUirStringGraph =
    let program = surf.sampleStringSurfaceProgram()
    let facts = sfacts.buildStringSemanticFacts(program)
    return lowerStringSurfaceProgramToHighUir(program, facts)
