import std/seqs

type
    CompilerCoreSurfaceContract =
        version: str
        topLevelForms: str[]
        blockKinds: str[]
        importStyle: str
        routineNameStyle: str
        bodyStorage: str
        parseMode: str
        executableAstStorage: str
        executableAstCoverage: str
        stableTopLevelOrder: bool

fn compilerCoreSurfaceContract(): CompilerCoreSurfaceContract =
    var out: CompilerCoreSurfaceContract
    out.version = "v2.compiler_core_surface.v1"
    out.topLevelForms = []
    add(out.topLevelForms, "module")
    add(out.topLevelForms, "import")
    add(out.topLevelForms, "type")
    add(out.topLevelForms, "const")
    add(out.topLevelForms, "var")
    add(out.topLevelForms, "fn")
    add(out.topLevelForms, "iterator")
    add(out.topLevelForms, "importc_fn")
    out.blockKinds = []
    add(out.blockKinds, "module_decl")
    add(out.blockKinds, "type_block")
    add(out.blockKinds, "const_block")
    add(out.blockKinds, "var_block")
    add(out.blockKinds, "routine_block")
    out.importStyle = "normalized_module_path_optional_alias"
    out.routineNameStyle = "identifier_or_backtick_operator"
    out.bodyStorage = "outline_block_lines"
    out.parseMode = "indentation_sensitive_outline"
    out.executableAstStorage = "stmt_expr_soa_subset"
    out.executableAstCoverage = "routine_body_subset"
    out.stableTopLevelOrder = true
    return out

fn compilerCoreTopLevelFormCount(): int32 =
    return compilerCoreSurfaceContract().topLevelForms.len

fn compilerCoreBlockKindCount(): int32 =
    return compilerCoreSurfaceContract().blockKinds.len
