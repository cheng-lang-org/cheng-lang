import std/seqs

type
    StringSurfaceContract =
        version: str
        valueModel: str
        abiBoundaryType: str
        operatorStyle: str
        searchAlgorithm: str
        concatStrategy: str
        zeroCopySlice: bool
        comparisonFastPath: str
        symbolForms: str[]
        surfaceForms: str[]
        builderApis: str[]

fn stringSurfaceContract(): StringSurfaceContract =
    var out: StringSurfaceContract
    out.version = "v2.string_surface.v1"
    out.valueModel = "fat_value_utf8_bytes"
    out.abiBoundaryType = "cstring"
    out.operatorStyle = "symbol_first"
    out.searchAlgorithm = "two_way_bytes"
    out.concatStrategy = "allocate_once"
    out.zeroCopySlice = true
    out.comparisonFastPath = "ptr_eq_or_len_gate_then_wordwise_cmp"
    out.symbolForms = []
    add(out.symbolForms, "a == b")
    add(out.symbolForms, "a != b")
    add(out.symbolForms, "a + b")
    add(out.symbolForms, "s[i]")
    add(out.symbolForms, "s[a..<b]")
    add(out.symbolForms, "c in s")
    add(out.symbolForms, "sub in s")
    add(out.symbolForms, "$s")
    out.surfaceForms = []
    add(out.surfaceForms, "len(s)")
    add(out.surfaceForms, "s.len")
    add(out.surfaceForms, "s[i]")
    add(out.surfaceForms, "s[a..<b]")
    add(out.surfaceForms, "sub in s")
    add(out.surfaceForms, "s.startsWith(prefix)")
    add(out.surfaceForms, "s.endsWith(suffix)")
    add(out.surfaceForms, "s.contains(sub)")
    add(out.surfaceForms, "$s")
    out.builderApis = []
    add(out.builderApis, "StrBuilder(cap)")
    add(out.builderApis, "builder.append(str)")
    add(out.builderApis, "builder.appendByte(u8)")
    add(out.builderApis, "builder.finish()")
    return out

fn stringSurfaceFormCount(): int32 =
    let c = stringSurfaceContract()
    return c.surfaceForms.len

fn stringSymbolFormCount(): int32 =
    let c = stringSurfaceContract()
    return c.symbolForms.len

fn stringBuilderApiCount(): int32 =
    let c = stringSurfaceContract()
    return c.builderApis.len
