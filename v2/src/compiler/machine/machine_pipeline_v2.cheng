fn compilerCoreDirectExecCStringCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                           itemIdx: int32,
                                           opStart: int32,
                                           opCount: int32,
                                           targetTriple: str): str =
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "return_value" &&
       plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        if calleeItemIdx >= 0 &&
           compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0), "str"):
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "load_str" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        if calleeItemIdx >= 0 &&
           compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0), "str") &&
           compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 1), "str"):
            return compilerCoreDirectExecCStringSecondArgSymbol(plan,
                                                                itemIdx,
                                                                calleeItemIdx,
                                                                "load_str",
                                                                targetTriple)
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "load_str" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let argTypeText = compilerCoreDirectLeadingCurrentParamTypeText(plan,
                                                                        itemIdx,
                                                                        plan.opKinds[opStart + 1],
                                                                        plan.opPrimaryTexts[opStart + 1],
                                                                        plan.opArg0s[opStart + 1])
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        if calleeItemIdx >= 0 &&
           len(argTypeText) > 0 &&
           compilerCoreNormalizedTypeText(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0)) ==
               compilerCoreNormalizedTypeText(argTypeText) &&
           compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 1), "str"):
            return compilerCoreDirectExecCStringSecondArgSymbol(plan,
                                                                itemIdx,
                                                                calleeItemIdx,
                                                                plan.opKinds[opStart + 1],
                                                                targetTriple)
    return ""

fn compilerCoreDirectExecCStringCallWords(plan: cflow.LowUirCompilerCorePlan,
                                          itemIdx: int32,
                                          opStart: int32,
                                          opCount: int32,
                                          architecture: str): str =
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "load_str" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
            return ""
        return machineDirectCallTwoCStringArgsWords(architecture,
                                                    len(plan.opPrimaryTexts[opStart + 1]),
                                                    len(plan.opPrimaryTexts[opStart + 2]))
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       compilerCoreIsDirectScalarValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
            return ""
        return machineDirectCallCStringThenSimpleArgWords(architecture,
                                                          plan.opKinds[opStart + 2],
                                                          plan.opPrimaryTexts[opStart + 2],
                                                          plan.opArg0s[opStart + 2],
                                                          len(plan.opPrimaryTexts[opStart + 1]))
    let cstringPayload = compilerCoreDirectExecCallCStringPayloadText(plan, itemIdx)
    if len(cstringPayload) > 0:
        return machineDirectCallCStringArgWords(architecture, len(cstringPayload))
    let secondCStringPayload = compilerCoreDirectExecCallSecondCStringPayloadText(plan, itemIdx)
    if len(secondCStringPayload) > 0:
        return machineDirectCallSecondCStringArgWords(architecture, len(secondCStringPayload))
    return ""

fn compilerCoreDirectExecSingleSimpleCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                                itemIdx: int32,
                                                opStart: int32,
                                                opCount: int32,
                                                targetTriple: str): str =
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "return_value" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreDirectExecSimpleCallItemIndex(plan, itemIdx, opStart, opCount, targetTriple)
        if calleeItemIdx >= 0 &&
           compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)) == 2 &&
           compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0)) == 2:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
        if calleeItemIdx >= 0 &&
           compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)) == 1:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecMultiSimpleCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32,
                                               opStart: int32,
                                               opCount: int32,
                                               targetTriple: str): str =
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecSimpleCallItemIndex(plan, itemIdx, opStart, opCount, targetTriple)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opArg0s[opStart + 4] == 3:
        let calleeItemIdx = compilerCoreDirectExecSimpleCallItemIndex(plan, itemIdx, opStart, opCount, targetTriple)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 7 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 4]) &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opArg0s[opStart + 5] == 4:
        let calleeItemIdx = compilerCoreDirectExecSimpleCallItemIndex(plan, itemIdx, opStart, opCount, targetTriple)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecSimpleCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                          itemIdx: int32,
                                          opStart: int32,
                                          opCount: int32,
                                          targetTriple: str): str =
    let singleSimpleCallSymbol = compilerCoreDirectExecSingleSimpleCallSymbol(plan,
                                                                              itemIdx,
                                                                              opStart,
                                                                              opCount,
                                                                              targetTriple)
    if len(singleSimpleCallSymbol) > 0:
        return singleSimpleCallSymbol
    return compilerCoreDirectExecMultiSimpleCallSymbol(plan,
                                                       itemIdx,
                                                       opStart,
                                                       opCount,
                                                       targetTriple)

fn compilerCoreDirectExecSingleSimpleCallWords(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32,
                                               opStart: int32,
                                               opCount: int32,
                                               targetTriple: str,
                                               architecture: str): str =
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "return_value" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 2] == 1:
        let callerParamTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
        let calleeItemIdx = compilerCoreDirectExecSimpleCallItemIndex(plan, itemIdx, opStart, opCount, targetTriple)
        let importcWords = compilerCoreDirectExecImportcBridgeWords(plan,
                                                                    itemIdx,
                                                                    calleeItemIdx,
                                                                    architecture,
                                                                    [0])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
            return ""
        if calleeItemIdx >= 0 &&
           compilerCoreDirectTypeRegWidth(callerParamTypeText) == 2 &&
           compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0)) == 2:
            let baseReg = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], 0)
            return machineDirectCallRegisterPairArgWords(architecture, baseReg, baseReg + 1, false)
        if compilerCoreDirectTypeRegWidth(callerParamTypeText) != 1:
            return ""
        return machineDirectCallSimpleArgWords(architecture,
                                               plan.opKinds[opStart + 1],
                                               plan.opPrimaryTexts[opStart + 1],
                                               plan.opArg0s[opStart + 1])
    return ""

fn compilerCoreDirectExecMultiSimpleCallWords(plan: cflow.LowUirCompilerCorePlan,
                                              itemIdx: int32,
                                              opStart: int32,
                                              opCount: int32,
                                              targetTriple: str,
                                              architecture: str): str =
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecSimpleCallItemIndex(plan, itemIdx, opStart, opCount, targetTriple)
        let importcWords = compilerCoreDirectExecImportcBridgeWords(plan,
                                                                    itemIdx,
                                                                    calleeItemIdx,
                                                                    architecture,
                                                                    [plan.opKinds[opStart + 1] == "load_param" ? plan.opArg0s[opStart + 1] else: -1,
                                                                     plan.opKinds[opStart + 2] == "load_param" ? plan.opArg0s[opStart + 2] else: -1])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
            return ""
        return machineDirectCallTwoSimpleArgWords(architecture,
                                                  plan.opKinds[opStart + 1],
                                                  plan.opPrimaryTexts[opStart + 1],
                                                  plan.opArg0s[opStart + 1],
                                                  plan.opKinds[opStart + 2],
                                                  plan.opPrimaryTexts[opStart + 2],
                                                  plan.opArg0s[opStart + 2])
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opArg0s[opStart + 4] == 3:
        let calleeItemIdx = compilerCoreDirectExecSimpleCallItemIndex(plan, itemIdx, opStart, opCount, targetTriple)
        let importcWords = compilerCoreDirectExecImportcBridgeWords(plan,
                                                                    itemIdx,
                                                                    calleeItemIdx,
                                                                    architecture,
                                                                    [plan.opKinds[opStart + 1] == "load_param" ? plan.opArg0s[opStart + 1] else: -1,
                                                                     plan.opKinds[opStart + 2] == "load_param" ? plan.opArg0s[opStart + 2] else: -1,
                                                                     plan.opKinds[opStart + 3] == "load_param" ? plan.opArg0s[opStart + 3] else: -1])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
            return ""
        return machineDirectCallThreeSimpleArgWords(architecture,
                                                    plan.opKinds[opStart + 1],
                                                    plan.opPrimaryTexts[opStart + 1],
                                                    plan.opArg0s[opStart + 1],
                                                    plan.opKinds[opStart + 2],
                                                    plan.opPrimaryTexts[opStart + 2],
                                                    plan.opArg0s[opStart + 2],
                                                    plan.opKinds[opStart + 3],
                                                    plan.opPrimaryTexts[opStart + 3],
                                                    plan.opArg0s[opStart + 3])
    if opCount == 7 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 4]) &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opArg0s[opStart + 5] == 4:
        let calleeItemIdx = compilerCoreDirectExecSimpleCallItemIndex(plan, itemIdx, opStart, opCount, targetTriple)
        let importcWords = compilerCoreDirectExecImportcBridgeWords(plan,
                                                                    itemIdx,
                                                                    calleeItemIdx,
                                                                    architecture,
                                                                    [plan.opKinds[opStart + 1] == "load_param" ? plan.opArg0s[opStart + 1] else: -1,
                                                                     plan.opKinds[opStart + 2] == "load_param" ? plan.opArg0s[opStart + 2] else: -1,
                                                                     plan.opKinds[opStart + 3] == "load_param" ? plan.opArg0s[opStart + 3] else: -1,
                                                                     plan.opKinds[opStart + 4] == "load_param" ? plan.opArg0s[opStart + 4] else: -1])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
            return ""
        return machineDirectCallFourSimpleArgWords(architecture,
                                                   plan.opKinds[opStart + 1],
                                                   plan.opPrimaryTexts[opStart + 1],
                                                   plan.opArg0s[opStart + 1],
                                                   plan.opKinds[opStart + 2],
                                                   plan.opPrimaryTexts[opStart + 2],
                                                   plan.opArg0s[opStart + 2],
                                                   plan.opKinds[opStart + 3],
                                                   plan.opPrimaryTexts[opStart + 3],
                                                   plan.opArg0s[opStart + 3],
                                                   plan.opKinds[opStart + 4],
                                                   plan.opPrimaryTexts[opStart + 4],
                                                   plan.opArg0s[opStart + 4])
    return ""

fn compilerCoreDirectExecSimpleCallWords(plan: cflow.LowUirCompilerCorePlan,
                                         itemIdx: int32,
                                         opStart: int32,
                                         opCount: int32,
                                         targetTriple: str,
                                         architecture: str): str =
    let singleSimpleCallWords = compilerCoreDirectExecSingleSimpleCallWords(plan,
                                                                            itemIdx,
                                                                            opStart,
                                                                            opCount,
                                                                            targetTriple,
                                                                            architecture)
    if len(singleSimpleCallWords) > 0:
        return singleSimpleCallWords
    return compilerCoreDirectExecMultiSimpleCallWords(plan,
                                                      itemIdx,
                                                      opStart,
                                                      opCount,
                                                      targetTriple,
                                                      architecture)

fn compilerCoreDirectExecZeroArgCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                           itemIdx: int32,
                                           opStart: int32,
                                           opCount: int32,
                                           targetTriple: str): str =
    if opCount == 3 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "return_value" &&
       plan.opArg0s[opStart + 1] == 0:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 0)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                    itemIdx: int32,
                                    targetTriple: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if !compilerCoreDirectCallReturnTypeSupported(plan.returnTypeTexts[itemIdx]):
        return ""
    let varStrOutCallSymbol = compilerCoreDirectExecImportcScalarArgsVarStrOutCallSymbol(plan,
                                                                                          itemIdx,
                                                                                          targetTriple)
    if len(varStrOutCallSymbol) > 0:
        return varStrOutCallSymbol
    let paramCStringIfOrReturnCallSymbol = compilerCoreDirectExecParamCStringIfOrReturnCallSymbol(plan,
                                                                                                   itemIdx,
                                                                                                   targetTriple)
    if len(paramCStringIfOrReturnCallSymbol) > 0:
        return paramCStringIfOrReturnCallSymbol
    let paramCStringFourIfReturnCallSymbol = compilerCoreDirectExecParamCStringFourIfReturnCallSymbol(plan,
                                                                                                      itemIdx,
                                                                                                      targetTriple)
    if len(paramCStringFourIfReturnCallSymbol) > 0:
        return paramCStringFourIfReturnCallSymbol
    let paramCStringChainReturnCallSymbol = compilerCoreDirectExecParamCStringChainReturnCallSymbol(plan,
                                                                                                    itemIdx,
                                                                                                    targetTriple)
    if len(paramCStringChainReturnCallSymbol) > 0:
        return paramCStringChainReturnCallSymbol
    let paramCStringChainReturnInt32CallSymbol = compilerCoreDirectExecParamCStringChainReturnInt32CallSymbol(plan,
                                                                                                              itemIdx,
                                                                                                              targetTriple)
    if len(paramCStringChainReturnInt32CallSymbol) > 0:
        return paramCStringChainReturnInt32CallSymbol
    let paramCStringTwoIfOrReturnCallSymbol = compilerCoreDirectExecParamCStringTwoIfOrReturnCallSymbol(plan,
                                                                                                         itemIdx,
                                                                                                         targetTriple)
    if len(paramCStringTwoIfOrReturnCallSymbol) > 0:
        return paramCStringTwoIfOrReturnCallSymbol
    let paramCStringTwoIfReturnCallSymbol = compilerCoreDirectExecParamCStringTwoIfReturnCallSymbol(plan,
                                                                                                     itemIdx,
                                                                                                     targetTriple)
    if len(paramCStringTwoIfReturnCallSymbol) > 0:
        return paramCStringTwoIfReturnCallSymbol
    let fieldCStringIfExprCallSymbol = compilerCoreDirectExecFieldCStringIfExprCallSymbol(plan,
                                                                                          itemIdx,
                                                                                          targetTriple)
    if len(fieldCStringIfExprCallSymbol) > 0:
        return fieldCStringIfExprCallSymbol
    let cstringCallSymbol = compilerCoreDirectExecCStringCallSymbol(plan,
                                                                    itemIdx,
                                                                    opStart,
                                                                    opCount,
                                                                    targetTriple)
    if len(cstringCallSymbol) > 0:
        return cstringCallSymbol
    let compareConstSymbol = compilerCoreDirectExecCallCompareConstSymbol(plan,
                                                                          itemIdx,
                                                                          opStart,
                                                                          opCount,
                                                                          targetTriple)
    if len(compareConstSymbol) > 0:
        return compareConstSymbol
    let zeroArgCallSymbol = compilerCoreDirectExecZeroArgCallSymbol(plan,
                                                                    itemIdx,
                                                                    opStart,
                                                                    opCount,
                                                                    targetTriple)
    if len(zeroArgCallSymbol) > 0:
        return zeroArgCallSymbol
    let fieldCallSymbol = compilerCoreDirectExecFieldCallSymbol(plan,
                                                                itemIdx,
                                                                opStart,
                                                                opCount,
                                                                targetTriple)
    if len(fieldCallSymbol) > 0:
        return fieldCallSymbol
    let aliasCallSymbol = compilerCoreDirectExecAliasCallSymbol(plan,
                                                                itemIdx,
                                                                opStart,
                                                                opCount,
                                                                targetTriple)
    if len(aliasCallSymbol) > 0:
        return aliasCallSymbol
    let simpleCallSymbol = compilerCoreDirectExecSimpleCallSymbol(plan,
                                                                  itemIdx,
                                                                  opStart,
                                                                  opCount,
                                                                  targetTriple)
    if len(simpleCallSymbol) > 0:
        return simpleCallSymbol
    return ""

fn compilerCoreDirectExecImportcScalarArgsVarStrOutCallInfo(plan: cflow.LowUirCompilerCorePlan,
                                                            itemIdx: int32,
                                                            calleeItemIdx: var int32,
                                                            argKinds: var str[],
                                                            argPrimaryTexts: var str[],
                                                            argArg0s: var int32[]): bool =
    calleeItemIdx = -1
    argKinds = []
    argPrimaryTexts = []
    argArg0s = []
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "str"):
        return false
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    for argCount in 0..<5:
        let callIdx = opStart + 3 + argCount
        let dropIdx = callIdx + 1
        let loadIdx = callIdx + 2
        let returnIdx = callIdx + 3
        if opCount != argCount + 7 ||
           plan.opKinds[opStart] != "local_decl" ||
           plan.opKinds[opStart + 1] != "load_routine" ||
           plan.opKinds[callIdx] != "call" ||
           plan.opKinds[dropIdx] != "drop_value" ||
           plan.opKinds[loadIdx] != "load_local" ||
           plan.opKinds[returnIdx] != "return_value" ||
           plan.opArg0s[callIdx] != argCount + 1:
            continue
        let localSlot = plan.opArg0s[opStart]
        if localSlot < 0 ||
           plan.opKinds[opStart + 2 + argCount] != "load_local" ||
           plan.opArg0s[opStart + 2 + argCount] != localSlot ||
           plan.opArg0s[loadIdx] != localSlot:
            continue
        var argsOk: bool = true
        var localArgKinds: str[]
        var localArgPrimaryTexts: str[]
        var localArgArg0s: int32[]
        localArgKinds = []
        localArgPrimaryTexts = []
        localArgArg0s = []
        for i in 0..<argCount:
            let argIdx = opStart + 2 + i
            if !compilerCoreDirectNestedScalarArgSupported(plan, itemIdx, argIdx):
                argsOk = false
            add(localArgKinds, plan.opKinds[argIdx])
            add(localArgPrimaryTexts, plan.opPrimaryTexts[argIdx])
            add(localArgArg0s, plan.opArg0s[argIdx])
        if !argsOk:
            continue
        let localCalleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 1, argCount + 1)
        if localCalleeItemIdx < 0 ||
           plan.topLevelKinds[localCalleeItemIdx] != "importc_fn" ||
           !compilerCoreDirectExecImportcBridgeNeeded(plan, localCalleeItemIdx, true):
            continue
        let outParamTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[localCalleeItemIdx], argCount)
        if !compilerCoreTypeMatches(outParamTypeText, "str"):
            continue
        calleeItemIdx = localCalleeItemIdx
        argKinds = localArgKinds
        argPrimaryTexts = localArgPrimaryTexts
        argArg0s = localArgArg0s
        return true
    return false

fn compilerCoreDirectExecImportcScalarArgsVarStrOutCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                                              itemIdx: int32,
                                                              targetTriple: str): str =
    var calleeItemIdx: int32 = -1
    var argKinds: str[]
    var argPrimaryTexts: str[]
    var argArg0s: int32[]
    argKinds = []
    argPrimaryTexts = []
    argArg0s = []
    if compilerCoreDirectExecImportcScalarArgsVarStrOutCallInfo(plan,
                                                                itemIdx,
                                                                calleeItemIdx,
                                                                argKinds,
                                                                argPrimaryTexts,
                                                                argArg0s):
        return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecImportcScalarArgsVarStrOutCallWords(plan: cflow.LowUirCompilerCorePlan,
                                                             itemIdx: int32,
                                                             architecture: str): str =
    var calleeItemIdx: int32 = -1
    var argKinds: str[]
    var argPrimaryTexts: str[]
    var argArg0s: int32[]
    argKinds = []
    argPrimaryTexts = []
    argArg0s = []
    if compilerCoreDirectExecImportcScalarArgsVarStrOutCallInfo(plan,
                                                                itemIdx,
                                                                calleeItemIdx,
                                                                argKinds,
                                                                argPrimaryTexts,
                                                                argArg0s):
        return machineDirectCallScalarArgsVarStrOutReturnWords(architecture,
                                                               argKinds,
                                                               argPrimaryTexts,
                                                               argArg0s)
    return ""

fn compilerCoreDirectExecImportcBridgeNeeded(plan: cflow.LowUirCompilerCorePlan,
                                             calleeItemIdx: int32,
                                             wantVoid: bool): bool =
    if calleeItemIdx < 0 || plan.topLevelKinds[calleeItemIdx] != "importc_fn":
        return false
    if !wantVoid && compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[calleeItemIdx]) == 2:
        return true
    for i in 0..<plan.paramCounts[calleeItemIdx]:
        if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], i)) == 2:
            return true
    return false

fn compilerCoreDirectExecImportcBridgeWords(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32,
                                            calleeItemIdx: int32,
                                            architecture: str,
                                            argParamIdxs: int32[]): str =
    if !compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
        return ""
    if argParamIdxs.len != plan.paramCounts[calleeItemIdx]:
        return ""
    for i in 0..<argParamIdxs.len:
        if argParamIdxs[i] < 0:
            return ""
    return machineDirectCallImportcBridgeWords(architecture,
                                               plan.signatureTexts[itemIdx],
                                               plan.signatureTexts[calleeItemIdx],
                                               plan.returnTypeTexts[calleeItemIdx],
                                               argParamIdxs)

fn compilerCoreDirectExecImportcBridgeVoidWords(plan: cflow.LowUirCompilerCorePlan,
                                                itemIdx: int32,
                                                calleeItemIdx: int32,
                                                architecture: str,
                                                argParamIdxs: int32[]): str =
    if !compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
        return ""
    if argParamIdxs.len != plan.paramCounts[calleeItemIdx]:
        return ""
    for i in 0..<argParamIdxs.len:
        if argParamIdxs[i] < 0:
            return ""
    return machineDirectCallImportcBridgeVoidWords(architecture,
                                                   plan.signatureTexts[itemIdx],
                                                   plan.signatureTexts[calleeItemIdx],
                                                   argParamIdxs)

fn compilerCoreDirectExecCallWords(plan: cflow.LowUirCompilerCorePlan,
                                   itemIdx: int32,
                                   targetTriple: str,
                                   architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    let varStrOutCallWords = compilerCoreDirectExecImportcScalarArgsVarStrOutCallWords(plan,
                                                                                        itemIdx,
                                                                                        architecture)
    if len(varStrOutCallWords) > 0:
        return varStrOutCallWords
    let paramCStringIfOrReturnWords = compilerCoreDirectExecParamCStringIfOrReturnWords(plan,
                                                                                        itemIdx,
                                                                                        architecture)
    if len(paramCStringIfOrReturnWords) > 0:
        return paramCStringIfOrReturnWords
    let paramCStringFourIfReturnWords = compilerCoreDirectExecParamCStringFourIfReturnWords(plan,
                                                                                            itemIdx,
                                                                                            architecture)
    if len(paramCStringFourIfReturnWords) > 0:
        return paramCStringFourIfReturnWords
    let paramCStringChainReturnWords = compilerCoreDirectExecParamCStringChainReturnWords(plan,
                                                                                          itemIdx,
                                                                                          architecture)
    if len(paramCStringChainReturnWords) > 0:
        return paramCStringChainReturnWords
    let paramCStringChainReturnInt32Words = compilerCoreDirectExecParamCStringChainReturnInt32Words(plan,
                                                                                                     itemIdx,
                                                                                                     architecture)
    if len(paramCStringChainReturnInt32Words) > 0:
        return paramCStringChainReturnInt32Words
    let paramCStringTwoIfOrReturnWords = compilerCoreDirectExecParamCStringTwoIfOrReturnWords(plan,
                                                                                              itemIdx,
                                                                                              architecture)
    if len(paramCStringTwoIfOrReturnWords) > 0:
        return paramCStringTwoIfOrReturnWords
    let paramCStringTwoIfReturnWords = compilerCoreDirectExecParamCStringTwoIfReturnWords(plan,
                                                                                          itemIdx,
                                                                                          architecture)
    if len(paramCStringTwoIfReturnWords) > 0:
        return paramCStringTwoIfReturnWords
    let fieldCStringIfExprWords = compilerCoreDirectExecFieldCStringIfExprWords(plan,
                                                                                itemIdx,
                                                                                architecture)
    if len(fieldCStringIfExprWords) > 0:
        return fieldCStringIfExprWords
    let cstringCallWords = compilerCoreDirectExecCStringCallWords(plan,
                                                                  itemIdx,
                                                                  opStart,
                                                                  opCount,
                                                                  architecture)
    if len(cstringCallWords) > 0:
        return cstringCallWords
    let compareConstWords = compilerCoreDirectExecCallCompareConstWords(plan,
                                                                        itemIdx,
                                                                        opStart,
                                                                        opCount,
                                                                        targetTriple,
                                                                        architecture)
    if len(compareConstWords) > 0:
        return compareConstWords
    let zeroArgCallWords = compilerCoreDirectExecZeroArgCallReturnWordsAt(plan,
                                                                          itemIdx,
                                                                          architecture,
                                                                          opStart,
                                                                          opCount)
    if len(zeroArgCallWords) > 0:
        return zeroArgCallWords
    let fieldCallWords = compilerCoreDirectExecFieldCallWords(plan,
                                                              itemIdx,
                                                              opStart,
                                                              opCount,
                                                              architecture)
    if len(fieldCallWords) > 0:
        return fieldCallWords
    let aliasCallWords = compilerCoreDirectExecAliasCallWords(plan,
                                                              itemIdx,
                                                              opStart,
                                                              opCount,
                                                              architecture)
    if len(aliasCallWords) > 0:
        return aliasCallWords
    let simpleCallWords = compilerCoreDirectExecSimpleCallWords(plan,
                                                                itemIdx,
                                                                opStart,
                                                                opCount,
                                                                targetTriple,
                                                                architecture)
    if len(simpleCallWords) > 0:
        return simpleCallWords
    return ""

fn compilerCoreDirectExecVoidThenConstCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                                 itemIdx: int32,
                                                 targetTriple: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "drop_value" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "return_value" &&
        plan.opArg0s[opStart + 1] == 0:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 0)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    for argCount in 1..<5:
        let callIdx = opStart + 1 + argCount
        let dropIdx = callIdx + 1
        let constIdx = callIdx + 2
        let returnIdx = callIdx + 3
        if opCount != argCount + 5 ||
           plan.opKinds[opStart] != "load_routine" ||
           plan.opKinds[callIdx] != "call" ||
           plan.opKinds[dropIdx] != "drop_value" ||
           !compilerCoreIsDirectConstValueKind(plan.opKinds[constIdx]) ||
           plan.opKinds[returnIdx] != "return_value" ||
           plan.opArg0s[callIdx] != argCount:
            continue
        var argKinds: str[]
        var argPrimaryTexts: str[]
        var argArg0s: int32[]
        argKinds = []
        argPrimaryTexts = []
        argArg0s = []
        var argsOk: bool = true
        for i in 0..<argCount:
            let argIdx = opStart + 1 + i
            if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[argIdx]):
                argsOk = false
            add(argKinds, plan.opKinds[argIdx])
            add(argPrimaryTexts, plan.opPrimaryTexts[argIdx])
            add(argArg0s, plan.opArg0s[argIdx])
        if !argsOk:
            continue
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, argCount)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecVoidThenConstCallWords(plan: cflow.LowUirCompilerCorePlan,
                                                itemIdx: int32,
                                                architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "drop_value" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "return_value" &&
        plan.opArg0s[opStart + 1] == 0:
        return machineDirectCallVoidThenConstWords(architecture,
                                                   plan.opKinds[opStart + 3],
                                                   plan.opPrimaryTexts[opStart + 3],
                                                   plan.opArg0s[opStart + 3])
    for argCount in 1..<5:
        let callIdx = opStart + 1 + argCount
        let dropIdx = callIdx + 1
        let constIdx = callIdx + 2
        let returnIdx = callIdx + 3
        if opCount != argCount + 5 ||
           plan.opKinds[opStart] != "load_routine" ||
           plan.opKinds[callIdx] != "call" ||
           plan.opKinds[dropIdx] != "drop_value" ||
           !compilerCoreIsDirectConstValueKind(plan.opKinds[constIdx]) ||
           plan.opKinds[returnIdx] != "return_value" ||
           plan.opArg0s[callIdx] != argCount:
            continue
        var argKinds: str[]
        var argPrimaryTexts: str[]
        var argArg0s: int32[]
        argKinds = []
        argPrimaryTexts = []
        argArg0s = []
        var argsOk: bool = true
        for i in 0..<argCount:
            let argIdx = opStart + 1 + i
            if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[argIdx]):
                argsOk = false
            add(argKinds, plan.opKinds[argIdx])
            add(argPrimaryTexts, plan.opPrimaryTexts[argIdx])
            add(argArg0s, plan.opArg0s[argIdx])
        if !argsOk:
            continue
        return machineDirectCallSimpleArgsVoidThenConstWords(architecture,
                                                             argKinds,
                                                             argPrimaryTexts,
                                                             argArg0s,
                                                             plan.opKinds[constIdx],
                                                             plan.opPrimaryTexts[constIdx],
                                                             plan.opArg0s[constIdx])
    return ""

fn compilerCoreDirectExecFallbackCallSymbols(plan: cflow.LowUirCompilerCorePlan,
                                             itemIdx: int32,
                                             targetTriple: str): str[] =
    var out: str[]
    out = []
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if !compilerCoreDirectCallReturnTypeSupported(plan.returnTypeTexts[itemIdx]):
        return out
    if opCount < 11 ||
       plan.opKinds[opStart] != "local_decl":
        return out
    let localSlot = plan.opArg0s[opStart]
    let firstArgCount = plan.opArg0s[opStart + 4]
    if firstArgCount < 0 || firstArgCount > 4:
        return out
    let firstCallIdx = opStart + 4
    let firstRoutineIdx = opStart + 1
    if plan.opKinds[firstRoutineIdx] != "load_routine" ||
       plan.opKinds[firstCallIdx] != "call" ||
       plan.opKinds[firstCallIdx + 1] != "store_local" ||
       plan.opArg0s[firstCallIdx + 1] != localSlot ||
       plan.opKinds[firstCallIdx + 2] != "load_local" ||
       plan.opArg0s[firstCallIdx + 2] != localSlot ||
       plan.opKinds[firstCallIdx + 3] != "load_nil" ||
       plan.opKinds[firstCallIdx + 4] != "binary_op" ||
       plan.opPrimaryTexts[firstCallIdx + 4] != "!=" ||
       plan.opKinds[firstCallIdx + 5] != "jump_if_false" ||
       plan.opKinds[firstCallIdx + 6] != "load_local" ||
       plan.opArg0s[firstCallIdx + 6] != localSlot ||
       plan.opKinds[firstCallIdx + 7] != "return_value" ||
       plan.opKinds[firstCallIdx + 8] != "jump" ||
       plan.opKinds[firstCallIdx + 9] != "label":
        return out
    let elseLabel = plan.opPrimaryTexts[firstCallIdx + 5]
    let endLabel = plan.opPrimaryTexts[firstCallIdx + 8]
    if plan.opPrimaryTexts[firstCallIdx + 9] != elseLabel:
        return out
    let secondRoutineIdx = firstCallIdx + 10
    if secondRoutineIdx >= opStart + opCount ||
       plan.opKinds[secondRoutineIdx] != "load_routine":
        return out
    let secondCallIdx = secondRoutineIdx + 1 + firstArgCount
    if secondCallIdx + 2 >= opStart + opCount ||
       plan.opKinds[secondCallIdx] != "call" ||
       plan.opArg0s[secondCallIdx] != firstArgCount ||
       plan.opKinds[secondCallIdx + 1] != "return_value" ||
       plan.opKinds[secondCallIdx + 2] != "label" ||
       plan.opPrimaryTexts[secondCallIdx + 2] != endLabel:
        return out
    for i in 0..<firstArgCount:
        let lhsIdx = firstRoutineIdx + 1 + i
        let rhsIdx = secondRoutineIdx + 1 + i
        if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[lhsIdx]) ||
           plan.opKinds[lhsIdx] != plan.opKinds[rhsIdx] ||
           plan.opPrimaryTexts[lhsIdx] != plan.opPrimaryTexts[rhsIdx] ||
           plan.opArg0s[lhsIdx] != plan.opArg0s[rhsIdx]:
            return out
    let firstCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[firstRoutineIdx])
    let secondCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[secondRoutineIdx])
    if firstCalleeIdx < 0 || secondCalleeIdx < 0:
        return out
    let firstSymbol = compilerCoreDirectExecCalleeSymbol(plan, firstCalleeIdx, targetTriple)
    let secondSymbol = compilerCoreDirectExecCalleeSymbol(plan, secondCalleeIdx, targetTriple)
    if len(firstSymbol) <= 0 || len(secondSymbol) <= 0:
        return out
    add(out, firstSymbol)
    add(out, secondSymbol)
    return out

fn compilerCoreDirectExecFallbackCallWords(plan: cflow.LowUirCompilerCorePlan,
                                           itemIdx: int32,
                                           architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount < 11 || plan.opKinds[opStart] != "local_decl":
        return ""
    let firstArgCount = plan.opArg0s[opStart + 4]
    if firstArgCount < 0 || firstArgCount > 4:
        return ""
    var argKinds: str[]
    var argPrimaryTexts: str[]
    var argArg0s: int32[]
    argKinds = []
    argPrimaryTexts = []
    argArg0s = []
    for i in 0..<firstArgCount:
        let argIdx = opStart + 2 + i
        if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[argIdx]):
            return ""
        add(argKinds, plan.opKinds[argIdx])
        add(argPrimaryTexts, plan.opPrimaryTexts[argIdx])
        add(argArg0s, plan.opArg0s[argIdx])
    return machineDirectFallbackCallWords(architecture, argKinds, argPrimaryTexts, argArg0s)

fn compilerCoreDirectExecVoidNestedCallSymbols(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32,
                                               targetTriple: str): str[] =
    var out: str[]
    out = []
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    for innerArgCount in 0..<5:
        let innerOnlyCallIdx = opStart + 2 + innerArgCount
        let outerOnlyCallIdx = innerOnlyCallIdx + 1
        if opCount == innerArgCount + 6 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerOnlyCallIdx] == "call" &&
           plan.opKinds[outerOnlyCallIdx] == "call" &&
           plan.opKinds[outerOnlyCallIdx + 1] == "drop_value" &&
           plan.opKinds[outerOnlyCallIdx + 2] == "return_void" &&
           plan.opArg0s[innerOnlyCallIdx] == innerArgCount &&
           plan.opArg0s[outerOnlyCallIdx] == 1:
            var argsOkNoOuter: bool = true
            for i in 0..<innerArgCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOkNoOuter = false
            if !argsOkNoOuter:
                continue
            let outerOnlyCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerOnlyCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerOnlyCalleeIdx < 0 || innerOnlyCalleeIdx < 0:
                continue
            if plan.paramCounts[outerOnlyCalleeIdx] != 1:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerOnlyCalleeIdx]) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerOnlyCalleeIdx], 0)) != 1:
                continue
            let innerOnlySymbol = compilerCoreDirectExecCalleeSymbol(plan, innerOnlyCalleeIdx, targetTriple)
            let outerOnlySymbol = compilerCoreDirectExecCalleeSymbol(plan, outerOnlyCalleeIdx, targetTriple)
            if len(innerOnlySymbol) <= 0 || len(outerOnlySymbol) <= 0:
                continue
            add(out, innerOnlySymbol)
            add(out, outerOnlySymbol)
            return out
        for outerLeadingArgCount in 1..<4:
            let innerLeadingRoutineIdx = opStart + 1 + outerLeadingArgCount
            let innerLeadingCallIdx = innerLeadingRoutineIdx + 1 + innerArgCount
            let outerLeadingCallIdx = innerLeadingCallIdx + 1
            if opCount != outerLeadingArgCount + innerArgCount + 6 ||
               plan.opKinds[opStart] != "load_routine" ||
               plan.opKinds[innerLeadingRoutineIdx] != "load_routine" ||
               plan.opKinds[innerLeadingCallIdx] != "call" ||
               plan.opKinds[outerLeadingCallIdx] != "call" ||
               plan.opKinds[outerLeadingCallIdx + 1] != "drop_value" ||
               plan.opKinds[outerLeadingCallIdx + 2] != "return_void" ||
               plan.opArg0s[innerLeadingCallIdx] != innerArgCount ||
               plan.opArg0s[outerLeadingCallIdx] != outerLeadingArgCount + 1:
                continue
            var leadingArgsOk: bool = true
            var outerLeadingArgIdxs: int32[]
            outerLeadingArgIdxs = []
            for i in 0..<outerLeadingArgCount:
                let outerLeadingArgIdx = opStart + 1 + i
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerLeadingArgIdx):
                    leadingArgsOk = false
                add(outerLeadingArgIdxs, outerLeadingArgIdx)
            for i in 0..<innerArgCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, innerLeadingRoutineIdx + 1 + i):
                    leadingArgsOk = false
            if !leadingArgsOk:
                continue
            let outerLeadingCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerLeadingCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[innerLeadingRoutineIdx])
            var innerLeadingReturnWidth: int32 = 0
            if !compilerCoreDirectNestedLeadingArgsMatch(plan,
                                                         itemIdx,
                                                         innerLeadingCalleeIdx,
                                                         outerLeadingCalleeIdx,
                                                         outerLeadingArgIdxs,
                                                         targetTriple,
                                                         innerLeadingReturnWidth) ||
               innerLeadingReturnWidth != 1:
                continue
            let innerLeadingSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerLeadingCalleeIdx, targetTriple)
            let outerLeadingSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerLeadingCalleeIdx, targetTriple)
            if len(innerLeadingSymbol) <= 0 || len(outerLeadingSymbol) <= 0:
                continue
            add(out, innerLeadingSymbol)
            add(out, outerLeadingSymbol)
            return out
        let innerCallIdx = opStart + 2 + innerArgCount
        let outerArgIdx = innerCallIdx + 1
        let outerCallIdx = innerCallIdx + 2
        if opCount != innerArgCount + 7 ||
           plan.opKinds[opStart] != "load_routine" ||
           plan.opKinds[opStart + 1] != "load_routine" ||
           plan.opKinds[innerCallIdx] != "call" ||
           plan.opKinds[outerCallIdx] != "call" ||
           plan.opKinds[outerCallIdx + 1] != "drop_value" ||
           plan.opKinds[outerCallIdx + 2] != "return_void" ||
           plan.opArg0s[innerCallIdx] != innerArgCount ||
           plan.opArg0s[outerCallIdx] != 2:
            continue
        var argsOkWide: bool = compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArgIdx)
        for i in 0..<innerArgCount:
            if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                argsOkWide = false
        if !argsOkWide:
            continue
        let outerWideCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let innerWideCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
        var innerReturnWidth: int32 = 0
        if !compilerCoreDirectNestedTrailingArgsMatch(plan,
                                                      itemIdx,
                                                      innerWideCalleeIdx,
                                                      outerWideCalleeIdx,
                                                      [outerArgIdx],
                                                      targetTriple,
                                                      innerReturnWidth) ||
           innerReturnWidth != 1:
            continue
        let innerWideSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerWideCalleeIdx, targetTriple)
        let outerWideSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerWideCalleeIdx, targetTriple)
        if len(innerWideSymbol) <= 0 || len(outerWideSymbol) <= 0:
            continue
        add(out, innerWideSymbol)
        add(out, outerWideSymbol)
        return out
    return out

fn compilerCoreDirectExecVoidNestedCallWords(plan: cflow.LowUirCompilerCorePlan,
                                             itemIdx: int32,
                                             targetTriple: str): str =
    let architecture = mtarget.machineTargetArchitecture(targetTriple)
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    for innerArgCount in 0..<5:
        let innerOnlyCallIdx = opStart + 2 + innerArgCount
        let outerOnlyCallIdx = innerOnlyCallIdx + 1
        if opCount == innerArgCount + 6 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerOnlyCallIdx] == "call" &&
           plan.opKinds[outerOnlyCallIdx] == "call" &&
           plan.opKinds[outerOnlyCallIdx + 1] == "drop_value" &&
           plan.opKinds[outerOnlyCallIdx + 2] == "return_void" &&
           plan.opArg0s[innerOnlyCallIdx] == innerArgCount &&
           plan.opArg0s[outerOnlyCallIdx] == 1:
            var innerOnlyArgKinds: str[]
            var innerOnlyArgPrimaryTexts: str[]
            var innerOnlyArgArg0s: int32[]
            innerOnlyArgKinds = []
            innerOnlyArgPrimaryTexts = []
            innerOnlyArgArg0s = []
            var argsOkNoOuter: bool = true
            for i in 0..<innerArgCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOkNoOuter = false
                add(innerOnlyArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerOnlyArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerOnlyArgArg0s, plan.opArg0s[opStart + 2 + i])
            if !argsOkNoOuter:
                continue
            return machineDirectNestedCallVoidWords(architecture,
                                                    plan.signatureTexts[itemIdx],
                                                    innerOnlyArgKinds,
                                                    innerOnlyArgPrimaryTexts,
                                                    innerOnlyArgArg0s)
        for outerLeadingArgCount in 1..<4:
            let innerLeadingRoutineIdx = opStart + 1 + outerLeadingArgCount
            let innerLeadingCallIdx = innerLeadingRoutineIdx + 1 + innerArgCount
            let outerLeadingCallIdx = innerLeadingCallIdx + 1
            if opCount != outerLeadingArgCount + innerArgCount + 6 ||
               plan.opKinds[opStart] != "load_routine" ||
               plan.opKinds[innerLeadingRoutineIdx] != "load_routine" ||
               plan.opKinds[innerLeadingCallIdx] != "call" ||
               plan.opKinds[outerLeadingCallIdx] != "call" ||
               plan.opKinds[outerLeadingCallIdx + 1] != "drop_value" ||
               plan.opKinds[outerLeadingCallIdx + 2] != "return_void" ||
               plan.opArg0s[innerLeadingCallIdx] != innerArgCount ||
               plan.opArg0s[outerLeadingCallIdx] != outerLeadingArgCount + 1:
                continue
            var outerLeadingArgKinds: str[]
            var outerLeadingArgPrimaryTexts: str[]
            var outerLeadingArgArg0s: int32[]
            var innerLeadingArgKinds: str[]
            var innerLeadingArgPrimaryTexts: str[]
            var innerLeadingArgArg0s: int32[]
            var outerLeadingArgIdxs: int32[]
            outerLeadingArgKinds = []
            outerLeadingArgPrimaryTexts = []
            outerLeadingArgArg0s = []
            innerLeadingArgKinds = []
            innerLeadingArgPrimaryTexts = []
            innerLeadingArgArg0s = []
            outerLeadingArgIdxs = []
            var leadingArgsOk: bool = true
            for i in 0..<outerLeadingArgCount:
                let outerLeadingArgIdx = opStart + 1 + i
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerLeadingArgIdx):
                    leadingArgsOk = false
                add(outerLeadingArgKinds, plan.opKinds[outerLeadingArgIdx])
                add(outerLeadingArgPrimaryTexts, plan.opPrimaryTexts[outerLeadingArgIdx])
                add(outerLeadingArgArg0s, plan.opArg0s[outerLeadingArgIdx])
                add(outerLeadingArgIdxs, outerLeadingArgIdx)
            for i in 0..<innerArgCount:
                let innerLeadingArgIdx = innerLeadingRoutineIdx + 1 + i
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, innerLeadingArgIdx):
                    leadingArgsOk = false
                add(innerLeadingArgKinds, plan.opKinds[innerLeadingArgIdx])
                add(innerLeadingArgPrimaryTexts, plan.opPrimaryTexts[innerLeadingArgIdx])
                add(innerLeadingArgArg0s, plan.opArg0s[innerLeadingArgIdx])
            let outerLeadingCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerLeadingCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[innerLeadingRoutineIdx])
            var innerLeadingReturnWidth: int32 = 0
            if leadingArgsOk &&
               compilerCoreDirectNestedLeadingArgsMatch(plan,
                                                        itemIdx,
                                                        innerLeadingCalleeIdx,
                                                        outerLeadingCalleeIdx,
                                                        outerLeadingArgIdxs,
                                                        targetTriple,
                                                        innerLeadingReturnWidth) &&
               innerLeadingReturnWidth == 1:
                return machineDirectNestedCallLeadingArgsVoidWords(architecture,
                                                                   plan.signatureTexts[itemIdx],
                                                                   outerLeadingArgKinds,
                                                                   outerLeadingArgPrimaryTexts,
                                                                   outerLeadingArgArg0s,
                                                                   innerLeadingArgKinds,
                                                                   innerLeadingArgPrimaryTexts,
                                                                   innerLeadingArgArg0s)
        let innerCallIdx = opStart + 2 + innerArgCount
        let outerArgIdx = innerCallIdx + 1
        let outerCallIdx = innerCallIdx + 2
        if opCount != innerArgCount + 7 ||
           plan.opKinds[opStart] != "load_routine" ||
           plan.opKinds[opStart + 1] != "load_routine" ||
           plan.opKinds[innerCallIdx] != "call" ||
           plan.opKinds[outerCallIdx] != "call" ||
           plan.opKinds[outerCallIdx + 1] != "drop_value" ||
           plan.opKinds[outerCallIdx + 2] != "return_void" ||
           plan.opArg0s[innerCallIdx] != innerArgCount ||
           plan.opArg0s[outerCallIdx] != 2:
            continue
        var innerArgKinds: str[]
        var innerArgPrimaryTexts: str[]
        var innerArgArg0s: int32[]
        innerArgKinds = []
        innerArgPrimaryTexts = []
        innerArgArg0s = []
        var argsOk: bool = true
        for i in 0..<innerArgCount:
            if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                argsOk = false
            add(innerArgKinds, plan.opKinds[opStart + 2 + i])
            add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
            add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
        if argsOk &&
           compilerCoreDirectNestedScalarArgSupported(plan, itemIdx, outerArgIdx):
            return machineDirectNestedCallTrailingSimpleArgVoidWords(architecture,
                                                                     plan.signatureTexts[itemIdx],
                                                                     innerArgKinds,
                                                                     innerArgPrimaryTexts,
                                                                     innerArgArg0s,
                                                                     plan.opKinds[outerArgIdx],
                                                                     plan.opPrimaryTexts[outerArgIdx],
                                                                     plan.opArg0s[outerArgIdx])
        var argsOkWide: bool = compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArgIdx)
        for i in 0..<innerArgCount:
            if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                argsOkWide = false
        let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
        var innerReturnWidth: int32 = 0
        if argsOkWide &&
           compilerCoreDirectNestedTrailingArgsMatch(plan,
                                                     itemIdx,
                                                     innerCalleeIdx,
                                                     outerCalleeIdx,
                                                     [outerArgIdx],
                                                     targetTriple,
                                                     innerReturnWidth) &&
           innerReturnWidth == 1:
            return machineDirectNestedCallTrailingArgsVoidWords(architecture,
                                                                plan.signatureTexts[itemIdx],
                                                                innerArgKinds,
                                                                innerArgPrimaryTexts,
                                                                innerArgArg0s,
                                                                innerReturnWidth,
                                                                [plan.opKinds[outerArgIdx]],
                                                                [plan.opPrimaryTexts[outerArgIdx]],
                                                                [plan.opArg0s[outerArgIdx]])
    return ""

fn compilerCoreMatchDirectExecVoidNilGuardCurrentParamCall(plan: cflow.LowUirCompilerCorePlan,
                                                           itemIdx: int32,
                                                           guardParamIdx: var int32,
                                                           callLoadRoutineIdx: var int32,
                                                           argParamIdxs: var int32[]): bool =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    let argCount = opCount - 9
    if argCount < 1 || argCount > 4:
        return false
    let callIdx = opStart + 7 + argCount
    if plan.opKinds[opStart] != "load_param" ||
       plan.opKinds[opStart + 1] != "load_nil" ||
       plan.opKinds[opStart + 2] != "binary_op" ||
       plan.opPrimaryTexts[opStart + 2] != "==" ||
       plan.opKinds[opStart + 3] != "jump_if_false" ||
       plan.opKinds[opStart + 4] != "return_void" ||
       plan.opKinds[opStart + 5] != "label" ||
       plan.opPrimaryTexts[opStart + 3] != plan.opPrimaryTexts[opStart + 5] ||
       plan.opKinds[opStart + 6] != "load_routine" ||
       plan.opKinds[callIdx] != "call" ||
       plan.opKinds[callIdx + 1] != "drop_value" ||
       plan.opArg0s[callIdx] != argCount:
        return false
    guardParamIdx = plan.opArg0s[opStart]
    let guardTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], guardParamIdx)
    if compilerCoreDirectTypeRegWidth(guardTypeText) != 1:
        return false
    callLoadRoutineIdx = opStart + 6
    argParamIdxs = []
    for i in 0..<argCount:
        let argIdx = opStart + 7 + i
        if plan.opKinds[argIdx] != "load_param":
            return false
        add(argParamIdxs, plan.opArg0s[argIdx])
    return compilerCoreDirectExecCallItemIndex(plan, itemIdx, callLoadRoutineIdx, argCount) >= 0

fn compilerCoreDirectExecSimpleVoidCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                              itemIdx: int32,
                                              opStart: int32,
                                              opCount: int32,
                                              targetTriple: str): str =
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "drop_value" &&
       plan.opKinds[opStart + 4] == "return_void" &&
       plan.opArg0s[opStart + 2] == 1:
        var calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        let importcDirect = calleeItemIdx >= 0 && plan.topLevelKinds[calleeItemIdx] == "importc_fn"
        if plan.opKinds[opStart + 1] == "load_param" &&
           !importcDirect &&
           (calleeItemIdx < 0 || !compilerCoreHasDirectExecBody(plan, calleeItemIdx, targetTriple)):
            calleeItemIdx = compilerCoreFindUniqueDirectBodyPlanItemIndexByLabel(plan,
                                                                                 itemIdx,
                                                                                 plan.opPrimaryTexts[opStart],
                                                                                 1,
                                                                                 targetTriple)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opKinds[opStart + 2] == "load_field" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "drop_value" &&
       plan.opKinds[opStart + 5] == "return_void" &&
       plan.opArg0s[opStart + 3] == 1:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0:
            var sourceReg: int32 = -1
            var is64: bool = false
            if compilerCoreDirectParamScalarFieldArgBinding(plan.signatureTexts[itemIdx],
                                                            0,
                                                            plan.opPrimaryTexts[opStart + 2],
                                                            compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0),
                                                            sourceReg,
                                                            is64):
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "drop_value" &&
       plan.opKinds[opStart + 5] == "return_void" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 7 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "drop_value" &&
       plan.opKinds[opStart + 6] == "return_void" &&
       plan.opArg0s[opStart + 4] == 3:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 8 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 4]) &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "drop_value" &&
       plan.opKinds[opStart + 7] == "return_void" &&
       plan.opArg0s[opStart + 5] == 4:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 8 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "drop_value" &&
       plan.opKinds[opStart + 7] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 5] == 1:
        var resolvedKind: str = ""
        var resolvedPrimaryText: str = ""
        var resolvedArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            resolvedKind,
                                            resolvedPrimaryText,
                                            resolvedArg0):
            let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 9 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "drop_value" &&
       plan.opKinds[opStart + 8] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 6] == 2:
        var lhsKind: str = ""
        var lhsPrimaryText: str = ""
        var lhsArg0: int32 = -1
        var rhsKind: str = ""
        var rhsPrimaryText: str = ""
        var rhsArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            lhsKind,
                                            lhsPrimaryText,
                                            lhsArg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            rhsKind,
                                            rhsPrimaryText,
                                            rhsArg0):
            let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 10 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 7] == "call" &&
       plan.opKinds[opStart + 8] == "drop_value" &&
       plan.opKinds[opStart + 9] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 7] == 3:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0):
            let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 11 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 8] == "call" &&
       plan.opKinds[opStart + 9] == "drop_value" &&
       plan.opKinds[opStart + 10] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 8] == 4:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        var arg3Kind: str = ""
        var arg3PrimaryText: str = ""
        var arg3Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 7,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg3Kind,
                                            arg3PrimaryText,
                                            arg3Arg0):
            let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecSimpleVoidCallWords(plan: cflow.LowUirCompilerCorePlan,
                                             itemIdx: int32,
                                             opStart: int32,
                                             opCount: int32,
                                             architecture: str): str =
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "drop_value" &&
       plan.opKinds[opStart + 4] == "return_void" &&
       plan.opArg0s[opStart + 2] == 1:
        var calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        let importcDirect = calleeItemIdx >= 0 && plan.topLevelKinds[calleeItemIdx] == "importc_fn"
        if !importcDirect &&
           (calleeItemIdx < 0 ||
            !plan.executableAstReady[calleeItemIdx] ||
            (plan.canonicalOps[calleeItemIdx] != "compiler_fn_exec" &&
             plan.canonicalOps[calleeItemIdx] != "compiler_iterator_exec") ||
            len(compilerCoreDirectExecWords(plan, calleeItemIdx, architecture)) <= 0):
            var matchIdx: int32 = -1
            var matchCount: int32 = 0
            let baseName = plan.opPrimaryTexts[opStart]
            for i in 0..<plan.itemIds.len:
                if i == itemIdx || plan.labels[i] != baseName:
                    continue
                let topLevelKind = plan.topLevelKinds[i]
                if topLevelKind != "fn" && topLevelKind != "iterator":
                    continue
                if plan.paramCounts[i] != 1 ||
                   !plan.executableAstReady[i] ||
                   (plan.canonicalOps[i] != "compiler_fn_exec" &&
                    plan.canonicalOps[i] != "compiler_iterator_exec"):
                    continue
                if len(compilerCoreDirectExecWords(plan, i, architecture)) <= 0:
                    continue
                matchIdx = i
                matchCount = matchCount + 1
                if matchCount > 1:
                    matchIdx = -1
                    break
            calleeItemIdx = matchCount == 1 ? matchIdx else: -1
        if calleeItemIdx < 0:
            return ""
        let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                        itemIdx,
                                                                        calleeItemIdx,
                                                                        architecture,
                                                                        [plan.opArg0s[opStart + 1]])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return ""
        return machineDirectCallParamArgsVoidWords(architecture,
                                                   plan.signatureTexts[itemIdx],
                                                   [plan.opArg0s[opStart + 1]])
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "load_param" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "drop_value" &&
       plan.opKinds[opStart + 5] == "return_void" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                        itemIdx,
                                                                        calleeItemIdx,
                                                                        architecture,
                                                                        [plan.opArg0s[opStart + 1],
                                                                         plan.opArg0s[opStart + 2]])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return ""
        return machineDirectCallParamArgsVoidWords(architecture,
                                                   plan.signatureTexts[itemIdx],
                                                   [plan.opArg0s[opStart + 1],
                                                    plan.opArg0s[opStart + 2]])
    if opCount == 7 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "load_param" &&
       plan.opKinds[opStart + 3] == "load_param" &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "drop_value" &&
       plan.opKinds[opStart + 6] == "return_void" &&
       plan.opArg0s[opStart + 4] == 3:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 3)
        let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                        itemIdx,
                                                                        calleeItemIdx,
                                                                        architecture,
                                                                        [plan.opArg0s[opStart + 1],
                                                                         plan.opArg0s[opStart + 2],
                                                                         plan.opArg0s[opStart + 3]])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return ""
        return machineDirectCallParamArgsVoidWords(architecture,
                                                   plan.signatureTexts[itemIdx],
                                                   [plan.opArg0s[opStart + 1],
                                                    plan.opArg0s[opStart + 2],
                                                    plan.opArg0s[opStart + 3]])
    if opCount == 8 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "load_param" &&
       plan.opKinds[opStart + 3] == "load_param" &&
       plan.opKinds[opStart + 4] == "load_param" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "drop_value" &&
       plan.opKinds[opStart + 7] == "return_void" &&
       plan.opArg0s[opStart + 5] == 4:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 4)
        let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                        itemIdx,
                                                                        calleeItemIdx,
                                                                        architecture,
                                                                        [plan.opArg0s[opStart + 1],
                                                                         plan.opArg0s[opStart + 2],
                                                                         plan.opArg0s[opStart + 3],
                                                                         plan.opArg0s[opStart + 4]])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return ""
        return machineDirectCallParamArgsVoidWords(architecture,
                                                   plan.signatureTexts[itemIdx],
                                                   [plan.opArg0s[opStart + 1],
                                                    plan.opArg0s[opStart + 2],
                                                    plan.opArg0s[opStart + 3],
                                                    plan.opArg0s[opStart + 4]])
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "drop_value" &&
       plan.opKinds[opStart + 4] == "return_void" &&
       plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                        itemIdx,
                                                                        calleeItemIdx,
                                                                        architecture,
                                                                        [plan.opKinds[opStart + 1] == "load_param" ? plan.opArg0s[opStart + 1] else: -1])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return ""
        return machineDirectCallSimpleArgVoidWords(architecture,
                                                   plan.opKinds[opStart + 1],
                                                   plan.opPrimaryTexts[opStart + 1],
                                                   plan.opArg0s[opStart + 1])
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opKinds[opStart + 2] == "load_field" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "drop_value" &&
       plan.opKinds[opStart + 5] == "return_void" &&
       plan.opArg0s[opStart + 3] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        if calleeItemIdx < 0:
            return ""
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return ""
        var sourceReg: int32 = -1
        var is64: bool = false
        if compilerCoreDirectParamScalarFieldArgBinding(plan.signatureTexts[itemIdx],
                                                        0,
                                                        plan.opPrimaryTexts[opStart + 2],
                                                        compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0),
                                                        sourceReg,
                                                        is64):
            return machineDirectCallRegisterArgVoidWords(architecture, sourceReg, is64)
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "drop_value" &&
       plan.opKinds[opStart + 5] == "return_void" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                        itemIdx,
                                                                        calleeItemIdx,
                                                                        architecture,
                                                                        [plan.opKinds[opStart + 1] == "load_param" ? plan.opArg0s[opStart + 1] else: -1,
                                                                         plan.opKinds[opStart + 2] == "load_param" ? plan.opArg0s[opStart + 2] else: -1])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return ""
        return machineDirectCallTwoSimpleArgVoidWords(architecture,
                                                      plan.opKinds[opStart + 1],
                                                      plan.opPrimaryTexts[opStart + 1],
                                                      plan.opArg0s[opStart + 1],
                                                      plan.opKinds[opStart + 2],
                                                      plan.opPrimaryTexts[opStart + 2],
                                                      plan.opArg0s[opStart + 2])
    if opCount == 7 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "drop_value" &&
       plan.opKinds[opStart + 6] == "return_void" &&
       plan.opArg0s[opStart + 4] == 3:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 3)
        let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                        itemIdx,
                                                                        calleeItemIdx,
                                                                        architecture,
                                                                        [plan.opKinds[opStart + 1] == "load_param" ? plan.opArg0s[opStart + 1] else: -1,
                                                                         plan.opKinds[opStart + 2] == "load_param" ? plan.opArg0s[opStart + 2] else: -1,
                                                                         plan.opKinds[opStart + 3] == "load_param" ? plan.opArg0s[opStart + 3] else: -1])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return ""
        return machineDirectCallThreeSimpleArgVoidWords(architecture,
                                                        plan.opKinds[opStart + 1],
                                                        plan.opPrimaryTexts[opStart + 1],
                                                        plan.opArg0s[opStart + 1],
                                                        plan.opKinds[opStart + 2],
                                                        plan.opPrimaryTexts[opStart + 2],
                                                        plan.opArg0s[opStart + 2],
                                                        plan.opKinds[opStart + 3],
                                                        plan.opPrimaryTexts[opStart + 3],
                                                        plan.opArg0s[opStart + 3])
    if opCount == 8 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 4]) &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "drop_value" &&
       plan.opKinds[opStart + 7] == "return_void" &&
       plan.opArg0s[opStart + 5] == 4:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 4)
        let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                        itemIdx,
                                                                        calleeItemIdx,
                                                                        architecture,
                                                                        [plan.opKinds[opStart + 1] == "load_param" ? plan.opArg0s[opStart + 1] else: -1,
                                                                         plan.opKinds[opStart + 2] == "load_param" ? plan.opArg0s[opStart + 2] else: -1,
                                                                         plan.opKinds[opStart + 3] == "load_param" ? plan.opArg0s[opStart + 3] else: -1,
                                                                         plan.opKinds[opStart + 4] == "load_param" ? plan.opArg0s[opStart + 4] else: -1])
        if len(importcWords) > 0:
            return importcWords
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return ""
        return machineDirectCallFourSimpleArgVoidWords(architecture,
                                                       plan.opKinds[opStart + 1],
                                                       plan.opPrimaryTexts[opStart + 1],
                                                       plan.opArg0s[opStart + 1],
                                                       plan.opKinds[opStart + 2],
                                                       plan.opPrimaryTexts[opStart + 2],
                                                       plan.opArg0s[opStart + 2],
                                                       plan.opKinds[opStart + 3],
                                                       plan.opPrimaryTexts[opStart + 3],
                                                       plan.opArg0s[opStart + 3],
                                                       plan.opKinds[opStart + 4],
                                                       plan.opPrimaryTexts[opStart + 4],
                                                       plan.opArg0s[opStart + 4])
    return ""

fn compilerCoreDirectExecZeroArgVoidCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32,
                                               opStart: int32,
                                               opCount: int32,
                                               targetTriple: str): str =
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "drop_value" &&
       plan.opKinds[opStart + 3] == "return_void" &&
       plan.opArg0s[opStart + 1] == 0:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecZeroArgVoidCallWords(plan: cflow.LowUirCompilerCorePlan,
                                              itemIdx: int32,
                                              opStart: int32,
                                              opCount: int32,
                                              architecture: str): str =
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "drop_value" &&
       plan.opKinds[opStart + 3] == "return_void" &&
       plan.opArg0s[opStart + 1] == 0:
        return machineDirectCallVoidWords(architecture)
    return ""

fn compilerCoreDirectExecVoidCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                        itemIdx: int32,
                                        targetTriple: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    var guardParamIdx: int32 = -1
    var callLoadRoutineIdx: int32 = -1
    var guardArgParamIdxs: int32[]
    guardArgParamIdxs = []
    if compilerCoreMatchDirectExecVoidNilGuardCurrentParamCall(plan,
                                                               itemIdx,
                                                               guardParamIdx,
                                                               callLoadRoutineIdx,
                                                               guardArgParamIdxs):
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan,
                                                                itemIdx,
                                                                callLoadRoutineIdx,
                                                                guardArgParamIdxs.len)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "drop_value" &&
       plan.opKinds[opStart + 4] == "return_void" &&
       plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0 &&
           compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0), "str"):
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    let zeroArgVoidCallSymbol = compilerCoreDirectExecZeroArgVoidCallSymbol(plan,
                                                                            itemIdx,
                                                                            opStart,
                                                                            opCount,
                                                                            targetTriple)
    if len(zeroArgVoidCallSymbol) > 0:
        return zeroArgVoidCallSymbol
    let simpleVoidCallSymbol = compilerCoreDirectExecSimpleVoidCallSymbol(plan,
                                                                          itemIdx,
                                                                          opStart,
                                                                          opCount,
                                                                          targetTriple)
    if len(simpleVoidCallSymbol) > 0:
        return simpleVoidCallSymbol
    if opCount >= 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + opCount - 3] == "call" &&
       plan.opKinds[opStart + opCount - 2] == "drop_value" &&
       plan.opKinds[opStart + opCount - 1] == "return_void":
        let callIdx = opStart + opCount - 3
        let argCount = plan.opArg0s[callIdx]
        var argKinds: str[]
        var argPrimaryTexts: str[]
        var argArg0s: int32[]
        var sawIdentityCast: bool = false
        if argCount >= 1 &&
           argCount <= 4 &&
           compilerCoreMatchDirectIdentityScalarCallArgs(plan,
                                                         itemIdx,
                                                         opStart + 1,
                                                         callIdx,
                                                         argCount,
                                                         argKinds,
                                                         argPrimaryTexts,
                                                         argArg0s,
                                                         sawIdentityCast) &&
           sawIdentityCast:
            let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, argCount)
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecVoidCallWords(plan: cflow.LowUirCompilerCorePlan,
                                       itemIdx: int32,
                                       architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    var guardParamIdx: int32 = -1
    var callLoadRoutineIdx: int32 = -1
    var guardArgParamIdxs: int32[]
    guardArgParamIdxs = []
    let cstringPayload = compilerCoreDirectExecVoidCallCStringPayloadText(plan, itemIdx)
    if len(cstringPayload) > 0:
        return machineDirectCallCStringArgVoidWords(architecture, len(cstringPayload))
    if compilerCoreMatchDirectExecVoidNilGuardCurrentParamCall(plan,
                                                               itemIdx,
                                                               guardParamIdx,
                                                               callLoadRoutineIdx,
                                                               guardArgParamIdxs):
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan,
                                                                itemIdx,
                                                                callLoadRoutineIdx,
                                                                guardArgParamIdxs.len)
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return machineDirectIfParamNilReturnElseCallImportcBridgeVoidWords(architecture,
                                                                               plan.signatureTexts[itemIdx],
                                                                               plan.signatureTexts[calleeItemIdx],
                                                                               guardParamIdx,
                                                                               guardArgParamIdxs)
        return machineDirectIfParamNilReturnElseCallParamArgsVoidWords(architecture,
                                                                       plan.signatureTexts[itemIdx],
                                                                       guardParamIdx,
                                                                       guardArgParamIdxs)
    let zeroArgVoidCallWords = compilerCoreDirectExecZeroArgVoidCallWords(plan,
                                                                          itemIdx,
                                                                          opStart,
                                                                          opCount,
                                                                          architecture)
    if len(zeroArgVoidCallWords) > 0:
        return zeroArgVoidCallWords
    let simpleVoidCallWords = compilerCoreDirectExecSimpleVoidCallWords(plan,
                                                                        itemIdx,
                                                                        opStart,
                                                                        opCount,
                                                                        architecture)
    if len(simpleVoidCallWords) > 0:
        return simpleVoidCallWords
    if opCount >= 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + opCount - 3] == "call" &&
       plan.opKinds[opStart + opCount - 2] == "drop_value" &&
       plan.opKinds[opStart + opCount - 1] == "return_void":
        let callIdx = opStart + opCount - 3
        let argCount = plan.opArg0s[callIdx]
        var argKinds: str[]
        var argPrimaryTexts: str[]
        var argArg0s: int32[]
        var sawIdentityCast: bool = false
        if argCount >= 1 &&
           argCount <= 4 &&
           compilerCoreMatchDirectIdentityScalarCallArgs(plan,
                                                         itemIdx,
                                                         opStart + 1,
                                                         callIdx,
                                                         argCount,
                                                         argKinds,
                                                         argPrimaryTexts,
                                                         argArg0s,
                                                         sawIdentityCast) &&
           sawIdentityCast:
            let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, argCount)
            var importcArgParamIdxs: int32[]
            var allParams: bool = true
            var allWidth1Simple: bool = true
            importcArgParamIdxs = []
            for i in 0..<argKinds.len:
                if argKinds[i] == "load_param":
                    add(importcArgParamIdxs, argArg0s[i])
                    if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx],
                                                                                         argArg0s[i])) != 1:
                        allWidth1Simple = false
                else:
                    add(importcArgParamIdxs, -1)
                    allParams = false
                    if !compilerCoreIsDirectConstValueKind(argKinds[i]):
                        allWidth1Simple = false
            let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                            itemIdx,
                                                                            calleeItemIdx,
                                                                            architecture,
                                                                            importcArgParamIdxs)
            if len(importcWords) > 0:
                return importcWords
            if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
                return ""
            if allParams:
                return machineDirectCallParamArgsVoidWords(architecture,
                                                           plan.signatureTexts[itemIdx],
                                                           argArg0s)
            if !allWidth1Simple:
                return ""
            if argCount == 1:
                return machineDirectCallSimpleArgVoidWords(architecture,
                                                           argKinds[0],
                                                           argPrimaryTexts[0],
                                                           argArg0s[0])
            if argCount == 2:
                return machineDirectCallTwoSimpleArgVoidWords(architecture,
                                                              argKinds[0],
                                                              argPrimaryTexts[0],
                                                              argArg0s[0],
                                                              argKinds[1],
                                                              argPrimaryTexts[1],
                                                              argArg0s[1])
            if argCount == 3:
                return machineDirectCallThreeSimpleArgVoidWords(architecture,
                                                                argKinds[0],
                                                                argPrimaryTexts[0],
                                                                argArg0s[0],
                                                                argKinds[1],
                                                                argPrimaryTexts[1],
                                                                argArg0s[1],
                                                                argKinds[2],
                                                                argPrimaryTexts[2],
                                                                argArg0s[2])
            if argCount == 4:
                return machineDirectCallFourSimpleArgVoidWords(architecture,
                                                               argKinds[0],
                                                               argPrimaryTexts[0],
                                                               argArg0s[0],
                                                               argKinds[1],
                                                               argPrimaryTexts[1],
                                                               argArg0s[1],
                                                               argKinds[2],
                                                               argPrimaryTexts[2],
                                                               argArg0s[2],
                                                               argKinds[3],
                                                               argPrimaryTexts[3],
                                                               argArg0s[3])
    if opCount == 8 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "drop_value" &&
       plan.opKinds[opStart + 7] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 5] == 1:
        var resolvedKind: str = ""
        var resolvedPrimaryText: str = ""
        var resolvedArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            resolvedKind,
                                            resolvedPrimaryText,
                                            resolvedArg0):
            let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 3, 1)
            let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                            itemIdx,
                                                                            calleeItemIdx,
                                                                            architecture,
                                                                            [resolvedKind == "load_param" ? resolvedArg0 else: -1])
            if len(importcWords) > 0:
                return importcWords
            if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
                return ""
            return machineDirectCallSimpleArgVoidWords(architecture,
                                                       resolvedKind,
                                                       resolvedPrimaryText,
                                                       resolvedArg0)
    if opCount == 9 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "drop_value" &&
       plan.opKinds[opStart + 8] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 6] == 2:
        var lhsKind: str = ""
        var lhsPrimaryText: str = ""
        var lhsArg0: int32 = -1
        var rhsKind: str = ""
        var rhsPrimaryText: str = ""
        var rhsArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            lhsKind,
                                            lhsPrimaryText,
                                            lhsArg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            rhsKind,
                                            rhsPrimaryText,
                                            rhsArg0):
            let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 3, 2)
            let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                            itemIdx,
                                                                            calleeItemIdx,
                                                                            architecture,
                                                                            [lhsKind == "load_param" ? lhsArg0 else: -1,
                                                                             rhsKind == "load_param" ? rhsArg0 else: -1])
            if len(importcWords) > 0:
                return importcWords
            if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
                return ""
            return machineDirectCallTwoSimpleArgVoidWords(architecture,
                                                          lhsKind,
                                                          lhsPrimaryText,
                                                          lhsArg0,
                                                          rhsKind,
                                                          rhsPrimaryText,
                                                          rhsArg0)
    if opCount == 10 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 7] == "call" &&
       plan.opKinds[opStart + 8] == "drop_value" &&
       plan.opKinds[opStart + 9] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 7] == 3:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0):
            let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 3, 3)
            let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                            itemIdx,
                                                                            calleeItemIdx,
                                                                            architecture,
                                                                            [arg0Kind == "load_param" ? arg0Arg0 else: -1,
                                                                             arg1Kind == "load_param" ? arg1Arg0 else: -1,
                                                                             arg2Kind == "load_param" ? arg2Arg0 else: -1])
            if len(importcWords) > 0:
                return importcWords
            if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
                return ""
            return machineDirectCallThreeSimpleArgVoidWords(architecture,
                                                            arg0Kind,
                                                            arg0PrimaryText,
                                                            arg0Arg0,
                                                            arg1Kind,
                                                            arg1PrimaryText,
                                                            arg1Arg0,
                                                            arg2Kind,
                                                            arg2PrimaryText,
                                                            arg2Arg0)
    if opCount == 11 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 8] == "call" &&
       plan.opKinds[opStart + 9] == "drop_value" &&
       plan.opKinds[opStart + 10] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 8] == 4:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        var arg3Kind: str = ""
        var arg3PrimaryText: str = ""
        var arg3Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 7,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg3Kind,
                                            arg3PrimaryText,
                                            arg3Arg0):
            let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 3, 4)
            let importcWords = compilerCoreDirectExecImportcBridgeVoidWords(plan,
                                                                            itemIdx,
                                                                            calleeItemIdx,
                                                                            architecture,
                                                                            [arg0Kind == "load_param" ? arg0Arg0 else: -1,
                                                                             arg1Kind == "load_param" ? arg1Arg0 else: -1,
                                                                             arg2Kind == "load_param" ? arg2Arg0 else: -1,
                                                                             arg3Kind == "load_param" ? arg3Arg0 else: -1])
            if len(importcWords) > 0:
                return importcWords
            if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
                return ""
            return machineDirectCallFourSimpleArgVoidWords(architecture,
                                                           arg0Kind,
                                                           arg0PrimaryText,
                                                           arg0Arg0,
                                                           arg1Kind,
                                                           arg1PrimaryText,
                                                           arg1Arg0,
                                                           arg2Kind,
                                                           arg2PrimaryText,
                                                           arg2Arg0,
                                                           arg3Kind,
                                                           arg3PrimaryText,
                                                           arg3Arg0)
    return ""

fn appendMachineFunction(out: var MachineModuleBundle,
                         itemId: int32,
                         opName: str,
                         runtimeTarget: str,
                         bindingSummary: str,
                         logicalFrameSize: int32) =
    let symbolName = machineFunctionSymbolName(out.targetTriple, out.moduleKind, opName, itemId)
    let callSymbol = machineCallSymbolName(out.targetTriple, runtimeTarget)
    let words = machineStubWords(out.architecture)
    let functionRelocStart = out.relocOffsets.len
    add(out.itemIds, itemId)
    add(out.symbolNames, symbolName)
    add(out.runtimeTargets, runtimeTarget)
    add(out.callSymbolNames, callSymbol)
    add(out.frameSizes, alignedSize(logicalFrameSize, out.stackAlignBytes))
    add(out.stackAligns, out.stackAlignBytes)
    add(out.argRegs, machineArgRegs(out.architecture))
    add(out.scratchRegs, machineScratchRegs(out.architecture))
    add(out.calleeSavedRegs, machineCalleeSavedRegs(out.architecture))
    add(out.bindingSummaries, bindingSummary)
    add(out.instructionWordHex, words)
    add(out.functionByteSizes, wordCount(words) * 4)
    add(out.localPayloadPageRelocOffsets, 8)
    add(out.localPayloadPageoffRelocOffsets, 12)
    add(out.callRelocOffsets, 16)
    add(out.metadataOperandModes, "local_payload")
    let payloadText = "runtime=" + runtimeTarget + "|bindings=" + bindingSummary
    add(out.localPayloadTexts, payloadText)
    let metadataSymbol = symbolName + "_meta"
    appendMachineRelocation(out,
                            8,
                            metadataSymbol,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            12,
                            metadataSymbol,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            16,
                            callSymbol,
                            out.callRelocationKind)
    add(out.functionRelocStarts, functionRelocStart)
    add(out.functionRelocCounts, out.relocOffsets.len - functionRelocStart)

fn appendMachineDispatchEntryFunction(out: var MachineModuleBundle,
                                      itemId: int32,
                                      opName: str,
                                      runtimeTarget: str,
                                      bindingSummary: str,
                                      logicalFrameSize: int32) =
    let symbolName = machineFunctionSymbolName(out.targetTriple, out.moduleKind, opName, itemId)
    let callSymbol = machineCallSymbolName(out.targetTriple, runtimeTarget)
    let words = machineDispatchEntryWords(out.architecture)
    let functionRelocStart = out.relocOffsets.len
    add(out.itemIds, itemId)
    add(out.symbolNames, symbolName)
    add(out.runtimeTargets, runtimeTarget)
    add(out.callSymbolNames, callSymbol)
    add(out.frameSizes, alignedSize(logicalFrameSize, out.stackAlignBytes))
    add(out.stackAligns, out.stackAlignBytes)
    add(out.argRegs, machineArgRegs(out.architecture))
    add(out.scratchRegs, machineScratchRegs(out.architecture))
    add(out.calleeSavedRegs, machineCalleeSavedRegs(out.architecture))
    add(out.bindingSummaries, bindingSummary)
    add(out.instructionWordHex, words)
    add(out.functionByteSizes, wordCount(words) * 4)
    add(out.localPayloadPageRelocOffsets, 0)
    add(out.localPayloadPageoffRelocOffsets, 0)
    add(out.callRelocOffsets, 8)
    add(out.metadataOperandModes, "argv_passthrough")
    add(out.localPayloadTexts, "")
    appendMachineRelocation(out,
                            8,
                            callSymbol,
                            out.callRelocationKind)
    add(out.functionRelocStarts, functionRelocStart)
    add(out.functionRelocCounts, out.relocOffsets.len - functionRelocStart)

fn appendCompilerCoreArgvBridgeFunction(out: var MachineModuleBundle,
                                        bridgeItemId: int32,
                                        bindingSummary: str,
                                        dispatchTarget: str) =
    appendMachineDispatchEntryFunction(out,
                                       bridgeItemId,
                                       "compiler_program_entry",
                                       dispatchTarget,
                                       bindingSummary,
                                       16)
    out.entrySymbolOverride = out.symbolNames[out.symbolNames.len - 1]

fn appendMachineTraceProviderFunction(out: var MachineModuleBundle,
                                      itemId: int32,
                                      symbolName: str,
                                      runtimeTarget: str,
                                      bindingSummary: str,
                                      logicalFrameSize: int32) =
    let words = machineTraceProviderWords(out.architecture)
    let functionRelocStart = out.relocOffsets.len
    add(out.itemIds, itemId)
    add(out.symbolNames, symbolName)
    add(out.runtimeTargets, runtimeTarget)
    add(out.callSymbolNames, machineLibcSymbolName(out.targetTriple, "puts"))
    add(out.frameSizes, alignedSize(logicalFrameSize, out.stackAlignBytes))
    add(out.stackAligns, out.stackAlignBytes)
    add(out.argRegs, machineArgRegs(out.architecture))
    add(out.scratchRegs, machineScratchRegs(out.architecture))
    add(out.calleeSavedRegs, machineCalleeSavedRegs(out.architecture))
    add(out.bindingSummaries, bindingSummary)
    add(out.instructionWordHex, words)
    add(out.functionByteSizes, wordCount(words) * 4)
    add(out.localPayloadPageRelocOffsets, 0)
    add(out.localPayloadPageoffRelocOffsets, 0)
    add(out.callRelocOffsets, 8)
    add(out.metadataOperandModes, "arg0_cstring")
    add(out.localPayloadTexts, "")
    appendMachineRelocation(out,
                            8,
                            machineLibcSymbolName(out.targetTriple, "puts"),
                            out.callRelocationKind)
    add(out.functionRelocStarts, functionRelocStart)
    add(out.functionRelocCounts, out.relocOffsets.len - functionRelocStart)

fn buildRuntimeProviderMachineModule(providerModulePath: str,
                                     providerManifestCid: str,
                                     runtimeTargets: str[],
                                     targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle = newMachineModuleBundle("runtime_provider", targetTriple)
    for i in 0..<runtimeTargets.len:
        let symbolName = machineCallSymbolName(targetTriple, runtimeTargets[i])
        let bindingSummary = "provider_module=" + providerModulePath +
                             "|manifest_cid=" + providerManifestCid +
                             "|runtime_target=" + runtimeTargets[i]
        appendMachineTraceProviderFunction(out,
                                           i,
                                           symbolName,
                                           runtimeTargets[i],
                                           bindingSummary,
                                           16)
    return out

fn buildCompilerCoreArgvEntryProviderMachineModule(sourcePath: str,
                                                   providerManifestCid: str,
                                                   runtimeTargets: str[],
                                                   targetTriple: str): MachineModuleBundle =
    if runtimeTargets.len <= 0:
        panic("v2 machine pipeline: compiler_core runtime targets missing")
    let track = compilerCoreExecutionTrackForSourcePath(sourcePath)
    let expectedRuntimeTarget = compilerCoreArgvRuntimeTargetForTrack(track)
    let expectedLocalPayloadTarget = compilerCoreLocalPayloadRuntimeTargetForTrack(track)
    var runtimeTarget: str = ""
    var localPayloadTarget: str = ""
    for i in 0..<runtimeTargets.len:
        if runtimeTargets[i] == expectedRuntimeTarget:
            runtimeTarget = runtimeTargets[i]
        elif runtimeTargets[i] == expectedLocalPayloadTarget:
            localPayloadTarget = runtimeTargets[i]
    if len(runtimeTarget) <= 0:
        panic("v2 machine pipeline: compiler_core runtime argv target missing")
    if len(localPayloadTarget) <= 0:
        localPayloadTarget = expectedLocalPayloadTarget
    let compiled = cpipe.compileCompilerCoreSourceClosure(sourcePath)
    let full = lowerCompilerCorePlanToMachine(compiled.lowPlan, targetTriple, sourcePath)
    let entryIdx = compilerCorePlanEntryIndex(compiled.lowPlan, sourcePath)
    var entryLabel: str = "compilerCoreArgvEntry"
    if entryIdx >= 0:
        entryLabel = compiled.lowPlan.labels[entryIdx]
    if entryIdx < 0:
        panic("v2 machine pipeline: compiler_core runtime argv/main entry missing")
    let entryItemId = compiled.lowPlan.itemIds[entryIdx]
    let fullEntryIdx = machineFunctionIndexByItemId(full, entryItemId)
    if fullEntryIdx < 0:
        panic("v2 machine pipeline: compiler_core runtime entry symbol missing")
    var out: MachineModuleBundle = newMachineModuleBundle("runtime_provider", targetTriple)
    let entryCallSymbol = full.symbolNames[fullEntryIdx]
    let bindingSummary = "provider_module=runtime/compiler_core_runtime_v2" +
                         "|manifest_cid=" + providerManifestCid +
                         "|runtime_target=" + runtimeTarget +
                         "|entry_label=" + entryLabel
    appendMachineFunction(out,
                          entryItemId,
                          "runtime_provider_export",
                          runtimeTarget,
                          bindingSummary,
                          full.frameSizes[fullEntryIdx])
    let providerIdx = machineFunctionIndexByItemId(out, entryItemId)
    if providerIdx < 0:
        panic("v2 machine pipeline: compiler_core runtime provider export missing")
    rewriteMachineFunctionSymbol(out,
                                 providerIdx,
                                 machineCallSymbolName(targetTriple, runtimeTarget))
    let bridgeWords = "a9bf7bfd;910003fd;94000000;94000000;a8c17bfd;d65f03c0"
    rewriteMachineFunctionDirectExecCalls(out,
                                          providerIdx,
                                          bridgeWords,
                                          [machineLibcSymbolName(targetTriple, "__cheng_setCmdLine"),
                                           entryCallSymbol])
    var localPayloadBridgeLabel: str = "driver_c_compiler_core_tooling_local_payload_bridge"
    if track == "program":
        localPayloadBridgeLabel = "driver_c_compiler_core_program_local_payload_bridge"
    let localPayloadBindingSummary = "provider_module=runtime/compiler_core_runtime_v2" +
                                     "|manifest_cid=" + providerManifestCid +
                                     "|runtime_target=" + localPayloadTarget +
                                     "|entry_label=" + localPayloadBridgeLabel
    appendMachineDispatchEntryFunction(out,
                                       1001000000 + entryItemId,
                                       "runtime_provider_local_payload_export",
                                       localPayloadTarget,
                                       localPayloadBindingSummary,
                                       16)
    let localPayloadIdx = machineFunctionIndexByItemId(out, 1001000000 + entryItemId)
    if localPayloadIdx < 0:
        panic("v2 machine pipeline: compiler_core runtime local_payload export missing")
    rewriteMachineFunctionSymbol(out,
                                 localPayloadIdx,
                                 machineCallSymbolName(targetTriple, localPayloadTarget))
    rewriteMachineFunctionDirectExecCall(out,
                                         localPayloadIdx,
                                         machineDispatchEntryWords(out.architecture),
                                         machineLibcSymbolName(targetTriple, localPayloadBridgeLabel))
    return out

fn buildCompilerCoreArgvEntryProviderMachineModuleForProgram(programMachine: MachineModuleBundle,
                                                             programSourcePath: str,
                                                             providerManifestCid: str,
                                                             runtimeTargets: str[],
                                                             targetTriple: str): MachineModuleBundle =
    if runtimeTargets.len <= 0:
        panic("v2 machine pipeline: compiler_core runtime targets missing")
    if programMachine.moduleKind != "compiler_core":
        panic("v2 machine pipeline: compiler_core provider requires compiler_core program machine")
    let track = compilerCoreExecutionTrackForSourcePath(programSourcePath)
    let expectedRuntimeTarget = compilerCoreArgvRuntimeTargetForTrack(track)
    let expectedLocalPayloadTarget = compilerCoreLocalPayloadRuntimeTargetForTrack(track)
    var runtimeTarget: str = ""
    var localPayloadTarget: str = ""
    for i in 0..<runtimeTargets.len:
        if runtimeTargets[i] == expectedRuntimeTarget:
            runtimeTarget = runtimeTargets[i]
        elif runtimeTargets[i] == expectedLocalPayloadTarget:
            localPayloadTarget = runtimeTargets[i]
    if len(runtimeTarget) <= 0:
        panic("v2 machine pipeline: compiler_core runtime argv target missing")
    if len(localPayloadTarget) <= 0:
        localPayloadTarget = expectedLocalPayloadTarget
    let entryIdx = compilerCoreArgvProviderEntryFunctionIndex(programMachine)
    if entryIdx < 0 ||
       entryIdx >= programMachine.symbolNames.len ||
       len(programMachine.symbolNames[entryIdx]) <= 0:
        if len(programSourcePath) <= 0:
            panic("v2 machine pipeline: compiler_core argv entry symbol missing")
        return buildCompilerCoreArgvEntryProviderMachineModule(programSourcePath,
                                                               providerManifestCid,
                                                               runtimeTargets,
                                                               targetTriple)
    let entryItemId = programMachine.itemIds[entryIdx]
    let entryCallSymbol = programMachine.symbolNames[entryIdx]
    let entryLabel = bindingSummaryFieldValue(programMachine.bindingSummaries[entryIdx], "label")
    var out: MachineModuleBundle = newMachineModuleBundle("runtime_provider", targetTriple)
    let bindingSummary = "provider_module=runtime/compiler_core_runtime_v2" +
                         "|manifest_cid=" + providerManifestCid +
                         "|runtime_target=" + runtimeTarget +
                         "|entry_label=" + (len(entryLabel) > 0 ? entryLabel else: "main")
    appendMachineFunction(out,
                          entryItemId,
                          "runtime_provider_export",
                          runtimeTarget,
                          bindingSummary,
                          programMachine.frameSizes[entryIdx])
    let providerIdx = machineFunctionIndexByItemId(out, entryItemId)
    if providerIdx < 0:
        panic("v2 machine pipeline: compiler_core runtime provider export missing")
    rewriteMachineFunctionSymbol(out,
                                 providerIdx,
                                 machineCallSymbolName(targetTriple, runtimeTarget))
    let bridgeWords = "a9bf7bfd;910003fd;94000000;94000000;a8c17bfd;d65f03c0"
    rewriteMachineFunctionDirectExecCalls(out,
                                          providerIdx,
                                          bridgeWords,
                                          [machineLibcSymbolName(targetTriple, "__cheng_setCmdLine"),
                                           entryCallSymbol])
    var localPayloadBridgeLabel: str = "driver_c_compiler_core_tooling_local_payload_bridge"
    if track == "program":
        localPayloadBridgeLabel = "driver_c_compiler_core_program_local_payload_bridge"
    let localPayloadBindingSummary = "provider_module=runtime/compiler_core_runtime_v2" +
                                     "|manifest_cid=" + providerManifestCid +
                                     "|runtime_target=" + localPayloadTarget +
                                     "|entry_label=" + localPayloadBridgeLabel
    appendMachineDispatchEntryFunction(out,
                                       1001000000 + entryItemId,
                                       "runtime_provider_local_payload_export",
                                       localPayloadTarget,
                                       localPayloadBindingSummary,
                                       16)
    let localPayloadIdx = machineFunctionIndexByItemId(out, 1001000000 + entryItemId)
    if localPayloadIdx < 0:
        panic("v2 machine pipeline: compiler_core runtime local_payload export missing")
    rewriteMachineFunctionSymbol(out,
                                 localPayloadIdx,
                                 machineCallSymbolName(targetTriple, localPayloadTarget))
    rewriteMachineFunctionDirectExecCall(out,
                                         localPayloadIdx,
                                         machineDispatchEntryWords(out.architecture),
                                         machineLibcSymbolName(targetTriple, localPayloadBridgeLabel))
    return out

fn lowerStringPlanToMachine(plan: slow.LowUirStringPlan, targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle = newMachineModuleBundle("string", targetTriple)
    for i in 0..<plan.exprIds.len:
        var frameSize: int32 = 16
        if plan.allocationModes[i] == "builder_state" || plan.effectClasses[i] == "stateful_local":
            frameSize = frameSize + 16
        if !plan.zeroCopyFacts[i]:
            frameSize = frameSize + 16
        let bindingSummary = "result=" + plan.resultKinds[i] +
                             "|alloc=" + plan.allocationModes[i] +
                             "|effect=" + plan.effectClasses[i] +
                             "|zero_copy=" + if plan.zeroCopyFacts[i]: "1" else: "0"
        appendMachineFunction(out,
                              plan.exprIds[i],
                              plan.canonicalOps[i],
                              plan.runtimeTargets[i],
                              bindingSummary,
                              frameSize)
    return out

fn lowerCompilerCorePlanToMachine(plan: cflow.LowUirCompilerCorePlan,
                                  targetTriple: str,
                                  preferredSourcePath: str): MachineModuleBundle =
    var out: MachineModuleBundle = newMachineModuleBundle("compiler_core", targetTriple)
    var moduleCount: int32 = 0
    var importCount: int32 = 0
    var typeCount: int32 = 0
    var constCount: int32 = 0
    var varCount: int32 = 0
    var importcRoutineCount: int32 = 0
    var routineCount: int32 = 0
    var iteratorCount: int32 = 0
    var entryIndex: int32 = compilerCorePlanEntryIndex(plan, preferredSourcePath)
    for i in 0..<plan.itemIds.len:
        if entryIndex < 0 &&
           plan.labels[i] == "compilerCoreArgvEntry" &&
           plan.topLevelKinds[i] == "fn" &&
           plan.canonicalOps[i] == "compiler_fn_exec":
            entryIndex = i
        var frameSize: int32 = 16
        if plan.effectClasses[i] != "module_resolution":
            frameSize = frameSize + 16
        if plan.bodyLineCounts[i] > 0:
            frameSize = frameSize + 16
        if plan.bindingScopes[i] == "type_scope" || plan.bindingScopes[i] == "iterator_scope":
            frameSize = frameSize + 16
        if plan.executableAstReady[i]:
            frameSize = frameSize + (plan.localCounts[i] * 8)
        let bindingSummary = "top_level=" + plan.topLevelKinds[i] +
                             "|label=" + plan.labels[i] +
                             "|proof=" + plan.proofDomains[i] +
                             "|effect=" + plan.effectClasses[i] +
                             "|scope=" + plan.bindingScopes[i] +
                             "|import_path=" + plan.importPaths[i] +
                             "|import_alias=" + plan.importAliases[i] +
                             "|import_category=" + plan.importCategories[i] +
                             "|ast_ready=" + if plan.executableAstReady[i]: "1" else: "0" +
                             "|return_type=" + plan.returnTypeTexts[i] +
                             "|param_count=" + intToStr(plan.paramCounts[i]) +
                             "|local_count=" + intToStr(plan.localCounts[i]) +
                             "|stmt_count=" + intToStr(plan.stmtCounts[i]) +
                             "|expr_count=" + intToStr(plan.exprCounts[i]) +
                             "|body_lines=" + intToStr(plan.bodyLineCounts[i]) +
                             "|signature_hash=" + plan.signatureHashes[i] +
                             "|body_hash=" + plan.bodyHashes[i]
        let runtimeTarget = compilerCoreMachineRuntimeTarget(plan.runtimeTargets[i], plan.sourcePaths[i])
        let payloadPrelude = compilerCorePayloadPreludeText(plan,
                                                           i,
                                                           runtimeTarget,
                                                           bindingSummary)
        appendMachineFunction(out,
                              plan.itemIds[i],
                              plan.canonicalOps[i],
                              runtimeTarget,
                              bindingSummary,
                              frameSize)
        rewriteMachineFunctionPayload(out,
                                      out.itemIds.len - 1,
                                      "local_payload",
                                      payloadPrelude)
        if plan.executableAstReady[i] && plan.routineOpCounts[i] > 0:
            let payloadText = payloadPrelude + "\n" +
                              compilerCoreRoutineExecPlanText(plan, i)
            rewriteMachineFunctionPayload(out,
                                          out.itemIds.len - 1,
                                          "exec_plan_payload",
                                          payloadText)
            let directCStringPayload = compilerCoreDirectExecCStringPayloadText(plan, i)
            if len(directCStringPayload) > 0:
                let directCStringWords = machineDirectReturnCStringLiteralWords(out.architecture,
                                                                                len(directCStringPayload))
                if len(directCStringWords) > 0:
                    rewriteMachineFunctionDirectExecCStringData(out,
                                                                out.itemIds.len - 1,
                                                                directCStringWords,
                                                                directCStringPayload)
                    continue
            let directWords = compilerCoreDirectExecWords(plan, i, out.architecture)
            if len(directWords) > 0:
                rewriteMachineFunctionDirectExec(out,
                                                 out.itemIds.len - 1,
                                                 directWords)
            else:
                let directIfElseCallSymbols = compilerCoreDirectExecIfElseCallSymbols(plan, i, out.targetTriple)
                if directIfElseCallSymbols.len > 0:
                    let directIfElseCallWords = compilerCoreDirectExecIfElseCallWords(plan, i, out.architecture)
                    if len(directIfElseCallWords) > 0:
                        rewriteMachineFunctionDirectExecCalls(out,
                                                              out.itemIds.len - 1,
                                                              directIfElseCallWords,
                                                              directIfElseCallSymbols)
                else:
                    let directFallbackSymbols = compilerCoreDirectExecFallbackCallSymbols(plan,
                                                                                          i,
                                                                                          out.targetTriple)
                    if directFallbackSymbols.len > 0:
                        let directFallbackWords = compilerCoreDirectExecFallbackCallWords(plan,
                                                                                          i,
                                                                                          out.architecture)
                        if len(directFallbackWords) > 0:
                            rewriteMachineFunctionDirectExecCalls(out,
                                                                  out.itemIds.len - 1,
                                                                  directFallbackWords,
                                                                  directFallbackSymbols)
                    else:
                        let directNestedSymbols0 = compilerCoreDirectExecNestedCallSymbols(plan, i, out.targetTriple)
                        var directNestedSymbols: str[] = directNestedSymbols0
                        if compilerCoreDirectExecCallSymbolsTargetOutline(directNestedSymbols0):
                            directNestedSymbols = []
                        if directNestedSymbols.len > 0:
                            let directNestedWords = compilerCoreDirectExecNestedCallWords(plan, i, out.targetTriple)
                            if len(directNestedWords) > 0:
                                let directNestedCStringPayload = compilerCoreDirectExecNestedCallCStringPayloadText(plan, i)
                                if len(directNestedCStringPayload) > 0:
                                    rewriteMachineFunctionDirectExecCallsCStringData(out,
                                                                                     out.itemIds.len - 1,
                                                                                     directNestedWords,
                                                                                     directNestedSymbols,
                                                                                     directNestedCStringPayload)
                                else:
                                    rewriteMachineFunctionDirectExecCalls(out,
                                                                          out.itemIds.len - 1,
                                                                          directNestedWords,
                                                                          directNestedSymbols)
                        else:
                            let directNestedVoidSymbols0 = compilerCoreDirectExecVoidNestedCallSymbols(plan,
                                                                                                       i,
                                                                                                       out.targetTriple)
                            var directNestedVoidSymbols: str[] = directNestedVoidSymbols0
                            if compilerCoreDirectExecCallSymbolsTargetOutline(directNestedVoidSymbols0):
                                directNestedVoidSymbols = []
                            if directNestedVoidSymbols.len > 0:
                                let directNestedVoidWords = compilerCoreDirectExecVoidNestedCallWords(plan,
                                                                                                      i,
                                                                                                      out.targetTriple)
                                if len(directNestedVoidWords) > 0:
                                    rewriteMachineFunctionDirectExecCalls(out,
                                                                          out.itemIds.len - 1,
                                                                          directNestedVoidWords,
                                                                          directNestedVoidSymbols)
                            else:
                                let directCallSymbol0 = compilerCoreDirectExecCallSymbol(plan, i, out.targetTriple)
                                var directCallSymbol: str = directCallSymbol0
                                if compilerCoreDirectExecCallSymbolTargetsOutline(directCallSymbol0):
                                    directCallSymbol = ""
                                if len(directCallSymbol) > 0:
                                    let directCallWords = compilerCoreDirectExecCallWords(plan, i, out.targetTriple, out.architecture)
                                    let directCallIfOrThenCStringPayload0 = compilerCoreDirectExecParamCStringIfOrReturnThenPayload0Text(plan, i)
                                    let directCallIfOrThenCStringPayload1 = compilerCoreDirectExecParamCStringIfOrReturnThenPayload1Text(plan, i)
                                    let directCallIfOrElseCStringPayload = compilerCoreDirectExecParamCStringIfOrReturnElsePayloadText(plan, i)
                                    let directCallIfOrCondCStringPayload0 = compilerCoreDirectExecParamCStringIfOrReturnCondPayload0Text(plan, i)
                                    let directCallIfOrCondCStringPayload1 = compilerCoreDirectExecParamCStringIfOrReturnCondPayload1Text(plan, i)
                                    let directCallFourIfThenCStringPayload0 = compilerCoreDirectExecParamCStringFourIfReturnThenPayload0Text(plan, i)
                                    let directCallFourIfThenCStringPayload1 = compilerCoreDirectExecParamCStringFourIfReturnThenPayload1Text(plan, i)
                                    let directCallFourIfThenCStringPayload2 = compilerCoreDirectExecParamCStringFourIfReturnThenPayload2Text(plan, i)
                                    let directCallFourIfThenCStringPayload3 = compilerCoreDirectExecParamCStringFourIfReturnThenPayload3Text(plan, i)
                                    let directCallFourIfElseCStringPayload = compilerCoreDirectExecParamCStringFourIfReturnElsePayloadText(plan, i)
                                    let directCallFourIfCondCStringPayload0 = compilerCoreDirectExecParamCStringFourIfReturnCondPayload0Text(plan, i)
                                    let directCallFourIfCondCStringPayload1 = compilerCoreDirectExecParamCStringFourIfReturnCondPayload1Text(plan, i)
                                    let directCallFourIfCondCStringPayload2 = compilerCoreDirectExecParamCStringFourIfReturnCondPayload2Text(plan, i)
                                    let directCallFourIfCondCStringPayload3 = compilerCoreDirectExecParamCStringFourIfReturnCondPayload3Text(plan, i)
                                    let directCallTwoIfOrThenCStringPayload0 = compilerCoreDirectExecParamCStringTwoIfOrReturnThenPayload0Text(plan, i)
                                    let directCallTwoIfOrThenCStringPayload1 = compilerCoreDirectExecParamCStringTwoIfOrReturnThenPayload1Text(plan, i)
                                    let directCallTwoIfOrElseCStringPayload = compilerCoreDirectExecParamCStringTwoIfOrReturnElsePayloadText(plan, i)
                                    let directCallTwoIfOrCondCStringPayload0 = compilerCoreDirectExecParamCStringTwoIfOrReturnCondPayload0Text(plan, i)
                                    let directCallTwoIfOrCondCStringPayload1 = compilerCoreDirectExecParamCStringTwoIfOrReturnCondPayload1Text(plan, i)
                                    let directCallTwoIfOrCondCStringPayload2 = compilerCoreDirectExecParamCStringTwoIfOrReturnCondPayload2Text(plan, i)
                                    let directCallTwoIfOrCondCStringPayload3 = compilerCoreDirectExecParamCStringTwoIfOrReturnCondPayload3Text(plan, i)
                                    let directCallTwoIfThenCStringPayload0 = compilerCoreDirectExecParamCStringTwoIfReturnThenPayload0Text(plan, i)
                                    let directCallTwoIfThenCStringPayload1 = compilerCoreDirectExecParamCStringTwoIfReturnThenPayload1Text(plan, i)
                                    let directCallTwoIfElseCStringPayload = compilerCoreDirectExecParamCStringTwoIfReturnElsePayloadText(plan, i)
                                    let directCallTwoIfCondCStringPayload0 = compilerCoreDirectExecParamCStringTwoIfReturnCondPayload0Text(plan, i)
                                    let directCallTwoIfCondCStringPayload1 = compilerCoreDirectExecParamCStringTwoIfReturnCondPayload1Text(plan, i)
                                    let directCallIfExprThenCStringPayload = compilerCoreDirectExecFieldCStringIfExprThenPayloadText(plan, i)
                                    let directCallIfExprElseCStringPayload = compilerCoreDirectExecFieldCStringIfExprElsePayloadText(plan, i)
                                    let directCallIfExprCondCStringPayload = compilerCoreDirectExecFieldCStringIfExprCondPayloadText(plan, i)
                                    let directCallCStringPayload = compilerCoreDirectExecCallCStringPayloadText(plan, i)
                                    let directCallSecondCStringPayload = compilerCoreDirectExecCallSecondCStringPayloadText(plan, i)
                                    if len(directCallWords) > 0 &&
                                       len(directCallIfOrThenCStringPayload0) > 0 &&
                                       len(directCallIfOrThenCStringPayload1) > 0 &&
                                       len(directCallIfOrElseCStringPayload) > 0 &&
                                       len(directCallIfOrCondCStringPayload0) > 0 &&
                                       len(directCallIfOrCondCStringPayload1) > 0:
                                        rewriteMachineFunctionDirectExecCallFiveCStringData(out,
                                                                                            out.itemIds.len - 1,
                                                                                            directCallWords,
                                                                                            directCallSymbol,
                                                                                            directCallIfOrThenCStringPayload0,
                                                                                            directCallIfOrThenCStringPayload1,
                                                                                            directCallIfOrElseCStringPayload,
                                                                                            directCallIfOrCondCStringPayload0,
                                                                                            directCallIfOrCondCStringPayload1)
                                    elif len(directCallWords) > 0 &&
                                       len(directCallFourIfThenCStringPayload0) > 0 &&
                                       len(directCallFourIfThenCStringPayload1) > 0 &&
                                       len(directCallFourIfThenCStringPayload2) > 0 &&
                                       len(directCallFourIfThenCStringPayload3) > 0 &&
                                       len(directCallFourIfElseCStringPayload) > 0 &&
                                       len(directCallFourIfCondCStringPayload0) > 0 &&
                                       len(directCallFourIfCondCStringPayload1) > 0 &&
                                       len(directCallFourIfCondCStringPayload2) > 0 &&
                                       len(directCallFourIfCondCStringPayload3) > 0:
                                        rewriteMachineFunctionDirectExecCallNineCStringData(out,
                                                                                            out.itemIds.len - 1,
                                                                                            directCallWords,
                                                                                            directCallSymbol,
                                                                                            directCallFourIfThenCStringPayload0,
                                                                                            directCallFourIfThenCStringPayload1,
                                                                                            directCallFourIfThenCStringPayload2,
                                                                                            directCallFourIfThenCStringPayload3,
                                                                                            directCallFourIfElseCStringPayload,
                                                                                            directCallFourIfCondCStringPayload0,
                                                                                            directCallFourIfCondCStringPayload1,
                                                                                            directCallFourIfCondCStringPayload2,
                                                                                            directCallFourIfCondCStringPayload3)
                                    elif len(directCallWords) > 0 &&
                                       rewriteMachineFunctionDirectExecParamCStringChainReturn(out,
                                                                                               out.itemIds.len - 1,
                                                                                               directCallWords,
                                                                                               directCallSymbol,
                                                                                               plan,
                                                                                               i):
                                        discard
                                    elif len(directCallWords) > 0 &&
                                       rewriteMachineFunctionDirectExecParamCStringChainReturnInt32(out,
                                                                                                   out.itemIds.len - 1,
                                                                                                   directCallWords,
                                                                                                   directCallSymbol,
                                                                                                   plan,
                                                                                                   i):
                                        discard
                                    elif len(directCallWords) > 0 &&
                                       len(directCallTwoIfOrThenCStringPayload0) > 0 &&
                                       len(directCallTwoIfOrThenCStringPayload1) > 0 &&
                                       len(directCallTwoIfOrElseCStringPayload) > 0 &&
                                       len(directCallTwoIfOrCondCStringPayload0) > 0 &&
                                       len(directCallTwoIfOrCondCStringPayload1) > 0 &&
                                       len(directCallTwoIfOrCondCStringPayload2) > 0 &&
                                       len(directCallTwoIfOrCondCStringPayload3) > 0:
                                        rewriteMachineFunctionDirectExecCallNineCStringData(out,
                                                                                            out.itemIds.len - 1,
                                                                                            directCallWords,
                                                                                            directCallSymbol,
                                                                                            directCallTwoIfOrThenCStringPayload0,
                                                                                            directCallTwoIfOrThenCStringPayload0,
                                                                                            directCallTwoIfOrThenCStringPayload1,
                                                                                            directCallTwoIfOrThenCStringPayload1,
                                                                                            directCallTwoIfOrElseCStringPayload,
                                                                                            directCallTwoIfOrCondCStringPayload0,
                                                                                            directCallTwoIfOrCondCStringPayload1,
                                                                                            directCallTwoIfOrCondCStringPayload2,
                                                                                            directCallTwoIfOrCondCStringPayload3)
                                    elif len(directCallWords) > 0 &&
                                       len(directCallTwoIfThenCStringPayload0) > 0 &&
                                       len(directCallTwoIfThenCStringPayload1) > 0 &&
                                       len(directCallTwoIfElseCStringPayload) > 0 &&
                                       len(directCallTwoIfCondCStringPayload0) > 0 &&
                                       len(directCallTwoIfCondCStringPayload1) > 0:
                                        rewriteMachineFunctionDirectExecCallFiveCStringData(out,
                                                                                            out.itemIds.len - 1,
                                                                                            directCallWords,
                                                                                            directCallSymbol,
                                                                                            directCallTwoIfThenCStringPayload0,
                                                                                            directCallTwoIfThenCStringPayload1,
                                                                                            directCallTwoIfElseCStringPayload,
                                                                                            directCallTwoIfCondCStringPayload0,
                                                                                            directCallTwoIfCondCStringPayload1)
                                    elif len(directCallWords) > 0 &&
                                       len(directCallIfExprThenCStringPayload) > 0 &&
                                       len(directCallIfExprElseCStringPayload) > 0 &&
                                       len(directCallIfExprCondCStringPayload) > 0:
                                        rewriteMachineFunctionDirectExecCallThreeCStringData(out,
                                                                                             out.itemIds.len - 1,
                                                                                             directCallWords,
                                                                                             directCallSymbol,
                                                                                             directCallIfExprThenCStringPayload,
                                                                                             directCallIfExprElseCStringPayload,
                                                                                             directCallIfExprCondCStringPayload)
                                    elif len(directCallWords) > 0 &&
                                       len(directCallCStringPayload) > 0 &&
                                       len(directCallSecondCStringPayload) > 0:
                                        rewriteMachineFunctionDirectExecCallTwoCStringData(out,
                                                                                           out.itemIds.len - 1,
                                                                                           directCallWords,
                                                                                           directCallSymbol,
                                                                                           directCallCStringPayload,
                                                                                           directCallSecondCStringPayload)
                                    else:
                                        if len(directCallWords) > 0 && len(directCallCStringPayload) > 0:
                                            rewriteMachineFunctionDirectExecCallCStringData(out,
                                                                                            out.itemIds.len - 1,
                                                                                            directCallWords,
                                                                                            directCallSymbol,
                                                                                            directCallCStringPayload)
                                        elif len(directCallWords) > 0:
                                            rewriteMachineFunctionDirectExecCall(out,
                                                                                 out.itemIds.len - 1,
                                                                                 directCallWords,
                                                                                 directCallSymbol)
                                else:
                                    let directVoidThenConstCallSymbol0 =
                                        compilerCoreDirectExecVoidThenConstCallSymbol(plan, i, out.targetTriple)
                                    var directVoidThenConstCallSymbol: str = directVoidThenConstCallSymbol0
                                    if compilerCoreDirectExecCallSymbolTargetsOutline(directVoidThenConstCallSymbol0):
                                        directVoidThenConstCallSymbol = ""
                                    if len(directVoidThenConstCallSymbol) > 0:
                                        let directVoidThenConstCallWords =
                                            compilerCoreDirectExecVoidThenConstCallWords(plan,
                                                                                         i,
                                                                                         out.architecture)
                                        rewriteMachineFunctionDirectExecCall(out,
                                                                             out.itemIds.len - 1,
                                                                             directVoidThenConstCallWords,
                                                                             directVoidThenConstCallSymbol)
                                    else:
                                        let directVoidCallSymbol0 = compilerCoreDirectExecVoidCallSymbol(plan, i, out.targetTriple)
                                        var directVoidCallSymbol: str = directVoidCallSymbol0
                                        if compilerCoreDirectExecCallSymbolTargetsOutline(directVoidCallSymbol0):
                                            directVoidCallSymbol = ""
                                        if len(directVoidCallSymbol) > 0:
                                            let directVoidCallWords = compilerCoreDirectExecVoidCallWords(plan, i, out.architecture)
                                            let directVoidCallCStringPayload = compilerCoreDirectExecVoidCallCStringPayloadText(plan, i)
                                            if len(directVoidCallWords) > 0 && len(directVoidCallCStringPayload) > 0:
                                                rewriteMachineFunctionDirectExecCallCStringData(out,
                                                                                                out.itemIds.len - 1,
                                                                                                directVoidCallWords,
                                                                                                directVoidCallSymbol,
                                                                                                directVoidCallCStringPayload)
                                            elif len(directVoidCallWords) > 0:
                                                rewriteMachineFunctionDirectExecCall(out,
                                                                                     out.itemIds.len - 1,
                                                                                     directVoidCallWords,
                                                                                     directVoidCallSymbol)
        if plan.topLevelKinds[i] == "module":
            moduleCount = moduleCount + 1
        elif plan.topLevelKinds[i] == "import":
            importCount = importCount + 1
        elif plan.topLevelKinds[i] == "type":
            typeCount = typeCount + 1
        elif plan.topLevelKinds[i] == "const":
            constCount = constCount + 1
        elif plan.topLevelKinds[i] == "var":
            varCount = varCount + 1
        elif plan.topLevelKinds[i] == "importc_fn":
            importcRoutineCount = importcRoutineCount + 1
        elif plan.topLevelKinds[i] == "iterator":
            iteratorCount = iteratorCount + 1
        else:
            routineCount = routineCount + 1
    if compilerCoreExecutionTrackForSourcePath(preferredSourcePath) == "program" &&
       entryIndex >= 0 &&
       plan.itemIds.len > 0:
        appendMachineGlobalDataSymbol(out,
                                      compilerCoreProgramRegistrySymbolName(out.targetTriple),
                                      out.cstringSectionName,
                                      compilerCoreProgramRegistryText(plan,
                                                                     out.targetTriple,
                                                                     preferredSourcePath),
                                      0)
    if entryIndex < 0 && plan.itemIds.len > 0:
        entryIndex = 0
    if entryIndex >= 0:
        let entryItemId = plan.itemIds[entryIndex]
        let dispatchTarget = compilerCoreArgvRuntimeTargetForTrack(compilerCoreExecutionTrackForSourcePath(sourcePath))
        let entryAstReady = if plan.executableAstReady[entryIndex]: "1" else: "0"
        let bindingSummary = "entry_bridge=1" +
                             "|dispatch=" + dispatchTarget +
                             "|entry_label=" + plan.labels[entryIndex] +
                             "|entry_kind=" + plan.topLevelKinds[entryIndex] +
                             "|entry_op=" + plan.canonicalOps[entryIndex] +
                             "|entry_ast_ready=" + entryAstReady +
                             "|entry_return_type=" + plan.returnTypeTexts[entryIndex] +
                             "|entry_param_count=" + intToStr(plan.paramCounts[entryIndex]) +
                             "|entry_local_count=" + intToStr(plan.localCounts[entryIndex]) +
                             "|entry_stmt_count=" + intToStr(plan.stmtCounts[entryIndex]) +
                             "|entry_expr_count=" + intToStr(plan.exprCounts[entryIndex]) +
                             "|entry_exec_op_count=" + intToStr(plan.routineOpCounts[entryIndex]) +
                             "|entry_exec_op_hash=" + plan.routineOpHashes[entryIndex] +
                             "|top_levels=" + intToStr(plan.itemIds.len) +
                             "|modules=" + intToStr(moduleCount) +
                             "|imports=" + intToStr(importCount) +
                             "|types=" + intToStr(typeCount) +
                             "|consts=" + intToStr(constCount) +
                             "|vars=" + intToStr(varCount) +
                             "|importc_routines=" + intToStr(importcRoutineCount) +
                             "|routines=" + intToStr(routineCount) +
                             "|iterators=" + intToStr(iteratorCount)
        appendCompilerCoreArgvBridgeFunction(out,
                                             1000000000 + entryItemId,
                                             bindingSummary,
                                             dispatchTarget)
    return out

fn lowerUnimakerPlanToMachine(plan: uflow.LowUirUnimakerPlan, targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle = newMachineModuleBundle("unimaker", targetTriple)
    for i in 0..<plan.declIds.len:
        var frameSize: int32 = 16
        if plan.effectClasses[i] != "pure_contract":
            frameSize = frameSize + 16
        if len(plan.networkDomains[i]) > 0:
            frameSize = frameSize + 16
        if plan.antiEntropySignatureKinds[i] != "none":
            frameSize = frameSize + 16
        let bindingSummary = "proof=" + plan.proofDomains[i] +
                             "|effect=" + plan.effectClasses[i] +
                             "|network_mode=" + plan.networkModes[i] +
                             "|capability=" + plan.capabilityKinds[i] +
                             "|domain=" + plan.networkDomains[i] +
                             "|topology_ref=" + plan.topologyRefs[i] +
                             "|transport=" + plan.transportModes[i] +
                             "|repair=" + plan.repairModes[i] +
                             "|dispersal=" + plan.dispersalModes[i] +
                             "|priority=" + plan.priorityClasses[i] +
                             "|identity=" + plan.identityScopes[i] +
                             "|signature=" + plan.antiEntropySignatureKinds[i]
        appendMachineFunction(out,
                              plan.declIds[i],
                              plan.canonicalOps[i],
                              plan.runtimeTargets[i],
                              bindingSummary,
                              frameSize)
    return out

fn lowerNetworkDistributionPlanToMachine(plan: nflow.LowUirNetworkDistributionPlan,
                                         targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle = newMachineModuleBundle("network_distribution", targetTriple)
    for i in 0..<plan.opIds.len:
        var frameSize: int32 = 16
        if plan.transportModes[i] == "coded_bulk_dispersal":
            frameSize = frameSize + 16
        if plan.priorityClasses[i] == "background":
            frameSize = frameSize + 16
        if plan.antiEntropySignatureKinds[i] != "none":
            frameSize = frameSize + 16
        let bindingSummary = "proof=" + plan.proofDomains[i] +
                             "|identity=" + plan.identityScopes[i] +
                             "|addressing=" + plan.addressingModes[i] +
                             "|depth=" + intToStr(plan.topologyDepths[i]) +
                             "|address_binding=" + plan.addressBindings[i] +
                             "|distance_metric=" + plan.distanceMetrics[i] +
                             "|route_plan_model=" + plan.routePlanModels[i] +
                             "|transport=" + plan.transportModes[i] +
                             "|repair=" + plan.repairModes[i] +
                             "|dispersal=" + plan.dispersalModes[i] +
                             "|priority=" + plan.priorityClasses[i] +
                             "|signature=" + plan.antiEntropySignatureKinds[i] +
                             "|topology=" + plan.topologyCanonicalForms[i]
        appendMachineFunction(out,
                              plan.opIds[i],
                              plan.canonicalOps[i],
                              plan.runtimeTargets[i],
                              bindingSummary,
                              frameSize)
    return out

fn sampleStringMachineModule(targetTriple: str): MachineModuleBundle =
    return lowerStringPlanToMachine(spipe.sampleStringPipeline().lowPlan, targetTriple)

fn sampleUnimakerMachineModule(targetTriple: str): MachineModuleBundle =
    return lowerUnimakerPlanToMachine(upipe.sampleUnimakerPipeline().lowPlan, targetTriple)

fn sampleCompilerCoreMachineModule(targetTriple: str): MachineModuleBundle =
    let parsed = parser.parseV2SourceFileStrict("v2/src/runtime/strings_v2.cheng")
    let bundle = cpipe.compileCompilerCoreProgram(parsed.compilerCoreProgram)
    return lowerCompilerCorePlanToMachine(bundle.lowPlan, targetTriple, "")

fn sampleNetworkDistributionMachineModule(targetTriple: str): MachineModuleBundle =
    return lowerNetworkDistributionPlanToMachine(npipe.sampleNetworkDistributionPipeline().lowPlan,
                                                 targetTriple)

fn machineModuleLines(bundle: MachineModuleBundle): str[] =
    var out: str[]
    out = []
    add(out, "machine_pipeline_version=" + bundle.version)
    add(out, "module_kind=" + bundle.moduleKind)
    add(out, "target=" + bundle.targetTriple)
    add(out, "architecture=" + bundle.architecture)
    add(out, "obj_format=" + bundle.objFormat)
    add(out, "text_section=" + bundle.textSectionName)
    add(out, "call_relocation=" + bundle.callRelocationKind)
    add(out, "metadata_page_relocation=" + bundle.metadataPageRelocationKind)
    add(out, "metadata_pageoff_relocation=" + bundle.metadataPageoffRelocationKind)
    add(out, "entry_symbol_override=" + bundle.entrySymbolOverride)
    add(out, "function_count=" + intToStr(bundle.itemIds.len))
    for i in 0..<bundle.itemIds.len:
        add(out, "function." + intToStr(i) + ".symbol=" + bundle.symbolNames[i])
        add(out, "function." + intToStr(i) + ".runtime=" + bundle.runtimeTargets[i])
        add(out, "function." + intToStr(i) + ".call_symbol=" + bundle.callSymbolNames[i])
        add(out, "function." + intToStr(i) + ".frame_size=" + intToStr(bundle.frameSizes[i]))
        add(out, "function." + intToStr(i) + ".bindings=" + bundle.bindingSummaries[i])
        add(out, "function." + intToStr(i) + ".metadata_mode=" + bundle.metadataOperandModes[i])
        add(out, "function." + intToStr(i) + ".payload=" + bundle.localPayloadTexts[i])
        add(out, "function." + intToStr(i) + ".words=" + bundle.instructionWordHex[i])
    return out

fn machineModuleText(bundle: MachineModuleBundle): str =
    return joinWithSep(machineModuleLines(bundle), "\n")

fn machineModuleCid(bundle: MachineModuleBundle): str =
    return ident.sha256HexText(machineModuleText(bundle))
