    thenPayload0 = ""
    condPayload1 = ""
    thenPayload1 = ""
    condPayload2 = ""
    thenPayload2 = ""
    condPayload3 = ""
    thenPayload3 = ""
    elsePayload = ""
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "str"):
        return false
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 30 ||
       plan.opKinds[opStart] != "load_param" ||
       plan.opKinds[opStart + 1] != "load_str" ||
       plan.opKinds[opStart + 2] != "binary_op" ||
       plan.opKinds[opStart + 3] != "jump_if_false" ||
       plan.opKinds[opStart + 4] != "load_str" ||
       plan.opKinds[opStart + 5] != "return_value" ||
       plan.opKinds[opStart + 6] != "label" ||
       plan.opKinds[opStart + 7] != "load_param" ||
       plan.opKinds[opStart + 8] != "load_str" ||
       plan.opKinds[opStart + 9] != "binary_op" ||
       plan.opKinds[opStart + 10] != "jump_if_false" ||
       plan.opKinds[opStart + 11] != "load_str" ||
       plan.opKinds[opStart + 12] != "return_value" ||
       plan.opKinds[opStart + 13] != "label" ||
       plan.opKinds[opStart + 14] != "load_param" ||
       plan.opKinds[opStart + 15] != "load_str" ||
       plan.opKinds[opStart + 16] != "binary_op" ||
       plan.opKinds[opStart + 17] != "jump_if_false" ||
       plan.opKinds[opStart + 18] != "load_str" ||
       plan.opKinds[opStart + 19] != "return_value" ||
       plan.opKinds[opStart + 20] != "label" ||
       plan.opKinds[opStart + 21] != "load_param" ||
       plan.opKinds[opStart + 22] != "load_str" ||
       plan.opKinds[opStart + 23] != "binary_op" ||
       plan.opKinds[opStart + 24] != "jump_if_false" ||
       plan.opKinds[opStart + 25] != "load_str" ||
       plan.opKinds[opStart + 26] != "return_value" ||
       plan.opKinds[opStart + 27] != "label" ||
       plan.opKinds[opStart + 28] != "load_str" ||
       plan.opKinds[opStart + 29] != "return_value":
        return false
    let paramIdx = plan.opArg0s[opStart]
    if plan.opArg0s[opStart + 7] != paramIdx ||
       plan.opArg0s[opStart + 14] != paramIdx ||
       plan.opArg0s[opStart + 21] != paramIdx:
        return false
    let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], paramIdx)
    if !compilerCoreTypeMatches(paramTypeText, "str"):
        return false
    sourceReg0 = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], paramIdx)
    sourceReg1 = sourceReg0 + 1
    sourceReg1Is64 = compilerCoreDirectSecondRegIs64(paramTypeText)
    if sourceReg1Is64:
        return false
    if plan.opPrimaryTexts[opStart + 2] != "==" ||
       plan.opPrimaryTexts[opStart + 9] != "==" ||
       plan.opPrimaryTexts[opStart + 16] != "==" ||
       plan.opPrimaryTexts[opStart + 23] != "==" ||
       plan.opPrimaryTexts[opStart + 3] != plan.opPrimaryTexts[opStart + 6] ||
       plan.opPrimaryTexts[opStart + 10] != plan.opPrimaryTexts[opStart + 13] ||
       plan.opPrimaryTexts[opStart + 17] != plan.opPrimaryTexts[opStart + 20] ||
       plan.opPrimaryTexts[opStart + 24] != plan.opPrimaryTexts[opStart + 27]:
        return false
    condPayload0 = plan.opPrimaryTexts[opStart + 1]
    thenPayload0 = plan.opPrimaryTexts[opStart + 4]
    condPayload1 = plan.opPrimaryTexts[opStart + 8]
    thenPayload1 = plan.opPrimaryTexts[opStart + 11]
    condPayload2 = plan.opPrimaryTexts[opStart + 15]
    thenPayload2 = plan.opPrimaryTexts[opStart + 18]
    condPayload3 = plan.opPrimaryTexts[opStart + 22]
    thenPayload3 = plan.opPrimaryTexts[opStart + 25]
    elsePayload = plan.opPrimaryTexts[opStart + 28]
    return true

