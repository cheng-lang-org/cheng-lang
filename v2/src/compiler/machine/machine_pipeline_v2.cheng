                            dataSymbol4,
                            out.cstringSectionName,
                            payloadText4,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineDataSymbol(out,
                            dataSymbol5,
                            out.cstringSectionName,
                            payloadText5,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineDataSymbol(out,
                            dataSymbol6,
                            out.cstringSectionName,
                            payloadText6,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineDataSymbol(out,
                            dataSymbol7,
                            out.cstringSectionName,
                            payloadText7,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineDataSymbol(out,
                            dataSymbol8,
                            out.cstringSectionName,
                            payloadText8,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineRelocation(out,
                            firstCStringOffsets[0],
                            dataSymbol0,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            firstCStringOffsets[1],
                            dataSymbol0,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            firstCStringOffsets[2],
                            dataSymbol1,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            firstCStringOffsets[3],
                            dataSymbol1,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            firstCStringOffsets[4],
                            dataSymbol2,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            firstCStringOffsets[5],
                            dataSymbol2,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            firstCStringOffsets[6],
                            dataSymbol3,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            firstCStringOffsets[7],
                            dataSymbol3,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            firstCStringOffsets[8],
                            dataSymbol4,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            firstCStringOffsets[9],
                            dataSymbol4,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            secondCStringOffsets[0],
                            dataSymbol5,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            secondCStringOffsets[1],
                            dataSymbol5,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            secondCStringOffsets[2],
                            dataSymbol6,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            secondCStringOffsets[3],
                            dataSymbol6,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            secondCStringOffsets[4],
                            dataSymbol7,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            secondCStringOffsets[5],
                            dataSymbol7,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            secondCStringOffsets[6],
                            dataSymbol8,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            secondCStringOffsets[7],
                            dataSymbol8,
                            out.metadataPageoffRelocationKind)
    for i in 0..<callOffsets.len:
        appendMachineRelocation(out,
                                callOffsets[i],
                                callSymbol,
                                out.callRelocationKind)
    out.functionRelocCounts[functionIdx] = 22

fn rewriteMachineFunctionDirectExecCallChainCStringData(out: var MachineModuleBundle,
                                                        functionIdx: int32,
                                                        words: str,
                                                        callSymbol: str,
                                                        returnPayloads: str[],
                                                        condPayloads: str[]) =
    if returnPayloads.len != condPayloads.len + 1:
        panic("v2 machine pipeline: direct exec call chain cstring payload arity mismatch")
    let callOffsets = machineDirectCallRelocOffsets(words)
    let firstCStringOffsets = machineDirectFirstCStringRelocOffsets(words)
    let secondCStringOffsets = machineDirectSecondCStringRelocOffsets(words)
    if callOffsets.len != condPayloads.len:
        panic("v2 machine pipeline: direct exec call chain cstring call reloc count mismatch")
    if firstCStringOffsets.len != returnPayloads.len * 2 ||
       secondCStringOffsets.len != condPayloads.len * 2:
        panic("v2 machine pipeline: direct exec call chain cstring data reloc count mismatch")
    var callSymbols: str[]
    callSymbols = []
    for i in 0..<callOffsets.len:
        add(callSymbols, callSymbol)
    var payloadTexts: str[]
    payloadTexts = []
    for i in 0..<returnPayloads.len:
        add(payloadTexts, returnPayloads[i])
    for i in 0..<condPayloads.len:
        add(payloadTexts, condPayloads[i])
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = joinWithSep(callSymbols, ";")
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = firstCStringOffsets[0]
    out.localPayloadPageoffRelocOffsets[functionIdx] = firstCStringOffsets[1]
    out.callRelocOffsets[functionIdx] = callOffsets[0]
    out.metadataOperandModes[functionIdx] = "direct_exec_call_chain_cstring_payload"
    out.localPayloadTexts[functionIdx] = joinWithSep(payloadTexts, "|")
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    for i in 0..<returnPayloads.len:
        let dataSymbol = out.symbolNames[functionIdx] + "_cstring" + intToStr(i)
        appendMachineDataSymbol(out,
                                dataSymbol,
                                out.cstringSectionName,
                                returnPayloads[i],
                                mtarget.machineTargetCStringAlignPow2(out.targetTriple))
        appendMachineRelocation(out,
                                firstCStringOffsets[i * 2],
                                dataSymbol,
                                out.metadataPageRelocationKind)
        appendMachineRelocation(out,
                                firstCStringOffsets[i * 2 + 1],
                                dataSymbol,
                                out.metadataPageoffRelocationKind)
    for i in 0..<condPayloads.len:
        let dataSymbol = out.symbolNames[functionIdx] + "_cstring" + intToStr(returnPayloads.len + i)
        appendMachineDataSymbol(out,
                                dataSymbol,
                                out.cstringSectionName,
                                condPayloads[i],
                                mtarget.machineTargetCStringAlignPow2(out.targetTriple))
        appendMachineRelocation(out,
                                secondCStringOffsets[i * 2],
                                dataSymbol,
                                out.metadataPageRelocationKind)
        appendMachineRelocation(out,
                                secondCStringOffsets[i * 2 + 1],
                                dataSymbol,
                                out.metadataPageoffRelocationKind)
    for i in 0..<callOffsets.len:
        appendMachineRelocation(out,
                                callOffsets[i],
                                callSymbol,
                                out.callRelocationKind)
    out.functionRelocCounts[functionIdx] = returnPayloads.len * 2 + condPayloads.len * 2 + callOffsets.len

fn rewriteMachineFunctionDirectExecCallChainCondCStringData(out: var MachineModuleBundle,
                                                            functionIdx: int32,
                                                            words: str,
                                                            callSymbol: str,
                                                            condPayloads: str[]) =
    let callOffsets = machineDirectCallRelocOffsets(words)
    let secondCStringOffsets = machineDirectSecondCStringRelocOffsets(words)
    if callOffsets.len != condPayloads.len:
        panic("v2 machine pipeline: direct exec call chain cond cstring call reloc count mismatch")
    if secondCStringOffsets.len != condPayloads.len * 2:
        panic("v2 machine pipeline: direct exec call chain cond cstring data reloc count mismatch")
    var callSymbols: str[]
    callSymbols = []
    for i in 0..<callOffsets.len:
        add(callSymbols, callSymbol)
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = joinWithSep(callSymbols, ";")
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = secondCStringOffsets[0]
    out.localPayloadPageoffRelocOffsets[functionIdx] = secondCStringOffsets[1]
    out.callRelocOffsets[functionIdx] = callOffsets[0]
    out.metadataOperandModes[functionIdx] = "direct_exec_call_chain_cond_cstring_payload"
    out.localPayloadTexts[functionIdx] = joinWithSep(condPayloads, "|")
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    for i in 0..<condPayloads.len:
        let dataSymbol = out.symbolNames[functionIdx] + "_cstring" + intToStr(i)
        appendMachineDataSymbol(out,
                                dataSymbol,
                                out.cstringSectionName,
                                condPayloads[i],
                                mtarget.machineTargetCStringAlignPow2(out.targetTriple))
        appendMachineRelocation(out,
                                secondCStringOffsets[i * 2],
                                dataSymbol,
                                out.metadataPageRelocationKind)
        appendMachineRelocation(out,
                                secondCStringOffsets[i * 2 + 1],
                                dataSymbol,
                                out.metadataPageoffRelocationKind)
    for i in 0..<callOffsets.len:
        appendMachineRelocation(out,
                                callOffsets[i],
                                callSymbol,
                                out.callRelocationKind)
    out.functionRelocCounts[functionIdx] = condPayloads.len * 2 + callOffsets.len

fn rewriteMachineFunctionDirectExecCallsCStringData(out: var MachineModuleBundle,
                                                    functionIdx: int32,
                                                    words: str,
                                                    callSymbols: str[],
                                                    payloadText: str) =
    let callOffsets = machineDirectCallRelocOffsets(words)
    if callOffsets.len != callSymbols.len:
        panic("v2 machine pipeline: direct exec call reloc count mismatch")
    let dataRelocOffsets = machineDirectSecondCStringRelocOffsets(words)
    if dataRelocOffsets.len != 2:
        panic("v2 machine pipeline: direct exec nested cstring reloc count mismatch")
    let dataSymbol = out.symbolNames[functionIdx] + "_cstring"
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = joinWithSep(callSymbols, ";")
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = dataRelocOffsets[0]
    out.localPayloadPageoffRelocOffsets[functionIdx] = dataRelocOffsets[1]
    out.callRelocOffsets[functionIdx] = callOffsets[0]
    out.metadataOperandModes[functionIdx] = "direct_exec_call_cstring_payload"
    out.localPayloadTexts[functionIdx] = payloadText
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    appendMachineDataSymbol(out,
                            dataSymbol,
                            out.cstringSectionName,
                            payloadText,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineRelocation(out,
                            dataRelocOffsets[0],
                            dataSymbol,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            dataRelocOffsets[1],
                            dataSymbol,
                            out.metadataPageoffRelocationKind)
    for i in 0..<callOffsets.len:
        appendMachineRelocation(out,
                                callOffsets[i],
                                callSymbols[i],
                                out.callRelocationKind)
    out.functionRelocCounts[functionIdx] = 2 + callOffsets.len

fn rewriteMachineFunctionSymbol(out: var MachineModuleBundle,
                                functionIdx: int32,
                                symbolName: str) =
    out.symbolNames[functionIdx] = symbolName

fn compilerCoreFindPlanItemIndex(plan: cflow.LowUirCompilerCorePlan, itemId: int32): int32 =
    for i in 0..<plan.itemIds.len:
        if plan.itemIds[i] == itemId:
            return i
    return -1

fn compilerCoreMachineImportVisibleName(importPath: str, importAlias: str): str =
    if len(importAlias) > 0:
        return importAlias
    var slashIdx: int32 = -1
    for i in 0..<len(importPath):
        if importPath[i] == '/':
            slashIdx = i
    if slashIdx >= 0:
        return strings.sliceBytes(importPath, slashIdx + 1, len(importPath) - slashIdx - 1)
    return importPath

fn compilerCoreFindQualifiedPlanItemIndex(plan: cflow.LowUirCompilerCorePlan,
                                          itemIdx: int32,
                                          qualifiedName: str,
                                          expectedParamCount: int32): int32 =
    var dotIdx: int32 = -1
    for i in 0..<len(qualifiedName):
        if qualifiedName[i] == '.':
            dotIdx = i
    if dotIdx <= 0 || dotIdx >= len(qualifiedName) - 1:
        return -1
    let importName = strings.sliceBytes(qualifiedName, 0, dotIdx)
    let fieldName = strings.sliceBytes(qualifiedName, dotIdx + 1, len(qualifiedName) - dotIdx - 1)
    let ownerModulePath = itemIdx >= 0 && itemIdx < plan.ownerModules.len ? plan.ownerModules[itemIdx] else: ""
    var importIdx: int32 = -1
    for i in 0..<plan.itemIds.len:
        if plan.topLevelKinds[i] != "import":
            continue
        if i >= plan.ownerModules.len || plan.ownerModules[i] != ownerModulePath:
            continue
        if compilerCoreMachineImportVisibleName(plan.importPaths[i], plan.importAliases[i]) == importName:
            if importIdx >= 0:
                return -1
            importIdx = i
    if importIdx < 0:
        return -1
    let targetModulePath = plan.importTargetModulePaths[importIdx]
    var matchIdx: int32 = -1
    var matchCount: int32 = 0
    for i in 0..<plan.itemIds.len:
        if i >= plan.ownerModules.len || plan.ownerModules[i] != targetModulePath:
            continue
        if plan.labels[i] != fieldName:
            continue
        let topLevelKind = plan.topLevelKinds[i]
        if topLevelKind != "fn" && topLevelKind != "iterator" && topLevelKind != "importc_fn" &&
           topLevelKind != "const" && topLevelKind != "var":
            continue
        if expectedParamCount >= 0 &&
           (topLevelKind == "fn" || topLevelKind == "iterator" || topLevelKind == "importc_fn") &&
           plan.paramCounts[i] != expectedParamCount:
            continue
        matchIdx = i
        matchCount = matchCount + 1
        if matchCount > 1:
            return -1
    return matchIdx

fn compilerCoreDirectExecCallItemIndex(plan: cflow.LowUirCompilerCorePlan,
                                       itemIdx: int32,
                                       opIdx: int32,
                                       expectedParamCount: int32): int32 =
    let qualifiedName = plan.opPrimaryTexts[opIdx]
    if strings.find(qualifiedName, ".") >= 0:
        let qualifiedIdx = compilerCoreFindQualifiedPlanItemIndex(plan, itemIdx, qualifiedName, expectedParamCount)
        if qualifiedIdx >= 0:
            return qualifiedIdx
    return compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opIdx])

fn compilerCorePlanCallableMatchesResolvedArgType(plan: cflow.LowUirCompilerCorePlan,
                                                  candidateIdx: int32,
                                                  resolvedArgTypeText: str,
                                                  expectedParamCount: int32): bool =
    if candidateIdx < 0 || candidateIdx >= plan.itemIds.len:
        return false
    let topLevelKind = plan.topLevelKinds[candidateIdx]
    if topLevelKind != "fn" && topLevelKind != "iterator" && topLevelKind != "importc_fn":
        return false
    if expectedParamCount >= 0 && plan.paramCounts[candidateIdx] != expectedParamCount:
        return false
    if expectedParamCount != 1:
        return true
    return compilerCoreNormalizedTypeText(compilerCoreSignatureParamTypeText(plan.signatureTexts[candidateIdx], 0)) ==
           compilerCoreNormalizedTypeText(resolvedArgTypeText)

fn compilerCoreFindPlanItemIndexByResolvedTypeCall(plan: cflow.LowUirCompilerCorePlan,
                                                   itemIdx: int32,
                                                   opIdx: int32,
                                                   resolvedArgTypeText: str,
                                                   expectedParamCount: int32): int32 =
    let directIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opIdx])
    if compilerCorePlanCallableMatchesResolvedArgType(plan,
                                                      directIdx,
                                                      resolvedArgTypeText,
                                                      expectedParamCount):
        return directIdx
    let qualifiedName = plan.opPrimaryTexts[opIdx]
    if strings.find(qualifiedName, ".") >= 0:
        let qualifiedIdx = compilerCoreFindQualifiedPlanItemIndex(plan, itemIdx, qualifiedName, expectedParamCount)
        if compilerCorePlanCallableMatchesResolvedArgType(plan,
                                                          qualifiedIdx,
                                                          resolvedArgTypeText,
                                                          expectedParamCount):
            return qualifiedIdx
    var dotIdx: int32 = -1
    for i in 0..<len(qualifiedName):
        if qualifiedName[i] == '.':
            dotIdx = i
    let baseName = dotIdx >= 0 ? slice(qualifiedName, dotIdx + 1, len(qualifiedName) - dotIdx - 1) else: qualifiedName
    var matchIdx: int32 = -1
    var matchCount: int32 = 0
    for i in 0..<plan.itemIds.len:
        if plan.labels[i] != baseName:
            continue
        if !compilerCorePlanCallableMatchesResolvedArgType(plan,
                                                           i,
                                                           resolvedArgTypeText,
                                                           expectedParamCount):
            continue
        matchIdx = i
        matchCount = matchCount + 1
        if matchCount > 1:
            return -1
    return matchCount == 1 ? matchIdx else: -1

fn compilerCoreDirectArgTypeText(plan: cflow.LowUirCompilerCorePlan,
                                 currentSignatureText: str,
                                 argKind: str,
                                 argPrimaryText: str,
                                 argArg0: int32): str =
    if argKind == "resolved_type":
        return argPrimaryText
    if argKind == "load_param":
        return compilerCoreSignatureParamTypeText(currentSignatureText, argArg0)
    if argKind == "load_param_cast":
        return argPrimaryText
    if argKind == "load_int32":
        return "int32"
    if argKind == "load_bool":
        return "bool"
    if argKind == "load_str":
        return "str"
    if argKind == "load_nil":
        return "nil"
    return ""

fn compilerCorePlanCallableMatchesDirectCallArgs(plan: cflow.LowUirCompilerCorePlan,
                                                 candidateIdx: int32,
                                                 currentSignatureText: str,
                                                 argKinds: str[],
                                                 argPrimaryTexts: str[],
                                                 argArg0s: int32[],
                                                 expectedParamCount: int32): bool =
    if candidateIdx < 0 || candidateIdx >= plan.itemIds.len:
        return false
    let topLevelKind = plan.topLevelKinds[candidateIdx]
    if topLevelKind != "fn" && topLevelKind != "iterator" && topLevelKind != "importc_fn":
        return false
    if expectedParamCount >= 0 && plan.paramCounts[candidateIdx] != expectedParamCount:
        return false
    if argKinds.len != argPrimaryTexts.len || argKinds.len != argArg0s.len:
        return false
    for i in 0..<argKinds.len:
        let argTypeText = compilerCoreDirectArgTypeText(plan,
                                                        currentSignatureText,
                                                        argKinds[i],
                                                        argPrimaryTexts[i],
                                                        argArg0s[i])
        if len(argTypeText) <= 0 || argTypeText == "nil":
            continue
        if compilerCoreNormalizedTypeText(compilerCoreSignatureParamTypeText(plan.signatureTexts[candidateIdx], i)) !=
           compilerCoreNormalizedTypeText(argTypeText):
            return false
    return true

fn compilerCorePlanCallableHasDirectExecTarget(plan: cflow.LowUirCompilerCorePlan,
                                               candidateIdx: int32,
                                               targetTriple: str): bool =
    if candidateIdx < 0 || candidateIdx >= plan.itemIds.len:
        return false
    if plan.topLevelKinds[candidateIdx] == "importc_fn":
        return len(compilerCoreDirectExecCalleeSymbol(plan, candidateIdx, targetTriple)) > 0
    return compilerCoreHasDirectExecBody(plan, candidateIdx, targetTriple)

fn compilerCoreFindPlanItemIndexByDirectCallArgs(plan: cflow.LowUirCompilerCorePlan,
                                                 itemIdx: int32,
                                                 opIdx: int32,
                                                 currentSignatureText: str,
                                                 argKinds: str[],
                                                 argPrimaryTexts: str[],
                                                 argArg0s: int32[],
                                                 expectedParamCount: int32,
                                                 targetTriple: str): int32 =
    let directIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opIdx])
    if directIdx != itemIdx &&
       compilerCorePlanCallableMatchesDirectCallArgs(plan,
                                                     directIdx,
                                                     currentSignatureText,
                                                     argKinds,
                                                     argPrimaryTexts,
                                                     argArg0s,
                                                     expectedParamCount) &&
       compilerCorePlanCallableHasDirectExecTarget(plan, directIdx, targetTriple):
        return directIdx
    let qualifiedName = plan.opPrimaryTexts[opIdx]
    if strings.find(qualifiedName, ".") >= 0:
        let qualifiedIdx = compilerCoreFindQualifiedPlanItemIndex(plan, itemIdx, qualifiedName, expectedParamCount)
        if qualifiedIdx != itemIdx &&
           compilerCorePlanCallableMatchesDirectCallArgs(plan,
                                                         qualifiedIdx,
                                                         currentSignatureText,
                                                         argKinds,
                                                         argPrimaryTexts,
                                                         argArg0s,
                                                         expectedParamCount) &&
           compilerCorePlanCallableHasDirectExecTarget(plan, qualifiedIdx, targetTriple):
            return qualifiedIdx
    var dotIdx: int32 = -1
    for i in 0..<len(qualifiedName):
        if qualifiedName[i] == '.':
            dotIdx = i
    let baseName = dotIdx >= 0 ? slice(qualifiedName, dotIdx + 1, len(qualifiedName) - dotIdx - 1) else: qualifiedName
    var directMatchIdx: int32 = -1
    var directMatchCount: int32 = 0
    for i in 0..<plan.itemIds.len:
        if i == itemIdx || plan.labels[i] != baseName:
            continue
        if !compilerCorePlanCallableMatchesDirectCallArgs(plan,
                                                          i,
                                                          currentSignatureText,
                                                          argKinds,
                                                          argPrimaryTexts,
                                                          argArg0s,
                                                          expectedParamCount):
            continue
        if !compilerCorePlanCallableHasDirectExecTarget(plan, i, targetTriple):
            continue
        directMatchIdx = i
        directMatchCount = directMatchCount + 1
        if directMatchCount > 1:
            return -1
    return directMatchCount == 1 ? directMatchIdx else: -1

fn compilerCoreDirectExecSimpleCallItemIndex(plan: cflow.LowUirCompilerCorePlan,
                                             itemIdx: int32,
                                             opStart: int32,
                                             opCount: int32,
                                             targetTriple: str): int32 =
    if opCount < 4 || opCount > 7:
        return -1
    let callIdx = opStart + opCount - 2
    let argCount = opCount - 3
    if plan.opKinds[opStart] != "load_routine" ||
       plan.opKinds[callIdx] != "call" ||
       plan.opKinds[callIdx + 1] != "return_value" ||
       plan.opArg0s[callIdx] != argCount:
        return -1
    var argKinds: str[] = []
    var argPrimaryTexts: str[] = []
    var argArg0s: int32[] = []
    for i in 0..<argCount:
        let argIdx = opStart + 1 + i
        if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[argIdx]):
            return -1
        add(argKinds, plan.opKinds[argIdx])
        add(argPrimaryTexts, plan.opPrimaryTexts[argIdx])
        add(argArg0s, plan.opArg0s[argIdx])
    return compilerCoreFindPlanItemIndexByDirectCallArgs(plan,
                                                         itemIdx,
                                                         opStart,
                                                         plan.signatureTexts[itemIdx],
                                                         argKinds,
                                                         argPrimaryTexts,
                                                         argArg0s,
                                                         argCount,
                                                         targetTriple)

fn compilerCoreFindUniqueDirectBodyPlanItemIndexByLabel(plan: cflow.LowUirCompilerCorePlan,
                                                        itemIdx: int32,
                                                        qualifiedName: str,
                                                        expectedParamCount: int32,
                                                        targetTriple: str): int32 =
    if strings.find(qualifiedName, ".") >= 0:
        let qualifiedIdx = compilerCoreFindQualifiedPlanItemIndex(plan,
                                                                  itemIdx,
                                                                  qualifiedName,
                                                                  expectedParamCount)
        if qualifiedIdx >= 0 &&
           compilerCoreHasDirectExecBody(plan, qualifiedIdx, targetTriple):
            return qualifiedIdx
    var dotIdx: int32 = -1
    for i in 0..<len(qualifiedName):
        if qualifiedName[i] == '.':
            dotIdx = i
    let baseName = dotIdx >= 0 ? slice(qualifiedName, dotIdx + 1, len(qualifiedName) - dotIdx - 1) else: qualifiedName
    var matchIdx: int32 = -1
    var matchCount: int32 = 0
    for i in 0..<plan.itemIds.len:
        if i == itemIdx || plan.labels[i] != baseName:
            continue
        let topLevelKind = plan.topLevelKinds[i]
        if topLevelKind != "fn" && topLevelKind != "iterator":
            continue
        if expectedParamCount >= 0 && plan.paramCounts[i] != expectedParamCount:
            continue
        if !compilerCoreHasDirectExecBody(plan, i, targetTriple):
            continue
        matchIdx = i
        matchCount = matchCount + 1
        if matchCount > 1:
            return -1
    return matchCount == 1 ? matchIdx else: -1

fn compilerCoreTrimAscii(text: str): str =
    if len(text) == 0:
        return ""
    var start: int32 = 0
    var stop: int32 = len(text)
    while start < stop && (text[start] == ' ' || text[start] == '\t' || text[start] == '\n' || text[start] == '\r'):
        start = start + 1
    while stop > start && (text[stop - 1] == ' ' || text[stop - 1] == '\t' || text[stop - 1] == '\n' || text[stop - 1] == '\r'):
        stop = stop - 1
    return slice(text, start, stop - start)

fn compilerCoreLastIndexOf(text: str, pattern: str): int32 =
    if len(pattern) == 0 || len(pattern) > len(text):
        return -1
    var i: int32 = len(text) - len(pattern)
    while i >= 0:
        var ok: bool = true
        for j in 0..<len(pattern):
            if text[i + j] != pattern[j]:
                ok = false
                break
        if ok:
            return i
        i = i - 1
    return -1

fn compilerCoreTopLevelTokenIndex(text: str, token: char): int32 =
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    for i in 0..<len(text):
        let ch = text[i]
        if ch == '(':
            depthParen = depthParen + 1
        elif ch == ')':
            depthParen = depthParen - 1
        elif ch == '[':
            depthBracket = depthBracket + 1
        elif ch == ']':
            depthBracket = depthBracket - 1
        elif ch == '{':
            depthBrace = depthBrace + 1
        elif ch == '}':
            depthBrace = depthBrace - 1
        elif ch == token && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            return i
    return -1

fn compilerCoreLastTopLevelAssignIndex(text: str): int32 =
    var out: int32 = -1
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var inString: bool = false
    var inChar: bool = false
    var i: int32 = 0
    while i < len(text):
        let ch = text[i]
        if inString:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '"':
                inString = false
            i = i + 1
            continue
        if inChar:
            if ch == '\\':
                i = i + 2
                continue
            if ch == '\'':
                inChar = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
            i = i + 1
            continue
        if ch == '\'':
            inChar = true
            i = i + 1
            continue
        if ch == '(':
            depthParen = depthParen + 1
            i = i + 1
            continue
        if ch == ')':
            depthParen = depthParen - 1
            i = i + 1
            continue
        if ch == '[':
            depthBracket = depthBracket + 1
            i = i + 1
            continue
        if ch == ']':
            depthBracket = depthBracket - 1
            i = i + 1
            continue
        if ch == '{':
            depthBrace = depthBrace + 1
            i = i + 1
            continue
        if ch == '}':
            depthBrace = depthBrace - 1
            i = i + 1
            continue
        if ch == '=' &&
           depthParen == 0 &&
           depthBracket == 0 &&
           depthBrace == 0 &&
           !(i > 0 && (text[i - 1] == '=' || text[i - 1] == '!' || text[i - 1] == '<' || text[i - 1] == '>')) &&
           !(i + 1 < len(text) && text[i + 1] == '='):
            out = i
        i = i + 1
    return out

fn compilerCoreSignatureParamTypeText(signatureText: str, paramIndex: int32): str =
    let openIdx = compilerCoreTopLevelTokenIndex(signatureText, '(')
    let closeIdx = compilerCoreLastIndexOf(signatureText, ")")
    if openIdx < 0 || closeIdx < 0 || closeIdx <= openIdx:
        return ""
    var partStart: int32 = openIdx + 1
    var partIdx: int32 = 0
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var i: int32 = openIdx + 1
    while i <= closeIdx:
        let atEnd = i == closeIdx
        let ch = atEnd ? ',' else: signatureText[i]
        if !atEnd:
            if ch == '(':
                depthParen = depthParen + 1
            elif ch == ')':
                depthParen = depthParen - 1
            elif ch == '[':
                depthBracket = depthBracket + 1
            elif ch == ']':
                depthBracket = depthBracket - 1
            elif ch == '{':
                depthBrace = depthBrace + 1
            elif ch == '}':
                depthBrace = depthBrace - 1
        
        if (atEnd || ch == ',') && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            let partText = compilerCoreTrimAscii(slice(signatureText, partStart, i - partStart))
            if len(partText) > 0:
                if partIdx == paramIndex:
                    let colonIdx = compilerCoreTopLevelTokenIndex(partText, ':')
                    if colonIdx < 0:
                        return ""
                    let typeText = compilerCoreTrimAscii(slice(partText, colonIdx + 1, len(partText) - colonIdx - 1))
                    let eqIdx = compilerCoreLastTopLevelAssignIndex(typeText)
                    if eqIdx < 0:
                        return typeText
                    return compilerCoreTrimAscii(slice(typeText, 0, eqIdx))
                partIdx = partIdx + 1
            
            partStart = i + 1
        
        i = i + 1
    return ""

fn compilerCoreTypeEndsWith(text: str, suffix: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(text)
    if len(suffix) > len(normalizedText):
        return false
    let start = len(normalizedText) - len(suffix)
    for i in 0..<len(suffix):
        if normalizedText[start + i] != suffix[i]:
            return false
    return true

fn compilerCoreNormalizedTypeText(text: str): str =
    if len(text) > 4 &&
       text[0] == 'v' &&
       text[1] == 'a' &&
       text[2] == 'r' &&
       text[3] == ' ':
        return strings.sliceBytes(text, 4, len(text) - 4)
    return text

fn compilerCoreTypeEndsWithRaw(text: str, suffix: str): bool =
    if len(suffix) > len(text):
        return false
    let start = len(text) - len(suffix)
    for i in 0..<len(suffix):
        if text[start + i] != suffix[i]:
            return false
    return true

fn compilerCoreTypeMatches(text: str, bareName: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(text)
    return normalizedText == bareName || compilerCoreTypeEndsWithRaw(normalizedText, "." + bareName)

fn compilerCoreTypeHeadText(text: str): str =
    let normalizedText = compilerCoreNormalizedTypeText(text)
    var genericIdx: int32 = -1
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    for i in 0..<len(normalizedText):
        let ch = normalizedText[i]
        if ch == '[' && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            genericIdx = i
            break
        if ch == '(':
            depthParen = depthParen + 1
        elif ch == ')':
            depthParen = depthParen - 1
        elif ch == '[':
            depthBracket = depthBracket + 1
        elif ch == ']':
            depthBracket = depthBracket - 1
        elif ch == '{':
            depthBrace = depthBrace + 1
        elif ch == '}':
            depthBrace = depthBrace - 1
    if genericIdx >= 0:
        return slice(normalizedText, 0, genericIdx)
    return normalizedText

fn compilerCoreTypeHeadMatches(text: str, bareName: str): bool =
    let headText = compilerCoreTypeHeadText(text)
    return headText == bareName || compilerCoreTypeEndsWithRaw(headText, "." + bareName)

fn compilerCoreDirectTuplePairElementTypes(typeText: str,
                                           elem0TypeText: var str,
                                           elem1TypeText: var str): bool =
    elem0TypeText = ""
    elem1TypeText = ""
    let normalizedText = compilerCoreNormalizedTypeText(typeText)
    if !compilerCoreTypeHeadMatches(normalizedText, "tuple"):
        return false
    let openIdx = compilerCoreTopLevelTokenIndex(normalizedText, '[')
    let closeIdx = compilerCoreLastIndexOf(normalizedText, "]")
    if openIdx < 0 || closeIdx <= openIdx:
        return false
    let innerText = slice(normalizedText, openIdx + 1, closeIdx - openIdx - 1)
    var partStart: int32 = 0
    var partIdx: int32 = 0
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var i: int32 = 0
    while i <= len(innerText):
        let atEnd = i == len(innerText)
        let ch = atEnd ? ',' else: innerText[i]
        if !atEnd:
            if ch == '(':
                depthParen = depthParen + 1
            elif ch == ')':
                depthParen = depthParen - 1
            elif ch == '[':
                depthBracket = depthBracket + 1
            elif ch == ']':
                depthBracket = depthBracket - 1
            elif ch == '{':
                depthBrace = depthBrace + 1
            elif ch == '}':
                depthBrace = depthBrace - 1
        if (atEnd || ch == ',') && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            let partText = compilerCoreTrimAscii(slice(innerText, partStart, i - partStart))
            if len(partText) <= 0:
                return false
            if partIdx == 0:
                elem0TypeText = partText
            elif partIdx == 1:
                elem1TypeText = partText
            else:
                return false
            partIdx = partIdx + 1
            partStart = i + 1
        i = i + 1
    return partIdx == 2

fn compilerCoreDirectTuplePairTypeSupported(typeText: str): bool =
    var elem0TypeText: str = ""
    var elem1TypeText: str = ""
    if !compilerCoreDirectTuplePairElementTypes(typeText, elem0TypeText, elem1TypeText):
        return false
    return compilerCoreDirectTypeRegWidth(elem0TypeText) == 1 &&
           compilerCoreDirectTypeRegWidth(elem1TypeText) == 1

fn compilerCoreDirectCallReturnTypeSupported(typeText: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(typeText)
    if len(normalizedText) <= 0:
        return true
    if compilerCoreTypeMatches(normalizedText, "void"):
        return true
    if compilerCoreTypeMatches(normalizedText, "bool") ||
       compilerCoreTypeMatches(normalizedText, "int8") ||
       compilerCoreTypeMatches(normalizedText, "int16") ||
       compilerCoreTypeMatches(normalizedText, "int32") ||
       compilerCoreTypeMatches(normalizedText, "int64") ||
       compilerCoreTypeMatches(normalizedText, "uint8") ||
       compilerCoreTypeMatches(normalizedText, "uint16") ||
       compilerCoreTypeMatches(normalizedText, "uint32") ||
       compilerCoreTypeMatches(normalizedText, "uint64") ||
       compilerCoreTypeMatches(normalizedText, "float64") ||
       compilerCoreTypeMatches(normalizedText, "char") ||
       compilerCoreTypeMatches(normalizedText, "ptr") ||
       compilerCoreTypeMatches(normalizedText, "cstring") ||
       compilerCoreTypeMatches(normalizedText, "DateTime") ||
       compilerCoreTypeMatches(normalizedText, "File") ||
       compilerCoreTypeMatches(normalizedText, "str") ||
       compilerCoreTypeMatches(normalizedText, "Bytes") ||
       compilerCoreTypeMatches(normalizedText, "ByteBuffer") ||
       compilerCoreTypeMatches(normalizedText, "ByteReader") ||
       compilerCoreDirectTuplePairTypeSupported(normalizedText) ||
       compilerCoreTypeEndsWith(normalizedText, "[]"):
        return true
    return false

fn compilerCoreDirectCtorConstReturnSupported(typeText: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(typeText)
    if len(normalizedText) <= 0:
        return false
    if compilerCoreTypeMatches(normalizedText, "float64") ||
       compilerCoreTypeMatches(normalizedText, "DateTime") ||
       compilerCoreTypeMatches(normalizedText, "File") ||
       compilerCoreTypeMatches(normalizedText, "str") ||
       compilerCoreTypeMatches(normalizedText, "Bytes") ||
       compilerCoreTypeMatches(normalizedText, "ByteBuffer") ||
       compilerCoreTypeMatches(normalizedText, "ByteReader") ||
       compilerCoreTypeEndsWith(normalizedText, "[]"):
        return false
    return true

fn compilerCoreDirectTypeRegWidth(typeText: str): int32 =
    let normalizedText = compilerCoreNormalizedTypeText(typeText)
    if compilerCoreTypeMatches(normalizedText, "str") ||
       compilerCoreTypeMatches(normalizedText, "Bytes") ||
       compilerCoreTypeMatches(normalizedText, "ByteBuffer") ||
       compilerCoreDirectTuplePairTypeSupported(normalizedText) ||
       compilerCoreTypeEndsWith(normalizedText, "[]"):
        return 2
    if compilerCoreTypeMatches(normalizedText, "ByteReader"):
        return 3
    return 1

fn compilerCoreParamBaseReg(signatureText: str, paramIndex: int32): int32 =
    var out: int32 = 0
    for i in 0..<paramIndex:
        out = out + compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(signatureText, i))
    return out

fn compilerCoreDirectAbiParamRegWidth(typeText: str): int32 =
    if len(typeText) > 4 &&
       typeText[0] == 'v' &&
       typeText[1] == 'a' &&
       typeText[2] == 'r' &&
       typeText[3] == ' ':
        return 1
    return compilerCoreDirectTypeRegWidth(typeText)

fn compilerCoreDirectAbiParamBaseReg(signatureText: str, paramIndex: int32): int32 =
    var out: int32 = 0
    for i in 0..<paramIndex:
        out = out + compilerCoreDirectAbiParamRegWidth(compilerCoreSignatureParamTypeText(signatureText, i))
    return out

fn compilerCoreDirectParamIs64(typeText: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(typeText)
    if compilerCoreTypeMatches(normalizedText, "int32") ||
       compilerCoreTypeMatches(normalizedText, "bool"):
        return false
    return true

fn compilerCoreDirectSecondRegIs64(typeText: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(typeText)
    var elem0TypeText: str = ""
    var elem1TypeText: str = ""
    if compilerCoreDirectTuplePairElementTypes(normalizedText, elem0TypeText, elem1TypeText):
        return compilerCoreDirectParamIs64(elem1TypeText)
    if compilerCoreTypeMatches(normalizedText, "str") ||
       compilerCoreTypeMatches(normalizedText, "Bytes") ||
       compilerCoreTypeMatches(normalizedText, "ByteBuffer") ||
       compilerCoreTypeEndsWith(normalizedText, "[]"):
        return false
    return true

fn compilerCoreDirectFieldReturnBinding(paramTypeText: str,
                                        fieldName: str,
                                        sourceReg: var int32,
                                        is64: var bool): bool =
    sourceReg = -1
    is64 = false
    if compilerCoreTypeMatches(paramTypeText, "str"):
        if fieldName == "data":
            sourceReg = 0
            is64 = true
            return true
        if fieldName == "len":
            sourceReg = 1
            is64 = false
            return true
    if compilerCoreTypeMatches(paramTypeText, "Bytes") ||
       compilerCoreTypeMatches(paramTypeText, "ByteBuffer"):
        if fieldName == "data":
            sourceReg = 0
            is64 = true
            return true
        if fieldName == "len":
            sourceReg = 1
            is64 = false
            return true
    if compilerCoreTypeEndsWith(paramTypeText, "[]"):
        if fieldName == "len":
            sourceReg = 0
            is64 = false
            return true
        if fieldName == "buffer":
            sourceReg = 1
            is64 = true
            return true
    if compilerCoreTypeMatches(paramTypeText, "DateTime") && fieldName == "unix":
        sourceReg = 0
        is64 = true
        return true
    if compilerCoreTypeMatches(paramTypeText, "ByteReader") && fieldName == "pos":
        sourceReg = 2
        is64 = false
        return true
    if compilerCoreTypeMatches(paramTypeText, "ExecCmdResult") && fieldName == "exitCode":
        sourceReg = 2
        is64 = false
        return true
    if compilerCoreTypeMatches(paramTypeText, "ErrorInfo") && fieldName == "code":
        sourceReg = 0
        is64 = false
        return true
    if compilerCoreTypeHeadMatches(paramTypeText, "Result") && fieldName == "ok":
        sourceReg = 0
        is64 = false
        return true
    return false

fn compilerCoreDirectScalarFieldArgBinding(paramTypeText: str,
                                           fieldName: str,
                                           targetTypeText: str,
                                           sourceReg: var int32,
                                           is64: var bool): bool =
    sourceReg = -1
    is64 = false
    if compilerCoreTypeMatches(paramTypeText, "str"):
        if fieldName == "data" &&
           (compilerCoreTypeMatches(targetTypeText, "ptr") ||
            compilerCoreTypeMatches(targetTypeText, "cstring")):
            sourceReg = 0
            is64 = true
            return true
        if fieldName == "len" &&
           (compilerCoreTypeMatches(targetTypeText, "int32") ||
            compilerCoreTypeMatches(targetTypeText, "int")):
            sourceReg = 1
            is64 = false
            return true
    if compilerCoreTypeMatches(paramTypeText, "Bytes") ||
       compilerCoreTypeMatches(paramTypeText, "ByteBuffer"):
        if fieldName == "data" &&
           compilerCoreTypeMatches(targetTypeText, "ptr"):
            sourceReg = 0
            is64 = true
            return true
        if fieldName == "len" &&
           (compilerCoreTypeMatches(targetTypeText, "int32") ||
            compilerCoreTypeMatches(targetTypeText, "int")):
            sourceReg = 1
            is64 = false
            return true
    if compilerCoreTypeEndsWith(paramTypeText, "[]"):
        if fieldName == "len" &&
           (compilerCoreTypeMatches(targetTypeText, "int32") ||
            compilerCoreTypeMatches(targetTypeText, "int")):
            sourceReg = 0
            is64 = false
            return true
        if fieldName == "buffer" &&
           compilerCoreTypeMatches(targetTypeText, "ptr"):
            sourceReg = 1
            is64 = true
            return true
    if compilerCoreTypeMatches(paramTypeText, "DateTime") &&
       fieldName == "unix" &&
       compilerCoreTypeMatches(targetTypeText, "int64"):
        sourceReg = 0
        is64 = true
        return true
    if compilerCoreTypeMatches(paramTypeText, "ByteReader") &&
       fieldName == "pos" &&
       (compilerCoreTypeMatches(targetTypeText, "int32") ||
        compilerCoreTypeMatches(targetTypeText, "int")):
        sourceReg = 2
        is64 = false
        return true
    if compilerCoreTypeMatches(paramTypeText, "ExecCmdResult") &&
       fieldName == "exitCode" &&
       (compilerCoreTypeMatches(targetTypeText, "int32") ||
        compilerCoreTypeMatches(targetTypeText, "int")):
        sourceReg = 2
        is64 = false
        return true
    if compilerCoreTypeMatches(paramTypeText, "ErrorInfo") &&
       fieldName == "code" &&
       (compilerCoreTypeMatches(targetTypeText, "int32") ||
        compilerCoreTypeMatches(targetTypeText, "int")):
        sourceReg = 0
        is64 = false
        return true
    if compilerCoreTypeHeadMatches(paramTypeText, "Result") &&
       fieldName == "ok" &&
       compilerCoreTypeMatches(targetTypeText, "bool"):
        sourceReg = 0
        is64 = false
        return true
    return false

