fn machineDirectIfElseCondArgThenCallArgWords(architecture: str,
                                              condKind: str,
                                              condPrimaryText: str,
                                              condArg0: int32,
                                              elseKind: str,
                                              elsePrimaryText: str,
                                              elseArg0: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64SubImmWord(true, 31, 31, 16))
    if !machineAppendLoadSimpleValueWords(architecture, words, 1, elseKind, elsePrimaryText, elseArg0):
        return ""
    add(words, machineAarch64StoreSpWord(true, 1, 0))
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, condKind, condPrimaryText, condArg0):
        return ""
    add(words, "94000000")
    add(words, machineAarch64CmpZeroWord(false, 0))
    let falseBranchIdx = words.len
    add(words, "")
    add(words, "94000000")
    let endBranchIdx = words.len
