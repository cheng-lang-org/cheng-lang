    return machineDirectReturnRegisterWords(architecture, sourceReg, is64)

fn compilerCoreDirectExecParamReturnWords(plan: cflow.LowUirCompilerCorePlan,
                                          itemIdx: int32,
                                          architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 2 ||
       plan.opKinds[opStart] != "load_param" ||
       plan.opKinds[opStart + 1] != "return_value":
        return ""
    let paramIdx = plan.opArg0s[opStart]
    if paramIdx < 0 || paramIdx >= plan.paramCounts[itemIdx]:
        return ""
    let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], paramIdx)
    let normalizedParamType = compilerCoreNormalizedTypeText(paramTypeText)
    let normalizedReturnType = compilerCoreNormalizedTypeText(plan.returnTypeTexts[itemIdx])
    if normalizedParamType != normalizedReturnType:
        return ""
    let regWidth = compilerCoreDirectTypeRegWidth(paramTypeText)
    if regWidth != 2:
        return ""
    let sourceReg0 = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], paramIdx)
    let sourceReg1 = sourceReg0 + 1
    return machineDirectReturnRegisterPairWords(architecture,
                                                sourceReg0,
                                                sourceReg1,
                                                false)

fn compilerCoreDirectExecBytesLiteralWords(plan: cflow.LowUirCompilerCorePlan,
                                           itemIdx: int32,
                                           architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "Bytes") &&
       opCount == 4 &&
       plan.opKinds[opStart] == "load_nil" &&
       plan.opKinds[opStart + 1] == "load_int32" &&
       plan.opPrimaryTexts[opStart + 1] == "0" &&
       plan.opKinds[opStart + 2] == "make_record" &&
       plan.opKinds[opStart + 3] == "return_value":
        return machineDirectReturnEmptyBytesWords(architecture)
    return ""

fn compilerCoreDirectExecCStringPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "str") || opCount < 2:
        return ""
    let payloadIdx = opStart + opCount - 2
    let returnIdx = opStart + opCount - 1
    if plan.opKinds[payloadIdx] != "load_str" || plan.opKinds[returnIdx] != "return_value":
        return ""
    var i = opStart
    while i < payloadIdx:
        if i + 1 >= payloadIdx:
            return ""
        if plan.opKinds[i] != "load_param" || plan.opKinds[i + 1] != "drop_value":
            return ""
        i = i + 2
    return plan.opPrimaryTexts[payloadIdx]

fn compilerCoreDirectExecCallCStringPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                                itemIdx: int32): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "return_value" &&
       plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false) &&
           !compilerCoreDirectExecImportcRawCStringAllowed(plan, calleeItemIdx, 1, "load_str"):
            return ""
        return plan.opPrimaryTexts[opStart + 1]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "load_str" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
            return ""
        return plan.opPrimaryTexts[opStart + 1]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2 &&
       compilerCoreIsDirectScalarValueKind(plan.opKinds[opStart + 2]):
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
            return ""
        return plan.opPrimaryTexts[opStart + 1]
    return ""

fn compilerCoreDirectExecCallSecondCStringPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                                      itemIdx: int32): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "load_str" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false) &&
           !compilerCoreDirectExecImportcRawCStringAllowed(plan, calleeItemIdx, 2, "load_str"):
            return ""
        return plan.opPrimaryTexts[opStart + 2]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "load_str" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let argTypeText = compilerCoreDirectLeadingCurrentParamTypeText(plan,
                                                                        itemIdx,
                                                                        plan.opKinds[opStart + 1],
                                                                        plan.opPrimaryTexts[opStart + 1],
                                                                        plan.opArg0s[opStart + 1])
        if len(argTypeText) <= 0:
            return ""
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false) &&
           !compilerCoreDirectExecImportcRawCStringAllowed(plan,
                                                           calleeItemIdx,
                                                           2,
                                                           plan.opKinds[opStart + 1]):
            return ""
        return plan.opPrimaryTexts[opStart + 2]
    return ""

fn compilerCoreMatchDirectExecFieldCStringIfExpr(plan: cflow.LowUirCompilerCorePlan,
                                                 itemIdx: int32,
                                                 sourceReg0: var int32,
                                                 sourceReg1: var int32,
                                                 sourceReg1Is64: var bool,
                                                 condPayload: var str,
                                                 thenPayload: var str,
                                                 elsePayload: var str): bool =
    sourceReg0 = -1
    sourceReg1 = -1
    sourceReg1Is64 = false
    condPayload = ""
    thenPayload = ""
    elsePayload = ""
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "str"):
        return false
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    var binaryIdx: int32 = -1
    var jumpIdx: int32 = -1
    var thenIdx: int32 = -1
    var jumpEndIdx: int32 = -1
    var elseLabelIdx: int32 = -1
    var elseIdx: int32 = -1
    var endLabelIdx: int32 = -1
    var phiIdx: int32 = -1
    var returnIdx: int32 = -1
    if opCount == 11 &&
       plan.opKinds[opStart] == "load_param" &&
       plan.opKinds[opStart + 1] == "load_str":
        let paramIdx = plan.opArg0s[opStart]
        if !compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], paramIdx), "str"):
            return false
        sourceReg0 = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], paramIdx)
        sourceReg1 = sourceReg0 + 1
        sourceReg1Is64 = compilerCoreDirectSecondRegIs64(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], paramIdx))
        binaryIdx = opStart + 2
        jumpIdx = opStart + 3
        thenIdx = opStart + 4
        jumpEndIdx = opStart + 5
        elseLabelIdx = opStart + 6
        elseIdx = opStart + 7
        endLabelIdx = opStart + 8
        phiIdx = opStart + 9
        returnIdx = opStart + 10
        condPayload = plan.opPrimaryTexts[opStart + 1]
    elif opCount == 12 &&
         plan.opKinds[opStart] == "load_param" &&
         plan.opKinds[opStart + 1] == "load_field" &&
         plan.opKinds[opStart + 2] == "load_str":
        let paramIdx = plan.opArg0s[opStart]
        var aggregateResultTypeText: str = ""
        if !compilerCoreDirectAggregateFieldBinding(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], paramIdx),
                                                    plan.opPrimaryTexts[opStart + 1],
                                                    aggregateResultTypeText,
                                                    sourceReg0,
                                                    sourceReg1,
                                                    sourceReg1Is64):
            return false
        if !compilerCoreTypeMatches(aggregateResultTypeText, "str") || sourceReg1Is64:
            return false
        binaryIdx = opStart + 3
        jumpIdx = opStart + 4
        thenIdx = opStart + 5
        jumpEndIdx = opStart + 6
        elseLabelIdx = opStart + 7
        elseIdx = opStart + 8
        endLabelIdx = opStart + 9
        phiIdx = opStart + 10
        returnIdx = opStart + 11
        condPayload = plan.opPrimaryTexts[opStart + 2]
    else:
        return false
    if plan.opKinds[binaryIdx] != "binary_op" ||
       plan.opKinds[jumpIdx] != "jump_if_false" ||
       plan.opKinds[thenIdx] != "load_str" ||
       plan.opKinds[jumpEndIdx] != "jump" ||
       plan.opKinds[elseLabelIdx] != "label" ||
       plan.opKinds[elseIdx] != "load_str" ||
       plan.opKinds[endLabelIdx] != "label" ||
       plan.opKinds[phiIdx] != "phi_merge" ||
       plan.opKinds[returnIdx] != "return_value":
        return false
    if plan.opPrimaryTexts[jumpIdx] != plan.opPrimaryTexts[elseLabelIdx] ||
       plan.opPrimaryTexts[jumpEndIdx] != plan.opPrimaryTexts[endLabelIdx]:
        return false
    if plan.opPrimaryTexts[binaryIdx] != "==" && plan.opPrimaryTexts[binaryIdx] != "!=":
        return false
    thenPayload = plan.opPrimaryTexts[thenIdx]
    elsePayload = plan.opPrimaryTexts[elseIdx]
    if plan.opPrimaryTexts[binaryIdx] == "!=":
        let originalThen = thenPayload
        thenPayload = elsePayload
        elsePayload = originalThen
    return true

fn compilerCoreDirectExecFieldCStringIfExprThenPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                                           itemIdx: int32): str =
    var sourceReg0: int32 = -1
    var sourceReg1: int32 = -1
    var sourceReg1Is64: bool = false
    var condPayload: str = ""
    var thenPayload: str = ""
    var elsePayload: str = ""
    if !compilerCoreMatchDirectExecFieldCStringIfExpr(plan,
                                                      itemIdx,
                                                      sourceReg0,
                                                      sourceReg1,
                                                      sourceReg1Is64,
                                                      condPayload,
                                                      thenPayload,
                                                      elsePayload):
        return ""
    return thenPayload

