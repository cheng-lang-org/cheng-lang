        let calleeWidth = compilerCoreDirectTypeRegWidth(calleeTypeText)
        if callerWidth != calleeWidth || callerWidth <= 0 || callerWidth > 2:
            return ""
        if callerWidth == 2 &&
           compilerCoreDirectSecondRegIs64(callerTypeText) != compilerCoreDirectSecondRegIs64(calleeTypeText):
            return ""
        let baseReg = compilerCoreParamBaseReg(callerSignatureText, argParamIdxs[i])
        if baseReg < 0 || baseReg + callerWidth - 1 > 7:
            return ""
        usedRegs[baseReg] = 1
        if callerWidth == 2:
            usedRegs[baseReg + 1] = 1
            add(argSlotOffsets, frameBytes)
            frameBytes = frameBytes + 24
        else:
            add(argSlotOffsets, -1)
    frameBytes = ((frameBytes + 15) / 16) * 16
    if frameBytes > 4095:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64SubImmWord(true, 31, 31, frameBytes))
    for reg in 0..<8:
        if usedRegs[reg] != 0:
            add(words, machineAarch64StoreSpWord(true, reg, reg * 8))
    for i in 0..<argParamIdxs.len:
        if argSlotOffsets[i] < 0:
            continue
        let callerTypeText = compilerCoreSignatureParamTypeText(callerSignatureText, argParamIdxs[i])
        let baseReg = compilerCoreParamBaseReg(callerSignatureText, argParamIdxs[i])
        add(words, machineAarch64LoadSpWord(true, 9, baseReg * 8))
        add(words, machineAarch64StoreSpWord(true, 9, argSlotOffsets[i]))
        add(words,
            machineAarch64LoadSpWord(compilerCoreDirectSecondRegIs64(callerTypeText),
                                     9,
                                     (baseReg + 1) * 8))
        add(words,
            machineAarch64StoreSpWord(compilerCoreDirectSecondRegIs64(callerTypeText),
                                      9,
                                      argSlotOffsets[i] + 8))
        add(words, machineAarch64StoreSpWord(false, 31, argSlotOffsets[i] + 12))
        add(words, machineAarch64StoreSpWord(true, 31, argSlotOffsets[i] + 16))
    for i in 0..<argParamIdxs.len:
        let callerTypeText = compilerCoreSignatureParamTypeText(callerSignatureText, argParamIdxs[i])
        let baseReg = compilerCoreParamBaseReg(callerSignatureText, argParamIdxs[i])
        if argSlotOffsets[i] >= 0:
            add(words, machineAarch64AddImmWord(true, i, 31, argSlotOffsets[i]))
        else:
            add(words,
                machineAarch64LoadSpWord(compilerCoreDirectParamIs64(callerTypeText),
                                         i,
                                         baseReg * 8))
    add(words, "94000000")
    add(words, machineAarch64MovZeroWord(0))
    add(words, machineAarch64AddImmWord(true, 31, 31, frameBytes))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectIfParamNilReturnElseCallImportcBridgeVoidWords(architecture: str,
                                                               callerSignatureText: str,
                                                               calleeSignatureText: str,
                                                               guardParamIdx: int32,
                                                               argParamIdxs: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if guardParamIdx < 0:
        return ""
    let guardTypeText = compilerCoreSignatureParamTypeText(callerSignatureText, guardParamIdx)
    if compilerCoreDirectTypeRegWidth(guardTypeText) != 1:
        return ""
    let guardBaseReg = compilerCoreParamBaseReg(callerSignatureText, guardParamIdx)
    if guardBaseReg < 0 || guardBaseReg > 7:
        return ""
    var usedRegs: int32[] = [0, 0, 0, 0, 0, 0, 0, 0]
    var argSlotOffsets: int32[]
    argSlotOffsets = []
    var frameBytes: int32 = 64
    for i in 0..<argParamIdxs.len:
        let callerTypeText = compilerCoreSignatureParamTypeText(callerSignatureText, argParamIdxs[i])
        let calleeTypeText = compilerCoreSignatureParamTypeText(calleeSignatureText, i)
        let callerWidth = compilerCoreDirectTypeRegWidth(callerTypeText)
        let calleeWidth = compilerCoreDirectTypeRegWidth(calleeTypeText)
        if callerWidth != calleeWidth || callerWidth <= 0 || callerWidth > 2:
            return ""
        if callerWidth == 2 &&
           compilerCoreDirectSecondRegIs64(callerTypeText) != compilerCoreDirectSecondRegIs64(calleeTypeText):
            return ""
        let baseReg = compilerCoreParamBaseReg(callerSignatureText, argParamIdxs[i])
        if baseReg < 0 || baseReg + callerWidth - 1 > 7:
            return ""
        usedRegs[baseReg] = 1
        if callerWidth == 2:
            usedRegs[baseReg + 1] = 1
            add(argSlotOffsets, frameBytes)
            frameBytes = frameBytes + 24
        else:
            add(argSlotOffsets, -1)
    frameBytes = ((frameBytes + 15) / 16) * 16
    if frameBytes > 4095:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    if guardBaseReg != 9:
        add(words, machineAarch64MovRegWord(compilerCoreDirectParamIs64(guardTypeText), 9, guardBaseReg))
    add(words, machineAarch64CmpZeroWord(compilerCoreDirectParamIs64(guardTypeText), 9))
    let elseBranchIdx = words.len
    add(words, "")
    let earlyReturnEpilogue = machineAarch64EpilogueWords()
    for i in 0..<earlyReturnEpilogue.len:
        add(words, earlyReturnEpilogue[i])
    let elseStartIdx = words.len
    add(words, machineAarch64SubImmWord(true, 31, 31, frameBytes))
    for reg in 0..<8:
        if usedRegs[reg] != 0:
            add(words, machineAarch64StoreSpWord(true, reg, reg * 8))
    for i in 0..<argParamIdxs.len:
        if argSlotOffsets[i] < 0:
            continue
        let callerTypeText = compilerCoreSignatureParamTypeText(callerSignatureText, argParamIdxs[i])
        let baseReg = compilerCoreParamBaseReg(callerSignatureText, argParamIdxs[i])
        add(words, machineAarch64LoadSpWord(true, 9, baseReg * 8))
        add(words, machineAarch64StoreSpWord(true, 9, argSlotOffsets[i]))
        add(words,
            machineAarch64LoadSpWord(compilerCoreDirectSecondRegIs64(callerTypeText),
                                     9,
                                     (baseReg + 1) * 8))
        add(words,
            machineAarch64StoreSpWord(compilerCoreDirectSecondRegIs64(callerTypeText),
                                      9,
                                      argSlotOffsets[i] + 8))
        add(words, machineAarch64StoreSpWord(false, 31, argSlotOffsets[i] + 12))
        add(words, machineAarch64StoreSpWord(true, 31, argSlotOffsets[i] + 16))
    for i in 0..<argParamIdxs.len:
        let callerTypeText = compilerCoreSignatureParamTypeText(callerSignatureText, argParamIdxs[i])
        let baseReg = compilerCoreParamBaseReg(callerSignatureText, argParamIdxs[i])
        if argSlotOffsets[i] >= 0:
            add(words, machineAarch64AddImmWord(true, i, 31, argSlotOffsets[i]))
        else:
            add(words,
                machineAarch64LoadSpWord(compilerCoreDirectParamIs64(callerTypeText),
                                         i,
                                         baseReg * 8))
    add(words, "94000000")
    add(words, machineAarch64MovZeroWord(0))
    add(words, machineAarch64AddImmWord(true, 31, 31, frameBytes))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[elseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - elseBranchIdx, "ne")
    return joinWordList(words)

fn machineDirectCallScalarArgsVarStrOutReturnWords(architecture: str,
                                                   argKinds: str[],
                                                   argPrimaryTexts: str[],
                                                   argArg0s: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if argKinds.len != argPrimaryTexts.len || argKinds.len != argArg0s.len || argKinds.len > 7:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64SubImmWord(true, 31, 31, 32))
    if !machineAppendLoadSimpleCallArgsWords(architecture, words, argKinds, argPrimaryTexts, argArg0s):
        return ""
    add(words, machineAarch64AddImmWord(true, argKinds.len, 31, 0))
    add(words, "94000000")
    add(words, machineAarch64LoadSpWord(true, 0, 0))
    add(words, machineAarch64LoadSpWord(false, 1, 8))
    add(words, machineAarch64AddImmWord(true, 31, 31, 32))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

