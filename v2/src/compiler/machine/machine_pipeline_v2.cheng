fn machineDirectNestedCallCompareConstRhsWords(architecture: str,
                                               signatureText: str,
                                               argKinds: str[],
                                               argPrimaryTexts: str[],
                                               argArg0s: int32[],
                                               rhsKind: str,
                                               rhsPrimaryText: str,
                                               rhsArg0: int32,
                                               operatorText: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if operatorText != "==" && operatorText != "!=" &&
       operatorText != "<" && operatorText != "<=" &&
       operatorText != ">" && operatorText != ">=":
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadDirectNestedCallArgsWords(architecture,
                                                   words,
                                                   signatureText,
                                                   argKinds,
                                                   argPrimaryTexts,
                                                   argArg0s):
        return ""
    add(words, "94000000")
    add(words, "94000000")
    if !machineAppendLoadSimpleValueWords(architecture, words, 1, rhsKind, rhsPrimaryText, rhsArg0):
        return ""
    add(words, machineAarch64CmpRegWord(false, 0, 1))
    let cond = machineCompareOperatorCond(operatorText)
    add(words, machineAarch64BranchCondWord(3, cond))
    add(words, machineAarch64MovInt32Word(0, 0))
    add(words, machineAarch64BranchWord(2))
    add(words, machineAarch64MovInt32Word(0, 1))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectFallbackCallWords(architecture: str,
                                  argKinds: str[],
                                  argPrimaryTexts: str[],
                                  argArg0s: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleCallArgsWords(architecture, words, argKinds, argPrimaryTexts, argArg0s):
        return ""
    add(words, "94000000")
    add(words, machineAarch64CmpZeroWord(true, 0))
    let elseBranchIdx = words.len
    add(words, "")
    let successEpilogue = machineAarch64EpilogueWords()
    for i in 0..<successEpilogue.len:
        add(words, successEpilogue[i])
    let elseStartIdx = words.len
    if !machineAppendLoadSimpleCallArgsWords(architecture, words, argKinds, argPrimaryTexts, argArg0s):
        return ""
    add(words, "94000000")
    let fallbackEpilogue = machineAarch64EpilogueWords()
    for i in 0..<fallbackEpilogue.len:
        add(words, fallbackEpilogue[i])
    words[elseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - elseBranchIdx, "eq")
    return joinWordList(words)

fn machineAppendLoadSimpleValueWords(architecture: str,
                                     words: var str[],
                                     targetReg: int32,
                                     opKind: str,
                                     opPrimaryText: str,
                                     opArg0: int32): bool =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if opKind == "load_param":
        if opArg0 < 0 || opArg0 > 7:
            return false
        if opArg0 != targetReg:
            add(words, machineAarch64MovRegWord(true, targetReg, opArg0))
        return true
    if opKind == "load_int32":
        let value = parser.parseIntStrict(opPrimaryText)
        if value < 0 || value > 65535:
            return false
        add(words, machineAarch64MovInt32Word(targetReg, value))
        return true
    if opKind == "load_bool":
        add(words, machineAarch64MovInt32Word(targetReg, opPrimaryText == "true" ? 1 else: 0))
        return true
    if opKind == "load_nil":
        add(words, machineAarch64MovZeroWord(targetReg))
        return true
    if opKind == "resolved_type":
        if opArg0 < 0 || opArg0 > 7 ||
           compilerCoreDirectTypeRegWidth(opPrimaryText) != 1:
            return false
        if opArg0 != targetReg:
            add(words, machineAarch64MovRegWord(compilerCoreDirectParamIs64(opPrimaryText), targetReg, opArg0))
        return true
    return false

fn machineFindSavedParamIndex(savedSourceRegs: int32[], sourceReg: int32): int32 =
    for i in 0..<savedSourceRegs.len:
        if savedSourceRegs[i] == sourceReg:
            return i
    return -1

fn machineAppendLoadSimpleCallArgsWords(architecture: str,
                                        words: var str[],
                                        argKinds: str[],
                                        argPrimaryTexts: str[],
                                        argArg0s: int32[]): bool =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if argKinds.len != argPrimaryTexts.len || argKinds.len != argArg0s.len:
        return false
    var savedSourceRegs: int32[]
    var savedScratchRegs: int32[]
    savedSourceRegs = []
    savedScratchRegs = []
    let scratchRegs = [9, 10]
    for i in 0..<argKinds.len:
        if argKinds[i] == "load_param":
            let srcReg = argArg0s[i]
            if srcReg < 0 || srcReg > 7:
                return false
            if srcReg < i && machineFindSavedParamIndex(savedSourceRegs, srcReg) < 0:
                if savedScratchRegs.len >= scratchRegs.len:
                    return false
                let scratchReg = scratchRegs[savedScratchRegs.len]
                add(words, machineAarch64MovRegWord(true, scratchReg, srcReg))
                add(savedSourceRegs, srcReg)
                add(savedScratchRegs, scratchReg)
    for i in 0..<argKinds.len:
        if argKinds[i] == "load_param":
            let srcReg = argArg0s[i]
            if srcReg < 0 || srcReg > 7:
                return false
            if srcReg != i:
                let savedIdx = machineFindSavedParamIndex(savedSourceRegs, srcReg)
                let loadReg = savedIdx >= 0 ? savedScratchRegs[savedIdx] else: srcReg
                add(words, machineAarch64MovRegWord(true, i, loadReg))
        elif !machineAppendLoadSimpleValueWords(architecture,
                                                words,
                                                i,
                                                argKinds[i],
                                                argPrimaryTexts[i],
                                                argArg0s[i]):
            return false
    return true

fn machineAppendLoadDirectNestedCallArgsWords(architecture: str,
                                              words: var str[],
                                              signatureText: str,
                                              argKinds: str[],
                                              argPrimaryTexts: str[],
                                              argArg0s: int32[]): bool =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if argKinds.len != argPrimaryTexts.len || argKinds.len != argArg0s.len:
        return false
    var usedRegs: int32[] = [0, 0, 0, 0, 0, 0, 0, 0]
    var targetReg: int32 = 0
    var needsSpill: bool = false
    for i in 0..<argKinds.len:
        if argKinds[i] == "load_param":
            let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, argArg0s[i])
            let regWidth = compilerCoreDirectTypeRegWidth(paramTypeText)
            let baseReg = compilerCoreParamBaseReg(signatureText, argArg0s[i])
            if regWidth <= 0 || regWidth > 2:
                return false
            if baseReg < 0 || baseReg + regWidth - 1 > 7:
                return false
            if targetReg + regWidth > 8:
                return false
            needsSpill = true
            usedRegs[baseReg] = 1
            if regWidth == 2:
                usedRegs[baseReg + 1] = 1
            targetReg = targetReg + regWidth
            continue
        if targetReg >= 8:
            return false
        targetReg = targetReg + 1
    if needsSpill:
        add(words, machineAarch64SubImmWord(true, 31, 31, 64))
        for reg in 0..<8:
            if usedRegs[reg] != 0:
                add(words, machineAarch64StoreSpWord(true, reg, reg * 8))
    targetReg = 0
    for i in 0..<argKinds.len:
        if argKinds[i] == "load_param":
            let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, argArg0s[i])
            let regWidth = compilerCoreDirectTypeRegWidth(paramTypeText)
            let baseReg = compilerCoreParamBaseReg(signatureText, argArg0s[i])
            if regWidth == 1:
                add(words,
                    machineAarch64LoadSpWord(compilerCoreDirectParamIs64(paramTypeText),
                                             targetReg,
                                             baseReg * 8))
            else:
                add(words, machineAarch64LoadSpWord(true, targetReg, baseReg * 8))
                add(words,
                    machineAarch64LoadSpWord(compilerCoreDirectSecondRegIs64(paramTypeText),
                                             targetReg + 1,
                                             (baseReg + 1) * 8))
            targetReg = targetReg + regWidth
            continue
        if !machineAppendLoadSimpleValueWords(architecture,
                                              words,
                                              targetReg,
                                              argKinds[i],
                                              argPrimaryTexts[i],
                                              argArg0s[i]):
            return false
        targetReg = targetReg + 1
    if needsSpill:
        add(words, machineAarch64AddImmWord(true, 31, 31, 64))
    return true

fn machineDirectCurrentArgRegWidth(signatureText: str,
                                   opKind: str,
                                   opArg0: int32): int32 =
    if opKind == "load_param":
        return compilerCoreDirectAbiParamRegWidth(compilerCoreSignatureParamTypeText(signatureText, opArg0))
    if opKind == "load_int32" || opKind == "load_bool" || opKind == "load_nil":
        return 1
    return 0

fn machineAppendSpillDirectCurrentArgsWords(architecture: str,
                                            words: var str[],
                                            signatureText: str,
                                            argKinds: str[],
                                            argPrimaryTexts: str[],
                                            argArg0s: int32[]): bool =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if argKinds.len != argPrimaryTexts.len || argKinds.len != argArg0s.len:
        return false
    add(words, machineAarch64SubImmWord(true, 31, 31, 64))
    var spillOffset: int32 = 0
    for i in 0..<argKinds.len:
        let regWidth = machineDirectCurrentArgRegWidth(signatureText, argKinds[i], argArg0s[i])
        if regWidth <= 0 || regWidth > 2 || spillOffset + regWidth * 8 > 64:
            return false
        if argKinds[i] == "load_param":
            let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, argArg0s[i])
            let baseReg = compilerCoreDirectAbiParamBaseReg(signatureText, argArg0s[i])
            if baseReg < 0 || baseReg + regWidth - 1 > 7:
                return false
            if regWidth == 1:
                add(words,
                    machineAarch64StoreSpWord(compilerCoreDirectParamIs64(paramTypeText),
                                              baseReg,
                                              spillOffset))
            else:
                add(words, machineAarch64StoreSpWord(true, baseReg, spillOffset))
                add(words,
                    machineAarch64StoreSpWord(compilerCoreDirectSecondRegIs64(paramTypeText),
                                              baseReg + 1,
                                              spillOffset + 8))
        else:
            if !machineAppendLoadSimpleValueWords(architecture,
                                                  words,
                                                  9,
                                                  argKinds[i],
                                                  argPrimaryTexts[i],
                                                  argArg0s[i]):
                return false
            add(words, machineAarch64StoreSpWord(true, 9, spillOffset))
        spillOffset = spillOffset + regWidth * 8
    return true

fn machineAppendRestoreSpilledDirectCurrentArgsWords(architecture: str,
                                                     words: var str[],
                                                     signatureText: str,
                                                     startReg: int32,
                                                     argKinds: str[],
                                                     argArg0s: int32[]): bool =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if argKinds.len != argArg0s.len:
        return false
    var spillOffset: int32 = 0
    var targetReg: int32 = startReg
    for i in 0..<argKinds.len:
        let regWidth = machineDirectCurrentArgRegWidth(signatureText, argKinds[i], argArg0s[i])
        if regWidth <= 0 || regWidth > 2 || targetReg + regWidth > 8:
            return false
        if regWidth == 1:
            let is64 = argKinds[i] == "load_param"
                ? compilerCoreDirectParamIs64(compilerCoreSignatureParamTypeText(signatureText, argArg0s[i]))
                : true
            add(words, machineAarch64LoadSpWord(is64, targetReg, spillOffset))
        else:
            let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, argArg0s[i])
            add(words, machineAarch64LoadSpWord(true, targetReg, spillOffset))
            add(words,
                machineAarch64LoadSpWord(compilerCoreDirectSecondRegIs64(paramTypeText),
                                         targetReg + 1,
                                         spillOffset + 8))
        targetReg = targetReg + regWidth
        spillOffset = spillOffset + regWidth * 8
    add(words, machineAarch64AddImmWord(true, 31, 31, 64))
    return true

fn machineDirectNestedCallTrailingArgsWords(architecture: str,
                                            signatureText: str,
                                            innerArgKinds: str[],
                                            innerArgPrimaryTexts: str[],
                                            innerArgArg0s: int32[],
                                            innerResultWidth: int32,
                                            outerArgKinds: str[],
                                            outerArgPrimaryTexts: str[],
                                            outerArgArg0s: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if innerResultWidth < 1 || innerResultWidth > 2:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    if outerArgKinds.len > 0 &&
       !machineAppendSpillDirectCurrentArgsWords(architecture,
                                                 words,
                                                 signatureText,
                                                 outerArgKinds,
                                                 outerArgPrimaryTexts,
                                                 outerArgArg0s):
        return ""
    if !machineAppendLoadDirectNestedCallArgsWords(architecture,
                                                   words,
                                                   signatureText,
                                                   innerArgKinds,
                                                   innerArgPrimaryTexts,
                                                   innerArgArg0s):
        return ""
    add(words, "94000000")
    if outerArgKinds.len > 0 &&
       !machineAppendRestoreSpilledDirectCurrentArgsWords(architecture,
                                                          words,
                                                          signatureText,
                                                          innerResultWidth,
                                                          outerArgKinds,
                                                          outerArgArg0s):
        return ""
    add(words, "94000000")
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectNestedCallLeadingArgsWords(architecture: str,
                                           signatureText: str,
                                           outerArgKinds: str[],
                                           outerArgPrimaryTexts: str[],
                                           outerArgArg0s: int32[],
                                           innerArgKinds: str[],
                                           innerArgPrimaryTexts: str[],
                                           innerArgArg0s: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var leadingRegWidth: int32 = 0
    for i in 0..<outerArgKinds.len:
        let regWidth = machineDirectCurrentArgRegWidth(signatureText, outerArgKinds[i], outerArgArg0s[i])
        if regWidth <= 0 || regWidth > 2 || leadingRegWidth + regWidth >= 8:
            return ""
        leadingRegWidth = leadingRegWidth + regWidth
    var words: str[]
    words = machineAarch64PrologueWords()
    if outerArgKinds.len > 0 &&
       !machineAppendSpillDirectCurrentArgsWords(architecture,
                                                 words,
                                                 signatureText,
                                                 outerArgKinds,
                                                 outerArgPrimaryTexts,
                                                 outerArgArg0s):
        return ""
    if !machineAppendLoadDirectNestedCallArgsWords(architecture,
                                                   words,
                                                   signatureText,
                                                   innerArgKinds,
                                                   innerArgPrimaryTexts,
                                                   innerArgArg0s):
        return ""
    add(words, "94000000")
    add(words, machineAarch64MovRegWord(true, 8, 0))
    if outerArgKinds.len > 0 &&
       !machineAppendRestoreSpilledDirectCurrentArgsWords(architecture,
                                                          words,
                                                          signatureText,
                                                          0,
                                                          outerArgKinds,
                                                          outerArgArg0s):
        return ""
    add(words, machineAarch64MovRegWord(true, leadingRegWidth, 8))
    add(words, "94000000")
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

