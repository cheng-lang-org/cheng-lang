fn machineDirectCallThreeSimpleArgVoidWords(architecture: str,
                                            arg0Kind: str,
                                            arg0PrimaryText: str,
                                            arg0Arg0: int32,
                                            arg1Kind: str,
                                            arg1PrimaryText: str,
                                            arg1Arg0: int32,
                                            arg2Kind: str,
                                            arg2PrimaryText: str,
                                            arg2Arg0: int32): str =
    if architecture != "aarch64":
