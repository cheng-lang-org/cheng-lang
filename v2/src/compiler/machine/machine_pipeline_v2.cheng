fn compilerCoreMatchDirectExecParamCStringChainReturn(plan: cflow.LowUirCompilerCorePlan,
                                                      itemIdx: int32,
                                                      minIfCount: int32,
                                                      sourceReg0: var int32,
                                                      sourceReg1: var int32,
                                                      sourceReg1Is64: var bool,
                                                      condPayloads: var str[],
                                                      returnPayloads: var str[]): bool =
    sourceReg0 = -1
    sourceReg1 = -1
    sourceReg1Is64 = false
    condPayloads = []
    returnPayloads = []
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "str"):
        return false
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount < minIfCount * 7 + 2 || (opCount - 2) % 7 != 0:
        return false
    let ifCount = (opCount - 2) / 7
    if ifCount < minIfCount || ifCount == 4:
        return false
    let finalOpStart = opStart + ifCount * 7
    if plan.opKinds[finalOpStart] != "load_str" ||
       plan.opKinds[finalOpStart + 1] != "return_value":
        return false
    let paramIdx = plan.opArg0s[opStart]
    let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], paramIdx)
    if !compilerCoreTypeMatches(paramTypeText, "str"):
        return false
    sourceReg0 = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], paramIdx)
    sourceReg1 = sourceReg0 + 1
    sourceReg1Is64 = compilerCoreDirectSecondRegIs64(paramTypeText)
    if sourceReg1Is64:
        return false
    for i in 0..<ifCount:
        let base = opStart + i * 7
        if plan.opKinds[base] != "load_param" ||
           plan.opKinds[base + 1] != "load_str" ||
           plan.opKinds[base + 2] != "binary_op" ||
           plan.opKinds[base + 3] != "jump_if_false" ||
           plan.opKinds[base + 4] != "load_str" ||
           plan.opKinds[base + 5] != "return_value" ||
           plan.opKinds[base + 6] != "label" ||
           plan.opArg0s[base] != paramIdx ||
           plan.opPrimaryTexts[base + 2] != "==" ||
           plan.opPrimaryTexts[base + 3] != plan.opPrimaryTexts[base + 6]:
            return false
        add(condPayloads, plan.opPrimaryTexts[base + 1])
        add(returnPayloads, plan.opPrimaryTexts[base + 4])
    add(returnPayloads, plan.opPrimaryTexts[finalOpStart])
    return true

