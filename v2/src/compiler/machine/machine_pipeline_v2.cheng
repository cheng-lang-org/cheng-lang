fn compilerCoreDirectVarFieldStoreBinding(paramTypeText: str,
                                          fieldName: str,
                                          offsetBytes: var int32,
                                          is64: var bool): bool =
    offsetBytes = -1
    is64 = false
    if len(paramTypeText) <= 4 ||
       paramTypeText[0] != 'v' ||
       paramTypeText[1] != 'a' ||
       paramTypeText[2] != 'r' ||
       paramTypeText[3] != ' ':
        return false
    if compilerCoreTypeMatches(paramTypeText, "str"):
        if fieldName == "data":
            offsetBytes = 0
            is64 = true
            return true
        if fieldName == "len":
            offsetBytes = 8
            is64 = false
            return true
        if fieldName == "store_id":
            offsetBytes = 12
            is64 = false
            return true
        if fieldName == "flags":
            offsetBytes = 16
            is64 = false
            return true
    if compilerCoreTypeMatches(paramTypeText, "Bytes") ||
       compilerCoreTypeMatches(paramTypeText, "ByteBuffer"):
        if fieldName == "data":
            offsetBytes = 0
            is64 = true
            return true
        if fieldName == "len":
            offsetBytes = 8
            is64 = false
            return true
    if compilerCoreTypeEndsWith(paramTypeText, "[]"):
        if fieldName == "len":
            offsetBytes = 0
            is64 = false
            return true
        if fieldName == "cap":
            offsetBytes = 4
            is64 = false
            return true
        if fieldName == "buffer":
            offsetBytes = 8
            is64 = true
            return true
    if compilerCoreTypeMatches(paramTypeText, "DateTime") && fieldName == "unix":
        offsetBytes = 0
        is64 = true
        return true
    if compilerCoreTypeMatches(paramTypeText, "ErrorInfo") && fieldName == "code":
        offsetBytes = 0
        is64 = false
        return true
    return false

fn compilerCoreDirectVarAggregateFieldStoreBinding(paramTypeText: str,
                                                   fieldName: str,
                                                   resultTypeText: var str,
                                                   offsetBytes: var int32): bool =
    resultTypeText = ""
    offsetBytes = -1
    if len(paramTypeText) <= 4 ||
       paramTypeText[0] != 'v' ||
       paramTypeText[1] != 'a' ||
       paramTypeText[2] != 'r' ||
       paramTypeText[3] != ' ':
        return false
    if compilerCoreTypeMatches(paramTypeText, "ErrorInfo") && fieldName == "msg":
        resultTypeText = "str"
        offsetBytes = 8
        return true
    return false

fn compilerCoreDirectArithmeticScalarTypeSupported(typeText: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(typeText)
    return compilerCoreTypeMatches(normalizedText, "int") ||
           compilerCoreTypeMatches(normalizedText, "int32") ||
           compilerCoreTypeMatches(normalizedText, "int64") ||
           compilerCoreTypeMatches(normalizedText, "uint8") ||
           compilerCoreTypeMatches(normalizedText, "uint16") ||
           compilerCoreTypeMatches(normalizedText, "uint32") ||
           compilerCoreTypeMatches(normalizedText, "uint64")

fn compilerCoreDirectVarScalarStoreParamBinding(signatureText: str,
                                                paramIndex: int32,
                                                is64: var bool): bool =
    is64 = false
    let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, paramIndex)
    if len(paramTypeText) <= 4 ||
       paramTypeText[0] != 'v' ||
       paramTypeText[1] != 'a' ||
       paramTypeText[2] != 'r' ||
       paramTypeText[3] != ' ':
        return false
    if compilerCoreDirectTypeRegWidth(paramTypeText) != 1 ||
       !compilerCoreDirectArithmeticScalarTypeSupported(paramTypeText):
        return false
    is64 = compilerCoreDirectParamIs64(paramTypeText)
    return true

fn compilerCoreDirectParamFieldReturnBinding(signatureText: str,
                                             paramIndex: int32,
                                             fieldName: str,
                                             sourceReg: var int32,
                                             is64: var bool): bool =
    let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, paramIndex)
    var relativeReg: int32 = -1
    if !compilerCoreDirectFieldReturnBinding(paramTypeText, fieldName, relativeReg, is64):
        return false
    sourceReg = compilerCoreParamBaseReg(signatureText, paramIndex) + relativeReg
    return true

fn compilerCoreDirectAbiParamFieldReturnBinding(signatureText: str,
                                                paramIndex: int32,
                                                fieldName: str,
                                                sourceReg: var int32,
                                                is64: var bool): bool =
    let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, paramIndex)
    var relativeReg: int32 = -1
    if !compilerCoreDirectFieldReturnBinding(paramTypeText, fieldName, relativeReg, is64):
        return false
    sourceReg = compilerCoreDirectAbiParamBaseReg(signatureText, paramIndex) + relativeReg
    return true

fn compilerCoreDirectParamScalarFieldArgBinding(signatureText: str,
                                                paramIndex: int32,
                                                fieldName: str,
                                                targetTypeText: str,
                                                sourceReg: var int32,
                                                is64: var bool): bool =
    let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, paramIndex)
    var relativeReg: int32 = -1
    if !compilerCoreDirectScalarFieldArgBinding(paramTypeText,
                                                fieldName,
                                                targetTypeText,
                                                relativeReg,
                                                is64):
        return false
    sourceReg = compilerCoreParamBaseReg(signatureText, paramIndex) + relativeReg
    return true

fn compilerCoreDirectParamAggregateFieldBinding(signatureText: str,
                                                paramIndex: int32,
                                                fieldName: str,
                                                resultTypeText: var str,
                                                sourceReg0: var int32,
                                                sourceReg1: var int32,
                                                sourceReg1Is64: var bool): bool =
    let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, paramIndex)
    var relativeReg0: int32 = -1
    var relativeReg1: int32 = -1
    if !compilerCoreDirectAggregateFieldBinding(paramTypeText,
                                                fieldName,
                                                resultTypeText,
                                                relativeReg0,
                                                relativeReg1,
                                                sourceReg1Is64):
        return false
    let baseReg = compilerCoreParamBaseReg(signatureText, paramIndex)
    sourceReg0 = baseReg + relativeReg0
    sourceReg1 = baseReg + relativeReg1
    return true

fn compilerCoreDirectAbiParamAggregateFieldBinding(signatureText: str,
                                                   paramIndex: int32,
                                                   fieldName: str,
                                                   resultTypeText: var str,
                                                   sourceReg0: var int32,
                                                   sourceReg1: var int32,
                                                   sourceReg1Is64: var bool): bool =
    let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, paramIndex)
    var relativeReg0: int32 = -1
    var relativeReg1: int32 = -1
    if !compilerCoreDirectAggregateFieldBinding(paramTypeText,
                                                fieldName,
                                                resultTypeText,
                                                relativeReg0,
                                                relativeReg1,
                                                sourceReg1Is64):
        return false
    let baseReg = compilerCoreDirectAbiParamBaseReg(signatureText, paramIndex)
    sourceReg0 = baseReg + relativeReg0
    sourceReg1 = baseReg + relativeReg1
    return true

fn compilerCoreDirectParamNestedFieldReturnBinding(signatureText: str,
                                                   paramIndex: int32,
                                                   aggregateFieldName: str,
                                                   nestedFieldName: str,
                                                   sourceReg: var int32,
                                                   is64: var bool): bool =
    var aggregateResultTypeText: str = ""
    var aggregateReg0: int32 = -1
    var aggregateReg1: int32 = -1
    var aggregateReg1Is64: bool = false
    if !compilerCoreDirectParamAggregateFieldBinding(signatureText,
                                                     paramIndex,
                                                     aggregateFieldName,
                                                     aggregateResultTypeText,
                                                     aggregateReg0,
                                                     aggregateReg1,
                                                     aggregateReg1Is64):
        return false
    var nestedRelativeReg: int32 = -1
    if !compilerCoreDirectFieldReturnBinding(aggregateResultTypeText, nestedFieldName, nestedRelativeReg, is64):
        return false
    if nestedRelativeReg == 0:
        sourceReg = aggregateReg0
        return true
    if nestedRelativeReg == 1:
        sourceReg = aggregateReg1
        return true
    return false

fn compilerCoreDirectParamTripleFieldReturnBinding(signatureText: str,
                                                   paramIndex: int32,
                                                   field0Name: str,
                                                   field1Name: str,
                                                   field2Name: str,
                                                   sourceReg: var int32,
                                                   is64: var bool): bool =
    let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, paramIndex)
    var resultTypeText: str = ""
    var aggregateReg0: int32 = -1
    var aggregateReg1: int32 = -1
    var aggregateReg1Is64: bool = false
    if !compilerCoreDirectNestedAggregateFieldBinding(paramTypeText,
                                                      field0Name,
                                                      field1Name,
                                                      resultTypeText,
                                                      aggregateReg0,
                                                      aggregateReg1,
                                                      aggregateReg1Is64):
        return false
    var nestedRelativeReg: int32 = -1
    if !compilerCoreDirectFieldReturnBinding(resultTypeText, field2Name, nestedRelativeReg, is64):
        return false
    if nestedRelativeReg == 0:
        sourceReg = aggregateReg0
        return true
    if nestedRelativeReg == 1:
        sourceReg = aggregateReg1
        return true
    return false

fn compilerCoreDirectExecParamAggregateWords(plan: cflow.LowUirCompilerCorePlan,
                                             itemIdx: int32,
                                             architecture: str): str =
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "ByteReader") || plan.paramCounts[itemIdx] != 1:
        return ""
    let returnTypeText = plan.returnTypeTexts[itemIdx]
    let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
    if !compilerCoreTypeMatches(paramTypeText, "ByteBuffer"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount < 6:
        return ""
    let returnIdx = opStart + opCount - 1
    let loadIdx = returnIdx - 1
    if plan.opKinds[loadIdx] != "load_local" || plan.opKinds[returnIdx] != "return_value":
        return ""
    let localSlot = plan.opArg0s[loadIdx]
    if localSlot < 0:
        return ""
    var i = opStart
    var sawDecl = false
    var sawBuf = false
    var sawPos = false
    while i < loadIdx:
        if plan.opKinds[i] == "local_decl":
            if plan.opArg0s[i] != localSlot:
                return ""
            sawDecl = true
            i = i + 1
            continue
        if i + 2 >= loadIdx:
            return ""
        if plan.opKinds[i + 1] != "load_local" || plan.opArg0s[i + 1] != localSlot:
            return ""
        if plan.opKinds[i + 2] != "store_field":
            return ""
        let fieldName = plan.opPrimaryTexts[i + 2]
        if fieldName == "buf":
            if plan.opKinds[i] != "load_param" || plan.opArg0s[i] != 0:
                return ""
            sawBuf = true
        elif fieldName == "pos":
            if plan.opKinds[i] != "load_int32" || plan.opPrimaryTexts[i] != "0":
                return ""
            sawPos = true
        else:
            return ""
        i = i + 3
    if sawDecl && sawBuf && sawPos:
        return machineDirectReturnRegisterPairPlusZeroI32Words(architecture, 0, 1, false, 2)
    return ""

