    add(words, "94000000")
    let epilogueStartIdx = words.len
    add(words, machineAarch64AddImmWord(true, 31, 31, 16))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[falseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - falseBranchIdx, "eq")
    words[endBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdx)
    return joinWordList(words)

fn machineDirectIfElseCondParamPairThenCallParamPairWords(architecture: str,
                                                          condSourceReg0: int32,
                                                          condSourceReg1: int32,
                                                          condSourceReg1Is64: bool,
                                                          elseSourceReg0: int32,
                                                          elseSourceReg1: int32,
                                                          elseSourceReg1Is64: bool): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if condSourceReg0 < 0 || condSourceReg0 > 7 || condSourceReg1 < 0 || condSourceReg1 > 7:
        return ""
    if elseSourceReg0 < 0 || elseSourceReg0 > 7 || elseSourceReg1 < 0 || elseSourceReg1 > 7:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64SubImmWord(true, 31, 31, 32))
    add(words, machineAarch64StoreSpWord(true, condSourceReg0, 0))
    add(words, machineAarch64StoreSpWord(condSourceReg1Is64, condSourceReg1, 8))
    add(words, machineAarch64StoreSpWord(true, elseSourceReg0, 16))
    add(words, machineAarch64StoreSpWord(elseSourceReg1Is64, elseSourceReg1, 24))
    add(words, machineAarch64LoadSpWord(true, 0, 0))
    add(words, machineAarch64LoadSpWord(condSourceReg1Is64, 1, 8))
    add(words, "94000000")
    add(words, machineAarch64CmpZeroWord(false, 0))
    let falseBranchIdx = words.len
    add(words, "")
    add(words, "94000000")
    let endBranchIdx = words.len
    add(words, "")
    let elseStartIdx = words.len
    add(words, machineAarch64LoadSpWord(true, 0, 16))
    add(words, machineAarch64LoadSpWord(elseSourceReg1Is64, 1, 24))
    add(words, "94000000")
    let epilogueStartIdx = words.len
    add(words, machineAarch64AddImmWord(true, 31, 31, 32))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[falseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - falseBranchIdx, "eq")
    words[endBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdx)
    return joinWordList(words)

