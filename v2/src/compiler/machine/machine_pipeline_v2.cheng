fn machineDirectCallParamArgsVoidWords(architecture: str,
                                       signatureText: str,
                                       argParamIdxs: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if argParamIdxs.len <= 0 || argParamIdxs.len > 4:
        return ""
    var words: str[]
    var argKinds: str[]
    var argPrimaryTexts: str[]
    words = machineAarch64PrologueWords()
    argKinds = []
    argPrimaryTexts = []
    for i in 0..<argParamIdxs.len:
        let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, argParamIdxs[i])
        let regWidth = compilerCoreDirectAbiParamRegWidth(paramTypeText)
        if regWidth <= 0 || regWidth > 2:
            return ""
        add(argKinds, "load_param")
        add(argPrimaryTexts, "")
    if !machineAppendSpillDirectCurrentArgsWords(architecture,
                                                 words,
                                                 signatureText,
                                                 argKinds,
                                                 argPrimaryTexts,
                                                 argParamIdxs):
        return ""
    var spillOffset: int32 = 0
    var targetReg: int32 = 0
    for i in 0..<argParamIdxs.len:
        let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, argParamIdxs[i])
        let regWidth = compilerCoreDirectAbiParamRegWidth(paramTypeText)
        if regWidth <= 0 || regWidth > 2 || targetReg + regWidth > 8:
            return ""
        if regWidth == 1:
            add(words,
                machineAarch64LoadSpWord(compilerCoreDirectParamIs64(paramTypeText),
                                         targetReg,
                                         spillOffset))
        else:
            add(words, machineAarch64LoadSpWord(true, targetReg, spillOffset))
            add(words,
                machineAarch64LoadSpWord(compilerCoreDirectSecondRegIs64(paramTypeText),
                                         targetReg + 1,
                                         spillOffset + 8))
        targetReg = targetReg + regWidth
        spillOffset = spillOffset + regWidth * 8
    add(words, "94000000")
    add(words, machineAarch64MovZeroWord(0))
    add(words, machineAarch64AddImmWord(true, 31, 31, 64))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectIfParamNilReturnElseCallParamArgsVoidWords(architecture: str,
                                                           signatureText: str,
                                                           guardParamIdx: int32,
                                                           argParamIdxs: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if guardParamIdx < 0:
        return ""
    if argParamIdxs.len <= 0 || argParamIdxs.len > 4:
        return ""
    let guardTypeText = compilerCoreSignatureParamTypeText(signatureText, guardParamIdx)
    if compilerCoreDirectTypeRegWidth(guardTypeText) != 1:
        return ""
    let guardBaseReg = compilerCoreParamBaseReg(signatureText, guardParamIdx)
    if guardBaseReg < 0 || guardBaseReg > 7:
        return ""
    var words: str[]
    var argKinds: str[]
    var argPrimaryTexts: str[]
    words = machineAarch64PrologueWords()
    if guardBaseReg != 9:
        add(words, machineAarch64MovRegWord(compilerCoreDirectParamIs64(guardTypeText), 9, guardBaseReg))
    add(words, machineAarch64CmpZeroWord(compilerCoreDirectParamIs64(guardTypeText), 9))
    let elseBranchIdx = words.len
    add(words, "")
    let earlyReturnEpilogue = machineAarch64EpilogueWords()
    for i in 0..<earlyReturnEpilogue.len:
        add(words, earlyReturnEpilogue[i])
    let elseStartIdx = words.len
    argKinds = []
    argPrimaryTexts = []
    for i in 0..<argParamIdxs.len:
        let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, argParamIdxs[i])
        let regWidth = compilerCoreDirectAbiParamRegWidth(paramTypeText)
        if regWidth <= 0 || regWidth > 2:
            return ""
        add(argKinds, "load_param")
        add(argPrimaryTexts, "")
    if !machineAppendSpillDirectCurrentArgsWords(architecture,
                                                 words,
                                                 signatureText,
                                                 argKinds,
                                                 argPrimaryTexts,
                                                 argParamIdxs):
        return ""
    if !machineAppendRestoreSpilledDirectCurrentArgsWords(architecture,
                                                          words,
                                                          signatureText,
                                                          0,
                                                          argKinds,
                                                          argParamIdxs):
        return ""
    add(words, "94000000")
    add(words, machineAarch64MovZeroWord(0))
    add(words, machineAarch64AddImmWord(true, 31, 31, 64))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[elseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - elseBranchIdx, "ne")
    return joinWordList(words)

