fn machineDirectCallRegisterPairArgWords(architecture: str,
                                         sourceReg0: int32,
                                         sourceReg1: int32,
                                         sourceReg1Is64: bool): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if sourceReg0 < 0 || sourceReg0 > 7 || sourceReg1 < 0 || sourceReg1 > 7:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    var loadReg1: int32 = sourceReg1
    if sourceReg1 == 0 && sourceReg0 != 0:
        add(words, machineAarch64MovRegWord(true, 9, 0))
        loadReg1 = 9
    if sourceReg0 != 0:
        add(words, machineAarch64MovRegWord(true, 0, sourceReg0))
    if loadReg1 != 1:
        add(words, machineAarch64MovRegWord(sourceReg1Is64, 1, loadReg1))
    add(words, "94000000")
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCallImportcBridgeWords(architecture: str,
                                       callerSignatureText: str,
                                       calleeSignatureText: str,
                                       returnTypeText: str,
                                       argParamIdxs: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var usedRegs: int32[] = [0, 0, 0, 0, 0, 0, 0, 0]
    var argSlotOffsets: int32[]
    argSlotOffsets = []
    var frameBytes: int32 = 64
    for i in 0..<argParamIdxs.len:
        let callerTypeText = compilerCoreSignatureParamTypeText(callerSignatureText, argParamIdxs[i])
        let calleeTypeText = compilerCoreSignatureParamTypeText(calleeSignatureText, i)
        let callerWidth = compilerCoreDirectTypeRegWidth(callerTypeText)
        let calleeWidth = compilerCoreDirectTypeRegWidth(calleeTypeText)
        if callerWidth != calleeWidth || callerWidth <= 0 || callerWidth > 2:
            return ""
        if callerWidth == 2 &&
           compilerCoreDirectSecondRegIs64(callerTypeText) != compilerCoreDirectSecondRegIs64(calleeTypeText):
            return ""
        let baseReg = compilerCoreParamBaseReg(callerSignatureText, argParamIdxs[i])
        if baseReg < 0 || baseReg + callerWidth - 1 > 7:
            return ""
        usedRegs[baseReg] = 1
        if callerWidth == 2:
            usedRegs[baseReg + 1] = 1
            add(argSlotOffsets, frameBytes)
            frameBytes = frameBytes + 24
        else:
            add(argSlotOffsets, -1)
    let returnWidth = compilerCoreDirectTypeRegWidth(returnTypeText)
    if returnWidth <= 0 || returnWidth > 2:
        return ""
    let returnSlotOffset = returnWidth == 2 ? frameBytes else: -1
    if returnWidth == 2:
        frameBytes = frameBytes + 24
    frameBytes = ((frameBytes + 15) / 16) * 16
    if frameBytes > 4095:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64SubImmWord(true, 31, 31, frameBytes))
    for reg in 0..<8:
        if usedRegs[reg] != 0:
            add(words, machineAarch64StoreSpWord(true, reg, reg * 8))
    for i in 0..<argParamIdxs.len:
        if argSlotOffsets[i] < 0:
            continue
        let callerTypeText = compilerCoreSignatureParamTypeText(callerSignatureText, argParamIdxs[i])
        let baseReg = compilerCoreParamBaseReg(callerSignatureText, argParamIdxs[i])
        add(words, machineAarch64LoadSpWord(true, 9, baseReg * 8))
        add(words, machineAarch64StoreSpWord(true, 9, argSlotOffsets[i]))
        add(words,
            machineAarch64LoadSpWord(compilerCoreDirectSecondRegIs64(callerTypeText),
                                     9,
                                     (baseReg + 1) * 8))
        add(words,
            machineAarch64StoreSpWord(compilerCoreDirectSecondRegIs64(callerTypeText),
                                      9,
                                      argSlotOffsets[i] + 8))
        add(words, machineAarch64StoreSpWord(false, 31, argSlotOffsets[i] + 12))
        add(words, machineAarch64StoreSpWord(true, 31, argSlotOffsets[i] + 16))
    for i in 0..<argParamIdxs.len:
        let callerTypeText = compilerCoreSignatureParamTypeText(callerSignatureText, argParamIdxs[i])
        let baseReg = compilerCoreParamBaseReg(callerSignatureText, argParamIdxs[i])
        if argSlotOffsets[i] >= 0:
            add(words, machineAarch64AddImmWord(true, i, 31, argSlotOffsets[i]))
        else:
            add(words,
                machineAarch64LoadSpWord(compilerCoreDirectParamIs64(callerTypeText),
                                         i,
                                         baseReg * 8))
    if returnSlotOffset >= 0:
        add(words, machineAarch64AddImmWord(true, 8, 31, returnSlotOffset))
    add(words, "94000000")
    if returnSlotOffset >= 0:
        add(words, machineAarch64LoadSpWord(true, 0, returnSlotOffset))
        add(words,
            machineAarch64LoadSpWord(compilerCoreDirectSecondRegIs64(returnTypeText),
                                     1,
                                     returnSlotOffset + 8))
    add(words, machineAarch64AddImmWord(true, 31, 31, frameBytes))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCallImportcBridgeVoidWords(architecture: str,
                                           callerSignatureText: str,
                                           calleeSignatureText: str,
                                           argParamIdxs: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var usedRegs: int32[] = [0, 0, 0, 0, 0, 0, 0, 0]
