    return symbolName == "abs" ||
           symbolName == "free" ||
           symbolName == "puts" ||
           symbolName == "cheng_epoch_time" ||
           symbolName == "rawmemAsVoid" ||
           symbolName == "driver_c_cli_param1_eq_bridge" ||
           symbolName == "driver_c_str_eq_bridge" ||
           symbolName == "driver_c_read_flag_or_default_bridge" ||
           symbolName == "driver_c_read_int32_flag_or_default_bridge" ||
           symbolName == "driver_c_chr_i32_compat" ||
           symbolName == "driver_c_ord_char_compat" ||
           symbolName == "driver_c_compiler_core_print_usage_bridge" ||
           symbolName == "driver_c_compiler_core_print_status_bridge" ||
