fn machineDirectReturnCStringLiteralWords(architecture: str, byteLen: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if byteLen < 0 || byteLen > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, byteLen))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectUnaryWords(architecture: str,
                           opKind: str,
                           operandKind: str,
                           operandPrimaryText: str,
                           operandArg0: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleValueWords(architecture,
                                          words,
                                          0,
                                          operandKind,
                                          operandPrimaryText,
                                          operandArg0):
        return ""
    if opKind == "unary_neg":
        add(words, machineAarch64SubRegWord(false, 0, 31, 0))
    elif opKind == "unary_not":
        add(words, machineAarch64CmpZeroWord(false, 0))
        add(words, machineAarch64BranchCondWord(3, "eq"))
        add(words, machineAarch64MovInt32Word(0, 0))
        add(words, machineAarch64BranchWord(2))
        add(words, machineAarch64MovInt32Word(0, 1))
    else:
        return ""
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectBinaryWords(architecture: str,
                            lhsKind: str,
                            lhsPrimaryText: str,
                            lhsArg0: int32,
                            rhsKind: str,
                            rhsPrimaryText: str,
                            rhsArg0: int32,
                            operatorText: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, lhsKind, lhsPrimaryText, lhsArg0):
        return ""
    if !machineAppendLoadSimpleValueWords(architecture, words, 1, rhsKind, rhsPrimaryText, rhsArg0):
        return ""
    if operatorText == "+":
        add(words, machineAarch64AddRegWord(false, 0, 0, 1))
    elif operatorText == "-":
        add(words, machineAarch64SubRegWord(false, 0, 0, 1))
    elif operatorText == "==" || operatorText == "!=" ||
         operatorText == "<" || operatorText == "<=" ||
         operatorText == ">" || operatorText == ">=":
        add(words, machineAarch64CmpRegWord(false, 0, 1))
        let cond = operatorText == "==" ? "eq" else:
                   operatorText == "!=" ? "ne" else:
                   operatorText == "<" ? "lt" else:
                   operatorText == "<=" ? "le" else:
                   operatorText == ">" ? "gt" else: "ge"
        add(words, machineAarch64BranchCondWord(3, cond))
        add(words, machineAarch64MovInt32Word(0, 0))
        add(words, machineAarch64BranchWord(2))
        add(words, machineAarch64MovInt32Word(0, 1))
    else:
        return ""
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineAppendLoadDirectScalarValueWords(architecture: str,
                                           words: var str[],
                                           targetReg: int32,
                                           signatureText: str,
                                           opKind: str,
                                           opPrimaryText: str,
                                           opArg0: int32,
                                           is64: var bool): bool =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    is64 = false
    if opKind == "load_param":
        let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, opArg0)
        let sourceReg = compilerCoreParamBaseReg(signatureText, opArg0)
        if sourceReg < 0 || sourceReg > 7:
            return false
        is64 = compilerCoreDirectParamIs64(paramTypeText)
        if sourceReg != targetReg:
            add(words, machineAarch64MovRegWord(is64, targetReg, sourceReg))
        return true
    if opKind == "load_int32":
        let value = parser.parseIntStrict(opPrimaryText)
        if value < 0 || value > 65535:
            return false
        add(words, machineAarch64MovInt32Word(targetReg, value))
        return true
    if opKind == "load_bool":
        add(words, machineAarch64MovInt32Word(targetReg, opPrimaryText == "true" ? 1 else: 0))
        return true
    if opKind == "load_nil":
        is64 = true
        add(words, machineAarch64MovZeroWord(targetReg))
        return true
    return false

fn machineDirectArithmeticCompareWords(architecture: str,
                                       signatureText: str,
                                       lhsSourceReg: int32,
                                       lhsSourceIs64: bool,
                                       arithmeticOperatorText: str,
                                       rhsKind: str,
                                       rhsPrimaryText: str,
                                       rhsArg0: int32,
                                       compareSourceReg: int32,
                                       compareSourceIs64: bool,
                                       compareOperatorText: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if lhsSourceReg < 0 || lhsSourceReg > 7 || compareSourceReg < 0 || compareSourceReg > 7:
        return ""
    if arithmeticOperatorText != "+" && arithmeticOperatorText != "-":
        return ""
    if compareOperatorText != "==" && compareOperatorText != "!=" &&
       compareOperatorText != "<" && compareOperatorText != "<=" &&
       compareOperatorText != ">" && compareOperatorText != ">=":
        return ""
    if lhsSourceIs64 || compareSourceIs64:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    if lhsSourceReg != 9:
        add(words, machineAarch64MovRegWord(false, 9, lhsSourceReg))
    var rhsIs64: bool = false
    if !machineAppendLoadDirectScalarValueWords(architecture,
                                                words,
                                                10,
                                                signatureText,
                                                rhsKind,
                                                rhsPrimaryText,
                                                rhsArg0,
                                                rhsIs64):
        return ""
    if rhsIs64:
        return ""
    if arithmeticOperatorText == "+":
        add(words, machineAarch64AddRegWord(false, 9, 9, 10))
    else:
        add(words, machineAarch64SubRegWord(false, 9, 9, 10))
    if compareSourceReg != 10:
        add(words, machineAarch64MovRegWord(false, 10, compareSourceReg))
    add(words, machineAarch64CmpRegWord(false, 9, 10))
    let cond = compareOperatorText == "==" ? "eq" else:
               compareOperatorText == "!=" ? "ne" else:
               compareOperatorText == "<" ? "lt" else:
               compareOperatorText == "<=" ? "le" else:
               compareOperatorText == ">" ? "gt" else: "ge"
    add(words, machineAarch64BranchCondWord(3, cond))
    add(words, machineAarch64MovInt32Word(0, 0))
    add(words, machineAarch64BranchWord(2))
    add(words, machineAarch64MovInt32Word(0, 1))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectIfElseSimpleCondWords(architecture: str,
                                      condKind: str,
                                      condPrimaryText: str,
                                      condArg0: int32,
                                      thenKind: str,
                                      thenPrimaryText: str,
                                      thenArg0: int32,
                                      elseKind: str,
                                      elsePrimaryText: str,
                                      elseArg0: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, condKind, condPrimaryText, condArg0):
        return ""
    add(words, machineAarch64CmpZeroWord(false, 0))
    let falseBranchIdx = words.len
    add(words, "")
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, thenKind, thenPrimaryText, thenArg0):
        return ""
    let endBranchIdx = words.len
    add(words, "")
    let elseStartIdx = words.len
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, elseKind, elsePrimaryText, elseArg0):
        return ""
    let epilogueStartIdx = words.len
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[falseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - falseBranchIdx, "eq")
    words[endBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdx)
    return joinWordList(words)

fn machineDirectIfElseBinaryCondWords(architecture: str,
                                      lhsKind: str,
                                      lhsPrimaryText: str,
                                      lhsArg0: int32,
                                      rhsKind: str,
                                      rhsPrimaryText: str,
                                      rhsArg0: int32,
                                      operatorText: str,
                                      thenKind: str,
                                      thenPrimaryText: str,
                                      thenArg0: int32,
                                      elseKind: str,
                                      elsePrimaryText: str,
                                      elseArg0: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, lhsKind, lhsPrimaryText, lhsArg0):
        return ""
    if !machineAppendLoadSimpleValueWords(architecture, words, 1, rhsKind, rhsPrimaryText, rhsArg0):
        return ""
    add(words, machineAarch64CmpRegWord(false, 0, 1))
    let falseBranchIdx = words.len
    add(words, "")
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, thenKind, thenPrimaryText, thenArg0):
        return ""
    let endBranchIdx = words.len
    add(words, "")
    let elseStartIdx = words.len
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, elseKind, elsePrimaryText, elseArg0):
        return ""
    let epilogueStartIdx = words.len
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[falseBranchIdx] =
        machineAarch64BranchCondWord(elseStartIdx - falseBranchIdx,
                                     machineAarch64InverseCompareCond(operatorText))
    words[endBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdx)
    return joinWordList(words)

fn machineFunctionSymbolName(targetTriple: str, moduleKind: str, opName: str, itemId: int32): str =
    return mtarget.machineTargetSymbolPrefix(targetTriple) +
           "cheng_v2_" + sanitizeSymbolPart(moduleKind) + "_" +
           sanitizeSymbolPart(opName) + "_" + intToStr(itemId)

fn machineCallSymbolName(targetTriple: str, runtimeTarget: str): str =
    return mtarget.machineTargetSymbolPrefix(targetTriple) + sanitizeSymbolPart(runtimeTarget)

fn machineLibcSymbolName(targetTriple: str, symbolName: str): str =
    return mtarget.machineTargetSymbolPrefix(targetTriple) + symbolName

fn compilerCoreExecOpText(plan: cflow.LowUirCompilerCorePlan, opIdx: int32): str =
    return plan.opKinds[opIdx] + "|" +
           plan.opPrimaryTexts[opIdx] + "|" +
           plan.opSecondaryTexts[opIdx] + "|" +
           intToStr(plan.opArg0s[opIdx]) + "|" +
           intToStr(plan.opArg1s[opIdx]) + "|" +
           intToStr(plan.opArg2s[opIdx])

fn compilerCoreRoutineExecPlanText(plan: cflow.LowUirCompilerCorePlan, itemIdx: int32): str =
    let startIdx = plan.routineOpStarts[itemIdx]
    let opCount = plan.routineOpCounts[itemIdx]
    var lines: str[]
    lines = []
    add(lines, "exec_op_count=" + intToStr(opCount))
    add(lines, "exec_op_hash=" + plan.routineOpHashes[itemIdx])
    for i in 0..<opCount:
        add(lines, "op." + intToStr(i) + "=" + compilerCoreExecOpText(plan, startIdx + i))
    return joinWithSep(lines, "\n")

fn newMachineModuleBundle(moduleKind: str, targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle
    out.version = machinePipelineVersion()
    out.moduleKind = moduleKind
    out.targetTriple = targetTriple
    out.architecture = mtarget.machineTargetArchitecture(targetTriple)
    out.objFormat = mtarget.machineTargetObjFormat(targetTriple)
    out.symbolPrefix = mtarget.machineTargetSymbolPrefix(targetTriple)
    out.textSectionName = mtarget.machineTargetTextSectionName(targetTriple)
    out.cstringSectionName = mtarget.machineTargetCStringSectionName(targetTriple)
    out.callRelocationKind = mtarget.machineTargetCallRelocationKind(targetTriple)
    out.metadataPageRelocationKind = mtarget.machineTargetMetadataPageRelocationKind(targetTriple)
    out.metadataPageoffRelocationKind = mtarget.machineTargetMetadataPageoffRelocationKind(targetTriple)
    out.regalloc = mtarget.machineTargetContract().regalloc
    out.pointerWidthBits = mtarget.machineTargetPointerWidthBits(targetTriple)
    out.stackAlignBytes = mtarget.machineTargetStackAlignBytes(targetTriple)
    out.entrySymbolOverride = ""
    out.itemIds = []
    out.symbolNames = []
    out.runtimeTargets = []
    out.callSymbolNames = []
    out.frameSizes = []
    out.stackAligns = []
    out.argRegs = []
    out.scratchRegs = []
    out.calleeSavedRegs = []
    out.bindingSummaries = []
    out.instructionWordHex = []
    out.functionByteSizes = []
    out.localPayloadPageRelocOffsets = []
    out.localPayloadPageoffRelocOffsets = []
    out.callRelocOffsets = []
    out.metadataOperandModes = []
    out.localPayloadTexts = []
    out.functionRelocStarts = []
    out.functionRelocCounts = []
    out.relocOffsets = []
    out.relocSymbols = []
    out.relocKinds = []
    out.dataSymbolNames = []
    out.dataSectionNames = []
    out.dataPayloadTexts = []
    out.dataAlignPow2 = []
    return out

fn appendMachineRelocation(out: var MachineModuleBundle,
                           offset: int32,
                           symbolName: str,
                           relocKind: str) =
    add(out.relocOffsets, offset)
    add(out.relocSymbols, symbolName)
    add(out.relocKinds, relocKind)

fn appendMachineDataSymbol(out: var MachineModuleBundle,
                           symbolName: str,
                           sectionName: str,
                           payloadText: str,
                           alignPow2: int32) =
    add(out.dataSymbolNames, symbolName)
    add(out.dataSectionNames, sectionName)
    add(out.dataPayloadTexts, payloadText)
    add(out.dataAlignPow2, alignPow2)

fn rewriteMachineFunctionPayload(out: var MachineModuleBundle,
                                 functionIdx: int32,
                                 operandMode: str,
                                 payloadText: str) =
    out.metadataOperandModes[functionIdx] = operandMode
    out.localPayloadTexts[functionIdx] = payloadText
    let dataSymbol = out.symbolNames[functionIdx] + "_meta"
    for i in 0..<out.dataSymbolNames.len:
        if out.dataSymbolNames[i] == dataSymbol:
            out.dataPayloadTexts[i] = payloadText
            return

fn rewriteMachineFunctionDirectExec(out: var MachineModuleBundle,
                                    functionIdx: int32,
                                    words: str) =
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = ""
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = 0
    out.localPayloadPageoffRelocOffsets[functionIdx] = 0
    out.callRelocOffsets[functionIdx] = 0
    out.metadataOperandModes[functionIdx] = "direct_exec_no_payload"
    out.localPayloadTexts[functionIdx] = ""
    out.functionRelocCounts[functionIdx] = 0

fn machineDirectCallRelocOffset(words: str): int32 =
    var token: str = ""
    var wordIdx: int32 = 0
    for i in 0..<len(words):
        if words[i] == ';':
            if token == "94000000":
                return wordIdx * 4
            token = ""
            wordIdx = wordIdx + 1
        else:
            token = token + charToString(words[i])
    if token == "94000000":
        return wordIdx * 4
    panic("v2 machine pipeline: direct exec call words missing branch placeholder")

fn machineDirectCallRelocOffsets(words: str): int32[] =
    var out: int32[]
    out = []
    var token: str = ""
    var wordIdx: int32 = 0
    for i in 0..<len(words):
        if words[i] == ';':
            if token == "94000000":
                add(out, wordIdx * 4)
            token = ""
            wordIdx = wordIdx + 1
        else:
            token = token + charToString(words[i])
    if token == "94000000":
        add(out, wordIdx * 4)
    return out

fn machineDirectSecondCStringRelocOffsets(words: str): int32[] =
    var out: int32[]
    out = []
    var token: str = ""
    var wordIdx: int32 = 0
    for i in 0..<len(words):
        if words[i] == ';':
            if token == "90000002" || token == "91000042":
                add(out, wordIdx * 4)
            token = ""
            wordIdx = wordIdx + 1
        else:
            token = token + charToString(words[i])
    if token == "90000002" || token == "91000042":
        add(out, wordIdx * 4)
    return out

fn rewriteMachineFunctionDirectExecCalls(out: var MachineModuleBundle,
                                         functionIdx: int32,
                                         words: str,
                                         callSymbols: str[]) =
    let callOffsets = machineDirectCallRelocOffsets(words)
    if callOffsets.len != callSymbols.len:
        panic("v2 machine pipeline: direct exec call reloc count mismatch")
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = joinWithSep(callSymbols, ";")
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = 0
    out.localPayloadPageoffRelocOffsets[functionIdx] = 0
    out.callRelocOffsets[functionIdx] = callOffsets.len > 0 ? callOffsets[0] else: 0
    out.metadataOperandModes[functionIdx] = "direct_exec_no_payload"
    out.localPayloadTexts[functionIdx] = ""
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    for i in 0..<callOffsets.len:
        appendMachineRelocation(out,
                                callOffsets[i],
                                callSymbols[i],
                                out.callRelocationKind)
    out.functionRelocCounts[functionIdx] = callOffsets.len

fn rewriteMachineFunctionDirectExecCall(out: var MachineModuleBundle,
                                        functionIdx: int32,
                                        words: str,
                                        callSymbol: str) =
    rewriteMachineFunctionDirectExecCalls(out, functionIdx, words, [callSymbol])

fn rewriteMachineFunctionDirectExecCStringData(out: var MachineModuleBundle,
                                               functionIdx: int32,
                                               words: str,
                                               payloadText: str) =
    let dataSymbol = out.symbolNames[functionIdx] + "_cstring"
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = ""
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = 8
    out.localPayloadPageoffRelocOffsets[functionIdx] = 12
    out.callRelocOffsets[functionIdx] = 0
    out.metadataOperandModes[functionIdx] = "direct_exec_cstring_payload"
    out.localPayloadTexts[functionIdx] = payloadText
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    appendMachineDataSymbol(out,
                            dataSymbol,
                            out.cstringSectionName,
                            payloadText,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineRelocation(out,
                            8,
                            dataSymbol,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            12,
                            dataSymbol,
                            out.metadataPageoffRelocationKind)
    out.functionRelocCounts[functionIdx] = 2

fn rewriteMachineFunctionDirectExecCallCStringData(out: var MachineModuleBundle,
                                                   functionIdx: int32,
                                                   words: str,
                                                   callSymbol: str,
                                                   payloadText: str) =
    let callOffsets = machineDirectCallRelocOffsets(words)
    if callOffsets.len != 1:
        panic("v2 machine pipeline: direct exec call cstring reloc count mismatch")
    let dataSymbol = out.symbolNames[functionIdx] + "_cstring"
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = callSymbol
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = 8
    out.localPayloadPageoffRelocOffsets[functionIdx] = 12
    out.callRelocOffsets[functionIdx] = callOffsets[0]
    out.metadataOperandModes[functionIdx] = "direct_exec_call_cstring_payload"
    out.localPayloadTexts[functionIdx] = payloadText
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    appendMachineDataSymbol(out,
                            dataSymbol,
                            out.cstringSectionName,
                            payloadText,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineRelocation(out,
                            8,
                            dataSymbol,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            12,
                            dataSymbol,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            callOffsets[0],
                            callSymbol,
                            out.callRelocationKind)
    out.functionRelocCounts[functionIdx] = 3

fn rewriteMachineFunctionDirectExecCallsCStringData(out: var MachineModuleBundle,
                                                    functionIdx: int32,
                                                    words: str,
                                                    callSymbols: str[],
                                                    payloadText: str) =
    let callOffsets = machineDirectCallRelocOffsets(words)
    if callOffsets.len != callSymbols.len:
        panic("v2 machine pipeline: direct exec call reloc count mismatch")
    let dataRelocOffsets = machineDirectSecondCStringRelocOffsets(words)
    if dataRelocOffsets.len != 2:
        panic("v2 machine pipeline: direct exec nested cstring reloc count mismatch")
    let dataSymbol = out.symbolNames[functionIdx] + "_cstring"
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = joinWithSep(callSymbols, ";")
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = dataRelocOffsets[0]
    out.localPayloadPageoffRelocOffsets[functionIdx] = dataRelocOffsets[1]
    out.callRelocOffsets[functionIdx] = callOffsets[0]
    out.metadataOperandModes[functionIdx] = "direct_exec_call_cstring_payload"
    out.localPayloadTexts[functionIdx] = payloadText
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    appendMachineDataSymbol(out,
                            dataSymbol,
                            out.cstringSectionName,
                            payloadText,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineRelocation(out,
                            dataRelocOffsets[0],
                            dataSymbol,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            dataRelocOffsets[1],
                            dataSymbol,
                            out.metadataPageoffRelocationKind)
    for i in 0..<callOffsets.len:
        appendMachineRelocation(out,
                                callOffsets[i],
                                callSymbols[i],
                                out.callRelocationKind)
    out.functionRelocCounts[functionIdx] = 2 + callOffsets.len

fn rewriteMachineFunctionSymbol(out: var MachineModuleBundle,
                                functionIdx: int32,
                                symbolName: str) =
    out.symbolNames[functionIdx] = symbolName

fn compilerCoreFindPlanItemIndex(plan: cflow.LowUirCompilerCorePlan, itemId: int32): int32 =
    for i in 0..<plan.itemIds.len:
        if plan.itemIds[i] == itemId:
            return i
    return -1

fn compilerCoreMachineImportVisibleName(importPath: str, importAlias: str): str =
    if len(importAlias) > 0:
        return importAlias
    var slashIdx: int32 = -1
    for i in 0..<len(importPath):
        if importPath[i] == '/':
            slashIdx = i
    if slashIdx >= 0:
        return strings.sliceBytes(importPath, slashIdx + 1, len(importPath) - slashIdx - 1)
    return importPath

fn compilerCoreSourcePathToModulePath(sourcePath: str): str =
    let v2Idx = strings.find(sourcePath, "v2/src/")
    if v2Idx >= 0:
        let start = v2Idx + len("v2/src/")
        let stop = strings.endsWith(sourcePath, ".cheng") ? len(sourcePath) - len(".cheng") else: len(sourcePath)
        return strings.sliceBytes(sourcePath, start, stop - start)
    let srcIdx = strings.find(sourcePath, "src/")
    if srcIdx >= 0:
        let start = srcIdx + len("src/")
        let stop = strings.endsWith(sourcePath, ".cheng") ? len(sourcePath) - len(".cheng") else: len(sourcePath)
        return strings.sliceBytes(sourcePath, start, stop - start)
    return strings.endsWith(sourcePath, ".cheng") ?
        strings.sliceBytes(sourcePath, 0, len(sourcePath) - len(".cheng")) else:
        sourcePath

fn compilerCoreFindQualifiedPlanItemIndex(plan: cflow.LowUirCompilerCorePlan,
                                          itemIdx: int32,
                                          qualifiedName: str,
                                          expectedParamCount: int32): int32 =
    var dotIdx: int32 = -1
    for i in 0..<len(qualifiedName):
        if qualifiedName[i] == '.':
            dotIdx = i
    if dotIdx <= 0 || dotIdx >= len(qualifiedName) - 1:
        return -1
    let importName = strings.sliceBytes(qualifiedName, 0, dotIdx)
    let fieldName = strings.sliceBytes(qualifiedName, dotIdx + 1, len(qualifiedName) - dotIdx - 1)
    let ownerSourcePath = itemIdx >= 0 && itemIdx < plan.sourcePaths.len ? plan.sourcePaths[itemIdx] else: ""
    var importIdx: int32 = -1
    for i in 0..<plan.itemIds.len:
        if plan.topLevelKinds[i] != "import":
            continue
        if i >= plan.sourcePaths.len || plan.sourcePaths[i] != ownerSourcePath:
            continue
        if compilerCoreMachineImportVisibleName(plan.importPaths[i], plan.importAliases[i]) == importName:
            if importIdx >= 0:
                return -1
            importIdx = i
    if importIdx < 0:
        return -1
    let targetModulePath = plan.importPaths[importIdx]
    var matchIdx: int32 = -1
    var matchCount: int32 = 0
    for i in 0..<plan.itemIds.len:
        if i >= plan.sourcePaths.len || compilerCoreSourcePathToModulePath(plan.sourcePaths[i]) != targetModulePath:
            continue
        if plan.labels[i] != fieldName:
            continue
        let topLevelKind = plan.topLevelKinds[i]
        if topLevelKind != "fn" && topLevelKind != "iterator" && topLevelKind != "importc_fn" &&
           topLevelKind != "const" && topLevelKind != "var":
            continue
        if expectedParamCount >= 0 &&
           (topLevelKind == "fn" || topLevelKind == "iterator" || topLevelKind == "importc_fn") &&
           plan.paramCounts[i] != expectedParamCount:
            continue
        matchIdx = i
        matchCount = matchCount + 1
        if matchCount > 1:
            return -1
    return matchIdx

fn compilerCoreDirectExecCallItemIndex(plan: cflow.LowUirCompilerCorePlan,
                                       itemIdx: int32,
                                       opIdx: int32,
                                       expectedParamCount: int32): int32 =
    let qualifiedName = plan.opPrimaryTexts[opIdx]
    if strings.find(qualifiedName, ".") >= 0:
        let qualifiedIdx = compilerCoreFindQualifiedPlanItemIndex(plan, itemIdx, qualifiedName, expectedParamCount)
        if qualifiedIdx >= 0:
            return qualifiedIdx
    return compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opIdx])

fn compilerCoreTrimAscii(text: str): str =
    if len(text) == 0:
        return ""
    var start: int32 = 0
    var stop: int32 = len(text)
    while start < stop && (text[start] == ' ' || text[start] == '\t' || text[start] == '\n' || text[start] == '\r'):
        start = start + 1
    while stop > start && (text[stop - 1] == ' ' || text[stop - 1] == '\t' || text[stop - 1] == '\n' || text[stop - 1] == '\r'):
        stop = stop - 1
    return slice(text, start, stop - start)

fn compilerCoreLastIndexOf(text: str, pattern: str): int32 =
    if len(pattern) == 0 || len(pattern) > len(text):
        return -1
    var i: int32 = len(text) - len(pattern)
    while i >= 0:
        var ok: bool = true
        for j in 0..<len(pattern):
            if text[i + j] != pattern[j]:
                ok = false
                break
        if ok:
            return i
        i = i - 1
    return -1

fn compilerCoreTopLevelTokenIndex(text: str, token: char): int32 =
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    for i in 0..<len(text):
        let ch = text[i]
        if ch == '(':
            depthParen = depthParen + 1
        elif ch == ')':
            depthParen = depthParen - 1
        elif ch == '[':
            depthBracket = depthBracket + 1
        elif ch == ']':
            depthBracket = depthBracket - 1
        elif ch == '{':
            depthBrace = depthBrace + 1
        elif ch == '}':
            depthBrace = depthBrace - 1
        elif ch == token && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            return i
    return -1

fn compilerCoreSignatureParamTypeText(signatureText: str, paramIndex: int32): str =
    let openIdx = compilerCoreTopLevelTokenIndex(signatureText, '(')
    let closeIdx = compilerCoreLastIndexOf(signatureText, ")")
    if openIdx < 0 || closeIdx < 0 || closeIdx <= openIdx:
        return ""
    var partStart: int32 = openIdx + 1
    var partIdx: int32 = 0
    var depthParen: int32 = 0
    var depthBracket: int32 = 0
    var depthBrace: int32 = 0
    var i: int32 = openIdx + 1
    while i <= closeIdx:
        let atEnd = i == closeIdx
        let ch = atEnd ? ',' else: signatureText[i]
        if !atEnd:
            if ch == '(':
                depthParen = depthParen + 1
            elif ch == ')':
                depthParen = depthParen - 1
            elif ch == '[':
                depthBracket = depthBracket + 1
            elif ch == ']':
                depthBracket = depthBracket - 1
            elif ch == '{':
                depthBrace = depthBrace + 1
            elif ch == '}':
                depthBrace = depthBrace - 1
        
        if (atEnd || ch == ',') && depthParen == 0 && depthBracket == 0 && depthBrace == 0:
            let partText = compilerCoreTrimAscii(slice(signatureText, partStart, i - partStart))
            if len(partText) > 0:
                if partIdx == paramIndex:
                    let colonIdx = compilerCoreTopLevelTokenIndex(partText, ':')
                    if colonIdx < 0:
                        return ""
                    return compilerCoreTrimAscii(slice(partText, colonIdx + 1, len(partText) - colonIdx - 1))
                partIdx = partIdx + 1
            
            partStart = i + 1
        
        i = i + 1
    return ""

fn compilerCoreTypeEndsWith(text: str, suffix: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(text)
    if len(suffix) > len(normalizedText):
        return false
    let start = len(normalizedText) - len(suffix)
    for i in 0..<len(suffix):
        if normalizedText[start + i] != suffix[i]:
            return false
    return true

fn compilerCoreNormalizedTypeText(text: str): str =
    if len(text) > 4 &&
       text[0] == 'v' &&
       text[1] == 'a' &&
       text[2] == 'r' &&
       text[3] == ' ':
        return strings.sliceBytes(text, 4, len(text) - 4)
    return text

fn compilerCoreTypeEndsWithRaw(text: str, suffix: str): bool =
    if len(suffix) > len(text):
        return false
    let start = len(text) - len(suffix)
    for i in 0..<len(suffix):
        if text[start + i] != suffix[i]:
            return false
    return true

fn compilerCoreTypeMatches(text: str, bareName: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(text)
    return normalizedText == bareName || compilerCoreTypeEndsWithRaw(normalizedText, "." + bareName)

fn compilerCoreTypeHeadText(text: str): str =
    let normalizedText = compilerCoreNormalizedTypeText(text)
    let genericIdx = compilerCoreTopLevelTokenIndex(normalizedText, '[')
    if genericIdx >= 0:
        return slice(normalizedText, 0, genericIdx)
    return normalizedText

fn compilerCoreTypeHeadMatches(text: str, bareName: str): bool =
    let headText = compilerCoreTypeHeadText(text)
    return headText == bareName || compilerCoreTypeEndsWithRaw(headText, "." + bareName)

fn compilerCoreDirectCallReturnTypeSupported(typeText: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(typeText)
    if len(normalizedText) <= 0:
        return true
    if compilerCoreTypeMatches(normalizedText, "void"):
        return true
    if compilerCoreTypeMatches(normalizedText, "bool") ||
       compilerCoreTypeMatches(normalizedText, "int8") ||
       compilerCoreTypeMatches(normalizedText, "int16") ||
       compilerCoreTypeMatches(normalizedText, "int32") ||
       compilerCoreTypeMatches(normalizedText, "int64") ||
       compilerCoreTypeMatches(normalizedText, "uint8") ||
       compilerCoreTypeMatches(normalizedText, "uint16") ||
       compilerCoreTypeMatches(normalizedText, "uint32") ||
       compilerCoreTypeMatches(normalizedText, "uint64") ||
       compilerCoreTypeMatches(normalizedText, "float64") ||
       compilerCoreTypeMatches(normalizedText, "char") ||
       compilerCoreTypeMatches(normalizedText, "ptr") ||
       compilerCoreTypeMatches(normalizedText, "cstring") ||
       compilerCoreTypeMatches(normalizedText, "File") ||
       compilerCoreTypeMatches(normalizedText, "str") ||
       compilerCoreTypeMatches(normalizedText, "Bytes") ||
       compilerCoreTypeMatches(normalizedText, "ByteBuffer") ||
       compilerCoreTypeMatches(normalizedText, "ByteReader") ||
       compilerCoreTypeEndsWith(normalizedText, "[]"):
        return true
    return false

fn compilerCoreDirectTypeRegWidth(typeText: str): int32 =
    let normalizedText = compilerCoreNormalizedTypeText(typeText)
    if compilerCoreTypeMatches(normalizedText, "Bytes") ||
       compilerCoreTypeMatches(normalizedText, "ByteBuffer") ||
       compilerCoreTypeEndsWith(normalizedText, "[]"):
        return 2
    if compilerCoreTypeMatches(normalizedText, "ByteReader"):
        return 3
    return 1

fn compilerCoreParamBaseReg(signatureText: str, paramIndex: int32): int32 =
    var out: int32 = 0
    for i in 0..<paramIndex:
        out = out + compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(signatureText, i))
    return out

fn compilerCoreDirectParamIs64(typeText: str): bool =
    let normalizedText = compilerCoreNormalizedTypeText(typeText)
    if compilerCoreTypeMatches(normalizedText, "int32") ||
       compilerCoreTypeMatches(normalizedText, "bool"):
        return false
    return true

fn compilerCoreDirectFieldReturnBinding(paramTypeText: str,
                                        fieldName: str,
                                        sourceReg: var int32,
                                        is64: var bool): bool =
    sourceReg = -1
    is64 = false
    if compilerCoreTypeMatches(paramTypeText, "str"):
        if fieldName == "data":
            sourceReg = 0
            is64 = true
            return true
        if fieldName == "len":
            sourceReg = 1
            is64 = false
            return true
    if compilerCoreTypeMatches(paramTypeText, "Bytes") ||
       compilerCoreTypeMatches(paramTypeText, "ByteBuffer"):
        if fieldName == "data":
            sourceReg = 0
            is64 = true
            return true
        if fieldName == "len":
            sourceReg = 1
            is64 = false
            return true
    if compilerCoreTypeEndsWith(paramTypeText, "[]"):
        if fieldName == "len":
            sourceReg = 0
            is64 = false
            return true
        if fieldName == "buffer":
            sourceReg = 1
            is64 = true
            return true
    if compilerCoreTypeMatches(paramTypeText, "DateTime") && fieldName == "unix":
        sourceReg = 0
        is64 = true
        return true
    if compilerCoreTypeMatches(paramTypeText, "ByteReader") && fieldName == "pos":
        sourceReg = 2
        is64 = false
        return true
    if compilerCoreTypeMatches(paramTypeText, "ExecCmdResult") && fieldName == "exitCode":
        sourceReg = 2
        is64 = false
        return true
    if compilerCoreTypeMatches(paramTypeText, "ErrorInfo") && fieldName == "code":
        sourceReg = 0
        is64 = false
        return true
    if compilerCoreTypeHeadMatches(paramTypeText, "Result") && fieldName == "ok":
        sourceReg = 0
        is64 = false
        return true
    return false

fn compilerCoreDirectAggregateFieldBinding(paramTypeText: str,
                                           fieldName: str,
                                           resultTypeText: var str,
                                           sourceReg0: var int32,
                                           sourceReg1: var int32,
                                           sourceReg1Is64: var bool): bool =
    resultTypeText = ""
    sourceReg0 = -1
    sourceReg1 = -1
    sourceReg1Is64 = false
    if compilerCoreTypeMatches(paramTypeText, "ByteBuffer") && fieldName == "data":
        resultTypeText = "Bytes"
        sourceReg0 = 0
        sourceReg1 = 1
        sourceReg1Is64 = false
        return true
    if compilerCoreTypeMatches(paramTypeText, "ByteReader") && fieldName == "buf":
        resultTypeText = "ByteBuffer"
        sourceReg0 = 0
        sourceReg1 = 1
        sourceReg1Is64 = false
        return true
    if compilerCoreTypeMatches(paramTypeText, "ExecCmdResult") && fieldName == "output":
        resultTypeText = "str"
        sourceReg0 = 0
        sourceReg1 = 1
        sourceReg1Is64 = false
        return true
    if compilerCoreTypeMatches(paramTypeText, "ErrorInfo") && fieldName == "msg":
        resultTypeText = "str"
        sourceReg0 = 1
        sourceReg1 = 2
        sourceReg1Is64 = false
        return true
    return false

fn compilerCoreDirectParamFieldReturnBinding(signatureText: str,
                                             paramIndex: int32,
                                             fieldName: str,
                                             sourceReg: var int32,
                                             is64: var bool): bool =
    let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, paramIndex)
    var relativeReg: int32 = -1
    if !compilerCoreDirectFieldReturnBinding(paramTypeText, fieldName, relativeReg, is64):
        return false
    sourceReg = compilerCoreParamBaseReg(signatureText, paramIndex) + relativeReg
    return true

fn compilerCoreDirectParamAggregateFieldBinding(signatureText: str,
                                                paramIndex: int32,
                                                fieldName: str,
                                                resultTypeText: var str,
                                                sourceReg0: var int32,
                                                sourceReg1: var int32,
                                                sourceReg1Is64: var bool): bool =
    let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, paramIndex)
    var relativeReg0: int32 = -1
    var relativeReg1: int32 = -1
    if !compilerCoreDirectAggregateFieldBinding(paramTypeText,
                                                fieldName,
                                                resultTypeText,
                                                relativeReg0,
                                                relativeReg1,
                                                sourceReg1Is64):
        return false
    let baseReg = compilerCoreParamBaseReg(signatureText, paramIndex)
    sourceReg0 = baseReg + relativeReg0
    sourceReg1 = baseReg + relativeReg1
    return true

fn compilerCoreDirectParamNestedFieldReturnBinding(signatureText: str,
                                                   paramIndex: int32,
                                                   aggregateFieldName: str,
                                                   nestedFieldName: str,
                                                   sourceReg: var int32,
                                                   is64: var bool): bool =
    var aggregateResultTypeText: str = ""
    var aggregateReg0: int32 = -1
    var aggregateReg1: int32 = -1
    var aggregateReg1Is64: bool = false
    if !compilerCoreDirectParamAggregateFieldBinding(signatureText,
                                                     paramIndex,
                                                     aggregateFieldName,
                                                     aggregateResultTypeText,
                                                     aggregateReg0,
                                                     aggregateReg1,
                                                     aggregateReg1Is64):
        return false
    var nestedRelativeReg: int32 = -1
    if !compilerCoreDirectFieldReturnBinding(aggregateResultTypeText, nestedFieldName, nestedRelativeReg, is64):
        return false
    if nestedRelativeReg == 0:
        sourceReg = aggregateReg0
        return true
    if nestedRelativeReg == 1:
        sourceReg = aggregateReg1
        return true
    return false

fn compilerCoreDirectExecParamAggregateWords(plan: cflow.LowUirCompilerCorePlan,
                                             itemIdx: int32,
                                             architecture: str): str =
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "ByteReader") || plan.paramCounts[itemIdx] != 1:
        return ""
    let returnTypeText = plan.returnTypeTexts[itemIdx]
    let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
    if !compilerCoreTypeMatches(paramTypeText, "ByteBuffer"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount < 6:
        return ""
    let returnIdx = opStart + opCount - 1
    let loadIdx = returnIdx - 1
    if plan.opKinds[loadIdx] != "load_local" || plan.opKinds[returnIdx] != "return_value":
        return ""
    let localSlot = plan.opArg0s[loadIdx]
    if localSlot < 0:
        return ""
    var i = opStart
    var sawDecl = false
    var sawBuf = false
    var sawPos = false
    while i < loadIdx:
        if plan.opKinds[i] == "local_decl":
            if plan.opArg0s[i] != localSlot:
                return ""
            sawDecl = true
            i = i + 1
            continue
        if i + 2 >= loadIdx:
            return ""
        if plan.opKinds[i + 1] != "load_local" || plan.opArg0s[i + 1] != localSlot:
            return ""
        if plan.opKinds[i + 2] != "store_field":
            return ""
        let fieldName = plan.opPrimaryTexts[i + 2]
        if fieldName == "buf":
            if plan.opKinds[i] != "load_param" || plan.opArg0s[i] != 0:
                return ""
            sawBuf = true
        elif fieldName == "pos":
            if plan.opKinds[i] != "load_int32" || plan.opPrimaryTexts[i] != "0":
                return ""
            sawPos = true
        else:
            return ""
        i = i + 3
    if sawDecl && sawBuf && sawPos:
        return machineDirectReturnRegisterPairPlusZeroI32Words(architecture, 0, 1, false, 2)
    return ""

fn compilerCoreDirectExecImportcSymbolAllowed(symbolName: str): bool =
    return symbolName == "abs" ||
           symbolName == "free" ||
           symbolName == "driver_c_cli_param1_eq_bridge" ||
           symbolName == "driver_c_read_flag_or_default_bridge" ||
           symbolName == "driver_c_read_int32_flag_or_default_bridge" ||
           symbolName == "driver_c_compiler_core_print_usage_bridge" ||
           symbolName == "driver_c_compiler_core_print_status_bridge" ||
           symbolName == "driver_c_absolute_path_bridge" ||
           symbolName == "driver_c_program_absolute_path_bridge" ||
           symbolName == "driver_c_get_current_dir_bridge" ||
           symbolName == "driver_c_join_path2_bridge" ||
           symbolName == "driver_c_create_dir_all_bridge" ||
           symbolName == "driver_c_write_text_file_bridge" ||
           symbolName == "driver_c_compare_text_files_bridge" ||
           symbolName == "driver_c_compare_binary_files_bridge" ||
           symbolName == "driver_c_exec_file_capture_or_panic_bridge" ||
           symbolName == "driver_c_compare_text_files_or_panic_bridge" ||
           symbolName == "driver_c_extract_line_value_bridge" ||
           symbolName == "driver_c_count_external_cc_providers_bridge" ||
           symbolName == "driver_c_parse_plan_int32_or_zero_bridge" ||
           symbolName == "driver_c_provider_field_for_module_from_plan_text_bridge" ||
           symbolName == "driver_c_compiler_core_provider_source_kind_bridge" ||
           symbolName == "driver_c_compiler_core_provider_compile_mode_bridge" ||
           symbolName == "driver_c_run_stage_selfhost_host_bridge" ||
           symbolName == "driver_c_run_tooling_selfhost_host_bridge" ||
           symbolName == "driver_c_read_file_all" ||
           symbolName == "cheng_fopen" ||
           symbolName == "cheng_fread" ||
           symbolName == "cheng_fwrite" ||
           symbolName == "fopen" ||
           symbolName == "paramCount" ||
           symbolName == "cheng_errno" ||
           symbolName == "cheng_ptr_size" ||
           symbolName == "cheng_fclose" ||
           symbolName == "cheng_fflush" ||
           symbolName == "cheng_fgetc" ||
           symbolName == "remove" ||
           symbolName == "rmdir" ||
           symbolName == "getenv" ||
           symbolName == "rename" ||
           symbolName == "close" ||
           symbolName == "fcntl" ||
           symbolName == "cheng_dir_exists" ||
           symbolName == "cheng_mkdir1" ||
           symbolName == "cheng_file_mtime" ||
           symbolName == "cheng_file_size" ||
           symbolName == "cheng_file_exists" ||
           symbolName == "cheng_getcwd" ||
           symbolName == "cheng_rawbytes_get_at" ||
           symbolName == "cheng_rawbytes_set_at" ||
           symbolName == "get_stdout" ||
           symbolName == "cheng_pty_is_supported"

fn compilerCoreImportcSymbolTextFromSignature(signatureText: str, label: str): str =
    let trimmed = compilerCoreTrimAscii(signatureText)
    let prefix = "@importc(\""
    let startIdx = compilerCoreLastIndexOf(trimmed, prefix)
    if startIdx >= 0:
        let valueStart = startIdx + len(prefix)
        var valueStop: int32 = valueStart
        while valueStop < len(trimmed) && trimmed[valueStop] != '"':
            valueStop = valueStop + 1
        if valueStop > valueStart:
            return slice(trimmed, valueStart, valueStop - valueStart)
    return label

fn compilerCoreDirectExecCalleeSymbol(plan: cflow.LowUirCompilerCorePlan,
                                      calleeItemIdx: int32,
                                      targetTriple: str): str =
    if calleeItemIdx < 0:
        return ""
    if plan.topLevelKinds[calleeItemIdx] == "importc_fn":
        let sourceSymbolName = len(plan.importcSymbolTexts[calleeItemIdx]) > 0 ?
            plan.importcSymbolTexts[calleeItemIdx] :
            compilerCoreImportcSymbolTextFromSignature(plan.signatureTexts[calleeItemIdx],
                                                       plan.labels[calleeItemIdx])
        if !compilerCoreDirectExecImportcSymbolAllowed(sourceSymbolName):
            return ""
        let directSymbolName = sourceSymbolName == "driver_c_cli_param1_eq_bridge" ?
            "driver_c_cli_param1_eq_raw_bridge" else: sourceSymbolName
        return machineLibcSymbolName(targetTriple, directSymbolName)
    return machineFunctionSymbolName(targetTriple,
                                     "compiler_core",
                                     plan.canonicalOps[calleeItemIdx],
                                     plan.itemIds[calleeItemIdx])

fn compilerCoreIsDirectSimpleValueKind(kind: str): bool =
    return kind == "load_param" ||
           kind == "load_local" ||
           kind == "load_int32" ||
           kind == "load_bool" ||
           kind == "load_nil"

fn compilerCoreIsDirectConstValueKind(kind: str): bool =
    return kind == "load_int32" ||
           kind == "load_bool" ||
           kind == "load_nil"

fn compilerCoreResolveDirectCallArg(plan: cflow.LowUirCompilerCorePlan,
                                    opIdx: int32,
                                    aliasSlot: int32,
                                    aliasInitKind: str,
                                    aliasInitPrimaryText: str,
                                    aliasInitArg0: int32,
                                    resolvedKind: var str,
                                    resolvedPrimaryText: var str,
                                    resolvedArg0: var int32): bool =
    if plan.opKinds[opIdx] == "load_local" && plan.opArg0s[opIdx] == aliasSlot:
        if !compilerCoreIsDirectSimpleValueKind(aliasInitKind):
            return false
        resolvedKind = aliasInitKind
        resolvedPrimaryText = aliasInitPrimaryText
        resolvedArg0 = aliasInitArg0
        return true
    if compilerCoreIsDirectSimpleValueKind(plan.opKinds[opIdx]):
        resolvedKind = plan.opKinds[opIdx]
        resolvedPrimaryText = plan.opPrimaryTexts[opIdx]
        resolvedArg0 = plan.opArg0s[opIdx]
        return true
    return false

fn compilerCoreDirectExecLocalAliasWords(plan: cflow.LowUirCompilerCorePlan,
                                         itemIdx: int32,
                                         architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_local" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 2] == plan.opArg0s[opStart + 3]:
        return machineDirectReturnSimpleValueWords(architecture,
                                                   plan.opKinds[opStart + 1],
                                                   plan.opPrimaryTexts[opStart + 1],
                                                   plan.opArg0s[opStart + 1])
    return ""

fn compilerCoreDirectExecFieldWords(plan: cflow.LowUirCompilerCorePlan,
                                    itemIdx: int32,
                                    architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 3 &&
       plan.paramCounts[itemIdx] == 1 &&
       plan.opKinds[opStart] == "load_param" &&
       plan.opArg0s[opStart] == 0 &&
       plan.opKinds[opStart + 1] == "load_field" &&
       plan.opKinds[opStart + 2] == "return_value":
        let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
        var aggregateResultTypeText: str = ""
        var sourceReg0: int32 = -1
        var sourceReg1: int32 = -1
        var sourceReg1Is64: bool = false
        if compilerCoreDirectAggregateFieldBinding(paramTypeText,
                                                   plan.opPrimaryTexts[opStart + 1],
                                                   aggregateResultTypeText,
                                                   sourceReg0,
                                                   sourceReg1,
                                                   sourceReg1Is64) &&
           compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], aggregateResultTypeText):
            return machineDirectReturnRegisterPairWords(architecture,
                                                        sourceReg0,
                                                        sourceReg1,
                                                        sourceReg1Is64)
        var sourceReg: int32 = -1
        var is64: bool = false
        if compilerCoreDirectFieldReturnBinding(paramTypeText,
                                               plan.opPrimaryTexts[opStart + 1],
                                               sourceReg,
                                               is64):
            return machineDirectReturnRegisterWords(architecture, sourceReg, is64)
    return ""

fn compilerCoreDirectExecParamReturnWords(plan: cflow.LowUirCompilerCorePlan,
                                          itemIdx: int32,
                                          architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 2 ||
       plan.opKinds[opStart] != "load_param" ||
       plan.opKinds[opStart + 1] != "return_value":
        return ""
    let paramIdx = plan.opArg0s[opStart]
    if paramIdx < 0 || paramIdx >= plan.paramCounts[itemIdx]:
        return ""
    let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], paramIdx)
    let normalizedParamType = compilerCoreNormalizedTypeText(paramTypeText)
    let normalizedReturnType = compilerCoreNormalizedTypeText(plan.returnTypeTexts[itemIdx])
    if normalizedParamType != normalizedReturnType:
        return ""
    let regWidth = compilerCoreDirectTypeRegWidth(paramTypeText)
    if regWidth != 2:
        return ""
    let sourceReg0 = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], paramIdx)
    let sourceReg1 = sourceReg0 + 1
    return machineDirectReturnRegisterPairWords(architecture,
                                                sourceReg0,
                                                sourceReg1,
                                                false)

fn compilerCoreDirectExecBytesLiteralWords(plan: cflow.LowUirCompilerCorePlan,
                                           itemIdx: int32,
                                           architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "Bytes") &&
       opCount == 4 &&
       plan.opKinds[opStart] == "load_nil" &&
       plan.opKinds[opStart + 1] == "load_int32" &&
       plan.opPrimaryTexts[opStart + 1] == "0" &&
       plan.opKinds[opStart + 2] == "make_record" &&
       plan.opKinds[opStart + 3] == "return_value":
        return machineDirectReturnEmptyBytesWords(architecture)
    return ""

fn compilerCoreDirectExecCStringPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "str") &&
       opCount == 2 &&
       plan.opKinds[opStart] == "load_str" &&
       plan.opKinds[opStart + 1] == "return_value":
        return plan.opPrimaryTexts[opStart]
    return ""

fn compilerCoreDirectExecCallCStringPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                                itemIdx: int32): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "return_value" &&
       plan.opArg0s[opStart + 2] == 1:
        return plan.opPrimaryTexts[opStart + 1]
    return ""

fn compilerCoreDirectExecCallSecondCStringPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                                      itemIdx: int32): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "load_str" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        return plan.opPrimaryTexts[opStart + 2]
    return ""

fn compilerCoreDirectExecNestedCallCStringPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                                      itemIdx: int32): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    for argCount in 0..<5:
        let innerCallIdx = opStart + 2 + argCount
        let outerArgIdx = innerCallIdx + 1
        let outerCallIdx = innerCallIdx + 2
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerArgIdx] == "load_str" &&
           plan.opKinds[outerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx] == 2:
            return plan.opPrimaryTexts[outerArgIdx]
    return ""

fn compilerCoreDirectExecVoidCallCStringPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                                    itemIdx: int32): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "drop_value" &&
       plan.opKinds[opStart + 4] == "return_void" &&
       plan.opArg0s[opStart + 2] == 1:
        return plan.opPrimaryTexts[opStart + 1]
    return ""

fn compilerCoreDirectExecReturnsEmptyBytesBase(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32): bool =
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "Bytes"):
        return false
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_nil" &&
       plan.opKinds[opStart + 1] == "load_int32" &&
       plan.opPrimaryTexts[opStart + 1] == "0" &&
       plan.opKinds[opStart + 2] == "make_record" &&
       plan.opKinds[opStart + 3] == "return_value":
        return true
    if opCount < 5:
        return false
    let returnIdx = opStart + opCount - 1
    let loadIdx = returnIdx - 1
    if plan.opKinds[loadIdx] != "load_local" || plan.opKinds[returnIdx] != "return_value":
        return false
    let localSlot = plan.opArg0s[loadIdx]
    if localSlot < 0:
        return false
    var i = opStart
    var sawDecl = false
    var sawStore = false
    while i < loadIdx:
        if plan.opKinds[i] == "local_decl":
            if plan.opArg0s[i] != localSlot:
                return false
            sawDecl = true
            i = i + 1
            continue
        if i + 2 >= loadIdx:
            return false
        let zeroValueOk = plan.opKinds[i] == "load_nil" ||
                          (plan.opKinds[i] == "load_int32" && plan.opPrimaryTexts[i] == "0")
        if !zeroValueOk:
            return false
        if plan.opKinds[i + 1] != "load_local" || plan.opArg0s[i + 1] != localSlot:
            return false
        if plan.opKinds[i + 2] != "store_field":
            return false
        sawStore = true
        i = i + 3
    return sawDecl && sawStore

fn compilerCoreDirectExecZeroAggregateWords(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32,
                                            architecture: str): str =
    let returnTypeText = plan.returnTypeTexts[itemIdx]
    if !compilerCoreTypeMatches(returnTypeText, "Bytes") &&
       !compilerCoreTypeMatches(returnTypeText, "ByteBuffer"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount < 5:
        return ""
    let returnIdx = opStart + opCount - 1
    let loadIdx = returnIdx - 1
    if plan.opKinds[loadIdx] != "load_local" || plan.opKinds[returnIdx] != "return_value":
        return ""
    let localSlot = plan.opArg0s[loadIdx]
    if localSlot < 0:
        return ""
    if opCount == 7 &&
       plan.opKinds[opStart] == "local_decl" &&
       plan.opArg0s[opStart] == localSlot &&
       plan.opKinds[opStart + 1] == "load_routine" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opArg0s[opStart + 2] == 0 &&
       plan.opKinds[opStart + 3] == "load_local" &&
       plan.opArg0s[opStart + 3] == localSlot &&
       plan.opKinds[opStart + 4] == "store_field":
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
        if calleeItemIdx >= 0 && compilerCoreDirectExecReturnsEmptyBytesBase(plan, calleeItemIdx):
            var fieldResultTypeText: str = ""
            var sourceReg0: int32 = -1
            var sourceReg1: int32 = -1
            var sourceReg1Is64: bool = false
            if compilerCoreDirectAggregateFieldBinding(returnTypeText,
                                                       plan.opPrimaryTexts[opStart + 4],
                                                       fieldResultTypeText,
                                                       sourceReg0,
                                                       sourceReg1,
                                                       sourceReg1Is64) &&
               compilerCoreTypeMatches(fieldResultTypeText, "Bytes"):
                return machineDirectReturnEmptyBytesWords(architecture)
    var i = opStart
    var sawDecl = false
    var sawStore = false
    while i < loadIdx:
        if plan.opKinds[i] == "local_decl":
            if plan.opArg0s[i] != localSlot:
                return ""
            sawDecl = true
            i = i + 1
            continue
        if i + 2 >= loadIdx:
            return ""
        let zeroValueOk = plan.opKinds[i] == "load_nil" ||
                          (plan.opKinds[i] == "load_int32" && plan.opPrimaryTexts[i] == "0")
        if !zeroValueOk:
            return ""
        if plan.opKinds[i + 1] != "load_local" || plan.opArg0s[i + 1] != localSlot:
            return ""
        if plan.opKinds[i + 2] != "store_field":
            return ""
        sawStore = true
        i = i + 3
    if sawDecl && sawStore:
        return machineDirectReturnEmptyBytesWords(architecture)
    return ""

fn compilerCoreDirectExecDropOnlyWords(plan: cflow.LowUirCompilerCorePlan,
                                       itemIdx: int32,
                                       architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount <= 0:
        return ""
    var limit = opCount
    if plan.opKinds[opStart + opCount - 1] == "return_void":
        limit = limit - 1
    if limit <= 0:
        return ""
    if (limit % 2) != 0:
        return ""
    var i: int32 = 0
    while i < limit:
        if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + i]):
            return ""
        if plan.opKinds[opStart + i + 1] != "drop_value":
            return ""
        i = i + 2
    return machineDirectReturnVoidWords(architecture)

fn compilerCoreDirectExecZeroVarStrOutWords(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32,
                                            architecture: str): str =
    if plan.paramCounts[itemIdx] != 1:
        return ""
    if !compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0), "str"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 13:
        return ""
    let expectedFieldNames = ["data", "len", "store_id", "flags"]
    for fieldIdx in 0..<4:
        let loadValueIdx = opStart + (fieldIdx * 3)
        let loadParamIdx = loadValueIdx + 1
        let storeFieldIdx = loadValueIdx + 2
        if fieldIdx == 0:
            if plan.opKinds[loadValueIdx] != "load_nil":
                return ""
        else:
            if plan.opKinds[loadValueIdx] != "load_int32" || plan.opPrimaryTexts[loadValueIdx] != "0":
                return ""
        if plan.opKinds[loadParamIdx] != "load_param" || plan.opArg0s[loadParamIdx] != 0:
            return ""
        if plan.opKinds[storeFieldIdx] != "store_field" || plan.opPrimaryTexts[storeFieldIdx] != expectedFieldNames[fieldIdx]:
            return ""
    if plan.opKinds[opStart + 12] != "return_void":
        return ""
    return machineDirectZeroVarStrOutWords(architecture)

fn compilerCoreDirectExecCopyVarStrOutWords(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32,
                                            architecture: str): str =
    if plan.paramCounts[itemIdx] != 2:
        return ""
    let outParamType = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
    if len(outParamType) <= 4 ||
       outParamType[0] != 'v' ||
       outParamType[1] != 'a' ||
       outParamType[2] != 'r' ||
       outParamType[3] != ' ' ||
       !compilerCoreTypeMatches(outParamType, "str"):
        return ""
    if !compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 1), "str"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 17:
        return ""
    let expectedFieldNames = ["data", "len", "store_id", "flags"]
    for fieldIdx in 0..<4:
        let loadValueBaseIdx = opStart + (fieldIdx * 4)
        let loadValueFieldIdx = loadValueBaseIdx + 1
        let loadOutIdx = loadValueBaseIdx + 2
        let storeFieldIdx = loadValueBaseIdx + 3
        if plan.opKinds[loadValueBaseIdx] != "load_param" || plan.opArg0s[loadValueBaseIdx] != 1:
            return ""
        if plan.opKinds[loadValueFieldIdx] != "load_field" ||
           plan.opPrimaryTexts[loadValueFieldIdx] != expectedFieldNames[fieldIdx]:
            return ""
        if plan.opKinds[loadOutIdx] != "load_param" || plan.opArg0s[loadOutIdx] != 0:
            return ""
        if plan.opKinds[storeFieldIdx] != "store_field" ||
           plan.opPrimaryTexts[storeFieldIdx] != expectedFieldNames[fieldIdx]:
            return ""
    if plan.opKinds[opStart + 16] != "return_void":
        return ""
    return machineDirectCopyVarStrOutWords(architecture)

fn compilerCoreDirectExecIfElseWords(plan: cflow.LowUirCompilerCorePlan,
                                     itemIdx: int32,
                                     architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 9 &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart]) &&
       plan.opKinds[opStart + 1] == "jump_if_false" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "return_value" &&
       plan.opKinds[opStart + 4] == "jump" &&
       plan.opKinds[opStart + 5] == "label" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 6]) &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opKinds[opStart + 8] == "label" &&
       plan.opPrimaryTexts[opStart + 1] == plan.opPrimaryTexts[opStart + 5] &&
       plan.opPrimaryTexts[opStart + 4] == plan.opPrimaryTexts[opStart + 8]:
        return machineDirectIfElseSimpleCondWords(architecture,
                                                  plan.opKinds[opStart],
                                                  plan.opPrimaryTexts[opStart],
                                                  plan.opArg0s[opStart],
                                                  plan.opKinds[opStart + 2],
                                                  plan.opPrimaryTexts[opStart + 2],
                                                  plan.opArg0s[opStart + 2],
                                                  plan.opKinds[opStart + 6],
                                                  plan.opPrimaryTexts[opStart + 6],
                                                  plan.opArg0s[opStart + 6])
    if opCount == 11 &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "binary_op" &&
       plan.opKinds[opStart + 3] == "jump_if_false" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 4]) &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opKinds[opStart + 6] == "jump" &&
       plan.opKinds[opStart + 7] == "label" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 8]) &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opKinds[opStart + 10] == "label" &&
       plan.opPrimaryTexts[opStart + 3] == plan.opPrimaryTexts[opStart + 7] &&
       plan.opPrimaryTexts[opStart + 6] == plan.opPrimaryTexts[opStart + 10]:
        return machineDirectIfElseBinaryCondWords(architecture,
                                                  plan.opKinds[opStart],
                                                  plan.opPrimaryTexts[opStart],
                                                  plan.opArg0s[opStart],
                                                  plan.opKinds[opStart + 1],
                                                  plan.opPrimaryTexts[opStart + 1],
                                                  plan.opArg0s[opStart + 1],
                                                  plan.opPrimaryTexts[opStart + 2],
                                                  plan.opKinds[opStart + 4],
                                                  plan.opPrimaryTexts[opStart + 4],
                                                  plan.opArg0s[opStart + 4],
                                                 plan.opKinds[opStart + 8],
                                                 plan.opPrimaryTexts[opStart + 8],
                                                 plan.opArg0s[opStart + 8])
    return ""

fn compilerCoreDirectExecIfElseCallSymbols(plan: cflow.LowUirCompilerCorePlan,
                                           itemIdx: int32,
                                           targetTriple: str): str[] =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if !compilerCoreDirectCallReturnTypeSupported(plan.returnTypeTexts[itemIdx]):
        return []
    if opCount == 12 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opKinds[opStart + 6] == "jump" &&
       plan.opKinds[opStart + 7] == "label" &&
       plan.opKinds[opStart + 8] == "load_routine" &&
       plan.opKinds[opStart + 9] == "call" &&
       plan.opKinds[opStart + 10] == "return_value" &&
       plan.opKinds[opStart + 11] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 4] == 0 &&
       plan.opArg0s[opStart + 9] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 7] &&
       plan.opPrimaryTexts[opStart + 6] == plan.opPrimaryTexts[opStart + 11]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let thenItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 8])
        if condItemIdx >= 0 && thenItemIdx >= 0 && elseItemIdx >= 0:
            let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
            let thenSymbol = compilerCoreDirectExecCalleeSymbol(plan, thenItemIdx, targetTriple)
            let elseSymbol = compilerCoreDirectExecCalleeSymbol(plan, elseItemIdx, targetTriple)
            if len(condSymbol) > 0 && len(thenSymbol) > 0 && len(elseSymbol) > 0:
                return [condSymbol, thenSymbol, elseSymbol]
    if opCount == 11 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opKinds[opStart + 5] == "jump" &&
       plan.opKinds[opStart + 6] == "label" &&
       plan.opKinds[opStart + 7] == "load_routine" &&
       plan.opKinds[opStart + 8] == "call" &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opKinds[opStart + 10] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 8] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 6] &&
       plan.opPrimaryTexts[opStart + 5] == plan.opPrimaryTexts[opStart + 10]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 7])
        if condItemIdx >= 0 && elseItemIdx >= 0:
            let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
            let elseSymbol = compilerCoreDirectExecCalleeSymbol(plan, elseItemIdx, targetTriple)
            if len(condSymbol) > 0 && len(elseSymbol) > 0:
                return [condSymbol, elseSymbol]
    if opCount == 11 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opKinds[opStart + 6] == "jump" &&
       plan.opKinds[opStart + 7] == "label" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 8]) &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opKinds[opStart + 10] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 4] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 7] &&
       plan.opPrimaryTexts[opStart + 6] == plan.opPrimaryTexts[opStart + 10]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let thenItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
        if condItemIdx >= 0 && thenItemIdx >= 0:
            let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
            let thenSymbol = compilerCoreDirectExecCalleeSymbol(plan, thenItemIdx, targetTriple)
            if len(condSymbol) > 0 && len(thenSymbol) > 0:
                return [condSymbol, thenSymbol]
    if opCount == 14 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "binary_op" &&
       plan.opKinds[opStart + 4] == "jump_if_false" &&
       plan.opKinds[opStart + 5] == "load_routine" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opKinds[opStart + 8] == "jump" &&
       plan.opKinds[opStart + 9] == "label" &&
       plan.opKinds[opStart + 10] == "load_routine" &&
       plan.opKinds[opStart + 11] == "call" &&
       plan.opKinds[opStart + 12] == "return_value" &&
       plan.opKinds[opStart + 13] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 6] == 0 &&
       plan.opArg0s[opStart + 11] == 0 &&
       plan.opPrimaryTexts[opStart + 4] == plan.opPrimaryTexts[opStart + 9] &&
       plan.opPrimaryTexts[opStart + 8] == plan.opPrimaryTexts[opStart + 13]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let thenItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 5])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 10])
        if condItemIdx >= 0 && thenItemIdx >= 0 && elseItemIdx >= 0:
            let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
            let thenSymbol = compilerCoreDirectExecCalleeSymbol(plan, thenItemIdx, targetTriple)
            let elseSymbol = compilerCoreDirectExecCalleeSymbol(plan, elseItemIdx, targetTriple)
            if len(condSymbol) > 0 && len(thenSymbol) > 0 && len(elseSymbol) > 0:
                return [condSymbol, thenSymbol, elseSymbol]
    return []

fn compilerCoreDirectExecIfElseCallWords(plan: cflow.LowUirCompilerCorePlan,
                                         itemIdx: int32,
                                         architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 12 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opKinds[opStart + 6] == "jump" &&
       plan.opKinds[opStart + 7] == "label" &&
       plan.opKinds[opStart + 8] == "load_routine" &&
       plan.opKinds[opStart + 9] == "call" &&
       plan.opKinds[opStart + 10] == "return_value" &&
       plan.opKinds[opStart + 11] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 4] == 0 &&
       plan.opArg0s[opStart + 9] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 7] &&
       plan.opPrimaryTexts[opStart + 6] == plan.opPrimaryTexts[opStart + 11]:
        return machineDirectIfElseCallWords(architecture)
    if opCount == 11 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opKinds[opStart + 5] == "jump" &&
       plan.opKinds[opStart + 6] == "label" &&
       plan.opKinds[opStart + 7] == "load_routine" &&
       plan.opKinds[opStart + 8] == "call" &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opKinds[opStart + 10] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 8] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 6] &&
       plan.opPrimaryTexts[opStart + 5] == plan.opPrimaryTexts[opStart + 10]:
        return machineDirectIfElseConstThenCallWords(architecture,
                                                     plan.opKinds[opStart + 3],
                                                     plan.opPrimaryTexts[opStart + 3],
                                                     plan.opArg0s[opStart + 3])
    if opCount == 11 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opKinds[opStart + 6] == "jump" &&
       plan.opKinds[opStart + 7] == "label" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 8]) &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opKinds[opStart + 10] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 4] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 7] &&
       plan.opPrimaryTexts[opStart + 6] == plan.opPrimaryTexts[opStart + 10]:
        return machineDirectIfElseCallThenConstWords(architecture,
                                                     plan.opKinds[opStart + 8],
                                                     plan.opPrimaryTexts[opStart + 8],
                                                     plan.opArg0s[opStart + 8])
    if opCount == 14 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "binary_op" &&
       plan.opKinds[opStart + 4] == "jump_if_false" &&
       plan.opKinds[opStart + 5] == "load_routine" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opKinds[opStart + 8] == "jump" &&
       plan.opKinds[opStart + 9] == "label" &&
       plan.opKinds[opStart + 10] == "load_routine" &&
       plan.opKinds[opStart + 11] == "call" &&
       plan.opKinds[opStart + 12] == "return_value" &&
       plan.opKinds[opStart + 13] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 6] == 0 &&
       plan.opArg0s[opStart + 11] == 0 &&
       plan.opPrimaryTexts[opStart + 4] == plan.opPrimaryTexts[opStart + 9] &&
       plan.opPrimaryTexts[opStart + 8] == plan.opPrimaryTexts[opStart + 13]:
        return machineDirectIfElseCallCompareConstRhsWords(architecture,
                                                           plan.opKinds[opStart + 2],
                                                           plan.opPrimaryTexts[opStart + 2],
                                                           plan.opArg0s[opStart + 2],
                                                           plan.opPrimaryTexts[opStart + 3])
    return ""

fn compilerCoreDirectExecFieldArithmeticCompareWords(plan: cflow.LowUirCompilerCorePlan,
                                                     itemIdx: int32,
                                                     architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 9 ||
       plan.opKinds[opStart] != "load_param" ||
       plan.opKinds[opStart + 1] != "load_field" ||
       !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) ||
       plan.opKinds[opStart + 3] != "binary_op" ||
       plan.opKinds[opStart + 4] != "load_param" ||
       plan.opKinds[opStart + 5] != "load_field" ||
       plan.opKinds[opStart + 6] != "load_field" ||
       plan.opKinds[opStart + 7] != "binary_op" ||
       plan.opKinds[opStart + 8] != "return_value":
        return ""
    let arithmeticOperatorText = plan.opPrimaryTexts[opStart + 3]
    let compareOperatorText = plan.opPrimaryTexts[opStart + 7]
    if arithmeticOperatorText != "+" && arithmeticOperatorText != "-":
        return ""
    if compareOperatorText != "==" && compareOperatorText != "!=" &&
       compareOperatorText != "<" && compareOperatorText != "<=" &&
       compareOperatorText != ">" && compareOperatorText != ">=":
        return ""
    var lhsSourceReg: int32 = -1
    var lhsSourceIs64: bool = false
    if !compilerCoreDirectParamFieldReturnBinding(plan.signatureTexts[itemIdx],
                                                  plan.opArg0s[opStart],
                                                  plan.opPrimaryTexts[opStart + 1],
                                                  lhsSourceReg,
                                                  lhsSourceIs64):
        return ""
    var compareSourceReg: int32 = -1
    var compareSourceIs64: bool = false
    if !compilerCoreDirectParamNestedFieldReturnBinding(plan.signatureTexts[itemIdx],
                                                        plan.opArg0s[opStart + 4],
                                                        plan.opPrimaryTexts[opStart + 5],
                                                        plan.opPrimaryTexts[opStart + 6],
                                                        compareSourceReg,
                                                        compareSourceIs64):
        return ""
    return machineDirectArithmeticCompareWords(architecture,
                                               plan.signatureTexts[itemIdx],
                                               lhsSourceReg,
                                               lhsSourceIs64,
                                               arithmeticOperatorText,
                                               plan.opKinds[opStart + 2],
                                               plan.opPrimaryTexts[opStart + 2],
                                               plan.opArg0s[opStart + 2],
                                               compareSourceReg,
                                               compareSourceIs64,
                                               compareOperatorText)

fn compilerCoreDirectExecWords(plan: cflow.LowUirCompilerCorePlan,
                               itemIdx: int32,
                               architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    let paramReturnWords = compilerCoreDirectExecParamReturnWords(plan, itemIdx, architecture)
    if len(paramReturnWords) > 0:
        return paramReturnWords
    let fieldWords = compilerCoreDirectExecFieldWords(plan, itemIdx, architecture)
    if len(fieldWords) > 0:
        return fieldWords
    let bytesLiteralWords = compilerCoreDirectExecBytesLiteralWords(plan, itemIdx, architecture)
    if len(bytesLiteralWords) > 0:
        return bytesLiteralWords
    let paramAggregateWords = compilerCoreDirectExecParamAggregateWords(plan, itemIdx, architecture)
    if len(paramAggregateWords) > 0:
        return paramAggregateWords
    let zeroAggregateWords = compilerCoreDirectExecZeroAggregateWords(plan, itemIdx, architecture)
    if len(zeroAggregateWords) > 0:
        return zeroAggregateWords
    let zeroVarStrOutWords = compilerCoreDirectExecZeroVarStrOutWords(plan, itemIdx, architecture)
    if len(zeroVarStrOutWords) > 0:
        return zeroVarStrOutWords
    let copyVarStrOutWords = compilerCoreDirectExecCopyVarStrOutWords(plan, itemIdx, architecture)
    if len(copyVarStrOutWords) > 0:
        return copyVarStrOutWords
    let dropOnlyWords = compilerCoreDirectExecDropOnlyWords(plan, itemIdx, architecture)
    if len(dropOnlyWords) > 0:
        return dropOnlyWords
    let localAliasWords = compilerCoreDirectExecLocalAliasWords(plan, itemIdx, architecture)
    if len(localAliasWords) > 0:
        return localAliasWords
    let ifElseCallWords = compilerCoreDirectExecIfElseCallWords(plan, itemIdx, architecture)
    if len(ifElseCallWords) > 0:
        return ifElseCallWords
    let ifElseWords = compilerCoreDirectExecIfElseWords(plan, itemIdx, architecture)
    if len(ifElseWords) > 0:
        return ifElseWords
    let fieldArithmeticCompareWords = compilerCoreDirectExecFieldArithmeticCompareWords(plan, itemIdx, architecture)
    if len(fieldArithmeticCompareWords) > 0:
        return fieldArithmeticCompareWords
    if opCount <= 0:
        return ""
    if opCount == 1 && plan.opKinds[opStart] == "return_void":
        return machineDirectReturnVoidWords(architecture)
    if opCount == 2 && plan.opKinds[opStart + 1] == "return_value":
        return machineDirectReturnSimpleValueWords(architecture,
                                                   plan.opKinds[opStart],
                                                   plan.opPrimaryTexts[opStart],
                                                   plan.opArg0s[opStart])
    if opCount == 3 && plan.opKinds[opStart + 2] == "return_value":
        return machineDirectUnaryWords(architecture,
                                       plan.opKinds[opStart + 1],
                                       plan.opKinds[opStart],
                                       plan.opPrimaryTexts[opStart],
                                       plan.opArg0s[opStart])
    if opCount == 4 &&
       plan.opKinds[opStart + 2] == "binary_op" &&
       plan.opKinds[opStart + 3] == "return_value":
        return machineDirectBinaryWords(architecture,
                                        plan.opKinds[opStart],
                                        plan.opPrimaryTexts[opStart],
                                        plan.opArg0s[opStart],
                                        plan.opKinds[opStart + 1],
                                        plan.opPrimaryTexts[opStart + 1],
                                        plan.opArg0s[opStart + 1],
                                        plan.opPrimaryTexts[opStart + 2])
    return ""

fn compilerCoreDirectExecNestedCallSymbols(plan: cflow.LowUirCompilerCorePlan,
                                           itemIdx: int32,
                                           targetTriple: str): str[] =
    var out: str[]
    out = []
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if !compilerCoreDirectCallReturnTypeSupported(plan.returnTypeTexts[itemIdx]):
        return out
    for argCount in 0..<5:
        let innerCallIdx = opStart + 2 + argCount
        let outerCallIdx = innerCallIdx + 1
        if opCount == argCount + 5 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[outerCallIdx + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx] == 1:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
            if !argsOk:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerCalleeIdx < 0 || innerCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 1:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) != 1:
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        let outerArgIdx = innerCallIdx + 1
        let outerCallIdx2 = innerCallIdx + 2
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           compilerCoreIsDirectSimpleValueKind(plan.opKinds[outerArgIdx]) &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
            if !argsOk:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerCalleeIdx < 0 || innerCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 2:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1)) != 1:
                continue
            if plan.opKinds[outerArgIdx] == "load_param" &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArgIdx])) != 1:
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerArgIdx] == "load_str" &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
            if !argsOk:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerCalleeIdx < 0 || innerCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 2:
                continue
            if !compilerCoreTypeMatches(plan.returnTypeTexts[innerCalleeIdx], "str"):
                continue
            if !compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0), "str"):
                continue
            if !compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1), "str"):
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx] == "call" &&
           compilerCoreIsDirectConstValueKind(plan.opKinds[outerCallIdx + 1]) &&
           plan.opKinds[outerCallIdx + 2] == "binary_op" &&
           plan.opKinds[outerCallIdx + 3] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx] == 1:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
            if !argsOk:
                continue
            let compareOperatorText = plan.opPrimaryTexts[outerCallIdx + 2]
            if compareOperatorText != "==" && compareOperatorText != "!=" &&
               compareOperatorText != "<" && compareOperatorText != "<=" &&
               compareOperatorText != ">" && compareOperatorText != ">=":
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerCalleeIdx < 0 || innerCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 1:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) != 1:
                continue
            if !compilerCoreTypeMatches(plan.returnTypeTexts[outerCalleeIdx], "int32") &&
               !compilerCoreTypeMatches(plan.returnTypeTexts[outerCalleeIdx], "bool"):
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
    return out

fn compilerCoreDirectExecNestedCallWords(plan: cflow.LowUirCompilerCorePlan,
                                         itemIdx: int32,
                                         architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    for argCount in 0..<5:
        let innerCallIdx = opStart + 2 + argCount
        let outerCallIdx = innerCallIdx + 1
        if opCount == argCount + 5 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx] == 1:
            var argKinds: str[]
            var argPrimaryTexts: str[]
            var argArg0s: int32[]
            argKinds = []
            argPrimaryTexts = []
            argArg0s = []
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
                add(argKinds, plan.opKinds[opStart + 2 + i])
                add(argPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(argArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk:
                return machineDirectNestedCallWords(architecture, argKinds, argPrimaryTexts, argArg0s)
        let outerArgIdx = innerCallIdx + 1
        let outerCallIdx2 = innerCallIdx + 2
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           compilerCoreIsDirectSimpleValueKind(plan.opKinds[outerArgIdx]) &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var innerArgKinds: str[]
            var innerArgPrimaryTexts: str[]
            var innerArgArg0s: int32[]
            innerArgKinds = []
            innerArgPrimaryTexts = []
            innerArgArg0s = []
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
                add(innerArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk:
                return machineDirectNestedCallTrailingSimpleArgWords(architecture,
                                                                     innerArgKinds,
                                                                     innerArgPrimaryTexts,
                                                                     innerArgArg0s,
                                                                     plan.opKinds[outerArgIdx],
                                                                     plan.opPrimaryTexts[outerArgIdx],
                                                                     plan.opArg0s[outerArgIdx])
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerArgIdx] == "load_str" &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var innerArgKinds: str[]
            var innerArgPrimaryTexts: str[]
            var innerArgArg0s: int32[]
            innerArgKinds = []
            innerArgPrimaryTexts = []
            innerArgArg0s = []
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
                add(innerArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk:
                return machineDirectNestedCallTrailingCStringArgWords(architecture,
                                                                      innerArgKinds,
                                                                      innerArgPrimaryTexts,
                                                                      innerArgArg0s,
                                                                      len(plan.opPrimaryTexts[outerArgIdx]))
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx] == "call" &&
           compilerCoreIsDirectConstValueKind(plan.opKinds[outerCallIdx + 1]) &&
           plan.opKinds[outerCallIdx + 2] == "binary_op" &&
           plan.opKinds[outerCallIdx + 3] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx] == 1:
            let compareOperatorText = plan.opPrimaryTexts[outerCallIdx + 2]
            if compareOperatorText != "==" && compareOperatorText != "!=" &&
               compareOperatorText != "<" && compareOperatorText != "<=" &&
               compareOperatorText != ">" && compareOperatorText != ">=":
                continue
            var argKinds: str[]
            var argPrimaryTexts: str[]
            var argArg0s: int32[]
            argKinds = []
            argPrimaryTexts = []
            argArg0s = []
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
                add(argKinds, plan.opKinds[opStart + 2 + i])
                add(argPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(argArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk:
                return machineDirectNestedCallCompareConstRhsWords(architecture,
                                                                   argKinds,
                                                                   argPrimaryTexts,
                                                                   argArg0s,
                                                                   plan.opKinds[outerCallIdx + 1],
                                                                   plan.opPrimaryTexts[outerCallIdx + 1],
                                                                   plan.opArg0s[outerCallIdx + 1],
                                                                   compareOperatorText)
    return ""

fn compilerCoreDirectExecCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                    itemIdx: int32,
                                    targetTriple: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if !compilerCoreDirectCallReturnTypeSupported(plan.returnTypeTexts[itemIdx]):
        return ""
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "return_value" &&
       plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        if calleeItemIdx >= 0 &&
           compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0), "str"):
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "load_str" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        if calleeItemIdx >= 0 &&
           compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0), "str") &&
           compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 1), "str"):
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "binary_op" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 1] == 0:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 0)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "call" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "binary_op" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 3 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
        plan.opKinds[opStart + 2] == "return_value" &&
        plan.opArg0s[opStart + 1] == 0:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 0)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "return_value" &&
       plan.opArg0s[opStart + 1] == 0 &&
        plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opKinds[opStart + 2] == "load_field" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        if calleeItemIdx >= 0:
            let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
            var aggregateResultTypeText: str = ""
            var sourceReg0: int32 = -1
            var sourceReg1: int32 = -1
            var sourceReg1Is64: bool = false
            if compilerCoreDirectAggregateFieldBinding(paramTypeText,
                                                       plan.opPrimaryTexts[opStart + 2],
                                                       aggregateResultTypeText,
                                                       sourceReg0,
                                                       sourceReg1,
                                                       sourceReg1Is64) &&
               compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0),
                                       aggregateResultTypeText):
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 2)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opArg0s[opStart + 4] == 3:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 3)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 7 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 4]) &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opArg0s[opStart + 5] == 4:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 4)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 7 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 5] == 1:
        var resolvedKind: str = ""
        var resolvedPrimaryText: str = ""
        var resolvedArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            resolvedKind,
                                            resolvedPrimaryText,
                                            resolvedArg0):
            let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 3, 1)
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 8 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 6] == 2:
        var lhsKind: str = ""
        var lhsPrimaryText: str = ""
        var lhsArg0: int32 = -1
        var rhsKind: str = ""
        var rhsPrimaryText: str = ""
        var rhsArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            lhsKind,
                                            lhsPrimaryText,
                                            lhsArg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            rhsKind,
                                            rhsPrimaryText,
                                            rhsArg0):
            let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 3, 2)
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 9 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 7] == "call" &&
       plan.opKinds[opStart + 8] == "return_value" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 7] == 3:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0):
            let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 3, 3)
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 10 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 8] == "call" &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 8] == 4:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        var arg3Kind: str = ""
        var arg3PrimaryText: str = ""
        var arg3Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 7,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg3Kind,
                                            arg3PrimaryText,
                                            arg3Arg0):
            let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 3, 4)
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecCallWords(plan: cflow.LowUirCompilerCorePlan,
                                   itemIdx: int32,
                                   architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    let cstringPayload = compilerCoreDirectExecCallCStringPayloadText(plan, itemIdx)
    if len(cstringPayload) > 0:
        return machineDirectCallCStringArgWords(architecture, len(cstringPayload))
    let secondCStringPayload = compilerCoreDirectExecCallSecondCStringPayloadText(plan, itemIdx)
    if len(secondCStringPayload) > 0:
        return machineDirectCallSecondCStringArgWords(architecture, len(secondCStringPayload))
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "binary_op" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 1] == 0:
        var argKinds: str[]
        var argPrimaryTexts: str[]
        var argArg0s: int32[]
        argKinds = []
        argPrimaryTexts = []
        argArg0s = []
        return machineDirectCallCompareConstRhsWords(architecture,
                                                     argKinds,
                                                     argPrimaryTexts,
                                                     argArg0s,
                                                     plan.opKinds[opStart + 2],
                                                     plan.opPrimaryTexts[opStart + 2],
                                                     plan.opArg0s[opStart + 2],
                                                     plan.opPrimaryTexts[opStart + 3])
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "call" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "binary_op" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opArg0s[opStart + 2] == 1:
        var argKinds: str[]
        var argPrimaryTexts: str[]
        var argArg0s: int32[]
        argKinds = []
        argPrimaryTexts = []
        argArg0s = []
        add(argKinds, plan.opKinds[opStart + 1])
        add(argPrimaryTexts, plan.opPrimaryTexts[opStart + 1])
        add(argArg0s, plan.opArg0s[opStart + 1])
        return machineDirectCallCompareConstRhsWords(architecture,
                                                     argKinds,
                                                     argPrimaryTexts,
                                                     argArg0s,
                                                     plan.opKinds[opStart + 3],
                                                     plan.opPrimaryTexts[opStart + 3],
                                                     plan.opArg0s[opStart + 3],
                                                     plan.opPrimaryTexts[opStart + 4])
    if opCount == 3 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "return_value" &&
       plan.opArg0s[opStart + 1] == 0:
        return machineDirectCallWords(architecture)
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "return_value" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 2] == 1:
        return machineDirectCallSimpleArgWords(architecture,
                                               plan.opKinds[opStart + 1],
                                               plan.opPrimaryTexts[opStart + 1],
                                               plan.opArg0s[opStart + 1])
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opKinds[opStart + 2] == "load_field" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 1:
        let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
        var aggregateResultTypeText: str = ""
        var sourceReg0: int32 = -1
        var sourceReg1: int32 = -1
        var sourceReg1Is64: bool = false
        if compilerCoreDirectAggregateFieldBinding(paramTypeText,
                                                   plan.opPrimaryTexts[opStart + 2],
                                                   aggregateResultTypeText,
                                                   sourceReg0,
                                                   sourceReg1,
                                                   sourceReg1Is64):
            return machineDirectCallRegisterPairArgWords(architecture,
                                                         sourceReg0,
                                                         sourceReg1,
                                                         sourceReg1Is64)
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 2:
        return machineDirectCallTwoSimpleArgWords(architecture,
                                                  plan.opKinds[opStart + 1],
                                                  plan.opPrimaryTexts[opStart + 1],
                                                  plan.opArg0s[opStart + 1],
                                                  plan.opKinds[opStart + 2],
                                                  plan.opPrimaryTexts[opStart + 2],
                                                  plan.opArg0s[opStart + 2])
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opArg0s[opStart + 4] == 3:
        return machineDirectCallThreeSimpleArgWords(architecture,
                                                    plan.opKinds[opStart + 1],
                                                    plan.opPrimaryTexts[opStart + 1],
                                                    plan.opArg0s[opStart + 1],
                                                    plan.opKinds[opStart + 2],
                                                    plan.opPrimaryTexts[opStart + 2],
                                                    plan.opArg0s[opStart + 2],
                                                    plan.opKinds[opStart + 3],
                                                    plan.opPrimaryTexts[opStart + 3],
                                                    plan.opArg0s[opStart + 3])
    if opCount == 7 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 4]) &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opArg0s[opStart + 5] == 4:
        return machineDirectCallFourSimpleArgWords(architecture,
                                                   plan.opKinds[opStart + 1],
                                                   plan.opPrimaryTexts[opStart + 1],
                                                   plan.opArg0s[opStart + 1],
                                                   plan.opKinds[opStart + 2],
                                                   plan.opPrimaryTexts[opStart + 2],
                                                   plan.opArg0s[opStart + 2],
                                                   plan.opKinds[opStart + 3],
                                                   plan.opPrimaryTexts[opStart + 3],
                                                   plan.opArg0s[opStart + 3],
                                                   plan.opKinds[opStart + 4],
                                                   plan.opPrimaryTexts[opStart + 4],
                                                   plan.opArg0s[opStart + 4])
    if opCount == 7 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 5] == 1:
        var resolvedKind: str = ""
        var resolvedPrimaryText: str = ""
        var resolvedArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            resolvedKind,
                                            resolvedPrimaryText,
                                            resolvedArg0):
            return machineDirectCallSimpleArgWords(architecture,
                                                   resolvedKind,
                                                   resolvedPrimaryText,
                                                   resolvedArg0)
    if opCount == 8 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 6] == 2:
        var lhsKind: str = ""
        var lhsPrimaryText: str = ""
        var lhsArg0: int32 = -1
        var rhsKind: str = ""
        var rhsPrimaryText: str = ""
        var rhsArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            lhsKind,
                                            lhsPrimaryText,
                                            lhsArg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            rhsKind,
                                            rhsPrimaryText,
                                            rhsArg0):
            return machineDirectCallTwoSimpleArgWords(architecture,
                                                      lhsKind,
                                                      lhsPrimaryText,
                                                      lhsArg0,
                                                      rhsKind,
                                                      rhsPrimaryText,
                                                      rhsArg0)
    if opCount == 9 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 7] == "call" &&
       plan.opKinds[opStart + 8] == "return_value" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 7] == 3:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0):
            return machineDirectCallThreeSimpleArgWords(architecture,
                                                        arg0Kind,
                                                        arg0PrimaryText,
                                                        arg0Arg0,
                                                        arg1Kind,
                                                        arg1PrimaryText,
                                                        arg1Arg0,
                                                        arg2Kind,
                                                        arg2PrimaryText,
                                                        arg2Arg0)
    if opCount == 10 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 8] == "call" &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 8] == 4:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        var arg3Kind: str = ""
        var arg3PrimaryText: str = ""
        var arg3Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 7,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg3Kind,
                                            arg3PrimaryText,
                                            arg3Arg0):
            return machineDirectCallFourSimpleArgWords(architecture,
                                                       arg0Kind,
                                                       arg0PrimaryText,
                                                       arg0Arg0,
                                                       arg1Kind,
                                                       arg1PrimaryText,
                                                       arg1Arg0,
                                                       arg2Kind,
                                                       arg2PrimaryText,
                                                       arg2Arg0,
                                                       arg3Kind,
                                                       arg3PrimaryText,
                                                       arg3Arg0)
    return ""

fn compilerCoreDirectExecVoidThenConstCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                                 itemIdx: int32,
                                                 targetTriple: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "drop_value" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "return_value" &&
        plan.opArg0s[opStart + 1] == 0:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 0)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    for argCount in 1..<5:
        let callIdx = opStart + 1 + argCount
        let dropIdx = callIdx + 1
        let constIdx = callIdx + 2
        let returnIdx = callIdx + 3
        if opCount != argCount + 5 ||
           plan.opKinds[opStart] != "load_routine" ||
           plan.opKinds[callIdx] != "call" ||
           plan.opKinds[dropIdx] != "drop_value" ||
           !compilerCoreIsDirectConstValueKind(plan.opKinds[constIdx]) ||
           plan.opKinds[returnIdx] != "return_value" ||
           plan.opArg0s[callIdx] != argCount:
            continue
        var argKinds: str[]
        var argPrimaryTexts: str[]
        var argArg0s: int32[]
        argKinds = []
        argPrimaryTexts = []
        argArg0s = []
        var argsOk: bool = true
        for i in 0..<argCount:
            let argIdx = opStart + 1 + i
            if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[argIdx]):
                argsOk = false
            add(argKinds, plan.opKinds[argIdx])
            add(argPrimaryTexts, plan.opPrimaryTexts[argIdx])
            add(argArg0s, plan.opArg0s[argIdx])
        if !argsOk:
            continue
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, argCount)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecVoidThenConstCallWords(plan: cflow.LowUirCompilerCorePlan,
                                                itemIdx: int32,
                                                architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "drop_value" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "return_value" &&
        plan.opArg0s[opStart + 1] == 0:
        return machineDirectCallVoidThenConstWords(architecture,
                                                   plan.opKinds[opStart + 3],
                                                   plan.opPrimaryTexts[opStart + 3],
                                                   plan.opArg0s[opStart + 3])
    for argCount in 1..<5:
        let callIdx = opStart + 1 + argCount
        let dropIdx = callIdx + 1
        let constIdx = callIdx + 2
        let returnIdx = callIdx + 3
        if opCount != argCount + 5 ||
           plan.opKinds[opStart] != "load_routine" ||
           plan.opKinds[callIdx] != "call" ||
           plan.opKinds[dropIdx] != "drop_value" ||
           !compilerCoreIsDirectConstValueKind(plan.opKinds[constIdx]) ||
           plan.opKinds[returnIdx] != "return_value" ||
           plan.opArg0s[callIdx] != argCount:
            continue
        var argKinds: str[]
        var argPrimaryTexts: str[]
        var argArg0s: int32[]
        argKinds = []
        argPrimaryTexts = []
        argArg0s = []
        var argsOk: bool = true
        for i in 0..<argCount:
            let argIdx = opStart + 1 + i
            if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[argIdx]):
                argsOk = false
            add(argKinds, plan.opKinds[argIdx])
            add(argPrimaryTexts, plan.opPrimaryTexts[argIdx])
            add(argArg0s, plan.opArg0s[argIdx])
        if !argsOk:
            continue
        return machineDirectCallSimpleArgsVoidThenConstWords(architecture,
                                                             argKinds,
                                                             argPrimaryTexts,
                                                             argArg0s,
                                                             plan.opKinds[constIdx],
                                                             plan.opPrimaryTexts[constIdx],
                                                             plan.opArg0s[constIdx])
    return ""

fn compilerCoreDirectExecFallbackCallSymbols(plan: cflow.LowUirCompilerCorePlan,
                                             itemIdx: int32,
                                             targetTriple: str): str[] =
    var out: str[]
    out = []
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if !compilerCoreDirectCallReturnTypeSupported(plan.returnTypeTexts[itemIdx]):
        return out
    if opCount < 11 ||
       plan.opKinds[opStart] != "local_decl":
        return out
    let localSlot = plan.opArg0s[opStart]
    let firstArgCount = plan.opArg0s[opStart + 4]
    if firstArgCount < 0 || firstArgCount > 4:
        return out
    let firstCallIdx = opStart + 4
    let firstRoutineIdx = opStart + 1
    if plan.opKinds[firstRoutineIdx] != "load_routine" ||
       plan.opKinds[firstCallIdx] != "call" ||
       plan.opKinds[firstCallIdx + 1] != "store_local" ||
       plan.opArg0s[firstCallIdx + 1] != localSlot ||
       plan.opKinds[firstCallIdx + 2] != "load_local" ||
       plan.opArg0s[firstCallIdx + 2] != localSlot ||
       plan.opKinds[firstCallIdx + 3] != "load_nil" ||
       plan.opKinds[firstCallIdx + 4] != "binary_op" ||
       plan.opPrimaryTexts[firstCallIdx + 4] != "!=" ||
       plan.opKinds[firstCallIdx + 5] != "jump_if_false" ||
       plan.opKinds[firstCallIdx + 6] != "load_local" ||
       plan.opArg0s[firstCallIdx + 6] != localSlot ||
       plan.opKinds[firstCallIdx + 7] != "return_value" ||
       plan.opKinds[firstCallIdx + 8] != "jump" ||
       plan.opKinds[firstCallIdx + 9] != "label":
        return out
    let elseLabel = plan.opPrimaryTexts[firstCallIdx + 5]
    let endLabel = plan.opPrimaryTexts[firstCallIdx + 8]
    if plan.opPrimaryTexts[firstCallIdx + 9] != elseLabel:
        return out
    let secondRoutineIdx = firstCallIdx + 10
    if secondRoutineIdx >= opStart + opCount ||
       plan.opKinds[secondRoutineIdx] != "load_routine":
        return out
    let secondCallIdx = secondRoutineIdx + 1 + firstArgCount
    if secondCallIdx + 2 >= opStart + opCount ||
       plan.opKinds[secondCallIdx] != "call" ||
       plan.opArg0s[secondCallIdx] != firstArgCount ||
       plan.opKinds[secondCallIdx + 1] != "return_value" ||
       plan.opKinds[secondCallIdx + 2] != "label" ||
       plan.opPrimaryTexts[secondCallIdx + 2] != endLabel:
        return out
    for i in 0..<firstArgCount:
        let lhsIdx = firstRoutineIdx + 1 + i
        let rhsIdx = secondRoutineIdx + 1 + i
        if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[lhsIdx]) ||
           plan.opKinds[lhsIdx] != plan.opKinds[rhsIdx] ||
           plan.opPrimaryTexts[lhsIdx] != plan.opPrimaryTexts[rhsIdx] ||
           plan.opArg0s[lhsIdx] != plan.opArg0s[rhsIdx]:
            return out
    let firstCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[firstRoutineIdx])
    let secondCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[secondRoutineIdx])
    if firstCalleeIdx < 0 || secondCalleeIdx < 0:
        return out
    let firstSymbol = compilerCoreDirectExecCalleeSymbol(plan, firstCalleeIdx, targetTriple)
    let secondSymbol = compilerCoreDirectExecCalleeSymbol(plan, secondCalleeIdx, targetTriple)
    if len(firstSymbol) <= 0 || len(secondSymbol) <= 0:
        return out
    add(out, firstSymbol)
    add(out, secondSymbol)
    return out

fn compilerCoreDirectExecFallbackCallWords(plan: cflow.LowUirCompilerCorePlan,
                                           itemIdx: int32,
                                           architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount < 11 || plan.opKinds[opStart] != "local_decl":
        return ""
    let firstArgCount = plan.opArg0s[opStart + 4]
    if firstArgCount < 0 || firstArgCount > 4:
        return ""
    var argKinds: str[]
    var argPrimaryTexts: str[]
    var argArg0s: int32[]
    argKinds = []
    argPrimaryTexts = []
    argArg0s = []
    for i in 0..<firstArgCount:
        let argIdx = opStart + 2 + i
        if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[argIdx]):
            return ""
        add(argKinds, plan.opKinds[argIdx])
        add(argPrimaryTexts, plan.opPrimaryTexts[argIdx])
        add(argArg0s, plan.opArg0s[argIdx])
    return machineDirectFallbackCallWords(architecture, argKinds, argPrimaryTexts, argArg0s)

fn compilerCoreDirectExecVoidNestedCallSymbols(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32,
                                               targetTriple: str): str[] =
    var out: str[]
    out = []
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    for innerArgCount in 0..<5:
        let innerOnlyCallIdx = opStart + 2 + innerArgCount
        let outerOnlyCallIdx = innerOnlyCallIdx + 1
        if opCount == innerArgCount + 6 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerOnlyCallIdx] == "call" &&
           plan.opKinds[outerOnlyCallIdx] == "call" &&
           plan.opKinds[outerOnlyCallIdx + 1] == "drop_value" &&
           plan.opKinds[outerOnlyCallIdx + 2] == "return_void" &&
           plan.opArg0s[innerOnlyCallIdx] == innerArgCount &&
           plan.opArg0s[outerOnlyCallIdx] == 1:
            var argsOkNoOuter: bool = true
            for i in 0..<innerArgCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOkNoOuter = false
            if !argsOkNoOuter:
                continue
            let outerOnlyCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerOnlyCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerOnlyCalleeIdx < 0 || innerOnlyCalleeIdx < 0:
                continue
            if plan.paramCounts[outerOnlyCalleeIdx] != 1:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerOnlyCalleeIdx]) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerOnlyCalleeIdx], 0)) != 1:
                continue
            let innerOnlySymbol = compilerCoreDirectExecCalleeSymbol(plan, innerOnlyCalleeIdx, targetTriple)
            let outerOnlySymbol = compilerCoreDirectExecCalleeSymbol(plan, outerOnlyCalleeIdx, targetTriple)
            if len(innerOnlySymbol) <= 0 || len(outerOnlySymbol) <= 0:
                continue
            add(out, innerOnlySymbol)
            add(out, outerOnlySymbol)
            return out
        let innerCallIdx = opStart + 2 + innerArgCount
        let outerArgIdx = innerCallIdx + 1
        let outerCallIdx = innerCallIdx + 2
        if opCount != innerArgCount + 7 ||
           plan.opKinds[opStart] != "load_routine" ||
           plan.opKinds[opStart + 1] != "load_routine" ||
           plan.opKinds[innerCallIdx] != "call" ||
           !compilerCoreIsDirectSimpleValueKind(plan.opKinds[outerArgIdx]) ||
           plan.opKinds[outerCallIdx] != "call" ||
           plan.opKinds[outerCallIdx + 1] != "drop_value" ||
           plan.opKinds[outerCallIdx + 2] != "return_void" ||
           plan.opArg0s[innerCallIdx] != innerArgCount ||
           plan.opArg0s[outerCallIdx] != 2:
            continue
        var argsOk: bool = true
        for i in 0..<innerArgCount:
            if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                argsOk = false
        if !argsOk:
            continue
        let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
        if outerCalleeIdx < 0 || innerCalleeIdx < 0:
            continue
        if plan.paramCounts[outerCalleeIdx] != 2:
            continue
        if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) != 1:
            continue
        if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) != 1:
            continue
        if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1)) != 1:
            continue
        if plan.opKinds[outerArgIdx] == "load_param" &&
           compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArgIdx])) != 1:
            continue
        let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
        let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
        if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
            continue
        add(out, innerSymbol)
        add(out, outerSymbol)
        return out
    return out

fn compilerCoreDirectExecVoidNestedCallWords(plan: cflow.LowUirCompilerCorePlan,
                                             itemIdx: int32,
                                             architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    for innerArgCount in 0..<5:
        let innerOnlyCallIdx = opStart + 2 + innerArgCount
        let outerOnlyCallIdx = innerOnlyCallIdx + 1
        if opCount == innerArgCount + 6 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerOnlyCallIdx] == "call" &&
           plan.opKinds[outerOnlyCallIdx] == "call" &&
           plan.opKinds[outerOnlyCallIdx + 1] == "drop_value" &&
           plan.opKinds[outerOnlyCallIdx + 2] == "return_void" &&
           plan.opArg0s[innerOnlyCallIdx] == innerArgCount &&
           plan.opArg0s[outerOnlyCallIdx] == 1:
            var innerOnlyArgKinds: str[]
            var innerOnlyArgPrimaryTexts: str[]
            var innerOnlyArgArg0s: int32[]
            innerOnlyArgKinds = []
            innerOnlyArgPrimaryTexts = []
            innerOnlyArgArg0s = []
            var argsOkNoOuter: bool = true
            for i in 0..<innerArgCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOkNoOuter = false
                add(innerOnlyArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerOnlyArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerOnlyArgArg0s, plan.opArg0s[opStart + 2 + i])
            if !argsOkNoOuter:
                continue
            return machineDirectNestedCallVoidWords(architecture,
                                                    innerOnlyArgKinds,
                                                    innerOnlyArgPrimaryTexts,
                                                    innerOnlyArgArg0s)
        let innerCallIdx = opStart + 2 + innerArgCount
        let outerArgIdx = innerCallIdx + 1
        let outerCallIdx = innerCallIdx + 2
        if opCount != innerArgCount + 7 ||
           plan.opKinds[opStart] != "load_routine" ||
           plan.opKinds[opStart + 1] != "load_routine" ||
           plan.opKinds[innerCallIdx] != "call" ||
           !compilerCoreIsDirectSimpleValueKind(plan.opKinds[outerArgIdx]) ||
           plan.opKinds[outerCallIdx] != "call" ||
           plan.opKinds[outerCallIdx + 1] != "drop_value" ||
           plan.opKinds[outerCallIdx + 2] != "return_void" ||
           plan.opArg0s[innerCallIdx] != innerArgCount ||
           plan.opArg0s[outerCallIdx] != 2:
            continue
        var innerArgKinds: str[]
        var innerArgPrimaryTexts: str[]
        var innerArgArg0s: int32[]
        innerArgKinds = []
        innerArgPrimaryTexts = []
        innerArgArg0s = []
        var argsOk: bool = true
        for i in 0..<innerArgCount:
            if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                argsOk = false
            add(innerArgKinds, plan.opKinds[opStart + 2 + i])
            add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
            add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
        if !argsOk:
            continue
        return machineDirectNestedCallTrailingSimpleArgVoidWords(architecture,
                                                                 innerArgKinds,
                                                                 innerArgPrimaryTexts,
                                                                 innerArgArg0s,
                                                                 plan.opKinds[outerArgIdx],
                                                                 plan.opPrimaryTexts[outerArgIdx],
                                                                 plan.opArg0s[outerArgIdx])
    return ""

fn compilerCoreDirectExecVoidCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                        itemIdx: int32,
                                        targetTriple: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "drop_value" &&
       plan.opKinds[opStart + 4] == "return_void" &&
       plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0 &&
           compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0), "str"):
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "drop_value" &&
       plan.opKinds[opStart + 3] == "return_void" &&
       plan.opArg0s[opStart + 1] == 0:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "drop_value" &&
       plan.opKinds[opStart + 4] == "return_void" &&
       plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "drop_value" &&
       plan.opKinds[opStart + 5] == "return_void" &&
       plan.opArg0s[opStart + 3] == 2:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 7 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "drop_value" &&
       plan.opKinds[opStart + 6] == "return_void" &&
       plan.opArg0s[opStart + 4] == 3:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 8 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 4]) &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "drop_value" &&
       plan.opKinds[opStart + 7] == "return_void" &&
       plan.opArg0s[opStart + 5] == 4:
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 8 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "drop_value" &&
       plan.opKinds[opStart + 7] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 5] == 1:
        var resolvedKind: str = ""
        var resolvedPrimaryText: str = ""
        var resolvedArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            resolvedKind,
                                            resolvedPrimaryText,
                                            resolvedArg0):
            let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 9 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "drop_value" &&
       plan.opKinds[opStart + 8] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 6] == 2:
        var lhsKind: str = ""
        var lhsPrimaryText: str = ""
        var lhsArg0: int32 = -1
        var rhsKind: str = ""
        var rhsPrimaryText: str = ""
        var rhsArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            lhsKind,
                                            lhsPrimaryText,
                                            lhsArg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            rhsKind,
                                            rhsPrimaryText,
                                            rhsArg0):
            let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 10 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 7] == "call" &&
       plan.opKinds[opStart + 8] == "drop_value" &&
       plan.opKinds[opStart + 9] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 7] == 3:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0):
            let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    if opCount == 11 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 8] == "call" &&
       plan.opKinds[opStart + 9] == "drop_value" &&
       plan.opKinds[opStart + 10] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 8] == 4:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        var arg3Kind: str = ""
        var arg3PrimaryText: str = ""
        var arg3Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 7,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg3Kind,
                                            arg3PrimaryText,
                                            arg3Arg0):
            let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
            if calleeItemIdx >= 0:
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecVoidCallWords(plan: cflow.LowUirCompilerCorePlan,
                                       itemIdx: int32,
                                       architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    let cstringPayload = compilerCoreDirectExecVoidCallCStringPayloadText(plan, itemIdx)
    if len(cstringPayload) > 0:
        return machineDirectCallCStringArgVoidWords(architecture, len(cstringPayload))
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "drop_value" &&
       plan.opKinds[opStart + 3] == "return_void" &&
       plan.opArg0s[opStart + 1] == 0:
        return machineDirectCallVoidWords(architecture)
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "drop_value" &&
       plan.opKinds[opStart + 4] == "return_void" &&
       plan.opArg0s[opStart + 2] == 1:
        return machineDirectCallSimpleArgVoidWords(architecture,
                                                   plan.opKinds[opStart + 1],
                                                   plan.opPrimaryTexts[opStart + 1],
                                                   plan.opArg0s[opStart + 1])
    if opCount == 6 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "drop_value" &&
       plan.opKinds[opStart + 5] == "return_void" &&
       plan.opArg0s[opStart + 3] == 2:
        return machineDirectCallTwoSimpleArgVoidWords(architecture,
                                                      plan.opKinds[opStart + 1],
                                                      plan.opPrimaryTexts[opStart + 1],
                                                      plan.opArg0s[opStart + 1],
                                                      plan.opKinds[opStart + 2],
                                                      plan.opPrimaryTexts[opStart + 2],
                                                      plan.opArg0s[opStart + 2])
    if opCount == 7 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "drop_value" &&
       plan.opKinds[opStart + 6] == "return_void" &&
       plan.opArg0s[opStart + 4] == 3:
        return machineDirectCallThreeSimpleArgVoidWords(architecture,
                                                        plan.opKinds[opStart + 1],
                                                        plan.opPrimaryTexts[opStart + 1],
                                                        plan.opArg0s[opStart + 1],
                                                        plan.opKinds[opStart + 2],
                                                        plan.opPrimaryTexts[opStart + 2],
                                                        plan.opArg0s[opStart + 2],
                                                        plan.opKinds[opStart + 3],
                                                        plan.opPrimaryTexts[opStart + 3],
                                                        plan.opArg0s[opStart + 3])
    if opCount == 8 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 3]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 4]) &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "drop_value" &&
       plan.opKinds[opStart + 7] == "return_void" &&
       plan.opArg0s[opStart + 5] == 4:
        return machineDirectCallFourSimpleArgVoidWords(architecture,
                                                       plan.opKinds[opStart + 1],
                                                       plan.opPrimaryTexts[opStart + 1],
                                                       plan.opArg0s[opStart + 1],
                                                       plan.opKinds[opStart + 2],
                                                       plan.opPrimaryTexts[opStart + 2],
                                                       plan.opArg0s[opStart + 2],
                                                       plan.opKinds[opStart + 3],
                                                       plan.opPrimaryTexts[opStart + 3],
                                                       plan.opArg0s[opStart + 3],
                                                       plan.opKinds[opStart + 4],
                                                       plan.opPrimaryTexts[opStart + 4],
                                                       plan.opArg0s[opStart + 4])
    if opCount == 8 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "drop_value" &&
       plan.opKinds[opStart + 7] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 5] == 1:
        var resolvedKind: str = ""
        var resolvedPrimaryText: str = ""
        var resolvedArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            resolvedKind,
                                            resolvedPrimaryText,
                                            resolvedArg0):
            return machineDirectCallSimpleArgVoidWords(architecture,
                                                       resolvedKind,
                                                       resolvedPrimaryText,
                                                       resolvedArg0)
    if opCount == 9 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "drop_value" &&
       plan.opKinds[opStart + 8] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 6] == 2:
        var lhsKind: str = ""
        var lhsPrimaryText: str = ""
        var lhsArg0: int32 = -1
        var rhsKind: str = ""
        var rhsPrimaryText: str = ""
        var rhsArg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            lhsKind,
                                            lhsPrimaryText,
                                            lhsArg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            rhsKind,
                                            rhsPrimaryText,
                                            rhsArg0):
            return machineDirectCallTwoSimpleArgVoidWords(architecture,
                                                          lhsKind,
                                                          lhsPrimaryText,
                                                          lhsArg0,
                                                          rhsKind,
                                                          rhsPrimaryText,
                                                          rhsArg0)
    if opCount == 10 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 7] == "call" &&
       plan.opKinds[opStart + 8] == "drop_value" &&
       plan.opKinds[opStart + 9] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 7] == 3:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0):
            return machineDirectCallThreeSimpleArgVoidWords(architecture,
                                                            arg0Kind,
                                                            arg0PrimaryText,
                                                            arg0Arg0,
                                                            arg1Kind,
                                                            arg1PrimaryText,
                                                            arg1Arg0,
                                                            arg2Kind,
                                                            arg2PrimaryText,
                                                            arg2Arg0)
    if opCount == 11 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 8] == "call" &&
       plan.opKinds[opStart + 9] == "drop_value" &&
       plan.opKinds[opStart + 10] == "return_void" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 8] == 4:
        var arg0Kind: str = ""
        var arg0PrimaryText: str = ""
        var arg0Arg0: int32 = -1
        var arg1Kind: str = ""
        var arg1PrimaryText: str = ""
        var arg1Arg0: int32 = -1
        var arg2Kind: str = ""
        var arg2PrimaryText: str = ""
        var arg2Arg0: int32 = -1
        var arg3Kind: str = ""
        var arg3PrimaryText: str = ""
        var arg3Arg0: int32 = -1
        if compilerCoreResolveDirectCallArg(plan,
                                            opStart + 4,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg0Kind,
                                            arg0PrimaryText,
                                            arg0Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 5,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg1Kind,
                                            arg1PrimaryText,
                                            arg1Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 6,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg2Kind,
                                            arg2PrimaryText,
                                            arg2Arg0) &&
           compilerCoreResolveDirectCallArg(plan,
                                            opStart + 7,
                                            plan.opArg0s[opStart],
                                            plan.opKinds[opStart + 1],
                                            plan.opPrimaryTexts[opStart + 1],
                                            plan.opArg0s[opStart + 1],
                                            arg3Kind,
                                            arg3PrimaryText,
                                            arg3Arg0):
            return machineDirectCallFourSimpleArgVoidWords(architecture,
                                                           arg0Kind,
                                                           arg0PrimaryText,
                                                           arg0Arg0,
                                                           arg1Kind,
                                                           arg1PrimaryText,
                                                           arg1Arg0,
                                                           arg2Kind,
                                                           arg2PrimaryText,
                                                           arg2Arg0,
                                                           arg3Kind,
                                                           arg3PrimaryText,
                                                           arg3Arg0)
    return ""

fn appendMachineFunction(out: var MachineModuleBundle,
                         itemId: int32,
                         opName: str,
                         runtimeTarget: str,
                         bindingSummary: str,
                         logicalFrameSize: int32) =
    let symbolName = machineFunctionSymbolName(out.targetTriple, out.moduleKind, opName, itemId)
    let callSymbol = machineCallSymbolName(out.targetTriple, runtimeTarget)
    let words = machineStubWords(out.architecture)
    let functionRelocStart = out.relocOffsets.len
    add(out.itemIds, itemId)
    add(out.symbolNames, symbolName)
    add(out.runtimeTargets, runtimeTarget)
    add(out.callSymbolNames, callSymbol)
    add(out.frameSizes, alignedSize(logicalFrameSize, out.stackAlignBytes))
    add(out.stackAligns, out.stackAlignBytes)
    add(out.argRegs, machineArgRegs(out.architecture))
    add(out.scratchRegs, machineScratchRegs(out.architecture))
    add(out.calleeSavedRegs, machineCalleeSavedRegs(out.architecture))
    add(out.bindingSummaries, bindingSummary)
    add(out.instructionWordHex, words)
    add(out.functionByteSizes, wordCount(words) * 4)
    add(out.localPayloadPageRelocOffsets, 8)
    add(out.localPayloadPageoffRelocOffsets, 12)
    add(out.callRelocOffsets, 16)
    add(out.metadataOperandModes, "local_payload")
    let payloadText = "runtime=" + runtimeTarget + "|bindings=" + bindingSummary
    add(out.localPayloadTexts, payloadText)
    let metadataSymbol = symbolName + "_meta"
    appendMachineRelocation(out,
                            8,
                            metadataSymbol,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            12,
                            metadataSymbol,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            16,
                            callSymbol,
                            out.callRelocationKind)
    add(out.functionRelocStarts, functionRelocStart)
    add(out.functionRelocCounts, out.relocOffsets.len - functionRelocStart)

fn appendMachineDispatchEntryFunction(out: var MachineModuleBundle,
                                      itemId: int32,
                                      opName: str,
                                      runtimeTarget: str,
                                      bindingSummary: str,
                                      logicalFrameSize: int32) =
    let symbolName = machineFunctionSymbolName(out.targetTriple, out.moduleKind, opName, itemId)
    let callSymbol = machineCallSymbolName(out.targetTriple, runtimeTarget)
    let words = machineDispatchEntryWords(out.architecture)
    let functionRelocStart = out.relocOffsets.len
    add(out.itemIds, itemId)
    add(out.symbolNames, symbolName)
    add(out.runtimeTargets, runtimeTarget)
    add(out.callSymbolNames, callSymbol)
    add(out.frameSizes, alignedSize(logicalFrameSize, out.stackAlignBytes))
    add(out.stackAligns, out.stackAlignBytes)
    add(out.argRegs, machineArgRegs(out.architecture))
    add(out.scratchRegs, machineScratchRegs(out.architecture))
    add(out.calleeSavedRegs, machineCalleeSavedRegs(out.architecture))
    add(out.bindingSummaries, bindingSummary)
    add(out.instructionWordHex, words)
    add(out.functionByteSizes, wordCount(words) * 4)
    add(out.localPayloadPageRelocOffsets, 0)
    add(out.localPayloadPageoffRelocOffsets, 0)
    add(out.callRelocOffsets, 8)
    add(out.metadataOperandModes, "argv_passthrough")
    add(out.localPayloadTexts, "")
    appendMachineRelocation(out,
                            8,
                            callSymbol,
                            out.callRelocationKind)
    add(out.functionRelocStarts, functionRelocStart)
    add(out.functionRelocCounts, out.relocOffsets.len - functionRelocStart)

fn appendCompilerCoreArgvBridgeFunction(out: var MachineModuleBundle,
                                        bridgeItemId: int32,
                                        bindingSummary: str) =
    appendMachineDispatchEntryFunction(out,
                                       bridgeItemId,
                                       "compiler_program_entry",
                                       "runtime/compiler_core.argv_entry",
                                       bindingSummary,
                                       16)
    out.entrySymbolOverride = out.symbolNames[out.symbolNames.len - 1]

fn appendMachineTraceProviderFunction(out: var MachineModuleBundle,
                                      itemId: int32,
                                      symbolName: str,
                                      runtimeTarget: str,
                                      bindingSummary: str,
                                      logicalFrameSize: int32) =
    let words = machineTraceProviderWords(out.architecture)
    let functionRelocStart = out.relocOffsets.len
    add(out.itemIds, itemId)
    add(out.symbolNames, symbolName)
    add(out.runtimeTargets, runtimeTarget)
    add(out.callSymbolNames, machineLibcSymbolName(out.targetTriple, "puts"))
    add(out.frameSizes, alignedSize(logicalFrameSize, out.stackAlignBytes))
    add(out.stackAligns, out.stackAlignBytes)
    add(out.argRegs, machineArgRegs(out.architecture))
    add(out.scratchRegs, machineScratchRegs(out.architecture))
    add(out.calleeSavedRegs, machineCalleeSavedRegs(out.architecture))
    add(out.bindingSummaries, bindingSummary)
    add(out.instructionWordHex, words)
    add(out.functionByteSizes, wordCount(words) * 4)
    add(out.localPayloadPageRelocOffsets, 0)
    add(out.localPayloadPageoffRelocOffsets, 0)
    add(out.callRelocOffsets, 8)
    add(out.metadataOperandModes, "arg0_cstring")
    add(out.localPayloadTexts, "")
    appendMachineRelocation(out,
                            8,
                            machineLibcSymbolName(out.targetTriple, "puts"),
                            out.callRelocationKind)
    add(out.functionRelocStarts, functionRelocStart)
    add(out.functionRelocCounts, out.relocOffsets.len - functionRelocStart)

fn buildRuntimeProviderMachineModule(providerModulePath: str,
                                     providerManifestCid: str,
                                     runtimeTargets: str[],
                                     targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle = newMachineModuleBundle("runtime_provider", targetTriple)
    for i in 0..<runtimeTargets.len:
        let symbolName = machineCallSymbolName(targetTriple, runtimeTargets[i])
        let bindingSummary = "provider_module=" + providerModulePath +
                             "|manifest_cid=" + providerManifestCid +
                             "|runtime_target=" + runtimeTargets[i]
        appendMachineTraceProviderFunction(out,
                                           i,
                                           symbolName,
                                           runtimeTargets[i],
                                           bindingSummary,
                                           16)
    return out

fn buildCompilerCoreArgvEntryProviderMachineModule(sourcePath: str,
                                                   providerManifestCid: str,
                                                   runtimeTargets: str[],
                                                   targetTriple: str): MachineModuleBundle =
    if runtimeTargets.len <= 0:
        panic("v2 machine pipeline: compiler_core runtime targets missing")
    let runtimeTarget = runtimeTargets[0]
    let localPayloadTarget = runtimeTargets.len > 1 ?
        runtimeTargets[1] :
        compilerCoreLocalPayloadRuntimeTarget()
    let compiled = cpipe.compileCompilerCoreSourceClosure(sourcePath)
    let full = lowerCompilerCorePlanToMachine(compiled.lowPlan, targetTriple)
    var entryIdx: int32 = -1
    for i in 0..<compiled.lowPlan.labels.len:
        if compiled.lowPlan.labels[i] == "compilerCoreArgvEntry":
            entryIdx = i
            break
    if entryIdx < 0:
        panic("v2 machine pipeline: compiler_core runtime argv entry missing")
    var out: MachineModuleBundle = newMachineModuleBundle("runtime_provider", targetTriple)
    let entryCallSymbol = full.symbolNames[entryIdx]
    let bindingSummary = "provider_module=runtime/compiler_core_runtime_v2" +
                         "|manifest_cid=" + providerManifestCid +
                         "|runtime_target=" + runtimeTarget +
                         "|entry_label=compilerCoreArgvEntry"
    appendMachineFunction(out,
                          compiled.lowPlan.itemIds[entryIdx],
                          "runtime_provider_export",
                          runtimeTarget,
                          bindingSummary,
                          full.frameSizes[entryIdx])
    rewriteMachineFunctionSymbol(out,
                                 0,
                                 machineCallSymbolName(targetTriple, runtimeTarget))
    let bridgeWords = "a9bf7bfd;910003fd;94000000;94000000;a8c17bfd;d65f03c0"
    rewriteMachineFunctionDirectExecCalls(out,
                                          0,
                                          bridgeWords,
                                          [machineLibcSymbolName(targetTriple, "__cheng_setCmdLine"),
                                           entryCallSymbol])
    let localPayloadBindingSummary = "provider_module=runtime/compiler_core_runtime_v2" +
                                     "|manifest_cid=" + providerManifestCid +
                                     "|runtime_target=" + localPayloadTarget +
                                     "|entry_label=driver_c_compiler_core_local_payload_bridge"
    appendMachineDispatchEntryFunction(out,
                                       1001000000 + compiled.lowPlan.itemIds[entryIdx],
                                       "runtime_provider_local_payload_export",
                                       localPayloadTarget,
                                       localPayloadBindingSummary,
                                       16)
    rewriteMachineFunctionSymbol(out,
                                 1,
                                 machineCallSymbolName(targetTriple, localPayloadTarget))
    rewriteMachineFunctionDirectExecCall(out,
                                         1,
                                         machineDispatchEntryWords(out.architecture),
                                         machineLibcSymbolName(targetTriple,
                                                               "driver_c_compiler_core_local_payload_bridge"))
    return out

fn lowerStringPlanToMachine(plan: slow.LowUirStringPlan, targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle = newMachineModuleBundle("string", targetTriple)
    for i in 0..<plan.exprIds.len:
        var frameSize: int32 = 16
        if plan.allocationModes[i] == "builder_state" || plan.effectClasses[i] == "stateful_local":
            frameSize = frameSize + 16
        if !plan.zeroCopyFacts[i]:
            frameSize = frameSize + 16
        let bindingSummary = "result=" + plan.resultKinds[i] +
                             "|alloc=" + plan.allocationModes[i] +
                             "|effect=" + plan.effectClasses[i] +
                             "|zero_copy=" + if plan.zeroCopyFacts[i]: "1" else: "0"
        appendMachineFunction(out,
                              plan.exprIds[i],
                              plan.canonicalOps[i],
                              plan.runtimeTargets[i],
                              bindingSummary,
                              frameSize)
    return out

fn lowerCompilerCorePlanToMachine(plan: cflow.LowUirCompilerCorePlan,
                                  targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle = newMachineModuleBundle("compiler_core", targetTriple)
    var moduleCount: int32 = 0
    var importCount: int32 = 0
    var typeCount: int32 = 0
    var constCount: int32 = 0
    var varCount: int32 = 0
    var importcRoutineCount: int32 = 0
    var routineCount: int32 = 0
    var iteratorCount: int32 = 0
    var entryIndex: int32 = -1
    for i in 0..<plan.itemIds.len:
        if entryIndex < 0 && plan.labels[i] == "main":
            entryIndex = i
        var frameSize: int32 = 16
        if plan.effectClasses[i] != "module_resolution":
            frameSize = frameSize + 16
        if plan.bodyLineCounts[i] > 0:
            frameSize = frameSize + 16
        if plan.bindingScopes[i] == "type_scope" || plan.bindingScopes[i] == "iterator_scope":
            frameSize = frameSize + 16
        if plan.executableAstReady[i]:
            frameSize = frameSize + (plan.localCounts[i] * 8)
        let bindingSummary = "top_level=" + plan.topLevelKinds[i] +
                             "|label=" + plan.labels[i] +
                             "|proof=" + plan.proofDomains[i] +
                             "|effect=" + plan.effectClasses[i] +
                             "|scope=" + plan.bindingScopes[i] +
                             "|import_path=" + plan.importPaths[i] +
                             "|import_alias=" + plan.importAliases[i] +
                             "|import_category=" + plan.importCategories[i] +
                             "|ast_ready=" + if plan.executableAstReady[i]: "1" else: "0" +
                             "|return_type=" + plan.returnTypeTexts[i] +
                             "|param_count=" + intToStr(plan.paramCounts[i]) +
                             "|local_count=" + intToStr(plan.localCounts[i]) +
                             "|stmt_count=" + intToStr(plan.stmtCounts[i]) +
                             "|expr_count=" + intToStr(plan.exprCounts[i]) +
                             "|body_lines=" + intToStr(plan.bodyLineCounts[i]) +
                             "|signature_hash=" + plan.signatureHashes[i] +
                             "|body_hash=" + plan.bodyHashes[i]
        let runtimeTarget = compilerCoreMachineRuntimeTarget(plan.runtimeTargets[i])
        appendMachineFunction(out,
                              plan.itemIds[i],
                              plan.canonicalOps[i],
                              runtimeTarget,
                              bindingSummary,
                              frameSize)
        if plan.executableAstReady[i] && plan.routineOpCounts[i] > 0:
            let payloadText = "runtime=" + runtimeTarget +
                              "|bindings=" + bindingSummary + "\n" +
                              compilerCoreRoutineExecPlanText(plan, i)
            rewriteMachineFunctionPayload(out,
                                          out.itemIds.len - 1,
                                          "exec_plan_payload",
                                          payloadText)
            let directCStringPayload = compilerCoreDirectExecCStringPayloadText(plan, i)
            if len(directCStringPayload) > 0:
                let directCStringWords = machineDirectReturnCStringLiteralWords(out.architecture,
                                                                                len(directCStringPayload))
                if len(directCStringWords) > 0:
                    rewriteMachineFunctionDirectExecCStringData(out,
                                                                out.itemIds.len - 1,
                                                                directCStringWords,
                                                                directCStringPayload)
                    continue
            let directWords = compilerCoreDirectExecWords(plan, i, out.architecture)
            if len(directWords) > 0:
                rewriteMachineFunctionDirectExec(out,
                                                 out.itemIds.len - 1,
                                                 directWords)
            else:
                let directIfElseCallSymbols = compilerCoreDirectExecIfElseCallSymbols(plan, i, out.targetTriple)
                if directIfElseCallSymbols.len > 0:
                    let directIfElseCallWords = compilerCoreDirectExecIfElseCallWords(plan, i, out.architecture)
                    if len(directIfElseCallWords) > 0:
                        rewriteMachineFunctionDirectExecCalls(out,
                                                              out.itemIds.len - 1,
                                                              directIfElseCallWords,
                                                              directIfElseCallSymbols)
                else:
                    let directFallbackSymbols = compilerCoreDirectExecFallbackCallSymbols(plan,
                                                                                          i,
                                                                                          out.targetTriple)
                    if directFallbackSymbols.len > 0:
                        let directFallbackWords = compilerCoreDirectExecFallbackCallWords(plan,
                                                                                          i,
                                                                                          out.architecture)
                        if len(directFallbackWords) > 0:
                            rewriteMachineFunctionDirectExecCalls(out,
                                                                  out.itemIds.len - 1,
                                                                  directFallbackWords,
                                                                  directFallbackSymbols)
                    else:
                        let directNestedSymbols = compilerCoreDirectExecNestedCallSymbols(plan, i, out.targetTriple)
                        if directNestedSymbols.len > 0:
                            let directNestedWords = compilerCoreDirectExecNestedCallWords(plan, i, out.architecture)
                            if len(directNestedWords) > 0:
                                let directNestedCStringPayload = compilerCoreDirectExecNestedCallCStringPayloadText(plan, i)
                                if len(directNestedCStringPayload) > 0:
                                    rewriteMachineFunctionDirectExecCallsCStringData(out,
                                                                                     out.itemIds.len - 1,
                                                                                     directNestedWords,
                                                                                     directNestedSymbols,
                                                                                     directNestedCStringPayload)
                                else:
                                    rewriteMachineFunctionDirectExecCalls(out,
                                                                          out.itemIds.len - 1,
                                                                          directNestedWords,
                                                                          directNestedSymbols)
                        else:
                            let directNestedVoidSymbols = compilerCoreDirectExecVoidNestedCallSymbols(plan,
                                                                                                      i,
                                                                                                      out.targetTriple)
                            if directNestedVoidSymbols.len > 0:
                                let directNestedVoidWords = compilerCoreDirectExecVoidNestedCallWords(plan,
                                                                                                      i,
                                                                                                      out.architecture)
                                if len(directNestedVoidWords) > 0:
                                    rewriteMachineFunctionDirectExecCalls(out,
                                                                          out.itemIds.len - 1,
                                                                          directNestedVoidWords,
                                                                          directNestedVoidSymbols)
                            else:
                                let directCallSymbol = compilerCoreDirectExecCallSymbol(plan, i, out.targetTriple)
                                if len(directCallSymbol) > 0:
                                    let directCallWords = compilerCoreDirectExecCallWords(plan, i, out.architecture)
                                    let directCallCStringPayload = compilerCoreDirectExecCallCStringPayloadText(plan, i)
                                    if len(directCallCStringPayload) > 0:
                                        rewriteMachineFunctionDirectExecCallCStringData(out,
                                                                                        out.itemIds.len - 1,
                                                                                        directCallWords,
                                                                                        directCallSymbol,
                                                                                        directCallCStringPayload)
                                    else:
                                        rewriteMachineFunctionDirectExecCall(out,
                                                                             out.itemIds.len - 1,
                                                                             directCallWords,
                                                                             directCallSymbol)
                                else:
                                    let directVoidThenConstCallSymbol =
                                        compilerCoreDirectExecVoidThenConstCallSymbol(plan, i, out.targetTriple)
                                    if len(directVoidThenConstCallSymbol) > 0:
                                        let directVoidThenConstCallWords =
                                            compilerCoreDirectExecVoidThenConstCallWords(plan,
                                                                                         i,
                                                                                         out.architecture)
                                        rewriteMachineFunctionDirectExecCall(out,
                                                                             out.itemIds.len - 1,
                                                                             directVoidThenConstCallWords,
                                                                             directVoidThenConstCallSymbol)
                                    else:
                                        let directVoidCallSymbol = compilerCoreDirectExecVoidCallSymbol(plan, i, out.targetTriple)
                                        if len(directVoidCallSymbol) > 0:
                                            let directVoidCallWords = compilerCoreDirectExecVoidCallWords(plan, i, out.architecture)
                                            let directVoidCallCStringPayload = compilerCoreDirectExecVoidCallCStringPayloadText(plan, i)
                                            if len(directVoidCallCStringPayload) > 0:
                                            rewriteMachineFunctionDirectExecCallCStringData(out,
                                                                                            out.itemIds.len - 1,
                                                                                            directVoidCallWords,
                                                                                            directVoidCallSymbol,
                                                                                            directVoidCallCStringPayload)
                                            else:
                                                rewriteMachineFunctionDirectExecCall(out,
                                                                                     out.itemIds.len - 1,
                                                                                     directVoidCallWords,
                                                                                     directVoidCallSymbol)
        if plan.topLevelKinds[i] == "module":
            moduleCount = moduleCount + 1
        elif plan.topLevelKinds[i] == "import":
            importCount = importCount + 1
        elif plan.topLevelKinds[i] == "type":
            typeCount = typeCount + 1
        elif plan.topLevelKinds[i] == "const":
            constCount = constCount + 1
        elif plan.topLevelKinds[i] == "var":
            varCount = varCount + 1
        elif plan.topLevelKinds[i] == "importc_fn":
            importcRoutineCount = importcRoutineCount + 1
        elif plan.topLevelKinds[i] == "iterator":
            iteratorCount = iteratorCount + 1
        else:
            routineCount = routineCount + 1
    if entryIndex < 0 && plan.itemIds.len > 0:
        entryIndex = 0
    if entryIndex >= 0:
        let entryItemId = plan.itemIds[entryIndex]
        let dispatchTarget = "runtime/compiler_core.argv_entry"
        let entryAstReady = if plan.executableAstReady[entryIndex]: "1" else: "0"
        let bindingSummary = "entry_bridge=1" +
                             "|dispatch=" + dispatchTarget +
                             "|entry_label=" + plan.labels[entryIndex] +
                             "|entry_kind=" + plan.topLevelKinds[entryIndex] +
                             "|entry_op=" + plan.canonicalOps[entryIndex] +
                             "|entry_ast_ready=" + entryAstReady +
                             "|entry_return_type=" + plan.returnTypeTexts[entryIndex] +
                             "|entry_param_count=" + intToStr(plan.paramCounts[entryIndex]) +
                             "|entry_local_count=" + intToStr(plan.localCounts[entryIndex]) +
                             "|entry_stmt_count=" + intToStr(plan.stmtCounts[entryIndex]) +
                             "|entry_expr_count=" + intToStr(plan.exprCounts[entryIndex]) +
                             "|entry_exec_op_count=" + intToStr(plan.routineOpCounts[entryIndex]) +
                             "|entry_exec_op_hash=" + plan.routineOpHashes[entryIndex] +
                             "|top_levels=" + intToStr(plan.itemIds.len) +
                             "|modules=" + intToStr(moduleCount) +
                             "|imports=" + intToStr(importCount) +
                             "|types=" + intToStr(typeCount) +
                             "|consts=" + intToStr(constCount) +
                             "|vars=" + intToStr(varCount) +
                             "|importc_routines=" + intToStr(importcRoutineCount) +
                             "|routines=" + intToStr(routineCount) +
                             "|iterators=" + intToStr(iteratorCount)
        appendCompilerCoreArgvBridgeFunction(out,
                                             1000000000 + entryItemId,
                                             bindingSummary)
    return out

fn lowerUnimakerPlanToMachine(plan: uflow.LowUirUnimakerPlan, targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle = newMachineModuleBundle("unimaker", targetTriple)
    for i in 0..<plan.declIds.len:
        var frameSize: int32 = 16
        if plan.effectClasses[i] != "pure_contract":
            frameSize = frameSize + 16
        if len(plan.networkDomains[i]) > 0:
            frameSize = frameSize + 16
        if plan.antiEntropySignatureKinds[i] != "none":
            frameSize = frameSize + 16
        let bindingSummary = "proof=" + plan.proofDomains[i] +
                             "|effect=" + plan.effectClasses[i] +
                             "|network_mode=" + plan.networkModes[i] +
                             "|capability=" + plan.capabilityKinds[i] +
                             "|domain=" + plan.networkDomains[i] +
                             "|topology_ref=" + plan.topologyRefs[i] +
                             "|transport=" + plan.transportModes[i] +
                             "|repair=" + plan.repairModes[i] +
                             "|dispersal=" + plan.dispersalModes[i] +
                             "|priority=" + plan.priorityClasses[i] +
                             "|identity=" + plan.identityScopes[i] +
                             "|signature=" + plan.antiEntropySignatureKinds[i]
        appendMachineFunction(out,
                              plan.declIds[i],
                              plan.canonicalOps[i],
                              plan.runtimeTargets[i],
                              bindingSummary,
                              frameSize)
    return out

fn lowerNetworkDistributionPlanToMachine(plan: nflow.LowUirNetworkDistributionPlan,
                                         targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle = newMachineModuleBundle("network_distribution", targetTriple)
    for i in 0..<plan.opIds.len:
        var frameSize: int32 = 16
        if plan.transportModes[i] == "coded_bulk_dispersal":
            frameSize = frameSize + 16
        if plan.priorityClasses[i] == "background":
            frameSize = frameSize + 16
        if plan.antiEntropySignatureKinds[i] != "none":
            frameSize = frameSize + 16
        let bindingSummary = "proof=" + plan.proofDomains[i] +
                             "|identity=" + plan.identityScopes[i] +
                             "|addressing=" + plan.addressingModes[i] +
                             "|depth=" + intToStr(plan.topologyDepths[i]) +
                             "|address_binding=" + plan.addressBindings[i] +
                             "|distance_metric=" + plan.distanceMetrics[i] +
                             "|route_plan_model=" + plan.routePlanModels[i] +
                             "|transport=" + plan.transportModes[i] +
                             "|repair=" + plan.repairModes[i] +
                             "|dispersal=" + plan.dispersalModes[i] +
                             "|priority=" + plan.priorityClasses[i] +
                             "|signature=" + plan.antiEntropySignatureKinds[i] +
                             "|topology=" + plan.topologyCanonicalForms[i]
        appendMachineFunction(out,
                              plan.opIds[i],
                              plan.canonicalOps[i],
                              plan.runtimeTargets[i],
                              bindingSummary,
                              frameSize)
    return out

fn sampleStringMachineModule(targetTriple: str): MachineModuleBundle =
    return lowerStringPlanToMachine(spipe.sampleStringPipeline().lowPlan, targetTriple)

fn sampleUnimakerMachineModule(targetTriple: str): MachineModuleBundle =
    return lowerUnimakerPlanToMachine(upipe.sampleUnimakerPipeline().lowPlan, targetTriple)

fn sampleCompilerCoreMachineModule(targetTriple: str): MachineModuleBundle =
    let parsed = parser.parseV2SourceFileStrict("v2/src/runtime/strings_v2.cheng")
    let bundle = cpipe.compileCompilerCoreProgram(parsed.compilerCoreProgram)
    return lowerCompilerCorePlanToMachine(bundle.lowPlan, targetTriple)

fn sampleNetworkDistributionMachineModule(targetTriple: str): MachineModuleBundle =
    return lowerNetworkDistributionPlanToMachine(npipe.sampleNetworkDistributionPipeline().lowPlan,
                                                 targetTriple)

fn machineModuleLines(bundle: MachineModuleBundle): str[] =
    var out: str[]
    out = []
    add(out, "machine_pipeline_version=" + bundle.version)
    add(out, "module_kind=" + bundle.moduleKind)
    add(out, "target=" + bundle.targetTriple)
    add(out, "architecture=" + bundle.architecture)
    add(out, "obj_format=" + bundle.objFormat)
    add(out, "text_section=" + bundle.textSectionName)
    add(out, "call_relocation=" + bundle.callRelocationKind)
    add(out, "metadata_page_relocation=" + bundle.metadataPageRelocationKind)
    add(out, "metadata_pageoff_relocation=" + bundle.metadataPageoffRelocationKind)
    add(out, "entry_symbol_override=" + bundle.entrySymbolOverride)
    add(out, "function_count=" + intToStr(bundle.itemIds.len))
    for i in 0..<bundle.itemIds.len:
        add(out, "function." + intToStr(i) + ".symbol=" + bundle.symbolNames[i])
        add(out, "function." + intToStr(i) + ".runtime=" + bundle.runtimeTargets[i])
        add(out, "function." + intToStr(i) + ".call_symbol=" + bundle.callSymbolNames[i])
        add(out, "function." + intToStr(i) + ".frame_size=" + intToStr(bundle.frameSizes[i]))
        add(out, "function." + intToStr(i) + ".bindings=" + bundle.bindingSummaries[i])
        add(out, "function." + intToStr(i) + ".metadata_mode=" + bundle.metadataOperandModes[i])
        add(out, "function." + intToStr(i) + ".payload=" + bundle.localPayloadTexts[i])
        add(out, "function." + intToStr(i) + ".words=" + bundle.instructionWordHex[i])
    return out

fn machineModuleText(bundle: MachineModuleBundle): str =
    return joinWithSep(machineModuleLines(bundle), "\n")

fn machineModuleCid(bundle: MachineModuleBundle): str =
    return ident.sha256HexText(machineModuleText(bundle))
