fn machineDirectReturnRegisterWords(architecture: str,
                                    sourceReg: int32,
                                    is64: bool): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if sourceReg < 0 || sourceReg > 7:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    if sourceReg != 0:
        add(words, machineAarch64MovRegWord(is64, 0, sourceReg))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectReturnRegisterPairWords(architecture: str,
                                        sourceReg0: int32,
                                        sourceReg1: int32,
                                        sourceReg1Is64: bool): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if sourceReg0 < 0 || sourceReg0 > 7 || sourceReg1 < 0 || sourceReg1 > 7:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    var loadReg1: int32 = sourceReg1
    if sourceReg1 == 0 && sourceReg0 != 0:
        add(words, machineAarch64MovRegWord(true, 9, 0))
        loadReg1 = 9
    if sourceReg0 != 0:
        add(words, machineAarch64MovRegWord(true, 0, sourceReg0))
    if loadReg1 != 1:
        add(words, machineAarch64MovRegWord(sourceReg1Is64, 1, loadReg1))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectReturnRegisterPairPlusZeroI32Words(architecture: str,
                                                   sourceReg0: int32,
                                                   sourceReg1: int32,
                                                   sourceReg1Is64: bool,
                                                   zeroReg: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if zeroReg < 0 || zeroReg > 7:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    var loadReg1: int32 = sourceReg1
    if sourceReg1 == 0 && sourceReg0 != 0:
        add(words, machineAarch64MovRegWord(true, 9, 0))
        loadReg1 = 9
    if sourceReg0 != 0:
        add(words, machineAarch64MovRegWord(true, 0, sourceReg0))
    if loadReg1 != 1:
        add(words, machineAarch64MovRegWord(sourceReg1Is64, 1, loadReg1))
    add(words, machineAarch64MovInt32Word(zeroReg, 0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectReturnEmptyBytesWords(architecture: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64MovZeroWord(0))
    add(words, machineAarch64MovInt32Word(1, 0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectZeroVarStrOutWords(architecture: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64StoreBaseWord(true, 31, 0, 0))
    add(words, machineAarch64StoreBaseWord(false, 31, 0, 8))
    add(words, machineAarch64StoreBaseWord(false, 31, 0, 12))
    add(words, machineAarch64StoreBaseWord(false, 31, 0, 16))
    add(words, machineAarch64MovInt32Word(0, 0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCopyVarStrOutWords(architecture: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64StoreBaseWord(true, 1, 0, 0))
    add(words, machineAarch64StoreBaseWord(false, 2, 0, 8))
    add(words, machineAarch64StoreBaseWord(false, 3, 0, 12))
    add(words, machineAarch64StoreBaseWord(false, 4, 0, 16))
    add(words, machineAarch64MovInt32Word(0, 0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectStoreVarStrPairWords(architecture: str,
                                     outPtrReg: int32,
                                     sourceReg0: int32,
                                     sourceReg1: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if outPtrReg < 0 || sourceReg0 < 0 || sourceReg1 < 0:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64StoreBaseWord(true, sourceReg0, outPtrReg, 0))
    add(words, machineAarch64StoreBaseWord(false, sourceReg1, outPtrReg, 8))
    add(words, machineAarch64MovZeroWord(9))
    add(words, machineAarch64StoreBaseWord(false, 9, outPtrReg, 12))
    add(words, machineAarch64StoreBaseWord(false, 9, outPtrReg, 16))
    add(words, machineAarch64MovInt32Word(0, 0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectStoreVarFieldSimpleValueWords(architecture: str,
                                              offsetBytes: int32,
                                              is64: bool,
                                              opKind: str,
                                              opPrimaryText: str,
                                              opArg0: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleValueWords(architecture, words, 9, opKind, opPrimaryText, opArg0):
        return ""
    add(words, machineAarch64StoreBaseWord(is64, 9, 0, offsetBytes))
    add(words, machineAarch64MovInt32Word(0, 0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectStoreParamScalarBinaryWords(architecture: str,
                                            signatureText: str,
                                            lhsParamIdx: int32,
                                            rhsKind: str,
                                            rhsPrimaryText: str,
                                            rhsArg0: int32,
                                            operatorText: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if operatorText != "+" && operatorText != "-":
        return ""
    var lhsIs64: bool = false
    if !compilerCoreDirectVarScalarStoreParamBinding(signatureText, lhsParamIdx, lhsIs64):
        return ""
    let lhsBaseReg = compilerCoreDirectAbiParamBaseReg(signatureText, lhsParamIdx)
    if lhsBaseReg < 0 || lhsBaseReg > 7:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64LoadBaseWord(lhsIs64, 9, lhsBaseReg, 0))
    if rhsKind == "load_param":
        let rhsTypeText = compilerCoreSignatureParamTypeText(signatureText, rhsArg0)
        if len(rhsTypeText) > 4 &&
           rhsTypeText[0] == 'v' &&
           rhsTypeText[1] == 'a' &&
           rhsTypeText[2] == 'r' &&
           rhsTypeText[3] == ' ':
            return ""
        if compilerCoreDirectTypeRegWidth(rhsTypeText) != 1 ||
           !compilerCoreDirectArithmeticScalarTypeSupported(rhsTypeText) ||
           compilerCoreDirectParamIs64(rhsTypeText) != lhsIs64:
            return ""
        let rhsBaseReg = compilerCoreDirectAbiParamBaseReg(signatureText, rhsArg0)
        if rhsBaseReg < 0 || rhsBaseReg > 7:
            return ""
        if rhsBaseReg != 10:
            add(words, machineAarch64MovRegWord(lhsIs64, 10, rhsBaseReg))
    elif rhsKind == "load_int32":
        if !machineAppendLoadSimpleValueWords(architecture, words, 10, rhsKind, rhsPrimaryText, rhsArg0):
            return ""
    else:
        return ""
    if operatorText == "+":
        add(words, machineAarch64AddRegWord(lhsIs64, 9, 9, 10))
    else:
        add(words, machineAarch64SubRegWord(lhsIs64, 9, 9, 10))
    add(words, machineAarch64StoreBaseWord(lhsIs64, 9, lhsBaseReg, 0))
    add(words, machineAarch64MovInt32Word(0, 0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectStoreVarFieldAndVarStrWords(architecture: str,
                                            outPtrReg: int32,
                                            scalarOffsetBytes: int32,
                                            scalarStoreIs64: bool,
                                            scalarSourceIsReg: bool,
                                            scalarSourceReg: int32,
                                            scalarSourceRegIs64: bool,
                                            scalarConstKind: str,
                                            scalarConstPrimaryText: str,
                                            scalarConstArg0: int32,
                                            strOffsetBytes: int32,
                                            strSourceIsZero: bool,
                                            strSourceReg0: int32,
                                            strSourceReg1: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if outPtrReg < 0 || outPtrReg > 7:
        return ""
    if scalarSourceIsReg:
        if scalarSourceReg < 0 || scalarSourceReg > 7:
            return ""
        if scalarStoreIs64 != scalarSourceRegIs64:
            return ""
    elif !machineIsDirectSimpleValueSupported(architecture, scalarConstKind):
        return ""
    if !strSourceIsZero && (strSourceReg0 < 0 || strSourceReg0 > 7 || strSourceReg1 < 0 || strSourceReg1 > 7):
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    if scalarSourceIsReg:
        if scalarSourceReg != 9:
            add(words, machineAarch64MovRegWord(scalarSourceRegIs64, 9, scalarSourceReg))
    else:
        if !machineAppendLoadSimpleValueWords(architecture,
                                              words,
                                              9,
                                              scalarConstKind,
                                              scalarConstPrimaryText,
                                              scalarConstArg0):
            return ""
    add(words, machineAarch64StoreBaseWord(scalarStoreIs64, 9, outPtrReg, scalarOffsetBytes))
    if strSourceIsZero:
        add(words, machineAarch64MovZeroWord(9))
        add(words, machineAarch64StoreBaseWord(true, 9, outPtrReg, strOffsetBytes))
        add(words, machineAarch64StoreBaseWord(false, 9, outPtrReg, strOffsetBytes + 8))
    else:
        add(words, machineAarch64StoreBaseWord(true, strSourceReg0, outPtrReg, strOffsetBytes))
        add(words, machineAarch64StoreBaseWord(false, strSourceReg1, outPtrReg, strOffsetBytes + 8))
        add(words, machineAarch64MovZeroWord(9))
    add(words, machineAarch64StoreBaseWord(false, 9, outPtrReg, strOffsetBytes + 12))
    add(words, machineAarch64StoreBaseWord(false, 9, outPtrReg, strOffsetBytes + 16))
    add(words, machineAarch64MovInt32Word(0, 0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectReturnCStringLiteralWords(architecture: str, byteLen: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if byteLen < 0 || byteLen > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, byteLen))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectIfRegisterZeroReturnCStringElseRegisterPairWords(architecture: str,
                                                                 zeroReg: int32,
                                                                 literalByteLen: int32,
                                                                 sourceReg0: int32,
                                                                 sourceReg1: int32,
                                                                 sourceReg1Is64: bool): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if zeroReg < 0 || zeroReg > 7 ||
       sourceReg0 < 0 || sourceReg0 > 7 ||
       sourceReg1 < 0 || sourceReg1 > 7 ||
       literalByteLen < 0 || literalByteLen > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64CmpZeroWord(false, zeroReg))
    let thenBranchIdx = words.len
    add(words, "")
    var loadReg1: int32 = sourceReg1
    if sourceReg1 == 0 && sourceReg0 != 0:
        add(words, machineAarch64MovRegWord(true, 9, 0))
        loadReg1 = 9
    if sourceReg0 != 0:
        add(words, machineAarch64MovRegWord(true, 0, sourceReg0))
    if loadReg1 != 1:
        add(words, machineAarch64MovRegWord(sourceReg1Is64, 1, loadReg1))
    let endBranchIdx = words.len
    add(words, "")
    let thenStartIdx = words.len
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, literalByteLen))
    let epilogueStartIdx = words.len
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[thenBranchIdx] = machineAarch64BranchCondWord(thenStartIdx - thenBranchIdx, "eq")
    words[endBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdx)
    return joinWordList(words)

fn machineDirectIfRegisterNonZeroElseRegisterPositiveWords(architecture: str,
                                                           guardReg: int32,
                                                           guardIs64: bool,
                                                           sourceReg: int32,
                                                           sourceIs64: bool): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if guardReg < 0 || guardReg > 7 || sourceReg < 0 || sourceReg > 7:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64CmpZeroWord(guardIs64, guardReg))
    let elseBranchIdx = words.len
    add(words, "")
    add(words, machineAarch64MovInt32Word(0, 1))
    let endBranchIdx = words.len
    add(words, "")
    let elseStartIdx = words.len
    add(words, machineAarch64CmpZeroWord(sourceIs64, sourceReg))
    add(words, machineAarch64BranchCondWord(3, "gt"))
    add(words, machineAarch64MovInt32Word(0, 0))
    add(words, machineAarch64BranchWord(2))
    add(words, machineAarch64MovInt32Word(0, 1))
    let epilogueStartIdx = words.len
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[elseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - elseBranchIdx, "eq")
    words[endBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdx)
    return joinWordList(words)

fn machineDirectUnaryWords(architecture: str,
                           opKind: str,
                           operandKind: str,
                           operandPrimaryText: str,
                           operandArg0: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleValueWords(architecture,
                                          words,
                                          0,
                                          operandKind,
                                          operandPrimaryText,
                                          operandArg0):
        return ""
    if opKind == "unary_neg":
        add(words, machineAarch64SubRegWord(false, 0, 31, 0))
    elif opKind == "unary_not":
        add(words, machineAarch64CmpZeroWord(false, 0))
        add(words, machineAarch64BranchCondWord(3, "eq"))
        add(words, machineAarch64MovInt32Word(0, 0))
        add(words, machineAarch64BranchWord(2))
        add(words, machineAarch64MovInt32Word(0, 1))
    else:
        return ""
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectUnaryRegisterWords(architecture: str,
                                   opKind: str,
                                   sourceReg: int32,
                                   is64: bool): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if sourceReg < 0 || sourceReg > 7:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    if opKind == "unary_neg":
        if sourceReg != 0:
            add(words, machineAarch64MovRegWord(is64, 0, sourceReg))
        add(words, machineAarch64SubRegWord(is64, 0, 31, 0))
    elif opKind == "unary_not":
        add(words, machineAarch64CmpZeroWord(is64, sourceReg))
        add(words, machineAarch64BranchCondWord(3, "eq"))
        add(words, machineAarch64MovInt32Word(0, 0))
        add(words, machineAarch64BranchWord(2))
        add(words, machineAarch64MovInt32Word(0, 1))
    else:
        return ""
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectBinaryWords(architecture: str,
                            lhsKind: str,
                            lhsPrimaryText: str,
                            lhsArg0: int32,
                            rhsKind: str,
                            rhsPrimaryText: str,
                            rhsArg0: int32,
                            operatorText: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, lhsKind, lhsPrimaryText, lhsArg0):
        return ""
    if !machineAppendLoadSimpleValueWords(architecture, words, 1, rhsKind, rhsPrimaryText, rhsArg0):
        return ""
    if operatorText == "+":
        add(words, machineAarch64AddRegWord(false, 0, 0, 1))
    elif operatorText == "-":
        add(words, machineAarch64SubRegWord(false, 0, 0, 1))
    elif operatorText == "==" || operatorText == "!=" ||
         operatorText == "<" || operatorText == "<=" ||
         operatorText == ">" || operatorText == ">=":
        add(words, machineAarch64CmpRegWord(false, 0, 1))
        let cond = machineCompareOperatorCond(operatorText)
        add(words, machineAarch64BranchCondWord(3, cond))
        add(words, machineAarch64MovInt32Word(0, 0))
        add(words, machineAarch64BranchWord(2))
        add(words, machineAarch64MovInt32Word(0, 1))
    else:
        return ""
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineAppendLoadDirectScalarValueWords(architecture: str,
                                           words: var str[],
                                           targetReg: int32,
                                           signatureText: str,
                                           opKind: str,
                                           opPrimaryText: str,
                                           opArg0: int32,
                                           is64: var bool): bool =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    is64 = false
    if opKind == "load_param":
        let paramTypeText = compilerCoreSignatureParamTypeText(signatureText, opArg0)
        let sourceReg = compilerCoreParamBaseReg(signatureText, opArg0)
        if sourceReg < 0 || sourceReg > 7:
            return false
        is64 = compilerCoreDirectParamIs64(paramTypeText)
        if sourceReg != targetReg:
            add(words, machineAarch64MovRegWord(is64, targetReg, sourceReg))
        return true
    if opKind == "load_int32":
        let value = parser.parseIntStrict(opPrimaryText)
        if value < 0 || value > 65535:
            return false
        add(words, machineAarch64MovInt32Word(targetReg, value))
        return true
    if opKind == "load_bool":
        add(words, machineAarch64MovInt32Word(targetReg, opPrimaryText == "true" ? 1 else: 0))
        return true
    if opKind == "load_nil":
        is64 = true
        add(words, machineAarch64MovZeroWord(targetReg))
        return true
    return false

fn machineDirectArithmeticCompareWords(architecture: str,
                                       signatureText: str,
                                       lhsSourceReg: int32,
                                       lhsSourceIs64: bool,
                                       arithmeticOperatorText: str,
                                       rhsKind: str,
                                       rhsPrimaryText: str,
                                       rhsArg0: int32,
                                       compareSourceReg: int32,
                                       compareSourceIs64: bool,
                                       compareOperatorText: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if lhsSourceReg < 0 || lhsSourceReg > 7 || compareSourceReg < 0 || compareSourceReg > 7:
        return ""
    if arithmeticOperatorText != "+" && arithmeticOperatorText != "-":
        return ""
    if compareOperatorText != "==" && compareOperatorText != "!=" &&
       compareOperatorText != "<" && compareOperatorText != "<=" &&
       compareOperatorText != ">" && compareOperatorText != ">=":
        return ""
    if lhsSourceIs64 || compareSourceIs64:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    if lhsSourceReg != 9:
        add(words, machineAarch64MovRegWord(false, 9, lhsSourceReg))
    var rhsIs64: bool = false
    if !machineAppendLoadDirectScalarValueWords(architecture,
                                                words,
                                                10,
                                                signatureText,
                                                rhsKind,
                                                rhsPrimaryText,
                                                rhsArg0,
                                                rhsIs64):
        return ""
    if rhsIs64:
        return ""
    if arithmeticOperatorText == "+":
        add(words, machineAarch64AddRegWord(false, 9, 9, 10))
    else:
        add(words, machineAarch64SubRegWord(false, 9, 9, 10))
    if compareSourceReg != 10:
        add(words, machineAarch64MovRegWord(false, 10, compareSourceReg))
    add(words, machineAarch64CmpRegWord(false, 9, 10))
    let cond = machineCompareOperatorCond(compareOperatorText)
    add(words, machineAarch64BranchCondWord(3, cond))
    add(words, machineAarch64MovInt32Word(0, 0))
    add(words, machineAarch64BranchWord(2))
    add(words, machineAarch64MovInt32Word(0, 1))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectIfElseSimpleCondWords(architecture: str,
                                      condKind: str,
                                      condPrimaryText: str,
                                      condArg0: int32,
                                      thenKind: str,
                                      thenPrimaryText: str,
                                      thenArg0: int32,
                                      elseKind: str,
                                      elsePrimaryText: str,
                                      elseArg0: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, condKind, condPrimaryText, condArg0):
        return ""
    add(words, machineAarch64CmpZeroWord(false, 0))
    let falseBranchIdx = words.len
    add(words, "")
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, thenKind, thenPrimaryText, thenArg0):
        return ""
    let endBranchIdx = words.len
    add(words, "")
    let elseStartIdx = words.len
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, elseKind, elsePrimaryText, elseArg0):
        return ""
    let epilogueStartIdx = words.len
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[falseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - falseBranchIdx, "eq")
    words[endBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdx)
    return joinWordList(words)

fn machineDirectIfElseBinaryCondWords(architecture: str,
                                      lhsKind: str,
                                      lhsPrimaryText: str,
                                      lhsArg0: int32,
                                      rhsKind: str,
                                      rhsPrimaryText: str,
                                      rhsArg0: int32,
                                      operatorText: str,
                                      thenKind: str,
                                      thenPrimaryText: str,
                                      thenArg0: int32,
                                      elseKind: str,
                                      elsePrimaryText: str,
                                      elseArg0: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, lhsKind, lhsPrimaryText, lhsArg0):
        return ""
    if !machineAppendLoadSimpleValueWords(architecture, words, 1, rhsKind, rhsPrimaryText, rhsArg0):
        return ""
    add(words, machineAarch64CmpRegWord(false, 0, 1))
    let falseBranchIdx = words.len
    add(words, "")
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, thenKind, thenPrimaryText, thenArg0):
        return ""
    let endBranchIdx = words.len
    add(words, "")
    let elseStartIdx = words.len
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, elseKind, elsePrimaryText, elseArg0):
        return ""
    let epilogueStartIdx = words.len
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[falseBranchIdx] =
        machineAarch64BranchCondWord(elseStartIdx - falseBranchIdx,
                                     machineAarch64InverseCompareCond(operatorText))
    words[endBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdx)
    return joinWordList(words)

fn machineFunctionSymbolName(targetTriple: str, moduleKind: str, opName: str, itemId: int32): str =
    return mtarget.machineTargetSymbolPrefix(targetTriple) +
           "cheng_v2_" + sanitizeSymbolPart(moduleKind) + "_" +
           sanitizeSymbolPart(opName) + "_" + intToStr(itemId)

fn machineCallSymbolName(targetTriple: str, runtimeTarget: str): str =
    return mtarget.machineTargetSymbolPrefix(targetTriple) + sanitizeSymbolPart(runtimeTarget)

fn machineLibcSymbolName(targetTriple: str, symbolName: str): str =
    return mtarget.machineTargetSymbolPrefix(targetTriple) + symbolName

fn compilerCoreExecOpText(plan: cflow.LowUirCompilerCorePlan, opIdx: int32): str =
    return plan.opKinds[opIdx] + "|" +
           compilerCoreHexEncodeText(plan.opPrimaryTexts[opIdx]) + "|" +
           compilerCoreHexEncodeText(plan.opSecondaryTexts[opIdx]) + "|" +
           intToStr(plan.opArg0s[opIdx]) + "|" +
           intToStr(plan.opArg1s[opIdx]) + "|" +
           intToStr(plan.opArg2s[opIdx])

fn compilerCoreTextLines(text: str): str[] =
    var out: str[]
    out = []
    if len(text) <= 0:
        return out
    var start: int32 = 0
    var i: int32 = 0
    while i <= len(text):
        if i == len(text) || text[i] == '\n':
            add(out, strings.sliceBytes(text, start, i - start))
            start = i + 1
        i = i + 1
    return out

fn compilerCorePayloadPreludeText(plan: cflow.LowUirCompilerCorePlan,
                                  itemIdx: int32,
                                  runtimeTarget: str,
                                  bindingSummary: str): str =
    var lines: str[]
    lines = []
    add(lines, "runtime=" + runtimeTarget + "|bindings=" + bindingSummary)
    add(lines, "runtime_target=" + runtimeTarget)
    add(lines, "binding_summary=" + bindingSummary)
    add(lines, "module_kind=compiler_core")
    add(lines, "item_id=" + intToStr(plan.itemIds[itemIdx]))
    add(lines, "canonical_op=" + plan.canonicalOps[itemIdx])
    add(lines, "top_level_kind=" + plan.topLevelKinds[itemIdx])
    add(lines, "label=" + plan.labels[itemIdx])
    add(lines, "owner_module=" + plan.ownerModules[itemIdx])
    add(lines, "source_path=" + plan.sourcePaths[itemIdx])
    add(lines, "import_path=" + plan.importPaths[itemIdx])
    add(lines, "import_alias=" + plan.importAliases[itemIdx])
    add(lines, "import_category=" + plan.importCategories[itemIdx])
    add(lines, "importc_symbol=" + plan.importcSymbolTexts[itemIdx])
    add(lines, "return_type=" + plan.returnTypeTexts[itemIdx])
    add(lines, "param_count=" + intToStr(plan.paramCounts[itemIdx]))
    add(lines, "local_count=" + intToStr(plan.localCounts[itemIdx]))
    add(lines, "stmt_count=" + intToStr(plan.stmtCounts[itemIdx]))
    add(lines, "expr_count=" + intToStr(plan.exprCounts[itemIdx]))
    add(lines, "body_line_count=" + intToStr(plan.bodyLineCounts[itemIdx]))
    add(lines, "body_text_hex=" + compilerCoreHexEncodeText(plan.bodyTexts[itemIdx]))
    add(lines, "ast_ready=" + if plan.executableAstReady[itemIdx]: "1" else: "0")
    add(lines, "signature_hash=" + plan.signatureHashes[itemIdx])
    add(lines, "body_hash=" + plan.bodyHashes[itemIdx])
    let signatureLines = compilerCoreTextLines(plan.signatureTexts[itemIdx])
    add(lines, "signature_line_count=" + intToStr(signatureLines.len))
    for i in 0..<signatureLines.len:
        add(lines, "signature_line." + intToStr(i) + "=" + signatureLines[i])
    let paramStart = plan.itemParamStarts[itemIdx]
    for i in 0..<plan.paramCounts[itemIdx]:
        add(lines, "param_kind." + intToStr(i) + "=" + plan.paramKinds[paramStart + i])
    let localStart = plan.itemLocalStarts[itemIdx]
    for i in 0..<plan.localCounts[itemIdx]:
        add(lines,
            "local_type_hex." + intToStr(i) + "=" +
            compilerCoreHexEncodeText(plan.localTypeTexts[localStart + i]))
    return joinWithSep(lines, "\n")

fn compilerCoreRoutineExecPlanText(plan: cflow.LowUirCompilerCorePlan, itemIdx: int32): str =
    let startIdx = plan.routineOpStarts[itemIdx]
    let opCount = plan.routineOpCounts[itemIdx]
    var lines: str[]
    lines = []
    add(lines, "exec_op_count=" + intToStr(opCount))
    add(lines, "exec_op_hash=" + plan.routineOpHashes[itemIdx])
    for i in 0..<opCount:
        add(lines, "op." + intToStr(i) + "=" + compilerCoreExecOpText(plan, startIdx + i))
    return joinWithSep(lines, "\n")

fn compilerCoreProgramReturnRegCount(returnTypeText: str): int32 =
    let normalizedText = compilerCoreNormalizedTypeText(returnTypeText)
    if len(normalizedText) <= 0 || normalizedText == "void":
        return 0
    return compilerCoreDirectTypeRegWidth(returnTypeText)

fn compilerCoreHexEncodeText(text: str): str =
    var out: str = ""
    for i in 0..<len(text):
        let value = int32(text[i]) & 255
        out = out + charToString(hexDigitLower((value >> 4) & 15))
        out = out + charToString(hexDigitLower(value & 15))
    return out

fn compilerCoreProgramRegistrySymbolName(targetTriple: str): str =
    return mtarget.machineTargetSymbolPrefix(targetTriple) +
           "cheng_v2_compiler_core_program_registry"

fn compilerCorePayloadTextForItem(plan: cflow.LowUirCompilerCorePlan,
                                  itemIdx: int32,
                                  runtimeTarget: str,
                                  bindingSummary: str): str =
    let payloadPrelude = compilerCorePayloadPreludeText(plan,
                                                        itemIdx,
                                                        runtimeTarget,
                                                        bindingSummary)
    if plan.executableAstReady[itemIdx] && plan.routineOpCounts[itemIdx] > 0:
        return payloadPrelude + "\n" + compilerCoreRoutineExecPlanText(plan, itemIdx)
    return payloadPrelude

fn compilerCoreProgramRegistryText(plan: cflow.LowUirCompilerCorePlan,
                                   targetTriple: str,
                                   preferredSourcePath: str): str =
    let entryIdx = compilerCorePlanEntryIndex(plan, preferredSourcePath)
    if entryIdx < 0:
        panic("v2 machine pipeline: compiler_core program registry entry missing")
    var lines: str[]
    lines = []
    add(lines, "compiler_core_program_registry_version=v1")
    add(lines, "module_kind=compiler_core")
    add(lines, "target=" + targetTriple)
    add(lines, "entry_item_id=" + intToStr(plan.itemIds[entryIdx]))
    add(lines, "entry_label=" + plan.labels[entryIdx])
    add(lines, "item_count=" + intToStr(plan.itemIds.len))
    for i in 0..<plan.itemIds.len:
        let bindingSummary = "top_level=" + plan.topLevelKinds[i] +
                             "|label=" + plan.labels[i] +
                             "|proof=" + plan.proofDomains[i] +
                             "|effect=" + plan.effectClasses[i] +
                             "|scope=" + plan.bindingScopes[i] +
                             "|import_path=" + plan.importPaths[i] +
                             "|import_alias=" + plan.importAliases[i] +
                             "|import_category=" + plan.importCategories[i] +
                             "|ast_ready=" + if plan.executableAstReady[i]: "1" else: "0" +
                             "|return_type=" + plan.returnTypeTexts[i] +
                             "|param_count=" + intToStr(plan.paramCounts[i]) +
                             "|local_count=" + intToStr(plan.localCounts[i]) +
                             "|stmt_count=" + intToStr(plan.stmtCounts[i]) +
                             "|expr_count=" + intToStr(plan.exprCounts[i]) +
                             "|body_lines=" + intToStr(plan.bodyLineCounts[i]) +
                             "|signature_hash=" + plan.signatureHashes[i] +
                             "|body_hash=" + plan.bodyHashes[i]
        let runtimeTarget = compilerCoreMachineRuntimeTarget(plan.runtimeTargets[i], plan.sourcePaths[i])
        let payloadText = compilerCorePayloadTextForItem(plan, i, runtimeTarget, bindingSummary)
        var payloadMode: str = "local_payload"
        if plan.executableAstReady[i] && plan.routineOpCounts[i] > 0:
            payloadMode = "exec_plan_payload"
        add(lines, "item." + intToStr(i) + ".item_id=" + intToStr(plan.itemIds[i]))
        add(lines, "item." + intToStr(i) + ".label=" + plan.labels[i])
        add(lines, "item." + intToStr(i) + ".canonical_op=" + plan.canonicalOps[i])
        add(lines, "item." + intToStr(i) + ".top_level_kind=" + plan.topLevelKinds[i])
        add(lines, "item." + intToStr(i) + ".owner_module=" + plan.ownerModules[i])
        add(lines, "item." + intToStr(i) + ".source_path=" + plan.sourcePaths[i])
        add(lines, "item." + intToStr(i) + ".import_path=" + plan.importPaths[i])
        add(lines, "item." + intToStr(i) + ".import_target_module=" + plan.importTargetModulePaths[i])
        add(lines, "item." + intToStr(i) + ".import_alias=" + plan.importAliases[i])
        add(lines, "item." + intToStr(i) + ".import_category=" + plan.importCategories[i])
        add(lines, "item." + intToStr(i) + ".importc_symbol=" + plan.importcSymbolTexts[i])
        add(lines, "item." + intToStr(i) + ".metadata_mode=" + payloadMode)
        add(lines, "item." + intToStr(i) + ".payload_hex=" + compilerCoreHexEncodeText(payloadText))
    return joinWithSep(lines, "\n")

fn newMachineModuleBundle(moduleKind: str, targetTriple: str): MachineModuleBundle =
    var out: MachineModuleBundle
    out.version = machinePipelineVersion()
    out.moduleKind = moduleKind
    out.targetTriple = targetTriple
    out.architecture = mtarget.machineTargetArchitecture(targetTriple)
    out.objFormat = mtarget.machineTargetObjFormat(targetTriple)
    out.symbolPrefix = mtarget.machineTargetSymbolPrefix(targetTriple)
    out.textSectionName = mtarget.machineTargetTextSectionName(targetTriple)
    out.cstringSectionName = mtarget.machineTargetCStringSectionName(targetTriple)
    out.callRelocationKind = mtarget.machineTargetCallRelocationKind(targetTriple)
    out.metadataPageRelocationKind = mtarget.machineTargetMetadataPageRelocationKind(targetTriple)
    out.metadataPageoffRelocationKind = mtarget.machineTargetMetadataPageoffRelocationKind(targetTriple)
    out.regalloc = mtarget.machineTargetContract().regalloc
    out.pointerWidthBits = mtarget.machineTargetPointerWidthBits(targetTriple)
    out.stackAlignBytes = mtarget.machineTargetStackAlignBytes(targetTriple)
    out.entrySymbolOverride = ""
    out.itemIds = []
    out.symbolNames = []
    out.runtimeTargets = []
    out.callSymbolNames = []
    out.frameSizes = []
    out.stackAligns = []
    out.argRegs = []
    out.scratchRegs = []
    out.calleeSavedRegs = []
    out.bindingSummaries = []
    out.instructionWordHex = []
    out.functionByteSizes = []
    out.localPayloadPageRelocOffsets = []
    out.localPayloadPageoffRelocOffsets = []
    out.callRelocOffsets = []
    out.metadataOperandModes = []
    out.localPayloadTexts = []
    out.functionRelocStarts = []
    out.functionRelocCounts = []
    out.relocOffsets = []
    out.relocSymbols = []
    out.relocKinds = []
    out.dataSymbolNames = []
    out.dataSymbolBindings = []
    out.dataSectionNames = []
    out.dataPayloadTexts = []
    out.dataAlignPow2 = []
    return out

fn machineFunctionIndexByItemId(bundle: MachineModuleBundle, itemId: int32): int32 =
    for i in 0..<bundle.itemIds.len:
        if bundle.itemIds[i] == itemId:
            return i
    return -1

fn compilerCorePlanEntryIndex(plan: cflow.LowUirCompilerCorePlan,
                              preferredSourcePath: str): int32 =
    var mainIdx: int32 = -1
    var preferredMainIdx: int32 = -1
    for i in 0..<plan.itemIds.len:
        if plan.labels[i] == "compilerCoreArgvEntry" &&
           plan.topLevelKinds[i] == "fn" &&
           plan.canonicalOps[i] == "compiler_fn_exec":
            return i
        if plan.labels[i] == "main" &&
           plan.topLevelKinds[i] == "fn" &&
           plan.canonicalOps[i] == "compiler_fn_exec":
            mainIdx = i
            if len(preferredSourcePath) > 0 &&
               i < len(plan.sourcePaths) &&
               plan.sourcePaths[i] == preferredSourcePath:
                preferredMainIdx = i
    return preferredMainIdx >= 0 ? preferredMainIdx else: mainIdx

fn compilerCoreProgramEntryFunctionIndex(bundle: MachineModuleBundle): int32 =
    var entryLabel: str = ""
    var entryKind: str = ""
    for i in 0..<bundle.bindingSummaries.len:
        if bundle.bindingSummaries[i].len >= len("entry_bridge=1|") &&
           strings.sliceBytes(bundle.bindingSummaries[i], 0, len("entry_bridge=1|")) == "entry_bridge=1|":
            let entryItemId = bundle.itemIds[i] - 1000000000
            let entryIdx = machineFunctionIndexByItemId(bundle, entryItemId)
            if entryIdx >= 0:
                return entryIdx
            entryLabel = bindingSummaryFieldValue(bundle.bindingSummaries[i], "entry_label")
            entryKind = bindingSummaryFieldValue(bundle.bindingSummaries[i], "entry_kind")
            break
    if len(entryLabel) > 0:
        let prefix = "top_level=" + (len(entryKind) > 0 ? entryKind else: "fn") + "|label=" + entryLabel + "|"
        for i in 0..<bundle.bindingSummaries.len:
            if bundle.bindingSummaries[i].len >= prefix.len &&
               strings.sliceBytes(bundle.bindingSummaries[i], 0, prefix.len) == prefix:
                return i
    let fallbackPrefix = "top_level=fn|label=main|"
    for i in 0..<bundle.bindingSummaries.len:
        if bundle.bindingSummaries[i].len >= fallbackPrefix.len &&
           strings.sliceBytes(bundle.bindingSummaries[i], 0, fallbackPrefix.len) == fallbackPrefix:
            return i
    return -1

fn compilerCoreArgvProviderEntryFunctionIndex(bundle: MachineModuleBundle): int32 =
    return compilerCoreProgramEntryFunctionIndex(bundle)

fn appendMachineRelocation(out: var MachineModuleBundle,
                           offset: int32,
                           symbolName: str,
                           relocKind: str) =
    add(out.relocOffsets, offset)
    add(out.relocSymbols, symbolName)
    add(out.relocKinds, relocKind)

fn appendMachineDataSymbol(out: var MachineModuleBundle,
                           symbolName: str,
                           sectionName: str,
                           payloadText: str,
                           alignPow2: int32) =
    add(out.dataSymbolNames, symbolName)
    add(out.dataSymbolBindings, "local")
    add(out.dataSectionNames, sectionName)
    add(out.dataPayloadTexts, payloadText)
    add(out.dataAlignPow2, alignPow2)

fn appendMachineGlobalDataSymbol(out: var MachineModuleBundle,
                                 symbolName: str,
                                 sectionName: str,
                                 payloadText: str,
                                 alignPow2: int32) =
    add(out.dataSymbolNames, symbolName)
    add(out.dataSymbolBindings, "global")
    add(out.dataSectionNames, sectionName)
    add(out.dataPayloadTexts, payloadText)
    add(out.dataAlignPow2, alignPow2)

fn rewriteMachineFunctionPayload(out: var MachineModuleBundle,
                                 functionIdx: int32,
                                 operandMode: str,
                                 payloadText: str) =
    out.metadataOperandModes[functionIdx] = operandMode
    out.localPayloadTexts[functionIdx] = payloadText
    let dataSymbol = out.symbolNames[functionIdx] + "_meta"
    for i in 0..<out.dataSymbolNames.len:
        if out.dataSymbolNames[i] == dataSymbol:
            out.dataPayloadTexts[i] = payloadText
            return

fn rewriteMachineFunctionProgramPayloadBridge(out: var MachineModuleBundle,
                                              functionIdx: int32,
                                              words: str,
                                              callSymbol: str,
                                              operandMode: str,
                                              payloadText: str) =
    let callOffsets = machineDirectCallRelocOffsets(words)
    let dataRelocOffsets = machineDirectFirstCStringRelocOffsets(words)
    if callOffsets.len != 1 || dataRelocOffsets.len != 2:
        panic("v2 machine pipeline: program payload bridge reloc count mismatch")
    let dataSymbol = out.symbolNames[functionIdx] + "_meta"
    out.callSymbolNames[functionIdx] = callSymbol
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = dataRelocOffsets[0]
    out.localPayloadPageoffRelocOffsets[functionIdx] = dataRelocOffsets[1]
    out.callRelocOffsets[functionIdx] = callOffsets[0]
    out.metadataOperandModes[functionIdx] = operandMode
    out.localPayloadTexts[functionIdx] = payloadText
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    appendMachineRelocation(out,
                            dataRelocOffsets[0],
                            dataSymbol,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            dataRelocOffsets[1],
                            dataSymbol,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            callOffsets[0],
                            callSymbol,
                            out.callRelocationKind)
    out.functionRelocCounts[functionIdx] = 3

fn machineCompilerCoreProgramPayloadBridgeWords(architecture: str,
                                                returnRegCount: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported program payload bridge architecture " + architecture)
    if returnRegCount < 0 || returnRegCount > 3:
        return ""
    let argFrameOffset = 0
    let resultFrameOffset = 64
    let frameBytes = 96
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64SubImmWord(true, 31, 31, frameBytes))
    for reg in 0..<8:
        add(words, machineAarch64StoreSpWord(true, reg, argFrameOffset + reg * 8))
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64AddImmWord(true, 1, 31, argFrameOffset))
    add(words, machineAarch64AddImmWord(true, 2, 31, resultFrameOffset))
    add(words, "94000000")
    add(words, machineAarch64LoadSpWord(true, 0, resultFrameOffset))
    if returnRegCount >= 2:
        add(words, machineAarch64LoadSpWord(true, 1, resultFrameOffset + 8))
    if returnRegCount >= 3:
        add(words, machineAarch64LoadSpWord(true, 2, resultFrameOffset + 16))
    add(words, machineAarch64AddImmWord(true, 31, 31, frameBytes))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn rewriteMachineFunctionDirectExec(out: var MachineModuleBundle,
                                    functionIdx: int32,
                                    words: str) =
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = ""
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = 0
    out.localPayloadPageoffRelocOffsets[functionIdx] = 0
    out.callRelocOffsets[functionIdx] = 0
    out.metadataOperandModes[functionIdx] = "direct_exec_no_payload"
    out.localPayloadTexts[functionIdx] = ""
    out.functionRelocCounts[functionIdx] = 0

fn machineDirectCallRelocOffset(words: str): int32 =
    var token: str = ""
    var wordIdx: int32 = 0
    for i in 0..<len(words):
        if words[i] == ';':
            if token == "94000000":
                return wordIdx * 4
            token = ""
            wordIdx = wordIdx + 1
        else:
            token = token + charToString(words[i])
    if token == "94000000":
        return wordIdx * 4
    panic("v2 machine pipeline: direct exec call words missing branch placeholder")

fn machineDirectCallRelocOffsets(words: str): int32[] =
    var out: int32[]
    out = []
    var token: str = ""
    var wordIdx: int32 = 0
    for i in 0..<len(words):
        if words[i] == ';':
            if token == "94000000":
                add(out, wordIdx * 4)
            token = ""
            wordIdx = wordIdx + 1
        else:
            token = token + charToString(words[i])
    if token == "94000000":
        add(out, wordIdx * 4)
    return out

fn machineDirectSecondCStringRelocOffsets(words: str): int32[] =
    var out: int32[]
    out = []
    var token: str = ""
    var wordIdx: int32 = 0
    for i in 0..<len(words):
        if words[i] == ';':
            if token == "90000002" || token == "91000042":
                add(out, wordIdx * 4)
            token = ""
            wordIdx = wordIdx + 1
        else:
            token = token + charToString(words[i])
    if token == "90000002" || token == "91000042":
        add(out, wordIdx * 4)
    return out

fn machineDirectFirstCStringRelocOffsets(words: str): int32[] =
    var out: int32[]
    out = []
    var token: str = ""
    var wordIdx: int32 = 0
    for i in 0..<len(words):
        if words[i] == ';':
            if token == "90000000" || token == "91000000":
                add(out, wordIdx * 4)
            token = ""
            wordIdx = wordIdx + 1
        else:
            token = token + charToString(words[i])
    if token == "90000000" || token == "91000000":
        add(out, wordIdx * 4)
    return out

fn rewriteMachineFunctionDirectExecCalls(out: var MachineModuleBundle,
                                         functionIdx: int32,
                                         words: str,
                                         callSymbols: str[]) =
    let callOffsets = machineDirectCallRelocOffsets(words)
    if callOffsets.len != callSymbols.len:
        panic("v2 machine pipeline: direct exec call reloc count mismatch")
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = joinWithSep(callSymbols, ";")
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = 0
    out.localPayloadPageoffRelocOffsets[functionIdx] = 0
    out.callRelocOffsets[functionIdx] = callOffsets.len > 0 ? callOffsets[0] else: 0
    out.metadataOperandModes[functionIdx] = "direct_exec_no_payload"
    out.localPayloadTexts[functionIdx] = ""
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    for i in 0..<callOffsets.len:
        appendMachineRelocation(out,
                                callOffsets[i],
                                callSymbols[i],
                                out.callRelocationKind)
    out.functionRelocCounts[functionIdx] = callOffsets.len

fn rewriteMachineFunctionDirectExecCall(out: var MachineModuleBundle,
                                        functionIdx: int32,
                                        words: str,
                                        callSymbol: str) =
    rewriteMachineFunctionDirectExecCalls(out, functionIdx, words, [callSymbol])

fn rewriteMachineFunctionDirectExecCStringData(out: var MachineModuleBundle,
                                               functionIdx: int32,
                                               words: str,
                                               payloadText: str) =
    let dataSymbol = out.symbolNames[functionIdx] + "_cstring"
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = ""
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = 8
    out.localPayloadPageoffRelocOffsets[functionIdx] = 12
    out.callRelocOffsets[functionIdx] = 0
    out.metadataOperandModes[functionIdx] = "direct_exec_cstring_payload"
    out.localPayloadTexts[functionIdx] = payloadText
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    appendMachineDataSymbol(out,
                            dataSymbol,
                            out.cstringSectionName,
                            payloadText,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineRelocation(out,
                            8,
                            dataSymbol,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            12,
                            dataSymbol,
                            out.metadataPageoffRelocationKind)
    out.functionRelocCounts[functionIdx] = 2

