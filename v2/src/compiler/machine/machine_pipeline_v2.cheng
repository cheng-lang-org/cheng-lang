fn compilerCoreMatchDirectExecParamCStringFourIfReturn(plan: cflow.LowUirCompilerCorePlan,
                                                       itemIdx: int32,
                                                       sourceReg0: var int32,
                                                       sourceReg1: var int32,
                                                       sourceReg1Is64: var bool,
                                                       condPayload0: var str,
                                                       thenPayload0: var str,
                                                       condPayload1: var str,
                                                       thenPayload1: var str,
                                                       condPayload2: var str,
                                                       thenPayload2: var str,
                                                       condPayload3: var str,
                                                       thenPayload3: var str,
                                                       elsePayload: var str): bool =
    sourceReg0 = -1
    sourceReg1 = -1
    sourceReg1Is64 = false
