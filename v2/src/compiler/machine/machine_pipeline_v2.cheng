fn compilerCoreImportcSymbolTextFromSignature(signatureText: str, label: str): str =
    let trimmed = compilerCoreTrimAscii(signatureText)
    let prefix = "@importc(\""
    let startIdx = compilerCoreLastIndexOf(trimmed, prefix)
    if startIdx >= 0:
        let valueStart = startIdx + len(prefix)
        var valueStop: int32 = valueStart
        while valueStop < len(trimmed) && trimmed[valueStop] != '"':
            valueStop = valueStop + 1
        if valueStop > valueStart:
            return slice(trimmed, valueStart, valueStop - valueStart)
    return label

fn compilerCoreDirectExecCalleeSymbol(plan: cflow.LowUirCompilerCorePlan,
                                      calleeItemIdx: int32,
                                      targetTriple: str): str =
    if calleeItemIdx < 0:
        return ""
    if plan.topLevelKinds[calleeItemIdx] == "importc_fn":
        var sourceSymbolName: str = ""
        if len(plan.importcSymbolTexts[calleeItemIdx]) > 0:
            sourceSymbolName = plan.importcSymbolTexts[calleeItemIdx]
        else:
            sourceSymbolName = compilerCoreImportcSymbolTextFromSignature(plan.signatureTexts[calleeItemIdx],
                                                                          plan.labels[calleeItemIdx])
        if !compilerCoreDirectExecImportcSymbolAllowed(sourceSymbolName):
            return ""
        var directSymbolName: str = sourceSymbolName
        if sourceSymbolName == "driver_c_cli_param1_eq_bridge":
            directSymbolName = "driver_c_cli_param1_eq_raw_bridge"
        return machineLibcSymbolName(targetTriple, directSymbolName)
    return machineFunctionSymbolName(targetTriple,
                                     "compiler_core",
                                     plan.canonicalOps[calleeItemIdx],
                                     plan.itemIds[calleeItemIdx])

fn compilerCoreDirectExecCallSymbolTargetsOutline(callSymbol: str): bool =
    return strings.find(callSymbol, "_fn_outline_") >= 0 ||
           strings.find(callSymbol, "_iterator_outline_") >= 0

fn compilerCoreDirectExecCallSymbolsTargetOutline(callSymbols: str[]): bool =
    for i in 0..<callSymbols.len:
        if compilerCoreDirectExecCallSymbolTargetsOutline(callSymbols[i]):
            return true
    return false

fn compilerCoreDirectExecCStringSecondArgSymbol(plan: cflow.LowUirCompilerCorePlan,
                                                itemIdx: int32,
                                                calleeItemIdx: int32,
                                                firstArgKind: str,
                                                targetTriple: str): str =
    if calleeItemIdx < 0:
        return ""
    if plan.topLevelKinds[calleeItemIdx] != "importc_fn":
        return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    var sourceSymbolName: str = ""
    if len(plan.importcSymbolTexts[calleeItemIdx]) > 0:
        sourceSymbolName = plan.importcSymbolTexts[calleeItemIdx]
    else:
        sourceSymbolName = compilerCoreImportcSymbolTextFromSignature(plan.signatureTexts[calleeItemIdx],
                                                                      plan.labels[calleeItemIdx])
    if !compilerCoreDirectExecImportcSymbolAllowed(sourceSymbolName):
        return ""
    var directSymbolName = sourceSymbolName
    if sourceSymbolName == "driver_c_str_eq_bridge" &&
       compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0), "str") &&
       compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 1), "str") &&
       firstArgKind != "load_str":
        directSymbolName = "driver_c_str_eq_raw_bridge"
    return machineLibcSymbolName(targetTriple, directSymbolName)

fn compilerCoreDirectExecImportcRawCStringAllowed(plan: cflow.LowUirCompilerCorePlan,
                                                  calleeItemIdx: int32,
                                                  argCount: int32,
                                                  firstArgKind: str): bool =
    if calleeItemIdx < 0 || plan.topLevelKinds[calleeItemIdx] != "importc_fn":
        return false
    var sourceSymbolName: str = ""
    if len(plan.importcSymbolTexts[calleeItemIdx]) > 0:
        sourceSymbolName = plan.importcSymbolTexts[calleeItemIdx]
    else:
        sourceSymbolName = compilerCoreImportcSymbolTextFromSignature(plan.signatureTexts[calleeItemIdx],
                                                                      plan.labels[calleeItemIdx])
    if sourceSymbolName == "driver_c_cli_param1_eq_bridge":
        return argCount == 1
    if sourceSymbolName == "driver_c_str_eq_bridge":
        return argCount == 2 && firstArgKind != "load_str"
    return false

fn compilerCoreIsDirectSimpleValueKind(kind: str): bool =
    return kind == "load_param" ||
           kind == "load_local" ||
           kind == "load_int32" ||
           kind == "load_bool" ||
           kind == "load_nil"

fn compilerCoreIsDirectScalarValueKind(kind: str): bool =
    return kind == "load_param" ||
           kind == "load_int32" ||
           kind == "load_bool" ||
           kind == "load_nil"

fn compilerCoreDirectNestedScalarArgSupported(plan: cflow.LowUirCompilerCorePlan,
                                              itemIdx: int32,
                                              opIdx: int32): bool =
    let kind = plan.opKinds[opIdx]
    if !compilerCoreIsDirectScalarValueKind(kind):
        return false
    if kind == "load_param":
        return compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx],
                                                                                 plan.opArg0s[opIdx])) == 1
    return true

fn compilerCoreDirectNestedInnerArgSupported(plan: cflow.LowUirCompilerCorePlan,
                                             itemIdx: int32,
                                             opIdx: int32): bool =
    let kind = plan.opKinds[opIdx]
    if kind == "load_param":
        let regWidth = compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx],
                                                                                         plan.opArg0s[opIdx]))
        return regWidth >= 1 && regWidth <= 2
    return compilerCoreIsDirectConstValueKind(kind)

fn compilerCoreDirectNestedArgRegWidth(plan: cflow.LowUirCompilerCorePlan,
                                       itemIdx: int32,
                                       opIdx: int32): int32 =
    let kind = plan.opKinds[opIdx]
    if kind == "load_param":
        return compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx],
                                                                                 plan.opArg0s[opIdx]))
    return compilerCoreIsDirectConstValueKind(kind) ? 1 else: 0

fn compilerCoreHasDirectExecBody(plan: cflow.LowUirCompilerCorePlan,
                                 itemIdx: int32,
                                 targetTriple: str): bool =
    let architecture = mtarget.machineTargetArchitecture(targetTriple)
    let cstringPayload = compilerCoreDirectExecCStringPayloadText(plan, itemIdx)
    if len(cstringPayload) > 0 &&
       len(machineDirectReturnCStringLiteralWords(architecture, len(cstringPayload))) > 0:
        return true
    if len(compilerCoreDirectExecWords(plan, itemIdx, architecture)) > 0:
        return true
    let ifElseSymbols = compilerCoreDirectExecIfElseCallSymbols(plan, itemIdx, targetTriple)
    if ifElseSymbols.len > 0 &&
       len(compilerCoreDirectExecIfElseCallWords(plan, itemIdx, architecture)) > 0:
        return true
    let nestedSymbols = compilerCoreDirectExecNestedCallSymbols(plan, itemIdx, targetTriple)
    if nestedSymbols.len > 0 &&
       !compilerCoreDirectExecCallSymbolsTargetOutline(nestedSymbols) &&
       len(compilerCoreDirectExecNestedCallWords(plan, itemIdx, targetTriple)) > 0:
        return true
    let fallbackSymbols = compilerCoreDirectExecFallbackCallSymbols(plan, itemIdx, targetTriple)
    if fallbackSymbols.len > 0 &&
       len(compilerCoreDirectExecFallbackCallWords(plan, itemIdx, architecture)) > 0:
        return true
    let nestedVoidSymbols = compilerCoreDirectExecVoidNestedCallSymbols(plan, itemIdx, targetTriple)
    if nestedVoidSymbols.len > 0 &&
       !compilerCoreDirectExecCallSymbolsTargetOutline(nestedVoidSymbols) &&
       len(compilerCoreDirectExecVoidNestedCallWords(plan, itemIdx, targetTriple)) > 0:
        return true
    let directCallSymbol = compilerCoreDirectExecCallSymbol(plan, itemIdx, targetTriple)
    if len(directCallSymbol) > 0 &&
       !compilerCoreDirectExecCallSymbolTargetsOutline(directCallSymbol) &&
       len(compilerCoreDirectExecCallWords(plan, itemIdx, targetTriple, architecture)) > 0:
        return true
    let directVoidCallSymbol = compilerCoreDirectExecVoidCallSymbol(plan, itemIdx, targetTriple)
    if len(directVoidCallSymbol) > 0 &&
       !compilerCoreDirectExecCallSymbolTargetsOutline(directVoidCallSymbol) &&
       len(compilerCoreDirectExecVoidCallWords(plan, itemIdx, architecture)) > 0:
        return true
    return false

fn compilerCoreDirectNestedTrailingArgsMatch(plan: cflow.LowUirCompilerCorePlan,
                                             itemIdx: int32,
                                             innerCalleeIdx: int32,
                                             outerCalleeIdx: int32,
                                             outerArgOpIdxs: int32[],
                                             targetTriple: str,
                                             innerReturnWidth: var int32): bool =
    if innerCalleeIdx < 0 || outerCalleeIdx < 0:
        return false
    innerReturnWidth = compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx])
    if innerReturnWidth < 1 || innerReturnWidth > 2:
        return false
    if plan.paramCounts[outerCalleeIdx] != outerArgOpIdxs.len + 1:
        return false
    if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) != innerReturnWidth:
        return false
    var needsDirectOuterBody: bool = innerReturnWidth == 2
    for i in 0..<outerArgOpIdxs.len:
        let outerArgWidth = compilerCoreDirectNestedArgRegWidth(plan, itemIdx, outerArgOpIdxs[i])
        if outerArgWidth <= 0 || outerArgWidth > 2:
            return false
        if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], i + 1)) != outerArgWidth:
            return false
        if outerArgWidth == 2:
            needsDirectOuterBody = true
    if needsDirectOuterBody && (outerCalleeIdx == itemIdx ||
       !compilerCoreHasDirectExecBody(plan, outerCalleeIdx, targetTriple)):
        return false
    return true

fn compilerCoreDirectNestedLeadingArgsMatch(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32,
                                            innerCalleeIdx: int32,
                                            outerCalleeIdx: int32,
                                            outerArgOpIdxs: int32[],
                                            targetTriple: str,
                                            innerReturnWidth: var int32): bool =
    if innerCalleeIdx < 0 || outerCalleeIdx < 0:
        return false
    innerReturnWidth = compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx])
    if innerReturnWidth < 1 || innerReturnWidth > 2:
        return false
    if plan.paramCounts[outerCalleeIdx] != outerArgOpIdxs.len + 1:
        return false
    var needsDirectOuterBody: bool = innerReturnWidth == 2
    for i in 0..<outerArgOpIdxs.len:
        let outerArgWidth = compilerCoreDirectNestedArgRegWidth(plan, itemIdx, outerArgOpIdxs[i])
        if outerArgWidth <= 0 || outerArgWidth > 2:
            return false
        if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], i)) != outerArgWidth:
            return false
        if outerArgWidth == 2:
            needsDirectOuterBody = true
    if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx],
                                                                         outerArgOpIdxs.len)) != innerReturnWidth:
        return false
    if needsDirectOuterBody && (outerCalleeIdx == itemIdx ||
       !compilerCoreHasDirectExecBody(plan, outerCalleeIdx, targetTriple)):
        return false
    return true

fn compilerCoreIsDirectConstValueKind(kind: str): bool =
    return kind == "load_int32" ||
           kind == "load_bool" ||
           kind == "load_nil"

fn compilerCoreResolveDirectCallArg(plan: cflow.LowUirCompilerCorePlan,
                                    opIdx: int32,
                                    aliasSlot: int32,
                                    aliasInitKind: str,
                                    aliasInitPrimaryText: str,
                                    aliasInitArg0: int32,
                                    resolvedKind: var str,
                                    resolvedPrimaryText: var str,
                                    resolvedArg0: var int32): bool =
    if plan.opKinds[opIdx] == "load_local" && plan.opArg0s[opIdx] == aliasSlot:
        if !compilerCoreIsDirectSimpleValueKind(aliasInitKind):
            return false
        resolvedKind = aliasInitKind
        resolvedPrimaryText = aliasInitPrimaryText
        resolvedArg0 = aliasInitArg0
        return true
    if compilerCoreIsDirectSimpleValueKind(plan.opKinds[opIdx]):
        resolvedKind = plan.opKinds[opIdx]
        resolvedPrimaryText = plan.opPrimaryTexts[opIdx]
        resolvedArg0 = plan.opArg0s[opIdx]
        return true
    return false

fn compilerCoreIsIdentityScalarCastLabel(label: str): bool =
    return label == "int" || label == "int32"

fn compilerCoreIsIdentityScalarCastSourceType(typeText: str): bool =
    return compilerCoreTypeMatches(typeText, "int") || compilerCoreTypeMatches(typeText, "int32")

fn compilerCoreResolveDirectIdentityScalarCastArg(plan: cflow.LowUirCompilerCorePlan,
                                                  itemIdx: int32,
                                                  opIdx: int32,
                                                  resolvedKind: var str,
                                                  resolvedPrimaryText: var str,
                                                  resolvedArg0: var int32,
                                                  consumedOps: var int32): bool =
    if opIdx + 2 >= plan.opKinds.len ||
       plan.opKinds[opIdx] != "load_routine" ||
       plan.opKinds[opIdx + 2] != "call" ||
       plan.opArg0s[opIdx + 2] != 1:
        return false
    let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opIdx, 1)
    if calleeItemIdx < 0 || !compilerCoreIsIdentityScalarCastLabel(plan.labels[calleeItemIdx]):
        return false
    if plan.opKinds[opIdx + 1] == "load_param":
        let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opIdx + 1])
        if compilerCoreDirectTypeRegWidth(paramTypeText) != 1 ||
           !compilerCoreIsIdentityScalarCastSourceType(paramTypeText):
            return false
        resolvedKind = plan.opKinds[opIdx + 1]
        resolvedPrimaryText = plan.opPrimaryTexts[opIdx + 1]
        resolvedArg0 = plan.opArg0s[opIdx + 1]
        consumedOps = 3
        return true
    return false

fn compilerCoreDirectLeadingCurrentParamTypeText(plan: cflow.LowUirCompilerCorePlan,
                                                 itemIdx: int32,
                                                 argKind: str,
                                                 argPrimaryText: str,
                                                 argArg0: int32): str =
    if argKind == "load_param":
        if compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], argArg0) != 0:
            return ""
        let argTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], argArg0)
        let regWidth = compilerCoreDirectTypeRegWidth(argTypeText)
        return regWidth >= 1 && regWidth <= 2 ? argTypeText else: ""
    if argKind == "load_param_cast":
        if compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], argArg0) != 0:
            return ""
        if !compilerCoreIsIdentityScalarCastSourceType(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx],
                                                                                          argArg0)):
            return ""
        let regWidth = compilerCoreDirectTypeRegWidth(argPrimaryText)
        return regWidth >= 1 && regWidth <= 2 ? argPrimaryText else: ""
    return ""

fn compilerCoreMatchDirectIdentityScalarCallArgs(plan: cflow.LowUirCompilerCorePlan,
                                                 itemIdx: int32,
                                                 firstOpIdx: int32,
                                                 callOpIdx: int32,
                                                 argCount: int32,
                                                 argKinds: var str[],
                                                 argPrimaryTexts: var str[],
                                                 argArg0s: var int32[],
                                                 sawIdentityCast: var bool): bool =
    argKinds = []
    argPrimaryTexts = []
    argArg0s = []
    sawIdentityCast = false
    var scanIdx: int32 = firstOpIdx
    for i in 0..<argCount:
        if scanIdx >= callOpIdx:
            return false
        if compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, scanIdx):
            add(argKinds, plan.opKinds[scanIdx])
            add(argPrimaryTexts, plan.opPrimaryTexts[scanIdx])
            add(argArg0s, plan.opArg0s[scanIdx])
            scanIdx = scanIdx + 1
            continue
        var resolvedKind: str = ""
        var resolvedPrimaryText: str = ""
        var resolvedArg0: int32 = -1
        var consumedOps: int32 = 0
        if !compilerCoreResolveDirectIdentityScalarCastArg(plan,
                                                           itemIdx,
                                                           scanIdx,
                                                           resolvedKind,
                                                           resolvedPrimaryText,
                                                           resolvedArg0,
                                                           consumedOps):
            return false
        add(argKinds, resolvedKind)
        add(argPrimaryTexts, resolvedPrimaryText)
        add(argArg0s, resolvedArg0)
        sawIdentityCast = true
        scanIdx = scanIdx + consumedOps
    return scanIdx == callOpIdx

fn compilerCoreDirectExecLocalAliasWords(plan: cflow.LowUirCompilerCorePlan,
                                         itemIdx: int32,
                                         architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "local_decl" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "store_local" &&
       plan.opKinds[opStart + 3] == "load_local" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 2] &&
       plan.opArg0s[opStart + 2] == plan.opArg0s[opStart + 3]:
        return machineDirectReturnSimpleValueWords(architecture,
                                                   plan.opKinds[opStart + 1],
                                                   plan.opPrimaryTexts[opStart + 1],
                                                   plan.opArg0s[opStart + 1])
    return ""

fn compilerCoreDirectExecFieldWords(plan: cflow.LowUirCompilerCorePlan,
                                    itemIdx: int32,
                                    architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 3 &&
       plan.paramCounts[itemIdx] == 1 &&
       plan.opKinds[opStart] == "load_param" &&
       plan.opArg0s[opStart] == 0 &&
       plan.opKinds[opStart + 1] == "load_field" &&
       plan.opKinds[opStart + 2] == "return_value":
        let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
        var aggregateResultTypeText: str = ""
        var sourceReg0: int32 = -1
        var sourceReg1: int32 = -1
        var sourceReg1Is64: bool = false
        if compilerCoreDirectAggregateFieldBinding(paramTypeText,
                                                   plan.opPrimaryTexts[opStart + 1],
                                                   aggregateResultTypeText,
                                                   sourceReg0,
                                                   sourceReg1,
                                                   sourceReg1Is64) &&
           compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], aggregateResultTypeText):
            return machineDirectReturnRegisterPairWords(architecture,
                                                        sourceReg0,
                                                        sourceReg1,
                                                        sourceReg1Is64)
        var sourceReg: int32 = -1
        var is64: bool = false
        if compilerCoreDirectFieldReturnBinding(paramTypeText,
                                               plan.opPrimaryTexts[opStart + 1],
                                               sourceReg,
                                               is64):
            return machineDirectReturnRegisterWords(architecture, sourceReg, is64)
    return ""

fn compilerCoreDirectExecUnaryFieldWords(plan: cflow.LowUirCompilerCorePlan,
                                         itemIdx: int32,
                                         architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 4 ||
       plan.paramCounts[itemIdx] != 1 ||
       plan.opKinds[opStart] != "load_param" ||
       plan.opArg0s[opStart] != 0 ||
       plan.opKinds[opStart + 1] != "load_field" ||
       plan.opKinds[opStart + 3] != "return_value":
        return ""
    let opKind = plan.opKinds[opStart + 2]
    if opKind != "unary_not" && opKind != "unary_neg":
        return ""
    let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
    var sourceReg: int32 = -1
    var is64: bool = false
    if !compilerCoreDirectFieldReturnBinding(paramTypeText,
                                             plan.opPrimaryTexts[opStart + 1],
                                             sourceReg,
                                             is64):
        return ""
    return machineDirectUnaryRegisterWords(architecture, opKind, sourceReg, is64)

fn compilerCoreDirectExecNestedFieldWords(plan: cflow.LowUirCompilerCorePlan,
                                          itemIdx: int32,
                                          architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 4 ||
       plan.opKinds[opStart] != "load_param" ||
       plan.opKinds[opStart + 1] != "load_field" ||
       plan.opKinds[opStart + 2] != "load_field" ||
       plan.opKinds[opStart + 3] != "return_value":
        return ""
    var sourceReg: int32 = -1
    var is64: bool = false
    if !compilerCoreDirectParamNestedFieldReturnBinding(plan.signatureTexts[itemIdx],
                                                        plan.opArg0s[opStart],
                                                        plan.opPrimaryTexts[opStart + 1],
                                                        plan.opPrimaryTexts[opStart + 2],
                                                        sourceReg,
                                                        is64):
        return ""
    return machineDirectReturnRegisterWords(architecture, sourceReg, is64)

fn compilerCoreDirectExecTripleFieldWords(plan: cflow.LowUirCompilerCorePlan,
                                          itemIdx: int32,
                                          architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 5 ||
       plan.opKinds[opStart] != "load_param" ||
       plan.opKinds[opStart + 1] != "load_field" ||
       plan.opKinds[opStart + 2] != "load_field" ||
       plan.opKinds[opStart + 3] != "load_field" ||
       plan.opKinds[opStart + 4] != "return_value":
        return ""
    var sourceReg: int32 = -1
    var is64: bool = false
    if !compilerCoreDirectParamTripleFieldReturnBinding(plan.signatureTexts[itemIdx],
                                                        plan.opArg0s[opStart],
                                                        plan.opPrimaryTexts[opStart + 1],
                                                        plan.opPrimaryTexts[opStart + 2],
                                                        plan.opPrimaryTexts[opStart + 3],
