    words = machineAarch64PrologueWords()
    argKinds = []
    argPrimaryTexts = []
    argArg0s = []
    add(argKinds, argKind)
    add(argPrimaryTexts, argPrimaryText)
    add(argArg0s, argArg0)
    if !machineAppendLoadSimpleCallArgsWords(architecture, words, argKinds, argPrimaryTexts, argArg0s):
        return ""
    add(words, "94000000")
