type
    MachineModuleBundle =
        version: str
        moduleKind: str
        targetTriple: str
        architecture: str
        objFormat: str
        symbolPrefix: str
        textSectionName: str
        cstringSectionName: str
        callRelocationKind: str
        metadataPageRelocationKind: str
        metadataPageoffRelocationKind: str
        regalloc: str
        pointerWidthBits: int32
        stackAlignBytes: int32
        entrySymbolOverride: str
        itemIds: int32[]
        symbolNames: str[]
        runtimeTargets: str[]
        callSymbolNames: str[]
        frameSizes: int32[]
        stackAligns: int32[]
        argRegs: str[]
        scratchRegs: str[]
        calleeSavedRegs: str[]
        bindingSummaries: str[]
        instructionWordHex: str[]
        functionByteSizes: int32[]
        localPayloadPageRelocOffsets: int32[]
        localPayloadPageoffRelocOffsets: int32[]
        callRelocOffsets: int32[]
        metadataOperandModes: str[]
        localPayloadTexts: str[]
        functionRelocStarts: int32[]
        functionRelocCounts: int32[]
        relocOffsets: int32[]
        relocSymbols: str[]
        relocKinds: str[]
        dataSymbolNames: str[]
        dataSymbolBindings: str[]
        dataSectionNames: str[]
        dataPayloadTexts: str[]
        dataAlignPow2: int32[]

fn machinePipelineVersion(): str =
    return "v2.machine_pipeline.v1"

fn sanitizeSymbolPart(text: str): str =
    var out: str = ""
    for i in 0..<text.len:
        let ch = text[i]
        if (ch >= 'a' && ch <= 'z') ||
           (ch >= 'A' && ch <= 'Z') ||
           (ch >= '0' && ch <= '9'):
            out = out + strings.sliceBytes(text, i, 1)
        else:
            out = out + "_"
    return out

fn joinWithSep(values: str[], sep: str): str =
    var out: str = ""
    for i in 0..<values.len:
        if i > 0:
            out = out + sep
        out = out + values[i]
    return out

fn bindingSummaryFieldValue(summary: str, key: str): str =
    let prefix = key + "="
    var fieldStart: int32 = 0
    while fieldStart < summary.len:
        var fieldEnd: int32 = fieldStart
        while fieldEnd < summary.len && summary[fieldEnd] != '|':
            fieldEnd = fieldEnd + 1
        if fieldEnd - fieldStart > prefix.len &&
           strings.sliceBytes(summary, fieldStart, prefix.len) == prefix:
            return strings.sliceBytes(summary,
                                      fieldStart + prefix.len,
                                      fieldEnd - fieldStart - prefix.len)
        fieldStart = fieldEnd + 1
    return ""

fn wordCount(words: str): int32 =
    if len(words) == 0:
        return 0
    var count: int32 = 1
    for i in 0..<words.len:
        if words[i] == ';':
            count = count + 1
    return count

fn alignedSize(value: int32, align: int32): int32 =
    if align <= 0:
        return value
    let rem = value % align
    if rem == 0:
        return value
    return value + (align - rem)

fn hexDigitLower(value: int32): char =
    return value < 10 ? char(int32('0') + value) : char(int32('a') + value - 10)

fn uint16HexLower(value: int32): str =
    var out: str = ""
    out = out + charToString(hexDigitLower((value >> 12) & 15))
    out = out + charToString(hexDigitLower((value >> 8) & 15))
    out = out + charToString(hexDigitLower((value >> 4) & 15))
    out = out + charToString(hexDigitLower(value & 15))
    return out

fn uint32HexLower(value: int32): str =
    var out: str = ""
    out = out + uint16HexLower((value >> 16) & 0xffff)
    out = out + uint16HexLower(value & 0xffff)
    return out

fn requireAarch64Architecture(architecture: str) =
    if architecture == "aarch64":
        return
    panic("v2 machine pipeline: unsupported architecture " + architecture)

fn machineArgRegs(architecture: str): str =
    requireAarch64Architecture(architecture)
    return "x0;x1;x2;x3"

fn machineScratchRegs(architecture: str): str =
    requireAarch64Architecture(architecture)
    return "x9;x10"

fn machineCalleeSavedRegs(architecture: str): str =
    requireAarch64Architecture(architecture)
    return "x29;x30"

fn machineStubWords(architecture: str): str =
    requireAarch64Architecture(architecture)
    return "a9bf7bfd;910003fd;90000000;91000000;94000000;a8c17bfd;d65f03c0"

fn machineDispatchEntryWords(architecture: str): str =
    requireAarch64Architecture(architecture)
    return "a9bf7bfd;910003fd;94000000;a8c17bfd;d65f03c0"

fn machineTraceProviderWords(architecture: str): str =
    requireAarch64Architecture(architecture)
    return "a9bf7bfd;910003fd;94000000;52800000;a8c17bfd;d65f03c0"

fn compilerCoreToolingArgvRuntimeTarget(): str =
    return "runtime/compiler_core.tooling_argv_entry"

fn compilerCoreToolingLocalPayloadRuntimeTarget(): str =
    return "runtime/compiler_core.tooling_local_payload_entry"

fn compilerCoreProgramArgvRuntimeTarget(): str =
    return "runtime/compiler_core.program_argv_entry"

fn compilerCoreProgramLocalPayloadRuntimeTarget(): str =
    return "runtime/compiler_core.program_local_payload_entry"

fn compilerCoreExecutionTrackForSourcePath(sourcePath: str): str =
    let toolingSuffix = "/v2/src/tooling/cheng_v2.cheng"
    if sourcePath == "v2/src/tooling/cheng_v2.cheng":
        return "tooling"
    if len(sourcePath) >= len(toolingSuffix) &&
       strings.sliceBytes(sourcePath,
                          len(sourcePath) - len(toolingSuffix),
                          len(toolingSuffix)) == toolingSuffix:
        return "tooling"
    return "program"

fn compilerCoreArgvRuntimeTargetForTrack(track: str): str =
    if track == "program":
        return compilerCoreProgramArgvRuntimeTarget()
    return compilerCoreToolingArgvRuntimeTarget()

fn compilerCoreLocalPayloadRuntimeTargetForTrack(track: str): str =
    if track == "program":
        return compilerCoreProgramLocalPayloadRuntimeTarget()
    return compilerCoreToolingLocalPayloadRuntimeTarget()

fn compilerCoreMachineRuntimeTarget(runtimeTarget: str,
                                    sourcePath: str): str =
    let track = compilerCoreExecutionTrackForSourcePath(sourcePath)
    if runtimeTarget == "runtime/compiler_core.argv_entry" ||
       runtimeTarget == compilerCoreArgvRuntimeTargetForTrack(track):
        return compilerCoreLocalPayloadRuntimeTargetForTrack(track)
    return runtimeTarget

fn machineAarch64MovWideWord(is64: bool, reg: int32, imm16: int32): str =
    let base = is64 ? 0xd2800000 else: 0x52800000
    return uint32HexLower(base | ((imm16 & 0xffff) << 5) | (reg & 31))

fn machineCompareOperatorCond(operatorText: str): str =
    if operatorText == "==":
        return "eq"
    if operatorText == "!=":
        return "ne"
    if operatorText == "<":
        return "lt"
    if operatorText == "<=":
        return "le"
    if operatorText == ">":
        return "gt"
    return "ge"

fn machineAarch64MovZeroWord(reg: int32): str =
    return machineAarch64MovWideWord(true, reg, 0)

fn machineAarch64MovInt32Word(reg: int32, value: int32): str =
    return machineAarch64MovWideWord(false, reg, value)

fn machineAarch64MovRegWord(is64: bool, dstReg: int32, srcReg: int32): str =
    let base = is64 ? 0xaa0003e0 else: 0x2a0003e0
    return uint32HexLower(base | ((srcReg & 31) << 16) | (dstReg & 31))

fn machineAarch64AddImmWord(is64: bool, dstReg: int32, srcReg: int32, imm12: int32): str =
    let base = is64 ? 0x91000000 else: 0x11000000
    return uint32HexLower(base |
                          ((imm12 & 0xfff) << 10) |
                          ((srcReg & 31) << 5) |
                          (dstReg & 31))

fn machineAarch64SubImmWord(is64: bool, dstReg: int32, srcReg: int32, imm12: int32): str =
    let base = is64 ? 0xd1000000 else: 0x51000000
    return uint32HexLower(base |
                          ((imm12 & 0xfff) << 10) |
                          ((srcReg & 31) << 5) |
                          (dstReg & 31))

fn machineAarch64StoreSpWord(is64: bool, srcReg: int32, offsetBytes: int32): str =
    let scaledOffset = is64 ? offsetBytes / 8 else: offsetBytes / 4
    let base = is64 ? 0xf9000000 else: 0xb9000000
    return uint32HexLower(base |
                          ((scaledOffset & 0xfff) << 10) |
                          (31 << 5) |
                          (srcReg & 31))

fn machineAarch64StoreBaseWord(is64: bool, srcReg: int32, baseReg: int32, offsetBytes: int32): str =
    let scaledOffset = is64 ? offsetBytes / 8 else: offsetBytes / 4
    let base = is64 ? 0xf9000000 else: 0xb9000000
    return uint32HexLower(base |
                          ((scaledOffset & 0xfff) << 10) |
                          ((baseReg & 31) << 5) |
                          (srcReg & 31))

fn machineAarch64LoadSpWord(is64: bool, dstReg: int32, offsetBytes: int32): str =
    let scaledOffset = is64 ? offsetBytes / 8 else: offsetBytes / 4
    let base = is64 ? 0xf9400000 else: 0xb9400000
    return uint32HexLower(base |
                          ((scaledOffset & 0xfff) << 10) |
                          (31 << 5) |
                          (dstReg & 31))

fn machineAarch64LoadBaseWord(is64: bool, dstReg: int32, baseReg: int32, offsetBytes: int32): str =
    let scaledOffset = is64 ? offsetBytes / 8 else: offsetBytes / 4
    let base = is64 ? 0xf9400000 else: 0xb9400000
    return uint32HexLower(base |
                          ((scaledOffset & 0xfff) << 10) |
                          ((baseReg & 31) << 5) |
                          (dstReg & 31))

fn machineAarch64AddRegWord(is64: bool, dstReg: int32, lhsReg: int32, rhsReg: int32): str =
    let base = is64 ? 0x8b000000 else: 0x0b000000
    return uint32HexLower(base |
                          ((rhsReg & 31) << 16) |
                          ((lhsReg & 31) << 5) |
                          (dstReg & 31))

fn machineAarch64SubRegWord(is64: bool, dstReg: int32, lhsReg: int32, rhsReg: int32): str =
    let base = is64 ? 0xcb000000 else: 0x4b000000
    return uint32HexLower(base |
                          ((rhsReg & 31) << 16) |
                          ((lhsReg & 31) << 5) |
                          (dstReg & 31))

fn machineAarch64CmpZeroWord(is64: bool, reg: int32): str =
    let base = is64 ? 0xf100001f else: 0x7100001f
    return uint32HexLower(base | ((reg & 31) << 5))

fn machineAarch64CmpRegWord(is64: bool, lhsReg: int32, rhsReg: int32): str =
    let base = is64 ? 0xeb00001f else: 0x6b00001f
    return uint32HexLower(base |
                          ((rhsReg & 31) << 16) |
                          ((lhsReg & 31) << 5))

fn machineAarch64BranchWord(offsetWords: int32): str =
    return uint32HexLower(0x14000000 | (offsetWords & 0x03ffffff))

fn machineAarch64CondCode(name: str): int32 =
    if name == "eq":
        return 0
    if name == "ne":
        return 1
    if name == "lt":
        return 11
    if name == "le":
        return 13
    if name == "gt":
        return 12
    if name == "ge":
        return 10
    panic("v2 machine pipeline: unsupported aarch64 cond code " + name)

fn machineAarch64BranchCondWord(offsetWords: int32, cond: str): str =
    return uint32HexLower(0x54000000 |
                          ((offsetWords & 0x7ffff) << 5) |
                          machineAarch64CondCode(cond))

fn machineAarch64InverseCompareCond(operatorText: str): str =
    if operatorText == "==":
        return "ne"
    if operatorText == "!=":
        return "eq"
    if operatorText == "<":
        return "ge"
    if operatorText == "<=":
        return "gt"
    if operatorText == ">":
        return "le"
    if operatorText == ">=":
        return "lt"
    panic("v2 machine pipeline: unsupported inverse compare op " + operatorText)

fn machineAarch64PrologueWords(): str[] =
    var out: str[]
    out = []
    add(out, "a9bf7bfd")
    add(out, "910003fd")
    return out

fn machineAarch64EpilogueWords(): str[] =
    var out: str[]
    out = []
    add(out, "a8c17bfd")
    add(out, "d65f03c0")
    return out

fn joinWordList(words: str[]): str =
    return joinWithSep(words, ";")

fn machineDirectReturnVoidWords(architecture: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64MovInt32Word(0, 0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectReturnInt32Words(architecture: str, value: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if value < 0 || value > 65535:
        panic("v2 machine pipeline: direct int32 return literal out of range")
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64MovInt32Word(0, value))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectReturnNilWords(architecture: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64MovZeroWord(0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCallWords(architecture: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, "94000000")
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCallCStringArgWords(architecture: str, byteLen: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if byteLen < 0 || byteLen > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, byteLen))
    add(words, "94000000")
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCallSecondCStringArgWords(architecture: str, byteLen: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if byteLen < 0 || byteLen > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64AdrpWord(2, 0))
    add(words, machineAarch64AddImmediateWord(2, 2, 0))
    add(words, machineAarch64MovInt32Word(3, byteLen))
    add(words, "94000000")
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCallCStringThenSimpleArgWords(architecture: str,
                                              simpleKind: str,
                                              simplePrimaryText: str,
                                              simpleArg0: int32,
                                              byteLen: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if byteLen < 0 || byteLen > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, byteLen))
    if !machineAppendLoadSimpleValueWords(architecture,
                                          words,
                                          2,
                                          simpleKind,
                                          simplePrimaryText,
                                          simpleArg0):
        return ""
    add(words, "94000000")
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCallTwoCStringArgsWords(architecture: str,
                                        byteLen0: int32,
                                        byteLen1: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if byteLen0 < 0 || byteLen0 > 65535 || byteLen1 < 0 || byteLen1 > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, byteLen0))
    add(words, machineAarch64AdrpWord(2, 0))
    add(words, machineAarch64AddImmediateWord(2, 2, 0))
    add(words, machineAarch64MovInt32Word(3, byteLen1))
    add(words, "94000000")
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCallRegisterPairSecondCStringIfElseReturnCStringWords(architecture: str,
                                                                      sourceReg0: int32,
                                                                      sourceReg1: int32,
                                                                      sourceReg1Is64: bool,
                                                                      condByteLen: int32,
                                                                      thenByteLen: int32,
                                                                      elseByteLen: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if sourceReg0 < 0 || sourceReg0 > 30 ||
       sourceReg1 < 0 || sourceReg1 > 30 ||
       condByteLen < 0 || condByteLen > 65535 ||
       thenByteLen < 0 || thenByteLen > 65535 ||
       elseByteLen < 0 || elseByteLen > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    var loadReg1: int32 = sourceReg1
    let tempReg = sourceReg0 == 9 ? 10 else: 9
    if sourceReg1 == 0 && sourceReg0 != 0:
        add(words, machineAarch64MovRegWord(true, tempReg, 0))
        loadReg1 = tempReg
    if sourceReg0 != 0:
        add(words, machineAarch64MovRegWord(true, 0, sourceReg0))
    if loadReg1 != 1:
        add(words, machineAarch64MovRegWord(sourceReg1Is64, 1, loadReg1))
    add(words, machineAarch64AdrpWord(2, 0))
    add(words, machineAarch64AddImmediateWord(2, 2, 0))
    add(words, machineAarch64MovInt32Word(3, condByteLen))
    add(words, "94000000")
    add(words, machineAarch64CmpZeroWord(false, 0))
    let elseBranchIdx = words.len
    add(words, "")
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, thenByteLen))
    let endBranchIdx = words.len
    add(words, "")
    let elseStartIdx = words.len
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, elseByteLen))
    let epilogueStartIdx = words.len
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[elseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - elseBranchIdx, "eq")
    words[endBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdx)
    return joinWordList(words)

fn machineDirectCallRegisterPairSecondCStringIfElseChainReturnCStringWords(architecture: str,
                                                                           sourceReg0: int32,
                                                                           sourceReg1: int32,
                                                                           sourceReg1Is64: bool,
                                                                           condByteLen0: int32,
                                                                           thenByteLen0: int32,
                                                                           condByteLen1: int32,
                                                                           thenByteLen1: int32,
                                                                           elseByteLen: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if sourceReg0 < 0 || sourceReg0 > 30 ||
       sourceReg1 < 0 || sourceReg1 > 30 ||
       condByteLen0 < 0 || condByteLen0 > 65535 ||
       thenByteLen0 < 0 || thenByteLen0 > 65535 ||
       condByteLen1 < 0 || condByteLen1 > 65535 ||
       thenByteLen1 < 0 || thenByteLen1 > 65535 ||
       elseByteLen < 0 || elseByteLen > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64SubImmWord(true, 31, 31, 16))
    add(words, machineAarch64StoreSpWord(true, sourceReg0, 0))
    add(words, machineAarch64StoreSpWord(sourceReg1Is64, sourceReg1, 8))
    add(words, machineAarch64LoadSpWord(true, 0, 0))
    add(words, machineAarch64LoadSpWord(sourceReg1Is64, 1, 8))
    add(words, machineAarch64AdrpWord(2, 0))
    add(words, machineAarch64AddImmediateWord(2, 2, 0))
    add(words, machineAarch64MovInt32Word(3, condByteLen0))
    add(words, "94000000")
    add(words, machineAarch64CmpZeroWord(false, 0))
    let secondCheckBranchIdx = words.len
    add(words, "")
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, thenByteLen0))
    let firstEndBranchIdx = words.len
    add(words, "")
    let secondCheckStartIdx = words.len
    add(words, machineAarch64LoadSpWord(true, 0, 0))
    add(words, machineAarch64LoadSpWord(sourceReg1Is64, 1, 8))
    add(words, machineAarch64AdrpWord(2, 0))
    add(words, machineAarch64AddImmediateWord(2, 2, 0))
    add(words, machineAarch64MovInt32Word(3, condByteLen1))
    add(words, "94000000")
    add(words, machineAarch64CmpZeroWord(false, 0))
    let elseBranchIdx = words.len
    add(words, "")
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, thenByteLen1))
    let secondEndBranchIdx = words.len
    add(words, "")
    let elseStartIdx = words.len
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, elseByteLen))
    let epilogueStartIdx = words.len
    add(words, machineAarch64AddImmWord(true, 31, 31, 16))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[secondCheckBranchIdx] = machineAarch64BranchCondWord(secondCheckStartIdx - secondCheckBranchIdx, "eq")
    words[firstEndBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - firstEndBranchIdx)
    words[elseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - elseBranchIdx, "eq")
    words[secondEndBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - secondEndBranchIdx)
    return joinWordList(words)

fn machineDirectCallRegisterPairSecondCStringTwoIfOrReturnCStringWords(architecture: str,
                                                                       sourceReg0: int32,
                                                                       sourceReg1: int32,
                                                                       sourceReg1Is64: bool,
                                                                       condByteLen0: int32,
                                                                       thenByteLen0: int32,
                                                                       condByteLen1: int32,
                                                                       thenByteLen1: int32,
                                                                       condByteLen2: int32,
                                                                       thenByteLen2: int32,
                                                                       condByteLen3: int32,
                                                                       thenByteLen3: int32,
                                                                       elseByteLen: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if sourceReg0 < 0 || sourceReg0 > 30 ||
       sourceReg1 < 0 || sourceReg1 > 30 ||
       condByteLen0 < 0 || condByteLen0 > 65535 ||
       thenByteLen0 < 0 || thenByteLen0 > 65535 ||
       condByteLen1 < 0 || condByteLen1 > 65535 ||
       thenByteLen1 < 0 || thenByteLen1 > 65535 ||
       condByteLen2 < 0 || condByteLen2 > 65535 ||
       thenByteLen2 < 0 || thenByteLen2 > 65535 ||
       condByteLen3 < 0 || condByteLen3 > 65535 ||
       thenByteLen3 < 0 || thenByteLen3 > 65535 ||
       elseByteLen < 0 || elseByteLen > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64SubImmWord(true, 31, 31, 16))
    add(words, machineAarch64StoreSpWord(true, sourceReg0, 0))
    add(words, machineAarch64StoreSpWord(sourceReg1Is64, sourceReg1, 8))
    add(words, machineAarch64LoadSpWord(true, 0, 0))
    add(words, machineAarch64LoadSpWord(sourceReg1Is64, 1, 8))
    add(words, machineAarch64AdrpWord(2, 0))
    add(words, machineAarch64AddImmediateWord(2, 2, 0))
    add(words, machineAarch64MovInt32Word(3, condByteLen0))
    add(words, "94000000")
    add(words, machineAarch64CmpZeroWord(false, 0))
    let firstOrSecondCheckBranchIdx = words.len
    add(words, "")
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, thenByteLen0))
    let firstThenEndBranchIdx = words.len
    add(words, "")
    let firstOrSecondCheckStartIdx = words.len
    add(words, machineAarch64LoadSpWord(true, 0, 0))
    add(words, machineAarch64LoadSpWord(sourceReg1Is64, 1, 8))
    add(words, machineAarch64AdrpWord(2, 0))
    add(words, machineAarch64AddImmediateWord(2, 2, 0))
    add(words, machineAarch64MovInt32Word(3, condByteLen1))
    add(words, "94000000")
    add(words, machineAarch64CmpZeroWord(false, 0))
    let secondIfFirstCheckBranchIdx = words.len
    add(words, "")
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, thenByteLen1))
    let secondThenEndBranchIdx = words.len
    add(words, "")
    let secondIfFirstCheckStartIdx = words.len
    add(words, machineAarch64LoadSpWord(true, 0, 0))
    add(words, machineAarch64LoadSpWord(sourceReg1Is64, 1, 8))
    add(words, machineAarch64AdrpWord(2, 0))
    add(words, machineAarch64AddImmediateWord(2, 2, 0))
    add(words, machineAarch64MovInt32Word(3, condByteLen2))
    add(words, "94000000")
    add(words, machineAarch64CmpZeroWord(false, 0))
    let secondIfSecondCheckBranchIdx = words.len
    add(words, "")
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, thenByteLen2))
    let thirdThenEndBranchIdx = words.len
    add(words, "")
    let secondIfSecondCheckStartIdx = words.len
    add(words, machineAarch64LoadSpWord(true, 0, 0))
    add(words, machineAarch64LoadSpWord(sourceReg1Is64, 1, 8))
    add(words, machineAarch64AdrpWord(2, 0))
    add(words, machineAarch64AddImmediateWord(2, 2, 0))
    add(words, machineAarch64MovInt32Word(3, condByteLen3))
    add(words, "94000000")
    add(words, machineAarch64CmpZeroWord(false, 0))
    let elseBranchIdx = words.len
    add(words, "")
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, thenByteLen3))
    let fourthThenEndBranchIdx = words.len
    add(words, "")
    let elseStartIdx = words.len
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, elseByteLen))
    let epilogueStartIdx = words.len
    add(words, machineAarch64AddImmWord(true, 31, 31, 16))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    words[firstOrSecondCheckBranchIdx] = machineAarch64BranchCondWord(firstOrSecondCheckStartIdx - firstOrSecondCheckBranchIdx,
                                                                       "eq")
    words[firstThenEndBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - firstThenEndBranchIdx)
    words[secondIfFirstCheckBranchIdx] = machineAarch64BranchCondWord(secondIfFirstCheckStartIdx - secondIfFirstCheckBranchIdx,
                                                                      "eq")
    words[secondThenEndBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - secondThenEndBranchIdx)
    words[secondIfSecondCheckBranchIdx] = machineAarch64BranchCondWord(secondIfSecondCheckStartIdx - secondIfSecondCheckBranchIdx,
                                                                       "eq")
    words[thirdThenEndBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - thirdThenEndBranchIdx)
    words[elseBranchIdx] = machineAarch64BranchCondWord(elseStartIdx - elseBranchIdx, "eq")
    words[fourthThenEndBranchIdx] = machineAarch64BranchWord(epilogueStartIdx - fourthThenEndBranchIdx)
    return joinWordList(words)

fn machineDirectCallRegisterPairSecondCStringChainReturnCStringWords(architecture: str,
                                                                     sourceReg0: int32,
                                                                     sourceReg1: int32,
                                                                     sourceReg1Is64: bool,
                                                                     condByteLens: int32[],
                                                                     returnByteLens: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if condByteLens.len < 1 || returnByteLens.len != condByteLens.len + 1:
        return ""
    if sourceReg0 < 0 || sourceReg0 > 30 ||
       sourceReg1 < 0 || sourceReg1 > 30:
        return ""
    for i in 0..<condByteLens.len:
        if condByteLens[i] < 0 || condByteLens[i] > 65535 ||
           returnByteLens[i] < 0 || returnByteLens[i] > 65535:
            return ""
    if returnByteLens[returnByteLens.len - 1] < 0 || returnByteLens[returnByteLens.len - 1] > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64SubImmWord(true, 31, 31, 16))
    add(words, machineAarch64StoreSpWord(true, sourceReg0, 0))
    add(words, machineAarch64StoreSpWord(sourceReg1Is64, sourceReg1, 8))
    var missBranchIdxs: int32[]
    missBranchIdxs = []
    var nextCheckStartIdxs: int32[]
    nextCheckStartIdxs = []
    var endBranchIdxs: int32[]
    endBranchIdxs = []
    for i in 0..<condByteLens.len:
        add(words, machineAarch64LoadSpWord(true, 0, 0))
        add(words, machineAarch64LoadSpWord(sourceReg1Is64, 1, 8))
        add(words, machineAarch64AdrpWord(2, 0))
        add(words, machineAarch64AddImmediateWord(2, 2, 0))
        add(words, machineAarch64MovInt32Word(3, condByteLens[i]))
        add(words, "94000000")
        add(words, machineAarch64CmpZeroWord(false, 0))
        add(missBranchIdxs, words.len)
        add(words, "")
        add(words, "90000000")
        add(words, "91000000")
        add(words, machineAarch64MovInt32Word(1, returnByteLens[i]))
        add(endBranchIdxs, words.len)
        add(words, "")
        if i + 1 < condByteLens.len:
            add(nextCheckStartIdxs, words.len)
    let elseStartIdx = words.len
    add(words, "90000000")
    add(words, "91000000")
    add(words, machineAarch64MovInt32Word(1, returnByteLens[returnByteLens.len - 1]))
    let epilogueStartIdx = words.len
    add(words, machineAarch64AddImmWord(true, 31, 31, 16))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    for i in 0..<missBranchIdxs.len:
        if i + 1 < missBranchIdxs.len:
            words[missBranchIdxs[i]] = machineAarch64BranchCondWord(nextCheckStartIdxs[i] - missBranchIdxs[i], "eq")
        else:
            words[missBranchIdxs[i]] = machineAarch64BranchCondWord(elseStartIdx - missBranchIdxs[i], "eq")
        words[endBranchIdxs[i]] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdxs[i])
    return joinWordList(words)

fn machineDirectCallRegisterPairSecondCStringChainReturnInt32Words(architecture: str,
                                                                   sourceReg0: int32,
                                                                   sourceReg1: int32,
                                                                   sourceReg1Is64: bool,
                                                                   condByteLens: int32[],
                                                                   returnValues: int32[]): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    if condByteLens.len < 1 || returnValues.len != condByteLens.len + 1:
        return ""
    if sourceReg0 < 0 || sourceReg0 > 30 ||
       sourceReg1 < 0 || sourceReg1 > 30:
        return ""
    for i in 0..<condByteLens.len:
        if condByteLens[i] < 0 || condByteLens[i] > 65535 ||
           returnValues[i] < 0 || returnValues[i] > 65535:
            return ""
    if returnValues[returnValues.len - 1] < 0 || returnValues[returnValues.len - 1] > 65535:
        return ""
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, machineAarch64SubImmWord(true, 31, 31, 16))
    add(words, machineAarch64StoreSpWord(true, sourceReg0, 0))
    add(words, machineAarch64StoreSpWord(sourceReg1Is64, sourceReg1, 8))
    var missBranchIdxs: int32[]
    missBranchIdxs = []
    var nextCheckStartIdxs: int32[]
    nextCheckStartIdxs = []
    var endBranchIdxs: int32[]
    endBranchIdxs = []
    for i in 0..<condByteLens.len:
        add(words, machineAarch64LoadSpWord(true, 0, 0))
        add(words, machineAarch64LoadSpWord(sourceReg1Is64, 1, 8))
        add(words, machineAarch64AdrpWord(2, 0))
        add(words, machineAarch64AddImmediateWord(2, 2, 0))
        add(words, machineAarch64MovInt32Word(3, condByteLens[i]))
        add(words, "94000000")
        add(words, machineAarch64CmpZeroWord(false, 0))
        add(missBranchIdxs, words.len)
        add(words, "")
        add(words, machineAarch64MovInt32Word(0, returnValues[i]))
        add(endBranchIdxs, words.len)
        add(words, "")
        if i + 1 < condByteLens.len:
            add(nextCheckStartIdxs, words.len)
    let elseStartIdx = words.len
    add(words, machineAarch64MovInt32Word(0, returnValues[returnValues.len - 1]))
    let epilogueStartIdx = words.len
    add(words, machineAarch64AddImmWord(true, 31, 31, 16))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    for i in 0..<missBranchIdxs.len:
        if i + 1 < missBranchIdxs.len:
            words[missBranchIdxs[i]] = machineAarch64BranchCondWord(nextCheckStartIdxs[i] - missBranchIdxs[i], "eq")
        else:
            words[missBranchIdxs[i]] = machineAarch64BranchCondWord(elseStartIdx - missBranchIdxs[i], "eq")
        words[endBranchIdxs[i]] = machineAarch64BranchWord(epilogueStartIdx - endBranchIdxs[i])
    return joinWordList(words)

fn machineDirectCallVoidWords(architecture: str): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, "94000000")
    add(words, machineAarch64MovZeroWord(0))
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCallVoidThenConstWords(architecture: str,
                                       constKind: str,
                                       constPrimaryText: str,
                                       constArg0: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    add(words, "94000000")
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, constKind, constPrimaryText, constArg0):
        return ""
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

fn machineDirectCallSimpleArgsVoidThenConstWords(architecture: str,
                                                 argKinds: str[],
                                                 argPrimaryTexts: str[],
                                                 argArg0s: int32[],
                                                 constKind: str,
                                                 constPrimaryText: str,
                                                 constArg0: int32): str =
    if architecture != "aarch64":
        panic("v2 machine pipeline: unsupported direct executable architecture " + architecture)
    var words: str[]
    words = machineAarch64PrologueWords()
    if !machineAppendLoadSimpleCallArgsWords(architecture, words, argKinds, argPrimaryTexts, argArg0s):
        return ""
    add(words, "94000000")
    if !machineAppendLoadSimpleValueWords(architecture, words, 0, constKind, constPrimaryText, constArg0):
        return ""
    let epilogue = machineAarch64EpilogueWords()
    for i in 0..<epilogue.len:
        add(words, epilogue[i])
    return joinWordList(words)

