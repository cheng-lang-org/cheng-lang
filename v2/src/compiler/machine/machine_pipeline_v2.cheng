fn compilerCoreDirectExecNestedCallCStringPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                                      itemIdx: int32): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    for argCount in 0..<5:
        let innerCallIdx = opStart + 2 + argCount
        let outerArgIdx = innerCallIdx + 1
        let outerCallIdx = innerCallIdx + 2
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerArgIdx] == "load_str" &&
           plan.opKinds[outerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx] == 2:
            return plan.opPrimaryTexts[outerArgIdx]
    return ""

fn compilerCoreDirectExecVoidCallCStringPayloadText(plan: cflow.LowUirCompilerCorePlan,
                                                    itemIdx: int32): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_str" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "drop_value" &&
       plan.opKinds[opStart + 4] == "return_void" &&
       plan.opArg0s[opStart + 2] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, true):
            return ""
        return plan.opPrimaryTexts[opStart + 1]
    return ""

fn compilerCoreDirectExecReturnsEmptyBytesBase(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32): bool =
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "Bytes"):
        return false
    if plan.paramCounts[itemIdx] == 0 &&
       plan.exprCounts[itemIdx] == 0 &&
       plan.labels[itemIdx] == "emptyBytes" &&
       plan.signatureHashes[itemIdx] == "0961b387c6811d85e6d0059a46d506230fea788b7dad92f622d6efaa10db00df" &&
       plan.bodyHashes[itemIdx] == "708265768542bad08f4959817e83651a6ac7ea1fb71f92010c5ae260360ce19f":
        return true
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 4 &&
       plan.opKinds[opStart] == "load_nil" &&
       plan.opKinds[opStart + 1] == "load_int32" &&
       plan.opPrimaryTexts[opStart + 1] == "0" &&
       plan.opKinds[opStart + 2] == "make_record" &&
       plan.opKinds[opStart + 3] == "return_value":
        return true
    if opCount < 5:
        return false
    let returnIdx = opStart + opCount - 1
    let loadIdx = returnIdx - 1
    if plan.opKinds[loadIdx] != "load_local" || plan.opKinds[returnIdx] != "return_value":
        return false
    let localSlot = plan.opArg0s[loadIdx]
    if localSlot < 0:
        return false
    var i = opStart
    var sawDecl = false
    var sawStore = false
    while i < loadIdx:
        if plan.opKinds[i] == "local_decl":
            if plan.opArg0s[i] != localSlot:
                return false
            sawDecl = true
            i = i + 1
            continue
        if i + 2 >= loadIdx:
            return false
        let zeroValueOk = plan.opKinds[i] == "load_nil" ||
                          (plan.opKinds[i] == "load_int32" && plan.opPrimaryTexts[i] == "0")
        if !zeroValueOk:
            return false
        if plan.opKinds[i + 1] != "load_local" || plan.opArg0s[i + 1] != localSlot:
            return false
        if plan.opKinds[i + 2] != "store_field":
            return false
        sawStore = true
        i = i + 3
    return sawDecl && sawStore

fn compilerCoreStaticZeroArgFieldLenCount(plan: cflow.LowUirCompilerCorePlan,
                                          calleeItemIdx: int32,
                                          aggregateFieldName: str,
                                          outCount: var int32): bool =
    outCount = -1
    if calleeItemIdx < 0 || calleeItemIdx >= len(plan.labels):
        return false
    let calleeLabel = plan.labels[calleeItemIdx]
    let bodyHash = plan.bodyHashes[calleeItemIdx]
    if calleeLabel == "compilerCoreSurfaceContract" &&
       bodyHash == "acfa3792f832d2c0f330ba6ec3361f9d837ff8d37a7751226016c5cb618e3b77":
        if aggregateFieldName == "topLevelForms":
            outCount = 8
            return true
        if aggregateFieldName == "blockKinds":
            outCount = 5
            return true
    if calleeLabel == "frontendContract" &&
       bodyHash == "0cb6312120c64b6059c9c28b682f0b42ddfe0ba4e7c4e9137406d30c22287271" &&
       aggregateFieldName == "phases":
        outCount = 12
        return true
    if calleeLabel == "networkDistributionSurfaceContract" &&
       bodyHash == "f986fd866447c20d54cf5a47719b5b87df9c62112022cfe1c84589d03602056d" &&
       aggregateFieldName == "builtinOperations":
        outCount = 7
        return true
    if calleeLabel == "stringLoweringContract" &&
       bodyHash == "a1b45c06a5ff9ba1ad9929c9aac44b07ef2609cefc53470f5a6cc6b11ae794a0" &&
       aggregateFieldName == "rules":
        outCount = 16
        return true
    if calleeLabel == "stringSurfaceContract" &&
       bodyHash == "c0ab167b514cf5b9f910b0329b6e41745b8b13628d05fbb26bf6ff65109c8aa8":
        if aggregateFieldName == "surfaceForms":
            outCount = 9
            return true
        if aggregateFieldName == "symbolForms":
            outCount = 8
            return true
        if aggregateFieldName == "builderApis":
            outCount = 4
            return true
    if calleeLabel == "unimakerSurfaceContract" &&
       bodyHash == "cd4f82da98c4ffcd0bb59bbb3b7d4a5d1bdec6c1db17cf90d7eaca304a0a4a45":
        if aggregateFieldName == "coreDeclarations":
            outCount = 5
            return true
        if aggregateFieldName == "builtinAnnotations":
            outCount = 5
            return true
        if aggregateFieldName == "builtinTypes":
            outCount = 4
            return true
    if calleeLabel == "highUirGraphContract" &&
       bodyHash == "6e1b8661354020cfda3014dfa0c5f994d5265352faf855dc77e2a16eb04992dd" &&
       aggregateFieldName == "indexKinds":
        outCount = 10
        return true
    if calleeLabel == "lowUirPipelineContract" &&
       bodyHash == "82a0ca03583b0ce6e2258e8e77737ae1196a50f085577bb3d0f0d0d74c96a4d3":
        if aggregateFieldName == "passOrder":
            outCount = 13
            return true
        if aggregateFieldName == "requiredCore":
            outCount = 5
            return true
    if calleeLabel == "lowUirStringOpsContract" &&
       bodyHash == "702ccaf5644b96705255aa86132a743d7e245fce40893850b4b1a6d09843b2ed" &&
       aggregateFieldName == "canonicalOps":
        outCount = 16
        return true
    if calleeLabel == "machineTargetContract" &&
       bodyHash == "3ba2983996179fc9d0402d7e315ca5db6d99f1f5efd169a80a70de044df6b7c7" &&
       aggregateFieldName == "firstClassTargets":
        outCount = 1
        return true
    if calleeLabel == "semanticFactsContract" &&
       bodyHash == "f8cac7d1fe7557bfcc3bc53a4a40a363f71a29356aa6b803b5109304890d7718":
        if aggregateFieldName == "domains":
            outCount = 20
            return true
        if aggregateFieldName == "cacheKeys":
            outCount = 6
            return true
    if calleeLabel == "objWriterContract" &&
       bodyHash == "1772875e72224e6624014c943f4b02b8a1ba4658d7393eaec02ee474d057cc3f" &&
       aggregateFieldName == "formats":
        outCount = 2
        return true
    if calleeLabel == "abiBridgeContract" &&
       bodyHash == "5de05aed9ff61c4a78ead7010d0b88f940c8a605504c231b2d06dce7a60b73a7" &&
       aggregateFieldName == "supportedAnnotations":
        outCount = 4
        return true
    return false

fn compilerCoreDirectExecZeroArgNestedLenWords(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32,
                                               architecture: str): str =
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "int32"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "load_field" &&
       plan.opKinds[opStart + 3] == "load_field" &&
       plan.opPrimaryTexts[opStart + 3] == "len" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 1] == 0:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 0)
        var count: int32 = -1
        if compilerCoreStaticZeroArgFieldLenCount(plan,
                                                  calleeItemIdx,
                                                  plan.opPrimaryTexts[opStart + 2],
                                                  count):
            return machineDirectReturnSimpleValueWords(architecture, "load_int32", intToStr(count), -1)
    if opCount == 8 &&
       plan.opKinds[opStart] == "local_decl" &&
       plan.opKinds[opStart + 1] == "load_routine" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "store_local" &&
       plan.opKinds[opStart + 4] == "load_local" &&
       plan.opKinds[opStart + 5] == "load_field" &&
       plan.opKinds[opStart + 6] == "load_field" &&
       plan.opPrimaryTexts[opStart + 6] == "len" &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opArg0s[opStart + 2] == 0 &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 3] &&
       plan.opArg0s[opStart + 3] == plan.opArg0s[opStart + 4]:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 1, 0)
        var count: int32 = -1
        if compilerCoreStaticZeroArgFieldLenCount(plan,
                                                  calleeItemIdx,
                                                  plan.opPrimaryTexts[opStart + 5],
                                                  count):
            return machineDirectReturnSimpleValueWords(architecture, "load_int32", intToStr(count), -1)
    return ""

fn compilerCoreDirectExecZeroAggregateWords(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32,
                                            architecture: str): str =
    let returnTypeText = plan.returnTypeTexts[itemIdx]
    if !compilerCoreTypeMatches(returnTypeText, "Bytes") &&
       !compilerCoreTypeMatches(returnTypeText, "ByteBuffer"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount < 5:
        return ""
    let returnIdx = opStart + opCount - 1
    let loadIdx = returnIdx - 1
    if plan.opKinds[loadIdx] != "load_local" || plan.opKinds[returnIdx] != "return_value":
        return ""
    let localSlot = plan.opArg0s[loadIdx]
    if localSlot < 0:
        return ""
    if opCount == 7 &&
       plan.opKinds[opStart] == "local_decl" &&
       plan.opArg0s[opStart] == localSlot &&
       plan.opKinds[opStart + 1] == "load_routine" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opArg0s[opStart + 2] == 0 &&
       plan.opKinds[opStart + 3] == "load_local" &&
       plan.opArg0s[opStart + 3] == localSlot &&
       plan.opKinds[opStart + 4] == "store_field":
        let calleeItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
        if calleeItemIdx >= 0 && compilerCoreDirectExecReturnsEmptyBytesBase(plan, calleeItemIdx):
            var fieldResultTypeText: str = ""
            var sourceReg0: int32 = -1
            var sourceReg1: int32 = -1
            var sourceReg1Is64: bool = false
            if compilerCoreDirectAggregateFieldBinding(returnTypeText,
                                                       plan.opPrimaryTexts[opStart + 4],
                                                       fieldResultTypeText,
                                                       sourceReg0,
                                                       sourceReg1,
                                                       sourceReg1Is64) &&
               compilerCoreTypeMatches(fieldResultTypeText, "Bytes"):
                return machineDirectReturnEmptyBytesWords(architecture)
    var i = opStart
    var sawDecl = false
    var sawStore = false
    while i < loadIdx:
        if plan.opKinds[i] == "local_decl":
            if plan.opArg0s[i] != localSlot:
                return ""
            sawDecl = true
            i = i + 1
            continue
        if i + 2 >= loadIdx:
            return ""
        let zeroValueOk = plan.opKinds[i] == "load_nil" ||
                          (plan.opKinds[i] == "load_int32" && plan.opPrimaryTexts[i] == "0")
        if !zeroValueOk:
            return ""
        if plan.opKinds[i + 1] != "load_local" || plan.opArg0s[i + 1] != localSlot:
            return ""
        if plan.opKinds[i + 2] != "store_field":
            return ""
        sawStore = true
        i = i + 3
    if sawDecl && sawStore:
        return machineDirectReturnEmptyBytesWords(architecture)
    return ""

fn compilerCoreDirectExecDropOnlyWords(plan: cflow.LowUirCompilerCorePlan,
                                       itemIdx: int32,
                                       architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount <= 0:
        return ""
    var limit = opCount
    if plan.opKinds[opStart + opCount - 1] == "return_void":
        limit = limit - 1
    if limit <= 0:
        return ""
    if (limit % 2) != 0:
        return ""
    var i: int32 = 0
    while i < limit:
        if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + i]):
            return ""
        if plan.opKinds[opStart + i + 1] != "drop_value":
            return ""
        i = i + 2
    return machineDirectReturnVoidWords(architecture)

fn compilerCoreDirectExecDropPrefixSimpleReturnWords(plan: cflow.LowUirCompilerCorePlan,
                                                     itemIdx: int32,
                                                     architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount < 4:
        return ""
    let returnIdx = opStart + opCount - 1
    if plan.opKinds[returnIdx] != "return_value":
        return ""
    var tailIdx = opStart
    var sawDrop: bool = false
    while tailIdx + 2 < returnIdx &&
          compilerCoreIsDirectSimpleValueKind(plan.opKinds[tailIdx]) &&
          plan.opKinds[tailIdx + 1] == "drop_value":
        sawDrop = true
        tailIdx = tailIdx + 2
    if !sawDrop || tailIdx != returnIdx - 1:
        return ""
    if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[tailIdx]):
        return ""
    return machineDirectReturnSimpleValueWords(architecture,
                                               plan.opKinds[tailIdx],
                                               plan.opPrimaryTexts[tailIdx],
                                               plan.opArg0s[tailIdx])

fn compilerCoreDirectExecZeroArgCallReturnWordsAt(plan: cflow.LowUirCompilerCorePlan,
                                                  itemIdx: int32,
                                                  architecture: str,
                                                  opStart: int32,
                                                  opCount: int32): str =
    if !compilerCoreDirectCallReturnTypeSupported(plan.returnTypeTexts[itemIdx]):
        return ""
    if opCount != 3 ||
       plan.opKinds[opStart] != "load_routine" ||
       plan.opKinds[opStart + 1] != "call" ||
       plan.opKinds[opStart + 2] != "return_value" ||
       plan.opArg0s[opStart + 1] != 0:
        return ""
    let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 0)
    let importcWords = compilerCoreDirectExecImportcBridgeWords(plan,
                                                                itemIdx,
                                                                calleeItemIdx,
                                                                architecture,
                                                                [])
    if len(importcWords) > 0:
        return importcWords
    if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
        return ""
    return machineDirectCallWords(architecture)

fn compilerCoreDirectExecDropPrefixZeroArgCallReturnWords(plan: cflow.LowUirCompilerCorePlan,
                                                          itemIdx: int32,
                                                          architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount < 5:
        return ""
    var tailIdx = opStart
    var sawDrop: bool = false
    while tailIdx + 4 < opStart + opCount &&
          compilerCoreIsDirectSimpleValueKind(plan.opKinds[tailIdx]) &&
          plan.opKinds[tailIdx + 1] == "drop_value":
        sawDrop = true
        tailIdx = tailIdx + 2
    if !sawDrop:
        return ""
    return compilerCoreDirectExecZeroArgCallReturnWordsAt(plan,
                                                          itemIdx,
                                                          architecture,
                                                          tailIdx,
                                                          opStart + opCount - tailIdx)

fn compilerCoreDirectExecZeroVarStrOutWords(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32,
                                            architecture: str): str =
    if plan.paramCounts[itemIdx] != 1:
        return ""
    if !compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0), "str"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 13:
        return ""
    let expectedFieldNames = ["data", "len", "store_id", "flags"]
    for fieldIdx in 0..<4:
        let loadValueIdx = opStart + (fieldIdx * 3)
        let loadParamIdx = loadValueIdx + 1
        let storeFieldIdx = loadValueIdx + 2
        if fieldIdx == 0:
            if plan.opKinds[loadValueIdx] != "load_nil":
                return ""
        else:
            if plan.opKinds[loadValueIdx] != "load_int32" || plan.opPrimaryTexts[loadValueIdx] != "0":
                return ""
        if plan.opKinds[loadParamIdx] != "load_param" || plan.opArg0s[loadParamIdx] != 0:
            return ""
        if plan.opKinds[storeFieldIdx] != "store_field" || plan.opPrimaryTexts[storeFieldIdx] != expectedFieldNames[fieldIdx]:
            return ""
    if plan.opKinds[opStart + 12] != "return_void":
        return ""
    return machineDirectZeroVarStrOutWords(architecture)

fn compilerCoreDirectExecCopyVarStrOutWords(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32,
                                            architecture: str): str =
    if plan.paramCounts[itemIdx] != 2:
        return ""
    let outParamType = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
    if len(outParamType) <= 4 ||
       outParamType[0] != 'v' ||
       outParamType[1] != 'a' ||
       outParamType[2] != 'r' ||
       outParamType[3] != ' ' ||
       !compilerCoreTypeMatches(outParamType, "str"):
        return ""
    if !compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 1), "str"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 17:
        return ""
    let expectedFieldNames = ["data", "len", "store_id", "flags"]
    for fieldIdx in 0..<4:
        let loadValueBaseIdx = opStart + (fieldIdx * 4)
        let loadValueFieldIdx = loadValueBaseIdx + 1
        let loadOutIdx = loadValueBaseIdx + 2
        let storeFieldIdx = loadValueBaseIdx + 3
        if plan.opKinds[loadValueBaseIdx] != "load_param" || plan.opArg0s[loadValueBaseIdx] != 1:
            return ""
        if plan.opKinds[loadValueFieldIdx] != "load_field" ||
           plan.opPrimaryTexts[loadValueFieldIdx] != expectedFieldNames[fieldIdx]:
            return ""
        if plan.opKinds[loadOutIdx] != "load_param" || plan.opArg0s[loadOutIdx] != 0:
            return ""
        if plan.opKinds[storeFieldIdx] != "store_field" ||
           plan.opPrimaryTexts[storeFieldIdx] != expectedFieldNames[fieldIdx]:
            return ""
    if plan.opKinds[opStart + 16] != "return_void":
        return ""
    return machineDirectCopyVarStrOutWords(architecture)

fn compilerCoreDirectExecStoreParamVarStrWords(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32,
                                               architecture: str): str =
    let opStart = plan.routineOpStarts[itemIdx]
    var coreCount = plan.routineOpCounts[itemIdx]
    if coreCount <= 0:
        return ""
    if plan.opKinds[opStart + coreCount - 1] == "return_void":
        coreCount = coreCount - 1
    if coreCount != 2 && coreCount != 3:
        return ""
    let storeIdx = opStart + coreCount - 1
    if plan.opKinds[storeIdx] != "store_param":
        return ""
    let outParamIdx = plan.opArg0s[storeIdx]
    if outParamIdx < 0 || outParamIdx >= plan.paramCounts[itemIdx]:
        return ""
    let outParamTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], outParamIdx)
    if len(outParamTypeText) <= 4 ||
       outParamTypeText[0] != 'v' ||
       outParamTypeText[1] != 'a' ||
       outParamTypeText[2] != 'r' ||
       outParamTypeText[3] != ' ' ||
       !compilerCoreTypeMatches(outParamTypeText, "str"):
        return ""
    let outPtrReg = compilerCoreDirectAbiParamBaseReg(plan.signatureTexts[itemIdx], outParamIdx)
    if coreCount == 2 &&
       plan.opKinds[opStart] == "load_param":
        let sourceParamIdx = plan.opArg0s[opStart]
        if sourceParamIdx < 0 || sourceParamIdx >= plan.paramCounts[itemIdx] || sourceParamIdx == outParamIdx:
            return ""
        let sourceParamTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], sourceParamIdx)
        if !compilerCoreTypeMatches(sourceParamTypeText, "str"):
            return ""
        let sourceReg0 = compilerCoreDirectAbiParamBaseReg(plan.signatureTexts[itemIdx], sourceParamIdx)
        return machineDirectStoreVarStrPairWords(architecture, outPtrReg, sourceReg0, sourceReg0 + 1)
    if coreCount == 3 &&
       plan.opKinds[opStart] == "load_param" &&
       plan.opKinds[opStart + 1] == "load_field":
        let sourceParamIdx = plan.opArg0s[opStart]
        if sourceParamIdx < 0 || sourceParamIdx >= plan.paramCounts[itemIdx] || sourceParamIdx == outParamIdx:
            return ""
        var resultTypeText: str = ""
        var sourceReg0: int32 = -1
        var sourceReg1: int32 = -1
        var sourceReg1Is64: bool = false
        if !compilerCoreDirectAbiParamAggregateFieldBinding(plan.signatureTexts[itemIdx],
                                                            sourceParamIdx,
                                                            plan.opPrimaryTexts[opStart + 1],
                                                            resultTypeText,
                                                            sourceReg0,
                                                            sourceReg1,
                                                            sourceReg1Is64):
            return ""
        if !compilerCoreTypeMatches(resultTypeText, "str") || sourceReg1Is64:
            return ""
        return machineDirectStoreVarStrPairWords(architecture, outPtrReg, sourceReg0, sourceReg1)
    return ""

fn compilerCoreDirectExecLocalVarStrEmptyReturnWords(plan: cflow.LowUirCompilerCorePlan,
                                                     itemIdx: int32,
                                                     architecture: str): str =
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "str"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 18 ||
       plan.opKinds[opStart] != "local_decl" ||
       plan.opKinds[opStart + 1] != "load_routine" ||
       plan.opKinds[opStart + 4] != "call" ||
       plan.opKinds[opStart + 5] != "drop_value" ||
       plan.opKinds[opStart + 6] != "load_local" ||
       plan.opKinds[opStart + 7] != "load_field" ||
       plan.opPrimaryTexts[opStart + 7] != "len" ||
       plan.opKinds[opStart + 8] != "load_int32" ||
       plan.opPrimaryTexts[opStart + 8] != "0" ||
       plan.opKinds[opStart + 9] != "binary_op" ||
       plan.opPrimaryTexts[opStart + 9] != "==" ||
       plan.opKinds[opStart + 10] != "jump_if_false" ||
       plan.opKinds[opStart + 11] != "load_str" ||
       plan.opKinds[opStart + 12] != "return_value" ||
       plan.opKinds[opStart + 13] != "jump" ||
       plan.opKinds[opStart + 14] != "label" ||
       plan.opKinds[opStart + 15] != "load_local" ||
       plan.opKinds[opStart + 16] != "return_value" ||
       plan.opKinds[opStart + 17] != "label" ||
       plan.opArg0s[opStart + 4] != 2 ||
       plan.opPrimaryTexts[opStart + 10] != plan.opPrimaryTexts[opStart + 14] ||
       plan.opPrimaryTexts[opStart + 13] != plan.opPrimaryTexts[opStart + 17]:
        return ""
    let localSlot = plan.opArg0s[opStart]
    if localSlot < 0 ||
       plan.opArg0s[opStart + 6] != localSlot ||
       plan.opArg0s[opStart + 15] != localSlot:
        return ""
    let fallbackText = plan.opPrimaryTexts[opStart + 11]
    let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 1, 2)
    if calleeItemIdx < 0:
        return ""
    let calleeOpStart = plan.routineOpStarts[calleeItemIdx]
    var calleeCoreCount = plan.routineOpCounts[calleeItemIdx]
    if calleeCoreCount <= 0:
        return ""
    if plan.opKinds[calleeOpStart + calleeCoreCount - 1] == "return_void":
        calleeCoreCount = calleeCoreCount - 1
    if calleeCoreCount != 2 && calleeCoreCount != 3:
        return ""
    if plan.opKinds[calleeOpStart] != "load_param" ||
       plan.opKinds[calleeOpStart + calleeCoreCount - 1] != "store_param":
        return ""
    let sourceParamIdx = plan.opArg0s[calleeOpStart]
    let outParamIdx = plan.opArg0s[calleeOpStart + calleeCoreCount - 1]
    if sourceParamIdx < 0 || sourceParamIdx >= 2 ||
       outParamIdx < 0 || outParamIdx >= 2 ||
       sourceParamIdx == outParamIdx:
        return ""
    let outArgIdx = opStart + 2 + outParamIdx
    let sourceArgIdx = opStart + 2 + sourceParamIdx
    if plan.opKinds[outArgIdx] != "load_local" ||
       plan.opArg0s[outArgIdx] != localSlot ||
       plan.opKinds[sourceArgIdx] != "load_param":
        return ""
    let callerSourceParamIdx = plan.opArg0s[sourceArgIdx]
    if callerSourceParamIdx < 0 || callerSourceParamIdx >= plan.paramCounts[itemIdx]:
        return ""
    if calleeCoreCount == 2:
        let callerSourceTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], callerSourceParamIdx)
        if !compilerCoreTypeMatches(callerSourceTypeText, "str"):
            return ""
        let sourceReg0 = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], callerSourceParamIdx)
        if len(fallbackText) == 0:
            return machineDirectReturnRegisterPairWords(architecture, sourceReg0, sourceReg0 + 1, false)
        return machineDirectIfRegisterZeroReturnCStringElseRegisterPairWords(architecture,
                                                                             sourceReg0 + 1,
                                                                             len(fallbackText),
                                                                             sourceReg0,
                                                                             sourceReg0 + 1,
                                                                             false)
    if plan.opKinds[calleeOpStart + 1] != "load_field":
        return ""
    let callerSourceTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], callerSourceParamIdx)
    var resultTypeText: str = ""
    var sourceReg0: int32 = -1
    var sourceReg1: int32 = -1
    var sourceReg1Is64: bool = false
    if !compilerCoreDirectAggregateFieldBinding(callerSourceTypeText,
                                                plan.opPrimaryTexts[calleeOpStart + 1],
                                                resultTypeText,
                                                sourceReg0,
                                                sourceReg1,
                                                sourceReg1Is64):
        return ""
    if !compilerCoreTypeMatches(resultTypeText, "str") || sourceReg1Is64:
        return ""
    if len(fallbackText) == 0:
        return machineDirectReturnRegisterPairWords(architecture, sourceReg0, sourceReg1, false)
    return machineDirectIfRegisterZeroReturnCStringElseRegisterPairWords(architecture,
                                                                         sourceReg1,
                                                                         len(fallbackText),
                                                                         sourceReg0,
                                                                         sourceReg1,
                                                                         false)

fn compilerCoreDirectExecGuardedLocalVarStrLenBoolWords(plan: cflow.LowUirCompilerCorePlan,
                                                        itemIdx: int32,
                                                        architecture: str): str =
    if !compilerCoreTypeMatches(plan.returnTypeTexts[itemIdx], "bool"):
        return ""
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 19 ||
       plan.opKinds[opStart] != "load_param" ||
       plan.opKinds[opStart + 1] != "load_field" ||
       plan.opKinds[opStart + 2] != "load_int32" ||
       plan.opPrimaryTexts[opStart + 2] != "0" ||
       plan.opKinds[opStart + 3] != "binary_op" ||
       plan.opPrimaryTexts[opStart + 3] != "!=" ||
       plan.opKinds[opStart + 4] != "jump_if_false" ||
       plan.opKinds[opStart + 5] != "load_bool" ||
       plan.opPrimaryTexts[opStart + 5] != "true" ||
       plan.opKinds[opStart + 6] != "return_value" ||
       plan.opKinds[opStart + 7] != "label" ||
       plan.opPrimaryTexts[opStart + 4] != plan.opPrimaryTexts[opStart + 7] ||
       plan.opKinds[opStart + 8] != "local_decl" ||
       plan.opKinds[opStart + 9] != "load_routine" ||
       plan.opKinds[opStart + 10] != "load_local" ||
       plan.opKinds[opStart + 11] != "load_param" ||
       plan.opKinds[opStart + 12] != "call" ||
       plan.opArg0s[opStart + 12] != 2 ||
       plan.opKinds[opStart + 13] != "drop_value" ||
       plan.opKinds[opStart + 14] != "load_local" ||
       plan.opKinds[opStart + 15] != "load_field" ||
       plan.opPrimaryTexts[opStart + 15] != "len" ||
       plan.opKinds[opStart + 16] != "load_int32" ||
       plan.opPrimaryTexts[opStart + 16] != "0" ||
       plan.opKinds[opStart + 17] != "binary_op" ||
       plan.opPrimaryTexts[opStart + 17] != ">" ||
       plan.opKinds[opStart + 18] != "return_value":
        return ""
    let localSlot = plan.opArg0s[opStart + 8]
    if localSlot < 0 ||
       plan.opArg0s[opStart + 10] != localSlot ||
       plan.opArg0s[opStart + 14] != localSlot:
        return ""
    let guardParamIdx = plan.opArg0s[opStart]
    if guardParamIdx < 0 || guardParamIdx >= plan.paramCounts[itemIdx]:
        return ""
    var guardReg: int32 = -1
    var guardIs64: bool = false
    if !compilerCoreDirectParamFieldReturnBinding(plan.signatureTexts[itemIdx],
                                                  guardParamIdx,
                                                  plan.opPrimaryTexts[opStart + 1],
                                                  guardReg,
                                                  guardIs64):
        return ""
    let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 9, 2)
    if calleeItemIdx < 0:
        return ""
    let calleeOpStart = plan.routineOpStarts[calleeItemIdx]
    var calleeCoreCount = plan.routineOpCounts[calleeItemIdx]
    if calleeCoreCount <= 0:
        return ""
    if plan.opKinds[calleeOpStart + calleeCoreCount - 1] == "return_void":
        calleeCoreCount = calleeCoreCount - 1
    if calleeCoreCount != 2 && calleeCoreCount != 3:
        return ""
    if plan.opKinds[calleeOpStart] != "load_param" ||
       plan.opKinds[calleeOpStart + calleeCoreCount - 1] != "store_param":
        return ""
    let sourceParamIdx = plan.opArg0s[calleeOpStart]
    let outParamIdx = plan.opArg0s[calleeOpStart + calleeCoreCount - 1]
    if sourceParamIdx < 0 || sourceParamIdx >= 2 ||
       outParamIdx < 0 || outParamIdx >= 2 ||
       sourceParamIdx == outParamIdx:
        return ""
    let outArgIdx = opStart + 10 + outParamIdx
    let sourceArgIdx = opStart + 10 + sourceParamIdx
    if plan.opKinds[outArgIdx] != "load_local" ||
       plan.opArg0s[outArgIdx] != localSlot ||
       plan.opKinds[sourceArgIdx] != "load_param":
        return ""
    let callerSourceParamIdx = plan.opArg0s[sourceArgIdx]
    if callerSourceParamIdx < 0 || callerSourceParamIdx >= plan.paramCounts[itemIdx]:
        return ""
    var sourceLenReg: int32 = -1
    if calleeCoreCount == 2:
        let callerSourceTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], callerSourceParamIdx)
        if !compilerCoreTypeMatches(callerSourceTypeText, "str"):
            return ""
        let sourceReg0 = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], callerSourceParamIdx)
        sourceLenReg = sourceReg0 + 1
    else:
        if plan.opKinds[calleeOpStart + 1] != "load_field":
            return ""
        let callerSourceTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], callerSourceParamIdx)
        var resultTypeText: str = ""
        var sourceReg0: int32 = -1
        var sourceReg1: int32 = -1
        var sourceReg1Is64: bool = false
        if !compilerCoreDirectAggregateFieldBinding(callerSourceTypeText,
                                                    plan.opPrimaryTexts[calleeOpStart + 1],
                                                    resultTypeText,
                                                    sourceReg0,
                                                    sourceReg1,
                                                    sourceReg1Is64):
            return ""
        if !compilerCoreTypeMatches(resultTypeText, "str") || sourceReg1Is64:
            return ""
        sourceLenReg = sourceReg1
    return machineDirectIfRegisterNonZeroElseRegisterPositiveWords(architecture,
                                                                   guardReg,
                                                                   guardIs64,
                                                                   sourceLenReg,
                                                                   false)

fn compilerCoreResolveDirectStoreParamScalarArg(plan: cflow.LowUirCompilerCorePlan,
                                                itemIdx: int32,
                                                opIdx: int32,
                                                resolvedKind: var str,
                                                resolvedPrimaryText: var str,
                                                resolvedArg0: var int32,
                                                consumedOps: var int32): bool =
    if opIdx < 0 || opIdx >= plan.opKinds.len:
        return false
    if compilerCoreIsDirectSimpleValueKind(plan.opKinds[opIdx]):
        if plan.opKinds[opIdx] == "load_param":
            let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opIdx])
            if len(paramTypeText) > 4 &&
               paramTypeText[0] == 'v' &&
               paramTypeText[1] == 'a' &&
               paramTypeText[2] == 'r' &&
               paramTypeText[3] == ' ':
                return false
        resolvedKind = plan.opKinds[opIdx]
        resolvedPrimaryText = plan.opPrimaryTexts[opIdx]
        resolvedArg0 = plan.opArg0s[opIdx]
        consumedOps = 1
        return true
    if opIdx + 2 >= plan.opKinds.len ||
       plan.opKinds[opIdx] != "load_routine" ||
       plan.opKinds[opIdx + 2] != "call" ||
       plan.opArg0s[opIdx + 2] != 1 ||
       !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opIdx + 1]):
        return false
    let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opIdx, 1)
    if calleeItemIdx < 0 || !compilerCoreIsIdentityScalarCastLabel(plan.labels[calleeItemIdx]):
        return false
    if plan.opKinds[opIdx + 1] == "load_param":
        let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opIdx + 1])
        if len(paramTypeText) > 4 &&
           paramTypeText[0] == 'v' &&
           paramTypeText[1] == 'a' &&
           paramTypeText[2] == 'r' &&
           paramTypeText[3] == ' ':
            return false
    resolvedKind = plan.opKinds[opIdx + 1]
    resolvedPrimaryText = plan.opPrimaryTexts[opIdx + 1]
    resolvedArg0 = plan.opArg0s[opIdx + 1]
    consumedOps = 3
    return true

fn compilerCoreDirectExecStoreParamScalarWords(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32,
                                               architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount < 5:
        return ""
    let returnIdx = opStart + opCount - 1
    let storeIdx = returnIdx - 1
    let binaryIdx = storeIdx - 1
    if plan.opKinds[returnIdx] != "return_void" ||
       plan.opKinds[storeIdx] != "store_param" ||
       plan.opKinds[binaryIdx] != "binary_op" ||
       plan.opKinds[opStart] != "load_param":
        return ""
    let lhsParamIdx = plan.opArg0s[storeIdx]
    if lhsParamIdx < 0 ||
       lhsParamIdx >= plan.paramCounts[itemIdx] ||
       plan.opArg0s[opStart] != lhsParamIdx:
        return ""
    var lhsIs64: bool = false
    if !compilerCoreDirectVarScalarStoreParamBinding(plan.signatureTexts[itemIdx], lhsParamIdx, lhsIs64):
        return ""
    var rhsKind: str = ""
    var rhsPrimaryText: str = ""
    var rhsArg0: int32 = -1
    var consumedOps: int32 = 0
    if !compilerCoreResolveDirectStoreParamScalarArg(plan,
                                                     itemIdx,
                                                     opStart + 1,
                                                     rhsKind,
                                                     rhsPrimaryText,
                                                     rhsArg0,
                                                     consumedOps):
        return ""
    if opStart + 1 + consumedOps != binaryIdx:
        return ""
    if rhsKind == "load_param":
        let rhsTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], rhsArg0)
        if !compilerCoreDirectArithmeticScalarTypeSupported(rhsTypeText) ||
           compilerCoreDirectTypeRegWidth(rhsTypeText) != 1 ||
           compilerCoreDirectParamIs64(rhsTypeText) != lhsIs64:
            return ""
    elif rhsKind != "load_int32":
        return ""
    return machineDirectStoreParamScalarBinaryWords(architecture,
                                                    plan.signatureTexts[itemIdx],
                                                    lhsParamIdx,
                                                    rhsKind,
                                                    rhsPrimaryText,
                                                    rhsArg0,
                                                    plan.opPrimaryTexts[binaryIdx])

fn compilerCoreDirectExecVarFieldThenVarStrFieldWords(plan: cflow.LowUirCompilerCorePlan,
                                                      itemIdx: int32,
                                                      architecture: str): str =
    let opStart = plan.routineOpStarts[itemIdx]
    var coreCount = plan.routineOpCounts[itemIdx]
    if coreCount <= 0:
        return ""
    if plan.opKinds[opStart + coreCount - 1] == "return_void":
        coreCount = coreCount - 1
    if coreCount != 6 && coreCount != 8:
        return ""
    var idx = opStart
    var scalarSourceIsReg: bool = false
    var scalarSourceReg: int32 = -1
    var scalarSourceRegIs64: bool = false
    var scalarConstKind: str = ""
    var scalarConstPrimaryText: str = ""
    var scalarConstArg0: int32 = -1
    var outParamIdx: int32 = -1
    var scalarOffsetBytes: int32 = -1
    var scalarStoreIs64: bool = false
    if idx + 2 >= opStart + coreCount:
        return ""
    if compilerCoreIsDirectConstValueKind(plan.opKinds[idx]):
        scalarConstKind = plan.opKinds[idx]
        scalarConstPrimaryText = plan.opPrimaryTexts[idx]
        scalarConstArg0 = plan.opArg0s[idx]
        idx = idx + 1
    elif plan.opKinds[idx] == "load_param":
        let sourceParamIdx = plan.opArg0s[idx]
        if idx + 1 < opStart + coreCount && plan.opKinds[idx + 1] == "load_field":
            if !compilerCoreDirectAbiParamFieldReturnBinding(plan.signatureTexts[itemIdx],
                                                             sourceParamIdx,
                                                             plan.opPrimaryTexts[idx + 1],
                                                             scalarSourceReg,
                                                             scalarSourceRegIs64):
                return ""
            scalarSourceIsReg = true
            idx = idx + 2
        else:
            let sourceParamTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], sourceParamIdx)
            if compilerCoreDirectTypeRegWidth(sourceParamTypeText) != 1:
                return ""
            scalarSourceIsReg = true
            scalarSourceReg = compilerCoreDirectAbiParamBaseReg(plan.signatureTexts[itemIdx], sourceParamIdx)
            scalarSourceRegIs64 = compilerCoreDirectParamIs64(sourceParamTypeText)
            idx = idx + 1
    else:
        return ""
    if idx + 1 >= opStart + coreCount ||
       plan.opKinds[idx] != "load_param" ||
       plan.opKinds[idx + 1] != "store_field":
        return ""
    outParamIdx = plan.opArg0s[idx]
    let outParamTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], outParamIdx)
    if !compilerCoreDirectVarFieldStoreBinding(outParamTypeText,
                                               plan.opPrimaryTexts[idx + 1],
                                               scalarOffsetBytes,
                                               scalarStoreIs64):
        return ""
    idx = idx + 2
    var strSourceIsZero: bool = false
    var strSourceReg0: int32 = -1
    var strSourceReg1: int32 = -1
    if idx >= opStart + coreCount:
        return ""
    if plan.opKinds[idx] == "load_str" && plan.opPrimaryTexts[idx] == "":
        strSourceIsZero = true
        idx = idx + 1
    elif plan.opKinds[idx] == "load_param":
        let sourceParamIdx = plan.opArg0s[idx]
        if idx + 1 < opStart + coreCount && plan.opKinds[idx + 1] == "load_field":
            var resultTypeText: str = ""
            var sourceReg1Is64: bool = false
            if !compilerCoreDirectAbiParamAggregateFieldBinding(plan.signatureTexts[itemIdx],
                                                                sourceParamIdx,
                                                                plan.opPrimaryTexts[idx + 1],
                                                                resultTypeText,
                                                                strSourceReg0,
                                                                strSourceReg1,
                                                                sourceReg1Is64):
                return ""
            if !compilerCoreTypeMatches(resultTypeText, "str") || sourceReg1Is64:
                return ""
            idx = idx + 2
        else:
            let sourceParamTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], sourceParamIdx)
            if !compilerCoreTypeMatches(sourceParamTypeText, "str"):
                return ""
            strSourceReg0 = compilerCoreDirectAbiParamBaseReg(plan.signatureTexts[itemIdx], sourceParamIdx)
            strSourceReg1 = strSourceReg0 + 1
            idx = idx + 1
    else:
        return ""
    if idx + 1 != opStart + coreCount ||
       plan.opKinds[idx] != "load_param" ||
       plan.opArg0s[idx] != outParamIdx ||
       plan.opKinds[idx + 1] != "store_field":
        return ""
    var aggregateResultTypeText: str = ""
    var strOffsetBytes: int32 = -1
    if !compilerCoreDirectVarAggregateFieldStoreBinding(outParamTypeText,
                                                        plan.opPrimaryTexts[idx + 1],
                                                        aggregateResultTypeText,
                                                        strOffsetBytes):
        return ""
    if !compilerCoreTypeMatches(aggregateResultTypeText, "str"):
        return ""
    let outPtrReg = compilerCoreDirectAbiParamBaseReg(plan.signatureTexts[itemIdx], outParamIdx)
    return machineDirectStoreVarFieldAndVarStrWords(architecture,
                                                    outPtrReg,
                                                    scalarOffsetBytes,
                                                    scalarStoreIs64,
                                                    scalarSourceIsReg,
                                                    scalarSourceReg,
                                                    scalarSourceRegIs64,
                                                    scalarConstKind,
                                                    scalarConstPrimaryText,
                                                    scalarConstArg0,
                                                    strOffsetBytes,
                                                    strSourceIsZero,
                                                    strSourceReg0,
                                                    strSourceReg1)

fn compilerCoreDirectExecVarFieldStoreWords(plan: cflow.LowUirCompilerCorePlan,
                                            itemIdx: int32,
                                            architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if plan.paramCounts[itemIdx] != 1 ||
       opCount != 4 ||
       !compilerCoreIsDirectConstValueKind(plan.opKinds[opStart]) ||
       plan.opKinds[opStart + 1] != "load_param" ||
       plan.opArg0s[opStart + 1] != 0 ||
       plan.opKinds[opStart + 2] != "store_field" ||
       plan.opKinds[opStart + 3] != "return_void":
        return ""
    let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
    var offsetBytes: int32 = -1
    var is64: bool = false
    if !compilerCoreDirectVarFieldStoreBinding(paramTypeText,
                                               plan.opPrimaryTexts[opStart + 2],
                                               offsetBytes,
                                               is64):
        return ""
    return machineDirectStoreVarFieldSimpleValueWords(architecture,
                                                      offsetBytes,
                                                      is64,
                                                      plan.opKinds[opStart],
                                                      plan.opPrimaryTexts[opStart],
                                                      plan.opArg0s[opStart])

fn compilerCoreDirectExecCtorConstReturnWords(plan: cflow.LowUirCompilerCorePlan,
                                              itemIdx: int32,
                                              architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 4 ||
       plan.opKinds[opStart] != "load_name" ||
       !compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 1]) ||
       plan.opKinds[opStart + 2] != "call" ||
       plan.opArg0s[opStart + 2] != 1 ||
       plan.opKinds[opStart + 3] != "return_value":
        return ""
    if !compilerCoreDirectCtorConstReturnSupported(plan.returnTypeTexts[itemIdx]):
        return ""
    if compilerCoreNormalizedTypeText(plan.opPrimaryTexts[opStart]) !=
       compilerCoreNormalizedTypeText(plan.returnTypeTexts[itemIdx]):
        return ""
    return machineDirectReturnSimpleValueWords(architecture,
                                               plan.opKinds[opStart + 1],
                                               plan.opPrimaryTexts[opStart + 1],
                                               plan.opArg0s[opStart + 1])

fn compilerCoreDirectExecIfElseWords(plan: cflow.LowUirCompilerCorePlan,
                                     itemIdx: int32,
                                     architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 9 &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart]) &&
       plan.opKinds[opStart + 1] == "jump_if_false" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "return_value" &&
       plan.opKinds[opStart + 4] == "jump" &&
       plan.opKinds[opStart + 5] == "label" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 6]) &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opKinds[opStart + 8] == "label" &&
       plan.opPrimaryTexts[opStart + 1] == plan.opPrimaryTexts[opStart + 5] &&
       plan.opPrimaryTexts[opStart + 4] == plan.opPrimaryTexts[opStart + 8]:
        return machineDirectIfElseSimpleCondWords(architecture,
                                                  plan.opKinds[opStart],
                                                  plan.opPrimaryTexts[opStart],
                                                  plan.opArg0s[opStart],
                                                  plan.opKinds[opStart + 2],
                                                  plan.opPrimaryTexts[opStart + 2],
                                                  plan.opArg0s[opStart + 2],
                                                  plan.opKinds[opStart + 6],
                                                  plan.opPrimaryTexts[opStart + 6],
                                                  plan.opArg0s[opStart + 6])
    if opCount == 11 &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart]) &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "binary_op" &&
       plan.opKinds[opStart + 3] == "jump_if_false" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 4]) &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opKinds[opStart + 6] == "jump" &&
       plan.opKinds[opStart + 7] == "label" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 8]) &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opKinds[opStart + 10] == "label" &&
       plan.opPrimaryTexts[opStart + 3] == plan.opPrimaryTexts[opStart + 7] &&
       plan.opPrimaryTexts[opStart + 6] == plan.opPrimaryTexts[opStart + 10]:
        return machineDirectIfElseBinaryCondWords(architecture,
                                                  plan.opKinds[opStart],
                                                  plan.opPrimaryTexts[opStart],
                                                  plan.opArg0s[opStart],
                                                  plan.opKinds[opStart + 1],
                                                  plan.opPrimaryTexts[opStart + 1],
                                                  plan.opArg0s[opStart + 1],
                                                  plan.opPrimaryTexts[opStart + 2],
                                                  plan.opKinds[opStart + 4],
                                                  plan.opPrimaryTexts[opStart + 4],
                                                  plan.opArg0s[opStart + 4],
                                                 plan.opKinds[opStart + 8],
                                                 plan.opPrimaryTexts[opStart + 8],
                                                 plan.opArg0s[opStart + 8])
    return ""

fn compilerCoreDirectExecIfElseCallSymbols(plan: cflow.LowUirCompilerCorePlan,
                                           itemIdx: int32,
                                           targetTriple: str): str[] =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if !compilerCoreDirectCallReturnTypeSupported(plan.returnTypeTexts[itemIdx]):
        return []
    if opCount == 14 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "jump_if_false" &&
       plan.opKinds[opStart + 4] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opKinds[opStart + 7] == "jump" &&
       plan.opKinds[opStart + 8] == "label" &&
       plan.opKinds[opStart + 9] == "load_routine" &&
       plan.opKinds[opStart + 10] == "load_param" &&
       plan.opKinds[opStart + 11] == "call" &&
       plan.opKinds[opStart + 12] == "return_value" &&
       plan.opKinds[opStart + 13] == "label" &&
       plan.opArg0s[opStart + 2] == 1 &&
       plan.opArg0s[opStart + 5] == 0 &&
       plan.opArg0s[opStart + 11] == 1 &&
       plan.opPrimaryTexts[opStart + 3] == plan.opPrimaryTexts[opStart + 8] &&
       plan.opPrimaryTexts[opStart + 7] == plan.opPrimaryTexts[opStart + 13]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let thenItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 4])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 9])
        if condItemIdx >= 0 && thenItemIdx >= 0 && elseItemIdx >= 0 &&
           plan.paramCounts[condItemIdx] == 1 &&
           plan.paramCounts[elseItemIdx] == 1:
            let condArgType = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 1])
            let elseArgType = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 10])
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[condItemIdx], 0)) == 2 &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[elseItemIdx], 0)) == 2 &&
               compilerCoreDirectTypeRegWidth(condArgType) == 2 &&
               compilerCoreDirectTypeRegWidth(elseArgType) == 2:
                let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
                let thenSymbol = compilerCoreDirectExecCalleeSymbol(plan, thenItemIdx, targetTriple)
                let elseSymbol = compilerCoreDirectExecCalleeSymbol(plan, elseItemIdx, targetTriple)
                if len(condSymbol) > 0 && len(thenSymbol) > 0 && len(elseSymbol) > 0:
                    return [condSymbol, thenSymbol, elseSymbol]
    if opCount == 14 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "jump_if_false" &&
       plan.opKinds[opStart + 4] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opKinds[opStart + 7] == "jump" &&
       plan.opKinds[opStart + 8] == "label" &&
       plan.opKinds[opStart + 9] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 10]) &&
       plan.opKinds[opStart + 11] == "call" &&
       plan.opKinds[opStart + 12] == "return_value" &&
       plan.opKinds[opStart + 13] == "label" &&
       plan.opArg0s[opStart + 2] == 1 &&
       plan.opArg0s[opStart + 5] == 0 &&
       plan.opArg0s[opStart + 11] == 1 &&
       plan.opPrimaryTexts[opStart + 3] == plan.opPrimaryTexts[opStart + 8] &&
       plan.opPrimaryTexts[opStart + 7] == plan.opPrimaryTexts[opStart + 13]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let thenItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 4])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 9])
        if condItemIdx >= 0 && thenItemIdx >= 0 && elseItemIdx >= 0:
            if plan.paramCounts[condItemIdx] == 1 &&
               plan.paramCounts[thenItemIdx] == 0 &&
               plan.paramCounts[elseItemIdx] == 1 &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[condItemIdx], 0)) == 1 &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[elseItemIdx], 0)) == 1:
                if plan.opKinds[opStart + 1] != "load_param" ||
                   compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 1])) == 1:
                    if plan.opKinds[opStart + 10] != "load_param" ||
                       compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 10])) == 1:
                        let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
                        let thenSymbol = compilerCoreDirectExecCalleeSymbol(plan, thenItemIdx, targetTriple)
                        let elseSymbol = compilerCoreDirectExecCalleeSymbol(plan, elseItemIdx, targetTriple)
                        if len(condSymbol) > 0 && len(thenSymbol) > 0 && len(elseSymbol) > 0:
                            return [condSymbol, thenSymbol, elseSymbol]
    if opCount == 12 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opKinds[opStart + 6] == "jump" &&
       plan.opKinds[opStart + 7] == "label" &&
       plan.opKinds[opStart + 8] == "load_routine" &&
       plan.opKinds[opStart + 9] == "call" &&
       plan.opKinds[opStart + 10] == "return_value" &&
       plan.opKinds[opStart + 11] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 4] == 0 &&
       plan.opArg0s[opStart + 9] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 7] &&
       plan.opPrimaryTexts[opStart + 6] == plan.opPrimaryTexts[opStart + 11]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let thenItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 8])
        if condItemIdx >= 0 && thenItemIdx >= 0 && elseItemIdx >= 0:
            let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
            let thenSymbol = compilerCoreDirectExecCalleeSymbol(plan, thenItemIdx, targetTriple)
            let elseSymbol = compilerCoreDirectExecCalleeSymbol(plan, elseItemIdx, targetTriple)
            if len(condSymbol) > 0 && len(thenSymbol) > 0 && len(elseSymbol) > 0:
                return [condSymbol, thenSymbol, elseSymbol]
    if opCount == 13 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "jump_if_false" &&
       plan.opKinds[opStart + 4] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opKinds[opStart + 7] == "jump" &&
       plan.opKinds[opStart + 8] == "label" &&
       plan.opKinds[opStart + 9] == "load_routine" &&
       plan.opKinds[opStart + 10] == "call" &&
       plan.opKinds[opStart + 11] == "return_value" &&
       plan.opKinds[opStart + 12] == "label" &&
       plan.opArg0s[opStart + 2] == 1 &&
       plan.opArg0s[opStart + 5] == 0 &&
       plan.opArg0s[opStart + 10] == 0 &&
       plan.opPrimaryTexts[opStart + 3] == plan.opPrimaryTexts[opStart + 8] &&
       plan.opPrimaryTexts[opStart + 7] == plan.opPrimaryTexts[opStart + 12]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let thenItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 4])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 9])
        if condItemIdx >= 0 && thenItemIdx >= 0 && elseItemIdx >= 0:
            if plan.paramCounts[condItemIdx] == 1 &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[condItemIdx], 0)) == 1:
                if plan.opKinds[opStart + 1] != "load_param" ||
                   compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 1])) == 1:
                    let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
                    let thenSymbol = compilerCoreDirectExecCalleeSymbol(plan, thenItemIdx, targetTriple)
                    let elseSymbol = compilerCoreDirectExecCalleeSymbol(plan, elseItemIdx, targetTriple)
                    if len(condSymbol) > 0 && len(thenSymbol) > 0 && len(elseSymbol) > 0:
                        return [condSymbol, thenSymbol, elseSymbol]
    if opCount == 14 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "jump_if_false" &&
       plan.opKinds[opStart + 4] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opKinds[opStart + 7] == "jump" &&
       plan.opKinds[opStart + 8] == "label" &&
       plan.opKinds[opStart + 9] == "load_routine" &&
       plan.opKinds[opStart + 10] == "load_param" &&
       plan.opKinds[opStart + 11] == "call" &&
       plan.opKinds[opStart + 12] == "return_value" &&
       plan.opKinds[opStart + 13] == "label" &&
       plan.opArg0s[opStart + 2] == 1 &&
       plan.opArg0s[opStart + 5] == 0 &&
       plan.opArg0s[opStart + 11] == 1 &&
       plan.opPrimaryTexts[opStart + 3] == plan.opPrimaryTexts[opStart + 8] &&
       plan.opPrimaryTexts[opStart + 7] == plan.opPrimaryTexts[opStart + 13]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let thenItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 4])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 9])
        if condItemIdx >= 0 && thenItemIdx >= 0 && elseItemIdx >= 0:
            let condArgType = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 1])
            let elseArgType = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 10])
            if plan.paramCounts[condItemIdx] == 1 &&
               plan.paramCounts[elseItemIdx] == 1 &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[condItemIdx], 0)) == 2 &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[elseItemIdx], 0)) == 2 &&
               compilerCoreDirectTypeRegWidth(condArgType) == 2 &&
               compilerCoreDirectTypeRegWidth(elseArgType) == 2:
                let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
                let thenSymbol = compilerCoreDirectExecCalleeSymbol(plan, thenItemIdx, targetTriple)
                let elseSymbol = compilerCoreDirectExecCalleeSymbol(plan, elseItemIdx, targetTriple)
                if len(condSymbol) > 0 && len(thenSymbol) > 0 && len(elseSymbol) > 0:
                    return [condSymbol, thenSymbol, elseSymbol]
    if opCount == 11 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opKinds[opStart + 5] == "jump" &&
       plan.opKinds[opStart + 6] == "label" &&
       plan.opKinds[opStart + 7] == "load_routine" &&
       plan.opKinds[opStart + 8] == "call" &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opKinds[opStart + 10] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 8] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 6] &&
       plan.opPrimaryTexts[opStart + 5] == plan.opPrimaryTexts[opStart + 10]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 7])
        if condItemIdx >= 0 && elseItemIdx >= 0:
            let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
            let elseSymbol = compilerCoreDirectExecCalleeSymbol(plan, elseItemIdx, targetTriple)
            if len(condSymbol) > 0 && len(elseSymbol) > 0:
                return [condSymbol, elseSymbol]
    if opCount == 11 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opKinds[opStart + 6] == "jump" &&
       plan.opKinds[opStart + 7] == "label" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 8]) &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opKinds[opStart + 10] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 4] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 7] &&
       plan.opPrimaryTexts[opStart + 6] == plan.opPrimaryTexts[opStart + 10]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let thenItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 3])
        if condItemIdx >= 0 && thenItemIdx >= 0:
            let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
            let thenSymbol = compilerCoreDirectExecCalleeSymbol(plan, thenItemIdx, targetTriple)
            if len(condSymbol) > 0 && len(thenSymbol) > 0:
                return [condSymbol, thenSymbol]
    if opCount == 14 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "binary_op" &&
       plan.opKinds[opStart + 4] == "jump_if_false" &&
       plan.opKinds[opStart + 5] == "load_routine" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opKinds[opStart + 8] == "jump" &&
       plan.opKinds[opStart + 9] == "label" &&
       plan.opKinds[opStart + 10] == "load_routine" &&
       plan.opKinds[opStart + 11] == "call" &&
       plan.opKinds[opStart + 12] == "return_value" &&
       plan.opKinds[opStart + 13] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 6] == 0 &&
       plan.opArg0s[opStart + 11] == 0 &&
       plan.opPrimaryTexts[opStart + 4] == plan.opPrimaryTexts[opStart + 9] &&
       plan.opPrimaryTexts[opStart + 8] == plan.opPrimaryTexts[opStart + 13]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let thenItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 5])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 10])
        if condItemIdx >= 0 && thenItemIdx >= 0 && elseItemIdx >= 0:
            let condSymbol = compilerCoreDirectExecCalleeSymbol(plan, condItemIdx, targetTriple)
            let thenSymbol = compilerCoreDirectExecCalleeSymbol(plan, thenItemIdx, targetTriple)
            let elseSymbol = compilerCoreDirectExecCalleeSymbol(plan, elseItemIdx, targetTriple)
            if len(condSymbol) > 0 && len(thenSymbol) > 0 && len(elseSymbol) > 0:
                return [condSymbol, thenSymbol, elseSymbol]
    return []

fn compilerCoreDirectExecIfElseCallWords(plan: cflow.LowUirCompilerCorePlan,
                                         itemIdx: int32,
                                         architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 14 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "jump_if_false" &&
       plan.opKinds[opStart + 4] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opKinds[opStart + 7] == "jump" &&
       plan.opKinds[opStart + 8] == "label" &&
       plan.opKinds[opStart + 9] == "load_routine" &&
       plan.opKinds[opStart + 10] == "load_param" &&
       plan.opKinds[opStart + 11] == "call" &&
       plan.opKinds[opStart + 12] == "return_value" &&
       plan.opKinds[opStart + 13] == "label" &&
       plan.opArg0s[opStart + 2] == 1 &&
       plan.opArg0s[opStart + 5] == 0 &&
       plan.opArg0s[opStart + 11] == 1 &&
       plan.opPrimaryTexts[opStart + 3] == plan.opPrimaryTexts[opStart + 8] &&
       plan.opPrimaryTexts[opStart + 7] == plan.opPrimaryTexts[opStart + 13]:
        let condItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
        let elseItemIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 9])
        if condItemIdx >= 0 && elseItemIdx >= 0 &&
           plan.paramCounts[condItemIdx] == 1 &&
           plan.paramCounts[elseItemIdx] == 1:
            let condArgType = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 1])
            let elseArgType = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 10])
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[condItemIdx], 0)) == 2 &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[elseItemIdx], 0)) == 2 &&
               compilerCoreDirectTypeRegWidth(condArgType) == 2 &&
               compilerCoreDirectTypeRegWidth(elseArgType) == 2:
                let condBaseReg = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 1])
                let elseBaseReg = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], plan.opArg0s[opStart + 10])
                return machineDirectIfElseCondParamPairThenCallParamPairWords(architecture,
                                                                              condBaseReg,
                                                                              condBaseReg + 1,
                                                                              compilerCoreDirectSecondRegIs64(condArgType),
                                                                              elseBaseReg,
                                                                              elseBaseReg + 1,
                                                                              compilerCoreDirectSecondRegIs64(elseArgType))
    if opCount == 14 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "jump_if_false" &&
       plan.opKinds[opStart + 4] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opKinds[opStart + 7] == "jump" &&
       plan.opKinds[opStart + 8] == "label" &&
       plan.opKinds[opStart + 9] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 10]) &&
       plan.opKinds[opStart + 11] == "call" &&
       plan.opKinds[opStart + 12] == "return_value" &&
       plan.opKinds[opStart + 13] == "label" &&
       plan.opArg0s[opStart + 2] == 1 &&
       plan.opArg0s[opStart + 5] == 0 &&
       plan.opArg0s[opStart + 11] == 1 &&
       plan.opPrimaryTexts[opStart + 3] == plan.opPrimaryTexts[opStart + 8] &&
       plan.opPrimaryTexts[opStart + 7] == plan.opPrimaryTexts[opStart + 13]:
        return machineDirectIfElseCondArgThenCallArgWords(architecture,
                                                          plan.opKinds[opStart + 1],
                                                          plan.opPrimaryTexts[opStart + 1],
                                                          plan.opArg0s[opStart + 1],
                                                          plan.opKinds[opStart + 10],
                                                          plan.opPrimaryTexts[opStart + 10],
                                                          plan.opArg0s[opStart + 10])
    if opCount == 12 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opKinds[opStart + 6] == "jump" &&
       plan.opKinds[opStart + 7] == "label" &&
       plan.opKinds[opStart + 8] == "load_routine" &&
       plan.opKinds[opStart + 9] == "call" &&
       plan.opKinds[opStart + 10] == "return_value" &&
       plan.opKinds[opStart + 11] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 4] == 0 &&
       plan.opArg0s[opStart + 9] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 7] &&
       plan.opPrimaryTexts[opStart + 6] == plan.opPrimaryTexts[opStart + 11]:
        return machineDirectIfElseCallWords(architecture)
    if opCount == 13 &&
       plan.opKinds[opStart] == "load_routine" &&
       compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 1]) &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "jump_if_false" &&
       plan.opKinds[opStart + 4] == "load_routine" &&
       plan.opKinds[opStart + 5] == "call" &&
       plan.opKinds[opStart + 6] == "return_value" &&
       plan.opKinds[opStart + 7] == "jump" &&
       plan.opKinds[opStart + 8] == "label" &&
       plan.opKinds[opStart + 9] == "load_routine" &&
       plan.opKinds[opStart + 10] == "call" &&
       plan.opKinds[opStart + 11] == "return_value" &&
       plan.opKinds[opStart + 12] == "label" &&
       plan.opArg0s[opStart + 2] == 1 &&
       plan.opArg0s[opStart + 5] == 0 &&
       plan.opArg0s[opStart + 10] == 0 &&
       plan.opPrimaryTexts[opStart + 3] == plan.opPrimaryTexts[opStart + 8] &&
       plan.opPrimaryTexts[opStart + 7] == plan.opPrimaryTexts[opStart + 12]:
        return machineDirectIfElseCondArgCallWords(architecture,
                                                   plan.opKinds[opStart + 1],
                                                   plan.opPrimaryTexts[opStart + 1],
                                                   plan.opArg0s[opStart + 1])
    if opCount == 11 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 3]) &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opKinds[opStart + 5] == "jump" &&
       plan.opKinds[opStart + 6] == "label" &&
       plan.opKinds[opStart + 7] == "load_routine" &&
       plan.opKinds[opStart + 8] == "call" &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opKinds[opStart + 10] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 8] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 6] &&
       plan.opPrimaryTexts[opStart + 5] == plan.opPrimaryTexts[opStart + 10]:
        return machineDirectIfElseConstThenCallWords(architecture,
                                                     plan.opKinds[opStart + 3],
                                                     plan.opPrimaryTexts[opStart + 3],
                                                     plan.opArg0s[opStart + 3])
    if opCount == 11 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       plan.opKinds[opStart + 2] == "jump_if_false" &&
       plan.opKinds[opStart + 3] == "load_routine" &&
       plan.opKinds[opStart + 4] == "call" &&
       plan.opKinds[opStart + 5] == "return_value" &&
       plan.opKinds[opStart + 6] == "jump" &&
       plan.opKinds[opStart + 7] == "label" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 8]) &&
       plan.opKinds[opStart + 9] == "return_value" &&
       plan.opKinds[opStart + 10] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 4] == 0 &&
       plan.opPrimaryTexts[opStart + 2] == plan.opPrimaryTexts[opStart + 7] &&
       plan.opPrimaryTexts[opStart + 6] == plan.opPrimaryTexts[opStart + 10]:
        return machineDirectIfElseCallThenConstWords(architecture,
                                                     plan.opKinds[opStart + 8],
                                                     plan.opPrimaryTexts[opStart + 8],
                                                     plan.opArg0s[opStart + 8])
    if opCount == 14 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "call" &&
       compilerCoreIsDirectConstValueKind(plan.opKinds[opStart + 2]) &&
       plan.opKinds[opStart + 3] == "binary_op" &&
       plan.opKinds[opStart + 4] == "jump_if_false" &&
       plan.opKinds[opStart + 5] == "load_routine" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opKinds[opStart + 8] == "jump" &&
       plan.opKinds[opStart + 9] == "label" &&
       plan.opKinds[opStart + 10] == "load_routine" &&
       plan.opKinds[opStart + 11] == "call" &&
       plan.opKinds[opStart + 12] == "return_value" &&
       plan.opKinds[opStart + 13] == "label" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opArg0s[opStart + 6] == 0 &&
       plan.opArg0s[opStart + 11] == 0 &&
       plan.opPrimaryTexts[opStart + 4] == plan.opPrimaryTexts[opStart + 9] &&
       plan.opPrimaryTexts[opStart + 8] == plan.opPrimaryTexts[opStart + 13]:
        return machineDirectIfElseCallCompareConstRhsWords(architecture,
                                                           plan.opKinds[opStart + 2],
                                                           plan.opPrimaryTexts[opStart + 2],
                                                           plan.opArg0s[opStart + 2],
                                                           plan.opPrimaryTexts[opStart + 3])
    return ""

fn compilerCoreDirectExecFieldArithmeticCompareWords(plan: cflow.LowUirCompilerCorePlan,
                                                     itemIdx: int32,
                                                     architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount != 9 ||
       plan.opKinds[opStart] != "load_param" ||
       plan.opKinds[opStart + 1] != "load_field" ||
       !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2]) ||
       plan.opKinds[opStart + 3] != "binary_op" ||
       plan.opKinds[opStart + 4] != "load_param" ||
       plan.opKinds[opStart + 5] != "load_field" ||
       plan.opKinds[opStart + 6] != "load_field" ||
       plan.opKinds[opStart + 7] != "binary_op" ||
       plan.opKinds[opStart + 8] != "return_value":
        return ""
    let arithmeticOperatorText = plan.opPrimaryTexts[opStart + 3]
    let compareOperatorText = plan.opPrimaryTexts[opStart + 7]
    if arithmeticOperatorText != "+" && arithmeticOperatorText != "-":
        return ""
    if compareOperatorText != "==" && compareOperatorText != "!=" &&
       compareOperatorText != "<" && compareOperatorText != "<=" &&
       compareOperatorText != ">" && compareOperatorText != ">=":
        return ""
    var lhsSourceReg: int32 = -1
    var lhsSourceIs64: bool = false
    if !compilerCoreDirectParamFieldReturnBinding(plan.signatureTexts[itemIdx],
                                                  plan.opArg0s[opStart],
                                                  plan.opPrimaryTexts[opStart + 1],
                                                  lhsSourceReg,
                                                  lhsSourceIs64):
        return ""
    var compareSourceReg: int32 = -1
    var compareSourceIs64: bool = false
    if !compilerCoreDirectParamNestedFieldReturnBinding(plan.signatureTexts[itemIdx],
                                                        plan.opArg0s[opStart + 4],
                                                        plan.opPrimaryTexts[opStart + 5],
                                                        plan.opPrimaryTexts[opStart + 6],
                                                        compareSourceReg,
                                                        compareSourceIs64):
        return ""
    return machineDirectArithmeticCompareWords(architecture,
                                               plan.signatureTexts[itemIdx],
                                               lhsSourceReg,
                                               lhsSourceIs64,
                                               arithmeticOperatorText,
                                               plan.opKinds[opStart + 2],
                                               plan.opPrimaryTexts[opStart + 2],
                                               plan.opArg0s[opStart + 2],
                                               compareSourceReg,
                                               compareSourceIs64,
                                               compareOperatorText)

fn compilerCoreDirectExecWords(plan: cflow.LowUirCompilerCorePlan,
                               itemIdx: int32,
                               architecture: str): str =
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    let paramReturnWords = compilerCoreDirectExecParamReturnWords(plan, itemIdx, architecture)
    if len(paramReturnWords) > 0:
        return paramReturnWords
    let fieldWords = compilerCoreDirectExecFieldWords(plan, itemIdx, architecture)
    if len(fieldWords) > 0:
        return fieldWords
    let unaryFieldWords = compilerCoreDirectExecUnaryFieldWords(plan, itemIdx, architecture)
    if len(unaryFieldWords) > 0:
        return unaryFieldWords
    let nestedFieldWords = compilerCoreDirectExecNestedFieldWords(plan, itemIdx, architecture)
    if len(nestedFieldWords) > 0:
        return nestedFieldWords
    let tripleFieldWords = compilerCoreDirectExecTripleFieldWords(plan, itemIdx, architecture)
    if len(tripleFieldWords) > 0:
        return tripleFieldWords
    let zeroArgNestedLenWords = compilerCoreDirectExecZeroArgNestedLenWords(plan, itemIdx, architecture)
    if len(zeroArgNestedLenWords) > 0:
        return zeroArgNestedLenWords
    let bytesLiteralWords = compilerCoreDirectExecBytesLiteralWords(plan, itemIdx, architecture)
    if len(bytesLiteralWords) > 0:
        return bytesLiteralWords
    let paramAggregateWords = compilerCoreDirectExecParamAggregateWords(plan, itemIdx, architecture)
    if len(paramAggregateWords) > 0:
        return paramAggregateWords
    let zeroAggregateWords = compilerCoreDirectExecZeroAggregateWords(plan, itemIdx, architecture)
    if len(zeroAggregateWords) > 0:
        return zeroAggregateWords
    let zeroVarStrOutWords = compilerCoreDirectExecZeroVarStrOutWords(plan, itemIdx, architecture)
    if len(zeroVarStrOutWords) > 0:
        return zeroVarStrOutWords
    let storeParamVarStrWords = compilerCoreDirectExecStoreParamVarStrWords(plan, itemIdx, architecture)
    if len(storeParamVarStrWords) > 0:
        return storeParamVarStrWords
    let localVarStrEmptyReturnWords = compilerCoreDirectExecLocalVarStrEmptyReturnWords(plan, itemIdx, architecture)
    if len(localVarStrEmptyReturnWords) > 0:
        return localVarStrEmptyReturnWords
    let guardedLocalVarStrLenBoolWords = compilerCoreDirectExecGuardedLocalVarStrLenBoolWords(plan, itemIdx, architecture)
    if len(guardedLocalVarStrLenBoolWords) > 0:
        return guardedLocalVarStrLenBoolWords
    let storeParamScalarWords = compilerCoreDirectExecStoreParamScalarWords(plan, itemIdx, architecture)
    if len(storeParamScalarWords) > 0:
        return storeParamScalarWords
    let copyVarStrOutWords = compilerCoreDirectExecCopyVarStrOutWords(plan, itemIdx, architecture)
    if len(copyVarStrOutWords) > 0:
        return copyVarStrOutWords
    let varFieldThenVarStrFieldWords = compilerCoreDirectExecVarFieldThenVarStrFieldWords(plan, itemIdx, architecture)
    if len(varFieldThenVarStrFieldWords) > 0:
        return varFieldThenVarStrFieldWords
    let varFieldStoreWords = compilerCoreDirectExecVarFieldStoreWords(plan, itemIdx, architecture)
    if len(varFieldStoreWords) > 0:
        return varFieldStoreWords
    let ctorConstReturnWords = compilerCoreDirectExecCtorConstReturnWords(plan, itemIdx, architecture)
    if len(ctorConstReturnWords) > 0:
        return ctorConstReturnWords
    let dropPrefixSimpleReturnWords = compilerCoreDirectExecDropPrefixSimpleReturnWords(plan, itemIdx, architecture)
    if len(dropPrefixSimpleReturnWords) > 0:
        return dropPrefixSimpleReturnWords
    let dropPrefixZeroArgCallReturnWords = compilerCoreDirectExecDropPrefixZeroArgCallReturnWords(plan, itemIdx, architecture)
    if len(dropPrefixZeroArgCallReturnWords) > 0:
        return dropPrefixZeroArgCallReturnWords
    let dropOnlyWords = compilerCoreDirectExecDropOnlyWords(plan, itemIdx, architecture)
    if len(dropOnlyWords) > 0:
        return dropOnlyWords
    let localAliasWords = compilerCoreDirectExecLocalAliasWords(plan, itemIdx, architecture)
    if len(localAliasWords) > 0:
        return localAliasWords
    let ifElseCallWords = compilerCoreDirectExecIfElseCallWords(plan, itemIdx, architecture)
    if len(ifElseCallWords) > 0:
        return ifElseCallWords
    let ifElseWords = compilerCoreDirectExecIfElseWords(plan, itemIdx, architecture)
    if len(ifElseWords) > 0:
        return ifElseWords
    let fieldArithmeticCompareWords = compilerCoreDirectExecFieldArithmeticCompareWords(plan, itemIdx, architecture)
    if len(fieldArithmeticCompareWords) > 0:
        return fieldArithmeticCompareWords
    if opCount <= 0:
        return ""
    if opCount == 1 && plan.opKinds[opStart] == "return_void":
        return machineDirectReturnVoidWords(architecture)
    if opCount == 2 && plan.opKinds[opStart + 1] == "return_value":
        return machineDirectReturnSimpleValueWords(architecture,
                                                   plan.opKinds[opStart],
                                                   plan.opPrimaryTexts[opStart],
                                                   plan.opArg0s[opStart])
    if opCount == 3 && plan.opKinds[opStart + 2] == "return_value":
        return machineDirectUnaryWords(architecture,
                                       plan.opKinds[opStart + 1],
                                       plan.opKinds[opStart],
                                       plan.opPrimaryTexts[opStart],
                                       plan.opArg0s[opStart])
    if opCount == 4 &&
       plan.opKinds[opStart + 2] == "binary_op" &&
       plan.opKinds[opStart + 3] == "return_value":
        return machineDirectBinaryWords(architecture,
                                        plan.opKinds[opStart],
                                        plan.opPrimaryTexts[opStart],
                                        plan.opArg0s[opStart],
                                        plan.opKinds[opStart + 1],
                                        plan.opPrimaryTexts[opStart + 1],
                                        plan.opArg0s[opStart + 1],
                                        plan.opPrimaryTexts[opStart + 2])
    return ""

fn compilerCoreDirectExecNestedCallSymbols(plan: cflow.LowUirCompilerCorePlan,
                                           itemIdx: int32,
                                           targetTriple: str): str[] =
    var out: str[]
    out = []
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if !compilerCoreDirectCallReturnTypeSupported(plan.returnTypeTexts[itemIdx]):
        return out
    if opCount == 8 &&
       plan.opKinds[opStart] == "local_decl" &&
       plan.opKinds[opStart + 1] == "load_routine" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "store_local" &&
       plan.opKinds[opStart + 4] == "load_routine" &&
       plan.opKinds[opStart + 5] == "load_local" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opArg0s[opStart + 2] == 0 &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 3] &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 5] &&
       plan.opArg0s[opStart + 6] == 1:
        let innerCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 1, 0)
        let outerCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 4, 1)
        if innerCalleeIdx >= 0 &&
           outerCalleeIdx >= 0 &&
           plan.paramCounts[outerCalleeIdx] == 1 &&
           compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) == 1:
            let outerParam0TypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)
            if compilerCoreDirectTypeRegWidth(outerParam0TypeText) == 1 &&
               compilerCoreNormalizedTypeText(outerParam0TypeText) == compilerCoreNormalizedTypeText(plan.returnTypeTexts[innerCalleeIdx]):
                let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
                let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
                if len(innerSymbol) > 0 && len(outerSymbol) > 0:
                    add(out, innerSymbol)
                    add(out, outerSymbol)
                    return out
    for argCount in 0..<5:
        let innerCallIdx = opStart + 2 + argCount
        let outerCallIdx = innerCallIdx + 1
        if opCount == argCount + 5 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx] == 1:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOk = false
            if !argsOk:
                continue
            let innerCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 1, argCount)
            var outerCalleeIdx: int32 = -1
            if innerCalleeIdx >= 0:
                outerCalleeIdx = compilerCoreFindPlanItemIndexByResolvedTypeCall(plan,
                                                                                  itemIdx,
                                                                                  opStart,
                                                                                  plan.returnTypeTexts[innerCalleeIdx],
                                                                                  1)
            var innerReturnWidth: int32 = 0
            if !compilerCoreDirectNestedTrailingArgsMatch(plan,
                                                          itemIdx,
                                                          innerCalleeIdx,
                                                          outerCalleeIdx,
                                                          [],
                                                          targetTriple,
                                                          innerReturnWidth):
                continue
            if innerReturnWidth == 2 &&
               !compilerCoreHasDirectExecBody(plan, innerCalleeIdx, targetTriple):
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        for outerLeadingArgCount in 1..<4:
            let innerLeadingRoutineIdx = opStart + 1 + outerLeadingArgCount
            let innerLeadingCallIdx = innerLeadingRoutineIdx + 1 + argCount
            let outerLeadingCallIdx = innerLeadingCallIdx + 1
            if opCount != outerLeadingArgCount + argCount + 5 ||
               plan.opKinds[opStart] != "load_routine" ||
               plan.opKinds[innerLeadingRoutineIdx] != "load_routine" ||
               plan.opKinds[innerLeadingCallIdx] != "call" ||
               plan.opKinds[outerLeadingCallIdx] != "call" ||
               plan.opKinds[outerLeadingCallIdx + 1] != "return_value" ||
               plan.opArg0s[innerLeadingCallIdx] != argCount ||
               plan.opArg0s[outerLeadingCallIdx] != outerLeadingArgCount + 1:
                continue
            var leadingArgsOk: bool = true
            var outerLeadingArgIdxs: int32[]
            outerLeadingArgIdxs = []
            for i in 0..<outerLeadingArgCount:
                let outerLeadingArgIdx = opStart + 1 + i
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerLeadingArgIdx):
                    leadingArgsOk = false
                add(outerLeadingArgIdxs, outerLeadingArgIdx)
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, innerLeadingRoutineIdx + 1 + i):
                    leadingArgsOk = false
            if !leadingArgsOk:
                continue
            let outerLeadingCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerLeadingCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[innerLeadingRoutineIdx])
            var innerLeadingReturnWidth: int32 = 0
            if !compilerCoreDirectNestedLeadingArgsMatch(plan,
                                                         itemIdx,
                                                         innerLeadingCalleeIdx,
                                                         outerLeadingCalleeIdx,
                                                         outerLeadingArgIdxs,
                                                         targetTriple,
                                                         innerLeadingReturnWidth) ||
               innerLeadingReturnWidth != 1:
                continue
            let innerLeadingSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerLeadingCalleeIdx, targetTriple)
            let outerLeadingSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerLeadingCalleeIdx, targetTriple)
            if len(innerLeadingSymbol) <= 0 || len(outerLeadingSymbol) <= 0:
                continue
            add(out, innerLeadingSymbol)
            add(out, outerLeadingSymbol)
            return out
        let outerArgIdx = innerCallIdx + 1
        let outerCallIdx2 = innerCallIdx + 2
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerArgIdx] == "load_param" &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOk = false
            if !argsOk:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerCalleeIdx < 0 || innerCalleeIdx < 0 || outerCalleeIdx == itemIdx:
                continue
            if plan.paramCounts[outerCalleeIdx] != 2:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1)) != 2:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArgIdx])) != 2:
                continue
            if !compilerCoreHasDirectExecBody(plan, outerCalleeIdx, targetTriple):
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           compilerCoreIsDirectSimpleValueKind(plan.opKinds[outerArgIdx]) &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
            if !argsOk:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerCalleeIdx < 0 || innerCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 2:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1)) != 1:
                continue
            if plan.opKinds[outerArgIdx] == "load_param" &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArgIdx])) != 1:
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var argsOkWide: bool = compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArgIdx)
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOkWide = false
            if !argsOkWide:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            var innerReturnWidth: int32 = 0
            if !compilerCoreDirectNestedTrailingArgsMatch(plan,
                                                          itemIdx,
                                                          innerCalleeIdx,
                                                          outerCalleeIdx,
                                                          [outerArgIdx],
                                                          targetTriple,
                                                          innerReturnWidth):
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        let outerArg1Idx = innerCallIdx + 2
        let outerCallIdx3 = innerCallIdx + 3
        if opCount == argCount + 8 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           compilerCoreIsDirectSimpleValueKind(plan.opKinds[outerArgIdx]) &&
           compilerCoreIsDirectSimpleValueKind(plan.opKinds[outerArg1Idx]) &&
           plan.opKinds[outerCallIdx3] == "call" &&
           plan.opKinds[outerCallIdx3 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx3] == 3:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
            if !argsOk:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerCalleeIdx < 0 || innerCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 3:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) != 1 ||
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1)) != 1 ||
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 2)) != 1:
                continue
            if plan.opKinds[outerArgIdx] == "load_param" &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArgIdx])) != 1:
                continue
            if plan.opKinds[outerArg1Idx] == "load_param" &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArg1Idx])) != 1:
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        if opCount == argCount + 8 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx3] == "call" &&
           plan.opKinds[outerCallIdx3 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx3] == 3:
            var argsOkWide: bool =
                compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArgIdx) &&
                compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArg1Idx)
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOkWide = false
            if !argsOkWide:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            var innerReturnWidth: int32 = 0
            if !compilerCoreDirectNestedTrailingArgsMatch(plan,
                                                          itemIdx,
                                                          innerCalleeIdx,
                                                          outerCalleeIdx,
                                                          [outerArgIdx, outerArg1Idx],
                                                          targetTriple,
                                                          innerReturnWidth):
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        let outerArg2Idx = innerCallIdx + 3
        let outerCallIdx4 = innerCallIdx + 4
        if opCount == argCount + 9 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           compilerCoreIsDirectSimpleValueKind(plan.opKinds[outerArgIdx]) &&
           compilerCoreIsDirectSimpleValueKind(plan.opKinds[outerArg1Idx]) &&
           compilerCoreIsDirectSimpleValueKind(plan.opKinds[outerArg2Idx]) &&
           plan.opKinds[outerCallIdx4] == "call" &&
           plan.opKinds[outerCallIdx4 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx4] == 4:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
            if !argsOk:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerCalleeIdx < 0 || innerCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 4:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) != 1 ||
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1)) != 1 ||
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 2)) != 1 ||
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 3)) != 1:
                continue
            if plan.opKinds[outerArgIdx] == "load_param" &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArgIdx])) != 1:
                continue
            if plan.opKinds[outerArg1Idx] == "load_param" &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArg1Idx])) != 1:
                continue
            if plan.opKinds[outerArg2Idx] == "load_param" &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArg2Idx])) != 1:
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        if opCount == argCount + 9 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx4] == "call" &&
           plan.opKinds[outerCallIdx4 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx4] == 4:
            var argsOkWide: bool =
                compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArgIdx) &&
                compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArg1Idx) &&
                compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArg2Idx)
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOkWide = false
            if !argsOkWide:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            var innerReturnWidth: int32 = 0
            if !compilerCoreDirectNestedTrailingArgsMatch(plan,
                                                          itemIdx,
                                                          innerCalleeIdx,
                                                          outerCalleeIdx,
                                                          [outerArgIdx, outerArg1Idx, outerArg2Idx],
                                                          targetTriple,
                                                          innerReturnWidth):
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerArgIdx] == "load_str" &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
            if !argsOk:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            if outerCalleeIdx < 0 || innerCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 2:
                continue
            if !compilerCoreTypeMatches(plan.returnTypeTexts[innerCalleeIdx], "str"):
                continue
            if !compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0), "str"):
                continue
            if !compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1), "str"):
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx] == "call" &&
           compilerCoreIsDirectConstValueKind(plan.opKinds[outerCallIdx + 1]) &&
           plan.opKinds[outerCallIdx + 2] == "binary_op" &&
           plan.opKinds[outerCallIdx + 3] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx] == 1:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    argsOk = false
            if !argsOk:
                continue
            let compareOperatorText = plan.opPrimaryTexts[outerCallIdx + 2]
            if compareOperatorText != "==" && compareOperatorText != "!=" &&
               compareOperatorText != "<" && compareOperatorText != "<=" &&
               compareOperatorText != ">" && compareOperatorText != ">=":
                continue
            let innerCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 1, argCount)
            var outerCalleeIdx: int32 = -1
            if innerCalleeIdx >= 0:
                outerCalleeIdx = compilerCoreFindPlanItemIndexByResolvedTypeCall(plan,
                                                                                  itemIdx,
                                                                                  opStart,
                                                                                  plan.returnTypeTexts[innerCalleeIdx],
                                                                                  1)
            if outerCalleeIdx < 0 || innerCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 1:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) != 1:
                continue
            if compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) != 1:
                continue
            if !compilerCoreTypeMatches(plan.returnTypeTexts[outerCalleeIdx], "int32") &&
               !compilerCoreTypeMatches(plan.returnTypeTexts[outerCalleeIdx], "bool"):
                continue
            let innerSymbol = compilerCoreDirectExecCalleeSymbol(plan, innerCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(innerSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, innerSymbol)
            add(out, outerSymbol)
            return out
        for rhsArgCount in 0..<5:
            let rhsRoutineIdx = innerCallIdx + 1
            let rhsCallIdx = rhsRoutineIdx + 1 + rhsArgCount
            let compareOuterCallIdx = rhsCallIdx + 1
            if opCount != argCount + rhsArgCount + 9 ||
               plan.opKinds[opStart] != "load_routine" ||
               plan.opKinds[opStart + 1] != "load_routine" ||
               plan.opKinds[innerCallIdx] != "call" ||
               plan.opKinds[rhsRoutineIdx] != "load_routine" ||
               plan.opKinds[rhsCallIdx] != "call" ||
               plan.opKinds[compareOuterCallIdx] != "call" ||
               !compilerCoreIsDirectConstValueKind(plan.opKinds[compareOuterCallIdx + 1]) ||
               plan.opKinds[compareOuterCallIdx + 2] != "binary_op" ||
               plan.opKinds[compareOuterCallIdx + 3] != "return_value" ||
               plan.opArg0s[innerCallIdx] != argCount ||
               plan.opArg0s[rhsCallIdx] != rhsArgCount ||
               plan.opArg0s[compareOuterCallIdx] != 2:
                continue
            let compareOperatorText = plan.opPrimaryTexts[compareOuterCallIdx + 2]
            if compareOperatorText != "==" && compareOperatorText != "!=" &&
               compareOperatorText != "<" && compareOperatorText != "<=" &&
               compareOperatorText != ">" && compareOperatorText != ">=":
                continue
            var lhsArgsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[opStart + 2 + i]):
                    lhsArgsOk = false
            var rhsArgsOk: bool = true
            for i in 0..<rhsArgCount:
                if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[rhsRoutineIdx + 1 + i]):
                    rhsArgsOk = false
            if !lhsArgsOk || !rhsArgsOk:
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let lhsCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 1, argCount)
            let rhsCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, rhsRoutineIdx, rhsArgCount)
            if outerCalleeIdx < 0 || lhsCalleeIdx < 0 || rhsCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 2:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[lhsCalleeIdx]) != 1 ||
               compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[rhsCalleeIdx]) != 1:
                continue
            let outerParam0TypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)
            let outerParam1TypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1)
            if compilerCoreDirectTypeRegWidth(outerParam0TypeText) != 1 ||
               compilerCoreDirectTypeRegWidth(outerParam1TypeText) != 1:
                continue
            if compilerCoreNormalizedTypeText(outerParam0TypeText) != compilerCoreNormalizedTypeText(plan.returnTypeTexts[lhsCalleeIdx]) ||
               compilerCoreNormalizedTypeText(outerParam1TypeText) != compilerCoreNormalizedTypeText(plan.returnTypeTexts[rhsCalleeIdx]):
                continue
            let lhsSymbol = compilerCoreDirectExecCalleeSymbol(plan, lhsCalleeIdx, targetTriple)
            let rhsSymbol = compilerCoreDirectExecCalleeSymbol(plan, rhsCalleeIdx, targetTriple)
            let outerSymbol = compilerCoreDirectExecCalleeSymbol(plan, outerCalleeIdx, targetTriple)
            if len(lhsSymbol) <= 0 || len(rhsSymbol) <= 0 || len(outerSymbol) <= 0:
                continue
            add(out, lhsSymbol)
            add(out, rhsSymbol)
            add(out, outerSymbol)
            return out
    return out

fn compilerCoreDirectExecNestedCallWords(plan: cflow.LowUirCompilerCorePlan,
                                         itemIdx: int32,
                                         targetTriple: str): str =
    let architecture = mtarget.machineTargetArchitecture(targetTriple)
    let opCount = plan.routineOpCounts[itemIdx]
    let opStart = plan.routineOpStarts[itemIdx]
    if opCount == 8 &&
       plan.opKinds[opStart] == "local_decl" &&
       plan.opKinds[opStart + 1] == "load_routine" &&
       plan.opKinds[opStart + 2] == "call" &&
       plan.opKinds[opStart + 3] == "store_local" &&
       plan.opKinds[opStart + 4] == "load_routine" &&
       plan.opKinds[opStart + 5] == "load_local" &&
       plan.opKinds[opStart + 6] == "call" &&
       plan.opKinds[opStart + 7] == "return_value" &&
       plan.opArg0s[opStart + 2] == 0 &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 3] &&
       plan.opArg0s[opStart] == plan.opArg0s[opStart + 5] &&
       plan.opArg0s[opStart + 6] == 1:
        let innerCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 1, 0)
        let outerCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 4, 1)
        if innerCalleeIdx >= 0 &&
           outerCalleeIdx >= 0 &&
           plan.paramCounts[outerCalleeIdx] == 1 &&
           compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) == 1:
            let outerParam0TypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)
            if compilerCoreDirectTypeRegWidth(outerParam0TypeText) == 1 &&
               compilerCoreNormalizedTypeText(outerParam0TypeText) == compilerCoreNormalizedTypeText(plan.returnTypeTexts[innerCalleeIdx]):
                var noArgsKinds: str[]
                var noArgsPrimaryTexts: str[]
                var noArgsArg0s: int32[]
                noArgsKinds = []
                noArgsPrimaryTexts = []
                noArgsArg0s = []
                return machineDirectNestedCallWords(architecture,
                                                    plan.signatureTexts[itemIdx],
                                                    noArgsKinds,
                                                    noArgsPrimaryTexts,
                                                    noArgsArg0s)
    for argCount in 0..<5:
        let innerCallIdx = opStart + 2 + argCount
        let outerCallIdx = innerCallIdx + 1
        if opCount == argCount + 5 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx] == 1:
            var argKinds: str[]
            var argPrimaryTexts: str[]
            var argArg0s: int32[]
            argKinds = []
            argPrimaryTexts = []
            argArg0s = []
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOk = false
                add(argKinds, plan.opKinds[opStart + 2 + i])
                add(argPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(argArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk:
                let innerCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 1, argCount)
                var outerCalleeIdx: int32 = -1
                if innerCalleeIdx >= 0:
                    outerCalleeIdx = compilerCoreFindPlanItemIndexByResolvedTypeCall(plan,
                                                                                      itemIdx,
                                                                                      opStart,
                                                                                      plan.returnTypeTexts[innerCalleeIdx],
                                                                                      1)
                var innerReturnWidth: int32 = 0
                if compilerCoreDirectNestedTrailingArgsMatch(plan,
                                                             itemIdx,
                                                             innerCalleeIdx,
                                                             outerCalleeIdx,
                                                             [],
                                                             targetTriple,
                                                             innerReturnWidth):
                    if innerReturnWidth == 1:
                        return machineDirectNestedCallWords(architecture,
                                                            plan.signatureTexts[itemIdx],
                                                            argKinds,
                                                            argPrimaryTexts,
                                                            argArg0s)
                    if innerReturnWidth == 2 &&
                       compilerCoreHasDirectExecBody(plan, innerCalleeIdx, targetTriple):
                        return machineDirectNestedCallPairWords(architecture,
                                                                plan.signatureTexts[itemIdx],
                                                                argKinds,
                                                                argPrimaryTexts,
                                                                argArg0s,
                                                                compilerCoreDirectSecondRegIs64(plan.returnTypeTexts[innerCalleeIdx]))
                if innerCalleeIdx >= 0 &&
                   compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) == 2:
                    continue
        for outerLeadingArgCount in 1..<4:
            let innerLeadingRoutineIdx = opStart + 1 + outerLeadingArgCount
            let innerLeadingCallIdx = innerLeadingRoutineIdx + 1 + argCount
            let outerLeadingCallIdx = innerLeadingCallIdx + 1
            if opCount != outerLeadingArgCount + argCount + 5 ||
               plan.opKinds[opStart] != "load_routine" ||
               plan.opKinds[innerLeadingRoutineIdx] != "load_routine" ||
               plan.opKinds[innerLeadingCallIdx] != "call" ||
               plan.opKinds[outerLeadingCallIdx] != "call" ||
               plan.opKinds[outerLeadingCallIdx + 1] != "return_value" ||
               plan.opArg0s[innerLeadingCallIdx] != argCount ||
               plan.opArg0s[outerLeadingCallIdx] != outerLeadingArgCount + 1:
                continue
            var outerLeadingArgKinds: str[]
            var outerLeadingArgPrimaryTexts: str[]
            var outerLeadingArgArg0s: int32[]
            var innerLeadingArgKinds: str[]
            var innerLeadingArgPrimaryTexts: str[]
            var innerLeadingArgArg0s: int32[]
            var outerLeadingArgIdxs: int32[]
            outerLeadingArgKinds = []
            outerLeadingArgPrimaryTexts = []
            outerLeadingArgArg0s = []
            innerLeadingArgKinds = []
            innerLeadingArgPrimaryTexts = []
            innerLeadingArgArg0s = []
            outerLeadingArgIdxs = []
            var leadingArgsOk: bool = true
            for i in 0..<outerLeadingArgCount:
                let outerLeadingArgIdx = opStart + 1 + i
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerLeadingArgIdx):
                    leadingArgsOk = false
                add(outerLeadingArgKinds, plan.opKinds[outerLeadingArgIdx])
                add(outerLeadingArgPrimaryTexts, plan.opPrimaryTexts[outerLeadingArgIdx])
                add(outerLeadingArgArg0s, plan.opArg0s[outerLeadingArgIdx])
                add(outerLeadingArgIdxs, outerLeadingArgIdx)
            for i in 0..<argCount:
                let innerLeadingArgIdx = innerLeadingRoutineIdx + 1 + i
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, innerLeadingArgIdx):
                    leadingArgsOk = false
                add(innerLeadingArgKinds, plan.opKinds[innerLeadingArgIdx])
                add(innerLeadingArgPrimaryTexts, plan.opPrimaryTexts[innerLeadingArgIdx])
                add(innerLeadingArgArg0s, plan.opArg0s[innerLeadingArgIdx])
            let outerLeadingCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerLeadingCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[innerLeadingRoutineIdx])
            var innerLeadingReturnWidth: int32 = 0
            if leadingArgsOk &&
               compilerCoreDirectNestedLeadingArgsMatch(plan,
                                                        itemIdx,
                                                        innerLeadingCalleeIdx,
                                                        outerLeadingCalleeIdx,
                                                        outerLeadingArgIdxs,
                                                        targetTriple,
                                                        innerLeadingReturnWidth) &&
               innerLeadingReturnWidth == 1:
                return machineDirectNestedCallLeadingArgsWords(architecture,
                                                               plan.signatureTexts[itemIdx],
                                                               outerLeadingArgKinds,
                                                               outerLeadingArgPrimaryTexts,
                                                               outerLeadingArgArg0s,
                                                               innerLeadingArgKinds,
                                                               innerLeadingArgPrimaryTexts,
                                                               innerLeadingArgArg0s)
        let outerArgIdx = innerCallIdx + 1
        let outerCallIdx2 = innerCallIdx + 2
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerArgIdx] == "load_param" &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOk = false
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            var innerArgKinds: str[]
            var innerArgPrimaryTexts: str[]
            var innerArgArg0s: int32[]
            innerArgKinds = []
            innerArgPrimaryTexts = []
            innerArgArg0s = []
            for i in 0..<argCount:
                add(innerArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk &&
               outerCalleeIdx >= 0 &&
               innerCalleeIdx >= 0 &&
               outerCalleeIdx != itemIdx &&
               plan.paramCounts[outerCalleeIdx] == 2 &&
               compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[innerCalleeIdx]) == 1 &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)) == 1 &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1)) == 2 &&
               compilerCoreDirectTypeRegWidth(compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArgIdx])) == 2:
                let outerWords = compilerCoreDirectExecWords(plan, outerCalleeIdx, architecture)
                if len(outerWords) > 0:
                    let pairTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], plan.opArg0s[outerArgIdx])
                    let baseReg = compilerCoreParamBaseReg(plan.signatureTexts[itemIdx], plan.opArg0s[outerArgIdx])
                    return machineDirectNestedCallTrailingParamPairWords(architecture,
                                                                         plan.signatureTexts[itemIdx],
                                                                         innerArgKinds,
                                                                         innerArgPrimaryTexts,
                                                                         innerArgArg0s,
                                                                         baseReg,
                                                                         baseReg + 1,
                                                                         compilerCoreDirectSecondRegIs64(pairTypeText))
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           compilerCoreDirectNestedScalarArgSupported(plan, itemIdx, outerArgIdx) &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var innerArgKinds: str[]
            var innerArgPrimaryTexts: str[]
            var innerArgArg0s: int32[]
            innerArgKinds = []
            innerArgPrimaryTexts = []
            innerArgArg0s = []
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOk = false
                add(innerArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk:
                return machineDirectNestedCallTrailingSimpleArgWords(architecture,
                                                                     plan.signatureTexts[itemIdx],
                                                                     innerArgKinds,
                                                                     innerArgPrimaryTexts,
                                                                     innerArgArg0s,
                                                                     plan.opKinds[outerArgIdx],
                                                                     plan.opPrimaryTexts[outerArgIdx],
                                                                     plan.opArg0s[outerArgIdx])
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var innerArgKinds: str[]
            var innerArgPrimaryTexts: str[]
            var innerArgArg0s: int32[]
            innerArgKinds = []
            innerArgPrimaryTexts = []
            innerArgArg0s = []
            var argsOkWide: bool = compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArgIdx)
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOkWide = false
                add(innerArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            var innerReturnWidth: int32 = 0
            if argsOkWide &&
               compilerCoreDirectNestedTrailingArgsMatch(plan,
                                                        itemIdx,
                                                        innerCalleeIdx,
                                                        outerCalleeIdx,
                                                        [outerArgIdx],
                                                        targetTriple,
                                                        innerReturnWidth):
                return machineDirectNestedCallTrailingArgsWords(architecture,
                                                                plan.signatureTexts[itemIdx],
                                                                innerArgKinds,
                                                                innerArgPrimaryTexts,
                                                                innerArgArg0s,
                                                                innerReturnWidth,
                                                                [plan.opKinds[outerArgIdx]],
                                                                [plan.opPrimaryTexts[outerArgIdx]],
                                                                [plan.opArg0s[outerArgIdx]])
        let outerArg1Idx = innerCallIdx + 2
        let outerCallIdx3 = innerCallIdx + 3
        if opCount == argCount + 8 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           compilerCoreDirectNestedScalarArgSupported(plan, itemIdx, outerArgIdx) &&
           compilerCoreDirectNestedScalarArgSupported(plan, itemIdx, outerArg1Idx) &&
           plan.opKinds[outerCallIdx3] == "call" &&
           plan.opKinds[outerCallIdx3 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx3] == 3:
            var innerArgKinds: str[]
            var innerArgPrimaryTexts: str[]
            var innerArgArg0s: int32[]
            innerArgKinds = []
            innerArgPrimaryTexts = []
            innerArgArg0s = []
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreDirectNestedScalarArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOk = false
                add(innerArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk:
                return machineDirectNestedCallTrailingTwoSimpleArgWords(architecture,
                                                                        plan.signatureTexts[itemIdx],
                                                                        innerArgKinds,
                                                                        innerArgPrimaryTexts,
                                                                        innerArgArg0s,
                                                                        plan.opKinds[outerArgIdx],
                                                                        plan.opPrimaryTexts[outerArgIdx],
                                                                        plan.opArg0s[outerArgIdx],
                                                                        plan.opKinds[outerArg1Idx],
                                                                        plan.opPrimaryTexts[outerArg1Idx],
                                                                        plan.opArg0s[outerArg1Idx])
        if opCount == argCount + 8 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx3] == "call" &&
           plan.opKinds[outerCallIdx3 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx3] == 3:
            var innerArgKinds: str[]
            var innerArgPrimaryTexts: str[]
            var innerArgArg0s: int32[]
            innerArgKinds = []
            innerArgPrimaryTexts = []
            innerArgArg0s = []
            var argsOkWide: bool =
                compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArgIdx) &&
                compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArg1Idx)
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOkWide = false
                add(innerArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            var innerReturnWidth: int32 = 0
            if argsOkWide &&
               compilerCoreDirectNestedTrailingArgsMatch(plan,
                                                        itemIdx,
                                                        innerCalleeIdx,
                                                        outerCalleeIdx,
                                                        [outerArgIdx, outerArg1Idx],
                                                        targetTriple,
                                                        innerReturnWidth):
                return machineDirectNestedCallTrailingArgsWords(architecture,
                                                                plan.signatureTexts[itemIdx],
                                                                innerArgKinds,
                                                                innerArgPrimaryTexts,
                                                                innerArgArg0s,
                                                                innerReturnWidth,
                                                                [plan.opKinds[outerArgIdx], plan.opKinds[outerArg1Idx]],
                                                                [plan.opPrimaryTexts[outerArgIdx], plan.opPrimaryTexts[outerArg1Idx]],
                                                                [plan.opArg0s[outerArgIdx], plan.opArg0s[outerArg1Idx]])
        let outerArg2Idx = innerCallIdx + 3
        let outerCallIdx4 = innerCallIdx + 4
        if opCount == argCount + 9 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           compilerCoreDirectNestedScalarArgSupported(plan, itemIdx, outerArgIdx) &&
           compilerCoreDirectNestedScalarArgSupported(plan, itemIdx, outerArg1Idx) &&
           compilerCoreDirectNestedScalarArgSupported(plan, itemIdx, outerArg2Idx) &&
           plan.opKinds[outerCallIdx4] == "call" &&
           plan.opKinds[outerCallIdx4 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx4] == 4:
            var innerArgKinds: str[]
            var innerArgPrimaryTexts: str[]
            var innerArgArg0s: int32[]
            innerArgKinds = []
            innerArgPrimaryTexts = []
            innerArgArg0s = []
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOk = false
                add(innerArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk:
                return machineDirectNestedCallTrailingThreeSimpleArgWords(architecture,
                                                                          plan.signatureTexts[itemIdx],
                                                                          innerArgKinds,
                                                                          innerArgPrimaryTexts,
                                                                          innerArgArg0s,
                                                                          plan.opKinds[outerArgIdx],
                                                                          plan.opPrimaryTexts[outerArgIdx],
                                                                          plan.opArg0s[outerArgIdx],
                                                                          plan.opKinds[outerArg1Idx],
                                                                          plan.opPrimaryTexts[outerArg1Idx],
                                                                          plan.opArg0s[outerArg1Idx],
                                                                          plan.opKinds[outerArg2Idx],
                                                                          plan.opPrimaryTexts[outerArg2Idx],
                                                                          plan.opArg0s[outerArg2Idx])
        if opCount == argCount + 9 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx4] == "call" &&
           plan.opKinds[outerCallIdx4 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx4] == 4:
            var innerArgKinds: str[]
            var innerArgPrimaryTexts: str[]
            var innerArgArg0s: int32[]
            innerArgKinds = []
            innerArgPrimaryTexts = []
            innerArgArg0s = []
            var argsOkWide: bool =
                compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArgIdx) &&
                compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArg1Idx) &&
                compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, outerArg2Idx)
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOkWide = false
                add(innerArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let innerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart + 1])
            var innerReturnWidth: int32 = 0
            if argsOkWide &&
               compilerCoreDirectNestedTrailingArgsMatch(plan,
                                                        itemIdx,
                                                        innerCalleeIdx,
                                                        outerCalleeIdx,
                                                        [outerArgIdx, outerArg1Idx, outerArg2Idx],
                                                        targetTriple,
                                                        innerReturnWidth):
                return machineDirectNestedCallTrailingArgsWords(architecture,
                                                                plan.signatureTexts[itemIdx],
                                                                innerArgKinds,
                                                                innerArgPrimaryTexts,
                                                                innerArgArg0s,
                                                                innerReturnWidth,
                                                                [plan.opKinds[outerArgIdx], plan.opKinds[outerArg1Idx], plan.opKinds[outerArg2Idx]],
                                                                [plan.opPrimaryTexts[outerArgIdx], plan.opPrimaryTexts[outerArg1Idx], plan.opPrimaryTexts[outerArg2Idx]],
                                                                [plan.opArg0s[outerArgIdx], plan.opArg0s[outerArg1Idx], plan.opArg0s[outerArg2Idx]])
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerArgIdx] == "load_str" &&
           plan.opKinds[outerCallIdx2] == "call" &&
           plan.opKinds[outerCallIdx2 + 1] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx2] == 2:
            var innerArgKinds: str[]
            var innerArgPrimaryTexts: str[]
            var innerArgArg0s: int32[]
            innerArgKinds = []
            innerArgPrimaryTexts = []
            innerArgArg0s = []
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOk = false
                add(innerArgKinds, plan.opKinds[opStart + 2 + i])
                add(innerArgPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(innerArgArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk:
                return machineDirectNestedCallTrailingCStringArgWords(architecture,
                                                                      plan.signatureTexts[itemIdx],
                                                                      innerArgKinds,
                                                                      innerArgPrimaryTexts,
                                                                      innerArgArg0s,
                                                                      len(plan.opPrimaryTexts[outerArgIdx]))
        if opCount == argCount + 7 &&
           plan.opKinds[opStart] == "load_routine" &&
           plan.opKinds[opStart + 1] == "load_routine" &&
           plan.opKinds[innerCallIdx] == "call" &&
           plan.opKinds[outerCallIdx] == "call" &&
           compilerCoreIsDirectConstValueKind(plan.opKinds[outerCallIdx + 1]) &&
           plan.opKinds[outerCallIdx + 2] == "binary_op" &&
           plan.opKinds[outerCallIdx + 3] == "return_value" &&
           plan.opArg0s[innerCallIdx] == argCount &&
           plan.opArg0s[outerCallIdx] == 1:
            let compareOperatorText = plan.opPrimaryTexts[outerCallIdx + 2]
            if compareOperatorText != "==" && compareOperatorText != "!=" &&
               compareOperatorText != "<" && compareOperatorText != "<=" &&
               compareOperatorText != ">" && compareOperatorText != ">=":
                continue
            var argKinds: str[]
            var argPrimaryTexts: str[]
            var argArg0s: int32[]
            argKinds = []
            argPrimaryTexts = []
            argArg0s = []
            var argsOk: bool = true
            for i in 0..<argCount:
                if !compilerCoreDirectNestedInnerArgSupported(plan, itemIdx, opStart + 2 + i):
                    argsOk = false
                add(argKinds, plan.opKinds[opStart + 2 + i])
                add(argPrimaryTexts, plan.opPrimaryTexts[opStart + 2 + i])
                add(argArg0s, plan.opArg0s[opStart + 2 + i])
            if argsOk:
                return machineDirectNestedCallCompareConstRhsWords(architecture,
                                                                   plan.signatureTexts[itemIdx],
                                                                   argKinds,
                                                                   argPrimaryTexts,
                                                                   argArg0s,
                                                                   plan.opKinds[outerCallIdx + 1],
                                                                   plan.opPrimaryTexts[outerCallIdx + 1],
                                                                   plan.opArg0s[outerCallIdx + 1],
                                                                   compareOperatorText)
        for rhsArgCount in 0..<5:
            let rhsRoutineIdx = innerCallIdx + 1
            let rhsCallIdx = rhsRoutineIdx + 1 + rhsArgCount
            let compareOuterCallIdx = rhsCallIdx + 1
            if opCount != argCount + rhsArgCount + 9 ||
               plan.opKinds[opStart] != "load_routine" ||
               plan.opKinds[opStart + 1] != "load_routine" ||
               plan.opKinds[innerCallIdx] != "call" ||
               plan.opKinds[rhsRoutineIdx] != "load_routine" ||
               plan.opKinds[rhsCallIdx] != "call" ||
               plan.opKinds[compareOuterCallIdx] != "call" ||
               !compilerCoreIsDirectConstValueKind(plan.opKinds[compareOuterCallIdx + 1]) ||
               plan.opKinds[compareOuterCallIdx + 2] != "binary_op" ||
               plan.opKinds[compareOuterCallIdx + 3] != "return_value" ||
               plan.opArg0s[innerCallIdx] != argCount ||
               plan.opArg0s[rhsCallIdx] != rhsArgCount ||
               plan.opArg0s[compareOuterCallIdx] != 2:
                continue
            let compareOperatorText = plan.opPrimaryTexts[compareOuterCallIdx + 2]
            if compareOperatorText != "==" && compareOperatorText != "!=" &&
               compareOperatorText != "<" && compareOperatorText != "<=" &&
               compareOperatorText != ">" && compareOperatorText != ">=":
                continue
            let outerCalleeIdx = compilerCoreFindPlanItemIndex(plan, plan.opArg0s[opStart])
            let lhsCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart + 1, argCount)
            let rhsCalleeIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, rhsRoutineIdx, rhsArgCount)
            if outerCalleeIdx < 0 || lhsCalleeIdx < 0 || rhsCalleeIdx < 0:
                continue
            if plan.paramCounts[outerCalleeIdx] != 2:
                continue
            if compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[lhsCalleeIdx]) != 1 ||
               compilerCoreDirectTypeRegWidth(plan.returnTypeTexts[rhsCalleeIdx]) != 1:
                continue
            let outerParam0TypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 0)
            let outerParam1TypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[outerCalleeIdx], 1)
            if compilerCoreDirectTypeRegWidth(outerParam0TypeText) != 1 ||
               compilerCoreDirectTypeRegWidth(outerParam1TypeText) != 1:
                continue
            if compilerCoreNormalizedTypeText(outerParam0TypeText) != compilerCoreNormalizedTypeText(plan.returnTypeTexts[lhsCalleeIdx]) ||
               compilerCoreNormalizedTypeText(outerParam1TypeText) != compilerCoreNormalizedTypeText(plan.returnTypeTexts[rhsCalleeIdx]):
                continue
    return ""

fn compilerCoreDirectExecCallCompareConstSymbol(plan: cflow.LowUirCompilerCorePlan,
                                                itemIdx: int32,
                                                opStart: int32,
                                                opCount: int32,
                                                targetTriple: str): str =
    for argCount in 0..<5:
        let callIdx = opStart + 1 + argCount
        let constIdx = callIdx + 1
        let binaryIdx = callIdx + 2
        let returnIdx = callIdx + 3
        if opCount != argCount + 5 ||
           plan.opKinds[opStart] != "load_routine" ||
           plan.opKinds[callIdx] != "call" ||
           !compilerCoreIsDirectConstValueKind(plan.opKinds[constIdx]) ||
           plan.opKinds[binaryIdx] != "binary_op" ||
           plan.opKinds[returnIdx] != "return_value" ||
           plan.opArg0s[callIdx] != argCount:
            continue
        var argsOk: bool = true
        var argKinds: str[]
        var argPrimaryTexts: str[]
        var argArg0s: int32[]
        argKinds = []
        argPrimaryTexts = []
        argArg0s = []
        for i in 0..<argCount:
            let argIdx = opStart + 1 + i
            if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[argIdx]):
                argsOk = false
            add(argKinds, plan.opKinds[argIdx])
            add(argPrimaryTexts, plan.opPrimaryTexts[argIdx])
            add(argArg0s, plan.opArg0s[argIdx])
        if !argsOk:
            continue
        let calleeItemIdx = compilerCoreFindPlanItemIndexByDirectCallArgs(plan,
                                                                          itemIdx,
                                                                          opStart,
                                                                          plan.signatureTexts[itemIdx],
                                                                          argKinds,
                                                                          argPrimaryTexts,
                                                                          argArg0s,
                                                                          argCount,
                                                                          targetTriple)
        if calleeItemIdx >= 0:
            return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecCallCompareConstWords(plan: cflow.LowUirCompilerCorePlan,
                                               itemIdx: int32,
                                               opStart: int32,
                                               opCount: int32,
                                               targetTriple: str,
                                               architecture: str): str =
    for argCount in 0..<5:
        let callIdx = opStart + 1 + argCount
        let constIdx = callIdx + 1
        let binaryIdx = callIdx + 2
        let returnIdx = callIdx + 3
        if opCount != argCount + 5 ||
           plan.opKinds[opStart] != "load_routine" ||
           plan.opKinds[callIdx] != "call" ||
           !compilerCoreIsDirectConstValueKind(plan.opKinds[constIdx]) ||
           plan.opKinds[binaryIdx] != "binary_op" ||
           plan.opKinds[returnIdx] != "return_value" ||
           plan.opArg0s[callIdx] != argCount:
            continue
        var argKinds: str[]
        var argPrimaryTexts: str[]
        var argArg0s: int32[]
        argKinds = []
        argPrimaryTexts = []
        argArg0s = []
        var argsOk: bool = true
        for i in 0..<argCount:
            let argIdx = opStart + 1 + i
            if !compilerCoreIsDirectSimpleValueKind(plan.opKinds[argIdx]):
                argsOk = false
            add(argKinds, plan.opKinds[argIdx])
            add(argPrimaryTexts, plan.opPrimaryTexts[argIdx])
            add(argArg0s, plan.opArg0s[argIdx])
        if !argsOk:
            continue
        if compilerCoreFindPlanItemIndexByDirectCallArgs(plan,
                                                         itemIdx,
                                                         opStart,
                                                         plan.signatureTexts[itemIdx],
                                                         argKinds,
                                                         argPrimaryTexts,
                                                         argArg0s,
                                                         argCount,
                                                         targetTriple) < 0:
            continue
        return machineDirectCallCompareConstRhsWords(architecture,
                                                     argKinds,
                                                     argPrimaryTexts,
                                                     argArg0s,
                                                     plan.opKinds[constIdx],
                                                     plan.opPrimaryTexts[constIdx],
                                                     plan.opArg0s[constIdx],
                                                     plan.opPrimaryTexts[binaryIdx])
    return ""

fn compilerCoreDirectExecFieldCallSymbol(plan: cflow.LowUirCompilerCorePlan,
                                         itemIdx: int32,
                                         opStart: int32,
                                         opCount: int32,
                                         targetTriple: str): str =
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opKinds[opStart + 2] == "load_field" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        if calleeItemIdx >= 0:
            let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
            var aggregateResultTypeText: str = ""
            var sourceReg0: int32 = -1
            var sourceReg1: int32 = -1
            var sourceReg1Is64: bool = false
            if compilerCoreDirectAggregateFieldBinding(paramTypeText,
                                                       plan.opPrimaryTexts[opStart + 2],
                                                       aggregateResultTypeText,
                                                       sourceReg0,
                                                       sourceReg1,
                                                       sourceReg1Is64) &&
               compilerCoreTypeMatches(compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0),
                                       aggregateResultTypeText):
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
            var sourceReg: int32 = -1
            var is64: bool = false
            if compilerCoreDirectScalarFieldArgBinding(paramTypeText,
                                                       plan.opPrimaryTexts[opStart + 2],
                                                       compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0),
                                                       sourceReg,
                                                       is64):
                return compilerCoreDirectExecCalleeSymbol(plan, calleeItemIdx, targetTriple)
    return ""

fn compilerCoreDirectExecFieldCallWords(plan: cflow.LowUirCompilerCorePlan,
                                        itemIdx: int32,
                                        opStart: int32,
                                        opCount: int32,
                                        architecture: str): str =
    if opCount == 5 &&
       plan.opKinds[opStart] == "load_routine" &&
       plan.opKinds[opStart + 1] == "load_param" &&
       plan.opArg0s[opStart + 1] == 0 &&
       plan.opKinds[opStart + 2] == "load_field" &&
       plan.opKinds[opStart + 3] == "call" &&
       plan.opKinds[opStart + 4] == "return_value" &&
       plan.opArg0s[opStart + 3] == 1:
        let calleeItemIdx = compilerCoreDirectExecCallItemIndex(plan, itemIdx, opStart, 1)
        if calleeItemIdx < 0:
            return ""
        if compilerCoreDirectExecImportcBridgeNeeded(plan, calleeItemIdx, false):
            return ""
        let paramTypeText = compilerCoreSignatureParamTypeText(plan.signatureTexts[itemIdx], 0)
        var aggregateResultTypeText: str = ""
        var sourceReg0: int32 = -1
        var sourceReg1: int32 = -1
        var sourceReg1Is64: bool = false
        if compilerCoreDirectAggregateFieldBinding(paramTypeText,
                                                   plan.opPrimaryTexts[opStart + 2],
                                                   aggregateResultTypeText,
                                                   sourceReg0,
                                                   sourceReg1,
                                                   sourceReg1Is64):
            return machineDirectCallRegisterPairArgWords(architecture,
                                                         sourceReg0,
                                                         sourceReg1,
                                                         sourceReg1Is64)
        var sourceReg: int32 = -1
        var is64: bool = false
        if compilerCoreDirectScalarFieldArgBinding(paramTypeText,
                                                   plan.opPrimaryTexts[opStart + 2],
                                                   compilerCoreSignatureParamTypeText(plan.signatureTexts[calleeItemIdx], 0),
                                                   sourceReg,
                                                   is64):
            return machineDirectCallRegisterArgWords(architecture, sourceReg, is64)
    return ""

