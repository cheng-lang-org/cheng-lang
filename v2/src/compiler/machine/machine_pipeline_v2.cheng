    return machineLibcSymbolName(targetTriple, "driver_c_str_eq_raw_bridge")

fn compilerCoreDirectExecFieldCStringIfExprWords(plan: cflow.LowUirCompilerCorePlan,
                                                 itemIdx: int32,
                                                 architecture: str): str =
    var sourceReg0: int32 = -1
    var sourceReg1: int32 = -1
    var sourceReg1Is64: bool = false
    var condPayload: str = ""
    var thenPayload: str = ""
    var elsePayload: str = ""
    if !compilerCoreMatchDirectExecFieldCStringIfExpr(plan,
                                                      itemIdx,
                                                      sourceReg0,
                                                      sourceReg1,
