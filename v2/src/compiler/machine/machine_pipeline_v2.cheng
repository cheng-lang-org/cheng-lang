fn rewriteMachineFunctionDirectExecCallTwoCStringData(out: var MachineModuleBundle,
                                                      functionIdx: int32,
                                                      words: str,
                                                      callSymbol: str,
                                                      payloadText0: str,
                                                      payloadText1: str) =
    let callOffsets = machineDirectCallRelocOffsets(words)
    if callOffsets.len != 1:
        panic("v2 machine pipeline: direct exec call two cstring reloc count mismatch")
    let dataRelocOffsets0 = machineDirectFirstCStringRelocOffsets(words)
    let dataRelocOffsets1 = machineDirectSecondCStringRelocOffsets(words)
    if dataRelocOffsets0.len != 2 || dataRelocOffsets1.len != 2:
        panic("v2 machine pipeline: direct exec call two cstring data reloc count mismatch")
    let dataSymbol0 = out.symbolNames[functionIdx] + "_cstring0"
    let dataSymbol1 = out.symbolNames[functionIdx] + "_cstring1"
    out.runtimeTargets[functionIdx] = ""
    out.callSymbolNames[functionIdx] = callSymbol
    out.instructionWordHex[functionIdx] = words
    out.functionByteSizes[functionIdx] = wordCount(words) * 4
    out.localPayloadPageRelocOffsets[functionIdx] = dataRelocOffsets0[0]
    out.localPayloadPageoffRelocOffsets[functionIdx] = dataRelocOffsets0[1]
    out.callRelocOffsets[functionIdx] = callOffsets[0]
    out.metadataOperandModes[functionIdx] = "direct_exec_call_cstring_payload"
    out.localPayloadTexts[functionIdx] = payloadText0 + "|" + payloadText1
    let relocStart = out.relocOffsets.len
    out.functionRelocStarts[functionIdx] = relocStart
    appendMachineDataSymbol(out,
                            dataSymbol0,
                            out.cstringSectionName,
                            payloadText0,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineDataSymbol(out,
                            dataSymbol1,
                            out.cstringSectionName,
                            payloadText1,
                            mtarget.machineTargetCStringAlignPow2(out.targetTriple))
    appendMachineRelocation(out,
                            dataRelocOffsets0[0],
                            dataSymbol0,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            dataRelocOffsets0[1],
                            dataSymbol0,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            dataRelocOffsets1[0],
                            dataSymbol1,
                            out.metadataPageRelocationKind)
    appendMachineRelocation(out,
                            dataRelocOffsets1[1],
                            dataSymbol1,
                            out.metadataPageoffRelocationKind)
    appendMachineRelocation(out,
                            callOffsets[0],
                            callSymbol,
                            out.callRelocationKind)
    out.functionRelocCounts[functionIdx] = 5

