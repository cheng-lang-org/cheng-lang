type
    MachineTargetContract =
        version: str
        architectures: str[]
        firstClassTargets: str[]
        artifactKinds: str[]
        regalloc: str

fn machineTargetContract(): MachineTargetContract =
    var out: MachineTargetContract
    out.version = "v2.machine.v1"
    out.architectures = []
    add(out.architectures, "aarch64")
    out.firstClassTargets = []
    add(out.firstClassTargets, "arm64-apple-darwin")
    out.artifactKinds = []
    add(out.artifactKinds, "exe")
    add(out.artifactKinds, "shared")
    add(out.artifactKinds, "static")
    out.regalloc = "linear_scan_deterministic"
    return out

fn machineFirstClassTargetCount(): int32 =
    let c = machineTargetContract()
    return c.firstClassTargets.len

fn requireMachineTarget(target: str) =
    let c = machineTargetContract()
    for i in 0..<c.firstClassTargets.len:
        if c.firstClassTargets[i] == target:
            return
    panic("v2 machine target: unsupported target " + target)

fn machineTargetArchitecture(target: str): str =
    return machineTargetArchitectureBridge(target)

fn machineTargetObjFormat(target: str): str =
    return machineTargetObjFormatBridge(target)

