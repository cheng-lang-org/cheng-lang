import std/seqs

type
    MachineTargetContract =
        version: str
        architectures: str[]
        firstClassTargets: str[]
        artifactKinds: str[]
        regalloc: str

fn machineTargetContract(): MachineTargetContract =
    var out: MachineTargetContract
    out.version = "v2.machine.v1"
    out.architectures = []
    add(out.architectures, "aarch64")
    add(out.architectures, "x86_64")
    out.firstClassTargets = []
    add(out.firstClassTargets, "arm64-apple-darwin")
    add(out.firstClassTargets, "aarch64-linux-android")
    add(out.firstClassTargets, "aarch64-apple-ios")
    out.artifactKinds = []
    add(out.artifactKinds, "exe")
    add(out.artifactKinds, "shared")
    add(out.artifactKinds, "static")
    out.regalloc = "linear_scan_deterministic"
    return out

fn machineFirstClassTargetCount(): int32 =
    let c = machineTargetContract()
    return c.firstClassTargets.len

fn requireMachineTarget(target: str) =
    let c = machineTargetContract()
    for i in 0..<c.firstClassTargets.len:
        if c.firstClassTargets[i] == target:
            return
    panic("v2 machine target: unsupported target " + target)

fn machineTargetArchitecture(target: str): str =
    requireMachineTarget(target)
    return "aarch64"

fn machineTargetObjFormat(target: str): str =
    requireMachineTarget(target)
    if target == "aarch64-linux-android":
        return "elf"
    return "macho"

fn machineTargetSymbolPrefix(target: str): str =
    return machineTargetObjFormat(target) == "macho" ? "_" : ""

fn machineTargetTextSectionName(target: str): str =
    return machineTargetObjFormat(target) == "macho" ? "__TEXT,__text" : ".text"

fn machineTargetCStringSectionName(target: str): str =
    return machineTargetObjFormat(target) == "macho" ? "__TEXT,__cstring" : ".rodata.str1.1"

fn machineTargetSymtabSectionName(target: str): str =
    return machineTargetObjFormat(target) == "macho" ? "__LINKEDIT,symtab" : ".symtab"

fn machineTargetStrtabSectionName(target: str): str =
    return machineTargetObjFormat(target) == "macho" ? "__LINKEDIT,strtab" : ".strtab"

fn machineTargetRelocSectionName(target: str): str =
    return machineTargetObjFormat(target) == "macho" ? "__LINKEDIT,reloc" : ".rela.text"

fn machineTargetCallRelocationKind(target: str): str =
    return machineTargetObjFormat(target) == "macho" ? "ARM64_RELOC_BRANCH26" : "R_AARCH64_CALL26"

fn machineTargetMetadataPageRelocationKind(target: str): str =
    return machineTargetObjFormat(target) == "macho" ? "ARM64_RELOC_PAGE21" : "R_AARCH64_ADR_PREL_PG_HI21"

fn machineTargetMetadataPageoffRelocationKind(target: str): str =
    return machineTargetObjFormat(target) == "macho" ? "ARM64_RELOC_PAGEOFF12" : "R_AARCH64_ADD_ABS_LO12_NC"

fn machineTargetPointerWidthBits(target: str): int32 =
    requireMachineTarget(target)
    return 64

fn machineTargetStackAlignBytes(target: str): int32 =
    requireMachineTarget(target)
    return 16

fn machineTargetTextAlignPow2(target: str): int32 =
    requireMachineTarget(target)
    return 2

fn machineTargetCStringAlignPow2(target: str): int32 =
    requireMachineTarget(target)
    return 0

fn machineTargetDarwinPlatformId(target: str): int32 =
    if machineTargetObjFormat(target) != "macho":
        panic("v2 machine target: darwin platform id only for macho target " + target)
    return target == "aarch64-apple-ios" ? 2 else: 1

fn machineTargetDarwinPlatformName(target: str): str =
    if machineTargetObjFormat(target) != "macho":
        panic("v2 machine target: darwin platform name only for macho target " + target)
    return target == "aarch64-apple-ios" ? "ios" else: "macos"

fn machineTargetDarwinMinos(target: str): int32 =
    if machineTargetObjFormat(target) != "macho":
        panic("v2 machine target: darwin minos only for macho target " + target)
    return target == "aarch64-apple-ios" ? 0x00110000 else: 0x000d0000

fn machineTargetDarwinMinosText(target: str): str =
    if machineTargetObjFormat(target) != "macho":
        panic("v2 machine target: darwin minos text only for macho target " + target)
    return target == "aarch64-apple-ios" ? "17.0" else: "13.0"

fn machineTargetDarwinArchName(target: str): str =
    if machineTargetObjFormat(target) != "macho":
        panic("v2 machine target: darwin arch name only for macho target " + target)
    let arch = machineTargetArchitecture(target)
    return arch == "aarch64" ? "arm64" else: arch

fn machineTargetDarwinSdkName(target: str): str =
    if machineTargetObjFormat(target) != "macho":
        panic("v2 machine target: darwin sdk name only for macho target " + target)
    return target == "aarch64-apple-ios" ? "iphoneos" else: "macosx"
