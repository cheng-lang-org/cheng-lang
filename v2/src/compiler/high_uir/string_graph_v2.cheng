import std/seqs
import compiler/frontend/string_surface_ir_v2 as surf

type
    HighUirStringGraph =
        version: str
        exprIds: int32[]
        opNames: str[]
        runtimeTargets: str[]
        resultKinds: str[]
        allocationModes: str[]
        zeroCopyFacts: bool[]
        leftTexts: str[]
        rightTexts: str[]
        builderNames: str[]
        charValues: int32[]
        intArg0: int32[]
        intArg1: int32[]
        byteValues: int32[]

fn highUirStringGraphVersion(): str =
    return "v2.high_uir.string_graph.v1"

fn newHighUirStringGraph(): HighUirStringGraph =
    var out: HighUirStringGraph
    out.version = highUirStringGraphVersion()
    out.exprIds = []
    out.opNames = []
    out.runtimeTargets = []
    out.resultKinds = []
    out.allocationModes = []
    out.zeroCopyFacts = []
    out.leftTexts = []
    out.rightTexts = []
    out.builderNames = []
    out.charValues = []
    out.intArg0 = []
    out.intArg1 = []
    out.byteValues = []
    return out

fn appendHighUirStringExpr(graph: var HighUirStringGraph,
                           exprId: int32,
                           opName: str,
                           runtimeTarget: str,
                           resultKind: str,
                           allocationMode: str,
                           zeroCopy: bool,
                           expr: surf.StringSurfaceExpr) =
    add(graph.exprIds, exprId)
    add(graph.opNames, opName)
    add(graph.runtimeTargets, runtimeTarget)
    add(graph.resultKinds, resultKind)
    add(graph.allocationModes, allocationMode)
    add(graph.zeroCopyFacts, zeroCopy)
    add(graph.leftTexts, expr.leftText)
    add(graph.rightTexts, expr.rightText)
    add(graph.builderNames, expr.builderName)
    add(graph.charValues, int32(expr.charValue))
    add(graph.intArg0, expr.intArg0)
    add(graph.intArg1, expr.intArg1)
    add(graph.byteValues, int32(expr.byteValue))

fn highUirStringExprCount(graph: HighUirStringGraph): int32 =
    return graph.exprIds.len
