import std/seqs
import compiler/frontend/compiler_core_surface_ir_v2 as ccore
import compiler/semantic_facts/compiler_core_facts_v2 as cfacts

type
    HighUirCompilerCoreAstSlice =
        paramStart: int32
        localStart: int32
        stmtStart: int32
        exprStart: int32
    HighUirCompilerCoreGraph =
        version: str
        itemIds: int32[]
        opNames: str[]
        topLevelKinds: str[]
        labels: str[]
        ownerModules: str[]
        sourcePaths: str[]
        importcSymbolTexts: str[]
        proofDomains: str[]
        effectClasses: str[]
        bindingScopes: str[]
        importPaths: str[]
        importTargetModulePaths: str[]
        importAliases: str[]
        importCategories: str[]
        signatureTexts: str[]
        signatureHashes: str[]
        bodyTexts: str[]
        bodyLineCounts: int32[]
        bodyHashes: str[]
        executableAstReady: bool[]
        returnTypeTexts: str[]
        paramCounts: int32[]
        localCounts: int32[]
        stmtCounts: int32[]
        exprCounts: int32[]
        stmtKindSets: str[]
        exprKindSets: str[]
        stmtSemanticSets: str[]
        exprSemanticSets: str[]
        stmtAssignTargetKinds: str[]
        stmtAssignTargetTexts: str[]
        stmtAssignTargetOwnerTexts: str[]
        stmtAssignTargetValueInts: int32[]
        stmtAssignTargetFieldOrdinals: int32[]
        itemParamStarts: int32[]
        itemLocalStarts: int32[]
        itemStmtStarts: int32[]
        itemExprStarts: int32[]
        paramNames: str[]
        paramTypeTexts: str[]
        paramKinds: str[]
        localNames: str[]
        localTypeTexts: str[]
        localKinds: str[]
        localInitExprIds: int32[]
        stmtKinds: str[]
        stmtPrimaryTexts: str[]
        stmtDetailTexts: str[]
        stmtPrimaryExprIds: int32[]
        stmtSecondaryExprIds: int32[]
        stmtChildStarts: int32[]
        stmtChildCounts: int32[]
        stmtElseChildStarts: int32[]
        stmtElseChildCounts: int32[]
        stmtChildIds: int32[]
        exprKinds: str[]
        exprPrimaryTexts: str[]
        exprDetailTexts: str[]
        exprReferenceKinds: str[]
        exprReferenceTargetKinds: str[]
        exprReferenceTexts: str[]
        exprReferenceItemIds: int32[]
        exprReferenceValueInts: int32[]
        exprCallTargetKinds: str[]
        exprCallTargetTexts: str[]
        exprCallTargetItemIds: int32[]
        exprChildStarts: int32[]
        exprChildCounts: int32[]
        exprChildIds: int32[]
        exprChildArgNames: str[]

fn highUirCompilerCoreGraphVersion(): str =
    return "v2.high_uir.compiler_core_graph.v10"

fn newHighUirCompilerCoreAstSlice(): HighUirCompilerCoreAstSlice =
    var out: HighUirCompilerCoreAstSlice
    out.paramStart = 0
    out.localStart = 0
    out.stmtStart = 0
    out.exprStart = 0
    return out

fn newHighUirCompilerCoreGraph(): HighUirCompilerCoreGraph =
    var out: HighUirCompilerCoreGraph
    out.version = highUirCompilerCoreGraphVersion()
    out.itemIds = []
    out.opNames = []
    out.topLevelKinds = []
    out.labels = []
    out.ownerModules = []
    out.sourcePaths = []
    out.importcSymbolTexts = []
    out.proofDomains = []
    out.effectClasses = []
    out.bindingScopes = []
    out.importPaths = []
    out.importTargetModulePaths = []
    out.importAliases = []
    out.importCategories = []
    out.signatureTexts = []
    out.signatureHashes = []
    out.bodyTexts = []
    out.bodyLineCounts = []
    out.bodyHashes = []
    out.executableAstReady = []
    out.returnTypeTexts = []
    out.paramCounts = []
    out.localCounts = []
    out.stmtCounts = []
    out.exprCounts = []
    out.stmtKindSets = []
    out.exprKindSets = []
    out.stmtSemanticSets = []
    out.exprSemanticSets = []
    out.stmtAssignTargetKinds = []
    out.stmtAssignTargetTexts = []
    out.stmtAssignTargetOwnerTexts = []
    out.stmtAssignTargetValueInts = []
    out.stmtAssignTargetFieldOrdinals = []
    out.itemParamStarts = []
    out.itemLocalStarts = []
    out.itemStmtStarts = []
    out.itemExprStarts = []
    out.paramNames = []
    out.paramTypeTexts = []
    out.paramKinds = []
    out.localNames = []
    out.localTypeTexts = []
    out.localKinds = []
    out.localInitExprIds = []
    out.stmtKinds = []
    out.stmtPrimaryTexts = []
    out.stmtDetailTexts = []
    out.stmtPrimaryExprIds = []
    out.stmtSecondaryExprIds = []
    out.stmtChildStarts = []
    out.stmtChildCounts = []
    out.stmtElseChildStarts = []
    out.stmtElseChildCounts = []
    out.stmtChildIds = []
    out.exprKinds = []
    out.exprPrimaryTexts = []
    out.exprDetailTexts = []
    out.exprReferenceKinds = []
    out.exprReferenceTargetKinds = []
    out.exprReferenceTexts = []
    out.exprReferenceItemIds = []
    out.exprReferenceValueInts = []
    out.exprCallTargetKinds = []
    out.exprCallTargetTexts = []
    out.exprCallTargetItemIds = []
    out.exprChildStarts = []
    out.exprChildCounts = []
    out.exprChildIds = []
    out.exprChildArgNames = []
    return out

fn compilerCoreJoinBodyLines(bodyLines: str[]): str =
    var out: str = ""
    for i in 0..<bodyLines.len:
        if i > 0:
            out = out + "\n"
        out = out + bodyLines[i]
    return out

fn compilerCoreGraphExprId(oldExprStart: int32,
                           newExprStart: int32,
                           exprId: int32): int32 =
    if exprId < 0:
        return -1
    if exprId < oldExprStart:
        panic("v2 high_uir compiler_core graph: expr id outside routine slice")
    return newExprStart + (exprId - oldExprStart)

fn compilerCoreGraphStmtId(oldStmtStart: int32,
                           newStmtStart: int32,
                           stmtId: int32): int32 =
    if stmtId < 0:
        return -1
    if stmtId < oldStmtStart:
        panic("v2 high_uir compiler_core graph: stmt id outside routine slice")
    return newStmtStart + (stmtId - oldStmtStart)

fn appendHighUirCompilerCoreRoutineAst(graph: var HighUirCompilerCoreGraph,
                                       program: ccore.CompilerCoreProgram,
                                       facts: cfacts.CompilerCoreSemanticFacts,
                                       decl: ccore.CompilerCoreRoutineDecl): HighUirCompilerCoreAstSlice =
    var out = newHighUirCompilerCoreAstSlice()
    out.paramStart = graph.paramNames.len
    out.localStart = graph.localNames.len
    out.stmtStart = graph.stmtKinds.len
    out.exprStart = graph.exprKinds.len
    for i in 0..<decl.paramCount:
        let param = program.routineParams[decl.paramStart + i]
        add(graph.paramNames, param.name)
        add(graph.paramTypeTexts, param.typeText)
        add(graph.paramKinds, param.kind)
    for i in 0..<decl.exprCount:
        let expr = program.exprs[decl.exprStart + i]
        let childStart = graph.exprChildIds.len
        for j in 0..<expr.childCount:
            add(graph.exprChildIds,
                compilerCoreGraphExprId(decl.exprStart,
                                        out.exprStart,
                                        program.exprChildIds[expr.childStart + j]))
            add(graph.exprChildArgNames, program.exprChildArgNames[expr.childStart + j])
        add(graph.exprKinds, expr.kind)
        add(graph.exprPrimaryTexts, expr.primaryText)
        add(graph.exprDetailTexts, expr.detailText)
        add(graph.exprReferenceKinds, facts.exprReferenceKinds[decl.exprStart + i])
        add(graph.exprReferenceTargetKinds, facts.exprReferenceTargetKinds[decl.exprStart + i])
        add(graph.exprReferenceTexts, facts.exprReferenceTexts[decl.exprStart + i])
        add(graph.exprReferenceItemIds, facts.exprReferenceItemIds[decl.exprStart + i])
        add(graph.exprReferenceValueInts, facts.exprReferenceValueInts[decl.exprStart + i])
        add(graph.exprCallTargetKinds, facts.exprCallTargetKinds[decl.exprStart + i])
        add(graph.exprCallTargetTexts, facts.exprCallTargetTexts[decl.exprStart + i])
        add(graph.exprCallTargetItemIds, facts.exprCallTargetItemIds[decl.exprStart + i])
        add(graph.exprChildStarts, childStart)
        add(graph.exprChildCounts, expr.childCount)
    for i in 0..<decl.localCount:
        let local = program.locals[decl.localStart + i]
        add(graph.localNames, local.name)
        add(graph.localTypeTexts, local.typeText)
        add(graph.localKinds, local.kind)
        add(graph.localInitExprIds,
            compilerCoreGraphExprId(decl.exprStart,
                                    out.exprStart,
                                    local.initExprId))
    for i in 0..<decl.stmtCount:
        let stmt = program.stmts[decl.stmtStart + i]
        let childStart = graph.stmtChildIds.len
        for j in 0..<stmt.childCount:
            add(graph.stmtChildIds,
                compilerCoreGraphStmtId(decl.stmtStart,
                                        out.stmtStart,
                                        program.stmtChildIds[stmt.childStart + j]))
        let elseChildStart = graph.stmtChildIds.len
        for j in 0..<stmt.elseChildCount:
            add(graph.stmtChildIds,
                compilerCoreGraphStmtId(decl.stmtStart,
                                        out.stmtStart,
                                        program.stmtChildIds[stmt.elseChildStart + j]))
        add(graph.stmtKinds, stmt.kind)
        add(graph.stmtPrimaryTexts, stmt.primaryText)
        add(graph.stmtDetailTexts, stmt.detailText)
        add(graph.stmtAssignTargetKinds, facts.stmtAssignTargetKinds[decl.stmtStart + i])
        add(graph.stmtAssignTargetTexts, facts.stmtAssignTargetTexts[decl.stmtStart + i])
        add(graph.stmtAssignTargetOwnerTexts, facts.stmtAssignTargetOwnerTexts[decl.stmtStart + i])
        add(graph.stmtAssignTargetValueInts, facts.stmtAssignTargetValueInts[decl.stmtStart + i])
        add(graph.stmtAssignTargetFieldOrdinals, facts.stmtAssignTargetFieldOrdinals[decl.stmtStart + i])
        add(graph.stmtPrimaryExprIds,
            compilerCoreGraphExprId(decl.exprStart,
                                    out.exprStart,
                                    stmt.primaryExprId))
        add(graph.stmtSecondaryExprIds,
            compilerCoreGraphExprId(decl.exprStart,
                                    out.exprStart,
                                    stmt.secondaryExprId))
        add(graph.stmtChildStarts, childStart)
        add(graph.stmtChildCounts, stmt.childCount)
        add(graph.stmtElseChildStarts, elseChildStart)
        add(graph.stmtElseChildCounts, stmt.elseChildCount)
    return out

fn appendHighUirCompilerCoreItem(graph: var HighUirCompilerCoreGraph,
                                 itemId: int32,
                                 opName: str,
                                 proofDomain: str,
                                 effectClass: str,
                                 bindingScope: str,
                                 importPath: str,
                                 importTargetModulePath: str,
                                 importAlias: str,
                                 importCategory: str,
                                 signatureText: str,
                                 signatureHash: str,
                                 bodyText: str,
                                 bodyLineCount: int32,
                                 bodyHash: str,
                                 executableAstReady: bool,
                                 returnTypeText: str,
                                 paramCount: int32,
                                 localCount: int32,
                                 stmtCount: int32,
                                 exprCount: int32,
                                 stmtKindSet: str,
                                 exprKindSet: str,
                                 stmtSemanticSet: str,
                                 exprSemanticSet: str,
                                 itemParamStart: int32,
                                 itemLocalStart: int32,
                                 itemStmtStart: int32,
                                 itemExprStart: int32,
                                 topLevelKind: str,
                                 label: str,
                                 importcSymbolText: str,
                                 ownerModule: str,
                                 sourcePath: str) =
    add(graph.itemIds, itemId)
    add(graph.opNames, opName)
    add(graph.topLevelKinds, topLevelKind)
    add(graph.labels, label)
    add(graph.ownerModules, ownerModule)
    add(graph.sourcePaths, sourcePath)
    add(graph.importcSymbolTexts, importcSymbolText)
    add(graph.proofDomains, proofDomain)
    add(graph.effectClasses, effectClass)
    add(graph.bindingScopes, bindingScope)
    add(graph.importPaths, importPath)
    add(graph.importTargetModulePaths, importTargetModulePath)
    add(graph.importAliases, importAlias)
    add(graph.importCategories, importCategory)
    add(graph.signatureTexts, signatureText)
    add(graph.signatureHashes, signatureHash)
    add(graph.bodyTexts, bodyText)
    add(graph.bodyLineCounts, bodyLineCount)
    add(graph.bodyHashes, bodyHash)
    add(graph.executableAstReady, executableAstReady)
    add(graph.returnTypeTexts, returnTypeText)
    add(graph.paramCounts, paramCount)
    add(graph.localCounts, localCount)
    add(graph.stmtCounts, stmtCount)
    add(graph.exprCounts, exprCount)
    add(graph.stmtKindSets, stmtKindSet)
    add(graph.exprKindSets, exprKindSet)
    add(graph.stmtSemanticSets, stmtSemanticSet)
    add(graph.exprSemanticSets, exprSemanticSet)
    add(graph.itemParamStarts, itemParamStart)
    add(graph.itemLocalStarts, itemLocalStart)
    add(graph.itemStmtStarts, itemStmtStart)
    add(graph.itemExprStarts, itemExprStart)

fn highUirCompilerCoreExprCount(graph: HighUirCompilerCoreGraph): int32 =
    return graph.exprKinds.len

fn highUirCompilerCoreStmtCount(graph: HighUirCompilerCoreGraph): int32 =
    return graph.stmtKinds.len
