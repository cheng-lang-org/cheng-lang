import std/seqs

type
    HighUirGraphContract =
        version: str
        storageModel: str
        indexKinds: str[]
        requiresSemanticFacts: bool
        indexOnly: bool

fn highUirGraphContract(): HighUirGraphContract =
    var out: HighUirGraphContract
    out.version = "v2.high_uir_graph.v2"
    out.storageModel = "soa_index"
    out.indexKinds = []
    add(out.indexKinds, "expr_id")
    add(out.indexKinds, "stmt_id")
    add(out.indexKinds, "block_id")
    add(out.indexKinds, "func_id")
    add(out.indexKinds, "actor_id")
    add(out.indexKinds, "state_id")
    add(out.indexKinds, "type_ref")
    add(out.indexKinds, "fact_ref")
    add(out.indexKinds, "contract_ref")
    add(out.indexKinds, "hash_ref")
    out.requiresSemanticFacts = true
    out.indexOnly = true
    return out

fn highUirIndexKindCount(): int32 =
    let c = highUirGraphContract()
    return c.indexKinds.len
