import std/seqs

type
    ObjWriterContract =
        version: str
        formats: str[]
        packageKinds: str[]
        notes: str[]

fn objWriterContract(): ObjWriterContract =
    var out: ObjWriterContract
    out.version = "v2.obj_writer.v1"
    out.formats = []
    add(out.formats, "macho")
    add(out.formats, "elf")
    out.packageKinds = []
    add(out.packageKinds, "exe")
    add(out.packageKinds, "shared")
    add(out.packageKinds, "static")
    out.notes = []
    add(out.notes, "darwin_and_ios_use_macho")
    add(out.notes, "android_uses_elf")
    add(out.notes, "public_emit_c_removed")
    return out

fn objWriterFormatCount(): int32 =
    let c = objWriterContract()
    return c.formats.len
