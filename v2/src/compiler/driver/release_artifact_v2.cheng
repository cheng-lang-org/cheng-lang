    add(lines, "native_link_plan_version=" + linkPlan.version)
    add(lines, "system_link_plan_version=" + systemLink.version)
    add(lines, "machine_architecture=" + machineBundle.architecture)
    add(lines, "machine_text_section=" + machineBundle.textSectionName)
    add(lines, "machine_call_relocation=" + machineBundle.callRelocationKind)
    add(lines, "machine_metadata_page_relocation=" + machineBundle.metadataPageRelocationKind)
    add(lines, "machine_metadata_pageoff_relocation=" + machineBundle.metadataPageoffRelocationKind)
    add(lines, "machine_stack_align=" + intToStr(machineBundle.stackAlignBytes))
    add(lines, "system_link_linker_flavor=" + systemLink.linkerFlavor)
    add(lines, "system_link_output_kind=" + systemLink.outputKind)
    add(lines, "system_link_output_suffix=" + systemLink.outputSuffix)
    add(lines, "system_link_entry_required=" + if systemLink.entryRequired: "1" else: "0")
    add(lines, "system_link_entry_symbol=" + systemLink.entrySymbol)
    add(lines, "system_link_provider_count=" + intToStr(systemLink.providerModules.len))
    var providerSymbolIdx: int32 = 0
    for i in 0..<systemLink.providerModules.len:
        add(lines, "system_link.provider." + intToStr(i) + ".module=" + systemLink.providerModules[i])
        add(lines, "system_link.provider." + intToStr(i) + ".source_path=" + systemLink.providerSourcePaths[i])
        add(lines, "system_link.provider." + intToStr(i) + ".source_kind=" + systemLink.providerSourceKinds[i])
        add(lines, "system_link.provider." + intToStr(i) + ".compile_mode=" + systemLink.providerCompileModes[i])
        add(lines, "system_link.provider." + intToStr(i) + ".manifest_cid=" + systemLink.providerManifestCids[i])
        add(lines, "system_link.provider." + intToStr(i) + ".execution_model=" + systemLink.providerExecutionModels[i])
        add(lines, "system_link.provider." + intToStr(i) + ".trace_symbol=" + systemLink.providerTraceSymbols[i])
        add(lines, "system_link.provider." + intToStr(i) + ".provider_symbol_count=" + intToStr(systemLink.providerSymbolCounts[i]))
        for j in 0..<systemLink.providerSymbolCounts[i]:
            add(lines,
                "system_link.provider." + intToStr(i) + ".provider_symbol." + intToStr(j) + "=" +
                systemLink.providerSymbolsFlat[providerSymbolIdx])
            providerSymbolIdx = providerSymbolIdx + 1
        add(lines, "system_link.provider." + intToStr(i) + ".obj_file_cid=" + systemLink.providerObjFileCids[i])
        add(lines, "system_link.provider." + intToStr(i) + ".obj_file_byte_count=" + intToStr(systemLink.providerObjFileByteCounts[i]))
    add(lines, "system_link_missing_reason_count=" + intToStr(systemLink.missingReasons.len))
    for i in 0..<systemLink.missingReasons.len:
        add(lines, "system_link.missing_reason." + intToStr(i) + "=" + systemLink.missingReasons[i])
    add(lines, "native_link_provider_count=" + intToStr(linkPlan.providerModules.len))
    add(lines, "native_link_runtime_target_count=" + intToStr(linkPlan.runtimeTargets.len))
    for i in 0..<linkPlan.providerModules.len:
        add(lines, "native_link.provider." + intToStr(i) + "=" + linkPlan.providerModules[i])
    for i in 0..<linkPlan.runtimeTargets.len:
        add(lines, "native_link.required." + intToStr(i) + "=" + linkPlan.runtimeTargets[i])
    add(lines, "compiler_core_top_level_count=" + intToStr(bundle.program.topLevelKinds.len))
    add(lines, "compiler_core_module_count=" + intToStr(bundle.program.modules.len))
    add(lines, "compiler_core_import_count=" + intToStr(bundle.program.imports.len))
    add(lines, "compiler_core_type_block_count=" + intToStr(bundle.program.typeBlocks.len))
    add(lines, "compiler_core_const_count=" + intToStr(bundle.program.constDecls.len))
    add(lines, "compiler_core_var_count=" + intToStr(bundle.program.varDecls.len))
    add(lines, "compiler_core_routine_count=" + intToStr(bundle.program.routines.len))
    for i in 0..<bundle.lowPlan.itemIds.len:
        add(lines, "compiler_core.item." + intToStr(i) + ".kind=" + bundle.lowPlan.topLevelKinds[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".label=" + bundle.lowPlan.labels[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".op=" + bundle.lowPlan.canonicalOps[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".runtime=" + bundle.lowPlan.runtimeTargets[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".proof=" + bundle.lowPlan.proofDomains[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".effect=" + bundle.lowPlan.effectClasses[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".binding_scope=" + bundle.lowPlan.bindingScopes[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".import_path=" + bundle.lowPlan.importPaths[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".import_alias=" + bundle.lowPlan.importAliases[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".import_category=" + bundle.lowPlan.importCategories[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".body_line_count=" + intToStr(bundle.lowPlan.bodyLineCounts[i]))
        add(lines, "compiler_core.item." + intToStr(i) + ".ast_ready=" + if bundle.lowPlan.executableAstReady[i]: "1" else: "0")
        add(lines, "compiler_core.item." + intToStr(i) + ".return_type=" + bundle.lowPlan.returnTypeTexts[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".param_count=" + intToStr(bundle.lowPlan.paramCounts[i]))
        add(lines, "compiler_core.item." + intToStr(i) + ".local_count=" + intToStr(bundle.lowPlan.localCounts[i]))
        add(lines, "compiler_core.item." + intToStr(i) + ".stmt_count=" + intToStr(bundle.lowPlan.stmtCounts[i]))
        add(lines, "compiler_core.item." + intToStr(i) + ".expr_count=" + intToStr(bundle.lowPlan.exprCounts[i]))
        add(lines, "compiler_core.item." + intToStr(i) + ".exec_op_count=" + intToStr(bundle.lowPlan.routineOpCounts[i]))
        add(lines, "compiler_core.item." + intToStr(i) + ".exec_op_hash=" + bundle.lowPlan.routineOpHashes[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".signature_hash=" + bundle.lowPlan.signatureHashes[i])
        add(lines, "compiler_core.item." + intToStr(i) + ".body_hash=" + bundle.lowPlan.bodyHashes[i])
    return manifest.joinLines(lines)

fn releaseArtifactCompileKeyHasLine(bundle: ReleaseArtifactBundle, line: str): bool =
    return parser.findText(bundle.compileKeyText, line) >= 0

fn releaseArtifactManifestRoot(sourcePath: str): str =
    if os.dirExists(sourcePath):
        return sourcePath
    let parent = os.parentDir(sourcePath)
    if len(parent) > 0:
        return parent
    return "."

fn buildReleaseArtifact(sourcePath: str, emitKind: str, targetTriple: str): ReleaseArtifactBundle =
    requireEmitKind(emitKind)
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    let manifestBundle = if parsed.compilerCoreProgram.topLevelKinds.len > 0:
        manifest.resolveCompilerCoreSourceManifest(sourcePath)
    else:
        manifest.resolveSourceManifest(releaseArtifactManifestRoot(sourcePath))
    let machine = mtarget.machineTargetContract()
    let writer = owriter.objWriterContract()
    let objFormat = objFormatForTarget(targetTriple)
    var moduleKind: str = ""
    var pipelineVersion: str = ""
    var surfaceCount: int32 = 0
    var compileKeyText: str = ""
    var topologyCount: int32 = 0
    var networkEntryCount: int32 = 0
    var compilerCoreEntryCount: int32 = 0
    var machineBundle: mpipeline.MachineModuleBundle
    var objBundle: oimg.ObjImageBundle
    var objFile: ofile.ObjFileBundle
    var linkPlan: NativeLinkPlanBundle
    var systemLink: slink.SystemLinkPlanBundle
    if parsed.networkProgram.topologies.len > 0 || parsed.networkProgram.ops.len > 0:
        let bundle = npipe.compileNetworkDistributionProgram(parsed.networkProgram)
        moduleKind = if parsed.networkProgram.ops.len > 0: "network_distribution" else: "topology"
        pipelineVersion = bundle.version
        surfaceCount = bundle.program.topologies.len + bundle.program.ops.len
        topologyCount = bundle.program.topologies.len
        networkEntryCount = bundle.lowPlan.opIds.len
        machineBundle = mpipeline.lowerNetworkDistributionPlanToMachine(bundle.lowPlan, targetTriple)
        objBundle = oimg.writeObjImage(machineBundle)
        objFile = ofile.buildObjFile(machineBundle)
        linkPlan = buildNativeLinkPlan(machineBundle, emitKind, targetTriple)
        if linkPlan.unresolvedTargets.len > 0:
            panic("v2 release artifact: unresolved native link closure for " + moduleKind)
        systemLink = slink.buildSystemLinkPlan(machineBundle,
                                               objFile,
                                               emitKind,
                                               linkPlan.providerModules,
                                               [],
                                               [],
                                               [])
        compileKeyText = buildNetworkCompileKeyText(bundle,
                                                    machineBundle,
                                                    objBundle,
                                                    objFile,
                                                    linkPlan,
                                                    systemLink,
                                                    moduleKind,
                                                    emitKind,
                                                    targetTriple,
                                                    manifestBundle.manifestCid,
                                                    objFormat)
    elif parsed.unimakerProgram.decls.len > 0:
        let bundle = upipe.compileUnimakerSurfaceProgram(parsed.unimakerProgram)
        moduleKind = "unimaker"
        pipelineVersion = bundle.version
        surfaceCount = bundle.program.decls.len
        machineBundle = mpipeline.lowerUnimakerPlanToMachine(bundle.lowPlan, targetTriple)
        objBundle = oimg.writeObjImage(machineBundle)
        objFile = ofile.buildObjFile(machineBundle)
        linkPlan = buildNativeLinkPlan(machineBundle, emitKind, targetTriple)
        if linkPlan.unresolvedTargets.len > 0:
            panic("v2 release artifact: unresolved native link closure for " + moduleKind)
        systemLink = slink.buildSystemLinkPlan(machineBundle,
                                               objFile,
                                               emitKind,
                                               linkPlan.providerModules,
                                               [],
                                               [],
                                               [])
        compileKeyText = buildUnimakerCompileKeyText(bundle,
                                                     machineBundle,
                                                     objBundle,
                                                     objFile,
                                                     linkPlan,
                                                     systemLink,
                                                     emitKind,
                                                     targetTriple,
                                                     manifestBundle.manifestCid,
                                                     objFormat)
    elif parsed.compilerCoreProgram.topLevelKinds.len > 0:
        let bundle = cpipe.compileCompilerCoreSourceClosure(sourcePath)
        moduleKind = "compiler_core"
        pipelineVersion = bundle.version
        surfaceCount = bundle.program.topLevelKinds.len
        compilerCoreEntryCount = bundle.lowPlan.itemIds.len
        machineBundle = mpipeline.lowerCompilerCorePlanToMachine(bundle.lowPlan, targetTriple)
        objBundle = oimg.writeObjImage(machineBundle)
        objFile = ofile.buildObjFile(machineBundle)
        linkPlan = buildNativeLinkPlan(machineBundle, emitKind, targetTriple)
        if linkPlan.unresolvedTargets.len > 0:
            panic("v2 release artifact: unresolved native link closure for " + moduleKind)
        systemLink = slink.buildSystemLinkPlan(machineBundle,
                                               objFile,
                                               emitKind,
                                               linkPlan.providerModules,
                                               bundle.lowPlan.itemIds,
                                               bundle.lowPlan.canonicalOps,
                                               bundle.lowPlan.labels)
        compileKeyText = buildCompilerCoreCompileKeyText(bundle,
                                                         machineBundle,
                                                         objBundle,
                                                         objFile,
                                                         linkPlan,
                                                         systemLink,
                                                         emitKind,
                                                         targetTriple,
                                                         manifestBundle.manifestCid,
                                                         objFormat)
    else:
        panic("v2 release artifact: no supported surface in " + sourcePath)
    let compileKey = ident.sha256HexText(compileKeyText)
    var lines: str[]
    lines = []
    add(lines, "artifact_version=" + releaseArtifactVersion())
    add(lines, "source=" + sourcePath)
    add(lines, "emit=" + emitKind)
    add(lines, "target=" + targetTriple)
    add(lines, "module_kind=" + moduleKind)
    add(lines, "pipeline_version=" + pipelineVersion)
    add(lines, "surface_count=" + intToStr(surfaceCount))
    add(lines, "machine_version=" + machine.version)
    add(lines, "machine_pipeline_version=" + machineBundle.version)
    add(lines, "obj_writer_version=" + writer.version)
    add(lines, "obj_image_version=" + objBundle.version)
    add(lines, "obj_file_version=" + objFile.version)
    add(lines, "obj_format=" + objFormat)
    add(lines, "manifest_cid=" + manifestBundle.manifestCid)
    add(lines, "compile_key=" + compileKey)
    add(lines, "obj_image_cid=" + objBundle.imageCid)
    add(lines, "obj_file_cid=" + objFile.fileCid)
    add(lines, "obj_file_byte_count=" + intToStr(objFile.fileByteCount))
    add(lines, "obj_section_count=" + intToStr(objBundle.sectionNames.len))
    add(lines, "obj_symbol_count=" + intToStr(objBundle.symbolNames.len))
    add(lines, "obj_reloc_count=" + intToStr(objBundle.relocationOffsets.len))
    add(lines, "link_plan_version=" + linkPlan.version)
    add(lines, "link_plan_cid=" + linkPlan.planCid)
    add(lines, "system_link_plan_version=" + systemLink.version)
    add(lines, "system_link_plan_cid=" + systemLink.planCid)
    add(lines, "runtime_target_count=" + intToStr(linkPlan.runtimeTargets.len))
    add(lines, "runtime_unresolved_count=" + intToStr(linkPlan.unresolvedTargets.len))
    add(lines, "native_link_closure_ok=" + if linkPlan.unresolvedTargets.len == 0: "1" else: "0")
    add(lines, "system_link_ready=" + if systemLink.missingReasons.len == 0: "1" else: "0")
    add(lines, "system_link_missing_reason_count=" + intToStr(systemLink.missingReasons.len))
    if moduleKind == "network_distribution" || moduleKind == "topology":
        add(lines, "topology_count=" + intToStr(topologyCount))
        add(lines, "network_entry_count=" + intToStr(networkEntryCount))
    elif moduleKind == "compiler_core":
        add(lines, "compiler_core_entry_count=" + intToStr(compilerCoreEntryCount))
    else:
        add(lines, "unimaker_entry_count=" + intToStr(surfaceCount))
    var out: ReleaseArtifactBundle
    out.version = releaseArtifactVersion()
    out.sourcePath = sourcePath
    out.emitKind = emitKind
    out.targetTriple = targetTriple
    out.moduleKind = moduleKind
    out.machineVersion = machine.version
    out.machinePipelineVersion = machineBundle.version
    out.objWriterVersion = writer.version
    out.objImageVersion = objBundle.version
    out.objFileVersion = objFile.version
    out.objFormat = objFormat
    out.manifestCid = manifestBundle.manifestCid
    out.compileKey = compileKey
    out.compileKeyText = compileKeyText
    out.objImageCid = objBundle.imageCid
    out.objFileCid = objFile.fileCid
    out.objFileByteCount = objFile.fileByteCount
    out.objSectionCount = objBundle.sectionNames.len
    out.objSymbolCount = objBundle.symbolNames.len
    out.objRelocCount = objBundle.relocationOffsets.len
    out.linkPlanVersion = linkPlan.version
    out.linkPlanCid = linkPlan.planCid
    out.systemLinkPlanVersion = systemLink.version
    out.systemLinkPlanCid = systemLink.planCid
    out.runtimeTargetCount = linkPlan.runtimeTargets.len
    out.runtimeUnresolvedCount = linkPlan.unresolvedTargets.len
    out.nativeLinkClosureOk = linkPlan.unresolvedTargets.len == 0
    out.systemLinkReady = systemLink.missingReasons.len == 0
    out.systemLinkMissingReasonCount = systemLink.missingReasons.len
    out.topologyCount = topologyCount
    out.networkEntryCount = networkEntryCount
    out.compilerCoreEntryCount = compilerCoreEntryCount
    out.systemLinkPlanText = systemLink.planText
    out.artifactText = manifest.joinLines(lines)
    return out
