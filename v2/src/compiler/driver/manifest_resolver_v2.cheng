import std/os
import std/seqs
import std/strutils as strutils
import std/strings as strings
import std/system
import compiler/driver/identity_v2 as ident
import compiler/frontend/v2_source_parser as parser
import compiler/frontend/network_distribution_surface_ir_v2 as nsurf

type
    SourceManifestBundle =
        version: str
        rootPath: str
        packageId: str
        filePaths: str[]
        fileCids: str[]
        fileTopologyRefs: str[]
        topologyCanonicalForms: str[]
        manifestText: str
        manifestCid: str
    CompilerCoreDeclaredModuleIndex =
        modulePaths: str[]
        sourcePaths: str[]
        lookupModulePaths: str[]
        lookupModuleIds: int32[]
        importTargetModulePaths: str[]
        importTargetStarts: int32[]
        importTargetCounts: int32[]
    CompilerCoreClosureGraph =
        modulePaths: str[]
        sourcePaths: str[]
        lookupModulePaths: str[]
        lookupModuleIds: int32[]
        importEdgeOwnerModuleIds: int32[]
        importEdgeTargetModuleIds: int32[]
        moduleSccIds: int32[]

fn sourceManifestVersion(): str =
    return "v2.source_manifest.v1"

fn newCompilerCoreDeclaredModuleIndex(): CompilerCoreDeclaredModuleIndex =
    var out: CompilerCoreDeclaredModuleIndex
    out.modulePaths = []
    out.sourcePaths = []
    out.lookupModulePaths = []
    out.lookupModuleIds = []
    out.importTargetModulePaths = []
    out.importTargetStarts = []
    out.importTargetCounts = []
    return out

fn newCompilerCoreClosureGraph(): CompilerCoreClosureGraph =
    var out: CompilerCoreClosureGraph
    out.modulePaths = []
    out.sourcePaths = []
    out.lookupModulePaths = []
    out.lookupModuleIds = []
    out.importEdgeOwnerModuleIds = []
    out.importEdgeTargetModuleIds = []
    out.moduleSccIds = []
    return out

fn createDirAll(path: str) =
    if path.len == 0 || os.dirExists(path):
        return
    let parent = os.parentDir(path)
    if parent.len > 0 && parent != path:
        createDirAll(parent)
    if !os.dirExists(path):
        os.createDir(path)

fn shouldIncludeSourcePath(relPath: str): bool =
    return relPath == "cheng-package.toml" || strings.hasSuffix(relPath, ".cheng")

fn ensureChengExt(path: str): str =
    if strings.hasSuffix(path, ".cheng"):
        return path
    return path + ".cheng"

fn currentPathProbe(path: str): str =
    let abs = os.absolutePath(path)
    if os.dirExists(abs):
        return abs
    return os.parentDir(abs)

fn findNearestPackageRoot(path: str): str =
    var probe = currentPathProbe(path)
    while probe.len > 0:
        if os.fileExists(os.joinPath(probe, "cheng-package.toml")):
            return probe
        let parent = os.parentDir(probe)
        if parent.len == 0 || parent == probe:
            break
        probe = parent
    return ""

fn findWorkspaceRoot(path: str): str =
    var probe = currentPathProbe(path)
    while probe.len > 0:
        if os.fileExists(os.joinPath(probe, "src/std/system.cheng")):
            return probe
        let parent = os.parentDir(probe)
        if parent.len == 0 || parent == probe:
            break
        probe = parent
    return ""

fn packageNameFromId(packageId: str): str =
    let slashIdx = parser.findLastChar(packageId, '/')
    if slashIdx < 0 || slashIdx + 1 >= packageId.len:
        return ""
    return strings.sliceBytes(packageId, slashIdx + 1, packageId.len - slashIdx - 1)

fn normalizeModulePath(modulePath: str): str =
    if strutils.startsWith(modulePath, "cheng/") && modulePath.len > len("cheng/"):
        return strings.sliceBytes(modulePath, len("cheng/"), modulePath.len - len("cheng/"))
    return modulePath

fn compilerCorePackageSourceRoots(packageRoot: str): str[] =
    var out: str[]
    out = []
    seqs.add(out, os.joinPath(packageRoot, "src"))
    seqs.add(out, os.joinPath(os.joinPath(packageRoot, "tests"), "contracts"))
    seqs.add(out, os.joinPath(packageRoot, "examples"))
    seqs.add(out, packageRoot)
    return out

fn compilerCoreSourceRoots(packageRoot: str, workspaceRoot: str): str[] =
    var out = compilerCorePackageSourceRoots(packageRoot)
    seqs.add(out, os.joinPath(workspaceRoot, "src"))
    return out

fn sortClosureModuleLookup(paths: var str[], ids: var int32[]) =
    var i: int32 = 1
    while i < paths.len:
        var j: int32 = i
        while j > 0 && cmp(paths[j], paths[j - 1]) < 0:
            let swapPath = paths[j - 1]
            let swapId = ids[j - 1]
            paths[j - 1] = paths[j]
            ids[j - 1] = ids[j]
            paths[j] = swapPath
            ids[j] = swapId
            j = j - 1
        i = i + 1

fn findDeclaredModulePathSlot(index: CompilerCoreDeclaredModuleIndex, modulePath: str): int32 =
    var lo: int32 = 0
    var hi: int32 = index.lookupModulePaths.len
    while lo < hi:
        let mid = lo + (hi - lo) / 2
        let order = cmp(index.lookupModulePaths[mid], modulePath)
        if order == 0:
            return index.lookupModuleIds[mid]
        if order < 0:
            lo = mid + 1
        else:
            hi = mid
    return -1

fn ensureDeclaredModule(index: var CompilerCoreDeclaredModuleIndex,
                        modulePath: str,
                        sourcePath: str): int32 =
    let normalizedModulePath = normalizeModulePath(modulePath)
    if normalizedModulePath.len == 0:
        system.panicStr("v2 source manifest: empty declared module path")
    let existing = findDeclaredModulePathSlot(index, normalizedModulePath)
    if existing >= 0:
        if existing < index.sourcePaths.len &&
           len(index.sourcePaths[existing]) > 0 &&
           len(sourcePath) > 0 &&
           index.sourcePaths[existing] != sourcePath:
            system.panicStr("v2 source manifest: duplicate declared module " +
                         normalizedModulePath +
                         " from " +
                         index.sourcePaths[existing] +
                         " and " +
                         sourcePath)
        if existing < index.sourcePaths.len &&
           len(index.sourcePaths[existing]) == 0 &&
           len(sourcePath) > 0:
            index.sourcePaths[existing] = sourcePath
        return existing
    let next = index.modulePaths.len
    seqs.add(index.modulePaths, normalizedModulePath)
    seqs.add(index.sourcePaths, sourcePath)
    seqs.add(index.lookupModulePaths, normalizedModulePath)
    seqs.add(index.lookupModuleIds, next)
    seqs.add(index.importTargetStarts, -1)
    seqs.add(index.importTargetCounts, 0)
    sortClosureModuleLookup(index.lookupModulePaths, index.lookupModuleIds)
    return next

fn declaredModuleSourcePath(index: CompilerCoreDeclaredModuleIndex, modulePath: str): str =
    let normalizedModulePath = normalizeModulePath(modulePath)
    let slot = findDeclaredModulePathSlot(index, normalizedModulePath)
    if slot < 0 || slot >= index.sourcePaths.len:
        system.panicStr("v2 source manifest: unresolved declared module " + normalizedModulePath)
    return index.sourcePaths[slot]

fn setDeclaredModuleImportTargetPaths(index: var CompilerCoreDeclaredModuleIndex,
                                      modulePath: str,
                                      importTargetModulePaths: str[]) =
    let normalizedModulePath = normalizeModulePath(modulePath)
    let slot = findDeclaredModulePathSlot(index, normalizedModulePath)
    if slot < 0 || slot >= index.modulePaths.len:
        system.panicStr("v2 source manifest: unresolved declared module " + normalizedModulePath)
    if slot >= index.importTargetStarts.len || slot >= index.importTargetCounts.len:
        system.panicStr("v2 source manifest: declared module import index mismatch " + normalizedModulePath)
    let existingStart = index.importTargetStarts[slot]
    let existingCount = index.importTargetCounts[slot]
    if existingStart >= 0:
        if existingCount != importTargetModulePaths.len:
            system.panicStr("v2 source manifest: duplicate declared import targets " + normalizedModulePath)
        for i in 0..<existingCount:
            if index.importTargetModulePaths[existingStart + i] != importTargetModulePaths[i]:
                system.panicStr("v2 source manifest: duplicate declared import targets " + normalizedModulePath)
        return
    index.importTargetStarts[slot] = index.importTargetModulePaths.len
    index.importTargetCounts[slot] = importTargetModulePaths.len
    for i in 0..<importTargetModulePaths.len:
        seqs.add(index.importTargetModulePaths, importTargetModulePaths[i])

fn declaredModuleImportTargetPaths(index: CompilerCoreDeclaredModuleIndex, modulePath: str): str[] =
    var out: str[]
    out = []
    let normalizedModulePath = normalizeModulePath(modulePath)
    let slot = findDeclaredModulePathSlot(index, normalizedModulePath)
    if slot < 0 || slot >= index.modulePaths.len:
        system.panicStr("v2 source manifest: unresolved declared module " + normalizedModulePath)
    if slot >= index.importTargetStarts.len || slot >= index.importTargetCounts.len:
        system.panicStr("v2 source manifest: declared module import index mismatch " + normalizedModulePath)
    let start = index.importTargetStarts[slot]
    let count = index.importTargetCounts[slot]
    if start < 0:
        return out
    for i in 0..<count:
        seqs.add(out, index.importTargetModulePaths[start + i])
    return out

fn findClosureModulePathSlot(graph: CompilerCoreClosureGraph, modulePath: str): int32 =
    var lo: int32 = 0
    var hi: int32 = graph.lookupModulePaths.len
    while lo < hi:
        let mid = lo + (hi - lo) / 2
        let order = cmp(graph.lookupModulePaths[mid], modulePath)
        if order == 0:
            return graph.lookupModuleIds[mid]
        if order < 0:
            lo = mid + 1
        else:
            hi = mid
    return -1

fn ensureClosureModulePath(graph: var CompilerCoreClosureGraph,
                           modulePath: str,
                           sourcePath: str): int32 =
    let existing = findClosureModulePathSlot(graph, modulePath)
    if existing >= 0:
        if existing < graph.sourcePaths.len &&
           len(graph.sourcePaths[existing]) <= 0 &&
           len(sourcePath) > 0:
            graph.sourcePaths[existing] = sourcePath
        return existing
    let next = graph.modulePaths.len
    seqs.add(graph.modulePaths, modulePath)
    seqs.add(graph.sourcePaths, sourcePath)
    seqs.add(graph.lookupModulePaths, modulePath)
    seqs.add(graph.lookupModuleIds, next)
    sortClosureModuleLookup(graph.lookupModulePaths, graph.lookupModuleIds)
    return next

fn tarjanVisitClosureGraph(graph: CompilerCoreClosureGraph,
                           moduleId: int32,
                           nextIndex: var int32,
                           indices: var int32[],
                           lowLinks: var int32[],
                           onStack: var bool[],
                           stack: var int32[],
                           sccIds: var int32[],
                           sccCount: var int32) =
    indices[moduleId] = nextIndex
    lowLinks[moduleId] = nextIndex
    nextIndex = nextIndex + 1
    seqs.add(stack, moduleId)
    onStack[moduleId] = true
    for edgeIdx in 0..<graph.importEdgeOwnerModuleIds.len:
        if graph.importEdgeOwnerModuleIds[edgeIdx] != moduleId:
            continue
        let targetModuleId = graph.importEdgeTargetModuleIds[edgeIdx]
        if targetModuleId < 0:
            continue
        if indices[targetModuleId] < 0:
            tarjanVisitClosureGraph(graph,
                                    targetModuleId,
                                    nextIndex,
                                    indices,
                                    lowLinks,
                                    onStack,
                                    stack,
                                    sccIds,
                                    sccCount)
            if lowLinks[targetModuleId] < lowLinks[moduleId]:
                lowLinks[moduleId] = lowLinks[targetModuleId]
        elif onStack[targetModuleId]:
            if indices[targetModuleId] < lowLinks[moduleId]:
                lowLinks[moduleId] = indices[targetModuleId]
    if lowLinks[moduleId] == indices[moduleId]:
        while stack.len > 0:
            let stackModuleId = stack[stack.len - 1]
            seqs.setLen(stack, stack.len - 1)
            onStack[stackModuleId] = false
            sccIds[stackModuleId] = sccCount
            if stackModuleId == moduleId:
                break
        sccCount = sccCount + 1

fn collectCompilerCoreSourceOwnerModulesFromParsed(parsed: parser.ParsedV2Source): str[] =
    var out: str[]
    out = []
    for i in 0..<parsed.compilerCoreProgram.topLevelOwnerModules.len:
        ident.appendUnique(out, normalizeModulePath(parsed.compilerCoreProgram.topLevelOwnerModules[i]))
    return out

fn collectCompilerCoreOwnerModuleImportPathsFromParsed(parsed: parser.ParsedV2Source,
                                                       ownerModulePath: str): str[] =
    var out: str[]
    out = []
    let normalizedOwnerModulePath = normalizeModulePath(ownerModulePath)
    for i in 0..<parsed.compilerCoreProgram.topLevelKinds.len:
        if parsed.compilerCoreProgram.topLevelKinds[i] != "import":
            continue
        if i >= parsed.compilerCoreProgram.topLevelImportDeclIdxs.len:
            system.panicStr("v2 source manifest: missing topLevelImportDeclIdx " + parsed.sourcePath)
        let importIdx = parsed.compilerCoreProgram.topLevelImportDeclIdxs[i]
        if importIdx < 0 || importIdx >= parsed.compilerCoreProgram.imports.len:
            system.panicStr("v2 source manifest: invalid topLevelImportDeclIdx " + parsed.sourcePath)
        var importOwnerModulePath: str = ""
        if i < parsed.compilerCoreProgram.topLevelOwnerModules.len:
            importOwnerModulePath = normalizeModulePath(parsed.compilerCoreProgram.topLevelOwnerModules[i])
        if importOwnerModulePath == normalizedOwnerModulePath:
            ident.appendUnique(out, normalizeModulePath(parsed.compilerCoreProgram.imports[importIdx].modulePath))
    return out

fn loadDeclaredModulesFromSource(index: var CompilerCoreDeclaredModuleIndex, sourcePath: str): str[] =
    let parsed = parser.parseV2SourceFileStrict(sourcePath)
    let ownerModulePaths = collectCompilerCoreSourceOwnerModulesFromParsed(parsed)
    for i in 0..<ownerModulePaths.len:
        discard ensureDeclaredModule(index, ownerModulePaths[i], sourcePath)
    for i in 0..<ownerModulePaths.len:
        setDeclaredModuleImportTargetPaths(index,
                                           ownerModulePaths[i],
                                           collectCompilerCoreOwnerModuleImportPathsFromParsed(parsed,
                                                                                               ownerModulePaths[i]))
    return ownerModulePaths

fn resolveCompilerCoreModuleSourcePath(modulePath: str,
                                       packageRoot: str,
                                       workspaceRoot: str,
                                       packageId: str): str =
    let normalized = normalizeModulePath(modulePath)
    if normalized.len == 0:
        system.panicStr("v2 source manifest: empty compiler_core import path")
    if strutils.startsWith(normalized, "std/"):
        let rel = strings.sliceBytes(normalized, len("std/"), normalized.len - len("std/"))
        let candidate = os.joinPath(os.joinPath(workspaceRoot, "src/std"), ensureChengExt(rel))
        if os.fileExists(candidate):
            return candidate
        system.panicStr("v2 source manifest: missing std import " + normalized)
    var packageLocal = normalized
    let packageName = packageNameFromId(packageId)
    if packageName.len > 0 && strutils.startsWith(normalized, packageName + "/"):
        packageLocal = strings.sliceBytes(normalized, len(packageName) + 1, normalized.len - len(packageName) - 1)
    if packageRoot.len > 0:
        let packageRoots = compilerCorePackageSourceRoots(packageRoot)
        for i in 0..<packageRoots.len:
            let packageCandidate = os.joinPath(packageRoots[i], ensureChengExt(packageLocal))
            if os.fileExists(packageCandidate):
                return packageCandidate
    let workspaceCandidate = os.joinPath(os.joinPath(workspaceRoot, "src"), ensureChengExt(normalized))
    if os.fileExists(workspaceCandidate):
        return workspaceCandidate
    system.panicStr("v2 source manifest: unresolved compiler_core import " + modulePath)

fn ensureDeclaredModuleLoaded(index: var CompilerCoreDeclaredModuleIndex,
                              modulePath: str,
                              packageRoot: str,
                              workspaceRoot: str,
                              packageId: str): str =
    let normalizedModulePath = normalizeModulePath(modulePath)
    let existing = findDeclaredModulePathSlot(index, normalizedModulePath)
    if existing >= 0:
        return index.modulePaths[existing]
    let sourcePath = resolveCompilerCoreModuleSourcePath(normalizedModulePath,
                                                         packageRoot,
                                                         workspaceRoot,
                                                         packageId)
    let ownerModulePaths: str[] = loadDeclaredModulesFromSource(index, sourcePath)
    if ownerModulePaths.len == 0:
        system.panicStr("v2 source manifest: resolved module has no compiler_core owners " +
                     normalizedModulePath +
                     " -> " +
                     sourcePath)
    var canonicalModulePath = normalizedModulePath
    if !hasString(ownerModulePaths, normalizedModulePath):
        if ownerModulePaths.len == 1:
            canonicalModulePath = ownerModulePaths[0]
        else:
            system.panicStr("v2 source manifest: resolved module alias has no unique owner " +
                         normalizedModulePath +
                         " -> " +
                         sourcePath)
    return declaredModulePath(index, canonicalModulePath)

fn declaredModulePath(index: CompilerCoreDeclaredModuleIndex, modulePath: str): str =
    let normalizedModulePath = normalizeModulePath(modulePath)
    let slot = findDeclaredModulePathSlot(index, normalizedModulePath)
    if slot < 0 || slot >= index.modulePaths.len:
        system.panicStr("v2 source manifest: unresolved declared module " + normalizedModulePath)
    return index.modulePaths[slot]

fn buildCompilerCoreClosureGraph(entrySourcePath: str,
                                 packageRoot: str,
                                 workspaceRoot: str,
                                 packageId: str): CompilerCoreClosureGraph =
    var out = newCompilerCoreClosureGraph()
    var declaredModules = newCompilerCoreDeclaredModuleIndex()
    let entryModulePaths: str[] = loadDeclaredModulesFromSource(declaredModules, entrySourcePath)
    if entryModulePaths.len == 0:
        system.panicStr("v2 source manifest: entry source has no compiler_core module owners " + entrySourcePath)
    var discoveredModulePaths: str[]
    discoveredModulePaths = []
    var queue: str[]
    queue = []
    for i in 0..<entryModulePaths.len:
        let sourcePath = declaredModuleSourcePath(declaredModules, entryModulePaths[i])
        discard ensureClosureModulePath(out, entryModulePaths[i], sourcePath)
        ident.appendUnique(discoveredModulePaths, entryModulePaths[i])
        seqs.add(queue, entryModulePaths[i])
    var queueIdx: int32 = 0
    while queueIdx < queue.len:
        let ownerModulePath = queue[queueIdx]
        queueIdx = queueIdx + 1
        let ownerSourcePath = declaredModuleSourcePath(declaredModules, ownerModulePath)
        let ownerModuleId = ensureClosureModulePath(out, ownerModulePath, ownerSourcePath)
        let imports = declaredModuleImportTargetPaths(declaredModules, ownerModulePath)
        for i in 0..<imports.len:
            let targetModulePath = ensureDeclaredModuleLoaded(declaredModules,
                                                              imports[i],
                                                              packageRoot,
                                                              workspaceRoot,
                                                              packageId)
            let targetSourcePath = declaredModuleSourcePath(declaredModules, targetModulePath)
            let targetModuleId = ensureClosureModulePath(out, targetModulePath, targetSourcePath)
            seqs.add(out.importEdgeOwnerModuleIds, ownerModuleId)
            seqs.add(out.importEdgeTargetModuleIds, targetModuleId)
            if !hasString(discoveredModulePaths, targetModulePath):
                ident.appendUnique(discoveredModulePaths, targetModulePath)
                seqs.add(queue, targetModulePath)
    var indices: int32[] = []
    var lowLinks: int32[] = []
    var onStack: bool[] = []
    var stack: int32[] = []
    out.moduleSccIds = []
    for i in 0..<out.modulePaths.len:
        seqs.add(indices, -1)
        seqs.add(lowLinks, -1)
        seqs.add(onStack, false)
        seqs.add(out.moduleSccIds, -1)
    var nextIndex: int32 = 0
    var sccCount: int32 = 0
    for i in 0..<out.modulePaths.len:
        if indices[i] < 0:
            tarjanVisitClosureGraph(out,
                                    i,
                                    nextIndex,
                                    indices,
                                    lowLinks,
                                    onStack,
                                    stack,
                                    out.moduleSccIds,
                                    sccCount)
    return out

fn hasSccEdge(sourceSccIds: int32[],
              targetSccIds: int32[],
              sourceSccId: int32,
              targetSccId: int32): bool =
    for i in 0..<sourceSccIds.len:
        if sourceSccIds[i] == sourceSccId && targetSccIds[i] == targetSccId:
            return true
    return false

fn compilerCoreSccCount(graph: CompilerCoreClosureGraph): int32 =
    var out: int32 = 0
    for i in 0..<graph.moduleSccIds.len:
        if graph.moduleSccIds[i] + 1 > out:
            out = graph.moduleSccIds[i] + 1
    return out

fn pickNextReadyScc(indegrees: int32[],
                    emitted: bool[],
                    sccOrders: int32[]): int32 =
    var best: int32 = -1
    for sccId in 0..<indegrees.len:
        if emitted[sccId] || indegrees[sccId] != 0:
            continue
        if best < 0 || sccOrders[sccId] < sccOrders[best]:
            best = sccId
    return best

fn orderedCompilerCoreClosureSourcePaths(graph: CompilerCoreClosureGraph): str[] =
    let sccCount = compilerCoreSccCount(graph)
    var sccOrders: int32[] = []
    var emitted: bool[] = []
    var indegrees: int32[] = []
    var dagSourceSccIds: int32[] = []
    var dagTargetSccIds: int32[] = []
    for sccId in 0..<sccCount:
        seqs.add(sccOrders, graph.modulePaths.len)
        seqs.add(emitted, false)
        seqs.add(indegrees, 0)
    for moduleId in 0..<graph.modulePaths.len:
        let sccId = graph.moduleSccIds[moduleId]
        if moduleId < sccOrders[sccId]:
            sccOrders[sccId] = moduleId
    for edgeIdx in 0..<graph.importEdgeOwnerModuleIds.len:
        let ownerSccId = graph.moduleSccIds[graph.importEdgeOwnerModuleIds[edgeIdx]]
        let targetSccId = graph.moduleSccIds[graph.importEdgeTargetModuleIds[edgeIdx]]
        if ownerSccId == targetSccId:
            continue
        if hasSccEdge(dagSourceSccIds, dagTargetSccIds, targetSccId, ownerSccId):
            continue
        seqs.add(dagSourceSccIds, targetSccId)
        seqs.add(dagTargetSccIds, ownerSccId)
        indegrees[ownerSccId] = indegrees[ownerSccId] + 1
    var out: str[] = []
    var emittedCount: int32 = 0
    while emittedCount < sccCount:
        let nextSccId = pickNextReadyScc(indegrees, emitted, sccOrders)
        if nextSccId < 0:
            system.panicStr("v2 source manifest: compiler_core closure SCC ordering failed")
        emitted[nextSccId] = true
        emittedCount = emittedCount + 1
        var emittedSourcePaths: str[] = []
        for moduleId in 0..<graph.modulePaths.len:
            if graph.moduleSccIds[moduleId] != nextSccId:
                continue
            if hasString(emittedSourcePaths, graph.sourcePaths[moduleId]):
                continue
            ident.appendUnique(emittedSourcePaths, graph.sourcePaths[moduleId])
            seqs.add(out, graph.sourcePaths[moduleId])
        for edgeIdx in 0..<dagSourceSccIds.len:
            if dagSourceSccIds[edgeIdx] == nextSccId:
                indegrees[dagTargetSccIds[edgeIdx]] = indegrees[dagTargetSccIds[edgeIdx]] - 1
    return out

fn hasString(values: str[], target: str): bool =
    for i in 0..<values.len:
        if values[i] == target:
            return true
    return false

fn collectCompilerCoreClosurePaths(entryPath: str): str[] =
    let entryAbs = os.absolutePath(entryPath)
    if !os.fileExists(entryAbs):
        system.panicStr("v2 source manifest: missing entry source " + entryPath)
    let packageRoot = findNearestPackageRoot(entryAbs)
    if packageRoot.len == 0:
        system.panicStr("v2 source manifest: missing package root for " + entryPath)
    let workspaceRoot = findWorkspaceRoot(entryAbs)
    if workspaceRoot.len == 0:
        system.panicStr("v2 source manifest: missing workspace root for " + entryPath)
    let packageId = parsePackageId(packageRoot)
    let graph = buildCompilerCoreClosureGraph(entryAbs, packageRoot, workspaceRoot, packageId)
    var out: str[]
    out = []
    let packageManifest = os.joinPath(packageRoot, "cheng-package.toml")
    if os.fileExists(packageManifest):
        ident.appendUnique(out, packageManifest)
    let orderedSourcePaths = orderedCompilerCoreClosureSourcePaths(graph)
    for i in 0..<orderedSourcePaths.len:
        ident.appendUnique(out, orderedSourcePaths[i])
    return out

fn parsePackageId(rootPath: str): str =
    var manifestPath: str = ""
    if os.dirExists(rootPath):
        manifestPath = os.joinPath(rootPath, "cheng-package.toml")
    else:
        manifestPath = os.joinPath(os.parentDir(rootPath), "cheng-package.toml")
    if !os.fileExists(manifestPath):
        return "pkg://cheng/v2"
    let lines = strutils.split(os.readFile(manifestPath), '\n')
    for i in 0..<lines.len:
        let line = strutils.strip(lines[i])
        if strutils.startsWith(line, "package_id"):
            let eqIdx = parser.findChar(line, '=')
            if eqIdx < 0:
                continue
            var value = strutils.strip(strings.sliceBytes(line, eqIdx + 1, line.len - eqIdx - 1))
            if value.len >= 2 && value[0] == '"' && value[value.len - 1] == '"':
                value = strings.sliceBytes(value, 1, value.len - 2)
            return value
    return "pkg://cheng/v2"

fn joinLines(lines: str[]): str =
    return strutils.join(lines, "\n")

fn topologyRefsForParsed(parsed: parser.ParsedV2Source): str =
    var refs: str[]
    refs = []
    for i in 0..<parsed.networkProgram.topologies.len:
        ident.appendUnique(refs, parsed.networkProgram.topologies[i].name)
    ident.sortStrings(refs)
    return strutils.join(refs, ";")

fn topologyCanonicalFormsForParsed(parsed: parser.ParsedV2Source): str[] =
    var out: str[]
    out = []
    for i in 0..<parsed.networkProgram.topologies.len:
        ident.appendUnique(out, nsurf.topologyCanonicalForm(parsed.networkProgram.topologies[i]))
    ident.sortStrings(out)
    return out

fn collectSourcePaths(rootPath: str): str[] =
    var out: str[]
    out = []
    if os.dirExists(rootPath):
        let files = os.walkDirRec(rootPath)
        for i in 0..<files.len:
            let rel = os.relativePath(files[i], rootPath)
            if shouldIncludeSourcePath(rel):
                seqs.add(out, files[i])
        let packagePath = os.joinPath(rootPath, "cheng-package.toml")
        if os.fileExists(packagePath):
            ident.appendUnique(out, packagePath)
    elif os.fileExists(rootPath):
        seqs.add(out, rootPath)
        let parentPackage = os.joinPath(os.parentDir(rootPath), "cheng-package.toml")
        if os.fileExists(parentPackage):
            ident.appendUnique(out, parentPackage)
    ident.sortStrings(out)
    return out

fn tryParseManifestSurfaceFile(path: str, out: var parser.ParsedV2Source): bool =
    var parsed = parser.newParsedV2Source(path)
    let lines = strutils.split(os.readFile(path), '\n')
    var hadRecognized: bool = false
    for i in 0..<lines.len:
        let line = strutils.strip(lines[i])
        if line.len == 0 || strutils.startsWith(line, "//") || strutils.startsWith(line, "#"):
            continue
        if parser.parseUnimakerLine(parsed.unimakerProgram, line):
            ident.appendUnique(parsed.surfaceKinds, "unimaker")
            hadRecognized = true
            continue
        if parser.parseTopologyLine(parsed.networkProgram, line):
            ident.appendUnique(parsed.surfaceKinds, "topology")
            hadRecognized = true
            continue
        if parser.parseNetworkOpLine(parsed.networkProgram, line):
            ident.appendUnique(parsed.surfaceKinds, "network_distribution")
            hadRecognized = true
            continue
        if hadRecognized:
            return false
    if hadRecognized:
        out = parsed
        return true
    return false

fn buildSourceManifestFromPaths(rootPath: str, packageId: str, fullPaths: str[]): SourceManifestBundle =
    var out: SourceManifestBundle
    var workspaceRoot: str = ""
    if rootPath == "." && fullPaths.len > 0:
        workspaceRoot = findWorkspaceRoot(fullPaths[0])
    out.version = sourceManifestVersion()
    out.rootPath = rootPath
    out.packageId = packageId
    out.filePaths = []
    out.fileCids = []
    out.fileTopologyRefs = []
    out.topologyCanonicalForms = []
    for i in 0..<fullPaths.len:
        var rel: str = ""
        if rootPath == ".":
            rel = os.relativePath(fullPaths[i], workspaceRoot)
        elif os.dirExists(rootPath):
            rel = os.relativePath(fullPaths[i], rootPath)
        else:
            rel = os.relativePath(fullPaths[i], os.parentDir(rootPath))
        let cid = ident.sha256HexFile(fullPaths[i])
        seqs.add(out.filePaths, rel)
        seqs.add(out.fileCids, cid)
        var parsed: parser.ParsedV2Source
        let parseOk = tryParseManifestSurfaceFile(fullPaths[i], parsed)
        if parseOk && parser.sourceHasRecognizedSurface(parsed):
            seqs.add(out.fileTopologyRefs, topologyRefsForParsed(parsed))
            let forms = topologyCanonicalFormsForParsed(parsed)
            for j in 0..<forms.len:
                ident.appendUnique(out.topologyCanonicalForms, forms[j])
        else:
            seqs.add(out.fileTopologyRefs, "")
    ident.sortStrings(out.topologyCanonicalForms)
    var lines: str[]
    lines = []
    seqs.add(lines, "source_manifest_version=" + out.version)
    seqs.add(lines, "package_id=" + out.packageId)
    seqs.add(lines, "root=" + out.rootPath)
    seqs.add(lines, "file_count=" + intToStr(out.filePaths.len))
    for i in 0..<out.filePaths.len:
        seqs.add(lines, "file." + intToStr(i) + ".path=" + out.filePaths[i])
        seqs.add(lines, "file." + intToStr(i) + ".cid=" + out.fileCids[i])
        seqs.add(lines, "file." + intToStr(i) + ".topologies=" + out.fileTopologyRefs[i])
    seqs.add(lines, "topology_count=" + intToStr(out.topologyCanonicalForms.len))
    for i in 0..<out.topologyCanonicalForms.len:
        seqs.add(lines, "topology." + intToStr(i) + "=" + out.topologyCanonicalForms[i])
    out.manifestText = joinLines(lines)
    out.manifestCid = ident.sha256HexText(out.manifestText)
    return out

fn resolveSourceManifest(rootPath: str): SourceManifestBundle =
    let fullPaths = collectSourcePaths(rootPath)
    return buildSourceManifestFromPaths(rootPath, parsePackageId(rootPath), fullPaths)

fn resolveCompilerCoreSourceManifest(entryPath: str): SourceManifestBundle =
    let entryAbs = os.absolutePath(entryPath)
    let packageRoot = findNearestPackageRoot(entryAbs)
    if packageRoot.len == 0:
        system.panicStr("v2 source manifest: missing package root for " + entryPath)
    let fullPaths = collectCompilerCoreClosurePaths(entryAbs)
    return buildSourceManifestFromPaths(".", parsePackageId(packageRoot), fullPaths)
