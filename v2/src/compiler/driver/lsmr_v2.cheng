import std/seqs
import std/system
import compiler/driver/identity_v2 as ident
import runtime/lsmr_contract_v2 as lsmr

type
    LsmrAddress =
        version: str
        depth: int32
        digits: int32[]
        canonicalText: str
    LsmrRoutePlan =
        version: str
        contentCid: str
        depth: int32
        priorityClass: str
        dispersalMode: str
        addressingMode: str
        addressBinding: str
        distanceMetric: str
        sourceAddress: LsmrAddress
        targetAddress: LsmrAddress
        totalDistance: int32
        pathTexts: str[]
        canonicalText: str
        canonicalCid: str

fn joinLines(lines: str[]): str =
    var out: str = ""
    for i in 0..<lines.len:
        if i > 0:
            out = out + "\n"
        out = out + lines[i]
    return out

fn normalizedCidHex(cid: str): str =
    var out: str = ""
    for i in 0..<len(cid):
        let ch = cid[i]
        if ch >= '0' && ch <= '9':
            out = out + charToString(ch)
        elif ch >= 'a' && ch <= 'f':
            out = out + charToString(ch)
        elif ch >= 'A' && ch <= 'F':
            out = out + charToString(char(int32(ch) - int32('A') + int32('a')))
        else:
            panic("v2 lsmr: invalid cid hex " + cid)
    if len(out) == 0 || (len(out) % 2) != 0:
        panic("v2 lsmr: invalid cid hex length")
    return out

fn hexCharValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return int32(ch) - int32('a') + 10
    panic("v2 lsmr: invalid hex char")

fn reverseDigits(values: int32[]): int32[] =
    var out: int32[]
    out = []
    var i: int32 = values.len - 1
    while i >= 0:
        add(out, values[i])
        i = i - 1
    return out

fn hexToBase9Digits(cid: str): int32[] =
    let normalized = normalizedCidHex(cid)
    var work: int32[]
    work = []
    for i in 0..<len(normalized):
        add(work, hexCharValue(normalized[i]))
    var remainders: int32[]
    remainders = []
    while work.len > 0:
        var quotient: int32[]
        quotient = []
        var carry: int32 = 0
        for i in 0..<work.len:
            let value = carry * 16 + work[i]
            let q = value / 9
            carry = value % 9
            if quotient.len > 0 || q != 0:
                add(quotient, q)
        add(remainders, carry)
        work = quotient
    if remainders.len <= 0:
        add(remainders, 0)
    return reverseDigits(remainders)

fn digitArrayText(digits: int32[]): str =
    var out: str = ""
    for i in 0..<digits.len:
        if i > 0:
            out = out + "/"
        out = out + intToStr(digits[i])
    return out

fn cloneDigits(digits: int32[]): int32[] =
    var out: int32[]
    out = []
    for i in 0..<digits.len:
        add(out, digits[i])
    return out

fn newLsmrAddress(digits: int32[]): LsmrAddress =
    var out: LsmrAddress
    out.version = lsmr.lsmrAddressIdentityVersion()
    out.depth = digits.len
    out.digits = cloneDigits(digits)
    out.canonicalText = digitArrayText(digits)
    return out

fn rootPublisherAddress(depth: int32): LsmrAddress =
    if depth <= 0:
        panic("v2 lsmr: invalid depth")
    var digits: int32[]
    digits = []
    for i in 0..<depth:
        add(digits, lsmr.lsmrRuntimeContract().rootPublisherDigit)
    return newLsmrAddress(digits)

fn lsmrAddressFromCid(cid: str, depth: int32): LsmrAddress =
    if depth <= 0:
        panic("v2 lsmr: invalid depth")
    let base9 = hexToBase9Digits(cid)
    var digits: int32[]
    digits = []
    var i: int32 = 0
    while i < depth:
        let value = i < base9.len ? base9[i] : 0
        add(digits, value + 1)
        i = i + 1
    return newLsmrAddress(digits)

fn luoshuDigitX(digit: int32): int32 =
    if digit == 8 || digit == 3 || digit == 4:
        return 0
    if digit == 1 || digit == 5 || digit == 9:
        return 1
    if digit == 6 || digit == 7 || digit == 2:
        return 2
    panic("v2 lsmr: invalid luoshu digit")

fn luoshuDigitY(digit: int32): int32 =
    if digit == 8 || digit == 1 || digit == 6:
        return 0
    if digit == 3 || digit == 5 || digit == 7:
        return 1
    if digit == 4 || digit == 9 || digit == 2:
        return 2
    panic("v2 lsmr: invalid luoshu digit")

fn luoshuDigitAt(x: int32, y: int32): int32 =
    if x == 0 && y == 0:
        return 8
    if x == 1 && y == 0:
        return 1
    if x == 2 && y == 0:
        return 6
    if x == 0 && y == 1:
        return 3
    if x == 1 && y == 1:
        return 5
    if x == 2 && y == 1:
        return 7
    if x == 0 && y == 2:
        return 4
    if x == 1 && y == 2:
        return 9
    if x == 2 && y == 2:
        return 2
    panic("v2 lsmr: invalid luoshu coordinate")

fn perLevelManhattanDistance(fromDigit: int32, toDigit: int32): int32 =
    let dx = luoshuDigitX(fromDigit) - luoshuDigitX(toDigit)
    let dy = luoshuDigitY(fromDigit) - luoshuDigitY(toDigit)
    return (if dx < 0: -dx else: dx) + (if dy < 0: -dy else: dy)

fn appendLevelShortestPaths(currentDigit: int32,
                            targetDigit: int32,
                            currentText: str,
                            outPaths: var str[]) =
    if currentDigit == targetDigit:
        ident.appendUnique(outPaths, currentText)
        return
    let currentX = luoshuDigitX(currentDigit)
    let currentY = luoshuDigitY(currentDigit)
    let targetX = luoshuDigitX(targetDigit)
    let targetY = luoshuDigitY(targetDigit)
    if currentX < targetX:
        let nextDigit = luoshuDigitAt(currentX + 1, currentY)
        appendLevelShortestPaths(nextDigit, targetDigit, currentText + ">" + intToStr(nextDigit), outPaths)
    elif currentX > targetX:
        let nextDigit = luoshuDigitAt(currentX - 1, currentY)
        appendLevelShortestPaths(nextDigit, targetDigit, currentText + ">" + intToStr(nextDigit), outPaths)
    if currentY < targetY:
        let nextDigit = luoshuDigitAt(currentX, currentY + 1)
        appendLevelShortestPaths(nextDigit, targetDigit, currentText + ">" + intToStr(nextDigit), outPaths)
    elif currentY > targetY:
        let nextDigit = luoshuDigitAt(currentX, currentY - 1)
        appendLevelShortestPaths(nextDigit, targetDigit, currentText + ">" + intToStr(nextDigit), outPaths)

fn splitLevelPathDigits(pathText: str): int32[] =
    var out: int32[]
    out = []
    for i in 0..<len(pathText):
        let ch = pathText[i]
        if ch >= '1' && ch <= '9':
            add(out, int32(ch) - int32('0'))
    return out

fn extendFullRoutePaths(level: int32,
                        currentDigits: int32[],
                        targetDigits: int32[],
                        currentPathText: str,
                        outPaths: var str[]) =
    if level >= targetDigits.len:
        ident.appendUnique(outPaths, currentPathText)
        return
    var levelPaths: str[]
    levelPaths = []
    appendLevelShortestPaths(currentDigits[level],
                             targetDigits[level],
                             intToStr(currentDigits[level]),
                             levelPaths)
    ident.sortStrings(levelPaths)
    for i in 0..<levelPaths.len:
        let levelDigits = splitLevelPathDigits(levelPaths[i])
        var nextDigits = cloneDigits(currentDigits)
        var nextPathText = currentPathText
        for j in 1..<levelDigits.len:
            nextDigits[level] = levelDigits[j]
            nextPathText = nextPathText + " -> " + digitArrayText(nextDigits)
        extendFullRoutePaths(level + 1, nextDigits, targetDigits, nextPathText, outPaths)

fn totalDistance(sourceAddress: LsmrAddress, targetAddress: LsmrAddress): int32 =
    var out: int32 = 0
    for i in 0..<sourceAddress.depth:
        out = out + perLevelManhattanDistance(sourceAddress.digits[i], targetAddress.digits[i])
    return out

fn buildLsmrRoutePlan(cid: str,
                      depth: int32,
                      priorityClass: str,
                      dispersalMode: str): LsmrRoutePlan =
    let contract = lsmr.lsmrRuntimeContract()
    let sourceAddress = rootPublisherAddress(depth)
    let targetAddress = lsmrAddressFromCid(cid, depth)
    var pathTexts: str[]
    pathTexts = []
    extendFullRoutePaths(0, sourceAddress.digits, targetAddress.digits, sourceAddress.canonicalText, pathTexts)
    ident.sortStrings(pathTexts)
    var lines: str[]
    lines = []
    add(lines, "lsmr_route_plan_version=" + lsmr.lsmrRoutePlanIdentityVersion())
    add(lines, "cid=" + normalizedCidHex(cid))
    add(lines, "depth=" + intToStr(depth))
    add(lines, "priority=" + priorityClass)
    add(lines, "dispersal=" + dispersalMode)
    add(lines, "addressing=" + contract.addressingMode)
    add(lines, "address_binding=" + contract.addressBinding)
    add(lines, "distance_metric=" + contract.distanceMetric)
    add(lines, "cell_layout=" + contract.cellLayout)
    add(lines, "source_address=" + sourceAddress.canonicalText)
    add(lines, "target_address=" + targetAddress.canonicalText)
    add(lines, "total_distance=" + intToStr(totalDistance(sourceAddress, targetAddress)))
    add(lines, "path_count=" + intToStr(pathTexts.len))
    for i in 0..<pathTexts.len:
        add(lines, "path." + intToStr(i) + "=" + pathTexts[i])
    let body = joinLines(lines)
    var out: LsmrRoutePlan
    out.version = lsmr.lsmrRoutePlanIdentityVersion()
    out.contentCid = normalizedCidHex(cid)
    out.depth = depth
    out.priorityClass = priorityClass
    out.dispersalMode = dispersalMode
    out.addressingMode = contract.addressingMode
    out.addressBinding = contract.addressBinding
    out.distanceMetric = contract.distanceMetric
    out.sourceAddress = sourceAddress
    out.targetAddress = targetAddress
    out.totalDistance = totalDistance(sourceAddress, targetAddress)
    out.pathTexts = pathTexts
    out.canonicalText = body
    out.canonicalCid = ident.sha256HexText(body)
    return out

fn buildLsmrAddressArtifactText(cid: str, depth: int32): str =
    let contract = lsmr.lsmrRuntimeContract()
    let address = lsmrAddressFromCid(cid, depth)
    var lines: str[]
    lines = []
    add(lines, "lsmr_address_version=" + lsmr.lsmrAddressIdentityVersion())
    add(lines, "cid=" + normalizedCidHex(cid))
    add(lines, "depth=" + intToStr(depth))
    add(lines, "addressing=" + contract.addressingMode)
    add(lines, "address_binding=" + contract.addressBinding)
    add(lines, "distance_metric=" + contract.distanceMetric)
    add(lines, "cell_layout=" + contract.cellLayout)
    add(lines, "address=" + address.canonicalText)
    let body = joinLines(lines)
    return body + "\naddress_cid=" + ident.sha256HexText(body) + "\n"

fn buildLsmrRoutePlanArtifactText(cid: str,
                                  depth: int32,
                                  priorityClass: str,
                                  dispersalMode: str): str =
    let plan = buildLsmrRoutePlan(cid, depth, priorityClass, dispersalMode)
    return plan.canonicalText + "\nroute_plan_cid=" + plan.canonicalCid + "\n"
