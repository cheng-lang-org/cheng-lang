import compiler/driver/system_link_plan_v2 as slink
import runtime/core_runtime_v2 as corun
import runtime/compiler_core_runtime_v2 as crun
import runtime/strings_v2 as srun
import runtime/unimaker_runtime_contract_v2 as urun
import runtime/network_distribution_runtime_v2 as nrun
import bootstrap/selfhost_contract as selfhost

type
    V2SurfaceContract =
        rootDir: str
        packageId: str
        devEntry: str
        toolingEntry: str
        factsVersion: str
        highUirVersion: str
        abiBridgeVersion: str
        lowUirVersion: str
        functionParallelism: bool
        deterministicMerge: bool

fn v2SurfaceContract(): V2SurfaceContract =
    let facts = sfacts.semanticFactsContract()
    let high = huir.highUirGraphContract()
    let bridge = abridge.abiBridgeContract()
    let low = luir.lowUirPipelineContract()
    let _front = ffront.frontendContract()
    let _machine = mtarget.machineTargetContract()
    let _writer = owriter.objWriterContract()
    let _runtime = srun.stringRuntimeContract()
    var out: V2SurfaceContract
    out.rootDir = "v2"
    out.packageId = "pkg://cheng/v2"
    out.devEntry = "cheng_v2"
    out.toolingEntry = "cheng_tooling_v2"
    out.factsVersion = facts.version
    out.highUirVersion = high.version
    out.abiBridgeVersion = bridge.version
    out.lowUirVersion = low.version
    out.functionParallelism = low.parallelUnit == "function_task"
    out.deterministicMerge = low.mergeMode == "stable_declaration_order"
    return out

fn v2HasIndexOnlySoa(): bool =
    let high = huir.highUirGraphContract()
    return high.indexOnly && high.storageModel == "soa_index"

fn v2SurfaceLines(): str[] =
    let surface = v2SurfaceContract()
    let front = ffront.frontendContract()
    let ccore = cfront.compilerCoreSurfaceContract()
    let sstr = sfront.stringSurfaceContract()
    let ustr = ufront.unimakerSurfaceContract()
    let nstr = nfront.networkDistributionSurfaceContract()
    let surfaceProgram = sir.sampleStringSurfaceProgram()
    let infraProgram = uir.sampleUnimakerSurfaceProgram()
    let networkProgram = nsurf.sampleNetworkDistributionProgram()
    let slow = slower.stringLoweringContract()
    let facts = sfacts.semanticFactsContract()
    let stringFacts = sffacts.buildStringSemanticFacts(surfaceProgram)
    let infraFacts = uffacts.buildUnimakerSemanticFacts(infraProgram)
    let networkFacts = nffacts.buildNetworkDistributionFacts(networkProgram)
    let high = huir.highUirGraphContract()
    let highString = shigh.newHighUirStringGraph()
    let highInfra = uhigh.newHighUirUnimakerGraph()
    let highNetwork = nhigh.newHighUirNetworkDistributionGraph()
    let bridge = abridge.abiBridgeContract()
    let low = luir.lowUirPipelineContract()
    let stringOps = sops.lowUirStringOpsContract()
    let infraOps = uops.lowUirUnimakerOpsContract()
    let networkOps = nops.lowUirNetworkDistributionOpsContract()
    let lowStringVersion = slowlower.lowUirStringPlanVersion()
    let lowInfraVersion = uflow.lowUirUnimakerPlanVersion()
    let lowNetworkVersion = nflow.lowUirNetworkDistributionPlanVersion()
    let machine = mtarget.machineTargetContract()
    let writer = owriter.objWriterContract()
    let machineBundle = mpipeline.sampleNetworkDistributionMachineModule(machine.firstClassTargets[0])
    let objImage = oimg.writeObjImage(machineBundle)
    let objFile = ofile.sampleNetworkDistributionObjFile(machine.firstClassTargets[0])
    let linkPlan = rart.buildNativeLinkPlan(machineBundle, "exe", machine.firstClassTargets[0])
    let systemLink = slink.buildSystemLinkPlan(machineBundle,
                                               objFile,
                                               "exe",
                                               linkPlan.providerModules,
                                               [],
                                               [],
                                               [])
    let coreRuntime = corun.coreRuntimeContract()
    let compilerCoreRuntime = crun.compilerCoreRuntimeContract()
    let runtime = srun.stringRuntimeContract()
    let infraRuntime = urun.unimakerRuntimeContract()
    let networkRuntime = nrun.networkDistributionRuntimeContract()
    let pipelineVersion = spipe.stringPipelineVersion()
    let infraPipelineVersion = upipe.unimakerPipelineVersion()
    let networkPipelineVersion = npipe.networkDistributionPipelineVersion()
    let selfhostContract = selfhost.selfhostContract()
    var out: str[]
    out = []
    add(out, "root=" + surface.rootDir)
    add(out, "package_id=" + surface.packageId)
    add(out, "dev_entry=" + surface.devEntry)
    add(out, "tooling_entry=" + surface.toolingEntry)
    add(out, "frontend_version=" + front.version)
    add(out, "frontend_phases=" + intToStr(front.phases.len))
    add(out, "compiler_core_surface_version=" + ccore.version)
    add(out, "compiler_core_top_level_forms=" + intToStr(ccore.topLevelForms.len))
    add(out, "compiler_core_block_kinds=" + intToStr(ccore.blockKinds.len))
    add(out, "string_surface_version=" + sstr.version)
    add(out, "string_operator_style=" + sstr.operatorStyle)
    add(out, "string_symbol_forms=" + intToStr(sstr.symbolForms.len))
    add(out, "string_search_algorithm=" + sstr.searchAlgorithm)
    add(out, "string_surface_forms=" + intToStr(sstr.surfaceForms.len))
    add(out, "string_lowering_version=" + slow.version)
    add(out, "string_lowering_rules=" + intToStr(slow.rules.len))
    add(out, "string_surface_ir_version=" + surfaceProgram.version)
    add(out, "string_surface_ir_exprs=" + intToStr(surfaceProgram.exprs.len))
    add(out, "string_facts_version=" + stringFacts.version)
    add(out, "string_fact_count=" + intToStr(stringFacts.factIds.len))
    add(out, "string_high_uir_graph_version=" + highString.version)
    add(out, "string_low_uir_plan_version=" + lowStringVersion)
    add(out, "string_pipeline_version=" + pipelineVersion)
    add(out, "string_runtime_version=" + runtime.version)
    add(out, "string_builder_growth=" + runtime.builderGrowth)
    add(out, "string_lowering_helpers=" + intToStr(runtime.loweringHelpers.len))
    add(out, "string_low_uir_ops=" + intToStr(stringOps.canonicalOps.len))
    add(out, "unimaker_surface_version=" + ustr.version)
    add(out, "unimaker_state_model=" + ustr.stateModel)
    add(out, "unimaker_code_identity=" + ustr.codeIdentity)
    add(out, "unimaker_compiler_agent_mode=" + ustr.compilerAgentMode)
    add(out, "unimaker_decl_forms=" + intToStr(ustr.coreDeclarations.len))
    add(out, "unimaker_annotations=" + intToStr(ustr.builtinAnnotations.len))
    add(out, "unimaker_builtin_types=" + intToStr(ustr.builtinTypes.len))
    add(out, "unimaker_surface_ir_version=" + infraProgram.version)
    add(out, "unimaker_surface_ir_decls=" + intToStr(infraProgram.decls.len))
    add(out, "unimaker_facts_version=" + infraFacts.version)
    add(out, "unimaker_fact_count=" + intToStr(infraFacts.declIds.len))
    add(out, "unimaker_high_uir_graph_version=" + highInfra.version)
    add(out, "unimaker_low_uir_plan_version=" + lowInfraVersion)
    add(out, "unimaker_pipeline_version=" + infraPipelineVersion)
    add(out, "unimaker_runtime_version=" + infraRuntime.version)
    add(out, "unimaker_runtime_services=" + intToStr(infraRuntime.services.len))
    add(out, "unimaker_low_uir_ops=" + intToStr(infraOps.canonicalOps.len))
    add(out, "network_surface_version=" + nstr.version)
    add(out, "network_topologies=" + intToStr(networkProgram.topologies.len))
    add(out, "network_ops=" + intToStr(networkProgram.ops.len))
    add(out, "network_facts_version=" + networkFacts.version)
    add(out, "network_fact_count=" + intToStr(networkFacts.opIds.len))
    add(out, "network_high_uir_graph_version=" + highNetwork.version)
    add(out, "network_low_uir_plan_version=" + lowNetworkVersion)
    add(out, "network_pipeline_version=" + networkPipelineVersion)
    add(out, "network_runtime_version=" + networkRuntime.version)
    add(out, "network_runtime_services=" + intToStr(networkRuntime.services.len))
    add(out, "network_low_uir_ops=" + intToStr(networkOps.canonicalOps.len))
    add(out, "source_manifest_version=" + mresolve.sourceManifestVersion())
    add(out, "release_artifact_version=" + rart.releaseArtifactVersion())
    add(out, "core_runtime_version=" + coreRuntime.version)
    add(out, "core_runtime_services=" + intToStr(coreRuntime.services.len))
    add(out, "compiler_core_runtime_version=" + compilerCoreRuntime.version)
    add(out, "compiler_core_runtime_services=" + intToStr(compilerCoreRuntime.services.len))
    add(out, "selfhost_version=" + selfhostContract.version)
    add(out, "selfhost_status=" + selfhostContract.currentStatus)
    add(out, "selfhost_stages=" + intToStr(selfhostContract.stages.len))
    add(out, "selfhost_proof_keys=" + intToStr(selfhostContract.proofKeys.len))
    add(out, "selfhost_proof_invariants=" + intToStr(selfhostContract.proofInvariants.len))
    add(out, "semantic_facts_version=" + facts.version)
    add(out, "semantic_fact_domains=" + intToStr(facts.domains.len))
    add(out, "high_uir_version=" + high.version)
    add(out, "high_uir_storage=" + high.storageModel)
    add(out, "abi_bridge_version=" + bridge.version)
    add(out, "abi_annotations=" + intToStr(bridge.supportedAnnotations.len))
    add(out, "low_uir_version=" + low.version)
    add(out, "low_uir_passes=" + intToStr(low.passOrder.len))
    add(out, "machine_version=" + machine.version)
    add(out, "machine_targets=" + intToStr(machine.firstClassTargets.len))
    add(out, "machine_pipeline_version=" + machineBundle.version)
    add(out, "machine_function_count=" + intToStr(machineBundle.itemIds.len))
    add(out, "obj_writer_version=" + writer.version)
    add(out, "obj_formats=" + intToStr(writer.formats.len))
    add(out, "obj_image_version=" + objImage.version)
    add(out, "obj_image_sections=" + intToStr(objImage.sectionNames.len))
    add(out, "obj_file_version=" + objFile.version)
    add(out, "obj_file_regions=" + intToStr(objFile.regionNames.len))
    add(out, "system_link_plan_version=" + systemLink.version)
    add(out, "system_link_linker_flavor=" + systemLink.linkerFlavor)
    add(out, "parallel_unit=" + low.parallelUnit)
    add(out, "merge_mode=" + low.mergeMode)
    return out

fn v2SurfaceText(): str =
    let lines = v2SurfaceLines()
    var out: str = ""
    for i in 0..<lines.len:
        if i > 0:
            out = out + "\n"
        out = out + lines[i]
    return out
