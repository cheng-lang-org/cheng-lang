import std/os
import std/strutils as strutils
import std/strings as strings

fn currentPathProbe(path: str): str =
    let abs = os.absolutePath(path)
    if os.dirExists(abs):
        return abs
    return os.parentDir(abs)

fn findNearestPackageRoot(path: str): str =
    var probe = currentPathProbe(path)
    while len(probe) > 0:
        if os.fileExists(os.joinPath(probe, "cheng-package.toml")):
            return probe
        let parent = os.parentDir(probe)
        if len(parent) == 0 || parent == probe:
            break
        probe = parent
    return ""

fn parsePackageManifestValue(rootPath: str, key: str): str =
    var manifestPath: str = ""
    if os.dirExists(rootPath):
        manifestPath = os.joinPath(rootPath, "cheng-package.toml")
    else:
        manifestPath = os.joinPath(os.parentDir(rootPath), "cheng-package.toml")
    if !os.fileExists(manifestPath):
        return ""
    let lines = strutils.split(os.readFile(manifestPath), '\n')
    for i in 0..<lines.len:
        let line = strutils.strip(lines[i])
        if !strutils.startsWith(line, key):
            continue
        let eqIdx = strings.find(line, "=")
        if eqIdx < 0:
            continue
        var value = strutils.strip(strings.sliceBytes(line, eqIdx + 1, len(line) - eqIdx - 1))
        if len(value) >= 2 && value[0] == '"' && value[len(value) - 1] == '"':
            value = strings.sliceBytes(value, 1, len(value) - 2)
        return value
    return ""

fn parsePackageModulePrefix(rootPath: str): str =
    var prefix = strutils.strip(parsePackageManifestValue(rootPath, "module_prefix"))
    if strutils.startsWith(prefix, "cheng/") && len(prefix) > len("cheng/"):
        prefix = strings.sliceBytes(prefix, len("cheng/"), len(prefix) - len("cheng/"))
    while len(prefix) > 0 && prefix[len(prefix) - 1] == '/':
        prefix = strings.sliceBytes(prefix, 0, len(prefix) - 1)
    return prefix

fn compilerPackageSourceRoots(packageRoot: str): str[] =
    var out: str[] = []
    add(out, os.joinPath(packageRoot, "src"))
    add(out, os.joinPath(os.joinPath(packageRoot, "tests"), "contracts"))
    add(out, os.joinPath(packageRoot, "examples"))
    add(out, packageRoot)
    return out

fn pathStartsWithRoot(path: str, root: str): bool =
    let pathAbs = os.absolutePath(path)
    let rootAbs = os.absolutePath(root)
    return pathAbs == rootAbs || strutils.startsWith(pathAbs, rootAbs + "/")

fn dropChengExt(path: str): str =
    if strings.endsWith(path, ".cheng"):
        return strings.sliceBytes(path, 0, len(path) - len(".cheng"))
    return path

fn prefixedModulePath(prefix: str, relPath: str): str =
    let rel = dropChengExt(relPath)
    if len(prefix) <= 0:
        return rel
    if len(rel) <= 0:
        return prefix
    return prefix + "/" + rel

fn defaultOwnerModulePathForSourcePath(sourcePath: str): str =
    let packageRoot = findNearestPackageRoot(sourcePath)
    if len(packageRoot) > 0:
        let packageRoots = compilerPackageSourceRoots(packageRoot)
        let modulePrefix = parsePackageModulePrefix(packageRoot)
        for i in 0..<packageRoots.len:
            if !os.dirExists(packageRoots[i]):
                continue
            if pathStartsWithRoot(sourcePath, packageRoots[i]):
                let rel = os.relativePath(os.absolutePath(sourcePath), os.absolutePath(packageRoots[i]))
                return prefixedModulePath(modulePrefix, rel)
    let path = os.absolutePath(sourcePath)
    let v2Idx = strings.find(path, "v2/src/")
    if v2Idx >= 0:
        let start = v2Idx + len("v2/src/")
        var stop: int32 = strings.len(path)
        if strings.endsWith(path, ".cheng"):
            stop = strings.len(path) - len(".cheng")
        return strings.sliceBytes(path, start, stop - start)
    let srcIdx = strings.find(path, "src/")
    if srcIdx >= 0:
        let start = srcIdx + len("src/")
        var stop: int32 = strings.len(path)
        if strings.endsWith(path, ".cheng"):
            stop = strings.len(path) - len(".cheng")
        return strings.sliceBytes(path, start, stop - start)
    return dropChengExt(path)

fn declaredModulePathForSourcePath(sourcePath: str): str =
    return defaultOwnerModulePathForSourcePath(sourcePath)
