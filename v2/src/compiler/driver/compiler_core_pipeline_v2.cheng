import std/seqs
import std/strings as strings
import std/system
import compiler/frontend/compiler_core_surface_ir_v2 as ccore
import compiler/frontend/v2_source_parser as parser
import compiler/driver/manifest_resolver_v2 as mresolve
import compiler/semantic_facts/compiler_core_facts_v2 as cfacts
import compiler/high_uir/compiler_core_graph_v2 as cgraph
import compiler/low_uir/compiler_core_lowering_v2 as clow

type
    CompilerCorePipelineBundle =
        version: str
        program: ccore.CompilerCoreProgram
        facts: cfacts.CompilerCoreSemanticFacts
        highGraph: cgraph.HighUirCompilerCoreGraph
        lowPlan: clow.LowUirCompilerCorePlan

fn compilerCorePipelineVersion(): str =
    return "v2.driver.compiler_core_pipeline.v1"

fn lowerCompilerCoreProgramToHighUir(program: ccore.CompilerCoreProgram,
                                     facts: cfacts.CompilerCoreSemanticFacts): cgraph.HighUirCompilerCoreGraph =
    var out: cgraph.HighUirCompilerCoreGraph = cgraph.newHighUirCompilerCoreGraph()
    var moduleIdx: int32 = 0
    var typeIdx: int32 = 0
    var constIdx: int32 = 0
    var varIdx: int32 = 0
    var routineIdx: int32 = 0
    for i in 0..<facts.itemIds.len:
        var signatureText: str = ""
        if facts.topLevelKinds[i] == "module":
            signatureText = program.modules[moduleIdx].headerText
            moduleIdx = moduleIdx + 1
        elif facts.topLevelKinds[i] == "type":
            signatureText = program.typeBlocks[typeIdx].headerText
            typeIdx = typeIdx + 1
        elif facts.topLevelKinds[i] == "const":
            signatureText = program.constDecls[constIdx].headerText
            constIdx = constIdx + 1
        elif facts.topLevelKinds[i] == "var":
            signatureText = program.varDecls[varIdx].headerText
            varIdx = varIdx + 1
        elif facts.topLevelKinds[i] != "import":
            signatureText = program.routines[routineIdx].signatureText
            routineIdx = routineIdx + 1
        cgraph.appendHighUirCompilerCoreItem(out,
                                             facts.itemIds[i],
                                             facts.highOps[i],
                                             facts.proofDomains[i],
                                             facts.effectClasses[i],
                                             facts.bindingScopes[i],
                                             facts.importPaths[i],
                                             facts.importAliases[i],
                                             facts.importCategories[i],
                                             signatureText,
                                             facts.signatureHashes[i],
                                             facts.bodyLineCounts[i],
                                             facts.bodyHashes[i],
                                             facts.executableAstReady[i],
                                             facts.returnTypeTexts[i],
                                             facts.paramCounts[i],
                                             facts.localCounts[i],
                                             facts.stmtCounts[i],
                                             facts.exprCounts[i],
                                             facts.topLevelKinds[i],
                                             facts.topLevelLabels[i],
                                             facts.importcSymbolTexts[i])
    return out

fn compileCompilerCoreProgram(program: ccore.CompilerCoreProgram): CompilerCorePipelineBundle =
    var out: CompilerCorePipelineBundle
    out.version = compilerCorePipelineVersion()
    out.program = program
    out.facts = cfacts.buildCompilerCoreSemanticFacts(program)
    out.highGraph = lowerCompilerCoreProgramToHighUir(program, out.facts)
    out.lowPlan = clow.lowerHighUirCompilerCoreGraphToLowUir(out.program, out.highGraph)
    return out

fn compileCompilerCoreSourceClosure(entryPath: str): CompilerCorePipelineBundle =
    let manifest = mresolve.resolveCompilerCoreSourceManifest(entryPath)
    var merged: ccore.CompilerCoreProgram = ccore.newCompilerCoreProgram()
    for i in 0..<manifest.filePaths.len:
        let path = manifest.filePaths[i]
        if !strings.hasSuffix(path, ".cheng"):
            continue
        let parsed = parser.parseV2SourceFileStrict(path)
        if parsed.compilerCoreProgram.topLevelKinds.len <= 0:
            continue
        ccore.appendCompilerCoreProgram(merged, parsed.compilerCoreProgram)
    return compileCompilerCoreProgram(merged)

fn compilerCorePipelineLines(bundle: CompilerCorePipelineBundle): str[] =
    var out: str[]
    out = []
    add(out, "pipeline_version=" + bundle.version)
    add(out, "top_levels=" + intToStr(bundle.program.topLevelKinds.len))
    add(out, "modules=" + intToStr(bundle.program.modules.len))
    add(out, "imports=" + intToStr(bundle.program.imports.len))
    add(out, "type_blocks=" + intToStr(bundle.program.typeBlocks.len))
    add(out, "consts=" + intToStr(bundle.program.constDecls.len))
    add(out, "vars=" + intToStr(bundle.program.varDecls.len))
    add(out, "routines=" + intToStr(bundle.program.routines.len))
    add(out, "routine_params=" + intToStr(bundle.program.routineParams.len))
    add(out, "locals=" + intToStr(bundle.program.locals.len))
    add(out, "stmts=" + intToStr(bundle.program.stmts.len))
    add(out, "exprs=" + intToStr(bundle.program.exprs.len))
    add(out, "facts=" + intToStr(bundle.facts.itemIds.len))
    add(out, "facts.executable_ast_items=" + intToStr(cfacts.compilerCoreExecutableAstItemCount(bundle.facts)))
    add(out, "facts.param_count=" + intToStr(cfacts.compilerCoreExecutableParamCount(bundle.facts)))
    add(out, "facts.local_count=" + intToStr(cfacts.compilerCoreExecutableLocalCount(bundle.facts)))
    add(out, "facts.stmt_count=" + intToStr(cfacts.compilerCoreExecutableStmtCount(bundle.facts)))
    add(out, "facts.expr_count=" + intToStr(cfacts.compilerCoreExecutableExprCount(bundle.facts)))
    add(out, "high_uir_nodes=" + intToStr(bundle.highGraph.itemIds.len))
    add(out, "low_uir_nodes=" + intToStr(bundle.lowPlan.itemIds.len))
    for i in 0..<bundle.lowPlan.itemIds.len:
        let astReadyText = if bundle.lowPlan.executableAstReady[i]: "1" else: "0"
        add(out, intToStr(i) + ":" +
                 bundle.lowPlan.topLevelKinds[i] + ":" +
                 bundle.lowPlan.labels[i] + " => " +
                 bundle.lowPlan.canonicalOps[i] + " => " +
                 bundle.lowPlan.runtimeTargets[i] +
                 " | ast_ready=" + astReadyText +
                 " | params=" + intToStr(bundle.lowPlan.paramCounts[i]) +
                 " | locals=" + intToStr(bundle.lowPlan.localCounts[i]) +
                 " | stmts=" + intToStr(bundle.lowPlan.stmtCounts[i]) +
                 " | exprs=" + intToStr(bundle.lowPlan.exprCounts[i]) +
                 " | exec_ops=" + intToStr(bundle.lowPlan.routineOpCounts[i]) +
                 " | exec_hash=" + bundle.lowPlan.routineOpHashes[i])
    return out
