import std/seqs

type
    LowUirPipelineContract =
        version: str
        passOrder: str[]
        requiredCore: str[]
        accelerated: str[]
        parallelUnit: str
        mergeMode: str

fn lowUirPipelineContract(): LowUirPipelineContract =
    var out: LowUirPipelineContract
    out.version = "v2.low_uir_pipeline.v1"
    out.passOrder = []
    add(out.passOrder, "canonicalize")
    add(out.passOrder, "proof_import")
    add(out.passOrder, "noalias")
    add(out.passOrder, "ssu")
    add(out.passOrder, "inline")
    add(out.passOrder, "cse")
    add(out.passOrder, "sroa")
    add(out.passOrder, "licm")
    add(out.passOrder, "cfg_canonicalize")
    add(out.passOrder, "egraph")
    add(out.passOrder, "ssa")
    add(out.passOrder, "post_ssa_cleanup")
    add(out.passOrder, "late_vectorize")
    out.requiredCore = []
    add(out.requiredCore, "canonicalize")
    add(out.requiredCore, "proof_import")
    add(out.requiredCore, "noalias")
    add(out.requiredCore, "ssu")
    add(out.requiredCore, "ssa")
    out.accelerated = []
    add(out.accelerated, "inline")
    add(out.accelerated, "cse")
    add(out.accelerated, "sroa")
    add(out.accelerated, "licm")
    add(out.accelerated, "egraph")
    add(out.accelerated, "late_vectorize")
    out.parallelUnit = "function_task"
    out.mergeMode = "stable_declaration_order"
    return out

fn lowUirPassCount(): int32 =
    let c = lowUirPipelineContract()
    return c.passOrder.len

fn lowUirRequiredCoreCount(): int32 =
    let c = lowUirPipelineContract()
    return c.requiredCore.len
