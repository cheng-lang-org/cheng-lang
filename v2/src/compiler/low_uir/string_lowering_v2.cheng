import std/seqs
import std/system
import compiler/high_uir/string_graph_v2 as hstr
import compiler/low_uir/string_ops_contract as sops

type
    LowUirStringPlan =
        version: str
        exprIds: int32[]
        canonicalOps: str[]
        runtimeTargets: str[]
        resultKinds: str[]
        allocationModes: str[]
        effectClasses: str[]
        zeroCopyFacts: bool[]

fn lowUirStringPlanVersion(): str =
    return "v2.low_uir.string_lowering.v1"

fn newLowUirStringPlan(): LowUirStringPlan =
    var out: LowUirStringPlan
    out.version = lowUirStringPlanVersion()
    out.exprIds = []
    out.canonicalOps = []
    out.runtimeTargets = []
    out.resultKinds = []
    out.allocationModes = []
    out.effectClasses = []
    out.zeroCopyFacts = []
    return out

fn lowerHighUirStringGraphToLowUir(graph: hstr.HighUirStringGraph): LowUirStringPlan =
    var out: LowUirStringPlan = newLowUirStringPlan()
    let contract = sops.lowUirStringOpsContract()
    for i in 0..<graph.exprIds.len:
        let opName = graph.opNames[i]
        let opIdx = sops.findLowUirStringOp(opName)
        if opIdx < 0:
            panic("v2 low_uir string lowering: missing canonical op for " + opName)
        let op = contract.canonicalOps[opIdx]
        add(out.exprIds, graph.exprIds[i])
        add(out.canonicalOps, op.opName)
        add(out.runtimeTargets, op.runtimeTarget)
        add(out.resultKinds, graph.resultKinds[i])
        add(out.allocationModes, op.allocationMode)
        add(out.effectClasses, op.effectClass)
        add(out.zeroCopyFacts, op.zeroCopy)
    return out

fn lowUirStringPlanCount(plan: LowUirStringPlan): int32 =
    return plan.exprIds.len
