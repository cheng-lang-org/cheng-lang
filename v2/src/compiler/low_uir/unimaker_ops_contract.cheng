import std/seqs

type
    LowUirUnimakerOp =
        opName: str
        runtimeTarget: str
        effectClass: str
        proofDomain: str
    LowUirUnimakerOpsContract =
        version: str
        canonicalOps: LowUirUnimakerOp[]
        codeIdentity: str
        stateModel: str
        evolveMode: str

fn lowUirUnimakerOp(opName: str,
                    runtimeTarget: str,
                    effectClass: str,
                    proofDomain: str): LowUirUnimakerOp =
    var out: LowUirUnimakerOp
    out.opName = opName
    out.runtimeTarget = runtimeTarget
    out.effectClass = effectClass
    out.proofDomain = proofDomain
    return out

fn lowUirUnimakerOpsContract(): LowUirUnimakerOpsContract =
    var out: LowUirUnimakerOpsContract
    out.version = "v2.low_uir.unimaker_ops.v1"
    out.canonicalOps = []
    add(out.canonicalOps, lowUirUnimakerOp("asset_contract_def",
                                           "runtime/unimaker.verify_asset_contract",
                                           "pure_contract",
                                           "refinement_contract"))
    add(out.canonicalOps, lowUirUnimakerOp("actor_def",
                                           "runtime/unimaker.spawn_actor",
                                           "isolated_state",
                                           "actor_isolation"))
    add(out.canonicalOps, lowUirUnimakerOp("ganzhi_state_def",
                                           "runtime/unimaker.register_ganzhi_state",
                                           "crdt_state",
                                           "ganzhi_merge"))
    add(out.canonicalOps, lowUirUnimakerOp("hardware_callback_def",
                                           "runtime/unimaker.bind_nfc_callback",
                                           "hardware_interrupt",
                                           "capability_contract"))
    add(out.canonicalOps, lowUirUnimakerOp("evolve_site_def",
                                           "runtime/unimaker.register_evolve_site",
                                           "agentic_candidate",
                                           "evolve_candidate"))
    out.codeIdentity = "content_addressed_manifest"
    out.stateModel = "actor_owned_state_plus_crdt_snapshot"
    out.evolveMode = "offline_candidate_gate"
    return out

fn findLowUirUnimakerOp(opName: str): int32 =
    let c = lowUirUnimakerOpsContract()
    for i in 0..<c.canonicalOps.len:
        if c.canonicalOps[i].opName == opName:
            return i
    return -1
