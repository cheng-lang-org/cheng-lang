import std/seqs
import std/strings as strings
import std/strutils as strutils
import std/system
import compiler/driver/identity_v2 as ident
import compiler/driver/manifest_resolver_v2 as manifest
import compiler/high_uir/compiler_core_graph_v2 as cgraph
import compiler/low_uir/compiler_core_ops_contract as cops

type
    LowUirLoopLabels =
        continueLabels: str[]
        breakLabels: str[]

    LowUirCompilerCorePlan =
        version: str
        itemIds: int32[]
        canonicalOps: str[]
        runtimeTargets: str[]
        proofDomains: str[]
        effectClasses: str[]
        bindingScopes: str[]
        topLevelKinds: str[]
        labels: str[]
        ownerModules: str[]
        sourcePaths: str[]
        importcSymbolTexts: str[]
        importPaths: str[]
        importTargetModulePaths: str[]
        importAliases: str[]
        importCategories: str[]
        signatureTexts: str[]
        signatureHashes: str[]
        bodyTexts: str[]
        bodyLineCounts: int32[]
        bodyHashes: str[]
        executableAstReady: bool[]
        returnTypeTexts: str[]
        paramCounts: int32[]
        itemParamStarts: int32[]
        paramKinds: str[]
        localCounts: int32[]
        itemLocalStarts: int32[]
        localTypeTexts: str[]
        stmtCounts: int32[]
        exprCounts: int32[]
        stmtKindSets: str[]
        exprKindSets: str[]
        stmtSemanticSets: str[]
        exprSemanticSets: str[]
        exprReferenceKinds: str[]
        exprReferenceTargetKinds: str[]
        exprReferenceTexts: str[]
        exprReferenceItemIds: int32[]
        exprReferenceValueInts: int32[]
        routineOpStarts: int32[]
        routineOpCounts: int32[]
        routineOpHashes: str[]
        opKinds: str[]
        opPrimaryTexts: str[]
        opSecondaryTexts: str[]
        opArg0s: int32[]
        opArg1s: int32[]
        opArg2s: int32[]

fn lowUirCompilerCorePlanVersion(): str =
    return "v2.low_uir.compiler_core_lowering.v16"

fn newLowUirCompilerCorePlan(): LowUirCompilerCorePlan =
    var out: LowUirCompilerCorePlan
    out.version = lowUirCompilerCorePlanVersion()
    out.itemIds = []
    out.canonicalOps = []
    out.runtimeTargets = []
    out.proofDomains = []
    out.effectClasses = []
    out.bindingScopes = []
    out.topLevelKinds = []
    out.labels = []
    out.ownerModules = []
    out.sourcePaths = []
    out.importcSymbolTexts = []
    out.importPaths = []
    out.importTargetModulePaths = []
    out.importAliases = []
    out.importCategories = []
    out.signatureTexts = []
    out.signatureHashes = []
    out.bodyTexts = []
    out.bodyLineCounts = []
    out.bodyHashes = []
    out.executableAstReady = []
    out.returnTypeTexts = []
    out.paramCounts = []
    out.itemParamStarts = []
    out.paramKinds = []
    out.localCounts = []
    out.itemLocalStarts = []
    out.localTypeTexts = []
    out.stmtCounts = []
    out.exprCounts = []
    out.stmtKindSets = []
    out.exprKindSets = []
    out.stmtSemanticSets = []
    out.exprSemanticSets = []
    out.exprReferenceKinds = []
    out.exprReferenceTargetKinds = []
    out.exprReferenceTexts = []
    out.exprReferenceItemIds = []
    out.exprReferenceValueInts = []
    out.routineOpStarts = []
    out.routineOpCounts = []
    out.routineOpHashes = []
    out.opKinds = []
    out.opPrimaryTexts = []
    out.opSecondaryTexts = []
    out.opArg0s = []
    out.opArg1s = []
    out.opArg2s = []
    return out

fn appendLowUirCompilerCoreExecOp(plan: var LowUirCompilerCorePlan,
                                  kind: str,
                                  primaryText: str,
                                  secondaryText: str,
                                  arg0: int32,
                                  arg1: int32,
                                  arg2: int32) =
    seqs.add(plan.opKinds, kind)
    seqs.add(plan.opPrimaryTexts, primaryText)
    seqs.add(plan.opSecondaryTexts, secondaryText)
    seqs.add(plan.opArg0s, arg0)
    seqs.add(plan.opArg1s, arg1)
    seqs.add(plan.opArg2s, arg2)

fn compilerCoreExprChildIds(graph: cgraph.HighUirCompilerCoreGraph, exprId: int32): int32[] =
    var out: int32[]
    out = []
    for i in 0..<graph.exprChildCounts[exprId]:
        seqs.add(out, graph.exprChildIds[graph.exprChildStarts[exprId] + i])
    return out

fn compilerCoreExprChildArgNames(graph: cgraph.HighUirCompilerCoreGraph, exprId: int32): str[] =
    var out: str[]
    out = []
    for i in 0..<graph.exprChildCounts[exprId]:
        seqs.add(out, graph.exprChildArgNames[graph.exprChildStarts[exprId] + i])
    return out

fn compilerCoreJoinWithSep(values: str[], sep: str): str =
    var out: str = ""
    for i in 0..<values.len:
        if i > 0:
            out = out + sep
        out = out + values[i]
    return out

fn compilerCoreLineEndsWithAssign(line: str): bool =
    let trimmed = strutils.strip(line)
    return strings.len(trimmed) > 0 && trimmed[strings.len(trimmed) - 1] == '='

fn compilerCoreRoutineSignatureEndsWithAssign(signatureText: str): bool =
    let lines = strutils.split(signatureText, '\n')
    var idx: int32 = lines.len - 1
    while idx >= 0:
        let trimmed = strutils.strip(lines[idx])
        if strings.len(trimmed) > 0:
            return compilerCoreLineEndsWithAssign(trimmed)
        idx = idx - 1
    return false

fn compilerCoreTypeConstructorText(graph: cgraph.HighUirCompilerCoreGraph, exprId: int32): str =
    if exprId < 0:
        return ""
    let exprKind = graph.exprKinds[exprId]
    if exprKind == "name_ref" &&
       graph.exprReferenceKinds[exprId] == "name" &&
       (graph.exprReferenceTargetKinds[exprId] == "type" ||
        graph.exprReferenceTargetKinds[exprId] == "type_param"):
        return graph.exprPrimaryTexts[exprId]
    if exprKind == "index":
        let childIds = compilerCoreExprChildIds(graph, exprId)
        if childIds.len != 2:
            return ""
        let baseText = compilerCoreTypeConstructorText(graph, childIds[0])
        let argText = compilerCoreTypeConstructorText(graph, childIds[1])
        if strings.len(baseText) <= 0 || strings.len(argText) <= 0:
            return ""
        return baseText + "[" + argText + "]"
    if exprKind == "suffix_ctor" && graph.exprPrimaryTexts[exprId] == "[]":
        let childIds = compilerCoreExprChildIds(graph, exprId)
        if childIds.len != 1:
            return ""
        let baseText = compilerCoreTypeConstructorText(graph, childIds[0])
        if strings.len(baseText) <= 0:
            return ""
        return baseText + "[]"
    return ""

fn compilerCoreExplicitGenericRoutineBaseCalleeExprId(graph: cgraph.HighUirCompilerCoreGraph,
                                                      exprId: int32): int32 =
    if exprId < 0 || graph.exprKinds[exprId] != "call":
        return -1
    let childIds = compilerCoreExprChildIds(graph, exprId)
    if childIds.len <= 0:
        return -1
    let calleeExprId = childIds[0]
    let callTargetKind = graph.exprCallTargetKinds[exprId]
    if callTargetKind != "routine" && callTargetKind != "import_field_routine":
        return calleeExprId
    if graph.exprKinds[calleeExprId] != "index":
        return calleeExprId
    let calleeChildIds = compilerCoreExprChildIds(graph, calleeExprId)
    if calleeChildIds.len != 2:
        return calleeExprId
    if strings.len(compilerCoreTypeConstructorText(graph, calleeChildIds[1])) <= 0:
        return calleeExprId
    return calleeChildIds[0]

fn compilerCoreStmtChildIds(graph: cgraph.HighUirCompilerCoreGraph,
                            stmtId: int32): int32[] =
    var out: int32[]
    out = []
    for i in 0..<graph.stmtChildCounts[stmtId]:
        seqs.add(out, graph.stmtChildIds[graph.stmtChildStarts[stmtId] + i])
    return out

fn compilerCoreStmtElseChildIds(graph: cgraph.HighUirCompilerCoreGraph,
                                stmtId: int32): int32[] =
    var out: int32[]
    out = []
    for i in 0..<graph.stmtElseChildCounts[stmtId]:
        seqs.add(out, graph.stmtChildIds[graph.stmtElseChildStarts[stmtId] + i])
    return out

fn compilerCoreRootStmtIds(graph: cgraph.HighUirCompilerCoreGraph,
                           itemIdx: int32): int32[] =
    let stmtStart = graph.itemStmtStarts[itemIdx]
    let stmtCount = graph.stmtCounts[itemIdx]
    var referenced: int32[]
    var out: int32[]
    referenced = []
    out = []
    for i in 0..<stmtCount:
        seqs.add(referenced, 0)
    for stmtOffset in 0..<stmtCount:
        let stmtId = stmtStart + stmtOffset
        for childOffset in 0..<graph.stmtChildCounts[stmtId]:
            let childId = graph.stmtChildIds[graph.stmtChildStarts[stmtId] + childOffset]
            if childId >= stmtStart && childId < stmtStart + stmtCount:
                referenced[childId - stmtStart] = 1
        for elseChildOffset in 0..<graph.stmtElseChildCounts[stmtId]:
            let childId = graph.stmtChildIds[graph.stmtElseChildStarts[stmtId] + elseChildOffset]
            if childId >= stmtStart && childId < stmtStart + stmtCount:
                referenced[childId - stmtStart] = 1
    for stmtOffset in 0..<stmtCount:
        if referenced[stmtOffset] == 0:
            seqs.add(out, stmtStart + stmtOffset)
    return out

fn compilerCoreFindParamSlot(graph: cgraph.HighUirCompilerCoreGraph,
                             itemIdx: int32,
                             name: str): int32 =
    let start = graph.itemParamStarts[itemIdx]
    for i in 0..<graph.paramCounts[itemIdx]:
        if graph.paramNames[start + i] == name:
            return i
    return -1

fn compilerCoreFindLocalSlot(graph: cgraph.HighUirCompilerCoreGraph,
                             itemIdx: int32,
                             name: str): int32 =
    let start = graph.itemLocalStarts[itemIdx]
    for i in 0..<graph.localCounts[itemIdx]:
        if graph.localNames[start + i] == name:
            return i
    return -1

fn compilerCoreFindItemIndexById(graph: cgraph.HighUirCompilerCoreGraph,
                                 itemId: int32): int32 =
    for i in 0..<graph.itemIds.len:
        if graph.itemIds[i] == itemId:
            return i
    return -1

fn compilerCoreItemParamKind(graph: cgraph.HighUirCompilerCoreGraph,
                             itemIdx: int32,
                             paramSlot: int32): str =
    if itemIdx < 0 || itemIdx >= graph.itemIds.len:
        return ""
    if paramSlot < 0 || paramSlot >= graph.paramCounts[itemIdx]:
        return ""
    let start = graph.itemParamStarts[itemIdx]
    return graph.paramKinds[start + paramSlot]

fn compilerCoreLowerVarArgExpr(graph: cgraph.HighUirCompilerCoreGraph,
                               itemIdx: int32,
                               itemId: int32,
                               ownerSourcePath: str,
                               exprId: int32,
                               out: var LowUirCompilerCorePlan) =
    compilerCoreLowerAddressExpr(graph, itemIdx, itemId, ownerSourcePath, exprId, out)

fn compilerCoreFindTopLevelKind(graph: cgraph.HighUirCompilerCoreGraph, label: str): str =
    for i in 0..<graph.labels.len:
        if graph.labels[i] == label:
            return graph.topLevelKinds[i]
    return ""

fn compilerCoreFindTopLevelItemId(graph: cgraph.HighUirCompilerCoreGraph, label: str): int32 =
    for i in 0..<graph.labels.len:
        if graph.labels[i] == label:
            return graph.itemIds[i]
    return -1

fn compilerCoreImportVisibleName(importPath: str, importAlias: str): str =
    if strings.len(importAlias) > 0:
        return importAlias
    var slashIdx: int32 = -1
    for i in 0..<strings.len(importPath):
        if importPath[i] == '/':
            slashIdx = i
    if slashIdx >= 0:
        return strings.sliceBytes(importPath, slashIdx + 1, strings.len(importPath) - slashIdx - 1)
    return importPath

fn compilerCoreBodyLines(bodyText: str): str[] =
    var out: str[]
    out = []
    var start: int32 = 0
    var i: int32 = 0
    while i <= strings.len(bodyText):
        if i == strings.len(bodyText) || bodyText[i] == '\n':
            seqs.add(out, strings.sliceBytes(bodyText, start, i - start))
            start = i + 1
        i = i + 1
    return out

fn compilerCoreFindImportVisibleItemId(graph: cgraph.HighUirCompilerCoreGraph,
                                       ownerModulePath: str,
                                       name: str): int32 =
    for i in 0..<graph.topLevelKinds.len:
        if graph.topLevelKinds[i] != "import":
            continue
        if i >= graph.ownerModules.len || graph.ownerModules[i] != ownerModulePath:
            continue
        if compilerCoreImportVisibleName(graph.importPaths[i], graph.importAliases[i]) == name:
            return graph.itemIds[i]
    return -1

fn compilerCoreResolveImportFieldItem(graph: cgraph.HighUirCompilerCoreGraph,
                                      ownerModulePath: str,
                                      importName: str,
                                      fieldName: str,
                                      resolvedKind: var str,
                                      resolvedItemId: var int32): bool =
    var targetModulePath: str = ""
    for i in 0..<graph.topLevelKinds.len:
        if graph.topLevelKinds[i] != "import":
            continue
        if i >= graph.ownerModules.len || graph.ownerModules[i] != ownerModulePath:
            continue
        if compilerCoreImportVisibleName(graph.importPaths[i], graph.importAliases[i]) == importName:
            targetModulePath = graph.importTargetModulePaths[i]
            break
    if strings.len(targetModulePath) <= 0:
        return false
    var matchCount: int32 = 0
    for i in 0..<graph.topLevelKinds.len:
        if i >= graph.ownerModules.len || graph.ownerModules[i] != targetModulePath:
            continue
        if graph.labels[i] != fieldName:
            continue
        let topLevelKind = graph.topLevelKinds[i]
        if topLevelKind != "fn" && topLevelKind != "iterator" && topLevelKind != "importc_fn" &&
           topLevelKind != "const" && topLevelKind != "var":
            continue
        matchCount = matchCount + 1
        if matchCount > 1:
            return false
        resolvedKind = topLevelKind
        resolvedItemId = graph.itemIds[i]
    return matchCount == 1

fn compilerCoreQualifiedFieldName(baseName: str, fieldName: str): str =
    if strings.len(baseName) <= 0:
        return fieldName
    return baseName + "." + fieldName

fn compilerCoreLineIndent(rawLine: str): int32 =
    var out: int32 = 0
    while out < strings.len(rawLine) && (rawLine[out] == ' ' || rawLine[out] == '\t'):
        out = out + 1
    return out

fn compilerCoreTrimInlineComment(rawText: str): str =
    for i in 0..<strings.len(rawText):
        if rawText[i] == '#':
            return strutils.strip(strings.sliceBytes(rawText, 0, i))
    return strutils.strip(rawText)

fn compilerCoreIntDigitValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn compilerCoreIntDigitsValid(text: str, start: int32, base: int32): bool =
    var sawDigit: bool = false
    var prevUnderscore: bool = false
    for i in start..<strings.len(text):
        if text[i] == '_':
            if !sawDigit || prevUnderscore:
                return false
            prevUnderscore = true
            continue
        let digit = compilerCoreIntDigitValue(text[i])
        if digit < 0 || digit >= base:
            return false
        sawDigit = true
        prevUnderscore = false
    return sawDigit && !prevUnderscore

fn compilerCoreParseInt32Text(rawText: str, outValue: var int32): bool =
    let text = strutils.strip(rawText)
    if strings.len(text) <= 0:
        return false
    var start: int32 = 0
    var sign: int32 = 1
    if text[0] == '-':
        sign = -1
        start = 1
    if start >= strings.len(text):
        return false
    var base: int32 = 10
    if start + 1 < strings.len(text) && text[start] == '0':
        let marker = text[start + 1]
        if marker == 'x' || marker == 'X':
            base = 16
            start = start + 2
        elif marker == 'b' || marker == 'B':
            base = 2
            start = start + 2
        elif marker == 'o' || marker == 'O':
            base = 8
            start = start + 2
    if start >= strings.len(text):
        return false
    if !compilerCoreIntDigitsValid(text, start, base):
        return false
    var value: int64 = 0
    for i in start..<strings.len(text):
        if text[i] == '_':
            continue
        let digit = compilerCoreIntDigitValue(text[i])
        if digit < 0 || digit >= base:
            return false
        value = value * int64(base) + int64(digit)
    value = value * int64(sign)
    if value < int64(-2147483648) || value > int64(2147483647):
        return false
    outValue = int32(value)
    return true

fn compilerCoreParseInt64Text(rawText: str, outValue: var int64): bool =
    let text = strutils.strip(rawText)
    if strings.len(text) <= 0:
        return false
    var start: int32 = 0
    var sign: int32 = 1
    if text[0] == '-':
        sign = -1
        start = 1
    if start >= strings.len(text):
        return false
    var base: int32 = 10
    if start + 1 < strings.len(text) && text[start] == '0':
        let marker = text[start + 1]
        if marker == 'x' || marker == 'X':
            base = 16
            start = start + 2
        elif marker == 'b' || marker == 'B':
            base = 2
            start = start + 2
        elif marker == 'o' || marker == 'O':
            base = 8
            start = start + 2
    if start >= strings.len(text):
        return false
    if !compilerCoreIntDigitsValid(text, start, base):
        return false
    var value: uint64 = 0
    for i in start..<strings.len(text):
        if text[i] == '_':
            continue
        let digit = compilerCoreIntDigitValue(text[i])
        if digit < 0 || digit >= base:
            return false
        let nextValue = value * uint64(base) + uint64(digit)
        if nextValue < value:
            return false
        value = nextValue
    if sign < 0:
        let minMagnitude: uint64 = uint64(1) << uint64(63)
        if value > minMagnitude:
            return false
        if value == minMagnitude:
            outValue = int64(-9223372036854775807) - int64(1)
            return true
        outValue = -int64(value)
        return true
    let maxPositive: uint64 = (uint64(1) << uint64(63)) - uint64(1)
    if value > maxPositive:
        return false
    outValue = int64(value)
    return true

fn compilerCoreSplitEnumFieldParts(text: str): str[] =
    var out: str[]
    var start: int32 = 0
    for i in 0..<strings.len(text):
        if text[i] == ',':
            let part = strutils.strip(strings.sliceBytes(text, start, i - start))
            if strings.len(part) > 0:
                seqs.add(out, part)
            start = i + 1
    let tail = strutils.strip(strings.sliceBytes(text, start, strings.len(text) - start))
    if strings.len(tail) > 0:
        seqs.add(out, tail)
    return out

fn compilerCoreCountEnumMemberMatchesInFieldText(fieldText: str,
                                                 memberName: str,
                                                 nextOrdinal: var int32,
                                                 outOrdinal: var int32): int32 =
    let parts = compilerCoreSplitEnumFieldParts(fieldText)
    var matchCount: int32 = 0
    for i in 0..<parts.len:
        let part = compilerCoreTrimInlineComment(parts[i])
        if strings.len(part) <= 0:
            continue
        let eqIdx = strings.find(part, "=")
        var fieldName: str = part
        var fieldOrdinal: int32 = nextOrdinal
        if eqIdx >= 0:
            fieldName = strutils.strip(strings.sliceBytes(part, 0, eqIdx))
            let valueText = strutils.strip(strings.sliceBytes(part, eqIdx + 1, strings.len(part) - eqIdx - 1))
            if !compilerCoreParseInt32Text(valueText, fieldOrdinal):
                system.panicStr("v2 low_uir compiler_core lowering: unsupported enum ordinal " + valueText)
        if strings.len(fieldName) <= 0:
            system.panicStr("v2 low_uir compiler_core lowering: malformed enum field " + part)
        if fieldName == memberName:
            matchCount = matchCount + 1
            outOrdinal = fieldOrdinal
        nextOrdinal = fieldOrdinal + 1
    return matchCount

fn compilerCoreCountEnumMemberMatchesInTypeBlock(bodyLines: str[],
                                                 memberName: str,
                                                 outOrdinal: var int32): int32 =
    var matchCount: int32 = 0
    var activeEnumIndent: int32 = -1
    var nextOrdinal: int32 = 0
    for i in 0..<bodyLines.len:
        let rawLine = bodyLines[i]
        let line = compilerCoreTrimInlineComment(rawLine)
        if strings.len(line) <= 0:
            continue
        let indent = compilerCoreLineIndent(rawLine)
        let enumIdx = strings.find(line, "= enum")
        if enumIdx >= 0:
            activeEnumIndent = indent
            nextOrdinal = 0
            let suffix = strutils.strip(strings.sliceBytes(line,
                                                           enumIdx + strings.len("= enum"),
                                                           strings.len(line) - enumIdx - strings.len("= enum")))
            if strings.len(suffix) > 0:
                matchCount = matchCount +
                    compilerCoreCountEnumMemberMatchesInFieldText(suffix,
                                                                  memberName,
                                                                  nextOrdinal,
                                                                  outOrdinal)
            continue
        if activeEnumIndent >= 0 && indent > activeEnumIndent:
            matchCount = matchCount +
                compilerCoreCountEnumMemberMatchesInFieldText(line,
                                                              memberName,
                                                              nextOrdinal,
                                                              outOrdinal)
            continue
        activeEnumIndent = -1
    return matchCount

fn compilerCoreResolveEnumMemberOrdinalInModulePath(graph: cgraph.HighUirCompilerCoreGraph,
                                                    modulePath: str,
                                                    memberName: str,
                                                    outOrdinal: var int32): bool =
    var matchCount: int32 = 0
    for i in 0..<graph.topLevelKinds.len:
        if graph.topLevelKinds[i] != "type":
            continue
        if i >= graph.ownerModules.len || graph.ownerModules[i] != modulePath:
            continue
        matchCount = matchCount +
            compilerCoreCountEnumMemberMatchesInTypeBlock(compilerCoreBodyLines(graph.bodyTexts[i]), memberName, outOrdinal)
        if matchCount > 1:
            return false
    return matchCount == 1

fn compilerCoreResolveImportEnumFieldOrdinal(graph: cgraph.HighUirCompilerCoreGraph,
                                             ownerModulePath: str,
                                             importName: str,
                                             fieldName: str,
                                             outOrdinal: var int32): bool =
    var targetModulePath: str = ""
    for i in 0..<graph.topLevelKinds.len:
        if graph.topLevelKinds[i] != "import":
            continue
        if i >= graph.ownerModules.len || graph.ownerModules[i] != ownerModulePath:
            continue
        if compilerCoreImportVisibleName(graph.importPaths[i], graph.importAliases[i]) == importName:
            if strings.len(targetModulePath) > 0:
                return false
            targetModulePath = graph.importTargetModulePaths[i]
    if strings.len(targetModulePath) <= 0:
        return false
    return compilerCoreResolveEnumMemberOrdinalInModulePath(graph, targetModulePath, fieldName, outOrdinal)

fn compilerCoreRoutineLabel(itemId: int32, suffix: str): str =
    return "item." + intToStr(itemId) + "." + suffix

fn compilerCoreCharLiteralValue(text: str): int32 =
    if strings.len(text) < 3 || text[0] != '\'' || text[strings.len(text) - 1] != '\'':
        system.panicStr("compiler_core_lowering: malformed char literal " + text)
    if strings.len(text) == 3:
        return int32(text[1])
    if strings.len(text) == 4 && text[1] == '\\':
        if text[2] == 'n':
            return 10
        if text[2] == 'r':
            return 13
        if text[2] == 't':
            return 9
        if text[2] == '0':
            return 0
        if text[2] == '\\':
            return int32('\\')
        if text[2] == '\'':
            return int32('\'')
    system.panicStr("compiler_core_lowering: unsupported char literal " + text)

fn compilerCoreIntLiteralValue(text: str): int32 =
    let trimmed = strutils.strip(text)
    if strings.len(trimmed) <= 0:
        system.panicStr("compiler_core_lowering: malformed int literal " + text)
    var base: int32 = 10
    var start: int32 = 0
    if strings.len(trimmed) >= 2 && trimmed[0] == '0':
        let marker = trimmed[1]
        if marker == 'x' || marker == 'X':
            base = 16
            start = 2
        elif marker == 'b' || marker == 'B':
            base = 2
            start = 2
        elif marker == 'o' || marker == 'O':
            base = 8
            start = 2
    if start > 0 && start >= strings.len(trimmed):
        system.panicStr("compiler_core_lowering: malformed int literal " + text)
    if !compilerCoreIntDigitsValid(trimmed, start, base):
        system.panicStr("compiler_core_lowering: malformed int literal " + text)
    var value: int64 = 0
    for i in start..<strings.len(trimmed):
        if trimmed[i] == '_':
            continue
        let digit = compilerCoreIntDigitValue(trimmed[i])
        if digit < 0 || digit >= base:
            system.panicStr("compiler_core_lowering: malformed int literal " + text)
        value = value * int64(base) + int64(digit)
        if value > int64(2147483647):
            system.panicStr("compiler_core_lowering: int literal out of int32 range " + text)
    return int32(value)

fn compilerCoreIntLiteralValueInt64(text: str): int64 =
    var value: int64 = 0
    if !compilerCoreParseInt64Text(text, value):
        system.panicStr("compiler_core_lowering: malformed int64 literal " + text)
    return value

fn compilerCoreLowerAddressExpr(graph: cgraph.HighUirCompilerCoreGraph,
                                itemIdx: int32,
                                itemId: int32,
                                ownerSourcePath: str,
                                exprId: int32,
                                out: var LowUirCompilerCorePlan) =
    if exprId < 0:
        system.panicStr("v2 low_uir compiler_core lowering: negative addr_of expr")
    let exprKind = graph.exprKinds[exprId]
    let exprPrimaryText = graph.exprPrimaryTexts[exprId]
    let exprReferenceKind = graph.exprReferenceKinds[exprId]
    let exprReferenceTargetKind = graph.exprReferenceTargetKinds[exprId]
    let exprReferenceText = graph.exprReferenceTexts[exprId]
    let exprReferenceItemId = graph.exprReferenceItemIds[exprId]
    let exprReferenceValueInt = graph.exprReferenceValueInts[exprId]
    let childIds = compilerCoreExprChildIds(graph, exprId)
    if exprKind == "name_ref":
        if exprReferenceKind == "param":
            appendLowUirCompilerCoreExecOp(out, "addr_of_param", exprPrimaryText, "", exprReferenceValueInt, exprId, -1)
            return
        if exprReferenceKind == "local":
            appendLowUirCompilerCoreExecOp(out, "addr_of_local", exprPrimaryText, "", exprReferenceValueInt, exprId, -1)
            return
        if exprReferenceKind == "global" || exprReferenceKind == "name":
            appendLowUirCompilerCoreExecOp(out,
                                           "addr_of_name",
                                           exprPrimaryText,
                                           exprReferenceTargetKind,
                                           exprReferenceItemId,
                                           exprId,
                                           -1)
            return
        system.panicStr("v2 low_uir compiler_core lowering: unsupported addr_of name_ref reference kind " + exprReferenceKind)
    if exprKind == "field" && childIds.len > 0:
        if exprReferenceKind == "import_field_global":
            appendLowUirCompilerCoreExecOp(out,
                                           "addr_of_name",
                                           exprReferenceText,
                                           exprReferenceTargetKind,
                                           exprReferenceItemId,
                                           exprId,
                                           childIds[0])
            return
        if exprReferenceKind != "field_access":
            system.panicStr("v2 low_uir compiler_core lowering: unsupported addr_of field reference kind " + exprReferenceKind)
        compilerCoreLowerAddressExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[0], out)
        appendLowUirCompilerCoreExecOp(out, "addr_of_field", exprPrimaryText, "", exprId, childIds[0], exprReferenceValueInt)
        return
    if exprKind == "index" && childIds.len == 2:
        compilerCoreLowerAddressExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[0], out)
        compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[1], out)
        appendLowUirCompilerCoreExecOp(out, "addr_of_index", "", "", exprId, childIds[0], childIds[1])
        return
    system.panicStr("v2 low_uir compiler_core lowering: unsupported addr_of child kind " + exprKind)

fn compilerCoreLowerExpr(graph: cgraph.HighUirCompilerCoreGraph,
                         itemIdx: int32,
                         itemId: int32,
                         ownerSourcePath: str,
                         exprId: int32,
                         out: var LowUirCompilerCorePlan) =
    if exprId < 0:
        return
    let exprKind = graph.exprKinds[exprId]
    let exprPrimaryText = graph.exprPrimaryTexts[exprId]
    let exprDetailText = graph.exprDetailTexts[exprId]
    let exprReferenceKind = graph.exprReferenceKinds[exprId]
    let exprReferenceTargetKind = graph.exprReferenceTargetKinds[exprId]
    let exprReferenceText = graph.exprReferenceTexts[exprId]
    let exprReferenceItemId = graph.exprReferenceItemIds[exprId]
    let exprReferenceValueInt = graph.exprReferenceValueInts[exprId]
    let childIds = compilerCoreExprChildIds(graph, exprId)
    if exprKind == "int_lit":
        var value32: int32 = 0
        if compilerCoreParseInt32Text(exprPrimaryText, value32):
            appendLowUirCompilerCoreExecOp(out,
                                           "load_int32",
                                           intToStr(value32),
                                           "",
                                           exprId,
                                           -1,
                                           -1)
        else:
            appendLowUirCompilerCoreExecOp(out,
                                           "load_int64",
                                           int64ToStr(compilerCoreIntLiteralValueInt64(exprPrimaryText)),
                                           "",
                                           exprId,
                                           -1,
                                           -1)
        return
    if exprKind == "float_lit":
        appendLowUirCompilerCoreExecOp(out, "load_float64", exprPrimaryText, "", exprId, -1, -1)
        return
    if exprKind == "bool_lit":
        appendLowUirCompilerCoreExecOp(out, "load_bool", exprPrimaryText, "", exprId, -1, -1)
        return
    if exprKind == "nil_lit":
        appendLowUirCompilerCoreExecOp(out, "load_nil", "", "", exprId, -1, -1)
        return
    if exprKind == "str_lit":
        appendLowUirCompilerCoreExecOp(out, "load_str", exprPrimaryText, "", exprId, -1, -1)
        return
    if exprKind == "char_lit":
        appendLowUirCompilerCoreExecOp(out,
                                       "load_int32",
                                       intToStr(compilerCoreCharLiteralValue(exprPrimaryText)),
                                       "",
                                       exprId,
                                       -1,
                                       -1)
        return
    if exprKind == "name_ref":
        if exprReferenceKind == "param":
            appendLowUirCompilerCoreExecOp(out, "load_param", exprPrimaryText, "", exprReferenceValueInt, exprId, -1)
            return
        if exprReferenceKind == "local":
            appendLowUirCompilerCoreExecOp(out, "load_local", exprPrimaryText, "", exprReferenceValueInt, exprId, -1)
            return
        if exprReferenceKind == "import_visible":
            appendLowUirCompilerCoreExecOp(out, "load_import", exprPrimaryText, "", exprReferenceItemId, exprId, -1)
            return
        if exprReferenceKind == "routine":
            appendLowUirCompilerCoreExecOp(out, "load_routine", exprPrimaryText, exprReferenceTargetKind, exprReferenceItemId, exprId, -1)
            return
        if exprReferenceKind == "global":
            appendLowUirCompilerCoreExecOp(out, "load_global", exprPrimaryText, exprReferenceTargetKind, exprReferenceItemId, exprId, -1)
            return
        if exprReferenceKind == "enum_member":
            appendLowUirCompilerCoreExecOp(out, "load_int32", intToStr(exprReferenceValueInt), "", exprId, -1, -1)
            return
        if exprReferenceKind == "name":
            appendLowUirCompilerCoreExecOp(out, "load_name", exprPrimaryText, exprReferenceTargetKind, exprReferenceItemId, exprId, -1)
            return
        system.panicStr("v2 low_uir compiler_core lowering: unsupported name_ref reference kind " + exprReferenceKind)
        return
    if exprKind == "field":
        if exprReferenceKind == "import_field_routine":
            appendLowUirCompilerCoreExecOp(out,
                                           "load_routine",
                                           exprReferenceText,
                                           exprReferenceTargetKind,
                                           exprReferenceItemId,
                                           exprId,
                                           childIds[0])
            return
        if exprReferenceKind == "import_field_global":
            appendLowUirCompilerCoreExecOp(out,
                                           "load_global",
                                           exprReferenceText,
                                           exprReferenceTargetKind,
                                           exprReferenceItemId,
                                           exprId,
                                           childIds[0])
            return
        if exprReferenceKind == "import_field_enum":
            appendLowUirCompilerCoreExecOp(out,
                                           "load_int32",
                                           intToStr(exprReferenceValueInt),
                                           "",
                                           exprId,
                                           -1,
                                           -1)
            return
        if exprReferenceKind == "field_access":
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[0], out)
            appendLowUirCompilerCoreExecOp(out, "load_field", exprPrimaryText, "", exprId, childIds[0], exprReferenceValueInt)
            return
        system.panicStr("v2 low_uir compiler_core lowering: unsupported field reference kind " + exprReferenceKind)
        return
    if exprKind == "index":
        compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[0], out)
        compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[1], out)
        appendLowUirCompilerCoreExecOp(out, "load_index", "", "", exprId, childIds[0], childIds[1])
        return
    if exprKind == "call":
        let callTargetKind = graph.exprCallTargetKinds[exprId]
        let callTargetText = graph.exprCallTargetTexts[exprId]
        let callTargetItemIdx = compilerCoreFindItemIndexById(graph, graph.exprCallTargetItemIds[exprId])
        if callTargetKind == "new_ref_ctor":
            appendLowUirCompilerCoreExecOp(out,
                                           "new_ref",
                                           callTargetText,
                                           "",
                                           exprId,
                                           childIds[1],
                                           -1)
            return
        if callTargetKind == "cast_int32" || callTargetKind == "cast_int64" ||
           callTargetKind == "scalar_ctor":
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[1], out)
            appendLowUirCompilerCoreExecOp(out,
                                           callTargetKind == "scalar_ctor" ? "cast_type" else: callTargetKind,
                                           callTargetText,
                                           "",
                                           exprId,
                                           childIds[1],
                                           -1)
            return
        if callTargetKind == "record_ctor":
            let childArgNames = compilerCoreExprChildArgNames(graph, exprId)
            var fieldNames: str[]
            fieldNames = []
            for i in 1..<childIds.len:
                let fieldName = childArgNames[i]
                if strings.len(fieldName) <= 0:
                    system.panicStr("v2 low_uir compiler_core lowering: unnamed type constructor arg " + callTargetText)
                compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[i], out)
                seqs.add(fieldNames, fieldName)
            appendLowUirCompilerCoreExecOp(out,
                                           "make_record",
                                           callTargetText,
                                           compilerCoreJoinWithSep(fieldNames, "\n"),
                                           childIds.len - 1,
                                           exprId,
                                           -1)
            return
        if callTargetKind == "overload_unresolved":
            system.panicStr("v2 low_uir compiler_core lowering: unresolved overload callee=" +
                  callTargetText +
                  " caller=" + graph.labels[itemIdx] +
                  " caller_source=" + ownerSourcePath +
                  " expr_id=" + intToStr(exprId))
        let loweredCalleeExprId = compilerCoreExplicitGenericRoutineBaseCalleeExprId(graph, exprId)
        compilerCoreLowerExpr(graph,
                              itemIdx,
                              itemId,
                              ownerSourcePath,
                              loweredCalleeExprId >= 0 ? loweredCalleeExprId else: childIds[0],
                              out)
        for i in 1..<childIds.len:
            if callTargetItemIdx >= 0 && i - 1 >= graph.paramCounts[callTargetItemIdx]:
                system.panicStr("v2 low_uir compiler_core lowering: call arg slot out of range callee=" +
                      callTargetText + " item_idx=" + intToStr(callTargetItemIdx) +
                      " caller=" + graph.labels[itemIdx] +
                      " caller_source=" + ownerSourcePath +
                      " expr_id=" + intToStr(exprId) +
                      " call_target_kind=" + callTargetKind +
                      " arg_slot=" + intToStr(i - 1) +
                      " param_count=" + intToStr(graph.paramCounts[callTargetItemIdx]))
            let paramKind = compilerCoreItemParamKind(graph, callTargetItemIdx, i - 1)
            if strings.len(paramKind) > 0 && paramKind != "value_param" && paramKind != "var_param":
                system.panicStr("v2 low_uir compiler_core lowering: unsupported param kind " + paramKind)
            if paramKind == "var_param":
                compilerCoreLowerVarArgExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[i], out)
            else:
                compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[i], out)
                appendLowUirCompilerCoreExecOp(out,
                                               "materialize",
                                               "",
                                               "",
                                               childIds[i],
                                               -1,
                                               -1)
        appendLowUirCompilerCoreExecOp(out, "call", "", "", childIds.len - 1, exprId, childIds.len)
        return
    if exprKind == "unary":
        if exprDetailText == "addr_of":
            compilerCoreLowerAddressExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[0], out)
            return
        compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[0], out)
        var opKind: str = ""
        if exprDetailText == "not":
            opKind = "unary_not"
        elif exprDetailText == "neg":
            opKind = "unary_neg"
        else:
            system.panicStr("v2 low_uir compiler_core lowering: unsupported unary detail " + exprDetailText)
        appendLowUirCompilerCoreExecOp(out, opKind, exprPrimaryText, exprDetailText, exprId, childIds[0], -1)
        return
    if exprKind == "binary":
        if exprDetailText == "logical_and":
            let falseLabel = compilerCoreRoutineLabel(itemId, "logical_and." + intToStr(exprId) + ".false")
            let endLabel = compilerCoreRoutineLabel(itemId, "logical_and." + intToStr(exprId) + ".end")
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[0], out)
            appendLowUirCompilerCoreExecOp(out, "jump_if_false", falseLabel, "", exprId, childIds[0], -1)
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[1], out)
            appendLowUirCompilerCoreExecOp(out, "jump_if_false", falseLabel, "", exprId, childIds[1], -1)
            appendLowUirCompilerCoreExecOp(out, "load_bool", "true", "", exprId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "jump", endLabel, "", exprId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "label", falseLabel, "", exprId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "load_bool", "false", "", exprId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "label", endLabel, "", exprId, -1, -1)
            return
        if exprDetailText == "logical_or":
            let rhsLabel = compilerCoreRoutineLabel(itemId, "logical_or." + intToStr(exprId) + ".rhs")
            let falseLabel = compilerCoreRoutineLabel(itemId, "logical_or." + intToStr(exprId) + ".false")
            let endLabel = compilerCoreRoutineLabel(itemId, "logical_or." + intToStr(exprId) + ".end")
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[0], out)
            appendLowUirCompilerCoreExecOp(out, "jump_if_false", rhsLabel, "", exprId, childIds[0], -1)
            appendLowUirCompilerCoreExecOp(out, "load_bool", "true", "", exprId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "jump", endLabel, "", exprId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "label", rhsLabel, "", exprId, -1, -1)
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[1], out)
            appendLowUirCompilerCoreExecOp(out, "jump_if_false", falseLabel, "", exprId, childIds[1], -1)
            appendLowUirCompilerCoreExecOp(out, "load_bool", "true", "", exprId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "jump", endLabel, "", exprId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "label", falseLabel, "", exprId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "load_bool", "false", "", exprId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "label", endLabel, "", exprId, -1, -1)
            return
        compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[0], out)
        compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[1], out)
        appendLowUirCompilerCoreExecOp(out, "binary_op", exprPrimaryText, exprDetailText, exprId, childIds[0], childIds[1])
        return
    if exprKind == "array_lit":
        for i in 0..<childIds.len:
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[i], out)
        appendLowUirCompilerCoreExecOp(out, "make_array", "", "", childIds.len, exprId, -1)
        return
    if exprKind == "tuple_lit":
        for i in 0..<childIds.len:
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[i], out)
        appendLowUirCompilerCoreExecOp(out, "make_tuple", "", "", childIds.len, exprId, -1)
        return
    if exprKind == "record_lit":
        let childArgNames = compilerCoreExprChildArgNames(graph, exprId)
        for i in 0..<childIds.len:
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[i], out)
        appendLowUirCompilerCoreExecOp(out,
                                       "make_record",
                                       exprPrimaryText,
                                       compilerCoreJoinWithSep(childArgNames, "\n"),
                                       childIds.len,
                                       exprId,
                                       -1)
        return
    if exprKind == "if_expr":
        let elseLabel = compilerCoreRoutineLabel(itemId, "if_expr." + intToStr(exprId) + ".else")
        let endLabel = compilerCoreRoutineLabel(itemId, "if_expr." + intToStr(exprId) + ".end")
        compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[0], out)
        appendLowUirCompilerCoreExecOp(out, "jump_if_false", elseLabel, "", exprId, childIds[0], -1)
        compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[1], out)
        appendLowUirCompilerCoreExecOp(out, "jump", endLabel, "", exprId, -1, -1)
        appendLowUirCompilerCoreExecOp(out, "label", elseLabel, "", exprId, -1, -1)
        compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, childIds[2], out)
        appendLowUirCompilerCoreExecOp(out, "label", endLabel, "", exprId, -1, -1)
        appendLowUirCompilerCoreExecOp(out, "phi_merge", "if_expr", "", exprId, 2, -1)
        return
    system.panicStr("v2 low_uir compiler_core lowering: unsupported executable expr kind " + exprKind)

fn compilerCoreLowerStmtIds(graph: cgraph.HighUirCompilerCoreGraph,
                            itemIdx: int32,
                            itemId: int32,
                            ownerSourcePath: str,
                            stmtIds: int32[],
                            finalExprStmtIsReturn: bool,
                            loopLabels: var LowUirLoopLabels,
                            out: var LowUirCompilerCorePlan) =
    for i in 0..<stmtIds.len:
        let stmtId = stmtIds[i]
        let stmtKind = graph.stmtKinds[stmtId]
        let stmtPrimaryText = graph.stmtPrimaryTexts[stmtId]
        let stmtDetailText = graph.stmtDetailTexts[stmtId]
        let stmtPrimaryExprId = graph.stmtPrimaryExprIds[stmtId]
        let stmtSecondaryExprId = graph.stmtSecondaryExprIds[stmtId]
        if stmtKind == "return":
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, stmtPrimaryExprId, out)
            let returnKind = stmtPrimaryExprId >= 0 ? "return_value" else: "return_void"
            appendLowUirCompilerCoreExecOp(out, returnKind, "", "", stmtId, stmtPrimaryExprId, -1)
            continue
        if stmtKind == "let" || stmtKind == "var":
            let localSlot = compilerCoreFindLocalSlot(graph, itemIdx, stmtPrimaryText)
            appendLowUirCompilerCoreExecOp(out, "local_decl", stmtPrimaryText, stmtKind, localSlot, stmtId, -1)
            if stmtPrimaryExprId >= 0:
                compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, stmtPrimaryExprId, out)
                appendLowUirCompilerCoreExecOp(out, "store_local", stmtPrimaryText, stmtKind, localSlot, stmtPrimaryExprId, -1)
            continue
        if stmtKind == "assign":
            let lhsExprKind = graph.exprKinds[stmtPrimaryExprId]
            let lhsTargetKind = graph.stmtAssignTargetKinds[stmtId]
            let lhsTargetText = graph.stmtAssignTargetTexts[stmtId]
            let lhsTargetOwnerText = graph.stmtAssignTargetOwnerTexts[stmtId]
            let lhsTargetValueInt = graph.stmtAssignTargetValueInts[stmtId]
            let lhsTargetFieldOrdinal = graph.stmtAssignTargetFieldOrdinals[stmtId]
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, stmtSecondaryExprId, out)
            if lhsTargetKind == "local":
                appendLowUirCompilerCoreExecOp(out, "store_local", lhsTargetText, "", lhsTargetValueInt, stmtSecondaryExprId, -1)
                continue
            if lhsTargetKind == "param":
                appendLowUirCompilerCoreExecOp(out, "store_param", lhsTargetText, "", lhsTargetValueInt, stmtSecondaryExprId, -1)
                continue
            if lhsTargetKind == "name":
                appendLowUirCompilerCoreExecOp(out, "store_name", lhsTargetText, "", stmtPrimaryExprId, stmtSecondaryExprId, -1)
                continue
            let lhsChildIds = compilerCoreExprChildIds(graph, stmtPrimaryExprId)
            if lhsTargetKind == "local_field":
                appendLowUirCompilerCoreExecOp(out,
                                               "store_local_field",
                                               lhsTargetText,
                                               lhsTargetOwnerText,
                                               lhsTargetValueInt,
                                               lhsTargetFieldOrdinal,
                                               lhsChildIds[0])
                continue
            if lhsTargetKind == "param_field":
                appendLowUirCompilerCoreExecOp(out,
                                               "store_param_field",
                                               lhsTargetText,
                                               lhsTargetOwnerText,
                                               lhsTargetValueInt,
                                               lhsTargetFieldOrdinal,
                                               lhsChildIds[0])
                continue
            if lhsTargetKind == "field":
                let baseExprId = lhsChildIds[0]
                compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, baseExprId, out)
                appendLowUirCompilerCoreExecOp(out,
                                               "store_field",
                                               lhsTargetText,
                                               "",
                                               stmtPrimaryExprId,
                                               stmtSecondaryExprId,
                                               lhsTargetFieldOrdinal)
                continue
            if lhsTargetKind == "index":
                compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, lhsChildIds[0], out)
                compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, lhsChildIds[1], out)
                appendLowUirCompilerCoreExecOp(out, "store_index", "", "", stmtPrimaryExprId, stmtSecondaryExprId, lhsChildIds[1])
                continue
            system.panicStr("v2 low_uir compiler_core lowering: unsupported assignment lhs target " + lhsTargetKind + " expr " + lhsExprKind)
        if stmtKind == "expr_stmt":
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, stmtPrimaryExprId, out)
            let finalExprKind = finalExprStmtIsReturn && i == stmtIds.len - 1 ? "return_value" else: "drop_value"
            appendLowUirCompilerCoreExecOp(out, finalExprKind, "", "", stmtId, stmtPrimaryExprId, -1)
            continue
        if stmtKind == "break":
            if loopLabels.breakLabels.len <= 0:
                system.panicStr("v2 low_uir compiler_core lowering: break outside loop")
            appendLowUirCompilerCoreExecOp(out,
                                           "jump",
                                           loopLabels.breakLabels[loopLabels.breakLabels.len - 1],
                                           "",
                                           stmtId,
                                           -1,
                                           -1)
            continue
        if stmtKind == "continue":
            if loopLabels.continueLabels.len <= 0:
                system.panicStr("v2 low_uir compiler_core lowering: continue outside loop")
            appendLowUirCompilerCoreExecOp(out,
                                           "jump",
                                           loopLabels.continueLabels[loopLabels.continueLabels.len - 1],
                                           "",
                                           stmtId,
                                           -1,
                                           -1)
            continue
        if stmtKind == "if":
            let elseLabel = compilerCoreRoutineLabel(itemId, "if." + intToStr(stmtId) + ".else")
            let endLabel = compilerCoreRoutineLabel(itemId, "if." + intToStr(stmtId) + ".end")
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, stmtPrimaryExprId, out)
            appendLowUirCompilerCoreExecOp(out, "jump_if_false", elseLabel, "", stmtId, stmtPrimaryExprId, -1)
            compilerCoreLowerStmtIds(graph, itemIdx, itemId, ownerSourcePath, compilerCoreStmtChildIds(graph, stmtId), false, loopLabels, out)
            if graph.stmtElseChildCounts[stmtId] > 0:
                appendLowUirCompilerCoreExecOp(out, "jump", endLabel, "", stmtId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "label", elseLabel, "", stmtId, -1, -1)
            if graph.stmtElseChildCounts[stmtId] > 0:
                compilerCoreLowerStmtIds(graph, itemIdx, itemId, ownerSourcePath, compilerCoreStmtElseChildIds(graph, stmtId), false, loopLabels, out)
                appendLowUirCompilerCoreExecOp(out, "label", endLabel, "", stmtId, -1, -1)
            continue
        if stmtKind == "while":
            let headLabel = compilerCoreRoutineLabel(itemId, "while." + intToStr(stmtId) + ".head")
            let endLabel = compilerCoreRoutineLabel(itemId, "while." + intToStr(stmtId) + ".end")
            seqs.add(loopLabels.continueLabels, headLabel)
            seqs.add(loopLabels.breakLabels, endLabel)
            appendLowUirCompilerCoreExecOp(out, "label", headLabel, "", stmtId, -1, -1)
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, stmtPrimaryExprId, out)
            appendLowUirCompilerCoreExecOp(out, "jump_if_false", endLabel, "", stmtId, stmtPrimaryExprId, -1)
            compilerCoreLowerStmtIds(graph, itemIdx, itemId, ownerSourcePath, compilerCoreStmtChildIds(graph, stmtId), false, loopLabels, out)
            appendLowUirCompilerCoreExecOp(out, "jump", headLabel, "", stmtId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "label", endLabel, "", stmtId, -1, -1)
            seqs.setLen(loopLabels.continueLabels, loopLabels.continueLabels.len - 1)
            seqs.setLen(loopLabels.breakLabels, loopLabels.breakLabels.len - 1)
            continue
        if stmtKind == "for_range":
            let iterName = stmtPrimaryText
            let rangeKind = stmtDetailText
            let headLabel = compilerCoreRoutineLabel(itemId, "for_range." + intToStr(stmtId) + ".head")
            let stepLabel = compilerCoreRoutineLabel(itemId, "for_range." + intToStr(stmtId) + ".step")
            let endLabel = compilerCoreRoutineLabel(itemId, "for_range." + intToStr(stmtId) + ".end")
            seqs.add(loopLabels.continueLabels, stepLabel)
            seqs.add(loopLabels.breakLabels, endLabel)
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, stmtPrimaryExprId, out)
            compilerCoreLowerExpr(graph, itemIdx, itemId, ownerSourcePath, stmtSecondaryExprId, out)
            appendLowUirCompilerCoreExecOp(out, "for_range_init", iterName, rangeKind, stmtId, stmtPrimaryExprId, stmtSecondaryExprId)
            appendLowUirCompilerCoreExecOp(out, "label", headLabel, "", stmtId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "for_range_check", iterName, rangeKind, stmtId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "jump_if_false", endLabel, "", stmtId, -1, -1)
            compilerCoreLowerStmtIds(graph, itemIdx, itemId, ownerSourcePath, compilerCoreStmtChildIds(graph, stmtId), false, loopLabels, out)
            appendLowUirCompilerCoreExecOp(out, "label", stepLabel, "", stmtId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "for_range_step", iterName, rangeKind, stmtId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "jump", headLabel, "", stmtId, -1, -1)
            appendLowUirCompilerCoreExecOp(out, "label", endLabel, "", stmtId, -1, -1)
            seqs.setLen(loopLabels.continueLabels, loopLabels.continueLabels.len - 1)
            seqs.setLen(loopLabels.breakLabels, loopLabels.breakLabels.len - 1)
            continue
        system.panicStr("v2 low_uir compiler_core lowering: unsupported executable stmt kind " + stmtKind)

fn compilerCoreRoutineOpHash(plan: LowUirCompilerCorePlan,
                             startIdx: int32,
                             opCount: int32): str =
    var lines: str[]
    lines = []
    for i in 0..<opCount:
        let idx = startIdx + i
        seqs.add(lines, plan.opKinds[idx] + "|" +
                   plan.opPrimaryTexts[idx] + "|" +
                   plan.opSecondaryTexts[idx] + "|" +
                   intToStr(plan.opArg0s[idx]) + "|" +
                   intToStr(plan.opArg1s[idx]) + "|" +
                   intToStr(plan.opArg2s[idx]))
    return ident.sha256HexText(manifest.joinLines(lines))

fn lowerHighUirCompilerCoreGraphToLowUir(graph: cgraph.HighUirCompilerCoreGraph): LowUirCompilerCorePlan =
    var out: LowUirCompilerCorePlan = newLowUirCompilerCorePlan()
    var loopLabels: LowUirLoopLabels
    loopLabels.continueLabels = []
    loopLabels.breakLabels = []
    let contract = cops.lowUirCompilerCoreOpsContract()
    for i in 0..<graph.itemIds.len:
        let opIdx = cops.findLowUirCompilerCoreOp(graph.opNames[i])
        if opIdx < 0:
            system.panicStr("v2 low_uir compiler_core lowering: missing canonical op for " + graph.opNames[i])
        let op = contract.canonicalOps[opIdx]
        let routineOpStart = out.opKinds.len
        seqs.add(out.itemIds, graph.itemIds[i])
        seqs.add(out.canonicalOps, op.opName)
        seqs.add(out.runtimeTargets, op.runtimeTarget)
        seqs.add(out.proofDomains, op.proofDomain)
        seqs.add(out.effectClasses, op.effectClass)
        seqs.add(out.bindingScopes, op.bindingScope)
        seqs.add(out.topLevelKinds, graph.topLevelKinds[i])
        seqs.add(out.labels, graph.labels[i])
        seqs.add(out.ownerModules, graph.ownerModules[i])
        seqs.add(out.sourcePaths, graph.sourcePaths[i])
        seqs.add(out.importcSymbolTexts, graph.importcSymbolTexts[i])
        seqs.add(out.importPaths, graph.importPaths[i])
        seqs.add(out.importTargetModulePaths, graph.importTargetModulePaths[i])
        seqs.add(out.importAliases, graph.importAliases[i])
        seqs.add(out.importCategories, graph.importCategories[i])
        seqs.add(out.signatureTexts, graph.signatureTexts[i])
        seqs.add(out.signatureHashes, graph.signatureHashes[i])
        seqs.add(out.bodyTexts, graph.bodyTexts[i])
        seqs.add(out.bodyLineCounts, graph.bodyLineCounts[i])
        seqs.add(out.bodyHashes, graph.bodyHashes[i])
        seqs.add(out.executableAstReady, graph.executableAstReady[i])
        seqs.add(out.returnTypeTexts, graph.returnTypeTexts[i])
        seqs.add(out.paramCounts, graph.paramCounts[i])
        seqs.add(out.itemParamStarts, out.paramKinds.len)
        for paramOffset in 0..<graph.paramCounts[i]:
            seqs.add(out.paramKinds,
                     graph.paramKinds[graph.itemParamStarts[i] + paramOffset])
        seqs.add(out.localCounts, graph.localCounts[i])
        seqs.add(out.itemLocalStarts, out.localTypeTexts.len)
        for localOffset in 0..<graph.localCounts[i]:
            seqs.add(out.localTypeTexts,
                     graph.localTypeTexts[graph.itemLocalStarts[i] + localOffset])
        seqs.add(out.stmtCounts, graph.stmtCounts[i])
        seqs.add(out.exprCounts, graph.exprCounts[i])
        seqs.add(out.stmtKindSets, graph.stmtKindSets[i])
        seqs.add(out.exprKindSets, graph.exprKindSets[i])
        seqs.add(out.stmtSemanticSets, graph.stmtSemanticSets[i])
        seqs.add(out.exprSemanticSets, graph.exprSemanticSets[i])
        for exprOffset in 0..<graph.exprCounts[i]:
            let exprId = graph.itemExprStarts[i] + exprOffset
            seqs.add(out.exprReferenceKinds, graph.exprReferenceKinds[exprId])
            seqs.add(out.exprReferenceTargetKinds, graph.exprReferenceTargetKinds[exprId])
            seqs.add(out.exprReferenceTexts, graph.exprReferenceTexts[exprId])
            seqs.add(out.exprReferenceItemIds, graph.exprReferenceItemIds[exprId])
            seqs.add(out.exprReferenceValueInts, graph.exprReferenceValueInts[exprId])
        seqs.add(out.routineOpStarts, routineOpStart)
        if graph.topLevelKinds[i] == "fn" ||
           graph.topLevelKinds[i] == "iterator" ||
           graph.topLevelKinds[i] == "importc_fn" ||
           graph.topLevelKinds[i] == "const" ||
           graph.topLevelKinds[i] == "var":
            if graph.executableAstReady[i]:
                let stmtIds = compilerCoreRootStmtIds(graph, i)
                compilerCoreLowerStmtIds(graph,
                                         i,
                                         graph.itemIds[i],
                                         graph.sourcePaths[i],
                                         stmtIds,
                                         compilerCoreRoutineSignatureEndsWithAssign(graph.signatureTexts[i]),
                                         loopLabels,
                                         out)
            seqs.add(out.routineOpCounts, out.opKinds.len - routineOpStart)
            seqs.add(out.routineOpHashes, compilerCoreRoutineOpHash(out, routineOpStart, out.opKinds.len - routineOpStart))
        else:
            seqs.add(out.routineOpCounts, 0)
            seqs.add(out.routineOpHashes, ident.sha256HexText(""))
    if out.exprReferenceKinds.len != graph.exprKinds.len:
        system.panicStr("v2 low_uir compiler_core lowering: expr reference kind count mismatch")
    return out
