import std/seqs

type
    LowUirNetworkDistributionOp =
        opName: str
        runtimeTarget: str
        proofDomain: str
        identityScope: str
    LowUirNetworkDistributionOpsContract =
        version: str
        canonicalOps: LowUirNetworkDistributionOp[]
        fixedPriorityMappings: str[]

fn lowUirNetworkDistributionOp(opName: str,
                               runtimeTarget: str,
                               proofDomain: str,
                               identityScope: str): LowUirNetworkDistributionOp =
    var out: LowUirNetworkDistributionOp
    out.opName = opName
    out.runtimeTarget = runtimeTarget
    out.proofDomain = proofDomain
    out.identityScope = identityScope
    return out

fn lowUirNetworkDistributionOpsContract(): LowUirNetworkDistributionOpsContract =
    var out: LowUirNetworkDistributionOpsContract
    out.version = "v2.low_uir.network_distribution_ops.v1"
    out.canonicalOps = []
    add(out.canonicalOps, lowUirNetworkDistributionOp("publish_source_manifest",
                                                      "runtime/network_distribution_v2.publish_source_manifest",
                                                      "content_identity_publication",
                                                      "source_manifest"))
    add(out.canonicalOps, lowUirNetworkDistributionOp("publish_rule_pack",
                                                      "runtime/network_distribution_v2.publish_rule_pack",
                                                      "rule_pack_publication",
                                                      "rule_pack"))
    add(out.canonicalOps, lowUirNetworkDistributionOp("publish_compiler_rule_pack",
                                                      "runtime/network_distribution_v2.publish_compiler_rule_pack",
                                                      "compiler_rule_pack_publication",
                                                      "compiler_rule_pack"))
    add(out.canonicalOps, lowUirNetworkDistributionOp("route_lsmr_tree",
                                                      "runtime/network_distribution_v2.route_lsmr_tree",
                                                      "topology_routing",
                                                      "topology_control"))
    add(out.canonicalOps, lowUirNetworkDistributionOp("disperse_ida_fragments",
                                                      "runtime/network_distribution_v2.disperse_ida_fragments",
                                                      "coded_bulk_dispersal",
                                                      "fragment_set"))
    add(out.canonicalOps, lowUirNetworkDistributionOp("exchange_anti_entropy_signature",
                                                      "runtime/network_distribution_v2.exchange_anti_entropy_signature",
                                                      "anti_entropy_signature",
                                                      "anti_entropy_signature"))
    add(out.canonicalOps, lowUirNetworkDistributionOp("repair_from_signature_gap",
                                                      "runtime/network_distribution_v2.repair_from_signature_gap",
                                                      "signature_gap_repair",
                                                      "anti_entropy_repair"))
    out.fixedPriorityMappings = []
    add(out.fixedPriorityMappings, "urgent=deterministic_tree_push")
    add(out.fixedPriorityMappings, "bulk=coded_bulk_dispersal")
    add(out.fixedPriorityMappings, "background=passive_anti_entropy")
    return out

fn findLowUirNetworkDistributionOp(opName: str): int32 =
    let c = lowUirNetworkDistributionOpsContract()
    for i in 0..<c.canonicalOps.len:
        if c.canonicalOps[i].opName == opName:
            return i
    return -1
