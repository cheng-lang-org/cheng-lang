import compiler/bagua/bagua_core_v2 as bcore

type
    LowerRule =
        family: str
        preserveCfg: bool
        requiresProof: bool
        emitsSideEffect: bool
        canVectorize: bool
    PassHint =
        group: str
        cfgProof: bool
        layoutSroa: bool
        sideEffectOrdering: bool
        loopVectorWorklist: bool

fn lowerFamilyForUpper(upper: str): str =
    if upper == "乾":
        return "声明布局"
    if upper == "坤":
        return "物化"
    if upper == "坎":
        return "CFG/proof"
    if upper == "离":
        return "调用读投影"
    if upper == "艮":
        return "结束封口"
    if upper == "兑":
        return "边界交换"
    if upper == "震":
        return "写入触发"
    return "循环传播"

fn lowerRuleForAnnotation(annotation: bcore.BaguaAnnotation): LowerRule =
    var out: LowerRule
    out.family = lowerFamilyForUpper(annotation.upper)
    out.preserveCfg = annotation.upper == "坎" || annotation.upper == "巽"
    out.requiresProof = annotation.upper == "坎" || annotation.lower == "坎"
    out.emitsSideEffect = annotation.upper == "震" ||
                          annotation.upper == "兑" ||
                          annotation.upper == "艮" ||
                          annotation.lower == "震" ||
                          annotation.lower == "兑" ||
                          annotation.lower == "艮"
    out.canVectorize = annotation.upper == "巽" || annotation.lower == "巽"
    return out

fn passHintGroupForUpper(upper: str): str =
    if upper == "坎":
        return "cfg_proof"
    if upper == "坤":
        return "layout_sroa"
    if upper == "震":
        return "side_effect_ordering"
    if upper == "巽":
        return "loop_vector_worklist"
    return "none"

fn passHintForAnnotation(annotation: bcore.BaguaAnnotation): PassHint =
    var out: PassHint
    out.group = passHintGroupForUpper(annotation.upper)
    out.cfgProof = annotation.upper == "坎"
    out.layoutSroa = annotation.upper == "坤"
    out.sideEffectOrdering = annotation.upper == "震"
    out.loopVectorWorklist = annotation.upper == "巽"
    return out

fn annotationLowerFamilies(annotations: bcore.BaguaAnnotation[]): str[] =
    var out: str[]
    out = []
    for i in 0..<annotations.len:
        add(out, lowerRuleForAnnotation(annotations[i]).family)
    return out

fn annotationPreserveCfgFlags(annotations: bcore.BaguaAnnotation[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<annotations.len:
        add(out, lowerRuleForAnnotation(annotations[i]).preserveCfg)
    return out

fn annotationRequiresProofFlags(annotations: bcore.BaguaAnnotation[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<annotations.len:
        add(out, lowerRuleForAnnotation(annotations[i]).requiresProof)
    return out

fn annotationEmitsSideEffectFlags(annotations: bcore.BaguaAnnotation[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<annotations.len:
        add(out, lowerRuleForAnnotation(annotations[i]).emitsSideEffect)
    return out

fn annotationCanVectorizeFlags(annotations: bcore.BaguaAnnotation[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<annotations.len:
        add(out, lowerRuleForAnnotation(annotations[i]).canVectorize)
    return out

fn annotationPassHintGroups(annotations: bcore.BaguaAnnotation[]): str[] =
    var out: str[]
    out = []
    for i in 0..<annotations.len:
        add(out, passHintForAnnotation(annotations[i]).group)
    return out

fn annotationPassHintCfgProofFlags(annotations: bcore.BaguaAnnotation[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<annotations.len:
        add(out, passHintForAnnotation(annotations[i]).cfgProof)
    return out

fn annotationPassHintLayoutSroaFlags(annotations: bcore.BaguaAnnotation[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<annotations.len:
        add(out, passHintForAnnotation(annotations[i]).layoutSroa)
    return out

fn annotationPassHintSideEffectOrderingFlags(annotations: bcore.BaguaAnnotation[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<annotations.len:
        add(out, passHintForAnnotation(annotations[i]).sideEffectOrdering)
    return out

fn annotationPassHintLoopVectorWorklistFlags(annotations: bcore.BaguaAnnotation[]): bool[] =
    var out: bool[]
    out = []
    for i in 0..<annotations.len:
        add(out, passHintForAnnotation(annotations[i]).loopVectorWorklist)
    return out
