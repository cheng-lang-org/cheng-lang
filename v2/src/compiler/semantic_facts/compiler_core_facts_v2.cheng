fn compilerCoreFindText(text: str, pattern: str): int32 =
    if strings.len(pattern) <= 0:
        return 0
    if strings.len(pattern) > strings.len(text):
        return -1
    for i in 0..(strings.len(text) - strings.len(pattern)):
        if strings.sliceBytes(text, i, strings.len(pattern)) == pattern:
            return i
    return -1

fn compilerCoreImportcSymbolText(signatureText: str, label: str): str =
    let marker = "@importc(\""
    let markerIdx = compilerCoreFindText(signatureText, marker)
    if markerIdx < 0:
        return label
    let startIdx = markerIdx + strings.len(marker)
    for i in startIdx..<strings.len(signatureText):
        if signatureText[i] == '"':
            return strings.sliceBytes(signatureText, startIdx, i - startIdx)
    return label

fn joinWithSep(values: str[], sep: str): str =
    var out: str = ""
    for i in 0..<values.len:
        if i > 0:
            out = out + sep
        out = out + values[i]
    return out

fn compilerCoreBodyHash(bodyLines: str[]): str =
    return ident.sha256HexText(joinWithSep(bodyLines, "\n"))

fn compilerCoreCanonicalKindSet(values: str[]): str =
    var kinds: str[]
    kinds = []
    for i in 0..<values.len:
        ident.appendUnique(kinds, values[i])
    algorithm.sort(kinds)
    return joinWithSep(kinds, "|")

fn compilerCoreRoutineStmtKindSet(program: ccore.CompilerCoreProgram,
                                  decl: ccore.CompilerCoreRoutineDecl): str =
    var kinds: str[]
    kinds = []
    for i in 0..<decl.stmtCount:
        ident.appendUnique(kinds, program.stmts[decl.stmtStart + i].kind)
    return compilerCoreCanonicalKindSet(kinds)

fn compilerCoreRoutineExprKindSet(program: ccore.CompilerCoreProgram,
                                  decl: ccore.CompilerCoreRoutineDecl): str =
    var kinds: str[]
    kinds = []
    for i in 0..<decl.exprCount:
        ident.appendUnique(kinds, program.exprs[decl.exprStart + i].kind)
    return compilerCoreCanonicalKindSet(kinds)

fn compilerCoreFindParamSlot(program: ccore.CompilerCoreProgram,
                             decl: ccore.CompilerCoreRoutineDecl,
                             name: str): int32 =
    for i in 0..<decl.paramCount:
        if program.routineParams[decl.paramStart + i].name == name:
            return i
    return -1

fn compilerCoreFindLocalSlot(program: ccore.CompilerCoreProgram,
                             decl: ccore.CompilerCoreRoutineDecl,
                             name: str): int32 =
    for i in 0..<decl.localCount:
        if program.locals[decl.localStart + i].name == name:
            return i
    return -1

fn compilerCoreFindTopLevelKind(program: ccore.CompilerCoreProgram, label: str): str =
    for i in 0..<program.topLevelLabels.len:
        if program.topLevelLabels[i] == label:
            return program.topLevelKinds[i]
    return ""

fn compilerCoreFindTopLevelItemId(program: ccore.CompilerCoreProgram, label: str): int32 =
    for i in 0..<program.topLevelLabels.len:
        if program.topLevelLabels[i] == label:
            return i
    return -1

fn compilerCoreLineIndentWidth(rawLine: str): int32 =
    var indent: int32 = 0
    while indent < strings.len(rawLine) && (rawLine[indent] == ' ' || rawLine[indent] == '\t'):
        indent = indent + 1
    return indent

fn compilerCoreLeadingNameToken(text: str): str =
    var endIdx: int32 = 0
    while endIdx < strings.len(text):
        let ch = text[endIdx]
        if (ch >= 'a' && ch <= 'z') ||
           (ch >= 'A' && ch <= 'Z') ||
           (ch >= '0' && ch <= '9') ||
           ch == '_':
            endIdx = endIdx + 1
            continue
        break
    return strings.sliceBytes(text, 0, endIdx)

fn compilerCoreTypeDeclNameFromLine(rawLine: str): str =
    let line = compilerCoreTrimInlineComment(rawLine)
    if strings.len(line) <= 0:
        return ""
    let eqIdx = strings.find(line, "=")
    if eqIdx < 0:
        return ""
    let head = strutils.strip(strings.sliceBytes(line, 0, eqIdx))
    if strings.len(head) <= 0:
        return ""
    return compilerCoreLeadingNameToken(head)

fn compilerCoreTypeBlockDeclaresName(bodyLines: str[], typeName: str): bool =
    if strings.len(typeName) <= 0:
        return false
    var baseIndent: int32 = -1
    for i in 0..<bodyLines.len:
        let line = compilerCoreTrimInlineComment(bodyLines[i])
        if strings.len(line) <= 0:
            continue
        let indent = compilerCoreLineIndentWidth(bodyLines[i])
        if baseIndent < 0 || indent < baseIndent:
            baseIndent = indent
    if baseIndent < 0:
        return false
    var matchCount: int32 = 0
    for i in 0..<bodyLines.len:
        let line = compilerCoreTrimInlineComment(bodyLines[i])
        if strings.len(line) <= 0:
            continue
        if compilerCoreLineIndentWidth(bodyLines[i]) != baseIndent:
            continue
        if compilerCoreTypeDeclNameFromLine(bodyLines[i]) == typeName:
            matchCount = matchCount + 1
            if matchCount > 1:
                return false
        endif
    return matchCount == 1

fn compilerCoreTypeFieldTypeFromLine(rawLine: str, fieldName: str): str =
    let line = compilerCoreTrimInlineComment(rawLine)
    if strings.len(line) <= 0:
        return ""
    let colonIdx = strings.find(line, ":")
    if colonIdx <= 0:
        return ""
    let nameText = compilerCoreLeadingNameToken(strutils.strip(strings.sliceBytes(line, 0, colonIdx)))
    if nameText != fieldName:
        return ""
    var typeText = strutils.strip(strings.sliceBytes(line, colonIdx + 1, strings.len(line) - colonIdx - 1))
    let eqIdx = strings.find(typeText, "=")
    if eqIdx >= 0:
        typeText = strutils.strip(strings.sliceBytes(typeText, 0, eqIdx))
    return typeText

fn compilerCoreTypeFieldNameFromLine(rawLine: str): str =
    let line = compilerCoreTrimInlineComment(rawLine)
    if strings.len(line) <= 0:
        return ""
    let colonIdx = strings.find(line, ":")
    if colonIdx <= 0:
        return ""
    return compilerCoreLeadingNameToken(strutils.strip(strings.sliceBytes(line, 0, colonIdx)))

fn compilerCoreTypeAliasTargetFromLine(rawLine: str, typeName: str): str =
    if compilerCoreTypeDeclNameFromLine(rawLine) != typeName:
        return ""
    let line = compilerCoreTrimInlineComment(rawLine)
    if strings.len(line) <= 0:
        return ""
    let eqIdx = strings.find(line, "=")
    if eqIdx < 0:
        return ""
    return strutils.strip(strings.sliceBytes(line, eqIdx + 1, strings.len(line) - eqIdx - 1))

fn compilerCoreTransparentAliasTargetText(aliasTarget: str): str =
    let text = strutils.strip(aliasTarget)
    if strings.len(text) <= 0:
        return ""
    if text == "object" || text == "enum" || text == "tuple" || text == "distinct":
        return ""
    if strings.startsWith(text, "object ") ||
       strings.startsWith(text, "enum ") ||
       strings.startsWith(text, "tuple ") ||
       strings.startsWith(text, "distinct ") ||
       strings.startsWith(text, "ref object") ||
       strings.startsWith(text, "ptr object"):
        return ""
    return text

fn compilerCoreTypeBlockFieldType(bodyLines: str[],
                                  typeName: str,
                                  fieldName: str): str =
    if strings.len(typeName) <= 0 || strings.len(fieldName) <= 0:
        return ""
    var baseIndent: int32 = -1
    for i in 0..<bodyLines.len:
        let line = compilerCoreTrimInlineComment(bodyLines[i])
        if strings.len(line) <= 0:
            continue
        let indent = compilerCoreLineIndentWidth(bodyLines[i])
        if baseIndent < 0 || indent < baseIndent:
            baseIndent = indent
    if baseIndent < 0:
        return ""
    var insideType: bool = false
    var matchedType: str = ""
    for i in 0..<bodyLines.len:
        let rawLine = bodyLines[i]
        let line = compilerCoreTrimInlineComment(rawLine)
        if strings.len(line) <= 0:
            continue
        let indent = compilerCoreLineIndentWidth(rawLine)
        if indent == baseIndent:
            let declName = compilerCoreTypeDeclNameFromLine(rawLine)
            if insideType:
                if strings.len(declName) > 0:
                    return matchedType
            elif declName == typeName:
                insideType = true
            continue
        if !insideType || indent <= baseIndent:
            continue
        let fieldType = compilerCoreTypeFieldTypeFromLine(rawLine, fieldName)
        if strings.len(fieldType) <= 0:
            continue
        if strings.len(matchedType) > 0:
            return ""
        matchedType = fieldType
    return matchedType

fn compilerCoreTypeBlockFieldOrdinal(bodyLines: str[],
                                     typeName: str,
                                     fieldName: str): int32 =
    if strings.len(typeName) <= 0 || strings.len(fieldName) <= 0:
        return -1
    var baseIndent: int32 = -1
    for i in 0..<bodyLines.len:
        let line = compilerCoreTrimInlineComment(bodyLines[i])
        if strings.len(line) <= 0:
            continue
        let indent = compilerCoreLineIndentWidth(bodyLines[i])
        if baseIndent < 0 || indent < baseIndent:
            baseIndent = indent
    if baseIndent < 0:
        return -1
    var insideType: bool = false
    var matchedOrdinal: int32 = -1
    var currentOrdinal: int32 = 0
    for i in 0..<bodyLines.len:
        let rawLine = bodyLines[i]
        let line = compilerCoreTrimInlineComment(rawLine)
        if strings.len(line) <= 0:
            continue
        let indent = compilerCoreLineIndentWidth(rawLine)
        if indent == baseIndent:
            let declName = compilerCoreTypeDeclNameFromLine(rawLine)
            if insideType:
                if strings.len(declName) > 0:
                    return matchedOrdinal
            elif declName == typeName:
                insideType = true
                currentOrdinal = 0
            continue
        if !insideType || indent <= baseIndent:
            continue
        let currentFieldName = compilerCoreTypeFieldNameFromLine(rawLine)
        if strings.len(currentFieldName) <= 0:
            continue
        if currentFieldName == fieldName:
            if matchedOrdinal >= 0:
                return -1
            matchedOrdinal = currentOrdinal
        currentOrdinal = currentOrdinal + 1
    return matchedOrdinal

fn compilerCoreTypeBlockAliasText(bodyLines: str[], typeName: str): str =
    if strings.len(typeName) <= 0:
        return ""
    var baseIndent: int32 = -1
    for i in 0..<bodyLines.len:
        let line = compilerCoreTrimInlineComment(bodyLines[i])
        if strings.len(line) <= 0:
            continue
        let indent = compilerCoreLineIndentWidth(bodyLines[i])
        if baseIndent < 0 || indent < baseIndent:
            baseIndent = indent
    if baseIndent < 0:
        return ""
    var matchedType: str = ""
    for i in 0..<bodyLines.len:
        let line = compilerCoreTrimInlineComment(bodyLines[i])
        if strings.len(line) <= 0 || compilerCoreLineIndentWidth(bodyLines[i]) != baseIndent:
            continue
        let aliasType = compilerCoreTypeAliasTargetFromLine(bodyLines[i], typeName)
        if strings.len(aliasType) <= 0:
            continue
        if strings.len(matchedType) > 0:
            return ""
        matchedType = aliasType
    return matchedType

fn compilerCoreNormalizeImportModulePath(modulePath: str): str =
    if strutils.startsWith(modulePath, "cheng/") && strings.len(modulePath) > strings.len("cheng/"):
        return strings.sliceBytes(modulePath, strings.len("cheng/"), strings.len(modulePath) - strings.len("cheng/"))
    return modulePath

fn compilerCoreTopLevelModulePath(program: ccore.CompilerCoreProgram,
                                  itemId: int32): str =
    if itemId >= 0 && itemId < program.topLevelOwnerModules.len &&
       strings.len(program.topLevelOwnerModules[itemId]) > 0:
        return program.topLevelOwnerModules[itemId]
    compilerCoreFactsPanic("v2 semantic facts compiler_core: missing top-level owner module at item " + intToStr(itemId))
    return ""

fn compilerCoreFindModulePathSlotInArray(modulePaths: str[], modulePath: str): int32 =
    for i in 0..<modulePaths.len:
        if modulePaths[i] == modulePath:
            return i
    return -1

fn compilerCoreCompareNamedPair(leftOwner: str,
                                leftName: str,
                                rightOwner: str,
                                rightName: str): int32 =
    let ownerCmp = cmp(leftOwner, rightOwner)
    if ownerCmp != 0:
        return ownerCmp
    return cmp(leftName, rightName)

fn compilerCoreSortModulePathLookup(paths: var str[], ids: var int32[]) =
    var i: int32 = 1
    while i < paths.len:
        var j: int32 = i
        while j > 0 && cmp(paths[j], paths[j - 1]) < 0:
            let swapPath = paths[j - 1]
            paths[j - 1] = paths[j]
            paths[j] = swapPath
            let swapId = ids[j - 1]
            ids[j - 1] = ids[j]
            ids[j] = swapId
            j = j - 1
        i = i + 1

fn compilerCoreSortDeclaredModuleLookup(paths: var str[], owners: var str[]) =
    var i: int32 = 1
    while i < paths.len:
        var j: int32 = i
        while j > 0 && cmp(paths[j], paths[j - 1]) < 0:
            let swapPath = paths[j - 1]
            paths[j - 1] = paths[j]
            paths[j] = swapPath
            let swapOwner = owners[j - 1]
            owners[j - 1] = owners[j]
            owners[j] = swapOwner
            j = j - 1
        i = i + 1

fn compilerCoreSortEnumLookup(modulePaths: var str[],
                              memberNames: var str[],
                              ordinals: var int32[]) =
    var i: int32 = 1
    while i < modulePaths.len:
        var j: int32 = i
        while j > 0 &&
              compilerCoreCompareNamedPair(modulePaths[j],
                                           memberNames[j],
                                           modulePaths[j - 1],
                                           memberNames[j - 1]) < 0:
            let swapModule = modulePaths[j - 1]
            modulePaths[j - 1] = modulePaths[j]
            modulePaths[j] = swapModule
            let swapMember = memberNames[j - 1]
            memberNames[j - 1] = memberNames[j]
            memberNames[j] = swapMember
            let swapOrdinal = ordinals[j - 1]
            ordinals[j - 1] = ordinals[j]
            ordinals[j] = swapOrdinal
            j = j - 1
        i = i + 1

fn compilerCoreFindModulePathSlot(visibility: CompilerCoreVisibilityIndex, modulePath: str): int32 =
    var lo: int32 = 0
    var hi: int32 = visibility.lookupPaths.len
    while lo < hi:
        let mid = lo + (hi - lo) / 2
        let order = cmp(visibility.lookupPaths[mid], modulePath)
        if order == 0:
            return visibility.lookupIds[mid]
        if order < 0:
            lo = mid + 1
        else:
            hi = mid
    return -1

fn compilerCoreFindNamedBucket(ownerModuleIds: int32[],
                               names: str[],
                               ownerModuleId: int32,
                               name: str): int32 =
    for i in 0..<ownerModuleIds.len:
        if ownerModuleIds[i] == ownerModuleId && names[i] == name:
            return i
    return -1

fn compilerCoreEnsureNamedBucket(ownerModuleIds: var int32[],
                                 names: var str[],
                                 bucketStarts: var int32[],
                                 bucketCounts: var int32[],
                                 ownerModuleId: int32,
                                 name: str,
                                 entryCount: int32): int32 =
    let existing = compilerCoreFindNamedBucket(ownerModuleIds, names, ownerModuleId, name)
    if existing >= 0:
        return existing
    seqs.add(ownerModuleIds, ownerModuleId)
    seqs.add(names, name)
    seqs.add(bucketStarts, entryCount)
    seqs.add(bucketCounts, 0)
    return ownerModuleIds.len - 1

fn compilerCoreEnsureModulePath(modulePaths: var str[], modulePath: str): int32 =
    if strings.len(modulePath) <= 0:
        return -1
    let existing = compilerCoreFindModulePathSlotInArray(modulePaths, modulePath)
    if existing >= 0:
        return existing
    let next = modulePaths.len
    seqs.add(modulePaths, modulePath)
    return next

fn compilerCoreFindDeclaredModulePathSlotInIndex(index: CompilerCoreDeclaredModuleIndex,
                                                 declaredModulePath: str): int32 =
    var lo: int32 = 0
    var hi: int32 = index.lookupDeclaredModulePaths.len
    while lo < hi:
        let mid = lo + (hi - lo) / 2
        let order = cmp(index.lookupDeclaredModulePaths[mid], declaredModulePath)
        if order == 0:
            return mid
        if order < 0:
            lo = mid + 1
        else:
            hi = mid
    return -1

fn compilerCoreLookupDeclaredOwnerModulePath(index: CompilerCoreDeclaredModuleIndex,
                                             declaredModulePath: str): str =
    let slot = compilerCoreFindDeclaredModulePathSlotInIndex(index, declaredModulePath)
    if slot < 0:
        return ""
    return index.lookupOwnerModulePaths[slot]

fn buildCompilerCoreDeclaredModuleIndex(program: ccore.CompilerCoreProgram): CompilerCoreDeclaredModuleIndex =
    var out = newCompilerCoreDeclaredModuleIndex()
    for itemId in 0..<program.topLevelKinds.len:
        if itemId >= program.topLevelSourcePaths.len || itemId >= program.topLevelOwnerModules.len:
            continue
        let sourcePath = program.topLevelSourcePaths[itemId]
        let ownerModulePath = program.topLevelOwnerModules[itemId]
        if strings.len(sourcePath) <= 0 || strings.len(ownerModulePath) <= 0:
            continue
        let declaredModulePath = compilerCoreDeclaredModulePathForSourcePath(sourcePath)
        let existingIdx = compilerCoreFindModulePathSlotInArray(out.declaredModulePaths, declaredModulePath)
        if existingIdx >= 0:
            if out.ownerModulePaths[existingIdx] != ownerModulePath:
                compilerCoreFactsPanic("v2 semantic facts compiler_core: conflicting declared module owner " +
                                       declaredModulePath + " -> " + out.ownerModulePaths[existingIdx] +
                                       " vs " + ownerModulePath)
            continue
        seqs.add(out.declaredModulePaths, declaredModulePath)
        seqs.add(out.ownerModulePaths, ownerModulePath)
    for i in 0..<out.declaredModulePaths.len:
        seqs.add(out.lookupDeclaredModulePaths, out.declaredModulePaths[i])
        seqs.add(out.lookupOwnerModulePaths, out.ownerModulePaths[i])
    compilerCoreSortDeclaredModuleLookup(out.lookupDeclaredModulePaths, out.lookupOwnerModulePaths)
    return out

fn compilerCoreAppendVisibleModuleId(visibleModuleIds: var int32[],
                                     visibleStart: int32,
                                     moduleId: int32) =
    if moduleId < 0:
        return
    for i in visibleStart..<visibleModuleIds.len:
        if visibleModuleIds[i] == moduleId:
            return
    seqs.add(visibleModuleIds, moduleId)

fn compilerCoreTarjanVisit(graph: CompilerCoreModuleGraph,
                           moduleId: int32,
                           nextIndex: var int32,
                           indices: var int32[],
                           lowLinks: var int32[],
                           onStack: var bool[],
                           stack: var int32[],
                           sccIds: var int32[],
                           sccCount: var int32) =
    indices[moduleId] = nextIndex
    lowLinks[moduleId] = nextIndex
    nextIndex = nextIndex + 1
    seqs.add(stack, moduleId)
    onStack[moduleId] = true
    for edgeIdx in 0..<graph.importEdgeOwnerModuleIds.len:
        if graph.importEdgeOwnerModuleIds[edgeIdx] != moduleId:
            continue
        let targetModuleId = graph.importEdgeTargetModuleIds[edgeIdx]
        if targetModuleId < 0:
            continue
        if indices[targetModuleId] < 0:
            compilerCoreTarjanVisit(graph,
                                    targetModuleId,
                                    nextIndex,
                                    indices,
                                    lowLinks,
                                    onStack,
                                    stack,
                                    sccIds,
                                    sccCount)
            if lowLinks[targetModuleId] < lowLinks[moduleId]:
                lowLinks[moduleId] = lowLinks[targetModuleId]
        elif onStack[targetModuleId]:
            if indices[targetModuleId] < lowLinks[moduleId]:
                lowLinks[moduleId] = indices[targetModuleId]
    if lowLinks[moduleId] == indices[moduleId]:
        while stack.len > 0:
            let stackModuleId = stack[stack.len - 1]
            seqs.setLen(stack, stack.len - 1)
            onStack[stackModuleId] = false
            sccIds[stackModuleId] = sccCount
            if stackModuleId == moduleId:
                break
        sccCount = sccCount + 1

fn buildCompilerCoreModuleGraph(program: ccore.CompilerCoreProgram,
                                declaredIndex: CompilerCoreDeclaredModuleIndex): CompilerCoreModuleGraph =
    var out = newCompilerCoreModuleGraph()
    for i in 0..<program.topLevelOwnerModules.len:
        if strings.len(program.topLevelOwnerModules[i]) > 0:
            discard compilerCoreEnsureModulePath(out.modulePaths, program.topLevelOwnerModules[i])
    for i in 0..<program.topLevelKinds.len:
        if program.topLevelKinds[i] != "import":
            continue
        if i >= program.topLevelImportDeclIdxs.len:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: missing topLevelImportDeclIdx for item " + intToStr(i))
        let importIdx = program.topLevelImportDeclIdxs[i]
        if importIdx < 0 || importIdx >= program.imports.len:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: invalid topLevelImportDeclIdx " +
                                   intToStr(importIdx) + " for item " + intToStr(i))
        let ownerModulePath = compilerCoreTopLevelModulePath(program, i)
        let declaredTargetModulePath = compilerCoreNormalizeImportModulePath(program.imports[importIdx].modulePath)
        let targetModulePath = compilerCoreLookupDeclaredOwnerModulePath(declaredIndex, declaredTargetModulePath)
        if strings.len(targetModulePath) <= 0:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: missing declared import target owner " +
                                   declaredTargetModulePath)
        seqs.add(out.importEdgeOwnerModuleIds,
            compilerCoreEnsureModulePath(out.modulePaths, ownerModulePath))
        seqs.add(out.importEdgeTargetModuleIds,
            compilerCoreEnsureModulePath(out.modulePaths, targetModulePath))
    var indices: int32[]
    var lowLinks: int32[]
    var onStack: bool[]
    var stack: int32[]
    indices = []
    lowLinks = []
    onStack = []
    stack = []
    out.moduleSccIds = []
    for i in 0..<out.modulePaths.len:
        seqs.add(indices, -1)
        seqs.add(lowLinks, -1)
        seqs.add(onStack, false)
        seqs.add(out.moduleSccIds, -1)
    var nextIndex: int32 = 0
    var sccCount: int32 = 0
    for i in 0..<out.modulePaths.len:
        if indices[i] < 0:
            compilerCoreTarjanVisit(out,
                                    i,
                                    nextIndex,
                                    indices,
                                    lowLinks,
                                    onStack,
                                    stack,
                                    out.moduleSccIds,
                                    sccCount)
    return out

fn buildCompilerCoreTypeHeaderArena(program: ccore.CompilerCoreProgram): CompilerCoreTypeHeaderArena =
    var out = newCompilerCoreTypeHeaderArena()
    seqs.setLen(out.itemIdToTypeBodyIdx, program.topLevelKinds.len)
    for i in 0..<out.itemIdToTypeBodyIdx.len:
        out.itemIdToTypeBodyIdx[i] = -1
    var typeIdx: int32 = 0
    for itemId in 0..<program.topLevelKinds.len:
        if program.topLevelKinds[itemId] != "type":
            continue
        let ownerModulePath = compilerCoreTopLevelModulePath(program, itemId)
        let bodyLines = program.typeBlocks[typeIdx].bodyLines
        var baseIndent: int32 = -1
        for lineIdx in 0..<bodyLines.len:
            let line = compilerCoreTrimInlineComment(bodyLines[lineIdx])
            if strings.len(line) <= 0:
                continue
            let indent = compilerCoreLineIndentWidth(bodyLines[lineIdx])
            if baseIndent < 0 || indent < baseIndent:
                baseIndent = indent
        if baseIndent >= 0:
            for lineIdx in 0..<bodyLines.len:
                let line = compilerCoreTrimInlineComment(bodyLines[lineIdx])
                if strings.len(line) <= 0 || compilerCoreLineIndentWidth(bodyLines[lineIdx]) != baseIndent:
                    continue
                let typeName = compilerCoreTypeDeclNameFromLine(bodyLines[lineIdx])
                if strings.len(typeName) <= 0:
                    continue
                seqs.add(out.itemIds, itemId)
                seqs.add(out.ownerModulePaths, ownerModulePath)
                seqs.add(out.typeNames, typeName)
                seqs.add(out.typeBodyIdxs, typeIdx)
                out.itemIdToTypeBodyIdx[itemId] = typeIdx
        typeIdx = typeIdx + 1
    return out

fn buildCompilerCoreValueHeaderArena(program: ccore.CompilerCoreProgram): CompilerCoreValueHeaderArena =
    var out = newCompilerCoreValueHeaderArena()
    var constIdx: int32 = 0
    var varIdx: int32 = 0
    for itemId in 0..<program.topLevelKinds.len:
        let kind = program.topLevelKinds[itemId]
        if kind == "const":
            let decl = program.constDecls[constIdx]
            constIdx = constIdx + 1
            seqs.add(out.itemIds, itemId)
            seqs.add(out.ownerModulePaths, compilerCoreTopLevelModulePath(program, itemId))
            seqs.add(out.valueKinds, kind)
            seqs.add(out.valueNames, decl.label)
            continue
        if kind == "var":
            let decl = program.varDecls[varIdx]
            varIdx = varIdx + 1
            seqs.add(out.itemIds, itemId)
            seqs.add(out.ownerModulePaths, compilerCoreTopLevelModulePath(program, itemId))
            seqs.add(out.valueKinds, kind)
            seqs.add(out.valueNames, decl.label)
    return out

fn buildCompilerCoreRoutineHeaderArena(program: ccore.CompilerCoreProgram): CompilerCoreRoutineHeaderArena =
    var out = newCompilerCoreRoutineHeaderArena()
    var routineIdx: int32 = 0
    out.itemIdToRoutineDeclIdxs = []
    for itemId in 0..<program.topLevelKinds.len:
        seqs.add(out.itemIdToRoutineDeclIdxs, -1)
    for itemId in 0..<program.topLevelKinds.len:
        let kind = program.topLevelKinds[itemId]
        if kind != "fn" && kind != "iterator" && kind != "importc_fn":
            continue
        seqs.add(out.itemIds, itemId)
        seqs.add(out.ownerModulePaths, compilerCoreTopLevelModulePath(program, itemId))
        seqs.add(out.routineKinds, kind)
        seqs.add(out.routineNames, program.topLevelLabels[itemId])
        seqs.add(out.routineDeclIdxs, routineIdx)
        out.itemIdToRoutineDeclIdxs[itemId] = routineIdx
        routineIdx = routineIdx + 1
    return out

fn buildCompilerCoreImportHeaderArena(program: ccore.CompilerCoreProgram,
                                      declaredIndex: CompilerCoreDeclaredModuleIndex): CompilerCoreImportHeaderArena =
    var out = newCompilerCoreImportHeaderArena()
    for itemId in 0..<program.topLevelKinds.len:
        if program.topLevelKinds[itemId] != "import":
            continue
        if itemId >= program.topLevelImportDeclIdxs.len:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: missing topLevelImportDeclIdx for item " + intToStr(itemId))
        let importIdx = program.topLevelImportDeclIdxs[itemId]
        if importIdx < 0 || importIdx >= program.imports.len:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: invalid topLevelImportDeclIdx " +
                                   intToStr(importIdx) + " for item " + intToStr(itemId))
        let decl = program.imports[importIdx]
        let declaredTargetModulePath = compilerCoreNormalizeImportModulePath(decl.modulePath)
        let targetOwnerModulePath = compilerCoreLookupDeclaredOwnerModulePath(declaredIndex, declaredTargetModulePath)
        if strings.len(targetOwnerModulePath) <= 0:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: missing import target owner " +
                                   declaredTargetModulePath)
        seqs.add(out.itemIds, itemId)
        seqs.add(out.ownerModulePaths, compilerCoreTopLevelModulePath(program, itemId))
        seqs.add(out.importVisibleNames,
                 compilerCoreImportVisibleName(decl.modulePath, decl.alias))
        seqs.add(out.targetModulePaths, targetOwnerModulePath)
    return out

fn compilerCoreAppendEnumMembersFromFieldText(out: var CompilerCoreEnumMemberHeaderArena,
                                              ownerModulePath: str,
                                              fieldText: str,
                                              nextOrdinal: var int32) =
    let parts = compilerCoreSplitEnumFieldParts(fieldText)
    for i in 0..<parts.len:
        let part = compilerCoreTrimInlineComment(parts[i])
        if strings.len(part) <= 0:
            continue
        let eqIdx = strings.find(part, "=")
        var fieldName: str = part
        var fieldOrdinal: int32 = nextOrdinal
        if eqIdx >= 0:
            fieldName = strutils.strip(strings.sliceBytes(part, 0, eqIdx))
            let valueText = strutils.strip(strings.sliceBytes(part, eqIdx + 1, strings.len(part) - eqIdx - 1))
            if !compilerCoreParseInt32Text(valueText, fieldOrdinal):
                compilerCoreFactsPanic("v2 semantic facts compiler_core: unsupported enum ordinal " + valueText)
        if strings.len(fieldName) <= 0:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: malformed enum field " + part)
        seqs.add(out.ownerModulePaths, ownerModulePath)
        seqs.add(out.memberNames, fieldName)
        seqs.add(out.ordinals, fieldOrdinal)
        nextOrdinal = fieldOrdinal + 1

fn compilerCoreAppendEnumMembersFromTypeBlock(out: var CompilerCoreEnumMemberHeaderArena,
                                              ownerModulePath: str,
                                              bodyLines: str[]) =
    var activeEnumIndent: int32 = -1
    var nextOrdinal: int32 = 0
    for i in 0..<bodyLines.len:
        let rawLine = bodyLines[i]
        let line = compilerCoreTrimInlineComment(rawLine)
        if strings.len(line) <= 0:
            continue
        let indent = compilerCoreLineIndentWidth(rawLine)
        let enumIdx = strings.find(line, "= enum")
        if enumIdx >= 0:
            activeEnumIndent = indent
            nextOrdinal = 0
            let suffix = strutils.strip(strings.sliceBytes(line,
                                                           enumIdx + strings.len("= enum"),
                                                           strings.len(line) - enumIdx - strings.len("= enum")))
            if strings.len(suffix) > 0:
                compilerCoreAppendEnumMembersFromFieldText(out,
                                                           ownerModulePath,
                                                           suffix,
                                                           nextOrdinal)
            continue
        if activeEnumIndent >= 0 && indent > activeEnumIndent:
            compilerCoreAppendEnumMembersFromFieldText(out,
                                                       ownerModulePath,
                                                       line,
                                                       nextOrdinal)
            continue
        activeEnumIndent = -1

fn buildCompilerCoreEnumMemberHeaderArena(program: ccore.CompilerCoreProgram): CompilerCoreEnumMemberHeaderArena =
    var out = newCompilerCoreEnumMemberHeaderArena()
    var typeIdx: int32 = 0
    for itemId in 0..<program.topLevelKinds.len:
        if program.topLevelKinds[itemId] != "type":
            continue
        compilerCoreAppendEnumMembersFromTypeBlock(out,
                                                   compilerCoreTopLevelModulePath(program, itemId),
                                                   program.typeBlocks[typeIdx].bodyLines)
        typeIdx = typeIdx + 1
    out.lookupModulePaths = []
    out.lookupMemberNames = []
    out.lookupOrdinals = []
    for i in 0..<out.memberNames.len:
        seqs.add(out.lookupModulePaths, out.ownerModulePaths[i])
        seqs.add(out.lookupMemberNames, out.memberNames[i])
        seqs.add(out.lookupOrdinals, out.ordinals[i])
    compilerCoreSortEnumLookup(out.lookupModulePaths, out.lookupMemberNames, out.lookupOrdinals)
    return out

fn buildCompilerCoreVisibilityIndex(graph: CompilerCoreModuleGraph): CompilerCoreVisibilityIndex =
    var out = newCompilerCoreVisibilityIndex()
    out.modulePaths = graph.modulePaths
    out.lookupPaths = []
    out.lookupIds = []
    for moduleId in 0..<graph.modulePaths.len:
        seqs.add(out.lookupPaths, graph.modulePaths[moduleId])
        seqs.add(out.lookupIds, moduleId)
    compilerCoreSortModulePathLookup(out.lookupPaths, out.lookupIds)
    for moduleId in 0..<graph.modulePaths.len:
        let visibleStart = out.moduleVisibleModuleIds.len
        compilerCoreAppendVisibleModuleId(out.moduleVisibleModuleIds, visibleStart, moduleId)
        for otherId in 0..<graph.modulePaths.len:
            if graph.moduleSccIds[otherId] == graph.moduleSccIds[moduleId]:
                compilerCoreAppendVisibleModuleId(out.moduleVisibleModuleIds, visibleStart, otherId)
        for edgeIdx in 0..<graph.importEdgeOwnerModuleIds.len:
            if graph.importEdgeOwnerModuleIds[edgeIdx] == moduleId:
                compilerCoreAppendVisibleModuleId(out.moduleVisibleModuleIds,
                                                  visibleStart,
                                                  graph.importEdgeTargetModuleIds[edgeIdx])
        seqs.add(out.moduleVisibleStarts, visibleStart)
        seqs.add(out.moduleVisibleCounts, out.moduleVisibleModuleIds.len - visibleStart)
    return out

fn buildCompilerCoreImportHeaderIndex(importArena: CompilerCoreImportHeaderArena,
                                      visibility: CompilerCoreVisibilityIndex): CompilerCoreImportHeaderIndex =
    var out = newCompilerCoreImportHeaderIndex()
    for i in 0..<importArena.itemIds.len:
        let ownerModuleId = compilerCoreFindModulePathSlot(visibility, importArena.ownerModulePaths[i])
        let targetModuleId = compilerCoreFindModulePathSlot(visibility, importArena.targetModulePaths[i])
        if ownerModuleId < 0 || targetModuleId < 0:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: import header index lost module path")
        let bucketIdx = compilerCoreEnsureNamedBucket(out.ownerModuleIds,
                                                      out.visibleNames,
                                                      out.bucketStarts,
                                                      out.bucketCounts,
                                                      ownerModuleId,
                                                      importArena.importVisibleNames[i],
                                                      out.bucketItemIds.len)
        seqs.add(out.bucketItemIds, importArena.itemIds[i])
        seqs.add(out.bucketTargetModuleIds, targetModuleId)
        out.bucketCounts[bucketIdx] = out.bucketCounts[bucketIdx] + 1
    return out

fn buildCompilerCoreTypeHeaderIndex(typeArena: CompilerCoreTypeHeaderArena,
                                    visibility: CompilerCoreVisibilityIndex): CompilerCoreTypeHeaderIndex =
    var out = newCompilerCoreTypeHeaderIndex()
    for i in 0..<typeArena.itemIds.len:
        let ownerModuleId = compilerCoreFindModulePathSlot(visibility, typeArena.ownerModulePaths[i])
        if ownerModuleId < 0:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: type header index lost module path")
        let bucketIdx = compilerCoreEnsureNamedBucket(out.ownerModuleIds,
                                                      out.typeNames,
                                                      out.bucketStarts,
                                                      out.bucketCounts,
                                                      ownerModuleId,
                                                      typeArena.typeNames[i],
                                                      out.bucketItemIds.len)
        seqs.add(out.bucketItemIds, typeArena.itemIds[i])
        seqs.add(out.bucketTypeBodyIdxs, typeArena.typeBodyIdxs[i])
        out.bucketCounts[bucketIdx] = out.bucketCounts[bucketIdx] + 1
    return out

fn buildCompilerCoreValueHeaderIndex(valueArena: CompilerCoreValueHeaderArena,
                                     visibility: CompilerCoreVisibilityIndex): CompilerCoreValueHeaderIndex =
    var out = newCompilerCoreValueHeaderIndex()
    for i in 0..<valueArena.itemIds.len:
        let ownerModuleId = compilerCoreFindModulePathSlot(visibility, valueArena.ownerModulePaths[i])
        if ownerModuleId < 0:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: value header index lost module path")
        let bucketIdx = compilerCoreEnsureNamedBucket(out.ownerModuleIds,
                                                      out.valueNames,
                                                      out.bucketStarts,
                                                      out.bucketCounts,
                                                      ownerModuleId,
                                                      valueArena.valueNames[i],
                                                      out.bucketItemIds.len)
        seqs.add(out.bucketItemIds, valueArena.itemIds[i])
        seqs.add(out.bucketKinds, valueArena.valueKinds[i])
        out.bucketCounts[bucketIdx] = out.bucketCounts[bucketIdx] + 1
    return out

fn buildCompilerCoreRoutineHeaderIndex(routineArena: CompilerCoreRoutineHeaderArena,
                                       visibility: CompilerCoreVisibilityIndex): CompilerCoreRoutineHeaderIndex =
    var out = newCompilerCoreRoutineHeaderIndex()
    for i in 0..<routineArena.itemIds.len:
        let ownerModuleId = compilerCoreFindModulePathSlot(visibility, routineArena.ownerModulePaths[i])
        if ownerModuleId < 0:
            compilerCoreFactsPanic("v2 semantic facts compiler_core: routine header index lost module path")
        let bucketIdx = compilerCoreEnsureNamedBucket(out.ownerModuleIds,
                                                      out.routineNames,
                                                      out.bucketStarts,
                                                      out.bucketCounts,
                                                      ownerModuleId,
                                                      routineArena.routineNames[i],
                                                      out.bucketItemIds.len)
        seqs.add(out.bucketItemIds, routineArena.itemIds[i])
        seqs.add(out.bucketKinds, routineArena.routineKinds[i])
        seqs.add(out.bucketDeclIdxs, routineArena.routineDeclIdxs[i])
        out.bucketCounts[bucketIdx] = out.bucketCounts[bucketIdx] + 1
    return out

fn compilerCoreFindTypeItemIdInModulePath(typeIndex: CompilerCoreTypeHeaderIndex,
                                          visibility: CompilerCoreVisibilityIndex,
                                          modulePath: str,
                                          typeName: str): int32 =
    let moduleId = compilerCoreFindModulePathSlot(visibility, modulePath)
    if moduleId < 0:
        return -1
    let bucketIdx = compilerCoreFindNamedBucket(typeIndex.ownerModuleIds, typeIndex.typeNames, moduleId, typeName)
    if bucketIdx < 0:
        return -1
    let start = typeIndex.bucketStarts[bucketIdx]
    let count = typeIndex.bucketCounts[bucketIdx]
    if count != 1:
        return -1
    return typeIndex.bucketItemIds[start]

fn compilerCoreImportVisibleName(importPath: str, importAlias: str): str =
    if strings.len(importAlias) > 0:
        return importAlias
    var slashIdx: int32 = -1
    for i in 0..<strings.len(importPath):
        if importPath[i] == '/':
            slashIdx = i
    if slashIdx >= 0:
        return strings.sliceBytes(importPath, slashIdx + 1, strings.len(importPath) - slashIdx - 1)
    return importPath

fn compilerCoreFindImportVisibleItemIdInModule(importIndex: CompilerCoreImportHeaderIndex,
                                               visibility: CompilerCoreVisibilityIndex,
                                               ownerModulePath: str,
                                               name: str): int32 =
    let ownerModuleId = compilerCoreFindModulePathSlot(visibility, ownerModulePath)
    if ownerModuleId < 0:
        return -1
    let bucketIdx = compilerCoreFindNamedBucket(importIndex.ownerModuleIds, importIndex.visibleNames, ownerModuleId, name)
    if bucketIdx < 0:
        return -1
    let start = importIndex.bucketStarts[bucketIdx]
    let count = importIndex.bucketCounts[bucketIdx]
    if count != 1:
        return -1
    return importIndex.bucketItemIds[start]

fn compilerCoreFindImportModulePathInModule(importIndex: CompilerCoreImportHeaderIndex,
                                            visibility: CompilerCoreVisibilityIndex,
                                            ownerModulePath: str,
                                            visibleName: str): str =
    let ownerModuleId = compilerCoreFindModulePathSlot(visibility, ownerModulePath)
    if ownerModuleId < 0:
        return ""
    let bucketIdx = compilerCoreFindNamedBucket(importIndex.ownerModuleIds,
                                                importIndex.visibleNames,
                                                ownerModuleId,
                                                visibleName)
    if bucketIdx < 0:
        return ""
    let start = importIndex.bucketStarts[bucketIdx]
    let count = importIndex.bucketCounts[bucketIdx]
    if count <= 0:
        return ""
    let targetModuleId = importIndex.bucketTargetModuleIds[start]
    for i in 1..<count:
        if importIndex.bucketTargetModuleIds[start + i] != targetModuleId:
            return ""
    if targetModuleId < 0 || targetModuleId >= visibility.modulePaths.len:
        return ""
    return visibility.modulePaths[targetModuleId]

fn compilerCoreResolveTypeModulePathInModule(importIndex: CompilerCoreImportHeaderIndex,
                                             visibility: CompilerCoreVisibilityIndex,
                                             ownerModulePath: str,
                                             modulePrefix: str): str =
    if strings.len(modulePrefix) <= 0:
        return ""
    if strings.find(modulePrefix, "/") >= 0:
        return modulePrefix
    return compilerCoreFindImportModulePathInModule(importIndex, visibility, ownerModulePath, modulePrefix)

fn compilerCoreCanonicalizeQualifiedTypeTextInModule(importIndex: CompilerCoreImportHeaderIndex,
                                                     visibility: CompilerCoreVisibilityIndex,
                                                     program: ccore.CompilerCoreProgram,
                                                     typeArena: CompilerCoreTypeHeaderArena,
                                                     typeIndex: CompilerCoreTypeHeaderIndex,
                                                     ownerModulePath: str,
                                                     typeText: str): str =
    let wasVar = compilerCoreCallTypeIsVar(typeText)
    let normalized = compilerCoreNormalizeCallTypeText(typeText)
    if strings.len(normalized) <= 0:
        if wasVar:
            return "var " + normalized
        return normalized
    if strings.startsWith(normalized, "ref "):
        let inner = compilerCoreCanonicalizeQualifiedTypeTextInModule(importIndex,
                                                                      visibility,
                                                                      program,
                                                                      typeArena,
                                                                      typeIndex,
                                                                      ownerModulePath,
                                                                      strings.sliceBytes(normalized, 4, strings.len(normalized) - 4))
        let out = "ref " + inner
        if wasVar:
            return "var " + out
        return out
    var suffixBase: str = ""
    var suffixArg: str = ""
    if compilerCoreTypeTextSplitSuffixCtor(normalized, suffixBase, suffixArg):
        let canonicalArg = compilerCoreCanonicalizeQualifiedTypeTextInModule(importIndex,
                                                                             visibility,
                                                                             program,
                                                                             typeArena,
                                                                             typeIndex,
                                                                             ownerModulePath,
                                                                             suffixArg)
        let canonical = suffixBase == "[]"
            ? canonicalArg + "[]"
            : canonicalArg + suffixBase
        if wasVar:
            return "var " + canonical
        return canonical
    var ctorBase: str = ""
    var ctorArg: str = ""
    if compilerCoreTypeTextSplitSingleArgCtor(normalized, ctorBase, ctorArg):
        let canonicalBase = compilerCoreCanonicalizeVisibleLeafTypeTextInModule(program,
                                                                                typeIndex,
                                                                                visibility,
                                                                                ownerModulePath,
                                                                                ctorBase)
        let canonicalArg = compilerCoreCanonicalizeQualifiedTypeTextInModule(importIndex,
                                                                             visibility,
                                                                             program,
                                                                             typeArena,
                                                                             typeIndex,
                                                                             ownerModulePath,
                                                                             ctorArg)
        let canonical = canonicalBase + "[" + canonicalArg + "]"
        if wasVar:
            return "var " + canonical
        return canonical
    let dotIdx = strings.find(normalized, ".")
    if dotIdx <= 0:
        let canonical = compilerCoreCanonicalizeVisibleLeafTypeTextInModule(program,
                                                                            typeIndex,
                                                                            visibility,
                                                                            ownerModulePath,
                                                                            normalized)
        if wasVar:
            return "var " + canonical
        return canonical
    let modulePrefix = strings.sliceBytes(normalized, 0, dotIdx)
    let targetModulePath = compilerCoreResolveTypeModulePathInModule(importIndex,
                                                                     visibility,
                                                                     ownerModulePath,
                                                                     modulePrefix)
    if strings.len(targetModulePath) <= 0:
        if wasVar:
            return "var " + normalized
        return normalized
    let targetTypeName = strutils.strip(strings.sliceBytes(normalized,
                                                           dotIdx + 1,
                                                           strings.len(normalized) - dotIdx - 1))
    let canonical = targetModulePath + "." + targetTypeName
    if wasVar:
        return "var " + canonical
    return canonical

fn compilerCoreTopLevelKindMatchesVisibilityFilter(kind: str,
                                                   allowTypes: bool,
                                                   allowValues: bool,
                                                   allowRoutines: bool): bool =
    if allowTypes && kind == "type":
        return true
    if allowValues && (kind == "const" || kind == "var"):
        return true
    if allowRoutines && (kind == "fn" || kind == "iterator" || kind == "importc_fn"):
        return true
    return false

fn compilerCoreModuleCanSeeModuleId(visibility: CompilerCoreVisibilityIndex,
                                    ownerModuleId: int32,
                                    targetModuleId: int32): bool =
    if ownerModuleId < 0 || targetModuleId < 0:
        return false
    let visibleStart = visibility.moduleVisibleStarts[ownerModuleId]
    let visibleCount = visibility.moduleVisibleCounts[ownerModuleId]
    for i in 0..<visibleCount:
        if visibility.moduleVisibleModuleIds[visibleStart + i] == targetModuleId:
            return true
    return false

fn compilerCoreModuleCanSeeModulePath(visibility: CompilerCoreVisibilityIndex,
                                      ownerModulePath: str,
                                      targetModulePath: str): bool =
    if strings.len(ownerModulePath) <= 0 || strings.len(targetModulePath) <= 0:
        return false
    let ownerModuleId = compilerCoreFindModulePathSlot(visibility, ownerModulePath)
    let targetModuleId = compilerCoreFindModulePathSlot(visibility, targetModulePath)
    return compilerCoreModuleCanSeeModuleId(visibility, ownerModuleId, targetModuleId)

fn compilerCoreAppendVisibleBindingMatch(itemId: int32,
                                         kind: str,
                                         routineDeclIdx: int32,
                                         matchedItemId: var int32,
                                         matchedKind: var str,
                                         matchedRoutineDeclIdx: var int32): bool =
    if matchedItemId >= 0 && matchedItemId != itemId:
        return false
    matchedItemId = itemId
    matchedKind = kind
    matchedRoutineDeclIdx = routineDeclIdx
    return true

fn compilerCoreFindVisibleTopLevelBindingInModule(valueIndex: CompilerCoreValueHeaderIndex,
                                                  routineIndex: CompilerCoreRoutineHeaderIndex,
                                                  visibility: CompilerCoreVisibilityIndex,
                                                  ownerModulePath: str,
                                                  label: str,
                                                  allowValues: bool,
                                                  allowRoutines: bool,
                                                  matchedKind: var str,
                                                  matchedRoutineDeclIdx: var int32): int32 =
    let ownerModuleId = compilerCoreFindModulePathSlot(visibility, ownerModulePath)
    if ownerModuleId < 0:
        matchedKind = ""
        matchedRoutineDeclIdx = -1
        return -1
    for pass in 0..<2:
        var matchedItemId: int32 = -1
        matchedKind = ""
        matchedRoutineDeclIdx = -1
        let visibleStart = visibility.moduleVisibleStarts[ownerModuleId]
        let visibleCount = visibility.moduleVisibleCounts[ownerModuleId]
        for visibleIdx in 0..<visibleCount:
            let targetModuleId = visibility.moduleVisibleModuleIds[visibleStart + visibleIdx]
            let localMatch = targetModuleId == ownerModuleId
            if (pass == 0 && !localMatch) || (pass == 1 && localMatch):
                continue
            if allowValues:
                let bucketIdx = compilerCoreFindNamedBucket(valueIndex.ownerModuleIds,
                                                            valueIndex.valueNames,
                                                            targetModuleId,
                                                            label)
                if bucketIdx >= 0:
                    let start = valueIndex.bucketStarts[bucketIdx]
                    let count = valueIndex.bucketCounts[bucketIdx]
                    for i in 0..<count:
                        if !compilerCoreAppendVisibleBindingMatch(valueIndex.bucketItemIds[start + i],
                                                                  valueIndex.bucketKinds[start + i],
                                                                  -1,
                                                                  matchedItemId,
                                                                  matchedKind,
                                                                  matchedRoutineDeclIdx):
                            matchedKind = ""
                            matchedRoutineDeclIdx = -1
                            return -1
            if allowRoutines:
                let bucketIdx = compilerCoreFindNamedBucket(routineIndex.ownerModuleIds,
                                                            routineIndex.routineNames,
                                                            targetModuleId,
                                                            label)
                if bucketIdx >= 0:
                    let start = routineIndex.bucketStarts[bucketIdx]
                    let count = routineIndex.bucketCounts[bucketIdx]
                    for i in 0..<count:
                        if !compilerCoreAppendVisibleBindingMatch(routineIndex.bucketItemIds[start + i],
                                                                  routineIndex.bucketKinds[start + i],
                                                                  routineIndex.bucketDeclIdxs[start + i],
                                                                  matchedItemId,
                                                                  matchedKind,
                                                                  matchedRoutineDeclIdx):
                            matchedKind = ""
                            matchedRoutineDeclIdx = -1
                            return -1
        if matchedItemId >= 0:
            return matchedItemId
    matchedKind = ""
    matchedRoutineDeclIdx = -1
    return -1

fn compilerCoreFindVisibleTopLevelItemIdInModule(valueIndex: CompilerCoreValueHeaderIndex,
                                                 routineIndex: CompilerCoreRoutineHeaderIndex,
                                                 visibility: CompilerCoreVisibilityIndex,
                                                 ownerModulePath: str,
                                                 label: str,
                                                 allowTypes: bool,
                                                 allowValues: bool,
                                                 allowRoutines: bool): int32 =
    var matchedKind: str = ""
    var matchedRoutineDeclIdx: int32 = -1
    discard allowTypes
    return compilerCoreFindVisibleTopLevelBindingInModule(valueIndex,
                                                          routineIndex,
                                                          visibility,
                                                          ownerModulePath,
                                                          label,
                                                          allowValues,
                                                          allowRoutines,
                                                          matchedKind,
                                                          matchedRoutineDeclIdx)

fn compilerCoreFindVisibleTopLevelKindInModule(valueIndex: CompilerCoreValueHeaderIndex,
                                               routineIndex: CompilerCoreRoutineHeaderIndex,
                                               visibility: CompilerCoreVisibilityIndex,
                                               ownerModulePath: str,
                                               label: str,
                                               allowTypes: bool,
                                               allowValues: bool,
                                               allowRoutines: bool): str =
    var matchedKind: str = ""
    var matchedRoutineDeclIdx: int32 = -1
    discard allowTypes
    discard compilerCoreFindVisibleTopLevelBindingInModule(valueIndex,
                                                           routineIndex,
                                                           visibility,
                                                           ownerModulePath,
                                                           label,
                                                           allowValues,
                                                           allowRoutines,
                                                           matchedKind,
                                                           matchedRoutineDeclIdx)
    return matchedKind

fn compilerCoreFindVisibleTypeItemIdInModule(typeIndex: CompilerCoreTypeHeaderIndex,
                                             visibility: CompilerCoreVisibilityIndex,
                                             ownerModulePath: str,
                                             typeName: str): int32 =
    let ownerModuleId = compilerCoreFindModulePathSlot(visibility, ownerModulePath)
    if ownerModuleId < 0:
        return -1
    var matchedItemId: int32 = -1
    let visibleStart = visibility.moduleVisibleStarts[ownerModuleId]
    let visibleCount = visibility.moduleVisibleCounts[ownerModuleId]
    for visibleIdx in 0..<visibleCount:
        let targetModuleId = visibility.moduleVisibleModuleIds[visibleStart + visibleIdx]
        let bucketIdx = compilerCoreFindNamedBucket(typeIndex.ownerModuleIds, typeIndex.typeNames, targetModuleId, typeName)
        if bucketIdx < 0:
            continue
        let start = typeIndex.bucketStarts[bucketIdx]
        let count = typeIndex.bucketCounts[bucketIdx]
        for i in 0..<count:
            let itemId = typeIndex.bucketItemIds[start + i]
            if matchedItemId >= 0 && matchedItemId != itemId:
                return -1
            matchedItemId = itemId
    return matchedItemId

fn compilerCoreCanonicalizeVisibleLeafTypeTextInModule(program: ccore.CompilerCoreProgram,
                                                       typeIndex: CompilerCoreTypeHeaderIndex,
                                                       visibility: CompilerCoreVisibilityIndex,
                                                       ownerModulePath: str,
                                                       typeText: str): str =
    if compilerCoreBuiltinTypeToken(typeText):
        return typeText
    let typeItemId = compilerCoreFindVisibleTypeItemIdInModule(typeIndex,
                                                               visibility,
                                                               ownerModulePath,
                                                               typeText)
    if typeItemId < 0:
        return typeText
    return compilerCoreTopLevelModulePath(program, typeItemId) + "." + typeText

fn compilerCoreDeclaredModulePathForSourcePath(sourcePath: str): str =
    return mpath.declaredModulePathForSourcePath(sourcePath)

fn compilerCoreTrimInlineComment(rawText: str): str =
    for i in 0..<strings.len(rawText):
        if rawText[i] == '#':
            return strutils.strip(strings.sliceBytes(rawText, 0, i))
    return strutils.strip(rawText)

fn compilerCoreIntDigitValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn compilerCoreParseInt32Text(rawText: str, outValue: var int32): bool =
    let text = strutils.strip(rawText)
    if strings.len(text) <= 0:
        return false
    var start: int32 = 0
    var sign: int32 = 1
    if text[0] == '-':
        sign = -1
        start = 1
    if start >= strings.len(text):
        return false
    var base: int32 = 10
    if start + 1 < strings.len(text) && text[start] == '0':
        let marker = text[start + 1]
        if marker == 'x' || marker == 'X':
            base = 16
            start = start + 2
        elif marker == 'b' || marker == 'B':
            base = 2
            start = start + 2
        elif marker == 'o' || marker == 'O':
            base = 8
            start = start + 2
    if start >= strings.len(text):
        return false
    var sawDigit: bool = false
    var prevUnderscore: bool = false
    var value: int64 = 0
    for i in start..<strings.len(text):
        if text[i] == '_':
            if !sawDigit || prevUnderscore:
                return false
            prevUnderscore = true
            continue
        let digit = compilerCoreIntDigitValue(text[i])
        if digit < 0 || digit >= base:
            return false
        sawDigit = true
        prevUnderscore = false
        value = value * int64(base) + int64(digit)
    if !sawDigit || prevUnderscore:
        return false
    value = value * int64(sign)
    if value < int64(-2147483648) || value > int64(2147483647):
        return false
    outValue = int32(value)
    return true

fn compilerCoreSplitEnumFieldParts(text: str): str[] =
    var out: str[]
    var start: int32 = 0
    for i in 0..<strings.len(text):
        if text[i] == ',':
            let part = strutils.strip(strings.sliceBytes(text, start, i - start))
            if strings.len(part) > 0:
                seqs.add(out, part)
            start = i + 1
    let tail = strutils.strip(strings.sliceBytes(text, start, strings.len(text) - start))
    if strings.len(tail) > 0:
        seqs.add(out, tail)
    return out

fn compilerCoreTypeBodyIndexForItemId(typeArena: CompilerCoreTypeHeaderArena,
                                      itemId: int32): int32 =
    if itemId < 0 || itemId >= typeArena.itemIdToTypeBodyIdx.len:
        return -1
    return typeArena.itemIdToTypeBodyIdx[itemId]

fn compilerCoreResolveEnumMemberOrdinalInModulePath(enumArena: CompilerCoreEnumMemberHeaderArena,
                                                    modulePath: str,
                                                    memberName: str,
                                                    outOrdinal: var int32): bool =
    var lo: int32 = 0
    var hi: int32 = enumArena.lookupModulePaths.len
    while lo < hi:
        let mid = lo + (hi - lo) / 2
        let order = compilerCoreCompareNamedPair(enumArena.lookupModulePaths[mid],
                                                 enumArena.lookupMemberNames[mid],
                                                 modulePath,
                                                 memberName)
        if order < 0:
            lo = mid + 1
        else:
            hi = mid
    if lo < 0 || lo >= enumArena.lookupModulePaths.len:
        return false
    if compilerCoreCompareNamedPair(enumArena.lookupModulePaths[lo],
                                    enumArena.lookupMemberNames[lo],
                                    modulePath,
                                    memberName) != 0:
        return false
    if lo + 1 < enumArena.lookupModulePaths.len &&
       compilerCoreCompareNamedPair(enumArena.lookupModulePaths[lo + 1],
                                    enumArena.lookupMemberNames[lo + 1],
                                    modulePath,
                                    memberName) == 0:
        return false
    outOrdinal = enumArena.lookupOrdinals[lo]
    return true

fn compilerCoreResolveVisibleEnumMemberOrdinalInModule(enumArena: CompilerCoreEnumMemberHeaderArena,
                                                       visibility: CompilerCoreVisibilityIndex,
                                                       ownerModulePath: str,
                                                       memberName: str,
                                                       outOrdinal: var int32): bool =
    let ownerModuleId = compilerCoreFindModulePathSlot(visibility, ownerModulePath)
    if ownerModuleId < 0:
        return false
    let visibleStart = visibility.moduleVisibleStarts[ownerModuleId]
    let visibleCount = visibility.moduleVisibleCounts[ownerModuleId]
    for pass in 0..<2:
        var matched: bool = false
        var matchedOrdinal: int32 = 0
        for visibleIdx in 0..<visibleCount:
            let targetModuleId = visibility.moduleVisibleModuleIds[visibleStart + visibleIdx]
            let localMatch = targetModuleId == ownerModuleId
            if (pass == 0 && !localMatch) || (pass == 1 && localMatch):
                continue
            var ordinal: int32 = 0
            if !compilerCoreResolveEnumMemberOrdinalInModulePath(enumArena,
                                                                 visibility.modulePaths[targetModuleId],
                                                                 memberName,
                                                                 ordinal):
                continue
            if matched:
                return false
            matched = true
            matchedOrdinal = ordinal
        if matched:
            outOrdinal = matchedOrdinal
            return true
    return false

fn compilerCoreResolveImportFieldItemInModule(importIndex: CompilerCoreImportHeaderIndex,
                                              valueIndex: CompilerCoreValueHeaderIndex,
                                              routineIndex: CompilerCoreRoutineHeaderIndex,
                                              visibility: CompilerCoreVisibilityIndex,
                                              ownerModulePath: str,
                                              importName: str,
                                              fieldName: str,
                                              resolvedKind: var str,
                                              resolvedItemId: var int32): bool =
    let ownerModuleId = compilerCoreFindModulePathSlot(visibility, ownerModulePath)
    if ownerModuleId < 0:
        return false
    let importBucketIdx = compilerCoreFindNamedBucket(importIndex.ownerModuleIds,
                                                      importIndex.visibleNames,
                                                      ownerModuleId,
                                                      importName)
    if importBucketIdx < 0:
        return false
    let importStart = importIndex.bucketStarts[importBucketIdx]
    let importCount = importIndex.bucketCounts[importBucketIdx]
    if importCount <= 0:
        return false
    let targetModuleId = importIndex.bucketTargetModuleIds[importStart]
    for i in 1..<importCount:
        if importIndex.bucketTargetModuleIds[importStart + i] != targetModuleId:
            return false
    var matchCount: int32 = 0
    let valueBucketIdx = compilerCoreFindNamedBucket(valueIndex.ownerModuleIds,
                                                     valueIndex.valueNames,
                                                     targetModuleId,
                                                     fieldName)
    if valueBucketIdx >= 0:
        let start = valueIndex.bucketStarts[valueBucketIdx]
        let count = valueIndex.bucketCounts[valueBucketIdx]
        for i in 0..<count:
            matchCount = matchCount + 1
            if matchCount > 1:
                return false
            resolvedKind = valueIndex.bucketKinds[start + i]
            resolvedItemId = valueIndex.bucketItemIds[start + i]
    let routineBucketIdx = compilerCoreFindNamedBucket(routineIndex.ownerModuleIds,
                                                       routineIndex.routineNames,
                                                       targetModuleId,
                                                       fieldName)
    if routineBucketIdx >= 0:
        let start = routineIndex.bucketStarts[routineBucketIdx]
        let count = routineIndex.bucketCounts[routineBucketIdx]
        for i in 0..<count:
            matchCount = matchCount + 1
            if matchCount > 1:
                return false
            resolvedKind = routineIndex.bucketKinds[start + i]
            resolvedItemId = routineIndex.bucketItemIds[start + i]
    return matchCount == 1

fn compilerCoreResolveImportEnumFieldOrdinalInModule(importIndex: CompilerCoreImportHeaderIndex,
                                                     visibility: CompilerCoreVisibilityIndex,
                                                     enumArena: CompilerCoreEnumMemberHeaderArena,
                                                     ownerModulePath: str,
                                                     importName: str,
                                                     fieldName: str,
                                                     outOrdinal: var int32): bool =
    let targetModulePath = compilerCoreFindImportModulePathInModule(importIndex,
                                                                    visibility,
                                                                    ownerModulePath,
                                                                    importName)
    if strings.len(targetModulePath) <= 0:
        return false
    return compilerCoreResolveEnumMemberOrdinalInModulePath(enumArena, targetModulePath, fieldName, outOrdinal)

fn compilerCoreQualifiedFieldName(baseName: str, fieldName: str): str =
    if strings.len(baseName) <= 0:
        return fieldName
    return baseName + "." + fieldName

fn compilerCoreGenericParamEntryName(entryText: str): str =
    let text = strutils.strip(entryText)
    if strings.len(text) <= 0:
        return ""
    for i in 0..<strings.len(text):
        let ch = text[i]
        if ch == ':' || ch == '=' || ch == ' ' || ch == '\t':
            return strings.sliceBytes(text, 0, i)
    return text

fn compilerCoreRoutineGenericParamSlot(signatureText: str,
                                       routineName: str,
                                       name: str): int32 =
    if strings.len(signatureText) <= 0 || strings.len(routineName) <= 0 || strings.len(name) <= 0:
        return -1
    let nameIdx = strings.find(signatureText, routineName)
    if nameIdx < 0:
        return -1
    var genericStart: int32 = nameIdx + strings.len(routineName)
    while genericStart < strings.len(signatureText) &&
          (signatureText[genericStart] == ' ' || signatureText[genericStart] == '\t'):
        genericStart = genericStart + 1
    if genericStart >= strings.len(signatureText) || signatureText[genericStart] != '[':
        return -1
    var depth: int32 = 1
    var entryStart: int32 = genericStart + 1
    var slot: int32 = 0
    for i in entryStart..<strings.len(signatureText):
        let ch = signatureText[i]
        if ch == '[':
            depth = depth + 1
        elif ch == ']':
            depth = depth - 1
            if depth == 0:
                let entryName = compilerCoreGenericParamEntryName(strings.sliceBytes(signatureText,
                                                                                     entryStart,
                                                                                     i - entryStart))
                if strings.len(entryName) > 0:
                    if entryName == name:
                        return slot
                return -1
        elif ch == ',' && depth == 1:
            let entryName = compilerCoreGenericParamEntryName(strings.sliceBytes(signatureText,
                                                                                 entryStart,
                                                                                 i - entryStart))
            if strings.len(entryName) > 0:
                if entryName == name:
                    return slot
                slot = slot + 1
            entryStart = i + 1
    return -1

fn compilerCoreRoutineGenericParamNameAtSlot(signatureText: str,
                                             routineName: str,
                                             slot: int32): str =
    if strings.len(signatureText) <= 0 || strings.len(routineName) <= 0 || slot < 0:
        return ""
    let nameIdx = strings.find(signatureText, routineName)
    if nameIdx < 0:
        return ""
    var genericStart: int32 = nameIdx + strings.len(routineName)
    while genericStart < strings.len(signatureText) &&
          (signatureText[genericStart] == ' ' || signatureText[genericStart] == '\t'):
        genericStart = genericStart + 1
    if genericStart >= strings.len(signatureText) || signatureText[genericStart] != '[':
        return ""
    var depth: int32 = 1
    var entryStart: int32 = genericStart + 1
    var currentSlot: int32 = 0
    for i in entryStart..<strings.len(signatureText):
        let ch = signatureText[i]
        if ch == '[':
            depth = depth + 1
        elif ch == ']':
            depth = depth - 1
            if depth == 0:
                if currentSlot == slot:
                    return compilerCoreGenericParamEntryName(strings.sliceBytes(signatureText,
                                                                               entryStart,
                                                                               i - entryStart))
                return ""
        elif ch == ',' && depth == 1:
            if currentSlot == slot:
                return compilerCoreGenericParamEntryName(strings.sliceBytes(signatureText,
                                                                           entryStart,
                                                                           i - entryStart))
            currentSlot = currentSlot + 1
            entryStart = i + 1
    return ""

fn compilerCoreRoutineImplicitTypeParamNameAtSlotInModule(program: ccore.CompilerCoreProgram,
                                                          importIndex: CompilerCoreImportHeaderIndex,
                                                          typeIndex: CompilerCoreTypeHeaderIndex,
                                                          visibility: CompilerCoreVisibilityIndex,
                                                          decl: ccore.CompilerCoreRoutineDecl,
                                                          ownerModulePath: str,
                                                          slot: int32): str =
    if slot < 0:
        return ""
    var implicitNames: str[]
    implicitNames = []
    for i in 0..<decl.paramCount:
        compilerCoreAppendImplicitTypeParamsFromTextInModule(program,
                                                             importIndex,
                                                             typeIndex,
                                                             visibility,
                                                             ownerModulePath,
                                                             program.routineParams[decl.paramStart + i].typeText,
                                                             implicitNames)
    compilerCoreAppendImplicitTypeParamsFromTextInModule(program,
                                                         importIndex,
                                                         typeIndex,
                                                         visibility,
                                                         ownerModulePath,
                                                         decl.returnTypeText,
                                                         implicitNames)
    if slot >= implicitNames.len:
        return ""
    return implicitNames[slot]

fn compilerCoreSubstituteTypeParamToken(text: str,
                                        paramName: str,
                                        replacementText: str): str =
    if strings.len(text) <= 0 || strings.len(paramName) <= 0:
        return text
    var out: str = ""
    var i: int32 = 0
    while i < strings.len(text):
        if !compilerCoreIsNameStart(text[i]):
            out = out + strings.sliceBytes(text, i, 1)
            i = i + 1
            continue
        let start = i
        i = i + 1
        while i < strings.len(text) && compilerCoreIsNameContinue(text[i]):
            i = i + 1
        let token = strings.sliceBytes(text, start, i - start)
        out = out + (token == paramName ? replacementText else: token)
    return out

fn compilerCoreIsNameStart(ch: char): bool =
    return (ch >= 'a' && ch <= 'z') ||
           (ch >= 'A' && ch <= 'Z') ||
           ch == '_'

fn compilerCoreIsNameContinue(ch: char): bool =
    return compilerCoreIsNameStart(ch) || (ch >= '0' && ch <= '9')

fn compilerCoreFindTextSlot(values: str[], value: str): int32 =
    for i in 0..<values.len:
        if values[i] == value:
            return i
    return -1

fn compilerCoreBuiltinTypeToken(text: str): bool =
    return text == "bool" ||
           text == "byte" ||
           text == "char" ||
           text == "int" ||
           text == "int8" ||
           text == "int16" ||
           text == "int32" ||
           text == "int64" ||
           text == "uint" ||
           text == "uint8" ||
           text == "uint16" ||
           text == "uint32" ||
           text == "uint64" ||
           text == "float" ||
           text == "float32" ||
           text == "float64" ||
           text == "str" ||
           text == "ptr" ||
           text == "cstring" ||
           text == "void" ||
           text == "nil" ||
           text == "typedesc" ||
           text == "ref" ||
           text == "var"

fn compilerCoreBuiltinCtorTypeToken(text: str): bool =
    return compilerCoreBuiltinTypeToken(text) &&
           text != "void" &&
           text != "nil" &&
           text != "typedesc" &&
           text != "ref" &&
           text != "var"

fn compilerCoreTextHasNameToken(text: str, token: str): bool =
    if strings.len(token) <= 0:
        return false
    var i: int32 = 0
    while i < strings.len(text):
        if !compilerCoreIsNameStart(text[i]):
            i = i + 1
            continue
        let start = i
        i = i + 1
        while i < strings.len(text) && compilerCoreIsNameContinue(text[i]):
            i = i + 1
        if strings.sliceBytes(text, start, i - start) == token:
            return true
    return false

fn compilerCoreTypeTextRawPointerViolation(typeText: str): str =
    let text = strutils.strip(typeText)
    if strings.len(text) <= 0:
        return ""
    if strings.find(text, "*") >= 0:
        return "pointer_star_type"
    if compilerCoreTextHasNameToken(text, "ptr"):
        return "ptr_type"
    if compilerCoreTextHasNameToken(text, "ref"):
        return "ref_type"
    return ""

fn compilerCoreTextHasArrowMemberAccess(text: str): bool =
    var i: int32 = 0
    var inString: bool = false
    var inChar: bool = false
    var escaped: bool = false
    while i < strings.len(text):
        let ch = text[i]
        if escaped:
            escaped = false
            i = i + 1
            continue
        if (inString || inChar) && ch == '\\':
            escaped = true
            i = i + 1
            continue
        if !inChar && ch == '"':
            inString = !inString
            i = i + 1
            continue
        if !inString && ch == '\'':
            inChar = !inChar
            i = i + 1
            continue
        if !inString && !inChar && ch == '-' && i + 1 < len(text) && text[i + 1] == '>':
            return true
        i = i + 1
    return false

fn compilerCoreExprRawPointerViolation(program: ccore.CompilerCoreProgram,
                                       exprId: int32): str =
    if exprId < 0:
        return ""
    let expr = program.exprs[exprId]
    if expr.kind == "unary" && expr.detailText == "addr_of":
        return "addr_of"
    if expr.kind != "call" || expr.childCount <= 0:
        return ""
    let calleeExprId = program.exprChildIds[expr.childStart]
    let calleeExpr = program.exprs[calleeExprId]
    if calleeExpr.kind == "name_ref":
        if calleeExpr.primaryText == "ptr":
            return "ptr_cast"
        if calleeExpr.primaryText == "alloc" || calleeExpr.primaryText == "dealloc":
            return "raw_allocator"
        if calleeExpr.primaryText == "ptr_add" ||
           calleeExpr.primaryText == "strDataPtr" ||
           calleeExpr.primaryText == "rawmemAsVoid" ||
           calleeExpr.primaryText == "copyMem" ||
           calleeExpr.primaryText == "setMem" ||
           calleeExpr.primaryText == "zeroMem" ||
           calleeExpr.primaryText == "load_ptr" ||
           calleeExpr.primaryText == "store_ptr" ||
           strings.startsWith(calleeExpr.primaryText, "rawmem"):
            return calleeExpr.primaryText
    if calleeExpr.kind == "field" && calleeExpr.childCount > 0:
        let baseExprId = program.exprChildIds[calleeExpr.childStart]
        let baseExpr = program.exprs[baseExprId]
        if baseExpr.kind == "name_ref" && baseExpr.primaryText == "rawmem_support":
            return "rawmem_support"
    return ""

fn compilerCoreSourcePathNeedsNoPointerPolicy(sourcePath: str): bool =
    if strings.len(sourcePath) <= 0:
        return false
    return strings.find(sourcePath, "/v2/src/") >= 0 ||
           strings.find(sourcePath, "/v2/tests/") >= 0 ||
           strings.find(sourcePath, "/v2/examples/") >= 0 ||
           strings.startsWith(sourcePath, "v2/src/") ||
           strings.startsWith(sourcePath, "v2/tests/") ||
           strings.startsWith(sourcePath, "v2/examples/") ||
           strings.startsWith(sourcePath, "../src/") ||
           strings.startsWith(sourcePath, "../tests/") ||
           strings.startsWith(sourcePath, "../examples/")

fn compilerCoreFirstNoPointerViolation(program: ccore.CompilerCoreProgram): str =
    var typeIdx: int32 = 0
    var constIdx: int32 = 0
    var varIdx: int32 = 0
    var routineIdx: int32 = 0
    for itemId in 0..<program.topLevelKinds.len:
        let kind = program.topLevelKinds[itemId]
        let label = program.topLevelLabels[itemId]
        let sourcePath =
            itemId < len(program.topLevelSourcePaths)
            ? program.topLevelSourcePaths[itemId]
            : ""
        if kind == "import":
            if itemId >= len(program.topLevelImportDeclIdxs):
                return "v2 semantic facts compiler_core: missing topLevelImportDeclIdx for item " + intToStr(itemId)
            let importIdx = program.topLevelImportDeclIdxs[itemId]
            if importIdx < 0 || importIdx >= len(program.imports):
                return "v2 semantic facts compiler_core: invalid topLevelImportDeclIdx " +
                       intToStr(importIdx) + " for item " + intToStr(itemId)
            let importPath = compilerCoreNormalizeImportModulePath(program.imports[importIdx].modulePath)
            if !compilerCoreSourcePathNeedsNoPointerPolicy(sourcePath):
                continue
            if importPath == "std/rawmem_support":
                return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids import " +
                       importPath + " in " + sourcePath
            continue
        if kind == "type":
            let block = program.typeBlocks[typeIdx]
            typeIdx = typeIdx + 1
            if !compilerCoreSourcePathNeedsNoPointerPolicy(sourcePath):
                continue
            for lineIdx in 0..<block.bodyLines.len:
                let rawLine = compilerCoreTrimInlineComment(block.bodyLines[lineIdx])
                if strings.len(rawLine) <= 0:
                    continue
                let reason = compilerCoreTypeTextRawPointerViolation(rawLine)
                if strings.len(reason) > 0:
                    return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids " +
                           reason + " in type block " + label + " at " + sourcePath
                if compilerCoreTextHasArrowMemberAccess(rawLine):
                    return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids pointer member access in type block " +
                           label + " at " + sourcePath
            continue
        if kind == "const":
            let decl = program.constDecls[constIdx]
            constIdx = constIdx + 1
            if !compilerCoreSourcePathNeedsNoPointerPolicy(sourcePath):
                continue
            let reason = compilerCoreTypeTextRawPointerViolation(decl.headerText)
            if strings.len(reason) > 0:
                return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids " +
                       reason + " in const " + label + " at " + sourcePath
            continue
        if kind == "var":
            let decl = program.varDecls[varIdx]
            varIdx = varIdx + 1
            if !compilerCoreSourcePathNeedsNoPointerPolicy(sourcePath):
                continue
            let reason = compilerCoreTypeTextRawPointerViolation(decl.headerText)
            if strings.len(reason) > 0:
                return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids " +
                       reason + " in var " + label + " at " + sourcePath
            continue
        if kind == "module":
            continue
        let decl = program.routines[routineIdx]
        routineIdx = routineIdx + 1
        if !compilerCoreSourcePathNeedsNoPointerPolicy(sourcePath):
            continue
        var reason = compilerCoreTypeTextRawPointerViolation(decl.signatureText)
        if strings.len(reason) > 0:
            return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids " +
                   reason + " in routine signature " + label + " at " + sourcePath
        reason = compilerCoreTypeTextRawPointerViolation(decl.returnTypeText)
        if strings.len(reason) > 0:
            return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids " +
                   reason + " in routine return type " + label + " at " + sourcePath
        for i in 0..<decl.paramCount:
            reason = compilerCoreTypeTextRawPointerViolation(program.routineParams[decl.paramStart + i].typeText)
            if strings.len(reason) > 0:
                return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids " +
                       reason + " in routine param " + label + "." +
                       program.routineParams[decl.paramStart + i].name + " at " + sourcePath
        for i in 0..<decl.localCount:
            reason = compilerCoreTypeTextRawPointerViolation(program.locals[decl.localStart + i].typeText)
            if strings.len(reason) > 0:
                return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids " +
                       reason + " in local " + label + "." +
                       program.locals[decl.localStart + i].name + " at " + sourcePath
        for i in 0..<decl.exprCount:
            reason = compilerCoreExprRawPointerViolation(program, decl.exprStart + i)
            if strings.len(reason) > 0:
                return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids " +
                       reason + " in routine body " + label + " at " + sourcePath
        for i in 0..<decl.bodyLines.len:
            let rawLine = compilerCoreTrimInlineComment(decl.bodyLines[i])
            if strings.len(rawLine) > 0 && compilerCoreTextHasArrowMemberAccess(rawLine):
                return "v2 semantic facts compiler_core: ZRPC no-pointer policy forbids pointer member access in routine body " +
                       label + " at " + sourcePath
    return ""

fn compilerCoreRequireNoPointerSurfaceFree(program: ccore.CompilerCoreProgram) =
    let reason = compilerCoreFirstNoPointerViolation(program)
    if strings.len(reason) > 0:
        compilerCoreFactsPanic(reason)

fn compilerCoreTypeTokenIsImplicitParamCandidateInModule(program: ccore.CompilerCoreProgram,
                                                         importIndex: CompilerCoreImportHeaderIndex,
                                                         typeIndex: CompilerCoreTypeHeaderIndex,
                                                         visibility: CompilerCoreVisibilityIndex,
                                                         ownerModulePath: str,
                                                         token: str): bool =
    if strings.len(token) <= 0:
        return false
    if compilerCoreBuiltinTypeToken(token):
        return false
    if strings.find(token, ".") >= 0:
        return false
    if compilerCoreFindVisibleTypeItemIdInModule(typeIndex, visibility, ownerModulePath, token) >= 0:
        return false
    if compilerCoreFindImportVisibleItemIdInModule(importIndex, visibility, ownerModulePath, token) >= 0:
        return false
    return true

fn compilerCoreAppendImplicitTypeParamsFromTextInModule(program: ccore.CompilerCoreProgram,
                                                        importIndex: CompilerCoreImportHeaderIndex,
                                                        typeIndex: CompilerCoreTypeHeaderIndex,
                                                        visibility: CompilerCoreVisibilityIndex,
                                                        ownerModulePath: str,
                                                        typeText: str,
                                                        outNames: var str[]) =
    var i: int32 = 0
    while i < strings.len(typeText):
        if !compilerCoreIsNameStart(typeText[i]):
            i = i + 1
            continue
        let start = i
        i = i + 1
        while i < strings.len(typeText) && compilerCoreIsNameContinue(typeText[i]):
            i = i + 1
        var token = strings.sliceBytes(typeText, start, i - start)
        var tokenEnd = i
        while tokenEnd < strings.len(typeText) && typeText[tokenEnd] == '.':
            let nextStart = tokenEnd + 1
            if nextStart >= strings.len(typeText) || !compilerCoreIsNameStart(typeText[nextStart]):
                break
            var nextEnd = nextStart + 1
            while nextEnd < strings.len(typeText) && compilerCoreIsNameContinue(typeText[nextEnd]):
                nextEnd = nextEnd + 1
            token = token + "." + strings.sliceBytes(typeText, nextStart, nextEnd - nextStart)
            tokenEnd = nextEnd
        i = tokenEnd
        if compilerCoreTypeTokenIsImplicitParamCandidateInModule(program,
                                                                 importIndex,
                                                                 typeIndex,
                                                                 visibility,
                                                                 ownerModulePath,
                                                                 token) &&
           compilerCoreFindTextSlot(outNames, token) < 0:
            seqs.add(outNames, token)

fn compilerCoreRoutineImplicitTypeParamSlotInModule(program: ccore.CompilerCoreProgram,
                                                    importIndex: CompilerCoreImportHeaderIndex,
                                                    typeIndex: CompilerCoreTypeHeaderIndex,
                                                    visibility: CompilerCoreVisibilityIndex,
                                                    decl: ccore.CompilerCoreRoutineDecl,
                                                    ownerModulePath: str,
                                                    name: str): int32 =
    if strings.len(name) <= 0:
        return -1
    var implicitNames: str[]
    implicitNames = []
    for i in 0..<decl.paramCount:
        compilerCoreAppendImplicitTypeParamsFromTextInModule(program,
                                                             importIndex,
                                                             typeIndex,
                                                             visibility,
                                                             ownerModulePath,
                                                             program.routineParams[decl.paramStart + i].typeText,
                                                             implicitNames)
    compilerCoreAppendImplicitTypeParamsFromTextInModule(program,
                                                         importIndex,
                                                         typeIndex,
                                                         visibility,
                                                         ownerModulePath,
                                                         decl.returnTypeText,
                                                         implicitNames)
    return compilerCoreFindTextSlot(implicitNames, name)

fn compilerCoreExprReferenceKindInModule(program: ccore.CompilerCoreProgram,
                                         importIndex: CompilerCoreImportHeaderIndex,
                                         enumArena: CompilerCoreEnumMemberHeaderArena,
                                         typeIndex: CompilerCoreTypeHeaderIndex,
                                         valueIndex: CompilerCoreValueHeaderIndex,
                                         routineIndex: CompilerCoreRoutineHeaderIndex,
                                         visibility: CompilerCoreVisibilityIndex,
                                         decl: ccore.CompilerCoreRoutineDecl,
                                         ownerModulePath: str,
                                         sourcePath: str,
                                         exprId: int32,
                                         outTargetKind: var str,
                                         outTargetText: var str,
                                         outTargetItemId: var int32,
                                         outValueInt: var int32): str =
    outTargetKind = ""
    outTargetText = ""
    outTargetItemId = -1
    outValueInt = -1
    if exprId < 0:
        return "none"
    let expr = program.exprs[exprId]
    if expr.kind == "name_ref":
        let paramSlot = compilerCoreFindParamSlot(program, decl, expr.primaryText)
        if paramSlot >= 0:
            outValueInt = paramSlot
            return "param"
        let localSlot = compilerCoreFindLocalSlot(program, decl, expr.primaryText)
        if localSlot >= 0:
            outValueInt = localSlot
            return "local"
        let genericParamSlot = compilerCoreRoutineGenericParamSlot(decl.signatureText,
                                                                   decl.name,
                                                                   expr.primaryText)
        if genericParamSlot >= 0:
            outTargetKind = "type_param"
            outTargetText = expr.primaryText
            outValueInt = genericParamSlot
            return "name"
        let implicitParamSlot = compilerCoreRoutineImplicitTypeParamSlotInModule(program,
                                                                                 importIndex,
                                                                                 typeIndex,
                                                                                 visibility,
                                                                                 decl,
                                                                                 ownerModulePath,
                                                                                 expr.primaryText)
        if implicitParamSlot >= 0:
            outTargetKind = "type_param"
            outTargetText = expr.primaryText
            outValueInt = implicitParamSlot
            return "name"
        let typeItemId = compilerCoreFindVisibleTypeItemIdInModule(typeIndex,
                                                                   visibility,
                                                                   ownerModulePath,
                                                                   expr.primaryText)
        if typeItemId >= 0:
            outTargetKind = "type"
            outTargetItemId = typeItemId
            return "name"
        let importItemId = compilerCoreFindImportVisibleItemIdInModule(importIndex,
                                                                       visibility,
                                                                       ownerModulePath,
                                                                       expr.primaryText)
        if importItemId >= 0:
            outTargetItemId = importItemId
            return "import_visible"
        let topLevelKind = compilerCoreFindVisibleTopLevelKindInModule(valueIndex,
                                                                       routineIndex,
                                                                       visibility,
                                                                       ownerModulePath,
                                                                       expr.primaryText,
                                                                       false,
                                                                       true,
                                                                       true)
        let topLevelItemId = compilerCoreFindVisibleTopLevelItemIdInModule(valueIndex,
                                                                           routineIndex,
                                                                           visibility,
                                                                           ownerModulePath,
                                                                           expr.primaryText,
                                                                           false,
                                                                           true,
                                                                           true)
        if topLevelKind == "fn" || topLevelKind == "iterator" || topLevelKind == "importc_fn":
            outTargetKind = topLevelKind
            outTargetItemId = topLevelItemId
            return "routine"
        if topLevelKind == "const" || topLevelKind == "var":
            outTargetKind = topLevelKind
            outTargetItemId = topLevelItemId
            return "global"
        if topLevelKind == "import":
            outTargetItemId = topLevelItemId
            return "import_visible"
        var enumOrdinal: int32 = 0
        if compilerCoreResolveVisibleEnumMemberOrdinalInModule(enumArena,
                                                               visibility,
                                                               ownerModulePath,
                                                               expr.primaryText,
                                                               enumOrdinal):
            outValueInt = enumOrdinal
            return "enum_member"
        outTargetKind = topLevelKind
        outTargetItemId = topLevelItemId
        return "name"
    if expr.kind == "field" && expr.childCount > 0:
        let baseExprId = program.exprChildIds[expr.childStart]
        let baseExpr = program.exprs[baseExprId]
        if baseExpr.kind == "name_ref":
            var resolvedKind: str = ""
            var resolvedItemId: int32 = -1
            var enumOrdinal: int32 = 0
            if compilerCoreResolveImportFieldItemInModule(importIndex,
                                                          valueIndex,
                                                          routineIndex,
                                                          visibility,
                                                          ownerModulePath,
                                                          baseExpr.primaryText,
                                                          expr.primaryText,
                                                          resolvedKind,
                                                          resolvedItemId):
                outTargetKind = resolvedKind
                outTargetText = compilerCoreQualifiedFieldName(baseExpr.primaryText, expr.primaryText)
                outTargetItemId = resolvedItemId
                if resolvedKind == "fn" || resolvedKind == "iterator" || resolvedKind == "importc_fn":
                    return "import_field_routine"
                return "import_field_global"
            if compilerCoreResolveImportEnumFieldOrdinalInModule(importIndex,
                                                                 visibility,
                                                                 enumArena,
                                                                 ownerModulePath,
                                                                 baseExpr.primaryText,
                                                                 expr.primaryText,
                                                                 enumOrdinal):
                outValueInt = enumOrdinal
                outTargetText = compilerCoreQualifiedFieldName(baseExpr.primaryText, expr.primaryText)
                return "import_field_enum"
        return "field_access"
    if expr.kind == "index":
        return "index_access"
    if expr.kind == "call":
        return "call"
    return "none"

fn compilerCoreExprTypeConstructorTextInModule(program: ccore.CompilerCoreProgram,
                                               importIndex: CompilerCoreImportHeaderIndex,
                                               enumArena: CompilerCoreEnumMemberHeaderArena,
                                               typeArena: CompilerCoreTypeHeaderArena,
                                               typeIndex: CompilerCoreTypeHeaderIndex,
                                               valueIndex: CompilerCoreValueHeaderIndex,
                                               routineIndex: CompilerCoreRoutineHeaderIndex,
                                               visibility: CompilerCoreVisibilityIndex,
                                               decl: ccore.CompilerCoreRoutineDecl,
                                               ownerModulePath: str,
                                               sourcePath: str,
                                               exprId: int32): str =
    if exprId < 0:
        return ""
    let expr = program.exprs[exprId]
    if expr.kind == "name_ref":
        if compilerCoreBuiltinCtorTypeToken(expr.primaryText):
            return expr.primaryText
        var targetKind: str = ""
        var targetText: str = ""
        var targetItemId: int32 = -1
        var valueInt: int32 = -1
        let referenceKind = compilerCoreExprReferenceKindInModule(program,
                                                                  importIndex,
                                                                  enumArena,
                                                                  typeIndex,
                                                                  valueIndex,
                                                                  routineIndex,
                                                                  visibility,
                                                                  decl,
                                                                  ownerModulePath,
                                                                  sourcePath,
                                                                  exprId,
                                                                  targetKind,
                                                                  targetText,
                                                                  targetItemId,
                                                                  valueInt)
        if referenceKind == "name" &&
           (targetKind == "type" || targetKind == "type_param"):
            return expr.primaryText
        return ""
    if expr.kind == "index" && expr.childCount == 2:
        let baseText = compilerCoreExprTypeConstructorTextInModule(program,
                                                                   importIndex,
                                                                   enumArena,
                                                                   typeArena,
                                                                   typeIndex,
                                                                   valueIndex,
                                                                   routineIndex,
                                                                   visibility,
                                                                   decl,
                                                                   ownerModulePath,
                                                                   sourcePath,
                                                                   program.exprChildIds[expr.childStart])
        let argText = compilerCoreExprTypeConstructorTextInModule(program,
                                                                  importIndex,
                                                                  enumArena,
                                                                  typeArena,
                                                                  typeIndex,
                                                                  valueIndex,
                                                                  routineIndex,
                                                                  visibility,
                                                                  decl,
                                                                  ownerModulePath,
                                                                  sourcePath,
                                                                  program.exprChildIds[expr.childStart + 1])
        if strings.len(baseText) <= 0 || strings.len(argText) <= 0:
            return ""
        return baseText + "[" + argText + "]"
    if expr.kind == "suffix_ctor" && expr.childCount == 1 && expr.primaryText == "[]":
        let baseText = compilerCoreExprTypeConstructorTextInModule(program,
                                                                   importIndex,
                                                                   enumArena,
                                                                   typeArena,
                                                                   typeIndex,
                                                                   valueIndex,
                                                                   routineIndex,
                                                                   visibility,
                                                                   decl,
                                                                   ownerModulePath,
                                                                   sourcePath,
                                                                   program.exprChildIds[expr.childStart])
        if strings.len(baseText) <= 0:
            return ""
        return baseText + "[]"
    return ""

fn compilerCoreCallHasUnnamedSingleArg(program: ccore.CompilerCoreProgram,
                                       exprId: int32): bool =
    if exprId < 0:
        return false
    let expr = program.exprs[exprId]
    if expr.kind != "call" || expr.childCount != 2:
        return false
    return strings.len(program.exprChildArgNames[expr.childStart + 1]) <= 0

fn compilerCoreResolveTransparentTypeAliasInModule(program: ccore.CompilerCoreProgram,
                                                   importIndex: CompilerCoreImportHeaderIndex,
                                                   visibility: CompilerCoreVisibilityIndex,
                                                   typeArena: CompilerCoreTypeHeaderArena,
                                                   typeIndex: CompilerCoreTypeHeaderIndex,
                                                   ownerModulePath: str,
                                                   typeText: str,
                                                   depth: int32): str =
    let wasVar = compilerCoreCallTypeIsVar(typeText)
    let normalized = compilerCoreNormalizeCallTypeText(typeText)
    if strings.len(normalized) <= 0 || depth > 8:
        if wasVar:
            return "var " + normalized
        return normalized
    var targetModulePath: str = ownerModulePath
    var targetTypeName: str = normalized
    let dotIdx = strings.find(normalized, ".")
    if dotIdx > 0:
        targetModulePath = compilerCoreResolveTypeModulePathInModule(importIndex,
                                                                     visibility,
                                                                     ownerModulePath,
                                                                     strings.sliceBytes(normalized, 0, dotIdx))
        if strings.len(targetModulePath) <= 0:
            if wasVar:
                return "var " + normalized
            return normalized
        targetTypeName = strutils.strip(strings.sliceBytes(normalized, dotIdx + 1, strings.len(normalized) - dotIdx - 1))
    let typeItemId = compilerCoreFindTypeItemIdInModulePath(typeIndex,
                                                            visibility,
                                                            targetModulePath,
                                                            targetTypeName)
    if typeItemId < 0:
        if wasVar:
            return "var " + normalized
        return normalized
    let typeIdx = compilerCoreTypeBodyIndexForItemId(typeArena, typeItemId)
    if typeIdx < 0:
        if wasVar:
            return "var " + normalized
        return normalized
    let aliasType = compilerCoreTransparentAliasTargetText(
        compilerCoreTypeBlockAliasText(program.typeBlocks[typeIdx].bodyLines, targetTypeName))
    if strings.len(aliasType) <= 0:
        if wasVar:
            return "var " + normalized
            return normalized
    let resolved = compilerCoreResolveTransparentTypeAliasInModule(program,
                                                                   importIndex,
                                                                   visibility,
                                                                   typeArena,
                                                                   typeIndex,
                                                                   targetModulePath,
                                                                   aliasType,
                                                                   depth + 1)
    if wasVar && !compilerCoreCallTypeIsVar(resolved):
        return "var " + compilerCoreNormalizeCallTypeText(resolved)
    return resolved

fn compilerCoreRoutineIndexForTopLevelItem(program: ccore.CompilerCoreProgram,
                                           itemId: int32,
                                           routineArena: CompilerCoreRoutineHeaderArena): int32 =
    if itemId < 0 || itemId >= routineArena.itemIdToRoutineDeclIdxs.len:
        return -1
    return routineArena.itemIdToRoutineDeclIdxs[itemId]

fn compilerCoreRoutineReturnTypeTextForTopLevelItem(program: ccore.CompilerCoreProgram,
                                                    importIndex: CompilerCoreImportHeaderIndex,
                                                    visibility: CompilerCoreVisibilityIndex,
                                                    typeArena: CompilerCoreTypeHeaderArena,
                                                    typeIndex: CompilerCoreTypeHeaderIndex,
                                                    routineArena: CompilerCoreRoutineHeaderArena,
                                                    itemId: int32): str =
    let routineIdx = compilerCoreRoutineIndexForTopLevelItem(program, itemId, routineArena)
    if routineIdx < 0:
        return ""
    return compilerCoreCanonicalizeQualifiedTypeTextInModule(importIndex,
                                                             visibility,
                                                             program,
                                                             typeArena,
                                                             typeIndex,
                                                             compilerCoreTopLevelModulePath(program, itemId),
                                                             program.routines[routineIdx].returnTypeText)

fn compilerCoreExplicitGenericRoutineCallFactsInModule(program: ccore.CompilerCoreProgram,
                                                       importIndex: CompilerCoreImportHeaderIndex,
                                                       enumArena: CompilerCoreEnumMemberHeaderArena,
                                                       typeArena: CompilerCoreTypeHeaderArena,
                                                       typeIndex: CompilerCoreTypeHeaderIndex,
                                                       valueIndex: CompilerCoreValueHeaderIndex,
                                                       routineArena: CompilerCoreRoutineHeaderArena,
                                                       routineIndex: CompilerCoreRoutineHeaderIndex,
                                                       visibility: CompilerCoreVisibilityIndex,
                                                       decl: ccore.CompilerCoreRoutineDecl,
                                                       ownerModulePath: str,
                                                       sourcePath: str,
                                                       exprId: int32,
                                                       outTargetKind: var str,
                                                       outTargetText: var str,
                                                       outTargetItemId: var int32,
                                                       outTypeArgText: var str): bool =
    outTargetKind = ""
    outTargetText = ""
    outTargetItemId = -1
    outTypeArgText = ""
    if exprId < 0:
        return false
    let expr = program.exprs[exprId]
    if expr.kind != "call" || expr.childCount <= 0:
        return false
    let calleeExprId = program.exprChildIds[expr.childStart]
    let calleeExpr = program.exprs[calleeExprId]
    if calleeExpr.kind != "index" || calleeExpr.childCount != 2:
        return false
    let baseExprId = program.exprChildIds[calleeExpr.childStart]
    let typeArgExprId = program.exprChildIds[calleeExpr.childStart + 1]
    outTypeArgText = compilerCoreExprTypeConstructorTextInModule(program,
                                                                 importIndex,
                                                                 enumArena,
                                                                 typeArena,
                                                                 typeIndex,
                                                                 valueIndex,
                                                                 routineIndex,
                                                                 visibility,
                                                                 decl,
                                                                 ownerModulePath,
                                                                 sourcePath,
                                                                 typeArgExprId)
    if strings.len(outTypeArgText) <= 0:
        return false
    let baseExpr = program.exprs[baseExprId]
    if baseExpr.kind == "field" && baseExpr.childCount == 1:
        let importBaseExpr = program.exprs[program.exprChildIds[baseExpr.childStart]]
        if importBaseExpr.kind == "name_ref":
            let resolvedImportRoutineItemId = compilerCoreResolveImportFieldRoutineItemIdForCallInModule(program,
                                                                                                         importIndex,
                                                                                                         enumArena,
                                                                                                         typeArena,
                                                                                                         typeIndex,
                                                                                                         valueIndex,
                                                                                                         routineArena,
                                                                                                         routineIndex,
                                                                                                         visibility,
                                                                                                         decl,
                                                                                                         importBaseExpr.primaryText,
                                                                                                         baseExpr.primaryText,
                                                                                                         ownerModulePath,
                                                                                                         sourcePath,
                                                                                                         exprId)
            if resolvedImportRoutineItemId >= 0:
                outTargetKind = "import_field_routine"
                outTargetText = importBaseExpr.primaryText + "." + baseExpr.primaryText
                outTargetItemId = resolvedImportRoutineItemId
                return true
            if resolvedImportRoutineItemId == -2:
                outTargetKind = "overload_unresolved"
                outTargetText = importBaseExpr.primaryText + "." + baseExpr.primaryText
                return true
    var referenceTargetKind: str = ""
    var referenceTargetText: str = ""
    var referenceTargetItemId: int32 = -1
    var referenceValueInt: int32 = -1
    let referenceKind = compilerCoreExprReferenceKindInModule(program,
                                                              importIndex,
                                                              enumArena,
                                                              typeIndex,
                                                              valueIndex,
                                                              routineIndex,
                                                              visibility,
                                                              decl,
                                                              ownerModulePath,
                                                              sourcePath,
                                                              baseExprId,
                                                              referenceTargetKind,
                                                              referenceTargetText,
                                                              referenceTargetItemId,
                                                              referenceValueInt)
    if referenceKind == "routine" || referenceKind == "import_field_routine":
        outTargetKind = referenceKind == "routine" ? "routine" else: "import_field_routine"
        outTargetText = referenceKind == "import_field_routine" ? referenceTargetText else: baseExpr.primaryText
        outTargetItemId = referenceTargetItemId
        return true
    if baseExpr.kind == "name_ref":
        let resolvedRoutineItemId = compilerCoreResolveRoutineItemIdForCallInModule(program,
                                                                                    importIndex,
                                                                                    enumArena,
                                                                                    typeArena,
                                                                                    typeIndex,
                                                                                    valueIndex,
                                                                                    routineArena,
                                                                                    routineIndex,
                                                                                    visibility,
                                                                                    decl,
                                                                                    baseExpr.primaryText,
                                                                                    ownerModulePath,
                                                                                    sourcePath,
                                                                                    exprId)
        if resolvedRoutineItemId >= 0:
            outTargetKind = "routine"
            outTargetText = baseExpr.primaryText
            outTargetItemId = resolvedRoutineItemId
            return true
        if resolvedRoutineItemId == -2:
            outTargetKind = "overload_unresolved"
            outTargetText = baseExpr.primaryText
            return true
        return false
    return false

fn compilerCoreExplicitGenericRoutineReturnTypeTextForCallInModule(program: ccore.CompilerCoreProgram,
                                                                   importIndex: CompilerCoreImportHeaderIndex,
                                                                   enumArena: CompilerCoreEnumMemberHeaderArena,
                                                                   typeArena: CompilerCoreTypeHeaderArena,
                                                                   typeIndex: CompilerCoreTypeHeaderIndex,
                                                                   valueIndex: CompilerCoreValueHeaderIndex,
                                                                   routineArena: CompilerCoreRoutineHeaderArena,
                                                                   routineIndex: CompilerCoreRoutineHeaderIndex,
                                                                   visibility: CompilerCoreVisibilityIndex,
                                                                   decl: ccore.CompilerCoreRoutineDecl,
                                                                   ownerModulePath: str,
                                                                   sourcePath: str,
                                                                   exprId: int32): str =
    var targetKind: str = ""
    var targetText: str = ""
    var targetItemId: int32 = -1
    var typeArgText: str = ""
    if !compilerCoreExplicitGenericRoutineCallFactsInModule(program,
                                                            importIndex,
                                                            enumArena,
                                                            typeArena,
                                                            typeIndex,
                                                            valueIndex,
                                                            routineArena,
                                                            routineIndex,
                                                            visibility,
                                                            decl,
                                                            ownerModulePath,
                                                            sourcePath,
                                                            exprId,
                                                            targetKind,
                                                            targetText,
                                                            targetItemId,
                                                            typeArgText):
        return ""
    if strings.len(targetKind) <= 0 || targetKind == "overload_unresolved" || targetItemId < 0:
        return ""
    let routineIdx = compilerCoreRoutineIndexForTopLevelItem(program, targetItemId, routineArena)
    if routineIdx < 0:
        return ""
    let genericParamName = compilerCoreRoutineGenericParamNameAtSlot(program.routines[routineIdx].signatureText,
                                                                     program.routines[routineIdx].name,
                                                                     0)
    let genericName = strings.len(genericParamName) > 0
        ? genericParamName
        : compilerCoreRoutineImplicitTypeParamNameAtSlotInModule(program,
                                                                 importIndex,
                                                                 typeIndex,
                                                                 visibility,
                                                                 program.routines[routineIdx],
                                                                 compilerCoreTopLevelModulePath(program, targetItemId),
                                                                 0)
    if strings.len(genericName) <= 0:
        return ""
    let substituted = compilerCoreSubstituteTypeParamToken(program.routines[routineIdx].returnTypeText,
                                                           genericName,
                                                           typeArgText)
    return compilerCoreCanonicalizeQualifiedTypeTextInModule(importIndex,
                                                             visibility,
                                                             program,
                                                             typeArena,
                                                             typeIndex,
                                                             compilerCoreTopLevelModulePath(program, targetItemId),
                                                             substituted)

fn compilerCoreExprKnownTypeTextForCallResolutionInModule(program: ccore.CompilerCoreProgram,
                                                          importIndex: CompilerCoreImportHeaderIndex,
                                                          enumArena: CompilerCoreEnumMemberHeaderArena,
                                                          typeArena: CompilerCoreTypeHeaderArena,
                                                          typeIndex: CompilerCoreTypeHeaderIndex,
                                                          valueIndex: CompilerCoreValueHeaderIndex,
                                                          routineArena: CompilerCoreRoutineHeaderArena,
                                                          routineIndex: CompilerCoreRoutineHeaderIndex,
                                                          visibility: CompilerCoreVisibilityIndex,
                                                          callerDecl: ccore.CompilerCoreRoutineDecl,
                                                          ownerModulePath: str,
                                                          sourcePath: str,
                                                          exprId: int32): str =
    if exprId < 0:
        return ""
    let expr = program.exprs[exprId]
    if expr.kind == "name_ref":
        let paramSlot = compilerCoreFindParamSlot(program, callerDecl, expr.primaryText)
        if paramSlot >= 0:
            let param = program.routineParams[callerDecl.paramStart + paramSlot]
            if param.kind == "var_param" && !strings.startsWith(strutils.strip(param.typeText), "var "):
                return "var " + strutils.strip(param.typeText)
            return param.typeText
        let localSlot = compilerCoreFindLocalSlot(program, callerDecl, expr.primaryText)
        if localSlot >= 0:
            let local = program.locals[callerDecl.localStart + localSlot]
            var localTypeText = local.typeText
            if strings.len(localTypeText) <= 0 && local.initExprId >= 0:
                localTypeText = compilerCoreExprKnownTypeTextForCallResolutionInModule(program,
                                                                                       importIndex,
                                                                                       enumArena,
                                                                                       typeArena,
                                                                                       typeIndex,
                                                                                       valueIndex,
                                                                                       routineArena,
                                                                                       routineIndex,
                                                                                       visibility,
                                                                                       callerDecl,
                                                                                       ownerModulePath,
                                                                                       sourcePath,
                                                                                       local.initExprId)
            if local.kind == "var" &&
               strings.len(localTypeText) > 0 &&
               !strings.startsWith(strutils.strip(localTypeText), "var "):
                return "var " + strutils.strip(localTypeText)
            return localTypeText
        return ""
    if expr.kind == "bool_lit":
        return "bool"
    if expr.kind == "str_lit":
        return "str"
    if expr.kind == "char_lit":
        return "char"
    if expr.kind == "float_lit":
        return "float64"
    if expr.kind == "nil_lit":
        return "nil"
    if expr.kind == "int_lit":
        var value32: int32 = 0
        if compilerCoreParseInt32Text(expr.primaryText, value32):
            return "int32"
        return "int64"
    if expr.kind == "call" && expr.childCount > 0:
        let calleeExprId = program.exprChildIds[expr.childStart]
        let ctorText = compilerCoreExprTypeConstructorTextInModule(program,
                                                                   importIndex,
                                                                   enumArena,
                                                                   typeArena,
                                                                   typeIndex,
                                                                   valueIndex,
                                                                   routineIndex,
                                                                   visibility,
                                                                   callerDecl,
                                                                   ownerModulePath,
                                                                   sourcePath,
                                                                   calleeExprId)
        if strings.len(ctorText) > 0:
            return ctorText
        let explicitGenericReturnType = compilerCoreExplicitGenericRoutineReturnTypeTextForCallInModule(program,
                                                                                                        importIndex,
                                                                                                        enumArena,
                                                                                                        typeArena,
                                                                                                        typeIndex,
                                                                                                        valueIndex,
                                                                                                        routineArena,
                                                                                                        routineIndex,
                                                                                                        visibility,
                                                                                                        callerDecl,
                                                                                                        ownerModulePath,
                                                                                                        sourcePath,
                                                                                                        exprId)
        if strings.len(explicitGenericReturnType) > 0:
            return explicitGenericReturnType
        let calleeExpr = program.exprs[calleeExprId]
        if calleeExpr.kind == "name_ref":
            let routineItemId = compilerCoreResolveRoutineItemIdForCallInModule(program,
                                                                                importIndex,
                                                                                enumArena,
                                                                                typeArena,
                                                                                typeIndex,
                                                                                valueIndex,
                                                                                routineArena,
                                                                                routineIndex,
                                                                                visibility,
                                                                                callerDecl,
                                                                                calleeExpr.primaryText,
                                                                                ownerModulePath,
                                                                                sourcePath,
                                                                                exprId)
            let returnTypeText = compilerCoreRoutineReturnTypeTextForTopLevelItem(program,
                                                                                  importIndex,
                                                                                  visibility,
                                                                                  typeArena,
                                                                                  typeIndex,
                                                                                  routineArena,
                                                                                  routineItemId)
            if strings.len(returnTypeText) > 0:
                return returnTypeText
            return ""
        var targetKind: str = ""
        var targetText: str = ""
        var targetItemId: int32 = -1
        var valueInt: int32 = -1
        let referenceKind = compilerCoreExprReferenceKindInModule(program,
                                                                  importIndex,
                                                                  enumArena,
                                                                  typeIndex,
                                                                  valueIndex,
                                                                  routineIndex,
                                                                  visibility,
                                                                  callerDecl,
                                                                  ownerModulePath,
                                                                  sourcePath,
                                                                  calleeExprId,
                                                                  targetKind,
                                                                  targetText,
                                                                  targetItemId,
                                                                  valueInt)
        if referenceKind == "routine" || referenceKind == "import_field_routine":
            let returnTypeText = compilerCoreRoutineReturnTypeTextForTopLevelItem(program,
                                                                                  importIndex,
                                                                                  visibility,
                                                                                  typeArena,
                                                                                  typeIndex,
                                                                                  routineArena,
                                                                                  targetItemId)
            if strings.len(returnTypeText) > 0:
                return returnTypeText
        return ""
    if expr.kind == "field" && expr.childCount > 0:
        let baseExprId = program.exprChildIds[expr.childStart]
        let baseTypeText = compilerCoreExprKnownTypeTextForCallResolutionInModule(program,
                                                                                  importIndex,
                                                                                  enumArena,
                                                                                  typeArena,
                                                                                  typeIndex,
                                                                                  valueIndex,
                                                                                  routineArena,
                                                                                  routineIndex,
                                                                                  visibility,
                                                                                  callerDecl,
                                                                                  ownerModulePath,
                                                                                  sourcePath,
                                                                                  baseExprId)
    let baseType = compilerCoreNormalizeCallTypeText(compilerCoreResolveTransparentTypeAliasInModule(program,
                                                                                                         importIndex,
                                                                                                         visibility,
                                                                                                         typeArena,
                                                                                                         typeIndex,
                                                                                                         ownerModulePath,
                                                                                                         baseTypeText,
                                                                                                         0))
        if strings.len(baseType) <= 0:
            return ""
        if expr.primaryText == "len":
            var suffixBase: str = ""
            var suffixArg: str = ""
            if compilerCoreCallTypeIsStrlike(baseType) ||
               compilerCoreNormalizeCallTypeText(baseType) == "Bytes" ||
               (compilerCoreTypeTextSplitSuffixCtor(baseType, suffixBase, suffixArg) && suffixBase == "[]"):
                return "int32"
        var baseModulePath: str = ""
        var baseTypeName: str = baseType
        let dotIdx = strings.find(baseType, ".")
        if dotIdx > 0:
            baseModulePath = compilerCoreResolveTypeModulePathInModule(importIndex,
                                                                       visibility,
                                                                       ownerModulePath,
                                                                       strings.sliceBytes(baseType, 0, dotIdx))
            baseTypeName = strutils.strip(strings.sliceBytes(baseType, dotIdx + 1, strings.len(baseType) - dotIdx - 1))
        var typeItemId: int32 = -1
        if strings.len(baseModulePath) > 0:
            typeItemId = compilerCoreFindTypeItemIdInModulePath(typeIndex, visibility, baseModulePath, baseTypeName)
        else:
            typeItemId = compilerCoreFindVisibleTypeItemIdInModule(typeIndex, visibility, ownerModulePath, baseTypeName)
        if typeItemId < 0:
            return ""
        let typeIdx = compilerCoreTypeBodyIndexForItemId(typeArena, typeItemId)
        if typeIdx < 0:
            return ""
        let fieldType = compilerCoreTypeBlockFieldType(program.typeBlocks[typeIdx].bodyLines,
                                                       baseTypeName,
                                                       expr.primaryText)
        if strings.len(fieldType) <= 0:
            return ""
        let canonicalFieldType = compilerCoreCanonicalizeQualifiedTypeTextInModule(importIndex,
                                                                                   visibility,
                                                                                   program,
                                                                                   typeArena,
                                                                                   typeIndex,
                                                                                   compilerCoreTopLevelModulePath(program, typeItemId),
                                                                                   fieldType)
        if compilerCoreCallTypeIsVar(baseTypeText):
            return "var " + compilerCoreNormalizeCallTypeText(canonicalFieldType)
        return canonicalFieldType
    if expr.kind == "index" && expr.childCount == 2:
        let baseExprId = program.exprChildIds[expr.childStart]
        let baseTypeText = compilerCoreExprKnownTypeTextForCallResolutionInModule(program,
                                                                                  importIndex,
                                                                                  enumArena,
                                                                                  typeArena,
                                                                                  typeIndex,
                                                                                  valueIndex,
                                                                                  routineArena,
                                                                                  routineIndex,
                                                                                  visibility,
                                                                                  callerDecl,
                                                                                  ownerModulePath,
                                                                                  sourcePath,
                                                                                  baseExprId)
        return compilerCoreIndexedElementTypeTextInModule(program,
                                                          importIndex,
                                                          visibility,
                                                          typeArena,
                                                          typeIndex,
                                                          ownerModulePath,
                                                          baseTypeText)
    if expr.kind == "unary" && expr.childCount > 0:
        if expr.detailText == "not":
            return "bool"
        if expr.detailText == "neg":
            let operandTypeText = compilerCoreExprKnownTypeTextForCallResolutionInModule(program,
                                                                                 importIndex,
                                                                                 enumArena,
                                                                                 typeArena,
                                                                                 typeIndex,
                                                                                 valueIndex,
                                                                                 routineArena,
                                                                                 routineIndex,
                                                                                 visibility,
                                                                                 callerDecl,
                                                                                 ownerModulePath,
                                                                                 sourcePath,
                                                                                 program.exprChildIds[expr.childStart])
            if compilerCoreCallTypeIsInt32ish(operandTypeText):
                return "int32"
            if compilerCoreCallTypeIsInt64ish(operandTypeText):
                return "int64"
            if compilerCoreCallTypeIsFloat64ish(operandTypeText):
                return "float64"
        return ""
    if expr.kind == "binary" && expr.childCount == 2:
        if expr.detailText == "lt" || expr.detailText == "le" ||
           expr.detailText == "gt" || expr.detailText == "ge" ||
           expr.detailText == "eq" || expr.detailText == "ne" ||
           expr.detailText == "logical_and" || expr.detailText == "logical_or":
            return "bool"
        if expr.detailText == "add" || expr.detailText == "sub" ||
           expr.detailText == "mul" || expr.detailText == "div" ||
           expr.detailText == "mod" || expr.detailText == "bitwise_and" ||
           expr.detailText == "bitwise_or" || expr.detailText == "bitwise_xor" ||
           expr.detailText == "shift_left" || expr.detailText == "shift_right":
            let lhsTypeText = compilerCoreExprKnownTypeTextForCallResolutionInModule(program,
                                                                             importIndex,
                                                                             enumArena,
                                                                             typeArena,
                                                                             typeIndex,
                                                                             valueIndex,
                                                                             routineArena,
                                                                             routineIndex,
                                                                             visibility,
                                                                             callerDecl,
                                                                             ownerModulePath,
                                                                             sourcePath,
                                                                             program.exprChildIds[expr.childStart])
            let rhsTypeText = compilerCoreExprKnownTypeTextForCallResolutionInModule(program,
                                                                             importIndex,
                                                                             enumArena,
                                                                             typeArena,
                                                                             typeIndex,
                                                                             valueIndex,
                                                                             routineArena,
                                                                             routineIndex,
                                                                             visibility,
                                                                             callerDecl,
                                                                             ownerModulePath,
                                                                             sourcePath,
                                                                             program.exprChildIds[expr.childStart + 1])
            if expr.detailText == "add" &&
               compilerCoreCallTypeIsStrlike(lhsTypeText) &&
               compilerCoreCallTypeIsStrlike(rhsTypeText):
                return "str"
            let lhsInt32 = compilerCoreCallTypeIsInt32ish(lhsTypeText)
            let rhsInt32 = compilerCoreCallTypeIsInt32ish(rhsTypeText)
            if lhsInt32 && rhsInt32:
                return "int32"
            let lhsInt64 = lhsInt32 || compilerCoreCallTypeIsInt64ish(lhsTypeText)
            let rhsInt64 = rhsInt32 || compilerCoreCallTypeIsInt64ish(rhsTypeText)
            if lhsInt64 && rhsInt64:
                return "int64"
            if compilerCoreCallTypeIsFloat64ish(lhsTypeText) &&
               compilerCoreCallTypeIsFloat64ish(rhsTypeText):
                return "float64"
    return ""

fn compilerCoreExprRecordFieldOrdinalInModule(program: ccore.CompilerCoreProgram,
                                              importIndex: CompilerCoreImportHeaderIndex,
                                              enumArena: CompilerCoreEnumMemberHeaderArena,
                                              typeArena: CompilerCoreTypeHeaderArena,
                                              typeIndex: CompilerCoreTypeHeaderIndex,
                                              valueIndex: CompilerCoreValueHeaderIndex,
                                              routineArena: CompilerCoreRoutineHeaderArena,
                                              routineIndex: CompilerCoreRoutineHeaderIndex,
                                              visibility: CompilerCoreVisibilityIndex,
                                              callerDecl: ccore.CompilerCoreRoutineDecl,
                                              ownerModulePath: str,
                                              sourcePath: str,
                                              exprId: int32): int32 =
    if exprId < 0:
        return -1
    let expr = program.exprs[exprId]
    if expr.kind != "field" || expr.childCount <= 0:
        return -1
    let baseExprId = program.exprChildIds[expr.childStart]
    let baseTypeText = compilerCoreExprKnownTypeTextForCallResolutionInModule(program,
                                                                              importIndex,
                                                                              enumArena,
                                                                              typeArena,
                                                                              typeIndex,
                                                                              valueIndex,
                                                                              routineArena,
                                                                              routineIndex,
                                                                              visibility,
                                                                              callerDecl,
                                                                              ownerModulePath,
                                                                              sourcePath,
                                                                              baseExprId)
    let baseType = compilerCoreNormalizeCallTypeText(compilerCoreResolveTransparentTypeAliasInModule(program,
                                                                                                      importIndex,
                                                                                                      visibility,
                                                                                                      typeArena,
                                                                                                      typeIndex,
                                                                                                      ownerModulePath,
                                                                                                      baseTypeText,
                                                                                                      0))
    if strings.len(baseType) <= 0:
        return -1
    if expr.primaryText == "len":
        return -1
    var suffixBase: str = ""
    var suffixArg: str = ""
    if compilerCoreCallTypeIsStrlike(baseType) ||
       compilerCoreNormalizeCallTypeText(baseType) == "Bytes" ||
       (compilerCoreTypeTextSplitSuffixCtor(baseType, suffixBase, suffixArg) && suffixBase == "[]"):
        return -1
    var baseModulePath: str = ""
    var baseTypeName: str = baseType
    let dotIdx = strings.find(baseType, ".")
    if dotIdx > 0:
        baseModulePath = compilerCoreResolveTypeModulePathInModule(importIndex,
                                                                   visibility,
                                                                   ownerModulePath,
                                                                   strings.sliceBytes(baseType, 0, dotIdx))
        baseTypeName = strutils.strip(strings.sliceBytes(baseType, dotIdx + 1, strings.len(baseType) - dotIdx - 1))
    var typeItemId: int32 = -1
    if strings.len(baseModulePath) > 0:
        typeItemId = compilerCoreFindTypeItemIdInModulePath(typeIndex, visibility, baseModulePath, baseTypeName)
    else:
        typeItemId = compilerCoreFindVisibleTypeItemIdInModule(typeIndex, visibility, ownerModulePath, baseTypeName)
    if typeItemId < 0:
        return -1
    let typeIdx = compilerCoreTypeBodyIndexForItemId(typeArena, typeItemId)
    if typeIdx < 0:
        return -1
    return compilerCoreTypeBlockFieldOrdinal(program.typeBlocks[typeIdx].bodyLines,
                                             baseTypeName,
                                             expr.primaryText)

fn compilerCoreNormalizeCallTypeText(typeText: str): str =
    var text = strutils.strip(typeText)
    while strings.startsWith(text, "var "):
        text = strutils.strip(strings.sliceBytes(text, 4, strings.len(text) - 4))
    return text

fn compilerCoreCallTypeIsInt32ish(typeText: str): bool =
    let text = compilerCoreNormalizeCallTypeText(typeText)
    return text == "int" || text == "int32"

fn compilerCoreCallTypeIsInt64ish(typeText: str): bool =
    return compilerCoreNormalizeCallTypeText(typeText) == "int64"

fn compilerCoreCallTypeIsFloat64ish(typeText: str): bool =
    let text = compilerCoreNormalizeCallTypeText(typeText)
    return text == "float64" || text == "float"

fn compilerCoreCallTypeIsStrlike(typeText: str): bool =
    let text = compilerCoreNormalizeCallTypeText(typeText)
    return text == "str" || text == "cstring"

fn compilerCoreCallTypeIsVar(typeText: str): bool =
    return strings.startsWith(strutils.strip(typeText), "var ")

fn compilerCoreTypeTextIsRoutineTypeParamInModule(program: ccore.CompilerCoreProgram,
                                                  importIndex: CompilerCoreImportHeaderIndex,
                                                  typeIndex: CompilerCoreTypeHeaderIndex,
                                                  visibility: CompilerCoreVisibilityIndex,
                                                  decl: ccore.CompilerCoreRoutineDecl,
                                                  ownerModulePath: str,
                                                  typeText: str): bool =
    return compilerCoreRoutineGenericParamSlot(decl.signatureText, decl.name, typeText) >= 0 ||
           compilerCoreRoutineImplicitTypeParamSlotInModule(program,
                                                            importIndex,
                                                            typeIndex,
                                                            visibility,
                                                            decl,
                                                            ownerModulePath,
                                                            typeText) >= 0

fn compilerCoreTypeTextSplitSingleArgCtor(typeText: str,
                                          outBase: var str,
                                          outArg: var str): bool =
    let text = strutils.strip(typeText)
    outBase = ""
    outArg = ""
    let openIdx = strings.find(text, "[")
    if openIdx <= 0 || !strings.endsWith(text, "]"):
        return false
    var depth: int32 = 0
    for i in openIdx..<strings.len(text):
        let ch = text[i]
        if ch == '[':
            depth = depth + 1
        elif ch == ']':
            depth = depth - 1
            if depth == 0:
                if i != strings.len(text) - 1:
                    return false
                outBase = strutils.strip(strings.sliceBytes(text, 0, openIdx))
                outArg = strutils.strip(strings.sliceBytes(text,
                                                           openIdx + 1,
                                                           i - openIdx - 1))
                return strings.len(outBase) > 0 && strings.len(outArg) > 0
        elif ch == ',' && depth == 1:
            return false
    return false

fn compilerCoreTypeTextSplitSuffixCtor(typeText: str,
                                       outBase: var str,
                                       outArg: var str): bool =
    let text = strutils.strip(typeText)
    outBase = ""
    outArg = ""
    if strings.len(text) <= 2:
        return false
    if strings.endsWith(text, "[]"):
        outBase = "[]"
        outArg = strutils.strip(strings.sliceBytes(text, 0, strings.len(text) - 2))
        return strings.len(outArg) > 0
    if strings.endsWith(text, "*"):
        outBase = "*"
        outArg = strutils.strip(strings.sliceBytes(text, 0, strings.len(text) - 1))
        return strings.len(outArg) > 0
    return false

fn compilerCoreIndexedElementTypeTextInModule(program: ccore.CompilerCoreProgram,
                                              importIndex: CompilerCoreImportHeaderIndex,
                                              visibility: CompilerCoreVisibilityIndex,
                                              typeArena: CompilerCoreTypeHeaderArena,
                                              typeIndex: CompilerCoreTypeHeaderIndex,
                                              ownerModulePath: str,
                                              baseTypeText: str): str =
    let resolved = compilerCoreResolveTransparentTypeAliasInModule(program,
                                                                   importIndex,
                                                                   visibility,
                                                                   typeArena,
                                                                   typeIndex,
                                                                   ownerModulePath,
                                                                   baseTypeText,
                                                                   0)
    let normalized = compilerCoreNormalizeCallTypeText(resolved)
    if normalized == "str":
        return "char"
    var suffixBase: str = ""
    var suffixArg: str = ""
    if compilerCoreTypeTextSplitSuffixCtor(normalized, suffixBase, suffixArg) &&
       suffixBase == "[]":
        if compilerCoreCallTypeIsVar(baseTypeText):
            return "var " + suffixArg
        return suffixArg
    return ""

fn compilerCoreTypeMatchScoreInModule(program: ccore.CompilerCoreProgram,
                                      importIndex: CompilerCoreImportHeaderIndex,
                                      typeIndex: CompilerCoreTypeHeaderIndex,
                                      typeArena: CompilerCoreTypeHeaderArena,
                                      valueIndex: CompilerCoreValueHeaderIndex,
                                      routineArena: CompilerCoreRoutineHeaderArena,
                                      routineIndex: CompilerCoreRoutineHeaderIndex,
                                      visibility: CompilerCoreVisibilityIndex,
                                      decl: ccore.CompilerCoreRoutineDecl,
                                      actualOwnerModulePath: str,
                                      patternOwnerModulePath: str,
                                      actualTypeText: str,
                                      patternTypeText: str): int32 =
    let actualCanonical = compilerCoreCanonicalizeQualifiedTypeTextInModule(importIndex,
                                                                            visibility,
                                                                            program,
                                                                            typeArena,
                                                                            typeIndex,
                                                                            actualOwnerModulePath,
                                                                            actualTypeText)
    let patternCanonical = compilerCoreCanonicalizeQualifiedTypeTextInModule(importIndex,
                                                                             visibility,
                                                                             program,
                                                                             typeArena,
                                                                             typeIndex,
                                                                             patternOwnerModulePath,
                                                                             patternTypeText)
    let actual = compilerCoreNormalizeCallTypeText(compilerCoreResolveTransparentTypeAliasInModule(program,
                                                                                                   importIndex,
                                                                                                   visibility,
                                                                                                   typeArena,
                                                                                                   typeIndex,
                                                                                                   actualOwnerModulePath,
                                                                                                   actualCanonical,
                                                                                                   0))
    let pattern = compilerCoreNormalizeCallTypeText(compilerCoreResolveTransparentTypeAliasInModule(program,
                                                                                                    importIndex,
                                                                                                    visibility,
                                                                                                    typeArena,
                                                                                                    typeIndex,
                                                                                                    patternOwnerModulePath,
                                                                                                    patternCanonical,
                                                                                                    0))
    let actualIsVar = compilerCoreCallTypeIsVar(actualCanonical)
    let patternIsVar = compilerCoreCallTypeIsVar(patternCanonical)
    if strings.len(actual) <= 0 || strings.len(pattern) <= 0:
        return -1
    if actual == pattern:
        if patternIsVar:
            if actualIsVar:
                return 6
            return -1
        if actualIsVar:
            return 5
        return 4
    if compilerCoreTypeTextIsRoutineTypeParamInModule(program,
                                                      importIndex,
                                                      typeIndex,
                                                      visibility,
                                                      decl,
                                                      patternOwnerModulePath,
                                                      pattern):
        return 1
    if strings.startsWith(actual, "ref ") && strings.startsWith(pattern, "ref "):
        let innerScore = compilerCoreTypeMatchScoreInModule(program,
                                                            importIndex,
                                                            typeIndex,
                                                            typeArena,
                                                            valueIndex,
                                                            routineArena,
                                                            routineIndex,
                                                            visibility,
                                                            decl,
                                                            actualOwnerModulePath,
                                                            patternOwnerModulePath,
                                                            strings.sliceBytes(actual, 4, strings.len(actual) - 4),
                                                            strings.sliceBytes(pattern, 4, strings.len(pattern) - 4))
        if innerScore >= 0:
            return innerScore + 1
        return -1
    var actualSuffixBase: str = ""
    var actualSuffixArg: str = ""
    var patternSuffixBase: str = ""
    var patternSuffixArg: str = ""
    if compilerCoreTypeTextSplitSuffixCtor(actual, actualSuffixBase, actualSuffixArg) &&
       compilerCoreTypeTextSplitSuffixCtor(pattern, patternSuffixBase, patternSuffixArg) &&
       actualSuffixBase == patternSuffixBase:
        let innerScore = compilerCoreTypeMatchScoreInModule(program,
                                                            importIndex,
                                                            typeIndex,
                                                            typeArena,
                                                            valueIndex,
                                                            routineArena,
                                                            routineIndex,
                                                            visibility,
                                                            decl,
                                                            actualOwnerModulePath,
                                                            patternOwnerModulePath,
                                                            actualSuffixArg,
                                                            patternSuffixArg)
        if innerScore >= 0:
            return innerScore + 2
    var actualBase: str = ""
    var actualArg: str = ""
    var patternBase: str = ""
    var patternArg: str = ""
    if compilerCoreTypeTextSplitSingleArgCtor(actual, actualBase, actualArg) &&
       compilerCoreTypeTextSplitSingleArgCtor(pattern, patternBase, patternArg) &&
       actualBase == patternBase:
        let innerScore = compilerCoreTypeMatchScoreInModule(program,
                                                            importIndex,
                                                            typeIndex,
                                                            typeArena,
                                                            valueIndex,
                                                            routineArena,
                                                            routineIndex,
                                                            visibility,
                                                            decl,
                                                            actualOwnerModulePath,
                                                            patternOwnerModulePath,
                                                            actualArg,
                                                            patternArg)
        if innerScore >= 0:
            return innerScore + 2
    return -1

fn compilerCoreRoutineCallScoreInModule(program: ccore.CompilerCoreProgram,
                                        importIndex: CompilerCoreImportHeaderIndex,
                                        enumArena: CompilerCoreEnumMemberHeaderArena,
                                        typeArena: CompilerCoreTypeHeaderArena,
                                        typeIndex: CompilerCoreTypeHeaderIndex,
                                        valueIndex: CompilerCoreValueHeaderIndex,
                                        routineArena: CompilerCoreRoutineHeaderArena,
                                        routineIndex: CompilerCoreRoutineHeaderIndex,
                                        visibility: CompilerCoreVisibilityIndex,
                                        callerDecl: ccore.CompilerCoreRoutineDecl,
                                        calleeDecl: ccore.CompilerCoreRoutineDecl,
                                        callerOwnerModulePath: str,
                                        calleeOwnerModulePath: str,
                                        sourcePath: str,
                                        exprId: int32): int32 =
    if exprId < 0:
        return -1
    let expr = program.exprs[exprId]
    let argCount = expr.childCount - 1
    if expr.kind != "call" || argCount != calleeDecl.paramCount:
        return -1
    var totalScore: int32 = 0
    for i in 0..<argCount:
        let argName = program.exprChildArgNames[expr.childStart + 1 + i]
        if strings.len(argName) > 0 &&
           program.routineParams[calleeDecl.paramStart + i].name != argName:
            return -1
        let argTypeText = compilerCoreExprKnownTypeTextForCallResolutionInModule(program,
                                                                                 importIndex,
                                                                                 enumArena,
                                                                                 typeArena,
                                                                                 typeIndex,
                                                                                 valueIndex,
                                                                                 routineArena,
                                                                                 routineIndex,
                                                                                 visibility,
                                                                                 callerDecl,
                                                                                 callerOwnerModulePath,
                                                                                 sourcePath,
                                                                                 program.exprChildIds[expr.childStart + 1 + i])
        let paramTypeText = program.routineParams[calleeDecl.paramStart + i].typeText
        if strings.len(argTypeText) > 0 && argTypeText != "nil":
            let score = compilerCoreTypeMatchScoreInModule(program,
                                                           importIndex,
                                                           typeIndex,
                                                           typeArena,
                                                           valueIndex,
                                                           routineArena,
                                                           routineIndex,
                                                           visibility,
                                                           calleeDecl,
                                                           callerOwnerModulePath,
                                                           calleeOwnerModulePath,
                                                           argTypeText,
                                                           paramTypeText)
            if score < 0:
                return -1
            totalScore = totalScore + score
    return totalScore

fn compilerCoreResolveRoutineItemIdForCallInModule(program: ccore.CompilerCoreProgram,
                                                   importIndex: CompilerCoreImportHeaderIndex,
                                                   enumArena: CompilerCoreEnumMemberHeaderArena,
                                                   typeArena: CompilerCoreTypeHeaderArena,
                                                   typeIndex: CompilerCoreTypeHeaderIndex,
                                                   valueIndex: CompilerCoreValueHeaderIndex,
                                                   routineArena: CompilerCoreRoutineHeaderArena,
                                                   routineIndex: CompilerCoreRoutineHeaderIndex,
                                                   visibility: CompilerCoreVisibilityIndex,
                                                   callerDecl: ccore.CompilerCoreRoutineDecl,
                                                   label: str,
                                                   ownerModulePath: str,
                                                   sourcePath: str,
                                                   exprId: int32): int32 =
    let ownerModuleId = compilerCoreFindModulePathSlot(visibility, ownerModulePath)
    if ownerModuleId < 0:
        return -1
    for pass in 0..<2:
        var visibleLabelCount: int32 = 0
        var bestScore: int32 = -1
        var matchedItemId: int32 = -1
        let visibleStart = visibility.moduleVisibleStarts[ownerModuleId]
        let visibleCount = visibility.moduleVisibleCounts[ownerModuleId]
        for visibleIdx in 0..<visibleCount:
            let targetModuleId = visibility.moduleVisibleModuleIds[visibleStart + visibleIdx]
            let localMatch = targetModuleId == ownerModuleId
            if (pass == 0 && !localMatch) || (pass == 1 && localMatch):
                continue
            let bucketIdx = compilerCoreFindNamedBucket(routineIndex.ownerModuleIds,
                                                        routineIndex.routineNames,
                                                        targetModuleId,
                                                        label)
            if bucketIdx < 0:
                continue
            let start = routineIndex.bucketStarts[bucketIdx]
            let count = routineIndex.bucketCounts[bucketIdx]
            visibleLabelCount = visibleLabelCount + count
            for i in 0..<count:
                var calleeOwnerModulePath: str = ""
                if targetModuleId >= 0 && targetModuleId < visibility.modulePaths.len:
                    calleeOwnerModulePath = visibility.modulePaths[targetModuleId]
                let score = compilerCoreRoutineCallScoreInModule(program,
                                                                 importIndex,
                                                                 enumArena,
                                                                 typeArena,
                                                                 typeIndex,
                                                                 valueIndex,
                                                                 routineArena,
                                                                 routineIndex,
                                                                 visibility,
                                                                 callerDecl,
                                                                 program.routines[routineIndex.bucketDeclIdxs[start + i]],
                                                                 ownerModulePath,
                                                                 calleeOwnerModulePath,
                                                                 sourcePath,
                                                                 exprId)
                if score >= 0:
                    if score > bestScore:
                        bestScore = score
                        matchedItemId = routineIndex.bucketItemIds[start + i]
                    elif score == bestScore:
                        return -2
        if visibleLabelCount > 0:
            if matchedItemId >= 0:
                return matchedItemId
            if visibleLabelCount > 1:
                return -2
            return -1
    return -1

fn compilerCoreResolveImportFieldRoutineItemIdForCallInModule(program: ccore.CompilerCoreProgram,
                                                              importIndex: CompilerCoreImportHeaderIndex,
                                                              enumArena: CompilerCoreEnumMemberHeaderArena,
                                                              typeArena: CompilerCoreTypeHeaderArena,
                                                              typeIndex: CompilerCoreTypeHeaderIndex,
                                                              valueIndex: CompilerCoreValueHeaderIndex,
                                                              routineArena: CompilerCoreRoutineHeaderArena,
                                                              routineIndex: CompilerCoreRoutineHeaderIndex,
                                                              visibility: CompilerCoreVisibilityIndex,
                                                              callerDecl: ccore.CompilerCoreRoutineDecl,
                                                              importName: str,
                                                              fieldName: str,
                                                              ownerModulePath: str,
                                                              sourcePath: str,
                                                              exprId: int32): int32 =
    let targetModulePath = compilerCoreFindImportModulePathInModule(importIndex,
                                                                    ownerModulePath,
                                                                    importName)
    if strings.len(targetModulePath) <= 0:
        return -1
    let targetModuleId = compilerCoreFindModulePathSlot(visibility, targetModulePath)
    if targetModuleId < 0:
        return -1
    let bucketIdx = compilerCoreFindNamedBucket(routineIndex.ownerModuleIds,
                                                routineIndex.routineNames,
                                                targetModuleId,
                                                fieldName)
    if bucketIdx < 0:
        return -1
    let start = routineIndex.bucketStarts[bucketIdx]
    let count = routineIndex.bucketCounts[bucketIdx]
    var bestScore: int32 = -1
    var matchedItemId: int32 = -1
    for i in 0..<count:
        let score = compilerCoreRoutineCallScoreInModule(program,
                                                         importIndex,
                                                         enumArena,
                                                         typeArena,
                                                         typeIndex,
                                                         valueIndex,
                                                         routineArena,
                                                         routineIndex,
                                                         visibility,
                                                         callerDecl,
                                                         program.routines[routineIndex.bucketDeclIdxs[start + i]],
                                                         ownerModulePath,
                                                         targetModulePath,
                                                         sourcePath,
                                                         exprId)
        if score >= 0:
            if score > bestScore:
                bestScore = score
                matchedItemId = routineIndex.bucketItemIds[start + i]
            elif score == bestScore:
                return -2
    if matchedItemId >= 0:
        return matchedItemId
    if count > 1:
        return -2
    return -1

fn compilerCoreCallTargetFactsInModule(program: ccore.CompilerCoreProgram,
                                       importIndex: CompilerCoreImportHeaderIndex,
                                       enumArena: CompilerCoreEnumMemberHeaderArena,
                                       typeArena: CompilerCoreTypeHeaderArena,
                                       typeIndex: CompilerCoreTypeHeaderIndex,
                                       valueIndex: CompilerCoreValueHeaderIndex,
                                       routineArena: CompilerCoreRoutineHeaderArena,
                                       routineIndex: CompilerCoreRoutineHeaderIndex,
                                       visibility: CompilerCoreVisibilityIndex,
                                       decl: ccore.CompilerCoreRoutineDecl,
                                       ownerModulePath: str,
                                       sourcePath: str,
                                       exprId: int32,
                                       outTargetKind: var str,
                                       outTargetText: var str,
                                       outTargetItemId: var int32) =
    outTargetKind = "none"
    outTargetText = ""
    outTargetItemId = -1
    if exprId < 0:
        return
    let expr = program.exprs[exprId]
    if expr.kind != "call" || expr.childCount <= 0:
        return
    let calleeExprId = program.exprChildIds[expr.childStart]
    let calleeExpr = program.exprs[calleeExprId]
    if calleeExpr.kind == "name_ref" &&
       expr.childCount == 2 &&
       (calleeExpr.primaryText == "int32" ||
        calleeExpr.primaryText == "int64" ||
        calleeExpr.primaryText == "ptr" ||
        calleeExpr.primaryText == "cstring"):
        if calleeExpr.primaryText == "int32":
            outTargetKind = "cast_int32"
        elif calleeExpr.primaryText == "int64":
            outTargetKind = "cast_int64"
        else:
            outTargetKind = "scalar_ctor"
        outTargetText = calleeExpr.primaryText
        return
    if calleeExpr.kind == "name_ref" &&
       calleeExpr.primaryText == "new" &&
       expr.childCount == 2:
        let typeArgText = compilerCoreExprTypeConstructorTextInModule(program,
                                                                      importIndex,
                                                                      enumArena,
                                                                      typeArena,
                                                                      typeIndex,
                                                                      valueIndex,
                                                                      routineIndex,
                                                                      visibility,
                                                                      decl,
                                                                      ownerModulePath,
                                                                      sourcePath,
                                                                      program.exprChildIds[expr.childStart + 1])
        if strings.len(typeArgText) > 0:
            outTargetKind = "new_ref_ctor"
            outTargetText = typeArgText
            return
    let ctorText = compilerCoreExprTypeConstructorTextInModule(program,
                                                               importIndex,
                                                               enumArena,
                                                               typeArena,
                                                               typeIndex,
                                                               valueIndex,
                                                               routineIndex,
                                                               visibility,
                                                               decl,
                                                               ownerModulePath,
                                                               sourcePath,
                                                               calleeExprId)
    if strings.len(ctorText) > 0:
        if compilerCoreCallHasUnnamedSingleArg(program, exprId):
            outTargetKind = "scalar_ctor"
        else:
            outTargetKind = "record_ctor"
        outTargetText = ctorText
        return
    var explicitGenericTargetKind: str = ""
    var explicitGenericTargetText: str = ""
    var explicitGenericTargetItemId: int32 = -1
    var explicitGenericTypeArgText: str = ""
    if compilerCoreExplicitGenericRoutineCallFactsInModule(program,
                                                           importIndex,
                                                           enumArena,
                                                           typeArena,
                                                           typeIndex,
                                                           valueIndex,
                                                           routineArena,
                                                           routineIndex,
                                                           visibility,
                                                           decl,
                                                           ownerModulePath,
                                                           sourcePath,
                                                           exprId,
                                                           explicitGenericTargetKind,
                                                           explicitGenericTargetText,
                                                           explicitGenericTargetItemId,
                                                           explicitGenericTypeArgText):
        outTargetKind = explicitGenericTargetKind
        outTargetText = explicitGenericTargetText
        outTargetItemId = explicitGenericTargetItemId
        return
    if calleeExpr.kind == "field" && calleeExpr.childCount == 1:
        let baseExpr = program.exprs[program.exprChildIds[calleeExpr.childStart]]
        if baseExpr.kind == "name_ref":
            let resolvedImportRoutineItemId = compilerCoreResolveImportFieldRoutineItemIdForCallInModule(program,
                                                                                                         importIndex,
                                                                                                         enumArena,
                                                                                                         typeArena,
                                                                                                         typeIndex,
                                                                                                         valueIndex,
                                                                                                         routineArena,
                                                                                                         routineIndex,
                                                                                                         visibility,
                                                                                                         decl,
                                                                                                         baseExpr.primaryText,
                                                                                                         calleeExpr.primaryText,
                                                                                                         ownerModulePath,
                                                                                                         sourcePath,
                                                                                                         exprId)
            if resolvedImportRoutineItemId >= 0:
                outTargetKind = "import_field_routine"
                outTargetText = baseExpr.primaryText + "." + calleeExpr.primaryText
                outTargetItemId = resolvedImportRoutineItemId
                return
            if resolvedImportRoutineItemId == -2:
                outTargetKind = "overload_unresolved"
                outTargetText = baseExpr.primaryText + "." + calleeExpr.primaryText
                return
    if calleeExpr.kind == "name_ref":
        let resolvedRoutineItemId = compilerCoreResolveRoutineItemIdForCallInModule(program,
                                                                                    importIndex,
                                                                                    enumArena,
                                                                                    typeArena,
                                                                                    typeIndex,
                                                                                    valueIndex,
                                                                                    routineArena,
                                                                                    routineIndex,
                                                                                    visibility,
                                                                                    decl,
                                                                                    calleeExpr.primaryText,
                                                                                    ownerModulePath,
                                                                                    sourcePath,
                                                                                    exprId)
        if resolvedRoutineItemId >= 0:
            outTargetKind = "routine"
            outTargetText = calleeExpr.primaryText
            outTargetItemId = resolvedRoutineItemId
            return
        if resolvedRoutineItemId == -2:
            outTargetKind = "overload_unresolved"
            outTargetText = calleeExpr.primaryText
            return
    var referenceTargetKind: str = ""
    var referenceTargetText: str = ""
    var referenceTargetItemId: int32 = -1
    var referenceValueInt: int32 = -1
    let referenceKind = compilerCoreExprReferenceKindInModule(program,
                                                              importIndex,
                                                              enumArena,
                                                              typeIndex,
                                                              valueIndex,
                                                              routineIndex,
                                                              visibility,
                                                              decl,
                                                              ownerModulePath,
                                                              sourcePath,
                                                              calleeExprId,
                                                              referenceTargetKind,
                                                              referenceTargetText,
                                                              referenceTargetItemId,
                                                              referenceValueInt)
    if referenceKind == "routine":
        outTargetKind = "routine"
        outTargetText = calleeExpr.primaryText
        outTargetItemId = referenceTargetItemId
        return
    if referenceKind == "import_field_routine":
        outTargetKind = "import_field_routine"
        outTargetText = referenceTargetText
        outTargetItemId = referenceTargetItemId
        return

fn compilerCoreAssignTargetFactsInModule(program: ccore.CompilerCoreProgram,
                                         importIndex: CompilerCoreImportHeaderIndex,
                                         enumArena: CompilerCoreEnumMemberHeaderArena,
                                         typeArena: CompilerCoreTypeHeaderArena,
                                         typeIndex: CompilerCoreTypeHeaderIndex,
                                         valueIndex: CompilerCoreValueHeaderIndex,
                                         routineArena: CompilerCoreRoutineHeaderArena,
                                         routineIndex: CompilerCoreRoutineHeaderIndex,
                                         visibility: CompilerCoreVisibilityIndex,
                                         decl: ccore.CompilerCoreRoutineDecl,
                                         ownerModulePath: str,
                                         sourcePath: str,
                                         stmtId: int32,
                                         outTargetKind: var str,
                                         outTargetText: var str,
                                         outTargetOwnerText: var str,
                                         outTargetValueInt: var int32,
                                         outTargetFieldOrdinal: var int32) =
    outTargetKind = "none"
    outTargetText = ""
    outTargetOwnerText = ""
    outTargetValueInt = -1
    outTargetFieldOrdinal = -1
    let stmt = program.stmts[stmtId]
    if stmt.kind != "assign" || stmt.primaryExprId < 0:
        return
    let lhsExpr = program.exprs[stmt.primaryExprId]
    if lhsExpr.kind == "name_ref":
        outTargetText = lhsExpr.primaryText
        let localSlot = compilerCoreFindLocalSlot(program, decl, lhsExpr.primaryText)
        if localSlot >= 0:
            outTargetKind = "local"
            outTargetValueInt = localSlot
            return
        let paramSlot = compilerCoreFindParamSlot(program, decl, lhsExpr.primaryText)
        if paramSlot >= 0:
            outTargetKind = "param"
            outTargetValueInt = paramSlot
            return
        outTargetKind = "name"
        return
    if lhsExpr.kind == "field" && lhsExpr.childCount > 0:
        let baseExprId = program.exprChildIds[lhsExpr.childStart]
        outTargetText = lhsExpr.primaryText
        outTargetFieldOrdinal = compilerCoreExprRecordFieldOrdinalInModule(program,
                                                                           importIndex,
                                                                           enumArena,
                                                                           typeArena,
                                                                           typeIndex,
                                                                           valueIndex,
                                                                           routineArena,
                                                                           routineIndex,
                                                                           visibility,
                                                                           decl,
                                                                           ownerModulePath,
                                                                           sourcePath,
                                                                           stmt.primaryExprId)
        if program.exprs[baseExprId].kind == "name_ref":
            var baseTargetKind: str = ""
            var baseTargetText: str = ""
            var baseTargetItemId: int32 = -1
            var baseValueInt: int32 = -1
            let baseReferenceKind = compilerCoreExprReferenceKindInModule(program,
                                                                          importIndex,
                                                                          enumArena,
                                                                          typeIndex,
                                                                          valueIndex,
                                                                          routineIndex,
                                                                          visibility,
                                                                          decl,
                                                                          ownerModulePath,
                                                                          sourcePath,
                                                                          baseExprId,
                                                                          baseTargetKind,
                                                                          baseTargetText,
                                                                          baseTargetItemId,
                                                                          baseValueInt)
            if baseReferenceKind == "local":
                outTargetKind = "local_field"
                outTargetOwnerText = program.exprs[baseExprId].primaryText
                outTargetValueInt = baseValueInt
                return
            if baseReferenceKind == "param":
                outTargetKind = "param_field"
                outTargetOwnerText = program.exprs[baseExprId].primaryText
                outTargetValueInt = baseValueInt
                return
        outTargetKind = "field"
        return
    if lhsExpr.kind == "index" && lhsExpr.childCount == 2:
        outTargetKind = "index"
        return
    outTargetKind = "unsupported"
    outTargetText = lhsExpr.primaryText

fn compilerCoreStmtSemanticTag(stmt: ccore.CompilerCoreStmtNode, assignTargetKind: str): str =
    if stmt.kind == "assign" && assignTargetKind != "none":
        return stmt.kind + ":" + assignTargetKind
    if stmt.kind == "for_range" && strings.len(stmt.detailText) > 0:
        return stmt.kind + ":" + stmt.detailText
    return stmt.kind

fn compilerCoreExprSemanticTag(expr: ccore.CompilerCoreExprNode,
                               referenceKind: str,
                               callTargetKind: str): str =
    if (expr.kind == "unary" || expr.kind == "binary") && strings.len(expr.detailText) > 0:
        return expr.kind + ":" + expr.detailText
    if expr.kind == "call" && callTargetKind != "none":
        return expr.kind + ":" + callTargetKind
    if (expr.kind == "name_ref" || expr.kind == "field" || expr.kind == "index" || expr.kind == "call") &&
       referenceKind != "none":
        return expr.kind + ":" + referenceKind
    return expr.kind

fn compilerCoreRoutineStmtSemanticSet(program: ccore.CompilerCoreProgram,
                                      importIndex: CompilerCoreImportHeaderIndex,
                                      enumArena: CompilerCoreEnumMemberHeaderArena,
                                      typeArena: CompilerCoreTypeHeaderArena,
                                      typeIndex: CompilerCoreTypeHeaderIndex,
                                      valueIndex: CompilerCoreValueHeaderIndex,
                                      routineArena: CompilerCoreRoutineHeaderArena,
                                      routineIndex: CompilerCoreRoutineHeaderIndex,
                                      visibility: CompilerCoreVisibilityIndex,
                                      decl: ccore.CompilerCoreRoutineDecl,
                                      ownerModulePath: str,
                                      sourcePath: str,
                                      outAssignTargetKinds: var str[],
                                      outAssignTargetTexts: var str[],
                                      outAssignTargetOwnerTexts: var str[],
                                      outAssignTargetValueInts: var int32[],
                                      outAssignTargetFieldOrdinals: var int32[]): str =
    var kinds: str[]
    kinds = []
    for i in 0..<decl.stmtCount:
        let stmtId = decl.stmtStart + i
        var assignTargetKind: str = "none"
        var assignTargetText: str = ""
        var assignTargetOwnerText: str = ""
        var assignTargetValueInt: int32 = -1
        var assignTargetFieldOrdinal: int32 = -1
        compilerCoreAssignTargetFactsInModule(program,
                                              importIndex,
                                              enumArena,
                                              typeArena,
                                              typeIndex,
                                              valueIndex,
                                              routineArena,
                                              routineIndex,
                                              visibility,
                                              decl,
                                              ownerModulePath,
                                              sourcePath,
                                              stmtId,
                                              assignTargetKind,
                                              assignTargetText,
                                              assignTargetOwnerText,
                                              assignTargetValueInt,
                                              assignTargetFieldOrdinal)
        seqs.add(outAssignTargetKinds, assignTargetKind)
        seqs.add(outAssignTargetTexts, assignTargetText)
        seqs.add(outAssignTargetOwnerTexts, assignTargetOwnerText)
        seqs.add(outAssignTargetValueInts, assignTargetValueInt)
        seqs.add(outAssignTargetFieldOrdinals, assignTargetFieldOrdinal)
        ident.appendUnique(kinds,
                           compilerCoreStmtSemanticTag(program.stmts[stmtId], assignTargetKind))
    return compilerCoreCanonicalKindSet(kinds)

fn compilerCoreRoutineExprSemanticSet(program: ccore.CompilerCoreProgram,
                                      importIndex: CompilerCoreImportHeaderIndex,
                                      enumArena: CompilerCoreEnumMemberHeaderArena,
                                      typeArena: CompilerCoreTypeHeaderArena,
                                      typeIndex: CompilerCoreTypeHeaderIndex,
                                      valueIndex: CompilerCoreValueHeaderIndex,
                                      routineArena: CompilerCoreRoutineHeaderArena,
                                      routineIndex: CompilerCoreRoutineHeaderIndex,
                                      visibility: CompilerCoreVisibilityIndex,
                                      decl: ccore.CompilerCoreRoutineDecl,
                                      ownerModulePath: str,
                                      sourcePath: str,
                                      outReferenceKinds: var str[],
                                      outReferenceTargetKinds: var str[],
                                      outReferenceTexts: var str[],
                                      outReferenceItemIds: var int32[],
                                      outReferenceValueInts: var int32[],
                                      outCallTargetKinds: var str[],
                                      outCallTargetTexts: var str[],
                                      outCallTargetItemIds: var int32[]): str =
    var kinds: str[]
    kinds = []
    for i in 0..<decl.exprCount:
        let exprId = decl.exprStart + i
        var targetKind: str = ""
        var targetText: str = ""
        var targetItemId: int32 = -1
        var valueInt: int32 = -1
        let referenceKind = compilerCoreExprReferenceKindInModule(program,
                                                                  importIndex,
                                                                  enumArena,
                                                                  typeIndex,
                                                                  valueIndex,
                                                                  routineIndex,
                                                                  visibility,
                                                                  decl,
                                                                  ownerModulePath,
                                                                  sourcePath,
                                                                  exprId,
                                                                  targetKind,
                                                                  targetText,
                                                                  targetItemId,
                                                                  valueInt)
        if referenceKind == "field_access":
            valueInt = compilerCoreExprRecordFieldOrdinalInModule(program,
                                                                  importIndex,
                                                                  enumArena,
                                                                  typeArena,
                                                                  typeIndex,
                                                                  valueIndex,
                                                                  routineArena,
                                                                  routineIndex,
                                                                  visibility,
                                                                  decl,
                                                                  ownerModulePath,
                                                                  sourcePath,
                                                                  exprId)
        seqs.add(outReferenceKinds, referenceKind)
        seqs.add(outReferenceTargetKinds, targetKind)
        seqs.add(outReferenceTexts, targetText)
        seqs.add(outReferenceItemIds, targetItemId)
        seqs.add(outReferenceValueInts, valueInt)
        var callTargetKind: str = "none"
        var callTargetText: str = ""
        var callTargetItemId: int32 = -1
        compilerCoreCallTargetFactsInModule(program,
                                            importIndex,
                                            enumArena,
                                            typeArena,
                                            typeIndex,
                                            valueIndex,
                                            routineArena,
                                            routineIndex,
                                            visibility,
                                            decl,
                                            ownerModulePath,
                                            sourcePath,
                                            exprId,
                                            callTargetKind,
                                            callTargetText,
                                            callTargetItemId)
        seqs.add(outCallTargetKinds, callTargetKind)
        seqs.add(outCallTargetTexts, callTargetText)
        seqs.add(outCallTargetItemIds, callTargetItemId)
        ident.appendUnique(kinds,
                           compilerCoreExprSemanticTag(program.exprs[exprId],
                                                       referenceKind,
                                                       callTargetKind))
    return compilerCoreCanonicalKindSet(kinds)

fn compilerCoreImportCategory(modulePath: str): str =
    if strutils.startsWith(modulePath, "std/"):
        return "stdlib"
    if strutils.startsWith(modulePath, "compiler/"):
        return "compiler_module"
    if strutils.startsWith(modulePath, "runtime/"):
        return "runtime_module"
    if strutils.startsWith(modulePath, "bootstrap/"):
        return "bootstrap_module"
    return "package_local"

fn compilerCoreHighOpForKind(kind: str, executableAstReady: bool): str =
    if kind == "module":
        return "compiler_module_decl"
    if kind == "import":
        return "compiler_import_bind"
    if kind == "type":
        return "compiler_type_block"
    if kind == "const":
        return "compiler_const_decl"
    if kind == "var":
        return "compiler_var_decl"
    if kind == "importc_fn":
        return "compiler_importc_fn_decl"
    if executableAstReady:
        if kind == "iterator":
            return "compiler_iterator_exec"
        return "compiler_fn_exec"
    if kind == "iterator":
        return "compiler_iterator_outline"
    return "compiler_fn_outline"

fn compilerCoreProofDomainForKind(kind: str, executableAstReady: bool): str =
    if kind == "module":
        return "module_identity_outline"
    if kind == "import":
        return "module_path_resolution"
    if kind == "type":
        return "type_layout_outline"
    if kind == "const":
        return "const_value_outline"
    if kind == "var":
        return "var_storage_outline"
    if kind == "importc_fn":
        return "ffi_signature_outline"
    if executableAstReady:
        if kind == "iterator":
            return "iterator_control_flow_subset"
        return "routine_control_flow_subset"
    if kind == "iterator":
        return "iterator_signature_outline"
    return "routine_signature_outline"

fn compilerCoreEffectClassForKind(kind: str, executableAstReady: bool): str =
    if kind == "module":
        return "module_identity"
    if kind == "import":
        return "module_resolution"
    if kind == "type":
        return "type_layout"
    if kind == "const":
        return "const_binding"
    if kind == "var":
        return "storage_binding"
    if kind == "importc_fn":
        return "ffi_binding"
    if executableAstReady:
        if kind == "iterator":
            return "sequence_executable"
        return "control_flow_executable"
    if kind == "iterator":
        return "sequence_outline"
    return "control_flow_outline"

fn compilerCoreBindingScopeForKind(kind: str): str =
    if kind == "module":
        return "module_scope"
    if kind == "import":
        return "import_binding"
    if kind == "type":
        return "type_scope"
    if kind == "const":
        return "const_scope"
    if kind == "var":
        return "var_scope"
    if kind == "importc_fn":
        return "ffi_scope"
    if kind == "iterator":
        return "iterator_scope"
    return "routine_scope"

fn buildCompilerCoreSemanticFacts(program: ccore.CompilerCoreProgram): CompilerCoreSemanticFacts =
    var out: CompilerCoreSemanticFacts
    let declaredIndex = buildCompilerCoreDeclaredModuleIndex(program)
    compilerCoreRequireNoPointerSurfaceFree(program)
    let moduleGraph = buildCompilerCoreModuleGraph(program, declaredIndex)
    let importArena = buildCompilerCoreImportHeaderArena(program, declaredIndex)
    let enumArena = buildCompilerCoreEnumMemberHeaderArena(program)
    let typeArena = buildCompilerCoreTypeHeaderArena(program)
    let valueArena = buildCompilerCoreValueHeaderArena(program)
    let routineArena = buildCompilerCoreRoutineHeaderArena(program)
    let visibility = buildCompilerCoreVisibilityIndex(moduleGraph)
    let importIndex = buildCompilerCoreImportHeaderIndex(importArena, visibility)
    let typeIndex = buildCompilerCoreTypeHeaderIndex(typeArena, visibility)
    let valueIndex = buildCompilerCoreValueHeaderIndex(valueArena, visibility)
    let routineIndex = buildCompilerCoreRoutineHeaderIndex(routineArena, visibility)
    out.version = compilerCoreFactsVersion()
    out.itemIds = []
    out.topLevelKinds = []
    out.topLevelLabels = []
    out.importcSymbolTexts = []
    out.highOps = []
    out.proofDomains = []
    out.effectClasses = []
    out.bindingScopes = []
    out.importPaths = []
    out.importTargetModulePaths = []
    out.importAliases = []
    out.importCategories = []
    out.bodyLineCounts = []
    out.bodyHashes = []
    out.signatureHashes = []
    out.executableAstReady = []
    out.returnTypeTexts = []
    out.paramCounts = []
    out.localCounts = []
    out.stmtCounts = []
    out.exprCounts = []
    out.stmtKindSets = []
    out.exprKindSets = []
    out.stmtSemanticSets = []
    out.exprSemanticSets = []
    out.stmtAssignTargetKinds = []
    out.stmtAssignTargetTexts = []
    out.stmtAssignTargetOwnerTexts = []
    out.stmtAssignTargetValueInts = []
    out.stmtAssignTargetFieldOrdinals = []
    out.exprReferenceKinds = []
    out.exprReferenceTargetKinds = []
    out.exprReferenceTexts = []
    out.exprReferenceItemIds = []
    out.exprReferenceValueInts = []
    out.exprCallTargetKinds = []
    out.exprCallTargetTexts = []
    out.exprCallTargetItemIds = []
    var moduleIdx: int32 = 0
    var typeIdx: int32 = 0
    var constIdx: int32 = 0
    var varIdx: int32 = 0
    var routineIdx: int32 = 0
    for i in 0..<program.topLevelKinds.len:
        let kind = program.topLevelKinds[i]
        var label: str = program.topLevelLabels[i]
        var importcSymbolText: str = ""
        var importPath: str = ""
        var importTargetModulePath: str = ""
        var importAlias: str = ""
        var importCategory: str = ""
        var bodyLineCount: int32 = 0
        var bodyHash: str = ident.sha256HexText("")
        var signatureHash: str = ident.sha256HexText("")
        var executableAstReady: bool = false
        var returnTypeText: str = ""
        var paramCount: int32 = 0
        var localCount: int32 = 0
        var stmtCount: int32 = 0
        var exprCount: int32 = 0
        var stmtKindSet: str = ""
        var exprKindSet: str = ""
        var stmtSemanticSet: str = ""
        var exprSemanticSet: str = ""
        var sourcePath: str = ""
        var ownerModulePath: str = ""
        if i < len(program.topLevelSourcePaths):
            sourcePath = program.topLevelSourcePaths[i]
        if i < len(program.topLevelOwnerModules):
            ownerModulePath = program.topLevelOwnerModules[i]
        if kind == "module":
            let decl = program.modules[moduleIdx]
            moduleIdx = moduleIdx + 1
            label = decl.name
            signatureHash = ident.sha256HexText(decl.headerText)
        elif kind == "import":
            if i >= program.topLevelImportDeclIdxs.len:
                compilerCoreFactsPanic("v2 semantic facts compiler_core: missing topLevelImportDeclIdx for item " + intToStr(i))
            let importIdx = program.topLevelImportDeclIdxs[i]
            if importIdx < 0 || importIdx >= program.imports.len:
                compilerCoreFactsPanic("v2 semantic facts compiler_core: invalid topLevelImportDeclIdx " +
                                       intToStr(importIdx) + " for item " + intToStr(i))
            let decl = program.imports[importIdx]
            label = decl.modulePath
            importPath = decl.modulePath
            importTargetModulePath =
                compilerCoreLookupDeclaredOwnerModulePath(declaredIndex,
                                                         compilerCoreNormalizeImportModulePath(decl.modulePath))
            if strings.len(importTargetModulePath) <= 0:
                compilerCoreFactsPanic("v2 semantic facts compiler_core: missing import target owner " +
                                       compilerCoreNormalizeImportModulePath(decl.modulePath))
            importAlias = decl.alias
            importCategory = compilerCoreImportCategory(decl.modulePath)
        elif kind == "type":
            let block = program.typeBlocks[typeIdx]
            typeIdx = typeIdx + 1
            label = block.headerText
            bodyLineCount = block.bodyLines.len
            bodyHash = compilerCoreBodyHash(block.bodyLines)
        elif kind == "const":
            let decl = program.constDecls[constIdx]
            constIdx = constIdx + 1
            label = decl.label
            signatureHash = ident.sha256HexText(decl.headerText)
            bodyLineCount = decl.bodyLines.len
            bodyHash = compilerCoreBodyHash(decl.bodyLines)
            executableAstReady = decl.executableAstReady
            stmtCount = decl.stmtCount
            exprCount = decl.exprCount
            let pseudoDecl = ccore.compilerCoreValueDeclAsRoutineDecl(decl)
            stmtKindSet = compilerCoreRoutineStmtKindSet(program, pseudoDecl)
            exprKindSet = compilerCoreRoutineExprKindSet(program, pseudoDecl)
            stmtSemanticSet = compilerCoreRoutineStmtSemanticSet(program,
                                                                 importIndex,
                                                                 enumArena,
                                                                 typeArena,
                                                                 typeIndex,
                                                                 valueIndex,
                                                                 routineArena,
                                                                 routineIndex,
                                                                 visibility,
                                                                 pseudoDecl,
                                                                 ownerModulePath,
                                                                 sourcePath,
                                                                 out.stmtAssignTargetKinds,
                                                                 out.stmtAssignTargetTexts,
                                                                 out.stmtAssignTargetOwnerTexts,
                                                                 out.stmtAssignTargetValueInts,
                                                                 out.stmtAssignTargetFieldOrdinals)
            exprSemanticSet = compilerCoreRoutineExprSemanticSet(program,
                                                                 importIndex,
                                                                 enumArena,
                                                                 typeArena,
                                                                 typeIndex,
                                                                 valueIndex,
                                                                 routineArena,
                                                                 routineIndex,
                                                                 visibility,
                                                                 pseudoDecl,
                                                                 ownerModulePath,
                                                                 sourcePath,
                                                                 out.exprReferenceKinds,
                                                                 out.exprReferenceTargetKinds,
                                                                 out.exprReferenceTexts,
                                                                 out.exprReferenceItemIds,
                                                                 out.exprReferenceValueInts,
                                                                 out.exprCallTargetKinds,
                                                                 out.exprCallTargetTexts,
                                                                 out.exprCallTargetItemIds)
        elif kind == "var":
            let decl = program.varDecls[varIdx]
            varIdx = varIdx + 1
            label = decl.label
            signatureHash = ident.sha256HexText(decl.headerText)
            bodyLineCount = decl.bodyLines.len
            bodyHash = compilerCoreBodyHash(decl.bodyLines)
            executableAstReady = decl.executableAstReady
            stmtCount = decl.stmtCount
            exprCount = decl.exprCount
            let pseudoDecl = ccore.compilerCoreValueDeclAsRoutineDecl(decl)
            stmtKindSet = compilerCoreRoutineStmtKindSet(program, pseudoDecl)
            exprKindSet = compilerCoreRoutineExprKindSet(program, pseudoDecl)
            stmtSemanticSet = compilerCoreRoutineStmtSemanticSet(program,
                                                                 importIndex,
                                                                 enumArena,
                                                                 typeArena,
                                                                 typeIndex,
                                                                 valueIndex,
                                                                 routineArena,
                                                                 routineIndex,
                                                                 visibility,
                                                                 pseudoDecl,
                                                                 ownerModulePath,
                                                                 sourcePath,
                                                                 out.stmtAssignTargetKinds,
                                                                 out.stmtAssignTargetTexts,
                                                                 out.stmtAssignTargetOwnerTexts,
                                                                 out.stmtAssignTargetValueInts,
                                                                 out.stmtAssignTargetFieldOrdinals)
            exprSemanticSet = compilerCoreRoutineExprSemanticSet(program,
                                                                 importIndex,
                                                                 enumArena,
                                                                 typeArena,
                                                                 typeIndex,
                                                                 valueIndex,
                                                                 routineArena,
                                                                 routineIndex,
                                                                 visibility,
                                                                 pseudoDecl,
                                                                 ownerModulePath,
                                                                 sourcePath,
                                                                 out.exprReferenceKinds,
                                                                 out.exprReferenceTargetKinds,
                                                                 out.exprReferenceTexts,
                                                                 out.exprReferenceItemIds,
                                                                 out.exprReferenceValueInts,
                                                                 out.exprCallTargetKinds,
                                                                 out.exprCallTargetTexts,
                                                                 out.exprCallTargetItemIds)
        else:
            let decl = program.routines[routineIdx]
            routineIdx = routineIdx + 1
            label = decl.name
            if kind == "importc_fn":
                importcSymbolText = compilerCoreImportcSymbolText(decl.signatureText, decl.name)
            bodyLineCount = decl.bodyLines.len
            bodyHash = compilerCoreBodyHash(decl.bodyLines)
            signatureHash = ident.sha256HexText(decl.signatureText)
            executableAstReady = decl.executableAstReady
            returnTypeText = decl.returnTypeText
            paramCount = decl.paramCount
            localCount = decl.localCount
            stmtCount = decl.stmtCount
            exprCount = decl.exprCount
            stmtKindSet = compilerCoreRoutineStmtKindSet(program, decl)
            exprKindSet = compilerCoreRoutineExprKindSet(program, decl)
            stmtSemanticSet = compilerCoreRoutineStmtSemanticSet(program,
                                                                 importIndex,
                                                                 enumArena,
                                                                 typeArena,
                                                                 typeIndex,
                                                                 valueIndex,
                                                                 routineArena,
                                                                 routineIndex,
                                                                 visibility,
                                                                 decl,
                                                                 ownerModulePath,
                                                                 sourcePath,
                                                                 out.stmtAssignTargetKinds,
                                                                 out.stmtAssignTargetTexts,
                                                                 out.stmtAssignTargetOwnerTexts,
                                                                 out.stmtAssignTargetValueInts,
                                                                 out.stmtAssignTargetFieldOrdinals)
            exprSemanticSet = compilerCoreRoutineExprSemanticSet(program,
                                                                 importIndex,
                                                                 enumArena,
                                                                 typeArena,
                                                                 typeIndex,
                                                                 valueIndex,
                                                                 routineArena,
                                                                 routineIndex,
                                                                 visibility,
                                                                 decl,
                                                                 ownerModulePath,
                                                                 sourcePath,
                                                                 out.exprReferenceKinds,
                                                                 out.exprReferenceTargetKinds,
                                                                 out.exprReferenceTexts,
                                                                 out.exprReferenceItemIds,
                                                                 out.exprReferenceValueInts,
                                                                 out.exprCallTargetKinds,
                                                                 out.exprCallTargetTexts,
                                                                 out.exprCallTargetItemIds)
        seqs.add(out.itemIds, i)
        seqs.add(out.topLevelKinds, kind)
        seqs.add(out.topLevelLabels, label)
        seqs.add(out.importcSymbolTexts, importcSymbolText)
        seqs.add(out.highOps, compilerCoreHighOpForKind(kind, executableAstReady))
        seqs.add(out.proofDomains, compilerCoreProofDomainForKind(kind, executableAstReady))
        seqs.add(out.effectClasses, compilerCoreEffectClassForKind(kind, executableAstReady))
        seqs.add(out.bindingScopes, compilerCoreBindingScopeForKind(kind))
        seqs.add(out.importPaths, importPath)
        seqs.add(out.importTargetModulePaths, importTargetModulePath)
        seqs.add(out.importAliases, importAlias)
        seqs.add(out.importCategories, importCategory)
        seqs.add(out.bodyLineCounts, bodyLineCount)
        seqs.add(out.bodyHashes, bodyHash)
        seqs.add(out.signatureHashes, signatureHash)
        seqs.add(out.executableAstReady, executableAstReady)
        seqs.add(out.returnTypeTexts, returnTypeText)
        seqs.add(out.paramCounts, paramCount)
        seqs.add(out.localCounts, localCount)
        seqs.add(out.stmtCounts, stmtCount)
        seqs.add(out.exprCounts, exprCount)
        seqs.add(out.stmtKindSets, stmtKindSet)
        seqs.add(out.exprKindSets, exprKindSet)
        seqs.add(out.stmtSemanticSets, stmtSemanticSet)
        seqs.add(out.exprSemanticSets, exprSemanticSet)
    if out.exprReferenceKinds.len != program.exprs.len:
        compilerCoreFactsPanic("v2 semantic facts compiler_core: expr reference kind count mismatch")
    if out.exprCallTargetKinds.len != program.exprs.len:
        compilerCoreFactsPanic("v2 semantic facts compiler_core: expr call target kind count mismatch")
    if out.stmtAssignTargetKinds.len != program.stmts.len:
        compilerCoreFactsPanic("v2 semantic facts compiler_core: stmt assign target kind count mismatch")
    if out.stmtAssignTargetFieldOrdinals.len != program.stmts.len:
        compilerCoreFactsPanic("v2 semantic facts compiler_core: stmt assign target field ordinal count mismatch")
    return out

fn compilerCoreExecutableAstItemCount(facts: CompilerCoreSemanticFacts): int32 =
    var out: int32 = 0
    for i in 0..<facts.executableAstReady.len:
        if facts.executableAstReady[i]:
            out = out + 1
    return out

fn compilerCoreExecutableParamCount(facts: CompilerCoreSemanticFacts): int32 =
    var out: int32 = 0
    for i in 0..<facts.paramCounts.len:
        out = out + facts.paramCounts[i]
    return out

fn compilerCoreExecutableLocalCount(facts: CompilerCoreSemanticFacts): int32 =
    var out: int32 = 0
    for i in 0..<facts.localCounts.len:
        out = out + facts.localCounts[i]
    return out

fn compilerCoreExecutableStmtCount(facts: CompilerCoreSemanticFacts): int32 =
    var out: int32 = 0
    for i in 0..<facts.stmtCounts.len:
        out = out + facts.stmtCounts[i]
    return out

fn compilerCoreExecutableExprCount(facts: CompilerCoreSemanticFacts): int32 =
    var out: int32 = 0
    for i in 0..<facts.exprCounts.len:
        out = out + facts.exprCounts[i]
    return out
