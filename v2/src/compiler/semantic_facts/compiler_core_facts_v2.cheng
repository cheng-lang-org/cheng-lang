fn compilerCoreFactsPanic(msg: str) =
    system.panicStr(msg)

fn compilerCoreFactsVersion(): str =
    return "v2.semantic_facts.compiler_core.v22"

fn newCompilerCoreDeclaredModuleIndex(): CompilerCoreDeclaredModuleIndex =
    var out: CompilerCoreDeclaredModuleIndex
    out.declaredModulePaths = []
    out.ownerModulePaths = []
    out.lookupDeclaredModulePaths = []
    out.lookupOwnerModulePaths = []
    return out

