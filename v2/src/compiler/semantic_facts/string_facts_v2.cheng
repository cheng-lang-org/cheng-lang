import std/seqs
import std/system
import compiler/frontend/string_surface_ir_v2 as surf
import compiler/frontend/string_lowering_contract as slower

type
    StringSemanticFacts =
        version: str
        factIds: int32[]
        surfaceForms: str[]
        highOps: str[]
        runtimeTargets: str[]
        resultKinds: str[]
        allocationModes: str[]
        zeroCopyFacts: bool[]

fn stringFactsVersion(): str =
    return "v2.semantic_facts.string.v1"

fn stringResultKindForHighOp(highOp: str): str =
    if highOp == "str_eq" || highOp == "str_ne" || highOp == "str_contains_char" || highOp == "str_contains" || highOp == "str_starts_with" || highOp == "str_ends_with":
        return "bool"
    if highOp == "str_index":
        return "char"
    if highOp == "str_len":
        return "int32"
    if highOp == "str_slice_view" || highOp == "str_concat" || highOp == "str_to_owned" || highOp == "str_builder_finish":
        return "str"
    if highOp == "str_builder_init" || highOp == "str_builder_append" || highOp == "str_builder_append_byte":
        return "builder"
    return "unknown"

fn stringAllocationModeForHighOp(highOp: str): str =
    if highOp == "str_slice_view":
        return "borrow_view"
    if highOp == "str_concat":
        return "allocate_once"
    if highOp == "str_to_owned":
        return "copy_owned"
    if highOp == "str_builder_finish":
        return "move_owned_buffer"
    if highOp == "str_builder_init" || highOp == "str_builder_append" || highOp == "str_builder_append_byte":
        return "builder_state"
    return "none"

fn stringZeroCopyForHighOp(highOp: str): bool =
    if highOp == "str_concat" || highOp == "str_to_owned" || highOp == "str_builder_init" || highOp == "str_builder_append" || highOp == "str_builder_append_byte" || highOp == "str_builder_finish":
        return false
    return true

fn buildStringSemanticFacts(program: surf.StringSurfaceProgram): StringSemanticFacts =
    var out: StringSemanticFacts
    out.version = stringFactsVersion()
    out.factIds = []
    out.surfaceForms = []
    out.highOps = []
    out.runtimeTargets = []
    out.resultKinds = []
    out.allocationModes = []
    out.zeroCopyFacts = []
    let contract = slower.stringLoweringContract()
    for i in 0..<program.exprs.len:
        let expr = program.exprs[i]
        let ruleIdx = slower.findStringLoweringRule(expr.surfaceForm)
        if ruleIdx < 0:
            panic("v2 string facts: missing lowering rule for " + expr.surfaceForm)
        let rule = contract.rules[ruleIdx]
        add(out.factIds, i)
        add(out.surfaceForms, expr.surfaceForm)
        add(out.highOps, rule.highUirOp)
        add(out.runtimeTargets, rule.runtimeTarget)
        add(out.resultKinds, stringResultKindForHighOp(rule.highUirOp))
        add(out.allocationModes, stringAllocationModeForHighOp(rule.highUirOp))
        add(out.zeroCopyFacts, stringZeroCopyForHighOp(rule.highUirOp))
    return out

fn stringSemanticFactCount(facts: StringSemanticFacts): int32 =
    return facts.factIds.len
