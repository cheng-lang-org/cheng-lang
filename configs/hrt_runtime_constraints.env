# HRT runtime constraints template (Tier1/Tier2)
# Use 1 for enabled/true, 0 for disabled/false.

# tier1 | tier2
HRT_TIER=tier2

# CPU / scheduling
HRT_CPU_PINNED=1
HRT_DVFS_DISABLED=1
HRT_SCHED_POLICY=fifo
HRT_SCHED_PRIORITY=80

# Memory
HRT_MEM_LOCKED=1
HRT_WORKSET_BYTES=1048576

# Interrupt / IO
HRT_IRQ_BOUND=1
HRT_IO_BOUND_US=200

# Runtime guards
HRT_WATCHDOG_ENABLED=1
HRT_MAX_JITTER_US=200
HRT_WCET_BUDGET_US=1000

# Fixed-capacity resources
HRT_RING_CAPACITY=1024
HRT_ARENA_BYTES=1048576

# HRT mode requirements
HRT_CHENG_MM_ATOMIC=0
HRT_CHENG_MM=off
