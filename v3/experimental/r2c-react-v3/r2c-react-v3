discover_truth_routes_cmd() {
  repo_raw="$(read_flag --repo "$PWD" "$@")"
  repo="$(cd "$repo_raw" && pwd)"
  out_dir_raw="$(read_flag --out-dir "$repo/build/r2c_react_v3_cheng" "$@")"
  runtime_values="$(collect_flag_values --runtime-root "$@")"
  out_dir="$(abs_path "$repo" "$out_dir_raw")"
  helper_script="$exp_root/r2c-react-v3-discover-truth-routes.mjs"
  artifact_path="$out_dir/truth_routes_v1.json"
  summary_path="$out_dir/truth_routes_v1.summary.env"
  report_path="$out_dir/truth_routes_report_v1.json"
  log_path="$out_dir/truth_routes.log"
  mkdir -p "$out_dir"
  set -- "$helper_script" --repo "$repo" --out "$artifact_path" --summary-out "$summary_path"
  runtime_values="$(collect_flag_values --runtime-root "$@")"
  if [ -n "$runtime_values" ]; then
    OLD_IFS="${IFS}"
    IFS='
'
    for runtime_root in $runtime_values; do
      set -- "$@" --runtime-root "$runtime_root"
    done
    IFS="${OLD_IFS}"
  fi
  if ! node "$@" >"$log_path" 2>&1; then
    write_report "$report_path" discover-truth-routes false helper_failed "$repo" "$out_dir" "$helper_script" "$summary_path" "$log_path" "$artifact_path" truth_routes_v1 0 0 0 ""
