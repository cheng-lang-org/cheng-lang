  route="$(read_flag --route "" "$@")"
  if [ -z "$route" ]; then
    echo "r2c-react-v3: capture-truth missing --route" >&2
    return 1
  fi
  default_out_dir="$repo/build/r2c_react_v3_cheng/truth/$route"
  out_dir_raw="$(read_flag --out-dir "$default_out_dir" "$@")"
  base_url="$(read_flag --base-url "" "$@")"
