}

discover_truth_routes_cmd() {
  repo_raw="$(read_flag --repo "$PWD" "$@")"
  repo="$(cd "$repo_raw" && pwd)"
  out_dir_raw="$(read_flag --out-dir "$repo/build/r2c_react_v3_cheng" "$@")"
  runtime_values="$(collect_flag_values --runtime-root "$@")"
  out_dir="$(abs_path "$repo" "$out_dir_raw")"
  helper_script="$exp_root/r2c-react-v3-discover-truth-routes.mjs"
  artifact_path="$out_dir/truth_routes_v1.json"
  summary_path="$out_dir/truth_routes_v1.summary.env"
  report_path="$out_dir/truth_routes_report_v1.json"
  log_path="$out_dir/truth_routes.log"
  mkdir -p "$out_dir"
  set -- "$helper_script" --repo "$repo" --out "$artifact_path" --summary-out "$summary_path"
  runtime_values="$(collect_flag_values --runtime-root "$@")"
  if [ -n "$runtime_values" ]; then
    OLD_IFS="${IFS}"
    IFS='
'
    for runtime_root in $runtime_values; do
      set -- "$@" --runtime-root "$runtime_root"
    done
    IFS="${OLD_IFS}"
  fi
  if ! node "$@" >"$log_path" 2>&1; then
    write_report "$report_path" discover-truth-routes false helper_failed "$repo" "$out_dir" "$helper_script" "$summary_path" "$log_path" "$artifact_path" truth_routes_v1 0 0 0 ""
    echo "r2c-react-v3: truth route helper failed" >&2
    tail -n 80 "$log_path" >&2 || true
    return 1
  fi
  route_count="$(read_summary_value "$summary_path" route_count 0)"
  typescript_version="$(read_summary_value "$summary_path" typescript_version '')"
  write_report "$report_path" discover-truth-routes true ok "$repo" "$out_dir" "$helper_script" "$summary_path" "$log_path" "$artifact_path" truth_routes_v1 0 "$route_count" 0 "$typescript_version"
  printf '%s\n' "$report_path"
}

capture_truth_cmd() {
  repo_raw="$(read_flag --repo "$PWD" "$@")"
  repo="$(cd "$repo_raw" && pwd)"
  route="$(read_flag --route "" "$@")"
  if [ -z "$route" ]; then
    echo "r2c-react-v3: capture-truth missing --route" >&2
    return 1
  fi
  default_out_dir="$repo/build/r2c_react_v3_cheng/truth/$route"
  out_dir_raw="$(read_flag --out-dir "$default_out_dir" "$@")"
  base_url="$(read_flag --base-url "" "$@")"
  chrome_path="$(read_flag --chrome "" "$@")"
  width="$(read_flag --width "" "$@")"
  height="$(read_flag --height "" "$@")"
  truth_flag="$(read_flag --truth-flag "" "$@")"
  debug_port="$(read_flag --debug-port "" "$@")"
  wait_ms="$(read_flag --wait-ms "" "$@")"
  out_dir="$(abs_path "$repo" "$out_dir_raw")"
  helper_script="$exp_root/r2c-react-v3-truth-runtime.mjs"
  summary_path="$out_dir/$route.summary.env"
  report_path="$out_dir/capture_truth_report_v1.json"
  log_path="$out_dir/truth_runtime.log"
  mkdir -p "$out_dir"
  set -- "$helper_script" --route "$route" --out-dir "$out_dir" --summary-out "$summary_path"
  if [ -n "$base_url" ]; then set -- "$@" --base-url "$base_url"; fi
  if [ -n "$chrome_path" ]; then set -- "$@" --chrome "$chrome_path"; fi
  if [ -n "$width" ]; then set -- "$@" --width "$width"; fi
  if [ -n "$height" ]; then set -- "$@" --height "$height"; fi
  if [ -n "$truth_flag" ]; then set -- "$@" --truth-flag "$truth_flag"; fi
  if [ -n "$debug_port" ]; then set -- "$@" --debug-port "$debug_port"; fi
  if [ -n "$wait_ms" ]; then set -- "$@" --wait-ms "$wait_ms"; fi
  if ! node "$@" >"$log_path" 2>&1; then
    write_report "$report_path" capture-truth false helper_failed "$repo" "$out_dir" "$helper_script" "$summary_path" "$log_path" "" truth_runtime_v1 0 0 0 ""
    echo "r2c-react-v3: truth runtime helper failed" >&2
    tail -n 120 "$log_path" >&2 || true
    return 1
  fi
  semantic_nodes_count="$(read_summary_value "$summary_path" semantic_nodes_count 0)"
  runtime_state_path="$(read_summary_value "$summary_path" runtime_state_path '')"
  write_report "$report_path" capture-truth true ok "$repo" "$out_dir" "$helper_script" "$summary_path" "$log_path" "$runtime_state_path" truth_runtime_v1 0 1 "$semantic_nodes_count" ""
  printf '%s\n' "$report_path"
}

cmd="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

maybe_exec_stage3 "$cmd" "$@" || true

case "$cmd" in
  help|-h|--help)
    usage
    ;;
  status)
    status_cmd "$@"
    ;;
  frontend)
    frontend_like_cmd frontend false "$@"
    ;;
  static-surface)
    static_surface_cmd "$@"
    ;;
  semantic-surface)
    semantic_surface_cmd "$@"
    ;;
  codegen-surface)
    codegen_surface_cmd "$@"
    ;;
  exec-surface)
    exec_surface_cmd "$@"
    ;;
  exec-route-matrix)
    exec_route_matrix_cmd "$@"
    ;;
  compare-truth)
    compare_truth_cmd "$@"
    ;;
  compare-truth-matrix)
    compare_truth_matrix_cmd "$@"
    ;;
  compile)
    frontend_like_cmd compile true "$@"
    ;;
  discover-truth-routes)
    discover_truth_routes_cmd "$@"
    ;;
  capture-truth)
    capture_truth_cmd "$@"
    ;;
  prototype)
    exec python3 "$exp_root/r2c-react-v3.py" "$@"
    ;;
  *)
    echo "r2c-react-v3: unknown subcommand: $cmd" >&2
    usage >&2
    exit 2
    ;;
esac
