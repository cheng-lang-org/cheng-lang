#!/usr/bin/env sh
:
set -eu

root="$(CDPATH= cd -- "$(dirname -- "$0")/../../.." && pwd)"
exp_root="$root/v3/experimental/r2c-react-v3"
bridge_env="$root/artifacts/v3_bootstrap/bootstrap.env"
controller_name="${R2C_REACT_V3_CONTROLLER:-cheng.wrapper}"

usage() {
  cat <<EOF
usage: r2c-react-v3 <subcommand> [args]
subcommands:
  help
  status [--out <file>]
  frontend --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...]
  static-surface --repo <path> [--tsx-ast <file>] [--out-dir <dir>] [--asset-root <dir> ...]
  semantic-surface --repo <path> [--tsx-ast <file>] [--out-dir <dir>]
  codegen-surface --repo <path> [--tsx-ast <file>] [--out-dir <dir>]
  exec-surface --repo <path> [--out-dir <dir>] [--codegen-manifest <file>]
  exec-route-matrix --tsx-ast <file> --exec-snapshot <file> --truth-routes-file <file> [--codegen-manifest <file>] [--truth-trace <file>] [--out <file>]
  compare-truth --exec-snapshot <file> --truth-trace <file> [--truth-state <state>] [--out <file>]
  compare-truth-matrix --exec-route-matrix <file> --truth-trace <file> [--out <file>]
  compile --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...] [--asset-root <dir> ...] [--truth-trace <file>] [--truth-state <state>] [--truth-routes-file <file>] [--truth-routes-discover]
  discover-truth-routes --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...]
  capture-truth --repo <path> --route <state> [--out-dir <dir>] [--base-url <url>] [--chrome <bin>] [--width <n>] [--height <n>] [--truth-flag <0|1>] [--debug-port <n>] [--wait-ms <n>]
  prototype <args...>
EOF
}

maybe_exec_stage3() {
  if [ "${R2C_REACT_V3_NO_STAGE3_HANDOFF:-0}" = "1" ]; then
    return 1
  fi
  if [ ! -f "$bridge_env" ]; then
    return 1
  fi
  # shellcheck disable=SC1090
  . "$bridge_env"
  if [ -n "${V3_BOOTSTRAP_STAGE3:-}" ] && "$V3_BOOTSTRAP_STAGE3" r2c-react-v3 help >/dev/null 2>&1; then
    exec "$V3_BOOTSTRAP_STAGE3" r2c-react-v3 "$@"
  fi
  return 1
}

read_flag() {
  key="$1"
  default_value="$2"
  shift 2
  while [ "$#" -gt 0 ]; do
    case "$1" in
      "$key")
        shift
        if [ "$#" -gt 0 ]; then
          printf '%s\n' "$1"
          return 0
        fi
        ;;
      "$key":*)
        printf '%s\n' "${1#"$key:"}"
        return 0
        ;;
      "$key"=*)
        printf '%s\n' "${1#"$key="}"
        return 0
        ;;
    esac
    shift
  done
  printf '%s\n' "$default_value"
}

collect_flag_values() {
  key="$1"
  shift
  while [ "$#" -gt 0 ]; do
    case "$1" in
      "$key")
        shift
        if [ "$#" -gt 0 ]; then
          printf '%s\n' "$1"
        fi
        ;;
      "$key":*)
        printf '%s\n' "${1#"$key:"}"
        ;;
      "$key"=*)
        printf '%s\n' "${1#"$key="}"
        ;;
    esac
    shift
  done
}

has_flag() {
  key="$1"
  shift
  while [ "$#" -gt 0 ]; do
    case "$1" in
      "$key")
        return 0
        ;;
    esac
    shift
  done
  return 1
}

abs_path() {
  base="$1"
  target="$2"
  node -e 'const path=require("node:path"); console.log(path.resolve(process.argv[1], process.argv[2]));' "$base" "$target"
}

read_summary_value() {
  summary_path="$1"
  key="$2"
  default_value="$3"
  if [ ! -f "$summary_path" ]; then
    printf '%s\n' "$default_value"
    return 0
  fi
  value="$(awk -F= -v want="$key" '$1 == want { sub(/^[^=]*=/, ""); print; exit }' "$summary_path")"
  if [ -n "$value" ]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$default_value"
  fi
}

write_report() {
  report_path="$1"
  command_name="$2"
  ok_value="$3"
  reason_value="$4"
  repo_root="$5"
  out_dir="$6"
  helper_script="$7"
  helper_summary_path="$8"
  helper_log_path="$9"
  primary_artifact_path="${10}"
  primary_artifact_format="${11}"
  module_count="${12}"
  route_count="${13}"
  semantic_nodes_count="${14}"
  typescript_version="${15}"
  asset_count="${16:-0}"
  tailwind_token_count="${17:-0}"
  required_host_group_count="${18:-0}"
  required_host_groups="${19:-}"
  rsg_node_count="${20:-0}"
  rsg_edge_count="${21:-0}"
  blocker_count="${22:-0}"
  blocked="${23:-false}"
  mkdir -p "$(dirname "$report_path")"
  REPORT_PATH="$report_path" \
  REPORT_COMMAND="$command_name" \
  REPORT_OK="$ok_value" \
  REPORT_REASON="$reason_value" \
  REPORT_WORKSPACE_ROOT="$root" \
  REPORT_EXPERIMENTAL_ROOT="$exp_root" \
  REPORT_REPO_ROOT="$repo_root" \
  REPORT_OUT_DIR="$out_dir" \
  REPORT_HELPER_SCRIPT="$helper_script" \
  REPORT_HELPER_SUMMARY="$helper_summary_path" \
  REPORT_HELPER_LOG="$helper_log_path" \
  REPORT_PRIMARY_ARTIFACT="$primary_artifact_path" \
  REPORT_PRIMARY_FORMAT="$primary_artifact_format" \
  REPORT_MODULE_COUNT="$module_count" \
  REPORT_ROUTE_COUNT="$route_count" \
  REPORT_SEMANTIC_NODES_COUNT="$semantic_nodes_count" \
  REPORT_TYPESCRIPT_VERSION="$typescript_version" \
  REPORT_ASSET_COUNT="$asset_count" \
  REPORT_TAILWIND_TOKEN_COUNT="$tailwind_token_count" \
  REPORT_REQUIRED_HOST_GROUP_COUNT="$required_host_group_count" \
  REPORT_REQUIRED_HOST_GROUPS="$required_host_groups" \
  REPORT_RSG_NODE_COUNT="$rsg_node_count" \
  REPORT_RSG_EDGE_COUNT="$rsg_edge_count" \
  REPORT_BLOCKER_COUNT="$blocker_count" \
  REPORT_BLOCKED="$blocked" \
  REPORT_LEGACY_PROTOTYPE="$exp_root/r2c-react-v3.py" \
  REPORT_CONTROLLER="$controller_name" \
  node <<'EOF'
const fs = require('node:fs');
const path = require('node:path');
const requiredHostGroups = (process.env.REPORT_REQUIRED_HOST_GROUPS || '').split(',').map((item) => item.trim()).filter(Boolean);
const out = {
  format: 'controller_report_v1',
  controller: process.env.REPORT_CONTROLLER,
  command: process.env.REPORT_COMMAND,
  ok: process.env.REPORT_OK === 'true',
  reason: process.env.REPORT_REASON,
  workspace_root: process.env.REPORT_WORKSPACE_ROOT,
  experimental_root: process.env.REPORT_EXPERIMENTAL_ROOT,
  repo_root: process.env.REPORT_REPO_ROOT,
  out_dir: process.env.REPORT_OUT_DIR,
  node_program: 'node',
  python_program: 'python3',
  helper_script: process.env.REPORT_HELPER_SCRIPT,
  helper_summary_path: process.env.REPORT_HELPER_SUMMARY,
  helper_log_path: process.env.REPORT_HELPER_LOG,
  primary_artifact_path: process.env.REPORT_PRIMARY_ARTIFACT,
  primary_artifact_format: process.env.REPORT_PRIMARY_FORMAT,
  module_count: Number(process.env.REPORT_MODULE_COUNT || 0),
  route_count: Number(process.env.REPORT_ROUTE_COUNT || 0),
  semantic_nodes_count: Number(process.env.REPORT_SEMANTIC_NODES_COUNT || 0),
  asset_count: Number(process.env.REPORT_ASSET_COUNT || 0),
  tailwind_token_count: Number(process.env.REPORT_TAILWIND_TOKEN_COUNT || 0),
  required_host_group_count: Number(process.env.REPORT_REQUIRED_HOST_GROUP_COUNT || 0),
  required_host_groups: requiredHostGroups,
  rsg_node_count: Number(process.env.REPORT_RSG_NODE_COUNT || 0),
  rsg_edge_count: Number(process.env.REPORT_RSG_EDGE_COUNT || 0),
  blocker_count: Number(process.env.REPORT_BLOCKER_COUNT || 0),
  blocked: process.env.REPORT_BLOCKED === 'true',
  typescript_version: process.env.REPORT_TYPESCRIPT_VERSION || '',
  legacy_prototype_path: process.env.REPORT_LEGACY_PROTOTYPE,
  commands: [
    'status',
    'frontend',
    'static-surface',
    'semantic-surface',
    'codegen-surface',
    'exec-surface',
    'exec-route-matrix',
    'compile',
    'discover-truth-routes',
    'capture-truth',
    'compare-truth',
    'compare-truth-matrix',
    'prototype',
  ],
};
fs.mkdirSync(path.dirname(process.env.REPORT_PATH), { recursive: true });
fs.writeFileSync(process.env.REPORT_PATH, JSON.stringify(out, null, 2) + '\n', 'utf8');
EOF
}

status_cmd() {
  out_path="$(read_flag --out "" "$@")"
  if [ -n "$out_path" ]; then
    report_path="$(abs_path "$root" "$out_path")"
    mkdir -p "$(dirname "$report_path")"
    REPORT_PATH="$report_path" \
    REPORT_WORKSPACE_ROOT="$root" \
    REPORT_EXPERIMENTAL_ROOT="$exp_root" \
    REPORT_LEGACY_PROTOTYPE="$exp_root/r2c-react-v3.py" \
    REPORT_CONTROLLER="$controller_name" \
    node <<'EOF'
const fs = require('node:fs');
const path = require('node:path');
const out = {
  format: 'status_report_v1',
  controller: process.env.REPORT_CONTROLLER,
  workspace_root: process.env.REPORT_WORKSPACE_ROOT,
  experimental_root: process.env.REPORT_EXPERIMENTAL_ROOT,
  node_program: 'node',
  legacy_prototype_path: process.env.REPORT_LEGACY_PROTOTYPE,
  tsx_frontend_helper: path.join(process.env.REPORT_EXPERIMENTAL_ROOT, 'r2c-react-v3-ts-frontend.mjs'),
  static_surface_helper: path.join(process.env.REPORT_EXPERIMENTAL_ROOT, 'r2c-react-v3-static-surface.mjs'),
  semantic_surface_helper: path.join(process.env.REPORT_EXPERIMENTAL_ROOT, 'r2c-react-v3-semantic-surface.mjs'),
  codegen_surface_helper: path.join(process.env.REPORT_EXPERIMENTAL_ROOT, 'r2c-react-v3-codegen-surface.mjs'),
  exec_surface_helper: path.join(process.env.REPORT_EXPERIMENTAL_ROOT, 'r2c-react-v3-exec-surface.mjs'),
  truth_route_helper: path.join(process.env.REPORT_EXPERIMENTAL_ROOT, 'r2c-react-v3-discover-truth-routes.mjs'),
  truth_runtime_helper: path.join(process.env.REPORT_EXPERIMENTAL_ROOT, 'r2c-react-v3-truth-runtime.mjs'),
  exec_route_matrix_helper: path.join(process.env.REPORT_EXPERIMENTAL_ROOT, 'r2c-react-v3-exec-route-matrix.mjs'),
  truth_compare_helper: path.join(process.env.REPORT_EXPERIMENTAL_ROOT, 'r2c-react-v3-truth-compare.mjs'),
  truth_compare_matrix_helper: path.join(process.env.REPORT_EXPERIMENTAL_ROOT, 'r2c-react-v3-truth-compare-matrix.mjs'),
};
fs.mkdirSync(path.dirname(process.env.REPORT_PATH), { recursive: true });
fs.writeFileSync(process.env.REPORT_PATH, JSON.stringify(out, null, 2) + '\n', 'utf8');
EOF
    printf '%s\n' "$report_path"
    return 0
  fi
  node <<EOF
console.log(JSON.stringify({
  format: 'status_report_v1',
  controller: '$controller_name',
  workspace_root: '$root',
  experimental_root: '$exp_root',
  node_program: 'node',
  legacy_prototype_path: '$exp_root/r2c-react-v3.py',
  tsx_frontend_helper: '$exp_root/r2c-react-v3-ts-frontend.mjs',
  static_surface_helper: '$exp_root/r2c-react-v3-static-surface.mjs',
  semantic_surface_helper: '$exp_root/r2c-react-v3-semantic-surface.mjs',
  codegen_surface_helper: '$exp_root/r2c-react-v3-codegen-surface.mjs',
  exec_surface_helper: '$exp_root/r2c-react-v3-exec-surface.mjs',
  truth_route_helper: '$exp_root/r2c-react-v3-discover-truth-routes.mjs',
  truth_runtime_helper: '$exp_root/r2c-react-v3-truth-runtime.mjs',
  exec_route_matrix_helper: '$exp_root/r2c-react-v3-exec-route-matrix.mjs',
  truth_compare_helper: '$exp_root/r2c-react-v3-truth-compare.mjs',
  truth_compare_matrix_helper: '$exp_root/r2c-react-v3-truth-compare-matrix.mjs',
}, null, 2))
EOF
}

frontend_like_cmd() {
  command_name="$1"
  hard_fail_after_frontend="$2"
  shift 2
  repo_raw="$(read_flag --repo "$PWD" "$@")"
  repo="$(cd "$repo_raw" && pwd)"
  out_dir_raw="$(read_flag --out-dir "$repo/build/r2c_react_v3_cheng" "$@")"
  runtime_values="$(collect_flag_values --runtime-root "$@")"
  asset_values="$(collect_flag_values --asset-root "$@")"
  out_dir="$(abs_path "$repo" "$out_dir_raw")"
  helper_script="$exp_root/r2c-react-v3-ts-frontend.mjs"
  artifact_path="$out_dir/tsx_ast_v1.json"
  summary_path="$out_dir/tsx_ast_v1.summary.env"
  static_helper_script="$exp_root/r2c-react-v3-static-surface.mjs"
  static_summary_path="$out_dir/static_surface.summary.env"
  static_log_path="$out_dir/static_surface.log"
  semantic_helper_script="$exp_root/r2c-react-v3-semantic-surface.mjs"
  semantic_summary_path="$out_dir/semantic_surface.summary.env"
  semantic_log_path="$out_dir/semantic_surface.log"
  codegen_helper_script="$exp_root/r2c-react-v3-codegen-surface.mjs"
  codegen_summary_path="$out_dir/codegen_surface.summary.env"
  codegen_log_path="$out_dir/codegen_surface.log"
  exec_helper_script="$exp_root/r2c-react-v3-exec-surface.mjs"
  exec_summary_path="$out_dir/exec_surface.summary.env"
  exec_log_path="$out_dir/exec_surface.log"
  truth_trace_raw="$(read_flag --truth-trace "" "$@")"
  truth_state="$(read_flag --truth-state "" "$@")"
  truth_routes_file_raw="$(read_flag --truth-routes-file "" "$@")"
  truth_routes_discover=false
  if has_flag --truth-routes-discover "$@"; then
    truth_routes_discover=true
  fi
  truth_route_helper_script="$exp_root/r2c-react-v3-discover-truth-routes.mjs"
  truth_routes_summary_path="$out_dir/truth_routes_v1.summary.env"
  truth_routes_log_path="$out_dir/truth_routes.log"
  truth_routes_path="$out_dir/truth_routes_v1.json"
  exec_route_matrix_helper_script="$exp_root/r2c-react-v3-exec-route-matrix.mjs"
  exec_route_matrix_summary_path="$out_dir/exec_route_matrix.summary.env"
  exec_route_matrix_log_path="$out_dir/exec_route_matrix.log"
  exec_route_matrix_path="$out_dir/cheng_codegen_exec_route_matrix_v1.json"
  truth_compare_helper_script="$exp_root/r2c-react-v3-truth-compare.mjs"
  truth_compare_summary_path="$out_dir/truth_compare.summary.env"
  truth_compare_log_path="$out_dir/truth_compare.log"
  truth_compare_path="$out_dir/truth_compare_v1.json"
  truth_compare_matrix_helper_script="$exp_root/r2c-react-v3-truth-compare-matrix.mjs"
  truth_compare_matrix_summary_path="$out_dir/truth_compare_matrix.summary.env"
  truth_compare_matrix_log_path="$out_dir/truth_compare_matrix.log"
  truth_compare_matrix_path="$out_dir/truth_compare_matrix_v1.json"
  module_inventory_path="$out_dir/module_inventory_v1.json"
  rsg_path="$out_dir/rsg_v1.json"
  codegen_manifest_path="$out_dir/cheng_codegen_v1.json"
  exec_snapshot_path="$out_dir/cheng_codegen_exec_snapshot_v1.json"
  log_path="$out_dir/tsx_frontend.log"
  if [ "$hard_fail_after_frontend" = "true" ]; then
    report_path="$out_dir/compile_report_v1.json"
  else
    report_path="$out_dir/frontend_report_v1.json"
  fi
  mkdir -p "$out_dir"
  set -- "$helper_script" --repo "$repo" --out "$artifact_path" --summary-out "$summary_path"
  if [ -n "$runtime_values" ]; then
    OLD_IFS="${IFS}"
    IFS='
'
    for runtime_root in $runtime_values; do
      set -- "$@" --runtime-root "$runtime_root"
    done
    IFS="${OLD_IFS}"
  fi
  if ! node "$@" >"$log_path" 2>&1; then
    write_report "$report_path" "$command_name" false helper_failed "$repo" "$out_dir" "$helper_script" "$summary_path" "$log_path" "$artifact_path" tsx_ast_v1 0 0 0 ""
    echo "r2c-react-v3: tsx frontend helper failed" >&2
    tail -n 80 "$log_path" >&2 || true
    return 1
  fi
  module_count="$(read_summary_value "$summary_path" module_count 0)"
  typescript_version="$(read_summary_value "$summary_path" typescript_version '')"
  if [ "$hard_fail_after_frontend" = "true" ]; then
    set -- "$static_helper_script" --repo "$repo" --out-dir "$out_dir" --tsx-ast "$artifact_path" --summary-out "$static_summary_path"
    if [ -n "$asset_values" ]; then
      OLD_IFS="${IFS}"
      IFS='
'
      for asset_root in $asset_values; do
        set -- "$@" --asset-root "$asset_root"
      done
      IFS="${OLD_IFS}"
    fi
    if ! node "$@" >"$static_log_path" 2>&1; then
      write_report "$report_path" "$command_name" false helper_failed "$repo" "$out_dir" "$static_helper_script" "$static_summary_path" "$static_log_path" "$module_inventory_path" module_inventory_v1 "$module_count" 0 0 "$typescript_version"
      echo "r2c-react-v3: static surface helper failed" >&2
      tail -n 80 "$static_log_path" >&2 || true
      return 1
    fi
    asset_count="$(read_summary_value "$static_summary_path" asset_count 0)"
    tailwind_token_count="$(read_summary_value "$static_summary_path" tailwind_token_count 0)"
    required_host_group_count="$(read_summary_value "$static_summary_path" required_host_group_count 0)"
    required_host_groups="$(read_summary_value "$static_summary_path" required_host_groups '')"
    module_inventory_path="$(read_summary_value "$static_summary_path" module_inventory_path "$module_inventory_path")"
    typescript_version="$(read_summary_value "$static_summary_path" typescript_version "$typescript_version")"
    set -- "$semantic_helper_script" --repo "$repo" --out-dir "$out_dir" --tsx-ast "$artifact_path" --summary-out "$semantic_summary_path"
    if ! node "$@" >"$semantic_log_path" 2>&1; then
      write_report "$report_path" "$command_name" false helper_failed "$repo" "$out_dir" "$semantic_helper_script" "$semantic_summary_path" "$semantic_log_path" "$rsg_path" rsg_v1 "$module_count" 0 0 "$typescript_version" "$asset_count" "$tailwind_token_count" "$required_host_group_count" "$required_host_groups"
      echo "r2c-react-v3: semantic surface helper failed" >&2
      tail -n 80 "$semantic_log_path" >&2 || true
      return 1
    fi
    rsg_node_count="$(read_summary_value "$semantic_summary_path" rsg_node_count 0)"
    rsg_edge_count="$(read_summary_value "$semantic_summary_path" rsg_edge_count 0)"
    blocker_count="$(read_summary_value "$semantic_summary_path" blocker_count 0)"
    blocked="$(read_summary_value "$semantic_summary_path" blocked false)"
    rsg_path="$(read_summary_value "$semantic_summary_path" rsg_path "$rsg_path")"
    typescript_version="$(read_summary_value "$semantic_summary_path" typescript_version "$typescript_version")"
    set -- "$codegen_helper_script" --repo "$repo" --out-dir "$out_dir" --tsx-ast "$artifact_path" --summary-out "$codegen_summary_path"
    if ! node "$@" >"$codegen_log_path" 2>&1; then
      write_report "$report_path" "$command_name" false helper_failed "$repo" "$out_dir" "$codegen_helper_script" "$codegen_summary_path" "$codegen_log_path" "$codegen_manifest_path" cheng_codegen_v1 "$module_count" 0 0 "$typescript_version" "$asset_count" "$tailwind_token_count" "$required_host_group_count" "$required_host_groups" "$rsg_node_count" "$rsg_edge_count" "$blocker_count" "$blocked"
      echo "r2c-react-v3: codegen surface helper failed" >&2
      tail -n 80 "$codegen_log_path" >&2 || true
      return 1
    fi
    codegen_manifest_path="$(read_summary_value "$codegen_summary_path" codegen_manifest_path "$codegen_manifest_path")"
    typescript_version="$(read_summary_value "$codegen_summary_path" typescript_version "$typescript_version")"
    set -- "$exec_helper_script" --repo "$repo" --out-dir "$out_dir" --codegen-manifest "$codegen_manifest_path" --summary-out "$exec_summary_path"
    if ! node "$@" >"$exec_log_path" 2>&1; then
      write_report "$report_path" "$command_name" false helper_failed "$repo" "$out_dir" "$exec_helper_script" "$exec_summary_path" "$exec_log_path" "$exec_snapshot_path" cheng_codegen_exec_snapshot_v1 "$module_count" 0 0 "$typescript_version" "$asset_count" "$tailwind_token_count" "$required_host_group_count" "$required_host_groups" "$rsg_node_count" "$rsg_edge_count" "$blocker_count" "$blocked"
      echo "r2c-react-v3: exec surface helper failed" >&2
      tail -n 120 "$exec_log_path" >&2 || true
      return 1
    fi
    exec_semantic_nodes_count="$(read_summary_value "$exec_summary_path" snapshot_semantic_nodes_count 0)"
    exec_snapshot_path="$(read_summary_value "$exec_summary_path" snapshot_path "$exec_snapshot_path")"
    if [ -z "$truth_trace_raw" ]; then
      write_report "$report_path" "$command_name" false truth_compare_input_missing "$repo" "$out_dir" "$exec_helper_script" "$exec_summary_path" "$exec_log_path" "$exec_snapshot_path" cheng_codegen_exec_snapshot_v1 "$module_count" 1 "$exec_semantic_nodes_count" "$typescript_version" "$asset_count" "$tailwind_token_count" "$required_host_group_count" "$required_host_groups" "$rsg_node_count" "$rsg_edge_count" "$blocker_count" "$blocked"
      echo "r2c-react-v3: compile 现在已经 lift 到 exec surface；要完成真值验收请显式传 --truth-trace 和可选 --truth-state" >&2
      return 2
    fi
    truth_trace_path="$(abs_path "$repo" "$truth_trace_raw")"
    if [ ! -f "$truth_trace_path" ]; then
      write_report "$report_path" "$command_name" false missing_truth_trace "$repo" "$out_dir" "$truth_compare_helper_script" "$truth_compare_summary_path" "$truth_compare_log_path" "$truth_compare_path" truth_compare_v1 "$module_count" 1 "$exec_semantic_nodes_count" "$typescript_version" "$asset_count" "$tailwind_token_count" "$required_host_group_count" "$required_host_groups" "$rsg_node_count" "$rsg_edge_count" "$blocker_count" "$blocked"
      echo "r2c-react-v3: missing truth trace: $truth_trace_path" >&2
      return 1
    fi
    set -- "$truth_compare_helper_script" --exec-snapshot "$exec_snapshot_path" --truth-trace "$truth_trace_path" --out "$truth_compare_path" --summary-out "$truth_compare_summary_path"
    if [ -n "$truth_state" ]; then
      set -- "$@" --truth-state "$truth_state"
    fi
    if ! node "$@" >"$truth_compare_log_path" 2>&1; then
