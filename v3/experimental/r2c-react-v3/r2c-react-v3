maybe_exec_stage3() {
  if [ "${R2C_REACT_V3_NO_STAGE3_HANDOFF:-0}" = "1" ]; then
    return 1
  fi
  if [ ! -f "$bridge_env" ]; then
    return 1
  fi
  # shellcheck disable=SC1090
  . "$bridge_env"
  if [ -n "${V3_BOOTSTRAP_STAGE3:-}" ] && "$V3_BOOTSTRAP_STAGE3" r2c-react-v3 help >/dev/null 2>&1; then
    exec "$V3_BOOTSTRAP_STAGE3" r2c-react-v3 "$@"
  fi
  return 1
}

read_flag() {
  key="$1"
  default_value="$2"
  shift 2
  while [ "$#" -gt 0 ]; do
    case "$1" in
      "$key")
        shift
        if [ "$#" -gt 0 ]; then
          printf '%s\n' "$1"
          return 0
        fi
        ;;
      "$key":*)
        printf '%s\n' "${1#"$key:"}"
        return 0
        ;;
      "$key"=*)
        printf '%s\n' "${1#"$key="}"
        return 0
        ;;
    esac
    shift
  done
  printf '%s\n' "$default_value"
}

collect_flag_values() {
  key="$1"
  shift
  while [ "$#" -gt 0 ]; do
    case "$1" in
      "$key")
        shift
        if [ "$#" -gt 0 ]; then
          printf '%s\n' "$1"
        fi
        ;;
      "$key":*)
        printf '%s\n' "${1#"$key:"}"
        ;;
      "$key"=*)
        printf '%s\n' "${1#"$key="}"
        ;;
    esac
    shift
  done
}

has_flag() {
  key="$1"
  shift
  while [ "$#" -gt 0 ]; do
    case "$1" in
      "$key")
        return 0
        ;;
    esac
    shift
  done
  return 1
}

abs_path() {
  base="$1"
  target="$2"
  node -e 'const path=require("node:path"); console.log(path.resolve(process.argv[1], process.argv[2]));' "$base" "$target"
}

read_summary_value() {
  summary_path="$1"
  key="$2"
  default_value="$3"
  if [ ! -f "$summary_path" ]; then
    printf '%s\n' "$default_value"
    return 0
  fi
  value="$(awk -F= -v want="$key" '$1 == want { sub(/^[^=]*=/, ""); print; exit }' "$summary_path")"
  if [ -n "$value" ]; then
    printf '%s\n' "$value"
  else
    printf '%s\n' "$default_value"
  fi
}

