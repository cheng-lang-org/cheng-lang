    return 1
  fi
  route_count="$(read_summary_value "$summary_path" route_count 0)"
  typescript_version="$(read_summary_value "$summary_path" typescript_version '')"
  write_report "$report_path" discover-truth-routes true ok "$repo" "$out_dir" "$helper_script" "$summary_path" "$log_path" "$artifact_path" truth_routes_v1 0 "$route_count" 0 "$typescript_version"
