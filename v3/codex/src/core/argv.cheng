import std/strings

@importc("__cheng_rt_paramCount")
fn codexRtParamCount(): int32

@importc("__cheng_rt_paramStrCopyBridgeInto")
fn codexRtParamStrCopyBridgeInto(i: int32, out: var str)

fn codexArgCount(): int32 =
    let argc = codexRtParamCount()
    if argc <= 0:
        return 0
    return argc - 1

fn codexArgStr(i: int32): str =
    var out = ""
    codexRtParamStrCopyBridgeInto(i, out)
    return out

fn codexArgTryInlineValue(arg: str, key: str, outValue: var str): bool =
    outValue = ""
    if !strings.hasPrefix(arg, key):
        return false
    if strings.hasPrefix(arg, key + ":"):
        outValue = strings.dropPrefix(arg, key + ":")
        return true
    if strings.hasPrefix(arg, key + "="):
        outValue = strings.dropPrefix(arg, key + "=")
        return true
    return false

fn codexHasFlag(flag: str): bool =
    let count = codexArgCount()
    var i = 1
    while i <= count:
        if codexArgStr(i) == flag:
            return true
        i = i + 1
    return false

fn codexReadFlagValue(key: str, outValue: var str): bool =
    outValue = ""
    let count = codexArgCount()
    var i = 1
    while i <= count:
        let arg = codexArgStr(i)
        if codexArgTryInlineValue(arg, key, outValue):
            return true
        if arg == key:
            if i >= count:
                return false
            outValue = codexArgStr(i + 1)
            return true
        i = i + 1
    return false

fn codexReadFlagOrDefault(key: str, defaultValue: str): str =
    var out = ""
    if codexReadFlagValue(key, out):
        return out
    return defaultValue
