import std/monotimes
import std/os
import std/os_host_process as hostos
import std/result
import std/strings
import std/times
import cheng/codex/core/store
import cheng/codex/core/text as textutil
import cheng/codex/protocol/types

fn codexNowUnix(): int64 =
    return times.EpochTimeSeconds()

fn codexNowMonoNs(): int64 =
    let mono = monotimes.GetMonoTime()
    return monotimes.MonoTimeNs(mono)

fn codexSessionId(): str =
    return "codex-" + strings.Int64ToStr(codexNowUnix()) + "-" + strings.Int64ToStr(codexNowMonoNs())

fn codexDefaultTitle(promptText: str, commandText: str, sessionId: str): str =
    let promptTitle = textutil.codexTitleFromText(promptText)
    if textutil.codexTextNonEmpty(promptTitle):
        return promptTitle
    let commandTitle = textutil.codexTitleFromText(commandText)
    if textutil.codexTextNonEmpty(commandTitle):
        return commandTitle
    return sessionId

fn codexNewSession(cwd: str, title: str, promptText: str, commandText: str): types.CodexSession =
    var out: types.CodexSession
    out.sessionId = codexSessionId()
    out.cwd = cwd
    out.createdAt = codexNowUnix()
    out.updatedAt = out.createdAt
    if textutil.codexTextNonEmpty(title):
        out.title = title
    else:
        out.title = codexDefaultTitle(promptText, commandText, out.sessionId)
    return out

fn codexEnsureSession(home: str, req: types.CodexExecRequest): Result[types.CodexSession] =
    if textutil.codexTextNonEmpty(req.sessionId):
        let loadRes = store.codexStoreSessionRead(home, req.sessionId)
        if IsErr(loadRes):
            return Err[types.CodexSession](Error(loadRes))
        return Ok[types.CodexSession](Value(loadRes))
    var cwd = os.GetCurrentDir()
    if textutil.codexTextNonEmpty(req.cwd):
        cwd = req.cwd
    return Ok[types.CodexSession](codexNewSession(cwd, req.title, req.promptText, req.commandText))

fn codexAssistantSummary(exitCode: int32, outputText: str): str =
    if exitCode == 0:
        if textutil.codexTextNonEmpty(outputText):
            return "command ok rc=0"
        return "command ok rc=0 (no output)"
    if textutil.codexTextNonEmpty(outputText):
        return "command failed rc=" + intToStr(exitCode)
    return "command failed rc=" + intToStr(exitCode) + " (no output)"

fn codexAppendTurn(session: var types.CodexSession,
                   promptText: str,
                   commandText: str,
                   outputText: str,
                   exitCode: int32,
                   approved: bool) =
    var turn: types.CodexTurn
    turn.promptText = promptText
    turn.commandText = commandText
    turn.outputText = outputText
    turn.assistantText = codexAssistantSummary(exitCode, outputText)
    turn.exitCode = exitCode
    turn.approved = approved
    add(session.turns, turn)
    session.updatedAt = codexNowUnix()
    session.lastExitCode = exitCode

fn codexShellCapture(commandText: str, cwd: str, outOutput: var str, outExitCode: var int32) =
    var argv: str[]
    add(argv, "-lc")
    add(argv, commandText)
    var envOverrides: str[]
    hostos.OsHostProcessExecFileCaptureFill("/bin/sh",
                                            argv,
                                            envOverrides,
                                            cwd,
                                            true,
                                            0,
                                            outOutput,
                                            outExitCode)

fn codexSandboxProfilePathText(path: str): str =
    return "\"" + path + "\""

fn codexSandboxAllowWriteRule(path: str): str =
    return "(allow file-read* file-test-existence file-write* (subpath " +
        codexSandboxProfilePathText(path) + "))\n"

fn codexSandboxProfileText(writableRoot: str): str =
    var parts: str[]
    add(parts, "(version 1)\n")
    add(parts, "(deny default)\n")
    add(parts, "(allow process*)\n")
    add(parts, "(allow file-read*)\n")
    add(parts, "(allow file-read* file-test-existence file-write-data (literal \"/dev/null\"))\n")
    add(parts, "(allow file-read-data file-test-existence file-write-data (subpath \"/dev/fd\"))\n")
    add(parts, "(allow file-read* file-test-existence file-write* (subpath \"/tmp\"))\n")
    add(parts, "(allow file-read* file-write* (subpath \"/private/tmp\"))\n")
    add(parts, "(allow file-read* file-write* (subpath \"/var/tmp\"))\n")
    add(parts, "(allow file-read* file-write* (subpath \"/private/var/tmp\"))\n")
    if textutil.codexTextNonEmpty(writableRoot):
        add(parts, codexSandboxAllowWriteRule(writableRoot))
    return Fmt(parts)

fn codexSandboxWritableRoot(cwd: str, writableRoot: str): str =
    if !textutil.codexTextNonEmpty(writableRoot):
        return cwd
    if os.IsAbsolute(writableRoot):
        return writableRoot
    return os.JoinPath(cwd, writableRoot)

fn codexExecuteShell(home: str,
                     req: types.CodexExecRequest): Result[types.CodexExecResult] =
    if !textutil.codexTextNonEmpty(req.commandText):
        return Err[types.CodexExecResult]("codex exec: missing --command")
    if !req.autoApprove:
        return Err[types.CodexExecResult]("codex exec: shell execution requires --auto-approve")
    let sessionRes = codexEnsureSession(home, req)
    if IsErr(sessionRes):
        return Err[types.CodexExecResult](Error(sessionRes))
    var session = Value(sessionRes)
    var cwd = session.cwd
    if textutil.codexTextNonEmpty(req.cwd):
        cwd = req.cwd
    var outputText = ""
    var exitCode = -1
    codexShellCapture(req.commandText, cwd, outputText, exitCode)
    codexAppendTurn(session, req.promptText, req.commandText, outputText, exitCode, true)
    let saveRes = store.codexStoreSessionWrite(home, session)
    if IsErr(saveRes):
        return Err[types.CodexExecResult](Error(saveRes))
    var out: types.CodexExecResult
    out.ok = exitCode == 0
    out.exitCode = exitCode
    out.outputText = outputText
    out.assistantText = codexAssistantSummary(exitCode, outputText)
    return Ok[types.CodexExecResult](out)

fn codexSessionRenderSummary(session: types.CodexSession): str =
    var parts: str[]
    add(parts, Fmt"session_id={session.sessionId}")
    add(parts, Fmt"title={session.title}")
    add(parts, Fmt"cwd={session.cwd}")
    add(parts, Fmt"turn_count={intToStr(session.turns.len)}")
    add(parts, Fmt"last_exit_code={intToStr(session.lastExitCode)}")
    return Lines(parts)

fn codexSessionHistoryText(session: types.CodexSession, maxTurns: int32): str =
    if session.turns.len <= 0:
        return "(empty session)"
    var start = 0
    if maxTurns > 0 && session.turns.len > maxTurns:
        start = session.turns.len - maxTurns
    var parts: str[]
    for i in start..<session.turns.len:
        let turn = session.turns[i]
        add(parts, Fmt"[{intToStr(i + 1)}] ")
        if textutil.codexTextNonEmpty(turn.promptText):
            add(parts, Fmt"prompt: {turn.promptText}\n")
        if textutil.codexTextNonEmpty(turn.commandText):
            add(parts, Fmt"$ {turn.commandText}\n")
        if textutil.codexTextNonEmpty(turn.outputText):
            add(parts, turn.outputText)
            if len(turn.outputText) <= 0 || turn.outputText[len(turn.outputText) - 1] != '\n':
                add(parts, "\n")
        add(parts, Fmt"{turn.assistantText}\n")
    return Fmt(parts)

fn codexApplyPatch(cwd: str, patchPath: str): Result[types.CodexExecResult] =
    if !textutil.codexTextNonEmpty(patchPath):
        return Err[types.CodexExecResult]("codex apply: missing --patch")
    let command = "git apply " + os.QuoteShell(patchPath)
    var out: types.CodexExecResult
    codexShellCapture(command, cwd, out.outputText, out.exitCode)
    out.ok = out.exitCode == 0
    out.assistantText = codexAssistantSummary(out.exitCode, out.outputText)
    return Ok[types.CodexExecResult](out)

fn codexRunInSandbox(cwd: str, writableRoot: str, commandText: str): Result[types.CodexExecResult] =
    if !textutil.codexTextNonEmpty(commandText):
        return Err[types.CodexExecResult]("codex sandbox: missing command")
    let sandboxExec = "/usr/bin/sandbox-exec"
    if !store.codexStoreFileExists(sandboxExec):
        return Err[types.CodexExecResult]("codex sandbox: /usr/bin/sandbox-exec not available")
    var actualCwd = os.GetCurrentDir()
    if textutil.codexTextNonEmpty(cwd):
        actualCwd = cwd
    let writeRoot = codexSandboxWritableRoot(actualCwd, writableRoot)
    let profilePath = "/tmp/codex-sandbox-" + strings.Int64ToStr(codexNowUnix()) + "-" +
        strings.Int64ToStr(codexNowMonoNs()) + ".sb"
    if !store.codexStoreWriteText(profilePath, codexSandboxProfileText(writeRoot)):
        return Err[types.CodexExecResult]("codex sandbox: failed to write profile")
    var out: types.CodexExecResult
    hostos.OsHostProcessExecFileCaptureFill(sandboxExec,
                                            ["-f", profilePath, "/bin/sh", "-lc", commandText],
                                            [],
                                            actualCwd,
                                            true,
                                            0,
                                            out.outputText,
                                            out.exitCode)
    let _remove = os.RemoveFile(profilePath)
    out.ok = out.exitCode == 0
    out.assistantText = codexAssistantSummary(out.exitCode, out.outputText)
    return Ok[types.CodexExecResult](out)
