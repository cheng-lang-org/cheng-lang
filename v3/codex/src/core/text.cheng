import std/rawbytes
import std/strings
import std/strutils as strutil

fn codexTextTrim(raw: str): str =
    return strutil.Strip(raw)

fn codexTextNonEmpty(raw: str): bool =
    return codexTextTrim(raw) != ""

fn codexTextStartsWith(text: str, prefix: str): bool =
    return strings.HasPrefix(text, prefix)

fn codexTextDropPrefix(text: str, prefix: str): str =
    if !strings.HasPrefix(text, prefix):
        return text
    return strings.DropPrefix(text, prefix)

fn codexTextSlice(text: str, start: int32, count: int32): str =
    if count <= 0:
        return ""
    return strings.SliceBytes(text, start, count)

fn codexTextFind(text: str, needle: char): int32 =
    for i in 0..<len(text):
        if text[i] == needle:
            return i
    return -1

fn codexTextSplitFirst(text: str, sep: char, leftOut: var str, rightOut: var str): bool =
    leftOut = ""
    rightOut = ""
    let pos = codexTextFind(text, sep)
    if pos < 0:
        return false
    leftOut = codexTextSlice(text, 0, pos)
    rightOut = codexTextSlice(text, pos + 1, len(text) - pos - 1)
    return true

fn codexHexEncode(text: str): str =
    let bytes = rawbytes.BytesFromString(text)
    return rawbytes.BytesToHex(bytes)

fn codexHexNibble(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return int32(ch) - int32('a') + 10
    if ch >= 'A' && ch <= 'F':
        return int32(ch) - int32('A') + 10
    return -1

fn codexHexDecode(text: str, outValue: var str): bool =
    outValue = ""
    let n = len(text)
    if n == 0:
        return true
    if (n % 2) != 0:
        return false
    let outLen = n / 2
    var outBytes = bytesAlloc(outLen)
    if bytesLen(outBytes) != outLen:
        return false
    var i = 0
    while i < n:
        let hi = codexHexNibble(text[i])
        let lo = codexHexNibble(text[i + 1])
        if hi < 0 || lo < 0:
            return false
        bytesSet(outBytes, i / 2, (hi << 4) | lo)
        i = i + 2
    outValue = bytesToString(outBytes)
    return true

fn codexParseInt32Text(raw: str, outValue: var int32): bool =
    let text = codexTextTrim(raw)
    if text == "":
        return false
    var sign = int32(1)
    var i = 0
    if text[0] == '-':
        sign = int32(-1)
        i = 1
    elif text[0] == '+':
        i = 1
    if i >= len(text):
        return false
    var value = int32(0)
    while i < len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return false
        let digit = int32(ch) - int32('0')
        value = value * int32(10) + digit
        i = i + 1
    outValue = value * sign
    return true

fn codexParseInt64Text(raw: str, outValue: var int64): bool =
    let text = codexTextTrim(raw)
    if text == "":
        return false
    var sign = int64(1)
    var i = 0
    if text[0] == '-':
        sign = int64(-1)
        i = 1
    elif text[0] == '+':
        i = 1
    if i >= len(text):
        return false
    var value = int64(0)
    while i < len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return false
        let digit = int64(int32(ch) - int32('0'))
        value = value * int64(10) + digit
        i = i + 1
    outValue = value * sign
    return true

fn codexBoolText(value: bool): str =
    if value:
        return "1"
    return "0"

fn codexTextLowerAscii(raw: str): str =
    let text = codexTextTrim(raw)
    if text == "":
        return ""
    var out = ""
    var i = 0
    while i < len(text):
        let ch = text[i]
        if ch >= 'A' && ch <= 'Z':
            let lower = char(int32(ch) - int32('A') + int32('a'))
            out = out + strings.CharToStr(lower)
        else:
            out = out + strings.CharToStr(ch)
        i = i + 1
    return out

fn codexParseBoolText(raw: str, outValue: var bool): bool =
    let text = codexTextLowerAscii(raw)
    if text == "":
        return false
    if text == "1" || text == "true" || text == "yes" || text == "on":
        outValue = true
        return true
    if text == "0" || text == "false" || text == "no" || text == "off":
        outValue = false
        return true
    return false

fn codexTitleFromText(raw: str): str =
    let text = codexTextTrim(raw)
    if text == "":
        return ""
    if len(text) <= 48:
        return text
    return codexTextSlice(text, 0, 48)
