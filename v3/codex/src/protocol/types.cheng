type
    CodexTurn =
        promptText: str
        commandText: str
        outputText: str
        assistantText: str
        exitCode: int32
        approved: bool

    CodexSession =
        sessionId: str
        title: str
        cwd: str
        createdAt: int64
        updatedAt: int64
        lastExitCode: int32
        turns: CodexTurn[]

    CodexExecRequest =
        sessionId: str
        title: str
        cwd: str
        promptText: str
        commandText: str
        autoApprove: bool

    CodexExecResult =
        ok: bool
        exitCode: int32
        outputText: str
        assistantText: str

    CodexSessionSummary =
        sessionId: str
        title: str
        cwd: str
        updatedAt: int64
        lastExitCode: int32
        turnCount: int32

    CodexPluginSpec =
        name: str
        path: str
        enabled: bool

    CodexMcpServerSpec =
        name: str
        transportKind: str
        launchCommand: str
        cwd: str
        url: str
        bearerTokenEnvVar: str
        enabled: bool

fn codexTurnZero(): CodexTurn =
    var out: CodexTurn
    out.promptText = ""
    out.commandText = ""
    out.outputText = ""
    out.assistantText = ""
    out.exitCode = -1
    out.approved = false
    return out

fn codexSessionZero(): CodexSession =
    var out: CodexSession
    out.sessionId = ""
    out.title = ""
    out.cwd = ""
    out.createdAt = 0
    out.updatedAt = 0
    out.lastExitCode = -1
    out.turns = []
    return out

fn codexExecRequestZero(): CodexExecRequest =
    var out: CodexExecRequest
    out.sessionId = ""
    out.title = ""
    out.cwd = ""
    out.promptText = ""
    out.commandText = ""
    out.autoApprove = false
    return out

fn codexExecResultZero(): CodexExecResult =
    var out: CodexExecResult
    out.ok = false
    out.exitCode = -1
    out.outputText = ""
    out.assistantText = ""
    return out

fn codexSessionSummaryZero(): CodexSessionSummary =
    var out: CodexSessionSummary
    out.sessionId = ""
    out.title = ""
    out.cwd = ""
    out.updatedAt = 0
    out.lastExitCode = -1
    out.turnCount = 0
    return out

fn codexPluginSpecZero(): CodexPluginSpec =
    var out: CodexPluginSpec
    out.name = ""
    out.path = ""
    out.enabled = false
    return out

fn codexMcpServerSpecZero(): CodexMcpServerSpec =
    var out: CodexMcpServerSpec
    out.name = ""
    out.transportKind = ""
    out.launchCommand = ""
    out.cwd = ""
    out.url = ""
    out.bearerTokenEnvVar = ""
    out.enabled = false
    return out
