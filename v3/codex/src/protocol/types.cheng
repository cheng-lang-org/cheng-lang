type
    CodexTurn =
        promptText: str
        commandText: str
        outputText: str
        assistantText: str
        exitCode: int32 = -1
        approved: bool

    CodexSession =
        sessionId: str
        title: str
        cwd: str
        createdAt: int64
        updatedAt: int64
        lastExitCode: int32 = -1
        turns: CodexTurn[]

    CodexExecRequest =
        sessionId: str
        title: str
        cwd: str
        promptText: str
        commandText: str
        autoApprove: bool

    CodexExecResult =
        ok: bool
        exitCode: int32 = -1
        outputText: str
        assistantText: str

    CodexSessionSummary =
        sessionId: str
        title: str
        cwd: str
        updatedAt: int64
        lastExitCode: int32 = -1
        turnCount: int32

    CodexPluginSpec =
        name: str
        path: str
        enabled: bool

    CodexMcpServerSpec =
        name: str
        transportKind: str
        launchCommand: str
        cwd: str
        url: str
        bearerTokenEnvVar: str
        enabled: bool
