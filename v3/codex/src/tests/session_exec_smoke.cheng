import std/os
import std/result
import std/times
import cheng/codex/core/engine
import cheng/codex/core/store
import cheng/codex/protocol/types

fn codexSmokePrint(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn main(): int32 =
    let homeName = "codex-v3-smoke-" + intToStr(int32(times.EpochTimeSeconds()))
    let home = os.JoinPath("/tmp", homeName)
    var req: types.CodexExecRequest
    req.cwd = os.GetCurrentDir()
    req.promptText = "smoke"
    req.commandText = "printf codex-smoke"
    req.autoApprove = true
    let execRes = engine.codexExecuteShell(home, req)
    assert(IsOk(execRes), "codex smoke: exec ok")
    let run = Value(execRes)
    assert(run.ok, "codex smoke: shell rc")
    assert(run.outputText == "codex-smoke", "codex smoke: shell output")
    let lastRes = store.codexStoreLoadLastSession(home)
    assert(IsOk(lastRes), "codex smoke: last session")
    let session = Value(lastRes)
    assert(session.turns.len == 1, "codex smoke: turn count")
    assert(session.turns[0].commandText == "printf codex-smoke", "codex smoke: command text")
    assert(session.turns[0].outputText == "codex-smoke", "codex smoke: output text")
    let saveAuth = store.codexStoreSaveApiKey(home, "test-key")
    assert(IsOk(saveAuth), "codex smoke: save auth")
    assert(store.codexStoreReadApiKey(home) == "test-key", "codex smoke: load auth")
    codexSmokePrint("codex v3 session_exec_smoke ok")
    return 0
