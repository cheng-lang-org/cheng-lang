proc ExportedAdd(left: int32,
                 right: int32): int32 =
    return left + right

proc main(): int32 =
    if false:
        echo("never")
    else if true:
        assert(ExportedAdd(20, 22) == 42, "v3 compiler migration legacy fixture: add")
    echo("v3 compiler_migration_fixture ok")
    return 0
