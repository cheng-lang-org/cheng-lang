import std/cmdline as cmdline
import std/os
import std/result
import std/strings
import std/strutils as strutil
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/oracle_types as oracle_types
import cheng/v3/project/oracle_fixture
import cheng/v3/project/oracle_bft_state_machine as oracle_bft
import cheng/v3/project/oracle_bft_state_host as oracle_host

fn v3OracleMainPrintOut(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn v3OracleMainPrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn v3OracleMainUsage() =
    v3OracleMainPrintOut("usage: oracle_bft_state_machine <command> [flags]")
    v3OracleMainPrintOut("")
    v3OracleMainPrintOut("commands:")
    v3OracleMainPrintOut("  self-test")
    v3OracleMainPrintOut("  init --state:<file> --app-id:<id> [--force]")
    v3OracleMainPrintOut("  fixture-finalize --state:<file> --height:<n> --round:<n> --reporter-start:<n> --reporter-end:<n> [--time-hint-ms:<n>]")
    v3OracleMainPrintOut("  show-state --state:<file>")
    v3OracleMainPrintOut("  query-latest --state:<file> --pair:<ASSET/QUOTE> --now-round:<n>")
    v3OracleMainPrintOut("  query-twap --state:<file> --pair:<ASSET/QUOTE> --window-rounds:<n> --now-round:<n>")

fn v3OracleMainTextStartsWith(text: str, prefix: str): bool =
    if len(prefix) > len(text):
        return false
    var i = 0
    while i < len(prefix):
        if text[i] != prefix[i]:
            return false
        i = i + 1
    return true

fn v3OracleMainReadFlagValue(flag: str, outValue: var str): bool =
    outValue = ""
    let count = cmdline.ParamCount()
    let colonPrefix = flag + ":"
    let eqPrefix = flag + "="
    var i = 1
    while i <= count:
        let arg = cmdline.ParamStr(i)
        if arg == flag:
            if i >= count:
                return false
            outValue = cmdline.ParamStr(i + 1)
            return true
        if v3OracleMainTextStartsWith(arg, colonPrefix):
            outValue = strings.SliceBytes(arg, len(colonPrefix), len(arg) - len(colonPrefix))
            return true
        if v3OracleMainTextStartsWith(arg, eqPrefix):
            outValue = strings.SliceBytes(arg, len(eqPrefix), len(arg) - len(eqPrefix))
            return true
        i = i + 1
    return false

fn v3OracleMainReadRequiredFlag(flag: str, outValue: var str): Result[bool] =
    outValue = ""
    if !v3OracleMainReadFlagValue(flag, outValue):
        return Err[bool]("v3 oracle main: missing " + flag)
    outValue = strutil.Strip(outValue)
    if len(outValue) <= 0:
        return Err[bool]("v3 oracle main: empty " + flag)
    return Ok[bool](true)

fn v3OracleMainParseInt64(raw: str): Result[int64] =
    let text = strutil.Strip(raw)
    if len(text) <= 0:
        return Err[int64]("v3 oracle main: invalid integer")
    var sign = int64(1)
    var i = 0
    if text[0] == '+':
        i = 1
    elif text[0] == '-':
        sign = int64(-1)
        i = 1
    if i >= len(text):
        return Err[int64]("v3 oracle main: invalid integer")
    var value = int64(0)
    while i < len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int64]("v3 oracle main: invalid integer")
        value = value * int64(10) + int64(int32(ch) - int32('0'))
        i = i + 1
    return Ok[int64](value * sign)

fn v3OracleMainReadRequiredInt64Flag(flag: str): Result[int64] =
    var raw = ""
    let readRes = v3OracleMainReadRequiredFlag(flag, raw)
    if IsErr(readRes):
        return Err[int64](Error(readRes))
    return v3OracleMainParseInt64(raw)

fn v3OracleMainReadOptionalInt64Flag(flag: str, defaultValue: int64): Result[int64] =
    var raw = ""
    if !v3OracleMainReadFlagValue(flag, raw):
        return Ok[int64](defaultValue)
    return v3OracleMainParseInt64(raw)

fn v3OracleMainAppendReportLine(report: var str, key: str, value: str) =
    report = report + key + "=" + value + "\n"

fn v3OracleMainCommittee(): oracle_types.V3OracleCommitteeConfig =
    return oracle_fixture.oracleSmokeCommittee()

fn v3OracleMainAssetIdFromText(textRaw: str): int32 =
    let text = strutil.Strip(textRaw)
    if text == "BTC":
        return oracle_types.v3OracleAssetBtc
    if text == "ETH":
        return oracle_types.v3OracleAssetEth
    if text == "SOL":
        return oracle_types.v3OracleAssetSol
    if text == "BNB":
        return oracle_types.v3OracleAssetBnb
    if text == "XAU":
        return oracle_types.v3OracleAssetXau
    if text == "XAG":
        return oracle_types.v3OracleAssetXag
    if text == "XPT":
        return oracle_types.v3OracleAssetXpt
    if text == "XPD":
        return oracle_types.v3OracleAssetXpd
    return 0

fn v3OracleMainQuoteIdFromText(textRaw: str): int32 =
    let text = strutil.Strip(textRaw)
    if text == "USD":
        return oracle_types.v3OracleQuoteUsd
    if text == "CNY":
        return oracle_types.v3OracleQuoteCny
    if text == "EUR":
        return oracle_types.v3OracleQuoteEur
    if text == "HKD":
        return oracle_types.v3OracleQuoteHkd
    return 0

fn v3OracleMainResolvePair(pairTextRaw: str,
                           outPairId: var int32,
                           outPairName: var str): Result[bool] =
    outPairId = 0
    outPairName = ""
    var slashPos = -1
    var i = 0
    while i < len(pairTextRaw):
        if pairTextRaw[i] == '/':
            slashPos = i
            break
        i = i + 1
    if slashPos <= 0 || slashPos >= len(pairTextRaw) - 1:
        return Err[bool]("v3 oracle main: invalid pair")
    let assetText = strings.SliceBytes(pairTextRaw, 0, slashPos)
    let quoteText = strings.SliceBytes(pairTextRaw, slashPos + 1, len(pairTextRaw) - slashPos - 1)
    let assetId = v3OracleMainAssetIdFromText(assetText)
    let quoteId = v3OracleMainQuoteIdFromText(quoteText)
    if assetId <= 0 || quoteId <= 0:
        return Err[bool]("v3 oracle main: unsupported pair")
    let pairRes = oracle_types.v3OraclePairIdFromAssetQuote(assetId, quoteId)
    if IsErr(pairRes):
        return Err[bool](Error(pairRes))
    outPairId = Value(pairRes)
    outPairName = strutil.Strip(assetText) + "/" + strutil.Strip(quoteText)
    return Ok[bool](true)

fn v3OracleMainAppendFixtureBatch(batch: var oracle_bft.V3OracleBftTxBatch,
                                  roundId: int64,
                                  reporterStart: int32,
                                  reporterEnd: int32) =
    var reporter = reporterStart
    while reporter <= reporterEnd:
        oracle_bft.v3OracleBftTxBatchAdd(batch, oracle_fixture.oracleSmokeBatch(roundId, reporter))
        reporter = reporter + 1

fn v3OracleMainInitCommand(): int32 =
    var statePath = ""
    let stateRes = v3OracleMainReadRequiredFlag("--state", statePath)
    if IsErr(stateRes):
        v3OracleMainPrintErr(Error(stateRes))
        return 2
    var appId = ""
    let appRes = v3OracleMainReadRequiredFlag("--app-id", appId)
    if IsErr(appRes):
        v3OracleMainPrintErr(Error(appRes))
        return 2
    if os.FileExists(statePath) && !cmdline.HasFlag("--force"):
        v3OracleMainPrintErr("v3 oracle main: state already exists (pass --force)")
        return 2
    let machine = oracle_bft.v3OracleBftStateMachineInit(appId, v3OracleMainCommittee())
    let writeRes = oracle_host.v3OracleBftWriteState(statePath, machine)
    if IsErr(writeRes):
        v3OracleMainPrintErr(Error(writeRes))
        return 1
    var report = ""
    v3OracleMainAppendReportLine(report, "format", "v3_oracle_bft_init_v1")
    v3OracleMainAppendReportLine(report, "app_id", appId)
    v3OracleMainAppendReportLine(report, "state", statePath)
    v3OracleMainAppendReportLine(report, "app_hash", layout.fixedBytes32Hex(oracle_bft.v3OracleBftStateMachineQueryAppHash(machine)))
    v3OracleMainPrintOut(strutil.Strip(report))
    return 0

fn v3OracleMainFixtureFinalizeCommand(): int32 =
    var statePath = ""
    let stateRes = v3OracleMainReadRequiredFlag("--state", statePath)
    if IsErr(stateRes):
        v3OracleMainPrintErr(Error(stateRes))
        return 2
    let heightRes = v3OracleMainReadRequiredInt64Flag("--height")
    if IsErr(heightRes):
        v3OracleMainPrintErr(Error(heightRes))
        return 2
    let roundRes = v3OracleMainReadRequiredInt64Flag("--round")
    if IsErr(roundRes):
        v3OracleMainPrintErr(Error(roundRes))
        return 2
    let reporterStartRes = v3OracleMainReadRequiredInt64Flag("--reporter-start")
    if IsErr(reporterStartRes):
        v3OracleMainPrintErr(Error(reporterStartRes))
        return 2
    let reporterEndRes = v3OracleMainReadRequiredInt64Flag("--reporter-end")
    if IsErr(reporterEndRes):
        v3OracleMainPrintErr(Error(reporterEndRes))
        return 2
    let defaultTimeHint = oracle_types.v3OracleRoundEndMs(Value(roundRes)) + int64(1)
    let timeHintRes = v3OracleMainReadOptionalInt64Flag("--time-hint-ms", defaultTimeHint)
    if IsErr(timeHintRes):
        v3OracleMainPrintErr(Error(timeHintRes))
        return 2
    if Value(heightRes) <= int64(0) || Value(roundRes) < int64(0):
        v3OracleMainPrintErr("v3 oracle main: invalid height or round")
        return 2
    if Value(reporterStartRes) <= int64(0) || Value(reporterEndRes) < Value(reporterStartRes):
        v3OracleMainPrintErr("v3 oracle main: invalid reporter range")
        return 2
    var machine: oracle_bft.V3OracleBftStateMachine
    let loadRes = oracle_host.v3OracleBftLoadState(statePath, machine)
    if IsErr(loadRes):
        v3OracleMainPrintErr(Error(loadRes))
        return 1
    var batch = oracle_bft.V3OracleBftTxBatch()
    v3OracleMainAppendFixtureBatch(batch,
                                   Value(roundRes),
                                   int32(Value(reporterStartRes)),
                                   int32(Value(reporterEndRes)))
    var summary: oracle_bft.V3OracleBftBlockSummary
    let context = oracle_bft.v3OracleBftBlockContextMake(Value(heightRes),
                                                         0,
                                                         Value(timeHintRes),
                                                         layout.FixedBytes32())
    oracle_bft.v3OracleBftStateMachineFinalizeBatchSummaryWithContext(machine, context, batch, summary)
    let _commit = oracle_bft.v3OracleBftStateMachineCommit(machine)
    let writeRes = oracle_host.v3OracleBftWriteState(statePath, machine)
    if IsErr(writeRes):
        v3OracleMainPrintErr(Error(writeRes))
        return 1
    var report = ""
    v3OracleMainAppendReportLine(report, "format", "v3_oracle_bft_finalize_v1")
    v3OracleMainAppendReportLine(report, "height", strings.Int64ToStr(summary.height))
    v3OracleMainAppendReportLine(report, "round_id", strings.Int64ToStr(Value(roundRes)))
    v3OracleMainAppendReportLine(report, "accepted_count", intToStr(summary.acceptedCount))
    v3OracleMainAppendReportLine(report, "rejected_count", intToStr(summary.rejectedCount))
    v3OracleMainAppendReportLine(report, "finalized_round_count", intToStr(summary.finalizedRoundCount))
    v3OracleMainAppendReportLine(report, "last_finalized_round_id", strings.Int64ToStr(summary.lastFinalizedRoundId))
    v3OracleMainAppendReportLine(report, "app_hash", layout.fixedBytes32Hex(summary.appHash))
    v3OracleMainPrintOut(strutil.Strip(report))
    return 0

fn v3OracleMainShowStateCommand(): int32 =
    var statePath = ""
    let stateRes = v3OracleMainReadRequiredFlag("--state", statePath)
    if IsErr(stateRes):
        v3OracleMainPrintErr(Error(stateRes))
        return 2
    var machine: oracle_bft.V3OracleBftStateMachine
    let loadRes = oracle_host.v3OracleBftLoadState(statePath, machine)
    if IsErr(loadRes):
        v3OracleMainPrintErr(Error(loadRes))
        return 1
    var finalizedPairCount = 0
    for pairIndex in 0..<oracle_types.v3OraclePairCount:
        if machine.pairStates[pairIndex].available:
            finalizedPairCount = finalizedPairCount + 1
    var report = ""
    v3OracleMainAppendReportLine(report, "format", "v3_oracle_bft_state_v1")
    v3OracleMainAppendReportLine(report, "height", strings.Int64ToStr(machine.lastFinalizedHeight))
    v3OracleMainAppendReportLine(report, "last_finalized_round_id", strings.Int64ToStr(machine.lastFinalizedRoundId))
    v3OracleMainAppendReportLine(report, "pair_count_finalized", intToStr(finalizedPairCount))
    v3OracleMainAppendReportLine(report, "has_pending", oracle_host.v3OracleBftMachineHasPending(machine) ? "1" : "0")
    v3OracleMainAppendReportLine(report, "app_hash", layout.fixedBytes32Hex(oracle_bft.v3OracleBftStateMachineQueryAppHash(machine)))
    v3OracleMainPrintOut(strutil.Strip(report))
    return 0

fn v3OracleMainQueryLatestCommand(): int32 =
    var statePath = ""
    let stateRes = v3OracleMainReadRequiredFlag("--state", statePath)
    if IsErr(stateRes):
        v3OracleMainPrintErr(Error(stateRes))
        return 2
    var pairText = ""
    let pairRes = v3OracleMainReadRequiredFlag("--pair", pairText)
    if IsErr(pairRes):
        v3OracleMainPrintErr(Error(pairRes))
        return 2
    let nowRoundRes = v3OracleMainReadRequiredInt64Flag("--now-round")
    if IsErr(nowRoundRes):
        v3OracleMainPrintErr(Error(nowRoundRes))
        return 2
    var pairId = 0
    var pairName = ""
    let resolveRes = v3OracleMainResolvePair(pairText, pairId, pairName)
    if IsErr(resolveRes):
        v3OracleMainPrintErr(Error(resolveRes))
        return 2
    var machine: oracle_bft.V3OracleBftStateMachine
    let loadRes = oracle_host.v3OracleBftLoadState(statePath, machine)
    if IsErr(loadRes):
        v3OracleMainPrintErr(Error(loadRes))
        return 1
    let latest = oracle_bft.v3OracleBftStateMachineQueryLatest(machine,
                                                               pairId,
                                                               oracle_types.v3OracleRoundEndMs(Value(nowRoundRes)) + int64(1))
    var report = ""
    v3OracleMainAppendReportLine(report, "format", "v3_oracle_query_latest_v1")
    v3OracleMainAppendReportLine(report, "pair", pairName)
    v3OracleMainAppendReportLine(report, "pair_id", intToStr(pairId))
    v3OracleMainAppendReportLine(report, "code", intToStr(latest.code))
    v3OracleMainAppendReportLine(report, "stale", latest.stale ? "1" : "0")
    v3OracleMainAppendReportLine(report, "round_id", strings.Int64ToStr(latest.roundId))
    v3OracleMainAppendReportLine(report, "price_e8", strings.Int64ToStr(latest.priceE8))
    v3OracleMainAppendReportLine(report, "height", strings.Int64ToStr(latest.height))
    v3OracleMainAppendReportLine(report, "app_hash", layout.fixedBytes32Hex(latest.appHash))
    v3OracleMainPrintOut(strutil.Strip(report))
    return latest.code == oracle_bft.v3OracleBftCodeOk ? 0 : latest.code

fn v3OracleMainQueryTwapCommand(): int32 =
    var statePath = ""
    let stateRes = v3OracleMainReadRequiredFlag("--state", statePath)
    if IsErr(stateRes):
        v3OracleMainPrintErr(Error(stateRes))
        return 2
    var pairText = ""
    let pairRes = v3OracleMainReadRequiredFlag("--pair", pairText)
    if IsErr(pairRes):
        v3OracleMainPrintErr(Error(pairRes))
        return 2
    let windowRes = v3OracleMainReadRequiredInt64Flag("--window-rounds")
    if IsErr(windowRes):
        v3OracleMainPrintErr(Error(windowRes))
        return 2
    let nowRoundRes = v3OracleMainReadRequiredInt64Flag("--now-round")
    if IsErr(nowRoundRes):
        v3OracleMainPrintErr(Error(nowRoundRes))
        return 2
    var pairId = 0
    var pairName = ""
    let resolveRes = v3OracleMainResolvePair(pairText, pairId, pairName)
    if IsErr(resolveRes):
        v3OracleMainPrintErr(Error(resolveRes))
        return 2
    var machine: oracle_bft.V3OracleBftStateMachine
    let loadRes = oracle_host.v3OracleBftLoadState(statePath, machine)
    if IsErr(loadRes):
        v3OracleMainPrintErr(Error(loadRes))
        return 1
    let twap = oracle_bft.v3OracleBftStateMachineQueryTwap(machine,
                                                           pairId,
                                                           int32(Value(windowRes)),
                                                           oracle_types.v3OracleRoundEndMs(Value(nowRoundRes)) + int64(1))
    var report = ""
    v3OracleMainAppendReportLine(report, "format", "v3_oracle_query_twap_v1")
    v3OracleMainAppendReportLine(report, "pair", pairName)
    v3OracleMainAppendReportLine(report, "pair_id", intToStr(pairId))
    v3OracleMainAppendReportLine(report, "window_rounds", strings.Int64ToStr(Value(windowRes)))
    v3OracleMainAppendReportLine(report, "code", intToStr(twap.code))
    v3OracleMainAppendReportLine(report, "stale", twap.stale ? "1" : "0")
    v3OracleMainAppendReportLine(report, "round_id", strings.Int64ToStr(twap.roundId))
    v3OracleMainAppendReportLine(report, "price_e8", strings.Int64ToStr(twap.priceE8))
    v3OracleMainAppendReportLine(report, "height", strings.Int64ToStr(twap.height))
    v3OracleMainAppendReportLine(report, "app_hash", layout.fixedBytes32Hex(twap.appHash))
    v3OracleMainPrintOut(strutil.Strip(report))
    return twap.code == oracle_bft.v3OracleBftCodeOk ? 0 : twap.code

fn v3OracleMainSelfTest(): int32 =
    let statePath = "artifacts/v3_oracle_bft_state_machine/self_test.state"
    let _ = os.RemoveFile(statePath)
    var machine = oracle_bft.v3OracleBftStateMachineInit("oracle.bft.self-test", v3OracleMainCommittee())
    var summary: oracle_bft.V3OracleBftBlockSummary
    var roundId = int64(20)
    var height = int64(1)
    while roundId <= int64(22):
        var batch = oracle_bft.V3OracleBftTxBatch()
        v3OracleMainAppendFixtureBatch(batch, roundId, 1, 5)
        let context = oracle_bft.v3OracleBftBlockContextMake(height,
                                                             0,
                                                             oracle_types.v3OracleRoundEndMs(roundId) + int64(1),
                                                             layout.FixedBytes32())
        oracle_bft.v3OracleBftStateMachineFinalizeBatchSummaryWithContext(machine, context, batch, summary)
        let _commit = oracle_bft.v3OracleBftStateMachineCommit(machine)
        roundId = roundId + int64(1)
        height = height + int64(1)
    let writeRes = oracle_host.v3OracleBftWriteState(statePath, machine)
    if IsErr(writeRes):
        panic("v3 oracle main: self-test write " + Error(writeRes))
    let loadRes = oracle_host.v3OracleBftLoadState(statePath, machine)
    if IsErr(loadRes):
        panic("v3 oracle main: self-test load " + Error(loadRes))
    let pairId = oracle_fixture.oracleSmokePairId(oracle_types.v3OracleAssetBtc, oracle_types.v3OracleQuoteUsd)
    let pairIndex = oracle_types.v3OraclePairIndex(pairId)
    let latest = oracle_bft.v3OracleBftStateMachineQueryLatest(machine,
                                                               pairId,
                                                               oracle_types.v3OracleRoundEndMs(int64(22)) + int64(1))
    assert(latest.code == oracle_bft.v3OracleBftCodeOk, "v3 oracle main: latest code")
    assert(latest.priceE8 == oracle_fixture.oracleSmokePrice(int64(22), pairIndex, 3),
           "v3 oracle main: latest price")
    let twap = oracle_bft.v3OracleBftStateMachineQueryTwap(machine,
                                                           pairId,
                                                           3,
                                                           oracle_types.v3OracleRoundEndMs(int64(22)) + int64(1))
    assert(twap.code == oracle_bft.v3OracleBftCodeOk, "v3 oracle main: twap code")
    let stale = oracle_bft.v3OracleBftStateMachineQueryLatest(machine,
                                                              pairId,
                                                              oracle_types.v3OracleRoundStartMs(int64(24)))
    assert(stale.code == oracle_bft.v3OracleBftCodeStale, "v3 oracle main: stale code")
    let _ = os.RemoveFile(statePath)
    echo("v3 oracle_bft_state_machine self-test ok")
    return 0

fn main(): int32 =
    let count = cmdline.ParamCount()
    if count <= 0:
        v3OracleMainUsage()
        return 1
    let cmd = cmdline.ParamStr(1)
    if cmd == "help" || cmd == "--help" || cmd == "-h":
        v3OracleMainUsage()
        return 0
    if cmd == "self-test":
        return v3OracleMainSelfTest()
    if cmd == "init":
        return v3OracleMainInitCommand()
    if cmd == "fixture-finalize":
        return v3OracleMainFixtureFinalizeCommand()
    if cmd == "show-state":
        return v3OracleMainShowStateCommand()
    if cmd == "query-latest":
        return v3OracleMainQueryLatestCommand()
    if cmd == "query-twap":
        return v3OracleMainQueryTwapCommand()
    v3OracleMainUsage()
    return 1
