import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/oracle_types as oracle_types
import cheng/v3/project/oracle_bft_state_machine as oracle_bft

fn main(): int32 =
    let committee = oracle_types.v3OracleCommitteeConfigZero()
    let machine = oracle_bft.v3OracleBftStateMachineInit("v3.oracle.bft.main", committee)
    let appHash = oracle_bft.v3OracleBftStateMachineQueryAppHash(machine)
    echo("v3 oracle_bft_state_machine_main app_hash=" + layout.fixedBytes32Hex(appHash))
    return 0
