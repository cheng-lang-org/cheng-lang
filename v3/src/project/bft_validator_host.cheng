const
    v3BftValidatorStateMagic: str = "v3.bft.validator.state.v1"
    v3BftValidatorVoteLockMagic: str = "v3.bft.validator.vote_lock.v1"
    v3BftValidatorQueueCursorMagic: str = "v3.bft.validator.queue_cursor.v1"
    v3BftValidatorStateSyncAck: str = "ok"
    v3BftProposalWireVersion: int32 = 1
    v3BftVoteWireVersion: int32 = 1
    v3BftCommitWireVersion: int32 = 1
    v3BftValidatorCount: int32 = 3
    v3BftValidatorQuorum: int32 = 2

type
    V3BftValidatorState =
        validatorSlot: int32
        lastVotedHeight: int64
        lastVotedProposalHash: layout.FixedBytes32
        machine: bft.V3BftStateMachine

    V3BftProposal =
        version: int32
        appId: str
        height: int64
        proposerSlot: int32
        txs: Bytes[]
        sig: layout.FixedBytes64

    V3BftVote =
        version: int32
        appId: str
        height: int64
        validatorSlot: int32
        proposalHash: layout.FixedBytes32
        appHash: layout.FixedBytes32
        tipEventCid: layout.FixedBytes32
        eventCount: int32
        accountCount: int32
        accepted: bool
        sig: layout.FixedBytes64

    V3BftCommit =
        version: int32
        appId: str
        height: int64
        proposerSlot: int32
        proposalWire: Bytes
        appHash: layout.FixedBytes32
        tipEventCid: layout.FixedBytes32
        eventCount: int32
        accountCount: int32
        votes: Bytes[]
        sig: layout.FixedBytes64

    V3BftProposalPreview =
        proposalHash: layout.FixedBytes32
        appHash: layout.FixedBytes32
        tipEventCid: layout.FixedBytes32
        eventCount: int32
        accountCount: int32

    V3BftValidatorQueueTracker =
        knownFileSize: int64
        knownLineCount: int32
        consumedLineCount: int32
        pendingTxs: Bytes[]

fn v3BftValidatorInt64Text(value: int64): str =
    return strings.int64ToStr(value)

fn v3BftValidatorHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn v3BftValidatorBytesFromHex(textRaw: str): Result[Bytes] =
    let text = strutil.strip(textRaw)
    if len(text) <= 0:
        return Ok[Bytes](emptyBytes())
    if (len(text) % 2) != 0:
        return Err[Bytes]("v3 bft validator: invalid hex length")
    var out = bytesAlloc(len(text) / 2)
    var i = 0
    while i < len(text):
        let hi = v3BftValidatorHexValue(text[i])
        let lo = v3BftValidatorHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes]("v3 bft validator: invalid hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn v3BftValidatorParseInt64Text(raw: str): Result[int64] =
    let text = strutil.strip(raw)
    if len(text) <= 0:
        return Err[int64]("v3 bft validator: invalid integer: " + raw)
    var sign = int64(1)
    var i = 0
    if text[0] == '+':
        i = 1
    elif text[0] == '-':
        sign = int64(-1)
        i = 1
    if i >= len(text):
        return Err[int64]("v3 bft validator: invalid integer: " + raw)
    var value = int64(0)
    while i < len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int64]("v3 bft validator: invalid integer: " + raw)
        let digit = int64(int32(ch) - int32('0'))
        value = value * int64(10) + digit
        i = i + 1
    return Ok[int64](value * sign)

fn v3BftValidatorAppendU32(buf: var layout.ByteBuf, value: int32) =
    lt.v3AppendU32BE(buf, value)

fn v3BftValidatorAppendI64(buf: var layout.ByteBuf, value: int64) =
    lt.v3AppendU32BE(buf, int32(value >> 32))
    lt.v3AppendU32BE(buf, int32(value & int64(0xffffffff)))

fn v3BftValidatorAppendBool(buf: var layout.ByteBuf, value: bool) =
    if value:
        lt.v3AppendU32BE(buf, 1)
    else:
        lt.v3AppendU32BE(buf, 0)

fn v3BftValidatorAppendFixed32(buf: var layout.ByteBuf, value: layout.FixedBytes32) =
    lt.v3AppendFixed32(buf, value)

fn v3BftValidatorAppendFixed64(buf: var layout.ByteBuf, value: layout.FixedBytes64) =
    layout.byteBufAppendBytes(buf, layout.fixedBytes64ToBytes(value))

fn v3BftValidatorAppendBytes(buf: var layout.ByteBuf, value: Bytes) =
    lt.v3AppendU32BE(buf, bytesLen(value))
    layout.byteBufAppendBytes(buf, value)

fn v3BftValidatorAppendText(buf: var layout.ByteBuf, value: str) =
    v3BftValidatorAppendBytes(buf, bytesFromString(value))

fn v3BftValidatorReadU32(data: layout.ByteSpan,
                         offset: var int32): Result[int32] =
    if offset < 0 || offset + 4 > layout.byteSpanLen(data):
        return Err[int32]("v3 bft validator: short u32")
    let b0: int64 = int64(layout.byteSpanAt(data, offset))
    let b1: int64 = int64(layout.byteSpanAt(data, offset + 1))
    let b2: int64 = int64(layout.byteSpanAt(data, offset + 2))
    let b3: int64 = int64(layout.byteSpanAt(data, offset + 3))
    offset = offset + 4
    return Ok[int32](int32((b0 << 24) | (b1 << 16) | (b2 << 8) | b3))

fn v3BftValidatorReadI64(data: layout.ByteSpan,
                         offset: var int32): Result[int64] =
    let hiRes = v3BftValidatorReadU32(data, offset)
    if IsErr(hiRes):
        return Err[int64](Error(hiRes))
    let loRes = v3BftValidatorReadU32(data, offset)
    if IsErr(loRes):
        return Err[int64](Error(loRes))
    let hi = int32(Value(hiRes))
    let lo = int64(Value(loRes))
    return Ok[int64]((int64(hi) << 32) | (lo & int64(0xffffffff)))

fn v3BftValidatorReadBool(data: layout.ByteSpan,
                          offset: var int32): Result[bool] =
    let wordRes = v3BftValidatorReadU32(data, offset)
    if IsErr(wordRes):
        return Err[bool](Error(wordRes))
    if Value(wordRes) == 0:
        return Ok[bool](false)
    if Value(wordRes) == 1:
        return Ok[bool](true)
    return Err[bool]("v3 bft validator: invalid bool")

fn v3BftValidatorReadBytes(data: layout.ByteSpan,
                           offset: var int32): Result[Bytes] =
    let lenRes = v3BftValidatorReadU32(data, offset)
    if IsErr(lenRes):
        return Err[Bytes](Error(lenRes))
    let valueLen = Value(lenRes)
    if valueLen < 0 || offset + valueLen > layout.byteSpanLen(data):
        return Err[Bytes]("v3 bft validator: short bytes")
    let out = bytesSlice(data.data, offset, valueLen)
    offset = offset + valueLen
    return Ok[Bytes](out)

fn v3BftValidatorReadText(data: layout.ByteSpan,
                          offset: var int32): Result[str] =
    let bytesRes = v3BftValidatorReadBytes(data, offset)
    if IsErr(bytesRes):
        return Err[str](Error(bytesRes))
    return Ok[str](bytesToString(Value(bytesRes)))

fn v3BftValidatorReadFixed32(data: layout.ByteSpan,
                             offset: var int32): Result[layout.FixedBytes32] =
    if offset < 0 || offset + 32 > layout.byteSpanLen(data):
        return Err[layout.FixedBytes32]("v3 bft validator: short fixed32")
    let outRes = layout.fixedBytes32FromBytes(bytesSlice(data.data, offset, 32))
    if IsErr(outRes):
        return Err[layout.FixedBytes32](Error(outRes))
    offset = offset + 32
    return Ok[layout.FixedBytes32](Value(outRes))

fn v3BftValidatorReadFixed64(data: layout.ByteSpan,
                             offset: var int32): Result[layout.FixedBytes64] =
    if offset < 0 || offset + 64 > layout.byteSpanLen(data):
        return Err[layout.FixedBytes64]("v3 bft validator: short fixed64")
    let outRes = layout.fixedBytes64FromBytes(bytesSlice(data.data, offset, 64))
    if IsErr(outRes):
        return Err[layout.FixedBytes64](Error(outRes))
    offset = offset + 64
    return Ok[layout.FixedBytes64](Value(outRes))

fn v3BftValidatorPrivateHex(slot: int32): str =
    if slot == 1:
        return "60d71049a0cafe01faa9948dc77ee5bc4bd5e05b8e328fdb9cc4c38237250a05"
    if slot == 2:
        return "d312c4a184302fdd5a3fe211c477d78b6de911f033b803268cb37b3e1e639852"
    if slot == 3:
        return "4e99df50f57f4981fe453e7950f429b72c3f8e68461f47c9da11243cf1c52191"
    return ""

fn v3BftValidatorPrivateScalar(slot: int32): Result[fixed256.Scalar256] =
    let hexText = v3BftValidatorPrivateHex(slot)
    if len(hexText) <= 0:
        return Err[fixed256.Scalar256]("v3 bft validator: unknown validator slot")
    return fixed256.scalar256FromHex(hexText)

fn v3BftValidatorPublicKeyHex(slot: int32): str =
    if slot == 1:
        return "04963c1356849b8478030a6eb572581063ccedf53fda0bc7241247eba977e3b0666e4bf0c12caa47487c2927f83b17d6f9f332481cd2ab0c4885f91fc2a6c547d5"
    if slot == 2:
        return "04a07a1b4f54e85504185a40456e9020fcb7ae67bda04ac1fe5cd790e67035497a1be276d433dc5b772ca543cc6b96d6d443ff2da9e1ca1b3b847d1bab55ec0c2d"
    if slot == 3:
        return "04849d0a4d07c118a06e274519e743f23b327104b017e985ac50a7749f592120d865abc57511ef74ee12878e0583770e6457acb1abbe408a27ad220068936307ee"
    return ""

fn v3BftValidatorPublicKey(slot: int32): Result[layout.FixedBytes65] =
    let hexText = v3BftValidatorPublicKeyHex(slot)
    if len(hexText) <= 0:
        return Err[layout.FixedBytes65]("v3 bft validator: unknown validator slot")
    return layout.fixedBytes65FromHex(hexText)

fn v3BftValidatorSlotValid(slot: int32): bool =
    return slot >= 1 && slot <= v3BftValidatorCount

fn v3BftValidatorProposalSignable(proposal: V3BftProposal): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.bft.proposal.signable.v1"))
    v3BftValidatorAppendU32(buf, proposal.version)
    v3BftValidatorAppendText(buf, proposal.appId)
    v3BftValidatorAppendI64(buf, proposal.height)
    v3BftValidatorAppendU32(buf, proposal.proposerSlot)
    v3BftValidatorAppendU32(buf, proposal.txs.len)
    for i in 0..<proposal.txs.len:
        v3BftValidatorAppendBytes(buf, proposal.txs[i])
    return layout.byteBufToBytes(buf)

fn v3BftValidatorProposalHash(proposal: V3BftProposal): layout.FixedBytes32 =
    return fixed256.sha256Fixed(layout.byteSpanFromBytes(v3BftValidatorProposalSignable(proposal)))

fn v3BftValidatorEncodeProposal(proposal: V3BftProposal): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(320)
    v3BftValidatorAppendU32(buf, proposal.version)
    v3BftValidatorAppendText(buf, proposal.appId)
    v3BftValidatorAppendI64(buf, proposal.height)
    v3BftValidatorAppendU32(buf, proposal.proposerSlot)
    v3BftValidatorAppendU32(buf, proposal.txs.len)
    for i in 0..<proposal.txs.len:
        v3BftValidatorAppendBytes(buf, proposal.txs[i])
    v3BftValidatorAppendFixed64(buf, proposal.sig)
    return layout.byteBufToBytes(buf)

fn v3BftValidatorDecodeProposal(data: Bytes): Result[V3BftProposal] =
    let span = layout.byteSpanFromBytes(data)
    var offset = 0
    let versionRes = v3BftValidatorReadU32(span, offset)
    if IsErr(versionRes):
        return Err[V3BftProposal](Error(versionRes))
    let appIdRes = v3BftValidatorReadText(span, offset)
    if IsErr(appIdRes):
        return Err[V3BftProposal](Error(appIdRes))
    let heightRes = v3BftValidatorReadI64(span, offset)
    if IsErr(heightRes):
        return Err[V3BftProposal](Error(heightRes))
    let proposerRes = v3BftValidatorReadU32(span, offset)
    if IsErr(proposerRes):
        return Err[V3BftProposal](Error(proposerRes))
    let txCountRes = v3BftValidatorReadU32(span, offset)
    if IsErr(txCountRes):
        return Err[V3BftProposal](Error(txCountRes))
    var txs: Bytes[]
    txs = []
    for i in 0..<Value(txCountRes):
        let txRes = v3BftValidatorReadBytes(span, offset)
        if IsErr(txRes):
            return Err[V3BftProposal](Error(txRes))
        add(txs, Value(txRes))
    let sigRes = v3BftValidatorReadFixed64(span, offset)
    if IsErr(sigRes):
        return Err[V3BftProposal](Error(sigRes))
    if offset != layout.byteSpanLen(span):
        return Err[V3BftProposal]("v3 bft validator: proposal trailing bytes")
    var out: V3BftProposal
    out.version = Value(versionRes)
    out.appId = Value(appIdRes)
    out.height = Value(heightRes)
    out.proposerSlot = Value(proposerRes)
    out.txs = txs
    out.sig = Value(sigRes)
    return Ok[V3BftProposal](out)

fn v3BftValidatorVoteSignable(vote: V3BftVote): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.bft.vote.signable.v1"))
    v3BftValidatorAppendU32(buf, vote.version)
    v3BftValidatorAppendText(buf, vote.appId)
    v3BftValidatorAppendI64(buf, vote.height)
    v3BftValidatorAppendU32(buf, vote.validatorSlot)
    v3BftValidatorAppendFixed32(buf, vote.proposalHash)
    v3BftValidatorAppendFixed32(buf, vote.appHash)
    v3BftValidatorAppendFixed32(buf, vote.tipEventCid)
    v3BftValidatorAppendU32(buf, vote.eventCount)
    v3BftValidatorAppendU32(buf, vote.accountCount)
    v3BftValidatorAppendBool(buf, vote.accepted)
    return layout.byteBufToBytes(buf)

fn v3BftValidatorEncodeVote(vote: V3BftVote): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    v3BftValidatorAppendU32(buf, vote.version)
    v3BftValidatorAppendText(buf, vote.appId)
    v3BftValidatorAppendI64(buf, vote.height)
    v3BftValidatorAppendU32(buf, vote.validatorSlot)
    v3BftValidatorAppendFixed32(buf, vote.proposalHash)
    v3BftValidatorAppendFixed32(buf, vote.appHash)
    v3BftValidatorAppendFixed32(buf, vote.tipEventCid)
    v3BftValidatorAppendU32(buf, vote.eventCount)
    v3BftValidatorAppendU32(buf, vote.accountCount)
    v3BftValidatorAppendBool(buf, vote.accepted)
    v3BftValidatorAppendFixed64(buf, vote.sig)
    return layout.byteBufToBytes(buf)

fn v3BftValidatorDecodeVote(data: Bytes): Result[V3BftVote] =
    let span = layout.byteSpanFromBytes(data)
    var offset = 0
    let versionRes = v3BftValidatorReadU32(span, offset)
    if IsErr(versionRes):
        return Err[V3BftVote](Error(versionRes))
    let appIdRes = v3BftValidatorReadText(span, offset)
    if IsErr(appIdRes):
        return Err[V3BftVote](Error(appIdRes))
    let heightRes = v3BftValidatorReadI64(span, offset)
    if IsErr(heightRes):
        return Err[V3BftVote](Error(heightRes))
    let slotRes = v3BftValidatorReadU32(span, offset)
    if IsErr(slotRes):
        return Err[V3BftVote](Error(slotRes))
    let proposalHashRes = v3BftValidatorReadFixed32(span, offset)
    if IsErr(proposalHashRes):
        return Err[V3BftVote](Error(proposalHashRes))
    let appHashRes = v3BftValidatorReadFixed32(span, offset)
    if IsErr(appHashRes):
        return Err[V3BftVote](Error(appHashRes))
    let tipRes = v3BftValidatorReadFixed32(span, offset)
    if IsErr(tipRes):
        return Err[V3BftVote](Error(tipRes))
    let eventCountRes = v3BftValidatorReadU32(span, offset)
    if IsErr(eventCountRes):
        return Err[V3BftVote](Error(eventCountRes))
    let accountCountRes = v3BftValidatorReadU32(span, offset)
    if IsErr(accountCountRes):
        return Err[V3BftVote](Error(accountCountRes))
    let acceptedRes = v3BftValidatorReadBool(span, offset)
    if IsErr(acceptedRes):
        return Err[V3BftVote](Error(acceptedRes))
    let sigRes = v3BftValidatorReadFixed64(span, offset)
    if IsErr(sigRes):
        return Err[V3BftVote](Error(sigRes))
    if offset != layout.byteSpanLen(span):
        return Err[V3BftVote]("v3 bft validator: vote trailing bytes")
    var out: V3BftVote
    out.version = Value(versionRes)
    out.appId = Value(appIdRes)
    out.height = Value(heightRes)
    out.validatorSlot = Value(slotRes)
    out.proposalHash = Value(proposalHashRes)
    out.appHash = Value(appHashRes)
    out.tipEventCid = Value(tipRes)
    out.eventCount = Value(eventCountRes)
    out.accountCount = Value(accountCountRes)
    out.accepted = Value(acceptedRes)
    out.sig = Value(sigRes)
    return Ok[V3BftVote](out)

fn v3BftValidatorCommitSignable(commit: V3BftCommit): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(512)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.bft.commit.signable.v1"))
    v3BftValidatorAppendU32(buf, commit.version)
    v3BftValidatorAppendText(buf, commit.appId)
    v3BftValidatorAppendI64(buf, commit.height)
    v3BftValidatorAppendU32(buf, commit.proposerSlot)
    v3BftValidatorAppendBytes(buf, commit.proposalWire)
    v3BftValidatorAppendFixed32(buf, commit.appHash)
    v3BftValidatorAppendFixed32(buf, commit.tipEventCid)
    v3BftValidatorAppendU32(buf, commit.eventCount)
    v3BftValidatorAppendU32(buf, commit.accountCount)
    v3BftValidatorAppendU32(buf, commit.votes.len)
    for i in 0..<commit.votes.len:
        v3BftValidatorAppendBytes(buf, commit.votes[i])
    return layout.byteBufToBytes(buf)

fn v3BftValidatorEncodeCommit(commit: V3BftCommit): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(640)
    v3BftValidatorAppendU32(buf, commit.version)
    v3BftValidatorAppendText(buf, commit.appId)
    v3BftValidatorAppendI64(buf, commit.height)
    v3BftValidatorAppendU32(buf, commit.proposerSlot)
    v3BftValidatorAppendBytes(buf, commit.proposalWire)
    v3BftValidatorAppendFixed32(buf, commit.appHash)
    v3BftValidatorAppendFixed32(buf, commit.tipEventCid)
    v3BftValidatorAppendU32(buf, commit.eventCount)
    v3BftValidatorAppendU32(buf, commit.accountCount)
    v3BftValidatorAppendU32(buf, commit.votes.len)
    for i in 0..<commit.votes.len:
        v3BftValidatorAppendBytes(buf, commit.votes[i])
    v3BftValidatorAppendFixed64(buf, commit.sig)
    return layout.byteBufToBytes(buf)

fn v3BftValidatorDecodeCommit(data: Bytes): Result[V3BftCommit] =
    let span = layout.byteSpanFromBytes(data)
    var offset = 0
    let versionRes = v3BftValidatorReadU32(span, offset)
    if IsErr(versionRes):
        return Err[V3BftCommit](Error(versionRes))
    let appIdRes = v3BftValidatorReadText(span, offset)
    if IsErr(appIdRes):
        return Err[V3BftCommit](Error(appIdRes))
    let heightRes = v3BftValidatorReadI64(span, offset)
    if IsErr(heightRes):
        return Err[V3BftCommit](Error(heightRes))
    let proposerRes = v3BftValidatorReadU32(span, offset)
    if IsErr(proposerRes):
        return Err[V3BftCommit](Error(proposerRes))
    let proposalWireRes = v3BftValidatorReadBytes(span, offset)
    if IsErr(proposalWireRes):
        return Err[V3BftCommit](Error(proposalWireRes))
    let appHashRes = v3BftValidatorReadFixed32(span, offset)
    if IsErr(appHashRes):
        return Err[V3BftCommit](Error(appHashRes))
    let tipRes = v3BftValidatorReadFixed32(span, offset)
    if IsErr(tipRes):
        return Err[V3BftCommit](Error(tipRes))
    let eventCountRes = v3BftValidatorReadU32(span, offset)
    if IsErr(eventCountRes):
        return Err[V3BftCommit](Error(eventCountRes))
    let accountCountRes = v3BftValidatorReadU32(span, offset)
    if IsErr(accountCountRes):
        return Err[V3BftCommit](Error(accountCountRes))
    let voteCountRes = v3BftValidatorReadU32(span, offset)
    if IsErr(voteCountRes):
        return Err[V3BftCommit](Error(voteCountRes))
    var votes: Bytes[]
    votes = []
    for i in 0..<Value(voteCountRes):
        let voteRes = v3BftValidatorReadBytes(span, offset)
        if IsErr(voteRes):
            return Err[V3BftCommit](Error(voteRes))
        add(votes, Value(voteRes))
    let sigRes = v3BftValidatorReadFixed64(span, offset)
    if IsErr(sigRes):
        return Err[V3BftCommit](Error(sigRes))
    if offset != layout.byteSpanLen(span):
        return Err[V3BftCommit]("v3 bft validator: commit trailing bytes")
    var out: V3BftCommit
    out.version = Value(versionRes)
    out.appId = Value(appIdRes)
    out.height = Value(heightRes)
    out.proposerSlot = Value(proposerRes)
    out.proposalWire = Value(proposalWireRes)
    out.appHash = Value(appHashRes)
    out.tipEventCid = Value(tipRes)
    out.eventCount = Value(eventCountRes)
    out.accountCount = Value(accountCountRes)
    out.votes = votes
    out.sig = Value(sigRes)
    return Ok[V3BftCommit](out)

fn v3BftValidatorProposalFromTxs(appId: str,
                                 height: int64,
                                 proposerSlot: int32,
                                 txs: Bytes[]): Result[V3BftProposal] =
    if !v3BftValidatorSlotValid(proposerSlot):
        return Err[V3BftProposal]("v3 bft validator: invalid proposer slot")
    if height <= int64(0):
        return Err[V3BftProposal]("v3 bft validator: invalid proposal height")
    if txs.len <= 0:
        return Err[V3BftProposal]("v3 bft validator: empty proposal")
    var proposal: V3BftProposal
    proposal.version = v3BftProposalWireVersion
    proposal.appId = appId
    proposal.height = height
    proposal.proposerSlot = proposerSlot
    proposal.txs = []
    proposal.sig = layout.fixedBytes64Zero()
    for i in 0..<txs.len:
        let txRes = bft.v3BftDecodeTx(layout.byteSpanFromBytes(txs[i]))
        if IsErr(txRes):
            return Err[V3BftProposal]("v3 bft validator: invalid proposal tx")
        add(proposal.txs, txs[i])
    let privRes = v3BftValidatorPrivateScalar(proposerSlot)
    if IsErr(privRes):
        return Err[V3BftProposal](Error(privRes))
    let sigRes = fixed256.p256SignMessageFixed64(Value(privRes), v3BftValidatorProposalSignable(proposal))
    if IsErr(sigRes):
        return Err[V3BftProposal](Error(sigRes))
    proposal.sig = Value(sigRes)
    return Ok[V3BftProposal](proposal)

fn v3BftValidatorVerifyProposal(proposal: V3BftProposal): Result[bool] =
    if proposal.version != v3BftProposalWireVersion:
        return Err[bool]("v3 bft validator: bad proposal version")
    if !v3BftValidatorSlotValid(proposal.proposerSlot):
        return Err[bool]("v3 bft validator: bad proposal slot")
    if proposal.height <= int64(0):
        return Err[bool]("v3 bft validator: bad proposal height")
    if proposal.txs.len <= 0:
        return Err[bool]("v3 bft validator: empty proposal")
    for i in 0..<proposal.txs.len:
        let txRes = bft.v3BftDecodeTx(layout.byteSpanFromBytes(proposal.txs[i]))
        if IsErr(txRes):
            return Err[bool]("v3 bft validator: bad proposal tx")
    let pubRes = v3BftValidatorPublicKey(proposal.proposerSlot)
    if IsErr(pubRes):
        return Err[bool](Error(pubRes))
    let verifyRes = fixed256.p256VerifyMessageFixed64(Value(pubRes),
                                                      v3BftValidatorProposalSignable(proposal),
                                                      proposal.sig)
    if IsErr(verifyRes):
        return Err[bool](Error(verifyRes))
    if !Value(verifyRes):
        return Err[bool]("v3 bft validator: proposal signature mismatch")
    return Ok[bool](true)

fn v3BftValidatorPreviewProposal(state: V3BftValidatorState,
                                 proposal: V3BftProposal): Result[V3BftProposalPreview] =
    let verifyRes = v3BftValidatorVerifyProposal(proposal)
    if IsErr(verifyRes):
        return Err[V3BftProposalPreview](Error(verifyRes))
    if proposal.appId != state.machine.appId:
        return Err[V3BftProposalPreview]("v3 bft validator: proposal app id mismatch")
    if proposal.height != state.machine.lastFinalizedHeight + int64(1):
        return Err[V3BftProposalPreview]("v3 bft validator: proposal height mismatch")
    var clone = bft.v3BftStateMachineClone(state.machine)
    var summary = bft.v3BftBlockSummaryZero(int64(0))
    bft.v3BftStateMachineFinalizeBlockBytesSummary(clone, proposal.height, proposal.txs, summary)
    let commit = bft.v3BftStateMachineCommit(clone)
    var out: V3BftProposalPreview
    out.proposalHash = v3BftValidatorProposalHash(proposal)
    out.appHash = commit.appHash
    out.tipEventCid = commit.tipEventCid
    out.eventCount = commit.eventCount
    out.accountCount = commit.accountCount
    return Ok[V3BftProposalPreview](out)

fn v3BftValidatorBuildVoteAllowRepeat(state: V3BftValidatorState,
                                      proposal: V3BftProposal,
                                      allowRepeat: bool): Result[V3BftVote] =
    let previewRes = v3BftValidatorPreviewProposal(state, proposal)
    if IsErr(previewRes):
        return Err[V3BftVote](Error(previewRes))
    let preview = Value(previewRes)
    if state.lastVotedHeight == proposal.height:
        if layout.fixedBytes32Equal(state.lastVotedProposalHash, preview.proposalHash):
            if !allowRepeat:
                return Err[V3BftVote]("v3 bft validator: already voted for proposal")
        else:
            return Err[V3BftVote]("v3 bft validator: conflicting proposal at same height")
    var vote: V3BftVote
    vote.version = v3BftVoteWireVersion
    vote.appId = proposal.appId
    vote.height = proposal.height
    vote.validatorSlot = state.validatorSlot
    vote.proposalHash = preview.proposalHash
    vote.appHash = preview.appHash
    vote.tipEventCid = preview.tipEventCid
    vote.eventCount = preview.eventCount
    vote.accountCount = preview.accountCount
    vote.accepted = true
    vote.sig = layout.fixedBytes64Zero()
    let privRes = v3BftValidatorPrivateScalar(state.validatorSlot)
    if IsErr(privRes):
        return Err[V3BftVote](Error(privRes))
    let sigRes = fixed256.p256SignMessageFixed64(Value(privRes), v3BftValidatorVoteSignable(vote))
    if IsErr(sigRes):
        return Err[V3BftVote](Error(sigRes))
    vote.sig = Value(sigRes)
    return Ok[V3BftVote](vote)

fn v3BftValidatorBuildVote(state: V3BftValidatorState,
                           proposal: V3BftProposal): Result[V3BftVote] =
    return v3BftValidatorBuildVoteAllowRepeat(state, proposal, false)

fn v3BftValidatorVerifyVote(vote: V3BftVote): Result[bool] =
    if vote.version != v3BftVoteWireVersion:
        return Err[bool]("v3 bft validator: bad vote version")
    if !v3BftValidatorSlotValid(vote.validatorSlot):
        return Err[bool]("v3 bft validator: bad vote slot")
    if vote.height <= int64(0):
        return Err[bool]("v3 bft validator: bad vote height")
    let pubRes = v3BftValidatorPublicKey(vote.validatorSlot)
    if IsErr(pubRes):
        return Err[bool](Error(pubRes))
    let verifyRes = fixed256.p256VerifyMessageFixed64(Value(pubRes),
                                                      v3BftValidatorVoteSignable(vote),
                                                      vote.sig)
    if IsErr(verifyRes):
        return Err[bool](Error(verifyRes))
    if !Value(verifyRes):
        return Err[bool]("v3 bft validator: vote signature mismatch")
    return Ok[bool](true)

fn v3BftValidatorCommitFromVotes(proposal: V3BftProposal,
                                 preview: V3BftProposalPreview,
                                 votes: V3BftVote[]): Result[V3BftCommit] =
    if votes.len < v3BftValidatorQuorum:
        return Err[V3BftCommit]("v3 bft validator: insufficient commit votes")
    var voteWires: Bytes[]
    voteWires = []
    var seenSlots: int32[]
    seenSlots = []
    for i in 0..<votes.len:
        let verifyRes = v3BftValidatorVerifyVote(votes[i])
        if IsErr(verifyRes):
            return Err[V3BftCommit](Error(verifyRes))
        if !votes[i].accepted:
            return Err[V3BftCommit]("v3 bft validator: reject vote in commit")
        if votes[i].appId != proposal.appId ||
           votes[i].height != proposal.height ||
           !layout.fixedBytes32Equal(votes[i].proposalHash, preview.proposalHash) ||
           !layout.fixedBytes32Equal(votes[i].appHash, preview.appHash) ||
           !layout.fixedBytes32Equal(votes[i].tipEventCid, preview.tipEventCid) ||
           votes[i].eventCount != preview.eventCount ||
           votes[i].accountCount != preview.accountCount:
            return Err[V3BftCommit]("v3 bft validator: vote preview mismatch")
        for j in 0..<seenSlots.len:
            if seenSlots[j] == votes[i].validatorSlot:
                return Err[V3BftCommit]("v3 bft validator: duplicate commit vote")
        add(seenSlots, votes[i].validatorSlot)
        add(voteWires, v3BftValidatorEncodeVote(votes[i]))
    var commit: V3BftCommit
    commit.version = v3BftCommitWireVersion
    commit.appId = proposal.appId
    commit.height = proposal.height
    commit.proposerSlot = proposal.proposerSlot
    commit.proposalWire = v3BftValidatorEncodeProposal(proposal)
    commit.appHash = preview.appHash
    commit.tipEventCid = preview.tipEventCid
    commit.eventCount = preview.eventCount
    commit.accountCount = preview.accountCount
    commit.votes = voteWires
    commit.sig = layout.fixedBytes64Zero()
    let privRes = v3BftValidatorPrivateScalar(proposal.proposerSlot)
    if IsErr(privRes):
        return Err[V3BftCommit](Error(privRes))
    let sigRes = fixed256.p256SignMessageFixed64(Value(privRes), v3BftValidatorCommitSignable(commit))
    if IsErr(sigRes):
        return Err[V3BftCommit](Error(sigRes))
    commit.sig = Value(sigRes)
    return Ok[V3BftCommit](commit)

fn v3BftValidatorVerifyCommit(state: V3BftValidatorState,
                              commit: V3BftCommit): Result[V3BftProposalPreview] =
    if commit.version != v3BftCommitWireVersion:
        return Err[V3BftProposalPreview]("v3 bft validator: bad commit version")
    if !v3BftValidatorSlotValid(commit.proposerSlot):
        return Err[V3BftProposalPreview]("v3 bft validator: bad commit slot")
    let pubRes = v3BftValidatorPublicKey(commit.proposerSlot)
    if IsErr(pubRes):
        return Err[V3BftProposalPreview](Error(pubRes))
    let verifyRes = fixed256.p256VerifyMessageFixed64(Value(pubRes),
                                                      v3BftValidatorCommitSignable(commit),
                                                      commit.sig)
    if IsErr(verifyRes):
        return Err[V3BftProposalPreview](Error(verifyRes))
    if !Value(verifyRes):
        return Err[V3BftProposalPreview]("v3 bft validator: commit signature mismatch")
    let proposalRes = v3BftValidatorDecodeProposal(commit.proposalWire)
    if IsErr(proposalRes):
        return Err[V3BftProposalPreview](Error(proposalRes))
    let proposal = Value(proposalRes)
    let previewRes = v3BftValidatorPreviewProposal(state, proposal)
    if IsErr(previewRes):
        return Err[V3BftProposalPreview](Error(previewRes))
    let preview = Value(previewRes)
    if proposal.appId != commit.appId ||
       proposal.height != commit.height ||
       proposal.proposerSlot != commit.proposerSlot:
        return Err[V3BftProposalPreview]("v3 bft validator: commit proposal mismatch")
    if !layout.fixedBytes32Equal(commit.appHash, preview.appHash) ||
       !layout.fixedBytes32Equal(commit.tipEventCid, preview.tipEventCid) ||
       commit.eventCount != preview.eventCount ||
       commit.accountCount != preview.accountCount:
        return Err[V3BftProposalPreview]("v3 bft validator: commit preview mismatch")
    var seenSlots: int32[]
    seenSlots = []
    var yesCount = 0
    for i in 0..<commit.votes.len:
        let voteRes = v3BftValidatorDecodeVote(commit.votes[i])
        if IsErr(voteRes):
            return Err[V3BftProposalPreview](Error(voteRes))
        let vote = Value(voteRes)
        let voteVerifyRes = v3BftValidatorVerifyVote(vote)
        if IsErr(voteVerifyRes):
            return Err[V3BftProposalPreview](Error(voteVerifyRes))
        if !vote.accepted:
            return Err[V3BftProposalPreview]("v3 bft validator: reject vote in commit")
        if vote.appId != commit.appId ||
           vote.height != commit.height ||
           !layout.fixedBytes32Equal(vote.proposalHash, preview.proposalHash) ||
           !layout.fixedBytes32Equal(vote.appHash, commit.appHash) ||
           !layout.fixedBytes32Equal(vote.tipEventCid, commit.tipEventCid) ||
           vote.eventCount != commit.eventCount ||
           vote.accountCount != commit.accountCount:
            return Err[V3BftProposalPreview]("v3 bft validator: commit vote mismatch")
        for j in 0..<seenSlots.len:
            if seenSlots[j] == vote.validatorSlot:
                return Err[V3BftProposalPreview]("v3 bft validator: duplicate commit vote")
        add(seenSlots, vote.validatorSlot)
        yesCount = yesCount + 1
    if yesCount < v3BftValidatorQuorum:
        return Err[V3BftProposalPreview]("v3 bft validator: commit quorum missing")
    return Ok[V3BftProposalPreview](preview)

fn v3BftValidatorStateApplyCommit(state: var V3BftValidatorState,
                                  commit: V3BftCommit): Result[bool] =
    let previewRes = v3BftValidatorVerifyCommit(state, commit)
    if IsErr(previewRes):
        return Err[bool](Error(previewRes))
    let proposalRes = v3BftValidatorDecodeProposal(commit.proposalWire)
    if IsErr(proposalRes):
        return Err[bool](Error(proposalRes))
    let proposal = Value(proposalRes)
    var summary = bft.v3BftBlockSummaryZero(int64(0))
    bft.v3BftStateMachineFinalizeBlockBytesSummary(state.machine, proposal.height, proposal.txs, summary)
    let commitRes = bft.v3BftStateMachineCommit(state.machine)
    if !layout.fixedBytes32Equal(commitRes.appHash, commit.appHash):
        return Err[bool]("v3 bft validator: commit app hash apply mismatch")
    state.lastVotedHeight = proposal.height
    state.lastVotedProposalHash = v3BftValidatorProposalHash(proposal)
    return Ok[bool](true)

fn v3BftValidatorStateInit(appId: str,
                           validatorSlot: int32): Result[V3BftValidatorState] =
    if !v3BftValidatorSlotValid(validatorSlot):
        return Err[V3BftValidatorState]("v3 bft validator: invalid validator slot")
    var out: V3BftValidatorState
    out.validatorSlot = validatorSlot
    out.lastVotedHeight = int64(0)
    out.lastVotedProposalHash = layout.fixedBytes32Zero()
    out.machine = bft.v3BftStateMachineInit(appId)
    return Ok[V3BftValidatorState](out)

fn v3BftValidatorEncodeMachine(machine: bft.V3BftStateMachine): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(512)
    v3BftValidatorAppendText(buf, machine.appId)
    v3BftValidatorAppendI64(buf, machine.lastFinalizedHeight)
    v3BftValidatorAppendFixed32(buf, machine.lastCommitAppHash)
    v3BftValidatorAppendFixed32(buf, machine.lastCommitTipEventCid)
    v3BftValidatorAppendU32(buf, machine.index.eventCids.len)
    for i in 0..<machine.index.eventCids.len:
        v3BftValidatorAppendFixed32(buf, machine.index.eventCids[i])
        v3BftValidatorAppendU32(buf, machine.index.eventKinds[i])
        v3BftValidatorAppendU32(buf, machine.index.logOffsets[i])
    v3BftValidatorAppendU32(buf, machine.index.accountIds.len)
    for i in 0..<machine.index.accountIds.len:
        v3BftValidatorAppendU32(buf, machine.index.accountAssetIds[i])
        v3BftValidatorAppendU32(buf, machine.index.accountIds[i])
        v3BftValidatorAppendFixed32(buf, machine.index.accountHeads[i])
        v3BftValidatorAppendI64(buf, machine.index.balances[i])
        v3BftValidatorAppendU32(buf, machine.index.clockEpochs[i])
        v3BftValidatorAppendU32(buf, machine.index.clockGanzhi[i])
        v3BftValidatorAppendBool(buf, machine.index.diverged[i])
    v3BftValidatorAppendBool(buf, machine.index.stateTreeDirty)
    return layout.byteBufToBytes(buf)

fn v3BftValidatorDecodeMachine(data: Bytes): Result[bft.V3BftStateMachine] =
    let span = layout.byteSpanFromBytes(data)
    var offset = 0
    let appIdRes = v3BftValidatorReadText(span, offset)
    if IsErr(appIdRes):
        return Err[bft.V3BftStateMachine](Error(appIdRes))
    let heightRes = v3BftValidatorReadI64(span, offset)
    if IsErr(heightRes):
        return Err[bft.V3BftStateMachine](Error(heightRes))
    let lastAppHashRes = v3BftValidatorReadFixed32(span, offset)
    if IsErr(lastAppHashRes):
        return Err[bft.V3BftStateMachine](Error(lastAppHashRes))
    let lastTipRes = v3BftValidatorReadFixed32(span, offset)
    if IsErr(lastTipRes):
        return Err[bft.V3BftStateMachine](Error(lastTipRes))
    let eventCountRes = v3BftValidatorReadU32(span, offset)
    if IsErr(eventCountRes):
        return Err[bft.V3BftStateMachine](Error(eventCountRes))
    var machine = bft.v3BftStateMachineInit(Value(appIdRes))
    machine.lastFinalizedHeight = Value(heightRes)
    machine.lastCommitAppHash = Value(lastAppHashRes)
    machine.lastCommitTipEventCid = Value(lastTipRes)
    machine.index = consensus.v3ChainIndexZero()
    for i in 0..<Value(eventCountRes):
        let eventCidRes = v3BftValidatorReadFixed32(span, offset)
        if IsErr(eventCidRes):
            return Err[bft.V3BftStateMachine](Error(eventCidRes))
        let kindRes = v3BftValidatorReadU32(span, offset)
        if IsErr(kindRes):
            return Err[bft.V3BftStateMachine](Error(kindRes))
        let logRes = v3BftValidatorReadU32(span, offset)
        if IsErr(logRes):
            return Err[bft.V3BftStateMachine](Error(logRes))
        add(machine.index.eventCids, Value(eventCidRes))
        add(machine.index.eventKinds, Value(kindRes))
        add(machine.index.logOffsets, Value(logRes))
    let accountCountRes = v3BftValidatorReadU32(span, offset)
    if IsErr(accountCountRes):
        return Err[bft.V3BftStateMachine](Error(accountCountRes))
    for i in 0..<Value(accountCountRes):
        let assetRes = v3BftValidatorReadU32(span, offset)
        if IsErr(assetRes):
            return Err[bft.V3BftStateMachine](Error(assetRes))
        let accountRes = v3BftValidatorReadU32(span, offset)
        if IsErr(accountRes):
            return Err[bft.V3BftStateMachine](Error(accountRes))
        let headRes = v3BftValidatorReadFixed32(span, offset)
        if IsErr(headRes):
            return Err[bft.V3BftStateMachine](Error(headRes))
        let balanceRes = v3BftValidatorReadI64(span, offset)
        if IsErr(balanceRes):
            return Err[bft.V3BftStateMachine](Error(balanceRes))
        let epochRes = v3BftValidatorReadU32(span, offset)
        if IsErr(epochRes):
            return Err[bft.V3BftStateMachine](Error(epochRes))
        let ganzhiRes = v3BftValidatorReadU32(span, offset)
        if IsErr(ganzhiRes):
            return Err[bft.V3BftStateMachine](Error(ganzhiRes))
        let divergedRes = v3BftValidatorReadBool(span, offset)
        if IsErr(divergedRes):
            return Err[bft.V3BftStateMachine](Error(divergedRes))
        add(machine.index.accountAssetIds, Value(assetRes))
        add(machine.index.accountIds, Value(accountRes))
        add(machine.index.accountHeads, Value(headRes))
        add(machine.index.balances, Value(balanceRes))
        add(machine.index.clockEpochs, Value(epochRes))
        add(machine.index.clockGanzhi, Value(ganzhiRes))
        add(machine.index.diverged, Value(divergedRes))
    let dirtyRes = v3BftValidatorReadBool(span, offset)
    if IsErr(dirtyRes):
        return Err[bft.V3BftStateMachine](Error(dirtyRes))
    machine.index.stateTreeDirty = Value(dirtyRes)
    if offset != layout.byteSpanLen(span):
        return Err[bft.V3BftStateMachine]("v3 bft validator: machine trailing bytes")
    return Ok[bft.V3BftStateMachine](machine)

fn v3BftValidatorStateText(state: V3BftValidatorState): str =
    var out = ""
    out = out + v3BftValidatorStateMagic + "\n"
    out = out + "validator_slot=" + intToStr(state.validatorSlot) + "\n"
    out = out + "last_voted_height=" + v3BftValidatorInt64Text(state.lastVotedHeight) + "\n"
    out = out + "last_voted_proposal_hash=" + layout.fixedBytes32Hex(state.lastVotedProposalHash) + "\n"
    out = out + "machine_hex=" + bytesToHex(v3BftValidatorEncodeMachine(state.machine)) + "\n"
    return out

fn v3BftValidatorWriteState(pathRaw: str,
                            state: V3BftValidatorState): bool =
    return v3path.v3WriteTextFile(os.getCurrentDir(), pathRaw, v3BftValidatorStateText(state))

fn v3BftValidatorVoteLockText(state: V3BftValidatorState): str =
    var out = ""
    out = out + v3BftValidatorVoteLockMagic + "\n"
    out = out + "last_voted_height=" + v3BftValidatorInt64Text(state.lastVotedHeight) + "\n"
    out = out + "last_voted_proposal_hash=" + layout.fixedBytes32Hex(state.lastVotedProposalHash) + "\n"
    return out

fn v3BftValidatorQueueCursorText(consumedLineCount: int32): str =
    var out = ""
    out = out + v3BftValidatorQueueCursorMagic + "\n"
    out = out + "consumed_line_count=" + intToStr(consumedLineCount) + "\n"
    return out

fn v3BftValidatorDefaultVoteLockPath(statePathRaw: str): str =
    return statePathRaw + ".vote_lock"

fn v3BftValidatorDefaultQueueCursorPath(queuePathRaw: str): str =
    return queuePathRaw + ".cursor"

fn v3BftValidatorDefaultStateSyncDir(stateSyncFilePathRaw: str): str =
    return stateSyncFilePathRaw + ".snapshots"

fn v3BftValidatorWriteVoteLock(pathRaw: str,
                               state: V3BftValidatorState): bool =
    return v3path.v3WriteTextFile(os.getCurrentDir(), pathRaw, v3BftValidatorVoteLockText(state))

fn v3BftValidatorWriteQueueCursor(pathRaw: str,
                                  consumedLineCount: int32): bool =
    return v3path.v3WriteTextFile(os.getCurrentDir(), pathRaw, v3BftValidatorQueueCursorText(consumedLineCount))

fn v3BftValidatorLoadState(pathRaw: str): Result[V3BftValidatorState] =
    let text = v3path.v3ReadTextFile(os.getCurrentDir(), pathRaw)
    let trimmed = strutil.strip(text)
    if len(trimmed) <= 0:
        return Err[V3BftValidatorState]("v3 bft validator: missing state file")
    let lines = strutil.split(text, '\n')
    var sawMagic = false
    var validatorSlot = 0
    var lastVotedHeight = int64(0)
    var lastVotedProposalHash = layout.fixedBytes32Zero()
    var machineHex = ""
    for i in 0..<lines.len:
        let line = strutil.strip(lines[i])
        if len(line) <= 0:
            continue
        if line == v3BftValidatorStateMagic:
            sawMagic = true
        elif v3path.v3TextStartsWith(line, "validator_slot="):
            let slotRes = v3BftValidatorParseInt64Text(v3path.v3TextSlice(line, 15, len(line) - 15))
            if IsErr(slotRes):
                return Err[V3BftValidatorState](Error(slotRes))
            validatorSlot = int32(Value(slotRes))
        elif v3path.v3TextStartsWith(line, "last_voted_height="):
            let heightRes = v3BftValidatorParseInt64Text(v3path.v3TextSlice(line, 18, len(line) - 18))
            if IsErr(heightRes):
                return Err[V3BftValidatorState](Error(heightRes))
            lastVotedHeight = Value(heightRes)
        elif v3path.v3TextStartsWith(line, "last_voted_proposal_hash="):
            let hashRes = layout.fixedBytes32FromHex(v3path.v3TextSlice(line, 25, len(line) - 25))
            if IsErr(hashRes):
                return Err[V3BftValidatorState](Error(hashRes))
            lastVotedProposalHash = Value(hashRes)
        elif v3path.v3TextStartsWith(line, "machine_hex="):
            machineHex = strutil.strip(v3path.v3TextSlice(line, 12, len(line) - 12))
    if !sawMagic:
        return Err[V3BftValidatorState]("v3 bft validator: bad state magic")
    if !v3BftValidatorSlotValid(validatorSlot):
        return Err[V3BftValidatorState]("v3 bft validator: invalid state slot")
    let machineBytesRes = v3BftValidatorBytesFromHex(machineHex)
    if IsErr(machineBytesRes):
        return Err[V3BftValidatorState](Error(machineBytesRes))
    let machineRes = v3BftValidatorDecodeMachine(Value(machineBytesRes))
    if IsErr(machineRes):
        return Err[V3BftValidatorState](Error(machineRes))
    var out: V3BftValidatorState
    out.validatorSlot = validatorSlot
    out.lastVotedHeight = lastVotedHeight
    out.lastVotedProposalHash = lastVotedProposalHash
    out.machine = Value(machineRes)
    return Ok[V3BftValidatorState](out)

fn v3BftValidatorLoadVoteLock(pathRaw: str,
                              state: var V3BftValidatorState): Result[bool] =
    let text = v3path.v3ReadTextFile(os.getCurrentDir(), pathRaw)
    let trimmed = strutil.strip(text)
    if len(trimmed) <= 0:
        return Ok[bool](false)
    let lines = strutil.split(text, '\n')
    var sawMagic = false
    var sawHeight = false
    var sawHash = false
    var lastVotedHeight = int64(0)
    var lastVotedProposalHash = layout.fixedBytes32Zero()
    for i in 0..<lines.len:
        let line = strutil.strip(lines[i])
        if len(line) <= 0:
            continue
        if line == v3BftValidatorVoteLockMagic:
            sawMagic = true
        elif v3path.v3TextStartsWith(line, "last_voted_height="):
            let heightRes = v3BftValidatorParseInt64Text(v3path.v3TextSlice(line, 18, len(line) - 18))
            if IsErr(heightRes):
                return Err[bool](Error(heightRes))
            lastVotedHeight = Value(heightRes)
            sawHeight = true
        elif v3path.v3TextStartsWith(line, "last_voted_proposal_hash="):
            let hashRes = layout.fixedBytes32FromHex(v3path.v3TextSlice(line, 25, len(line) - 25))
            if IsErr(hashRes):
                return Err[bool](Error(hashRes))
            lastVotedProposalHash = Value(hashRes)
            sawHash = true
    if !sawMagic:
        return Err[bool]("v3 bft validator: bad vote lock magic")
    if !sawHeight || !sawHash:
        return Err[bool]("v3 bft validator: incomplete vote lock")
    state.lastVotedHeight = lastVotedHeight
    state.lastVotedProposalHash = lastVotedProposalHash
    return Ok[bool](true)

fn v3BftValidatorLoadQueueCursor(pathRaw: str): Result[int32] =
    let text = v3path.v3ReadTextFile(os.getCurrentDir(), pathRaw)
    let trimmed = strutil.strip(text)
    if len(trimmed) <= 0:
        return Ok[int32](0)
    let lines = strutil.split(text, '\n')
    var sawMagic = false
    var sawCount = false
    var consumedLineCount = 0
    for i in 0..<lines.len:
        let line = strutil.strip(lines[i])
        if len(line) <= 0:
            continue
        if line == v3BftValidatorQueueCursorMagic:
            sawMagic = true
        elif v3path.v3TextStartsWith(line, "consumed_line_count="):
            let countRes = v3BftValidatorParseInt64Text(v3path.v3TextSlice(line, 20, len(line) - 20))
            if IsErr(countRes):
                return Err[int32](Error(countRes))
            consumedLineCount = int32(Value(countRes))
            sawCount = true
    if !sawMagic:
        return Err[int32]("v3 bft validator: bad queue cursor magic")
    if !sawCount || consumedLineCount < 0:
        return Err[int32]("v3 bft validator: bad queue cursor count")
    return Ok[int32](consumedLineCount)

fn v3BftValidatorLoadLiveState(statePathRaw: str,
                               voteLockPathRaw: str): Result[V3BftValidatorState] =
    let stateRes = v3BftValidatorLoadState(statePathRaw)
    if IsErr(stateRes):
        return Err[V3BftValidatorState](Error(stateRes))
    var state = Value(stateRes)
    let voteLockRes = v3BftValidatorLoadVoteLock(voteLockPathRaw, state)
    if IsErr(voteLockRes):
        return Err[V3BftValidatorState](Error(voteLockRes))
    return Ok[V3BftValidatorState](state)

fn v3BftValidatorWriteHexFile(pathRaw: str,
                              data: Bytes): bool =
    return v3path.v3WriteTextFile(os.getCurrentDir(), pathRaw, bytesToHex(data) + "\n")

fn v3BftValidatorReadHexFile(pathRaw: str): Result[Bytes] =
    let text = v3path.v3ReadTextFile(os.getCurrentDir(), pathRaw)
    return v3BftValidatorBytesFromHex(text)

fn v3BftValidatorStateSnapshotPath(snapshotDirRaw: str,
                                   height: int64): str =
    return v3path.v3PathJoin(snapshotDirRaw, v3BftValidatorInt64Text(height) + ".hex")

fn v3BftValidatorReadStateSnapshot(snapshotDirRaw: str,
                                   height: int64): Result[Bytes] =
    let pathRaw = v3BftValidatorStateSnapshotPath(snapshotDirRaw, height)
    if !v3path.v3FileExistsNonEmpty(os.getCurrentDir(), pathRaw):
        return Err[Bytes]("v3 bft validator: missing state snapshot")
    return v3BftValidatorReadHexFile(pathRaw)

fn v3BftValidatorWriteStateSnapshot(snapshotDirRaw: str,
                                    machine: bft.V3BftStateMachine): bool =
    if !v3path.v3MkdirP(os.getCurrentDir(), snapshotDirRaw):
        return false
    return v3BftValidatorWriteHexFile(v3BftValidatorStateSnapshotPath(snapshotDirRaw, machine.lastFinalizedHeight),
                                      v3BftValidatorEncodeMachine(machine))

fn v3BftValidatorEncodeStateSyncRequest(height: int64): Bytes =
    var out = ""
    out = out + "height="
    out = out + v3BftValidatorInt64Text(height)
    out = out + "\n"
    return bytesFromString(out)

fn v3BftValidatorDecodeStateSyncRequest(data: Bytes): Result[int64] =
    let text = strutil.strip(bytesToString(data))
    if !v3path.v3TextStartsWith(text, "height="):
        return Err[int64]("v3 bft validator: bad state sync request")
    return v3BftValidatorParseInt64Text(v3path.v3TextSlice(text, 7, len(text) - 7))

fn v3BftValidatorEncodeStateSyncPayload(machineBytes: Bytes): Bytes =
    var out = ""
    out = out + "machine_hex="
    out = out + bytesToHex(machineBytes)
    out = out + "\n"
    return bytesFromString(out)

fn v3BftValidatorEncodeStateSyncError(err: str): Bytes =
    var out = ""
    out = out + "error="
    out = out + err
    out = out + "\n"
    return bytesFromString(out)

fn v3BftValidatorDecodeStateSyncPayload(data: Bytes): Result[bft.V3BftStateMachine] =
    let text = bytesToString(data)
    let lines = strutil.split(text, '\n')
    var machineHex = ""
    var errText = ""
    for i in 0..<lines.len:
        let line = strutil.strip(lines[i])
        if len(line) <= 0:
            continue
        if v3path.v3TextStartsWith(line, "machine_hex="):
            machineHex = strutil.strip(v3path.v3TextSlice(line, 12, len(line) - 12))
        elif v3path.v3TextStartsWith(line, "error="):
            errText = strutil.strip(v3path.v3TextSlice(line, 6, len(line) - 6))
    if len(errText) > 0:
        return Err[bft.V3BftStateMachine](errText)
    if len(machineHex) <= 0:
        return Err[bft.V3BftStateMachine]("v3 bft validator: missing state sync payload")
    let machineBytesRes = v3BftValidatorBytesFromHex(machineHex)
    if IsErr(machineBytesRes):
        return Err[bft.V3BftStateMachine](Error(machineBytesRes))
    return v3BftValidatorDecodeMachine(Value(machineBytesRes))

fn v3BftValidatorStateSyncPayloadForHeight(snapshotDirRaw: str,
                                           height: int64): Bytes =
    let snapshotRes = v3BftValidatorReadStateSnapshot(snapshotDirRaw, height)
    if IsErr(snapshotRes):
        return v3BftValidatorEncodeStateSyncError(Error(snapshotRes))
    return v3BftValidatorEncodeStateSyncPayload(Value(snapshotRes))

fn v3BftValidatorRetryableStateSyncRecvError(err: str): bool =
    return v3path.v3TextStartsWith(err, "v3 libp2p quic: dial") ||
           v3path.v3TextStartsWith(err, "v3 libp2p quic: unexpected eof") ||
           v3path.v3TextStartsWith(err, "msquic native: pipe read timeout") ||
           v3path.v3TextStartsWith(err, "msquic native: handshake ! ready") ||
           v3path.v3TextStartsWith(err, "msquic native: session ! ready")

fn v3BftValidatorQueueLoad(pathRaw: str): Result[Bytes[]] =
    let text = v3path.v3ReadTextFile(os.getCurrentDir(), pathRaw)
    let trimmed = strutil.strip(text)
    var out: Bytes[]
    out = []
    if len(trimmed) <= 0:
        return Ok[Bytes[]](out)
    let lines = strutil.split(text, '\n')
    for i in 0..<lines.len:
        let line = strutil.strip(lines[i])
        if len(line) <= 0:
            continue
        let bytesRes = v3BftValidatorBytesFromHex(line)
        if IsErr(bytesRes):
            return Err[Bytes[]](Error(bytesRes))
        let txRes = bft.v3BftDecodeTx(layout.byteSpanFromBytes(Value(bytesRes)))
        if IsErr(txRes):
            return Err[Bytes[]]("v3 bft validator: bad queued tx")
        add(out, Value(bytesRes))
    return Ok[Bytes[]](out)

fn v3BftValidatorQueueWrite(pathRaw: str,
                            txs: Bytes[]): bool =
    var out = ""
    for i in 0..<txs.len:
        out = out + bytesToHex(txs[i]) + "\n"
    return v3path.v3WriteTextFile(os.getCurrentDir(), pathRaw, out)

fn v3BftValidatorQueueAppend(pathRaw: str,
                             txWire: Bytes): bool =
    let existingRes = v3BftValidatorQueueLoad(pathRaw)
    if IsErr(existingRes):
        return false
    var txs = Value(existingRes)
    add(txs, txWire)
    return v3BftValidatorQueueWrite(pathRaw, txs)

fn v3BftValidatorQueueTrackerInit(pathRaw: str,
                                  cursorPathRaw: str): Result[V3BftValidatorQueueTracker] =
    let consumedRes = v3BftValidatorLoadQueueCursor(cursorPathRaw)
    if IsErr(consumedRes):
        return Err[V3BftValidatorQueueTracker](Error(consumedRes))
    let text = v3path.v3ReadTextFile(os.getCurrentDir(), pathRaw)
    let lines = strutil.split(text, '\n')
    let knownFileSize = v3path.v3PathFileSize(v3path.v3PathAbsolute(os.getCurrentDir(), pathRaw))
    var knownLineCount = 0
    var pendingTxs: Bytes[]
    pendingTxs = []
    for i in 0..<lines.len:
        let line = strutil.strip(lines[i])
        if len(line) <= 0:
            continue
        let bytesRes = v3BftValidatorBytesFromHex(line)
        if IsErr(bytesRes):
            return Err[V3BftValidatorQueueTracker](Error(bytesRes))
        let txRes = bft.v3BftDecodeTx(layout.byteSpanFromBytes(Value(bytesRes)))
        if IsErr(txRes):
            return Err[V3BftValidatorQueueTracker]("v3 bft validator: bad queued tx")
        if knownLineCount >= Value(consumedRes):
            add(pendingTxs, Value(bytesRes))
        knownLineCount = knownLineCount + 1
    if Value(consumedRes) > knownLineCount:
        return Err[V3BftValidatorQueueTracker]("v3 bft validator: queue cursor beyond queue tail")
    var out: V3BftValidatorQueueTracker
    out.knownFileSize = knownFileSize
    out.knownLineCount = knownLineCount
    out.consumedLineCount = Value(consumedRes)
    out.pendingTxs = pendingTxs
    return Ok[V3BftValidatorQueueTracker](out)

fn v3BftValidatorQueueTrackerRefresh(pathRaw: str,
                                     tracker: var V3BftValidatorQueueTracker): Result[int32] =
    let queuePath = v3path.v3PathAbsolute(os.getCurrentDir(), pathRaw)
    let fileSize = v3path.v3PathFileSize(queuePath)
    if fileSize == tracker.knownFileSize:
        return Ok[int32](0)
    if fileSize < tracker.knownFileSize:
        return Err[int32]("v3 bft validator: queue file shrank")
    let text = v3path.v3ReadTextFile(os.getCurrentDir(), pathRaw)
    let lines = strutil.split(text, '\n')
    var seenLineCount = 0
    var newCount = 0
    for i in 0..<lines.len:
        let line = strutil.strip(lines[i])
        if len(line) <= 0:
            continue
        if seenLineCount >= tracker.knownLineCount:
            let bytesRes = v3BftValidatorBytesFromHex(line)
            if IsErr(bytesRes):
                return Err[int32](Error(bytesRes))
            let txRes = bft.v3BftDecodeTx(layout.byteSpanFromBytes(Value(bytesRes)))
            if IsErr(txRes):
                return Err[int32]("v3 bft validator: bad queued tx")
            add(tracker.pendingTxs, Value(bytesRes))
            newCount = newCount + 1
        seenLineCount = seenLineCount + 1
    if seenLineCount < tracker.knownLineCount:
        return Err[int32]("v3 bft validator: queue line count regressed")
    tracker.knownLineCount = seenLineCount
    tracker.knownFileSize = fileSize
    return Ok[int32](newCount)

fn v3BftValidatorQueueTrackerCommit(cursorPathRaw: str,
                                    tracker: var V3BftValidatorQueueTracker,
                                    txCount: int32): Result[bool] =
    if txCount < 0 || txCount > tracker.pendingTxs.len:
        return Err[bool]("v3 bft validator: queue commit count out of range")
    var remaining: Bytes[]
    remaining = []
    for i in txCount..<tracker.pendingTxs.len:
        add(remaining, tracker.pendingTxs[i])
    tracker.pendingTxs = remaining
    tracker.consumedLineCount = tracker.consumedLineCount + txCount
    if tracker.consumedLineCount > tracker.knownLineCount:
        return Err[bool]("v3 bft validator: queue cursor advanced past queue tail")
    if !v3BftValidatorWriteQueueCursor(cursorPathRaw, tracker.consumedLineCount):
        return Err[bool]("v3 bft validator: failed to write queue cursor")
    return Ok[bool](true)

fn v3BftValidatorVoteMatchesPreview(vote: V3BftVote,
                                    proposal: V3BftProposal,
                                    preview: V3BftProposalPreview): bool =
    return vote.accepted &&
           vote.appId == proposal.appId &&
           vote.height == proposal.height &&
           layout.fixedBytes32Equal(vote.proposalHash, preview.proposalHash) &&
           layout.fixedBytes32Equal(vote.appHash, preview.appHash) &&
           layout.fixedBytes32Equal(vote.tipEventCid, preview.tipEventCid) &&
           vote.eventCount == preview.eventCount &&
           vote.accountCount == preview.accountCount

fn v3BftValidatorVoteSetAdd(out: var V3BftVote[],
                            vote: V3BftVote,
                            proposal: V3BftProposal,
                            preview: V3BftProposalPreview): Result[bool] =
    let verifyRes = v3BftValidatorVerifyVote(vote)
    if IsErr(verifyRes):
        return Err[bool](Error(verifyRes))
    if !v3BftValidatorVoteMatchesPreview(vote, proposal, preview):
        return Ok[bool](false)
    for i in 0..<out.len:
        if out[i].validatorSlot == vote.validatorSlot:
            return Ok[bool](false)
    add(out, vote)
    return Ok[bool](true)

fn v3BftValidatorVoteInboxLoad(pathRaw: str): Result[V3BftVote[]] =
    let text = v3path.v3ReadTextFile(os.getCurrentDir(), pathRaw)
    let trimmed = strutil.strip(text)
    var out: V3BftVote[]
    out = []
    if len(trimmed) <= 0:
        return Ok[V3BftVote[]](out)
    let lines = strutil.split(text, '\n')
    for i in 0..<lines.len:
        let line = strutil.strip(lines[i])
        if len(line) <= 0:
            continue
        let bytesRes = v3BftValidatorBytesFromHex(line)
        if IsErr(bytesRes):
            return Err[V3BftVote[]](Error(bytesRes))
        let voteRes = v3BftValidatorDecodeVote(Value(bytesRes))
        if IsErr(voteRes):
            return Err[V3BftVote[]](Error(voteRes))
        add(out, Value(voteRes))
    return Ok[V3BftVote[]](out)

fn v3BftValidatorVoteInboxAppend(pathRaw: str,
                                 voteWire: Bytes): bool =
    let existing = v3path.v3ReadTextFile(os.getCurrentDir(), pathRaw)
    return v3path.v3WriteTextFile(os.getCurrentDir(), pathRaw, existing + bytesToHex(voteWire) + "\n")

fn v3BftValidatorVoteSetForProposal(pathRaw: str,
                                    proposal: V3BftProposal,
                                    selfVote: V3BftVote,
                                    preview: V3BftProposalPreview): Result[V3BftVote[]] =
    let inboxRes = v3BftValidatorVoteInboxLoad(pathRaw)
    if IsErr(inboxRes):
        return Err[V3BftVote[]](Error(inboxRes))
    let inbox = Value(inboxRes)
    var out: V3BftVote[]
    out = []
    add(out, selfVote)
    for i in 0..<inbox.len:
        let vote = inbox[i]
        if vote.validatorSlot == selfVote.validatorSlot:
            continue
        let addRes = v3BftValidatorVoteSetAdd(out, vote, proposal, preview)
        if IsErr(addRes):
            continue
    return Ok[V3BftVote[]](out)

fn v3BftValidatorProposalProtocol(): types.V3Libp2pProtocolId =
    return types.v3Libp2pProtocolBftProposal

fn v3BftValidatorVoteProtocol(): types.V3Libp2pProtocolId =
    return types.v3Libp2pProtocolBftVote

fn v3BftValidatorCommitProtocol(): types.V3Libp2pProtocolId =
    return types.v3Libp2pProtocolBftCommit

fn v3BftValidatorStateSyncProtocol(): types.V3Libp2pProtocolId =
    return types.v3Libp2pProtocolBftStateSync

fn v3BftValidatorPublicTransportServerName(): str =
    return "server.cheng-quic.internal"

fn v3BftValidatorServeHexFileOnce(pathRaw: str,
                                  host: str,
                                  port: int32,
                                  protocol: types.V3Libp2pProtocolId,
                                  readyPath: str): Result[bool] =
    let payloadRes = v3BftValidatorReadHexFile(pathRaw)
    if IsErr(payloadRes):
        return Err[bool](Error(payloadRes))
    if bytesLen(Value(payloadRes)) <= 0:
        return Err[bool]("v3 bft validator: empty payload file")
    return quic_transport.v3Libp2pQuicServePayloadOnceNamed(host,
                                                            port,
                                                            v3BftValidatorPublicTransportServerName(),
                                                            protocol,
                                                            Value(payloadRes),
                                                            readyPath)

fn v3BftValidatorCaptureVoteOnce(pathRaw: str,
                                 host: str,
                                 port: int32,
                                 readyPath: str): Result[bool] =
    let ack = bytesFromString("ok")
    let requestRes = quic_transport.v3Libp2pQuicServeRequestCaptureOnceNamed(host,
                                                                             port,
                                                                             v3BftValidatorPublicTransportServerName(),
                                                                             v3BftValidatorVoteProtocol(),
                                                                             ack,
                                                                             readyPath)
    if IsErr(requestRes):
        return Err[bool](Error(requestRes))
    if !v3BftValidatorVoteInboxAppend(pathRaw, Value(requestRes)):
        return Err[bool]("v3 bft validator: failed to append vote inbox")
    return Ok[bool](true)

fn v3BftValidatorServeProposalWindow(host: str,
                                     port: int32,
                                     proposal: V3BftProposal,
                                     readyPath: str,
                                     maxServeCount: int32,
                                     waitMs: int32): Result[bool] =
    return quic_transport.v3Libp2pQuicServePayloadWindowNamed(host,
                                                              port,
                                                              v3BftValidatorPublicTransportServerName(),
                                                              v3BftValidatorProposalProtocol(),
                                                              v3BftValidatorEncodeProposal(proposal),
                                                              readyPath,
                                                              maxServeCount,
                                                              waitMs)

fn v3BftValidatorServeCommitWindow(host: str,
                                   port: int32,
                                   commit: V3BftCommit,
                                   readyPath: str,
                                   maxServeCount: int32,
                                   waitMs: int32): Result[bool] =
    return quic_transport.v3Libp2pQuicServePayloadWindowNamed(host,
                                                              port,
                                                              v3BftValidatorPublicTransportServerName(),
                                                              v3BftValidatorCommitProtocol(),
                                                              v3BftValidatorEncodeCommit(commit),
                                                              readyPath,
                                                              maxServeCount,
                                                              waitMs)

fn v3BftValidatorServeStateWindow(host: str,
                                  port: int32,
                                  machine: bft.V3BftStateMachine,
                                  readyPath: str,
                                  maxServeCount: int32,
                                  waitMs: int32): Result[bool] =
    return quic_transport.v3Libp2pQuicServePayloadWindowNamed(host,
                                                              port,
                                                              v3BftValidatorPublicTransportServerName(),
                                                              v3BftValidatorStateSyncProtocol(),
                                                              v3BftValidatorEncodeMachine(machine),
                                                              readyPath,
                                                              maxServeCount,
                                                              waitMs)

fn v3BftValidatorCaptureVotesWindow(host: str,
                                    port: int32,
                                    readyPath: str,
                                    maxCaptureCount: int32,
                                    waitMs: int32): Result[V3BftVote[]] =
    let ack = bytesFromString("ok")
    let captureRes = quic_transport.v3Libp2pQuicServeRequestCaptureWindowNamed(host,
                                                                               port,
                                                                               v3BftValidatorPublicTransportServerName(),
                                                                               v3BftValidatorVoteProtocol(),
                                                                               ack,
                                                                               readyPath,
                                                                               maxCaptureCount,
                                                                               waitMs)
    if IsErr(captureRes):
        return Err[V3BftVote[]](Error(captureRes))
    var out: V3BftVote[]
    out = []
    let wires = Value(captureRes)
    for i in 0..<wires.len:
        let voteRes = v3BftValidatorDecodeVote(wires[i])
        if IsErr(voteRes):
            return Err[V3BftVote[]](Error(voteRes))
        add(out, Value(voteRes))
    return Ok[V3BftVote[]](out)

fn v3BftValidatorSendVote(host: str,
                          port: int32,
                          vote: V3BftVote): Result[bool] =
    let voteWire = v3BftValidatorEncodeVote(vote)
    let replyRes = quic_transport.v3Libp2pQuicRequestResponseNamed(host,
                                                                   port,
                                                                   v3BftValidatorPublicTransportServerName(),
                                                                   v3BftValidatorVoteProtocol(),
                                                                   voteWire)
    if IsErr(replyRes):
        return Err[bool](Error(replyRes))
    if bytesToString(Value(replyRes)) != "ok":
        return Err[bool]("v3 bft validator: vote ack mismatch")
    return Ok[bool](true)

fn v3BftValidatorLoadProposalFile(pathRaw: str): Result[V3BftProposal] =
    let payloadRes = v3BftValidatorReadHexFile(pathRaw)
    if IsErr(payloadRes):
        return Err[V3BftProposal](Error(payloadRes))
    return v3BftValidatorDecodeProposal(Value(payloadRes))

fn v3BftValidatorRecvProposal(host: str,
                              port: int32): Result[V3BftProposal] =
    let payloadRes = quic_transport.v3Libp2pQuicRecvPayloadOnceNamed(host,
                                                                     port,
                                                                     v3BftValidatorPublicTransportServerName(),
                                                                     v3BftValidatorProposalProtocol())
    if IsErr(payloadRes):
        return Err[V3BftProposal](Error(payloadRes))
    return v3BftValidatorDecodeProposal(Value(payloadRes))

fn v3BftValidatorLoadCommitFile(pathRaw: str): Result[V3BftCommit] =
    let payloadRes = v3BftValidatorReadHexFile(pathRaw)
    if IsErr(payloadRes):
        return Err[V3BftCommit](Error(payloadRes))
    return v3BftValidatorDecodeCommit(Value(payloadRes))

fn v3BftValidatorRecvCommit(host: str,
                            port: int32): Result[V3BftCommit] =
    let payloadRes = quic_transport.v3Libp2pQuicRecvPayloadOnceNamed(host,
                                                                     port,
                                                                     v3BftValidatorPublicTransportServerName(),
                                                                     v3BftValidatorCommitProtocol())
    if IsErr(payloadRes):
        return Err[V3BftCommit](Error(payloadRes))
    return v3BftValidatorDecodeCommit(Value(payloadRes))

fn v3BftValidatorRecvStateMachine(host: str,
                                  port: int32,
                                  height: int64): Result[bft.V3BftStateMachine] =
    var ackOk = false
    for attempt in 0..<512:
        let ackRes = quic_transport.v3Libp2pQuicRequestResponseNamed(host,
                                                                     port,
                                                                     v3BftValidatorPublicTransportServerName(),
                                                                     v3BftValidatorStateSyncProtocol(),
                                                                     v3BftValidatorEncodeStateSyncRequest(height))
        if IsOk(ackRes):
            if strutil.strip(bytesToString(Value(ackRes))) != v3BftValidatorStateSyncAck:
                return Err[bft.V3BftStateMachine]("v3 bft validator: state sync ack mismatch")
            ackOk = true
            break
        if !v3BftValidatorRetryableStateSyncRecvError(Error(ackRes)):
            return Err[bft.V3BftStateMachine](Error(ackRes))
        attempt
    if !ackOk:
        return Err[bft.V3BftStateMachine]("v3 bft validator: state sync ack unavailable")
    for attempt in 0..<512:
        let payloadRes = quic_transport.v3Libp2pQuicRecvPayloadOnceNamed(host,
                                                                         port,
                                                                         v3BftValidatorPublicTransportServerName(),
                                                                         v3BftValidatorStateSyncProtocol())
        if IsOk(payloadRes):
            return v3BftValidatorDecodeStateSyncPayload(Value(payloadRes))
        if !v3BftValidatorRetryableStateSyncRecvError(Error(payloadRes)):
            return Err[bft.V3BftStateMachine](Error(payloadRes))
        attempt
    return Err[bft.V3BftStateMachine]("v3 bft validator: state sync payload unavailable")

fn v3BftValidatorMachineMatchesCommit(machine: bft.V3BftStateMachine,
                                      commit: V3BftCommit): bool =
    let machineCommit = bft.v3BftStateMachineCommit(machine)
    return machineCommit.height == commit.height &&
           layout.fixedBytes32Equal(machineCommit.appHash, commit.appHash) &&
           layout.fixedBytes32Equal(machineCommit.tipEventCid, commit.tipEventCid) &&
           machineCommit.eventCount == commit.eventCount &&
           machineCommit.accountCount == commit.accountCount

fn v3BftValidatorSyncMachineFromCommit(state: var V3BftValidatorState,
                                       commit: V3BftCommit,
                                       syncHost: str,
                                       syncPort: int32): Result[bool] =
    if len(syncHost) <= 0 || syncPort <= 0:
        return Err[bool]("v3 bft validator: missing state sync endpoint")
    let machineRes = v3BftValidatorRecvStateMachine(syncHost, syncPort, commit.height)
    if IsErr(machineRes):
        return Err[bool](Error(machineRes))
    let machine = Value(machineRes)
    if !v3BftValidatorMachineMatchesCommit(machine, commit):
        return Err[bool]("v3 bft validator: state sync commit mismatch")
    state.machine = machine
    return Ok[bool](true)

fn v3BftValidatorQueryBalance(state: V3BftValidatorState,
                              assetId: int32,
                              accountId: int32): bft.V3BftBalanceQueryResult =
    return bft.v3BftStateMachineQueryBalance(state.machine, assetId, accountId)

fn v3BftValidatorStateSummary(state: V3BftValidatorState): str =
    let commit = bft.v3BftStateMachineCommit(state.machine)
    var out = ""
    out = out + "validator_slot=" + intToStr(state.validatorSlot) + "\n"
    out = out + "height=" + v3BftValidatorInt64Text(commit.height) + "\n"
    out = out + "app_hash=" + layout.fixedBytes32Hex(commit.appHash) + "\n"
    out = out + "tip_event_cid=" + layout.fixedBytes32Hex(commit.tipEventCid) + "\n"
    out = out + "event_count=" + intToStr(commit.eventCount) + "\n"
    out = out + "account_count=" + intToStr(commit.accountCount) + "\n"
    out = out + "last_voted_height=" + v3BftValidatorInt64Text(state.lastVotedHeight)
    return out
