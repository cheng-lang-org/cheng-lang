fn oracleSmokeSig(roundId: int64, reporterSlot: int32): layout.FixedBytes64 =
    let sigRes = layout.fixedBytes64FromHex(oracleSmokeSigHex(roundId, reporterSlot))
    assert(IsOk(sigRes), "oracle smoke: sig")
    return Value(sigRes)

fn oracleSmokeBatchFill(roundId: int64,
                        reporterSlot: int32,
                        out: var oracle_plane.V3OracleSignedBatch) =
    let observedAtMs = oracle_types.V3OracleRoundStartMs(roundId) + int64(reporterSlot)
    out = oracle_plane.V3OracleSignedBatch()
    out.version = oracle_types.V3OracleVersion
    out.committeeSetId = 1
    out.reporterSlot = reporterSlot
    out.roundId = roundId
    out.observedAtMs = observedAtMs
    out.pricesE8 = oracleSmokePrices(roundId, reporterSlot)
    out.sig = oracleSmokeSig(roundId, reporterSlot)
    let cidRes = oracle_plane.v3OracleSignedBatchCid(out)
    assert(IsOk(cidRes), "oracle smoke: cid")
    out.batchCid = Value(cidRes)
    let okRes = oracle_plane.v3OracleSignedBatchStructuralValidate(out)
    assert(IsOk(okRes), "oracle smoke: structural")

fn oracleSmokeBatch(roundId: int64, reporterSlot: int32): oracle_plane.V3OracleSignedBatch =
    var batch = oracle_plane.V3OracleSignedBatch()
    oracleSmokeBatchFill(roundId, reporterSlot, batch)
    return batch

fn oracleSmokePairId(assetId: int32, quoteId: int32): int32 =
    let pairRes = oracle_types.V3OraclePairIdFromAssetQuote(assetId, quoteId)
    assert(IsOk(pairRes), "oracle smoke: pair id")
    return Value(pairRes)

fn OracleSmokeCommittee(): oracle_types.V3OracleCommitteeConfig =
    return oracleSmokeCommittee()

fn OracleSmokePrice(roundId: int64, pairIndex: int32, reporterSlot: int32): int64 =
    return oracleSmokePrice(roundId, pairIndex, reporterSlot)

fn OracleSmokeBatch(roundId: int64, reporterSlot: int32): oracle_plane.V3OracleSignedBatch =
    return oracleSmokeBatch(roundId, reporterSlot)

fn OracleSmokePairId(assetId: int32, quoteId: int32): int32 =
    return oracleSmokePairId(assetId, quoteId)

fn OracleSmokeBatchFill(roundId: int64,
                        reporterSlot: int32,
                        out: var oracle_plane.V3OracleSignedBatch) =
    oracleSmokeBatchFill(roundId, reporterSlot, out)
