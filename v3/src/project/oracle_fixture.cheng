    if slot == 3:
        return "04849d0a4d07c118a06e274519e743f23b327104b017e985ac50a7749f592120d865abc57511ef74ee12878e0583770e6457acb1abbe408a27ad220068936307ee"
    if slot == 4:
        return "0483898a50dd6df34f3fe95788b7f5bbd85e6372e82038e9ba16ea03054e4b31dca1e2f032a9d8ff5dd747dddc94e41626c65fb9f72f1a0829c357ad68c9bedb9c"
    if slot == 5:
        return "04a3435b80c5d1e5cdceaab69001870a89789de55226948d9fc17f2706db725e3e4398f1b4a3ba48be4454b6cdfae4522aace30bcc1a8bf1e37799a6b794418a71"
    if slot == 6:
        return "049f9d7d9707431e517488e9e82880a8c559acbae55b5ef20cf16d054d24c3bb37a5c688a96ced084282c77603e7447f018bc632949e23f8c5d3852272335beb5c"
    if slot == 7:
        return "0494ae32aab6e35ea0f4fa7667b845aa49b2a93a558f9a42e43221cc21ba2c049ed4ccb0b6b83cdf42a8cabce0437991bbefb6e991a896fed82a544d65ee7a9fb6"
    panic("oracle smoke: missing private key")

fn oracleSmokePubKey(slot: int32): layout.FixedBytes65 =
    let pubRes = layout.fixedBytes65FromHex(oracleSmokePubKeyHex(slot))
    assert(IsOk(pubRes), "oracle smoke: pubkey")
    return Value(pubRes)

fn oracleSmokeCommittee(): oracle_types.V3OracleCommitteeConfig =
    var pubKeys: layout.FixedBytes65[]
    pubKeys = []
    for slot in 1..<8:
        add(pubKeys, oracleSmokePubKey(slot))
    let committeeRes = oracle_types.V3OracleCommitteeConfigMake(1, pubKeys, oracle_types.V3OracleDefaultQuorum)
    assert(IsOk(committeeRes), "oracle smoke: committee")
    return Value(committeeRes)

fn oracleSmokePrice(roundId: int64, pairIndex: int32, reporterSlot: int32): int64 =
    return (roundId * int64(1000000000)) + int64((pairIndex + 1) * 1000) + int64(reporterSlot * 10) + int64(1)

fn oracleSmokePrices(roundId: int64, reporterSlot: int32): int64[] =
    var prices: int64[]
    prices = []
    for pairIndex in 0..<oracle_types.V3OraclePairCount:
        add(prices, oracleSmokePrice(roundId, pairIndex, reporterSlot))
    return prices

