import std/result
import std/rawbytes
import std/crypto/rand
import std/crypto/ecnist
import std/crypto/p256_fixed as pfix
import cheng/v3/std/bytes_layout as layout
import cheng/v3/std/crypto/fixed256
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/project/bio_reed_solomon as rs

const
    v3BioVersion: int32 = 1
    v3BioCodeN: int32 = rs.v3BioRsCodeBytes
    v3BioCodeK: int32 = rs.v3BioRsMessageBytes
    v3BioMaxCorrectable: int32 = rs.v3BioRsMaxCorrectable
    v3BioScalarRetryLimit: int32 = 256

type
    V3BioEnrollmentRecord =
        version: int32
        helper: layout.FixedBytes32
        pubKey: layout.FixedBytes65
        codeN: int32
        codeK: int32
        maxCorrectable: int32
        recordCid: layout.FixedBytes32

    V3BioSchnorrProof =
        commitA: layout.FixedBytes65
        responseZ: layout.FixedBytes32

    V3BioAssertion =
        recordCid: layout.FixedBytes32
        challengeNonce: layout.FixedBytes32
        commitA: layout.FixedBytes65
        responseZ: layout.FixedBytes32
        proofCid: layout.FixedBytes32

fn v3BioEnrollmentRecordZero(): V3BioEnrollmentRecord =
    return V3BioEnrollmentRecord(version: 1,
                                 helper: layout.fixedBytes32Zero(),
                                 pubKey: layout.fixedBytes65Zero(),
                                 codeN: 32,
                                 codeK: 16,
                                 maxCorrectable: 8,
                                 recordCid: layout.fixedBytes32Zero())

fn v3BioSchnorrProofZero(): V3BioSchnorrProof =
    var out: V3BioSchnorrProof
    out.commitA = layout.fixedBytes65Zero()
    out.responseZ = layout.fixedBytes32Zero()
    return out

fn v3BioAssertionZero(): V3BioAssertion =
    var out: V3BioAssertion
    out.recordCid = layout.fixedBytes32Zero()
    out.challengeNonce = layout.fixedBytes32Zero()
    out.commitA = layout.fixedBytes65Zero()
    out.responseZ = layout.fixedBytes32Zero()
    out.proofCid = layout.fixedBytes32Zero()
    return out

fn v3BioXorFixed32(left: layout.FixedBytes32, right: layout.FixedBytes32): layout.FixedBytes32 =
    var out: layout.FixedBytes32
    var i: int32 = 0
    while i < 32:
        out.data[i] = uint8((int32(left.data[i]) ^ int32(right.data[i])) & 255)
        i = i + 1
    return out

fn v3BioRandomMessage16(): Result[rs.V3BioMessage16] =
    var rawRes: Result[Bytes]
    rawRes = rand.randomBytes(16)
    if IsErr(rawRes):
        return Err[rs.V3BioMessage16](Error(rawRes))
    return rs.v3BioMessage16FromBytes(Value(rawRes))

fn v3BioRootSecretFromCodeword(codeword: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(128)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.bio.root"))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(codeword))
    return lt.v3FixedCidFromBuf(buf)

fn v3BioEnsureP256(): Result[bool] =
    return ecnist.p256EnsureInit()

fn v3BioScalarModulus(): pfix.P256Fixed =
    return pfix.p256ScalarModulus()

fn v3BioScalarFixedFromFixed32(value: layout.FixedBytes32): pfix.P256Fixed =
    var out: pfix.P256Fixed
    for limb in 0..<8:
        let offset: int32 = 28 - (limb * 4)
        let b0: uint64 = uint64(int32(value.data[offset]) & 255)
        let b1: uint64 = uint64(int32(value.data[offset + 1]) & 255)
        let b2: uint64 = uint64(int32(value.data[offset + 2]) & 255)
        let b3: uint64 = uint64(int32(value.data[offset + 3]) & 255)
        let word: uint64 = (b0 << uint64(24)) | (b1 << uint64(16)) | (b2 << uint64(8)) | b3
        out.limbs[limb] = int32(uint32(word))
    return out

fn v3BioScalarFixedToFixed32(value: pfix.P256Fixed): layout.FixedBytes32 =
    var out: layout.FixedBytes32
    for limb in 0..<8:
        let offset: int32 = 28 - (limb * 4)
        let word: uint64 = pfix.p256FixedWordToBitsU64(value.limbs[limb])
        out.data[offset] = uint8(int32((word >> uint64(24)) & uint64(255)))
        out.data[offset + 1] = uint8(int32((word >> uint64(16)) & uint64(255)))
        out.data[offset + 2] = uint8(int32((word >> uint64(8)) & uint64(255)))
        out.data[offset + 3] = uint8(int32(word & uint64(255)))
    return out

fn v3BioScalarFixedFromScalar(value: fixed256.Scalar256): pfix.P256Fixed =
    return v3BioScalarFixedFromFixed32(value.bytes)

fn v3BioScalarFromFixed(value: pfix.P256Fixed): fixed256.Scalar256 =
    return fixed256.Scalar256(bytes: v3BioScalarFixedToFixed32(value))

fn v3BioScalarModMul(left: fixed256.Scalar256,
                     right: fixed256.Scalar256): Result[fixed256.Scalar256] =
    var leftFixed: pfix.P256Fixed = v3BioScalarFixedFromScalar(left)
    var rightFixed: pfix.P256Fixed = v3BioScalarFixedFromScalar(right)
    var ctx: pfix.P256FixedMontgomeryContext = pfix.p256ScalarMontgomeryContext()
    let mulRes = pfix.p256FixedModMulWithContext(leftFixed, rightFixed, ctx)
    if IsErr(mulRes):
        return Err[fixed256.Scalar256](Error(mulRes))
    return Ok[fixed256.Scalar256](v3BioScalarFromFixed(Value(mulRes)))

fn v3BioScalarModAdd(left: fixed256.Scalar256,
                     right: fixed256.Scalar256): Result[fixed256.Scalar256] =
    var leftFixed: pfix.P256Fixed = v3BioScalarFixedFromScalar(left)
    var rightFixed: pfix.P256Fixed = v3BioScalarFixedFromScalar(right)
    var modulus: pfix.P256Fixed = v3BioScalarModulus()
    let addRes = pfix.p256FixedModAdd(leftFixed, rightFixed, modulus)
    if IsErr(addRes):
        return Err[fixed256.Scalar256](Error(addRes))
    return Ok[fixed256.Scalar256](v3BioScalarFromFixed(Value(addRes)))

fn v3BioHashBufToScalar(buf: layout.ByteBuf): Result[fixed256.Scalar256] =
    let initRes = v3BioEnsureP256()
    if IsErr(initRes):
        return Err[fixed256.Scalar256](Error(initRes))
    for counter in 0..<v3BioScalarRetryLimit:
        var attempt: layout.ByteBuf = layout.byteBufInit(layout.byteBufLen(buf) + 8)
        layout.byteBufAppendBytes(attempt, layout.byteBufToBytes(buf))
        lt.v3AppendU32BE(attempt, counter)
        let digest = lt.v3FixedCidFromBuf(attempt)
        var reduced: pfix.P256Fixed = v3BioScalarFixedFromFixed32(digest)
        var modulus: pfix.P256Fixed = v3BioScalarModulus()
        if pfix.p256FixedCmp(reduced, modulus) >= 0:
            reduced = pfix.p256FixedModSubTrusted(reduced, modulus, modulus)
        if pfix.p256FixedIsZero(reduced):
            continue
        return Ok[fixed256.Scalar256](v3BioScalarFromFixed(reduced))
    return Err[fixed256.Scalar256]("v3 bio: hash-to-scalar exhausted")

fn v3BioScalarFromRootSecret(rootSecret: layout.FixedBytes32): Result[fixed256.Scalar256] =
    var buf: layout.ByteBuf = layout.byteBufInit(96)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.bio.scalar"))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(rootSecret))
    return v3BioHashBufToScalar(buf)

fn v3BioNonceScalar(secret: fixed256.Scalar256,
                    challengeNonce: layout.FixedBytes32): Result[fixed256.Scalar256] =
    var buf: layout.ByteBuf = layout.byteBufInit(160)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.bio.nonce"))
    layout.byteBufAppendBytes(buf, fixed256.scalar256ToBytes(secret))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(challengeNonce))
    return v3BioHashBufToScalar(buf)

fn v3BioChallengeScalar(recordCid: layout.FixedBytes32,
                        challengeNonce: layout.FixedBytes32,
                        commitA: layout.FixedBytes65,
                        pubKey: layout.FixedBytes65): Result[fixed256.Scalar256] =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.bio.schnorr"))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(recordCid))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(challengeNonce))
    layout.byteBufAppendBytes(buf, layout.fixedBytes65ToBytes(commitA))
    layout.byteBufAppendBytes(buf, layout.fixedBytes65ToBytes(pubKey))
    return v3BioHashBufToScalar(buf)

fn v3BioScalarBytesValid(value: layout.FixedBytes32): bool =
    return ecnist.validateEcdsaPrivateKeyBytes(layout.fixedBytes32ToBytes(value))

fn v3BioScalarFromFixed32(value: layout.FixedBytes32): Result[fixed256.Scalar256] =
    if !v3BioScalarBytesValid(value):
        return Err[fixed256.Scalar256]("v3 bio: invalid scalar bytes")
    return fixed256.scalar256FromBytes(layout.fixedBytes32ToBytes(value))

fn v3BioPublicKeyFromScalar(value: fixed256.Scalar256): Result[layout.FixedBytes65] =
    return fixed256.p256PublicKey65FromPrivateScalar(value)

fn v3BioRecordCid(record: V3BioEnrollmentRecord): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.bio.record"))
    lt.v3AppendU32BE(buf, record.version)
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(record.helper))
    layout.byteBufAppendBytes(buf, layout.fixedBytes65ToBytes(record.pubKey))
    lt.v3AppendU32BE(buf, record.codeN)
    lt.v3AppendU32BE(buf, record.codeK)
    lt.v3AppendU32BE(buf, record.maxCorrectable)
    return lt.v3FixedCidFromBuf(buf)

fn v3BioAssertionCid(recordCid: layout.FixedBytes32,
                     challengeNonce: layout.FixedBytes32,
                     commitA: layout.FixedBytes65,
                     responseZ: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.bio.assertion"))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(recordCid))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(challengeNonce))
    layout.byteBufAppendBytes(buf, layout.fixedBytes65ToBytes(commitA))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(responseZ))
    return lt.v3FixedCidFromBuf(buf)

fn v3BioValidateRecord(record: V3BioEnrollmentRecord): Result[bool] =
    if record.version != v3BioVersion:
        return Err[bool]("v3 bio: unsupported record version")
    if record.codeN != 32:
        return Err[bool]("v3 bio: unsupported record parameters")
    if record.codeK != 16:
        return Err[bool]("v3 bio: unsupported record parameters")
    if record.maxCorrectable != 8:
        return Err[bool]("v3 bio: unsupported record parameters")
    if !fixed256.p256PublicKey65Valid(record.pubKey):
        return Err[bool]("v3 bio: invalid enrollment public key")
    let wantCid = v3BioRecordCid(record)
    if !layout.fixedBytes32Equal(wantCid, record.recordCid):
        return Err[bool]("v3 bio: record cid mismatch")
    return Ok[bool](true)

fn v3BioRecoverCodeword(feature32: layout.FixedBytes32,
                        helper: layout.FixedBytes32): Result[layout.FixedBytes32] =
    let masked = v3BioXorFixed32(feature32, helper)
    let messageRes = rs.v3BioRsDecode32x16(masked)
    if IsErr(messageRes):
        return Err[layout.FixedBytes32](Error(messageRes))
    return Ok[layout.FixedBytes32](rs.v3BioRsEncode16x32(Value(messageRes)))

fn v3BioRecoverRoot(feature32: layout.FixedBytes32,
                    helper: layout.FixedBytes32): Result[layout.FixedBytes32] =
    let codewordRes = v3BioRecoverCodeword(feature32, helper)
    if IsErr(codewordRes):
        return Err[layout.FixedBytes32](Error(codewordRes))
    return Ok[layout.FixedBytes32](v3BioRootSecretFromCodeword(Value(codewordRes)))

fn v3BioPointFixedFromPublicKey(pubKey: layout.FixedBytes65): Result[ecnist.EcPointFixed] =
    if !fixed256.p256PublicKey65Valid(pubKey):
        return Err[ecnist.EcPointFixed]("v3 bio: invalid point bytes")
    var point: ecnist.EcPoint
    let parseRes = ecnist.ecdsaParsePublicKeyPointBytes(layout.fixedBytes65ToBytes(pubKey), true, point)
    if IsErr(parseRes):
        return Err[ecnist.EcPointFixed](Error(parseRes))
    return ecnist.pointFixedFromBig(point)

fn v3BioFixed65FromPoint(point: ecnist.EcPointFixed): Result[layout.FixedBytes65] =
    return layout.fixedBytes65FromBytes(ecnist.ecdsaPublicPointFixedToBytes(point))

fn v3BioPointMulFixed(scalar: pfix.P256Fixed,
                      point: ecnist.EcPointFixed): Result[ecnist.EcPointFixed] =
    let initRes = v3BioEnsureP256()
    if IsErr(initRes):
        return Err[ecnist.EcPointFixed](Error(initRes))
    if point.inf:
        return Ok[ecnist.EcPointFixed](point)
    var workScalar: pfix.P256Fixed = scalar
    var result: ecnist.EcPointJacobianFixed = ecnist.pointJacobianInfinityFixed()
    var bit: int32 = 255
    while bit >= 0:
        ecnist.pointJacobianDoubleFixedInPlace(result)
        if pfix.p256FixedGetBit(workScalar, bit) != 0:
            ecnist.pointJacobianAddAffineFixedInPlace(result, point)
        bit = bit - 1
    return ecnist.pointJacobianToAffineFixed(result)

fn v3BioSchnorrProve(secret: fixed256.Scalar256,
                     recordCid: layout.FixedBytes32,
                     challengeNonce: layout.FixedBytes32): Result[V3BioSchnorrProof] =
    let initRes = v3BioEnsureP256()
    if IsErr(initRes):
        return Err[V3BioSchnorrProof](Error(initRes))
    let pubKeyRes = v3BioPublicKeyFromScalar(secret)
    if IsErr(pubKeyRes):
        return Err[V3BioSchnorrProof](Error(pubKeyRes))
    let pubKey = Value(pubKeyRes)
    let nonceScalarRes = v3BioNonceScalar(secret, challengeNonce)
    if IsErr(nonceScalarRes):
        return Err[V3BioSchnorrProof](Error(nonceScalarRes))
    let nonceScalar = Value(nonceScalarRes)
    let commitARes = v3BioPublicKeyFromScalar(nonceScalar)
    if IsErr(commitARes):
        return Err[V3BioSchnorrProof](Error(commitARes))
    let commitA = Value(commitARes)
    let challengeScalarRes = v3BioChallengeScalar(recordCid, challengeNonce, commitA, pubKey)
    if IsErr(challengeScalarRes):
        return Err[V3BioSchnorrProof](Error(challengeScalarRes))
    let challengeScalar = Value(challengeScalarRes)
    let exRes = v3BioScalarModMul(challengeScalar, secret)
    if IsErr(exRes):
        return Err[V3BioSchnorrProof](Error(exRes))
    let zRes = v3BioScalarModAdd(nonceScalar, Value(exRes))
    if IsErr(zRes):
        return Err[V3BioSchnorrProof](Error(zRes))
    var out = v3BioSchnorrProofZero()
    out.commitA = commitA
    out.responseZ = Value(zRes).bytes
    return Ok[V3BioSchnorrProof](out)

fn v3BioSchnorrVerify(pubKey: layout.FixedBytes65,
                      recordCid: layout.FixedBytes32,
                      challengeNonce: layout.FixedBytes32,
                      proof: V3BioSchnorrProof): Result[bool] =
    if !fixed256.p256PublicKey65Valid(pubKey):
        return Err[bool]("v3 bio: invalid verification public key")
    if !fixed256.p256PublicKey65Valid(proof.commitA):
        return Err[bool]("v3 bio: invalid commitment point")
    let zScalarRes = v3BioScalarFromFixed32(proof.responseZ)
    if IsErr(zScalarRes):
        return Err[bool](Error(zScalarRes))
    let challengeScalarRes = v3BioChallengeScalar(recordCid, challengeNonce, proof.commitA, pubKey)
    if IsErr(challengeScalarRes):
        return Err[bool](Error(challengeScalarRes))
    let zFixed: pfix.P256Fixed = v3BioScalarFixedFromScalar(Value(zScalarRes))
    let zPointRes = ecnist.pointMulGeneratorWnafFixed(zFixed)
    if IsErr(zPointRes):
        return Err[bool](Error(zPointRes))
    let pubPointRes = v3BioPointFixedFromPublicKey(pubKey)
    if IsErr(pubPointRes):
        return Err[bool](Error(pubPointRes))
    let commitPointRes = v3BioPointFixedFromPublicKey(proof.commitA)
    if IsErr(commitPointRes):
        return Err[bool](Error(commitPointRes))
    let challengeFixed: pfix.P256Fixed = v3BioScalarFixedFromScalar(Value(challengeScalarRes))
    let mulRes = v3BioPointMulFixed(challengeFixed, Value(pubPointRes))
    if IsErr(mulRes):
        return Err[bool](Error(mulRes))
    var rhsJac = ecnist.pointJacobianFromAffineFixed(Value(commitPointRes))
    rhsJac = ecnist.pointJacobianAddAffineFixed(rhsJac, Value(mulRes))
    let rhsPointRes = ecnist.pointJacobianToAffineFixed(rhsJac)
    if IsErr(rhsPointRes):
        return Err[bool](Error(rhsPointRes))
    let zPubKeyRes = v3BioFixed65FromPoint(Value(zPointRes))
    if IsErr(zPubKeyRes):
        return Err[bool](Error(zPubKeyRes))
    let rhsPubKeyRes = v3BioFixed65FromPoint(Value(rhsPointRes))
    if IsErr(rhsPubKeyRes):
        return Err[bool](Error(rhsPubKeyRes))
    return Ok[bool](layout.fixedBytes65Equal(Value(zPubKeyRes), Value(rhsPubKeyRes)))

fn v3BioEnroll(feature32: layout.FixedBytes32): Result[V3BioEnrollmentRecord] =
    let messageRes = v3BioRandomMessage16()
    if IsErr(messageRes):
        return Err[V3BioEnrollmentRecord](Error(messageRes))
    let codeword = rs.v3BioRsEncode16x32(Value(messageRes))
    let rootSecret = v3BioRootSecretFromCodeword(codeword)
    let scalarRes = v3BioScalarFromRootSecret(rootSecret)
    if IsErr(scalarRes):
        return Err[V3BioEnrollmentRecord](Error(scalarRes))
    let pubKeyRes = v3BioPublicKeyFromScalar(Value(scalarRes))
    if IsErr(pubKeyRes):
        return Err[V3BioEnrollmentRecord](Error(pubKeyRes))
    var out = v3BioEnrollmentRecordZero()
    out.helper = v3BioXorFixed32(feature32, codeword)
    out.pubKey = Value(pubKeyRes)
    out.recordCid = v3BioRecordCid(out)
    return Ok[V3BioEnrollmentRecord](out)

fn v3BioProve(feature32: layout.FixedBytes32,
              record: V3BioEnrollmentRecord,
              challengeNonce: layout.FixedBytes32): Result[V3BioAssertion] =
    let recordOk = v3BioValidateRecord(record)
    if IsErr(recordOk):
        return Err[V3BioAssertion](Error(recordOk))
    let rootRes = v3BioRecoverRoot(feature32, record.helper)
    if IsErr(rootRes):
        return Err[V3BioAssertion](Error(rootRes))
    let scalarRes = v3BioScalarFromRootSecret(Value(rootRes))
    if IsErr(scalarRes):
        return Err[V3BioAssertion](Error(scalarRes))
    let pubKeyRes = v3BioPublicKeyFromScalar(Value(scalarRes))
    if IsErr(pubKeyRes):
        return Err[V3BioAssertion](Error(pubKeyRes))
    if !layout.fixedBytes65Equal(Value(pubKeyRes), record.pubKey):
        return Err[V3BioAssertion]("v3 bio: recovered root does not match record")
    let proofRes = v3BioSchnorrProve(Value(scalarRes), record.recordCid, challengeNonce)
    if IsErr(proofRes):
        return Err[V3BioAssertion](Error(proofRes))
    let proof = Value(proofRes)
    var out = v3BioAssertionZero()
    out.recordCid = record.recordCid
    out.challengeNonce = challengeNonce
    out.commitA = proof.commitA
    out.responseZ = proof.responseZ
    out.proofCid = v3BioAssertionCid(out.recordCid, out.challengeNonce, out.commitA, out.responseZ)
    return Ok[V3BioAssertion](out)

fn v3BioVerify(record: V3BioEnrollmentRecord,
               challengeNonce: layout.FixedBytes32,
               assertion: V3BioAssertion): Result[bool] =
    let recordOk = v3BioValidateRecord(record)
    if IsErr(recordOk):
        return Err[bool](Error(recordOk))
    if !layout.fixedBytes32Equal(assertion.recordCid, record.recordCid):
        return Err[bool]("v3 bio: assertion record cid mismatch")
    if !layout.fixedBytes32Equal(assertion.challengeNonce, challengeNonce):
        return Err[bool]("v3 bio: assertion challenge mismatch")
    let wantProofCid = v3BioAssertionCid(assertion.recordCid,
                                         assertion.challengeNonce,
                                         assertion.commitA,
                                         assertion.responseZ)
    if !layout.fixedBytes32Equal(wantProofCid, assertion.proofCid):
        return Err[bool]("v3 bio: assertion proof cid mismatch")
    var proof = v3BioSchnorrProofZero()
    proof.commitA = assertion.commitA
    proof.responseZ = assertion.responseZ
    return v3BioSchnorrVerify(record.pubKey, record.recordCid, challengeNonce, proof)
