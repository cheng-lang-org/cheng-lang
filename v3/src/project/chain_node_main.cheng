fn v3ChainNodeServeOnceCommand(): int32 =
    var statePath = ""
    let statePathRes = v3ChainNodeReadRequiredStatePath(statePath)
    if IsErr(statePathRes):
        os.writeLine(os.get_stderr(), Error(statePathRes))
        return 2
    let loadRes = v3ChainNodeLoadState(statePath)
    if IsErr(loadRes):
        os.writeLine(os.get_stderr(), Error(loadRes))
        return 2
    var state = Value(loadRes)
    let host = cmdline.readFlagOrDefault("--host", "127.0.0.1")
    let port = cmdline.readInt32FlagOrDefault("--port", 0)
    let readyPath = cmdline.readFlagOrDefault("--ready-path", "")
    let snapshot = node.v3ChainNodeServeOnce(state)
    if !v3ChainNodeWriteSnapshotState(statePath, snapshot):
        os.writeLine(os.get_stderr(), "v3 chain_node: failed to persist state: " + statePath)
        return 2
    let payload = net.v3ChainNodeLibp2pEncodeSnapshot(snapshot)
    let serveRes = tcp_transport.v3Libp2pTcpServePayloadOnce(host,
                                                             port,
                                                             types.v3Libp2pProtocolSync,
                                                             payload,
                                                             readyPath)
    if IsErr(serveRes):
        os.writeLine(os.get_stderr(), Error(serveRes))
        return 2
    os.writeLine(os.get_stdout(), v3ChainNodeSnapshotReport(snapshot))
    return 0

fn v3ChainNodeSyncOnceCommand(): int32 =
    var statePath = ""
    let statePathRes = v3ChainNodeReadRequiredStatePath(statePath)
    if IsErr(statePathRes):
        os.writeLine(os.get_stderr(), Error(statePathRes))
        return 2
    let loadRes = v3ChainNodeLoadOrInitForSync(statePath)
    if IsErr(loadRes):
        os.writeLine(os.get_stderr(), Error(loadRes))
        return 2
    var state = Value(loadRes)
    let host = cmdline.readFlagOrDefault("--host", "127.0.0.1")
    let port = cmdline.readInt32FlagOrDefault("--port", -1)
    if port <= 0:
        os.writeLine(os.get_stderr(), "v3 chain_node: sync-once requires --port")
        return 2
    let payloadRes = tcp_transport.v3Libp2pTcpRecvPayloadOnce(host,
                                                              port,
                                                              types.v3Libp2pProtocolSync)
    if IsErr(payloadRes):
        os.writeLine(os.get_stderr(), Error(payloadRes))
        return 2
    var snapshot: node.V3ChainNodeServeSnapshot
    let snapshotRes = net.v3ChainNodeLibp2pDecodeSnapshotInto(Value(payloadRes), snapshot)
    if IsErr(snapshotRes):
        os.writeLine(os.get_stderr(), Error(snapshotRes))
        return 2
    let syncRes = node.v3ChainNodeSyncOnce(state, snapshot)
    if IsErr(syncRes):
        os.writeLine(os.get_stderr(), Error(syncRes))
        return 2
    let snapshot = node.v3ChainNodeServeOnce(state)
    if !v3ChainNodeWriteSnapshotState(statePath, snapshot):
        os.writeLine(os.get_stderr(), "v3 chain_node: failed to persist state: " + statePath)
        return 2
    os.writeLine(os.get_stdout(), "changed=" + intToStr(Value(syncRes) ? 1 : 0))
    os.writeLine(os.get_stdout(), v3ChainNodeSnapshotReport(snapshot))
    return 0

fn v3ChainNodeDaemonServeCommand(): int32 =
    let intervalMs = cmdline.readInt32FlagOrDefault("--interval-ms", 0)
    let maxServeCount = cmdline.readInt32FlagOrDefault("--max-serve-count", 0)
    var served = 0
    while maxServeCount <= 0 || served < maxServeCount:
        let rc = v3ChainNodeServeOnceCommand()
        if rc != 0:
            return rc
        served = served + 1
        if intervalMs > 0 && (maxServeCount <= 0 || served < maxServeCount):
            v3ChainNodeSleepMs(intervalMs)
    return 0

fn v3ChainNodeDaemonSyncCommand(): int32 =
    let intervalMs = cmdline.readInt32FlagOrDefault("--interval-ms", 1000)
    let maxSyncCount = cmdline.readInt32FlagOrDefault("--max-sync-count", 0)
    var synced = 0
    while maxSyncCount <= 0 || synced < maxSyncCount:
        let rc = v3ChainNodeSyncOnceCommand()
        if rc != 0:
            return rc
        synced = synced + 1
        if intervalMs > 0 && (maxSyncCount <= 0 || synced < maxSyncCount):
            v3ChainNodeSleepMs(intervalMs)
    return 0

fn main(argc: int32, argv: ptr): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let count = cmdline.paramCount()
    if count <= 0:
        v3ChainNodeUsage()
        return 0
    let cmd = cmdline.paramStr(1)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        v3ChainNodeUsage()
        return 0
    if cmd == "self-test":
        return v3ChainNodeMainSelfTest()
    if cmd == "init":
        return v3ChainNodeInitCommand()
    if cmd == "mint":
        return v3ChainNodeMintCommand()
    if cmd == "transfer":
        return v3ChainNodeTransferCommand()
    if cmd == "balance":
        return v3ChainNodeBalanceCommand()
    if cmd == "bio-did-operator-lookup":
        return v3ChainNodeBioDidOperatorLookupCommand()
    if cmd == "show-state":
        return v3ChainNodeShowStateCommand()
    if cmd == "dump-snapshot":
        return v3ChainNodeDumpSnapshotCommand()
    if cmd == "serve-once":
        return v3ChainNodeServeOnceCommand()
    if cmd == "sync-once":
        return v3ChainNodeSyncOnceCommand()
    if cmd == "daemon-serve":
        return v3ChainNodeDaemonServeCommand()
    if cmd == "daemon-sync":
        return v3ChainNodeDaemonSyncCommand()
    os.writeLine(os.get_stderr(), "v3 chain_node: unknown command: " + cmd)
    v3ChainNodeUsage()
    return 2
