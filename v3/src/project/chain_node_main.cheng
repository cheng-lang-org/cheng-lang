import std/cmdline as cmdline
import std/result
import cheng/v3/project/chain_node_cli_core as cli
import cheng/v3/project/chain_node_cli_init_main as cli_init
import cheng/v3/project/chain_node_cli_mint_main as cli_mint
import cheng/v3/project/chain_node_cli_transfer_main as cli_transfer
import cheng/v3/project/chain_node_cli_balance_main as cli_balance
import cheng/v3/project/chain_node_cli_show_state_main as cli_show
import cheng/v3/project/chain_node_cli_dump_snapshot_main as cli_snapshot
import cheng/v3/project/chain_node_cli_serve_once_main as cli_serve
import cheng/v3/project/chain_node_cli_sync_once_main as cli_sync
import cheng/v3/project/chain_node_cli_self_test_main as cli_self_test
import cheng/v3/project/chain_node_cli_bio_did_operator_lookup_main as cli_bio_did

fn v3ChainNodeUsageText(): str =
    return "usage: chain_node <command> [flags]\n\n" +
           "commands:\n" +
           "  init --state:<file> --node-id:<id> --address-seed:<seed>\n" +
           "  mint --state:<file> --asset:<id> --account:<id> --amount:<n>\n" +
           "  transfer --state:<file> --asset:<id> --from:<id> --to:<id> --amount:<n>\n" +
           "  balance --state:<file> --asset:<id> --account:<id>\n" +
           "  show-state --state:<file>\n" +
           "  dump-snapshot --state:<file>\n" +
           "  daemon-serve --state:<file> [--host:<ip>] [--port:<n>] [--ready-path:<file>]\n" +
           "  daemon-sync --state:<file> --node-id:<id> --address-seed:<seed> --host:<ip> --port:<n>\n" +
           "  self-test\n" +
           "  bio-did-operator-lookup --state:<file> --operator-id:<hex32> [--preferred-kinds:<kindA,kindB>]"

fn V3ChainNodeBioDidOperatorLookupText(statePath: str,
                                       operatorIdHex: str,
                                       preferredKindsText: str): Result[str] =
    var preferredKinds: str[]
    preferredKinds = []
    cli.V3ChainNodeCliAppendCsvKinds(preferredKinds, preferredKindsText)
    return cli.V3ChainNodeCliBioDidOperatorLookupJsonWithKinds(statePath,
                                                               operatorIdHex,
                                                               preferredKinds)

fn v3ChainNodePrintUsageAndReturn(code: int32): int32 =
    let usageText: str = v3ChainNodeUsageText()
    cli.V3ChainNodeCliPrintBlock(usageText)
    return code

fn v3ChainNodeDispatch(cmd: str): int32 =
    if cmd == "self-test":
        return cli_self_test.V3ChainNodeCliSelfTestCommand()
    if cmd == "init":
        return cli_init.V3ChainNodeCliInitCommand()
    if cmd == "mint":
        return cli_mint.V3ChainNodeCliMintCommand()
    if cmd == "transfer":
        return cli_transfer.V3ChainNodeCliTransferCommand()
    if cmd == "balance":
        return cli_balance.V3ChainNodeCliBalanceCommand()
    if cmd == "show-state":
        return cli_show.V3ChainNodeCliShowStateCommand()
    if cmd == "dump-snapshot":
        return cli_snapshot.V3ChainNodeCliDumpSnapshotCommand()
    if cmd == "daemon-serve" || cmd == "serve-once":
        return cli_serve.V3ChainNodeCliServeOnceCommand()
    if cmd == "daemon-sync" || cmd == "sync-once":
        return cli_sync.V3ChainNodeCliSyncOnceCommand()
    if cmd == "bio-did-operator-lookup":
        return cli_bio_did.V3ChainNodeCliBioDidOperatorLookupCommand()
    return v3ChainNodePrintUsageAndReturn(2)

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let count = cmdline.ParamCount()
    if count <= 0:
        return v3ChainNodePrintUsageAndReturn(0)
    let cmd = cmdline.ParamStr(1)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        return v3ChainNodePrintUsageAndReturn(0)
    return v3ChainNodeDispatch(cmd)
