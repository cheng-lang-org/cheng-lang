@importc("cheng_v3_sleep_ms_bridge")
fn cheng_v3_sleep_ms_bridge(value: int32)

fn v3BftMainCurrentDir(): str =
    return os.GetCurrentDir()

fn v3BftMainReadTextFile(pathRaw: str): str =
    let cwd = v3BftMainCurrentDir()
    return v3path.V3ReadTextFile(cwd, pathRaw)

fn v3BftMainWriteTextFile(pathRaw: str, text: str): bool =
    let cwd = v3BftMainCurrentDir()
    return v3path.V3WriteTextFile(cwd, pathRaw, text)

fn v3BftMainFileExistsNonEmpty(pathRaw: str): bool =
    let cwd = v3BftMainCurrentDir()
    return v3path.V3FileExistsNonEmpty(cwd, pathRaw)

fn v3BftMainAbsolutePath(pathRaw: str): str =
    let cwd = v3BftMainCurrentDir()
    return v3path.V3PathAbsolute(cwd, pathRaw)

fn v3BftMainPrintErr(text: str) =
    let stderr = os.Get_stderr()
    os.WriteLine(stderr, text)

fn v3BftMainPrintOut(text: str) =
    let stdout = os.Get_stdout()
    os.WriteLine(stdout, text)

fn v3BftMainUsage() =
    v3BftMainPrintOut("usage: bft_state_machine <command> [flags]")
    v3BftMainPrintOut("")
    v3BftMainPrintOut("commands:")
    v3BftMainPrintOut("  self-test")
    v3BftMainPrintOut("  init --state:<file> --app-id:<id> --validator-slot:<n> [--force]")
    v3BftMainPrintOut("  submit-mint --queue:<file> --asset:<id> --account:<id> --amount:<n>")
    v3BftMainPrintOut("  submit-transfer --queue:<file> --asset:<id> --from:<id> --to:<id> --amount:<n>")
    v3BftMainPrintOut("  submit-transfer-series --queue:<file> --asset:<id> --from:<id> --to:<id> --amount:<n> --count:<n>")
    v3BftMainPrintOut("  show-state --state:<file>")
    v3BftMainPrintOut("  query-balance --state:<file> --asset:<id> --account:<id>")
    v3BftMainPrintOut("  query-summary --state:<file> --asset:<id> --account-a:<id> --account-b:<id>")
    v3BftMainPrintOut("  curve25519-probe")
    v3BftMainPrintOut("  curve25519-sweep [--count:<n>]")
    v3BftMainPrintOut("  curve25519-generated-sweep [--count:<n>]")
    v3BftMainPrintOut("  curve25519-shared --priv-hex:<64hex> --pub-hex:<64hex>")
    v3BftMainPrintOut("  tls13-finished-probe")
    v3BftMainPrintOut("  tls13-packet-flight-probe")
    v3BftMainPrintOut("  tls13-derive-probe --shared-hex:<64hex> --thash-hex:<64hex> [--cipher-id:<id>]")
    v3BftMainPrintOut("  probe-proposal --host:<ip> --port:<n> [--attempts:<n>] [--interval-ms:<n>] [--handshake-only] [--debug-tls13]")
    v3BftMainPrintOut("  proposal-serve-daemon --file:<file> --host:<ip> --port:<n> [--ready-path:<file>] [--interval-ms:<n>] [--max-serve-count:<n>] [--debug-tls13]")
    v3BftMainPrintOut("  commit-serve-daemon --file:<file> --host:<ip> --port:<n> [--ready-path:<file>] [--interval-ms:<n>] [--max-serve-count:<n>]")
    v3BftMainPrintOut("  state-serve-daemon --file:<file> --host:<ip> --port:<n> [--snapshot-dir:<dir>] [--ready-path:<file>] [--interval-ms:<n>] [--max-serve-count:<n>]")
    v3BftMainPrintOut("  vote-capture-daemon --file:<file> --host:<ip> --port:<n> [--ready-path:<file>] [--interval-ms:<n>] [--max-vote-count:<n>]")
    v3BftMainPrintOut("  validator-proposer-daemon --state:<file> --queue:<file> --proposal-host:<ip> --proposal-port:<n> --vote-host:<ip> --vote-port:<n> --commit-host:<ip> --commit-port:<n> [--vote-lock:<file>] [--queue-cursor:<file>] [--proposal-file:<file>] [--commit-file:<file>] [--state-sync-file:<file>] [--state-sync-dir:<dir>] [--proposal-ready-path:<file>] [--vote-ready-path:<file>] [--commit-ready-path:<file>] [--interval-ms:<n>] [--proposal-window-ms:<n>] [--vote-window-ms:<n>] [--commit-window-ms:<n>] [--max-rounds:<n>] [--max-txs:<n>]")
    v3BftMainPrintOut("  validator-follower-daemon --state:<file> --proposal-host:<ip> --proposal-port:<n> --vote-host:<ip> --vote-port:<n> --commit-host:<ip> --commit-port:<n> [--sync-host:<ip>] [--sync-port:<n>] [--vote-lock:<file>] [--interval-ms:<n>] [--max-rounds:<n>]")

fn v3BftMainTextStartsWith(text: str, prefix: str): bool =
    if len(prefix) > len(text):
        return false
    for i in 0..<len(prefix):
        if text[i] != prefix[i]:
            return false
    return true

fn v3BftMainReadFlagValue(flag: str, outValue: var str): bool =
    outValue = ""
    let count = cmdline.ParamCount()
    let colonPrefix = flag + ":"
    let eqPrefix = flag + "="
    for i in 1..count:
        let arg = cmdline.ParamStr(i)
        if arg == flag:
            if i >= count:
                return false
            outValue = cmdline.ParamStr(i + 1)
            return true
        if v3BftMainTextStartsWith(arg, colonPrefix):
            outValue = v3path.V3TextSlice(arg, len(colonPrefix), len(arg) - len(colonPrefix))
            return true
        if v3BftMainTextStartsWith(arg, eqPrefix):
            outValue = v3path.V3TextSlice(arg, len(eqPrefix), len(arg) - len(eqPrefix))
            return true
    return false

fn v3BftMainReadRequiredFlag(flag: str, outValue: var str): Result[bool] =
    outValue = ""
    if !v3BftMainReadFlagValue(flag, outValue):
        return Err[bool]("v3 bft main: missing " + flag)
    outValue = strutil.Strip(outValue)
    if len(outValue) <= 0:
        return Err[bool]("v3 bft main: empty " + flag)
    return Ok[bool](true)

fn v3BftMainReadRequiredStatePath(outValue: var str): Result[bool] =
    return v3BftMainReadRequiredFlag("--state", outValue)

fn v3BftMainReadRequiredQueuePath(outValue: var str): Result[bool] =
    return v3BftMainReadRequiredFlag("--queue", outValue)

fn v3BftMainReadRequiredInt64Flag(flag: str): Result[int64] =
    var raw = ""
    let readRes = v3BftMainReadRequiredFlag(flag, raw)
    if IsErr(readRes):
        return Err[int64](Error(readRes))
    return host.v3BftValidatorParseInt64Text(raw)

fn v3BftMainReadServePort(flag: str): Result[int32] =
    let port = cmdline.ReadInt32FlagOrDefault(flag, -1)
    if port < 0 || port > 65535:
        return Err[int32]("v3 bft main: invalid " + flag)
    return Ok[int32](port)

fn v3BftMainResolveReadyPortForSecondPhase(requestedPort: int32,
                                           readyPath: str): Result[int32] =
    if requestedPort > 0:
        return Ok[int32](requestedPort)
    if requestedPort == 0:
        if len(readyPath) <= 0:
            return Err[int32]("v3 bft main: state-serve-daemon requires --ready-path when --port:0")
        let portTextRaw = v3BftMainReadTextFile(readyPath)
        let portText = strutil.Strip(portTextRaw)
        let parseRes = host.v3BftValidatorParseInt64Text(portText)
        if IsErr(parseRes):
            return Err[int32]("v3 bft main: invalid ready port")
        if Value(parseRes) <= int64(0) || Value(parseRes) > int64(65535):
            return Err[int32]("v3 bft main: invalid ready port")
        return Ok[int32](int32(Value(parseRes)))
    return Err[int32]("v3 bft main: invalid --port")

fn v3BftMainSleepMs(value: int32) =
    if value <= 0:
        return
    cheng_v3_sleep_ms_bridge(value)

fn v3BftMainFollowerVoteRetryLimit(): int32 =
    return 4

fn v3BftMainFollowerRetryableRecvError(err: str): bool =
    return v3BftMainTextStartsWith(err, "v3 libp2p quic: dial") ||
           v3BftMainTextStartsWith(err, "v3 libp2p quic: unexpected eof") ||
           v3BftMainTextStartsWith(err, "msquic: pipe closed") ||
           v3BftMainTextStartsWith(err, "msquic native: pipe read timeout") ||
           v3BftMainTextStartsWith(err, "msquic native: handshake ! ready") ||
           v3BftMainTextStartsWith(err, "msquic native: session ! ready")

fn v3BftMainFollowerRetryableLatestSyncError(err: str): bool =
    return v3BftMainFollowerRetryableRecvError(err) ||
           err == "v3 bft validator: missing state snapshot" ||
           err == "v3 bft validator: state sync ack unavailable" ||
           err == "v3 bft validator: state sync payload unavailable"

fn v3BftMainSelfTest(): int32 =
    let appId = "bft-validator-self-test"
    let init1Res = host.v3BftValidatorStateInit(appId, 1)
    let init2Res = host.v3BftValidatorStateInit(appId, 2)
    let init3Res = host.v3BftValidatorStateInit(appId, 3)
    if IsErr(init1Res):
        panic("v3 bft main: init1 " + Error(init1Res))
    if IsErr(init2Res):
        panic("v3 bft main: init2 " + Error(init2Res))
    if IsErr(init3Res):
        panic("v3 bft main: init3 " + Error(init3Res))
    var state1 = Value(init1Res)
    var state2 = Value(init2Res)
    var state3 = Value(init3Res)

    let mintWire = bft.v3BftEncodeTx(bft.v3BftTxMint(7, 1001, int64(100)))
    var batch1: Bytes[]
    batch1 = []
    add(batch1, mintWire)
    let proposal1Res = host.v3BftValidatorProposalFromTxs(appId, int64(1), 1, batch1)
    if IsErr(proposal1Res):
        panic("v3 bft main: proposal1 " + Error(proposal1Res))
    let preview1Res = host.v3BftValidatorPreviewProposal(state1, Value(proposal1Res))
    let preview2Res = host.v3BftValidatorPreviewProposal(state2, Value(proposal1Res))
    if IsErr(preview1Res):
        panic("v3 bft main: preview1 " + Error(preview1Res))
    if IsErr(preview2Res):
        panic("v3 bft main: preview2 " + Error(preview2Res))
    assert(layout.fixedBytes32Equal(Value(preview1Res).proposalHash, Value(preview2Res).proposalHash), "v3 bft main: preview proposal hash")
    assert(layout.fixedBytes32Equal(Value(preview1Res).appHash, Value(preview2Res).appHash), "v3 bft main: preview app hash")
    let selfVote1Res = host.v3BftValidatorBuildVote(state1, Value(proposal1Res))
    let vote2Res = host.v3BftValidatorBuildVote(state2, Value(proposal1Res))
    if IsErr(selfVote1Res):
        panic("v3 bft main: self vote1 " + Error(selfVote1Res))
    if IsErr(vote2Res):
        panic("v3 bft main: vote2 " + Error(vote2Res))
    var votes1: host.V3BftVote[]
    votes1 = []
    add(votes1, Value(selfVote1Res))
    add(votes1, Value(vote2Res))
    let commit1Res = host.v3BftValidatorCommitFromVotes(Value(proposal1Res), Value(preview1Res), votes1)
    if IsErr(commit1Res):
        panic("v3 bft main: commit1 " + Error(commit1Res))
    let apply1Res = host.v3BftValidatorStateApplyCommit(state1, Value(commit1Res))
    let apply2Res = host.v3BftValidatorStateApplyCommit(state2, Value(commit1Res))
    if IsErr(apply1Res):
        panic("v3 bft main: apply commit1 state1 " + Error(apply1Res))
    if IsErr(apply2Res):
        panic("v3 bft main: apply commit1 state2 " + Error(apply2Res))

    let alice1 = host.v3BftValidatorQueryBalance(state1, 7, 1001)
    let alice2 = host.v3BftValidatorQueryBalance(state2, 7, 1001)
    let alice3 = host.v3BftValidatorQueryBalance(state3, 7, 1001)
    assert(alice1.balance == int64(100), "v3 bft main: alice1")
    assert(alice2.balance == alice1.balance, "v3 bft main: alice2")
    assert(alice3.balance == int64(0), "v3 bft main: alice3")
    let statePath = "artifacts/v3_bft_state_machine/self_test_state.txt"
    let _ = os.RemoveFile(statePath)
    if !host.v3BftValidatorWriteState(statePath, state1):
        panic("v3 bft main: write state")
    let reloadRes = host.v3BftValidatorLoadState(statePath)
    if IsErr(reloadRes):
        panic("v3 bft main: reload state " + Error(reloadRes))
    let reloaded = Value(reloadRes)
    let aliceReloaded = host.v3BftValidatorQueryBalance(reloaded, 7, 1001)
    if aliceReloaded.balance != int64(100):
        panic("v3 bft main: reload alice balance")
    let bobReloaded = host.v3BftValidatorQueryBalance(reloaded, 7, 2002)
    if bobReloaded.balance != int64(0):
        panic("v3 bft main: reload bob balance")
    let _ = os.RemoveFile(statePath)
    echo("v3 bft_state_machine self-test ok")
    return 0

fn v3BftMainInitCommand(): int32 =
    var statePath = ""
    let stateRes = v3BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        v3BftMainPrintErr(Error(stateRes))
        return 2
    let absoluteStatePath = v3BftMainAbsolutePath(statePath)
    if v3path.V3PathFileExists(absoluteStatePath) && !cmdline.HasFlag("--force"):
        v3BftMainPrintErr("v3 bft main: state already exists: " + absoluteStatePath + " (pass --force to overwrite)")
        return 2
    var appId = ""
    let appIdRes = v3BftMainReadRequiredFlag("--app-id", appId)
    if IsErr(appIdRes):
        v3BftMainPrintErr(Error(appIdRes))
        return 2
    let validatorSlot = cmdline.ReadInt32FlagOrDefault("--validator-slot", 0)
    let initRes = host.v3BftValidatorStateInit(appId, validatorSlot)
    if IsErr(initRes):
        v3BftMainPrintErr(Error(initRes))
        return 2
    if !host.v3BftValidatorWriteState(statePath, Value(initRes)):
        v3BftMainPrintErr("v3 bft main: failed to write state: " + absoluteStatePath)
        return 2
    v3BftMainPrintOut(host.v3BftValidatorStateSummary(Value(initRes)))
    return 0

fn v3BftMainSubmitMintCommand(): int32 =
    var queuePath = ""
    let queueRes = v3BftMainReadRequiredQueuePath(queuePath)
    if IsErr(queueRes):
        v3BftMainPrintErr(Error(queueRes))
        return 2
    let assetId = cmdline.ReadInt32FlagOrDefault("--asset", -1)
    let accountId = cmdline.ReadInt32FlagOrDefault("--account", -1)
    let amountRes = v3BftMainReadRequiredInt64Flag("--amount")
    if assetId <= 0 || accountId <= 0 || IsErr(amountRes):
        if IsErr(amountRes):
            v3BftMainPrintErr(Error(amountRes))
        else:
            v3BftMainPrintErr("v3 bft main: submit-mint requires --asset --account --amount")
        return 2
    let txWire = bft.v3BftEncodeTx(bft.v3BftTxMint(assetId, accountId, Value(amountRes)))
    if !host.v3BftValidatorQueueAppend(queuePath, txWire):
        v3BftMainPrintErr("v3 bft main: failed to append queue")
        return 2
    v3BftMainPrintOut("queued_tx=" + bytesToHex(txWire))
    return 0

fn v3BftMainSubmitTransferCommand(): int32 =
    var queuePath = ""
    let queueRes = v3BftMainReadRequiredQueuePath(queuePath)
    if IsErr(queueRes):
        v3BftMainPrintErr(Error(queueRes))
        return 2
    let assetId = cmdline.ReadInt32FlagOrDefault("--asset", -1)
    let fromAccount = cmdline.ReadInt32FlagOrDefault("--from", -1)
    let toAccount = cmdline.ReadInt32FlagOrDefault("--to", -1)
    let amountRes = v3BftMainReadRequiredInt64Flag("--amount")
    if assetId <= 0 || fromAccount <= 0 || toAccount <= 0 || IsErr(amountRes):
        if IsErr(amountRes):
            v3BftMainPrintErr(Error(amountRes))
        else:
            v3BftMainPrintErr("v3 bft main: submit-transfer requires --asset --from --to --amount")
        return 2
    let txWire = bft.v3BftEncodeTx(bft.v3BftTxTransfer(assetId, fromAccount, toAccount, Value(amountRes)))
    if !host.v3BftValidatorQueueAppend(queuePath, txWire):
        v3BftMainPrintErr("v3 bft main: failed to append queue")
        return 2
    v3BftMainPrintOut("queued_tx=" + bytesToHex(txWire))
    return 0

fn v3BftMainSubmitTransferSeriesCommand(): int32 =
    var queuePath = ""
    let queueRes = v3BftMainReadRequiredQueuePath(queuePath)
    if IsErr(queueRes):
        v3BftMainPrintErr(Error(queueRes))
        return 2
    let assetId = cmdline.ReadInt32FlagOrDefault("--asset", -1)
    let fromAccount = cmdline.ReadInt32FlagOrDefault("--from", -1)
    let toAccount = cmdline.ReadInt32FlagOrDefault("--to", -1)
    let amountRes = v3BftMainReadRequiredInt64Flag("--amount")
    let count = cmdline.ReadInt32FlagOrDefault("--count", 0)
    if assetId <= 0 || fromAccount <= 0 || toAccount <= 0 || IsErr(amountRes) || count <= 0:
        if IsErr(amountRes):
            v3BftMainPrintErr(Error(amountRes))
        else:
            v3BftMainPrintErr("v3 bft main: submit-transfer-series requires --asset --from --to --amount --count")
        return 2
    let queueLoadRes = host.v3BftValidatorQueueLoad(queuePath)
    if IsErr(queueLoadRes):
        v3BftMainPrintErr(Error(queueLoadRes))
        return 2
    var txs = Value(queueLoadRes)
    let txWire = bft.v3BftEncodeTx(bft.v3BftTxTransfer(assetId, fromAccount, toAccount, Value(amountRes)))
    for i in 0..<count:
        i
        add(txs, txWire)
    if !host.v3BftValidatorQueueWrite(queuePath, txs):
        v3BftMainPrintErr("v3 bft main: failed to write queue")
        return 2
    let txWireBytes = int64(bytesLen(txWire))
    v3BftMainPrintOut("queued_count=" + host.v3BftValidatorInt64Text(int64(count)))
    v3BftMainPrintOut("tx_wire_bytes=" + host.v3BftValidatorInt64Text(txWireBytes))
    v3BftMainPrintOut("queued_bytes=" + host.v3BftValidatorInt64Text(txWireBytes * int64(count)))
    return 0

fn v3BftMainShowStateCommand(): int32 =
    var statePath = ""
    let stateRes = v3BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        v3BftMainPrintErr(Error(stateRes))
        return 2
    let loadRes = host.v3BftValidatorLoadState(statePath)
    if IsErr(loadRes):
        v3BftMainPrintErr(Error(loadRes))
        return 2
    v3BftMainPrintOut(host.v3BftValidatorStateSummary(Value(loadRes)))
    return 0

fn v3BftMainQueryBalanceCommand(): int32 =
    var statePath = ""
    let stateRes = v3BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        v3BftMainPrintErr(Error(stateRes))
        return 2
    let loadRes = host.v3BftValidatorLoadState(statePath)
    if IsErr(loadRes):
        v3BftMainPrintErr(Error(loadRes))
        return 2
    let assetId = cmdline.ReadInt32FlagOrDefault("--asset", -1)
    let accountId = cmdline.ReadInt32FlagOrDefault("--account", -1)
    if assetId <= 0 || accountId <= 0:
        v3BftMainPrintErr("v3 bft main: query-balance requires --asset and --account")
        return 2
    let res = host.v3BftValidatorQueryBalance(Value(loadRes), assetId, accountId)
    v3BftMainPrintOut("balance=" + host.v3BftValidatorInt64Text(res.balance))
    v3BftMainPrintOut("height=" + host.v3BftValidatorInt64Text(res.height))
    v3BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(res.appHash))
    return 0

fn v3BftMainQuerySummaryCommand(): int32 =
    var statePath = ""
    let stateRes = v3BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        v3BftMainPrintErr(Error(stateRes))
        return 2
    let loadRes = host.v3BftValidatorLoadState(statePath)
    if IsErr(loadRes):
        v3BftMainPrintErr(Error(loadRes))
        return 2
    let assetId = cmdline.ReadInt32FlagOrDefault("--asset", -1)
    let accountA = cmdline.ReadInt32FlagOrDefault("--account-a", -1)
    let accountB = cmdline.ReadInt32FlagOrDefault("--account-b", -1)
    if assetId <= 0 || accountA <= 0 || accountB <= 0:
        v3BftMainPrintErr("v3 bft main: query-summary requires --asset --account-a --account-b")
        return 2
    let state = Value(loadRes)
    let balanceA = host.v3BftValidatorQueryBalance(state, assetId, accountA)
    let balanceB = host.v3BftValidatorQueryBalance(state, assetId, accountB)
    v3BftMainPrintOut("height=" + host.v3BftValidatorInt64Text(state.machine.lastFinalizedHeight))
    v3BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(state.machine.lastCommitAppHash))
    v3BftMainPrintOut("balance_a=" + host.v3BftValidatorInt64Text(balanceA.balance))
    v3BftMainPrintOut("balance_b=" + host.v3BftValidatorInt64Text(balanceB.balance))
    return 0

fn v3BftMainProbeProposalCommand(): int32 =
    let hostText = cmdline.ReadFlagOrDefault("--host", "")
    let port = cmdline.ReadInt32FlagOrDefault("--port", -1)
    let attempts = cmdline.ReadInt32FlagOrDefault("--attempts", 256)
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 50)
    let handshakeOnlyText = cmdline.ReadFlagOrDefault("--handshake-only", "")
    let handshakeOnly = cmdline.HasFlag("--handshake-only") ||
                        (len(handshakeOnlyText) > 0 &&
                        handshakeOnlyText != "0" &&
                        handshakeOnlyText != "false" &&
                        handshakeOnlyText != "no" &&
                        handshakeOnlyText != "off")
    if len(hostText) <= 0 || port <= 0:
        v3BftMainPrintErr("v3 bft main: probe-proposal requires --host and --port")
        return 2
    var lastErr = ""
    for attempt in 0..<attempts:
        var client = qtransport.initMsQuicTransport()
        var conn: qconn.Connection
        let dialRes = quic_transport.v3Libp2pQuicDialClientNamed(client,
                                                                 conn,
                                                                 hostText,
                                                                 port,
                                                                 host.v3BftValidatorPublicTransportServerName())
        if IsErr(dialRes):
            lastErr = Error(dialRes)
        else:
            v3BftMainPrintOut("probe_stage=dial_ok")
            let selectRes = quic_transport.v3Libp2pQuicClientSelectProtocol(client,
                                                                            conn,
                                                                            host.v3BftValidatorProposalProtocol())
            if IsErr(selectRes):
                lastErr = Error(selectRes)
                qconn.connClose(conn)
            else:
                v3BftMainPrintOut("probe_stage=select_ok")
                if handshakeOnly:
                    qconn.connClose(conn)
                    return 0
                let payloadRes = quic_transport.v3Libp2pQuicReadFrame(client, conn)
                qconn.connClose(conn)
                if IsErr(payloadRes):
                    lastErr = Error(payloadRes)
                else:
                    v3BftMainPrintOut("probe_stage=read_ok")
                    let proposalRes = host.v3BftValidatorDecodeProposal(Value(payloadRes))
                    if IsErr(proposalRes):
                        lastErr = Error(proposalRes)
                    else:
                        let proposal = Value(proposalRes)
                        v3BftMainPrintOut("probe_stage=decode_ok")
                        v3BftMainPrintOut("proposal_height=" + host.v3BftValidatorInt64Text(proposal.height))
                        v3BftMainPrintOut("proposal_txs=" + intToStr(proposal.txs.len))
                        return 0
        if !v3BftMainFollowerRetryableRecvError(lastErr):
            v3BftMainPrintErr(lastErr)
            return 1
        if attempt + 1 < attempts && intervalMs > 0:
            v3BftMainSleepMs(intervalMs)
    v3BftMainPrintErr(lastErr)
    return 1

fn v3BftMainCurve25519ProbeCommand(): int32 =
    let aliceRes = fixed256.scalar256FromHex("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    let bobRes = fixed256.scalar256FromHex("5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    if IsErr(aliceRes):
        v3BftMainPrintErr(Error(aliceRes))
        return 2
    if IsErr(bobRes):
        v3BftMainPrintErr(Error(bobRes))
        return 2
    let alicePubRes = fixed256.curve25519PublicKey(Value(aliceRes))
    let bobPubRes = fixed256.curve25519PublicKey(Value(bobRes))
    if IsErr(alicePubRes):
        v3BftMainPrintErr(Error(alicePubRes))
        return 2
    if IsErr(bobPubRes):
        v3BftMainPrintErr(Error(bobPubRes))
        return 2
    let sharedRes = fixed256.curve25519SharedKeyFixed(Value(aliceRes), Value(bobPubRes))
    if IsErr(sharedRes):
        v3BftMainPrintErr(Error(sharedRes))
        return 2
    v3BftMainPrintOut("alice=" + layout.fixedBytes32Hex(Value(alicePubRes)))
    v3BftMainPrintOut("bob=" + layout.fixedBytes32Hex(Value(bobPubRes)))
    v3BftMainPrintOut("shared=" + layout.fixedBytes32Hex(Value(sharedRes)))
    return 0

fn v3BftMainCurve25519SweepCommand(): int32 =
    let count = cmdline.ReadInt32FlagOrDefault("--count", 8)
    if count <= 0:
        v3BftMainPrintErr("v3 bft main: curve25519-sweep count must be positive")
        return 2
    for i in 0..<count:
        let privA = v3BftMainTls13ProbeSeed32(101 + i)
        let privB = v3BftMainTls13ProbeSeed32(201 + i)
        let pubARes = curve25519.curve25519PublicFromPrivate(privA)
        let pubBRes = curve25519.curve25519PublicFromPrivate(privB)
        if IsErr(pubARes):
            v3BftMainPrintErr(ErrorText(pubARes))
            return 2
        if IsErr(pubBRes):
            v3BftMainPrintErr(ErrorText(pubBRes))
            return 2
        let sharedRes = curve25519.curve25519SharedKey(privA, Value(pubBRes))
        if IsErr(sharedRes):
            v3BftMainPrintErr(ErrorText(sharedRes))
            return 2
        v3BftMainPrintOut("tag=" + intToStr(i))
        v3BftMainPrintOut("pub_a=" + bytesToHex(Value(pubARes)))
        v3BftMainPrintOut("pub_b=" + bytesToHex(Value(pubBRes)))
        v3BftMainPrintOut("shared=" + bytesToHex(Value(sharedRes)))
    return 0

fn v3BftMainCurve25519GeneratedSweepCommand(): int32 =
    let count = cmdline.ReadInt32FlagOrDefault("--count", 4)
    if count <= 0:
        v3BftMainPrintErr("v3 bft main: curve25519-generated-sweep count must be positive")
        return 2
    for i in 0..<count:
        let seed = v3BftMainTls13ProbeSeed32(301 + i)
        if !rand.setRandomSeed(seed):
            v3BftMainPrintErr("v3 bft main: failed to set random seed")
            return 2
        var privA = emptyBytes()
        var pubA = emptyBytes()
        var privB = emptyBytes()
        var pubB = emptyBytes()
        let genARes = curve25519.generateCurve25519KeyPairInto(privA, pubA)
        let genBRes = curve25519.generateCurve25519KeyPairInto(privB, pubB)
        if IsErr(genARes):
            v3BftMainPrintErr(ErrorText(genARes))
            return 2
        if IsErr(genBRes):
            v3BftMainPrintErr(ErrorText(genBRes))
            return 2
        let sharedRes = curve25519.curve25519SharedKey(privA, pubB)
        if IsErr(sharedRes):
            v3BftMainPrintErr(ErrorText(sharedRes))
            return 2
        v3BftMainPrintOut("tag=" + intToStr(i))
        v3BftMainPrintOut("priv_a=" + bytesToHex(privA))
        v3BftMainPrintOut("pub_a=" + bytesToHex(pubA))
        v3BftMainPrintOut("priv_b=" + bytesToHex(privB))
        v3BftMainPrintOut("pub_b=" + bytesToHex(pubB))
        v3BftMainPrintOut("shared=" + bytesToHex(Value(sharedRes)))
    return 0

fn v3BftMainCurve25519SharedCommand(): int32 =
    var privHex = ""
    let privHexRes = v3BftMainReadRequiredFlag("--priv-hex", privHex)
    if IsErr(privHexRes):
        v3BftMainPrintErr(ErrorText(privHexRes))
        return 2
    var pubHex = ""
    let pubHexRes = v3BftMainReadRequiredFlag("--pub-hex", pubHex)
    if IsErr(pubHexRes):
        v3BftMainPrintErr(ErrorText(pubHexRes))
        return 2
    let privRes = fixed256.scalar256FromHex(privHex)
    if IsErr(privRes):
        v3BftMainPrintErr(ErrorText(privRes))
        return 2
    let pubRes = layout.fixedBytes32FromHex(pubHex)
    if IsErr(pubRes):
        v3BftMainPrintErr(ErrorText(pubRes))
        return 2
    let sharedRes = curve25519.curve25519SharedKey(fixed256.scalar256ToBytes(Value(privRes)),
                                                   layout.fixedBytes32ToBytes(Value(pubRes)))
    if IsErr(sharedRes):
        v3BftMainPrintErr(ErrorText(sharedRes))
        return 2
    v3BftMainPrintOut(bytesToHex(Value(sharedRes)))
    return 0

fn v3BftMainTls13ProbeSeed32(tag: int32): Bytes =
    let out = bytesAlloc(32)
    for i in 0..<32:
        let v = (tag * 41 + i * 17 + 29) & 255
        bytesSet(out, i, v)
    return out

fn v3BftMainTls13FinishedProbeCommand(): int32 =
    let serverName = host.v3BftValidatorPublicTransportServerName()
    let policy = test_pki.msquicMakePublicTransportTlsPolicy(serverName)
    let clientPrivRes = fixed256.scalar256FromHex("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    let serverPrivRes = fixed256.scalar256FromHex("5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    if IsErr(clientPrivRes):
        v3BftMainPrintErr(ErrorText(clientPrivRes))
        return 2
    if IsErr(serverPrivRes):
        v3BftMainPrintErr(ErrorText(serverPrivRes))
        return 2
    let clientPubRes = fixed256.curve25519PublicKey(Value(clientPrivRes))
    let serverPubRes = fixed256.curve25519PublicKey(Value(serverPrivRes))
    if IsErr(clientPubRes):
        v3BftMainPrintErr(ErrorText(clientPubRes))
        return 2
    if IsErr(serverPubRes):
        v3BftMainPrintErr(ErrorText(serverPubRes))
        return 2
    let clientPriv = fixed256.scalar256ToBytes(Value(clientPrivRes))
    let clientPub = layout.fixedBytes32ToBytes(Value(clientPubRes))
    let serverPriv = fixed256.scalar256ToBytes(Value(serverPrivRes))
    let serverPub = layout.fixedBytes32ToBytes(Value(serverPubRes))
    handshake13.msquicTls13ResetClientDefault(true)
    handshake13.msquicTls13ResetServerDefault(true)
    handshake13.msquicTls13ClientSetServerName(serverName)
    handshake13.msquicTls13ServerSetServerName(serverName)
    let trustRootRes = handshake13.msquicTls13ClientAddTrustRoot(policy.trustRoot0)
    if IsErr(trustRootRes):
        v3BftMainPrintErr(ErrorText(trustRootRes))
        return 2
    handshake13.msquicTls13ClientSetLocalX25519(clientPriv, clientPub)
    handshake13.msquicTls13ServerSetLocalX25519(serverPriv, serverPub)

    let clientHelloRes = handshake13.msquicTls13ClientBuildClientHello(v3BftMainTls13ProbeSeed32(17),
                                                                       "dm",
                                                                       serverName,
                                                                       emptyBytes())
    if IsErr(clientHelloRes):
        v3BftMainPrintErr(ErrorText(clientHelloRes))
        return 2
    let clientHello = Value(clientHelloRes)
    handshake13.msquicTls13ClientAppendTranscript(clientHello)
    let serverFeedRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideServer, clientHello)
    if IsErr(serverFeedRes):
        v3BftMainPrintErr(ErrorText(serverFeedRes))
        return 2
    v3BftMainPrintOut("server_feed_count=" + intToStr(Value(serverFeedRes)))

    let serverHelloRes = handshake13.msquicTls13ServerBuildServerHello(v3BftMainTls13ProbeSeed32(23), false)
    if IsErr(serverHelloRes):
        v3BftMainPrintErr(ErrorText(serverHelloRes))
        return 2
    let serverHello = Value(serverHelloRes)
    handshake13.msquicTls13ServerAppendTranscript(serverHello)
    let serverSecretsRes = handshake13.msquicTls13SideComputeHandshakeSecrets(handshake13.msQuicTls13SideServer)
    if IsErr(serverSecretsRes):
        v3BftMainPrintErr(ErrorText(serverSecretsRes))
        return 2

    let encryptedExtensionsRes = handshake13.msquicTls13BuildEncryptedExtensions("dm", emptyBytes())
    if IsErr(encryptedExtensionsRes):
        v3BftMainPrintErr(ErrorText(encryptedExtensionsRes))
        return 2
    let encryptedExtensions = Value(encryptedExtensionsRes)
    handshake13.msquicTls13ServerAppendTranscript(encryptedExtensions)

    let certificateRes = handshake13.msquicTls13BuildCertificate(policy.certChain0)
    if IsErr(certificateRes):
        v3BftMainPrintErr(ErrorText(certificateRes))
        return 2
    let certificate = Value(certificateRes)
    handshake13.msquicTls13ServerAppendTranscript(certificate)

    let certVerifyRes = handshake13.msquicTls13ServerBuildCertificateVerify(policy.certLeafKeyKind,
                                                                            policy.certPrivateKey,
                                                                            true)
    if IsErr(certVerifyRes):
        v3BftMainPrintErr(ErrorText(certVerifyRes))
        return 2
    let certVerify = Value(certVerifyRes)
    handshake13.msquicTls13ServerAppendTranscript(certVerify)

    let serverFinishedRes = handshake13.msquicTls13ServerBuildFinished(true)
    if IsErr(serverFinishedRes):
        v3BftMainPrintErr(ErrorText(serverFinishedRes))
        return 2
    let serverFinished = Value(serverFinishedRes)

    let clientServerHelloRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, serverHello)
    let clientEncryptedExtensionsRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, encryptedExtensions)
    let clientCertificateRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, certificate)
    let clientCertVerifyRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, certVerify)
    if IsErr(clientServerHelloRes):
        v3BftMainPrintErr(ErrorText(clientServerHelloRes))
        return 2
    if IsErr(clientEncryptedExtensionsRes):
        v3BftMainPrintErr(ErrorText(clientEncryptedExtensionsRes))
        return 2
    if IsErr(clientCertificateRes):
        v3BftMainPrintErr(ErrorText(clientCertificateRes))
        return 2
    if IsErr(clientCertVerifyRes):
        v3BftMainPrintErr(ErrorText(clientCertVerifyRes))
        return 2
    v3BftMainPrintOut("client_server_hello_count=" + intToStr(Value(clientServerHelloRes)))
    v3BftMainPrintOut("client_encrypted_extensions_count=" + intToStr(Value(clientEncryptedExtensionsRes)))
    v3BftMainPrintOut("client_certificate_count=" + intToStr(Value(clientCertificateRes)))
    v3BftMainPrintOut("client_cert_verify_count=" + intToStr(Value(clientCertVerifyRes)))

    let clientExpectedServerFinishedRes = handshake13.msquicTls13ClientBuildFinished(true)
    if IsErr(clientExpectedServerFinishedRes):
        v3BftMainPrintErr(ErrorText(clientExpectedServerFinishedRes))
        return 2
    let clientExpectedServerFinished = Value(clientExpectedServerFinishedRes)
    let parseFinishedRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, serverFinished)

    v3BftMainPrintOut("server_finished=" + bytesToHex(serverFinished))
    v3BftMainPrintOut("client_expected_server_finished=" + bytesToHex(clientExpectedServerFinished))
    if bytesEqual(serverFinished, clientExpectedServerFinished):
        v3BftMainPrintOut("server_finished_match=true")
    else:
        v3BftMainPrintOut("server_finished_match=false")
    if IsErr(parseFinishedRes):
        v3BftMainPrintOut("client_parse_finished=err:" + ErrorText(parseFinishedRes))
    else:
        v3BftMainPrintOut("client_parse_finished=ok:" + intToStr(Value(parseFinishedRes)))
    if handshake13.msquicTls13ClientFinishedOk():
        v3BftMainPrintOut("client_finished_ok=true")
    else:
        v3BftMainPrintOut("client_finished_ok=false")

    handshake13.msquicTls13ResetClientDefault(true)
    handshake13.msquicTls13ClientSetServerName(serverName)
    let combinedTrustRootRes = handshake13.msquicTls13ClientAddTrustRoot(policy.trustRoot0)
    if IsErr(combinedTrustRootRes):
        v3BftMainPrintErr(ErrorText(combinedTrustRootRes))
        return 2
    handshake13.msquicTls13ClientSetLocalX25519(clientPriv, clientPub)
    let combinedClientHelloRes = handshake13.msquicTls13ClientBuildClientHello(v3BftMainTls13ProbeSeed32(17),
                                                                               "dm",
                                                                               serverName,
                                                                               emptyBytes())
    if IsErr(combinedClientHelloRes):
        v3BftMainPrintErr(ErrorText(combinedClientHelloRes))
        return 2
    handshake13.msquicTls13ClientAppendTranscript(Value(combinedClientHelloRes))
    var serverFlightBuf = newByteBuffer()
    appendBytes(serverFlightBuf, serverHello)
    appendBytes(serverFlightBuf, encryptedExtensions)
    appendBytes(serverFlightBuf, certificate)
    appendBytes(serverFlightBuf, certVerify)
    appendBytes(serverFlightBuf, serverFinished)
    let combinedFeedRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideClient, toBytes(serverFlightBuf))
    if IsErr(combinedFeedRes):
        v3BftMainPrintOut("client_combined_feed=err:" + ErrorText(combinedFeedRes))
    else:
        v3BftMainPrintOut("client_combined_feed=ok:" + intToStr(Value(combinedFeedRes)))
    if handshake13.msquicTls13ClientFinishedOk():
        v3BftMainPrintOut("client_combined_finished_ok=true")
    else:
        v3BftMainPrintOut("client_combined_finished_ok=false")
    return 0

fn v3BftMainTls13PacketFlightProbeCommand(): int32 =
    let serverName = host.v3BftValidatorPublicTransportServerName()
    let policy = test_pki.msquicMakePublicTransportTlsPolicy(serverName)
    let clientPrivRes = fixed256.scalar256FromHex("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    let serverPrivRes = fixed256.scalar256FromHex("5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    if IsErr(clientPrivRes):
        v3BftMainPrintErr(ErrorText(clientPrivRes))
        return 2
    if IsErr(serverPrivRes):
        v3BftMainPrintErr(ErrorText(serverPrivRes))
        return 2
    let clientPubRes = fixed256.curve25519PublicKey(Value(clientPrivRes))
    let serverPubRes = fixed256.curve25519PublicKey(Value(serverPrivRes))
    if IsErr(clientPubRes):
        v3BftMainPrintErr(ErrorText(clientPubRes))
        return 2
    if IsErr(serverPubRes):
        v3BftMainPrintErr(ErrorText(serverPubRes))
        return 2
    let clientPriv = fixed256.scalar256ToBytes(Value(clientPrivRes))
    let clientPub = layout.fixedBytes32ToBytes(Value(clientPubRes))
    let serverPriv = fixed256.scalar256ToBytes(Value(serverPrivRes))
    let serverPub = layout.fixedBytes32ToBytes(Value(serverPubRes))

    qnative.msquicNativeResetSession()
    handshake13.msquicTls13ResetClientDefault(true)
    handshake13.msquicTls13ResetServerDefault(true)
    handshake13.msquicTls13ClientSetServerName(serverName)
    handshake13.msquicTls13ServerSetServerName(serverName)
    let trustRootRes = handshake13.msquicTls13ClientAddTrustRoot(policy.trustRoot0)
    if IsErr(trustRootRes):
        v3BftMainPrintErr(ErrorText(trustRootRes))
        return 2
    handshake13.msquicTls13ClientSetLocalX25519(clientPriv, clientPub)
    handshake13.msquicTls13ServerSetLocalX25519(serverPriv, serverPub)

    let clientHelloRes = handshake13.msquicTls13ClientBuildClientHello(v3BftMainTls13ProbeSeed32(17),
                                                                       "dm",
                                                                       serverName,
                                                                       emptyBytes())
    if IsErr(clientHelloRes):
        v3BftMainPrintErr(ErrorText(clientHelloRes))
        return 2
    let clientHello = Value(clientHelloRes)
    handshake13.msquicTls13ClientAppendTranscript(clientHello)
    let serverFeedRes = handshake13.msquicTls13SideFeed(handshake13.msQuicTls13SideServer, clientHello)
    if IsErr(serverFeedRes):
        v3BftMainPrintErr(ErrorText(serverFeedRes))
        return 2

    let serverHelloRes = handshake13.msquicTls13ServerBuildServerHello(v3BftMainTls13ProbeSeed32(23), false)
    if IsErr(serverHelloRes):
        v3BftMainPrintErr(ErrorText(serverHelloRes))
        return 2
    let serverHello = Value(serverHelloRes)
    handshake13.msquicTls13ServerAppendTranscript(serverHello)
    let serverSecretsRes = handshake13.msquicTls13SideComputeHandshakeSecrets(handshake13.msQuicTls13SideServer)
    if IsErr(serverSecretsRes):
        v3BftMainPrintErr(ErrorText(serverSecretsRes))
        return 2

    let encryptedExtensionsRes = handshake13.msquicTls13BuildEncryptedExtensions("dm", emptyBytes())
    if IsErr(encryptedExtensionsRes):
        v3BftMainPrintErr(ErrorText(encryptedExtensionsRes))
        return 2
    let encryptedExtensions = Value(encryptedExtensionsRes)
    handshake13.msquicTls13ServerAppendTranscript(encryptedExtensions)

    let certificateRes = handshake13.msquicTls13BuildCertificate(policy.certChain0)
    if IsErr(certificateRes):
        v3BftMainPrintErr(ErrorText(certificateRes))
        return 2
    let certificate = Value(certificateRes)
    handshake13.msquicTls13ServerAppendTranscript(certificate)

    let certVerifyRes = handshake13.msquicTls13ServerBuildCertificateVerify(policy.certLeafKeyKind,
                                                                            policy.certPrivateKey,
                                                                            true)
    if IsErr(certVerifyRes):
        v3BftMainPrintErr(ErrorText(certVerifyRes))
        return 2
    let certVerify = Value(certVerifyRes)
    handshake13.msquicTls13ServerAppendTranscript(certVerify)

    let serverFinishedRes = handshake13.msquicTls13ServerBuildFinished(true)
    if IsErr(serverFinishedRes):
        v3BftMainPrintErr(ErrorText(serverFinishedRes))
        return 2
    let serverFinished = Value(serverFinishedRes)

    var cryptoBuf = buffer.NewByteBuffer()
    buffer.AppendBytes(cryptoBuf, serverHello)
    buffer.AppendBytes(cryptoBuf, encryptedExtensions)
    buffer.AppendBytes(cryptoBuf, certificate)
    buffer.AppendBytes(cryptoBuf, certVerify)
    buffer.AppendBytes(cryptoBuf, serverFinished)

    var pkt: qpacket.MsQuicPacket = qpacket.initMsQuicPacket(1)
    let addRes = qpacket.msquicPacketAddFrame(pkt, qframe.msquicFrameCrypto(0, buffer.ToBytes(cryptoBuf)))
    if IsErr(addRes):
        v3BftMainPrintErr(ErrorText(addRes))
        return 2
    let payloadRes = qpacket.msquicPacketPayloadEncode(pkt)
    if IsErr(payloadRes):
        v3BftMainPrintErr(ErrorText(payloadRes))
        return 2
    let payload = Value(payloadRes)

    var header: qheader.QuicPacketHeader
    header.longHeader = true
    header.packetType = qheader.QuicPacketHandshake
    header.version = qnative.msquicNativeVersion
    header.dcid = qnative.msquicNativeConnId(0x11111111)
    header.scid = qnative.msquicNativeConnId(0x22222222)
    header.token = emptyBytes()
    header.payloadLength = int64(bytesLen(payload) + 2)
    header.packetNumber = 1
    header.packetNumberLen = 2
    header.spinBit = false
    header.keyPhase = false
    let headerRes = qheader.quicPacketHeaderEncode(header)
    if IsErr(headerRes):
        v3BftMainPrintErr(ErrorText(headerRes))
        return 2
    let wire = bytesConcat3(Value(headerRes), payload, emptyBytes())

    let decodeHeaderRes = qheader.quicPacketHeaderDecode(wire, qnative.msquicNativeConnIdLen)
    if IsErr(decodeHeaderRes):
        v3BftMainPrintErr(ErrorText(decodeHeaderRes))
        return 2
    let headerDec = Value(decodeHeaderRes)
    let payloadOffset: int32 = headerDec.next
    let decodedPayloadLen: int32 = int32(headerDec.header.payloadLength) - headerDec.header.packetNumberLen
    if decodedPayloadLen <= 0:
        v3BftMainPrintErr("v3 bft main: tls13 packet probe payload empty")
        return 2
    let decodedPayload = bytesSlice(wire, payloadOffset, decodedPayloadLen)
    var decodedPkt: qpacket.MsQuicPacket
    let decodePayloadRes = qpacket.msquicPacketPayloadDecodeInto(decodedPkt, decodedPayload, headerDec.header.packetNumber)
    if IsErr(decodePayloadRes):
        v3BftMainPrintErr(ErrorText(decodePayloadRes))
        return 2
    for i in 0..<decodedPkt.framesCount:
        if decodedPkt.frames[i].kind == qframe.FrameCrypto:
            let feedRes = qnative.msquicNativeHandleCryptoData(qnative.msquicNativeClientSide,
                                                               qnative.msquicNativePacketHandshakeCode,
                                                               decodedPkt.frames[i].offset,
                                                               decodedPkt.frames[i].data)
            if IsErr(feedRes):
                v3BftMainPrintOut("client_packet_feed=err:" + ErrorText(feedRes))
                v3BftMainPrintOut("client_last_error=" + handshake13.msquicTls13ClientLastErrorText())
                return 2
    var finishedOkText = "false"
    if handshake13.msquicTls13ClientFinishedOk():
        finishedOkText = "true"
    v3BftMainPrintOut("server_feed_count=" + intToStr(Value(serverFeedRes)))
    v3BftMainPrintOut("server_finished=" + bytesToHex(serverFinished))
    v3BftMainPrintOut("client_finished_ok=" + finishedOkText)
    v3BftMainPrintOut("client_message_count=" + intToStr(handshake13.msquicTls13ClientHandshakeMessageCount()))
    v3BftMainPrintOut("client_buffered=" + intToStr(handshake13.msquicTls13ClientBufferedHandshakeBytes()))
    v3BftMainPrintOut("client_last_error=" + handshake13.msquicTls13ClientLastErrorText())
    return 0

fn v3BftMainTls13DeriveProbeCommand(): int32 =
    var sharedHex = ""
    let sharedHexRes = v3BftMainReadRequiredFlag("--shared-hex", sharedHex)
    if IsErr(sharedHexRes):
        v3BftMainPrintErr(ErrorText(sharedHexRes))
        return 2
    var thashHex = ""
    let thashHexRes = v3BftMainReadRequiredFlag("--thash-hex", thashHex)
    if IsErr(thashHexRes):
        v3BftMainPrintErr(ErrorText(thashHexRes))
        return 2
    let sharedRes = tls13.msquicTls13HexDecode(sharedHex)
    if IsErr(sharedRes):
        v3BftMainPrintErr(ErrorText(sharedRes))
        return 2
    let thashRes = tls13.msquicTls13HexDecode(thashHex)
    if IsErr(thashRes):
        v3BftMainPrintErr(ErrorText(thashRes))
        return 2
    let cipherId = cmdline.ReadInt32FlagOrDefault("--cipher-id", 4865)
    let cipherRes = handshake13.msquicTls13CipherFromId(cipherId)
    if IsErr(cipherRes):
        v3BftMainPrintErr(ErrorText(cipherRes))
        return 2
    let shared = Value(sharedRes)
    let thash = Value(thashRes)
    let cipher = Value(cipherRes)
    let early = tls13.msquicTls13HkdfExtract(cipher, emptyBytes(), emptyBytes())
    let emptyHash = tls13.msquicTls13EmptyHash(cipher)
    let derived1Res = tls13.msquicTls13DeriveSecret(early, "derived", emptyHash, cipher)
    if IsErr(derived1Res):
        v3BftMainPrintErr(ErrorText(derived1Res))
        return 2
    let derived1 = Value(derived1Res)
    let handshake = tls13.msquicTls13HkdfExtract(cipher, shared, derived1)
    let chsRes = tls13.msquicTls13DeriveSecret(handshake, "c hs traffic", thash, cipher)
    if IsErr(chsRes):
        v3BftMainPrintErr(ErrorText(chsRes))
        return 2
    let shsRes = tls13.msquicTls13DeriveSecret(handshake, "s hs traffic", thash, cipher)
    if IsErr(shsRes):
        v3BftMainPrintErr(ErrorText(shsRes))
        return 2
    let derived2Res = tls13.msquicTls13DeriveSecret(handshake, "derived", emptyHash, cipher)
    if IsErr(derived2Res):
        v3BftMainPrintErr(ErrorText(derived2Res))
        return 2
    let derived2 = Value(derived2Res)
    let master = tls13.msquicTls13HkdfExtract(cipher, emptyBytes(), derived2)
    let hashLen = tls13.msquicTls13HashLen(cipher)
    let resumptionRes = tls13.msquicTls13ExpandLabel(master, "res master", emptyBytes(), hashLen, cipher)
    if IsErr(resumptionRes):
        v3BftMainPrintErr(ErrorText(resumptionRes))
        return 2
    let capRes = tls13.msquicTls13DeriveSecret(master, "c ap traffic", thash, cipher)
    if IsErr(capRes):
        v3BftMainPrintErr(ErrorText(capRes))
        return 2
    let sapRes = tls13.msquicTls13DeriveSecret(master, "s ap traffic", thash, cipher)
    if IsErr(sapRes):
        v3BftMainPrintErr(ErrorText(sapRes))
        return 2
    v3BftMainPrintOut("early=" + bytesToHex(early))
    v3BftMainPrintOut("empty_hash=" + bytesToHex(emptyHash))
    v3BftMainPrintOut("derived1=" + bytesToHex(derived1))
    v3BftMainPrintOut("handshake=" + bytesToHex(handshake))
    v3BftMainPrintOut("derived2=" + bytesToHex(derived2))
    v3BftMainPrintOut("chs=" + bytesToHex(Value(chsRes)))
    v3BftMainPrintOut("shs=" + bytesToHex(Value(shsRes)))
    v3BftMainPrintOut("cap=" + bytesToHex(Value(capRes)))
    v3BftMainPrintOut("sap=" + bytesToHex(Value(sapRes)))
    v3BftMainPrintOut("master=" + bytesToHex(master))
    v3BftMainPrintOut("resumption=" + bytesToHex(Value(resumptionRes)))
    return 0

fn v3BftMainServeHexDaemonCommand(protocol: types.V3Libp2pProtocolId): int32 =
    var filePath = ""
    let fileRes = v3BftMainReadRequiredFlag("--file", filePath)
    if IsErr(fileRes):
        v3BftMainPrintErr(Error(fileRes))
        return 2
    let hostText = cmdline.ReadFlagOrDefault("--host", "0.0.0.0")
    let portRes = v3BftMainReadServePort("--port")
    if IsErr(portRes):
        v3BftMainPrintErr(Error(portRes))
        return 2
    let port = Value(portRes)
    let readyPath = cmdline.ReadFlagOrDefault("--ready-path", "")
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 200)
    let maxServeCount = cmdline.ReadInt32FlagOrDefault("--max-serve-count", 0)
    var served = 0
    while maxServeCount <= 0 || served < maxServeCount:
        let payloadRes = host.v3BftValidatorReadHexFile(filePath)
        if IsOk(payloadRes) && bytesLen(Value(payloadRes)) > 0:
            let serveRes = host.v3BftValidatorServeHexFileOnce(filePath, hostText, port, protocol, readyPath)
            if IsErr(serveRes):
                v3BftMainPrintErr(Error(serveRes))
                return 2
            served = served + 1
        else:
            v3BftMainSleepMs(intervalMs)
    return 0

fn v3BftMainStateServeDaemonCommand(): int32 =
    var filePath = ""
    let fileRes = v3BftMainReadRequiredFlag("--file", filePath)
    if IsErr(fileRes):
        v3BftMainPrintErr(Error(fileRes))
        return 2
    let hostText = cmdline.ReadFlagOrDefault("--host", "0.0.0.0")
    let portRes = v3BftMainReadServePort("--port")
    if IsErr(portRes):
        v3BftMainPrintErr(Error(portRes))
        return 2
    let port = Value(portRes)
    var snapshotDir = cmdline.ReadFlagOrDefault("--snapshot-dir", "")
    if len(snapshotDir) <= 0:
        snapshotDir = host.v3BftValidatorDefaultStateSyncDir(filePath)
    let readyPath = cmdline.ReadFlagOrDefault("--ready-path", "")
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 0)
    let maxServeCount = cmdline.ReadInt32FlagOrDefault("--max-serve-count", 0)
    var served = 0
    while maxServeCount <= 0 || served < maxServeCount:
        let requestRes = quic_transport.v3Libp2pQuicServeRequestCaptureOnceNamed(hostText,
                                                                                 port,
                                                                                 host.v3BftValidatorPublicTransportServerName(),
                                                                                 host.v3BftValidatorStateSyncProtocol(),
                                                                                 bytesFromString(host.v3BftValidatorStateSyncAck),
                                                                                 readyPath)
        if IsErr(requestRes):
            v3BftMainPrintErr(Error(requestRes))
            return 2
        let heightRes = host.v3BftValidatorDecodeStateSyncRequest(Value(requestRes))
        var payload = host.v3BftValidatorEncodeStateSyncError("v3 bft validator: bad state sync request")
        if IsOk(heightRes):
            payload = host.v3BftValidatorStateSyncPayloadForHeight(snapshotDir, Value(heightRes))
        else:
            payload = host.v3BftValidatorEncodeStateSyncError(Error(heightRes))
        let payloadPortRes = v3BftMainResolveReadyPortForSecondPhase(port, readyPath)
        if IsErr(payloadPortRes):
            v3BftMainPrintErr(Error(payloadPortRes))
            return 2
        let serveRes = quic_transport.v3Libp2pQuicServePayloadOnceNamed(hostText,
                                                                        Value(payloadPortRes),
                                                                        host.v3BftValidatorPublicTransportServerName(),
                                                                        host.v3BftValidatorStateSyncProtocol(),
                                                                        payload,
                                                                        readyPath)
        if IsErr(serveRes):
            v3BftMainPrintErr(Error(serveRes))
            return 2
        served = served + 1
        if intervalMs > 0 && (maxServeCount <= 0 || served < maxServeCount):
            v3BftMainSleepMs(intervalMs)
    return 0

fn v3BftMainVoteCaptureDaemonCommand(): int32 =
    var filePath = ""
    let fileRes = v3BftMainReadRequiredFlag("--file", filePath)
    if IsErr(fileRes):
        v3BftMainPrintErr(Error(fileRes))
        return 2
    let hostText = cmdline.ReadFlagOrDefault("--host", "0.0.0.0")
    let portRes = v3BftMainReadServePort("--port")
    if IsErr(portRes):
        v3BftMainPrintErr(Error(portRes))
        return 2
    let port = Value(portRes)
    let readyPath = cmdline.ReadFlagOrDefault("--ready-path", "")
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 0)
    let maxVoteCount = cmdline.ReadInt32FlagOrDefault("--max-vote-count", 0)
    var captured = 0
    while maxVoteCount <= 0 || captured < maxVoteCount:
        let captureRes = host.v3BftValidatorCaptureVoteOnce(filePath, hostText, port, readyPath)
        if IsErr(captureRes):
            v3BftMainPrintErr(Error(captureRes))
            return 2
        captured = captured + 1
        if intervalMs > 0 && (maxVoteCount <= 0 || captured < maxVoteCount):
            v3BftMainSleepMs(intervalMs)
    return 0

fn v3BftMainClearFile(pathRaw: str) =
    let _ = v3BftMainWriteTextFile(pathRaw, "")

fn v3BftMainFollowerVoteStep(voteLockPath: str,
                             state: var host.V3BftValidatorState,
                             proposalHost: str,
                             proposalPort: int32,
                             voteHost: str,
                             votePort: int32): Result[bool] =
    let proposalRes = host.v3BftValidatorRecvProposal(proposalHost, proposalPort)
    if IsErr(proposalRes):
        if v3BftMainFollowerRetryableRecvError(Error(proposalRes)):
            return Ok[bool](false)
        return Err[bool](Error(proposalRes))
    let proposal = Value(proposalRes)
    if proposal.height <= state.machine.lastFinalizedHeight:
        return Ok[bool](false)
    let voteRes = host.v3BftValidatorBuildVote(state, proposal)
    if IsOk(voteRes):
        var voteSent = false
        for attempt in 0..<v3BftMainFollowerVoteRetryLimit():
            let sendRes = host.v3BftValidatorSendVote(voteHost, votePort, Value(voteRes))
            if IsOk(sendRes):
                voteSent = true
                break
            if !v3BftMainFollowerRetryableRecvError(Error(sendRes)):
                return Err[bool](Error(sendRes))
            if attempt + 1 < v3BftMainFollowerVoteRetryLimit():
                v3BftMainSleepMs(20)
        if !voteSent:
            return Ok[bool](false)
        state.lastVotedHeight = proposal.height
        state.lastVotedProposalHash = host.v3BftValidatorProposalHash(proposal)
        if !host.v3BftValidatorWriteVoteLock(voteLockPath, state):
            return Err[bool]("v3 bft main: failed to persist vote lock")
        return Ok[bool](true)
    if Error(voteRes) == "v3 bft validator: already voted for proposal" ||
       Error(voteRes) == "v3 bft validator: proposal height mismatch":
        return Ok[bool](false)
    return Err[bool](Error(voteRes))

fn v3BftMainFollowerCommitStep(statePath: str,
                               voteLockPath: str,
                               state: var host.V3BftValidatorState,
                               commitHost: str,
                               commitPort: int32,
                               syncHost: str,
                               syncPort: int32): Result[int64] =
    let commitRes = host.v3BftValidatorRecvCommit(commitHost, commitPort)
    if IsErr(commitRes):
        if v3BftMainFollowerRetryableRecvError(Error(commitRes)):
            return Ok[int64](int64(0))
        return Err[int64](Error(commitRes))
    let commit = Value(commitRes)
    if commit.height <= state.machine.lastFinalizedHeight:
        return Ok[int64](int64(0))
    let applyRes = host.v3BftValidatorStateApplyCommit(state, commit)
    if IsErr(applyRes):
        if Error(applyRes) == "v3 bft validator: proposal height mismatch":
            let syncRes = host.v3BftValidatorSyncMachineFromCommit(state, commit, syncHost, syncPort)
            if IsErr(syncRes):
                if Error(syncRes) == "v3 bft validator: state sync commit mismatch":
                    return Ok[int64](int64(0))
                if v3BftMainFollowerRetryableRecvError(Error(syncRes)):
                    return Ok[int64](int64(0))
                return Err[int64](Error(syncRes))
            if !host.v3BftValidatorWriteState(statePath, state):
                return Err[int64]("v3 bft main: failed to persist follower state")
            if !host.v3BftValidatorWriteVoteLock(voteLockPath, state):
                return Err[int64]("v3 bft main: failed to persist vote lock")
            v3BftMainPrintOut("synced_height=" + host.v3BftValidatorInt64Text(commit.height))
            v3BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(commit.appHash))
            return Ok[int64](commit.height)
        return Err[int64](Error(applyRes))
    if !host.v3BftValidatorWriteState(statePath, state):
        return Err[int64]("v3 bft main: failed to persist follower state")
    if !host.v3BftValidatorWriteVoteLock(voteLockPath, state):
        return Err[int64]("v3 bft main: failed to persist vote lock")
    v3BftMainPrintOut("applied_height=" + host.v3BftValidatorInt64Text(commit.height))
    v3BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(commit.appHash))
    return Ok[int64](commit.height)

fn v3BftMainProposerDaemonCommand(): int32 =
    var statePath = ""
    let stateRes = v3BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        v3BftMainPrintErr(Error(stateRes))
        return 2
    var queuePath = ""
    let queueRes = v3BftMainReadRequiredQueuePath(queuePath)
    if IsErr(queueRes):
        v3BftMainPrintErr(Error(queueRes))
        return 2
    var voteLockPath = cmdline.ReadFlagOrDefault("--vote-lock", "")
    if len(voteLockPath) <= 0:
        voteLockPath = host.v3BftValidatorDefaultVoteLockPath(statePath)
    var queueCursorPath = cmdline.ReadFlagOrDefault("--queue-cursor", "")
    if len(queueCursorPath) <= 0:
        queueCursorPath = host.v3BftValidatorDefaultQueueCursorPath(queuePath)
    var proposalFile = cmdline.ReadFlagOrDefault("--proposal-file", "")
    if len(proposalFile) <= 0:
        proposalFile = statePath + ".proposal"
    var commitFile = cmdline.ReadFlagOrDefault("--commit-file", "")
    if len(commitFile) <= 0:
        commitFile = statePath + ".commit"
    var stateSyncFile = cmdline.ReadFlagOrDefault("--state-sync-file", "")
    if len(stateSyncFile) <= 0:
        stateSyncFile = statePath + ".machine"
    var stateSyncDir = cmdline.ReadFlagOrDefault("--state-sync-dir", "")
    if len(stateSyncDir) <= 0:
        stateSyncDir = host.v3BftValidatorDefaultStateSyncDir(stateSyncFile)
    let proposalHost = cmdline.ReadFlagOrDefault("--proposal-host", "")
    let proposalPort = cmdline.ReadInt32FlagOrDefault("--proposal-port", -1)
    let voteHost = cmdline.ReadFlagOrDefault("--vote-host", "")
    let votePort = cmdline.ReadInt32FlagOrDefault("--vote-port", -1)
    let commitHost = cmdline.ReadFlagOrDefault("--commit-host", "")
    let commitPort = cmdline.ReadInt32FlagOrDefault("--commit-port", -1)
    let proposalReadyPath = cmdline.ReadFlagOrDefault("--proposal-ready-path", "")
    let voteReadyPath = cmdline.ReadFlagOrDefault("--vote-ready-path", "")
    let commitReadyPath = cmdline.ReadFlagOrDefault("--commit-ready-path", "")
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 200)
    let proposalWindowMs = cmdline.ReadInt32FlagOrDefault("--proposal-window-ms", intervalMs)
    let voteWindowMs = cmdline.ReadInt32FlagOrDefault("--vote-window-ms", intervalMs)
    let commitWindowMs = cmdline.ReadInt32FlagOrDefault("--commit-window-ms", intervalMs)
    let maxRounds = cmdline.ReadInt32FlagOrDefault("--max-rounds", 0)
    let maxTxs = cmdline.ReadInt32FlagOrDefault("--max-txs", 128)
    if len(proposalHost) <= 0 || proposalPort <= 0 || len(voteHost) <= 0 || votePort <= 0 || len(commitHost) <= 0 || commitPort <= 0:
        v3BftMainPrintErr("v3 bft main: proposer daemon requires proposal/vote/commit host+port")
        return 2
    let loadRes = host.v3BftValidatorLoadLiveState(statePath, voteLockPath)
    if IsErr(loadRes):
        v3BftMainPrintErr(Error(loadRes))
        return 2
    var state = Value(loadRes)
    if !host.v3BftValidatorWriteHexFile(stateSyncFile, host.v3BftValidatorEncodeMachine(state.machine)):
        v3BftMainPrintErr("v3 bft main: failed to write state sync file")
        return 2
    if !host.v3BftValidatorWriteStateSnapshot(stateSyncDir, state.machine):
        v3BftMainPrintErr("v3 bft main: failed to write state sync snapshot")
        return 2
    let queueTrackerRes = host.v3BftValidatorQueueTrackerInit(queuePath, queueCursorPath)
    if IsErr(queueTrackerRes):
        v3BftMainPrintErr(Error(queueTrackerRes))
        return 2
    var queueTracker = Value(queueTrackerRes)
    var currentProposal: host.V3BftProposal
    var currentPreview: host.V3BftProposalPreview
    var currentVotes: host.V3BftVote[]
    currentVotes = []
    var hasCurrentProposal = false
    var currentCommit: host.V3BftCommit
    var hasCurrentCommit = false
    let replayCommitRes = host.v3BftValidatorLoadCommitFile(commitFile)
    if IsOk(replayCommitRes) && Value(replayCommitRes).height == state.machine.lastFinalizedHeight:
        currentCommit = Value(replayCommitRes)
        hasCurrentCommit = true
    let replayProposalRes = host.v3BftValidatorLoadProposalFile(proposalFile)
    if IsOk(replayProposalRes) &&
       Value(replayProposalRes).proposerSlot == state.validatorSlot &&
       Value(replayProposalRes).height == state.machine.lastFinalizedHeight + int64(1):
        let previewRes = host.v3BftValidatorPreviewProposal(state, Value(replayProposalRes))
        let selfVoteRes = host.v3BftValidatorBuildVoteAllowRepeat(state, Value(replayProposalRes), true)
        if IsErr(previewRes):
            v3BftMainPrintErr(Error(previewRes))
            return 2
        if IsErr(selfVoteRes):
            v3BftMainPrintErr(Error(selfVoteRes))
            return 2
        currentProposal = Value(replayProposalRes)
        currentPreview = Value(previewRes)
        currentVotes = []
        add(currentVotes, Value(selfVoteRes))
        hasCurrentProposal = true
    var committedRounds = 0
    while maxRounds <= 0 || committedRounds < maxRounds:
        let refreshRes = host.v3BftValidatorQueueTrackerRefresh(queuePath, queueTracker)
        if IsErr(refreshRes):
            v3BftMainPrintErr(Error(refreshRes))
            return 2
        var progressed = false
        if hasCurrentCommit:
            if commitWindowMs > 0:
                let serveCommitRes = host.v3BftValidatorServeCommitWindow(commitHost,
                                                                          commitPort,
                                                                          currentCommit,
                                                                          commitReadyPath,
                                                                          host.v3BftValidatorCount - 1,
                                                                          commitWindowMs)
                if IsErr(serveCommitRes):
                    v3BftMainPrintErr(Error(serveCommitRes))
                    return 2
                progressed = true
        if !hasCurrentProposal && queueTracker.pendingTxs.len > 0:
            var batch: Bytes[]
            batch = []
            let takeCount = (maxTxs > 0 && maxTxs < queueTracker.pendingTxs.len) ? maxTxs : queueTracker.pendingTxs.len
            for i in 0..<takeCount:
                add(batch, queueTracker.pendingTxs[i])
            let proposalRes = host.v3BftValidatorProposalFromTxs(state.machine.appId,
                                                                 state.machine.lastFinalizedHeight + int64(1),
                                                                 state.validatorSlot,
                                                                 batch)
            if IsErr(proposalRes):
                v3BftMainPrintErr(Error(proposalRes))
                return 2
            let previewRes = host.v3BftValidatorPreviewProposal(state, Value(proposalRes))
            if IsErr(previewRes):
                v3BftMainPrintErr(Error(previewRes))
                return 2
            let selfVoteRes = host.v3BftValidatorBuildVoteAllowRepeat(state, Value(proposalRes), true)
            if IsErr(selfVoteRes):
                v3BftMainPrintErr(Error(selfVoteRes))
                return 2
            currentProposal = Value(proposalRes)
            currentPreview = Value(previewRes)
            currentVotes = []
            add(currentVotes, Value(selfVoteRes))
            state.lastVotedHeight = currentProposal.height
            state.lastVotedProposalHash = currentPreview.proposalHash
            if !host.v3BftValidatorWriteVoteLock(voteLockPath, state):
                v3BftMainPrintErr("v3 bft main: failed to write vote lock")
                return 2
            if len(proposalFile) > 0 &&
               !host.v3BftValidatorWriteHexFile(proposalFile, host.v3BftValidatorEncodeProposal(currentProposal)):
                v3BftMainPrintErr("v3 bft main: failed to write proposal file")
                return 2
            hasCurrentProposal = true
            progressed = true
        if hasCurrentProposal:
            if proposalWindowMs > 0:
                let serveProposalRes = host.v3BftValidatorServeProposalWindow(proposalHost,
                                                                              proposalPort,
                                                                              currentProposal,
                                                                              proposalReadyPath,
                                                                              host.v3BftValidatorCount - 1,
                                                                              proposalWindowMs)
                if IsErr(serveProposalRes):
                    v3BftMainPrintErr(Error(serveProposalRes))
                    return 2
            progressed = true
            let captureVotesRes = host.v3BftValidatorCaptureVotesWindow(voteHost,
                                                                        votePort,
                                                                        voteReadyPath,
                                                                        host.v3BftValidatorCount - 1,
                                                                        voteWindowMs)
            if IsErr(captureVotesRes):
                v3BftMainPrintErr(Error(captureVotesRes))
                return 2
            let capturedVotes = Value(captureVotesRes)
            if capturedVotes.len > 0:
                progressed = true
            for i in 0..<capturedVotes.len:
                let addVoteRes = host.v3BftValidatorVoteSetAdd(currentVotes,
                                                               capturedVotes[i],
                                                               currentProposal,
                                                               currentPreview)
                if IsErr(addVoteRes):
                    continue
            if currentVotes.len >= host.v3BftValidatorQuorum:
                let commitRes = host.v3BftValidatorCommitFromVotes(currentProposal, currentPreview, currentVotes)
                if IsErr(commitRes):
                    v3BftMainPrintErr(Error(commitRes))
                    return 2
                let applyRes = host.v3BftValidatorStateApplyCommit(state, Value(commitRes))
                if IsErr(applyRes):
                    v3BftMainPrintErr(Error(applyRes))
                    return 2
                if !host.v3BftValidatorWriteState(statePath, state):
                    v3BftMainPrintErr("v3 bft main: failed to write proposer state")
                    return 2
                if !host.v3BftValidatorWriteHexFile(stateSyncFile, host.v3BftValidatorEncodeMachine(state.machine)):
                    v3BftMainPrintErr("v3 bft main: failed to write state sync file")
                    return 2
                if !host.v3BftValidatorWriteStateSnapshot(stateSyncDir, state.machine):
                    v3BftMainPrintErr("v3 bft main: failed to write state sync snapshot")
                    return 2
                if !host.v3BftValidatorWriteVoteLock(voteLockPath, state):
                    v3BftMainPrintErr("v3 bft main: failed to write vote lock")
                    return 2
                let commitQueueRes = host.v3BftValidatorQueueTrackerCommit(queueCursorPath,
                                                                           queueTracker,
                                                                           currentProposal.txs.len)
                if IsErr(commitQueueRes):
                    v3BftMainPrintErr(Error(commitQueueRes))
                    return 2
                if len(commitFile) > 0 &&
                   !host.v3BftValidatorWriteHexFile(commitFile, host.v3BftValidatorEncodeCommit(Value(commitRes))):
                    v3BftMainPrintErr("v3 bft main: failed to write commit file")
                    return 2
                currentCommit = Value(commitRes)
                hasCurrentCommit = true
                hasCurrentProposal = false
                currentVotes = []
                v3BftMainClearFile(proposalFile)
                if commitWindowMs > 0:
                    let serveCommitNowRes = host.v3BftValidatorServeCommitWindow(commitHost,
                                                                                 commitPort,
                                                                                 currentCommit,
                                                                                 commitReadyPath,
                                                                                 host.v3BftValidatorCount - 1,
                                                                                 commitWindowMs)
                    if IsErr(serveCommitNowRes):
                        v3BftMainPrintErr(Error(serveCommitNowRes))
                        return 2
                committedRounds = committedRounds + 1
                v3BftMainPrintOut("committed_height=" + host.v3BftValidatorInt64Text(currentCommit.height))
                v3BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(currentCommit.appHash))
                progressed = true
        if !(progressed || Value(refreshRes) > 0):
            v3BftMainSleepMs(intervalMs)
    return 0

fn v3BftMainFollowerDaemonCommand(): int32 =
    var statePath = ""
    let stateRes = v3BftMainReadRequiredStatePath(statePath)
    if IsErr(stateRes):
        v3BftMainPrintErr(Error(stateRes))
        return 2
    var voteLockPath = cmdline.ReadFlagOrDefault("--vote-lock", "")
    if len(voteLockPath) <= 0:
        voteLockPath = host.v3BftValidatorDefaultVoteLockPath(statePath)
    let proposalHost = cmdline.ReadFlagOrDefault("--proposal-host", "")
    let proposalPort = cmdline.ReadInt32FlagOrDefault("--proposal-port", -1)
    let voteHost = cmdline.ReadFlagOrDefault("--vote-host", "")
    let votePort = cmdline.ReadInt32FlagOrDefault("--vote-port", -1)
    let commitHost = cmdline.ReadFlagOrDefault("--commit-host", "")
    let commitPort = cmdline.ReadInt32FlagOrDefault("--commit-port", -1)
    var syncHost = cmdline.ReadFlagOrDefault("--sync-host", "")
    if len(syncHost) <= 0:
        syncHost = commitHost
    let syncPort = cmdline.ReadInt32FlagOrDefault("--sync-port", -1)
    let intervalMs = cmdline.ReadInt32FlagOrDefault("--interval-ms", 100)
    let maxRounds = cmdline.ReadInt32FlagOrDefault("--max-rounds", 0)
    if len(proposalHost) <= 0 || proposalPort <= 0 || len(voteHost) <= 0 || votePort <= 0 || len(commitHost) <= 0 || commitPort <= 0:
        v3BftMainPrintErr("v3 bft main: follower daemon requires proposal/vote/commit host+port")
        return 2
    let loadRes = host.v3BftValidatorLoadLiveState(statePath, voteLockPath)
    if IsErr(loadRes):
        v3BftMainPrintErr(Error(loadRes))
        return 2
    var state = Value(loadRes)
    var appliedRounds = 0
    while maxRounds <= 0 || appliedRounds < maxRounds:
        let beforeHeight = state.machine.lastFinalizedHeight
        let voteStepRes = v3BftMainFollowerVoteStep(voteLockPath,
                                                    state,
                                                    proposalHost,
                                                    proposalPort,
                                                    voteHost,
                                                    votePort)
        if IsErr(voteStepRes):
            v3BftMainPrintErr(Error(voteStepRes))
            return 2
        let commitStepRes = v3BftMainFollowerCommitStep(statePath,
                                                        voteLockPath,
                                                        state,
                                                        commitHost,
                                                        commitPort,
                                                        syncHost,
                                                        syncPort)
        if IsErr(commitStepRes):
            v3BftMainPrintErr(Error(commitStepRes))
            return 2
        if Value(commitStepRes) > int64(0):
            let delta = state.machine.lastFinalizedHeight - beforeHeight
            if delta > int64(0):
                appliedRounds = appliedRounds + int32(delta)
            else:
                appliedRounds = appliedRounds + 1
            continue
        if Value(commitStepRes) <= int64(0) && !Value(voteStepRes):
            let syncLatestRes = host.v3BftValidatorSyncMachineLatest(state, syncHost, syncPort)
            if IsOk(syncLatestRes):
                let syncedHeight = Value(syncLatestRes)
                if syncedHeight > beforeHeight:
                    if !host.v3BftValidatorWriteState(statePath, state):
                        v3BftMainPrintErr("v3 bft main: failed to persist follower state")
                        return 2
                    if !host.v3BftValidatorWriteVoteLock(voteLockPath, state):
                        v3BftMainPrintErr("v3 bft main: failed to persist vote lock")
                        return 2
                    let commit = bft.v3BftStateMachineCommit(state.machine)
                    v3BftMainPrintOut("synced_height=" + host.v3BftValidatorInt64Text(commit.height))
                    v3BftMainPrintOut("app_hash=" + layout.fixedBytes32Hex(commit.appHash))
                    let delta = syncedHeight - beforeHeight
                    if delta > int64(0):
                        appliedRounds = appliedRounds + int32(delta)
                    else:
                        appliedRounds = appliedRounds + 1
                    continue
            elif !v3BftMainFollowerRetryableLatestSyncError(Error(syncLatestRes)):
                v3BftMainPrintErr(Error(syncLatestRes))
                return 2
        if maxRounds <= 0 || appliedRounds < maxRounds:
            v3BftMainSleepMs(intervalMs)
    return 0

fn main(argc: int32, argv: ptr): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let debugTls13 = cmdline.HasFlag("--debug-tls13")
    qnative.msquicNativeSetDebugTls13(debugTls13)
    handshake13.msquicTls13SetDebug(debugTls13)
    let count = cmdline.ParamCount()
    if count <= 0:
        return v3BftMainSelfTest()
    let cmd = cmdline.ParamStr(1)
    if len(cmd) <= 0:
        return v3BftMainSelfTest()
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        v3BftMainUsage()
        return 0
    if cmd == "self-test":
        return v3BftMainSelfTest()
    if cmd == "init":
        return v3BftMainInitCommand()
    if cmd == "submit-mint":
        return v3BftMainSubmitMintCommand()
    if cmd == "submit-transfer":
        return v3BftMainSubmitTransferCommand()
    if cmd == "submit-transfer-series":
        return v3BftMainSubmitTransferSeriesCommand()
    if cmd == "show-state":
        return v3BftMainShowStateCommand()
    if cmd == "query-balance":
        return v3BftMainQueryBalanceCommand()
    if cmd == "query-summary":
        return v3BftMainQuerySummaryCommand()
    if cmd == "curve25519-probe":
        return v3BftMainCurve25519ProbeCommand()
    if cmd == "curve25519-sweep":
        return v3BftMainCurve25519SweepCommand()
    if cmd == "curve25519-generated-sweep":
        return v3BftMainCurve25519GeneratedSweepCommand()
    if cmd == "curve25519-shared":
        return v3BftMainCurve25519SharedCommand()
    if cmd == "tls13-finished-probe":
        return v3BftMainTls13FinishedProbeCommand()
    if cmd == "tls13-packet-flight-probe":
        return v3BftMainTls13PacketFlightProbeCommand()
    if cmd == "tls13-derive-probe":
        return v3BftMainTls13DeriveProbeCommand()
    if cmd == "probe-proposal":
        return v3BftMainProbeProposalCommand()
    if cmd == "proposal-serve-daemon":
        return v3BftMainServeHexDaemonCommand(host.v3BftValidatorProposalProtocol())
    if cmd == "commit-serve-daemon":
        return v3BftMainServeHexDaemonCommand(host.v3BftValidatorCommitProtocol())
    if cmd == "state-serve-daemon":
        return v3BftMainStateServeDaemonCommand()
    if cmd == "vote-capture-daemon":
        return v3BftMainVoteCaptureDaemonCommand()
    if cmd == "validator-proposer-daemon":
        return v3BftMainProposerDaemonCommand()
    if cmd == "validator-follower-daemon":
        return v3BftMainFollowerDaemonCommand()
    v3BftMainPrintErr("v3 bft main: unknown command: " + cmd)
    v3BftMainUsage()
    return 2
