import std/system
import cheng/v3/chain/lsmr as lsmr
import cheng/v3/project/chain_node as node

fn main(): int32 =
    let addrRes = lsmr.v3LsmrAddressFromSeed("chain-node-a", 3)
    assert(addrRes.ok, "v3 chain_node rebuild main: address")
    var out: node.V3ChainNode
    node.v3ChainNodeZeroInto(out, "node-a", Value(addrRes))
    node.v3ChainNodeRebuildDerived(out)
    assert(out.nextEpoch >= 1, "v3 chain_node rebuild main: epoch")
    echo("v3 chain_node_rebuild_main ok")
    return 0
