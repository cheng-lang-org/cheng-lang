import std/system
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node mint main: init server")
    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node mint main: mint")
    let balanceRes = node.v3ChainNodeBalance(server, 7, 1001)
    assert(balanceRes.ok, "v3 chain_node mint main: balance")
    assert(balanceRes.value == int64(100), "v3 chain_node mint main: amount")
    echo("v3 chain_node_mint_main ok")
    return 0
