import std/result
import std/rawbytes
import cheng/v3/std/bytes_layout as layout
import cheng/v3/std/crypto/hash256
import cheng/v3/chain/binary_types as binary
import cheng/v3/chain/codec_binary as codec
import cheng/v3/chain/consensus
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/overlay/contracts as overlay
import cheng/v3/overlay/libp2p_bridge as bridge
import cheng/v3/libp2p/core/types as core
import cheng/v3/libp2p/host/host
import cheng/v3/project/chain_node

const
    v3ChainNodeLibp2pSnapshotVersion: int32 = 1
    v3ChainNodeLibp2pSnapshotMagic: str = "v3.chain_node.libp2p.snapshot"
    v3ChainNodeLibp2pSnapshotMagicLen: int32 = 29
    v3ChainNodeLibp2pSnapshotWireMinLen: int32 = 33

fn v3ChainNodeLibp2pAppendText(buf: var layout.ByteBuf, text: str) =
    for i in 0..<len(text):
        layout.byteBufAppendByte(buf, int32(text[i]) & 255)

fn v3ChainNodeLibp2pAppendSnapshotMagic(buf: var layout.ByteBuf) =
    layout.byteBufAppendByte(buf, int32('v'))
    layout.byteBufAppendByte(buf, int32('3'))
    layout.byteBufAppendByte(buf, int32('.'))
    layout.byteBufAppendByte(buf, int32('c'))
    layout.byteBufAppendByte(buf, int32('h'))
    layout.byteBufAppendByte(buf, int32('a'))
    layout.byteBufAppendByte(buf, int32('i'))
    layout.byteBufAppendByte(buf, int32('n'))
    layout.byteBufAppendByte(buf, int32('_'))
    layout.byteBufAppendByte(buf, int32('n'))
    layout.byteBufAppendByte(buf, int32('o'))
    layout.byteBufAppendByte(buf, int32('d'))
    layout.byteBufAppendByte(buf, int32('e'))
    layout.byteBufAppendByte(buf, int32('.'))
    layout.byteBufAppendByte(buf, int32('l'))
    layout.byteBufAppendByte(buf, int32('i'))
    layout.byteBufAppendByte(buf, int32('b'))
    layout.byteBufAppendByte(buf, int32('p'))
    layout.byteBufAppendByte(buf, int32('2'))
    layout.byteBufAppendByte(buf, int32('p'))
    layout.byteBufAppendByte(buf, int32('.'))
    layout.byteBufAppendByte(buf, int32('s'))
    layout.byteBufAppendByte(buf, int32('n'))
    layout.byteBufAppendByte(buf, int32('a'))
    layout.byteBufAppendByte(buf, int32('p'))
    layout.byteBufAppendByte(buf, int32('s'))
    layout.byteBufAppendByte(buf, int32('h'))
    layout.byteBufAppendByte(buf, int32('o'))
    layout.byteBufAppendByte(buf, int32('t'))

fn v3ChainNodeLibp2pPayloadHasSnapshotMagic(payload: Bytes): bool =
    if bytesLen(payload) < v3ChainNodeLibp2pSnapshotMagicLen:
        return false
    if bytesGet(payload, 0) != int32('v'):
        return false
    if bytesGet(payload, 1) != int32('3'):
        return false
    if bytesGet(payload, 2) != int32('.'):
        return false
    if bytesGet(payload, 3) != int32('c'):
        return false
    if bytesGet(payload, 4) != int32('h'):
        return false
    if bytesGet(payload, 5) != int32('a'):
        return false
    if bytesGet(payload, 6) != int32('i'):
        return false
    if bytesGet(payload, 7) != int32('n'):
        return false
    if bytesGet(payload, 8) != int32('_'):
        return false
    if bytesGet(payload, 9) != int32('n'):
        return false
    if bytesGet(payload, 10) != int32('o'):
        return false
    if bytesGet(payload, 11) != int32('d'):
        return false
    if bytesGet(payload, 12) != int32('e'):
        return false
    if bytesGet(payload, 13) != int32('.'):
        return false
    if bytesGet(payload, 14) != int32('l'):
        return false
    if bytesGet(payload, 15) != int32('i'):
        return false
    if bytesGet(payload, 16) != int32('b'):
        return false
    if bytesGet(payload, 17) != int32('p'):
        return false
    if bytesGet(payload, 18) != int32('2'):
        return false
    if bytesGet(payload, 19) != int32('p'):
        return false
    if bytesGet(payload, 20) != int32('.'):
        return false
    if bytesGet(payload, 21) != int32('s'):
        return false
    if bytesGet(payload, 22) != int32('n'):
        return false
    if bytesGet(payload, 23) != int32('a'):
        return false
    if bytesGet(payload, 24) != int32('p'):
        return false
    if bytesGet(payload, 25) != int32('s'):
        return false
    if bytesGet(payload, 26) != int32('h'):
        return false
    if bytesGet(payload, 27) != int32('o'):
        return false
    if bytesGet(payload, 28) != int32('t'):
        return false
    return true

fn v3ChainNodeLibp2pAppendI64BE(buf: var layout.ByteBuf, value: int64) =
    codec.v3BufAppendU32BE(buf, int64((value >> 32) & int64(0xffffffff)))
    codec.v3BufAppendU32BE(buf, int64(value & int64(0xffffffff)))

fn v3ChainNodeLibp2pReadI64BE(span: layout.ByteSpan, offset: int32): Result[int64] =
    let hiRes = codec.v3ReadU32BE(span, offset)
    if IsErr(hiRes):
        return Err[int64](Error(hiRes))
    let loRes = codec.v3ReadU32BE(span, offset + 4)
    if IsErr(loRes):
        return Err[int64](Error(loRes))
    let hi = int32(Value(hiRes))
    let lo = Value(loRes)
    return Ok[int64]((int64(hi) << 32) | (lo & int64(0xffffffff)))

fn v3ChainNodeLibp2pPayloadCid(payload: Bytes): layout.FixedBytes32 =
    var span: layout.ByteSpan
    span = layout.byteSpanFromBytes(payload)
    var out: layout.FixedBytes32
    out = hash256.sha256Fixed(span)
    return out

fn v3ChainNodeLibp2pFillIngress(out: var overlay.V3IngressEnvelope,
                                sourcePeerId: core.V3Libp2pPeerId,
                                address: binary.V3LsmrAddress,
                                payload: Bytes,
                                stampEpoch: int32,
                                stampGanzhi: int32) =
    out.sourcePeerId = sourcePeerId.value
    out.topicScope = overlay.v3OverlayScopeCell
    out.address = address
    out.payloadKind = 0
    out.payload = payload
    out.payloadCid = v3ChainNodeLibp2pPayloadCid(payload)
    out.payloadLen = bytesLen(payload)
    out.stampEpoch = stampEpoch
    out.stampGanzhi = stampGanzhi

fn v3ChainNodeLibp2pAppendSignature(buf: var layout.ByteBuf,
                                    signature: lt.V3AntiEntropySignature) =
    codec.v3BufAppendU32BE(buf, signature.stampEpoch)
    codec.v3BufAppendU32BE(buf, signature.stampGanzhi)
    codec.v3BufAppendU32BE(buf, signature.eventCount)
    codec.v3BufAppendU32BE(buf, signature.accountCount)
    codec.v3BufAppendFixed32(buf, signature.stateForestCid)
    codec.v3BufAppendU32BE(buf, signature.layerCount)
    for i in 0..<signature.layerCount:
        codec.v3BufAppendU32BE(buf, signature.layerSummaries[i].layerId)
        codec.v3BufAppendFixed32(buf, signature.layerSummaries[i].treeCid)
        codec.v3BufAppendU32BE(buf, signature.layerSummaries[i].nodeCount)
        codec.v3BufAppendU32BE(buf, signature.layerSummaries[i].entryCount)
    codec.v3BufAppendU32BE(buf, signature.rootCount)
    for i in 0..<signature.rootCount:
        codec.v3BufAppendU32BE(buf, signature.rootSummaries[i].layerId)
        codec.v3BufAppendU32BE(buf, signature.rootSummaries[i].baguaId)
        codec.v3BufAppendFixed32(buf, signature.rootSummaries[i].nodeCid)
        codec.v3BufAppendU32BE(buf, signature.rootSummaries[i].entryDescCount)

fn v3ChainNodeLibp2pDecodeSignature(span: layout.ByteSpan,
                                    offset0: int32,
                                    out: var lt.V3AntiEntropySignature): Result[int32] =
    var offset = offset0
    let epochRes = codec.v3ReadU32BE(span, offset)
    if IsErr(epochRes):
        return Err[int32](Error(epochRes))
    offset = offset + 4
    let ganzhiRes = codec.v3ReadU32BE(span, offset)
    if IsErr(ganzhiRes):
        return Err[int32](Error(ganzhiRes))
    offset = offset + 4
    let eventCountRes = codec.v3ReadU32BE(span, offset)
    if IsErr(eventCountRes):
        return Err[int32](Error(eventCountRes))
    offset = offset + 4
    let accountCountRes = codec.v3ReadU32BE(span, offset)
    if IsErr(accountCountRes):
        return Err[int32](Error(accountCountRes))
    offset = offset + 4
    let forestCidRes = codec.v3ReadFixed32(span, offset)
    if IsErr(forestCidRes):
        return Err[int32](Error(forestCidRes))
    offset = offset + 32
    let layerCountRes = codec.v3ReadU32BE(span, offset)
    if IsErr(layerCountRes):
        return Err[int32](Error(layerCountRes))
    offset = offset + 4

    out = lt.v3AntiEntropySignatureZero()
    out.stampEpoch = int32(Value(epochRes))
    out.stampGanzhi = int32(Value(ganzhiRes))
    out.eventCount = int32(Value(eventCountRes))
    out.accountCount = int32(Value(accountCountRes))
    out.stateForestCid = Value(forestCidRes)
    out.layerCount = int32(Value(layerCountRes))
    if out.layerCount < 0 || out.layerCount > 3:
        return Err[int32]("v3 chain_node libp2p: invalid signature layer count")
    for i in 0..<out.layerCount:
        let layerIdRes = codec.v3ReadU32BE(span, offset)
        if IsErr(layerIdRes):
            return Err[int32](Error(layerIdRes))
        offset = offset + 4
        let treeCidRes = codec.v3ReadFixed32(span, offset)
        if IsErr(treeCidRes):
            return Err[int32](Error(treeCidRes))
        offset = offset + 32
        let nodeCountRes = codec.v3ReadU32BE(span, offset)
        if IsErr(nodeCountRes):
            return Err[int32](Error(nodeCountRes))
        offset = offset + 4
        let entryCountRes = codec.v3ReadU32BE(span, offset)
        if IsErr(entryCountRes):
            return Err[int32](Error(entryCountRes))
        offset = offset + 4
        var summary: lt.V3StateLayerSummary
        summary.layerId = int32(Value(layerIdRes))
        summary.treeCid = Value(treeCidRes)
        summary.nodeCount = int32(Value(nodeCountRes))
        summary.entryCount = int32(Value(entryCountRes))
        out.layerSummaries[i] = summary
    let rootCountRes = codec.v3ReadU32BE(span, offset)
    if IsErr(rootCountRes):
        return Err[int32](Error(rootCountRes))
    offset = offset + 4
    out.rootCount = int32(Value(rootCountRes))
    if out.rootCount < 0 || out.rootCount > lt.v3BaguaRootSummaryMax:
        return Err[int32]("v3 chain_node libp2p: invalid signature root count")
    for i in 0..<out.rootCount:
        let layerIdRes = codec.v3ReadU32BE(span, offset)
        if IsErr(layerIdRes):
            return Err[int32](Error(layerIdRes))
        offset = offset + 4
        let baguaIdRes = codec.v3ReadU32BE(span, offset)
        if IsErr(baguaIdRes):
            return Err[int32](Error(baguaIdRes))
        offset = offset + 4
        let nodeCidRes = codec.v3ReadFixed32(span, offset)
        if IsErr(nodeCidRes):
            return Err[int32](Error(nodeCidRes))
        offset = offset + 32
        let entryDescCountRes = codec.v3ReadU32BE(span, offset)
        if IsErr(entryDescCountRes):
            return Err[int32](Error(entryDescCountRes))
        offset = offset + 4
        var root: lt.V3BaguaRootSummary
        root.layerId = int32(Value(layerIdRes))
        root.baguaId = int32(Value(baguaIdRes))
        root.nodeCid = Value(nodeCidRes)
        root.entryDescCount = int32(Value(entryDescCountRes))
        out.rootSummaries[i] = root
    return Ok[int32](offset)

fn v3ChainNodeLibp2pAppendEvent(buf: var layout.ByteBuf,
                                eventCid: layout.FixedBytes32,
                                event: consensus.V3ChainEvent) =
    codec.v3BufAppendFixed32(buf, eventCid)
    codec.v3BufAppendU32BE(buf, event.version)
    codec.v3BufAppendU32BE(buf, event.kind)
    codec.v3BufAppendU32BE(buf, event.assetId)
    codec.v3BufAppendU32BE(buf, event.fromAccount)
    codec.v3BufAppendU32BE(buf, event.toAccount)
    codec.v3BufAppendFixed32(buf, event.fromParentCid)
    codec.v3BufAppendFixed32(buf, event.toParentCid)
    codec.v3BufAppendFixed32(buf, event.bodyCid)
    v3ChainNodeLibp2pAppendI64BE(buf, event.amount)
    codec.v3BufAppendU32BE(buf, event.epoch)
    codec.v3BufAppendU32BE(buf, event.ganzhiIndex)
    codec.v3BufAppendU32BE(buf, event.spaceSlot)
    v3ChainNodeLibp2pAppendI64BE(buf, event.tick)
    codec.v3BufAppendU32BE(buf, event.stem)
    codec.v3BufAppendU32BE(buf, event.branch)

fn v3ChainNodeLibp2pDecodeEvent(span: layout.ByteSpan,
                                offset0: int32,
                                eventCid: var layout.FixedBytes32,
                                event: var consensus.V3ChainEvent): Result[int32] =
    var offset = offset0
    let eventCidRes = codec.v3ReadFixed32(span, offset)
    if IsErr(eventCidRes):
        return Err[int32](Error(eventCidRes))
    offset = offset + 32
    let versionRes = codec.v3ReadU32BE(span, offset)
    if IsErr(versionRes):
        return Err[int32](Error(versionRes))
    offset = offset + 4
    let kindRes = codec.v3ReadU32BE(span, offset)
    if IsErr(kindRes):
        return Err[int32](Error(kindRes))
    offset = offset + 4
    let assetIdRes = codec.v3ReadU32BE(span, offset)
    if IsErr(assetIdRes):
        return Err[int32](Error(assetIdRes))
    offset = offset + 4
    let fromAccountRes = codec.v3ReadU32BE(span, offset)
    if IsErr(fromAccountRes):
        return Err[int32](Error(fromAccountRes))
    offset = offset + 4
    let toAccountRes = codec.v3ReadU32BE(span, offset)
    if IsErr(toAccountRes):
        return Err[int32](Error(toAccountRes))
    offset = offset + 4
    let fromParentRes = codec.v3ReadFixed32(span, offset)
    if IsErr(fromParentRes):
        return Err[int32](Error(fromParentRes))
    offset = offset + 32
    let toParentRes = codec.v3ReadFixed32(span, offset)
    if IsErr(toParentRes):
        return Err[int32](Error(toParentRes))
    offset = offset + 32
    let bodyCidRes = codec.v3ReadFixed32(span, offset)
    if IsErr(bodyCidRes):
        return Err[int32](Error(bodyCidRes))
    offset = offset + 32
    let amountRes = v3ChainNodeLibp2pReadI64BE(span, offset)
    if IsErr(amountRes):
        return Err[int32](Error(amountRes))
    offset = offset + 8
    let epochRes = codec.v3ReadU32BE(span, offset)
    if IsErr(epochRes):
        return Err[int32](Error(epochRes))
    offset = offset + 4
    let ganzhiRes = codec.v3ReadU32BE(span, offset)
    if IsErr(ganzhiRes):
        return Err[int32](Error(ganzhiRes))
    offset = offset + 4
    let slotRes = codec.v3ReadU32BE(span, offset)
    if IsErr(slotRes):
        return Err[int32](Error(slotRes))
    offset = offset + 4
    let tickRes = v3ChainNodeLibp2pReadI64BE(span, offset)
    if IsErr(tickRes):
        return Err[int32](Error(tickRes))
    offset = offset + 8
    let stemRes = codec.v3ReadU32BE(span, offset)
    if IsErr(stemRes):
        return Err[int32](Error(stemRes))
    offset = offset + 4
    let branchRes = codec.v3ReadU32BE(span, offset)
    if IsErr(branchRes):
        return Err[int32](Error(branchRes))
    offset = offset + 4

    var outEvent: consensus.V3ChainEvent
    outEvent.version = int32(Value(versionRes))
    outEvent.kind = int32(Value(kindRes))
    outEvent.assetId = int32(Value(assetIdRes))
    outEvent.fromAccount = int32(Value(fromAccountRes))
    outEvent.toAccount = int32(Value(toAccountRes))
    outEvent.fromParentCid = Value(fromParentRes)
    outEvent.toParentCid = Value(toParentRes)
    outEvent.bodyCid = Value(bodyCidRes)
    outEvent.amount = Value(amountRes)
    outEvent.epoch = int32(Value(epochRes))
    outEvent.ganzhiIndex = int32(Value(ganzhiRes))
    outEvent.spaceSlot = int32(Value(slotRes))
    outEvent.tick = Value(tickRes)
    outEvent.stem = int32(Value(stemRes))
    outEvent.branch = int32(Value(branchRes))
    if !layout.fixedBytes32Equal(outEvent.bodyCid, consensus.v3ChainEventBodyCid(outEvent)):
        return Err[int32]("v3 chain_node libp2p: invalid event body cid")
    if !layout.fixedBytes32Equal(Value(eventCidRes), consensus.v3ChainEventCid(outEvent)):
        return Err[int32]("v3 chain_node libp2p: invalid event cid")
    eventCid = Value(eventCidRes)
    event = outEvent
    return Ok[int32](offset)

fn v3ChainNodeLibp2pEncodeSnapshot(snapshot: chain_node.V3ChainNodeServeSnapshot): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(2048)
    v3ChainNodeLibp2pAppendSnapshotMagic(buf)
    codec.v3BufAppendU32BE(buf, v3ChainNodeLibp2pSnapshotVersion)
    codec.v3BufAppendAddress(buf, snapshot.address)
    codec.v3BufAppendU32BE(buf, snapshot.serveCount)
    codec.v3BufAppendFixed32(buf, snapshot.tipEventCid)
    v3ChainNodeLibp2pAppendSignature(buf, snapshot.signature)
    codec.v3BufAppendU32BE(buf, snapshot.eventCids.len)
    for i in 0..<snapshot.eventCids.len:
        v3ChainNodeLibp2pAppendEvent(buf, snapshot.eventCids[i], snapshot.events[i])
    return layout.byteBufToBytes(buf)

fn v3ChainNodeLibp2pPayloadIsSnapshot(payload: Bytes): bool =
    return v3ChainNodeLibp2pPayloadHasSnapshotMagic(payload)

fn v3ChainNodeLibp2pDecodeSnapshotFill(payload: Bytes,
                                       out: var chain_node.V3ChainNodeServeSnapshot): Result[bool] =
    if bytesLen(payload) < v3ChainNodeLibp2pSnapshotWireMinLen:
        return Err[bool]("v3 chain_node libp2p: short snapshot payload")
    if !v3ChainNodeLibp2pPayloadHasSnapshotMagic(payload):
        return Err[bool]("v3 chain_node libp2p: bad snapshot magic")
    let span = layout.byteSpanFromBytes(payload)
    var offset = v3ChainNodeLibp2pSnapshotMagicLen
    let versionRes = codec.v3ReadU32BE(span, offset)
    if IsErr(versionRes):
        return Err[bool](Error(versionRes))
    offset = offset + 4
    if int32(Value(versionRes)) != v3ChainNodeLibp2pSnapshotVersion:
        return Err[bool]("v3 chain_node libp2p: bad snapshot version")
    let addressRes = codec.v3ReadAddress(span, offset)
    if IsErr(addressRes):
        return Err[bool](Error(addressRes))
    offset = offset + 36
    let serveCountRes = codec.v3ReadU32BE(span, offset)
    if IsErr(serveCountRes):
        return Err[bool](Error(serveCountRes))
    offset = offset + 4
    let tipEventCidRes = codec.v3ReadFixed32(span, offset)
    if IsErr(tipEventCidRes):
        return Err[bool](Error(tipEventCidRes))
    offset = offset + 32
    let signatureNextOffsetRes = v3ChainNodeLibp2pDecodeSignature(span, offset, out.signature)
    if IsErr(signatureNextOffsetRes):
        return Err[bool](Error(signatureNextOffsetRes))
    offset = int32(Value(signatureNextOffsetRes))
    let eventCountRes = codec.v3ReadU32BE(span, offset)
    if IsErr(eventCountRes):
        return Err[bool](Error(eventCountRes))
    offset = offset + 4
    let eventCount = int32(Value(eventCountRes))
    if eventCount < 0:
        return Err[bool]("v3 chain_node libp2p: invalid event count")
    out.eventCids = []
    out.events = []
    for i in 0..<eventCount:
        var eventCid: layout.FixedBytes32
        var event: consensus.V3ChainEvent
        let eventNextOffsetRes = v3ChainNodeLibp2pDecodeEvent(span, offset, eventCid, event)
        if IsErr(eventNextOffsetRes):
            return Err[bool](Error(eventNextOffsetRes))
        offset = int32(Value(eventNextOffsetRes))
        add(out.eventCids, eventCid)
        add(out.events, event)
    out.nodeId = ""
    out.address = Value(addressRes)
    out.serveCount = int32(Value(serveCountRes))
    out.tipEventCid = Value(tipEventCidRes)
    out.forest = lt.v3StateLayerForestZero()
    out.forest.forestCid = out.signature.stateForestCid
    return Ok[bool](true)

fn v3ChainNodeLibp2pDecodeSnapshotInto(payload: Bytes,
                                       out: var chain_node.V3ChainNodeServeSnapshot): Result[bool] =
    return v3ChainNodeLibp2pDecodeSnapshotFill(payload, out)

fn v3ChainNodeLibp2pDecodeSnapshot(payload: Bytes): Result[chain_node.V3ChainNodeServeSnapshot] =
    var out: chain_node.V3ChainNodeServeSnapshot
    let fillRes = v3ChainNodeLibp2pDecodeSnapshotInto(payload, out)
    if IsErr(fillRes):
        return Err[chain_node.V3ChainNodeServeSnapshot](Error(fillRes))
    return Ok[chain_node.V3ChainNodeServeSnapshot](out)

fn v3ChainNodeLibp2pSnapshotIngress(hostState: host.V3Libp2pHost,
                                    snapshot: chain_node.V3ChainNodeServeSnapshot): overlay.V3IngressEnvelope =
    let payload = v3ChainNodeLibp2pEncodeSnapshot(snapshot)
    var out: overlay.V3IngressEnvelope
    v3ChainNodeLibp2pFillIngress(out,
                                 hostState.selfPeerId,
                                 snapshot.address,
                                 payload,
                                 snapshot.signature.stampEpoch,
                                 snapshot.signature.stampGanzhi)
    return out

fn v3ChainNodeLibp2pAdvertiseIngress(hostState: host.V3Libp2pHost,
                                     snapshot: chain_node.V3ChainNodeServeSnapshot): Result[overlay.V3IngressEnvelope] =
    let advertise = binary.v3AdvertisePayloadMake(
        hostState.selfPeerId.value,
        snapshot.forest.forestCid,
        snapshot.tipEventCid,
        snapshot.signature.accountCount,
        snapshot.signature.eventCount,
        snapshot.signature.stampEpoch,
        snapshot.signature.stampGanzhi
    )
    let frameRes = codec.v3EncodeAdvertiseFrame(advertise,
                                                snapshot.signature.stampEpoch,
                                                snapshot.signature.stampGanzhi)
    if IsErr(frameRes):
        return Err[overlay.V3IngressEnvelope](Error(frameRes))
    var out: overlay.V3IngressEnvelope
    v3ChainNodeLibp2pFillIngress(out,
                                 hostState.selfPeerId,
                                 snapshot.address,
                                 Value(frameRes),
                                 snapshot.signature.stampEpoch,
                                 snapshot.signature.stampGanzhi)
    return Ok[overlay.V3IngressEnvelope](out)

fn v3ChainNodeLibp2pServeOnce(nodeState: var chain_node.V3ChainNode,
                              hostState: var host.V3Libp2pHost): Result[bool] =
    let snapshot = chain_node.v3ChainNodeServeOnce(nodeState)
    let advertiseIngressRes = v3ChainNodeLibp2pAdvertiseIngress(hostState, snapshot)
    if IsErr(advertiseIngressRes):
        return Err[bool](Error(advertiseIngressRes))
    bridge.v3Libp2pRelayPublish(hostState, Value(advertiseIngressRes))
    let snapshotIngress = v3ChainNodeLibp2pSnapshotIngress(hostState, snapshot)
    host.v3Libp2pStorePut(hostState, snapshotIngress)
    host.v3Libp2pKadProvide(hostState, snapshot.tipEventCid)
    host.v3Libp2pKadProvide(hostState, snapshot.forest.forestCid)
    return Ok[bool](true)

fn v3ChainNodeLibp2pStampLess(leftEpoch: int32,
                              leftGanzhi: int32,
                              rightEpoch: int32,
                              rightGanzhi: int32): bool =
    if leftEpoch != rightEpoch:
        return leftEpoch < rightEpoch
    return leftGanzhi < rightGanzhi

fn v3ChainNodeLibp2pSnapshotQuery(address: binary.V3LsmrAddress): overlay.V3StoreQuery =
    var query = overlay.v3OverlayStoreQueryZero()
    query.topicScope = overlay.v3OverlayScopeCell
    query.address = address
    return query

fn v3ChainNodeLibp2pLatestSnapshotFromIngresses(entries: overlay.V3IngressEnvelope[],
                                                address: binary.V3LsmrAddress): Result[overlay.V3IngressEnvelope] =
    var found = false
    var best: overlay.V3IngressEnvelope
    for i in 0..<entries.len:
        let ingress = entries[i]
        if ingress.topicScope != overlay.v3OverlayScopeCell:
            continue
        if !binary.v3LsmrAddressEqual(ingress.address, address):
            continue
        if !v3ChainNodeLibp2pPayloadIsSnapshot(ingress.payload):
            continue
        if !found || v3ChainNodeLibp2pStampLess(best.stampEpoch,
                                                best.stampGanzhi,
                                                ingress.stampEpoch,
                                                ingress.stampGanzhi):
            found = true
            best = ingress
    if !found:
        return Err[overlay.V3IngressEnvelope]("v3 chain_node libp2p: snapshot missing")
    return Ok[overlay.V3IngressEnvelope](best)

fn v3ChainNodeLibp2pLatestSnapshot(remoteHost: host.V3Libp2pHost,
                                   address: binary.V3LsmrAddress): Result[overlay.V3IngressEnvelope] =
    let query = v3ChainNodeLibp2pSnapshotQuery(address)
    let entries = host.v3Libp2pStoreQuery(remoteHost, query)
    return v3ChainNodeLibp2pLatestSnapshotFromIngresses(entries, address)

fn v3ChainNodeLibp2pDecodeLatestSnapshotFill(entries: overlay.V3IngressEnvelope[],
                                             address: binary.V3LsmrAddress,
                                             out: var chain_node.V3ChainNodeServeSnapshot): Result[bool] =
    var bestIndex = -1
    for i in 0..<entries.len:
        let ingress = entries[i]
        if ingress.topicScope != overlay.v3OverlayScopeCell:
            continue
        if !binary.v3LsmrAddressEqual(ingress.address, address):
            continue
        if !v3ChainNodeLibp2pPayloadIsSnapshot(ingress.payload):
            continue
        if bestIndex < 0:
            bestIndex = i
            continue
        if v3ChainNodeLibp2pStampLess(entries[bestIndex].stampEpoch,
                                      entries[bestIndex].stampGanzhi,
                                      ingress.stampEpoch,
                                      ingress.stampGanzhi):
            bestIndex = i
    if bestIndex < 0:
        return Err[bool]("v3 chain_node libp2p: snapshot missing")
    return v3ChainNodeLibp2pDecodeSnapshotFill(entries[bestIndex].payload, out)

fn v3ChainNodeLibp2pSyncOnce(nodeState: var chain_node.V3ChainNode,
                             hostState: var host.V3Libp2pHost,
                             remoteHost: var host.V3Libp2pHost,
                             remotePeerId: core.V3Libp2pPeerId): Result[bool] =
    let query = v3ChainNodeLibp2pSnapshotQuery(nodeState.address)
    var entries: overlay.V3IngressEnvelope[]
    let entriesRes = host.v3Libp2pSyncRequest(hostState, remoteHost, remotePeerId, query, entries)
    if IsErr(entriesRes):
        return Err[bool](Error(entriesRes))
    var snapshot: chain_node.V3ChainNodeServeSnapshot
    let snapshotRes = v3ChainNodeLibp2pDecodeLatestSnapshotFill(entries, nodeState.address, snapshot)
    if IsErr(snapshotRes):
        return Err[bool](Error(snapshotRes))
    let syncRes = chain_node.v3ChainNodeSyncOnce(nodeState, snapshot)
    if IsErr(syncRes):
        return Err[bool](Error(syncRes))
    return Ok[bool](Value(syncRes))
