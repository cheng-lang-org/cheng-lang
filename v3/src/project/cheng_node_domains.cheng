import std/result
import std/system as system
import std/rawbytes
import std/strings as strings
import std/strutils as strutil
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/oracle_types as oracle_types
import cheng/v3/project/oracle_bft_state_machine as oracle_bft
import cheng/v3/project/oracle_fixture
import cheng/v3/DiLoCo/core/diloco as diloco
import cheng/v3/DiLoCo/protocol/wire as diloco_wire
import cheng/v3/libp2p/identity/did
import cheng/v3/libp2p/core/types as libtypes
import cheng/v3/libp2p/core/peer_id
import cheng/v3/project/unimaker_edge_types as evotypes
import cheng/v3/project/unimaker_evomap_protocol as evo

type
    V3ChengNodeOracleDomain =
        machine: oracle_bft.V3OracleBftStateMachine

    V3ChengNodeDilocoDomain =
        state: diloco.V3DiLoCoState

    V3ChengNodeEvoMapDomain =
        agentKeys: str[]
        agents: evo.V3EvoMapA2AHello[]
        taskKeys: str[]
        tasks: evo.V3EvoMapA2ATask[]
        capsuleKeys: str[]
        capsules: evotypes.V3EvoCapsule[]

fn v3ChengNodeDomainOwnText(text: str): str =
    return system.SystemToStringStr(text)

fn v3ChengNodeDomainAppendText(buf: var layout.ByteBuf,
                               text: str) =
    lt.v3AppendU32BE(buf, len(text))
    let raw = bytesFromString(text)
    layout.byteBufAppendBytes(buf, raw)

fn v3ChengNodeDomainHashTextCid(tag: str,
                                text: str): layout.FixedBytes32 =
    var buf = layout.byteBufInit(192)
    v3ChengNodeDomainAppendText(buf, tag)
    v3ChengNodeDomainAppendText(buf, text)
    return lt.v3FixedCidFromBuf(buf)

fn v3ChengNodeDomainLineValue(text: str,
                              key: str): str =
    let prefix = key + "="
    var lineStart: int32
    let n = strings.Len(text)
    while lineStart < n:
        var lineEnd: int32 = lineStart
        while lineEnd < n:
            if text[lineEnd] == '\n':
                break
            lineEnd = lineEnd + 1
        let lineLen = lineEnd - lineStart
        if lineLen >= strings.Len(prefix):
            let line = strings.SliceBytes(text, lineStart, lineLen)
            if strings.SliceBytes(line, 0, strings.Len(prefix)) == prefix:
                return strings.SliceBytes(line,
                                          strings.Len(prefix),
                                          strings.Len(line) - strings.Len(prefix))
        lineStart = lineEnd + 1
    return ""

fn v3ChengNodeDomainRequireText(text: str,
                                key: str): Result[str] =
    let value = v3ChengNodeDomainLineValue(text, key)
    if len(value) <= 0:
        return Err[str]("cheng_node domain: missing " + key)
    return Ok[str](value)

fn v3ChengNodeDomainRequireInt32(text: str,
                                 key: str): Result[int32] =
    let valueRes = v3ChengNodeDomainRequireText(text, key)
    if IsErr(valueRes):
        return Err[int32](Error(valueRes))
    return Ok[int32](int32(parseInt(Value(valueRes))))

fn v3ChengNodeDomainRequireInt64(text: str,
                                 key: str): Result[int64] =
    let valueRes = v3ChengNodeDomainRequireText(text, key)
    if IsErr(valueRes):
        return Err[int64](Error(valueRes))
    return Ok[int64](int64(parseInt(Value(valueRes))))

fn v3ChengNodeDomainRequireBool(text: str,
                                key: str): Result[bool] =
    let valueRes = v3ChengNodeDomainRequireText(text, key)
    if IsErr(valueRes):
        return Err[bool](Error(valueRes))
    let value = Value(valueRes)
    if value == "1":
        return Ok[bool](true)
    if value == "0":
        return Ok[bool](false)
    return Err[bool]("cheng_node domain: invalid bool " + key)

fn v3ChengNodeDomainRequireFixed32(text: str,
                                   key: str): Result[layout.FixedBytes32] =
    let valueRes = v3ChengNodeDomainRequireText(text, key)
    if IsErr(valueRes):
        return Err[layout.FixedBytes32](Error(valueRes))
    return layout.fixedBytes32FromHex(Value(valueRes))

fn v3ChengNodeDomainBoolText(value: bool): str =
    if value:
        return "1"
    return "0"

fn v3ChengNodeOracleCommittee(): oracle_types.V3OracleCommitteeConfig =
    var pubKeys: layout.FixedBytes65[]
    pubKeys = []
    add(pubKeys, oracle_fixture.oracleSmokePubKey(1))
    add(pubKeys, oracle_fixture.oracleSmokePubKey(2))
    add(pubKeys, oracle_fixture.oracleSmokePubKey(3))
    let committeeRes = oracle_types.v3OracleCommitteeConfigMake(1, pubKeys, 3)
    if IsErr(committeeRes):
        panic(Error(committeeRes))
    return Value(committeeRes)

fn V3ChengNodeOracleDomainInit(): V3ChengNodeOracleDomain =
    var out: V3ChengNodeOracleDomain
    out.machine = oracle_bft.v3OracleBftStateMachineInit("cheng_node.oracle",
                                                         v3ChengNodeOracleCommittee())
    return out

fn v3ChengNodeOracleAssetText(assetId: int32): str =
    if assetId == oracle_types.v3OracleAssetBtc:
        return "BTC"
    if assetId == oracle_types.v3OracleAssetEth:
        return "ETH"
    if assetId == oracle_types.v3OracleAssetSol:
        return "SOL"
    if assetId == oracle_types.v3OracleAssetBnb:
        return "BNB"
    if assetId == oracle_types.v3OracleAssetXau:
        return "XAU"
    if assetId == oracle_types.v3OracleAssetXag:
        return "XAG"
    if assetId == oracle_types.v3OracleAssetXpt:
        return "XPT"
    if assetId == oracle_types.v3OracleAssetXpd:
        return "XPD"
    return ""

fn v3ChengNodeOracleQuoteText(quoteId: int32): str =
    if quoteId == oracle_types.v3OracleQuoteUsd:
        return "USD"
    if quoteId == oracle_types.v3OracleQuoteCny:
        return "CNY"
    if quoteId == oracle_types.v3OracleQuoteEur:
        return "EUR"
    if quoteId == oracle_types.v3OracleQuoteHkd:
        return "HKD"
    return ""

fn V3ChengNodeOraclePairKeyFromPairId(pairId: int32): str =
    if !oracle_types.v3OraclePairValid(pairId):
        return ""
    let pairIndex = pairId - 1
    let assetId = (pairIndex / oracle_types.v3OracleQuoteCount) + 1
    let quoteId = (pairIndex % oracle_types.v3OracleQuoteCount) + 1
    let assetText = v3ChengNodeOracleAssetText(assetId)
    let quoteText = v3ChengNodeOracleQuoteText(quoteId)
    if len(assetText) <= 0 || len(quoteText) <= 0:
        return ""
    return assetText + "/" + quoteText

fn V3ChengNodeOracleResolvePair(pairTextRaw: str,
                                outPairId: var int32,
                                outPairKey: var str): Result[bool] =
    outPairId = 0
    outPairKey = ""
    var slashPos = -1
    var i = 0
    while i < len(pairTextRaw):
        if pairTextRaw[i] == '/':
            slashPos = i
            break
        i = i + 1
    if slashPos <= 0 || slashPos >= len(pairTextRaw) - 1:
        return Err[bool]("cheng_node oracle: invalid pair")
    let assetText = strutil.Strip(strings.SliceBytes(pairTextRaw, 0, slashPos))
    let quoteText = strutil.Strip(strings.SliceBytes(pairTextRaw,
                                                     slashPos + 1,
                                                     len(pairTextRaw) - slashPos - 1))
    var assetId = 0
    if assetText == "BTC":
        assetId = oracle_types.v3OracleAssetBtc
    elif assetText == "ETH":
        assetId = oracle_types.v3OracleAssetEth
    elif assetText == "SOL":
        assetId = oracle_types.v3OracleAssetSol
    elif assetText == "BNB":
        assetId = oracle_types.v3OracleAssetBnb
    elif assetText == "XAU":
        assetId = oracle_types.v3OracleAssetXau
    elif assetText == "XAG":
        assetId = oracle_types.v3OracleAssetXag
    elif assetText == "XPT":
        assetId = oracle_types.v3OracleAssetXpt
    elif assetText == "XPD":
        assetId = oracle_types.v3OracleAssetXpd
    var quoteId = 0
    if quoteText == "USD":
        quoteId = oracle_types.v3OracleQuoteUsd
    elif quoteText == "CNY":
        quoteId = oracle_types.v3OracleQuoteCny
    elif quoteText == "EUR":
        quoteId = oracle_types.v3OracleQuoteEur
    elif quoteText == "HKD":
        quoteId = oracle_types.v3OracleQuoteHkd
    if assetId <= 0 || quoteId <= 0:
        return Err[bool]("cheng_node oracle: unsupported pair")
    let pairRes = oracle_types.v3OraclePairIdFromAssetQuote(assetId, quoteId)
    if IsErr(pairRes):
        return Err[bool](Error(pairRes))
    outPairId = Value(pairRes)
    outPairKey = assetText + "/" + quoteText
    return Ok[bool](true)

fn v3ChengNodeOracleHistoryStart(pairState: oracle_types.V3OraclePairState): int32 =
    let raw = pairState.historyHead - pairState.historyLen
    if raw >= 0:
        return raw
    return raw + oracle_types.v3OracleHistoryMax

fn V3ChengNodeOracleMachineStateText(domain: V3ChengNodeOracleDomain): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out, "version", "1")
    out = did.v3DidStoreAppendLine(out, "kind", "oracle_machine")
    out = did.v3DidStoreAppendLine(out, "has_finalized", v3ChengNodeDomainBoolText(domain.machine.hasFinalized))
    out = did.v3DidStoreAppendLine(out, "last_finalized_round_id", int64ToStr(domain.machine.lastFinalizedRoundId))
    out = did.v3DidStoreAppendLine(out, "last_finalized_height", int64ToStr(domain.machine.lastFinalizedHeight))
    out = did.v3DidStoreAppendLine(out, "last_commit_app_hash", layout.fixedBytes32Hex(domain.machine.lastCommitAppHash))
    out = did.v3DidStoreAppendLine(out, "app_hash", layout.fixedBytes32Hex(oracle_bft.v3OracleBftStateMachineQueryAppHash(domain.machine)))
    return out

fn V3ChengNodeOraclePairStateText(domain: V3ChengNodeOracleDomain,
                                  pairId: int32): Result[str] =
    let stateRes = oracle_bft.v3OracleBftLatestState(domain.machine, pairId)
    if IsErr(stateRes):
        return Err[str](Error(stateRes))
    let pairState = Value(stateRes)
    let pairKey = V3ChengNodeOraclePairKeyFromPairId(pairId)
    if len(pairKey) <= 0:
        return Err[str]("cheng_node oracle: pair key missing")
    var out = ""
    out = did.v3DidStoreAppendLine(out, "version", "1")
    out = did.v3DidStoreAppendLine(out, "kind", "oracle_pair")
    out = did.v3DidStoreAppendLine(out, "pair_key", pairKey)
    out = did.v3DidStoreAppendLine(out, "pair_id", intToStr(pairId))
    out = did.v3DidStoreAppendLine(out, "available", v3ChengNodeDomainBoolText(pairState.available))
    out = did.v3DidStoreAppendLine(out, "latest_round_id", int64ToStr(pairState.latestRoundId))
    out = did.v3DidStoreAppendLine(out, "latest_price_e8", int64ToStr(pairState.latestPriceE8))
    out = did.v3DidStoreAppendLine(out, "history_count", intToStr(pairState.historyLen))
    out = did.v3DidStoreAppendLine(out, "reporter_count", intToStr(domain.machine.committee.quorum))
    out = did.v3DidStoreAppendLine(out, "height", int64ToStr(domain.machine.lastFinalizedHeight))
    out = did.v3DidStoreAppendLine(out, "app_hash", layout.fixedBytes32Hex(oracle_bft.v3OracleBftStateMachineQueryAppHash(domain.machine)))
    let start = v3ChengNodeOracleHistoryStart(pairState)
    var historyPos = 0
    while historyPos < pairState.historyLen:
        let idx = (start + historyPos) % oracle_types.v3OracleHistoryMax
        let prefix = "history." + intToStr(historyPos)
        out = did.v3DidStoreAppendLine(out, prefix + ".round_id", int64ToStr(pairState.historyRoundIds[idx]))
        out = did.v3DidStoreAppendLine(out, prefix + ".price_e8", int64ToStr(pairState.historyPricesE8[idx]))
        historyPos = historyPos + 1
    return Ok[str](out)

fn V3ChengNodeOracleApplyMachineText(domain: var V3ChengNodeOracleDomain,
                                     text: str): Result[bool] =
    let hasFinalizedRes = v3ChengNodeDomainRequireBool(text, "has_finalized")
    if IsErr(hasFinalizedRes):
        return Err[bool](Error(hasFinalizedRes))
    let roundRes = v3ChengNodeDomainRequireInt64(text, "last_finalized_round_id")
    if IsErr(roundRes):
        return Err[bool](Error(roundRes))
    let heightRes = v3ChengNodeDomainRequireInt64(text, "last_finalized_height")
    if IsErr(heightRes):
        return Err[bool](Error(heightRes))
    let lastCommitRes = v3ChengNodeDomainRequireFixed32(text, "last_commit_app_hash")
    if IsErr(lastCommitRes):
        return Err[bool](Error(lastCommitRes))
    domain.machine.hasFinalized = Value(hasFinalizedRes)
    domain.machine.lastFinalizedRoundId = Value(roundRes)
    domain.machine.lastFinalizedHeight = Value(heightRes)
    domain.machine.lastCommitAppHash = Value(lastCommitRes)
    return Ok[bool](true)

fn V3ChengNodeOracleApplyPairText(domain: var V3ChengNodeOracleDomain,
                                  text: str): Result[bool] =
    let pairIdRes = v3ChengNodeDomainRequireInt32(text, "pair_id")
    if IsErr(pairIdRes):
        return Err[bool](Error(pairIdRes))
    let pairId = Value(pairIdRes)
    if !oracle_types.v3OraclePairValid(pairId):
        return Err[bool]("cheng_node oracle: invalid pair id")
    let historyCountRes = v3ChengNodeDomainRequireInt32(text, "history_count")
    if IsErr(historyCountRes):
        return Err[bool](Error(historyCountRes))
    let availableRes = v3ChengNodeDomainRequireBool(text, "available")
    if IsErr(availableRes):
        return Err[bool](Error(availableRes))
    var pairState = oracle_types.V3OraclePairState()
    var historyPos = 0
    while historyPos < Value(historyCountRes):
        let prefix = "history." + intToStr(historyPos)
        let roundRes = v3ChengNodeDomainRequireInt64(text, prefix + ".round_id")
        if IsErr(roundRes):
            return Err[bool](Error(roundRes))
        let priceRes = v3ChengNodeDomainRequireInt64(text, prefix + ".price_e8")
        if IsErr(priceRes):
            return Err[bool](Error(priceRes))
        oracle_bft.v3OracleBftPairStatePush(pairState, Value(roundRes), Value(priceRes))
        historyPos = historyPos + 1
    if !Value(availableRes):
        pairState = oracle_types.V3OraclePairState()
    domain.machine.pairStates[oracle_types.v3OraclePairIndex(pairId)] = pairState
    return Ok[bool](true)

fn V3ChengNodeOracleFinalizeFixtureRound(domain: var V3ChengNodeOracleDomain,
                                         roundId: int64): Result[oracle_bft.V3OracleBftBlockSummary] =
    if roundId <= int64(0):
        return Err[oracle_bft.V3OracleBftBlockSummary]("cheng_node oracle: invalid round")
    var batch = oracle_bft.V3OracleBftTxBatch()
    oracle_bft.v3OracleBftTxBatchAdd(batch, oracle_fixture.oracleSmokeBatch(roundId, 1))
    oracle_bft.v3OracleBftTxBatchAdd(batch, oracle_fixture.oracleSmokeBatch(roundId, 2))
    oracle_bft.v3OracleBftTxBatchAdd(batch, oracle_fixture.oracleSmokeBatch(roundId, 3))
    var summary = oracle_bft.v3OracleBftBlockSummaryZero(roundId)
    let timeHint = oracle_types.v3OracleRoundEndMs(roundId) + int64(1)
    let context = oracle_bft.v3OracleBftBlockContextMake(roundId,
                                                         0,
                                                         timeHint,
                                                         layout.FixedBytes32())
    oracle_bft.v3OracleBftStateMachineFinalizeBatchSummaryWithContext(domain.machine,
                                                                      context,
                                                                      batch,
                                                                      summary)
    if summary.finalizedRoundCount <= 0:
        return Err[oracle_bft.V3OracleBftBlockSummary]("cheng_node oracle: round not finalized")
    let _commit = oracle_bft.v3OracleBftStateMachineCommit(domain.machine)
    return Ok[oracle_bft.V3OracleBftBlockSummary](summary)

fn V3ChengNodeOracleLatestReportText(domain: V3ChengNodeOracleDomain,
                                     pairId: int32): Result[str] =
    let nowMs = oracle_types.v3OracleRoundEndMs(domain.machine.lastFinalizedRoundId) + int64(1)
    let latest = oracle_bft.v3OracleBftStateMachineQueryLatest(domain.machine, pairId, nowMs)
    if latest.code != oracle_bft.v3OracleBftCodeOk:
        return Err[str]("cheng_node oracle: latest unavailable")
    var out = ""
    out = did.v3DidStoreAppendLine(out, "pair_id", intToStr(pairId))
    out = did.v3DidStoreAppendLine(out, "pair_key", V3ChengNodeOraclePairKeyFromPairId(pairId))
    out = did.v3DidStoreAppendLine(out, "round_id", int64ToStr(latest.roundId))
    out = did.v3DidStoreAppendLine(out, "price_e8", int64ToStr(latest.priceE8))
    out = did.v3DidStoreAppendLine(out, "reporter_count", intToStr(latest.reporterCount))
    out = did.v3DidStoreAppendLine(out, "height", int64ToStr(latest.height))
    out = did.v3DidStoreAppendLine(out, "app_hash", layout.fixedBytes32Hex(latest.appHash))
    return Ok[str](out)

fn v3ChengNodeDilocoTrimJob(state: var diloco.V3DiLoCoState,
                            jobBundleCid: layout.FixedBytes32) =
    var nextJobs: diloco.V3DiLoCoJob[]
    nextJobs = []
    for i in 0..<state.jobs.len:
        if layout.fixedBytes32Equal(state.jobs[i].jobBundleCid, jobBundleCid):
            continue
        add(nextJobs, state.jobs[i])
    state.jobs = nextJobs
    var nextBarriers: diloco.V3DiLoCoBarrier[]
    nextBarriers = []
    for i in 0..<state.barriers.len:
        if layout.fixedBytes32Equal(state.barriers[i].jobBundleCid, jobBundleCid):
            continue
        add(nextBarriers, state.barriers[i])
    state.barriers = nextBarriers
    var nextDeltas: diloco.V3DiLoCoOuterDelta[]
    nextDeltas = []
    for i in 0..<state.deltas.len:
        if layout.fixedBytes32Equal(state.deltas[i].jobBundleCid, jobBundleCid):
            continue
        add(nextDeltas, state.deltas[i])
    state.deltas = nextDeltas
    var nextCommits: diloco.V3DiLoCoMergeCommit[]
    nextCommits = []
    for i in 0..<state.commits.len:
        if layout.fixedBytes32Equal(state.commits[i].jobBundleCid, jobBundleCid):
            continue
        add(nextCommits, state.commits[i])
    state.commits = nextCommits
    var nextVersions: diloco.V3DiLoCoGlobalVersion[]
    nextVersions = []
    for i in 0..<state.versions.len:
        if layout.fixedBytes32Equal(state.versions[i].jobBundleCid, jobBundleCid):
            continue
        add(nextVersions, state.versions[i])
    state.versions = nextVersions

fn v3ChengNodeDilocoTrimCohort(state: var diloco.V3DiLoCoState,
                               jobBundleCid: layout.FixedBytes32) =
    var next: diloco.V3DiLoCoCohort[]
    next = []
    for i in 0..<state.cohorts.len:
        if layout.fixedBytes32Equal(state.cohorts[i].jobBundleCid, jobBundleCid):
            continue
        add(next, state.cohorts[i])
    state.cohorts = next

fn v3ChengNodeDilocoTrimLease(state: var diloco.V3DiLoCoState,
                              jobBundleCid: layout.FixedBytes32,
                              peerId: libtypes.V3Libp2pPeerId) =
    var next: diloco.V3DiLoCoLease[]
    next = []
    for i in 0..<state.leases.len:
        if layout.fixedBytes32Equal(state.leases[i].jobBundleCid, jobBundleCid) &&
           libtypes.v3Libp2pPeerIdEqual(state.leases[i].peerId, peerId):
            continue
        add(next, state.leases[i])
    state.leases = next

fn V3ChengNodeDilocoDomainInit(): V3ChengNodeDilocoDomain =
    var out: V3ChengNodeDilocoDomain
    out.state = diloco.V3DiLoCoStateInit("cheng_node.diloco")
    return out

fn V3ChengNodeDilocoJobBundleCid(jobKey: str): layout.FixedBytes32 =
    let fixedRes = layout.fixedBytes32FromHex(jobKey)
    if IsOk(fixedRes):
        return Value(fixedRes)
    return v3ChengNodeDomainHashTextCid("cheng_node.diloco.job", jobKey)

fn V3ChengNodeDilocoPeerIdFromSeed(seed: str): libtypes.V3Libp2pPeerId =
    return peer_id.v3Libp2pPeerIdFromSeed("cheng_node.diloco.peer|" + seed)

fn V3ChengNodeDilocoPeerTextFromSeed(seed: str): str =
    return peer_id.v3Libp2pPeerIdText(V3ChengNodeDilocoPeerIdFromSeed(seed))

fn v3ChengNodeDilocoArtifactRef(jobBundleCid: layout.FixedBytes32,
                                tag: str): Result[diloco.V3DiLoCoArtifactRef] =
    var out = diloco.V3DiLoCoArtifactRef()
    let payloadText = "cheng_node.diloco.artifact|" + tag
    let res = diloco.V3DiLoCoArtifactRefFromBytesFill(out,
                                                      jobBundleCid,
                                                      bytesFromString(payloadText),
                                                      256,
                                                      tag)
    if IsErr(res):
        return Err[diloco.V3DiLoCoArtifactRef](Error(res))
    return Ok[diloco.V3DiLoCoArtifactRef](out)

fn v3ChengNodeDilocoCurrentDeltas(state: diloco.V3DiLoCoState,
                                  job: diloco.V3DiLoCoJob): diloco.V3DiLoCoOuterDelta[] =
    var out: diloco.V3DiLoCoOuterDelta[]
    out = []
    for i in 0..<state.deltas.len:
        let delta = state.deltas[i]
        if !layout.fixedBytes32Equal(delta.jobBundleCid, job.jobBundleCid):
            continue
        if !layout.fixedBytes32Equal(delta.baseVersionCid, job.currentGlobalVersionCid):
            continue
        if delta.outerStep != job.currentOuterStep:
            continue
        add(out, delta)
    return out

fn v3ChengNodeDilocoCurrentBarrier(state: diloco.V3DiLoCoState,
                                   job: diloco.V3DiLoCoJob,
                                   outBarrier: var diloco.V3DiLoCoBarrier): bool =
    let pos = diloco.V3DiLoCoBarrierPos(state,
                                        job.jobBundleCid,
                                        job.currentGlobalVersionCid,
                                        job.currentOuterStep)
    if pos < 0:
        outBarrier = diloco.V3DiLoCoBarrier()
        return false
    outBarrier = diloco.V3DiLoCoBarrier()
    diloco.V3DiLoCoBarrierCopyFill(outBarrier, state.barriers[pos])
    return true

fn v3ChengNodeDilocoCurrentCommit(state: diloco.V3DiLoCoState,
                                  job: diloco.V3DiLoCoJob,
                                  outCommit: var diloco.V3DiLoCoMergeCommit): bool =
    let pos = diloco.V3DiLoCoCommitPos(state,
                                       job.jobBundleCid,
                                       job.currentGlobalVersionCid,
                                       job.currentOuterStep)
    if pos < 0:
        outCommit = diloco.V3DiLoCoMergeCommit()
        return false
    outCommit = diloco.V3DiLoCoMergeCommit()
    diloco.V3DiLoCoMergeCommitCopyFill(outCommit, state.commits[pos])
    return true

fn V3ChengNodeDilocoJobStateText(domain: V3ChengNodeDilocoDomain,
                                 jobKey: str,
                                 jobBundleCid: layout.FixedBytes32): Result[str] =
    let jobPos = diloco.V3DiLoCoJobPos(domain.state, jobBundleCid)
    if jobPos < 0:
        return Err[str]("cheng_node diloco: job missing")
    let job = domain.state.jobs[jobPos]
    var status = diloco.V3DiLoCoStepStatus()
    let statusRes = diloco.V3DiLoCoFetchStepStatusFill(status, domain.state, jobBundleCid)
    if IsErr(statusRes):
        return Err[str](Error(statusRes))
    var lineage: diloco.V3DiLoCoGlobalVersion[]
    let lineageRes = diloco.V3DiLoCoFetchLineageFill(lineage, domain.state, jobBundleCid)
    if IsErr(lineageRes):
        return Err[str](Error(lineageRes))
    var barrier = diloco.V3DiLoCoBarrier()
    let hasBarrier = v3ChengNodeDilocoCurrentBarrier(domain.state, job, barrier)
    let deltas = v3ChengNodeDilocoCurrentDeltas(domain.state, job)
    var commit = diloco.V3DiLoCoMergeCommit()
    let hasCommit = v3ChengNodeDilocoCurrentCommit(domain.state, job, commit)
    var out = ""
    out = did.v3DidStoreAppendLine(out, "version", "1")
    out = did.v3DidStoreAppendLine(out, "kind", "diloco_job")
    out = did.v3DidStoreAppendLine(out, "job_key", jobKey)
    out = diloco_wire.V3DiLoCoWireAppendJob(out, "job", job)
    out = diloco_wire.V3DiLoCoWireAppendStepStatus(out, "status", status)
    out = diloco_wire.V3DiLoCoWireAppendGlobalVersionArray(out, "versions", lineage)
    out = did.v3DidStoreAppendLine(out, "barrier_present", v3ChengNodeDomainBoolText(hasBarrier))
    if hasBarrier:
        out = diloco_wire.V3DiLoCoWireAppendBarrier(out, "barrier", barrier)
    out = did.v3DidStoreAppendLine(out, "delta_count", intToStr(deltas.len))
    for i in 0..<deltas.len:
        out = diloco_wire.V3DiLoCoWireAppendOuterDelta(out, "delta." + intToStr(i), deltas[i])
    out = did.v3DidStoreAppendLine(out, "commit_present", v3ChengNodeDomainBoolText(hasCommit))
    if hasCommit:
        out = diloco_wire.V3DiLoCoWireAppendMergeCommit(out, "commit", commit)
    return Ok[str](out)

fn V3ChengNodeDilocoCohortStateText(jobKey: str,
                                    cohort: diloco.V3DiLoCoCohort): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out, "version", "1")
    out = did.v3DidStoreAppendLine(out, "kind", "diloco_cohort")
    out = did.v3DidStoreAppendLine(out, "job_key", jobKey)
    out = diloco_wire.V3DiLoCoWireAppendCohort(out, "cohort", cohort)
    return out

fn V3ChengNodeDilocoLeaseStateText(jobKey: str,
                                   leaseKey: str,
                                   lease: diloco.V3DiLoCoLease): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out, "version", "1")
    out = did.v3DidStoreAppendLine(out, "kind", "diloco_lease")
    out = did.v3DidStoreAppendLine(out, "job_key", jobKey)
    out = did.v3DidStoreAppendLine(out, "lease_key", leaseKey)
    out = diloco_wire.V3DiLoCoWireAppendLease(out, "lease", lease)
    return out

fn V3ChengNodeDilocoApplyJobText(domain: var V3ChengNodeDilocoDomain,
                                 text: str): Result[bool] =
    var job = diloco.V3DiLoCoJob()
    let jobRes = diloco_wire.V3DiLoCoWireParseJobFill(job, text, "job")
    if IsErr(jobRes):
        return Err[bool](Error(jobRes))
    var lineage: diloco.V3DiLoCoGlobalVersion[]
    let lineageRes = diloco_wire.V3DiLoCoWireParseGlobalVersionArrayFill(lineage, text, "versions")
    if IsErr(lineageRes):
        return Err[bool](Error(lineageRes))
    let barrierPresentRes = v3ChengNodeDomainRequireBool(text, "barrier_present")
    if IsErr(barrierPresentRes):
        return Err[bool](Error(barrierPresentRes))
    var barrier = diloco.V3DiLoCoBarrier()
    if Value(barrierPresentRes):
        let barrierRes = diloco_wire.V3DiLoCoWireParseBarrierFill(barrier, text, "barrier")
        if IsErr(barrierRes):
            return Err[bool](Error(barrierRes))
    let deltaCountRes = v3ChengNodeDomainRequireInt32(text, "delta_count")
    if IsErr(deltaCountRes):
        return Err[bool](Error(deltaCountRes))
    var deltas: diloco.V3DiLoCoOuterDelta[]
    deltas = []
    var deltaIndex = 0
    while deltaIndex < Value(deltaCountRes):
        add(deltas, diloco.V3DiLoCoOuterDelta())
        let deltaRes = diloco_wire.V3DiLoCoWireParseOuterDeltaFill(deltas[deltas.len - 1],
                                                                   text,
                                                                   "delta." + intToStr(deltaIndex))
        if IsErr(deltaRes):
            return Err[bool](Error(deltaRes))
        deltaIndex = deltaIndex + 1
    let commitPresentRes = v3ChengNodeDomainRequireBool(text, "commit_present")
    if IsErr(commitPresentRes):
        return Err[bool](Error(commitPresentRes))
    var commit = diloco.V3DiLoCoMergeCommit()
    if Value(commitPresentRes):
        let commitRes = diloco_wire.V3DiLoCoWireParseMergeCommitFill(commit, text, "commit")
        if IsErr(commitRes):
            return Err[bool](Error(commitRes))
    v3ChengNodeDilocoTrimJob(domain.state, job.jobBundleCid)
    add(domain.state.jobs, job)
    for i in 0..<lineage.len:
        add(domain.state.versions, lineage[i])
    if Value(barrierPresentRes):
        add(domain.state.barriers, barrier)
    for i in 0..<deltas.len:
        add(domain.state.deltas, deltas[i])
    if Value(commitPresentRes):
        add(domain.state.commits, commit)
    return Ok[bool](true)

fn V3ChengNodeDilocoApplyCohortText(domain: var V3ChengNodeDilocoDomain,
                                    text: str): Result[bool] =
    var cohort = diloco.V3DiLoCoCohort()
    let cohortRes = diloco_wire.V3DiLoCoWireParseCohortFill(cohort, text, "cohort")
    if IsErr(cohortRes):
        return Err[bool](Error(cohortRes))
    v3ChengNodeDilocoTrimCohort(domain.state, cohort.jobBundleCid)
    add(domain.state.cohorts, cohort)
    return Ok[bool](true)

fn V3ChengNodeDilocoApplyLeaseText(domain: var V3ChengNodeDilocoDomain,
                                   text: str): Result[bool] =
    var lease = diloco.V3DiLoCoLease()
    let leaseRes = diloco_wire.V3DiLoCoWireParseLeaseFill(lease, text, "lease")
    if IsErr(leaseRes):
        return Err[bool](Error(leaseRes))
    v3ChengNodeDilocoTrimLease(domain.state, lease.jobBundleCid, lease.peerId)
    add(domain.state.leases, lease)
    return Ok[bool](true)

fn V3ChengNodeDilocoStatusReportText(domain: V3ChengNodeDilocoDomain,
                                     jobKey: str): Result[str] =
    let jobBundleCid = V3ChengNodeDilocoJobBundleCid(jobKey)
    let jobPos = diloco.V3DiLoCoJobPos(domain.state, jobBundleCid)
    if jobPos < 0:
        return Err[str]("cheng_node diloco: job missing")
    var status = diloco.V3DiLoCoStepStatus()
    let statusRes = diloco.V3DiLoCoFetchStepStatusFill(status, domain.state, jobBundleCid)
    if IsErr(statusRes):
        return Err[str](Error(statusRes))
    var version = diloco.V3DiLoCoGlobalVersion()
    let versionRes = diloco.V3DiLoCoFetchGlobalVersionFill(version, domain.state, jobBundleCid)
    if IsErr(versionRes):
        return Err[str](Error(versionRes))
    var lineage: diloco.V3DiLoCoGlobalVersion[]
    let lineageRes = diloco.V3DiLoCoFetchLineageFill(lineage, domain.state, jobBundleCid)
    if IsErr(lineageRes):
        return Err[str](Error(lineageRes))
    var out = ""
    out = did.v3DidStoreAppendLine(out, "job_key", jobKey)
    out = did.v3DidStoreAppendLine(out, "job_bundle_cid", layout.fixedBytes32Hex(jobBundleCid))
    out = diloco_wire.V3DiLoCoWireAppendJob(out, "job", domain.state.jobs[jobPos])
    out = diloco_wire.V3DiLoCoWireAppendStepStatus(out, "status", status)
    out = diloco_wire.V3DiLoCoWireAppendGlobalVersion(out, "current_version", version)
    out = diloco_wire.V3DiLoCoWireAppendGlobalVersionArray(out, "lineage", lineage)
    out = did.v3DidStoreAppendLine(out, "cohort_count", intToStr(domain.state.cohorts.len))
    out = did.v3DidStoreAppendLine(out, "lease_count", intToStr(domain.state.leases.len))
    return Ok[str](out)

fn V3ChengNodeEvoMapDomainInit(): V3ChengNodeEvoMapDomain =
    var out: V3ChengNodeEvoMapDomain
    out.agentKeys = []
    out.agents = []
    out.taskKeys = []
    out.tasks = []
    out.capsuleKeys = []
    out.capsules = []
    return out

fn v3ChengNodeEvoMapHeadCid(domain: V3ChengNodeEvoMapDomain): layout.FixedBytes32 =
    if domain.capsules.len <= 0:
        return layout.FixedBytes32()
    return evotypes.v3UnimakerGraphHeadCid(domain.capsules)

fn v3ChengNodeEvoMapMaxSequence(domain: V3ChengNodeEvoMapDomain): int32 =
    var out = 0
    for i in 0..<domain.capsules.len:
        if domain.capsules[i].sequence > out:
            out = domain.capsules[i].sequence
    return out

fn v3ChengNodeEvoMapIdentity(evomapKey: layout.FixedBytes32,
                             didText: str,
                             peerText: str,
                             deviceLabel: str): evotypes.V3AgentIdentity =
    var out = evotypes.V3AgentIdentity()
    out.didText = v3ChengNodeDomainOwnText(didText)
    out.peerIdText = v3ChengNodeDomainOwnText(peerText)
    out.deviceLabel = v3ChengNodeDomainOwnText(deviceLabel)
    let keyHex = layout.fixedBytes32Hex(evomapKey)
    out.signatureCid = evotypes.v3UnimakerHashText("v3.cheng_node.evomap.signature",
                                                   [keyHex,
                                                    out.didText,
                                                    out.peerIdText,
                                                    out.deviceLabel])
    out.identityCid = evotypes.v3UnimakerHashText("v3.unimaker.identity",
                                                  [out.didText,
                                                   out.peerIdText,
                                                   out.deviceLabel,
                                                   layout.fixedBytes32Hex(out.signatureCid)])
    return out

fn v3ChengNodeEvoMapAgentPos(domain: V3ChengNodeEvoMapDomain,
                             keyText: str): int32 =
    for i in 0..<domain.agentKeys.len:
        if domain.agentKeys[i] == keyText:
            return i
    return -1

fn v3ChengNodeEvoMapTaskPos(domain: V3ChengNodeEvoMapDomain,
                            keyText: str): int32 =
    for i in 0..<domain.taskKeys.len:
        if domain.taskKeys[i] == keyText:
            return i
    return -1

fn v3ChengNodeEvoMapCapsulePos(domain: V3ChengNodeEvoMapDomain,
                               keyText: str): int32 =
    for i in 0..<domain.capsuleKeys.len:
        if domain.capsuleKeys[i] == keyText:
            return i
    return -1

fn V3ChengNodeEvoMapAgentText(hello: evo.V3EvoMapA2AHello): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out, "version", "1")
    out = did.v3DidStoreAppendLine(out, "kind", "evomap_agent")
    out = did.v3DidStoreAppendLine(out, "peer_key", hello.identity.peerIdText)
    out = did.v3DidStoreAppendLine(out, "payload_json", evo.v3UnimakerProtocolEncodeHello(hello))
    return out

fn V3ChengNodeEvoMapTaskText(taskValue: evo.V3EvoMapA2ATask): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out, "version", "1")
    out = did.v3DidStoreAppendLine(out, "kind", "evomap_task")
    out = did.v3DidStoreAppendLine(out, "task_key", taskValue.task.taskId)
    out = did.v3DidStoreAppendLine(out, "payload_json", evo.v3UnimakerProtocolEncodeTask(taskValue))
    return out

fn V3ChengNodeEvoMapCapsuleText(capsule: evotypes.V3EvoCapsule): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out, "version", "1")
    out = did.v3DidStoreAppendLine(out, "kind", "evomap_capsule")
    out = did.v3DidStoreAppendLine(out, "capsule_key", layout.fixedBytes32Hex(capsule.capsuleCid))
    out = did.v3DidStoreAppendLine(out, "payload_json", evo.v3UnimakerProtocolEncodeCapsuleNode(capsule))
    return out

fn V3ChengNodeEvoMapApplyAgentText(domain: var V3ChengNodeEvoMapDomain,
                                   text: str): Result[bool] =
    let payloadRes = v3ChengNodeDomainRequireText(text, "payload_json")
    if IsErr(payloadRes):
        return Err[bool](Error(payloadRes))
    let helloRes = evo.v3UnimakerProtocolDecodeHello(Value(payloadRes))
    if IsErr(helloRes):
        return Err[bool](Error(helloRes))
    let hello = Value(helloRes)
    let pos = v3ChengNodeEvoMapAgentPos(domain, hello.identity.peerIdText)
    if pos >= 0:
        domain.agents[pos] = hello
    else:
        add(domain.agentKeys, v3ChengNodeDomainOwnText(hello.identity.peerIdText))
        add(domain.agents, hello)
    return Ok[bool](true)

fn V3ChengNodeEvoMapApplyTaskText(domain: var V3ChengNodeEvoMapDomain,
                                  text: str): Result[bool] =
    let payloadRes = v3ChengNodeDomainRequireText(text, "payload_json")
    if IsErr(payloadRes):
        return Err[bool](Error(payloadRes))
    let taskRes = evo.v3UnimakerProtocolDecodeTask(Value(payloadRes))
    if IsErr(taskRes):
        return Err[bool](Error(taskRes))
    let taskValue = Value(taskRes)
    let pos = v3ChengNodeEvoMapTaskPos(domain, taskValue.task.taskId)
    if pos >= 0:
        domain.tasks[pos] = taskValue
    else:
        add(domain.taskKeys, v3ChengNodeDomainOwnText(taskValue.task.taskId))
        add(domain.tasks, taskValue)
    return Ok[bool](true)

fn V3ChengNodeEvoMapApplyCapsuleText(domain: var V3ChengNodeEvoMapDomain,
                                     text: str): Result[bool] =
    let payloadRes = v3ChengNodeDomainRequireText(text, "payload_json")
    if IsErr(payloadRes):
        return Err[bool](Error(payloadRes))
    let nodeRes = evo.v3UnimakerProtocolParseText(Value(payloadRes))
    if IsErr(nodeRes):
        return Err[bool](Error(nodeRes))
    let capsuleRes = evo.v3UnimakerProtocolDecodeCapsuleNode(Value(nodeRes))
    if IsErr(capsuleRes):
        return Err[bool](Error(capsuleRes))
    let capsule = Value(capsuleRes)
    let keyText = layout.fixedBytes32Hex(capsule.capsuleCid)
    let pos = v3ChengNodeEvoMapCapsulePos(domain, keyText)
    if pos >= 0:
        domain.capsules[pos] = capsule
    else:
        add(domain.capsuleKeys, v3ChengNodeDomainOwnText(keyText))
        add(domain.capsules, capsule)
    return Ok[bool](true)

fn V3ChengNodeEvoMapStatusReportText(domain: V3ChengNodeEvoMapDomain): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out, "agent_count", intToStr(domain.agents.len))
    out = did.v3DidStoreAppendLine(out, "task_count", intToStr(domain.tasks.len))
    out = did.v3DidStoreAppendLine(out, "capsule_count", intToStr(domain.capsules.len))
    out = did.v3DidStoreAppendLine(out, "head_cid", layout.fixedBytes32Hex(v3ChengNodeEvoMapHeadCid(domain)))
    out = did.v3DidStoreAppendLine(out, "next_sequence", intToStr(v3ChengNodeEvoMapMaxSequence(domain) + 1))
    return out
