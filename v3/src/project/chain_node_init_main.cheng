import std/system
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node init main: init server")
    var client: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(client, "node-b", "chain-node-b")),
           "v3 chain_node init main: init client")
    assert(server.nextEpoch >= 1, "v3 chain_node init main: server epoch")
    assert(client.nextEpoch >= 1, "v3 chain_node init main: client epoch")
    echo("v3 chain_node_init_main ok")
    return 0
