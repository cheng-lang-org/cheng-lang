import std/system
import cheng/v3/project/chain_node as node

fn main(): int32 =
    let server = node.v3ChainNodeInit("node-a", "chain-node-a")
    let client = node.v3ChainNodeInit("node-b", "chain-node-b")
    assert(server.nextEpoch >= 1, "v3 chain_node init main: server epoch")
    assert(client.nextEpoch >= 1, "v3 chain_node init main: client epoch")
    echo("v3 chain_node_init_main ok")
    return 0
