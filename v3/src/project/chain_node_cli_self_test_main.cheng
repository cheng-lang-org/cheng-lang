import std/cmdline as cmdline
import cheng/v3/project/chain_node_cli_core as cli

fn v3ChainNodeCliSelfTestCommand(): int32 =
    return cli.V3ChainNodeCmdSelfTestMain()

fn V3ChainNodeCliSelfTestCommand(): int32 =
    return v3ChainNodeCliSelfTestCommand()

fn main(argc: int32, argv: str*): int32 =
    cmdline.CaptureCmdLine(argc, argv)
    return v3ChainNodeCliSelfTestCommand()
