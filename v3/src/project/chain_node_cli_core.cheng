fn v3ChainNodeCmdShowStateMain(): int32 =
    return v3ChainNodeCmdShowStateRun(v3ChainNodeCliReadFlag("--state", ""))

fn v3ChainNodeCmdDumpSnapshotRun(statePath: str): int32 =
    var stateMissing = v3ChainNodeCliTextEmpty(statePath)
    if stateMissing:
        echo("v3 chain_node: missing --state")
        return 2
    let text = v3path.v3ReadTextFile(v3ChainNodeCliCurrentDir(), statePath)
    if len(text) <= 0:
        echo("v3 chain_node: missing or empty state file: " +
             v3ChainNodeCliAbsolutePath(statePath))
        return 2
    echo(text)
    return 0

fn v3ChainNodeCmdDumpSnapshotMain(): int32 =
    return v3ChainNodeCmdDumpSnapshotRun(v3ChainNodeCliReadFlag("--state", ""))

fn v3ChainNodeCmdServeOnceRun(statePath: str): int32 =
    var stateMissing = v3ChainNodeCliTextEmpty(statePath)
    if stateMissing:
        echo("v3 chain_node: missing --state")
        return 2
    let loadRes = v3ChainNodeCliLoadState(statePath)
    if IsErr(loadRes):
        echo(Error(loadRes))
        return 2
    var state = Value(loadRes)
    let port = v3ChainNodeCliReadInt32FlagOrDefault("--port", 0)
    let hostText = v3ChainNodeCliReadFlag("--host", "127.0.0.1")
    let readyPath = v3ChainNodeCliReadFlag("--ready-path", "")
    let snapshot = node.v3ChainNodeServeOnce(state)
    let payload = net.v3ChainNodeLibp2pEncodeSnapshot(snapshot)
    let serveRes = tcp_transport.v3Libp2pTcpServePayloadOnce(hostText,
                                                             port,
                                                             types.v3Libp2pProtocolSync,
                                                             payload,
                                                             readyPath)
    if !serveRes.ok:
        echo(serveRes.error)
        return 2
    if !v3ChainNodeCliWriteState(statePath, snapshot):
        echo("v3 chain_node: failed to persist state: " +
             v3ChainNodeCliAbsolutePath(statePath))
        return 2
    echo(v3ChainNodeCliSnapshotReport(snapshot))
    return 0

fn v3ChainNodeCmdServeOnceMain(): int32 =
    return v3ChainNodeCmdServeOnceRun(v3ChainNodeCliReadFlag("--state", ""))

fn v3ChainNodeCmdSyncOnceRun(statePath: str): int32 =
    var stateMissing = v3ChainNodeCliTextEmpty(statePath)
    if stateMissing:
        echo("v3 chain_node: missing --state")
        return 2
    let loadRes = v3ChainNodeCliLoadOrInitForSync(statePath)
    if IsErr(loadRes):
        echo(Error(loadRes))
        return 2
    var state = Value(loadRes)
    let hostText = v3ChainNodeCliReadFlag("--host", "127.0.0.1")
    let port = v3ChainNodeCliReadInt32FlagOrDefault("--port", -1)
    if port <= 0:
        echo("v3 chain_node: sync-once requires --port")
        return 2
    let payloadRes = tcp_transport.v3Libp2pTcpRecvPayloadOnce(hostText,
                                                              port,
                                                              types.v3Libp2pProtocolSync)
    if !payloadRes.ok:
        echo(payloadRes.error)
        return 2
    let snapshotRes = net.v3ChainNodeLibp2pDecodeSnapshot(payloadRes.value)
    if IsErr(snapshotRes):
        echo(Error(snapshotRes))
        return 2
    let syncRes = node.v3ChainNodeSyncOnce(state, Value(snapshotRes))
    if IsErr(syncRes):
        echo(Error(syncRes))
        return 2
    let snapshot = node.v3ChainNodeServeOnce(state)
    if !v3ChainNodeCliWriteState(statePath, snapshot):
        echo("v3 chain_node: failed to persist state: " +
             v3ChainNodeCliAbsolutePath(statePath))
        return 2
    if Value(syncRes):
        echo("changed=1")
    else:
        echo("changed=0")
    echo(v3ChainNodeCliSnapshotReport(snapshot))
    return 0

fn v3ChainNodeCmdSyncOnceMain(): int32 =
    return v3ChainNodeCmdSyncOnceRun(v3ChainNodeCliReadFlag("--state", ""))
