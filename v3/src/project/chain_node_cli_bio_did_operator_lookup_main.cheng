import std/cmdline as cmdline
import std/result
import cheng/v3/project/chain_node_cli_core as cli

fn v3ChainNodeCliBioDidOperatorLookupCommand(): int32 =
    var stateRaw = ""
    stateRaw = cli.V3ChainNodeCliReadFlag("--state", "")
    var statePath = ""
    let statePathReq = cli.V3ChainNodeCliRequireTextInto(statePath, stateRaw, "--state")
    if IsErr(statePathReq):
        let errText: str = Error(statePathReq)
        cli.V3ChainNodeCliPrintErr(errText)
        return 2
    var operatorRaw = ""
    operatorRaw = cli.V3ChainNodeCliReadFlag("--operator-id", "")
    var operatorId = ""
    let operatorIdReq = cli.V3ChainNodeCliRequireTextInto(operatorId, operatorRaw, "--operator-id")
    if IsErr(operatorIdReq):
        let errText: str = Error(operatorIdReq)
        cli.V3ChainNodeCliPrintErr(errText)
        return 2
    var preferredKinds: str[]
    preferredKinds = []
    let preferredKindsText = cli.V3ChainNodeCliReadFlag("--preferred-kinds", "")
    cli.V3ChainNodeCliAppendCsvKinds(preferredKinds, preferredKindsText)
    let lookupRes = cli.V3ChainNodeCliBioDidOperatorLookupJsonWithKinds(statePath,
                                                                        operatorId,
                                                                        preferredKinds)
    if IsErr(lookupRes):
        let errText: str = Error(lookupRes)
        cli.V3ChainNodeCliPrintErr(errText)
        return 2
    let lookupText = Value(lookupRes)
    cli.V3ChainNodeCliPrintBlock(lookupText)
    return 0

fn V3ChainNodeCliBioDidOperatorLookupCommand(): int32 =
    return v3ChainNodeCliBioDidOperatorLookupCommand()

fn main(argc: int32, argv: str*): int32 =
    cmdline.CaptureCmdLine(argc, argv)
    return v3ChainNodeCliBioDidOperatorLookupCommand()
