import std/result
import std/rawbytes
import std/times
import cheng/v3/chain/erasure_swarm as swarm
import cheng/v3/chain/content_plane as content
import cheng/v3/chain/content_runtime as runtime
import cheng/v3/chain/content_runtime_host as runtime_host
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peerstore as ps
import cheng/v3/libp2p/core/scheduler
import cheng/v3/libp2p/host/host as host_base
import cheng/v3/project/tailnet_train_island as island

fn v3TailnetTrainIslandPeerIdListContains(peerIds: types.V3Libp2pPeerId[],
                                          peerId: types.V3Libp2pPeerId): bool =
    for i in 0..<peerIds.len:
        if types.v3Libp2pPeerIdEqual(peerIds[i], peerId):
            return true
    return false

fn v3TailnetTrainIslandCandidateInsert(peerIds: var types.V3Libp2pPeerId[],
                                       endpoints: var ps.V3Libp2pPeerEndpoint[],
                                       scores: var scheduler.V3Libp2pPlacementScore[],
                                       request: scheduler.V3Libp2pWorkloadRequest,
                                       maxCount: int32,
                                       peerId: types.V3Libp2pPeerId,
                                       endpoint: ps.V3Libp2pPeerEndpoint,
                                       score: scheduler.V3Libp2pPlacementScore) =
    if maxCount <= 0 || v3TailnetTrainIslandPeerIdListContains(peerIds, peerId):
        return
    var insertPos = peerIds.len
    for i in 0..<peerIds.len:
        if scheduler.v3Libp2pPlacementScoreBetter(score,
                                                  scores[i],
                                                  request,
                                                  peerId,
                                                  peerIds[i]):
            insertPos = i
            break
    if peerIds.len >= maxCount && insertPos >= maxCount:
        return
    if peerIds.len < maxCount:
        add(peerIds, types.v3Libp2pPeerIdZero())
        add(endpoints, ps.v3Libp2pPeerEndpointZero())
        add(scores, scheduler.v3Libp2pPlacementScoreZero())
        var i = peerIds.len - 1
        while i > insertPos:
            peerIds[i] = peerIds[i - 1]
            endpoints[i] = ps.v3Libp2pPeerEndpointClone(endpoints[i - 1])
            scores[i] = scores[i - 1]
            i = i - 1
    else:
        var i = peerIds.len - 1
        while i > insertPos:
            peerIds[i] = peerIds[i - 1]
            endpoints[i] = ps.v3Libp2pPeerEndpointClone(endpoints[i - 1])
            scores[i] = scores[i - 1]
            i = i - 1
    peerIds[insertPos] = peerId
    endpoints[insertPos] = ps.v3Libp2pPeerEndpointClone(endpoint)
    scores[insertPos] = score

fn v3TailnetTrainIslandWorkerEndpointEligible(endpoint: ps.V3Libp2pPeerEndpoint,
                                              trustedOnly: bool): bool =
    if endpoint.addr.networkDomain != types.v3Libp2pNetworkDomainTailnet:
        return false
    if trustedOnly && endpoint.addr.visibility != types.v3Libp2pVisibilityTrustedOnly:
        return false
    return true

fn v3TailnetTrainIslandBuildWorkerGroup(out: var island.V3TailnetTrainWorkerGroup,
                                        trainIsland: island.V3TailnetTrainIsland,
                                        hostState: host_base.V3Libp2pHost,
                                        rendezvous: island.V3TailnetTrainRendezvous): Result[bool] =
    if trainIsland.trustedOnly && !hostState.trustedInfra:
        return Err[bool]("v3 tailnet train island: coordinator trusted infra missing")
    var selectedPeerIds: types.V3Libp2pPeerId[]
    var selectedEndpoints: ps.V3Libp2pPeerEndpoint[]
    var selectedScores: scheduler.V3Libp2pPlacementScore[]
    selectedPeerIds = []
    selectedEndpoints = []
    selectedScores = []
    for i in 0..<hostState.peers.peers.len:
        let record = hostState.peers.peers[i]
        let trustedView = host_base.v3Libp2pHostTrustedView(hostState, record)
        var score = scheduler.v3Libp2pPlacementScoreZero()
        if !scheduler.v3Libp2pPeerPlacementScoreFill(score, record, trustedView, rendezvous.workload):
            continue
        var endpoint = ps.v3Libp2pPeerEndpointZero()
        if !ps.v3Libp2pPeerRecordSelectEndpoint(record, trustedView, endpoint):
            continue
        if !v3TailnetTrainIslandWorkerEndpointEligible(endpoint, trainIsland.trustedOnly):
            continue
        v3TailnetTrainIslandCandidateInsert(selectedPeerIds,
                                            selectedEndpoints,
                                            selectedScores,
                                            rendezvous.workload,
                                            rendezvous.requestedWorkerCount,
                                            record.peerId,
                                            endpoint,
                                            score)
    if selectedPeerIds.len != rendezvous.requestedWorkerCount:
        return Err[bool]("v3 tailnet train island: worker group incomplete")
    out = island.v3TailnetTrainWorkerGroupZero()
    out.rendezvousCid = rendezvous.rendezvousCid
    out.leaderPeerId = selectedPeerIds[0]
    let now = times.EpochTimeSeconds()
    for i in 0..<selectedPeerIds.len:
        var member = island.v3TailnetTrainWorkerMemberZero()
        member.peerId = selectedPeerIds[i]
        member.endpoint = ps.v3Libp2pPeerEndpointClone(selectedEndpoints[i])
        if i == 0:
            member.roleKind = island.v3TailnetTrainRoleLeader
        else:
            member.roleKind = island.v3TailnetTrainRoleWorker
        let pos = ps.v3Libp2pPeerstorePos(hostState.peers, selectedPeerIds[i])
        if pos >= 0:
            member.sampledAtEpochSeconds = hostState.peers.peers[pos].resources.sampledAtEpochSeconds
        member.joinedAtEpochSeconds = now
        add(out.members, member)
    out.memberCount = out.members.len
    return Ok[bool](true)

fn v3TailnetTrainIslandVersionStub(version: island.V3TailnetCheckpointVersion): content.V3ContentStub =
    var stub = content.v3ContentStubZero()
    stub.version = 1
    stub.bundleCid = version.jobBundleCid
    stub.blobSummaryCid = version.blobSummaryCid
    stub.manifestCid = version.manifestCid
    stub.payloadLen = version.payloadLen
    stub.stubCid = version.stubCid
    return stub

fn v3TailnetTrainIslandVersionParams(version: island.V3TailnetCheckpointVersion): swarm.V3ErasureEncodingParams =
    var params = swarm.v3ErasureEncodingParamsZero()
    params.version = 1
    params.layoutKind = version.layoutKind
    params.dataShardCount = version.dataShardCount
    params.parityShardCount = version.parityShardCount
    params.shardPayloadBytes = version.shardPayloadBytes
    params.paramsCid = version.paramsCid
    return params

fn v3TailnetTrainIslandFetchCheckpointManifestFill(out: var swarm.V3ErasureShardManifest,
                                                   localHost: var host_base.V3Libp2pHost,
                                                   remoteHost: var host_base.V3Libp2pHost,
                                                   remotePeerId: types.V3Libp2pPeerId,
                                                   remoteRuntime: var runtime.V3ContentRuntime,
                                                   version: island.V3TailnetCheckpointVersion): Result[bool] =
    let stub = v3TailnetTrainIslandVersionStub(version)
    return runtime_host.v3ContentRuntimeRequestManifestFill(out,
                                                            localHost,
                                                            remoteHost,
                                                            remotePeerId,
                                                            remoteRuntime,
                                                            stub)

fn v3TailnetTrainIslandFetchCheckpointShards(out: var swarm.V3ErasureShardPullResponse[],
                                             localHost: var host_base.V3Libp2pHost,
                                             remoteHost: var host_base.V3Libp2pHost,
                                             remotePeerId: types.V3Libp2pPeerId,
                                             remoteRuntime: var runtime.V3ContentRuntime,
                                             manifest: swarm.V3ErasureShardManifest): Result[bool] =
    out = []
    for i in 0..<manifest.shardCount:
        let requestRes = swarm.v3ErasureShardPullRequestMake(manifest, manifest.shardIndices[i])
        if IsErr(requestRes):
            return Err[bool](Error(requestRes))
        let pullRes = runtime_host.v3ContentRuntimeRequestShardPull(localHost,
                                                                    remoteHost,
                                                                    remotePeerId,
                                                                    remoteRuntime,
                                                                    Value(requestRes))
        if IsErr(pullRes):
            return Err[bool](Error(pullRes))
        add(out, Value(pullRes))
    return Ok[bool](true)

fn v3TailnetTrainIslandRebuildCheckpoint(version: island.V3TailnetCheckpointVersion,
                                         manifest: swarm.V3ErasureShardManifest,
                                         responses: swarm.V3ErasureShardPullResponse[]): Result[Bytes] =
    let stub = v3TailnetTrainIslandVersionStub(version)
    let params = v3TailnetTrainIslandVersionParams(version)
    return runtime.v3ContentRuntimeRebuildBlobAgainstStub(stub,
                                                          manifest,
                                                          params,
                                                          responses)

fn v3TailnetTrainIslandShardResponsePos(responses: swarm.V3ErasureShardPullResponse[],
                                        shardIndex: int32): int32 =
    for i in 0..<responses.len:
        if responses[i].shardIndex == shardIndex:
            return i
    return -1

fn v3TailnetTrainIslandAssembleSystematicCheckpointFill(out: var Bytes,
                                                        manifest: swarm.V3ErasureShardManifest,
                                                        params: swarm.V3ErasureEncodingParams,
                                                        responses: swarm.V3ErasureShardPullResponse[]): Result[bool] =
    let manifestOk = swarm.v3ErasureManifestValidate(manifest, params)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    if params.layoutKind != swarm.v3ErasureLayoutRsSystematic:
        return Err[bool]("v3 tailnet train island: checkpoint assemble layout")
    if params.parityShardCount != 0:
        return Err[bool]("v3 tailnet train island: checkpoint assemble parity")
    out = bytesAlloc(manifest.blobByteLen)
    var next = 0
    for shardIndex in 0..<params.dataShardCount:
        let responsePos = v3TailnetTrainIslandShardResponsePos(responses, shardIndex)
        if responsePos < 0:
            return Err[bool]("v3 tailnet train island: checkpoint assemble shard missing")
        let response = responses[responsePos]
        let requestRes = swarm.v3ErasureShardPullRequestMake(manifest, shardIndex)
        if IsErr(requestRes):
            return Err[bool](Error(requestRes))
        let responseOk = swarm.v3ErasureShardPullResponseValidate(response, Value(requestRes))
        if IsErr(responseOk):
            return Err[bool](Error(responseOk))
        for i in 0..<response.payloadLen:
            if next >= manifest.blobByteLen:
                break
            bytesSet(out, next, bytesGet(response.payload, i))
            next = next + 1
    if next != manifest.blobByteLen:
        return Err[bool]("v3 tailnet train island: checkpoint assemble short blob")
    return Ok[bool](true)

fn v3TailnetTrainIslandCheckpointBlobCachedFill(out: var Bytes,
                                                runtimeState: runtime.V3ContentRuntime,
                                                version: island.V3TailnetCheckpointVersion): bool =
    return runtime.v3ContentRuntimeCachedBlob(runtimeState, version.blobCid, out)

fn v3TailnetTrainIslandFetchCheckpointBlobFill(out: var Bytes,
                                               localHost: var host_base.V3Libp2pHost,
                                               remoteHost: var host_base.V3Libp2pHost,
                                               remotePeerId: types.V3Libp2pPeerId,
                                               remoteRuntime: var runtime.V3ContentRuntime,
                                               version: island.V3TailnetCheckpointVersion): Result[bool] =
    var manifest = swarm.v3ErasureShardManifestZero()
    let manifestRes = v3TailnetTrainIslandFetchCheckpointManifestFill(manifest,
                                                                      localHost,
                                                                      remoteHost,
                                                                      remotePeerId,
                                                                      remoteRuntime,
                                                                      version)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    var responses: swarm.V3ErasureShardPullResponse[]
    let responsesRes = v3TailnetTrainIslandFetchCheckpointShards(responses,
                                                                 localHost,
                                                                 remoteHost,
                                                                 remotePeerId,
                                                                 remoteRuntime,
                                                                 manifest)
    if IsErr(responsesRes):
        return Err[bool](Error(responsesRes))
    let params = v3TailnetTrainIslandVersionParams(version)
    if params.layoutKind == swarm.v3ErasureLayoutRsSystematic && params.parityShardCount == 0:
        let assembleRes = v3TailnetTrainIslandAssembleSystematicCheckpointFill(out,
                                                                               manifest,
                                                                               params,
                                                                               responses)
        if IsErr(assembleRes):
            return Err[bool](Error(assembleRes))
    else:
        let blobRes = v3TailnetTrainIslandRebuildCheckpoint(version, manifest, responses)
        if IsErr(blobRes):
            return Err[bool](Error(blobRes))
        out = Value(blobRes)
    return Ok[bool](true)
