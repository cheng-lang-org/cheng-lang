import std/result
import std/system as system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/project/cheng_node_map as cmap

type
    V3ChengNodeObjectEntry =
        cidHex: str
        objectKind: str
        text: str

    V3ChengNodeObjectStore =
        entryIndex: cmap.V3ChengNodeStrIntMap
        entries: V3ChengNodeObjectEntry[]

fn v3ChengNodeObjectOwnText(text: str): str =
    return system.SystemToStringStr(text)

fn V3ChengNodeObjectStoreInitInPlace(out: var V3ChengNodeObjectStore) =
    out.entries = []
    cmap.V3ChengNodeStrIntMapInitInPlace(out.entryIndex, 128)

fn V3ChengNodeObjectStorePut(store: var V3ChengNodeObjectStore,
                             payloadCid: layout.FixedBytes32,
                             objectKind: str,
                             text: str): Result[bool] =
    let cidHex = layout.fixedBytes32Hex(payloadCid)
    if len(cidHex) <= 0:
        return Err[bool]("cheng_node object: empty cid")
    var found = false
    let raw = cmap.V3ChengNodeStrIntMapGet(store.entryIndex, cidHex, found)
    if found && raw > 0:
        let slot = raw - 1
        store.entries[slot].objectKind = v3ChengNodeObjectOwnText(objectKind)
        store.entries[slot].text = v3ChengNodeObjectOwnText(text)
        return Ok[bool](false)
    let entry = V3ChengNodeObjectEntry(cidHex: v3ChengNodeObjectOwnText(cidHex),
                                       objectKind: v3ChengNodeObjectOwnText(objectKind),
                                       text: v3ChengNodeObjectOwnText(text))
    add(store.entries, entry)
    cmap.V3ChengNodeStrIntMapPut(store.entryIndex, cidHex, store.entries.len)
    return Ok[bool](true)

fn V3ChengNodeObjectStoreGet(store: V3ChengNodeObjectStore,
                             payloadCid: layout.FixedBytes32): Result[V3ChengNodeObjectEntry] =
    let cidHex = layout.fixedBytes32Hex(payloadCid)
    var found = false
    let raw = cmap.V3ChengNodeStrIntMapGet(store.entryIndex, cidHex, found)
    if !found || raw <= 0:
        return Err[V3ChengNodeObjectEntry]("cheng_node object: cid not found")
    return Ok[V3ChengNodeObjectEntry](store.entries[raw - 1])

fn V3ChengNodeObjectCount(store: V3ChengNodeObjectStore): int32 =
    return store.entries.len
