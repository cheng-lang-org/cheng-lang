const
    v3ChengNodeCtlChainStateMagic: str = "v3.chain_node.state.v1"

fn v3ChengNodeCtlRootSeed(): str =
    return cmdline.readFlagOrDefault("--root", "cheng_node.devroot")

fn v3ChengNodeCtlStatePath(): str =
    return cmdline.readFlagOrDefault("--state", "artifacts/cheng_node.state")

fn v3ChengNodeCtlOutPath(): str =
    return cmdline.readFlagOrDefault("--out", v3ChengNodeCtlStatePath())

fn v3ChengNodeCtlWithDelta(): bool =
    return cmdline.hasFlag("--with-delta")

fn v3ChengNodeCtlRemoteRootSeed(): str =
    return cmdline.readFlagOrDefault("--remote-root", v3ChengNodeCtlRootSeed())

fn v3ChengNodeCtlRequireTextFlag(flagName: str): Result[str] =
    let raw = cmdline.readFlagOrDefault(flagName, "")
    if len(raw) <= 0:
        return Err[str]("cheng_node: missing " + flagName)
    return Ok[str](raw)

fn v3ChengNodeCtlRequireInt32Flag(flagName: str): Result[int32] =
    let rawRes = v3ChengNodeCtlRequireTextFlag(flagName)
    if IsErr(rawRes):
        return Err[int32](Error(rawRes))
    let value = int32(parseInt(Value(rawRes)))
    if value <= 0:
        return Err[int32]("cheng_node: invalid positive int32 for " + flagName)
    return Ok[int32](value)

fn v3ChengNodeCtlRequireInt64Flag(flagName: str): Result[int64] =
    let rawRes = v3ChengNodeCtlRequireTextFlag(flagName)
    if IsErr(rawRes):
        return Err[int64](Error(rawRes))
    return Ok[int64](int64(parseInt(Value(rawRes))))

fn v3ChengNodeCtlFlagOrDefault(flagName: str,
                               defaultValue: str): str =
    return cmdline.readFlagOrDefault(flagName, defaultValue)

fn v3ChengNodeCtlWordAt(index: int32): str =
    let count = cmdline.ParamCount()
    if count < index:
        return ""
    let text = cmdline.ParamStr(index)
    if len(text) <= 0:
        return ""
    if text[0] == '-':
        return ""
    return text

fn v3ChengNodeCtlCsvValues(text: str): str[] =
    let raw = strutil.Strip(text)
    if len(raw) <= 0:
        return []
    var out: str[]
    out = []
    var token = ""
    var i = 0
    while i < len(raw):
        if raw[i] == ',':
            let value = strutil.Strip(token)
            if len(value) > 0:
                add(out, value)
            token = ""
            i = i + 1
            continue
        token = token + strings.SliceBytes(raw, i, 1)
        i = i + 1
    let tail = strutil.Strip(token)
    if len(tail) > 0:
        add(out, tail)
    return out

fn v3ChengNodeCtlCsvFixed32(text: str): Result[layout.FixedBytes32[]] =
    var out: layout.FixedBytes32[]
    out = []
    let values = v3ChengNodeCtlCsvValues(text)
    for i in 0..<values.len:
        let fixedRes = layout.fixedBytes32FromHex(values[i])
        if IsErr(fixedRes):
            return Err[layout.FixedBytes32[]](Error(fixedRes))
        add(out, Value(fixedRes))
    return Ok[layout.FixedBytes32[]](out)

fn v3ChengNodeCtlOptionalInt64Flag(flagName: str): Result[int64] =
    let raw = v3ChengNodeCtlFlagOrDefault(flagName, "")
    if len(raw) <= 0:
        return Ok[int64](int64(0))
    return Ok[int64](int64(parseInt(raw)))

fn v3ChengNodeCtlPathIsAbsolute(pathRaw: str): bool =
    let path = pathRaw
    if len(path) <= 0:
        return false
    if path[0] == '/':
        return true
    if len(path) > 1 && path[1] == char(58):
        return true
    return false

fn v3ChengNodeCtlAbsolutePath(pathRaw: str): str =
    let path = pathRaw
    if len(path) <= 0:
        return ""
    if v3ChengNodeCtlPathIsAbsolute(path):
        return path
    let cwd = os.GetCurrentDir()
    if len(cwd) <= 0:
        return path
    return os.JoinPath(cwd, path)

fn v3ChengNodeCtlReadRequiredTextFile(pathRaw: str): Result[str] =
    let path = v3ChengNodeCtlAbsolutePath(pathRaw)
    let text = os.ReadFile(path)
    if len(text) <= 0:
        return Err[str]("cheng_node: missing text file: " + path)
    return Ok[str](text)

fn v3ChengNodeCtlEnsureDir(pathRaw: str): bool =
    let path = strutil.Strip(pathRaw)
    if len(path) <= 0:
        return false
    if os.DirExists(path):
        return true
    let parent = os.ParentDir(path)
    if len(parent) > 0 && parent != path && !os.DirExists(parent):
        if !v3ChengNodeCtlEnsureDir(parent):
            return false
    if !os.DirExists(path):
        os.CreateDir(path)
    return os.DirExists(path)

fn v3ChengNodeCtlChainHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn v3ChengNodeCtlChainBytesFromHex(text: str): Result[Bytes] =
    if (len(text) % 2) != 0:
        return Err[Bytes]("cheng_node: invalid chain state hex length")
    var out: Bytes
    out = bytesAlloc(len(text) / 2)
    var i: int32
    while i < len(text):
        let hi = v3ChengNodeCtlChainHexValue(text[i])
        let lo = v3ChengNodeCtlChainHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes]("cheng_node: invalid chain state hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn v3ChengNodeCtlChainCloneText(text: str): str =
    if len(text) <= 0:
        return ""
    return newStringCopy(strDataPtr(text), strLenFast(text))

fn v3ChengNodeCtlChainWriteState(pathRaw: str,
                                 snapshot: chain.V3ChainNodeServeSnapshot): Result[str] =
    let path = v3ChengNodeCtlAbsolutePath(pathRaw)
    if len(path) <= 0:
        return Err[str]("cheng_node: invalid chain state path")
    let parent = os.ParentDir(path)
    if len(parent) > 0 && !v3ChengNodeCtlEnsureDir(parent):
        return Err[str]("cheng_node: failed to create chain state dir: " + parent)
    let payload = chainnet.V3ChainNodeLibp2pEncodeSnapshot(snapshot)
    let file = os.openImplWrite(path)
    if file == nil:
        return Err[str]("cheng_node: failed to open chain state for write: " + path)
    os.WriteLine(file, v3ChengNodeCtlChainStateMagic)
    os.WriteLine(file, "node_id=" + snapshot.nodeId)
    os.WriteLine(file, "payload_hex=" + bytesToHex(payload))
    os.Close(file)
    if !os.FileExists(path):
        return Err[str]("cheng_node: failed to persist chain state: " + path)
    return Ok[str](path)

fn v3ChengNodeCtlChainExtractStateText(text: str,
                                       outNodeId: var str,
                                       outPayloadHex: var str): bool =
    outNodeId = ""
    outPayloadHex = ""
    var phase: int32
    var start: int32
    var i: int32
    while i < len(text):
        if text[i] != '\n':
            i = i + 1
            continue
        let line = strutil.Strip(strings.SliceBytes(text, start, i - start))
        if len(line) <= 0:
            start = i + 1
            i = i + 1
            continue
        if phase == 0:
            if line != v3ChengNodeCtlChainStateMagic:
                return false
            phase = 1
        elif phase == 1:
            if len(line) <= 8 || strings.SliceBytes(line, 0, 8) != "node_id=":
                return false
            outNodeId = strutil.Strip(strings.SliceBytes(line, 8, len(line) - 8))
            phase = 2
        elif phase == 2:
            if len(line) <= 12 || strings.SliceBytes(line, 0, 12) != "payload_hex=":
                return false
            outPayloadHex = strutil.Strip(strings.SliceBytes(line, 12, len(line) - 12))
            phase = 3
        else:
            return false
        start = i + 1
        i = i + 1
    if start < len(text):
        let tail = strutil.Strip(strings.SliceBytes(text, start, len(text) - start))
        if len(tail) > 0:
            if phase != 2:
                return false
            if len(tail) <= 12 || strings.SliceBytes(tail, 0, 12) != "payload_hex=":
                return false
            outPayloadHex = strutil.Strip(strings.SliceBytes(tail, 12, len(tail) - 12))
            phase = 3
    if phase != 3 || len(outNodeId) <= 0 || len(outPayloadHex) <= 0:
        return false
    return true

fn v3ChengNodeCtlChainLoadSnapshot(pathRaw: str,
                                   outSnapshot: var chain.V3ChainNodeServeSnapshot): Result[str] =
    let textRes = v3ChengNodeCtlReadRequiredTextFile(pathRaw)
    if IsErr(textRes):
        return Err[str](Error(textRes))
    var nodeId = ""
    var payloadHex = ""
    if !v3ChengNodeCtlChainExtractStateText(Value(textRes), nodeId, payloadHex):
        return Err[str]("cheng_node: invalid chain state file: " + v3ChengNodeCtlAbsolutePath(pathRaw))
    let payloadRes = v3ChengNodeCtlChainBytesFromHex(payloadHex)
    if IsErr(payloadRes):
        return Err[str](Error(payloadRes))
    let decodeRes = chainnet.V3ChainNodeLibp2pDecodeSnapshotInto(Value(payloadRes), outSnapshot)
    if IsErr(decodeRes):
        return Err[str](Error(decodeRes))
    outSnapshot.nodeId = v3ChengNodeCtlChainCloneText(nodeId)
    return Ok[str](nodeId)

fn v3ChengNodeCtlChainLoadStateInto(out: var chain.V3ChainNode,
                                    pathRaw: str): Result[bool] =
    var snapshot: chain.V3ChainNodeServeSnapshot
    let nodeIdRes = v3ChengNodeCtlChainLoadSnapshot(pathRaw, snapshot)
    if IsErr(nodeIdRes):
        return Err[bool](Error(nodeIdRes))
    let replayRes = chain.v3ChainNodeReplayFromSnapshotInto(out,
                                                            Value(nodeIdRes),
                                                            snapshot.address,
                                                            snapshot)
    if IsErr(replayRes):
        return Err[bool](Error(replayRes))
    return Ok[bool](true)

fn v3ChengNodeCtlChainLoadOrInitForSyncInto(out: var chain.V3ChainNode,
                                            statePath: str): Result[bool] =
    let absoluteState = v3ChengNodeCtlAbsolutePath(statePath)
    if len(absoluteState) > 0 && os.FileExists(absoluteState):
        return v3ChengNodeCtlChainLoadStateInto(out, absoluteState)
    let nodeId = strutil.Strip(v3ChengNodeCtlFlagOrDefault("--node-id", ""))
    if len(nodeId) <= 0:
        return Err[bool]("cheng_node: chain-daemon-sync missing state; require --node-id and --address-seed")
    let addressSeed = strutil.Strip(v3ChengNodeCtlFlagOrDefault("--address-seed", ""))
    if len(addressSeed) <= 0:
        return Err[bool]("cheng_node: chain-daemon-sync missing state; require --node-id and --address-seed")
    return chain.V3ChainNodeInitInto(out, nodeId, addressSeed)

fn v3ChengNodeCtlChainSnapshotReportText(snapshot: chain.V3ChainNodeServeSnapshot): str =
    var out = ""
    out = out + "node_id=" + snapshot.nodeId + "\n"
    out = out + "serve_count=" + strings.IntToStr(snapshot.serveCount) + "\n"
    out = out + "event_count=" + strings.IntToStr(snapshot.events.len) + "\n"
    out = out + "tip_event_cid=" + layout.fixedBytes32Hex(snapshot.tipEventCid) + "\n"
    out = out + "forest_cid=" + layout.fixedBytes32Hex(snapshot.forest.forestCid) + "\n"
    out = out + "signature_event_count=" + strings.IntToStr(snapshot.signature.eventCount) + "\n"
    out = out + "signature_account_count=" + strings.IntToStr(snapshot.signature.accountCount)
    return out

fn v3ChengNodeCtlChainStateReportText(snapshot: chain.V3ChainNodeServeSnapshot): str =
    var out = ""
    out = out + "node_id=" + snapshot.nodeId + "\n"
    out = out + "serve_count=" + strings.IntToStr(snapshot.serveCount + 1) + "\n"
    out = out + "event_count=" + strings.IntToStr(snapshot.events.len) + "\n"
    out = out + "tip_event_cid=" + layout.fixedBytes32Hex(snapshot.tipEventCid) + "\n"
    out = out + "forest_cid=" + layout.fixedBytes32Hex(snapshot.forest.forestCid) + "\n"
    out = out + "signature_event_count=" + strings.IntToStr(snapshot.signature.eventCount) + "\n"
    out = out + "signature_account_count=" + strings.IntToStr(snapshot.signature.accountCount)
    return out

fn v3ChengNodeCtlChainInitText(): Result[str] =
    let statePathRes = v3ChengNodeCtlRequireTextFlag("--state")
    if IsErr(statePathRes):
        return Err[str](Error(statePathRes))
    let statePath = v3ChengNodeCtlAbsolutePath(Value(statePathRes))
    if os.FileExists(statePath) && !cmdline.hasFlag("--force"):
        return Err[str]("cheng_node: chain state already exists: " + statePath + " (pass --force to overwrite)")
    let nodeIdRes = v3ChengNodeCtlRequireTextFlag("--node-id")
    if IsErr(nodeIdRes):
        return Err[str](Error(nodeIdRes))
    let addressSeedRes = v3ChengNodeCtlRequireTextFlag("--address-seed")
    if IsErr(addressSeedRes):
        return Err[str](Error(addressSeedRes))
    var core: chain.V3ChainNode
    let initRes = chain.V3ChainNodeInitInto(core, Value(nodeIdRes), Value(addressSeedRes))
    if IsErr(initRes):
        return Err[str](Error(initRes))
    var snapshot: chain.V3ChainNodeServeSnapshot
    chain.V3ChainNodeServeOnceInto(snapshot, core)
    let writeRes = v3ChengNodeCtlChainWriteState(statePath, snapshot)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    return Ok[str](v3ChengNodeCtlChainSnapshotReportText(snapshot))

fn v3ChengNodeCtlChainMintText(): Result[str] =
    let statePathRes = v3ChengNodeCtlRequireTextFlag("--state")
    if IsErr(statePathRes):
        return Err[str](Error(statePathRes))
    let assetRes = v3ChengNodeCtlRequireInt32Flag("--asset")
    if IsErr(assetRes):
        return Err[str](Error(assetRes))
    let accountRes = v3ChengNodeCtlRequireInt32Flag("--account")
    if IsErr(accountRes):
        return Err[str](Error(accountRes))
    let amountRes = v3ChengNodeCtlRequireInt64Flag("--amount")
    if IsErr(amountRes):
        return Err[str](Error(amountRes))
    var core: chain.V3ChainNode
    let loadRes = v3ChengNodeCtlChainLoadStateInto(core, Value(statePathRes))
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let mintRes = chain.V3ChainNodeMint(core, Value(assetRes), Value(accountRes), Value(amountRes))
    if IsErr(mintRes):
        return Err[str](Error(mintRes))
    var snapshot: chain.V3ChainNodeServeSnapshot
    chain.V3ChainNodeServeOnceInto(snapshot, core)
    let writeRes = v3ChengNodeCtlChainWriteState(Value(statePathRes), snapshot)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "event_cid=" + layout.fixedBytes32Hex(Value(mintRes)) + "\n"
    out = out + v3ChengNodeCtlChainSnapshotReportText(snapshot)
    return Ok[str](out)

fn v3ChengNodeCtlChainTransferText(): Result[str] =
    let statePathRes = v3ChengNodeCtlRequireTextFlag("--state")
    if IsErr(statePathRes):
        return Err[str](Error(statePathRes))
    let assetRes = v3ChengNodeCtlRequireInt32Flag("--asset")
    if IsErr(assetRes):
        return Err[str](Error(assetRes))
    let fromRes = v3ChengNodeCtlRequireInt32Flag("--from")
    if IsErr(fromRes):
        return Err[str](Error(fromRes))
    let toRes = v3ChengNodeCtlRequireInt32Flag("--to")
    if IsErr(toRes):
        return Err[str](Error(toRes))
    let amountRes = v3ChengNodeCtlRequireInt64Flag("--amount")
    if IsErr(amountRes):
        return Err[str](Error(amountRes))
    var core: chain.V3ChainNode
    let loadRes = v3ChengNodeCtlChainLoadStateInto(core, Value(statePathRes))
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let transferRes = chain.V3ChainNodeTransfer(core,
                                                Value(assetRes),
                                                Value(fromRes),
                                                Value(toRes),
                                                Value(amountRes))
    if IsErr(transferRes):
        return Err[str](Error(transferRes))
    var snapshot: chain.V3ChainNodeServeSnapshot
    chain.V3ChainNodeServeOnceInto(snapshot, core)
    let writeRes = v3ChengNodeCtlChainWriteState(Value(statePathRes), snapshot)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "event_cid=" + layout.fixedBytes32Hex(Value(transferRes)) + "\n"
    out = out + v3ChengNodeCtlChainSnapshotReportText(snapshot)
    return Ok[str](out)

fn v3ChengNodeCtlChainBalanceText(): Result[str] =
    let statePathRes = v3ChengNodeCtlRequireTextFlag("--state")
    if IsErr(statePathRes):
        return Err[str](Error(statePathRes))
    let assetRes = v3ChengNodeCtlRequireInt32Flag("--asset")
    if IsErr(assetRes):
        return Err[str](Error(assetRes))
    let accountRes = v3ChengNodeCtlRequireInt32Flag("--account")
    if IsErr(accountRes):
        return Err[str](Error(accountRes))
    var core: chain.V3ChainNode
    let loadRes = v3ChengNodeCtlChainLoadStateInto(core, Value(statePathRes))
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let balanceRes = chain.V3ChainNodeBalance(core, Value(assetRes), Value(accountRes))
    if IsErr(balanceRes):
        return Err[str](Error(balanceRes))
    return Ok[str]("balance=" + strings.Int64ToStr(Value(balanceRes)))

fn v3ChengNodeCtlChainShowStateText(): Result[str] =
    let statePathRes = v3ChengNodeCtlRequireTextFlag("--state")
    if IsErr(statePathRes):
        return Err[str](Error(statePathRes))
    var core: chain.V3ChainNode
    let loadRes = v3ChengNodeCtlChainLoadStateInto(core, Value(statePathRes))
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    var snapshot: chain.V3ChainNodeServeSnapshot
    chain.V3ChainNodeServeOnceInto(snapshot, core)
    return Ok[str](v3ChengNodeCtlChainSnapshotReportText(snapshot))

fn v3ChengNodeCtlChainDumpSnapshotText(): Result[str] =
    let statePathRes = v3ChengNodeCtlRequireTextFlag("--state")
    if IsErr(statePathRes):
        return Err[str](Error(statePathRes))
    return v3ChengNodeCtlReadRequiredTextFile(Value(statePathRes))

fn v3ChengNodeCtlChainServeText(): Result[str] =
    let statePathRes = v3ChengNodeCtlRequireTextFlag("--state")
    if IsErr(statePathRes):
        return Err[str](Error(statePathRes))
    var core: chain.V3ChainNode
    let loadRes = v3ChengNodeCtlChainLoadStateInto(core, Value(statePathRes))
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let port = int32(parseInt(v3ChengNodeCtlFlagOrDefault("--port", "0")))
    let hostText = v3ChengNodeCtlFlagOrDefault("--host", "127.0.0.1")
    let readyPath = v3ChengNodeCtlFlagOrDefault("--ready-path", "")
    var snapshot: chain.V3ChainNodeServeSnapshot
    chain.V3ChainNodeServeOnceInto(snapshot, core)
    let payload = chainnet.V3ChainNodeLibp2pEncodeSnapshot(snapshot)
    let serveRes = tcp_transport.V3Libp2pTcpServePayloadOnce(hostText,
                                                             port,
                                                             libtypes.V3Libp2pProtocolSync,
                                                             payload,
                                                             readyPath)
    if !serveRes.ok:
        return Err[str](ErrorText(serveRes))
    let writeRes = v3ChengNodeCtlChainWriteState(Value(statePathRes), snapshot)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    return Ok[str](v3ChengNodeCtlChainSnapshotReportText(snapshot))

fn v3ChengNodeCtlChainSyncText(): Result[str] =
    let statePathRes = v3ChengNodeCtlRequireTextFlag("--state")
    if IsErr(statePathRes):
        return Err[str](Error(statePathRes))
    let portRes = v3ChengNodeCtlRequireInt32Flag("--port")
    if IsErr(portRes):
        return Err[str](Error(portRes))
    var core: chain.V3ChainNode
    let loadRes = v3ChengNodeCtlChainLoadOrInitForSyncInto(core, Value(statePathRes))
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let hostText = v3ChengNodeCtlFlagOrDefault("--host", "127.0.0.1")
    let payloadRes = tcp_transport.V3Libp2pTcpRecvPayloadOnce(hostText,
                                                              Value(portRes),
                                                              libtypes.V3Libp2pProtocolSync)
    if !payloadRes.ok:
        return Err[str](ErrorText(payloadRes))
    var incoming: chain.V3ChainNodeServeSnapshot
    let snapshotRes = chainnet.V3ChainNodeLibp2pDecodeSnapshotInto(payloadRes.value, incoming)
    if IsErr(snapshotRes):
        return Err[str](Error(snapshotRes))
    let syncRes = chain.V3ChainNodeSyncOnce(core, incoming)
    if IsErr(syncRes):
        return Err[str](Error(syncRes))
    var snapshot: chain.V3ChainNodeServeSnapshot
    chain.V3ChainNodeServeOnceInto(snapshot, core)
    let writeRes = v3ChengNodeCtlChainWriteState(Value(statePathRes), snapshot)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + (Value(syncRes) ? "changed=1" : "changed=0") + "\n"
    out = out + v3ChengNodeCtlChainSnapshotReportText(snapshot)
    return Ok[str](out)

fn v3ChengNodeCtlChainSelfTestText(): Result[str] =
    var server: chain.V3ChainNode
    let initServerRes = chain.V3ChainNodeInitInto(server, "node-a", "chain-node-a")
    if IsErr(initServerRes):
        return Err[str](Error(initServerRes))
    var client: chain.V3ChainNode
    let initClientRes = chain.V3ChainNodeInitInto(client, "node-b", "chain-node-b")
    if IsErr(initClientRes):
        return Err[str](Error(initClientRes))
    let mintRes = chain.V3ChainNodeMint(server, 7, 1001, int64(100))
    if IsErr(mintRes):
        return Err[str](Error(mintRes))
    let transferRes = chain.V3ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    if IsErr(transferRes):
        return Err[str](Error(transferRes))
    var served: chain.V3ChainNodeServeSnapshot
    chain.V3ChainNodeServeOnceInto(served, server)
    let syncRes = chain.V3ChainNodeSyncOnce(client, served)
    if IsErr(syncRes):
        return Err[str](Error(syncRes))
    if !Value(syncRes):
        return Err[str]("cheng_node: chain-self-test expected changed=1")
    let aliceRes = chain.V3ChainNodeBalance(client, 7, 1001)
    if IsErr(aliceRes):
        return Err[str](Error(aliceRes))
    let bobRes = chain.V3ChainNodeBalance(client, 7, 2002)
    if IsErr(bobRes):
        return Err[str](Error(bobRes))
    if Value(aliceRes) != int64(60):
        return Err[str]("cheng_node: chain-self-test alice balance drift")
    if Value(bobRes) != int64(40):
        return Err[str]("cheng_node: chain-self-test bob balance drift")
    var clientServed: chain.V3ChainNodeServeSnapshot
    chain.V3ChainNodeServeOnceInto(clientServed, client)
    if !layout.FixedBytes32Equal(served.tipEventCid, clientServed.tipEventCid):
        return Err[str]("cheng_node: chain-self-test tip drift")
    if !layout.FixedBytes32Equal(served.forest.forestCid, clientServed.forest.forestCid):
        return Err[str]("cheng_node: chain-self-test forest drift")
    if !anti.V3AntiEntropySignatureEqual(served.signature, clientServed.signature):
        return Err[str]("cheng_node: chain-self-test signature drift")
    return Ok[str]("v3 chain_node self-test ok")

fn v3ChengNodeCtlRequireContains(text: str,
                                 needle: str,
                                 context: str): Result[bool] =
    if !strutil.Contains(text, needle):
        return Err[bool]("cheng_node: verify missing " + context)
    return Ok[bool](true)

fn v3ChengNodeCtlCompilerBuildReceiptText(receiptKey: str,
                                          receiptCid: layout.FixedBytes32): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "receipt_key=" + receiptKey + "\n"
    out = out + "receipt_cid=" + layout.fixedBytes32Hex(receiptCid)
    return out

fn v3ChengNodeCtlCompilerTargetReceiptText(receiptKey: str,
                                           receipt: ccsg.V3CompileReceipt): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "target=" + receipt.targetTriple + "\n"
    out = out + "receipt_key=" + receiptKey + "\n"
    out = out + "receipt_cid=" + layout.fixedBytes32Hex(receipt.receiptCid) + "\n"
    out = out + "world_head_cid=" + layout.fixedBytes32Hex(receipt.worldHeadCid) + "\n"
    out = out + "bootstrap_stage=" + receipt.bootstrapStage
    return out

fn v3ChengNodeCtlChainUsageText(): str =
    var out = ""
    out = out + "chain commands:\n"
    out = out + "  chain init --state:<file> --node-id:<id> --address-seed:<seed>\n"
    out = out + "  chain mint --state:<file> --asset:<id> --account:<id> --amount:<n>\n"
    out = out + "  chain transfer --state:<file> --asset:<id> --from:<id> --to:<id> --amount:<n>\n"
    out = out + "  chain balance --state:<file> --asset:<id> --account:<id>\n"
    out = out + "  chain state show --state:<file>\n"
    out = out + "  chain snapshot dump --state:<file>\n"
    out = out + "  chain daemon serve --state:<file> [--host:<ip>] [--port:<n>] [--ready-path:<file>]\n"
    out = out + "  chain daemon sync --state:<file> --node-id:<id> --address-seed:<seed> --host:<ip> --port:<n>\n"
    out = out + "  chain self test"
    return out

fn v3ChengNodeCtlLibp2pUsageText(): str =
    var out = ""
    out = out + "libp2p commands:\n"
    out = out + "  libp2p surface --root:<seed> --state:<path>\n"
    out = out + "  libp2p head --root:<seed> --state:<path>\n"
    out = out + "  libp2p announce --root:<seed> --state:<path> --transport:<tcp|quic|webrtc> --host:<text> --port:<int> [--topic:<text>] [--capability:<text>]\n"
    out = out + "  libp2p discover --root:<seed> --state:<path> [--peer:<id>|--topic:<text>|--capability:<text>] [--remote-state:<path>] [--remote-root:<seed>] [--with-delta]\n"
    out = out + "  libp2p stream --root:<seed> --state:<path> --remote-state:<path> [--remote-root:<seed>] --protocol:<identify|sync|store|content|proxy_tcp>"
    return out

fn v3ChengNodeCtlUsageText(): str =
    var out = ""
    out = out + "usage: cheng_node_main <command> [flags]\n"
    out = out + "compat: cheng_node_main ctl <command> [flags]\n\n"
    out = out + "commands:\n"
    out = out + "  identity --root:<seed>\n"
    out = out + "  bootstrap --root:<seed>\n"
    out = out + "  required-surface\n"
    out = out + "  libp2p surface --root:<seed> --state:<path>\n"
    out = out + "  libp2p head --root:<seed> --state:<path>\n"
    out = out + "  libp2p announce --root:<seed> --state:<path> --transport:<tcp|quic|webrtc> --host:<text> --port:<int> [--topic:<text>] [--capability:<text>]\n"
    out = out + "  libp2p discover --root:<seed> --state:<path> [--peer:<id>|--topic:<text>|--capability:<text>] [--remote-state:<path>] [--remote-root:<seed>] [--with-delta]\n"
    out = out + "  libp2p stream --root:<seed> --state:<path> --remote-state:<path> [--remote-root:<seed>] --protocol:<identify|sync|store|content|proxy_tcp>\n"
    out = out + "  head --root:<seed> --state:<path>\n"
    out = out + "  announce --root:<seed> --state:<path> --transport:<tcp|quic|webrtc> --host:<text> --port:<int> [--topic:<text>] [--capability:<text>]\n"
    out = out + "  discover --root:<seed> --state:<path> [--peer:<id>|--topic:<text>|--capability:<text>] [--remote-state:<path>] [--remote-root:<seed>] [--with-delta]\n"
    out = out + "  stream --root:<seed> --state:<path> --remote-state:<path> [--remote-root:<seed>] --protocol:<identify|sync|store|content|proxy_tcp>\n"
    out = out + "  query --root:<seed> --state:<path> --group:<name> --kind:<name> --key:<text> [--with-delta]\n"
    out = out + "  balance --root:<seed> --state:<path> --asset:<id> --account:<id> [--with-delta]\n"
    out = out + "  did --root:<seed> --state:<path> --subject:<did> [--with-delta]\n"
    out = out + "  did-operator --root:<seed> --state:<path> --operator:<hex> [--with-delta]\n"
    out = out + "  mint --root:<seed> --state:<path> --asset:<id> --account:<id> --amount:<int64>\n"
    out = out + "  transfer --root:<seed> --state:<path> --asset:<id> --from:<id> --to:<id> --amount:<int64>\n"
    out = out + "  sync-did --root:<seed> --state:<path>\n"
    out = out + "  oracle-submit --root:<seed> --state:<path> --round:<id> --pair:<asset/quote>\n"
    out = out + "  oracle --root:<seed> --state:<path> --pair:<asset/quote> [--with-delta]\n"
    out = out + "  diloco-open --root:<seed> --state:<path> --job:<text> --workers:<int> --inner-steps:<int> --timeout:<int>\n"
    out = out + "  diloco-join --root:<seed> --state:<path> --job:<text> --peer-seed:<text>\n"
    out = out + "  diloco-lease --root:<seed> --state:<path> --job:<text> --peer-seed:<text>\n"
    out = out + "  diloco-barrier --root:<seed> --state:<path> --job:<text> --peer-seed:<text>\n"
    out = out + "  diloco-delta --root:<seed> --state:<path> --job:<text> --peer-seed:<text> --samples:<int> --tokens:<int> --inner-steps:<int> --weight-num:<int> --weight-den:<int>\n"
    out = out + "  diloco-merge --root:<seed> --state:<path> --job:<text> --leader-seed:<text> [--peer-seed:<text>]\n"
    out = out + "  diloco-status --root:<seed> --state:<path> --job:<text>\n"
    out = out + "  vpn-peer --root:<seed> --state:<path> --peer:<id> [--tailnet-ip:<ip>] [--direct:<0|1>] [--relay:<0|1>] [--relay-only:<0|1>] [--derp-region:<text>] [--bound-addr:<multiaddr>]\n"
    out = out + "  vpn-route --root:<seed> --state:<path> --mode:<overlay|exit> --key:<text> [--addr:<multiaddr>] [--name:<text> --host:<text> --port:<int> --server-name:<text>]\n"
    out = out + "  vpn-status --root:<seed> --state:<path>\n"
    out = out + "  evomap-agent --root:<seed> --state:<path> --did:<text> --peer:<text> --device:<text>\n"
    out = out + "  evomap-task --root:<seed> --state:<path> --peer:<text> --task-id:<text> --prompt:<text> [--keywords:a,b] [--context:c1,c2]\n"
    out = out + "  evomap-capsule --root:<seed> --state:<path> --did:<text> --peer:<text> --device:<text> --kind:<text> --task-id:<text> --content:<text> [--keywords:a,b] [--parents:c1,c2] [--relation:<kind>] [--created-at:<epoch>] [--gene-capability:<text>] [--gene-strategy:<text>] [--gene-condition:<text>]\n"
    out = out + "  evomap-status --root:<seed> --state:<path>\n"
    out = out + "  import-legacy-chain --root:<seed> --legacy-state:<path> --out:<path>\n"
    out = out + "  import-legacy-oracle --root:<seed> --state:<path> --legacy-state:<path>\n"
    out = out + "  import-compiler-package --root:<seed> --state:<path> --report:<path>\n"
    out = out + "  import-compiler-world --root:<seed> --state:<path> --report:<path>\n"
    out = out + "  import-compiler-receipt --root:<seed> --state:<path> --report:<path> --receipt-key:<text>\n"
    out = out + "  verify-legacy-chain --root:<seed> --state:<path> --legacy-state:<path>\n"
    out = out + "  verify-legacy-oracle --root:<seed> --state:<path> --legacy-state:<path>\n"
    out = out + "  verify-compiler-package --root:<seed> --state:<path> --report:<path>\n"
    out = out + "  verify-compiler-world --root:<seed> --state:<path> --report:<path>\n"
    out = out + "  verify-compiler-receipt --root:<seed> --state:<path> --report:<path> --receipt-key:<text>\n"
    out = out + "  compiler <subcommand> [args]\n"
    out = out + "\n"
    out = out + "\n"
    out = out + v3ChengNodeCtlLibp2pUsageText() + "\n\n"
    out = out + v3ChengNodeCtlChainUsageText()
    return out

fn v3ChengNodeCtlIdentityText(rootSeed: str): Result[str] =
    let identityRes = identity.V3ChengNodeIdentityDerive(rootSeed)
    if IsErr(identityRes):
        return Err[str](Error(identityRes))
    let id = Value(identityRes)
    var out = ""
    out = out + "root_id=" + layout.fixedBytes32Hex(id.rootId) + "\n"
    out = out + "chain=" + layout.fixedBytes32Hex(id.chainKey) + "\n"
    out = out + "did=" + layout.fixedBytes32Hex(id.didKey) + "\n"
    out = out + "libp2p=" + layout.fixedBytes32Hex(id.libp2pKey) + "\n"
    out = out + "discovery=" + layout.fixedBytes32Hex(id.discoveryKey) + "\n"
    out = out + "oracle=" + layout.fixedBytes32Hex(id.oracleKey) + "\n"
    out = out + "diloco=" + layout.fixedBytes32Hex(id.dilocoKey) + "\n"
    out = out + "vpn=" + layout.fixedBytes32Hex(id.vpnKey) + "\n"
    out = out + "evomap=" + layout.fixedBytes32Hex(id.evomapKey) + "\n"
    out = out + "compiler=" + layout.fixedBytes32Hex(id.compilerKey) + "\n"
    out = out + "admin=" + layout.fixedBytes32Hex(id.adminKey) + "\n"
    return Ok[str](out)

fn v3ChengNodeCtlBootstrapText(rootSeed: str): Result[str] =
    let nodeRes = node.V3ChengNodeInit(rootSeed)
    if IsErr(nodeRes):
        return Err[str](Error(nodeRes))
    return Ok[str](node.V3ChengNodeBootstrapSummaryText(Value(nodeRes)))

