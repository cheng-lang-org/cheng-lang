fn v3ChengNodeCtlLoadRemoteNode(remoteRootSeed: str,
                                remoteStatePath: str): Result[node.V3ChengNode] =
    var remote: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadStateInto(remote, remoteStatePath, remoteRootSeed)
    if IsErr(loadRes):
        return Err[node.V3ChengNode](Error(loadRes))
    return Ok[node.V3ChengNode](remote)

fn v3ChengNodeCtlVerifyIndexedStoredText(core: var node.V3ChengNode,
                                         indexGroup: str,
                                         lookupKind: str,
                                         keyText: str,
                                         expectedKind: str,
                                         expectedText: str): Result[str] =
    let entryRes = cindex.V3ChengNodeIndexGet(core.indices, indexGroup, lookupKind, keyText)
    if IsErr(entryRes):
        return Err[str](Error(entryRes))
    let entry = Value(entryRes)
    let objectRes = cobject.V3ChengNodeObjectStoreGet(core.objects, entry.valueCid)
    if IsErr(objectRes):
        return Err[str](Error(objectRes))
    let objectEntry = Value(objectRes)
    if objectEntry.objectKind != expectedKind:
        return Err[str]("cheng_node: verify object kind mismatch")
    if objectEntry.text != expectedText:
        return Err[str]("cheng_node: verify object text mismatch")
    var out = ""
    out = out + "verified=1\n"
    out = out + "index_group=" + indexGroup + "\n"
    out = out + "lookup_kind=" + lookupKind + "\n"
    out = out + "key_text=" + keyText + "\n"
    out = out + "payload_kind=" + objectEntry.objectKind + "\n"
    out = out + "value_cid=" + layout.fixedBytes32Hex(entry.valueCid)
    return Ok[str](out)

fn v3ChengNodeCtlVerifyIndexedObjectText(core: var node.V3ChengNode,
                                         indexGroup: str,
                                         lookupKind: str,
                                         keyText: str,
                                         expectedKind: str,
                                         expectedText: str,
                                         verifyProofDelta: bool): Result[str] =
    if verifyProofDelta:
        let queryRes = node.V3ChengNodeKeyedQueryText(core,
                                                      indexGroup,
                                                      lookupKind,
                                                      keyText,
                                                      true)
        if IsErr(queryRes):
            return Err[str](Error(queryRes))
        let queryText = Value(queryRes)
        let foundRes = v3ChengNodeCtlRequireContains(queryText, "found=1", "found=1")
        if IsErr(foundRes):
            return Err[str](Error(foundRes))
        let proofRes = v3ChengNodeCtlRequireContains(queryText, "proof_cid=", "proof_cid")
        if IsErr(proofRes):
            return Err[str](Error(proofRes))
        let snapshotRes = v3ChengNodeCtlRequireContains(queryText, "snapshot_cid=", "snapshot_cid")
        if IsErr(snapshotRes):
            return Err[str](Error(snapshotRes))
        let payloadRes = v3ChengNodeCtlRequireContains(queryText, "payload_present=1", "payload_present")
        if IsErr(payloadRes):
            return Err[str](Error(payloadRes))
        let deltaRes = v3ChengNodeCtlRequireContains(queryText, "delta_count=1", "delta_count")
        if IsErr(deltaRes):
            return Err[str](Error(deltaRes))
    return v3ChengNodeCtlVerifyIndexedStoredText(core,
                                                 indexGroup,
                                                 lookupKind,
                                                 keyText,
                                                 expectedKind,
                                                 expectedText)

fn v3ChengNodeCtlVerifyExpectedGroupCount(actual: var node.V3ChengNode,
                                          expected: var node.V3ChengNode,
                                          groupName: str): Result[int32] =
    var verifiedCount = 0
    var proofVerified = false
    for i in 0..<expected.indices.entries.len:
        let entry = expected.indices.entries[i]
        if !entry.active || entry.groupName != groupName:
            continue
        let objectRes = cobject.V3ChengNodeObjectStoreGet(expected.objects, entry.valueCid)
        if IsErr(objectRes):
            return Err[int32](Error(objectRes))
        let verifyRes = v3ChengNodeCtlVerifyIndexedObjectText(actual,
                                                              entry.groupName,
                                                              entry.lookupKind,
                                                              entry.keyText,
                                                              Value(objectRes).objectKind,
                                                              Value(objectRes).text,
                                                              !proofVerified)
        if IsErr(verifyRes):
            return Err[int32](Error(verifyRes))
        proofVerified = true
        verifiedCount = verifiedCount + 1
    return Ok[int32](verifiedCount)

fn v3ChengNodeCtlVerifyLegacyChainOnNodeText(actual: var node.V3ChengNode,
                                             rootSeed: str,
                                             statePath: str,
                                             legacyStatePath: str): Result[str] =
    let nodeRes = node.V3ChengNodeInit(rootSeed)
    if IsErr(nodeRes):
        return Err[str](Error(nodeRes))
    var expected = Value(nodeRes)
    var snapshot: chain.V3ChainNodeServeSnapshot
    let loadLegacyRes = state.V3ChengNodeLoadLegacyChainSnapshotInto(snapshot, legacyStatePath)
    if IsErr(loadLegacyRes):
        return Err[str](Error(loadLegacyRes))
    let importRes = node.V3ChengNodeImportChainSnapshot(expected, snapshot)
    if IsErr(importRes):
        return Err[str](Error(importRes))
    let balanceCountRes = v3ChengNodeCtlVerifyExpectedGroupCount(actual, expected, "balance")
    if IsErr(balanceCountRes):
        return Err[str](Error(balanceCountRes))
    let didCountRes = v3ChengNodeCtlVerifyExpectedGroupCount(actual, expected, "did")
    if IsErr(didCountRes):
        return Err[str](Error(didCountRes))
    let operatorCountRes = v3ChengNodeCtlVerifyExpectedGroupCount(actual, expected, "did_operator")
    if IsErr(operatorCountRes):
        return Err[str](Error(operatorCountRes))
    var out = ""
    out = out + "legacy_state_path=" + v3ChengNodeCtlAbsolutePath(legacyStatePath) + "\n"
    out = out + "state_path=" + v3ChengNodeCtlAbsolutePath(statePath) + "\n"
    out = out + "balance_verified_count=" + intToStr(Value(balanceCountRes)) + "\n"
    out = out + "did_verified_count=" + intToStr(Value(didCountRes)) + "\n"
    out = out + "did_operator_verified_count=" + intToStr(Value(operatorCountRes)) + "\n"
    out = out + "verified=1"
    return Ok[str](out)

fn v3ChengNodeCtlVerifyLegacyChainText(rootSeed: str,
                                       statePath: str,
                                       legacyStatePath: str): Result[str] =
    let actualRes = v3ChengNodeCtlLoadRemoteNode(rootSeed, statePath)
    if IsErr(actualRes):
        return Err[str](Error(actualRes))
    var actual = Value(actualRes)
    return v3ChengNodeCtlVerifyLegacyChainOnNodeText(actual,
                                                     rootSeed,
                                                     statePath,
                                                     legacyStatePath)

fn v3ChengNodeCtlVerifyLegacyOracleOnNodeText(actual: var node.V3ChengNode,
                                              rootSeed: str,
                                              statePath: str,
                                              legacyStatePath: str): Result[str] =
    let nodeRes = node.V3ChengNodeInit(rootSeed)
    if IsErr(nodeRes):
        return Err[str](Error(nodeRes))
    var expected = Value(nodeRes)
    var machine: oracle_bft.V3OracleBftStateMachine
    let loadLegacyRes = oracle_host.v3OracleBftLoadState(legacyStatePath, machine)
    if IsErr(loadLegacyRes):
        return Err[str](Error(loadLegacyRes))
    let importRes = node.V3ChengNodeImportOracleState(expected, machine)
    if IsErr(importRes):
        return Err[str](Error(importRes))
    let oracleCountRes = v3ChengNodeCtlVerifyExpectedGroupCount(actual, expected, "oracle")
    if IsErr(oracleCountRes):
        return Err[str](Error(oracleCountRes))
    var out = ""
    out = out + "legacy_state_path=" + v3ChengNodeCtlAbsolutePath(legacyStatePath) + "\n"
    out = out + "state_path=" + v3ChengNodeCtlAbsolutePath(statePath) + "\n"
    out = out + "oracle_verified_count=" + intToStr(Value(oracleCountRes)) + "\n"
    out = out + "verified=1"
    return Ok[str](out)

fn v3ChengNodeCtlVerifyLegacyOracleText(rootSeed: str,
                                        statePath: str,
                                        legacyStatePath: str): Result[str] =
    let actualRes = v3ChengNodeCtlLoadRemoteNode(rootSeed, statePath)
    if IsErr(actualRes):
        return Err[str](Error(actualRes))
    var actual = Value(actualRes)
    return v3ChengNodeCtlVerifyLegacyOracleOnNodeText(actual,
                                                      rootSeed,
                                                      statePath,
                                                      legacyStatePath)

fn v3ChengNodeCtlVerifyCompilerPackageOnNodeText(actual: var node.V3ChengNode,
                                                 statePath: str,
                                                 reportPath: str): Result[str] =
    let textRes = v3ChengNodeCtlReadRequiredTextFile(reportPath)
    if IsErr(textRes):
        return Err[str](Error(textRes))
    var snapshot: cworld.V3CompilerPackageSnapshot
    let parseRes = cworld.v3CompilerPackageSnapshotFromReportText(Value(textRes), snapshot)
    if IsErr(parseRes):
        return Err[str](Error(parseRes))
    let verifyRes = v3ChengNodeCtlVerifyIndexedObjectText(actual,
                                                          "compiler",
                                                          "package",
                                                          snapshot.packageId,
                                                          "compiler_package_snapshot",
                                                          cworld.v3CompilerPackageSnapshotReport(snapshot),
                                                          true)
    if IsErr(verifyRes):
        return Err[str](Error(verifyRes))
    var out = ""
    out = out + "report_path=" + v3ChengNodeCtlAbsolutePath(reportPath) + "\n"
    out = out + "state_path=" + v3ChengNodeCtlAbsolutePath(statePath) + "\n"
    out = out + "package_id=" + snapshot.packageId + "\n"
    out = out + "verified=1"
    return Ok[str](out)

fn v3ChengNodeCtlVerifyCompilerPackageText(rootSeed: str,
                                           statePath: str,
                                           reportPath: str): Result[str] =
    let actualRes = v3ChengNodeCtlLoadRemoteNode(rootSeed, statePath)
    if IsErr(actualRes):
        return Err[str](Error(actualRes))
    var actual = Value(actualRes)
    return v3ChengNodeCtlVerifyCompilerPackageOnNodeText(actual,
                                                         statePath,
                                                         reportPath)

fn v3ChengNodeCtlVerifyCompilerWorldOnNodeText(actual: var node.V3ChengNode,
                                               statePath: str,
                                               reportPath: str): Result[str] =
    let textRes = v3ChengNodeCtlReadRequiredTextFile(reportPath)
    if IsErr(textRes):
        return Err[str](Error(textRes))
    var head: cworld.V3CompilerWorldHead
    let parseRes = cworld.v3CompilerWorldHeadFromReportText(Value(textRes), head)
    if IsErr(parseRes):
        return Err[str](Error(parseRes))
    let verifyRes = v3ChengNodeCtlVerifyIndexedObjectText(actual,
                                                          "compiler",
                                                          "world_head",
                                                          layout.fixedBytes32Hex(head.headCid),
                                                          "compiler_world_head",
                                                          cworld.v3CompilerWorldHeadReport(head),
                                                          true)
    if IsErr(verifyRes):
        return Err[str](Error(verifyRes))
    var out = ""
    out = out + "report_path=" + v3ChengNodeCtlAbsolutePath(reportPath) + "\n"
    out = out + "state_path=" + v3ChengNodeCtlAbsolutePath(statePath) + "\n"
    out = out + "world_head_cid=" + layout.fixedBytes32Hex(head.headCid) + "\n"
    out = out + "verified=1"
    return Ok[str](out)

fn v3ChengNodeCtlVerifyCompilerWorldText(rootSeed: str,
                                         statePath: str,
                                         reportPath: str): Result[str] =
    let actualRes = v3ChengNodeCtlLoadRemoteNode(rootSeed, statePath)
    if IsErr(actualRes):
        return Err[str](Error(actualRes))
    var actual = Value(actualRes)
    return v3ChengNodeCtlVerifyCompilerWorldOnNodeText(actual,
                                                       statePath,
                                                       reportPath)

fn v3ChengNodeCtlVerifyCompilerReceiptOnNodeText(actual: var node.V3ChengNode,
                                                 statePath: str,
                                                 reportPath: str,
                                                 receiptKey: str): Result[str] =
    let textRes = v3ChengNodeCtlReadRequiredTextFile(reportPath)
    if IsErr(textRes):
        return Err[str](Error(textRes))
    var receipt: ccsg.V3CompileReceipt
    let parseRes = ccsg.v3CompileReceiptFromReportText(Value(textRes), receipt)
    if IsErr(parseRes):
        return Err[str](Error(parseRes))
    let receiptVerifyRes = v3ChengNodeCtlVerifyIndexedObjectText(actual,
                                                                 "compiler",
                                                                 "build_receipt",
                                                                 receiptKey,
                                                                 "compiler_build_receipt",
                                                                 v3ChengNodeCtlCompilerBuildReceiptText(receiptKey, receipt.receiptCid),
                                                                 true)
    if IsErr(receiptVerifyRes):
        return Err[str](Error(receiptVerifyRes))
    let targetVerifyRes = v3ChengNodeCtlVerifyIndexedObjectText(actual,
                                                                "compiler",
                                                                "target",
                                                                receipt.targetTriple,
                                                                "compiler_target_receipt",
                                                                v3ChengNodeCtlCompilerTargetReceiptText(receiptKey, receipt),
                                                                false)
    if IsErr(targetVerifyRes):
        return Err[str](Error(targetVerifyRes))
    var out = ""
    out = out + "report_path=" + v3ChengNodeCtlAbsolutePath(reportPath) + "\n"
    out = out + "state_path=" + v3ChengNodeCtlAbsolutePath(statePath) + "\n"
    out = out + "receipt_key=" + receiptKey + "\n"
    out = out + "target=" + receipt.targetTriple + "\n"
    out = out + "verified=1"
    return Ok[str](out)

fn v3ChengNodeCtlVerifyCompilerReceiptText(rootSeed: str,
                                           statePath: str,
                                           reportPath: str,
                                           receiptKey: str): Result[str] =
    let actualRes = v3ChengNodeCtlLoadRemoteNode(rootSeed, statePath)
    if IsErr(actualRes):
        return Err[str](Error(actualRes))
    var actual = Value(actualRes)
    return v3ChengNodeCtlVerifyCompilerReceiptOnNodeText(actual,
                                                         statePath,
                                                         reportPath,
                                                         receiptKey)

fn v3ChengNodeCtlAnnounceText(rootSeed: str,
                              statePath: str): Result[str] =
    let transportRes = v3ChengNodeCtlRequireTextFlag("--transport")
    if IsErr(transportRes):
        return Err[str](Error(transportRes))
    let hostRes = v3ChengNodeCtlRequireTextFlag("--host")
    if IsErr(hostRes):
        return Err[str](Error(hostRes))
    let portRes = v3ChengNodeCtlRequireInt32Flag("--port")
    if IsErr(portRes):
        return Err[str](Error(portRes))
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let announcePeerRes = node.V3ChengNodeAnnouncePeer(core,
                                                       Value(transportRes),
                                                       Value(hostRes),
                                                       Value(portRes))
    if IsErr(announcePeerRes):
        return Err[str](Error(announcePeerRes))
    let topicText = v3ChengNodeCtlFlagOrDefault("--topic", "")
    if len(topicText) > 0:
        let announceTopicRes = node.V3ChengNodeAnnounceDiscovery(core,
                                                                 "topic",
                                                                 topicText,
                                                                 Value(transportRes),
                                                                 Value(hostRes),
                                                                 Value(portRes),
                                                                 "public",
                                                                 "public",
                                                                 100)
        if IsErr(announceTopicRes):
            return Err[str](Error(announceTopicRes))
    let capabilityText = v3ChengNodeCtlFlagOrDefault("--capability", "")
    if len(capabilityText) > 0:
        let announceCapabilityRes = node.V3ChengNodeAnnounceDiscovery(core,
                                                                      "capability",
                                                                      capabilityText,
                                                                      Value(transportRes),
                                                                      Value(hostRes),
                                                                      Value(portRes),
                                                                      "public",
                                                                      "public",
                                                                      100)
        if IsErr(announceCapabilityRes):
            return Err[str](Error(announceCapabilityRes))
    let writeRes = state.V3ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + "peer_id=" + node.V3ChengNodeLocalPeerIdText(core) + "\n"
    out = out + node.V3ChengNodeBootstrapSummaryText(core)
    return Ok[str](out)

fn v3ChengNodeCtlDiscoverKindAndKey(): Result[str[]] =
    let peerText = v3ChengNodeCtlFlagOrDefault("--peer", "")
    if len(peerText) > 0:
        return Ok[str[]](["peer", peerText])
    let topicText = v3ChengNodeCtlFlagOrDefault("--topic", "")
    if len(topicText) > 0:
        return Ok[str[]](["topic", topicText])
    let capabilityText = v3ChengNodeCtlFlagOrDefault("--capability", "")
    if len(capabilityText) > 0:
        return Ok[str[]](["capability", capabilityText])
    return Err[str[]]("cheng_node: missing --peer or --topic or --capability")

fn v3ChengNodeCtlDiscoverText(rootSeed: str,
                              statePath: str): Result[str] =
    let kindKeyRes = v3ChengNodeCtlDiscoverKindAndKey()
    if IsErr(kindKeyRes):
        return Err[str](Error(kindKeyRes))
    let kindKey = Value(kindKeyRes)
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let remoteStatePath = v3ChengNodeCtlFlagOrDefault("--remote-state", "")
    if len(remoteStatePath) > 0:
        let remoteRes = v3ChengNodeCtlLoadRemoteNode(v3ChengNodeCtlRemoteRootSeed(), remoteStatePath)
        if IsErr(remoteRes):
            return Err[str](Error(remoteRes))
        var remote = Value(remoteRes)
        let syncRes = node.V3ChengNodeSyncDiscoveryFromRemote(core, remote, kindKey[0], kindKey[1])
        if IsErr(syncRes):
            return Err[str](Error(syncRes))
        let writeRes = state.V3ChengNodeWriteState(statePath, core)
        if IsErr(writeRes):
            return Err[str](Error(writeRes))
    return node.V3ChengNodeKeyedQueryText(core,
                                          "discovery",
                                          kindKey[0],
                                          kindKey[1],
                                          v3ChengNodeCtlWithDelta())

fn v3ChengNodeCtlStreamText(rootSeed: str,
                            statePath: str): Result[str] =
    let protocolRes = v3ChengNodeCtlRequireTextFlag("--protocol")
    if IsErr(protocolRes):
        return Err[str](Error(protocolRes))
    let remoteStateRes = v3ChengNodeCtlRequireTextFlag("--remote-state")
    if IsErr(remoteStateRes):
        return Err[str](Error(remoteStateRes))
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let remoteRes = v3ChengNodeCtlLoadRemoteNode(v3ChengNodeCtlRemoteRootSeed(), Value(remoteStateRes))
    if IsErr(remoteRes):
        return Err[str](Error(remoteRes))
    var remote = Value(remoteRes)
    return node.V3ChengNodeStreamText(core, remote, Value(protocolRes))

fn v3ChengNodeCtlVpnPeerText(rootSeed: str,
                             statePath: str): Result[str] =
    let peerRes = v3ChengNodeCtlRequireTextFlag("--peer")
    if IsErr(peerRes):
        return Err[str](Error(peerRes))
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    var session = tsnet.v3Libp2pTailnetPeerSessionZero()
    session.peerId = Value(peerRes)
    session.remoteTailnetIp = v3ChengNodeCtlFlagOrDefault("--tailnet-ip", "")
    session.directReachable = v3ChengNodeCtlFlagOrDefault("--direct", "0") == "1"
    session.relayAllowed = v3ChengNodeCtlFlagOrDefault("--relay", "0") == "1"
    session.relayOnly = v3ChengNodeCtlFlagOrDefault("--relay-only", "0") == "1"
    session.derpRegionCode = v3ChengNodeCtlFlagOrDefault("--derp-region", "")
    session.signedPreface = v3ChengNodeCtlFlagOrDefault("--signed-preface", "")
    session.boundAddrText = v3ChengNodeCtlFlagOrDefault("--bound-addr", "")
    session.lastError = v3ChengNodeCtlFlagOrDefault("--last-error", "")
    let upsertRes = node.V3ChengNodeVpnUpsertPeer(core, session)
    if IsErr(upsertRes):
        return Err[str](Error(upsertRes))
    let writeRes = state.V3ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + node.V3ChengNodeVpnStatusReportText(core)
    return Ok[str](out)

fn v3ChengNodeCtlVpnRouteText(rootSeed: str,
                              statePath: str): Result[str] =
    let modeRes = v3ChengNodeCtlRequireTextFlag("--mode")
    if IsErr(modeRes):
        return Err[str](Error(modeRes))
    let keyRes = v3ChengNodeCtlRequireTextFlag("--key")
    if IsErr(keyRes):
        return Err[str](Error(keyRes))
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    if Value(modeRes) == "overlay":
        let addrTextRes = v3ChengNodeCtlRequireTextFlag("--addr")
        if IsErr(addrTextRes):
            return Err[str](Error(addrTextRes))
        let addrRes = multiaddr.v3Libp2pMultiaddrParse(Value(addrTextRes))
        if IsErr(addrRes):
            return Err[str](Error(addrRes))
        let upsertRes = node.V3ChengNodeVpnUpsertOverlayRoute(core, Value(keyRes), Value(addrRes))
        if IsErr(upsertRes):
            return Err[str](Error(upsertRes))
    else:
        let nameRes = v3ChengNodeCtlRequireTextFlag("--name")
        if IsErr(nameRes):
            return Err[str](Error(nameRes))
        let hostRes = v3ChengNodeCtlRequireTextFlag("--host")
        if IsErr(hostRes):
            return Err[str](Error(hostRes))
        let portRes = v3ChengNodeCtlRequireInt32Flag("--port")
        if IsErr(portRes):
            return Err[str](Error(portRes))
        let serverNameRes = v3ChengNodeCtlRequireTextFlag("--server-name")
        if IsErr(serverNameRes):
            return Err[str](Error(serverNameRes))
        var cfg: vpncfg.V3VpnProxyExitConfig
        cfg.name = Value(nameRes)
        cfg.host = Value(hostRes)
        cfg.port = Value(portRes)
        cfg.serverName = Value(serverNameRes)
        let upsertRes = node.V3ChengNodeVpnUpsertExitRoute(core, Value(keyRes), cfg)
        if IsErr(upsertRes):
            return Err[str](Error(upsertRes))
    let writeRes = state.V3ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + node.V3ChengNodeVpnStatusReportText(core)
    return Ok[str](out)

fn v3ChengNodeCtlVpnStatusText(rootSeed: str,
                               statePath: str): Result[str] =
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadStateInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    return Ok[str](node.V3ChengNodeVpnStatusReportText(core))

fn v3ChengNodeCtlPrintUsageAndReturn(code: int32): int32 =
    echo(v3ChengNodeCtlUsageText())
    return code

fn v3ChengNodeCtlChainPrintUsageAndReturn(code: int32): int32 =
    echo(v3ChengNodeCtlChainUsageText())
    return code

fn v3ChengNodeCtlLibp2pPrintUsageAndReturn(code: int32): int32 =
    echo(v3ChengNodeCtlLibp2pUsageText())
    return code

fn v3ChengNodeCtlPrintResultAndReturn(textRes: Result[str]): int32 =
    if IsErr(textRes):
        echo(Error(textRes))
        return 1
    echo(Value(textRes))
    return 0

fn v3ChengNodeCtlChainCommandAt(commandIndex: int32): int32 =
    let subcmd = v3ChengNodeCtlWordAt(commandIndex)
    if subcmd == "" || subcmd == "--help" || subcmd == "-h" || subcmd == "help":
        return v3ChengNodeCtlChainPrintUsageAndReturn(0)
    if subcmd == "init":
        return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlChainInitText())
    if subcmd == "mint":
        return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlChainMintText())
    if subcmd == "transfer":
        return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlChainTransferText())
    if subcmd == "balance":
        return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlChainBalanceText())
    if subcmd == "state":
        let stateSubcmd = v3ChengNodeCtlWordAt(commandIndex + 1)
        if stateSubcmd == "show":
            return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlChainShowStateText())
        return v3ChengNodeCtlChainPrintUsageAndReturn(2)
    if subcmd == "snapshot":
        let snapshotSubcmd = v3ChengNodeCtlWordAt(commandIndex + 1)
        if snapshotSubcmd == "dump":
            return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlChainDumpSnapshotText())
        return v3ChengNodeCtlChainPrintUsageAndReturn(2)
    if subcmd == "daemon":
        let daemonSubcmd = v3ChengNodeCtlWordAt(commandIndex + 1)
        if daemonSubcmd == "serve":
            return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlChainServeText())
        if daemonSubcmd == "sync":
            return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlChainSyncText())
        return v3ChengNodeCtlChainPrintUsageAndReturn(2)
    if subcmd == "self":
        let selfSubcmd = v3ChengNodeCtlWordAt(commandIndex + 1)
        if selfSubcmd == "test":
            return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlChainSelfTestText())
        return v3ChengNodeCtlChainPrintUsageAndReturn(2)
    return v3ChengNodeCtlChainPrintUsageAndReturn(2)

fn v3ChengNodeCtlLibp2pCommandAt(commandIndex: int32): int32 =
    let subcmd = v3ChengNodeCtlWordAt(commandIndex)
    if subcmd == "" || subcmd == "--help" || subcmd == "-h" || subcmd == "help":
        return v3ChengNodeCtlLibp2pPrintUsageAndReturn(0)
    if subcmd == "surface":
        return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlLibp2pSurfaceText(v3ChengNodeCtlRootSeed(),
                                                                                   v3ChengNodeCtlStatePath()))
    if subcmd == "head":
        return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlHeadText(v3ChengNodeCtlRootSeed(),
                                                                          v3ChengNodeCtlStatePath()))
    if subcmd == "announce":
        return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlAnnounceText(v3ChengNodeCtlRootSeed(),
                                                                              v3ChengNodeCtlStatePath()))
    if subcmd == "discover":
        return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlDiscoverText(v3ChengNodeCtlRootSeed(),
                                                                              v3ChengNodeCtlStatePath()))
    if subcmd == "stream":
        return v3ChengNodeCtlPrintResultAndReturn(v3ChengNodeCtlStreamText(v3ChengNodeCtlRootSeed(),
                                                                            v3ChengNodeCtlStatePath()))
    return v3ChengNodeCtlLibp2pPrintUsageAndReturn(2)

fn V3ChengNodeCommandAt(commandIndex: int32): int32 =
    let count = cmdline.ParamCount()
    if count < commandIndex:
        return v3ChengNodeCtlPrintUsageAndReturn(0)
    let subcmd = cmdline.ParamStr(commandIndex)
    if subcmd == "--help" || subcmd == "-h" || subcmd == "help":
        return v3ChengNodeCtlPrintUsageAndReturn(0)
    if subcmd == "identity":
        let textRes = v3ChengNodeCtlIdentityText(v3ChengNodeCtlRootSeed())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "bootstrap":
        let textRes = v3ChengNodeCtlBootstrapText(v3ChengNodeCtlRootSeed())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "required-surface":
        let textRes = v3ChengNodeCtlRequiredSurfaceText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "compiler":
        return compiler_domain.V3ChengNodeCompilerCommandAt(commandIndex + 1)
    if subcmd == "libp2p":
        return v3ChengNodeCtlLibp2pCommandAt(commandIndex + 1)
    if subcmd == "chain":
        return v3ChengNodeCtlChainCommandAt(commandIndex + 1)
    if subcmd == "chain-init":
        let textRes = v3ChengNodeCtlChainInitText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "chain-mint":
        let textRes = v3ChengNodeCtlChainMintText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "chain-transfer":
        let textRes = v3ChengNodeCtlChainTransferText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "chain-balance":
        let textRes = v3ChengNodeCtlChainBalanceText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "chain-show-state":
        let textRes = v3ChengNodeCtlChainShowStateText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "chain-dump-snapshot":
        let textRes = v3ChengNodeCtlChainDumpSnapshotText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "chain-daemon-serve":
        let textRes = v3ChengNodeCtlChainServeText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "chain-daemon-sync":
        let textRes = v3ChengNodeCtlChainSyncText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "chain-self-test":
        let textRes = v3ChengNodeCtlChainSelfTestText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "head":
        let textRes = v3ChengNodeCtlHeadText(v3ChengNodeCtlRootSeed(),
                                             v3ChengNodeCtlStatePath())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "announce":
        let textRes = v3ChengNodeCtlAnnounceText(v3ChengNodeCtlRootSeed(),
                                                 v3ChengNodeCtlStatePath())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "discover":
        let textRes = v3ChengNodeCtlDiscoverText(v3ChengNodeCtlRootSeed(),
                                                 v3ChengNodeCtlStatePath())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "stream":
        let textRes = v3ChengNodeCtlStreamText(v3ChengNodeCtlRootSeed(),
                                               v3ChengNodeCtlStatePath())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "query":
        let groupRes = v3ChengNodeCtlRequireTextFlag("--group")
        if IsErr(groupRes):
            echo(Error(groupRes))
            return 1
        let kindRes = v3ChengNodeCtlRequireTextFlag("--kind")
        if IsErr(kindRes):
            echo(Error(kindRes))
            return 1
        let keyRes = v3ChengNodeCtlRequireTextFlag("--key")
        if IsErr(keyRes):
            echo(Error(keyRes))
            return 1
        let textRes = v3ChengNodeCtlQueryText(v3ChengNodeCtlRootSeed(),
                                              v3ChengNodeCtlStatePath(),
                                              Value(groupRes),
                                              Value(kindRes),
                                              Value(keyRes),
                                              v3ChengNodeCtlWithDelta())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "balance":
        let assetRes = v3ChengNodeCtlRequireInt32Flag("--asset")
        if IsErr(assetRes):
            echo(Error(assetRes))
            return 1
        let accountRes = v3ChengNodeCtlRequireInt32Flag("--account")
        if IsErr(accountRes):
            echo(Error(accountRes))
            return 1
        let textRes = v3ChengNodeCtlBalanceText(v3ChengNodeCtlRootSeed(),
                                                v3ChengNodeCtlStatePath(),
                                                Value(assetRes),
                                                Value(accountRes),
                                                v3ChengNodeCtlWithDelta())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "did":
        let subjectRes = v3ChengNodeCtlRequireTextFlag("--subject")
        if IsErr(subjectRes):
