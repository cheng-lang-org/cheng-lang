            return 1
        let textRes = v3ChengNodeCtlTransferText(v3ChengNodeCtlRootSeed(),
                                                 v3ChengNodeCtlStatePath(),
                                                 Value(assetRes),
                                                 Value(fromRes),
                                                 Value(toRes),
                                                 Value(amountRes))
        if IsErr(textRes):
