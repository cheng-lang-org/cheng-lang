        let textRes = v3ChengNodeCtlQueryText(v3ChengNodeCtlRootSeed(),
                                              v3ChengNodeCtlStatePath(),
                                              Value(groupRes),
                                              Value(kindRes),
                                              Value(keyRes),
                                              v3ChengNodeCtlWithDelta())
        if IsErr(textRes):
