import std/cmdline as cmdline
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/project/cheng_node as node
import cheng/v3/project/cheng_node_identity as identity

fn v3ChengNodeCtlRootSeed(): str =
    return cmdline.readFlagOrDefault("--root", "cheng_node.devroot")

fn v3ChengNodeCtlUsageText(): str =
    var out = ""
    out = out + "usage: cheng_node ctl <command> [flags]\n\n"
    out = out + "commands:\n"
    out = out + "  identity --root:<seed>\n"
    out = out + "  bootstrap --root:<seed>\n"
    out = out + "  required-surface\n"
    return out

fn v3ChengNodeCtlIdentityText(rootSeed: str): Result[str] =
    let identityRes = identity.V3ChengNodeIdentityDerive(rootSeed)
    if IsErr(identityRes):
        return Err[str](Error(identityRes))
    let id = Value(identityRes)
    var out = ""
    out = out + "root_id=" + layout.fixedBytes32Hex(id.rootId) + "\n"
    out = out + "chain=" + layout.fixedBytes32Hex(id.chainKey) + "\n"
    out = out + "did=" + layout.fixedBytes32Hex(id.didKey) + "\n"
    out = out + "libp2p=" + layout.fixedBytes32Hex(id.libp2pKey) + "\n"
    out = out + "discovery=" + layout.fixedBytes32Hex(id.discoveryKey) + "\n"
    out = out + "oracle=" + layout.fixedBytes32Hex(id.oracleKey) + "\n"
    out = out + "diloco=" + layout.fixedBytes32Hex(id.dilocoKey) + "\n"
    out = out + "vpn=" + layout.fixedBytes32Hex(id.vpnKey) + "\n"
    out = out + "compiler=" + layout.fixedBytes32Hex(id.compilerKey) + "\n"
    out = out + "admin=" + layout.fixedBytes32Hex(id.adminKey) + "\n"
    return Ok[str](out)

fn v3ChengNodeCtlBootstrapText(rootSeed: str): Result[str] =
    let nodeRes = node.V3ChengNodeInit(rootSeed)
    if IsErr(nodeRes):
        return Err[str](Error(nodeRes))
    return Ok[str](node.V3ChengNodeBootstrapSummaryText(Value(nodeRes)))

fn v3ChengNodeCtlRequiredSurfaceText(): Result[str] =
    let nodeRes = node.V3ChengNodeInit("cheng_node.required_surface")
    if IsErr(nodeRes):
        return Err[str](Error(nodeRes))
    return Ok[str](node.V3ChengNodeRequiredSurfaceText(Value(nodeRes)))

fn v3ChengNodeCtlPrintUsageAndReturn(code: int32): int32 =
    echo(v3ChengNodeCtlUsageText())
    return code

fn V3ChengNodeCtlCommand(): int32 =
    let count = cmdline.ParamCount()
    if count < 2:
        return v3ChengNodeCtlPrintUsageAndReturn(0)
    let subcmd = cmdline.ParamStr(2)
    if subcmd == "--help" || subcmd == "-h" || subcmd == "help":
        return v3ChengNodeCtlPrintUsageAndReturn(0)
    if subcmd == "identity":
        let textRes = v3ChengNodeCtlIdentityText(v3ChengNodeCtlRootSeed())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "bootstrap":
        let textRes = v3ChengNodeCtlBootstrapText(v3ChengNodeCtlRootSeed())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "required-surface":
        let textRes = v3ChengNodeCtlRequiredSurfaceText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    return v3ChengNodeCtlPrintUsageAndReturn(2)
