fn v3ChengNodeCtlOracleSubmitText(rootSeed: str,
                                  statePath: str): Result[str] =
    let roundRes = v3ChengNodeCtlRequireInt64Flag("--round")
    if IsErr(roundRes):
        return Err[str](Error(roundRes))
    let pairRes = v3ChengNodeCtlRequireTextFlag("--pair")
    if IsErr(pairRes):
        return Err[str](Error(pairRes))
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let submitRes = node.V3ChengNodeOracleSubmitFixtureRound(core, Value(roundRes))
    if IsErr(submitRes):
        return Err[str](Error(submitRes))
    let writeRes = state.V3ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    let queryRes = node.V3ChengNodeOracleQueryText(core, Value(pairRes), v3ChengNodeCtlWithDelta())
    if IsErr(queryRes):
        return Err[str](Error(queryRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + Value(queryRes)
    return Ok[str](out)

fn v3ChengNodeCtlOracleText(rootSeed: str,
                            statePath: str): Result[str] =
    let pairRes = v3ChengNodeCtlRequireTextFlag("--pair")
    if IsErr(pairRes):
        return Err[str](Error(pairRes))
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadStateInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    return node.V3ChengNodeOracleQueryText(core, Value(pairRes), v3ChengNodeCtlWithDelta())

fn v3ChengNodeCtlDilocoOpenText(rootSeed: str,
                                statePath: str): Result[str] =
    let jobRes = v3ChengNodeCtlRequireTextFlag("--job")
    if IsErr(jobRes):
        return Err[str](Error(jobRes))
    let workersRes = v3ChengNodeCtlRequireInt32Flag("--workers")
    if IsErr(workersRes):
        return Err[str](Error(workersRes))
    let innerStepsRes = v3ChengNodeCtlRequireInt32Flag("--inner-steps")
    if IsErr(innerStepsRes):
        return Err[str](Error(innerStepsRes))
    let timeoutRes = v3ChengNodeCtlRequireInt32Flag("--timeout")
    if IsErr(timeoutRes):
        return Err[str](Error(timeoutRes))
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let openRes = node.V3ChengNodeDilocoOpenJob(core,
                                                Value(jobRes),
                                                Value(workersRes),
                                                Value(innerStepsRes),
                                                Value(timeoutRes))
    if IsErr(openRes):
        return Err[str](Error(openRes))
    let writeRes = state.V3ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    let statusRes = node.V3ChengNodeDilocoStatusText(core, Value(jobRes))
    if IsErr(statusRes):
        return Err[str](Error(statusRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + Value(statusRes)
    return Ok[str](out)

