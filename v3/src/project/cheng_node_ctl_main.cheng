                                          withDelta)

fn v3ChengNodeCtlBalanceText(rootSeed: str,
                             statePath: str,
                             assetId: int32,
                             accountId: int32,
                             withDelta: bool): Result[str] =
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadStateInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    return node.V3ChengNodeBalanceQueryText(core, assetId, accountId, withDelta)

fn v3ChengNodeCtlMintText(rootSeed: str,
                          statePath: str,
                          assetId: int32,
                          accountId: int32,
                          amount: int64): Result[str] =
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let mintRes = node.V3ChengNodeChainMint(core, assetId, accountId, amount)
    if IsErr(mintRes):
        return Err[str](Error(mintRes))
    let writeRes = state.V3ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    let balanceRes = node.V3ChengNodeBalanceQueryText(core, assetId, accountId, false)
    if IsErr(balanceRes):
        return Err[str](Error(balanceRes))
    out = out + Value(balanceRes)
    return Ok[str](out)

fn v3ChengNodeCtlTransferText(rootSeed: str,
                              statePath: str,
                              assetId: int32,
                              fromAccount: int32,
                              toAccount: int32,
                              amount: int64): Result[str] =
    var core: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let transferRes = node.V3ChengNodeChainTransfer(core,
                                                    assetId,
                                                    fromAccount,
                                                    toAccount,
                                                    amount)
    if IsErr(transferRes):
        return Err[str](Error(transferRes))
    let writeRes = state.V3ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    let fromBalanceRes = node.V3ChengNodeBalanceQueryText(core, assetId, fromAccount, false)
    if IsErr(fromBalanceRes):
        return Err[str](Error(fromBalanceRes))
    let toBalanceRes = node.V3ChengNodeBalanceQueryText(core, assetId, toAccount, false)
    if IsErr(toBalanceRes):
        return Err[str](Error(toBalanceRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + "from_result_begin\n"
    out = out + Value(fromBalanceRes) + "\n"
    out = out + "from_result_end\n"
    out = out + "to_result_begin\n"
    out = out + Value(toBalanceRes) + "\n"
    out = out + "to_result_end"
    return Ok[str](out)

fn v3ChengNodeCtlSyncDidText(rootSeed: str,
                             statePath: str): Result[str] =
    var core: node.V3ChengNode
