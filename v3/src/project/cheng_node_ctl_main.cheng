fn v3ChengNodeCtlImportLegacyChainText(rootSeed: str,
                                       legacyStatePath: str,
                                       outPath: str): Result[str] =
    let nodeRes = node.V3ChengNodeInit(rootSeed)
    if IsErr(nodeRes):
        return Err[str](Error(nodeRes))
    var core = Value(nodeRes)
    var snapshot: chain.V3ChainNodeServeSnapshot
    let loadRes = state.V3ChengNodeLoadLegacyChainSnapshotInto(snapshot, legacyStatePath)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let importRes = node.V3ChengNodeImportChainSnapshot(core, snapshot)
    if IsErr(importRes):
        return Err[str](Error(importRes))
    let writeRes = state.V3ChengNodeWriteState(outPath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "legacy_state_path=" + v3ChengNodeCtlAbsolutePath(legacyStatePath) + "\n"
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + node.V3ChengNodeBootstrapSummaryText(core)
    return Ok[str](out)

fn v3ChengNodeCtlImportLegacyOracleText(rootSeed: str,
                                        statePath: str,
                                        legacyStatePath: str): Result[str] =
    var core: node.V3ChengNode
    let loadNodeRes = state.V3ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadNodeRes):
        return Err[str](Error(loadNodeRes))
    var machine: oracle_bft.V3OracleBftStateMachine
    let loadLegacyRes = oracle_host.v3OracleBftLoadState(legacyStatePath, machine)
    if IsErr(loadLegacyRes):
        return Err[str](Error(loadLegacyRes))
    let importRes = node.V3ChengNodeImportOracleState(core, machine)
    if IsErr(importRes):
        return Err[str](Error(importRes))
    let writeRes = state.V3ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "legacy_state_path=" + v3ChengNodeCtlAbsolutePath(legacyStatePath) + "\n"
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + "oracle_has_finalized=" + (machine.hasFinalized ? "1" : "0") + "\n"
    out = out + "oracle_last_round_id=" + strings.Int64ToStr(machine.lastFinalizedRoundId) + "\n"
    out = out + "oracle_last_height=" + strings.Int64ToStr(machine.lastFinalizedHeight)
    return Ok[str](out)

