fn v3UnimakerFixed32SeqContains(values: layout.FixedBytes32[],
                                needle: layout.FixedBytes32): bool =
    for i in 0..<values.len:
        if layout.fixedBytes32Equal(values[i], needle):
            return true
    return false

fn v3UnimakerStrSeqContains(values: str[],
                            needle: str): bool =
    let normalizedNeedle = strutil.ToLowerAscii(strutil.Strip(needle))
    if len(normalizedNeedle) <= 0:
        return false
    for i in 0..<values.len:
        let normalizedValue = strutil.ToLowerAscii(strutil.Strip(values[i]))
        if normalizedValue == normalizedNeedle:
            return true
    return false

fn v3UnimakerCapsuleKeywordMatch(capsule: V3EvoCapsule,
                                 keyword: str): bool =
    if v3UnimakerStrSeqContains(capsule.keywords, keyword):
        return true
    let normalizedKeyword = strutil.ToLowerAscii(strutil.Strip(keyword))
    if len(normalizedKeyword) <= 0:
        return false
    let normalizedText = strutil.ToLowerAscii(capsule.contentText)
    return strutil.Contains(normalizedText, normalizedKeyword)

fn v3UnimakerGraphHeadCid(capsules: V3EvoCapsule[]): layout.FixedBytes32 =
    var ordered: str[] = []
    for i in 0..<capsules.len:
        add(ordered, layout.fixedBytes32Hex(capsules[i].capsuleCid))
    if ordered.len > 1:
        var i = 1
        while i < ordered.len:
            let value = ordered[i]
            var j = i
            while j > 0:
                if !v3UnimakerStrLess(value, ordered[j - 1]):
                    break
                ordered[j] = ordered[j - 1]
                j = j - 1
            ordered[j] = value
            i = i + 1
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    v3UnimakerAppendText(buf, "v3.unimaker.graph.head")
    lt.v3AppendU32BE(buf, ordered.len)
    for i in 0..<ordered.len:
        v3UnimakerAppendText(buf, ordered[i])
    return hash256.sha256Fixed(layout.byteBufView(buf))
