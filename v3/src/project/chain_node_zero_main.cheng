import std/system
import cheng/v3/chain/lsmr as lsmr
import cheng/v3/project/chain_node as node

fn main(): int32 =
    let addrRes = lsmr.v3LsmrAddressFromSeed("chain-node-a", 3)
    assert(addrRes.ok, "v3 chain_node zero main: address")
    var zero: node.V3ChainNode
    node.v3ChainNodeZeroInto(zero, "node-a", Value(addrRes))
    assert(zero.nextEpoch == 1, "v3 chain_node zero main: epoch")
    echo("v3 chain_node_zero_main ok")
    return 0
