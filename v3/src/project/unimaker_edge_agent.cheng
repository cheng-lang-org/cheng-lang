import std/result
import std/system as system
import std/os as os
import std/strings as strings
import std/strutils as strutil
import cheng/v3/std/bytes_layout as layout
import cheng/v3/tooling/path as v3path
import cheng/v3/libp2p/mobile/mobile_sdk as mobile_sdk
import cheng/v3/project/unimaker_edge_types as types
import cheng/v3/project/unimaker_evomap_protocol as proto

type
    V3UnimakerAgent =
        cfg: types.V3UnimakerAgentConfig
        sdk: mobile_sdk.V3MobileSdk
        identity: types.V3AgentIdentity
        genes: types.V3EvoGene[]
        capsules: types.V3EvoCapsule[]
        nodes: types.V3MemoryNode[]
        edges: types.V3MemoryEdge[]
        headCid: layout.FixedBytes32
        nextSequence: int32

fn v3UnimakerAgentRootDir(cfg: types.V3UnimakerAgentConfig): str =
    let rootDirText: str = strutil.Strip(cfg.rootDir)
    if strings.Len(rootDirText) > 0:
        return cfg.rootDir
    return v3path.V3PathCurrentDir()

fn v3UnimakerAgentAbsoluteIdentityStorePath(cfg: types.V3UnimakerAgentConfig): str =
    return v3path.V3PathAbsolute(v3UnimakerAgentRootDir(cfg), cfg.identityStorePath)

fn v3UnimakerAgentAbsoluteEventLogPath(cfg: types.V3UnimakerAgentConfig): str =
    return v3path.V3PathAbsolute(v3UnimakerAgentRootDir(cfg), cfg.eventLogPath)

fn v3UnimakerAgentRequire(ok: bool, message: str) =
    if !ok:
        system.panic(message)

fn v3UnimakerAgentFindGenePos(genes: types.V3EvoGene[],
                              capability: str): int32 =
    for i in 0..<genes.len:
        if genes[i].capability == capability:
            return i
    return -1

fn v3UnimakerAgentFindCapsulePos(capsules: types.V3EvoCapsule[],
                                 capsuleCid: layout.FixedBytes32): int32 =
    for i in 0..<capsules.len:
        if layout.fixedBytes32Equal(capsules[i].capsuleCid, capsuleCid):
            return i
    return -1

fn v3UnimakerAgentCloneCapsules(values: types.V3EvoCapsule[]): types.V3EvoCapsule[] =
    var out: types.V3EvoCapsule[]
    for i in 0..<values.len:
        add(out, types.v3UnimakerCapsuleClone(values[i]))
    return out

fn v3UnimakerAgentEdgeExists(edges: types.V3MemoryEdge[],
                             edgeKind: str,
                             fromCid: layout.FixedBytes32,
                             toCid: layout.FixedBytes32): bool =
    for i in 0..<edges.len:
        if edges[i].edgeKind != edgeKind:
            continue
        if !layout.fixedBytes32Equal(edges[i].fromCid, fromCid):
            continue
        if !layout.fixedBytes32Equal(edges[i].toCid, toCid):
            continue
        return true
    return false

fn v3UnimakerAgentCurrentCursor(agent: V3UnimakerAgent): types.V3SyncCursor =
    return types.v3UnimakerCursorMake(agent.capsules.len, agent.headCid)

fn v3UnimakerAgentCapsuleCount(agent: V3UnimakerAgent): int32 =
    return agent.capsules.len

fn v3UnimakerAgentNodeCount(agent: V3UnimakerAgent): int32 =
    return agent.nodes.len

fn v3UnimakerAgentEdgeCount(agent: V3UnimakerAgent): int32 =
    return agent.edges.len

fn v3UnimakerAgentHeadCid(agent: V3UnimakerAgent): layout.FixedBytes32 =
    return agent.headCid

fn v3UnimakerAgentHelloPayload(agent: V3UnimakerAgent): str =
    var hello = proto.V3EvoMapA2AHello()
    hello.version = types.v3UnimakerProtocolVersion
    hello.identity = agent.identity
    hello.cursor = v3UnimakerAgentCurrentCursor(agent)
    hello.genes = agent.genes
    return proto.v3UnimakerProtocolEncodeHello(hello)

fn v3UnimakerAgentResultPayload(agent: V3UnimakerAgent,
                                plan: types.V3AgentPlan): str =
    var resultValue = proto.V3EvoMapA2AResult()
    resultValue.version = types.v3UnimakerProtocolVersion
    resultValue.taskId = plan.taskId
    resultValue.actionKind = plan.actionKind
    resultValue.planText = plan.planText
    resultValue.headCid = agent.headCid
    resultValue.selectedCapsuleCids = types.v3UnimakerCloneFixed32Seq(plan.selectedCapsuleCids)
    resultValue.memoryHitCount = plan.memoryHitCount
    resultValue.confidenceScore = plan.confidenceScore
    resultValue.geneCid = plan.geneCid
    return proto.v3UnimakerProtocolEncodeResult(resultValue)

fn v3UnimakerAgentPersistCapsules(cfg: types.V3UnimakerAgentConfig,
                                  capsules: types.V3EvoCapsule[]): Result[bool] =
    let path = v3UnimakerAgentAbsoluteEventLogPath(cfg)
    if len(path) <= 0:
        return Err[bool]("v3 unimaker agent: empty event log path")
    let tmpPath = path + ".tmp"
    if os.FileExists(tmpPath):
        let _ = os.RemoveFile(tmpPath)
    var lines: str[]
    for i in 0..<capsules.len:
        let line = proto.v3UnimakerProtocolEncodeCapsuleNode(capsules[i])
        add(lines, line)
    var text = strutil.Join(lines, "\n")
    if len(text) > 0:
        text = text + "\n"
    if !v3path.V3WriteTextFile("", tmpPath, text):
        return Err[bool]("v3 unimaker agent: write tmp event log failed")
    if os.FileExists(path):
        let _ = os.RemoveFile(path)
    if !os.RenameFile(tmpPath, path):
        return Err[bool]("v3 unimaker agent: rename event log failed")
    return Ok[bool](true)

fn v3UnimakerAgentLoadCapsules(cfg: types.V3UnimakerAgentConfig): Result[types.V3EvoCapsule[]] =
    let path = v3UnimakerAgentAbsoluteEventLogPath(cfg)
    if len(path) <= 0:
        return Err[types.V3EvoCapsule[]]("v3 unimaker agent: empty event log path")
    if !v3path.V3PathFileExists(path):
        return Ok[types.V3EvoCapsule[]]([])
    let text = v3path.V3ReadTextFile("", path)
    if len(text) <= 0:
        return Ok[types.V3EvoCapsule[]]([])
    let lines = strutil.Split(text, '\n')
    var out: types.V3EvoCapsule[]
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if len(line) <= 0:
            continue
        let nodeRes = proto.v3UnimakerProtocolParseText(line)
        if IsErr(nodeRes):
            return Err[types.V3EvoCapsule[]](Error(nodeRes))
        let capsuleRes = proto.v3UnimakerProtocolDecodeCapsuleNode(Value(nodeRes))
        if IsErr(capsuleRes):
            return Err[types.V3EvoCapsule[]](Error(capsuleRes))
        add(out, Value(capsuleRes))
    return Ok[types.V3EvoCapsule[]](out)

fn v3UnimakerAgentRebuildGraph(agent: var V3UnimakerAgent) =
    agent.nodes = []
    agent.edges = []
    for i in 0..<agent.capsules.len:
        let capsule = agent.capsules[i]
        add(agent.nodes, types.v3UnimakerMemoryNodeFromCapsule(capsule))
        if !v3UnimakerAgentEdgeExists(agent.edges,
                                      types.v3UnimakerEdgeKindFromDevice,
                                      agent.identity.identityCid,
                                      capsule.capsuleCid):
            add(agent.edges, types.v3UnimakerMemoryEdgeMake(types.v3UnimakerEdgeKindFromDevice,
                                                            agent.identity.identityCid,
                                                            capsule.capsuleCid))
        for j in 0..<capsule.parentCids.len:
            if !v3UnimakerAgentEdgeExists(agent.edges,
                                          capsule.relationKind,
                                          capsule.capsuleCid,
                                          capsule.parentCids[j]):
                add(agent.edges, types.v3UnimakerMemoryEdgeMake(capsule.relationKind,
                                                                capsule.capsuleCid,
                                                                capsule.parentCids[j]))
    agent.headCid = types.v3UnimakerGraphHeadCid(agent.capsules)
    agent.nextSequence = agent.capsules.len + 1

fn v3UnimakerAgentValidateEvent(event: types.V3EvolutionEvent): Result[bool] =
    if !types.v3UnimakerEventKindValid(event.eventKind):
        return Err[bool]("v3 unimaker agent: invalid event kind")
    let contentText: str = strutil.Strip(event.contentText)
    if strings.Len(contentText) <= 0:
        return Err[bool]("v3 unimaker agent: empty event content")
    if event.createdAtEpochSeconds <= int64(0):
        return Err[bool]("v3 unimaker agent: invalid event timestamp")
    if len(event.relationKind) > 0:
        if !types.v3UnimakerEdgeKindValid(event.relationKind):
            return Err[bool]("v3 unimaker agent: invalid event relation kind")
        if event.relationKind == types.v3UnimakerEdgeKindFromDevice:
            return Err[bool]("v3 unimaker agent: from_device is reserved")
    return Ok[bool](true)

fn v3UnimakerAgentValidateIncomingCapsule(existing: types.V3EvoCapsule[],
                                          staged: types.V3EvoCapsule[],
                                          capsule: types.V3EvoCapsule): Result[bool] =
    for i in 0..<capsule.parentCids.len:
        if v3UnimakerAgentFindCapsulePos(existing, capsule.parentCids[i]) >= 0:
            continue
        if v3UnimakerAgentFindCapsulePos(staged, capsule.parentCids[i]) >= 0:
            continue
        return Err[bool]("v3 unimaker agent: parent capsule missing")
    return Ok[bool](true)

fn v3UnimakerAgentHitBetter(left: types.V3MemoryHit,
                            right: types.V3MemoryHit): bool =
    if left.score != right.score:
        return left.score > right.score
    if left.capsule.createdAtEpochSeconds != right.capsule.createdAtEpochSeconds:
        return left.capsule.createdAtEpochSeconds > right.capsule.createdAtEpochSeconds
    return left.capsule.sequence > right.capsule.sequence

fn v3UnimakerAgentSortHits(hits: var types.V3MemoryHit[]) =
    if hits.len <= 1:
        return
    var i = 1
    while i < hits.len:
        let value = hits[i]
        var j = i
        while j > 0:
            if !v3UnimakerAgentHitBetter(value, hits[j - 1]):
                break
            hits[j] = hits[j - 1]
            j = j - 1
        hits[j] = value
        i = i + 1

fn v3UnimakerAgentMatchCapsule(capsule: types.V3EvoCapsule,
                               query: types.V3MemoryQuery): types.V3MemoryHit =
    var hit = types.V3MemoryHit()
    hit.capsule = types.v3UnimakerCapsuleClone(capsule)
    var labels: str[]
    if len(query.taskId) > 0:
        if capsule.taskId == query.taskId:
            hit.score = hit.score + 3
            add(labels, "task")
    if len(query.keyword) > 0:
        if types.v3UnimakerCapsuleKeywordMatch(capsule, query.keyword):
            hit.score = hit.score + 1
            add(labels, "keyword")
    if query.hasParent:
        if types.v3UnimakerFixed32SeqContains(capsule.parentCids, query.parentCid):
            hit.score = hit.score + 2
            add(labels, "parent")
    hit.matchedBy = strutil.Join(labels, "+")
    return hit

fn v3UnimakerAgentPlanHits(agent: V3UnimakerAgent,
                           task: types.V3AgentTask): types.V3MemoryHit[] =
    var hits: types.V3MemoryHit[]
    for i in 0..<agent.capsules.len:
        var query = types.V3MemoryQuery()
        query.taskId = task.taskId
        query.limit = agent.capsules.len
        var hit = v3UnimakerAgentMatchCapsule(agent.capsules[i], query)
        for j in 0..<task.keywords.len:
            if types.v3UnimakerCapsuleKeywordMatch(agent.capsules[i], task.keywords[j]):
                hit.score = hit.score + 1
                if len(hit.matchedBy) > 0:
                    hit.matchedBy = hit.matchedBy + "+"
                hit.matchedBy = hit.matchedBy + "task_keyword"
                break
        if hit.score <= 0:
            continue
        add(hits, hit)
    v3UnimakerAgentSortHits(hits)
    return hits

fn v3UnimakerAgentInit(cfg: types.V3UnimakerAgentConfig): V3UnimakerAgent =
    let rootDir = v3UnimakerAgentRootDir(cfg)
    let eventLogPathText: str = strutil.Strip(cfg.eventLogPath)
    let identityStorePathText: str = strutil.Strip(cfg.identityStorePath)
    v3UnimakerAgentRequire(strings.Len(eventLogPathText) > 0,
                           "v3 unimaker agent: event log path required")
    v3UnimakerAgentRequire(strings.Len(identityStorePathText) > 0,
                           "v3 unimaker agent: identity store path required")
    var out = V3UnimakerAgent()
    out.cfg = cfg
    out.cfg.rootDir = rootDir
    let identityStorePath = v3UnimakerAgentAbsoluteIdentityStorePath(out.cfg)
    let eventLogPath = v3UnimakerAgentAbsoluteEventLogPath(out.cfg)
    v3UnimakerAgentRequire(len(identityStorePath) > 0,
                           "v3 unimaker agent: invalid identity store path")
    v3UnimakerAgentRequire(len(eventLogPath) > 0,
                           "v3 unimaker agent: invalid event log path")
    var sdk = mobile_sdk.v3MobileSdkInit("")
    let initRes = mobile_sdk.v3MobileSdkInitWithDidStoreFill(sdk,
                                                             identityStorePath,
                                                             cfg.rootSeedHint,
                                                             cfg.deviceSeedHint,
                                                             cfg.deviceLabelHint,
                                                             cfg.epochSeconds)
    if IsErr(initRes):
        system.panic("v3 unimaker agent: identity init failed: " + Error(initRes))
    mobile_sdk.v3MobileSdkStart(sdk)
    mobile_sdk.v3MobileSdkSetMdns(sdk, true, 15)
    mobile_sdk.v3MobileSdkSetTrustedInfra(sdk, true)
    v3UnimakerAgentRequire(sdk.host.hasDidIdentity,
                           "v3 unimaker agent: sdk missing did identity")
    out.sdk = sdk
    out.identity = types.v3UnimakerAgentIdentityMake(sdk.host.didIdentity)
    out.genes = types.v3UnimakerDefaultGenes()
    let loadRes = v3UnimakerAgentLoadCapsules(out.cfg)
    if IsErr(loadRes):
        system.panic("v3 unimaker agent: load capsules failed: " + Error(loadRes))
    out.capsules = Value(loadRes)
    v3UnimakerAgentRebuildGraph(out)
    return out

fn v3UnimakerAgentIngest(agent: var V3UnimakerAgent,
                         event: types.V3EvolutionEvent): Result[types.V3EvoCapsule] =
    let validateRes = v3UnimakerAgentValidateEvent(event)
    if IsErr(validateRes):
        return Err[types.V3EvoCapsule](Error(validateRes))
    let genePos = v3UnimakerAgentFindGenePos(agent.genes, "event_ingest")
    if genePos < 0:
        return Err[types.V3EvoCapsule]("v3 unimaker agent: missing event_ingest gene")
    let capsule = types.v3UnimakerCapsuleMake(agent.nextSequence,
                                              agent.identity,
                                              event,
                                              agent.genes[genePos])
    if v3UnimakerAgentFindCapsulePos(agent.capsules, capsule.capsuleCid) >= 0:
        return Err[types.V3EvoCapsule]("v3 unimaker agent: duplicate capsule")
    var staged = v3UnimakerAgentCloneCapsules(agent.capsules)
    add(staged, capsule)
    let persistRes = v3UnimakerAgentPersistCapsules(agent.cfg, staged)
    if IsErr(persistRes):
        return Err[types.V3EvoCapsule](Error(persistRes))
    agent.capsules = staged
    v3UnimakerAgentRebuildGraph(agent)
    return Ok[types.V3EvoCapsule](types.v3UnimakerCapsuleClone(capsule))

fn v3UnimakerAgentRecall(agent: V3UnimakerAgent,
                         query: types.V3MemoryQuery): Result[types.V3MemoryHit[]] =
    if query.limit <= 0:
        return Err[types.V3MemoryHit[]]("v3 unimaker agent: query limit must be > 0")
    if len(query.taskId) <= 0 && len(query.keyword) <= 0 && !query.hasParent:
        return Err[types.V3MemoryHit[]]("v3 unimaker agent: empty memory query")
    var hits: types.V3MemoryHit[]
    for i in 0..<agent.capsules.len:
        let hit = v3UnimakerAgentMatchCapsule(agent.capsules[i], query)
        if hit.score <= 0:
            continue
        add(hits, hit)
    v3UnimakerAgentSortHits(hits)
    if hits.len <= query.limit:
        return Ok[types.V3MemoryHit[]](hits)
    var limited: types.V3MemoryHit[]
    for i in 0..<query.limit:
        add(limited, hits[i])
    return Ok[types.V3MemoryHit[]](limited)

fn v3UnimakerAgentPlan(agent: V3UnimakerAgent,
                       task: types.V3AgentTask): Result[types.V3AgentPlan] =
    let genePos = v3UnimakerAgentFindGenePos(agent.genes, "task_planning")
    if genePos < 0:
        return Err[types.V3AgentPlan]("v3 unimaker agent: missing task_planning gene")
    let taskIdText: str = strutil.Strip(task.taskId)
    if strings.Len(taskIdText) <= 0:
        return Err[types.V3AgentPlan]("v3 unimaker agent: task id required")
    let hits = v3UnimakerAgentPlanHits(agent, task)
    var out = types.V3AgentPlan()
    out.taskId = task.taskId
    out.geneCid = agent.genes[genePos].geneCid
    out.memoryHitCount = hits.len
    if hits.len > 0:
        out.actionKind = types.v3UnimakerPlanActionReuseMemory
        out.confidenceScore = hits[0].score
        add(out.selectedCapsuleCids, hits[0].capsule.capsuleCid)
        if hits.len > 1:
            add(out.selectedCapsuleCids, hits[1].capsule.capsuleCid)
        out.planText = "reuse memory capsules for task " + task.taskId
        return Ok[types.V3AgentPlan](out)
    out.actionKind = types.v3UnimakerPlanActionCaptureFirst
    out.confidenceScore = 1
    out.planText = "capture first capsule for task " + task.taskId
    return Ok[types.V3AgentPlan](out)

fn v3UnimakerAgentSyncPush(agent: V3UnimakerAgent,
                           peer: var types.V3UnimakerSyncPeer): Result[types.V3SyncReport] =
    if !types.v3UnimakerTransportKindValid(peer.transportKind):
        return Err[types.V3SyncReport]("v3 unimaker agent: invalid peer transport kind")
    peer.lastHelloPayload = v3UnimakerAgentHelloPayload(agent)
    let start = peer.remoteCursor.eventCount
    var push = proto.V3EvoMapGeppush()
    push.version = types.v3UnimakerProtocolVersion
    push.cursor = v3UnimakerAgentCurrentCursor(agent)
    var i = start
    while i < agent.capsules.len:
        add(push.capsules, types.v3UnimakerCapsuleClone(agent.capsules[i]))
        i = i + 1
    let payload = proto.v3UnimakerProtocolEncodePush(push)
    peer.outboundPushPayload = payload
    peer.remoteCursor = push.cursor
    var report = types.V3SyncReport()
    report.pushedCount = push.capsules.len
    report.headCid = agent.headCid
    report.cursor = push.cursor
    report.requestPath = proto.v3UnimakerProtocolPushPath()
    report.payloadText = payload
    return Ok[types.V3SyncReport](report)

fn v3UnimakerAgentSyncPull(agent: var V3UnimakerAgent,
                           peer: var types.V3UnimakerSyncPeer,
                           cursor: types.V3SyncCursor): Result[types.V3SyncReport] =
    if !types.v3UnimakerTransportKindValid(peer.transportKind):
        return Err[types.V3SyncReport]("v3 unimaker agent: invalid peer transport kind")
    var pull = proto.V3EvoMapGeppull()
    pull.version = types.v3UnimakerProtocolVersion
    pull.cursor = cursor
    peer.outboundPullPayload = proto.v3UnimakerProtocolEncodePull(pull)
    var report = types.V3SyncReport()
    report.requestPath = proto.v3UnimakerProtocolPullPath()
    report.payloadText = peer.outboundPullPayload
    let inboundPushPayload: str = strutil.Strip(peer.inboundPushPayload)
    if strings.Len(inboundPushPayload) <= 0:
        report.headCid = agent.headCid
        report.cursor = v3UnimakerAgentCurrentCursor(agent)
        return Ok[types.V3SyncReport](report)
    let pushRes = proto.v3UnimakerProtocolDecodePush(peer.inboundPushPayload)
    if IsErr(pushRes):
        return Err[types.V3SyncReport](Error(pushRes))
    let push = Value(pushRes)
    report.pulledCount = push.capsules.len
    var staged = v3UnimakerAgentCloneCapsules(agent.capsules)
    var mergedCount: int32
    var duplicateCount: int32
    for i in 0..<push.capsules.len:
        let capsule = push.capsules[i]
        if v3UnimakerAgentFindCapsulePos(staged, capsule.capsuleCid) >= 0:
            duplicateCount = duplicateCount + 1
            continue
        let validateRes = v3UnimakerAgentValidateIncomingCapsule(agent.capsules, staged, capsule)
        if IsErr(validateRes):
            return Err[types.V3SyncReport](Error(validateRes))
        add(staged, types.v3UnimakerCapsuleClone(capsule))
        mergedCount = mergedCount + 1
    let expectedHead = types.v3UnimakerGraphHeadCid(staged)
    if !layout.fixedBytes32Equal(expectedHead, push.cursor.headCid):
        return Err[types.V3SyncReport]("v3 unimaker agent: remote head cid mismatch")
    if mergedCount > 0:
        let persistRes = v3UnimakerAgentPersistCapsules(agent.cfg, staged)
        if IsErr(persistRes):
            return Err[types.V3SyncReport](Error(persistRes))
        agent.capsules = staged
        v3UnimakerAgentRebuildGraph(agent)
    report.mergedCount = mergedCount
    report.duplicateCount = duplicateCount
    report.headCid = agent.headCid
    report.cursor = v3UnimakerAgentCurrentCursor(agent)
    return Ok[types.V3SyncReport](report)
