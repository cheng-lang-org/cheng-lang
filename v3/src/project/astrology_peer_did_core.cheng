import std/system
import std/result
import std/strings as strings
import cheng/v3/std/bytes_layout as layout
import cheng/v3/std/crypto/hash256
import cheng/v3/libp2p/identity/did

const
    v3AstrologyPeerDidSeedPrefix = "v3.astrology.peer.bind|"

type
    V3AstrologyPeerDidUser =
        didText: str
        peerIdText: str
        displayName: str
        rootSeed: str
        boundAtEpochSeconds: did.V3DidWord64
        bindingDigest: layout.FixedBytes32

fn v3AstrologyPeerDidIsSpace(ch: char): bool =
    let code = int32(ch)
    if code == 32:
        return true
    if code == 9:
        return true
    if code == 10:
        return true
    if code == 13:
        return true
    return false

fn v3AstrologyPeerDidNormalizePeerText(peerIdText: str): str =
    if len(peerIdText) <= 0:
        return ""
    var start = 0
    var stop = len(peerIdText) - 1
    while start <= stop && v3AstrologyPeerDidIsSpace(peerIdText[start]):
        start = start + 1
    while stop >= start && v3AstrologyPeerDidIsSpace(peerIdText[stop]):
        stop = stop - 1
    if stop < start:
        return ""
    var out = ""
    var i = start
    while i <= stop:
        out = out + strings.CharToStr(peerIdText[i])
        i = i + 1
    return out

fn v3AstrologyPeerDidDefaultDisplayName(peerIdText: str): str =
    let normalized = v3AstrologyPeerDidNormalizePeerText(peerIdText)
    if len(normalized) <= 0:
        return "DID 用户"
    var preview = ""
    var i = 0
    while i < len(normalized) && i < 8:
        preview = preview + strings.CharToStr(normalized[i])
        i = i + 1
    return "DID 用户 " + preview

fn v3AstrologyPeerDidRootSeed(peerIdText: str): str =
    return v3AstrologyPeerDidSeedPrefix + v3AstrologyPeerDidNormalizePeerText(peerIdText)

fn v3AstrologyPeerDidBindingDigest(peerIdText: str,
                                   didText: str,
                                   displayName: str,
                                   epochSeconds: int64): layout.FixedBytes32 =
    var payload = "peer=" + peerIdText
    payload = payload + "|did=" + didText
    payload = payload + "|display=" + displayName
    payload = payload + "|bound_at=" + strings.Int64ToStr(epochSeconds)
    return hash256.sha256Fixed(layout.byteSpanFromBytes(bytesFromString("v3.astrology.peer.did|" + payload)))

fn v3AstrologyPeerDidUserMake(peerIdText: str,
                              displayName: str,
                              epochSeconds: int64): Result[V3AstrologyPeerDidUser] =
    let normalizedPeer = v3AstrologyPeerDidNormalizePeerText(peerIdText)
    if len(normalizedPeer) <= 0:
        return Err[V3AstrologyPeerDidUser]("v3 astrology peer did: empty peer id")
    let normalizedDisplayName = v3AstrologyPeerDidNormalizePeerText(displayName)
    var finalDisplayName = v3AstrologyPeerDidDefaultDisplayName(normalizedPeer)
    if len(normalizedDisplayName) > 0:
        finalDisplayName = normalizedDisplayName
    let rootSeed = v3AstrologyPeerDidRootSeed(normalizedPeer)
    var out = V3AstrologyPeerDidUser()
    out.peerIdText = normalizedPeer
    out.displayName = finalDisplayName
    out.rootSeed = rootSeed
    out.didText = did.v3DidFromRootSeed(rootSeed)
    out.boundAtEpochSeconds = did.v3DidWord64FromInt64(epochSeconds)
    out.bindingDigest = v3AstrologyPeerDidBindingDigest(normalizedPeer,
                                                        out.didText,
                                                        finalDisplayName,
                                                        epochSeconds)
    return Ok[V3AstrologyPeerDidUser](out)

fn v3AstrologyPeerDidUserMatches(user: V3AstrologyPeerDidUser, peerIdText: str): bool =
    return user.peerIdText == v3AstrologyPeerDidNormalizePeerText(peerIdText)

fn v3AstrologyPeerDidUserSummary(user: V3AstrologyPeerDidUser): str =
    return user.displayName + " | " + user.didText + " | peer=" + user.peerIdText
