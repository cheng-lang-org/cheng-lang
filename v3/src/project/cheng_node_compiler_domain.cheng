fn V3ChengNodeCompilerStatusText(): str =
    var out = ""
    out = out + "cheng_node.compiler_domain\n"
    out = out + "version=v3.compiler_runtime.v1\n"
    out = out + "execution=argv_control_plane\n"
    out = out + "bootstrap_mode=v3_selfhost\n"
    out = out + "ordinary_command=system-link-exec\n"
    out = out + "ordinary_pipeline=node_control_plane_bridge_handoff_until_selfhost_native_codegen\n"
    out = out + "root=" + v3ChengNodeCompilerRoot()
    return out

fn v3ChengNodeCompilerBuildPlan(): Result[sexec.V3SystemLinkExecPlan] =
    let reqRes = v3ChengNodeCompilerRequest()
    if IsErr(reqRes):
        return Err[sexec.V3SystemLinkExecPlan](Error(reqRes))
    let requestedWorldHead = strutil.Strip(cmdline.readFlagOrDefault("--world-head", ""))
    let lockPath = strutil.Strip(cmdline.readFlagOrDefault("--lock", ""))
    let baselineSurfacePath = strutil.Strip(cmdline.readFlagOrDefault("--baseline-surface", ""))
    let channelRaw = strutil.Strip(cmdline.readFlagOrDefault("--channel", "stable"))
    return sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(v3ChengNodeCompilerRoot(),
                                                              Value(reqRes),
                                                              requestedWorldHead,
                                                              lockPath,
                                                              baselineSurfacePath,
                                                              channelRaw)

fn V3ChengNodeCompilerBuildPlanText(): Result[str] =
    let planRes = v3ChengNodeCompilerBuildPlan()
    if IsErr(planRes):
        return Err[str](Error(planRes))
    return Ok[str](sexec.v3SystemLinkExecPlanReport(Value(planRes)))

fn V3ChengNodeCompilerSystemLinkExecText(): Result[str] =
    let reqRes = v3ChengNodeCompilerRequest()
    if IsErr(reqRes):
        return Err[str](Error(reqRes))
    let planRes = v3ChengNodeCompilerBuildPlan()
    if IsErr(planRes):
        return Err[str](Error(planRes))
    let req = Value(reqRes)
    let plan = Value(planRes)
    let rootDir = v3ChengNodeCompilerRoot()
    let report = sexec.v3SystemLinkExecPlanReport(plan)
    if !v3ChengNodeCompilerWriteOptionalReport(rootDir, req.reportPath, report):
        return Err[str]("cheng_node compiler: failed to write report: " + req.reportPath)
    var bridgeMaterializeErr = ""
    if !v3ChengNodeCompilerMaterializeBrowserBridgeOutputs(rootDir, plan, bridgeMaterializeErr):
        if len(bridgeMaterializeErr) > 0:
            return Err[str](bridgeMaterializeErr)
        return Err[str]("cheng_node compiler: failed to materialize browser bridge outputs")
    let bridgeCompiler = v3ChengNodeCompilerBridgeCompilerPath(rootDir)
    if len(bridgeCompiler) > 0:
        let bridgeArgsRes = v3ChengNodeCompilerSystemLinkExecArgs(req, plan)
        if IsErr(bridgeArgsRes):
            return Err[str](Error(bridgeArgsRes))
        var forwardArgv: str[]
        add(forwardArgv, "system-link-exec")
        let bridgeArgs = Value(bridgeArgsRes)
        for i in 0..<bridgeArgs.len:
            add(forwardArgv, bridgeArgs[i])
        var bridgeOutput = ""
        let bridgeRc = v3ChengNodeCompilerRunBridgeCapture(rootDir,
                                                           bridgeCompiler,
                                                           forwardArgv,
                                                           ["CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"],
                                                           bridgeOutput)
        if bridgeRc != 0:
            var err = "cheng_node compiler: bridge compiler failed"
            if len(bridgeOutput) > 0:
                err = bridgeOutput
            if len(report) > 0:
                err = err + "\n" + report
            return Err[str](err)
        bridgeMaterializeErr = ""
        if !v3ChengNodeCompilerMaterializeBrowserBridgeOutputs(rootDir, plan, bridgeMaterializeErr):
            if len(bridgeMaterializeErr) > 0:
                return Err[str](bridgeMaterializeErr)
            return Err[str]("cheng_node compiler: failed to restore browser bridge outputs")
        if len(req.reportPath) > 0 && v3path.V3PathFileExists(v3path.V3PathAbsolute(rootDir, req.reportPath)):
            return Ok[str](strutil.Strip(v3path.V3ReadTextFile(rootDir, req.reportPath)))
        if len(bridgeOutput) > 0:
            return Ok[str](bridgeOutput)
        return Ok[str](report)
    if sexec.v3SystemLinkExecPlanReady(plan):
        return Err[str]("cheng_node compiler: missing live Cheng bridge for system-link-exec\n" + report)
    if plan.primaryObjectPlan.missingReasons.len > 0:
        return Err[str]("cheng_node compiler: primary object machine code not emitted\n" + report)
    return Err[str]("cheng_node compiler: ordinary pipeline blocked\n" + report)

fn V3ChengNodeCompilerCsgText(): Result[str] =
    let planRes = v3ChengNodeCompilerBuildPlan()
    if IsErr(planRes):
        return Err[str](Error(planRes))
    return Ok[str](ccsg.v3CompilerCsgReport(Value(planRes).compilerCsg))

fn V3ChengNodeCompilerSurfaceReportText(): Result[str] =
    let planRes = v3ChengNodeCompilerBuildPlan()
    if IsErr(planRes):
        return Err[str](Error(planRes))
    return Ok[str](ccsg.v3CompilerExportSurfaceReport(Value(planRes).exportSurface))

fn V3ChengNodeCompilerReceiptText(): Result[str] =
