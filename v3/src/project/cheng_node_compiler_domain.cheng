    if IsErr(planRes):
        return Err[str](Error(planRes))
    return Ok[str](ccsg.v3CompileReceiptReport(Value(planRes).compileReceipt))

fn V3ChengNodeCompilerWorldSyncText(): Result[str] =
    let sourcePathRes = v3ChengNodeCompilerRequireFlag("--in")
    if IsErr(sourcePathRes):
        return Err[str](Error(sourcePathRes))
    let outputPathRes = v3ChengNodeCompilerRequireFlag("--out")
    if IsErr(outputPathRes):
        return Err[str](Error(outputPathRes))
    return cwlp.v3CompilerWorldSyncSmokeReport(v3ChengNodeCompilerRoot(),
                                               Value(sourcePathRes),
                                               Value(outputPathRes))

fn V3ChengNodeCompilerMaterializeWorldMirrorsText(): Result[str] =
    let bundlePrefixRes = v3ChengNodeCompilerRequireFlag("--in")
    if IsErr(bundlePrefixRes):
