                                                                                             Value(bundlePrefixRes))
    if IsErr(materializeRes):
        return Err[str](Error(materializeRes))
    return Ok[str](cwlp.v3CompilerWorldManagedMirrorMaterializeReport(Value(bundlePrefixRes),
                                                                      Value(materializeRes)))

fn V3ChengNodeCompilerFreshNodeSelfhostText(): Result[str] =
    let reqRes = v3ChengNodeCompilerRequest()
    if IsErr(reqRes):
        return Err[str](Error(reqRes))
    let planRes = v3ChengNodeCompilerBuildPlan()
    if IsErr(planRes):
        return Err[str](Error(planRes))
    return cwlp.v3CompilerWorldFreshNodeSelfhostReport(v3ChengNodeCompilerRoot(),
                                                       Value(reqRes),
                                                       Value(planRes))

fn v3ChengNodeCompilerEquivalenceProofText(): Result[str] =
    let baselineCsgRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-csg", ""))
    if IsErr(baselineCsgRes):
        return Err[str](Error(baselineCsgRes))
    let migratedCsgRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-csg", ""))
    if IsErr(migratedCsgRes):
        return Err[str](Error(migratedCsgRes))
    let baselineSurfaceRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-surface", ""))
    if IsErr(baselineSurfaceRes):
        return Err[str](Error(baselineSurfaceRes))
    let migratedSurfaceRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-surface", ""))
    if IsErr(migratedSurfaceRes):
        return Err[str](Error(migratedSurfaceRes))
    let baselineReceiptRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-receipt", ""))
    if IsErr(baselineReceiptRes):
        return Err[str](Error(baselineReceiptRes))
    let migratedReceiptRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-receipt", ""))
    if IsErr(migratedReceiptRes):
        return Err[str](Error(migratedReceiptRes))
    let packageIdRes = v3ChengNodeCompilerRequireFlag("--package")
    if IsErr(packageIdRes):
        return Err[str](Error(packageIdRes))
    let channelRaw = strutil.Strip(cmdline.readFlagOrDefault("--channel", "stable"))
    var baselineGraphCid = layout.FixedBytes32()
    var migratedGraphCid = layout.FixedBytes32()
    var baselineSurfaceCid = layout.FixedBytes32()
    var migratedSurfaceCid = layout.FixedBytes32()
    var baselineReceiptCid = layout.FixedBytes32()
    var migratedReceiptCid = layout.FixedBytes32()
    var graphEquivalent = 0
    var exportSurfaceCompatible = 0
    var compileReceiptEquivalent = 0
    var targetTriple = ""
    let graphRes = ceq.v3CompilerEquivalenceGraphCompareTexts(Value(baselineCsgRes),
                                                              Value(migratedCsgRes),
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[str](Error(graphRes))
    let surfaceRes = ceq.v3CompilerEquivalenceSurfaceCompareTexts(Value(baselineSurfaceRes),
                                                                  Value(migratedSurfaceRes),
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[str](Error(surfaceRes))
    let receiptRes = ceq.v3CompilerEquivalenceReceiptCompareTexts(Value(baselineReceiptRes),
                                                                  Value(migratedReceiptRes),
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[str](Error(receiptRes))
    var proof: ceq.V3CompilerEquivalenceProof
    let proofRes = ceq.v3CompilerEquivalenceProofMake(Value(packageIdRes),
                                                      channelRaw,
                                                      baselineGraphCid,
                                                      migratedGraphCid,
                                                      baselineSurfaceCid,
                                                      migratedSurfaceCid,
                                                      baselineReceiptCid,
                                                      migratedReceiptCid,
                                                      targetTriple,
                                                      graphEquivalent,
                                                      exportSurfaceCompatible,
                                                      compileReceiptEquivalent,
                                                      proof)
    if IsErr(proofRes):
        return Err[str](Error(proofRes))
    return Ok[str](ceq.v3CompilerEquivalenceProofReport(proof))

fn V3ChengNodeCompilerPublishCheckText(): Result[str] =
    let proofTextRes = v3ChengNodeCompilerEquivalenceProofText()
    if IsErr(proofTextRes):
        return Err[str](Error(proofTextRes))
    proofTextRes
    let worldHeadCidRes = layout.fixedBytes32FromHex(cmdline.readFlagOrDefault("--world-head-cid", ""))
    if IsErr(worldHeadCidRes):
        return Err[str]("cheng_node compiler: invalid --world-head-cid")
    let baselineCsgRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-csg", ""))
    if IsErr(baselineCsgRes):
        return Err[str](Error(baselineCsgRes))
    let migratedCsgRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-csg", ""))
    if IsErr(migratedCsgRes):
        return Err[str](Error(migratedCsgRes))
    let baselineSurfaceRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-surface", ""))
    if IsErr(baselineSurfaceRes):
        return Err[str](Error(baselineSurfaceRes))
    let migratedSurfaceRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-surface", ""))
    if IsErr(migratedSurfaceRes):
        return Err[str](Error(migratedSurfaceRes))
    let baselineReceiptRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-receipt", ""))
    if IsErr(baselineReceiptRes):
        return Err[str](Error(baselineReceiptRes))
    let migratedReceiptRes = v3ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-receipt", ""))
    if IsErr(migratedReceiptRes):
        return Err[str](Error(migratedReceiptRes))
    let packageIdRes = v3ChengNodeCompilerRequireFlag("--package")
    if IsErr(packageIdRes):
        return Err[str](Error(packageIdRes))
    let channelRaw = strutil.Strip(cmdline.readFlagOrDefault("--channel", "stable"))
    var baselineGraphCid = layout.FixedBytes32()
    var migratedGraphCid = layout.FixedBytes32()
    var baselineSurfaceCid = layout.FixedBytes32()
    var migratedSurfaceCid = layout.FixedBytes32()
    var baselineReceiptCid = layout.FixedBytes32()
    var migratedReceiptCid = layout.FixedBytes32()
    var graphEquivalent = 0
    var exportSurfaceCompatible = 0
    var compileReceiptEquivalent = 0
    var targetTriple = ""
    let graphRes = ceq.v3CompilerEquivalenceGraphCompareTexts(Value(baselineCsgRes),
                                                              Value(migratedCsgRes),
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[str](Error(graphRes))
    let surfaceRes = ceq.v3CompilerEquivalenceSurfaceCompareTexts(Value(baselineSurfaceRes),
                                                                  Value(migratedSurfaceRes),
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[str](Error(surfaceRes))
    let receiptRes = ceq.v3CompilerEquivalenceReceiptCompareTexts(Value(baselineReceiptRes),
                                                                  Value(migratedReceiptRes),
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[str](Error(receiptRes))
    var proof: ceq.V3CompilerEquivalenceProof
    let proofRes = ceq.v3CompilerEquivalenceProofMake(Value(packageIdRes),
                                                      channelRaw,
                                                      baselineGraphCid,
                                                      migratedGraphCid,
                                                      baselineSurfaceCid,
                                                      migratedSurfaceCid,
                                                      baselineReceiptCid,
                                                      migratedReceiptCid,
                                                      targetTriple,
                                                      graphEquivalent,
                                                      exportSurfaceCompatible,
                                                      compileReceiptEquivalent,
                                                      proof)
    if IsErr(proofRes):
        return Err[str](Error(proofRes))
    var channel = ""
    var stableGateRequired = 0
    var equivalenceCheckedFlag = 0
    var equivalencePassed = 0
    var publishAllowed = 0
    var proofCid = layout.FixedBytes32()
    let decisionRes = cpub.v3CompilerPublishDecisionEvaluate(channelRaw,
                                                             Value(worldHeadCidRes),
                                                             true,
                                                             proof,
                                                             channel,
                                                             stableGateRequired,
                                                             equivalenceCheckedFlag,
                                                             equivalencePassed,
                                                             publishAllowed,
                                                             proofCid)
    if IsErr(decisionRes):
        return Err[str](Error(decisionRes))
    return Ok[str](cpub.v3CompilerPublishDecisionReport(channel,
                                                        stableGateRequired,
                                                        equivalenceCheckedFlag,
                                                        equivalencePassed,
                                                        publishAllowed,
                                                        Value(worldHeadCidRes),
                                                        proofCid))

fn v3ChengNodeCompilerPrintForwardResult(subcmd: str,
                                         commandIndex: int32): int32 =
    let textRes = v3ChengNodeCompilerForwardSubcommandText(subcmd, commandIndex)
    if IsErr(textRes):
        echo(Error(textRes))
        return 1
    let text = Value(textRes)
    if len(text) > 0:
        echo(text)
    return 0

fn V3ChengNodeCompilerCommandAt(commandIndex: int32): int32 =
    let count = cmdline.ParamCount()
    if count < commandIndex:
        echo(v3ChengNodeCompilerUsageText())
        return 0
    let subcmd = cmdline.ParamStr(commandIndex)
    if subcmd == "--help" || subcmd == "-h" || subcmd == "help":
        echo(v3ChengNodeCompilerUsageText())
        return 0
    if subcmd == "surface":
        echo(V3ChengNodeCompilerSurfaceText())
        return 0
    if subcmd == "status":
        echo(V3ChengNodeCompilerStatusText())
        return 0
    if subcmd == "system-link-exec":
        let textRes = V3ChengNodeCompilerSystemLinkExecText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "debug-report":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-symbols":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-line-map":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-object":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-elf":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-asm":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "profile-run":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "profile-report":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "crash-report":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-build-plan":
        let textRes = V3ChengNodeCompilerBuildPlanText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "emit-csg":
        let textRes = V3ChengNodeCompilerCsgText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "migrate-csg":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "emit-surface":
        let textRes = V3ChengNodeCompilerSurfaceReportText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "emit-receipt":
        let textRes = V3ChengNodeCompilerReceiptText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "verify-world":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "world-sync":
        let textRes = V3ChengNodeCompilerWorldSyncText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "materialize-world-mirrors":
        let textRes = V3ChengNodeCompilerMaterializeWorldMirrorsText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "prove-migration":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "publish-world":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "fresh-node-selfhost":
        let textRes = V3ChengNodeCompilerFreshNodeSelfhostText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "follow-world":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "selfhost-build":
        return v3ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "prove-equivalence":
        let textRes = v3ChengNodeCompilerEquivalenceProofText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "publish-check":
        let textRes = V3ChengNodeCompilerPublishCheckText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    echo(v3ChengNodeCompilerUsageText())
    return 2
