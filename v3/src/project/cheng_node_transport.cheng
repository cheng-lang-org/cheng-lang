import std/result
import std/rawbytes
import std/strutils as strutil
import std/strings as strings
import cheng/v3/std/bytes_layout as layout
import cheng/v3/std/crypto/hash256
import cheng/v3/chain/binary_types as binary
import cheng/v3/overlay/contracts as overlay
import cheng/v3/overlay/libp2p_bridge as bridge
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peer_id
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host
import cheng/v3/libp2p/host/host_quic
import cheng/v3/libp2p/transports/tailnet_transport as tsnet
import cheng/v3/tooling/vpn_proxy_config as vpncfg
import cheng/v3/tooling/vpn_proxy_routing as vpnrouting

type
    V3ChengNodeTransportState =
        host: host.V3Libp2pHost

    V3ChengNodeVpnState =
        overlay: tsnet.V3Libp2pTailnetTransport
        exitRouteKeys: str[]
        exits: vpnrouting.V3VpnProxyExitState[]

fn v3ChengNodeTransportLineValue(text: str,
                                 key: str): str =
    let prefix = key + "="
    var lineStart: int32
    while lineStart < len(text):
        var lineEnd: int32 = lineStart
        while lineEnd < len(text):
            if text[lineEnd] == '\n':
                break
            lineEnd = lineEnd + 1
        let lineLen = lineEnd - lineStart
        if lineLen >= strings.Len(prefix):
            let line = strings.SliceBytes(text, lineStart, lineLen)
            if line == prefix:
                return ""
            if strings.SliceBytes(line, 0, strings.Len(prefix)) == prefix:
                return strings.SliceBytes(line,
                                          strings.Len(prefix),
                                          strings.Len(line) - strings.Len(prefix))
        lineStart = lineEnd + 1
    return ""

fn v3ChengNodeTransportBoolText(value: bool): str =
    if value:
        return "1"
    return "0"

fn v3ChengNodeTransportBoolValue(text: str): bool =
    return text == "1" || text == "true" || text == "yes" || text == "on"

fn v3ChengNodeTransportHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return 0

fn v3ChengNodeTransportDefaultProtocolsText(): str =
    return "identify,store,sync,ingress,webrtc_signal,content,proxy_tcp"

fn v3ChengNodeTransportSupportedTransportsText(): str =
    return "tcp,quic,webrtc"

fn v3ChengNodeTransportDiscoveryKindsText(): str =
    return "peer,topic,capability"

fn v3ChengNodeTransportStreamProtocolsText(): str =
    return "identify,sync,store,content,proxy_tcp"

fn v3ChengNodeTransportRegisterDefaultHandlers(hostState: var host.V3Libp2pHost) =
    host.v3Libp2pRegisterHandler(hostState, types.v3Libp2pProtocolIdentify)
    host.v3Libp2pRegisterHandler(hostState, types.v3Libp2pProtocolStore)
    host.v3Libp2pRegisterHandler(hostState, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(hostState, types.v3Libp2pProtocolIngress)
    host.v3Libp2pRegisterHandler(hostState, types.v3Libp2pProtocolWebrtcSignal)
    host.v3Libp2pRegisterHandler(hostState, types.v3Libp2pProtocolContent)
    host.v3Libp2pRegisterHandler(hostState, types.v3Libp2pProtocolProxyTcp)

fn V3ChengNodeTransportStateInit(seed: str): V3ChengNodeTransportState =
    var out: V3ChengNodeTransportState
    out.host = host.v3Libp2pHostInit(seed)
    v3ChengNodeTransportRegisterDefaultHandlers(out.host)
    return out

fn v3ChengNodeTransportSyntheticIpv4(seed: str): str =
    let b0 = v3ChengNodeTransportHexValue(seed[0])
    let b1 = v3ChengNodeTransportHexValue(seed[1])
    let b2 = v3ChengNodeTransportHexValue(seed[2])
    let b3 = v3ChengNodeTransportHexValue(seed[3])
    let octet2 = 1 + ((b0 * 16 + b1) % 191)
    let octet3 = 1 + ((b2 * 16 + b3) % 253)
    return "100.64." + intToStr(octet2) + "." + intToStr(octet3)

fn V3ChengNodeVpnStateInit(vpnSeed: str,
                           localPeerIdText: str): V3ChengNodeVpnState =
    var cfg = tsnet.v3Libp2pTailnetTransportConfigZero()
    cfg.controlEndpoint = "cheng_node://control/" + localPeerIdText
    cfg.relayEndpoint = "cheng_node://derp/" + localPeerIdText
    cfg.localPeerId = localPeerIdText
    cfg.syntheticIPv4 = v3ChengNodeTransportSyntheticIpv4(vpnSeed)
    cfg.exactRouting = true
    var out: V3ChengNodeVpnState
    out.overlay = tsnet.v3Libp2pTailnetTransportInit(cfg)
    tsnet.v3Libp2pTailnetSetProviderReady(out.overlay, true, "control-ready")
    tsnet.v3Libp2pTailnetSetProxyListenersReady(out.overlay, true, "proxy-ready")
    tsnet.v3Libp2pTailnetSetDerpHealthy(out.overlay, true, "derp-ready")
    out.exitRouteKeys = []
    out.exits = []
    return out

fn V3ChengNodeTransportPeerIdText(state: V3ChengNodeTransportState): str =
    return peer_id.v3Libp2pPeerIdText(state.host.selfPeerId)

fn V3ChengNodeTransportSurfaceText(state: V3ChengNodeTransportState): str =
    var out = ""
    out = out + "peer_id=" + V3ChengNodeTransportPeerIdText(state) + "\n"
    out = out + "supported_transports=" + v3ChengNodeTransportSupportedTransportsText() + "\n"
    out = out + "supported_protocols=" + v3ChengNodeTransportDefaultProtocolsText() + "\n"
    out = out + "stream_protocols=" + v3ChengNodeTransportStreamProtocolsText() + "\n"
    out = out + "discovery_kinds=" + v3ChengNodeTransportDiscoveryKindsText() + "\n"
    out = out + "network_domains=public,lan,tailnet,browser-webrtc\n"
    out = out + "listen_addr_count=" + intToStr(state.host.listenAddrs.len) + "\n"
    out = out + "handler_count=" + intToStr(state.host.supportedProtocols.len)
    return out

fn v3ChengNodeTransportProtocolIdText(protocolId: types.V3Libp2pProtocolId): str =
    if protocolId == types.v3Libp2pProtocolIdentify:
        return "identify"
    if protocolId == types.v3Libp2pProtocolStore:
        return "store"
    if protocolId == types.v3Libp2pProtocolSync:
        return "sync"
    if protocolId == types.v3Libp2pProtocolIngress:
        return "ingress"
    if protocolId == types.v3Libp2pProtocolWebrtcSignal:
        return "webrtc_signal"
    if protocolId == types.v3Libp2pProtocolContent:
        return "content"
    if protocolId == types.v3Libp2pProtocolProxyTcp:
        return "proxy_tcp"
    return "unknown"

fn V3ChengNodeTransportProtocolId(protocolText: str): Result[types.V3Libp2pProtocolId] =
    if protocolText == "identify":
        return Ok[types.V3Libp2pProtocolId](types.v3Libp2pProtocolIdentify)
    if protocolText == "store":
        return Ok[types.V3Libp2pProtocolId](types.v3Libp2pProtocolStore)
    if protocolText == "sync":
        return Ok[types.V3Libp2pProtocolId](types.v3Libp2pProtocolSync)
    if protocolText == "ingress":
        return Ok[types.V3Libp2pProtocolId](types.v3Libp2pProtocolIngress)
    if protocolText == "webrtc_signal":
        return Ok[types.V3Libp2pProtocolId](types.v3Libp2pProtocolWebrtcSignal)
    if protocolText == "content":
        return Ok[types.V3Libp2pProtocolId](types.v3Libp2pProtocolContent)
    if protocolText == "proxy_tcp":
        return Ok[types.V3Libp2pProtocolId](types.v3Libp2pProtocolProxyTcp)
    return Err[types.V3Libp2pProtocolId]("cheng_node transport: unsupported protocol")

fn V3ChengNodeTransportListenAddr(kindText: str,
                                  hostText: str,
                                  port: int32,
                                  networkDomain: str,
                                  visibility: str,
                                  priority: int32): Result[types.V3Libp2pMultiaddr] =
    var out = types.v3Libp2pMultiaddrZero()
    if kindText == "tcp":
        multiaddr.v3Libp2pMultiaddrFillTcp(out, hostText, port)
    elif kindText == "quic":
        multiaddr.v3Libp2pMultiaddrFillQuic(out, hostText, port)
    elif kindText == "webrtc":
        out.host = hostText
        out.port = port
        out.transport = types.v3Libp2pTransportWebrtc
        out.networkDomain = types.v3Libp2pNetworkDomainBrowserWebrtc
        out.visibility = types.v3Libp2pVisibilityPublic
        out.priority = 100
    else:
        return Err[types.V3Libp2pMultiaddr]("cheng_node transport: unsupported listen transport")
    if networkDomain == "tailnet":
        out.networkDomain = types.v3Libp2pNetworkDomainTailnet
    elif networkDomain == "lan":
        out.networkDomain = types.v3Libp2pNetworkDomainLan
    elif networkDomain == "browser-webrtc":
        out.networkDomain = types.v3Libp2pNetworkDomainBrowserWebrtc
    else:
        out.networkDomain = types.v3Libp2pNetworkDomainPublic
    if visibility == "trusted-only":
        out.visibility = types.v3Libp2pVisibilityTrustedOnly
    elif visibility == "local-only":
        out.visibility = types.v3Libp2pVisibilityLocalOnly
    else:
        out.visibility = types.v3Libp2pVisibilityPublic
    out.priority = priority
    return Ok[types.V3Libp2pMultiaddr](out)

fn v3ChengNodeTransportDiscoveryScope(lookupKind: str): overlay.V3OverlayTopicScope =
    if lookupKind == "capability":
        return overlay.v3OverlayScopeGlobal
    if lookupKind == "topic":
        return overlay.v3OverlayScopeRegion
    return overlay.v3OverlayScopeCell

fn v3ChengNodeTransportDiscoveryAddressFill(out: var binary.V3LsmrAddress,
                                            lookupKind: str,
                                            keyText: str) =
    let payload = bytesFromString("cheng_node.discovery|" + lookupKind + "|" + keyText)
    let cid = hash256.sha256Fixed(layout.byteSpanFromBytes(payload))
    out = binary.v3LsmrAddressZero()
    out.depth = 12
    for i in 0..<12:
        out.digits[i] = 1 + ((int32(cid.data[i]) & 255) % 8)

fn V3ChengNodeTransportDiscoveryQueryFill(out: var overlay.V3StoreQuery,
                                          lookupKind: str,
                                          keyText: str) =
    out = overlay.v3OverlayStoreQueryZero()
    out.topicScope = v3ChengNodeTransportDiscoveryScope(lookupKind)
    v3ChengNodeTransportDiscoveryAddressFill(out.address, lookupKind, keyText)
    out.rangeLimit = 1

fn V3ChengNodeTransportDiscoveryObjectText(entryKind: str,
                                           keyText: str,
                                           ownerPeerId: str,
                                           addr: types.V3Libp2pMultiaddr): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "entry_kind=" + entryKind + "\n"
    out = out + "key_text=" + keyText + "\n"
    out = out + "owner_peer_id=" + ownerPeerId + "\n"
    out = out + "transport=" + types.v3Libp2pTransportText(addr.transport) + "\n"
    out = out + "host=" + addr.host + "\n"
    out = out + "port=" + intToStr(addr.port) + "\n"
    out = out + "network_domain=" + types.v3Libp2pNetworkDomainText(addr.networkDomain) + "\n"
    out = out + "visibility=" + types.v3Libp2pVisibilityText(addr.visibility) + "\n"
    out = out + "priority=" + intToStr(addr.priority) + "\n"
    out = out + "protocols=" + v3ChengNodeTransportDefaultProtocolsText()
    return out

fn V3ChengNodeTransportDiscoveryOwnerPeerId(text: str): str =
    return v3ChengNodeTransportLineValue(text, "owner_peer_id")

fn V3ChengNodeTransportDiscoveryKeyText(text: str): str =
    return v3ChengNodeTransportLineValue(text, "key_text")

fn V3ChengNodeTransportDiscoveryEntryKind(text: str): str =
    return v3ChengNodeTransportLineValue(text, "entry_kind")

fn V3ChengNodeTransportDiscoveryAddrFill(out: var types.V3Libp2pMultiaddr,
                                         text: str): Result[bool] =
    let transportText = v3ChengNodeTransportLineValue(text, "transport")
    let hostText = v3ChengNodeTransportLineValue(text, "host")
    let portText = v3ChengNodeTransportLineValue(text, "port")
    let networkDomainText = v3ChengNodeTransportLineValue(text, "network_domain")
    let visibilityText = v3ChengNodeTransportLineValue(text, "visibility")
    let priorityText = v3ChengNodeTransportLineValue(text, "priority")
    if len(transportText) <= 0 || len(hostText) <= 0 || len(portText) <= 0:
        return Err[bool]("cheng_node transport: discovery object missing address")
    var priority = 100
    if len(priorityText) > 0:
        priority = int32(parseInt(priorityText))
    let addrRes = V3ChengNodeTransportListenAddr(transportText,
                                                 hostText,
                                                 int32(parseInt(portText)),
                                                 networkDomainText,
                                                 visibilityText,
                                                 priority)
    if IsErr(addrRes):
        return Err[bool](Error(addrRes))
    out = Value(addrRes)
    return Ok[bool](true)

fn v3ChengNodeTransportHasListenAddr(hostState: host.V3Libp2pHost,
                                     addr: types.V3Libp2pMultiaddr): bool =
    for i in 0..<hostState.listenAddrs.len:
        if multiaddr.v3Libp2pMultiaddrEqual(hostState.listenAddrs[i], addr):
            return true
    return false

fn V3ChengNodeTransportApplyDiscoveryText(state: var V3ChengNodeTransportState,
                                          text: str): Result[bool] =
    let ownerPeerText = V3ChengNodeTransportDiscoveryOwnerPeerId(text)
    if len(ownerPeerText) <= 0:
        return Err[bool]("cheng_node transport: discovery object missing owner_peer_id")
    var addr = types.v3Libp2pMultiaddrZero()
    let addrRes = V3ChengNodeTransportDiscoveryAddrFill(addr, text)
    if IsErr(addrRes):
        return Err[bool](Error(addrRes))
    let selfPeerText = peer_id.v3Libp2pPeerIdText(state.host.selfPeerId)
    if ownerPeerText == selfPeerText:
        if !v3ChengNodeTransportHasListenAddr(state.host, addr):
            let listenRes = host.v3Libp2pListen(state.host, addr)
            if IsErr(listenRes):
                return Err[bool](Error(listenRes))
        let entryKind = V3ChengNodeTransportDiscoveryEntryKind(text)
        if entryKind == "topic":
            let keyText = V3ChengNodeTransportDiscoveryKeyText(text)
            var address = binary.v3LsmrAddressZero()
            v3ChengNodeTransportDiscoveryAddressFill(address, "topic", keyText)
            let topicId = bridge.v3Libp2pTopicId(overlay.v3OverlayScopeRegion, address)
            host.v3Libp2pSubscribe(state.host, topicId)
        return Ok[bool](true)
    let peerRes = peer_id.v3Libp2pPeerIdFromText(ownerPeerText)
    if IsErr(peerRes):
        return Err[bool](Error(peerRes))
    let dialRes = host.v3Libp2pDial(state.host,
                                    Value(peerRes),
                                    addr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    if IsErr(dialRes):
        return Err[bool](Error(dialRes))
    return Ok[bool](true)

fn V3ChengNodeTransportPublishDiscovery(state: var V3ChengNodeTransportState,
                                        lookupKind: str,
                                        keyText: str,
                                        objectText: str,
                                        payloadCid: layout.FixedBytes32,
                                        stampEpoch: int32,
                                        stampGanzhi: int32): Result[bool] =
    var address = binary.v3LsmrAddressZero()
    v3ChengNodeTransportDiscoveryAddressFill(address, lookupKind, keyText)
    let payload = bytesSlice(bytesFromString(objectText), 0, len(objectText))
    let ingress = bridge.v3Libp2pIngressMake(state.host.selfPeerId,
                                             v3ChengNodeTransportDiscoveryScope(lookupKind),
                                             address,
                                             0,
                                             payloadCid,
                                             payload,
                                             stampEpoch,
                                             stampGanzhi)
    bridge.v3Libp2pRelayPublish(state.host, ingress)
    return Ok[bool](true)

fn v3ChengNodeTransportRemotePrimaryAddr(remote: V3ChengNodeTransportState,
                                         out: var types.V3Libp2pMultiaddr): bool =
    if remote.host.listenAddrs.len <= 0:
        return false
    out = multiaddr.v3Libp2pMultiaddrClone(remote.host.listenAddrs[0])
    return true

fn V3ChengNodeTransportSyncDiscoveryText(local: var V3ChengNodeTransportState,
                                         remote: var V3ChengNodeTransportState,
                                         lookupKind: str,
                                         keyText: str,
                                         outText: var str): Result[bool] =
    outText = ""
    var remoteAddr = types.v3Libp2pMultiaddrZero()
    if !v3ChengNodeTransportRemotePrimaryAddr(remote, remoteAddr):
        return Err[bool]("cheng_node transport: remote host missing listen addr")
    let dialRes = host.v3Libp2pDial(local.host,
                                    remote.host.selfPeerId,
                                    remoteAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    if IsErr(dialRes):
        return Err[bool](Error(dialRes))
    var query = overlay.v3OverlayStoreQueryZero()
    V3ChengNodeTransportDiscoveryQueryFill(query, lookupKind, keyText)
    var entries: overlay.V3IngressEnvelope[]
    var syncRes: Result[bool]
    if remoteAddr.transport == types.v3Libp2pTransportQuic:
        syncRes = host_quic.v3Libp2pSyncRequest(local.host,
                                                remote.host,
                                                remote.host.selfPeerId,
                                                query,
                                                entries)
    else:
        syncRes = host.v3Libp2pSyncRequest(local.host,
                                           remote.host,
                                           remote.host.selfPeerId,
                                           query,
                                           entries)
    if IsErr(syncRes):
        return Err[bool](Error(syncRes))
    if entries.len <= 0:
        return Err[bool]("cheng_node transport: remote discovery entry missing")
    outText = bytesToString(entries[entries.len - 1].payload)
    return Ok[bool](true)

fn V3ChengNodeTransportIdentifyText(local: var V3ChengNodeTransportState,
                                    remote: var V3ChengNodeTransportState): Result[str] =
    var remoteAddr = types.v3Libp2pMultiaddrZero()
    if !v3ChengNodeTransportRemotePrimaryAddr(remote, remoteAddr):
        return Err[str]("cheng_node transport: remote host missing listen addr")
    let dialRes = host.v3Libp2pDial(local.host,
                                    remote.host.selfPeerId,
                                    remoteAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    if IsErr(dialRes):
        return Err[str](Error(dialRes))
    var resources = types.v3Libp2pNodeResourceZero()
    let identifyRes = host.v3Libp2pIdentifyRequest(local.host,
                                                   remote.host,
                                                   remote.host.selfPeerId,
                                                   resources)
    if IsErr(identifyRes):
        return Err[str](Error(identifyRes))
    var out = ""
    out = out + "peer_id=" + peer_id.v3Libp2pPeerIdText(remote.host.selfPeerId) + "\n"
    out = out + "transport=" + types.v3Libp2pTransportText(remoteAddr.transport) + "\n"
    out = out + "cpu_logical_cores=" + intToStr(resources.cpuLogicalCores) + "\n"
    out = out + "memory_total_bytes=" + int64ToStr(resources.memoryTotalBytes) + "\n"
    out = out + "open_stream_count=" + intToStr(local.host.openStreamPeers.len)
    return Ok[str](out)

fn V3ChengNodeVpnPeerObjectText(session: tsnet.V3Libp2pTailnetPeerSession): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "peer_id=" + session.peerId + "\n"
    out = out + "remote_tailnet_ip=" + session.remoteTailnetIp + "\n"
    out = out + "direct_reachable=" + v3ChengNodeTransportBoolText(session.directReachable) + "\n"
    out = out + "relay_allowed=" + v3ChengNodeTransportBoolText(session.relayAllowed) + "\n"
    out = out + "relay_only=" + v3ChengNodeTransportBoolText(session.relayOnly) + "\n"
    out = out + "derp_region_code=" + session.derpRegionCode + "\n"
    out = out + "signed_preface=" + session.signedPreface + "\n"
    out = out + "bound_addr_text=" + session.boundAddrText + "\n"
    out = out + "last_path=" + session.lastPath + "\n"
    out = out + "last_error=" + session.lastError
    return out

fn V3ChengNodeVpnPeerSessionFromText(out: var tsnet.V3Libp2pTailnetPeerSession,
                                     text: str): Result[bool] =
    out = tsnet.v3Libp2pTailnetPeerSessionZero()
    out.peerId = v3ChengNodeTransportLineValue(text, "peer_id")
    if len(out.peerId) <= 0:
        return Err[bool]("cheng_node vpn: peer session missing peer_id")
    out.remoteTailnetIp = v3ChengNodeTransportLineValue(text, "remote_tailnet_ip")
    out.directReachable = v3ChengNodeTransportBoolValue(v3ChengNodeTransportLineValue(text, "direct_reachable"))
    out.relayAllowed = v3ChengNodeTransportBoolValue(v3ChengNodeTransportLineValue(text, "relay_allowed"))
    out.relayOnly = v3ChengNodeTransportBoolValue(v3ChengNodeTransportLineValue(text, "relay_only"))
    out.derpRegionCode = v3ChengNodeTransportLineValue(text, "derp_region_code")
    out.signedPreface = v3ChengNodeTransportLineValue(text, "signed_preface")
    out.boundAddrText = v3ChengNodeTransportLineValue(text, "bound_addr_text")
    out.lastPath = v3ChengNodeTransportLineValue(text, "last_path")
    out.lastError = v3ChengNodeTransportLineValue(text, "last_error")
    return Ok[bool](true)

fn V3ChengNodeVpnApplyPeerText(state: var V3ChengNodeVpnState,
                               text: str): Result[bool] =
    var session = tsnet.v3Libp2pTailnetPeerSessionZero()
    let parseRes = V3ChengNodeVpnPeerSessionFromText(session, text)
    if IsErr(parseRes):
        return Err[bool](Error(parseRes))
    tsnet.v3Libp2pTailnetUpsertPeerSession(state.overlay, session)
    return Ok[bool](true)

fn V3ChengNodeVpnOverlayRouteObjectText(routeKey: str,
                                        peerIdText: str,
                                        rawAddr: types.V3Libp2pMultiaddr,
                                        publishedAddr: types.V3Libp2pMultiaddr): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "mode=overlay\n"
    out = out + "route_key=" + routeKey + "\n"
    out = out + "peer_id=" + peerIdText + "\n"
    out = out + "raw_addr=" + tsnet.v3Libp2pTailnetAddrText(rawAddr) + "\n"
    out = out + "published_addr=" + tsnet.v3Libp2pTailnetAddrText(publishedAddr)
    return out

fn V3ChengNodeVpnApplyOverlayRouteText(state: var V3ChengNodeVpnState,
                                       text: str): Result[bool] =
    let rawText = v3ChengNodeTransportLineValue(text, "raw_addr")
    if len(rawText) <= 0:
        return Err[bool]("cheng_node vpn: overlay route missing raw_addr")
    let addrRes = multiaddr.v3Libp2pMultiaddrParse(rawText)
    if IsErr(addrRes):
        return Err[bool](Error(addrRes))
    let listenRes = tsnet.v3Libp2pTailnetListen(state.overlay, Value(addrRes))
    if IsErr(listenRes):
        return Err[bool](Error(listenRes))
    return Ok[bool](true)

fn V3ChengNodeVpnExitRouteObjectText(routeKey: str,
                                     cfg: vpncfg.V3VpnProxyExitConfig,
                                     exitState: vpnrouting.V3VpnProxyExitState): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "mode=exit\n"
    out = out + "route_key=" + routeKey + "\n"
    out = out + "name=" + cfg.name + "\n"
    out = out + "host=" + cfg.host + "\n"
    out = out + "port=" + intToStr(cfg.port) + "\n"
    out = out + "server_name=" + cfg.serverName + "\n"
    out = out + "healthy=" + v3ChengNodeTransportBoolText(exitState.healthy) + "\n"
    out = out + "ewma_ms=" + int64ToStr(exitState.ewmaMs) + "\n"
    out = out + "last_error=" + exitState.lastError
    return out

fn v3ChengNodeVpnExitRoutePos(state: V3ChengNodeVpnState,
                              routeKey: str): int32 =
    for i in 0..<state.exitRouteKeys.len:
        if state.exitRouteKeys[i] == routeKey:
            return i
    return -1

fn V3ChengNodeVpnApplyExitRouteText(state: var V3ChengNodeVpnState,
                                    text: str): Result[bool] =
    let routeKey = v3ChengNodeTransportLineValue(text, "route_key")
    if len(routeKey) <= 0:
        return Err[bool]("cheng_node vpn: exit route missing route_key")
    var cfg: vpncfg.V3VpnProxyExitConfig
    cfg.name = v3ChengNodeTransportLineValue(text, "name")
    cfg.host = v3ChengNodeTransportLineValue(text, "host")
    cfg.port = int32(parseInt(v3ChengNodeTransportLineValue(text, "port")))
    cfg.serverName = v3ChengNodeTransportLineValue(text, "server_name")
    var exits = vpnrouting.V3VpnProxyInitExitStates([cfg])
    if exits.len <= 0:
        return Err[bool]("cheng_node vpn: exit state init failed")
    exits[0].healthy = v3ChengNodeTransportBoolValue(v3ChengNodeTransportLineValue(text, "healthy"))
    exits[0].ewmaMs = int64(parseInt(v3ChengNodeTransportLineValue(text, "ewma_ms")))
    exits[0].lastError = v3ChengNodeTransportLineValue(text, "last_error")
    let pos = v3ChengNodeVpnExitRoutePos(state, routeKey)
    if pos >= 0:
        state.exits[pos] = exits[0]
        return Ok[bool](true)
    add(state.exitRouteKeys, routeKey)
    add(state.exits, exits[0])
    return Ok[bool](true)

fn V3ChengNodeVpnStatusText(state: V3ChengNodeVpnState): str =
    var snapshot: tsnet.V3Libp2pTailnetStatusSnapshot
    tsnet.v3Libp2pTailnetStatusFill(snapshot, state.overlay)
    var out = ""
    out = out + "provider_label=" + snapshot.providerLabel + "\n"
    out = out + "control_plane=" + snapshot.controlPlane + "\n"
    out = out + "overlay_ready=" + v3ChengNodeTransportBoolText(snapshot.providerReady) + "\n"
    out = out + "proxy_ready=" + v3ChengNodeTransportBoolText(snapshot.proxyListenersReady) + "\n"
    out = out + "relay_healthy=" + v3ChengNodeTransportBoolText(snapshot.relayHealthy) + "\n"
    out = out + "published_count=" + intToStr(snapshot.publishedCount) + "\n"
    out = out + "session_count=" + intToStr(snapshot.sessionCount) + "\n"
    out = out + "exit_count=" + intToStr(state.exits.len) + "\n"
    out = out + "startup_stage=" + snapshot.startupStage + "\n"
    out = out + "derp_map=" + snapshot.tailnetDerpMapSummary
    return out
