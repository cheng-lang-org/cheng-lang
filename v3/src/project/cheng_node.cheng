const
    v3ChengNodeDidBundleAssetId: int32 = 930001
    v3ChengNodeDidOperatorAnchorAssetId: int32 = 930002
    v3ChengNodeDidOperatorAnchorAccountId: int32 = 1

type
    V3ChengNode =
        version: int32
        identity: identity.V3ChengNodeIdentity
        indices: cindex.V3ChengNodeIndexRegistry
        objects: cobject.V3ChengNodeObjectStore
        ledger: ledger.V3ChengNodeLedger
        actors: actor.V3ChengNodeActorBus
        chainState: chain.V3ChainNode
        transport: ctransport.V3ChengNodeTransportState
        vpn: ctransport.V3ChengNodeVpnState
        oracle: cdomain.V3ChengNodeOracleDomain
        diloco: cdomain.V3ChengNodeDilocoDomain
        evomap: cdomain.V3ChengNodeEvoMapDomain

fn v3ChengNodeAppendText(buf: var layout.ByteBuf, text: str) =
    lt.v3AppendU32BE(buf, len(text))
    for i in 0..<len(text):
        layout.byteBufAppendByte(buf, int32(text[i]) & 255)

fn v3ChengNodeBufCid(buf: var layout.ByteBuf): layout.FixedBytes32 =
    let data = layout.byteBufToBytes(buf)
    return hash256.sha256Fixed(layout.byteSpanFromBytes(data))

fn v3ChengNodeHashTextCid(tag: str, text: str): layout.FixedBytes32 =
    var buf = layout.byteBufInit(128)
    v3ChengNodeAppendText(buf, tag)
    v3ChengNodeAppendText(buf, text)
    return v3ChengNodeBufCid(buf)

fn v3ChengNodeSyntheticSnapshotCid(event: ledger.V3ChengNodeEventRecord,
                                   nextSnapshotVersion: int32): layout.FixedBytes32 =
    var buf = layout.byteBufInit(192)
    v3ChengNodeAppendText(buf, "cheng_node.snapshot")
    lt.v3AppendU32BE(buf, nextSnapshotVersion)
    v3ChengNodeAppendText(buf, event.objectKind)
    v3ChengNodeAppendText(buf, event.indexGroup)
    v3ChengNodeAppendText(buf, event.lookupKind)
    v3ChengNodeAppendText(buf, event.keyText)
    lt.v3AppendU32BE(buf, event.seq)
    lt.v3AppendFixed32(buf, event.payloadCid)
    lt.v3AppendFixed32(buf, event.eventCid)
    return v3ChengNodeBufCid(buf)

fn v3ChengNodeDispatchForEvent(node: var V3ChengNode,
                               actorName: str,
                               event: ledger.V3ChengNodeEventRecord) =
    let topic = event.indexGroup + "/" + event.lookupKind
    let ledgerDispatchRes = actor.V3ChengNodeActorBusDispatch(node.actors, "event_ledger", topic, event.seq)
    if IsErr(ledgerDispatchRes):
        let ledgerErr = Error(ledgerDispatchRes)
        panic ledgerErr
    if event.indexGroup == "discovery" && actorName != "transport_discovery":
        let transportDispatchRes = actor.V3ChengNodeActorBusDispatch(node.actors, "transport_discovery", topic, event.seq)
        if IsErr(transportDispatchRes):
            let transportErr = Error(transportDispatchRes)
            panic transportErr
    let actorDispatchRes = actor.V3ChengNodeActorBusDispatch(node.actors, actorName, topic, event.seq)
    if IsErr(actorDispatchRes):
        let actorErr = Error(actorDispatchRes)
        panic actorErr

fn v3ChengNodeRegisterObjectText(node: var V3ChengNode,
                                 payloadCid: layout.FixedBytes32,
                                 objectKind: str,
                                 objectText: str): Result[bool] =
    if layout.fixedBytes32Equal(payloadCid, layout.fixedBytes32Zero()):
        return Err[bool]("cheng_node: zero payload cid")
    return cobject.V3ChengNodeObjectStorePut(node.objects, payloadCid, objectKind, objectText)

fn v3ChengNodeAnchorIndexedCid(node: var V3ChengNode,
                               actorName: str,
                               indexGroup: str,
                               lookupKind: str,
                               keyText: str,
                               objectKind: str,
                               payloadCid: layout.FixedBytes32): Result[ledger.V3ChengNodeProofBundle] =
    let eventRes = ledger.V3ChengNodeLedgerAppend(node.ledger,
                                                  actorName,
                                                  objectKind,
                                                  indexGroup,
                                                  lookupKind,
                                                  keyText,
                                                  payloadCid)
    if IsErr(eventRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(eventRes))
    let event = Value(eventRes)
    v3ChengNodeDispatchForEvent(node, actorName, event)
    let snapshotVersion = node.ledger.manifest.snapshotVersion + 1
    let snapshotCid = v3ChengNodeSyntheticSnapshotCid(event, snapshotVersion)
    let snapshotRes = ledger.V3ChengNodeLedgerSealSnapshot(node.ledger, snapshotVersion, snapshotCid)
    if IsErr(snapshotRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(snapshotRes))
    let proofRes = ledger.V3ChengNodeLedgerBuildProof(node.ledger,
                                                      indexGroup,
                                                      lookupKind,
                                                      keyText,
                                                      payloadCid,
                                                      event.eventCid)
    if IsErr(proofRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(proofRes))
    let proof = Value(proofRes)
    let upsertRes = cindex.V3ChengNodeIndexUpsert(node.indices,
                                                  indexGroup,
                                                  lookupKind,
                                                  keyText,
                                                  payloadCid,
                                                  event.seq,
                                                  proof.proofCid)
    if IsErr(upsertRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(upsertRes))
    let snapshotHeadKey = layout.fixedBytes32Hex(node.ledger.manifest.headCid)
    let snapshotHeadUpsertRes = cindex.V3ChengNodeIndexUpsert(node.indices,
                                                              "snapshot",
                                                              "head",
                                                              snapshotHeadKey,
                                                              snapshotCid,
                                                              event.seq,
                                                              proof.proofCid)
    if IsErr(snapshotHeadUpsertRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(snapshotHeadUpsertRes))
    let snapshotVersionKey = intToStr(snapshotVersion)
    let snapshotVersionUpsertRes = cindex.V3ChengNodeIndexUpsert(node.indices,
                                                                 "snapshot",
                                                                 "version",
                                                                 snapshotVersionKey,
                                                                 snapshotCid,
                                                                 event.seq,
                                                                 proof.proofCid)
    if IsErr(snapshotVersionUpsertRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(snapshotVersionUpsertRes))
    return Ok[ledger.V3ChengNodeProofBundle](proof)

fn v3ChengNodePayloadFromText(objectKind: str,
                              objectText: str): layout.FixedBytes32 =
    return v3ChengNodeHashTextCid(objectKind, objectText)

fn v3ChengNodeLineValue(text: str,
                        key: str): str =
    let prefix = key + "="
    var lineStart: int32
    let n = strings.Len(text)
    while lineStart < n:
        var lineEnd: int32 = lineStart
        while lineEnd < n:
            if text[lineEnd] == '\n':
                break
            lineEnd = lineEnd + 1
        let lineLen = lineEnd - lineStart
        if lineLen >= strings.Len(prefix):
            let line = strings.SliceBytes(text, lineStart, lineLen)
            if strings.SliceBytes(line, 0, strings.Len(prefix)) == prefix:
                return strings.SliceBytes(line, strings.Len(prefix), strings.Len(line) - strings.Len(prefix))
        lineStart = lineEnd + 1
    return ""

fn v3ChengNodeBalanceObjectText(assetId: int32,
                                accountId: int32,
                                balance: int64,
                                headCid: layout.FixedBytes32): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "asset_id=" + intToStr(assetId) + "\n"
    out = out + "account_id=" + intToStr(accountId) + "\n"
    out = out + "balance=" + int64ToStr(balance) + "\n"
    out = out + "head_cid=" + layout.fixedBytes32Hex(headCid)
    return out

fn v3ChengNodeBalanceValueFromText(text: str): int64 =
    let balanceText = v3ChengNodeLineValue(text, "balance")
    if len(balanceText) <= 0:
        return int64(0)
    return int64(parseInt(balanceText))

fn v3ChengNodeMaxInt32(left: int32,
                       right: int32): int32 =
    if left >= right:
        return left
    return right

fn v3ChengNodeChunkCount(payloadLen: int32): int32 =
    if payloadLen <= 28:
        return 1
    return 1 + ((payloadLen - 28 + 31) / 32)

fn v3ChengNodeChunksToPayload(chunks: layout.FixedBytes32[]): Result[Bytes] =
    if chunks.len <= 0:
        return Err[Bytes]("cheng_node: missing chunks")
    let head = layout.fixedBytes32ToBytes(chunks[0])
    let payloadLen = int32(
        int64(bytesGet(head, 0) & 255) * int64(16777216) +
        int64(bytesGet(head, 1) & 255) * int64(65536) +
        int64(bytesGet(head, 2) & 255) * int64(256) +
        int64(bytesGet(head, 3) & 255)
    )
    if payloadLen < 0:
        return Err[Bytes]("cheng_node: invalid chunk length")
    let wantChunkCount = v3ChengNodeChunkCount(payloadLen)
    if wantChunkCount != chunks.len:
        return Err[Bytes]("cheng_node: chunk count mismatch")
    let out = bytesAlloc(payloadLen)
    var copied = 0
    var headPos = 4
    while headPos < 32 && copied < payloadLen:
        bytesSet(out, copied, bytesGet(head, headPos))
        copied = copied + 1
        headPos = headPos + 1
    for i in 1..<chunks.len:
        let chunkBytes = layout.fixedBytes32ToBytes(chunks[i])
        var j = 0
        while j < 32 && copied < payloadLen:
            bytesSet(out, copied, bytesGet(chunkBytes, j))
            copied = copied + 1
            j = j + 1
    if copied != payloadLen:
        return Err[Bytes]("cheng_node: payload size mismatch")
    return Ok[Bytes](out)

fn v3ChengNodeLoadChunkedText(node: var chain.V3ChainNode,
                              assetId: int32,
                              accountId: int32,
                              seqId: int32): Result[str] =
    var maxOrdinal = 0
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.v3ConsensusKindMint:
            continue
        if event.assetId != assetId:
            continue
        if event.toAccount != accountId:
            continue
        if event.fromAccount != seqId:
            continue
        let ordinal = int32(event.amount)
        if int64(ordinal) != event.amount:
            return Err[str]("cheng_node: chunk ordinal overflow")
        if ordinal > maxOrdinal:
            maxOrdinal = ordinal
    if maxOrdinal <= 0:
        return Err[str]("cheng_node: chunk seq missing")
    var chunks: layout.FixedBytes32[]
    chunks = []
    var ordinal = 1
    while ordinal <= maxOrdinal:
        var foundCount = 0
        var chunk = layout.fixedBytes32Zero()
        for i in 0..<node.events.len:
            let event = node.events[i]
            if event.kind != consensus.v3ConsensusKindMint:
                continue
            if event.assetId != assetId:
                continue
            if event.toAccount != accountId:
                continue
            if event.fromAccount != seqId:
                continue
            if event.amount != int64(ordinal):
                continue
            foundCount = foundCount + 1
            chunk = event.fromParentCid
        if foundCount != 1:
            return Err[str]("cheng_node: chunk multiplicity mismatch")
        add(chunks, chunk)
        ordinal = ordinal + 1
    let payloadRes = v3ChengNodeChunksToPayload(chunks)
    if IsErr(payloadRes):
        return Err[str](Error(payloadRes))
    return Ok[str](bytesToString(Value(payloadRes)))

fn v3ChengNodeCompilerBuildReceiptText(receiptKey: str,
                                       receiptCid: layout.FixedBytes32): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "receipt_key=" + receiptKey + "\n"
    out = out + "receipt_cid=" + layout.fixedBytes32Hex(receiptCid)
    return out

fn v3ChengNodeCompilerTargetReceiptText(receiptKey: str,
                                        receipt: ccsg.V3CompileReceipt): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "target=" + receipt.targetTriple + "\n"
    out = out + "receipt_key=" + receiptKey + "\n"
    out = out + "receipt_cid=" + layout.fixedBytes32Hex(receipt.receiptCid) + "\n"
    out = out + "world_head_cid=" + layout.fixedBytes32Hex(receipt.worldHeadCid) + "\n"
    out = out + "bootstrap_stage=" + receipt.bootstrapStage
    return out

fn v3ChengNodeMoqBuildText(build: moq.V3Libp2pMoqBuildResult): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "owner_peer_id=" + build.ownerPeerId + "\n"
    out = out + "mime_type=" + build.mimeType + "\n"
    out = out + "bundle_cid=" + build.bundleCid + "\n"
    out = out + "blob_cid=" + build.blobCid + "\n"
    out = out + "catalog_key=" + build.catalogKey + "\n"
    out = out + "blob_byte_len=" + intToStr(build.blobByteLen) + "\n"
    out = out + "object_target_bytes=" + intToStr(build.objectTargetBytes) + "\n"
    out = out + "source_block_bytes=" + intToStr(build.sourceBlockBytes) + "\n"
    out = out + "object_count=" + intToStr(build.objectCount)
    return out

fn v3ChengNodeDiscoveryObjectKind(lookupKind: str): str =
    if lookupKind == "topic":
        return "discovery_topic"
    if lookupKind == "capability":
        return "discovery_capability"
    return "discovery_peer"

fn v3ChengNodeApplyRuntimeObject(node: var V3ChengNode,
                                 objectKind: str,
                                 keyText: str,
                                 payloadCid: layout.FixedBytes32): Result[bool] =
    let objectRes = cobject.V3ChengNodeObjectStoreGet(node.objects, payloadCid)
    if IsErr(objectRes):
        return Err[bool](Error(objectRes))
    let objectText = Value(objectRes).text
    if objectKind == "discovery_peer" ||
       objectKind == "discovery_topic" ||
       objectKind == "discovery_capability":
        let applyRes = ctransport.V3ChengNodeTransportApplyDiscoveryText(node.transport, objectText)
        if IsErr(applyRes):
            return Err[bool](Error(applyRes))
        var lookupKind = "peer"
        if objectKind == "discovery_topic":
            lookupKind = "topic"
        elif objectKind == "discovery_capability":
            lookupKind = "capability"
        let publishRes = ctransport.V3ChengNodeTransportPublishDiscovery(node.transport,
                                                                         lookupKind,
                                                                         keyText,
                                                                         objectText,
                                                                         payloadCid,
                                                                         node.ledger.manifest.headSeq,
                                                                         node.ledger.manifest.snapshotVersion)
        if IsErr(publishRes):
            return Err[bool](Error(publishRes))
        return Ok[bool](true)
    if objectKind == "vpn_peer_session":
        return ctransport.V3ChengNodeVpnApplyPeerText(node.vpn, objectText)
    if objectKind == "vpn_overlay_route":
        return ctransport.V3ChengNodeVpnApplyOverlayRouteText(node.vpn, objectText)
    if objectKind == "vpn_exit_route":
        return ctransport.V3ChengNodeVpnApplyExitRouteText(node.vpn, objectText)
    if objectKind == "oracle_machine_state":
        return cdomain.V3ChengNodeOracleApplyMachineText(node.oracle, objectText)
    if objectKind == "oracle_pair_state":
        return cdomain.V3ChengNodeOracleApplyPairText(node.oracle, objectText)
    if objectKind == "diloco_job_state":
        return cdomain.V3ChengNodeDilocoApplyJobText(node.diloco, objectText)
    if objectKind == "diloco_cohort_state":
        return cdomain.V3ChengNodeDilocoApplyCohortText(node.diloco, objectText)
    if objectKind == "diloco_lease_state":
        return cdomain.V3ChengNodeDilocoApplyLeaseText(node.diloco, objectText)
    if objectKind == "evomap_agent_hello":
        return cdomain.V3ChengNodeEvoMapApplyAgentText(node.evomap, objectText)
    if objectKind == "evomap_task":
        return cdomain.V3ChengNodeEvoMapApplyTaskText(node.evomap, objectText)
    if objectKind == "evomap_capsule":
        return cdomain.V3ChengNodeEvoMapApplyCapsuleText(node.evomap, objectText)
    return Ok[bool](false)

fn v3ChengNodeAnnounceDiscoveryText(node: var V3ChengNode,
                                    lookupKind: str,
                                    keyText: str,
                                    objectText: str): Result[bool] =
    let objectKind = v3ChengNodeDiscoveryObjectKind(lookupKind)
    let upsertRes = V3ChengNodeUpsertIndexedText(node,
                                                 "transport_discovery",
                                                 "discovery",
                                                 lookupKind,
                                                 keyText,
                                                 objectKind,
                                                 objectText)
    if IsErr(upsertRes):
        return Err[bool](Error(upsertRes))
    let payloadCid = v3ChengNodePayloadFromText(objectKind, objectText)
    let applyRes = ctransport.V3ChengNodeTransportApplyDiscoveryText(node.transport, objectText)
    if IsErr(applyRes):
        return Err[bool](Error(applyRes))
    let publishRes = ctransport.V3ChengNodeTransportPublishDiscovery(node.transport,
                                                                     lookupKind,
                                                                     keyText,
                                                                     objectText,
                                                                     payloadCid,
                                                                     node.ledger.manifest.headSeq,
                                                                     node.ledger.manifest.snapshotVersion)
    if IsErr(publishRes):
        return Err[bool](Error(publishRes))
    return Ok[bool](Value(upsertRes))

fn V3ChengNodeInit(rootSeed: str): Result[V3ChengNode] =
    let identityRes = identity.V3ChengNodeIdentityDerive(rootSeed)
    if IsErr(identityRes):
        return Err[V3ChengNode](Error(identityRes))
    var out: V3ChengNode
    out.version = 1
    out.identity = Value(identityRes)
    cindex.V3ChengNodeIndexRegistryInitInPlace(out.indices)
    cobject.V3ChengNodeObjectStoreInitInPlace(out.objects)
    out.ledger = ledger.V3ChengNodeLedgerInit()
    actor.V3ChengNodeActorBusInitInPlace(out.actors)
    let chainInitRes = chain.V3ChainNodeInitInto(out.chainState,
                                                 "cheng_node.chain",
                                                 rootSeed)
    if IsErr(chainInitRes):
        return Err[V3ChengNode](Error(chainInitRes))
    out.transport = ctransport.V3ChengNodeTransportStateInit(layout.fixedBytes32Hex(out.identity.libp2pKey))
    out.vpn = ctransport.V3ChengNodeVpnStateInit(layout.fixedBytes32Hex(out.identity.vpnKey),
                                                 ctransport.V3ChengNodeTransportPeerIdText(out.transport))
    out.oracle = cdomain.V3ChengNodeOracleDomainInit()
    out.diloco = cdomain.V3ChengNodeDilocoDomainInit()
    out.evomap = cdomain.V3ChengNodeEvoMapDomainInit()
    return Ok[V3ChengNode](out)

fn V3ChengNodeAnchorIndexedObject(node: var V3ChengNode,
                                  actorName: str,
                                  indexGroup: str,
                                  lookupKind: str,
                                  keyText: str,
                                  objectKind: str,
                                  payloadCid: layout.FixedBytes32): Result[ledger.V3ChengNodeProofBundle] =
    return v3ChengNodeAnchorIndexedCid(node,
                                       actorName,
                                       indexGroup,
                                       lookupKind,
                                       keyText,
                                       objectKind,
                                       payloadCid)

fn V3ChengNodeAnchorIndexedText(node: var V3ChengNode,
                                actorName: str,
                                indexGroup: str,
                                lookupKind: str,
                                keyText: str,
                                objectKind: str,
                                objectText: str): Result[ledger.V3ChengNodeProofBundle] =
    let payloadCid = v3ChengNodePayloadFromText(objectKind, objectText)
    let storeRes = v3ChengNodeRegisterObjectText(node, payloadCid, objectKind, objectText)
    if IsErr(storeRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(storeRes))
    return v3ChengNodeAnchorIndexedCid(node,
                                       actorName,
                                       indexGroup,
                                       lookupKind,
                                       keyText,
                                       objectKind,
                                       payloadCid)

fn V3ChengNodeUpsertIndexedText(node: var V3ChengNode,
                                actorName: str,
                                indexGroup: str,
                                lookupKind: str,
                                keyText: str,
                                objectKind: str,
                                objectText: str): Result[bool] =
    let payloadCid = v3ChengNodePayloadFromText(objectKind, objectText)
    let storeRes = v3ChengNodeRegisterObjectText(node, payloadCid, objectKind, objectText)
    if IsErr(storeRes):
        return Err[bool](Error(storeRes))
    let currentRes = cindex.V3ChengNodeIndexGet(node.indices, indexGroup, lookupKind, keyText)
    if IsOk(currentRes):
        let current = Value(currentRes)
        if layout.fixedBytes32Equal(current.valueCid, payloadCid):
            return Ok[bool](false)
    let proofRes = v3ChengNodeAnchorIndexedCid(node,
                                               actorName,
                                               indexGroup,
                                               lookupKind,
                                               keyText,
                                               objectKind,
                                               payloadCid)
    if IsErr(proofRes):
        return Err[bool](Error(proofRes))
    return Ok[bool](true)

fn V3ChengNodeTombstoneIndexedObject(node: var V3ChengNode,
                                     actorName: str,
                                     indexGroup: str,
                                     lookupKind: str,
                                     keyText: str): Result[ledger.V3ChengNodeProofBundle] =
    let zeroCid = layout.fixedBytes32Zero()
    let eventRes = ledger.V3ChengNodeLedgerAppend(node.ledger,
                                                  actorName,
                                                  "index_tombstone",
                                                  indexGroup,
                                                  lookupKind,
                                                  keyText,
                                                  zeroCid)
    if IsErr(eventRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(eventRes))
    let event = Value(eventRes)
    v3ChengNodeDispatchForEvent(node, actorName, event)
    let snapshotVersion = node.ledger.manifest.snapshotVersion + 1
    let snapshotCid = v3ChengNodeSyntheticSnapshotCid(event, snapshotVersion)
    let snapshotRes = ledger.V3ChengNodeLedgerSealSnapshot(node.ledger, snapshotVersion, snapshotCid)
    if IsErr(snapshotRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(snapshotRes))
    let proofRes = ledger.V3ChengNodeLedgerBuildProof(node.ledger,
                                                      indexGroup,
                                                      lookupKind,
                                                      keyText,
                                                      zeroCid,
                                                      event.eventCid)
    if IsErr(proofRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(proofRes))
    let proof = Value(proofRes)
    let removeRes = cindex.V3ChengNodeIndexRemove(node.indices,
                                                  indexGroup,
                                                  lookupKind,
                                                  keyText,
                                                  event.seq,
                                                  proof.proofCid)
    if IsErr(removeRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(removeRes))
    let snapshotHeadKey = layout.fixedBytes32Hex(node.ledger.manifest.headCid)
    let snapshotHeadUpsertRes = cindex.V3ChengNodeIndexUpsert(node.indices,
                                                              "snapshot",
                                                              "head",
                                                              snapshotHeadKey,
                                                              snapshotCid,
                                                              event.seq,
                                                              proof.proofCid)
    if IsErr(snapshotHeadUpsertRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(snapshotHeadUpsertRes))
    let snapshotVersionUpsertRes = cindex.V3ChengNodeIndexUpsert(node.indices,
                                                                 "snapshot",
                                                                 "version",
                                                                 intToStr(snapshotVersion),
                                                                 snapshotCid,
                                                                 event.seq,
                                                                 proof.proofCid)
    if IsErr(snapshotVersionUpsertRes):
        return Err[ledger.V3ChengNodeProofBundle](Error(snapshotVersionUpsertRes))
    return Ok[ledger.V3ChengNodeProofBundle](proof)

fn v3ChengNodeRefreshBalanceKey(node: var V3ChengNode,
                                assetId: int32,
                                accountId: int32): Result[bool] =
    let balanceRes = chain.V3ChainNodeBalance(node.chainState, assetId, accountId)
    if IsErr(balanceRes):
        return Err[bool](Error(balanceRes))
    let balance = Value(balanceRes)
    let headCid = chain.V3ChainNodeAccountHeadFromNode(node.chainState, assetId, accountId)
    let balanceKey = cindex.v3ChengNodeBalanceKey(assetId, accountId)
    let objectText = v3ChengNodeBalanceObjectText(assetId, accountId, balance, headCid)
    return V3ChengNodeUpsertIndexedText(node,
                                        "chain",
                                        "balance",
                                        "asset_account",
                                        balanceKey,
                                        "balance_cell",
                                        objectText)

fn V3ChengNodeChainMint(node: var V3ChengNode,
                        assetId: int32,
                        accountId: int32,
                        amount: int64): Result[bool] =
    let mintRes = chain.V3ChainNodeMint(node.chainState, assetId, accountId, amount)
    if IsErr(mintRes):
        return Err[bool](Error(mintRes))
    return v3ChengNodeRefreshBalanceKey(node, assetId, accountId)

fn V3ChengNodeChainTransfer(node: var V3ChengNode,
                            assetId: int32,
                            fromAccount: int32,
                            toAccount: int32,
                            amount: int64): Result[bool] =
    let transferRes = chain.V3ChainNodeTransfer(node.chainState,
                                                assetId,
                                                fromAccount,
                                                toAccount,
                                                amount)
    if IsErr(transferRes):
        return Err[bool](Error(transferRes))
    let fromRefreshRes = v3ChengNodeRefreshBalanceKey(node, assetId, fromAccount)
    if IsErr(fromRefreshRes):
        return Err[bool](Error(fromRefreshRes))
    let toRefreshRes = v3ChengNodeRefreshBalanceKey(node, assetId, toAccount)
    if IsErr(toRefreshRes):
        return Err[bool](Error(toRefreshRes))
    return Ok[bool](true)

fn V3ChengNodeSyncDidIndexes(node: var V3ChengNode): Result[bool] =
    var changed = false
    var didAccountIds: int32[]
    didAccountIds = []
    var didMaxSeqs: int32[]
    didMaxSeqs = []
    for i in 0..<node.chainState.events.len:
        let event = node.chainState.events[i]
        if event.kind != consensus.v3ConsensusKindMint:
            continue
        if event.assetId != v3ChengNodeDidBundleAssetId:
            continue
        var slot = -1
        for j in 0..<didAccountIds.len:
            if didAccountIds[j] == event.toAccount:
                slot = j
                break
        if slot < 0:
            add(didAccountIds, event.toAccount)
            add(didMaxSeqs, event.fromAccount)
            continue
        didMaxSeqs[slot] = v3ChengNodeMaxInt32(didMaxSeqs[slot], event.fromAccount)
    for i in 0..<didAccountIds.len:
        let textRes = v3ChengNodeLoadChunkedText(node.chainState,
                                                 v3ChengNodeDidBundleAssetId,
                                                 didAccountIds[i],
                                                 didMaxSeqs[i])
        if IsErr(textRes):
            return Err[bool](Error(textRes))
        let objectText = Value(textRes)
        let didText = v3ChengNodeLineValue(objectText, "did")
        if len(didText) <= 0:
            return Err[bool]("cheng_node: did bundle missing did")
        let upsertRes = V3ChengNodeUpsertIndexedText(node,
                                                     "did",
                                                     "did",
                                                     "subject",
                                                     didText,
                                                     "did_bundle",
                                                     objectText)
        if IsErr(upsertRes):
            return Err[bool](Error(upsertRes))
        if Value(upsertRes):
            changed = true
    var maxAnchorSeq = 0
    for i in 0..<node.chainState.events.len:
        let event = node.chainState.events[i]
        if event.kind != consensus.v3ConsensusKindMint:
            continue
        if event.assetId != v3ChengNodeDidOperatorAnchorAssetId:
            continue
        if event.toAccount != v3ChengNodeDidOperatorAnchorAccountId:
            continue
        if event.fromAccount > maxAnchorSeq:
            maxAnchorSeq = event.fromAccount
    var anchorSeq = 1
    while anchorSeq <= maxAnchorSeq:
        let textRes = v3ChengNodeLoadChunkedText(node.chainState,
                                                 v3ChengNodeDidOperatorAnchorAssetId,
                                                 v3ChengNodeDidOperatorAnchorAccountId,
                                                 anchorSeq)
        if IsErr(textRes):
            return Err[bool](Error(textRes))
        let objectText = Value(textRes)
        let keyText = v3ChengNodeLineValue(objectText, "operator_id")
        if len(keyText) <= 0:
            return Err[bool]("cheng_node: operator anchor missing operator_id")
        let upsertRes = V3ChengNodeUpsertIndexedText(node,
                                                     "did",
                                                     "did_operator",
                                                     "operator",
                                                     keyText,
                                                     "did_operator_anchor",
                                                     objectText)
        if IsErr(upsertRes):
            return Err[bool](Error(upsertRes))
        if Value(upsertRes):
            changed = true
        anchorSeq = anchorSeq + 1
    return Ok[bool](changed)

fn V3ChengNodeImportChainSnapshot(node: var V3ChengNode,
                                  snapshot: chain.V3ChainNodeServeSnapshot): Result[bool] =
    let replayRes = chain.v3ChainNodeReplayFromSnapshotInto(node.chainState,
                                                            snapshot.nodeId,
                                                            snapshot.address,
                                                            snapshot)
    if IsErr(replayRes):
        return Err[bool](Error(replayRes))
    var changed = false
    for i in 0..<node.chainState.index.accountAssetIds.len:
        let assetId = node.chainState.index.accountAssetIds[i]
        let accountId = node.chainState.index.accountIds[i]
        let refreshRes = v3ChengNodeRefreshBalanceKey(node, assetId, accountId)
        if IsErr(refreshRes):
            return Err[bool](Error(refreshRes))
        if Value(refreshRes):
            changed = true
    let didRes = V3ChengNodeSyncDidIndexes(node)
    if IsErr(didRes):
        return Err[bool](Error(didRes))
    if Value(didRes):
        changed = true
    return Ok[bool](changed)

fn V3ChengNodeImportOracleState(node: var V3ChengNode,
                                machine: oracle_bft.V3OracleBftStateMachine): Result[bool] =
    node.oracle.machine = machine
    return v3ChengNodeOracleSyncIndexes(node)

fn V3ChengNodeReplayStoredEvent(node: var V3ChengNode,
                                actorName: str,
                                objectKind: str,
                                indexGroup: str,
                                lookupKind: str,
                                keyText: str,
                                payloadCid: layout.FixedBytes32): Result[bool] =
    if objectKind == "index_tombstone":
        let zeroCid = layout.fixedBytes32Zero()
        let eventRes = ledger.V3ChengNodeLedgerAppend(node.ledger,
                                                      actorName,
                                                      "index_tombstone",
                                                      indexGroup,
                                                      lookupKind,
                                                      keyText,
                                                      zeroCid)
        if IsErr(eventRes):
            return Err[bool](Error(eventRes))
        let event = Value(eventRes)
        let snapshotVersion = node.ledger.manifest.snapshotVersion + 1
        let snapshotCid = v3ChengNodeSyntheticSnapshotCid(event, snapshotVersion)
        let snapshotRes = ledger.V3ChengNodeLedgerSealSnapshot(node.ledger, snapshotVersion, snapshotCid)
        if IsErr(snapshotRes):
            return Err[bool](Error(snapshotRes))
        let proofRes = ledger.V3ChengNodeLedgerBuildProof(node.ledger,
                                                          indexGroup,
                                                          lookupKind,
                                                          keyText,
                                                          zeroCid,
                                                          event.eventCid)
        if IsErr(proofRes):
            return Err[bool](Error(proofRes))
        let proof = Value(proofRes)
        let removeRes = cindex.V3ChengNodeIndexRemove(node.indices,
                                                      indexGroup,
                                                      lookupKind,
                                                      keyText,
                                                      event.seq,
                                                      proof.proofCid)
        if IsErr(removeRes):
            return Err[bool](Error(removeRes))
        let snapshotHeadKey = layout.fixedBytes32Hex(node.ledger.manifest.headCid)
        let snapshotHeadUpsertRes = cindex.V3ChengNodeIndexUpsert(node.indices,
                                                                  "snapshot",
                                                                  "head",
                                                                  snapshotHeadKey,
                                                                  snapshotCid,
                                                                  event.seq,
                                                                  proof.proofCid)
        if IsErr(snapshotHeadUpsertRes):
            return Err[bool](Error(snapshotHeadUpsertRes))
        let snapshotVersionUpsertRes = cindex.V3ChengNodeIndexUpsert(node.indices,
                                                                     "snapshot",
                                                                     "version",
                                                                     intToStr(snapshotVersion),
                                                                     snapshotCid,
                                                                     event.seq,
                                                                     proof.proofCid)
        if IsErr(snapshotVersionUpsertRes):
            return Err[bool](Error(snapshotVersionUpsertRes))
        return Ok[bool](true)
    let eventRes = ledger.V3ChengNodeLedgerAppend(node.ledger,
                                                  actorName,
                                                  objectKind,
                                                  indexGroup,
                                                  lookupKind,
                                                  keyText,
                                                  payloadCid)
    if IsErr(eventRes):
        return Err[bool](Error(eventRes))
    let event = Value(eventRes)
    let snapshotVersion = node.ledger.manifest.snapshotVersion + 1
    let snapshotCid = v3ChengNodeSyntheticSnapshotCid(event, snapshotVersion)
    let snapshotRes = ledger.V3ChengNodeLedgerSealSnapshot(node.ledger, snapshotVersion, snapshotCid)
    if IsErr(snapshotRes):
        return Err[bool](Error(snapshotRes))
    let proofRes = ledger.V3ChengNodeLedgerBuildProof(node.ledger,
                                                      indexGroup,
                                                      lookupKind,
                                                      keyText,
                                                      payloadCid,
                                                      event.eventCid)
    if IsErr(proofRes):
        return Err[bool](Error(proofRes))
    let proof = Value(proofRes)
    let upsertRes = cindex.V3ChengNodeIndexUpsert(node.indices,
                                                  indexGroup,
                                                  lookupKind,
                                                  keyText,
                                                  payloadCid,
                                                  event.seq,
                                                  proof.proofCid)
    if IsErr(upsertRes):
        return Err[bool](Error(upsertRes))
    let snapshotHeadKey = layout.fixedBytes32Hex(node.ledger.manifest.headCid)
    let snapshotHeadUpsertRes = cindex.V3ChengNodeIndexUpsert(node.indices,
                                                              "snapshot",
                                                              "head",
                                                              snapshotHeadKey,
                                                              snapshotCid,
                                                              event.seq,
                                                              proof.proofCid)
    if IsErr(snapshotHeadUpsertRes):
        return Err[bool](Error(snapshotHeadUpsertRes))
    let snapshotVersionUpsertRes = cindex.V3ChengNodeIndexUpsert(node.indices,
                                                                 "snapshot",
                                                                 "version",
                                                                 intToStr(snapshotVersion),
                                                                 snapshotCid,
                                                                 event.seq,
                                                                 proof.proofCid)
    if IsErr(snapshotVersionUpsertRes):
        return Err[bool](Error(snapshotVersionUpsertRes))
    let runtimeRes = v3ChengNodeApplyRuntimeObject(node, objectKind, keyText, payloadCid)
    if IsErr(runtimeRes):
        return Err[bool](Error(runtimeRes))
    return Ok[bool](true)

fn V3ChengNodeLocalPeerIdText(node: V3ChengNode): str =
    return ctransport.V3ChengNodeTransportPeerIdText(node.transport)

fn V3ChengNodeLibp2pSurfaceText(node: V3ChengNode): str =
    return ctransport.V3ChengNodeTransportSurfaceText(node.transport)

fn V3ChengNodeAnnounceDiscovery(node: var V3ChengNode,
                                lookupKind: str,
                                keyText: str,
                                transportKind: str,
                                hostText: str,
                                port: int32,
                                networkDomain: str,
                                visibility: str,
                                priority: int32): Result[bool] =
    let addrRes = ctransport.V3ChengNodeTransportListenAddr(transportKind,
                                                            hostText,
                                                            port,
                                                            networkDomain,
                                                            visibility,
                                                            priority)
    if IsErr(addrRes):
        return Err[bool](Error(addrRes))
    let objectText = ctransport.V3ChengNodeTransportDiscoveryObjectText(lookupKind,
                                                                        keyText,
                                                                        ctransport.V3ChengNodeTransportPeerIdText(node.transport),
                                                                        Value(addrRes))
    return v3ChengNodeAnnounceDiscoveryText(node, lookupKind, keyText, objectText)

fn V3ChengNodeAnnouncePeer(node: var V3ChengNode,
                           transportKind: str,
                           hostText: str,
                           port: int32): Result[bool] =
    var networkDomain = "public"
    if transportKind == "webrtc":
        networkDomain = "browser-webrtc"
    return V3ChengNodeAnnounceDiscovery(node,
                                        "peer",
                                        ctransport.V3ChengNodeTransportPeerIdText(node.transport),
                                        transportKind,
                                        hostText,
                                        port,
                                        networkDomain,
                                        "public",
                                        100)

fn V3ChengNodeSyncDiscoveryFromRemote(node: var V3ChengNode,
                                      remote: var V3ChengNode,
                                      lookupKind: str,
                                      keyText: str): Result[bool] =
    var objectText = ""
    let syncRes = ctransport.V3ChengNodeTransportSyncDiscoveryText(node.transport,
                                                                   remote.transport,
                                                                   lookupKind,
                                                                   keyText,
                                                                   objectText)
    if IsErr(syncRes):
        return Err[bool](Error(syncRes))
    return v3ChengNodeAnnounceDiscoveryText(node, lookupKind, keyText, objectText)

fn V3ChengNodeStreamText(node: var V3ChengNode,
                         remote: var V3ChengNode,
                         protocolText: str): Result[str] =
    if protocolText == "identify":
        return ctransport.V3ChengNodeTransportIdentifyText(node.transport, remote.transport)
    let protocolRes = ctransport.V3ChengNodeTransportProtocolId(protocolText)
    if IsErr(protocolRes):
        return Err[str](Error(protocolRes))
    if remote.transport.host.listenAddrs.len <= 0:
        return Err[str]("cheng_node: remote transport has no listen addr")
    let remoteAddr = remote.transport.host.listenAddrs[0]
    let dialRes = libhost.v3Libp2pDial(node.transport.host,
                                       remote.transport.host.selfPeerId,
                                       remoteAddr,
                                       2)
    if IsErr(dialRes):
        return Err[str](Error(dialRes))
    let streamRes = libhost.v3Libp2pOpenStream(node.transport.host,
                                               remote.transport.host.selfPeerId,
                                               Value(protocolRes))
    if IsErr(streamRes):
        return Err[str](Error(streamRes))
    var out = ""
    out = out + "peer_id=" + ctransport.V3ChengNodeTransportPeerIdText(remote.transport) + "\n"
    out = out + "transport=" + libtypes.v3Libp2pTransportText(remoteAddr.transport) + "\n"
    out = out + "protocol=" + protocolText + "\n"
    out = out + "stream_id=" + intToStr(Value(streamRes)) + "\n"
    out = out + "open_stream_count=" + intToStr(node.transport.host.openStreamPeers.len)
    return Ok[str](out)

fn V3ChengNodeVpnUpsertPeer(node: var V3ChengNode,
                            session: tsnet.V3Libp2pTailnetPeerSession): Result[bool] =
    let objectText = ctransport.V3ChengNodeVpnPeerObjectText(session)
    let applyRes = ctransport.V3ChengNodeVpnApplyPeerText(node.vpn, objectText)
    if IsErr(applyRes):
        return Err[bool](Error(applyRes))
    return V3ChengNodeUpsertIndexedText(node,
                                        "vpn",
                                        "vpn_peer",
                                        "peer",
                                        session.peerId,
                                        "vpn_peer_session",
                                        objectText)

fn V3ChengNodeVpnUpsertOverlayRoute(node: var V3ChengNode,
                                    routeKey: str,
                                    rawAddr: libtypes.V3Libp2pMultiaddr): Result[bool] =
    let listenRes = tsnet.v3Libp2pTailnetListen(node.vpn.overlay, rawAddr)
    if IsErr(listenRes):
        return Err[bool](Error(listenRes))
    let objectText = ctransport.V3ChengNodeVpnOverlayRouteObjectText(routeKey,
                                                                     ctransport.V3ChengNodeTransportPeerIdText(node.transport),
                                                                     rawAddr,
                                                                     Value(listenRes))
    let applyRes = ctransport.V3ChengNodeVpnApplyOverlayRouteText(node.vpn, objectText)
    if IsErr(applyRes):
        return Err[bool](Error(applyRes))
    return V3ChengNodeUpsertIndexedText(node,
                                        "vpn",
                                        "vpn_route",
                                        "route",
                                        routeKey,
                                        "vpn_overlay_route",
                                        objectText)

fn V3ChengNodeVpnUpsertExitRoute(node: var V3ChengNode,
                                 routeKey: str,
                                 cfg: vpncfg.V3VpnProxyExitConfig): Result[bool] =
    var exits = vpnrouting.V3VpnProxyInitExitStates([cfg])
    if exits.len <= 0:
        return Err[bool]("cheng_node: exit state init failed")
    let objectText = ctransport.V3ChengNodeVpnExitRouteObjectText(routeKey, cfg, exits[0])
    let applyRes = ctransport.V3ChengNodeVpnApplyExitRouteText(node.vpn, objectText)
    if IsErr(applyRes):
        return Err[bool](Error(applyRes))
    return V3ChengNodeUpsertIndexedText(node,
                                        "vpn",
                                        "vpn_route",
                                        "route",
                                        routeKey,
                                        "vpn_exit_route",
                                        objectText)

fn V3ChengNodeVpnStatusReportText(node: V3ChengNode): str =
    return ctransport.V3ChengNodeVpnStatusText(node.vpn)

fn v3ChengNodeOracleSyncIndexes(node: var V3ChengNode): Result[bool] =
    if !node.oracle.machine.hasFinalized:
        return Ok[bool](false)
    var changed = false
    let machineText = cdomain.V3ChengNodeOracleMachineStateText(node.oracle)
    let machineUpsertRes = V3ChengNodeUpsertIndexedText(node,
                                                        "oracle",
                                                        "oracle",
                                                        "pair",
                                                        "__machine__",
                                                        "oracle_machine_state",
                                                        machineText)
    if IsErr(machineUpsertRes):
        return Err[bool](Error(machineUpsertRes))
    if Value(machineUpsertRes):
        changed = true
    var pairId = 1
    while pairId <= oracle_types.v3OraclePairCount:
        let pairKey = cdomain.V3ChengNodeOraclePairKeyFromPairId(pairId)
        if len(pairKey) <= 0:
            return Err[bool]("cheng_node oracle: pair key missing")
        let pairTextRes = cdomain.V3ChengNodeOraclePairStateText(node.oracle, pairId)
        if IsErr(pairTextRes):
            return Err[bool](Error(pairTextRes))
        let pairUpsertRes = V3ChengNodeUpsertIndexedText(node,
                                                         "oracle",
                                                         "oracle",
                                                         "pair",
                                                         pairKey,
                                                         "oracle_pair_state",
                                                         Value(pairTextRes))
        if IsErr(pairUpsertRes):
            return Err[bool](Error(pairUpsertRes))
        if Value(pairUpsertRes):
            changed = true
        pairId = pairId + 1
    return Ok[bool](changed)

fn V3ChengNodeOracleSubmitFixtureRound(node: var V3ChengNode,
                                       roundId: int64): Result[bool] =
    let finalizeRes = cdomain.V3ChengNodeOracleFinalizeFixtureRound(node.oracle, roundId)
    if IsErr(finalizeRes):
        return Err[bool](Error(finalizeRes))
    return v3ChengNodeOracleSyncIndexes(node)

fn V3ChengNodeOracleQueryText(node: V3ChengNode,
                              pairText: str,
                              withDelta: bool): Result[str] =
    var pairId = 0
    var pairKey = ""
    let resolveRes = cdomain.V3ChengNodeOracleResolvePair(pairText, pairId, pairKey)
    if IsErr(resolveRes):
        return Err[str](Error(resolveRes))
    let queryRes = V3ChengNodeKeyedQueryText(node,
                                             "oracle",
                                             "pair",
                                             pairKey,
                                             withDelta)
    if IsErr(queryRes):
        return Err[str](Error(queryRes))
    var out = ""
    let latestRes = cdomain.V3ChengNodeOracleLatestReportText(node.oracle, pairId)
    if IsOk(latestRes):
        out = out + Value(latestRes) + "\n"
    out = out + Value(queryRes)
    return Ok[str](out)

fn v3ChengNodeDilocoArtifactRef(jobBundleCid: layout.FixedBytes32,
                                tag: str): Result[diloco.V3DiLoCoArtifactRef] =
    var out = diloco.V3DiLoCoArtifactRefZero()
    let payloadText = "cheng_node.diloco.artifact|" + tag
    let refRes = diloco.V3DiLoCoArtifactRefFromBytesFill(out,
                                                         jobBundleCid,
                                                         bytesFromString(payloadText),
                                                         256,
                                                         tag)
    if IsErr(refRes):
        return Err[diloco.V3DiLoCoArtifactRef](Error(refRes))
    return Ok[diloco.V3DiLoCoArtifactRef](out)

fn v3ChengNodeDilocoLeaseKey(jobKey: str,
                             peerText: str): str =
    return jobKey + "/" + peerText

fn v3ChengNodeDilocoSyncJobText(node: var V3ChengNode,
                                jobKey: str,
                                jobBundleCid: layout.FixedBytes32): Result[bool] =
    let jobTextRes = cdomain.V3ChengNodeDilocoJobStateText(node.diloco,
                                                           jobKey,
                                                           jobBundleCid)
    if IsErr(jobTextRes):
        return Err[bool](Error(jobTextRes))
    return V3ChengNodeUpsertIndexedText(node,
                                        "diloco",
                                        "diloco_job",
                                        "job",
                                        jobKey,
                                        "diloco_job_state",
                                        Value(jobTextRes))

fn v3ChengNodeDilocoSyncCohortText(node: var V3ChengNode,
                                   jobKey: str,
                                   jobBundleCid: layout.FixedBytes32): Result[bool] =
    let cohortPos = diloco.V3DiLoCoCohortPos(node.diloco.state, jobBundleCid)
    if cohortPos < 0:
        return Err[bool]("cheng_node diloco: cohort missing")
    let cohortText = cdomain.V3ChengNodeDilocoCohortStateText(jobKey,
                                                              node.diloco.state.cohorts[cohortPos])
    return V3ChengNodeUpsertIndexedText(node,
                                        "diloco",
                                        "diloco_cohort",
                                        "cohort",
                                        jobKey,
                                        "diloco_cohort_state",
                                        cohortText)

fn v3ChengNodeDilocoSyncLeaseText(node: var V3ChengNode,
                                  jobKey: str,
                                  lease: diloco.V3DiLoCoLease): Result[bool] =
    let peerText = peer_id.v3Libp2pPeerIdText(lease.peerId)
    let leaseKey = v3ChengNodeDilocoLeaseKey(jobKey, peerText)
    let leaseText = cdomain.V3ChengNodeDilocoLeaseStateText(jobKey, leaseKey, lease)
    return V3ChengNodeUpsertIndexedText(node,
                                        "diloco",
                                        "diloco_lease",
                                        "lease",
                                        leaseKey,
                                        "diloco_lease_state",
                                        leaseText)

fn v3ChengNodeDilocoSyncAllLeases(node: var V3ChengNode,
                                  jobKey: str,
                                  jobBundleCid: layout.FixedBytes32): Result[bool] =
    var changed = false
    for i in 0..<node.diloco.state.leases.len:
        let lease = node.diloco.state.leases[i]
        if !layout.fixedBytes32Equal(lease.jobBundleCid, jobBundleCid):
            continue
        let leaseSyncRes = v3ChengNodeDilocoSyncLeaseText(node, jobKey, lease)
        if IsErr(leaseSyncRes):
            return Err[bool](Error(leaseSyncRes))
        if Value(leaseSyncRes):
            changed = true
    return Ok[bool](changed)

fn V3ChengNodeDilocoOpenJob(node: var V3ChengNode,
                            jobKey: str,
                            requestedWorkerCount: int32,
                            innerStepBudget: int32,
                            outerStepTimeoutSeconds: int32): Result[bool] =
    if len(jobKey) <= 0:
        return Err[bool]("cheng_node diloco: job key missing")
    let jobBundleCid = cdomain.V3ChengNodeDilocoJobBundleCid(jobKey)
    let modelRefRes = v3ChengNodeDilocoArtifactRef(jobBundleCid, jobKey + "|model.genesis")
    if IsErr(modelRefRes):
        return Err[bool](Error(modelRefRes))
    let optimizerRefRes = v3ChengNodeDilocoArtifactRef(jobBundleCid, jobKey + "|optimizer.genesis")
    if IsErr(optimizerRefRes):
        return Err[bool](Error(optimizerRefRes))
    var job = diloco.V3DiLoCoJobZero()
    var version = diloco.V3DiLoCoGlobalVersionZero()
    let openRes = diloco.V3DiLoCoOpenJobFill(job,
                                             version,
                                             node.diloco.state,
                                             jobBundleCid,
                                             requestedWorkerCount,
                                             innerStepBudget,
                                             outerStepTimeoutSeconds,
                                             Value(modelRefRes),
                                             Value(optimizerRefRes))
    if IsErr(openRes):
        return Err[bool](Error(openRes))
    return v3ChengNodeDilocoSyncJobText(node, jobKey, jobBundleCid)

fn V3ChengNodeDilocoJoinCohort(node: var V3ChengNode,
                               jobKey: str,
                               peerSeed: str): Result[bool] =
    let jobBundleCid = cdomain.V3ChengNodeDilocoJobBundleCid(jobKey)
    let peerId = cdomain.V3ChengNodeDilocoPeerIdFromSeed(peerSeed)
    var cohort = diloco.V3DiLoCoCohortZero()
    let joinRes = diloco.V3DiLoCoJoinCohortFill(cohort,
                                                node.diloco.state,
                                                jobBundleCid,
                                                peerId)
    if IsErr(joinRes):
        return Err[bool](Error(joinRes))
    let cohortSyncRes = v3ChengNodeDilocoSyncCohortText(node, jobKey, jobBundleCid)
    if IsErr(cohortSyncRes):
        return Err[bool](Error(cohortSyncRes))
    let jobSyncRes = v3ChengNodeDilocoSyncJobText(node, jobKey, jobBundleCid)
    if IsErr(jobSyncRes):
        return Err[bool](Error(jobSyncRes))
    return Ok[bool](Value(cohortSyncRes) || Value(jobSyncRes))

fn V3ChengNodeDilocoFetchLease(node: var V3ChengNode,
                               jobKey: str,
                               peerSeed: str): Result[bool] =
    let jobBundleCid = cdomain.V3ChengNodeDilocoJobBundleCid(jobKey)
    let peerId = cdomain.V3ChengNodeDilocoPeerIdFromSeed(peerSeed)
    var lease = diloco.V3DiLoCoLeaseZero()
    let leaseRes = diloco.V3DiLoCoFetchLeaseFill(lease,
                                                 node.diloco.state,
                                                 jobBundleCid,
                                                 peerId)
    if IsErr(leaseRes):
        return Err[bool](Error(leaseRes))
    return v3ChengNodeDilocoSyncLeaseText(node, jobKey, lease)

fn V3ChengNodeDilocoReportBarrier(node: var V3ChengNode,
                                  jobKey: str,
                                  peerSeed: str): Result[bool] =
    let jobBundleCid = cdomain.V3ChengNodeDilocoJobBundleCid(jobKey)
    let peerId = cdomain.V3ChengNodeDilocoPeerIdFromSeed(peerSeed)
    var barrier = diloco.V3DiLoCoBarrierZero()
    let barrierRes = diloco.V3DiLoCoReportInnerStepDoneFill(barrier,
                                                            node.diloco.state,
                                                            jobBundleCid,
                                                            peerId)
    if IsErr(barrierRes):
        return Err[bool](Error(barrierRes))
    return v3ChengNodeDilocoSyncJobText(node, jobKey, jobBundleCid)

fn V3ChengNodeDilocoSubmitOuterDelta(node: var V3ChengNode,
                                     jobKey: str,
                                     peerSeed: str,
                                     sampleCount: int32,
                                     tokenCount: int32,
                                     innerStepCount: int32,
                                     weightNumerator: int32,
                                     weightDenominator: int32): Result[bool] =
    let jobBundleCid = cdomain.V3ChengNodeDilocoJobBundleCid(jobKey)
    let jobPos = diloco.V3DiLoCoJobPos(node.diloco.state, jobBundleCid)
    if jobPos < 0:
        return Err[bool]("cheng_node diloco: job missing")
    let job = node.diloco.state.jobs[jobPos]
    let peerId = cdomain.V3ChengNodeDilocoPeerIdFromSeed(peerSeed)
    let peerText = peer_id.v3Libp2pPeerIdText(peerId)
    let modelTag = jobKey + "|model_delta|" + peerText + "|" + intToStr(job.currentOuterStep)
    let optimizerTag = jobKey + "|optimizer_delta|" + peerText + "|" + intToStr(job.currentOuterStep)
    let modelRefRes = v3ChengNodeDilocoArtifactRef(jobBundleCid, modelTag)
    if IsErr(modelRefRes):
        return Err[bool](Error(modelRefRes))
    let optimizerRefRes = v3ChengNodeDilocoArtifactRef(jobBundleCid, optimizerTag)
    if IsErr(optimizerRefRes):
        return Err[bool](Error(optimizerRefRes))
    var delta = diloco.V3DiLoCoOuterDeltaZero()
    let deltaRes = diloco.V3DiLoCoSubmitOuterDeltaFill(delta,
                                                       node.diloco.state,
                                                       jobBundleCid,
                                                       job.currentGlobalVersionCid,
                                                       job.currentOuterStep,
                                                       peerId,
                                                       Value(modelRefRes),
                                                       Value(optimizerRefRes),
                                                       sampleCount,
                                                       tokenCount,
                                                       innerStepCount,
                                                       weightNumerator,
                                                       weightDenominator)
    if IsErr(deltaRes):
        return Err[bool](Error(deltaRes))
    return v3ChengNodeDilocoSyncJobText(node, jobKey, jobBundleCid)

fn V3ChengNodeDilocoPublishMerge(node: var V3ChengNode,
                                 jobKey: str,
                                 leaderSeed: str): Result[bool] =
    let jobBundleCid = cdomain.V3ChengNodeDilocoJobBundleCid(jobKey)
    let jobPos = diloco.V3DiLoCoJobPos(node.diloco.state, jobBundleCid)
    if jobPos < 0:
        return Err[bool]("cheng_node diloco: job missing")
    let job = node.diloco.state.jobs[jobPos]
    let leaderPeerId = cdomain.V3ChengNodeDilocoPeerIdFromSeed(leaderSeed)
    let leaderPeerText = peer_id.v3Libp2pPeerIdText(leaderPeerId)
    let modelRefRes = v3ChengNodeDilocoArtifactRef(jobBundleCid,
                                                   jobKey + "|merge_model|" + leaderPeerText + "|" + intToStr(job.currentOuterStep))
    if IsErr(modelRefRes):
        return Err[bool](Error(modelRefRes))
    let optimizerRefRes = v3ChengNodeDilocoArtifactRef(jobBundleCid,
                                                       jobKey + "|merge_optimizer|" + leaderPeerText + "|" + intToStr(job.currentOuterStep))
    if IsErr(optimizerRefRes):
        return Err[bool](Error(optimizerRefRes))
    var commit = diloco.V3DiLoCoMergeCommitZero()
    var version = diloco.V3DiLoCoGlobalVersionZero()
    let mergeRes = diloco.V3DiLoCoPublishMergeCommitFill(commit,
                                                         version,
                                                         node.diloco.state,
                                                         jobBundleCid,
                                                         leaderPeerId,
                                                         Value(modelRefRes),
                                                         Value(optimizerRefRes))
    if IsErr(mergeRes):
        return Err[bool](Error(mergeRes))
    let jobSyncRes = v3ChengNodeDilocoSyncJobText(node, jobKey, jobBundleCid)
    if IsErr(jobSyncRes):
        return Err[bool](Error(jobSyncRes))
    let leaseSyncRes = v3ChengNodeDilocoSyncAllLeases(node, jobKey, jobBundleCid)
    if IsErr(leaseSyncRes):
        return Err[bool](Error(leaseSyncRes))
    return Ok[bool](Value(jobSyncRes) || Value(leaseSyncRes))

fn V3ChengNodeDilocoStatusText(node: V3ChengNode,
                               jobKey: str): Result[str] =
    return cdomain.V3ChengNodeDilocoStatusReportText(node.diloco, jobKey)

fn v3ChengNodeEvoMapNextSequence(node: V3ChengNode): int32 =
    var out = 1
    for i in 0..<node.evomap.capsules.len:
        if node.evomap.capsules[i].sequence >= out:
            out = node.evomap.capsules[i].sequence + 1
    return out

fn v3ChengNodeEvoMapIdentity(node: V3ChengNode,
                             didText: str,
                             peerText: str,
                             deviceLabel: str): evotypes.V3AgentIdentity =
    var out = evotypes.v3UnimakerAgentIdentityZero()
    out.didText = didText
    out.peerIdText = peerText
    out.deviceLabel = deviceLabel
    let keyHex = layout.fixedBytes32Hex(node.identity.evomapKey)
    out.signatureCid = evotypes.v3UnimakerHashText("v3.cheng_node.evomap.signature",
                                                   [keyHex,
                                                    out.didText,
                                                    out.peerIdText,
                                                    out.deviceLabel])
    out.identityCid = evotypes.v3UnimakerHashText("v3.unimaker.identity",
                                                  [out.didText,
                                                   out.peerIdText,
                                                   out.deviceLabel,
                                                   layout.fixedBytes32Hex(out.signatureCid)])
    return out

fn v3ChengNodeEvoMapResolveGene(capsuleKind: str,
                                capability: str,
                                strategy: str,
                                condition: str): Result[evotypes.V3EvoGene] =
    let capabilitySet = len(capability) > 0
    let strategySet = len(strategy) > 0
    let conditionSet = len(condition) > 0
    if capabilitySet || strategySet || conditionSet:
        if !capabilitySet || !strategySet || !conditionSet:
            return Err[evotypes.V3EvoGene]("cheng_node evomap: incomplete gene fields")
        return Ok[evotypes.V3EvoGene](evotypes.v3UnimakerGeneMake(capability,
                                                                  strategy,
                                                                  condition))
    let defaults = evotypes.v3UnimakerDefaultGenes()
    if defaults.len <= 0:
        return Err[evotypes.V3EvoGene]("cheng_node evomap: default gene missing")
    for i in 0..<defaults.len:
        if defaults[i].capability == "event_ingest":
            return Ok[evotypes.V3EvoGene](defaults[i])
    return Ok[evotypes.V3EvoGene](defaults[0])

fn V3ChengNodeEvoMapUpsertAgent(node: var V3ChengNode,
                                didText: str,
                                peerText: str,
                                deviceLabel: str): Result[bool] =
    if len(didText) <= 0 || len(peerText) <= 0 || len(deviceLabel) <= 0:
        return Err[bool]("cheng_node evomap: identity fields missing")
    var hello = evo.v3UnimakerProtocolHelloZero()
    hello.identity = v3ChengNodeEvoMapIdentity(node, didText, peerText, deviceLabel)
    hello.cursor = evotypes.v3UnimakerCursorMake(node.evomap.capsules.len,
                                                 evotypes.v3UnimakerGraphHeadCid(node.evomap.capsules))
    hello.genes = evotypes.v3UnimakerDefaultGenes()
    let objectText = cdomain.V3ChengNodeEvoMapAgentText(hello)
    let applyRes = cdomain.V3ChengNodeEvoMapApplyAgentText(node.evomap, objectText)
    if IsErr(applyRes):
        return Err[bool](Error(applyRes))
    return V3ChengNodeUpsertIndexedText(node,
                                        "evomap",
                                        "evomap",
                                        "agent",
                                        peerText,
                                        "evomap_agent_hello",
                                        objectText)

fn V3ChengNodeEvoMapAnchorTask(node: var V3ChengNode,
                               requesterPeerIdText: str,
                               taskId: str,
                               promptText: str,
                               keywords: str[],
                               contextCapsuleCids: layout.FixedBytes32[]): Result[bool] =
    if len(requesterPeerIdText) <= 0 || len(taskId) <= 0 || len(promptText) <= 0:
        return Err[bool]("cheng_node evomap: task fields missing")
    var taskValue = evo.v3UnimakerProtocolTaskZero()
    taskValue.requesterPeerIdText = requesterPeerIdText
    taskValue.task.taskId = taskId
    taskValue.task.promptText = promptText
    taskValue.task.keywords = keywords
    taskValue.contextCapsuleCids = contextCapsuleCids
    let objectText = cdomain.V3ChengNodeEvoMapTaskText(taskValue)
    let applyRes = cdomain.V3ChengNodeEvoMapApplyTaskText(node.evomap, objectText)
    if IsErr(applyRes):
        return Err[bool](Error(applyRes))
    return V3ChengNodeUpsertIndexedText(node,
                                        "evomap",
                                        "evomap",
                                        "task",
                                        taskId,
                                        "evomap_task",
                                        objectText)

fn V3ChengNodeEvoMapAnchorCapsule(node: var V3ChengNode,
                                  didText: str,
                                  peerText: str,
                                  deviceLabel: str,
                                  capsuleKind: str,
                                  taskId: str,
                                  contentText: str,
                                  keywords: str[],
                                  parentCids: layout.FixedBytes32[],
                                  relationKind: str,
                                  createdAtEpochSeconds: int64,
                                  geneCapability: str,
                                  geneStrategy: str,
                                  geneCondition: str): Result[bool] =
    if len(didText) <= 0 || len(peerText) <= 0 || len(deviceLabel) <= 0:
        return Err[bool]("cheng_node evomap: capsule identity missing")
    if len(taskId) <= 0 || len(contentText) <= 0:
        return Err[bool]("cheng_node evomap: capsule fields missing")
    if !evotypes.v3UnimakerCapsuleKindValid(capsuleKind):
        return Err[bool]("cheng_node evomap: invalid capsule kind")
    let relationText = len(relationKind) > 0 ? relationKind : evotypes.v3UnimakerEdgeKindCausedBy
    if !evotypes.v3UnimakerEdgeKindValid(relationText):
        return Err[bool]("cheng_node evomap: invalid relation kind")
    let geneRes = v3ChengNodeEvoMapResolveGene(capsuleKind,
                                               geneCapability,
                                               geneStrategy,
                                               geneCondition)
    if IsErr(geneRes):
        return Err[bool](Error(geneRes))
    let identityValue = v3ChengNodeEvoMapIdentity(node, didText, peerText, deviceLabel)
    let createdAt = createdAtEpochSeconds > int64(0) ? createdAtEpochSeconds : times.EpochTimeSeconds()
    let eventValue = evotypes.v3UnimakerEventMake(capsuleKind,
                                                  taskId,
                                                  contentText,
                                                  keywords,
                                                  parentCids,
                                                  relationText,
                                                  createdAt)
    let capsule = evotypes.v3UnimakerCapsuleMake(v3ChengNodeEvoMapNextSequence(node),
                                                 identityValue,
                                                 eventValue,
                                                 Value(geneRes))
    let objectText = cdomain.V3ChengNodeEvoMapCapsuleText(capsule)
    let applyRes = cdomain.V3ChengNodeEvoMapApplyCapsuleText(node.evomap, objectText)
    if IsErr(applyRes):
        return Err[bool](Error(applyRes))
    return V3ChengNodeUpsertIndexedText(node,
                                        "evomap",
                                        "evomap",
                                        "capsule",
                                        layout.fixedBytes32Hex(capsule.capsuleCid),
                                        "evomap_capsule",
                                        objectText)

fn V3ChengNodeEvoMapStatusText(node: V3ChengNode): str =
    return cdomain.V3ChengNodeEvoMapStatusReportText(node.evomap)

