import std/rawbytes
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/codec_binary as codec
import cheng/v3/libp2p/core/types

const
    v3Libp2pIdentifyRequestMagic: str = "v3.identify.request"
    v3Libp2pIdentifyResponseMagic: str = "v3.identify.resource"
    v3Libp2pIdentifyVersion: int32 = 1

fn v3Libp2pIdentifyAppendI64BE(buf: var layout.ByteBuf, value: int64) =
    codec.v3BufAppendU32BE(buf, int64((value >> 32) & int64(0xffffffff)))
    codec.v3BufAppendU32BE(buf, int64(value & int64(0xffffffff)))

fn v3Libp2pIdentifyReadU32BE(payload: Bytes, offset: int32): Result[int32] =
    if offset < 0 || (offset + 4) > bytesLen(payload):
        return Err[int32]("v3 libp2p identify: truncated u32")
    let b0 = bytesGet(payload, offset)
    let b1 = bytesGet(payload, offset + 1)
    let b2 = bytesGet(payload, offset + 2)
    let b3 = bytesGet(payload, offset + 3)
    return Ok[int32]((b0 << 24) | (b1 << 16) | (b2 << 8) | b3)

fn v3Libp2pIdentifyReadI64BE(payload: Bytes, offset: int32): Result[int64] =
    let hiRes = v3Libp2pIdentifyReadU32BE(payload, offset)
    if IsErr(hiRes):
        return Err[int64](Error(hiRes))
    let loRes = v3Libp2pIdentifyReadU32BE(payload, offset + 4)
    if IsErr(loRes):
        return Err[int64](Error(loRes))
    let hi = Value(hiRes)
    let lo = Value(loRes)
    return Ok[int64]((int64(hi) << 32) | (int64(lo) & int64(0xffffffff)))

fn v3Libp2pIdentifyRequestEncode(): Bytes =
    return bytesFromString(v3Libp2pIdentifyRequestMagic)

fn v3Libp2pIdentifyRequestValidate(payload: Bytes): Result[bool] =
    let want = bytesFromString(v3Libp2pIdentifyRequestMagic)
    if bytesLen(payload) != bytesLen(want):
        return Err[bool]("v3 libp2p identify: invalid request len")
    for i in 0..<bytesLen(want):
        if bytesGet(payload, i) != bytesGet(want, i):
            return Err[bool]("v3 libp2p identify: invalid request magic")
    return Ok[bool](true)

fn v3Libp2pIdentifyResponseEncode(sample: types.V3Libp2pNodeResource): Bytes =
    var buf = layout.byteBufInit(128)
    layout.byteBufAppendBytes(buf, bytesFromString(v3Libp2pIdentifyResponseMagic))
    codec.v3BufAppendU32BE(buf, v3Libp2pIdentifyVersion)
    v3Libp2pIdentifyAppendI64BE(buf, sample.sampledAtEpochSeconds)
    codec.v3BufAppendU32BE(buf, sample.cpuLogicalCores)
    v3Libp2pIdentifyAppendI64BE(buf, sample.memoryAvailableBytes)
    v3Libp2pIdentifyAppendI64BE(buf, sample.memoryTotalBytes)
    v3Libp2pIdentifyAppendI64BE(buf, sample.diskAvailableBytes)
    v3Libp2pIdentifyAppendI64BE(buf, sample.diskTotalBytes)
    codec.v3BufAppendU32BE(buf, sample.gpuDeviceCount)
    codec.v3BufAppendU32BE(buf, sample.gpuCoreCount)
    codec.v3BufAppendU32BE(buf, sample.npuDeviceCount)
    codec.v3BufAppendU32BE(buf, sample.npuCoreCount)
    return layout.byteBufToBytes(buf)

fn v3Libp2pIdentifyResponseDecodeFill(out: var types.V3Libp2pNodeResource,
                                      payload: Bytes): Result[bool] =
    let magic = bytesFromString(v3Libp2pIdentifyResponseMagic)
    if bytesLen(payload) < (bytesLen(magic) + 52):
        return Err[bool]("v3 libp2p identify: response too short")
    for i in 0..<bytesLen(magic):
        if bytesGet(payload, i) != bytesGet(magic, i):
            return Err[bool]("v3 libp2p identify: invalid response magic")
    var offset = bytesLen(magic)
    let versionRes = v3Libp2pIdentifyReadU32BE(payload, offset)
    if IsErr(versionRes):
        return Err[bool](Error(versionRes))
    offset = offset + 4
    if Value(versionRes) != v3Libp2pIdentifyVersion:
        return Err[bool]("v3 libp2p identify: unsupported response version")
    out = types.v3Libp2pNodeResourceZero()
    let sampledRes = v3Libp2pIdentifyReadI64BE(payload, offset)
    if IsErr(sampledRes):
        return Err[bool](Error(sampledRes))
    offset = offset + 8
    let cpuRes = v3Libp2pIdentifyReadU32BE(payload, offset)
    if IsErr(cpuRes):
        return Err[bool](Error(cpuRes))
    offset = offset + 4
    let memAvailRes = v3Libp2pIdentifyReadI64BE(payload, offset)
    if IsErr(memAvailRes):
        return Err[bool](Error(memAvailRes))
    offset = offset + 8
    let memTotalRes = v3Libp2pIdentifyReadI64BE(payload, offset)
    if IsErr(memTotalRes):
        return Err[bool](Error(memTotalRes))
    offset = offset + 8
    let diskAvailRes = v3Libp2pIdentifyReadI64BE(payload, offset)
    if IsErr(diskAvailRes):
        return Err[bool](Error(diskAvailRes))
    offset = offset + 8
    let diskTotalRes = v3Libp2pIdentifyReadI64BE(payload, offset)
    if IsErr(diskTotalRes):
        return Err[bool](Error(diskTotalRes))
    offset = offset + 8
    let gpuDeviceRes = v3Libp2pIdentifyReadU32BE(payload, offset)
    if IsErr(gpuDeviceRes):
        return Err[bool](Error(gpuDeviceRes))
    offset = offset + 4
    let gpuCoreRes = v3Libp2pIdentifyReadU32BE(payload, offset)
    if IsErr(gpuCoreRes):
        return Err[bool](Error(gpuCoreRes))
    offset = offset + 4
    let npuDeviceRes = v3Libp2pIdentifyReadU32BE(payload, offset)
    if IsErr(npuDeviceRes):
        return Err[bool](Error(npuDeviceRes))
    offset = offset + 4
    let npuCoreRes = v3Libp2pIdentifyReadU32BE(payload, offset)
    if IsErr(npuCoreRes):
        return Err[bool](Error(npuCoreRes))
    out.sampledAtEpochSeconds = Value(sampledRes)
    out.cpuLogicalCores = Value(cpuRes)
    out.memoryAvailableBytes = Value(memAvailRes)
    out.memoryTotalBytes = Value(memTotalRes)
    out.diskAvailableBytes = Value(diskAvailRes)
    out.diskTotalBytes = Value(diskTotalRes)
    out.gpuDeviceCount = Value(gpuDeviceRes)
    out.gpuCoreCount = Value(gpuCoreRes)
    out.npuDeviceCount = Value(npuDeviceRes)
    out.npuCoreCount = Value(npuCoreRes)
    return Ok[bool](true)
