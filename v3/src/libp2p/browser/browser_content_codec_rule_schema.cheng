import cheng/v3/lang/browser_abi_rule as barule

fn v3BrowserContentCodecModulePath(): str =
    return "cheng/v3/libp2p/browser/browser_content_codec_abi"

fn v3BrowserContentCodecRules(sourcePath: str): barule.V3BrowserAbiRule[] =
    var out: barule.V3BrowserAbiRule[] = []
    add(out, barule.v3BrowserAbiRuleNew(sourcePath,
                                        "input_bytes_required",
                                        "bytes_required",
                                        "bytes",
                                        "inline_result_error",
                                        "result_bytes",
                                        "none"))
    add(out, barule.v3BrowserAbiRuleNew(sourcePath,
                                        "input_text_required",
                                        "text_required",
                                        "text",
                                        "inline_result_error",
                                        "result_text",
                                        "none"))
    add(out, barule.v3BrowserAbiRuleNew(sourcePath,
                                        "input_text_optional",
                                        "text_optional",
                                        "text",
                                        "inline_result_error",
                                        "result_text",
                                        "none"))
    add(out, barule.v3BrowserAbiRuleNew(sourcePath,
                                        "output_bytes_handle",
                                        "none",
                                        "bytes",
                                        "inline_result_error",
                                        "handle_result",
                                        "raw_handle"))
    add(out, barule.v3BrowserAbiRuleNew(sourcePath,
                                        "output_text_handle",
                                        "none",
                                        "text",
                                        "inline_result_error",
                                        "handle_result",
                                        "text_handle"))
    add(out, barule.v3BrowserAbiRuleNew(sourcePath,
                                        "export_moq_fountain_bytes_result",
                                        "none",
                                        "bytes",
                                        "moq_fountain_last_error",
                                        "status_i32",
                                        "raw_handle"))
    add(out, barule.v3BrowserAbiRuleNew(sourcePath,
                                        "export_moq_fountain_text_result",
                                        "none",
                                        "text",
                                        "moq_fountain_last_error",
                                        "status_i32",
                                        "text_handle"))
    add(out, barule.v3BrowserAbiRuleNew(sourcePath,
                                        "moq_fountain_last_error_handle",
                                        "none",
                                        "text",
                                        "moq_fountain_last_error",
                                        "handle_result",
                                        "text_handle"))
    return out
