import cheng/v3/lang/browser_abi_rule as barule

fn v3BrowserContentCodecModulePath(): str =
    return "cheng/v3/libp2p/browser/browser_content_codec_abi"

fn v3BrowserContentCodecRuleInputBytesRequiredName(): str =
    return "input_bytes_required"

fn v3BrowserContentCodecRuleInputTextRequiredName(): str =
    return "input_text_required"

fn v3BrowserContentCodecRuleInputTextOptionalName(): str =
    return "input_text_optional"

fn v3BrowserContentCodecRuleOutputBytesHandleName(): str =
    return "output_bytes_handle"

fn v3BrowserContentCodecRuleOutputTextHandleName(): str =
    return "output_text_handle"

fn v3BrowserContentCodecRuleExportMoqFountainBytesResultName(): str =
    return "export_moq_fountain_bytes_result"

fn v3BrowserContentCodecRuleExportMoqFountainTextResultName(): str =
    return "export_moq_fountain_text_result"

fn v3BrowserContentCodecRuleMoqFountainLastErrorHandleName(): str =
    return "moq_fountain_last_error_handle"

fn v3BrowserContentCodecRuleByName(sourcePath: str,
                                   ruleName: str): barule.V3BrowserAbiRule =
    if ruleName == v3BrowserContentCodecRuleInputBytesRequiredName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          "bytes_required",
                                          "bytes",
                                          "inline_result_error",
                                          "result_bytes",
                                          "none")
    if ruleName == v3BrowserContentCodecRuleInputTextRequiredName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          "text_required",
                                          "text",
                                          "inline_result_error",
                                          "result_text",
                                          "none")
    if ruleName == v3BrowserContentCodecRuleInputTextOptionalName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          "text_optional",
                                          "text",
                                          "inline_result_error",
                                          "result_text",
                                          "none")
    if ruleName == v3BrowserContentCodecRuleOutputBytesHandleName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          "none",
                                          "bytes",
                                          "inline_result_error",
                                          "handle_result",
                                          "raw_handle")
    if ruleName == v3BrowserContentCodecRuleOutputTextHandleName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          "none",
                                          "text",
                                          "inline_result_error",
                                          "handle_result",
                                          "text_handle")
    if ruleName == v3BrowserContentCodecRuleExportMoqFountainBytesResultName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          "none",
                                          "bytes",
                                          "moq_fountain_last_error",
                                          "status_i32",
                                          "raw_handle")
    if ruleName == v3BrowserContentCodecRuleExportMoqFountainTextResultName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          "none",
                                          "text",
                                          "moq_fountain_last_error",
                                          "status_i32",
                                          "text_handle")
    if ruleName == v3BrowserContentCodecRuleMoqFountainLastErrorHandleName():
        return barule.v3BrowserAbiRuleNew(sourcePath,
                                          ruleName,
                                          "none",
                                          "text",
                                          "moq_fountain_last_error",
                                          "handle_result",
                                          "text_handle")
    assert(false, "browser_content_codec_rule_schema invalid rule name")
    return barule.v3BrowserAbiRuleNew(sourcePath,
                                      ruleName,
                                      "none",
                                      "none",
                                      "inline_result_error",
                                      "none",
                                      "none")

fn v3BrowserContentCodecRules(sourcePath: str): barule.V3BrowserAbiRule[] =
    var out: barule.V3BrowserAbiRule[] = []
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleInputBytesRequiredName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleInputTextRequiredName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleInputTextOptionalName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleOutputBytesHandleName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleOutputTextHandleName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleExportMoqFountainBytesResultName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleExportMoqFountainTextResultName()))
    add(out, v3BrowserContentCodecRuleByName(sourcePath, v3BrowserContentCodecRuleMoqFountainLastErrorHandleName()))
    return out
