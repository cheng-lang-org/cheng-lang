import cheng/v3/lang/browser_abi_rule as barule
import cheng/v3/libp2p/browser/browser_host_probe_rule_schema as browserprobe

importc fn cheng_v3_browser_now_ms_bridge(): int32
importc fn cheng_v3_browser_echo_i32_bridge(value: int32): int32
importc fn cheng_v3_browser_peer_handle_bridge(): int32
importc fn cheng_v3_browser_did_handle_bridge(): int32
importc fn cheng_v3_browser_dm_active_count_bridge(): int32
importc fn cheng_v3_browser_dm_connect_start_bridge(peerHandle: int32): int32
importc fn cheng_v3_browser_dm_wait_start_bridge(peerHandle: int32, timeoutMs: int32): int32
importc fn cheng_v3_browser_dm_send_start_bridge(peerHandle: int32,
                                                 conversationHandle: int32,
                                                 messageHandle: int32,
                                                 timestampMs: int32): int32

type V3BrowserHostProbeBridgePlan = barule.V3BrowserAbiBridgePlan

const v3BrowserHostProbeInputScalarNone = 0
const v3BrowserHostProbeInputScalarI32_1 = 1
const v3BrowserHostProbeInputScalarI32_2 = 2
const v3BrowserHostProbeInputScalarI32_4 = 4
const v3BrowserHostProbeOutputScalarI32 = 1

fn v3BrowserHostProbeBridgePlanForSourceRuleName(sourcePath: str,
                                                 ruleName: str): V3BrowserHostProbeBridgePlan =
    let rule = browserprobe.v3BrowserHostProbeRuleByName(sourcePath, ruleName)
    return barule.v3BrowserAbiBridgePlanForRule(rule)

fn v3BrowserHostProbeBridgePlanForRuleName(ruleName: str): V3BrowserHostProbeBridgePlan =
    return v3BrowserHostProbeBridgePlanForSourceRuleName(browserprobe.v3BrowserHostProbeModulePath(),
                                                         ruleName)

fn v3BrowserHostProbeInputSchemaKindFromBridgePlan(plan: V3BrowserHostProbeBridgePlan): int32 =
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleNowMsName():
        return v3BrowserHostProbeInputScalarNone
    if plan.ruleName == browserprobe.v3BrowserHostProbeRulePeerHandleName():
        return v3BrowserHostProbeInputScalarNone
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleDidHandleName():
        return v3BrowserHostProbeInputScalarNone
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleDmActiveCountName():
        return v3BrowserHostProbeInputScalarNone
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleEchoI32Name():
        return v3BrowserHostProbeInputScalarI32_1
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleDmConnectStartName():
        return v3BrowserHostProbeInputScalarI32_1
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleDmWaitStartName():
        return v3BrowserHostProbeInputScalarI32_2
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleDmSendStartName():
        return v3BrowserHostProbeInputScalarI32_4
    return -1

fn v3BrowserHostProbeOutputSchemaKindFromBridgePlan(plan: V3BrowserHostProbeBridgePlan): int32 =
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleNowMsName():
        return v3BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleEchoI32Name():
        return v3BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.v3BrowserHostProbeRulePeerHandleName():
        return v3BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleDidHandleName():
        return v3BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleDmActiveCountName():
        return v3BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleDmConnectStartName():
        return v3BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleDmWaitStartName():
        return v3BrowserHostProbeOutputScalarI32
    if plan.ruleName == browserprobe.v3BrowserHostProbeRuleDmSendStartName():
        return v3BrowserHostProbeOutputScalarI32
    return -1

fn v3BrowserHostProbeBridgeKeyForSourceRuleName(sourcePath: str,
                                                ruleName: str): str =
    let rule = browserprobe.v3BrowserHostProbeRuleByName(sourcePath, ruleName)
    let spec = barule.v3BrowserAbiBridgeSpecForRule(rule)
    return spec.bridgeKey

fn v3BrowserHostProbeBridgeKeyForRuleName(ruleName: str): str =
    return v3BrowserHostProbeBridgeKeyForSourceRuleName(browserprobe.v3BrowserHostProbeModulePath(),
                                                        ruleName)

fn v3BrowserHostProbeBridgeHelperNameForSourceRuleName(sourcePath: str,
                                                       ruleName: str): str =
    let rule = browserprobe.v3BrowserHostProbeRuleByName(sourcePath, ruleName)
    let spec = barule.v3BrowserAbiBridgeSpecForRule(rule)
    return barule.v3BrowserAbiBridgeHelperName(spec)

fn v3BrowserHostProbeBridgeHelperNameForRuleName(ruleName: str): str =
    return v3BrowserHostProbeBridgeHelperNameForSourceRuleName(browserprobe.v3BrowserHostProbeModulePath(),
                                                               ruleName)

fn v3BrowserHostProbeBridgeEmitLineForSourceRuleName(sourcePath: str,
                                                     ruleName: str): str =
    let rule = browserprobe.v3BrowserHostProbeRuleByName(sourcePath, ruleName)
    let spec = barule.v3BrowserAbiBridgeSpecForRule(rule)
    return barule.v3BrowserAbiBridgeEmitLine(spec)

fn v3BrowserHostProbeBridgeEmitLineForRuleName(ruleName: str): str =
    return v3BrowserHostProbeBridgeEmitLineForSourceRuleName(browserprobe.v3BrowserHostProbeModulePath(),
                                                             ruleName)

fn v3BrowserHostProbeAppendBridgeReportLine(out: var str,
                                            index: int32,
                                            sourcePath: str,
                                            ruleName: str) =
    out = out + "browser_bridge_plan["
    out = out + intToStr(index)
    out = out + "]="
    out = out + v3BrowserHostProbeBridgeEmitLineForSourceRuleName(sourcePath, ruleName)
    out = out + "\n"

fn v3BrowserHostProbeAppendBridgeReportLines(out: var str,
                                             sourcePath: str,
                                             startIndex: int32): int32 =
    var nextIndex = startIndex
    v3BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.v3BrowserHostProbeRuleNowMsName())
    nextIndex = nextIndex + 1
    v3BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.v3BrowserHostProbeRuleEchoI32Name())
    nextIndex = nextIndex + 1
    v3BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.v3BrowserHostProbeRulePeerHandleName())
    nextIndex = nextIndex + 1
    v3BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.v3BrowserHostProbeRuleDidHandleName())
    nextIndex = nextIndex + 1
    v3BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.v3BrowserHostProbeRuleDmActiveCountName())
    nextIndex = nextIndex + 1
    v3BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.v3BrowserHostProbeRuleDmConnectStartName())
    nextIndex = nextIndex + 1
    v3BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.v3BrowserHostProbeRuleDmWaitStartName())
    nextIndex = nextIndex + 1
    v3BrowserHostProbeAppendBridgeReportLine(out, nextIndex, sourcePath, browserprobe.v3BrowserHostProbeRuleDmSendStartName())
    return nextIndex + 1

fn v3BrowserHostProbeNowMs(): int32 =
    return cheng_v3_browser_now_ms_bridge()

fn v3BrowserHostProbeEchoI32(value: int32): int32 =
    return cheng_v3_browser_echo_i32_bridge(value)

fn v3BrowserHostProbePeerHandle(): int32 =
    return cheng_v3_browser_peer_handle_bridge()

fn v3BrowserHostProbeDidHandle(): int32 =
    return cheng_v3_browser_did_handle_bridge()

fn v3BrowserHostProbeDmActiveCount(): int32 =
    return cheng_v3_browser_dm_active_count_bridge()

fn v3BrowserHostProbeDmConnectStart(peerHandle: int32): int32 =
    return cheng_v3_browser_dm_connect_start_bridge(peerHandle)

fn v3BrowserHostProbeDmWaitStart(peerHandle: int32,
                                 timeoutMs: int32): int32 =
    return cheng_v3_browser_dm_wait_start_bridge(peerHandle, timeoutMs)

fn v3BrowserHostProbeDmSendStart(peerHandle: int32,
                                 conversationHandle: int32,
                                 messageHandle: int32,
                                 timestampMs: int32): int32 =
    return cheng_v3_browser_dm_send_start_bridge(peerHandle,
                                                 conversationHandle,
                                                 messageHandle,
                                                 timestampMs)
