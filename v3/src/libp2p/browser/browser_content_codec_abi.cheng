import std/rawbytes
import std/strings
import cheng/v3/libp2p/content/moq_fountain as moq

type V3BrowserCodecInputSchema = object
    kind: int32
    missingError: str
    copyError: str

type V3BrowserCodecOutputSchema = object
    kind: int32
    handleError: str

type V3BrowserCodecErrorSchema = object
    kind: int32

type V3BrowserCodecExportSchema = object
    output: V3BrowserCodecOutputSchema
    error: V3BrowserCodecErrorSchema

type V3BrowserMoqFountainPeerInput = object
    ownerPeerId: str
    remotePeersCsv: str
    mimeType: str

type V3BrowserMoqFountainBuildRequest = object
    blobBytes: Bytes
    ownerPeerId: str
    remotePeersCsv: str
    mimeType: str

const v3BrowserCodecInputBytesRequired = 1
const v3BrowserCodecInputTextRequired = 2
const v3BrowserCodecInputTextOptional = 3
const v3BrowserCodecOutputBytesHandle = 1
const v3BrowserCodecOutputTextHandle = 2
const v3BrowserCodecErrorMoqFountainLastError = 1

importc fn cheng_v3_browser_distributed_video_build_bridge(blobHandle: int32,
                                                           ownerPeerHandle: int32,
                                                           remotePeersHandle: int32,
                                                           dataShardCount: int32,
                                                           parityShardCount: int32,
                                                           shardPayloadBytes: int32): int32
importc fn cheng_v3_browser_distributed_video_rebuild_bridge(manifestPayloadHandle: int32,
                                                             shardSpecsHandle: int32,
                                                             dataShardCount: int32,
                                                             parityShardCount: int32,
                                                             shardPayloadBytes: int32): int32
importc fn cheng_v3_browser_distributed_video_last_error_handle_bridge(): int32
@importc("cheng_v3_browser_input_len_bridge")
fn cheng_v3_browser_input_len_bridge(handle: int32): int32
@importc("cheng_v3_browser_input_copy_bridge")
fn cheng_v3_browser_input_copy_bridge(handle: int32, data: ptr, n: int32): int32
@importc("cheng_v3_buffer_handle_from_raw_bridge")
fn cheng_v3_buffer_handle_from_raw_bridge(data: ptr, n: int32): int32
@importc("cheng_v3_buffer_handle_from_text_bridge")
fn cheng_v3_buffer_handle_from_text_bridge(text: str): int32
importc fn cheng_v3_browser_buffer_handle_len_bridge(handle: int32): int32
importc fn cheng_v3_browser_buffer_handle_byte_bridge(handle: int32, idx: int32): int32
importc fn cheng_v3_browser_buffer_handle_release_bridge(handle: int32): int32
importc fn cheng_v3_browser_moq_fountain_last_error_store_bridge(text: str): int32
importc fn cheng_v3_browser_moq_fountain_last_error_handle_bridge(): int32

fn browserMoqFountainSetLastError(text: str) =
    cheng_v3_browser_moq_fountain_last_error_store_bridge(text)

fn browserDistributedVideoBuild(blobHandle: int32,
                                ownerPeerHandle: int32,
                                remotePeersHandle: int32,
                                dataShardCount: int32,
                                parityShardCount: int32,
                                shardPayloadBytes: int32): int32 =
    return cheng_v3_browser_distributed_video_build_bridge(blobHandle,
                                                           ownerPeerHandle,
                                                           remotePeersHandle,
                                                           dataShardCount,
                                                           parityShardCount,
                                                           shardPayloadBytes)

fn browserDistributedVideoRebuild(manifestPayloadHandle: int32,
                                  shardSpecsHandle: int32,
                                  dataShardCount: int32,
                                  parityShardCount: int32,
                                  shardPayloadBytes: int32): int32 =
    return cheng_v3_browser_distributed_video_rebuild_bridge(manifestPayloadHandle,
                                                             shardSpecsHandle,
                                                             dataShardCount,
                                                             parityShardCount,
                                                             shardPayloadBytes)

fn browserDistributedVideoLastErrorHandle(): int32 =
    return cheng_v3_browser_distributed_video_last_error_handle_bridge()

fn browserInputBytes(handle: int32): int32 =
    return handle

fn browserInputText(handle: int32): int32 =
    return handle

fn browserInputTextRoundtripLen(handle: int32): int32 =
    let textRes = browserInputTextRequired(handle,
                                           "browser_input_missing_text",
                                           "browser_input_copy_text_failed")
    if IsErr(textRes):
        return if Error(textRes) == "browser_input_copy_text_failed": -2 else: -1
    let text = Value(textRes)
    return text.len

fn browserInputRemotePeerCount(handle: int32): int32 =
    let textRes = browserInputTextRequired(handle,
                                           "browser_input_missing_remote_peers",
                                           "browser_input_copy_remote_peers_failed")
    if IsErr(textRes):
        return if Error(textRes) == "browser_input_copy_remote_peers_failed": -2 else: -1
    let text = Value(textRes)
    let peers = moq.v3Libp2pMoqNormalizePeerCsv(text)
    return peers.len

fn v3BrowserCodecInputSchema(kind: int32,
                             missingError: str,
                             copyError: str): V3BrowserCodecInputSchema =
    var out: V3BrowserCodecInputSchema
    out.kind = kind
    out.missingError = missingError
    out.copyError = copyError
    return out

fn v3BrowserCodecOutputSchema(kind: int32,
                              handleError: str): V3BrowserCodecOutputSchema =
    var out: V3BrowserCodecOutputSchema
    out.kind = kind
    out.handleError = handleError
    return out

fn v3BrowserCodecErrorSchema(kind: int32): V3BrowserCodecErrorSchema =
    var out: V3BrowserCodecErrorSchema
    out.kind = kind
    return out

fn v3BrowserCodecExportSchema(output: V3BrowserCodecOutputSchema,
                              error: V3BrowserCodecErrorSchema): V3BrowserCodecExportSchema =
    var out: V3BrowserCodecExportSchema
    out.output = output
    out.error = error
    return out

fn browserCodecInputBytesRequiredSchema(missingError: str,
                                        copyError: str): V3BrowserCodecInputSchema =
    return v3BrowserCodecInputSchema(v3BrowserCodecInputBytesRequired, missingError, copyError)

fn browserCodecInputTextRequiredSchema(missingError: str,
                                       copyError: str): V3BrowserCodecInputSchema =
    return v3BrowserCodecInputSchema(v3BrowserCodecInputTextRequired, missingError, copyError)

fn browserCodecInputTextOptionalSchema(copyError: str): V3BrowserCodecInputSchema =
    return v3BrowserCodecInputSchema(v3BrowserCodecInputTextOptional, "", copyError)

fn browserCodecOutputBytesHandleSchema(handleError: str): V3BrowserCodecOutputSchema =
    return v3BrowserCodecOutputSchema(v3BrowserCodecOutputBytesHandle, handleError)

fn browserCodecOutputTextHandleSchema(handleError: str): V3BrowserCodecOutputSchema =
    return v3BrowserCodecOutputSchema(v3BrowserCodecOutputTextHandle, handleError)

fn browserCodecMoqFountainErrorSchema(): V3BrowserCodecErrorSchema =
    return v3BrowserCodecErrorSchema(v3BrowserCodecErrorMoqFountainLastError)

fn browserCodecMoqFountainExportSchema(outputKind: int32,
                                       handleError: str): V3BrowserCodecExportSchema =
    return v3BrowserCodecExportSchema(v3BrowserCodecOutputSchema(outputKind, handleError),
                                      browserCodecMoqFountainErrorSchema())

fn browserCodecPublishError(text: str,
                            schema: V3BrowserCodecErrorSchema) =
    if schema.kind == v3BrowserCodecErrorMoqFountainLastError:
        browserMoqFountainSetLastError(text)

fn browserCodecClearError(schema: V3BrowserCodecErrorSchema) =
    browserCodecPublishError("", schema)

fn browserCodecReadInputBytes(handle: int32,
                              schema: V3BrowserCodecInputSchema): Result[Bytes] =
    let inputLen = cheng_v3_browser_input_len_bridge(handle)
    if handle <= 0 || inputLen <= 0:
        if schema.kind == v3BrowserCodecInputTextOptional:
            return Ok[Bytes](bytesAlloc(0))
        return Err[Bytes](schema.missingError)
    var inputBytes = bytesAlloc(inputLen)
    if cheng_v3_browser_input_copy_bridge(handle, inputBytes.data, inputLen) <= 0:
        return Err[Bytes](schema.copyError)
    return Ok[Bytes](inputBytes)

fn browserCodecReadInputText(handle: int32,
                             schema: V3BrowserCodecInputSchema): Result[str] =
    let bytesRes = browserCodecReadInputBytes(handle, schema)
    if IsErr(bytesRes):
        return Err[str](Error(bytesRes))
    return Ok[str](bytesToString(Value(bytesRes)))

fn browserCodecWriteOutputBytesHandle(payload: Bytes,
                                      schema: V3BrowserCodecOutputSchema): Result[int32] =
    if schema.kind != v3BrowserCodecOutputBytesHandle:
        return Err[int32](schema.handleError)
    let handle = cheng_v3_buffer_handle_from_raw_bridge(payload.data, bytesLen(payload))
    if handle <= 0:
        return Err[int32](schema.handleError)
    return Ok[int32](handle)

fn browserCodecWriteOutputTextHandle(text: str,
                                     schema: V3BrowserCodecOutputSchema): Result[int32] =
    if schema.kind != v3BrowserCodecOutputTextHandle || len(text) <= 0:
        return Err[int32](schema.handleError)
    let handle = cheng_v3_buffer_handle_from_text_bridge(text)
    if handle <= 0:
        return Err[int32](schema.handleError)
    return Ok[int32](handle)

fn browserCodecLiftTextHandle(textRes: Result[str],
                              schema: V3BrowserCodecOutputSchema): Result[int32] =
    if IsErr(textRes):
        return Err[int32](Error(textRes))
    return browserCodecWriteOutputTextHandle(Value(textRes), schema)

fn browserCodecLiftBytesHandle(bytesRes: Result[Bytes],
                               schema: V3BrowserCodecOutputSchema): Result[int32] =
    if IsErr(bytesRes):
        return Err[int32](Error(bytesRes))
    return browserCodecWriteOutputBytesHandle(Value(bytesRes), schema)

fn browserCodecExportHandleResult(handleRes: Result[int32],
                                  schema: V3BrowserCodecExportSchema): int32 =
    browserCodecClearError(schema.error)
    if IsErr(handleRes):
        browserCodecPublishError(Error(handleRes), schema.error)
        return 0
    return Value(handleRes)

fn browserCodecExportTextResult(textRes: Result[str],
                                schema: V3BrowserCodecExportSchema): int32 =
    let handleRes = browserCodecLiftTextHandle(textRes, schema.output)
    return browserCodecExportHandleResult(handleRes, schema)

fn browserCodecExportBytesResult(bytesRes: Result[Bytes],
                                 schema: V3BrowserCodecExportSchema): int32 =
    let handleRes = browserCodecLiftBytesHandle(bytesRes, schema.output)
    return browserCodecExportHandleResult(handleRes, schema)

fn browserCodecExportMoqFountainTextResult(textRes: Result[str],
                                           handleError: str): int32 =
    let schema = browserCodecMoqFountainExportSchema(v3BrowserCodecOutputTextHandle, handleError)
    return browserCodecExportTextResult(textRes, schema)

fn browserCodecExportMoqFountainBytesResult(bytesRes: Result[Bytes],
                                            handleError: str): int32 =
    let schema = browserCodecMoqFountainExportSchema(v3BrowserCodecOutputBytesHandle, handleError)
    return browserCodecExportBytesResult(bytesRes, schema)

fn browserInputBytesRequired(handle: int32,
                             missingError: str,
                             copyError: str): Result[Bytes] =
    let schema = browserCodecInputBytesRequiredSchema(missingError, copyError)
    return browserCodecReadInputBytes(handle, schema)

fn browserInputTextRequired(handle: int32,
                            missingError: str,
                            copyError: str): Result[str] =
    let schema = browserCodecInputTextRequiredSchema(missingError, copyError)
    return browserCodecReadInputText(handle, schema)

fn browserInputTextOptional(handle: int32,
                            copyError: str): Result[str] =
    let schema = browserCodecInputTextOptionalSchema(copyError)
    return browserCodecReadInputText(handle, schema)

fn browserBufferHandleFromBytesRequired(payload: Bytes,
                                        handleError: str): Result[int32] =
    let schema = browserCodecOutputBytesHandleSchema(handleError)
    return browserCodecWriteOutputBytesHandle(payload, schema)

fn browserBufferHandleFromTextRequired(text: str,
                                       handleError: str): Result[int32] =
    let schema = browserCodecOutputTextHandleSchema(handleError)
    return browserCodecWriteOutputTextHandle(text, schema)

fn browserMoqFountainBuildWireText(blobBytes: Bytes,
                                   ownerPeerId: str,
                                   remotePeersCsv: str,
                                   mimeType: str,
                                   objectTargetBytes: int32,
                                   sourceBlockBytes: int32,
                                   repairDropletCount: int32): Result[str] =
    let wireText = moq.v3Libp2pMoqBuildToWire(blobBytes,
                                              ownerPeerId,
                                              remotePeersCsv,
                                              mimeType,
                                              objectTargetBytes,
                                              sourceBlockBytes,
                                              repairDropletCount)
    if len(wireText) <= 0:
        return Err[str]("moq_fountain_build_returned_empty_wire")
    return Ok[str](wireText)

fn browserMoqFountainBuildWireBytes(blobBytes: Bytes,
                                    ownerPeerId: str,
                                    remotePeersCsv: str,
                                    mimeType: str,
                                    objectTargetBytes: int32,
                                    sourceBlockBytes: int32,
                                    repairDropletCount: int32): Result[Bytes] =
    let wireTextRes = browserMoqFountainBuildWireText(blobBytes,
                                                      ownerPeerId,
                                                      remotePeersCsv,
                                                      mimeType,
                                                      objectTargetBytes,
                                                      sourceBlockBytes,
                                                      repairDropletCount)
    if IsErr(wireTextRes):
        return Err[Bytes](Error(wireTextRes))
    let wireText = Value(wireTextRes)
    return Ok[Bytes](bytesSlice(bytesFromString(wireText), 0, len(wireText)))

fn browserMoqFountainPeerInput(ownerPeerHandle: int32,
                               remotePeersHandle: int32,
                               mimeTypeHandle: int32): Result[V3BrowserMoqFountainPeerInput] =
    let ownerPeerSchema = browserCodecInputTextRequiredSchema("moq_fountain_missing_owner_peer",
                                                              "moq_fountain_copy_owner_peer_failed")
    let remotePeersSchema = browserCodecInputTextRequiredSchema("moq_fountain_missing_remote_peers",
                                                                "moq_fountain_copy_remote_peers_failed")
    let mimeTypeSchema = browserCodecInputTextOptionalSchema("moq_fountain_copy_mime_type_failed")
    let ownerPeerRes = browserCodecReadInputText(ownerPeerHandle, ownerPeerSchema)
    if IsErr(ownerPeerRes):
        return Err[V3BrowserMoqFountainPeerInput](Error(ownerPeerRes))
    let remotePeersRes = browserCodecReadInputText(remotePeersHandle, remotePeersSchema)
    if IsErr(remotePeersRes):
        return Err[V3BrowserMoqFountainPeerInput](Error(remotePeersRes))
    let mimeTypeRes = browserCodecReadInputText(mimeTypeHandle, mimeTypeSchema)
    if IsErr(mimeTypeRes):
        return Err[V3BrowserMoqFountainPeerInput](Error(mimeTypeRes))
    var out: V3BrowserMoqFountainPeerInput
    out.ownerPeerId = Value(ownerPeerRes)
    out.remotePeersCsv = Value(remotePeersRes)
    out.mimeType = Value(mimeTypeRes)
    return Ok[V3BrowserMoqFountainPeerInput](out)

fn browserMoqFountainBuildRequest(blobHandle: int32,
                                  ownerPeerHandle: int32,
                                  remotePeersHandle: int32,
                                  mimeTypeHandle: int32): Result[V3BrowserMoqFountainBuildRequest] =
    let blobSchema = browserCodecInputBytesRequiredSchema("moq_fountain_missing_blob",
                                                          "moq_fountain_copy_blob_failed")
    let blobBytesRes = browserCodecReadInputBytes(blobHandle, blobSchema)
    if IsErr(blobBytesRes):
        return Err[V3BrowserMoqFountainBuildRequest](Error(blobBytesRes))
    let peerInputRes = browserMoqFountainPeerInput(ownerPeerHandle,
                                                   remotePeersHandle,
                                                   mimeTypeHandle)
    if IsErr(peerInputRes):
        return Err[V3BrowserMoqFountainBuildRequest](Error(peerInputRes))
    let peerInput = Value(peerInputRes)
    var out: V3BrowserMoqFountainBuildRequest
    out.blobBytes = Value(blobBytesRes)
    out.ownerPeerId = peerInput.ownerPeerId
    out.remotePeersCsv = peerInput.remotePeersCsv
    out.mimeType = peerInput.mimeType
    return Ok[V3BrowserMoqFountainBuildRequest](out)

fn browserMoqFountainBuildWireFromHandles(blobHandle: int32,
                                          ownerPeerHandle: int32,
                                          remotePeersHandle: int32,
                                          mimeTypeHandle: int32,
                                          objectTargetBytes: int32,
                                          sourceBlockBytes: int32,
                                          repairDropletCount: int32): Result[str] =
    let requestRes = browserMoqFountainBuildRequest(blobHandle,
                                                    ownerPeerHandle,
                                                    remotePeersHandle,
                                                    mimeTypeHandle)
    if IsErr(requestRes):
        return Err[str](Error(requestRes))
    let request = Value(requestRes)
    return browserMoqFountainBuildWireText(request.blobBytes,
                                           request.ownerPeerId,
                                           request.remotePeersCsv,
                                           request.mimeType,
                                           objectTargetBytes,
                                           sourceBlockBytes,
                                           repairDropletCount)

fn browserMoqFountainBuildWireBytesFromHandles(blobHandle: int32,
                                               ownerPeerHandle: int32,
                                               remotePeersHandle: int32,
                                               mimeTypeHandle: int32,
                                               objectTargetBytes: int32,
                                               sourceBlockBytes: int32,
                                               repairDropletCount: int32): Result[Bytes] =
    let requestRes = browserMoqFountainBuildRequest(blobHandle,
                                                    ownerPeerHandle,
                                                    remotePeersHandle,
                                                    mimeTypeHandle)
    if IsErr(requestRes):
        return Err[Bytes](Error(requestRes))
    let request = Value(requestRes)
    return browserMoqFountainBuildWireBytes(request.blobBytes,
                                            request.ownerPeerId,
                                            request.remotePeersCsv,
                                            request.mimeType,
                                            objectTargetBytes,
                                            sourceBlockBytes,
                                            repairDropletCount)

fn browserMoqFountainRebuildWireText(requestWireHandle: int32): Result[str] =
    let requestWireRes = browserInputTextRequired(requestWireHandle,
                                                  "moq_fountain_missing_request_wire",
                                                  "moq_fountain_copy_request_wire_failed")
    if IsErr(requestWireRes):
        return Err[str](Error(requestWireRes))
    return Ok[str](moq.v3Libp2pMoqRebuildToWire(Value(requestWireRes)))

fn browserMoqFountainRebuildWireBytes(requestWireHandle: int32): Result[Bytes] =
    let wireTextRes = browserMoqFountainRebuildWireText(requestWireHandle)
    if IsErr(wireTextRes):
        return Err[Bytes](Error(wireTextRes))
    let wireText = Value(wireTextRes)
    return Ok[Bytes](bytesSlice(bytesFromString(wireText), 0, len(wireText)))

fn browserMoqFountainInputRemotePeerCount(ownerPeerHandle: int32,
                                          remotePeersHandle: int32,
                                          mimeTypeHandle: int32): int32 =
    let peerInputRes = browserMoqFountainPeerInput(ownerPeerHandle,
                                                   remotePeersHandle,
                                                   mimeTypeHandle)
    if IsErr(peerInputRes):
        return -1
    let peerInput = Value(peerInputRes)
    let peers = moq.v3Libp2pMoqNormalizePeerCsv(peerInput.remotePeersCsv)
    return peers.len

fn browserMoqFountainBuildRemotePeerCount(blobHandle: int32,
                                          ownerPeerHandle: int32,
                                          remotePeersHandle: int32,
                                          mimeTypeHandle: int32,
                                          objectTargetBytes: int32,
                                          sourceBlockBytes: int32,
                                          repairDropletCount: int32): int32 =
    let requestRes = browserMoqFountainBuildRequest(blobHandle,
                                                    ownerPeerHandle,
                                                    remotePeersHandle,
                                                    mimeTypeHandle)
    if IsErr(requestRes):
        return -1
    let request = Value(requestRes)
    let buildRes = moq.v3Libp2pMoqBuild(request.blobBytes,
                                        request.ownerPeerId,
                                        request.remotePeersCsv,
                                        request.mimeType,
                                        objectTargetBytes,
                                        sourceBlockBytes,
                                        repairDropletCount)
    if IsErr(buildRes):
        return -2
    return Value(buildRes).remoteAckPeerIds.len

fn browserMoqFountainBuildWireRemotePeerCsvLen(blobHandle: int32,
                                               ownerPeerHandle: int32,
                                               remotePeersHandle: int32,
                                               mimeTypeHandle: int32,
                                               objectTargetBytes: int32,
                                               sourceBlockBytes: int32,
                                               repairDropletCount: int32): int32 =
    let requestRes = browserMoqFountainBuildRequest(blobHandle,
                                                    ownerPeerHandle,
                                                    remotePeersHandle,
                                                    mimeTypeHandle)
    if IsErr(requestRes):
        return -1
    let request = Value(requestRes)
    let wireTextRes = browserMoqFountainBuildWireText(request.blobBytes,
                                                      request.ownerPeerId,
                                                      request.remotePeersCsv,
                                                      request.mimeType,
                                                      objectTargetBytes,
                                                      sourceBlockBytes,
                                                      repairDropletCount)
    if IsErr(wireTextRes):
        return -2
    let csvRes = moq.v3Libp2pMoqWireFindValue(Value(wireTextRes), "remote_ack_peer_ids")
    if IsErr(csvRes):
        return -3
    return Value(csvRes).len

fn browserMoqFountainBuild(blobHandle: int32,
                           ownerPeerHandle: int32,
                           remotePeersHandle: int32,
                           mimeTypeHandle: int32,
                           objectTargetBytes: int32,
                           sourceBlockBytes: int32,
                           repairDropletCount: int32): int32 =
    let wireTextRes = browserMoqFountainBuildWireFromHandles(blobHandle,
                                                             ownerPeerHandle,
                                                             remotePeersHandle,
                                                             mimeTypeHandle,
                                                             objectTargetBytes,
                                                             sourceBlockBytes,
                                                             repairDropletCount)
    return browserCodecExportMoqFountainTextResult(wireTextRes,
                                                   "moq_fountain_build_buffer_handle_failed")

fn browserMoqFountainBuildBytes(blobHandle: int32,
                                ownerPeerHandle: int32,
                                remotePeersHandle: int32,
                                mimeTypeHandle: int32,
                                objectTargetBytes: int32,
                                sourceBlockBytes: int32,
                                repairDropletCount: int32): int32 =
    let wireBytesRes = browserMoqFountainBuildWireBytesFromHandles(blobHandle,
                                                                   ownerPeerHandle,
                                                                   remotePeersHandle,
                                                                   mimeTypeHandle,
                                                                   objectTargetBytes,
                                                                   sourceBlockBytes,
                                                                   repairDropletCount)
    return browserCodecExportMoqFountainBytesResult(wireBytesRes,
                                                    "moq_fountain_build_raw_buffer_handle_failed")

fn browserMoqFountainRebuild(requestWireHandle: int32): int32 =
    let wireTextRes = browserMoqFountainRebuildWireText(requestWireHandle)
    return browserCodecExportMoqFountainTextResult(wireTextRes,
                                                   "moq_fountain_rebuild_buffer_handle_failed")

fn browserMoqFountainRebuildBytes(requestWireHandle: int32): int32 =
    let wireBytesRes = browserMoqFountainRebuildWireBytes(requestWireHandle)
    return browserCodecExportMoqFountainBytesResult(wireBytesRes,
                                                    "moq_fountain_rebuild_raw_buffer_handle_failed")

fn browserMoqFountainLastErrorHandle(): int32 =
    return cheng_v3_browser_moq_fountain_last_error_handle_bridge()

fn browserBufferHandleLen(handle: int32): int32 =
    return cheng_v3_browser_buffer_handle_len_bridge(handle)

fn browserBufferHandleByte(handle: int32, idx: int32): int32 =
    return cheng_v3_browser_buffer_handle_byte_bridge(handle, idx)

fn browserBufferHandleRelease(handle: int32): int32 =
    return cheng_v3_browser_buffer_handle_release_bridge(handle)
