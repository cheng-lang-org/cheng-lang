import std/rawbytes
import std/result
import std/strings
import std/strformat
import std/strutils
import cheng/v3/std/bytes_layout as layout

importc fn cheng_v3_sha256_hex_bridge(text: str): str

type V3Libp2pMoqDroplet = object
    objectIndex: int32
    dropletIndex: int32
    kindCode: int32
    key: str
    peerId: str
    cid: str
    degree: int32
    blockIndexes: int32[]
    payload: Bytes

type V3Libp2pMoqObject = object
    objectIndex: int32
    groupId: str
    objectId: str
    priority: int32
    byteOffset: int32
    byteLength: int32
    objectCid: str
    sourceBlockBytes: int32
    sourceBlockCount: int32
    repairDropletCount: int32
    droplets: V3Libp2pMoqDroplet[]

type V3Libp2pMoqEquation = object
    coeffs: int32[]
    payload: Bytes

type V3Libp2pMoqBuildResult = object
    ownerPeerId: str
    mimeType: str
    bundleCid: str
    blobCid: str
    catalogKey: str
    catalogCid: str
    catalogSizeBytes: int32
    catalogPayload: Bytes
    rebuildTemplateKey: str
    rebuildTemplateCid: str
    rebuildTemplateSizeBytes: int32
    rebuildTemplatePayload: Bytes
    blobByteLen: int32
    objectTargetBytes: int32
    sourceBlockBytes: int32
    objectCount: int32
    remoteAckPeerIds: str[]
    objects: V3Libp2pMoqObject[]
    droplets: V3Libp2pMoqDroplet[]

type V3Libp2pMoqRebuildResult = object
    blob: Bytes
    blobCid: str
    blobByteLen: int32

const v3Libp2pMoqCatalogMagic = "unimaker.moq.fountain.catalog.v1"
const v3Libp2pMoqTransport = "native_media_rpc"
const v3Libp2pMoqLayout = "lt_xor_v1"
const v3Libp2pMoqDropletKindSource = 1
const v3Libp2pMoqDropletKindRepair = 2

fn v3Libp2pMoqErrorWire(errorText: str): str =
    var rows: str[]
    rows = []
    add(rows, "ok=0")
    add(rows, v3Libp2pMoqFmt2("error=", errorText))
    return v3Libp2pMoqLinesWithNewline(rows)

fn v3Libp2pMoqMaxInt32(left: int32, right: int32): int32 =
    if left >= right:
        return left
    return right

fn v3Libp2pMoqMinInt32(left: int32, right: int32): int32 =
    if left <= right:
        return left
    return right

fn v3Libp2pMoqNormalizePositiveInt(value: int32, fallback: int32): int32 =
    var out = value
    if out <= 0:
        out = fallback
    if out <= 0:
        return 1
    return out

fn v3Libp2pMoqHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn v3Libp2pMoqBytesFromHex(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](bytesAlloc(0))
    if (len(text) % 2) != 0:
        return Err[Bytes]("moq_fountain_invalid_hex_length")
    var out = bytesAlloc(len(text) / 2)
    var i: int32 = 0
    while i < len(text):
        let hi = v3Libp2pMoqHexValue(text[i])
        let lo = v3Libp2pMoqHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes]("moq_fountain_invalid_hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn v3Libp2pMoqSha256HexBytes(data: Bytes): str =
    let text = bytesToString(data)
    let digest = cheng_v3_sha256_hex_bridge(text)
    return digest

fn v3Libp2pMoqSha256HexText(text: str): str =
    return cheng_v3_sha256_hex_bridge(text)

fn v3Libp2pMoqAsciiTrimLeft(text: str): int32 =
    var idx: int32 = 0
    while idx < len(text):
        let code = int32(text[idx])
        if code == 32 || code == 10 || code == 13 || code == 9:
            idx = idx + 1
            continue
        break
    return idx

fn v3Libp2pMoqAsciiTrimRight(text: str): int32 =
    var idx: int32 = len(text)
    while idx > 0:
        let code = int32(text[idx - 1])
        if code == 32 || code == 10 || code == 13 || code == 9:
            idx = idx - 1
            continue
        break
    return idx

fn v3Libp2pMoqTrimAscii(text: str): str =
    let start = v3Libp2pMoqAsciiTrimLeft(text)
    let stop = v3Libp2pMoqAsciiTrimRight(text)
    var sliceStart: int32 = 0
    var sliceCount: int32 = 0
    if stop > start:
        sliceStart = start
        sliceCount = stop - start
    let out = strings.SliceBytes(text, sliceStart, sliceCount)
    return out

fn v3Libp2pMoqSplitCsv(text: str): str[] =
    var out: str[]
    out = []
    if len(text) <= 0:
        return out
    var start: int32 = 0
    var idx: int32 = 0
    while idx <= len(text):
        let atEnd = idx >= len(text)
        var hitSplit = atEnd
        if !hitSplit:
            if text[idx] == ',':
                hitSplit = true
        if hitSplit:
            var item = ""
            if idx > start:
                item = strings.SliceBytes(text, start, idx - start)
            add(out, item)
            start = idx + 1
        idx = idx + 1
    return out

fn v3Libp2pMoqNormalizePeerCsv(peerCsv: str): str[] =
    let parts = v3Libp2pMoqSplitCsv(peerCsv)
    var out: str[]
    out = []
    var i: int32 = 0
    while i < parts.len:
        let candidate = v3Libp2pMoqTrimAscii(parts[i])
        if len(candidate) <= 0:
            i = i + 1
            continue
        var exists = false
        var j: int32 = 0
        while j < out.len:
            if out[j] == candidate:
                exists = true
                break
            j = j + 1
        if !exists:
            add(out, candidate)
        i = i + 1
    return out

fn v3Libp2pMoqJoinCsv(values: str[]): str =
    if values.len <= 0:
        return ""
    return strutils.Join(values, ",")

fn v3Libp2pMoqJoinIntCsv(values: int32[]): str =
    var rows: str[]
    rows = []
    var i: int32 = 0
    while i < values.len:
        add(rows, strings.IntToStr(values[i]))
        i = i + 1
    return strutils.Join(rows, ",")

fn v3Libp2pMoqFmt2(left: str, right: str): str =
    var parts: str[]
    parts = []
    add(parts, left)
    add(parts, right)
    return Fmt(parts)

fn v3Libp2pMoqFmt3(first: str, second: str, third: str): str =
    var parts: str[]
    parts = []
    add(parts, first)
    add(parts, second)
    add(parts, third)
    return Fmt(parts)

fn v3Libp2pMoqCatalogJson(ownerPeerId: str,
                          mimeType: str,
                          blobCid: str,
                          blobByteLen: int32,
                          bundleCid: str,
                          objectTargetBytes: int32,
                          sourceBlockBytes: int32,
                          objects: V3Libp2pMoqObject[]): str =
    var catalogMagic = "\"unimaker.moq.fountain.catalog.v1\""
    var transportText = "\"moq\""
    var layoutText = "\"lt_fountain_v1\""
    var ownerPeerText = ""
    ownerPeerText = v3Libp2pMoqJsonQuote(ownerPeerId)
    var mimeTypeText = ""
    mimeTypeText = v3Libp2pMoqJsonQuote(mimeType)
    var blobCidText = ""
    blobCidText = v3Libp2pMoqJsonQuote(blobCid)
    var trackIdRaw = ""
    trackIdRaw = v3Libp2pMoqFmt2("track:", bundleCid)
    var trackIdText = ""
    trackIdText = v3Libp2pMoqJsonQuote(trackIdRaw)
    var bundleCidText = ""
    bundleCidText = v3Libp2pMoqJsonQuote(bundleCid)
    var blobByteLenText = ""
    blobByteLenText = strings.IntToStr(blobByteLen)
    var objectTargetBytesText = ""
    objectTargetBytesText = strings.IntToStr(objectTargetBytes)
    var sourceBlockBytesText = ""
    sourceBlockBytesText = strings.IntToStr(sourceBlockBytes)
    var objectCountText = ""
    objectCountText = strings.IntToStr(objects.len)
    var out = "{"
    v3Libp2pMoqConcatAssign(out, "\"magic\":")
    v3Libp2pMoqConcatAssign(out, catalogMagic)
    v3Libp2pMoqConcatAssign(out, ",\"version\":1,")
    v3Libp2pMoqConcatAssign(out, "\"transport\":")
    v3Libp2pMoqConcatAssign(out, transportText)
    v3Libp2pMoqConcatAssign(out, ",\"fountainLayout\":")
    v3Libp2pMoqConcatAssign(out, layoutText)
    v3Libp2pMoqConcatAssign(out, ",\"ownerPeerId\":")
    v3Libp2pMoqConcatAssign(out, ownerPeerText)
    v3Libp2pMoqConcatAssign(out, ",\"mimeType\":")
    v3Libp2pMoqConcatAssign(out, mimeTypeText)
    v3Libp2pMoqConcatAssign(out, ",\"blobCid\":")
    v3Libp2pMoqConcatAssign(out, blobCidText)
    v3Libp2pMoqConcatAssign(out, ",\"blobByteLen\":")
    v3Libp2pMoqConcatAssign(out, blobByteLenText)
    v3Libp2pMoqConcatAssign(out, ",\"trackId\":")
    v3Libp2pMoqConcatAssign(out, trackIdText)
    v3Libp2pMoqConcatAssign(out, ",\"bundleCid\":")
    v3Libp2pMoqConcatAssign(out, bundleCidText)
    v3Libp2pMoqConcatAssign(out, ",\"objectTargetBytes\":")
    v3Libp2pMoqConcatAssign(out, objectTargetBytesText)
    v3Libp2pMoqConcatAssign(out, ",\"sourceBlockBytes\":")
    v3Libp2pMoqConcatAssign(out, sourceBlockBytesText)
    v3Libp2pMoqConcatAssign(out, ",\"objectCount\":")
    v3Libp2pMoqConcatAssign(out, objectCountText)
    v3Libp2pMoqConcatAssign(out, ",\"objects\":[")
    var objectIndex: int32 = 0
    while objectIndex < objects.len:
        if objectIndex > 0:
            v3Libp2pMoqConcatAssign(out, ",")
        var objectJson = ""
        objectJson = v3Libp2pMoqObjectJson(objects[objectIndex])
        v3Libp2pMoqConcatAssign(out, objectJson)
        objectIndex = objectIndex + 1
    v3Libp2pMoqConcatAssign(out, "]}")
    return out

fn v3Libp2pMoqCatalogBytes(ownerPeerId: str,
                           mimeType: str,
                           blobCid: str,
                           blobByteLen: int32,
                           bundleCid: str,
                           objectTargetBytes: int32,
                           sourceBlockBytes: int32,
                           objects: V3Libp2pMoqObject[]): Bytes =
    return bytesFromString(v3Libp2pMoqCatalogJson(ownerPeerId,
                                                  mimeType,
                                                  blobCid,
                                                  blobByteLen,
                                                  bundleCid,
                                                  objectTargetBytes,
                                                  sourceBlockBytes,
                                                  objects))

fn v3Libp2pMoqConcatAssign(out: var str, part: str) =
    out = v3Libp2pMoqFmt2(out, part)

fn v3Libp2pMoqPrefixKey(prefix: str, key: str): str =
    return v3Libp2pMoqFmt2(prefix, key)

fn v3Libp2pMoqLinesWithNewline(rows: str[]): str =
    let body = Lines(rows)
    return v3Libp2pMoqFmt2(body, "\n")

fn v3Libp2pMoqBuildBundleSeed(ownerPeerId: str,
                              blobCid: str,
                              mimeType: str,
                              peers: str[],
                              objectTargetBytes: int32,
                              sourceBlockBytes: int32,
                              repairDropletCount: int32): str =
    let peerCsv = v3Libp2pMoqJoinCsv(peers)
    var bundleSeed = ownerPeerId
    v3Libp2pMoqConcatAssign(bundleSeed, "|")
    v3Libp2pMoqConcatAssign(bundleSeed, blobCid)
    v3Libp2pMoqConcatAssign(bundleSeed, "|")
    v3Libp2pMoqConcatAssign(bundleSeed, mimeType)
    v3Libp2pMoqConcatAssign(bundleSeed, "|")
    v3Libp2pMoqConcatAssign(bundleSeed, peerCsv)
    v3Libp2pMoqConcatAssign(bundleSeed, "|")
    v3Libp2pMoqConcatAssign(bundleSeed, strings.IntToStr(objectTargetBytes))
    v3Libp2pMoqConcatAssign(bundleSeed, "|")
    v3Libp2pMoqConcatAssign(bundleSeed, strings.IntToStr(sourceBlockBytes))
    v3Libp2pMoqConcatAssign(bundleSeed, "|")
    v3Libp2pMoqConcatAssign(bundleSeed, strings.IntToStr(repairDropletCount))
    return bundleSeed

fn v3Libp2pMoqSourceDropletKey(bundleCid: str,
                               objectIndex: int32,
                               sourceDropletIndex: int32): str =
    var parts: str[]
    parts = []
    add(parts, "moqdrop-")
    add(parts, bundleCid)
    add(parts, "-o")
    add(parts, strings.IntToStr(objectIndex))
    add(parts, "-s")
    add(parts, strings.IntToStr(sourceDropletIndex))
    return Fmt(parts)

fn v3Libp2pMoqRepairDropletKey(bundleCid: str,
                               objectIndex: int32,
                               repairIndex: int32): str =
    var parts: str[]
    parts = []
    add(parts, "moqdrop-")
    add(parts, bundleCid)
    add(parts, "-o")
    add(parts, strings.IntToStr(objectIndex))
    add(parts, "-r")
    add(parts, strings.IntToStr(repairIndex))
    return Fmt(parts)

fn v3Libp2pMoqRepairDegreeSeed(bundleCid: str,
                               objectIndex: int32,
                               repairIndex: int32): str =
    var parts: str[]
    parts = []
    add(parts, bundleCid)
    add(parts, "|o")
    add(parts, strings.IntToStr(objectIndex))
    add(parts, "|r")
    add(parts, strings.IntToStr(repairIndex))
    return Fmt(parts)

fn v3Libp2pMoqRepairSeed(bundleCid: str,
                         objectIndex: int32,
                         repairIndex: int32): str =
    var parts: str[]
    parts = []
    add(parts, bundleCid)
    add(parts, "|repair|")
    add(parts, strings.IntToStr(objectIndex))
    add(parts, "|")
    add(parts, strings.IntToStr(repairIndex))
    return Fmt(parts)

fn v3Libp2pMoqObjectIdText(objectIndex: int32): str =
    var parts: str[]
    parts = []
    add(parts, "object-")
    add(parts, strings.IntToStr(objectIndex))
    return Fmt(parts)

fn v3Libp2pMoqHexDigitCode(value: int32): int32 =
    if value < 10:
        return int32('0') + value
    return int32('a') + value - 10

fn v3Libp2pMoqHex4(value: int32): str =
    var out = bytesAlloc(4)
    bytesSet(out, 0, v3Libp2pMoqHexDigitCode((value >> 12) & 15))
    bytesSet(out, 1, v3Libp2pMoqHexDigitCode((value >> 8) & 15))
    bytesSet(out, 2, v3Libp2pMoqHexDigitCode((value >> 4) & 15))
    bytesSet(out, 3, v3Libp2pMoqHexDigitCode(value & 15))
    return bytesToString(out)

fn v3Libp2pMoqJsonQuote(text: str): str =
    var out = "\""
    var idx: int32 = 0
    while idx < len(text):
        let code = int32(text[idx]) & 255
        if code == 34:
            v3Libp2pMoqConcatAssign(out, "\\\"")
        elif code == 92:
            v3Libp2pMoqConcatAssign(out, "\\\\")
        elif code == 8:
            v3Libp2pMoqConcatAssign(out, "\\b")
        elif code == 12:
            v3Libp2pMoqConcatAssign(out, "\\f")
        elif code == 10:
            v3Libp2pMoqConcatAssign(out, "\\n")
        elif code == 13:
            v3Libp2pMoqConcatAssign(out, "\\r")
        elif code == 9:
            v3Libp2pMoqConcatAssign(out, "\\t")
        elif code < 32:
            v3Libp2pMoqConcatAssign(out, "\\u")
            var hexText = ""
            hexText = v3Libp2pMoqHex4(code)
            v3Libp2pMoqConcatAssign(out, hexText)
        else:
            var byteText = ""
            byteText = strings.SliceBytes(text, idx, 1)
            v3Libp2pMoqConcatAssign(out, byteText)
        idx = idx + 1
    v3Libp2pMoqConcatAssign(out, "\"")
    return out

fn v3Libp2pMoqJoinIntJson(values: int32[]): str =
    if values.len <= 0:
        return "[]"
    var out = "["
    var i: int32 = 0
    while i < values.len:
        if i > 0:
            v3Libp2pMoqConcatAssign(out, ",")
        var itemText = ""
        itemText = strings.IntToStr(values[i])
        v3Libp2pMoqConcatAssign(out, itemText)
        i = i + 1
    v3Libp2pMoqConcatAssign(out, "]")
    return out

fn v3Libp2pMoqContainsInt(values: int32[], want: int32): bool =
    var i: int32 = 0
    while i < values.len:
        if values[i] == want:
            return true
        i = i + 1
    return false

fn v3Libp2pMoqSortInts(values0: int32[]): int32[] =
    var values = values0
    var i: int32 = 0
    while i < values.len:
        var j: int32 = i + 1
        while j < values.len:
            if values[j] < values[i]:
                let tmp = values[i]
                values[i] = values[j]
                values[j] = tmp
            j = j + 1
        i = i + 1
    return values

fn v3Libp2pMoqHashSeed(text: str): int32 =
    let digestHex = v3Libp2pMoqSha256HexText(text)
    if len(digestHex) < 8:
        return 1
    var out: int32 = 0
    var i: int32 = 0
    while i < 8:
        let nibble = v3Libp2pMoqHexValue(digestHex[i])
        if nibble < 0:
            return 1
        out = (out << 4) | nibble
        i = i + 1
    if out == 0:
        return 1
    return out

fn v3Libp2pMoqDropletKindText(kindCode: int32): str =
    if kindCode == v3Libp2pMoqDropletKindSource:
        return "source"
    if kindCode == v3Libp2pMoqDropletKindRepair:
        return "repair"
    return "unknown"

fn v3Libp2pMoqDropletJson(droplet: V3Libp2pMoqDroplet): str =
    var row = "{"
    var objectIndexText = ""
    objectIndexText = strings.IntToStr(droplet.objectIndex)
    var dropletIndexText = ""
    dropletIndexText = strings.IntToStr(droplet.dropletIndex)
    var kindRaw = ""
    kindRaw = v3Libp2pMoqDropletKindText(droplet.kindCode)
    var kindText = ""
    kindText = v3Libp2pMoqJsonQuote(kindRaw)
    var keyText = ""
    keyText = v3Libp2pMoqJsonQuote(droplet.key)
    var peerIdText = ""
    peerIdText = v3Libp2pMoqJsonQuote(droplet.peerId)
    var cidText = ""
    cidText = v3Libp2pMoqJsonQuote(droplet.cid)
    var degreeText = ""
    degreeText = strings.IntToStr(droplet.degree)
    var blockIndexesText = ""
    blockIndexesText = v3Libp2pMoqJoinIntJson(droplet.blockIndexes)
    v3Libp2pMoqConcatAssign(row, "\"objectIndex\":")
    v3Libp2pMoqConcatAssign(row, objectIndexText)
    v3Libp2pMoqConcatAssign(row, ",\"dropletIndex\":")
    v3Libp2pMoqConcatAssign(row, dropletIndexText)
    v3Libp2pMoqConcatAssign(row, ",\"kind\":")
    v3Libp2pMoqConcatAssign(row, kindText)
    v3Libp2pMoqConcatAssign(row, ",\"key\":")
    v3Libp2pMoqConcatAssign(row, keyText)
    v3Libp2pMoqConcatAssign(row, ",\"peerId\":")
    v3Libp2pMoqConcatAssign(row, peerIdText)
    v3Libp2pMoqConcatAssign(row, ",\"cid\":")
    v3Libp2pMoqConcatAssign(row, cidText)
    v3Libp2pMoqConcatAssign(row, ",\"degree\":")
    v3Libp2pMoqConcatAssign(row, degreeText)
    v3Libp2pMoqConcatAssign(row, ",\"blockIndexes\":")
    v3Libp2pMoqConcatAssign(row, blockIndexesText)
    v3Libp2pMoqConcatAssign(row, "}")
    return row

fn v3Libp2pMoqDropletsJson(droplets: V3Libp2pMoqDroplet[]): str =
    var out = ""
    var idx: int32 = 0
    while idx < droplets.len:
        if idx > 0:
            v3Libp2pMoqConcatAssign(out, ",")
        var dropletJson = ""
        dropletJson = v3Libp2pMoqDropletJson(droplets[idx])
        v3Libp2pMoqConcatAssign(out, dropletJson)
        idx = idx + 1
    return out

fn v3Libp2pMoqObjectJson(item: V3Libp2pMoqObject): str =
    var row = "{"
    var objectIndexText = ""
    objectIndexText = strings.IntToStr(item.objectIndex)
    var groupIdText = ""
    groupIdText = v3Libp2pMoqJsonQuote(item.groupId)
    var objectIdText = ""
    objectIdText = v3Libp2pMoqJsonQuote(item.objectId)
    var priorityText = ""
    priorityText = strings.IntToStr(item.priority)
    var byteOffsetText = ""
    byteOffsetText = strings.IntToStr(item.byteOffset)
    var byteLengthText = ""
    byteLengthText = strings.IntToStr(item.byteLength)
    var objectCidText = ""
    objectCidText = v3Libp2pMoqJsonQuote(item.objectCid)
    var sourceBlockBytesText = ""
    sourceBlockBytesText = strings.IntToStr(item.sourceBlockBytes)
    var sourceBlockCountText = ""
    sourceBlockCountText = strings.IntToStr(item.sourceBlockCount)
    var repairDropletCountText = ""
    repairDropletCountText = strings.IntToStr(item.repairDropletCount)
    var dropletsText = ""
    dropletsText = v3Libp2pMoqDropletsJson(item.droplets)
    v3Libp2pMoqConcatAssign(row, "\"objectIndex\":")
    v3Libp2pMoqConcatAssign(row, objectIndexText)
    v3Libp2pMoqConcatAssign(row, ",\"groupId\":")
    v3Libp2pMoqConcatAssign(row, groupIdText)
    v3Libp2pMoqConcatAssign(row, ",\"objectId\":")
    v3Libp2pMoqConcatAssign(row, objectIdText)
    v3Libp2pMoqConcatAssign(row, ",\"priority\":")
    v3Libp2pMoqConcatAssign(row, priorityText)
    v3Libp2pMoqConcatAssign(row, ",\"byteOffset\":")
    v3Libp2pMoqConcatAssign(row, byteOffsetText)
    v3Libp2pMoqConcatAssign(row, ",\"byteLength\":")
    v3Libp2pMoqConcatAssign(row, byteLengthText)
    v3Libp2pMoqConcatAssign(row, ",\"objectCid\":")
    v3Libp2pMoqConcatAssign(row, objectCidText)
    v3Libp2pMoqConcatAssign(row, ",\"sourceBlockBytes\":")
    v3Libp2pMoqConcatAssign(row, sourceBlockBytesText)
    v3Libp2pMoqConcatAssign(row, ",\"sourceBlockCount\":")
    v3Libp2pMoqConcatAssign(row, sourceBlockCountText)
    v3Libp2pMoqConcatAssign(row, ",\"repairDropletCount\":")
    v3Libp2pMoqConcatAssign(row, repairDropletCountText)
    v3Libp2pMoqConcatAssign(row, ",\"droplets\":[")
    v3Libp2pMoqConcatAssign(row, dropletsText)
    v3Libp2pMoqConcatAssign(row, "]}")
    return row

fn v3Libp2pMoqParseInt32Text(text: str): int32 =
    return int32(strutils.ParseInt(text))

fn v3Libp2pMoqParseInt32Wire(requestWire: str, key: str): Result[int32] =
    let rawRes = v3Libp2pMoqWireFindValue(requestWire, key)
    if IsErr(rawRes):
        let errorText = Error(rawRes)
        return Err[int32](errorText)
    let rawValue = Value(rawRes)
    let parsed = v3Libp2pMoqParseInt32Text(rawValue)
    return Ok[int32](parsed)

fn v3Libp2pMoqAppendDroplets(out: var V3Libp2pMoqDroplet[],
                             droplets: V3Libp2pMoqDroplet[]) =
    var idx: int32 = 0
    while idx < droplets.len:
        add(out, droplets[idx])
        idx = idx + 1

fn v3Libp2pMoqNextSeed(state0: int32): int32 =
    var state = state0
    if state == 0:
        state = 1
    state = state ^ (state << 13)
    state = state ^ (state >> 17)
    state = state ^ (state << 5)
    if state == 0:
        return 1
    return state

fn v3Libp2pMoqPositiveMod(value: int32, modBy: int32): int32 =
    if modBy <= 0:
        return 0
    let normalized = value & 2147483647
    return normalized % modBy

fn v3Libp2pMoqChooseUniqueBlockIndexes(blockCount: int32,
                                       degree0: int32,
                                       seedText: str): int32[] =
    var out: int32[]
    out = []
    if blockCount <= 0:
        return out
    let degree = v3Libp2pMoqMinInt32(blockCount, v3Libp2pMoqMaxInt32(1, degree0))
    var seed = v3Libp2pMoqHashSeed(seedText)
    while out.len < degree:
        seed = v3Libp2pMoqNextSeed(seed)
        let candidate = v3Libp2pMoqPositiveMod(seed, blockCount)
        if !v3Libp2pMoqContainsInt(out, candidate):
            add(out, candidate)
    return out

fn v3Libp2pMoqPadBlock(data: Bytes, blockBytes: int32): Bytes =
    if bytesLen(data) == blockBytes:
        return bytesSlice(data, 0, bytesLen(data))
    var out = bytesAlloc(blockBytes)
    let copyLen = v3Libp2pMoqMinInt32(bytesLen(data), blockBytes)
    var i: int32 = 0
    while i < copyLen:
        bytesSet(out, i, bytesGet(data, i))
        i = i + 1
    return out

fn v3Libp2pMoqXorInto(target: var Bytes, source: Bytes): Result[bool] =
    if bytesLen(target) != bytesLen(source):
        return Err[bool]("moq_fountain_xor_length_mismatch")
    var i: int32 = 0
    let n = bytesLen(target)
    while i < n:
        bytesSet(target, i, bytesGet(target, i) ^ bytesGet(source, i))
        i = i + 1
    return Ok[bool](true)

fn v3Libp2pMoqXorBytes(left: Bytes, right: Bytes): Result[Bytes] =
    if bytesLen(left) != bytesLen(right):
        return Err[Bytes]("moq_fountain_xor_length_mismatch")
    var out = bytesAlloc(bytesLen(left))
    var i: int32 = 0
    let n = bytesLen(left)
    while i < n:
        bytesSet(out, i, bytesGet(left, i) ^ bytesGet(right, i))
        i = i + 1
    return Ok[Bytes](out)

fn v3Libp2pMoqBuildObject(objectBytes: Bytes,
                          objectIndex: int32,
                          byteOffset: int32,
                          peers: str[],
                          bundleCid: str,
                          sourceBlockBytes: int32,
                          repairDropletCount: int32): Result[V3Libp2pMoqObject] =
    let objectByteLen = bytesLen(objectBytes)
    let objectCid = v3Libp2pMoqSha256HexBytes(objectBytes)
    let sourceBlockCount = (objectByteLen + sourceBlockBytes - 1) / sourceBlockBytes
    var blocks: Bytes[]
    blocks = []
    var blockIndex: int32 = 0
    while blockIndex < sourceBlockCount:
        let blockOffset = blockIndex * sourceBlockBytes
        let blockLen = v3Libp2pMoqMinInt32(sourceBlockBytes, objectByteLen - blockOffset)
        let blockBytes = bytesSlice(objectBytes, blockOffset, blockLen)
        add(blocks, v3Libp2pMoqPadBlock(blockBytes, sourceBlockBytes))
        blockIndex = blockIndex + 1
    var objectDroplets: V3Libp2pMoqDroplet[]
    objectDroplets = []
    var sourceDropletIndex: int32 = 0
    while sourceDropletIndex < blocks.len:
        let payload = blocks[sourceDropletIndex]
        var indexes: int32[]
        indexes = []
        add(indexes, sourceDropletIndex)
        let peerSlot = (objectIndex + sourceDropletIndex) % peers.len
        var peerId = ""
        var peerIdx: int32 = 0
        while peerIdx < peers.len:
            if peerIdx == peerSlot:
                peerId = peers[peerIdx]
                break
            peerIdx = peerIdx + 1
        let key = v3Libp2pMoqSourceDropletKey(bundleCid, objectIndex, sourceDropletIndex)
        let droplet = V3Libp2pMoqDroplet(
            objectIndex: objectIndex,
            dropletIndex: sourceDropletIndex,
            kindCode: v3Libp2pMoqDropletKindSource,
            key: key,
            peerId: peerId,
            cid: v3Libp2pMoqSha256HexBytes(payload),
            degree: 1,
            blockIndexes: indexes,
            payload: payload
        )
        add(objectDroplets, droplet)
        sourceDropletIndex = sourceDropletIndex + 1
    var repairIndex: int32 = 0
    while repairIndex < repairDropletCount:
        var degreeBase: int32 = 1
        if sourceBlockCount > 1:
            let seedText = v3Libp2pMoqRepairDegreeSeed(bundleCid, objectIndex, repairIndex)
            degreeBase = 2 + v3Libp2pMoqPositiveMod(v3Libp2pMoqHashSeed(seedText), sourceBlockCount - 1)
        let repairSeed = v3Libp2pMoqRepairSeed(bundleCid, objectIndex, repairIndex)
        let blockIndexes = v3Libp2pMoqChooseUniqueBlockIndexes(sourceBlockCount, degreeBase, repairSeed)
        if blockIndexes.len <= 0:
            return Err[V3Libp2pMoqObject]("moq_fountain_empty_repair_block_set")
        let firstBlockIndex = blockIndexes[0]
        if firstBlockIndex < 0 || firstBlockIndex >= blocks.len:
            return Err[V3Libp2pMoqObject]("moq_fountain_block_index_out_of_range")
        var payload = bytesSlice(blocks[firstBlockIndex], 0, bytesLen(blocks[firstBlockIndex]))
        var blockPick: int32 = 1
        while blockPick < blockIndexes.len:
            let wantedIndex = blockIndexes[blockPick]
            if wantedIndex < 0 || wantedIndex >= blocks.len:
                return Err[V3Libp2pMoqObject]("moq_fountain_block_index_out_of_range")
            let xorOk = v3Libp2pMoqXorInto(payload, blocks[wantedIndex])
            if IsErr(xorOk):
                return Err[V3Libp2pMoqObject](Error(xorOk))
            blockPick = blockPick + 1
        let dropletIndex = sourceBlockCount + repairIndex
        let peerSlot = (objectIndex + dropletIndex) % peers.len
        var peerId = ""
        var peerIdx: int32 = 0
        while peerIdx < peers.len:
            if peerIdx == peerSlot:
                peerId = peers[peerIdx]
                break
            peerIdx = peerIdx + 1
        let key = v3Libp2pMoqRepairDropletKey(bundleCid, objectIndex, repairIndex)
        let droplet = V3Libp2pMoqDroplet(
            objectIndex: objectIndex,
            dropletIndex: dropletIndex,
            kindCode: v3Libp2pMoqDropletKindRepair,
            key: key,
            peerId: peerId,
            cid: v3Libp2pMoqSha256HexBytes(payload),
            degree: blockIndexes.len,
            blockIndexes: blockIndexes,
            payload: payload
        )
        add(objectDroplets, droplet)
        repairIndex = repairIndex + 1
    let objectOut = V3Libp2pMoqObject(
        objectIndex: objectIndex,
        groupId: bundleCid,
        objectId: v3Libp2pMoqObjectIdText(objectIndex),
        priority: objectIndex,
        byteOffset: byteOffset,
        byteLength: objectByteLen,
        objectCid: objectCid,
        sourceBlockBytes: sourceBlockBytes,
        sourceBlockCount: sourceBlockCount,
        repairDropletCount: repairDropletCount,
        droplets: objectDroplets
    )
    return Ok[V3Libp2pMoqObject](objectOut)

fn v3Libp2pMoqBuildResultFillFromParts(out: var V3Libp2pMoqBuildResult,
                                       ownerPeerId: str,
                                       mimeType: str,
                                       bundleCid: str,
                                       blobCid: str,
                                       blobByteLen: int32,
                                       objectTargetBytes: int32,
                                       sourceBlockBytes: int32,
                                       remoteAckPeerIds: str[],
                                       objects: V3Libp2pMoqObject[],
                                       droplets: V3Libp2pMoqDroplet[]) =
    let catalogPayload = v3Libp2pMoqCatalogBytes(ownerPeerId,
                                                 mimeType,
                                                 blobCid,
                                                 blobByteLen,
                                                 bundleCid,
                                                 objectTargetBytes,
                                                 sourceBlockBytes,
                                                 objects)
    let rebuildTemplatePayload = bytesFromString(v3Libp2pMoqRebuildTemplateWireFromParts(blobCid,
                                                                                          blobByteLen,
                                                                                          objects,
                                                                                          droplets))
    out.ownerPeerId = ownerPeerId
    out.mimeType = mimeType
    out.bundleCid = bundleCid
    out.blobCid = blobCid
    out.catalogKey = v3Libp2pMoqFmt2("moqcatalog-", bundleCid)
    out.catalogCid = v3Libp2pMoqSha256HexBytes(catalogPayload)
    out.catalogSizeBytes = bytesLen(catalogPayload)
    out.catalogPayload = catalogPayload
    out.rebuildTemplateKey = v3Libp2pMoqFmt2("moqrebuild-", bundleCid)
    out.rebuildTemplateCid = v3Libp2pMoqSha256HexBytes(rebuildTemplatePayload)
    out.rebuildTemplateSizeBytes = bytesLen(rebuildTemplatePayload)
    out.rebuildTemplatePayload = rebuildTemplatePayload
    out.blobByteLen = blobByteLen
    out.objectTargetBytes = objectTargetBytes
    out.sourceBlockBytes = sourceBlockBytes
    out.objectCount = objects.len
    out.remoteAckPeerIds = remoteAckPeerIds
    out.objects = objects
    out.droplets = droplets

fn v3Libp2pMoqBuild(blobBytes: Bytes,
                    ownerPeerId: str,
                    remotePeersCsv: str,
                    mimeType0: str,
                    objectTargetBytes0: int32,
                    sourceBlockBytes0: int32,
                    repairDropletCount0: int32): Result[V3Libp2pMoqBuildResult] =
    if bytesLen(blobBytes) <= 0:
        return Err[V3Libp2pMoqBuildResult]("moq_fountain_empty_blob")
    let peers = v3Libp2pMoqNormalizePeerCsv(remotePeersCsv)
    if peers.len <= 0:
        return Err[V3Libp2pMoqBuildResult]("video_publish_insufficient_storage_peers")
    let objectTargetBytes = v3Libp2pMoqNormalizePositiveInt(objectTargetBytes0, 512 * 1024)
    let sourceBlockBytes = v3Libp2pMoqNormalizePositiveInt(sourceBlockBytes0, 128 * 1024)
    let repairDropletCount = v3Libp2pMoqNormalizePositiveInt(repairDropletCount0, 2)
    let mimeType = if len(mimeType0) > 0: mimeType0 else: "video/mp4"
    let blobCid = v3Libp2pMoqSha256HexBytes(blobBytes)
    let bundleSeed = v3Libp2pMoqBuildBundleSeed(ownerPeerId,
                                                blobCid,
                                                mimeType,
                                                peers,
                                                objectTargetBytes,
                                                sourceBlockBytes,
                                                repairDropletCount)
    let bundleCid = v3Libp2pMoqSha256HexText(bundleSeed)
    var objects: V3Libp2pMoqObject[]
    objects = []
    var allDroplets: V3Libp2pMoqDroplet[]
    allDroplets = []
    var byteOffset: int32 = 0
    var objectIndex: int32 = 0
    while byteOffset < bytesLen(blobBytes):
        let objectByteLen = v3Libp2pMoqMinInt32(objectTargetBytes, bytesLen(blobBytes) - byteOffset)
        let objectBytes = bytesSlice(blobBytes, byteOffset, objectByteLen)
        let objectRes = v3Libp2pMoqBuildObject(objectBytes,
                                               objectIndex,
                                               byteOffset,
                                               peers,
                                               bundleCid,
                                               sourceBlockBytes,
                                               repairDropletCount)
        if IsErr(objectRes):
            return Err[V3Libp2pMoqBuildResult](Error(objectRes))
        let objectOut = Value(objectRes)
        add(objects, objectOut)
        v3Libp2pMoqAppendDroplets(allDroplets, objectOut.droplets)
        byteOffset = byteOffset + objectByteLen
        objectIndex = objectIndex + 1
    var out: V3Libp2pMoqBuildResult
    v3Libp2pMoqBuildResultFillFromParts(out,
                                        ownerPeerId,
                                        mimeType,
                                        bundleCid,
                                        blobCid,
                                        bytesLen(blobBytes),
                                        objectTargetBytes,
                                        sourceBlockBytes,
                                        peers,
                                        objects,
                                        allDroplets)
    return Ok[V3Libp2pMoqBuildResult](out)

fn v3Libp2pMoqAppendWireLine(out: var str, line: str) =
    let lineText = v3Libp2pMoqFmt2(line, "\n")
    out = v3Libp2pMoqFmt2(out, lineText)

fn v3Libp2pMoqRebuildTemplateWireFromParts(blobCid: str,
                                           blobByteLen: int32,
                                           objects: V3Libp2pMoqObject[],
                                           droplets: V3Libp2pMoqDroplet[]): str =
    var out = ""
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("blob_cid=", blobCid))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("blob_byte_len=", strings.IntToStr(blobByteLen)))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("object_count=", strings.IntToStr(objects.len)))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("droplet_count=", strings.IntToStr(droplets.len)))
    var objectRow: int32 = 0
    while objectRow < objects.len:
        let item = objects[objectRow]
        let prefix = v3Libp2pMoqFmt3("object.", strings.IntToStr(objectRow), ".")
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "object_index=", strings.IntToStr(item.objectIndex)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "byte_length=", strings.IntToStr(item.byteLength)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "source_block_bytes=", strings.IntToStr(item.sourceBlockBytes)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "source_block_count=", strings.IntToStr(item.sourceBlockCount)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "object_cid="), item.objectCid))
        objectRow = objectRow + 1
    var dropletRow: int32 = 0
    while dropletRow < droplets.len:
        let item = droplets[dropletRow]
        let prefix = v3Libp2pMoqFmt3("droplet.", strings.IntToStr(dropletRow), ".")
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "object_index=", strings.IntToStr(item.objectIndex)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "droplet_index=", strings.IntToStr(item.dropletIndex)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "key="), item.key))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "peer_id="), item.peerId))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "cid="), item.cid))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "block_indexes="), v3Libp2pMoqJoinIntCsv(item.blockIndexes)))
        dropletRow = dropletRow + 1
    return out

fn v3Libp2pMoqBuildWireFromParts(ownerPeerId: str,
                                 mimeType: str,
                                 bundleCid: str,
                                 blobCid: str,
                                 blobByteLen: int32,
                                 objectTargetBytes: int32,
                                 sourceBlockBytes: int32,
                                 remoteAckPeerIds: str[],
                                 objects: V3Libp2pMoqObject[],
                                 droplets: V3Libp2pMoqDroplet[]): str =
    let catalogPayload = v3Libp2pMoqCatalogBytes(ownerPeerId,
                                                 mimeType,
                                                 blobCid,
                                                 blobByteLen,
                                                 bundleCid,
                                                 objectTargetBytes,
                                                 sourceBlockBytes,
                                                 objects)
    let catalogCid = v3Libp2pMoqSha256HexBytes(catalogPayload)
    let rebuildTemplatePayload = bytesFromString(v3Libp2pMoqRebuildTemplateWireFromParts(blobCid,
                                                                                          blobByteLen,
                                                                                          objects,
                                                                                          droplets))
    let rebuildTemplateCid = v3Libp2pMoqSha256HexBytes(rebuildTemplatePayload)
    var out = ""
    v3Libp2pMoqAppendWireLine(out, "ok=1")
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("owner_peer_id=", ownerPeerId))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("mime_type=", mimeType))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("bundle_cid=", bundleCid))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("blob_cid=", blobCid))
    let catalogKey = v3Libp2pMoqFmt2("moqcatalog-", bundleCid)
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("catalog_key=", catalogKey))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("catalog_cid=", catalogCid))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("catalog_size_bytes=", strings.IntToStr(bytesLen(catalogPayload))))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("catalog_payload_hex=", bytesToHex(catalogPayload)))
    let rebuildTemplateKey = v3Libp2pMoqFmt2("moqrebuild-", bundleCid)
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("rebuild_template_key=", rebuildTemplateKey))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("rebuild_template_cid=", rebuildTemplateCid))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("rebuild_template_size_bytes=", strings.IntToStr(bytesLen(rebuildTemplatePayload))))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("rebuild_template_payload_hex=", bytesToHex(rebuildTemplatePayload)))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("blob_byte_len=", strings.IntToStr(blobByteLen)))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("object_target_bytes=", strings.IntToStr(objectTargetBytes)))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("source_block_bytes=", strings.IntToStr(sourceBlockBytes)))
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("object_count=", strings.IntToStr(objects.len)))
    let remoteAckCsv = v3Libp2pMoqJoinCsv(remoteAckPeerIds)
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("remote_ack_peer_ids=", remoteAckCsv))
    var objectRow: int32 = 0
    while objectRow < objects.len:
        let item = objects[objectRow]
        let prefix = v3Libp2pMoqFmt3("object.", strings.IntToStr(objectRow), ".")
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "object_index=", strings.IntToStr(item.objectIndex)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "group_id="), item.groupId))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "object_id="), item.objectId))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "priority=", strings.IntToStr(item.priority)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "byte_offset=", strings.IntToStr(item.byteOffset)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "byte_length=", strings.IntToStr(item.byteLength)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "object_cid="), item.objectCid))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "source_block_bytes=", strings.IntToStr(item.sourceBlockBytes)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "source_block_count=", strings.IntToStr(item.sourceBlockCount)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "repair_droplet_count=", strings.IntToStr(item.repairDropletCount)))
        objectRow = objectRow + 1
    v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2("droplet_count=", strings.IntToStr(droplets.len)))
    var dropletRow: int32 = 0
    while dropletRow < droplets.len:
        let droplet = droplets[dropletRow]
        let prefix = v3Libp2pMoqFmt3("droplet.", strings.IntToStr(dropletRow), ".")
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "object_index=", strings.IntToStr(droplet.objectIndex)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "droplet_index=", strings.IntToStr(droplet.dropletIndex)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "kind="), v3Libp2pMoqDropletKindText(droplet.kindCode)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "key="), droplet.key))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "peer_id="), droplet.peerId))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "cid="), droplet.cid))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt3(prefix, "degree=", strings.IntToStr(droplet.degree)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "block_indexes="), v3Libp2pMoqJoinIntCsv(droplet.blockIndexes)))
        v3Libp2pMoqAppendWireLine(out, v3Libp2pMoqFmt2(v3Libp2pMoqPrefixKey(prefix, "payload_hex="), bytesToHex(droplet.payload)))
        dropletRow = dropletRow + 1
    return out

fn v3Libp2pMoqBuildResultToWire(result: V3Libp2pMoqBuildResult): str =
    return v3Libp2pMoqBuildWireFromParts(result.ownerPeerId,
                                         result.mimeType,
                                         result.bundleCid,
                                         result.blobCid,
                                         result.blobByteLen,
                                         result.objectTargetBytes,
                                         result.sourceBlockBytes,
                                         result.remoteAckPeerIds,
                                         result.objects,
                                         result.droplets)

fn v3Libp2pMoqBuildToWire(blobBytes: Bytes,
                          ownerPeerId: str,
                          remotePeersCsv: str,
                          mimeType0: str,
                          objectTargetBytes0: int32,
                          sourceBlockBytes0: int32,
                          repairDropletCount0: int32): str =
    let buildRes = v3Libp2pMoqBuild(blobBytes,
                                    ownerPeerId,
                                    remotePeersCsv,
                                    mimeType0,
                                    objectTargetBytes0,
                                    sourceBlockBytes0,
                                    repairDropletCount0)
    if IsErr(buildRes):
        return v3Libp2pMoqErrorWire(Error(buildRes))
    return v3Libp2pMoqBuildResultToWire(Value(buildRes))

fn v3Libp2pMoqWireFindValue(wire: str, key: str): Result[str] =
    let prefix = v3Libp2pMoqFmt2(key, "=")
    var lineStart: int32 = 0
    let n = strings.Len(wire)
    while lineStart < n:
        var lineEnd: int32 = lineStart
        while lineEnd < n:
            if wire[lineEnd] == '\n':
                break
            lineEnd = lineEnd + 1
        var line = ""
        if lineEnd > lineStart:
            line = strutils.SliceStr(wire, lineStart, lineEnd - 1)
        if strutils.StartsWith(line, prefix):
            return Ok[str](strutils.SliceStr(line, strings.Len(prefix), strings.Len(line) - 1))
        lineStart = lineEnd + 1
    return Err[str](v3Libp2pMoqFmt2("moq_fountain_missing_wire_field:", key))

fn v3Libp2pMoqDecodeBlockIndexes(csv: str): int32[] =
    let parts = v3Libp2pMoqSplitCsv(csv)
    var out: int32[]
    out = []
    var i: int32 = 0
    while i < parts.len:
        let item = v3Libp2pMoqTrimAscii(parts[i])
        if len(item) <= 0:
            i = i + 1
            continue
        add(out, v3Libp2pMoqParseInt32Text(item))
        i = i + 1
    return out

fn v3Libp2pMoqCoeffOffset(row: int32, col: int32, colCount: int32): int32 =
    return row * colCount + col

fn v3Libp2pMoqCoeffGet(coeffData: int32[],
                       row: int32,
                       col: int32,
                       colCount: int32): int32 =
    return coeffData[v3Libp2pMoqCoeffOffset(row, col, colCount)]

fn v3Libp2pMoqCoeffSet(coeffData: var int32[],
                       row: int32,
                       col: int32,
                       colCount: int32,
                       value: int32) =
    coeffData[v3Libp2pMoqCoeffOffset(row, col, colCount)] = value

fn v3Libp2pMoqCoeffSwapRows(coeffData: var int32[],
                            leftRow: int32,
                            rightRow: int32,
                            colCount: int32) =
    var col: int32 = 0
    while col < colCount:
        let leftValue = v3Libp2pMoqCoeffGet(coeffData, leftRow, col, colCount)
        let rightValue = v3Libp2pMoqCoeffGet(coeffData, rightRow, col, colCount)
        v3Libp2pMoqCoeffSet(coeffData, leftRow, col, colCount, rightValue)
        v3Libp2pMoqCoeffSet(coeffData, rightRow, col, colCount, leftValue)
        col = col + 1

fn v3Libp2pMoqCopyBlockIntoFlat(target: var Bytes,
                                blockBytes: int32,
                                blockIndex: int32,
                                source: Bytes): Result[bool] =
    if bytesLen(source) != blockBytes:
        return Err[bool]("moq_fountain_invalid_solved_block")
    let offset = blockIndex * blockBytes
    var idx: int32 = 0
    while idx < blockBytes:
        bytesSet(target, offset + idx, bytesGet(source, idx))
        idx = idx + 1
    return Ok[bool](true)

fn v3Libp2pMoqSolveObjectBytes(sourceBlockCount: int32,
                               blockBytes: int32,
                               byteLength: int32,
                               coeffData0: int32[],
                               payloadRows0: Bytes[]): Result[Bytes] =
    if sourceBlockCount <= 0:
        return Err[Bytes]("moq_fountain_invalid_object")
    let rowCount = payloadRows0.len
    if rowCount <= 0:
        return Err[Bytes]("moq_fountain_insufficient_droplets")
    if coeffData0.len != rowCount * sourceBlockCount:
        return Err[Bytes]("moq_fountain_invalid_coeff_matrix")
    var coeffData = coeffData0
    var payloadRows = payloadRows0
    let solvedFlatLen = sourceBlockCount * blockBytes
    var solvedFlat = bytesAlloc(solvedFlatLen)
    var solvedMask = bytesAlloc(sourceBlockCount)
    var solvedCount: int32 = 0
    var pivotRow: int32 = 0
    var col: int32 = 0
    while col < sourceBlockCount && pivotRow < rowCount:
        var found: int32 = -1
        var row: int32 = pivotRow
        while row < rowCount:
            if v3Libp2pMoqCoeffGet(coeffData, row, col, sourceBlockCount) != 0:
                found = row
                break
            row = row + 1
        if found < 0:
            col = col + 1
            continue
        if found != pivotRow:
            v3Libp2pMoqCoeffSwapRows(coeffData, pivotRow, found, sourceBlockCount)
            let tempPayload = payloadRows[pivotRow]
            payloadRows[pivotRow] = payloadRows[found]
            payloadRows[found] = tempPayload
        row = 0
        while row < rowCount:
            if row == pivotRow:
                row = row + 1
                continue
            if v3Libp2pMoqCoeffGet(coeffData, row, col, sourceBlockCount) == 0:
                row = row + 1
                continue
            var coeffIndex: int32 = 0
            while coeffIndex < sourceBlockCount:
                let nextValue = v3Libp2pMoqCoeffGet(coeffData, row, coeffIndex, sourceBlockCount) ^
                                v3Libp2pMoqCoeffGet(coeffData, pivotRow, coeffIndex, sourceBlockCount)
                v3Libp2pMoqCoeffSet(coeffData, row, coeffIndex, sourceBlockCount, nextValue)
                coeffIndex = coeffIndex + 1
            let xorOk = v3Libp2pMoqXorInto(payloadRows[row], payloadRows[pivotRow])
            if IsErr(xorOk):
                return Err[Bytes](Error(xorOk))
            row = row + 1
        if bytesGet(solvedMask, col) == 0:
            solvedCount = solvedCount + 1
        bytesSet(solvedMask, col, 1)
        let copyOk = v3Libp2pMoqCopyBlockIntoFlat(solvedFlat, blockBytes, col, payloadRows[pivotRow])
        if IsErr(copyOk):
            return Err[Bytes](Error(copyOk))
        pivotRow = pivotRow + 1
        col = col + 1
    if solvedCount < sourceBlockCount:
        return Err[Bytes]("moq_fountain_insufficient_droplets")
    var i: int32 = 0
    while i < sourceBlockCount:
        if bytesGet(solvedMask, i) == 0:
            return Err[Bytes]("moq_fountain_invalid_solved_block")
        i = i + 1
    var objectBytes = bytesAlloc(byteLength)
    var writeOffset: int32 = 0
    var blockIndex: int32 = 0
    while blockIndex < sourceBlockCount:
        if writeOffset >= byteLength:
            break
        let copyLen = v3Libp2pMoqMinInt32(blockBytes, byteLength - writeOffset)
        let blockOffset = blockIndex * blockBytes
        var copyIndex: int32 = 0
        while copyIndex < copyLen:
            bytesSet(objectBytes, writeOffset + copyIndex, bytesGet(solvedFlat, blockOffset + copyIndex))
            copyIndex = copyIndex + 1
        writeOffset = writeOffset + copyLen
        blockIndex = blockIndex + 1
    return Ok[Bytes](objectBytes)

fn v3Libp2pMoqRebuildFromWire(requestWire: str): Result[V3Libp2pMoqRebuildResult] =
    let blobCidRes = v3Libp2pMoqWireFindValue(requestWire, "blob_cid")
    if IsErr(blobCidRes):
        return Err[V3Libp2pMoqRebuildResult](Error(blobCidRes))
    let blobByteLenRes = v3Libp2pMoqParseInt32Wire(requestWire, "blob_byte_len")
    if IsErr(blobByteLenRes):
        return Err[V3Libp2pMoqRebuildResult](Error(blobByteLenRes))
    let objectCountRes = v3Libp2pMoqParseInt32Wire(requestWire, "object_count")
    if IsErr(objectCountRes):
        return Err[V3Libp2pMoqRebuildResult](Error(objectCountRes))
    let dropletCountRes = v3Libp2pMoqParseInt32Wire(requestWire, "droplet_count")
    if IsErr(dropletCountRes):
        return Err[V3Libp2pMoqRebuildResult](Error(dropletCountRes))
    let blobCid = Value(blobCidRes)
    let blobByteLen = Value(blobByteLenRes)
    let objectCount = Value(objectCountRes)
    let dropletCount = Value(dropletCountRes)
    var objectBytesList: Bytes[]
    objectBytesList = []
    var objectIndex: int32 = 0
    while objectIndex < objectCount:
        let objectPrefix = v3Libp2pMoqFmt3("object.", strings.IntToStr(objectIndex), ".")
        let byteLengthRes = v3Libp2pMoqParseInt32Wire(requestWire, v3Libp2pMoqPrefixKey(objectPrefix, "byte_length"))
        if IsErr(byteLengthRes):
            return Err[V3Libp2pMoqRebuildResult](Error(byteLengthRes))
        let sourceBlockBytesRes = v3Libp2pMoqParseInt32Wire(requestWire, v3Libp2pMoqPrefixKey(objectPrefix, "source_block_bytes"))
        if IsErr(sourceBlockBytesRes):
            return Err[V3Libp2pMoqRebuildResult](Error(sourceBlockBytesRes))
        let sourceBlockCountRes = v3Libp2pMoqParseInt32Wire(requestWire, v3Libp2pMoqPrefixKey(objectPrefix, "source_block_count"))
        if IsErr(sourceBlockCountRes):
            return Err[V3Libp2pMoqRebuildResult](Error(sourceBlockCountRes))
        let objectCidRes = v3Libp2pMoqWireFindValue(requestWire, v3Libp2pMoqPrefixKey(objectPrefix, "object_cid"))
        if IsErr(objectCidRes):
            return Err[V3Libp2pMoqRebuildResult](Error(objectCidRes))
        let byteLength = Value(byteLengthRes)
        let sourceBlockBytes = Value(sourceBlockBytesRes)
        let sourceBlockCount = Value(sourceBlockCountRes)
        let objectCid = Value(objectCidRes)
        var coeffData: int32[]
        coeffData = []
        var payloadRows: Bytes[]
        payloadRows = []
        var dropletRow: int32 = 0
        while dropletRow < dropletCount:
            let prefix = v3Libp2pMoqFmt3("droplet.", strings.IntToStr(dropletRow), ".")
            let candidateObjectIndexRes = v3Libp2pMoqParseInt32Wire(requestWire, v3Libp2pMoqPrefixKey(prefix, "object_index"))
            if IsErr(candidateObjectIndexRes):
                return Err[V3Libp2pMoqRebuildResult](Error(candidateObjectIndexRes))
            let candidateObjectIndex = Value(candidateObjectIndexRes)
            if candidateObjectIndex != objectIndex:
                dropletRow = dropletRow + 1
                continue
            let payloadHexRes = v3Libp2pMoqWireFindValue(requestWire, v3Libp2pMoqPrefixKey(prefix, "payload_hex"))
            if IsErr(payloadHexRes):
                return Err[V3Libp2pMoqRebuildResult](Error(payloadHexRes))
            let payloadRes = v3Libp2pMoqBytesFromHex(Value(payloadHexRes))
            if IsErr(payloadRes):
                return Err[V3Libp2pMoqRebuildResult](Error(payloadRes))
            let payload = Value(payloadRes)
            if bytesLen(payload) != sourceBlockBytes:
                return Err[V3Libp2pMoqRebuildResult]("moq_fountain_payload_size_mismatch")
            let cidRes = v3Libp2pMoqWireFindValue(requestWire, v3Libp2pMoqPrefixKey(prefix, "cid"))
            if IsErr(cidRes):
                return Err[V3Libp2pMoqRebuildResult](Error(cidRes))
            let cid = Value(cidRes)
            if len(cid) > 0 && cid != v3Libp2pMoqSha256HexBytes(payload):
                return Err[V3Libp2pMoqRebuildResult]("moq_fountain_payload_cid_mismatch")
            let blockIndexesRes = v3Libp2pMoqWireFindValue(requestWire, v3Libp2pMoqPrefixKey(prefix, "block_indexes"))
            if IsErr(blockIndexesRes):
                return Err[V3Libp2pMoqRebuildResult](Error(blockIndexesRes))
            let blockIndexes = v3Libp2pMoqDecodeBlockIndexes(Value(blockIndexesRes))
            let rowIndex = payloadRows.len
            add(payloadRows, payload)
            var coeffIndex: int32 = 0
            while coeffIndex < sourceBlockCount:
                add(coeffData, 0)
                coeffIndex = coeffIndex + 1
            var blockIndex: int32 = 0
            while blockIndex < blockIndexes.len:
                let idx = blockIndexes[blockIndex]
                if idx < 0 || idx >= sourceBlockCount:
                    return Err[V3Libp2pMoqRebuildResult]("moq_fountain_block_index_out_of_range")
                let nextValue = v3Libp2pMoqCoeffGet(coeffData, rowIndex, idx, sourceBlockCount) ^ 1
                v3Libp2pMoqCoeffSet(coeffData, rowIndex, idx, sourceBlockCount, nextValue)
                blockIndex = blockIndex + 1
            dropletRow = dropletRow + 1
        let solvedRes = v3Libp2pMoqSolveObjectBytes(sourceBlockCount,
                                                   sourceBlockBytes,
                                                   byteLength,
                                                   coeffData,
                                                   payloadRows)
        if IsErr(solvedRes):
            return Err[V3Libp2pMoqRebuildResult](Error(solvedRes))
        let objectBytes = Value(solvedRes)
        if objectCid != v3Libp2pMoqSha256HexBytes(objectBytes):
            return Err[V3Libp2pMoqRebuildResult]("moq_fountain_object_cid_mismatch")
        add(objectBytesList, objectBytes)
        objectIndex = objectIndex + 1
    var rebuilt = bytesAlloc(blobByteLen)
    var blobOffset: int32 = 0
    objectIndex = 0
    while objectIndex < objectBytesList.len:
        let objectBytes = objectBytesList[objectIndex]
        var copyIndex: int32 = 0
        while copyIndex < bytesLen(objectBytes):
            if blobOffset + copyIndex >= blobByteLen:
                break
            bytesSet(rebuilt, blobOffset + copyIndex, bytesGet(objectBytes, copyIndex))
            copyIndex = copyIndex + 1
        blobOffset = blobOffset + bytesLen(objectBytes)
        objectIndex = objectIndex + 1
    if blobCid != v3Libp2pMoqSha256HexBytes(rebuilt):
        return Err[V3Libp2pMoqRebuildResult]("moq_fountain_blob_cid_mismatch")
    return Ok[V3Libp2pMoqRebuildResult](V3Libp2pMoqRebuildResult(
        blob: rebuilt,
        blobCid: blobCid,
        blobByteLen: blobByteLen
    ))

fn v3Libp2pMoqRebuildResultToWire(outputPath: str,
                                  result: V3Libp2pMoqRebuildResult): str =
    let rows = [
        "ok=1",
        v3Libp2pMoqFmt2("output_path=", outputPath),
        v3Libp2pMoqFmt2("blob_cid=", result.blobCid),
        v3Libp2pMoqFmt2("blob_byte_len=", strings.IntToStr(result.blobByteLen))
    ]
    return v3Libp2pMoqLinesWithNewline(rows)

fn v3Libp2pMoqBrowserRebuildResultToWire(result: V3Libp2pMoqRebuildResult): str =
    var rows: str[]
    rows = []
    add(rows, "ok=1")
    add(rows, v3Libp2pMoqFmt2("blob_cid=", result.blobCid))
    add(rows, v3Libp2pMoqFmt2("blob_byte_len=", strings.IntToStr(result.blobByteLen)))
    add(rows, v3Libp2pMoqFmt2("blob_hex=", bytesToHex(result.blob)))
    return v3Libp2pMoqLinesWithNewline(rows)

fn v3Libp2pMoqRebuildToWire(requestWire: str): str =
    let rebuiltRes = v3Libp2pMoqRebuildFromWire(requestWire)
    if IsErr(rebuiltRes):
        let errorText = Error(rebuiltRes)
        return v3Libp2pMoqErrorWire(errorText)
    let rebuilt = Value(rebuiltRes)
    return v3Libp2pMoqBrowserRebuildResultToWire(rebuilt)
