import std/result
import std/rawbytes
import std/strings
import std/multiformats/base58
import std/crypto/sha256
import std/crypto/sha512
import std/crypto/ed25519/ref10
import cheng/v3/std/bytes_layout as layout
import cheng/v3/libp2p/core/types

const
    v3Libp2pEd25519KeyType: int32 = 1
    v3Libp2pEd25519PubKeySize: int32 = 32
    v3Libp2pPeerProtoSize: int32 = 36
    v3Libp2pPeerIdBytesSize: int32 = 38
    v3Libp2pPeerIdIdentityCode: int32 = 0

fn v3Libp2pEncodeBase58(data: Bytes): str =
    return base58.encodeBase58(data)

fn v3Libp2pDecodeBase58(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Err[Bytes]("v3 libp2p peer: empty peer text")
    let decoded = base58.decodeBase58(text)
    if IsErr(decoded):
        return Err[Bytes]("v3 libp2p peer: invalid peer text")
    if bytesLen(Value(decoded)) <= 0:
        return Err[Bytes]("v3 libp2p peer: invalid peer text")
    return decoded

fn v3Libp2pPeerSeedBytes(seed: str): Bytes =
    return sha256.sha256Digest(bytesFromString("v3.libp2p.peer|" + seed))

fn v3Libp2pClampEd25519Scalar(out: var Bytes) =
    if bytesLen(out) != v3Libp2pEd25519PubKeySize:
        return
    bytesSet(out, 0, bytesGet(out, 0) & 248)
    bytesSet(out, 31, (bytesGet(out, 31) & 63) | 64)

fn v3Libp2pPeerPublicKeyValid(pubKeyBytes: Bytes): bool =
    if bytesLen(pubKeyBytes) != v3Libp2pEd25519PubKeySize:
        return false
    var point: ref10.GeP3
    return ref10.geFromBytesNegateVartime(point, pubKeyBytes)

fn v3Libp2pPeerPublicKeyFromSeedBytes(seedBytes: Bytes): Result[layout.FixedBytes32] =
    if bytesLen(seedBytes) != v3Libp2pEd25519PubKeySize:
        return Err[layout.FixedBytes32]("v3 libp2p peer: invalid seed size")
    let expanded = sha512.sha512Digest(seedBytes)
    if bytesLen(expanded) < v3Libp2pEd25519PubKeySize:
        return Err[layout.FixedBytes32]("v3 libp2p peer: invalid expanded seed")
    var scalar = bytesSlice(expanded, 0, v3Libp2pEd25519PubKeySize)
    v3Libp2pClampEd25519Scalar(scalar)
    var point: ref10.GeP3
    ref10.geScalarMultBase(point, scalar)
    return layout.fixedBytes32FromBytes(ref10.geP3ToBytes(point))

fn v3Libp2pPeerProtoBytes(pubKey: layout.FixedBytes32): Bytes =
    let out = bytesAlloc(v3Libp2pPeerProtoSize)
    let pubKeyBytes = layout.fixedBytes32ToBytes(pubKey)
    bytesSet(out, 0, 0x08)
    bytesSet(out, 1, v3Libp2pEd25519KeyType)
    bytesSet(out, 2, 0x12)
    bytesSet(out, 3, 0x20)
    for i in 0..<v3Libp2pEd25519PubKeySize:
        bytesSet(out, 4 + i, bytesGet(pubKeyBytes, i))
    return out

fn v3Libp2pPeerIdBytes(pubKey: layout.FixedBytes32): Bytes =
    let out = bytesAlloc(v3Libp2pPeerIdBytesSize)
    let protoBytes = v3Libp2pPeerProtoBytes(pubKey)
    bytesSet(out, 0, v3Libp2pPeerIdIdentityCode)
    bytesSet(out, 1, v3Libp2pPeerProtoSize)
    for i in 0..<v3Libp2pPeerProtoSize:
        bytesSet(out, 2 + i, bytesGet(protoBytes, i))
    return out

fn v3Libp2pPeerPublicKeyFromPeerIdBytes(peerIdBytes: Bytes): Result[layout.FixedBytes32] =
    if bytesLen(peerIdBytes) != v3Libp2pPeerIdBytesSize:
        return Err[layout.FixedBytes32]("v3 libp2p peer: invalid peer id size")
    if bytesGet(peerIdBytes, 0) != v3Libp2pPeerIdIdentityCode:
        return Err[layout.FixedBytes32]("v3 libp2p peer: unsupported multihash")
    if bytesGet(peerIdBytes, 1) != v3Libp2pPeerProtoSize:
        return Err[layout.FixedBytes32]("v3 libp2p peer: invalid peer id payload")
    if bytesGet(peerIdBytes, 2) != 0x08 ||
       bytesGet(peerIdBytes, 3) != v3Libp2pEd25519KeyType ||
       bytesGet(peerIdBytes, 4) != 0x12 ||
       bytesGet(peerIdBytes, 5) != 0x20:
        return Err[layout.FixedBytes32]("v3 libp2p peer: unsupported key protobuf")
    let pubKeyBytes = bytesSlice(peerIdBytes, 6, v3Libp2pEd25519PubKeySize)
    if !v3Libp2pPeerPublicKeyValid(pubKeyBytes):
        return Err[layout.FixedBytes32]("v3 libp2p peer: invalid ed25519 public key")
    return layout.fixedBytes32FromBytes(pubKeyBytes)

fn v3Libp2pPeerIdBytesFromText(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Err[Bytes]("v3 libp2p peer: empty peer text")
    if text[0] == 'z':
        if len(text) <= 1:
            return Err[Bytes]("v3 libp2p peer: invalid peer text")
        return v3Libp2pDecodeBase58(strings.sliceBytes(text, 1, len(text) - 1))
    return v3Libp2pDecodeBase58(text)

fn v3Libp2pPeerIdFillFromSeed(out: var types.V3Libp2pPeerId, seed: str) =
    let pubKeyRes = v3Libp2pPeerPublicKeyFromSeedBytes(v3Libp2pPeerSeedBytes(seed))
    if IsErr(pubKeyRes):
        out = types.v3Libp2pPeerIdZero()
        return
    out.value = Value(pubKeyRes)

fn v3Libp2pPeerIdFillFromText(out: var types.V3Libp2pPeerId, text: str): Result[bool] =
    let peerIdBytesRes = v3Libp2pPeerIdBytesFromText(text)
    if IsErr(peerIdBytesRes):
        return Err[bool](Error(peerIdBytesRes))
    let pubKeyRes = v3Libp2pPeerPublicKeyFromPeerIdBytes(Value(peerIdBytesRes))
    if IsErr(pubKeyRes):
        return Err[bool](Error(pubKeyRes))
    out.value = Value(pubKeyRes)
    return Ok[bool](true)

fn v3Libp2pPeerIdFromBytes(data: Bytes): types.V3Libp2pPeerId =
    var out = types.v3Libp2pPeerIdZero()
    if bytesLen(data) == v3Libp2pEd25519PubKeySize && v3Libp2pPeerPublicKeyValid(data):
        let fixedRes = layout.fixedBytes32FromBytes(data)
        if IsOk(fixedRes):
            out.value = Value(fixedRes)
            return out
    let hashed = sha256.sha256Digest(data)
    let pubKeyRes = v3Libp2pPeerPublicKeyFromSeedBytes(hashed)
    if IsOk(pubKeyRes):
        out.value = Value(pubKeyRes)
    return out

fn v3Libp2pPeerIdFromSeed(seed: str): types.V3Libp2pPeerId =
    var out: types.V3Libp2pPeerId
    v3Libp2pPeerIdFillFromSeed(out, seed)
    return out

fn v3Libp2pPeerIdFromText(text: str): Result[types.V3Libp2pPeerId] =
    var out = types.v3Libp2pPeerIdZero()
    let fillRes = v3Libp2pPeerIdFillFromText(out, text)
    if IsErr(fillRes):
        return Err[types.V3Libp2pPeerId](Error(fillRes))
    return Ok[types.V3Libp2pPeerId](out)

fn v3Libp2pPeerIdText(peerId: types.V3Libp2pPeerId): str =
    return v3Libp2pEncodeBase58(v3Libp2pPeerIdBytes(peerId.value))

fn v3Libp2pPeerIdDistance(left: types.V3Libp2pPeerId,
                          right: types.V3Libp2pPeerId): int64 =
    var out: int64 = int64(0)
    for i in 0..<4:
        let lv = int32(left.value.data[i]) & 255
        let rv = int32(right.value.data[i]) & 255
        out = (out << 8) | int64(lv ^ rv)
    return out
