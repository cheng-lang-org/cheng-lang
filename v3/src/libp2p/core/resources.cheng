import std/times
import cheng/v3/libp2p/core/types

importc fn cheng_v3_system_cpu_logical_cores_bridge(): int32
importc fn cheng_v3_system_memory_available_bytes_bridge(): int64
importc fn cheng_v3_system_memory_total_bytes_bridge(): int64
importc fn cheng_v3_system_disk_available_bytes_bridge(): int64
importc fn cheng_v3_system_disk_total_bytes_bridge(): int64
importc fn cheng_v3_system_gpu_device_count_bridge(): int32
importc fn cheng_v3_system_gpu_core_count_bridge(): int32
importc fn cheng_v3_system_npu_device_count_bridge(): int32
importc fn cheng_v3_system_npu_core_count_bridge(): int32

fn v3Libp2pNodeResourceCollectLocal(): types.V3Libp2pNodeResource =
    var out = types.v3Libp2pNodeResourceZero()
    out.sampledAtEpochSeconds = times.EpochTimeSeconds()
    out.cpuLogicalCores = cheng_v3_system_cpu_logical_cores_bridge()
    out.memoryAvailableBytes = cheng_v3_system_memory_available_bytes_bridge()
    out.memoryTotalBytes = cheng_v3_system_memory_total_bytes_bridge()
    out.diskAvailableBytes = cheng_v3_system_disk_available_bytes_bridge()
    out.diskTotalBytes = cheng_v3_system_disk_total_bytes_bridge()
    out.gpuDeviceCount = cheng_v3_system_gpu_device_count_bridge()
    out.gpuCoreCount = cheng_v3_system_gpu_core_count_bridge()
    out.npuDeviceCount = cheng_v3_system_npu_device_count_bridge()
    out.npuCoreCount = cheng_v3_system_npu_core_count_bridge()
    return out

fn v3Libp2pNodeResourceClone(sample: types.V3Libp2pNodeResource): types.V3Libp2pNodeResource =
    var out = types.v3Libp2pNodeResourceZero()
    out.sampledAtEpochSeconds = sample.sampledAtEpochSeconds
    out.cpuLogicalCores = sample.cpuLogicalCores
    out.memoryAvailableBytes = sample.memoryAvailableBytes
    out.memoryTotalBytes = sample.memoryTotalBytes
    out.diskAvailableBytes = sample.diskAvailableBytes
    out.diskTotalBytes = sample.diskTotalBytes
    out.gpuDeviceCount = sample.gpuDeviceCount
    out.gpuCoreCount = sample.gpuCoreCount
    out.npuDeviceCount = sample.npuDeviceCount
    out.npuCoreCount = sample.npuCoreCount
    return out

fn v3Libp2pNodeResourceVisible(sample: types.V3Libp2pNodeResource): bool =
    return sample.sampledAtEpochSeconds > 0
