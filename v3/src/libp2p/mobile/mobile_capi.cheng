@exportc("v3MobileCapiPeerIdFromSeed")
fn v3MobileCapiPeerIdFromSeed(seed: str): str =
    var peerValue: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(peerValue, seed)
    return peer_id.v3Libp2pPeerIdText(peerValue)

@exportc("v3MobileCapiDidFromRootSeed")
fn v3MobileCapiDidFromRootSeed(rootSeed: str): str =
    let out = did.v3DidFromRootSeed(rootSeed)
    return out

@exportc("v3MobileCapiDidDevicePeerIdFromSeed")
fn v3MobileCapiDidDevicePeerIdFromSeed(deviceSeed: str): str =
    let peerValue = did.v3DidDevicePeerIdFromSeed(deviceSeed)
    let out = peer_id.v3Libp2pPeerIdText(peerValue)
    return out

@exportc("v3MobileCapiPeerIdNormalize")
fn v3MobileCapiPeerIdNormalize(peerText: str): str =
    var peerValue: types.V3Libp2pPeerId
    let peerRes = peer_id.v3Libp2pPeerIdFillFromText(peerValue, peerText)
    if IsErr(peerRes):
        return ""
    return peer_id.v3Libp2pPeerIdText(peerValue)

@exportc("v3MobileCapiMultiaddrNormalize")
fn v3MobileCapiMultiaddrNormalize(addrText: str): str =
    var addr: types.V3Libp2pMultiaddr
    let addrRes = multiaddr.v3Libp2pMultiaddrFillFromText(addr, addrText)
    if IsErr(addrRes):
        return ""
    return multiaddr.v3Libp2pMultiaddrText(addr)

@exportc("v3MobileCapiDialableAddr")
fn v3MobileCapiDialableAddr(addrText: str, peerText: str): str =
    let base = v3MobileCapiMultiaddrNormalize(addrText)
    if len(base) <= 0:
        return ""
    let peer = v3MobileCapiPeerIdNormalize(peerText)
    if len(peer) <= 0:
        return ""
    if strContains(base, "/p2p/") || strContains(base, "/ipfs/"):
        return base
    var out = base
    out = out + "/p2p/"
    out = out + peer
    return out

fn v3MobileCapiBioDidCapture(requestId: str,
                             feature32Hex: str,
                             deviceBindingSeed: str,
                             deviceLabel: str,
                             sensorId: str,
                             hardwareAttestation: str): Result[bio_did.V3BioDidHardwareCapture] =
    let featureRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(feature32Hex)
    if IsErr(featureRes):
        return Err[bio_did.V3BioDidHardwareCapture]("v3 mobile capi: invalid fingerprint feature32")
    var capture = bio_did.V3BioDidHardwareCapture()
    capture.verified = true
    capture.feature32 = Value(featureRes)
    capture.requestId = requestId
    capture.sensorId = sensorId
    capture.deviceBindingSeed = deviceBindingSeed
    capture.deviceLabel = deviceLabel
    capture.hardwareAttestation = hardwareAttestation
    let captureOk = bio_did.v3BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        return Err[bio_did.V3BioDidHardwareCapture](Error(captureOk))
    return Ok[bio_did.V3BioDidHardwareCapture](capture)

fn v3MobileCapiTextHex(value: str): str =
    let raw = bytesFromString(value)
    let out = bytesToHex(raw)
    return out

fn v3MobileCapiDecodeWireText(text: str): Result[str] =
    let bytesRes = did.v3DidStoreDecodeBytes(text)
    if IsErr(bytesRes):
        return Err[str](Error(bytesRes))
    let decoded = bytesToString(Value(bytesRes))
    return Ok[str](decoded)

fn v3MobileCapiWireFindValue(wire: str, key: str): Result[str] =
    let prefix = key + "="
    var lineStart: int32
    let n = strings.Len(wire)
    while lineStart < n:
        var lineEnd = lineStart
        while lineEnd < n:
            if wire[lineEnd] == '\n':
                break
            lineEnd = lineEnd + 1
        var line = ""
        if lineEnd > lineStart:
            line = strutils.SliceStr(wire, lineStart, lineEnd - 1)
        if strutils.StartsWith(line, prefix):
            return Ok[str](strutils.SliceStr(line, strings.Len(prefix), strings.Len(line) - 1))
        lineStart = lineEnd + 1
    return Err[str]("v3 mobile capi: missing wire field " + key)

fn v3MobileCapiWireDecodedValue(wire: str, key: str): Result[str] =
    let rawRes = v3MobileCapiWireFindValue(wire, key)
    if IsErr(rawRes):
        return Err[str](Error(rawRes))
    let decodedRes = v3MobileCapiDecodeWireText(Value(rawRes))
    return decodedRes

fn v3MobileCapiBioDidErrorJson(errorText: str): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out, "ok", "0")
    out = did.v3DidStoreAppendLine(out, "error", errorText)
    return out

fn v3MobileCapiTextBufferHandle(text: str): uint64 =
    let raw = bytesFromString(text)
    let textLen = bytesLen(raw)
    if textLen <= 0 || raw.data == nil:
        return uint64(0)
    v3MobileCapiEmitLog("mobile_moq:text_buffer_handle_before_bridge")
    let handle = cheng_v3_buffer_handle_from_raw_bridge(raw.data, textLen)
    v3MobileCapiEmitLog("mobile_moq:text_buffer_handle_after_bridge")
    return handle

fn v3MobileCapiBytesBufferHandle(payload: Bytes): int32 =
    let payloadLen = bytesLen(payload)
    if payloadLen <= 0 || payload.data == nil:
        return 0
    return int32(cheng_v3_buffer_handle_from_raw_bridge(payload.data, payloadLen))

fn v3MobileCapiTextCString(text: str): ptr =
    let textLen = len(text)
    let raw = c_malloc(int64(textLen + 1))
    if raw == nil:
        return nil
    var out = bytesView(raw, textLen + 1)
    for i in 0..<textLen:
        bytesSet(out, i, int32(text[i]) & 255)
    bytesSet(out, textLen, 0)
    return raw

@exportc("v3MobileCapiStringFree")
fn v3MobileCapiStringFree(text: ptr) =
    c_free(text)

fn v3MobileCapiCopyRawText(raw: ptr): str =
    if raw == nil:
        return ""
    let out = strFromCStringCopy(cstring(raw))
    return out

fn v3MobileCapiCopyRawTextLen(raw: ptr, textLen: int32): str =
    if raw == nil || textLen <= 0:
        return ""
    return bytesToString(bytesView(raw, textLen))

type V3MobileMoqDroplet = object
    objectIndex: int32
    dropletIndex: int32
    kindCode: int32
    key: str
    peerId: str
    cid: str
    degree: int32
    blockIndexes: int32[]
    payload: Bytes

type V3MobileMoqObject = object
    objectIndex: int32
    groupId: str
    objectId: str
    priority: int32
    byteOffset: int32
    byteLength: int32
    objectCid: str
    sourceBlockBytes: int32
    sourceBlockCount: int32
    repairDropletCount: int32
    droplets: V3MobileMoqDroplet[]

type V3MobileMoqEquation = object
    coeffs: int32[]
    payload: Bytes

type V3MobileMoqBuildResult = object
    ownerPeerId: str
    mimeType: str
    bundleCid: str
    blobCid: str
    catalogKey: str
    catalogCid: str
    catalogSizeBytes: int32
    catalogPayload: Bytes
    rebuildTemplateKey: str
    rebuildTemplateCid: str
    rebuildTemplateSizeBytes: int32
    rebuildTemplatePayload: Bytes
    blobByteLen: int32
    objectTargetBytes: int32
    sourceBlockBytes: int32
    objectCount: int32
    remoteAckPeerIds: str[]
    objects: V3MobileMoqObject[]
    droplets: V3MobileMoqDroplet[]

const v3MobileMoqCatalogMagic = "unimaker.moq.fountain.catalog.v1"
const v3MobileMoqTransport = "native_media_rpc"
const v3MobileMoqLayout = "lt_xor_v1"
const v3MobileMoqDropletKindSource = 1
const v3MobileMoqDropletKindRepair = 2

fn v3MobileCapiByteBufAppendText(buf: var layout.ByteBuf, text: str) =
    if len(text) <= 0:
        return
    layout.byteBufAppendBytes(buf, bytesFromString(text))

fn v3MobileCapiWireBufAppendRaw(buf: var layout.ByteBuf, key: str, value: str) =
    v3MobileCapiByteBufAppendText(buf, key)
    layout.byteBufAppendByte(buf, int32('='))
    v3MobileCapiByteBufAppendText(buf, value)
    layout.byteBufAppendByte(buf, int32('\n'))

fn v3MobileCapiWireBufAppendInt(buf: var layout.ByteBuf, key: str, value: int32) =
    v3MobileCapiWireBufAppendRaw(buf, key, strings.IntToStr(value))

fn v3MobileCapiWireRow(key: str, value: str): str =
    var buf = layout.byteBufInit(len(key) + len(value) + 1)
    v3MobileCapiByteBufAppendText(buf, key)
    layout.byteBufAppendByte(buf, int32('='))
    v3MobileCapiByteBufAppendText(buf, value)
    return bytesToString(layout.byteBufToBytes(buf))

fn v3MobileCapiWireRowInt(key: str, value: int32): str =
    return v3MobileCapiWireRow(key, strings.IntToStr(value))

fn v3MobileCapiWireRowsText(rows: str[]): str =
    if rows.len <= 0:
        return ""
    var cap: int32
    var rowLen: int32
    while rowLen < rows.len:
        cap = cap + len(rows[rowLen]) + 1
        rowLen = rowLen + 1
    var buf = layout.byteBufInit(cap)
    var row: int32
    while row < rows.len:
        v3MobileCapiByteBufAppendText(buf, rows[row])
        layout.byteBufAppendByte(buf, int32('\n'))
        row = row + 1
    return bytesToString(layout.byteBufToBytes(buf))

fn v3MobileCapiWireRowsResult(rows: str[], errorText: str): Result[str] =
    let out = v3MobileCapiWireRowsText(rows)
    if len(out) <= 0:
        return Err[str](errorText)
    return Ok[str](out)

fn v3MobileCapiWireMergeRows(baseWire: str, extraRows: str[], errorText: str): Result[str] =
    let suffixRes = v3MobileCapiWireRowsResult(extraRows, errorText)
    if IsErr(suffixRes):
        return Err[str](Error(suffixRes))
    let suffix = Value(suffixRes)
    if len(baseWire) <= 0:
        return Ok[str](suffix)
    if baseWire[len(baseWire) - 1] == '\n':
        var buf = layout.byteBufInit(len(baseWire) + len(suffix))
        v3MobileCapiByteBufAppendText(buf, baseWire)
        v3MobileCapiByteBufAppendText(buf, suffix)
        return Ok[str](bytesToString(layout.byteBufToBytes(buf)))
    var buf = layout.byteBufInit(len(baseWire) + len(suffix) + 1)
    v3MobileCapiByteBufAppendText(buf, baseWire)
    layout.byteBufAppendByte(buf, int32('\n'))
    v3MobileCapiByteBufAppendText(buf, suffix)
    return Ok[str](bytesToString(layout.byteBufToBytes(buf)))

fn v3MobileCapiMoqDropletKindText(kindCode: int32): str =
    if kindCode == v3MobileMoqDropletKindSource:
        return "source"
    if kindCode == v3MobileMoqDropletKindRepair:
        return "repair"
    return "unknown"

fn v3MobileCapiMoqError(errorText: str): str =
    var rows: str[]
    rows = []
    add(rows, v3MobileCapiWireRow("ok", "0"))
    add(rows, v3MobileCapiWireRow("error", errorText))
    return v3MobileCapiWireRowsText(rows)

fn v3MobileCapiPathJoin(dirPath: str, fileName: str): str =
    if len(dirPath) <= 0:
        return fileName
    let needSep = dirPath[len(dirPath) - 1] != '/'
    var buf = layout.byteBufInit(len(dirPath) + len(fileName) + if needSep: 1 else: 0)
    v3MobileCapiByteBufAppendText(buf, dirPath)
    if needSep:
        layout.byteBufAppendByte(buf, int32('/'))
    v3MobileCapiByteBufAppendText(buf, fileName)
    return bytesToString(layout.byteBufToBytes(buf))

fn v3MobileCapiPathJoinStemSuffix(dirPath: str, fileNameStem: str, suffix: str): str =
    if len(dirPath) <= 0:
        var fileBuf = layout.byteBufInit(len(fileNameStem) + len(suffix))
        v3MobileCapiByteBufAppendText(fileBuf, fileNameStem)
        v3MobileCapiByteBufAppendText(fileBuf, suffix)
        return bytesToString(layout.byteBufToBytes(fileBuf))
    let needSep = dirPath[len(dirPath) - 1] != '/'
    var buf = layout.byteBufInit(len(dirPath) + len(fileNameStem) + len(suffix) + if needSep: 1 else: 0)
    v3MobileCapiByteBufAppendText(buf, dirPath)
    if needSep:
        layout.byteBufAppendByte(buf, int32('/'))
    v3MobileCapiByteBufAppendText(buf, fileNameStem)
    v3MobileCapiByteBufAppendText(buf, suffix)
    return bytesToString(layout.byteBufToBytes(buf))

fn v3MobileCapiDropletFileSuffix(objectIndex: int32,
                                 dropletIndex: int32): str =
    let objectText = strings.IntToStr(objectIndex)
    let dropletText = strings.IntToStr(dropletIndex)
    let cap = len(objectText) + len(dropletText) + 10
    var buf = layout.byteBufInit(cap)
    layout.byteBufAppendByte(buf, int32('.'))
    v3MobileCapiByteBufAppendText(buf, objectText)
    layout.byteBufAppendByte(buf, int32('.'))
    v3MobileCapiByteBufAppendText(buf, dropletText)
    v3MobileCapiByteBufAppendText(buf, ".droplet")
    return bytesToString(layout.byteBufToBytes(buf))

fn v3MobileCapiDropletKindFileSuffix(objectIndex: int32,
                                     kindText: str,
                                     dropletIndex: int32): str =
    let objectText = strings.IntToStr(objectIndex)
    let dropletText = strings.IntToStr(dropletIndex)
    let cap = len(objectText) + len(kindText) + len(dropletText) + 11
    var buf = layout.byteBufInit(cap)
    layout.byteBufAppendByte(buf, int32('.'))
    v3MobileCapiByteBufAppendText(buf, objectText)
    layout.byteBufAppendByte(buf, int32('.'))
    v3MobileCapiByteBufAppendText(buf, kindText)
    layout.byteBufAppendByte(buf, int32('.'))
    v3MobileCapiByteBufAppendText(buf, dropletText)
    v3MobileCapiByteBufAppendText(buf, ".droplet")
    return bytesToString(layout.byteBufToBytes(buf))

fn v3MobileCapiIndexedFieldKey(groupName: str,
                               itemIndex: int32,
                               fieldName: str): str =
    let indexText = strings.IntToStr(itemIndex)
    let cap = len(groupName) + len(indexText) + len(fieldName) + 2
    var buf = layout.byteBufInit(cap)
    v3MobileCapiByteBufAppendText(buf, groupName)
    layout.byteBufAppendByte(buf, int32('.'))
    v3MobileCapiByteBufAppendText(buf, indexText)
    layout.byteBufAppendByte(buf, int32('.'))
    v3MobileCapiByteBufAppendText(buf, fieldName)
    return bytesToString(layout.byteBufToBytes(buf))

fn v3MobileCapiWriteBytesFile(path: str, payload: Bytes): Result[bool] =
    let outFile = cheng_fopen(strToCStringTemp(path), "wb")
    if outFile == nil:
        return Err[bool]("moq_fountain_write_open_failed")
    let payloadLen = bytesLen(payload)
    if payloadLen > 0:
        let wrote: int32 = cheng_fwrite(payload.data, 1, payloadLen, outFile)
        if wrote != payloadLen:
            cheng_fclose(outFile)
            return Err[bool]("moq_fountain_write_failed")
    cheng_fclose(outFile)
    return Ok[bool](true)

fn v3MobileCapiAppendBytesFile(path: str, payload: Bytes): Result[bool] =
    let outFile = cheng_fopen(strToCStringTemp(path), "ab")
    if outFile == nil:
        return Err[bool]("moq_fountain_append_open_failed")
    let payloadLen = bytesLen(payload)
    if payloadLen > 0:
        let wrote: int32 = cheng_fwrite(payload.data, 1, payloadLen, outFile)
        if wrote != payloadLen:
            cheng_fclose(outFile)
            return Err[bool]("moq_fountain_append_failed")
    cheng_fclose(outFile)
    return Ok[bool](true)

fn v3MobileCapiWriteTraceLine(path: str, line: str): Result[bool] =
    v3MobileCapiAppendBytesFile(path, bytesFromString(line + "\n"))

fn v3MobileCapiMaybeWriteTraceLine(path: str, line: str) =
    if len(path) <= 0:
        return
    let _trace = v3MobileCapiWriteTraceLine(path, line)

fn v3MobileCapiMoqBuildPersistWire(result: V3MobileMoqBuildResult,
                                   outputDir: str,
                                   fileNameStem: str): Result[str] =
    v3MobileCapiEmitLog("mobile_moq:build_persist_wire_enter")
    let catalogPath = v3MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".catalog.json")
    v3MobileCapiEmitLog("mobile_moq:build_persist_wire_after_catalog_path")
    let catalogWriteRes = v3MobileCapiWriteBytesFile(catalogPath, result.catalogPayload)
    if IsErr(catalogWriteRes):
        return Err[str](Error(catalogWriteRes))
    v3MobileCapiEmitLog("mobile_moq:build_persist_wire_after_catalog_write")
    let rebuildPath = v3MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".rebuild.txt")
    v3MobileCapiEmitLog("mobile_moq:build_persist_wire_after_rebuild_path")
    let rebuildWriteRes = v3MobileCapiWriteBytesFile(rebuildPath, result.rebuildTemplatePayload)
    if IsErr(rebuildWriteRes):
        return Err[str](Error(rebuildWriteRes))
    v3MobileCapiEmitLog("mobile_moq:build_persist_wire_after_rebuild_write")
    var rows: str[]
    rows = []
    add(rows, v3MobileCapiWireRow("ok", "1"))
    add(rows, v3MobileCapiWireRow("owner_peer_id", result.ownerPeerId))
    add(rows, v3MobileCapiWireRow("mime_type", result.mimeType))
    add(rows, v3MobileCapiWireRow("bundle_cid", result.bundleCid))
    add(rows, v3MobileCapiWireRow("blob_cid", result.blobCid))
    add(rows, v3MobileCapiWireRow("catalog_key", result.catalogKey))
    add(rows, v3MobileCapiWireRow("catalog_cid", result.catalogCid))
    add(rows, v3MobileCapiWireRowInt("catalog_size_bytes", result.catalogSizeBytes))
    add(rows, v3MobileCapiWireRow("catalog_path", catalogPath))
    add(rows, v3MobileCapiWireRow("rebuild_template_key", result.rebuildTemplateKey))
    add(rows, v3MobileCapiWireRow("rebuild_template_cid", result.rebuildTemplateCid))
    add(rows, v3MobileCapiWireRowInt("rebuild_template_size_bytes", result.rebuildTemplateSizeBytes))
    add(rows, v3MobileCapiWireRow("rebuild_template_path", rebuildPath))
    add(rows, v3MobileCapiWireRowInt("blob_byte_len", result.blobByteLen))
    add(rows, v3MobileCapiWireRowInt("object_target_bytes", result.objectTargetBytes))
    add(rows, v3MobileCapiWireRowInt("source_block_bytes", result.sourceBlockBytes))
    add(rows, v3MobileCapiWireRowInt("object_count", result.objectCount))
    add(rows, v3MobileCapiWireRow("remote_ack_peer_ids", v3MobileCapiJoinCsv(result.remoteAckPeerIds)))
    v3MobileCapiEmitLog("mobile_moq:build_persist_wire_after_header_rows")
    var objectRow: int32
    while objectRow < result.objects.len:
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_object_row_begin")
        let objectIndexKey = v3MobileCapiIndexedFieldKey("object", objectRow, "object_index")
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_object_index_key_ready")
        add(rows,
            v3MobileCapiWireRowInt(objectIndexKey,
                                   result.objects[objectRow].objectIndex))
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_object_index_ready")
        let sourceBlockBytesKey = v3MobileCapiIndexedFieldKey("object", objectRow, "source_block_bytes")
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_object_block_key_ready")
        add(rows,
            v3MobileCapiWireRowInt(sourceBlockBytesKey,
                                   result.objects[objectRow].sourceBlockBytes))
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_object_block_ready")
        let repairDropletCountKey = v3MobileCapiIndexedFieldKey("object", objectRow, "repair_droplet_count")
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_object_repair_key_ready")
        add(rows,
            v3MobileCapiWireRowInt(repairDropletCountKey,
                                   result.objects[objectRow].repairDropletCount))
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_object_row_done")
        objectRow = objectRow + 1
    v3MobileCapiEmitLog("mobile_moq:build_persist_wire_after_object_rows")
    add(rows, v3MobileCapiWireRowInt("droplet_count", result.droplets.len))
    var dropletRow: int32
    while dropletRow < result.droplets.len:
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_droplet_row_begin")
        let dropletPath = v3MobileCapiPathJoinStemSuffix(outputDir,
                                                         fileNameStem,
                                                         v3MobileCapiDropletFileSuffix(result.droplets[dropletRow].objectIndex,
                                                                                      result.droplets[dropletRow].dropletIndex))
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_droplet_path_ready")
        let dropletWriteRes = v3MobileCapiWriteBytesFile(dropletPath, result.droplets[dropletRow].payload)
        if IsErr(dropletWriteRes):
            return Err[str](Error(dropletWriteRes))
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_droplet_write_ready")
        add(rows,
            v3MobileCapiWireRowInt(v3MobileCapiIndexedFieldKey("droplet",
                                                               dropletRow,
                                                               "object_index"),
                                   result.droplets[dropletRow].objectIndex))
        add(rows,
            v3MobileCapiWireRowInt(v3MobileCapiIndexedFieldKey("droplet",
                                                               dropletRow,
                                                               "droplet_index"),
                                   result.droplets[dropletRow].dropletIndex))
        add(rows,
            v3MobileCapiWireRow(v3MobileCapiIndexedFieldKey("droplet",
                                                            dropletRow,
                                                            "key"),
                                result.droplets[dropletRow].key))
        add(rows,
            v3MobileCapiWireRow(v3MobileCapiIndexedFieldKey("droplet",
                                                            dropletRow,
                                                            "peer_id"),
                                result.droplets[dropletRow].peerId))
        add(rows,
            v3MobileCapiWireRow(v3MobileCapiIndexedFieldKey("droplet",
                                                            dropletRow,
                                                            "cid"),
                                result.droplets[dropletRow].cid))
        add(rows,
            v3MobileCapiWireRow(v3MobileCapiIndexedFieldKey("droplet",
                                                            dropletRow,
                                                            "block_indexes"),
                                v3MobileCapiJoinIntCsv(result.droplets[dropletRow].blockIndexes)))
        add(rows,
            v3MobileCapiWireRow(v3MobileCapiIndexedFieldKey("droplet",
                                                            dropletRow,
                                                            "path"),
                                dropletPath))
        v3MobileCapiEmitLog("mobile_moq:build_persist_wire_droplet_row_done")
        dropletRow = dropletRow + 1
    v3MobileCapiEmitLog("mobile_moq:build_persist_wire_after_droplet_rows")
    return v3MobileCapiWireRowsResult(rows, "moq_fountain_empty_persist_wire")

fn v3MobileCapiMoqBuildPersistWireCore(result: moq.V3Libp2pMoqBuildResult,
                                       outputDir: str,
                                       fileNameStem: str): Result[str] =
    let catalogPath = v3MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".catalog.json")
    let catalogWriteRes = v3MobileCapiWriteBytesFile(catalogPath, result.catalogPayload)
    if IsErr(catalogWriteRes):
        return Err[str](Error(catalogWriteRes))
    let rebuildPath = v3MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".rebuild.txt")
    let rebuildWriteRes = v3MobileCapiWriteBytesFile(rebuildPath, result.rebuildTemplatePayload)
    if IsErr(rebuildWriteRes):
        return Err[str](Error(rebuildWriteRes))
    var rows: str[]
    rows = []
    add(rows, v3MobileCapiWireRow("ok", "1"))
    add(rows, v3MobileCapiWireRow("owner_peer_id", result.ownerPeerId))
    add(rows, v3MobileCapiWireRow("mime_type", result.mimeType))
    add(rows, v3MobileCapiWireRow("bundle_cid", result.bundleCid))
    add(rows, v3MobileCapiWireRow("blob_cid", result.blobCid))
    add(rows, v3MobileCapiWireRow("catalog_key", result.catalogKey))
    add(rows, v3MobileCapiWireRow("catalog_cid", result.catalogCid))
    add(rows, v3MobileCapiWireRowInt("catalog_size_bytes", result.catalogSizeBytes))
    add(rows, v3MobileCapiWireRow("catalog_path", catalogPath))
    add(rows, v3MobileCapiWireRow("rebuild_template_key", result.rebuildTemplateKey))
    add(rows, v3MobileCapiWireRow("rebuild_template_cid", result.rebuildTemplateCid))
    add(rows, v3MobileCapiWireRowInt("rebuild_template_size_bytes", result.rebuildTemplateSizeBytes))
    add(rows, v3MobileCapiWireRow("rebuild_template_path", rebuildPath))
    add(rows, v3MobileCapiWireRowInt("blob_byte_len", result.blobByteLen))
    add(rows, v3MobileCapiWireRowInt("object_target_bytes", result.objectTargetBytes))
    add(rows, v3MobileCapiWireRowInt("source_block_bytes", result.sourceBlockBytes))
    add(rows, v3MobileCapiWireRowInt("object_count", result.objectCount))
    add(rows, v3MobileCapiWireRow("remote_ack_peer_ids", v3MobileCapiJoinCsv(result.remoteAckPeerIds)))
    var objectRow: int32
    while objectRow < result.objects.len:
        let item = result.objects[objectRow]
        let prefix = "object." + strings.IntToStr(objectRow) + "."
        add(rows, v3MobileCapiWireRowInt(prefix + "object_index", item.objectIndex))
        add(rows, v3MobileCapiWireRowInt(prefix + "source_block_bytes", item.sourceBlockBytes))
        add(rows, v3MobileCapiWireRowInt(prefix + "repair_droplet_count", item.repairDropletCount))
        objectRow = objectRow + 1
    add(rows, v3MobileCapiWireRowInt("droplet_count", result.droplets.len))
    var dropletRow: int32
    while dropletRow < result.droplets.len:
        let droplet = result.droplets[dropletRow]
        let prefix = "droplet." + strings.IntToStr(dropletRow) + "."
        let dropletPath = v3MobileCapiPathJoinStemSuffix(outputDir,
                                                         fileNameStem,
                                                         v3MobileCapiDropletFileSuffix(droplet.objectIndex,
                                                                                      droplet.dropletIndex))
        let dropletWriteRes = v3MobileCapiWriteBytesFile(dropletPath, droplet.payload)
        if IsErr(dropletWriteRes):
            return Err[str](Error(dropletWriteRes))
        add(rows, v3MobileCapiWireRowInt(prefix + "object_index", droplet.objectIndex))
        add(rows, v3MobileCapiWireRowInt(prefix + "droplet_index", droplet.dropletIndex))
        add(rows, v3MobileCapiWireRow(prefix + "key", droplet.key))
        add(rows, v3MobileCapiWireRow(prefix + "peer_id", droplet.peerId))
        add(rows, v3MobileCapiWireRow(prefix + "cid", droplet.cid))
        add(rows, v3MobileCapiWireRow(prefix + "block_indexes", v3MobileCapiJoinIntCsv(droplet.blockIndexes)))
        add(rows, v3MobileCapiWireRow(prefix + "path", dropletPath))
        dropletRow = dropletRow + 1
    return v3MobileCapiWireRowsResult(rows, "moq_fountain_empty_persist_wire_core")

fn v3MobileCapiMoqPersistWire(requestWire: str,
                              outputDir: str,
                              fileNameStem: str): Result[str] =
    if len(outputDir) <= 0:
        return Err[str]("moq_fountain_missing_output_dir")
    if len(fileNameStem) <= 0:
        return Err[str]("moq_fountain_missing_file_stem")
    let catalogPayloadHexRes = moq.v3Libp2pMoqWireFindValue(requestWire, "catalog_payload_hex")
    if IsErr(catalogPayloadHexRes):
        return Err[str](Error(catalogPayloadHexRes))
    let rebuildPayloadHexRes = moq.v3Libp2pMoqWireFindValue(requestWire, "rebuild_template_payload_hex")
    if IsErr(rebuildPayloadHexRes):
        return Err[str](Error(rebuildPayloadHexRes))
    let catalogPayloadRes = moq.v3Libp2pMoqBytesFromHex(Value(catalogPayloadHexRes))
    if IsErr(catalogPayloadRes):
        return Err[str](Error(catalogPayloadRes))
    let rebuildPayloadRes = moq.v3Libp2pMoqBytesFromHex(Value(rebuildPayloadHexRes))
    if IsErr(rebuildPayloadRes):
        return Err[str](Error(rebuildPayloadRes))
    let catalogPath = v3MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".catalog.json")
    let catalogWriteRes = v3MobileCapiWriteBytesFile(catalogPath, Value(catalogPayloadRes))
    if IsErr(catalogWriteRes):
        return Err[str](Error(catalogWriteRes))
    let rebuildPath = v3MobileCapiPathJoinStemSuffix(outputDir, fileNameStem, ".rebuild.txt")
    let rebuildWriteRes = v3MobileCapiWriteBytesFile(rebuildPath, Value(rebuildPayloadRes))
    if IsErr(rebuildWriteRes):
        return Err[str](Error(rebuildWriteRes))
    let dropletCountRes = moq.v3Libp2pMoqParseInt32Wire(requestWire, "droplet_count")
    if IsErr(dropletCountRes):
        return Err[str](Error(dropletCountRes))
    let dropletCount = Value(dropletCountRes)
    var extraRows: str[]
    extraRows = []
    add(extraRows, v3MobileCapiWireRow("catalog_path", catalogPath))
    add(extraRows, v3MobileCapiWireRow("rebuild_template_path", rebuildPath))
    var dropletRow: int32
    while dropletRow < dropletCount:
        let prefix = "droplet." + strings.IntToStr(dropletRow) + "."
        let objectIndexRes = moq.v3Libp2pMoqParseInt32Wire(requestWire, prefix + "object_index")
        if IsErr(objectIndexRes):
            return Err[str](Error(objectIndexRes))
        let dropletIndexRes = moq.v3Libp2pMoqParseInt32Wire(requestWire, prefix + "droplet_index")
        if IsErr(dropletIndexRes):
            return Err[str](Error(dropletIndexRes))
        let kindRes = moq.v3Libp2pMoqWireFindValue(requestWire, prefix + "kind")
        if IsErr(kindRes):
            return Err[str](Error(kindRes))
        let payloadHexRes = moq.v3Libp2pMoqWireFindValue(requestWire, prefix + "payload_hex")
        if IsErr(payloadHexRes):
            return Err[str](Error(payloadHexRes))
        let payloadRes = moq.v3Libp2pMoqBytesFromHex(Value(payloadHexRes))
        if IsErr(payloadRes):
            return Err[str](Error(payloadRes))
        let dropletPath = v3MobileCapiPathJoinStemSuffix(outputDir,
                                                         fileNameStem,
                                                         v3MobileCapiDropletKindFileSuffix(Value(objectIndexRes),
                                                                                          Value(kindRes),
                                                                                          Value(dropletIndexRes)))
        let dropletWriteRes = v3MobileCapiWriteBytesFile(dropletPath, Value(payloadRes))
        if IsErr(dropletWriteRes):
            return Err[str](Error(dropletWriteRes))
        add(extraRows, v3MobileCapiWireRow(prefix + "path", dropletPath))
        dropletRow = dropletRow + 1
    return v3MobileCapiWireMergeRows(requestWire, extraRows, "moq_fountain_empty_persist_wire")

fn v3MobileCapiMoqBuildHandleWire(result: var V3MobileMoqBuildResult): str =
    var rows: str[]
    rows = []
    add(rows, v3MobileCapiWireRow("ok", "1"))
    add(rows, v3MobileCapiWireRow("owner_peer_id", result.ownerPeerId))
    add(rows, v3MobileCapiWireRow("mime_type", result.mimeType))
    add(rows, v3MobileCapiWireRow("bundle_cid", result.bundleCid))
    add(rows, v3MobileCapiWireRow("blob_cid", result.blobCid))
    add(rows, v3MobileCapiWireRow("catalog_key", result.catalogKey))
    add(rows, v3MobileCapiWireRow("catalog_cid", result.catalogCid))
    add(rows, v3MobileCapiWireRowInt("catalog_size_bytes", result.catalogSizeBytes))
    add(rows, v3MobileCapiWireRowInt("catalog_handle", v3MobileCapiBytesBufferHandle(result.catalogPayload)))
    add(rows, v3MobileCapiWireRow("rebuild_template_key", result.rebuildTemplateKey))
    add(rows, v3MobileCapiWireRow("rebuild_template_cid", result.rebuildTemplateCid))
    add(rows, v3MobileCapiWireRowInt("rebuild_template_size_bytes", result.rebuildTemplateSizeBytes))
    add(rows, v3MobileCapiWireRowInt("rebuild_template_handle", v3MobileCapiBytesBufferHandle(result.rebuildTemplatePayload)))
    add(rows, v3MobileCapiWireRowInt("blob_byte_len", result.blobByteLen))
    add(rows, v3MobileCapiWireRowInt("object_target_bytes", result.objectTargetBytes))
    add(rows, v3MobileCapiWireRowInt("source_block_bytes", result.sourceBlockBytes))
    add(rows, v3MobileCapiWireRowInt("object_count", result.objectCount))
    add(rows, v3MobileCapiWireRow("remote_ack_peer_ids", v3MobileCapiJoinCsv(result.remoteAckPeerIds)))
    var objectRow: int32
    while objectRow < result.objects.len:
        let item = result.objects[objectRow]
        let prefix = "object." + strings.IntToStr(objectRow) + "."
        add(rows, v3MobileCapiWireRowInt(prefix + "object_index", item.objectIndex))
        add(rows, v3MobileCapiWireRow(prefix + "group_id", item.groupId))
        add(rows, v3MobileCapiWireRow(prefix + "object_id", item.objectId))
        add(rows, v3MobileCapiWireRowInt(prefix + "priority", item.priority))
        add(rows, v3MobileCapiWireRowInt(prefix + "byte_offset", item.byteOffset))
        add(rows, v3MobileCapiWireRowInt(prefix + "byte_length", item.byteLength))
        add(rows, v3MobileCapiWireRow(prefix + "object_cid", item.objectCid))
        add(rows, v3MobileCapiWireRowInt(prefix + "source_block_bytes", item.sourceBlockBytes))
        add(rows, v3MobileCapiWireRowInt(prefix + "source_block_count", item.sourceBlockCount))
        add(rows, v3MobileCapiWireRowInt(prefix + "repair_droplet_count", item.repairDropletCount))
        objectRow = objectRow + 1
    add(rows, v3MobileCapiWireRowInt("droplet_count", result.droplets.len))
    var dropletRow: int32
    while dropletRow < result.droplets.len:
        let droplet = result.droplets[dropletRow]
        let prefix = "droplet." + strings.IntToStr(dropletRow) + "."
        add(rows, v3MobileCapiWireRowInt(prefix + "object_index", droplet.objectIndex))
        add(rows, v3MobileCapiWireRowInt(prefix + "droplet_index", droplet.dropletIndex))
        add(rows, v3MobileCapiWireRow(prefix + "kind", v3MobileCapiMoqDropletKindText(droplet.kindCode)))
        add(rows, v3MobileCapiWireRow(prefix + "key", droplet.key))
        add(rows, v3MobileCapiWireRow(prefix + "peer_id", droplet.peerId))
        add(rows, v3MobileCapiWireRow(prefix + "cid", droplet.cid))
        add(rows, v3MobileCapiWireRowInt(prefix + "degree", droplet.degree))
        add(rows, v3MobileCapiWireRow(prefix + "block_indexes", v3MobileCapiJoinIntCsv(droplet.blockIndexes)))
        add(rows, v3MobileCapiWireRowInt(prefix + "handle", v3MobileCapiBytesBufferHandle(droplet.payload)))
        dropletRow = dropletRow + 1
    let outRes = v3MobileCapiWireRowsResult(rows, "moq_fountain_empty_build_handle_wire")
    if IsErr(outRes):
        return v3MobileCapiMoqError(Error(outRes))
    return Value(outRes)

fn v3MobileCapiMaxInt32(left: int32, right: int32): int32 =
    if left >= right:
        return left
    return right

fn v3MobileCapiMinInt32(left: int32, right: int32): int32 =
    if left <= right:
        return left
    return right

fn v3MobileCapiNormalizePositiveInt(value: int32, fallback: int32): int32 =
    var out = value
    if out <= 0:
        out = fallback
    if out <= 0:
        return 1
    return out

fn v3MobileCapiHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn v3MobileCapiBytesFromHex(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Ok[Bytes](emptyBytes())
    if (len(text) % 2) != 0:
        return Err[Bytes]("v3 mobile capi: invalid hex length")
    var out = bytesAlloc(len(text) / 2)
    var i = 0
    while i < len(text):
        let hi = v3MobileCapiHexValue(text[i])
        let lo = v3MobileCapiHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes]("v3 mobile capi: invalid hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn v3MobileCapiSha256HexBytes(data: Bytes): str =
    let digest = hash256.sha256Fixed(layout.byteSpanFromBytes(data))
    return layout.fixedBytes32Hex(digest)

fn v3MobileCapiSha256HexText(text: str): str =
    return v3MobileCapiSha256HexBytes(bytesFromString(text))

fn v3MobileCapiAsciiTrimLeft(text: str): int32 =
    var idx: int32
    while idx < len(text):
        let ch = text[idx]
        let code = int32(ch)
        if code == 32:
            idx = idx + 1
            continue
        if code == 10:
            idx = idx + 1
            continue
        if code == 13:
            idx = idx + 1
            continue
        if code == 9:
            idx = idx + 1
            continue
        break
    return idx

fn v3MobileCapiAsciiTrimRight(text: str): int32 =
    var idx: int32 = len(text)
    while idx > 0:
        let ch = text[idx - 1]
        let code = int32(ch)
        if code == 32:
            idx = idx - 1
            continue
        if code == 10:
            idx = idx - 1
            continue
        if code == 13:
            idx = idx - 1
            continue
        if code == 9:
            idx = idx - 1
            continue
        break
    return idx

fn v3MobileCapiTrimAscii(text: str): str =
    let start = v3MobileCapiAsciiTrimLeft(text)
    let stop = v3MobileCapiAsciiTrimRight(text)
    if stop <= start:
        return ""
    return strings.SliceBytes(text, start, stop - start)

fn v3MobileCapiSplitCsv(text: str): str[] =
    var out: str[]
    out = []
    if len(text) <= 0:
        return out
    var start: int32
    var idx: int32
    while idx <= len(text):
        let atEnd = idx >= len(text)
        if atEnd || text[idx] == ',':
            var item = ""
            if idx > start:
                item = strings.SliceBytes(text, start, idx - start)
            add(out, item)
            start = idx + 1
        idx = idx + 1
    return out

fn v3MobileCapiNormalizePeerCsv(peerCsv: str): str[] =
    v3MobileCapiEmitLog("mobile_moq:normalize_peers_enter")
    let parts = v3MobileCapiSplitCsv(peerCsv)
    v3MobileCapiEmitLog("mobile_moq:normalize_peers_after_split")
    var out: str[]
    out = []
    var i: int32
    while i < parts.len:
        let part = parts[i]
        v3MobileCapiEmitLog("mobile_moq:normalize_peers_before_trim")
        let candidate = v3MobileCapiTrimAscii(part)
        v3MobileCapiEmitLog("mobile_moq:normalize_peers_after_trim")
        if len(candidate) <= 0:
            i = i + 1
            continue
        var exists = false
        var j: int32
        while j < out.len:
            v3MobileCapiEmitLog("mobile_moq:normalize_peers_before_equals")
            if out[j] == candidate:
                exists = true
                break
            j = j + 1
        if !exists:
            add(out, candidate)
        i = i + 1
    v3MobileCapiEmitLog("mobile_moq:normalize_peers_ok")
    return out

fn v3MobileCapiJoinCsv(values: str[]): str =
    if values.len <= 0:
        return ""
    return strutils.Join(values, ",")

fn v3MobileCapiJoinIntCsv(values: int32[]): str =
    var rows: int32[]
    rows = []
    var i: int32
    while i < values.len:
        add(rows, values[i])
        i = i + 1
    var texts: str[]
    texts = []
    i = 0
    while i < rows.len:
        add(texts, strings.IntToStr(rows[i]))
        i = i + 1
    return strutils.Join(texts, ",")

fn v3MobileCapiEscapeJsonText(text: str): str =
    var out = ""
    for i in 0..<len(text):
        let ch = text[i]
        let code = int32(ch)
        if code == 92:
            out = out + "\\\\"
        elif code == 34:
            out = out + "\\\""
        elif code == 8:
            out = out + "\\b"
        elif code == 12:
            out = out + "\\f"
        elif code == 10:
            out = out + "\\n"
        elif code == 13:
            out = out + "\\r"
        elif code == 9:
            out = out + "\\t"
        else:
            out = out + strings.charToStr(ch)
    return out

fn v3MobileCapiQuoteJsonTextBridge(text: str): str =
    return "\"" + v3MobileCapiEscapeJsonText(text) + "\""

fn v3MobileCapiStrformatFmtBridge(parts: str[]): str =
    return strutils.Join(parts, "")

fn v3MobileCapiStrformatLinesBridge(parts: str[]): str =
    return strutils.Join(parts, "\n")

fn v3MobileCapiJsonEscape(text: str): str =
    let quoted = v3MobileCapiQuoteJsonTextBridge(text)
    if len(quoted) <= 2:
        return ""
    return strings.SliceBytes(quoted, 1, len(quoted) - 2)

fn v3MobileCapiJsonQuote(text: str): str =
    let quoted = v3MobileCapiQuoteJsonTextBridge(text)
    return quoted

fn v3MobileCapiJoinIntJson(values: int32[]): str =
    if values.len <= 0:
        return "[]"
    var rows: str[]
    rows = []
    for i in 0..<values.len:
        add(rows, strings.IntToStr(values[i]))
    return "[" + strutils.Join(rows, ",") + "]"

fn v3MobileCapiContainsInt(values: int32[], want: int32): bool =
    for i in 0..<values.len:
        if values[i] == want:
            return true
    return false

fn v3MobileCapiSortInts(values0: int32[]): int32[] =
    var values = values0
    var i = 0
    while i < values.len:
        var j = i + 1
        while j < values.len:
            if values[j] < values[i]:
                let tmp = values[i]
                values[i] = values[j]
                values[j] = tmp
            j = j + 1
        i = i + 1
    return values

fn v3MobileCapiHashSeed(text: str): int32 =
    let digestHex = cheng_v3_sha256_hex_bridge(text)
    if len(digestHex) < 8:
        return 1
    var out: int32
    var i: int32
    while i < 8:
        let nibble = v3MobileCapiHexValue(digestHex[i])
        if nibble < 0:
            return 1
        out = (out << 4) | nibble
        i = i + 1
    if out == 0:
        return 1
    return out

fn v3MobileCapiMoqDropletJson(droplet: V3MobileMoqDroplet): str =
    let kindText = v3MobileCapiMoqDropletKindText(droplet.kindCode)
    var rows: str[]
    rows = []
    add(rows, Fmt(["\"objectIndex\":", strings.IntToStr(droplet.objectIndex)]))
    add(rows, Fmt(["\"dropletIndex\":", strings.IntToStr(droplet.dropletIndex)]))
    add(rows, Fmt(["\"kind\":", v3MobileCapiJsonQuote(kindText)]))
    add(rows, Fmt(["\"key\":", v3MobileCapiJsonQuote(droplet.key)]))
    add(rows, Fmt(["\"peerId\":", v3MobileCapiJsonQuote(droplet.peerId)]))
    add(rows, Fmt(["\"cid\":", v3MobileCapiJsonQuote(droplet.cid)]))
    add(rows, Fmt(["\"degree\":", strings.IntToStr(droplet.degree)]))
    add(rows, Fmt(["\"blockIndexes\":", v3MobileCapiJoinIntJson(droplet.blockIndexes)]))
    return Fmt(["{", strutils.Join(rows, ","), "}"])

fn v3MobileCapiMoqDropletsJson(droplets: V3MobileMoqDroplet[]): str =
    var rows: str[]
    rows = []
    var idx: int32
    while idx < droplets.len:
        add(rows, v3MobileCapiMoqDropletJson(droplets[idx]))
        idx = idx + 1
    return strutils.Join(rows, ",")

fn v3MobileCapiMoqObjectJson(item: V3MobileMoqObject): str =
    var rows: str[]
    rows = []
    add(rows, Fmt(["\"objectIndex\":", strings.IntToStr(item.objectIndex)]))
    add(rows, Fmt(["\"groupId\":", v3MobileCapiJsonQuote(item.groupId)]))
    add(rows, Fmt(["\"objectId\":", v3MobileCapiJsonQuote(item.objectId)]))
    add(rows, Fmt(["\"priority\":", strings.IntToStr(item.priority)]))
    add(rows, Fmt(["\"byteOffset\":", strings.IntToStr(item.byteOffset)]))
    add(rows, Fmt(["\"byteLength\":", strings.IntToStr(item.byteLength)]))
    add(rows, Fmt(["\"objectCid\":", v3MobileCapiJsonQuote(item.objectCid)]))
    add(rows, Fmt(["\"sourceBlockBytes\":", strings.IntToStr(item.sourceBlockBytes)]))
    add(rows, Fmt(["\"sourceBlockCount\":", strings.IntToStr(item.sourceBlockCount)]))
    add(rows, Fmt(["\"repairDropletCount\":", strings.IntToStr(item.repairDropletCount)]))
    add(rows, Fmt(["\"droplets\":[", v3MobileCapiMoqDropletsJson(item.droplets), "]"]))
    return Fmt(["{", strutils.Join(rows, ","), "}"])

fn v3MobileCapiParseInt32Text(text: str): int32 =
    return int32(strutils.ParseInt(text))

fn v3MobileCapiParseInt32Wire(requestWire: str, key: str): Result[int32] =
    let rawRes = v3MobileCapiWireFindValue(requestWire, key)
    if IsErr(rawRes):
        return Err[int32](Error(rawRes))
    let rawText = Value(rawRes)
    return Ok[int32](v3MobileCapiParseInt32Text(rawText))

fn v3MobileCapiMoqAppendDroplets(out: var V3MobileMoqDroplet[],
                                 droplets: V3MobileMoqDroplet[]) =
    var idx: int32
    while idx < droplets.len:
        add(out, droplets[idx])
        idx = idx + 1

fn v3MobileCapiMoqBuildObject(objectBytes: Bytes,
                              objectIndex: int32,
                              byteOffset: int32,
                              peers: str[],
                              bundleCid: str,
                              sourceBlockBytes: int32,
                              repairDropletCount: int32): Result[V3MobileMoqObject] =
    v3MobileCapiEmitLog("mobile_moq:build_object_enter")
    let objectByteLen = bytesLen(objectBytes)
    v3MobileCapiEmitLog("mobile_moq:build_object_after_len")
    let objectCid = v3MobileCapiSha256HexBytes(objectBytes)
    v3MobileCapiEmitLog("mobile_moq:build_object_after_object_cid")
    let sourceBlockCount = (objectByteLen + sourceBlockBytes - 1) / sourceBlockBytes
    v3MobileCapiEmitLog("mobile_moq:build_object_after_block_count")
    var blocks: Bytes[]
    blocks = []
    var blockIndex: int32
    while blockIndex < sourceBlockCount:
        let blockOffset = blockIndex * sourceBlockBytes
        let blockLen = v3MobileCapiMinInt32(sourceBlockBytes, objectByteLen - blockOffset)
        let blockBytes = bytesSlice(objectBytes, blockOffset, blockLen)
        add(blocks, v3MobileCapiPadBlock(blockBytes, sourceBlockBytes))
        blockIndex = blockIndex + 1
    v3MobileCapiEmitLog("mobile_moq:build_object_after_blocks")
    var objectDroplets: V3MobileMoqDroplet[]
    objectDroplets = []
    blockIndex = 0
    while blockIndex < sourceBlockCount:
        var indexes: int32[]
        indexes = []
        add(indexes, blockIndex)
        let peerId = peers[(objectIndex + blockIndex) % peers.len]
        let payload = blocks[blockIndex]
        let key = "moqdrop-" + bundleCid + "-o" + strings.IntToStr(objectIndex) + "-s" + strings.IntToStr(blockIndex)
        let droplet = V3MobileMoqDroplet(
            objectIndex: objectIndex,
            dropletIndex: blockIndex,
            kindCode: v3MobileMoqDropletKindSource,
            key: key,
            peerId: peerId,
            cid: v3MobileCapiSha256HexBytes(payload),
            degree: 1,
            blockIndexes: indexes,
            payload: payload
        )
        add(objectDroplets, droplet)
        blockIndex = blockIndex + 1
    v3MobileCapiEmitLog("mobile_moq:build_object_after_source_droplets")
    var repairIndex: int32
    while repairIndex < repairDropletCount:
        var degreeBase: int32 = 1
        if sourceBlockCount > 1:
            let seedText = bundleCid + "|o" + strings.IntToStr(objectIndex) + "|r" + strings.IntToStr(repairIndex)
            degreeBase = 2 + v3MobileCapiPositiveMod(v3MobileCapiHashSeed(seedText), sourceBlockCount - 1)
        let repairSeed = bundleCid + "|repair|" + strings.IntToStr(objectIndex) + "|" + strings.IntToStr(repairIndex)
        let blockIndexes = v3MobileCapiChooseUniqueBlockIndexes(
            sourceBlockCount,
            degreeBase,
            repairSeed
        )
        var payload = bytesAlloc(sourceBlockBytes)
        var blockPick: int32
        while blockPick < blockIndexes.len:
            let xorOk = v3MobileCapiXorInto(payload, blocks[blockIndexes[blockPick]])
            if IsErr(xorOk):
                return Err[V3MobileMoqObject](Error(xorOk))
            blockPick = blockPick + 1
        let dropletIndex = sourceBlockCount + repairIndex
        let peerId = peers[(objectIndex + dropletIndex) % peers.len]
        let key = "moqdrop-" + bundleCid + "-o" + strings.IntToStr(objectIndex) + "-r" + strings.IntToStr(repairIndex)
        let droplet = V3MobileMoqDroplet(
            objectIndex: objectIndex,
            dropletIndex: dropletIndex,
            kindCode: v3MobileMoqDropletKindRepair,
            key: key,
            peerId: peerId,
            cid: v3MobileCapiSha256HexBytes(payload),
            degree: blockIndexes.len,
            blockIndexes: blockIndexes,
            payload: payload
        )
        add(objectDroplets, droplet)
        repairIndex = repairIndex + 1
    v3MobileCapiEmitLog("mobile_moq:build_object_after_repair_droplets")
    let objectOut = V3MobileMoqObject(
        objectIndex: objectIndex,
        groupId: bundleCid,
        objectId: "object-" + strings.IntToStr(objectIndex),
        priority: objectIndex,
        byteOffset: byteOffset,
        byteLength: objectByteLen,
        objectCid: objectCid,
        sourceBlockBytes: sourceBlockBytes,
        sourceBlockCount: sourceBlockCount,
        repairDropletCount: repairDropletCount,
        droplets: objectDroplets
    )
    v3MobileCapiEmitLog("mobile_moq:build_object_ok")
    return Ok[V3MobileMoqObject](objectOut)

fn v3MobileCapiNextSeed(state0: int32): int32 =
    var state = state0
    if state == 0:
        state = 1
    state = state ^ (state << 13)
    state = state ^ (state >> 17)
    state = state ^ (state << 5)
    if state == 0:
        return 1
    return state

fn v3MobileCapiPositiveMod(value: int32, modBy: int32): int32 =
    if modBy <= 0:
        return 0
    let normalized = int64(value & 2147483647)
    return int32(normalized % int64(modBy))

fn v3MobileCapiChooseUniqueBlockIndexes(blockCount: int32, degree0: int32, seedText: str): int32[] =
    var out: int32[]
    out = []
    if blockCount <= 0:
        return out
    let degree = v3MobileCapiMinInt32(blockCount, v3MobileCapiMaxInt32(1, degree0))
    var seed = v3MobileCapiHashSeed(seedText)
    while out.len < degree:
        seed = v3MobileCapiNextSeed(seed)
        let candidate = v3MobileCapiPositiveMod(seed, blockCount)
        if !v3MobileCapiContainsInt(out, candidate):
            add(out, candidate)
    return v3MobileCapiSortInts(out)

fn v3MobileCapiPadBlock(data: Bytes, blockBytes: int32): Bytes =
    if bytesLen(data) == blockBytes:
        return bytesSlice(data, 0, bytesLen(data))
    var out = bytesAlloc(blockBytes)
    let copyLen = v3MobileCapiMinInt32(bytesLen(data), blockBytes)
    for i in 0..<copyLen:
        bytesSet(out, i, bytesGet(data, i))
    return out

fn v3MobileCapiXorInto(target: var Bytes, source: Bytes): Result[bool] =
    if bytesLen(target) != bytesLen(source):
        return Err[bool]("v3 mobile capi: xor length mismatch")
    for i in 0..<bytesLen(target):
        bytesSet(target, i, bytesGet(target, i) ^ bytesGet(source, i))
    return Ok[bool](true)

fn v3MobileCapiXorBytes(left: Bytes, right: Bytes): Result[Bytes] =
    if bytesLen(left) != bytesLen(right):
        return Err[Bytes]("v3 mobile capi: xor length mismatch")
    var out = bytesAlloc(bytesLen(left))
    for i in 0..<bytesLen(left):
        bytesSet(out, i, bytesGet(left, i) ^ bytesGet(right, i))
    return Ok[Bytes](out)

fn v3MobileCapiMoqBuildCatalogJson(ownerPeerId: str,
                                   mimeType: str,
                                   blobCid: str,
                                   blobByteLen: int32,
                                   bundleCid: str,
                                   objectTargetBytes: int32,
                                   sourceBlockBytes: int32,
                                   objects: V3MobileMoqObject[]): str =
    var objectRows: str[]
    objectRows = []
    var objectIndex: int32
    while objectIndex < objects.len:
        add(objectRows, v3MobileCapiMoqObjectJson(objects[objectIndex]))
        objectIndex = objectIndex + 1
    var rows: str[]
    rows = []
    add(rows, "\"magic\":\"unimaker.moq.fountain.catalog.v1\"")
    add(rows, "\"version\":1")
    add(rows, "\"transport\":\"native_media_rpc\"")
    add(rows, "\"fountainLayout\":\"lt_xor_v1\"")
    add(rows, Fmt(["\"ownerPeerId\":", v3MobileCapiJsonQuote(ownerPeerId)]))
    add(rows, Fmt(["\"mimeType\":", v3MobileCapiJsonQuote(mimeType)]))
    add(rows, Fmt(["\"blobCid\":", v3MobileCapiJsonQuote(blobCid)]))
    add(rows, Fmt(["\"blobByteLen\":", strings.IntToStr(blobByteLen)]))
    add(rows, Fmt(["\"trackId\":", v3MobileCapiJsonQuote("track:" + bundleCid)]))
    add(rows, Fmt(["\"bundleCid\":", v3MobileCapiJsonQuote(bundleCid)]))
    add(rows, Fmt(["\"objectTargetBytes\":", strings.IntToStr(objectTargetBytes)]))
    add(rows, Fmt(["\"sourceBlockBytes\":", strings.IntToStr(sourceBlockBytes)]))
    add(rows, Fmt(["\"objectCount\":", strings.IntToStr(objects.len)]))
    add(rows, Fmt(["\"objects\":[", strutils.Join(objectRows, ","), "]"]))
    return Fmt(["{", strutils.Join(rows, ","), "}"])

fn v3MobileCapiMoqBuildBundleSeed(ownerPeerId: str,
                                  blobCid: str,
                                  mimeType: str,
                                  peers: str[],
                                  objectTargetBytes: int32,
                                  sourceBlockBytes: int32,
                                  repairDropletCount: int32): str =
    return ownerPeerId + "|" +
        blobCid + "|" +
        mimeType + "|" +
        v3MobileCapiJoinCsv(peers) + "|" +
        strings.IntToStr(objectTargetBytes) + "|" +
        strings.IntToStr(sourceBlockBytes) + "|" +
        strings.IntToStr(repairDropletCount)

fn v3MobileCapiMoqRebuildTemplateWire(objects: V3MobileMoqObject[],
                                      droplets: V3MobileMoqDroplet[],
                                      blobCid: str,
                                      blobByteLen: int32): str =
    var rows: str[]
    rows = []
    add(rows, v3MobileCapiWireRow("blob_cid", blobCid))
    add(rows, v3MobileCapiWireRowInt("blob_byte_len", blobByteLen))
    add(rows, v3MobileCapiWireRowInt("object_count", objects.len))
    add(rows, v3MobileCapiWireRowInt("droplet_count", droplets.len))
    var objectRow: int32
    while objectRow < objects.len:
        let item = objects[objectRow]
        let prefix = "object." + strings.IntToStr(objectRow) + "."
        add(rows, v3MobileCapiWireRowInt(prefix + "object_index", item.objectIndex))
        add(rows, v3MobileCapiWireRowInt(prefix + "byte_length", item.byteLength))
        add(rows, v3MobileCapiWireRowInt(prefix + "source_block_bytes", item.sourceBlockBytes))
        add(rows, v3MobileCapiWireRowInt(prefix + "source_block_count", item.sourceBlockCount))
        add(rows, v3MobileCapiWireRow(prefix + "object_cid", item.objectCid))
        objectRow = objectRow + 1
    var dropletRow: int32
    while dropletRow < droplets.len:
        let item = droplets[dropletRow]
        let prefix = "droplet." + strings.IntToStr(dropletRow) + "."
        add(rows, v3MobileCapiWireRowInt(prefix + "object_index", item.objectIndex))
        add(rows, v3MobileCapiWireRowInt(prefix + "droplet_index", item.dropletIndex))
        add(rows, v3MobileCapiWireRow(prefix + "key", item.key))
        add(rows, v3MobileCapiWireRow(prefix + "peer_id", item.peerId))
        add(rows, v3MobileCapiWireRow(prefix + "cid", item.cid))
        add(rows, v3MobileCapiWireRow(prefix + "block_indexes", v3MobileCapiJoinIntCsv(item.blockIndexes)))
        dropletRow = dropletRow + 1
    return v3MobileCapiWireRowsText(rows)

fn v3MobileCapiMoqBuildResultToWire(result: V3MobileMoqBuildResult): str =
    var rows: str[]
    rows = []
    add(rows, v3MobileCapiWireRow("ok", "1"))
    add(rows, v3MobileCapiWireRow("owner_peer_id", result.ownerPeerId))
    add(rows, v3MobileCapiWireRow("mime_type", result.mimeType))
    add(rows, v3MobileCapiWireRow("bundle_cid", result.bundleCid))
    add(rows, v3MobileCapiWireRow("blob_cid", result.blobCid))
    add(rows, v3MobileCapiWireRow("catalog_key", result.catalogKey))
    add(rows, v3MobileCapiWireRow("catalog_cid", result.catalogCid))
    add(rows, v3MobileCapiWireRowInt("catalog_size_bytes", result.catalogSizeBytes))
    add(rows, v3MobileCapiWireRow("catalog_payload_hex", bytesToHex(result.catalogPayload)))
    add(rows, v3MobileCapiWireRow("rebuild_template_key", result.rebuildTemplateKey))
    add(rows, v3MobileCapiWireRow("rebuild_template_cid", result.rebuildTemplateCid))
    add(rows, v3MobileCapiWireRowInt("rebuild_template_size_bytes", result.rebuildTemplateSizeBytes))
    add(rows, v3MobileCapiWireRow("rebuild_template_payload_hex", bytesToHex(result.rebuildTemplatePayload)))
    add(rows, v3MobileCapiWireRowInt("blob_byte_len", result.blobByteLen))
    add(rows, v3MobileCapiWireRowInt("object_target_bytes", result.objectTargetBytes))
    add(rows, v3MobileCapiWireRowInt("source_block_bytes", result.sourceBlockBytes))
    add(rows, v3MobileCapiWireRowInt("object_count", result.objectCount))
    add(rows, v3MobileCapiWireRow("remote_ack_peer_ids", v3MobileCapiJoinCsv(result.remoteAckPeerIds)))
    var objectRow: int32
    while objectRow < result.objects.len:
        let item = result.objects[objectRow]
        let prefix = "object." + strings.IntToStr(objectRow) + "."
        add(rows, v3MobileCapiWireRowInt(prefix + "object_index", item.objectIndex))
        add(rows, v3MobileCapiWireRow(prefix + "group_id", item.groupId))
        add(rows, v3MobileCapiWireRow(prefix + "object_id", item.objectId))
        add(rows, v3MobileCapiWireRowInt(prefix + "priority", item.priority))
        add(rows, v3MobileCapiWireRowInt(prefix + "byte_offset", item.byteOffset))
        add(rows, v3MobileCapiWireRowInt(prefix + "byte_length", item.byteLength))
        add(rows, v3MobileCapiWireRow(prefix + "object_cid", item.objectCid))
        add(rows, v3MobileCapiWireRowInt(prefix + "source_block_bytes", item.sourceBlockBytes))
        add(rows, v3MobileCapiWireRowInt(prefix + "source_block_count", item.sourceBlockCount))
        add(rows, v3MobileCapiWireRowInt(prefix + "repair_droplet_count", item.repairDropletCount))
        objectRow = objectRow + 1
    add(rows, v3MobileCapiWireRowInt("droplet_count", result.droplets.len))
    var dropletRow: int32
    while dropletRow < result.droplets.len:
        let item = result.droplets[dropletRow]
        let prefix = "droplet." + strings.IntToStr(dropletRow) + "."
        add(rows, v3MobileCapiWireRowInt(prefix + "object_index", item.objectIndex))
        add(rows, v3MobileCapiWireRowInt(prefix + "droplet_index", item.dropletIndex))
        add(rows, v3MobileCapiWireRow(prefix + "kind", v3MobileCapiMoqDropletKindText(item.kindCode)))
        add(rows, v3MobileCapiWireRow(prefix + "key", item.key))
        add(rows, v3MobileCapiWireRow(prefix + "peer_id", item.peerId))
        add(rows, v3MobileCapiWireRow(prefix + "cid", item.cid))
        add(rows, v3MobileCapiWireRowInt(prefix + "degree", item.degree))
        add(rows, v3MobileCapiWireRow(prefix + "block_indexes", v3MobileCapiJoinIntCsv(item.blockIndexes)))
        add(rows, v3MobileCapiWireRow(prefix + "payload_hex", bytesToHex(item.payload)))
        dropletRow = dropletRow + 1
    return v3MobileCapiWireRowsText(rows)

fn v3MobileCapiMoqDropletFromCore(item: moq.V3Libp2pMoqDroplet): V3MobileMoqDroplet =
    return V3MobileMoqDroplet(
        objectIndex: item.objectIndex,
        dropletIndex: item.dropletIndex,
        kindCode: item.kindCode,
        key: item.key,
        peerId: item.peerId,
        cid: item.cid,
        degree: item.degree,
        blockIndexes: item.blockIndexes,
        payload: item.payload
    )

fn v3MobileCapiMoqObjectFromCore(item: moq.V3Libp2pMoqObject): V3MobileMoqObject =
    var objectDroplets: V3MobileMoqDroplet[]
    objectDroplets = []
    var idx: int32
    while idx < item.droplets.len:
        add(objectDroplets, v3MobileCapiMoqDropletFromCore(item.droplets[idx]))
        idx = idx + 1
    return V3MobileMoqObject(
        objectIndex: item.objectIndex,
        groupId: item.groupId,
        objectId: item.objectId,
        priority: item.priority,
        byteOffset: item.byteOffset,
        byteLength: item.byteLength,
        objectCid: item.objectCid,
        sourceBlockBytes: item.sourceBlockBytes,
        sourceBlockCount: item.sourceBlockCount,
        repairDropletCount: item.repairDropletCount,
        droplets: objectDroplets
    )

fn v3MobileCapiMoqBuildResultFromCore(item: moq.V3Libp2pMoqBuildResult): V3MobileMoqBuildResult =
    var objects: V3MobileMoqObject[]
    objects = []
    var objectIdx: int32
    while objectIdx < item.objects.len:
        add(objects, v3MobileCapiMoqObjectFromCore(item.objects[objectIdx]))
        objectIdx = objectIdx + 1
    var droplets: V3MobileMoqDroplet[]
    droplets = []
    var dropletIdx: int32
    while dropletIdx < item.droplets.len:
        add(droplets, v3MobileCapiMoqDropletFromCore(item.droplets[dropletIdx]))
        dropletIdx = dropletIdx + 1
    return V3MobileMoqBuildResult(
        ownerPeerId: item.ownerPeerId,
        mimeType: item.mimeType,
        bundleCid: item.bundleCid,
        blobCid: item.blobCid,
        catalogKey: item.catalogKey,
        catalogCid: item.catalogCid,
        catalogSizeBytes: item.catalogSizeBytes,
        catalogPayload: item.catalogPayload,
        rebuildTemplateKey: item.rebuildTemplateKey,
        rebuildTemplateCid: item.rebuildTemplateCid,
        rebuildTemplateSizeBytes: item.rebuildTemplateSizeBytes,
        rebuildTemplatePayload: item.rebuildTemplatePayload,
        blobByteLen: item.blobByteLen,
        objectTargetBytes: item.objectTargetBytes,
        sourceBlockBytes: item.sourceBlockBytes,
        objectCount: item.objectCount,
        remoteAckPeerIds: item.remoteAckPeerIds,
        objects: objects,
        droplets: droplets
    )

fn v3MobileCapiMoqSourceDropletKey(bundleCid: str, objectIndex: int32, dropletIndex: int32): str =
    return Fmt(["moqdrop-",
                bundleCid,
                "-o",
                strings.IntToStr(objectIndex),
                "-s",
                strings.IntToStr(dropletIndex)])

fn v3MobileCapiMoqRepairDropletKey(bundleCid: str, objectIndex: int32, repairIndex: int32): str =
    return Fmt(["moqdrop-",
                bundleCid,
                "-o",
                strings.IntToStr(objectIndex),
                "-r",
                strings.IntToStr(repairIndex)])

fn v3MobileCapiMoqHydratedCoreResult(base: V3MobileMoqBuildResult,
                                     blobBytes: Bytes,
                                     ownerPeerId: str,
                                     remotePeersCsv: str,
                                     mimeType0: str,
                                     objectTargetBytes0: int32,
                                     sourceBlockBytes0: int32,
                                     repairDropletCount0: int32): Result[V3MobileMoqBuildResult] =
    let peers = v3MobileCapiNormalizePeerCsv(remotePeersCsv)
    if peers.len <= 0:
        return Err[V3MobileMoqBuildResult]("video_publish_insufficient_storage_peers")
    let mimeType = if len(mimeType0) > 0: mimeType0 else: "video/mp4"
    let objectTargetBytes = v3MobileCapiNormalizePositiveInt(objectTargetBytes0, 512 * 1024)
    let sourceBlockBytes = v3MobileCapiNormalizePositiveInt(sourceBlockBytes0, 128 * 1024)
    let repairDropletCount = v3MobileCapiNormalizePositiveInt(repairDropletCount0, 2)
    let blobCid = v3MobileCapiSha256HexBytes(blobBytes)
    let bundleSeed = v3MobileCapiMoqBuildBundleSeed(ownerPeerId,
                                                    blobCid,
                                                    mimeType,
                                                    peers,
                                                    objectTargetBytes,
                                                    sourceBlockBytes,
                                                    repairDropletCount)
    if len(bundleSeed) <= 0:
        return Err[V3MobileMoqBuildResult]("moq_fountain_empty_bundle_seed")
    let bundleCid = v3MobileCapiSha256HexText(bundleSeed)
    if len(bundleCid) <= 0:
        return Err[V3MobileMoqBuildResult]("moq_fountain_empty_bundle_cid")

    var out = base
    out.ownerPeerId = ownerPeerId
    out.mimeType = mimeType
    out.blobCid = blobCid
    out.bundleCid = bundleCid
    out.blobByteLen = bytesLen(blobBytes)
    out.objectTargetBytes = objectTargetBytes
    out.sourceBlockBytes = sourceBlockBytes
    out.objectCount = out.objects.len
    out.remoteAckPeerIds = peers

    var objectRow: int32
    while objectRow < out.objects.len:
        out.objects[objectRow].groupId = bundleCid
        out.objects[objectRow].objectId = Fmt(["object-", strings.IntToStr(out.objects[objectRow].objectIndex)])
        objectRow = objectRow + 1

    var dropletRow: int32
    while dropletRow < out.droplets.len:
        let objectIndex = out.droplets[dropletRow].objectIndex
        var sourceBlockCount: int32
        var peerId = ""
        var findIdx: int32
        while findIdx < out.objects.len:
            if out.objects[findIdx].objectIndex == objectIndex:
                sourceBlockCount = out.objects[findIdx].sourceBlockCount
                break
            findIdx = findIdx + 1
        let peerSlot = (objectIndex + out.droplets[dropletRow].dropletIndex) % peers.len
        peerId = peers[peerSlot]
        out.droplets[dropletRow].peerId = peerId
        out.droplets[dropletRow].cid = v3MobileCapiSha256HexBytes(out.droplets[dropletRow].payload)
        if out.droplets[dropletRow].kindCode == v3MobileMoqDropletKindSource:
            out.droplets[dropletRow].key = v3MobileCapiMoqSourceDropletKey(bundleCid,
                                                                            objectIndex,
                                                                            out.droplets[dropletRow].dropletIndex)
        else:
            let repairIndex = out.droplets[dropletRow].dropletIndex - sourceBlockCount
            out.droplets[dropletRow].key = v3MobileCapiMoqRepairDropletKey(bundleCid,
                                                                            objectIndex,
                                                                            repairIndex)
        dropletRow = dropletRow + 1

    let catalogText = v3MobileCapiMoqBuildCatalogJson(ownerPeerId,
                                                      mimeType,
                                                      blobCid,
                                                      bytesLen(blobBytes),
                                                      bundleCid,
                                                      objectTargetBytes,
                                                      sourceBlockBytes,
                                                      out.objects)
    let catalogPayload = bytesFromString(catalogText)
    if bytesLen(catalogPayload) <= 0:
        return Err[V3MobileMoqBuildResult]("moq_fountain_empty_catalog_payload")
    out.catalogKey = Fmt(["moqcatalog-", bundleCid])
    out.catalogCid = v3MobileCapiSha256HexBytes(catalogPayload)
    out.catalogSizeBytes = bytesLen(catalogPayload)
    out.catalogPayload = catalogPayload

    let rebuildTemplateText = v3MobileCapiMoqRebuildTemplateWire(out.objects,
                                                                 out.droplets,
                                                                 blobCid,
                                                                 bytesLen(blobBytes))
    let rebuildTemplatePayload = bytesFromString(rebuildTemplateText)
    if bytesLen(rebuildTemplatePayload) <= 0:
        return Err[V3MobileMoqBuildResult]("moq_fountain_empty_rebuild_template")
    out.rebuildTemplateKey = Fmt(["moqrebuild-", bundleCid])
    out.rebuildTemplateCid = v3MobileCapiSha256HexBytes(rebuildTemplatePayload)
    out.rebuildTemplateSizeBytes = bytesLen(rebuildTemplatePayload)
    out.rebuildTemplatePayload = rebuildTemplatePayload
    return Ok[V3MobileMoqBuildResult](out)

fn v3MobileCapiMoqBuildPersistDirect(blobBytes: Bytes,
                                     ownerPeerId: str,
                                     remotePeersCsv: str,
                                     mimeType0: str,
                                     objectTargetBytes0: int32,
                                     sourceBlockBytes0: int32,
                                     repairDropletCount0: int32,
                                     outputDir: str,
                                     fileNameStem: str): Result[str] =
    v3MobileCapiEmitLog("mobile_moq:persist_direct_enter")
    if bytesLen(blobBytes) <= 0:
        return Err[str]("moq_fountain_empty_blob")
    if len(outputDir) <= 0:
        return Err[str]("moq_fountain_missing_output_dir")
    if len(fileNameStem) <= 0:
        return Err[str]("moq_fountain_missing_file_stem")
    let buildResolvedRes = v3MobileCapiMoqBuildResolved(blobBytes,
                                                        ownerPeerId,
                                                        remotePeersCsv,
                                                        mimeType0,
                                                        objectTargetBytes0,
                                                        sourceBlockBytes0,
                                                        repairDropletCount0,
                                                        "")
    v3MobileCapiEmitLog("mobile_moq:persist_direct_after_resolved")
    if IsErr(buildResolvedRes):
        return Err[str](Error(buildResolvedRes))
    let wireRes = v3MobileCapiMoqBuildPersistWire(Value(buildResolvedRes), outputDir, fileNameStem)
    if IsErr(wireRes):
        return Err[str](Error(wireRes))
    v3MobileCapiEmitLog("mobile_moq:persist_direct_ok")
    return wireRes

fn v3MobileCapiMoqBuildResolved(blobBytes: Bytes,
                                ownerPeerId: str,
                                remotePeersCsv: str,
                                mimeType0: str,
                                objectTargetBytes0: int32,
                                sourceBlockBytes0: int32,
                                repairDropletCount0: int32,
                                tracePath: str): Result[V3MobileMoqBuildResult] =
    v3MobileCapiEmitLog("mobile_moq:build_enter")
    let traceEnabled = len(tracePath) > 0
    if traceEnabled:
        v3MobileCapiMaybeWriteTraceLine(tracePath, "build:enter")
        v3MobileCapiMaybeWriteTraceLine(tracePath, "build:blob_len=" + strings.IntToStr(bytesLen(blobBytes)))
    if bytesLen(blobBytes) <= 0:
        if traceEnabled:
            v3MobileCapiMaybeWriteTraceLine(tracePath, "build:error=moq_fountain_empty_blob")
        return Err[V3MobileMoqBuildResult]("moq_fountain_empty_blob")
    v3MobileCapiEmitLog("mobile_moq:build_before_core")
    if traceEnabled:
        moq.v3Libp2pMoqSetTracePath(tracePath)
    let buildRes = moq.v3Libp2pMoqBuild(blobBytes,
                                        ownerPeerId,
                                        remotePeersCsv,
                                        mimeType0,
                                        objectTargetBytes0,
                                        sourceBlockBytes0,
                                        repairDropletCount0)
    if traceEnabled:
        moq.v3Libp2pMoqClearTracePath()
    v3MobileCapiEmitLog("mobile_moq:build_after_core")
    if IsErr(buildRes):
        if traceEnabled:
            v3MobileCapiMaybeWriteTraceLine(tracePath, "build:error=" + Error(buildRes))
        return Err[V3MobileMoqBuildResult](Error(buildRes))
    let hydrateRes = v3MobileCapiMoqHydratedCoreResult(v3MobileCapiMoqBuildResultFromCore(Value(buildRes)),
                                                       blobBytes,
                                                       ownerPeerId,
                                                       remotePeersCsv,
                                                       mimeType0,
                                                       objectTargetBytes0,
                                                       sourceBlockBytes0,
                                                       repairDropletCount0)
    if IsErr(hydrateRes):
        if traceEnabled:
            v3MobileCapiMaybeWriteTraceLine(tracePath, "build:error=" + Error(hydrateRes))
        return Err[V3MobileMoqBuildResult](Error(hydrateRes))
    let out = Value(hydrateRes)
    v3MobileCapiEmitLog("mobile_moq:build_ok")
    if traceEnabled:
        v3MobileCapiMaybeWriteTraceLine(tracePath, "build:blob_cid=" + out.blobCid)
        v3MobileCapiMaybeWriteTraceLine(tracePath, "build:bundle_cid=" + out.bundleCid)
        v3MobileCapiMaybeWriteTraceLine(tracePath,
                                        "build:objects_done count=" + strings.IntToStr(out.objects.len) +
                                            " droplets=" + strings.IntToStr(out.droplets.len))
        v3MobileCapiMaybeWriteTraceLine(tracePath, "build:catalog_bytes=" + strings.IntToStr(bytesLen(out.catalogPayload)))
        v3MobileCapiMaybeWriteTraceLine(tracePath, "build:rebuild_template_bytes=" + strings.IntToStr(bytesLen(out.rebuildTemplatePayload)))
        v3MobileCapiMaybeWriteTraceLine(tracePath, "build:ok")
    return Ok[V3MobileMoqBuildResult](out)

