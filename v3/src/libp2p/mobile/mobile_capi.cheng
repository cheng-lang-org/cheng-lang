                                   requestId: str,
                                   feature32Hex: str,
                                   deviceBindingSeed: str,
                                   deviceLabel: str,
                                   sensorId: str,
                                   hardwareAttestation: str): ptr =
    let out = v3MobileCapiBioDidImport(latestBundleText,
                                       requestId,
                                       feature32Hex,
                                       deviceBindingSeed,
                                       deviceLabel,
                                       sensorId,
                                       hardwareAttestation)
    let ctext = v3MobileCapiTextCString(out)
    return ctext

