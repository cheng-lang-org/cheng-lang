    v3MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_mime_type")
    if IsErr(mimeTypeRes):
        return v3MobileCapiTextBufferHandle(v3MobileCapiMoqError(Error(mimeTypeRes)))
    let objectTargetBytesRes = moq.v3Libp2pMoqParseInt32Wire(requestWire, "object_target_bytes")
    v3MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_object_target_bytes")
    if IsErr(objectTargetBytesRes):
        return v3MobileCapiTextBufferHandle(v3MobileCapiMoqError(Error(objectTargetBytesRes)))
    let sourceBlockBytesRes = moq.v3Libp2pMoqParseInt32Wire(requestWire, "source_block_bytes")
    v3MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_source_block_bytes")
    if IsErr(sourceBlockBytesRes):
        return v3MobileCapiTextBufferHandle(v3MobileCapiMoqError(Error(sourceBlockBytesRes)))
    let repairDropletCountRes = moq.v3Libp2pMoqParseInt32Wire(requestWire, "repair_droplet_count")
    v3MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_repair_droplet_count")
    if IsErr(repairDropletCountRes):
        return v3MobileCapiTextBufferHandle(v3MobileCapiMoqError(Error(repairDropletCountRes)))
    let outputDirRes = moq.v3Libp2pMoqWireFindValue(requestWire, "output_dir")
    v3MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_output_dir")
    if IsErr(outputDirRes):
        return v3MobileCapiTextBufferHandle(v3MobileCapiMoqError(Error(outputDirRes)))
    let fileNameStemRes = moq.v3Libp2pMoqWireFindValue(requestWire, "file_name_stem")
    v3MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_file_name_stem")
    if IsErr(fileNameStemRes):
        return v3MobileCapiTextBufferHandle(v3MobileCapiMoqError(Error(fileNameStemRes)))
    v3MobileCapiEmitLog("mobile_moq:build_persist_request_handle_before_build_call")
    let persistRes = v3MobileCapiMoqBuildPersistDirect(bytesView(blobPtr, blobLen),
                                                       Value(ownerPeerIdRes),
                                                       Value(remotePeersCsvRes),
                                                       Value(mimeTypeRes),
                                                       Value(objectTargetBytesRes),
                                                       Value(sourceBlockBytesRes),
                                                       Value(repairDropletCountRes),
                                                       Value(outputDirRes),
                                                       Value(fileNameStemRes))
    v3MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_build_call")
    if IsErr(persistRes):
        return v3MobileCapiTextBufferHandle(v3MobileCapiMoqError(Error(persistRes)))
    v3MobileCapiEmitLog("mobile_moq:build_persist_request_handle_after_persist_wire")
    v3MobileCapiEmitLog("mobile_moq:build_persist_request_handle_before_result_handle")
    return v3MobileCapiTextBufferHandle(Value(persistRes))

