import std/result
import cheng/v3/libp2p/identity/did
import cheng/v3/libp2p/mobile/android_bridge as bridge

type
    V3MobileSdk =
        host: bridge.V3MobileHost

fn v3MobileSdkInit(seed: str): V3MobileSdk =
    var out: V3MobileSdk
    out.host = bridge.v3MobileHostInit(seed)
    return out

fn v3MobileSdkInitWithDid(identity: did.V3DidIdentity): V3MobileSdk =
    var out: V3MobileSdk
    out.host = bridge.v3MobileHostInitWithDid(identity)
    return out

fn v3MobileSdkInitWithDidStore(identityStorePath: str,
                               rootSeedHint: str,
                               deviceSeedHint: str,
                               deviceLabelHint: str,
                               epochSeconds: int64): Result[V3MobileSdk] =
    var out: V3MobileSdk
    let initRes = v3MobileSdkInitWithDidStoreFill(out,
                                                  identityStorePath,
                                                  rootSeedHint,
                                                  deviceSeedHint,
                                                  deviceLabelHint,
                                                  epochSeconds)
    if IsErr(initRes):
        return Err[V3MobileSdk](Error(initRes))
    return Ok[V3MobileSdk](out)

fn v3MobileSdkInitWithDidStoreFill(out: var V3MobileSdk,
                                   identityStorePath: str,
                                   rootSeedHint: str,
                                   deviceSeedHint: str,
                                   deviceLabelHint: str,
                                   epochSeconds: int64): Result[bool] =
    var hostValue = bridge.v3MobileHostInit("")
    let hostRes = bridge.v3MobileHostInitWithDidStoreFill(hostValue,
                                                          identityStorePath,
                                                          rootSeedHint,
                                                          deviceSeedHint,
                                                          deviceLabelHint,
                                                          epochSeconds)
    if IsErr(hostRes):
        return Err[bool](Error(hostRes))
    out.host = hostValue
    return Ok[bool](true)

fn v3MobileSdkStart(sdk: var V3MobileSdk) =
    var hostInst = sdk.host
    bridge.v3MobileHostStart(hostInst)
    sdk.host = hostInst

fn v3MobileSdkStop(sdk: var V3MobileSdk) =
    var hostInst = sdk.host
    bridge.v3MobileHostStop(hostInst)
    sdk.host = hostInst

fn v3MobileSdkStarted(sdk: V3MobileSdk): bool =
    return bridge.v3MobileHostIsStarted(sdk.host)

fn v3MobileSdkSelfPeerText(sdk: V3MobileSdk): str =
    return bridge.v3MobileHostPeerIdText(sdk.host)

fn v3MobileSdkDidText(sdk: V3MobileSdk): str =
    return bridge.v3MobileHostDidText(sdk.host)

fn v3MobileSdkSaveDidIdentity(identityStorePath: str,
                              sdk: V3MobileSdk): Result[bool] =
    return bridge.v3MobileHostSaveDidIdentity(identityStorePath, sdk.host)

fn v3MobileSdkSetMdns(sdk: var V3MobileSdk,
                      enabled: bool,
                      intervalSeconds: int32) =
    var hostInst = sdk.host
    bridge.v3MobileHostSetMdnsEnabled(hostInst, enabled)
    bridge.v3MobileHostSetMdnsInterval(hostInst, intervalSeconds)
    sdk.host = hostInst

fn v3MobileSdkMdnsEnabled(sdk: V3MobileSdk): bool =
    return bridge.v3MobileHostMdnsEnabled(sdk.host)

fn v3MobileSdkMdnsInterval(sdk: V3MobileSdk): int32 =
    return bridge.v3MobileHostMdnsInterval(sdk.host)

fn v3MobileSdkSetTrustedInfra(sdk: var V3MobileSdk,
                              trusted: bool) =
    var hostInst = sdk.host
    bridge.v3MobileHostSetTrustedInfra(hostInst, trusted)
    sdk.host = hostInst

fn v3MobileSdkTrustedInfra(sdk: V3MobileSdk): bool =
    return bridge.v3MobileHostTrustedInfra(sdk.host)

fn v3MobileSdkListen(sdk: var V3MobileSdk,
                     addrText: str): Result[bool] =
    var hostInst = sdk.host
    let res = bridge.v3MobileHostListenAddText(hostInst, addrText)
    sdk.host = hostInst
    return res

fn v3MobileSdkListenCount(sdk: V3MobileSdk): int32 =
    return bridge.v3MobileHostListenAddrCount(sdk.host)

fn v3MobileSdkListenDialableAddrTextAt(sdk: V3MobileSdk,
                                       index: int32): str =
    return bridge.v3MobileHostDialableAddrTextAt(sdk.host, index)

fn v3MobileSdkAddBootstrapPeer(sdk: var V3MobileSdk,
                               peerText: str,
                               addrText: str): Result[bool] =
    var hostInst = sdk.host
    let res = bridge.v3MobileHostRegisterPeerHintText(hostInst,
                                                      peerText,
                                                      addrText,
                                                      0,
                                                      true,
                                                      true)
    sdk.host = hostInst
    return res

fn v3MobileSdkConnectRegistered(sdk: var V3MobileSdk,
                                peerText: str): Result[bool] =
    var hostInst = sdk.host
    let res = bridge.v3MobileHostConnectRegisteredText(hostInst, peerText)
    sdk.host = hostInst
    return res

fn v3MobileSdkConnectPreferred(sdk: var V3MobileSdk,
                               peerText: str,
                               addrText: str): Result[bool] =
    var hostInst = sdk.host
    let res = bridge.v3MobileHostConnectPreferredText(hostInst, peerText, addrText)
    sdk.host = hostInst
    return res

fn v3MobileSdkDisconnectPeer(sdk: var V3MobileSdk,
                             peerText: str): bool =
    var hostInst = sdk.host
    let ok = bridge.v3MobileHostDisconnectText(hostInst, peerText)
    sdk.host = hostInst
    return ok

fn v3MobileSdkReconnectBootstrap(sdk: var V3MobileSdk): int32 =
    var hostInst = sdk.host
    let count = bridge.v3MobileHostReconnectBootstrap(hostInst)
    sdk.host = hostInst
    return count

fn v3MobileSdkPeerCount(sdk: V3MobileSdk): int32 =
    return bridge.v3MobileHostPeerCount(sdk.host)

fn v3MobileSdkConnectedPeerCount(sdk: V3MobileSdk): int32 =
    return bridge.v3MobileHostConnectedPeerCount(sdk.host)

fn v3MobileSdkBootstrapPeerCount(sdk: V3MobileSdk): int32 =
    return bridge.v3MobileHostBootstrapPeerCount(sdk.host)

fn v3MobileSdkPeerConnected(sdk: V3MobileSdk,
                            peerText: str): bool =
    return bridge.v3MobileHostIsPeerConnectedText(sdk.host, peerText)

fn v3MobileSdkPeerDialableAddrTextAt(sdk: V3MobileSdk,
                                     peerText: str,
                                     index: int32): str =
    return bridge.v3MobileHostPeerDialableAddrTextAt(sdk.host, peerText, index)
