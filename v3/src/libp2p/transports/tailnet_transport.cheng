import std/result
import std/strutils as strutil
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr

importc fn cheng_v3_tailnet_provider_open_bridge(providerKindText: str, controlEndpointText: str, relayEndpointText: str, controlProbeEndpointText: str, relayProbeEndpointText: str, derpRegionCodeText: str, derpHostnameText: str): uint64
importc fn cheng_v3_tailnet_provider_command_bridge(handle: uint64, commandText: str): int32
importc fn cheng_v3_tailnet_provider_close_bridge(handle: uint64): int32
importc fn cheng_v3_tailnet_provider_active_count_bridge(): int32
importc fn cheng_v3_tailnet_provider_command_count_bridge(): int32
importc fn cheng_v3_tailnet_provider_probe_provider_ready_bridge(handle: uint64): int32
importc fn cheng_v3_tailnet_provider_probe_proxy_ready_bridge(handle: uint64): int32
importc fn cheng_v3_tailnet_provider_probe_listener_needs_repair_bridge(handle: uint64): int32
importc fn cheng_v3_tailnet_provider_probe_derp_healthy_bridge(handle: uint64): int32
importc fn cheng_v3_tailnet_provider_probe_startup_stage_bridge(handle: uint64): str

const
    v3Libp2pTailnetProviderSynthetic: int32 = 0
    v3Libp2pTailnetProviderHeadscale: int32 = 1

    v3Libp2pTailnetPathIdle: int32 = 0
    v3Libp2pTailnetPathDirect: int32 = 1
    v3Libp2pTailnetPathDerp: int32 = 2
    v3Libp2pTailnetPathDirectPending: int32 = 3
    v3Libp2pTailnetPathRepair: int32 = 4

type
    V3Libp2pTailnetProviderKind = int32
    V3Libp2pTailnetPathKind = int32

type
    V3Libp2pTailnetStatusSnapshot =
        providerKind: str
        controlPlane: str
        exactRouting: bool
        relayHealthy: bool
        providerReady: bool
        proxyListenersReady: bool
        listenerNeedsRepair: bool
        startupStage: str
        publishedCount: int32
        sessionCount: int32
        derpRegionCode: str
        derpHostname: str
        tailnetIPs: str[]
        tailnetPath: str
        tailnetRelay: str
        tailnetDerpMapSummary: str
        tailnetPeers: str[]

    V3Libp2pTailnetTransportConfig =
        providerKind: V3Libp2pTailnetProviderKind
        controlUrl: str
        controlProtocol: str
        controlEndpoint: str
        relayEndpoint: str
        controlProbeEndpoint: str
        relayProbeEndpoint: str
        authKey: str
        hostname: str
        stateDir: str
        wireguardPort: int32
        logLevel: str
        enableDebug: bool
        localPeerId: str
        localListenAddrs: str[]
        headscaleNamespace: str
        headscaleNoisePublicKey: str
        exactRouting: bool
        derpRegionId: int32
        derpRegionCode: str
        derpRegionName: str
        derpHostname: str
        derpStunPort: int32
        syntheticIPv4: str
        syntheticIPv6: str

    V3Libp2pTailnetListenerMapping =
        published: bool
        raw: types.V3Libp2pMultiaddr
        advertised: types.V3Libp2pMultiaddr
        rawText: str
        advertisedText: str

    V3Libp2pTailnetPeerSession =
        peerId: str
        remoteTailnetIp: str
        directReachable: bool
        relayAllowed: bool
        relayOnly: bool
        derpRegionCode: str
        signedPreface: str
        boundAddrText: str
        lastPath: str
        lastError: str

    V3Libp2pTailnetDialPlan =
        peerId: str
        requestedAddr: types.V3Libp2pMultiaddr
        rawAddr: types.V3Libp2pMultiaddr
        publishedAddr: types.V3Libp2pMultiaddr
        pathKind: V3Libp2pTailnetPathKind
        directAllowed: bool
        relayAllowed: bool
        relayOnly: bool
        directOnly: bool
        needsRepair: bool
        reachability: types.V3Libp2pReachabilityKind
        routeText: str

    V3Libp2pTailnetTransport =
        cfg: V3Libp2pTailnetTransportConfig
        runtimeHandle: uint64
        providerReady: bool
        derpHealthy: bool
        proxyListenersReady: bool
        listenerNeedsRepair: bool
        startupStage: str
        listenerMappings: V3Libp2pTailnetListenerMapping[]
        peerSessions: V3Libp2pTailnetPeerSession[]

fn v3Libp2pTailnetProviderKindText(kind: V3Libp2pTailnetProviderKind): str =
    if kind == v3Libp2pTailnetProviderHeadscale:
        return "headscale"
    return "synthetic"

fn v3Libp2pTailnetPathKindText(kind: V3Libp2pTailnetPathKind): str =
    if kind == v3Libp2pTailnetPathDirect:
        return "direct"
    if kind == v3Libp2pTailnetPathDerp:
        return "derp"
    if kind == v3Libp2pTailnetPathDirectPending:
        return "direct-pending"
    if kind == v3Libp2pTailnetPathRepair:
        return "repair"
    return "idle"

fn v3Libp2pTailnetTransportConfigZero(): V3Libp2pTailnetTransportConfig =
    var out: V3Libp2pTailnetTransportConfig
    out.providerKind = v3Libp2pTailnetProviderSynthetic
    out.controlProbeEndpoint = ""
    out.relayProbeEndpoint = ""
    out.localListenAddrs = []
    out.headscaleNamespace = ""
    out.headscaleNoisePublicKey = ""
    out.exactRouting = false
    out.derpRegionId = 0
    out.derpRegionCode = ""
    out.derpRegionName = ""
    out.derpHostname = ""
    out.derpStunPort = 3478
    out.syntheticIPv4 = ""
    out.syntheticIPv6 = ""
    return out

fn v3Libp2pTailnetListenerMappingZero(): V3Libp2pTailnetListenerMapping =
    var out: V3Libp2pTailnetListenerMapping
    out.raw = types.v3Libp2pMultiaddrZero()
    out.advertised = types.v3Libp2pMultiaddrZero()
    out.published = false
    out.rawText = ""
    out.advertisedText = ""
    return out

fn v3Libp2pTailnetPeerSessionZero(): V3Libp2pTailnetPeerSession =
    var out: V3Libp2pTailnetPeerSession
    out.peerId = ""
    out.remoteTailnetIp = ""
    out.directReachable = false
    out.relayAllowed = false
    out.relayOnly = false
    out.derpRegionCode = ""
    out.signedPreface = ""
    out.boundAddrText = ""
    out.lastPath = "idle"
    out.lastError = ""
    return out

fn v3Libp2pTailnetPeerSessionClone(session: V3Libp2pTailnetPeerSession): V3Libp2pTailnetPeerSession =
    var out = v3Libp2pTailnetPeerSessionZero()
    out.peerId = session.peerId
    out.remoteTailnetIp = session.remoteTailnetIp
    out.directReachable = session.directReachable
    out.relayAllowed = session.relayAllowed
    out.relayOnly = session.relayOnly
    out.derpRegionCode = session.derpRegionCode
    out.signedPreface = session.signedPreface
    out.boundAddrText = session.boundAddrText
    out.lastPath = session.lastPath
    out.lastError = session.lastError
    return out

fn v3Libp2pTailnetPeerSessionCount(transport: V3Libp2pTailnetTransport): int32 =
    return transport.peerSessions.len

fn v3Libp2pTailnetSessionBoolText(value: bool): str =
    if value:
        return "1"
    return "0"

fn v3Libp2pTailnetSessionBoolParse(text: str): bool =
    return text == "1" || text == "true"

fn v3Libp2pTailnetPeerSessionEncode(session: V3Libp2pTailnetPeerSession): str =
    var out = session.peerId
    out = out + "\n"
    out = out + session.remoteTailnetIp
    out = out + "\n"
    out = out + v3Libp2pTailnetSessionBoolText(session.directReachable)
    out = out + "\n"
    out = out + v3Libp2pTailnetSessionBoolText(session.relayAllowed)
    out = out + "\n"
    out = out + v3Libp2pTailnetSessionBoolText(session.relayOnly)
    out = out + "\n"
    out = out + session.derpRegionCode
    out = out + "\n"
    out = out + session.signedPreface
    out = out + "\n"
    out = out + session.boundAddrText
    out = out + "\n"
    out = out + session.lastPath
    out = out + "\n"
    out = out + session.lastError
    return out

fn v3Libp2pTailnetPeerSessionDecodeFill(out: var V3Libp2pTailnetPeerSession,
                                        payload: str): bool =
    let parts = strutil.split(payload, '\n')
    if parts.len < 10:
        return false
    out = v3Libp2pTailnetPeerSessionZero()
    out.peerId = parts[0]
    out.remoteTailnetIp = parts[1]
    out.directReachable = v3Libp2pTailnetSessionBoolParse(parts[2])
    out.relayAllowed = v3Libp2pTailnetSessionBoolParse(parts[3])
    out.relayOnly = v3Libp2pTailnetSessionBoolParse(parts[4])
    out.derpRegionCode = parts[5]
    out.signedPreface = parts[6]
    out.boundAddrText = parts[7]
    out.lastPath = parts[8]
    out.lastError = parts[9]
    return true

fn v3Libp2pTailnetPeerSessionHintsFill(payload: str,
                                       remoteTailnetIp: var str,
                                       directReachable: var bool,
                                       relayAllowed: var bool,
                                       relayOnly: var bool,
                                       boundAddrText: var str): bool =
    let parts = strutil.split(payload, '\n')
    if parts.len < 8:
        return false
    remoteTailnetIp = parts[1]
    directReachable = v3Libp2pTailnetSessionBoolParse(parts[2])
    relayAllowed = v3Libp2pTailnetSessionBoolParse(parts[3])
    relayOnly = v3Libp2pTailnetSessionBoolParse(parts[4])
    boundAddrText = parts[7]
    return true

fn v3Libp2pTailnetDialPlanZero(): V3Libp2pTailnetDialPlan =
    var out: V3Libp2pTailnetDialPlan
    out.requestedAddr = types.v3Libp2pMultiaddrZero()
    out.rawAddr = types.v3Libp2pMultiaddrZero()
    out.publishedAddr = types.v3Libp2pMultiaddrZero()
    out.pathKind = v3Libp2pTailnetPathIdle
    out.directAllowed = true
    out.relayAllowed = false
    out.relayOnly = false
    out.directOnly = false
    out.needsRepair = false
    out.reachability = types.v3Libp2pReachabilityUnknown
    out.routeText = ""
    return out

fn v3Libp2pTailnetTransportInit(cfg: V3Libp2pTailnetTransportConfig): V3Libp2pTailnetTransport =
    var out: V3Libp2pTailnetTransport
    out.cfg = cfg
    out.runtimeHandle = uint64(0)
    out.providerReady = false
    out.derpHealthy = false
    out.proxyListenersReady = false
    out.listenerNeedsRepair = false
    out.startupStage = "init"
    out.listenerMappings = []
    out.peerSessions = []
    return out

fn v3Libp2pTailnetSetProviderReady(transport: var V3Libp2pTailnetTransport,
                                   ready: bool,
                                   startupStage: str) =
    transport.providerReady = ready
    if !ready:
        transport.proxyListenersReady = false
    transport.startupStage = startupStage

fn v3Libp2pTailnetSetProxyListenersReady(transport: var V3Libp2pTailnetTransport,
                                         ready: bool,
                                         startupStage: str) =
    transport.proxyListenersReady = ready
    transport.startupStage = startupStage

fn v3Libp2pTailnetSetListenerNeedsRepair(transport: var V3Libp2pTailnetTransport,
                                         needsRepair: bool,
                                         startupStage: str) =
    transport.listenerNeedsRepair = needsRepair
    transport.startupStage = startupStage

fn v3Libp2pTailnetConfigSetHeadscale(cfg: var V3Libp2pTailnetTransportConfig,
                                     namespace: str,
                                     noisePublicKey: str,
                                     regionId: int32,
                                     regionCode: str,
                                     regionName: str,
                                     hostname: str,
                                     exactRouting: bool) =
    cfg.providerKind = v3Libp2pTailnetProviderHeadscale
    cfg.headscaleNamespace = namespace
    cfg.headscaleNoisePublicKey = noisePublicKey
    cfg.derpRegionId = regionId
    cfg.derpRegionCode = regionCode
    cfg.derpRegionName = regionName
    cfg.derpHostname = hostname
    cfg.exactRouting = exactRouting

fn v3Libp2pTailnetConfigSetProbeEndpoints(cfg: var V3Libp2pTailnetTransportConfig,
                                          controlProbeEndpoint: str,
                                          relayProbeEndpoint: str) =
    cfg.controlProbeEndpoint = controlProbeEndpoint
    cfg.relayProbeEndpoint = relayProbeEndpoint

fn v3Libp2pTailnetProviderUsesExactRouting(transport: V3Libp2pTailnetTransport): bool =
    return transport.cfg.exactRouting

fn v3Libp2pTailnetSetDerpHealthy(transport: var V3Libp2pTailnetTransport,
                                 healthy: bool,
                                 startupStage: str) =
    transport.derpHealthy = healthy
    transport.startupStage = startupStage

fn v3Libp2pTailnetProviderRuntimeEnsure(transport: var V3Libp2pTailnetTransport) =
    if transport.runtimeHandle != uint64(0):
        return
    transport.runtimeHandle = cheng_v3_tailnet_provider_open_bridge(v3Libp2pTailnetProviderKindText(transport.cfg.providerKind),
                                                                    transport.cfg.controlEndpoint,
                                                                    transport.cfg.relayEndpoint,
                                                                    transport.cfg.controlProbeEndpoint,
                                                                    transport.cfg.relayProbeEndpoint,
                                                                    transport.cfg.derpRegionCode,
                                                                    transport.cfg.derpHostname)

fn v3Libp2pTailnetProviderRuntimeCommand(transport: var V3Libp2pTailnetTransport,
                                         command: str) =
    v3Libp2pTailnetProviderRuntimeEnsure(transport)
    if transport.runtimeHandle == uint64(0):
        return
    cheng_v3_tailnet_provider_command_bridge(transport.runtimeHandle, command)

fn v3Libp2pTailnetProviderApplyRuntimeState(transport: var V3Libp2pTailnetTransport) =
    transport.providerReady = v3Libp2pTailnetProviderRuntimeReadyNow(transport)
    transport.proxyListenersReady = v3Libp2pTailnetProviderRuntimeProxyReadyNow(transport)
    transport.listenerNeedsRepair = v3Libp2pTailnetProviderRuntimeListenerNeedsRepairNow(transport)
    transport.derpHealthy = v3Libp2pTailnetProviderRuntimeDerpHealthyNow(transport)
    transport.startupStage = v3Libp2pTailnetProviderRuntimeStartupStageNow(transport)

fn v3Libp2pTailnetProviderStart(transport: var V3Libp2pTailnetTransport) =
    v3Libp2pTailnetProviderRuntimeCommand(transport, "provider-start")
    v3Libp2pTailnetProviderApplyRuntimeState(transport)

fn v3Libp2pTailnetProviderMarkProxyReady(transport: var V3Libp2pTailnetTransport) =
    v3Libp2pTailnetProviderRuntimeCommand(transport, "proxy-ready")
    v3Libp2pTailnetProviderApplyRuntimeState(transport)

fn v3Libp2pTailnetProviderMarkListenerRepairNeeded(transport: var V3Libp2pTailnetTransport) =
    v3Libp2pTailnetProviderRuntimeCommand(transport, "repair-needed")
    v3Libp2pTailnetProviderApplyRuntimeState(transport)

fn v3Libp2pTailnetProviderRepairListeners(transport: var V3Libp2pTailnetTransport) =
    v3Libp2pTailnetProviderRuntimeCommand(transport, "repair-listeners")
    v3Libp2pTailnetProviderApplyRuntimeState(transport)

fn v3Libp2pTailnetProviderReconnectDerp(transport: var V3Libp2pTailnetTransport) =
    v3Libp2pTailnetProviderRuntimeCommand(transport, "derp-reconnect")
    v3Libp2pTailnetProviderApplyRuntimeState(transport)

fn v3Libp2pTailnetProviderDerpReady(transport: var V3Libp2pTailnetTransport) =
    v3Libp2pTailnetProviderRuntimeCommand(transport, "derp-ready")
    v3Libp2pTailnetProviderApplyRuntimeState(transport)

fn v3Libp2pTailnetProviderRuntimeActiveCountNow(): int32 =
    return cheng_v3_tailnet_provider_active_count_bridge()

fn v3Libp2pTailnetProviderRuntimeCommandCountNow(): int32 =
    return cheng_v3_tailnet_provider_command_count_bridge()

fn v3Libp2pTailnetProviderRuntimeReadyNow(transport: V3Libp2pTailnetTransport): bool =
    if transport.runtimeHandle == uint64(0):
        return transport.providerReady
    return cheng_v3_tailnet_provider_probe_provider_ready_bridge(transport.runtimeHandle) != 0

fn v3Libp2pTailnetProviderRuntimeProxyReadyNow(transport: V3Libp2pTailnetTransport): bool =
    if transport.runtimeHandle == uint64(0):
        return transport.proxyListenersReady
    return cheng_v3_tailnet_provider_probe_proxy_ready_bridge(transport.runtimeHandle) != 0

fn v3Libp2pTailnetProviderRuntimeListenerNeedsRepairNow(transport: V3Libp2pTailnetTransport): bool =
    if transport.runtimeHandle == uint64(0):
        return transport.listenerNeedsRepair
    return cheng_v3_tailnet_provider_probe_listener_needs_repair_bridge(transport.runtimeHandle) != 0

fn v3Libp2pTailnetProviderRuntimeDerpHealthyNow(transport: V3Libp2pTailnetTransport): bool =
    if transport.runtimeHandle == uint64(0):
        return transport.derpHealthy
    return cheng_v3_tailnet_provider_probe_derp_healthy_bridge(transport.runtimeHandle) != 0

fn v3Libp2pTailnetProviderRuntimeStartupStageNow(transport: V3Libp2pTailnetTransport): str =
    if transport.runtimeHandle == uint64(0):
        return transport.startupStage
    let stage = cheng_v3_tailnet_provider_probe_startup_stage_bridge(transport.runtimeHandle)
    if len(stage) > 0:
        return stage
    return transport.startupStage

fn v3Libp2pTailnetProviderClose(transport: var V3Libp2pTailnetTransport): bool =
    if transport.runtimeHandle == uint64(0):
        transport.providerReady = false
        transport.proxyListenersReady = false
        transport.derpHealthy = false
        transport.listenerNeedsRepair = false
        transport.startupStage = "closed"
        return true
    if cheng_v3_tailnet_provider_close_bridge(transport.runtimeHandle) != 0:
        return false
    transport.runtimeHandle = uint64(0)
    transport.providerReady = false
    transport.proxyListenersReady = false
    transport.derpHealthy = false
    transport.listenerNeedsRepair = false
    transport.startupStage = "closed"
    return true

fn v3Libp2pTailnetPeerSessionAtFill(out: var V3Libp2pTailnetPeerSession,
                                    transport: V3Libp2pTailnetTransport,
                                    pos: int32): bool =
    if pos < 0 || pos >= transport.peerSessions.len:
        return false
    out = v3Libp2pTailnetPeerSessionClone(transport.peerSessions[pos])
    return true

fn v3Libp2pTailnetPeerSessionPeerIdText(payload: str): str =
    for i in 0..<len(payload):
        if payload[i] == '\n':
            if i <= 0:
                return ""
            return strutil.sliceStr(payload, 0, i - 1)
    return payload

fn v3Libp2pTailnetPeerSessionPos(transport: V3Libp2pTailnetTransport,
                                 peerId: str): int32 =
    for i in 0..<transport.peerSessions.len:
        if transport.peerSessions[i].peerId == peerId:
            return i
    return -1

fn v3Libp2pTailnetUpsertPeerSession(transport: var V3Libp2pTailnetTransport,
                                    session: V3Libp2pTailnetPeerSession) =
    if len(session.peerId) == 0:
        return
    let pos = v3Libp2pTailnetPeerSessionPos(transport, session.peerId)
    var next = v3Libp2pTailnetPeerSessionClone(session)
    next.relayAllowed = session.relayAllowed || session.relayOnly
    if session.directReachable:
        next.lastPath = "direct"
    elif next.relayAllowed:
        next.lastPath = "derp"
    else:
        next.lastPath = "idle"
    if len(session.lastError) > 0:
        next.lastPath = "error"
    var sessions = transport.peerSessions
    if pos >= 0:
        sessions[pos] = next
        transport.peerSessions = sessions
        return
    add(sessions, next)
    transport.peerSessions = sessions

fn v3Libp2pTailnetRegisterPeerSession(transport: var V3Libp2pTailnetTransport,
                                      peerId: str) =
    var session = v3Libp2pTailnetPeerSessionZero()
    session.peerId = peerId
    session.relayAllowed = true
    v3Libp2pTailnetUpsertPeerSession(transport, session)

fn v3Libp2pTailnetDerpAvailable(transport: V3Libp2pTailnetTransport): bool =
    if !v3Libp2pTailnetProviderRuntimeDerpHealthyNow(transport):
        return false
    return len(transport.cfg.relayEndpoint) > 0

fn v3Libp2pTailnetDerpMapSummary(transport: V3Libp2pTailnetTransport): str =
    if transport.cfg.providerKind == v3Libp2pTailnetProviderHeadscale:
        var out = "headscale"
        if len(transport.cfg.headscaleNamespace) > 0:
            out = out + "/"
            out = out + transport.cfg.headscaleNamespace
        if len(transport.cfg.controlUrl) > 0:
            out = out + "@"
            out = out + transport.cfg.controlUrl
        elif len(transport.cfg.controlEndpoint) > 0:
            out = out + "@"
            out = out + transport.cfg.controlEndpoint
        if len(transport.cfg.derpRegionCode) > 0:
            out = out + "#"
            out = out + transport.cfg.derpRegionCode
        if len(transport.cfg.derpHostname) > 0:
            out = out + "/"
            out = out + transport.cfg.derpHostname
        return out
    if len(transport.cfg.controlEndpoint) > 0:
        return transport.cfg.controlEndpoint
    return transport.cfg.controlUrl

fn v3Libp2pTailnetHostFamily(host: str): str =
    for i in 0..<len(host):
        if host[i] == ':':
            return "ip6"
    return "ip4"

fn v3Libp2pTailnetSyntheticHost(cfg: V3Libp2pTailnetTransportConfig,
                                rawAddr: types.V3Libp2pMultiaddr): str =
    let family = v3Libp2pTailnetHostFamily(rawAddr.host)
    if family == "ip6" && len(cfg.syntheticIPv6) > 0:
        return cfg.syntheticIPv6
    if family == "ip4" && len(cfg.syntheticIPv4) > 0:
        return cfg.syntheticIPv4
    return rawAddr.host

fn v3Libp2pTailnetAddrText(addr: types.V3Libp2pMultiaddr): str =
    if len(addr.raw) > 0:
        return addr.raw
    let family = v3Libp2pTailnetHostFamily(addr.host)
    var out: str = "/"
    out = out + family
    out = out + "/"
    out = out + addr.host
    if addr.transport == types.v3Libp2pTransportTcp:
        out = out + "/tcp/"
        out = out + intToStr(addr.port)
        return out
    if addr.transport == types.v3Libp2pTransportQuic:
        out = out + "/udp/"
        out = out + intToStr(addr.port)
        out = out + "/quic-v1"
        return out
    if addr.transport == types.v3Libp2pTransportWebrtc:
        out = out + "/udp/"
        out = out + intToStr(addr.port)
        out = out + "/webrtc-direct"
        return out
    return out

fn v3Libp2pTailnetMapListenAddr(cfg: V3Libp2pTailnetTransportConfig,
                                rawAddr: types.V3Libp2pMultiaddr,
                                out: var V3Libp2pTailnetListenerMapping): Result[bool] =
    if rawAddr.transport != types.v3Libp2pTransportTcp &&
       rawAddr.transport != types.v3Libp2pTransportQuic:
        return Err[bool]("v3 libp2p tailnet: unsupported transport")
    let syntheticHost = v3Libp2pTailnetSyntheticHost(cfg, rawAddr)
    var advertised = multiaddr.v3Libp2pMultiaddrClone(rawAddr)
    advertised.host = syntheticHost
    multiaddr.v3Libp2pMultiaddrSetRoutingMeta(advertised,
                                              types.v3Libp2pNetworkDomainTailnet,
                                              types.v3Libp2pVisibilityTrustedOnly,
                                              900)
    advertised.raw = ""
    out.published = true
    out.raw = multiaddr.v3Libp2pMultiaddrClone(rawAddr)
    out.advertised = advertised
    out.rawText = v3Libp2pTailnetAddrText(rawAddr)
    out.advertisedText = v3Libp2pTailnetAddrText(advertised)
    return Ok[bool](true)

fn v3Libp2pTailnetListenerMappingPosByRawText(transport: V3Libp2pTailnetTransport,
                                              rawText: str): int32 =
    for i in 0..<transport.listenerMappings.len:
        if transport.listenerMappings[i].rawText == rawText:
            return i
    return -1

fn v3Libp2pTailnetListenerMappingPosByPublishedText(transport: V3Libp2pTailnetTransport,
                                                    publishedText: str): int32 =
    for i in 0..<transport.listenerMappings.len:
        if transport.listenerMappings[i].advertisedText == publishedText:
            return i
    return -1

fn v3Libp2pTailnetListen(transport: var V3Libp2pTailnetTransport,
                         rawAddr: types.V3Libp2pMultiaddr): Result[types.V3Libp2pMultiaddr] =
    var mapping = v3Libp2pTailnetListenerMappingZero()
    let mapRes = v3Libp2pTailnetMapListenAddr(transport.cfg, rawAddr, mapping)
    if IsErr(mapRes):
        return Err[types.V3Libp2pMultiaddr](Error(mapRes))
    let pos = v3Libp2pTailnetListenerMappingPosByRawText(transport, mapping.rawText)
    if pos >= 0:
        transport.listenerMappings[pos] = mapping
    else:
        add(transport.listenerMappings, mapping)
    return Ok[types.V3Libp2pMultiaddr](mapping.advertised)

fn v3Libp2pTailnetPublishedAddrs(transport: V3Libp2pTailnetTransport): types.V3Libp2pMultiaddr[] =
    var out: types.V3Libp2pMultiaddr[]
    out = []
    for i in 0..<transport.listenerMappings.len:
        let mapping = transport.listenerMappings[i]
        if !mapping.published:
            continue
        add(out, multiaddr.v3Libp2pMultiaddrClone(mapping.advertised))
    return out

fn v3Libp2pTailnetResolvePublishedToRaw(transport: V3Libp2pTailnetTransport,
                                        advertisedAddr: types.V3Libp2pMultiaddr,
                                        out: var types.V3Libp2pMultiaddr): bool =
    let advertisedText = v3Libp2pTailnetAddrText(advertisedAddr)
    let pos = v3Libp2pTailnetListenerMappingPosByPublishedText(transport, advertisedText)
    if pos < 0:
        return false
    out = multiaddr.v3Libp2pMultiaddrClone(transport.listenerMappings[pos].raw)
    return true

fn v3Libp2pTailnetResolveRawToPublished(transport: V3Libp2pTailnetTransport,
                                        rawAddr: types.V3Libp2pMultiaddr,
                                        out: var types.V3Libp2pMultiaddr): bool =
    let rawText = v3Libp2pTailnetAddrText(rawAddr)
    let pos = v3Libp2pTailnetListenerMappingPosByRawText(transport, rawText)
    if pos < 0:
        return false
    out = multiaddr.v3Libp2pMultiaddrClone(transport.listenerMappings[pos].advertised)
    return true

fn v3Libp2pTailnetProviderFullyReady(transport: V3Libp2pTailnetTransport): bool =
    if !v3Libp2pTailnetProviderRuntimeReadyNow(transport):
        return false
    if !v3Libp2pTailnetProviderRuntimeProxyReadyNow(transport):
        return false
    return !v3Libp2pTailnetProviderRuntimeListenerNeedsRepairNow(transport)

fn v3Libp2pTailnetStatusPathKind(transport: V3Libp2pTailnetTransport): V3Libp2pTailnetPathKind =
    if v3Libp2pTailnetProviderRuntimeListenerNeedsRepairNow(transport):
        return v3Libp2pTailnetPathRepair
    if v3Libp2pTailnetProviderFullyReady(transport):
        if transport.listenerMappings.len > 0 && v3Libp2pTailnetDerpAvailable(transport):
            return v3Libp2pTailnetPathDirect
        if transport.listenerMappings.len > 0:
            return v3Libp2pTailnetPathDirect
    if v3Libp2pTailnetProviderRuntimeReadyNow(transport) && transport.listenerMappings.len > 0:
        return v3Libp2pTailnetPathDirectPending
    if v3Libp2pTailnetDerpAvailable(transport):
        return v3Libp2pTailnetPathDerp
    return v3Libp2pTailnetPathIdle

fn v3Libp2pTailnetDialPlanFill(out: var V3Libp2pTailnetDialPlan,
                               transport: V3Libp2pTailnetTransport,
                               peerId: str,
                               requestedAddr: types.V3Libp2pMultiaddr,
                               relayOnly: bool,
                               directOnly: bool): Result[bool] =
    if relayOnly && directOnly:
        return Err[bool]("v3 libp2p tailnet: relay-only conflicts with direct-only")
    if requestedAddr.networkDomain != types.v3Libp2pNetworkDomainTailnet:
        return Err[bool]("v3 libp2p tailnet: dial plan requires tailnet addr")
    out = v3Libp2pTailnetDialPlanZero()
    out.peerId = peerId
    out.requestedAddr = multiaddr.v3Libp2pMultiaddrClone(requestedAddr)
    out.rawAddr = multiaddr.v3Libp2pMultiaddrClone(requestedAddr)
    out.publishedAddr = multiaddr.v3Libp2pMultiaddrClone(requestedAddr)
    out.relayOnly = relayOnly
    out.directOnly = directOnly
    out.directAllowed = !relayOnly
    let providerReady = v3Libp2pTailnetProviderRuntimeReadyNow(transport)
    let proxyListenersReady = v3Libp2pTailnetProviderRuntimeProxyReadyNow(transport)
    let listenerNeedsRepair = v3Libp2pTailnetProviderRuntimeListenerNeedsRepairNow(transport)
    let derpAvailable = v3Libp2pTailnetDerpAvailable(transport)
    let exactRouting = transport.cfg.exactRouting
    out.relayAllowed = derpAvailable && !directOnly
    out.needsRepair = providerReady && (!proxyListenersReady || listenerNeedsRepair)

    var mappedRaw = types.v3Libp2pMultiaddrZero()
    if v3Libp2pTailnetResolvePublishedToRaw(transport, requestedAddr, mappedRaw):
        out.rawAddr = mappedRaw

    let sessionPos = v3Libp2pTailnetPeerSessionPos(transport, peerId)
    if sessionPos >= 0:
        let session = transport.peerSessions[sessionPos]
        if session.relayOnly:
            out.directAllowed = false
        if len(session.remoteTailnetIp) > 0:
            out.publishedAddr.host = session.remoteTailnetIp
        if session.relayOnly:
            out.directAllowed = false
        if session.relayAllowed || session.relayOnly:
            out.relayAllowed = derpAvailable && !directOnly
        if exactRouting && len(session.boundAddrText) > 0:
            out.routeText = session.boundAddrText
    elif out.directAllowed && providerReady && proxyListenersReady && !listenerNeedsRepair:
        out.pathKind = v3Libp2pTailnetPathDirect
        out.reachability = types.v3Libp2pReachabilityDirect
        if exactRouting:
            out.routeText = v3Libp2pTailnetAddrText(out.rawAddr)
        else:
            out.routeText = v3Libp2pTailnetAddrText(out.publishedAddr)
        return Ok[bool](true)

    let directPossible = out.directAllowed &&
                         providerReady &&
                         proxyListenersReady &&
                         !listenerNeedsRepair
    if directPossible:
        out.pathKind = v3Libp2pTailnetPathDirect
        out.reachability = types.v3Libp2pReachabilityDirect
        if len(out.routeText) == 0:
            if exactRouting:
                out.routeText = v3Libp2pTailnetAddrText(out.rawAddr)
            else:
                out.routeText = v3Libp2pTailnetAddrText(out.publishedAddr)
        return Ok[bool](true)

    if out.relayAllowed:
        out.pathKind = v3Libp2pTailnetPathDerp
        out.reachability = types.v3Libp2pReachabilityRelayed
        out.routeText = transport.cfg.relayEndpoint
        return Ok[bool](true)

    if out.needsRepair:
        out.pathKind = v3Libp2pTailnetPathRepair
        out.routeText = "repair"
        return Err[bool]("v3 libp2p tailnet: listener repair required")

    if providerReady && !proxyListenersReady:
        out.pathKind = v3Libp2pTailnetPathDirectPending
        out.routeText = "direct-pending"
        return Err[bool]("v3 libp2p tailnet: proxy listeners pending")

    out.pathKind = v3Libp2pTailnetPathIdle
    out.routeText = "idle"
    return Err[bool]("v3 libp2p tailnet: no dial path")

fn v3Libp2pTailnetStatusFill(out: var V3Libp2pTailnetStatusSnapshot,
                             transport: V3Libp2pTailnetTransport) =
    out.providerKind = v3Libp2pTailnetProviderKindText(transport.cfg.providerKind)
    out.controlPlane = "synthetic"
    if transport.cfg.providerKind == v3Libp2pTailnetProviderHeadscale:
        out.controlPlane = "headscale"
    out.exactRouting = v3Libp2pTailnetProviderUsesExactRouting(transport)
    out.relayHealthy = v3Libp2pTailnetDerpAvailable(transport)
    out.providerReady = v3Libp2pTailnetProviderRuntimeReadyNow(transport)
    out.proxyListenersReady = v3Libp2pTailnetProviderRuntimeProxyReadyNow(transport)
    out.listenerNeedsRepair = v3Libp2pTailnetProviderRuntimeListenerNeedsRepairNow(transport)
    out.startupStage = v3Libp2pTailnetProviderRuntimeStartupStageNow(transport)
    out.publishedCount = 0
    out.sessionCount = v3Libp2pTailnetPeerSessionCount(transport)
    out.derpRegionCode = transport.cfg.derpRegionCode
    out.derpHostname = transport.cfg.derpHostname
    var tailnetIPs: str[] = []
    var tailnetPeers: str[] = []
    if len(transport.cfg.syntheticIPv4) > 0:
        add(tailnetIPs, transport.cfg.syntheticIPv4)
    if len(transport.cfg.syntheticIPv6) > 0:
        add(tailnetIPs, transport.cfg.syntheticIPv6)
    for i in 0..<transport.listenerMappings.len:
        if transport.listenerMappings[i].published:
            out.publishedCount = out.publishedCount + 1
    let pathKind = v3Libp2pTailnetStatusPathKind(transport)
    out.tailnetPath = v3Libp2pTailnetPathKindText(pathKind)
    if pathKind == v3Libp2pTailnetPathDirect:
        if out.relayHealthy:
            if out.publishedCount > 0:
                out.tailnetPath = "direct+derp"
    for i in 0..<transport.peerSessions.len:
        let peerId = transport.peerSessions[i].peerId
        if len(peerId) > 0:
            add(tailnetPeers, peerId)
    out.tailnetIPs = tailnetIPs
    out.tailnetPeers = tailnetPeers
    out.tailnetRelay = transport.cfg.relayEndpoint
    out.tailnetDerpMapSummary = v3Libp2pTailnetDerpMapSummary(transport)

fn v3Libp2pTailnetStatus(transport: V3Libp2pTailnetTransport): V3Libp2pTailnetStatusSnapshot =
    var out: V3Libp2pTailnetStatusSnapshot
    v3Libp2pTailnetStatusFill(out, transport)
    return out
