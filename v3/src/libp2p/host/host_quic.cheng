import std/result
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/core/peerstore as ps
import cheng/v3/libp2p/protocols/store_sync
import cheng/v3/libp2p/transports/quic_transport
import cheng/v3/libp2p/host/host as host_base

fn v3Libp2pQuicExchange(remoteHost: var host_base.V3Libp2pHost,
                        remoteAddr: types.V3Libp2pMultiaddr,
                        requestPayload: Bytes,
                        outPayload: var Bytes): Result[bool] =
    var pair: quic_transport.V3Libp2pQuicLoopbackPair
    let openRes = quic_transport.v3Libp2pQuicLoopbackOpenInto(pair, remoteAddr)
    if IsErr(openRes):
        return Err[bool]("v3 libp2p quic: open: " + ErrorText(openRes))
    let selectRes = quic_transport.v3Libp2pQuicLoopbackSelectProtocol(pair, types.v3Libp2pProtocolSync)
    if IsErr(selectRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: select: " + ErrorText(selectRes))
    let requestWriteRes = quic_transport.v3Libp2pQuicLoopbackWriteClient(pair, requestPayload)
    if IsErr(requestWriteRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: request write: " + ErrorText(requestWriteRes))
    let requestReadRes = quic_transport.v3Libp2pQuicLoopbackReadServer(pair, bytesLen(requestPayload))
    if IsErr(requestReadRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: request read: " + ErrorText(requestReadRes))
    let servePayloadRes = host_base.v3Libp2pSyncServePayload(remoteHost, Value(requestReadRes))
    if IsErr(servePayloadRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: serve: " + ErrorText(servePayloadRes))
    let responsePayload = Value(servePayloadRes)
    let responseWriteRes = quic_transport.v3Libp2pQuicLoopbackWriteServer(pair, responsePayload)
    if IsErr(responseWriteRes):
        quic_transport.v3Libp2pQuicLoopbackClose(pair)
        return Err[bool]("v3 libp2p quic: response write: " + ErrorText(responseWriteRes))
    let responseReadRes = quic_transport.v3Libp2pQuicLoopbackReadClient(pair, bytesLen(responsePayload))
    quic_transport.v3Libp2pQuicLoopbackClose(pair)
    if IsErr(responseReadRes):
        return Err[bool]("v3 libp2p quic: response read: " + ErrorText(responseReadRes))
    outPayload = Value(responseReadRes)
    return Ok[bool](true)

fn v3Libp2pSyncRequest(localHost: var host_base.V3Libp2pHost,
                       remoteHost: var host_base.V3Libp2pHost,
                       remotePeerId: types.V3Libp2pPeerId,
                       query: overlay.V3StoreQuery,
                       out: var overlay.V3IngressEnvelope[]): Result[bool] =
    if !types.v3Libp2pPeerIdEqual(remoteHost.selfPeerId, remotePeerId):
        return Err[bool]("v3 libp2p host: sync peer mismatch")
    if !host_base.v3Libp2pProtocolRegistered(remoteHost, types.v3Libp2pProtocolSync):
        return Err[bool]("v3 libp2p host: remote sync handler missing")
    let streamRes = host_base.v3Libp2pOpenStream(localHost, remotePeerId, types.v3Libp2pProtocolSync)
    if IsErr(streamRes):
        return Err[bool](Error(streamRes))
    localHost.syncRequestCount = localHost.syncRequestCount + 1
    let requestPayload = store_sync.v3Libp2pStoreQueryEncode(query)
    let peers = localHost.peers
    let pos = ps.v3Libp2pPeerstorePos(peers, remotePeerId)
    if pos < 0:
        return Err[bool]("v3 libp2p host: peer missing")
    let remoteAddr = multiaddr.v3Libp2pMultiaddrClone(peers.peers[pos].addr)
    if remoteAddr.transport != types.v3Libp2pTransportQuic:
        return host_base.v3Libp2pSyncRequest(localHost, remoteHost, remotePeerId, query, out)
    var responsePayload: Bytes
    let exchangeRes = v3Libp2pQuicExchange(remoteHost, remoteAddr, requestPayload, responsePayload)
    if IsErr(exchangeRes):
        return Err[bool](ErrorText(exchangeRes))
    out = []
    let decodeRes = store_sync.v3Libp2pStoreEntriesDecodeFill(responsePayload, out)
    if IsErr(decodeRes):
        return Err[bool](Error(decodeRes))
    return Ok[bool](true)
