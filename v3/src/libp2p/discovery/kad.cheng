import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peer_id
import cheng/v3/libp2p/core/peerstore as ps

type
    V3Libp2pProvideRecord =
        keyCid: layout.FixedBytes32
        provider: types.V3Libp2pPeerId

    V3Libp2pKadState =
        providers: V3Libp2pProvideRecord[]

fn v3Libp2pKadStateZero(): V3Libp2pKadState =
    var out: V3Libp2pKadState
    out.providers = []
    return out

fn v3Libp2pKadProvide(state: var V3Libp2pKadState,
                      keyCid: layout.FixedBytes32,
                      provider: types.V3Libp2pPeerId) =
    for i in 0..<state.providers.len:
        if layout.fixedBytes32Equal(state.providers[i].keyCid, keyCid):
            if types.v3Libp2pPeerIdEqual(state.providers[i].provider, provider):
                return
    add(state.providers, V3Libp2pProvideRecord(keyCid: keyCid, provider: provider))

fn v3Libp2pKadFindPeer(store: ps.V3Libp2pPeerstore,
                       target: types.V3Libp2pPeerId): Result[ps.V3Libp2pPeerRecord] =
    let pos = ps.v3Libp2pPeerstorePos(store, target)
    if pos < 0:
        return Err[ps.V3Libp2pPeerRecord]("v3 libp2p kad: peer not found")
    return Ok[ps.V3Libp2pPeerRecord](store.peers[pos])

fn v3Libp2pKadFindClosest(store: ps.V3Libp2pPeerstore,
                          target: types.V3Libp2pPeerId,
                          limit: int32): ps.V3Libp2pPeerRecord[] =
    var out: ps.V3Libp2pPeerRecord[]
    out = []
    if limit <= 0:
        return out
    for i in 0..<store.peers.len:
        let candidate = store.peers[i]
        let candidatePeerId = candidate.peerId
        let candidateDist = peer_id.v3Libp2pPeerIdDistance(candidatePeerId, target)
        var insertAt = out.len
        for j in 0..<out.len:
            let probePeerId = out[j].peerId
            let probeDist = peer_id.v3Libp2pPeerIdDistance(probePeerId, target)
            if candidateDist < probeDist:
                insertAt = j
                break
        if out.len < limit:
            add(out, candidate)
            var move = out.len - 1
            while move > insertAt:
                out[move] = out[move - 1]
                move = move - 1
            out[insertAt] = candidate
        elif insertAt < limit:
            var move2 = limit - 1
            while move2 > insertAt:
                out[move2] = out[move2 - 1]
                move2 = move2 - 1
            out[insertAt] = candidate
    return out
