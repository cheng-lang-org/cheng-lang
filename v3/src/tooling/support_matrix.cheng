import std/strutils as strutil
import cheng/v3/tooling/compiler_runtime as crun
import cheng/v3/backend/build_plan as buildplan
import cheng/v3/backend/system_link_plan as slplan

type
    V3SupportTargetRow =
        targetTriple: str
        objectFormat: str
        emitReady: bool
        runReady: bool
        debugReady: bool
        profileReady: bool
        releaseReady: bool
        nativeProvidersRequired: bool
        nativeProviderModulesRequired: bool
        linuxNolibcRuntime: bool

fn v3SupportMatrixBoolText(value: bool): str =
    if value:
        return "1"
    return "0"

fn v3SupportMatrixAppendLine(out: var str,
                             key: str,
                             value: str) =
    if len(out) > 0:
        out = out + "\n"
    out = out + key + "=" + value

fn v3SupportMatrixLanguageSurfaceText(): str =
    return "line_normalized_parser_stub"

fn v3SupportMatrixLanguageParsedText(): str =
    return "fn,import,let,var,const,type,if,for,while,case,range,comprehension,strformat,result_intrinsic,try"

fn v3SupportMatrixLanguageParsedUnsupportedText(): str =
    return "func,proc,method,converter,grouped_import_alias"

fn v3SupportMatrixOrdinaryPipelineText(): str =
    let contract = crun.v3CompilerRuntimeContract("")
    return contract.ordinaryPipelineState

fn v3SupportMatrixTargetRows(): V3SupportTargetRow[] =
    var out: V3SupportTargetRow[]
    add(out,
        V3SupportTargetRow(targetTriple: "arm64-apple-darwin",
                           objectFormat: "macho",
                           emitReady: true,
                           runReady: true,
                           debugReady: true,
                           profileReady: true,
                           releaseReady: true,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: true,
                           linuxNolibcRuntime: false))
    add(out,
        V3SupportTargetRow(targetTriple: "x86_64-apple-darwin",
                           objectFormat: "macho",
                           emitReady: true,
                           runReady: false,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: true,
                           linuxNolibcRuntime: false))
    add(out,
        V3SupportTargetRow(targetTriple: "aarch64-unknown-linux-gnu",
                           objectFormat: "elf",
                           emitReady: true,
                           runReady: true,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: false,
                           linuxNolibcRuntime: true))
    add(out,
        V3SupportTargetRow(targetTriple: "x86_64-unknown-linux-gnu",
                           objectFormat: "elf",
                           emitReady: true,
                           runReady: false,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: true,
                           linuxNolibcRuntime: false))
    add(out,
        V3SupportTargetRow(targetTriple: "aarch64-pc-windows-msvc",
                           objectFormat: "coff",
                           emitReady: true,
                           runReady: false,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: true,
                           linuxNolibcRuntime: false))
    add(out,
        V3SupportTargetRow(targetTriple: "x86_64-pc-windows-msvc",
                           objectFormat: "coff",
                           emitReady: true,
                           runReady: false,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: true,
                           nativeProviderModulesRequired: true,
                           linuxNolibcRuntime: false))
    add(out,
        V3SupportTargetRow(targetTriple: "wasm32-unknown-unknown",
                           objectFormat: "wasm",
                           emitReady: true,
                           runReady: false,
                           debugReady: false,
                           profileReady: false,
                           releaseReady: false,
                           nativeProvidersRequired: false,
                           nativeProviderModulesRequired: false,
                           linuxNolibcRuntime: false))
    return out

fn v3SupportMatrixTargetSummary(rows: V3SupportTargetRow[]): str =
    var out = ""
    for i in 0..<rows.len:
        let row = rows[i]
        if len(out) > 0:
            out = out + ","
        out = out + row.targetTriple
    return out

fn v3SupportMatrixReport(rootDir: str): str =
    let _ = rootDir
    var out = ""
    let rows = v3SupportMatrixTargetRows()
    let compilerPlan = buildplan.v3BackendBuildPlanDefault(rootDir)
    let backendPlan = buildplan.v3BackendBuildPlanBackendDriver(rootDir)
    v3SupportMatrixAppendLine(out, "format", "v3_support_matrix_v1")
    v3SupportMatrixAppendLine(out, "language_surface", v3SupportMatrixLanguageSurfaceText())
    v3SupportMatrixAppendLine(out, "language_ast_authority", "0")
    v3SupportMatrixAppendLine(out, "language_parsed_features", v3SupportMatrixLanguageParsedText())
    v3SupportMatrixAppendLine(out, "language_parsed_but_rejected_features", v3SupportMatrixLanguageParsedUnsupportedText())
    v3SupportMatrixAppendLine(out, "ordinary_pipeline_state", v3SupportMatrixOrdinaryPipelineText())
    v3SupportMatrixAppendLine(out, "ordinary_primary_object_codegen_ready", "0")
    v3SupportMatrixAppendLine(out, "typed_expr_unknown_gate", "0")
    v3SupportMatrixAppendLine(out, "typed_expr_deferred_gate", "0")
    v3SupportMatrixAppendLine(out, "target_count", intToStr(rows.len))
    v3SupportMatrixAppendLine(out, "targets", v3SupportMatrixTargetSummary(rows))
    v3SupportMatrixAppendLine(out, "compiler_build_source_unit_count", intToStr(compilerPlan.sourceUnits.len))
    v3SupportMatrixAppendLine(out, "backend_driver_build_source_unit_count", intToStr(backendPlan.sourceUnits.len))
    for i in 0..<rows.len:
        let row = rows[i]
        let prefix = "target[" + intToStr(i) + "]"
        v3SupportMatrixAppendLine(out, prefix + ".triple", row.targetTriple)
        v3SupportMatrixAppendLine(out, prefix + ".object_format", row.objectFormat)
        v3SupportMatrixAppendLine(out, prefix + ".emit_ready", v3SupportMatrixBoolText(row.emitReady))
        v3SupportMatrixAppendLine(out, prefix + ".run_ready", v3SupportMatrixBoolText(row.runReady))
        v3SupportMatrixAppendLine(out, prefix + ".debug_ready", v3SupportMatrixBoolText(row.debugReady))
        v3SupportMatrixAppendLine(out, prefix + ".profile_ready", v3SupportMatrixBoolText(row.profileReady))
        v3SupportMatrixAppendLine(out, prefix + ".release_ready", v3SupportMatrixBoolText(row.releaseReady))
        v3SupportMatrixAppendLine(out,
                                  prefix + ".native_providers_required",
                                  v3SupportMatrixBoolText(row.nativeProvidersRequired))
        v3SupportMatrixAppendLine(out,
                                  prefix + ".native_provider_modules_required",
                                  v3SupportMatrixBoolText(row.nativeProviderModulesRequired))
        v3SupportMatrixAppendLine(out,
                                  prefix + ".linux_nolibc_runtime",
                                  v3SupportMatrixBoolText(row.linuxNolibcRuntime))
    return out

fn v3SupportMatrixUsageLine(): str =
    return "  support-matrix               print the current language/target support matrix"

fn v3SupportMatrixHasCommand(text: str): bool =
    return strutil.Contains(text, "support-matrix")
