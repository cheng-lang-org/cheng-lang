    out = out + "typed_expr_call_builtin_count=" + intToStr(v3TypedExprCallBuiltinCount(typedExprFacts)) + "\n"
    out = out + "typed_expr_call_result_intrinsic_count=" + intToStr(v3TypedExprCallResultIntrinsicCount(typedExprFacts)) + "\n"
    out = out + "typed_expr_call_projection_count=" + intToStr(v3TypedExprCallProjectionCount(typedExprFacts)) + "\n"
