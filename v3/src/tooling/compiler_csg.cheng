    out = out + "typed_expr_return_deferred_count=" + intToStr(v3TypedExprReturnDeferredCount(typedExprFacts)) + "\n"
    out = out + "lowering_rule_count=" + intToStr(loweringRules.len) + "\n"
    out = out + "lowering_rule_unique_key_count=" + intToStr(v3TypedExprLoweringRuleUniqueKeyCount(loweringRules)) + "\n"
    out = out + "lowering_rule_arg_value_count=" + intToStr(v3TypedExprLoweringRuleCountArgPassKind(loweringRules, "value")) + "\n"
    out = out + "lowering_rule_arg_address_count=" + intToStr(v3TypedExprLoweringRuleCountArgPassKind(loweringRules, "address")) + "\n"
    out = out + "lowering_rule_arg_call_result_address_count=" + intToStr(v3TypedExprLoweringRuleCountArgPassKind(loweringRules, "call_result_address")) + "\n"
    out = out + "lowering_rule_result_reg_count=" + intToStr(v3TypedExprLoweringRuleCountResultPassKind(loweringRules, "reg")) + "\n"
    out = out + "lowering_rule_result_local_address_count=" + intToStr(v3TypedExprLoweringRuleCountResultPassKind(loweringRules, "local_address")) + "\n"
    out = out + "lowering_rule_result_sret_count=" + intToStr(v3TypedExprLoweringRuleCountResultPassKind(loweringRules, "sret")) + "\n"
    out = out + "lowering_rule_materialize_register_count=" + intToStr(v3TypedExprLoweringRuleCountMaterializeKind(loweringRules, "register")) + "\n"
    out = out + "lowering_rule_materialize_local_slot_count=" + intToStr(v3TypedExprLoweringRuleCountMaterializeKind(loweringRules, "local_slot")) + "\n"
    out = out + "lowering_rule_materialize_call_result_local_count=" + intToStr(v3TypedExprLoweringRuleCountMaterializeKind(loweringRules, "call_result_local")) + "\n"
    out = out + "lowering_rule_materialize_dest_address_count=" + intToStr(v3TypedExprLoweringRuleCountMaterializeKind(loweringRules, "dest_address")) + "\n"
    out = out + "lowering_rule_copy_scalar_store_count=" + intToStr(v3TypedExprLoweringRuleCountCopyKind(loweringRules, "scalar_store")) + "\n"
    out = out + "lowering_rule_copy_region_copy_count=" + intToStr(v3TypedExprLoweringRuleCountCopyKind(loweringRules, "region_copy")) + "\n"
    out = out + "lowering_rule_import_builtin_address_slot_count=" + intToStr(v3TypedExprLoweringRuleCountImportKind(loweringRules, "builtin_address_slot")) + "\n"
    out = out + "lowering_rule_import_i32_value_slot_count=" + intToStr(v3TypedExprLoweringRuleCountImportKind(loweringRules, "i32_value_slot")) + "\n"
    out = out + "lowering_rule_import_i32_address_slot_count=" + intToStr(v3TypedExprLoweringRuleCountImportKind(loweringRules, "i32_address_slot")) + "\n"
    out = out + "canonical_graph_cid=" + layout.fixedBytes32Hex(csg.canonicalGraphCid) + "\n"
    out = out + "graph_cid=" + layout.fixedBytes32Hex(csg.graphCid) + "\n"
    out = out + "node_count=" + intToStr(csg.nodeCount) + "\n"
    out = out + "edge_count=" + intToStr(csg.edgeCount)
    for i in 0..<csg.nodes.len:
        out = out + "\n" + v3CompilerCsgNodeReportLine(i, csg.nodes[i])
    for i in 0..<csg.edges.len:
        out = out + "\n" + v3CompilerCsgEdgeReportLine(i, csg.edges[i])
    return out

fn v3CompilerCsgNodeReportLine(index: int32,
                               node: V3CompilerCsgNode): str =
    var out = ""
    out = out + "node[" + intToStr(index) + "]="
    out = out + intToStr(node.nodeKind) + "|"
    out = out + intToStr(node.ownerNodeId) + "|"
    out = out + node.modulePath + "|"
    out = out + node.symbolText + "|"
    out = out + node.factText + "|"
    out = out + intToStr(node.resultLayoutKind) + "|"
    out = out + intToStr(node.effectKind) + "|"
    out = out + intToStr(node.capabilityKind) + "|"
    out = out + intToStr(node.callConv) + "|"
    out = out + intToStr(node.entryFlag) + "|"
    out = out + intToStr(node.exportedFlag) + "|"
    out = out + node.exportSymbolName + "|"
    out = out + layout.fixedBytes32Hex(node.factCid)
    return out

fn v3CompilerCsgEdgeReportLine(index: int32,
                               edge: V3CompilerCsgEdge): str =
    var out = ""
    out = out + "edge[" + intToStr(index) + "]="
    out = out + intToStr(edge.edgeKind) + "|"
    out = out + intToStr(edge.fromNodeId) + "|"
    out = out + intToStr(edge.toNodeId) + "|"
    out = out + layout.fixedBytes32Hex(edge.edgeCid)
    return out

fn v3CompilerExportSurfaceReport(surface: V3CsgExportSurface): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "package_id=" + surface.packageId + "\n"
    out = out + "exported_count=" + intToStr(surface.exportedSymbolCount) + "\n"
    out = out + "surface_cid=" + layout.fixedBytes32Hex(surface.surfaceCid)
    for i in 0..<surface.exportedSymbolCount:
        out = out + "\n" + v3CompilerExportSurfaceReportLine(surface, i)
    return out

fn v3CompilerExportSurfaceReportLine(surface: V3CsgExportSurface,
                                     index: int32): str =
    var out = ""
    out = out + "export[" + intToStr(index) + "]="
    out = out + surface.exportedSymbols[index] + "|"
    out = out + surface.exportedTargetNames[index] + "|"
    out = out + intToStr(surface.exportedLayouts[index]) + "|"
    out = out + intToStr(surface.exportedEffects[index]) + "|"
    out = out + intToStr(surface.exportedCapabilities[index])
    return out

fn v3CompilerCsgTextStartsWith(text: str,
                               prefix: str): bool =
    if prefix.len <= 0:
        return true
    if text.len < prefix.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn v3CompilerCsgParseUintText(text: str,
                              outOk: var bool): int32 =
    outOk = false
    if text.len <= 0:
        return 0
    var value = int32(0)
    for i in 0..<text.len:
        let ch = text[i]
        if ch < '0' || ch > '9':
            return 0
        value = value * 10 + (int32(ch) - int32('0'))
    outOk = true
    return value

fn v3CompilerExportSurfaceFromReportText(text: str,
                                         out: var V3CsgExportSurface): Result[bool] =
    let packageId = v3CompilerWorldLineValue(text, "package_id")
    let countText = v3CompilerWorldLineValue(text, "exported_count")
    if len(countText) <= 0:
        return Err[bool]("v3 compiler csg: exported_count missing")
    var countOk = false
    let exportedCount = v3CompilerCsgParseUintText(countText, countOk)
    if !countOk:
        return Err[bool]("v3 compiler csg: invalid exported_count: " + countText)
    out.exportedSymbols = []
    out.exportedTargetNames = []
    out.exportedLayouts = []
    out.exportedEffects = []
    out.exportedCapabilities = []
    let surfaceCidRes = layout.fixedBytes32FromHex(v3CompilerWorldLineValue(text, "surface_cid"))
    if IsErr(surfaceCidRes):
        return Err[bool]("v3 compiler csg: invalid surface cid")
    let surfaceCid = Value(surfaceCidRes)
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if !v3CompilerCsgTextStartsWith(line, "export["):
            continue
        var eqPos = -1
        for j in 0..<line.len:
            if line[j] == '=':
                eqPos = j
                break
        if eqPos < 0 || eqPos + 1 >= line.len:
            continue
        let payload = strutil.SliceStr(line, eqPos + 1, line.len - 1)
        var firstSep = -1
        var secondSep = -1
        var thirdSep = -1
        var fourthSep = -1
        for j in 0..<payload.len:
            if payload[j] != '|':
                continue
            if firstSep < 0:
                firstSep = j
                continue
            if secondSep < 0:
                secondSep = j
                continue
            if thirdSep < 0:
                thirdSep = j
                continue
            if fourthSep < 0:
                fourthSep = j
                continue
            return Err[bool]("v3 compiler csg: export row has too many separators")
        if firstSep <= 0 || secondSep <= firstSep + 1 || thirdSep <= secondSep + 1 || thirdSep >= payload.len - 1:
            return Err[bool]("v3 compiler csg: export row separator positions invalid")
        add(out.exportedSymbols, strutil.SliceStr(payload, 0, firstSep - 1))
        var targetName = ""
        var layoutOk = false
        var effectOk = false
        var capabilityOk = false
        var layoutText = ""
        var effectText = ""
        var capabilityText = ""
        if fourthSep >= 0:
            if fourthSep <= thirdSep + 1 || fourthSep >= payload.len - 1:
                return Err[bool]("v3 compiler csg: export row target separator invalid")
            targetName = strutil.SliceStr(payload, firstSep + 1, secondSep - 1)
            layoutText = strutil.SliceStr(payload, secondSep + 1, thirdSep - 1)
            effectText = strutil.SliceStr(payload, thirdSep + 1, fourthSep - 1)
            capabilityText = strutil.SliceStr(payload, fourthSep + 1, payload.len - 1)
        else:
            targetName = v3CompilerCsgTargetExportName(out.exportedSymbols[out.exportedSymbols.len - 1], "", "")
            layoutText = strutil.SliceStr(payload, firstSep + 1, secondSep - 1)
            effectText = strutil.SliceStr(payload, secondSep + 1, thirdSep - 1)
            capabilityText = strutil.SliceStr(payload, thirdSep + 1, payload.len - 1)
        let layoutValue = v3CompilerCsgParseUintText(layoutText, layoutOk)
        let effectValue = v3CompilerCsgParseUintText(effectText, effectOk)
        let capabilityValue = v3CompilerCsgParseUintText(capabilityText, capabilityOk)
        if !layoutOk || !effectOk || !capabilityOk:
            return Err[bool]("v3 compiler csg: export row numeric field invalid")
        add(out.exportedTargetNames, targetName)
        add(out.exportedLayouts, layoutValue)
        add(out.exportedEffects, effectValue)
        add(out.exportedCapabilities, capabilityValue)
    if out.exportedSymbols.len != exportedCount:
        return Err[bool]("v3 compiler csg: export count mismatch parsed=" +
                         intToStr(out.exportedSymbols.len) +
                         " expected=" +
                         intToStr(exportedCount) +
                         " countText=" +
                         countText)
    out.version = 1
    out.packageId = packageId
    out.exportedSymbolCount = exportedCount
    out.surfaceCid = surfaceCid
    return Ok[bool](true)

fn v3CompilerCsgGraphCidFromReportText(text: str): Result[layout.FixedBytes32] =
    let raw = v3CompilerWorldLineValue(text, "graph_cid")
    if len(raw) <= 0:
        return Err[layout.FixedBytes32]("v3 compiler csg: graph_cid missing")
    return layout.fixedBytes32FromHex(raw)

fn v3CompilerCsgCanonicalGraphCidFromReportText(text: str): Result[layout.FixedBytes32] =
    let raw = v3CompilerWorldLineValue(text, "canonical_graph_cid")
    if len(raw) > 0:
        return layout.fixedBytes32FromHex(raw)
    return v3CompilerCsgGraphCidFromReportText(text)

fn v3CompileReceiptReport(receipt: V3CompileReceipt): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "world_head_cid=" + layout.fixedBytes32Hex(receipt.worldHeadCid) + "\n"
    out = out + "compiler_csg_cid=" + layout.fixedBytes32Hex(receipt.compilerCsgCid) + "\n"
    out = out + "canonical_compiler_csg_cid=" + layout.fixedBytes32Hex(receipt.canonicalCompilerCsgCid) + "\n"
    out = out + "target=" + receipt.targetTriple + "\n"
    out = out + "output_digest=" + layout.fixedBytes32Hex(receipt.outputDigest) + "\n"
    out = out + "canonical_output_digest=" + layout.fixedBytes32Hex(receipt.canonicalOutputDigest) + "\n"
    out = out + "bootstrap_stage=" + receipt.bootstrapStage + "\n"
    out = out + "runtime_provider_count=" + intToStr(receipt.runtimeProviderSet.len) + "\n"
    out = out + "receipt_cid=" + layout.fixedBytes32Hex(receipt.receiptCid)
    for i in 0..<receipt.runtimeProviderSet.len:
        out = out + "\n" + v3CompileReceiptProviderReportLine(receipt.runtimeProviderSet[i], i)
    return out

fn v3CompileReceiptProviderReportLine(provider: str,
                                      index: int32): str =
    var out = ""
    out = out + "runtime_provider[" + intToStr(index) + "]="
    out = out + provider
    return out

fn v3CompileReceiptFromReportText(text: str,
                                  out: var V3CompileReceipt): Result[bool] =
    let worldHeadRes = layout.fixedBytes32FromHex(v3CompilerWorldLineValue(text, "world_head_cid"))
    if IsErr(worldHeadRes):
        return Err[bool]("v3 compiler csg: invalid world_head_cid")
    let csgRes = layout.fixedBytes32FromHex(v3CompilerWorldLineValue(text, "compiler_csg_cid"))
    if IsErr(csgRes):
        return Err[bool]("v3 compiler csg: invalid compiler_csg_cid")
    let canonicalCsgRaw = v3CompilerWorldLineValue(text, "canonical_compiler_csg_cid")
    var canonicalCsgRes: Result[layout.FixedBytes32]
    if len(canonicalCsgRaw) > 0:
        canonicalCsgRes = layout.fixedBytes32FromHex(canonicalCsgRaw)
    else:
        canonicalCsgRes = layout.fixedBytes32FromHex(v3CompilerWorldLineValue(text, "compiler_csg_cid"))
    if IsErr(canonicalCsgRes):
        return Err[bool]("v3 compiler csg: invalid canonical_compiler_csg_cid")
    let digestRes = layout.fixedBytes32FromHex(v3CompilerWorldLineValue(text, "output_digest"))
    if IsErr(digestRes):
        return Err[bool]("v3 compiler csg: invalid output_digest")
    let canonicalDigestRaw = v3CompilerWorldLineValue(text, "canonical_output_digest")
    var canonicalDigestRes: Result[layout.FixedBytes32]
    if len(canonicalDigestRaw) > 0:
        canonicalDigestRes = layout.fixedBytes32FromHex(canonicalDigestRaw)
    else:
        canonicalDigestRes = layout.fixedBytes32FromHex(v3CompilerWorldLineValue(text, "output_digest"))
    if IsErr(canonicalDigestRes):
        return Err[bool]("v3 compiler csg: invalid canonical_output_digest")
    let receiptCidRes = layout.fixedBytes32FromHex(v3CompilerWorldLineValue(text, "receipt_cid"))
    if IsErr(receiptCidRes):
        return Err[bool]("v3 compiler csg: invalid receipt_cid")
    out.version = 1
    out.worldHeadCid = Value(worldHeadRes)
    out.compilerCsgCid = Value(csgRes)
    out.canonicalCompilerCsgCid = Value(canonicalCsgRes)
    out.targetTriple = v3CompilerWorldLineValue(text, "target")
    out.outputDigest = Value(digestRes)
    out.canonicalOutputDigest = Value(canonicalDigestRes)
    out.bootstrapStage = v3CompilerWorldLineValue(text, "bootstrap_stage")
    out.runtimeProviderSet = []
    let providerPrefix = "runtime_provider["
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        var providerLine = false
        if line.len >= providerPrefix.len:
            providerLine = true
            for j in 0..<providerPrefix.len:
                if line[j] != providerPrefix[j]:
                    providerLine = false
                    break
        if !providerLine:
            continue
        let parts = strutil.Split(line, '=')
        if parts.len < 2:
            continue
        add(out.runtimeProviderSet, parts[1])
    out.receiptCid = Value(receiptCidRes)
    return Ok[bool](true)

fn v3CompileReceiptRuntimeProviderSetEqual(left: str[],
                                           right: str[]): bool =
    if left.len != right.len:
        return false
    for i in 0..<left.len:
        if left[i] != right[i]:
            return false
    return true

fn v3CompileReceiptEquivalent(base: V3CompileReceipt,
                              next: V3CompileReceipt): bool =
    if !layout.fixedBytes32Equal(base.canonicalCompilerCsgCid, next.canonicalCompilerCsgCid):
        return false
    if base.targetTriple != next.targetTriple:
        return false
    if !layout.fixedBytes32Equal(base.canonicalOutputDigest, next.canonicalOutputDigest):
        return false
    if base.bootstrapStage != next.bootstrapStage:
        return false
    if !v3CompileReceiptRuntimeProviderSetEqual(base.runtimeProviderSet, next.runtimeProviderSet):
        return false
    return true

fn v3CompilerWorldLineValue(text: str, key: str): str =
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let lineRaw = lines[i]
        let line = strutil.Strip(lineRaw)
        var matchedPrefix = false
        if line.len > key.len:
            if int32(line[key.len]) == 61:
                matchedPrefix = true
        if !matchedPrefix:
            continue
        var matched = true
        for j in 0..<key.len:
            if line[j] != key[j]:
                matched = false
                break
        if !matched:
            continue
        let valueRaw = strutil.SliceStr(line, key.len + 1, line.len - 1)
        let value = strutil.Strip(valueRaw)
        return value
    return ""
