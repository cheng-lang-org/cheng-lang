    V3TypedExprArgPassKind = texpr.V3TypedExprArgPassKind
    V3TypedExprResultPassKind = texpr.V3TypedExprResultPassKind
    V3TypedExprMaterializeKind = texpr.V3TypedExprMaterializeKind
    V3TypedExprCopyKind = texpr.V3TypedExprCopyKind
