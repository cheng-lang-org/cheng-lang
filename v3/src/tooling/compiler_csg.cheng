fn v3TypedExprFactsForSource(facts: V3TypedExprFact[],
                             sourcePathRaw: str): V3TypedExprFact[] =
    let sourcePath = parser.v3ParserNormalizePath(sourcePathRaw)
    var out: V3TypedExprFact[] = []
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath:
            continue
        add(out, v3CompilerCsgCloneTypedExprFact(facts[i]))
    return out

fn v3CompilerCsgTypedSourceText(sourcePath: str,
                                text: str): V3TypedExprSourceText =
    return texpr.v3TypedExprSourceTextNew(sourcePath, text)

fn v3CompilerCsgBuildTypedExprFacts(sourceTexts: V3TypedExprSourceText[],
                                    exprLayer: parser.V3NormalizedExprLayer,
                                    facts: var V3TypedExprFact[],
                                    err: var str): bool =
    return texpr.v3TypedExprBuildFacts(sourceTexts, exprLayer, facts, err)

fn v3CompilerCsgCloneNode(node: V3CompilerCsgNode): V3CompilerCsgNode =
    var out: V3CompilerCsgNode
    out.nodeId = node.nodeId
    out.nodeKind = node.nodeKind
    out.ownerNodeId = node.ownerNodeId
    out.modulePath = node.modulePath
    out.symbolText = node.symbolText
    out.factText = node.factText
    out.resultLayoutKind = node.resultLayoutKind
    out.effectKind = node.effectKind
    out.capabilityKind = node.capabilityKind
    out.callConv = node.callConv
    out.entryFlag = node.entryFlag
    out.exportedFlag = node.exportedFlag
    out.exportSymbolName = node.exportSymbolName
    out.factCid = node.factCid
    return out

fn v3CompilerCsgCloneNodes(nodes: V3CompilerCsgNode[]): V3CompilerCsgNode[] =
    var out: V3CompilerCsgNode[] = []
    for i in 0..<nodes.len:
        add(out, v3CompilerCsgCloneNode(nodes[i]))
    return out

fn v3CompilerCsgCloneEdge(edge: V3CompilerCsgEdge): V3CompilerCsgEdge =
    var out: V3CompilerCsgEdge
    out.edgeId = edge.edgeId
    out.fromNodeId = edge.fromNodeId
    out.toNodeId = edge.toNodeId
    out.edgeKind = edge.edgeKind
    out.edgeCid = edge.edgeCid
    return out

fn v3CompilerCsgCloneEdges(edges: V3CompilerCsgEdge[]): V3CompilerCsgEdge[] =
    var out: V3CompilerCsgEdge[] = []
    for i in 0..<edges.len:
        add(out, v3CompilerCsgCloneEdge(edges[i]))
    return out

fn v3CompilerCsgClone(csg: V3CompilerCsg): V3CompilerCsg =
    var out: V3CompilerCsg
    out.version = csg.version
    out.packageId = csg.packageId
    out.sourceBundleCid = csg.sourceBundleCid
    out.exprLayer = parser.v3NormalizedExprLayerClone(csg.exprLayer)
    out.typedExprFacts = v3CompilerCsgCloneTypedExprFacts(csg.typedExprFacts)
    out.nodeCount = csg.nodeCount
    out.edgeCount = csg.edgeCount
    out.nodes = v3CompilerCsgCloneNodes(csg.nodes)
    out.edges = v3CompilerCsgCloneEdges(csg.edges)
    out.canonicalGraphCid = csg.canonicalGraphCid
    out.graphCid = csg.graphCid
    return out

fn v3CompilerExportSurfaceClone(surface: V3CsgExportSurface): V3CsgExportSurface =
    var out: V3CsgExportSurface
    out.version = surface.version
    out.packageId = surface.packageId
    out.exportedSymbolCount = surface.exportedSymbolCount
    out.exportedSymbols = v3CompilerCsgCloneStrSeq(surface.exportedSymbols)
    out.exportedTargetNames = v3CompilerCsgCloneStrSeq(surface.exportedTargetNames)
    out.exportedLayouts = v3CompilerCsgCloneInt32Seq(surface.exportedLayouts)
    out.exportedEffects = v3CompilerCsgCloneInt32Seq(surface.exportedEffects)
    out.exportedCapabilities = v3CompilerCsgCloneInt32Seq(surface.exportedCapabilities)
    out.surfaceCid = surface.surfaceCid
    return out

fn v3CompilerLegacyMigrationClone(migration: V3CompilerLegacyMigration): V3CompilerLegacyMigration =
    var out: V3CompilerLegacyMigration
    out.version = migration.version
    out.packageId = migration.packageId
    out.entrySourcePath = migration.entrySourcePath
    out.entryModulePath = migration.entryModulePath
    out.unitCount = migration.unitCount
    out.appliedRuleCount = migration.appliedRuleCount
    out.appliedRules = v3CompilerCsgCloneStrSeq(migration.appliedRules)
    out.legacySourceBundleCid = migration.legacySourceBundleCid
    out.migratedSourceBundleCid = migration.migratedSourceBundleCid
    out.compilerCsg = v3CompilerCsgClone(migration.compilerCsg)
    out.exportSurface = v3CompilerExportSurfaceClone(migration.exportSurface)
    out.migrationCid = migration.migrationCid
    return out

fn v3CompilerCsgAppendText(buf: var layout.ByteBuf, text: str) =
    lt.v3AppendU32BE(buf, len(text))
    for i in 0..<len(text):
        layout.byteBufAppendByte(buf, int32(text[i]) & 255)

fn v3CompilerCsgAppendExprLayer(buf: var layout.ByteBuf,
                                layer: parser.V3NormalizedExprLayer) =
    lt.v3AppendU32BE(buf, layer.sourceCount)
    lt.v3AppendU32BE(buf, layer.exprs.len)
    lt.v3AppendU32BE(buf, layer.questionResidualCount)
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        v3CompilerCsgAppendText(buf, expr.exprId)
        v3CompilerCsgAppendText(buf, expr.sourcePath)
        lt.v3AppendU32BE(buf, expr.lineNumber)
        lt.v3AppendU32BE(buf, expr.columnNumber)
        lt.v3AppendU32BE(buf, expr.endLineNumber)
        lt.v3AppendU32BE(buf, expr.endColumnNumber)
        v3CompilerCsgAppendText(buf, parser.v3NormalizedExprKindText(expr.kind))
        v3CompilerCsgAppendText(buf, expr.detail)
        v3CompilerCsgAppendText(buf, expr.surfaceText)

fn v3CompilerCsgAppendTypedExprFacts(buf: var layout.ByteBuf,
                                     facts: V3TypedExprFact[]) =
    lt.v3AppendU32BE(buf, facts.len)
    for i in 0..<facts.len:
        let fact = facts[i]
        v3CompilerCsgAppendText(buf, fact.exprId)
        v3CompilerCsgAppendText(buf, fact.sourcePath)
        lt.v3AppendU32BE(buf, fact.lineNumber)
        lt.v3AppendU32BE(buf, fact.columnNumber)
        lt.v3AppendU32BE(buf, fact.endLineNumber)
        lt.v3AppendU32BE(buf, fact.endColumnNumber)
        v3CompilerCsgAppendText(buf, parser.v3NormalizedExprKindText(fact.kind))
        v3CompilerCsgAppendText(buf, fact.typeText)
        v3CompilerCsgAppendText(buf, v3TypedExprAbiClassText(fact.abiClass))
        v3CompilerCsgAppendText(buf, v3TypedExprValueKindText(fact.valueKind))
        v3CompilerCsgAppendText(buf, v3TypedExprPlaceKindText(fact.placeKind))
        v3CompilerCsgAppendText(buf, v3TypedExprLoweringModeText(fact.loweringMode))
        v3CompilerCsgAppendText(buf, v3TypedExprCallKindText(fact.callKind))
        v3CompilerCsgAppendText(buf, v3TypedExprReturnKindText(fact.returnKind))

fn v3CompilerCsgHashNode(nodeKind: int32,
                         ownerNodeId: int32,
                         modulePath: str,
                         symbolText: str,
                         factText: str,
                         resultLayoutKind: int32,
                         effectKind: int32,
                         capabilityKind: int32,
                         callConv: int32,
                         entryFlag: int32,
                         exportedFlag: int32,
                         exportSymbolName: str): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    v3CompilerCsgAppendText(buf, "v3.compiler.csg.node")
    lt.v3AppendU32BE(buf, nodeKind)
    lt.v3AppendU32BE(buf, ownerNodeId)
    v3CompilerCsgAppendText(buf, modulePath)
    v3CompilerCsgAppendText(buf, symbolText)
    v3CompilerCsgAppendText(buf, factText)
    lt.v3AppendU32BE(buf, resultLayoutKind)
    lt.v3AppendU32BE(buf, effectKind)
    lt.v3AppendU32BE(buf, capabilityKind)
    lt.v3AppendU32BE(buf, callConv)
    lt.v3AppendU32BE(buf, entryFlag)
    lt.v3AppendU32BE(buf, exportedFlag)
    v3CompilerCsgAppendText(buf, exportSymbolName)
    return lt.v3FixedCidFromBuf(buf)

fn v3CompilerCsgHashEdge(fromNodeId: int32,
                         toNodeId: int32,
                         edgeKind: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(96)
    v3CompilerCsgAppendText(buf, "v3.compiler.csg.edge")
    lt.v3AppendU32BE(buf, fromNodeId)
    lt.v3AppendU32BE(buf, toNodeId)
    lt.v3AppendU32BE(buf, edgeKind)
    return lt.v3FixedCidFromBuf(buf)

fn v3CompilerCsgGraphCid(packageId: str,
                         sourceBundleCid: layout.FixedBytes32,
                         exprLayer: parser.V3NormalizedExprLayer,
                         typedExprFacts: V3TypedExprFact[],
                         nodes: V3CompilerCsgNode[],
                         edges: V3CompilerCsgEdge[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(512)
    v3CompilerCsgAppendText(buf, "v3.compiler.csg.graph")
    v3CompilerCsgAppendText(buf, packageId)
    lt.v3AppendFixed32(buf, sourceBundleCid)
    v3CompilerCsgAppendExprLayer(buf, exprLayer)
    v3CompilerCsgAppendTypedExprFacts(buf, typedExprFacts)
    lt.v3AppendU32BE(buf, nodes.len)
    for i in 0..<nodes.len:
        let node = nodes[i]
        lt.v3AppendU32BE(buf, node.nodeId)
        lt.v3AppendU32BE(buf, node.nodeKind)
        lt.v3AppendU32BE(buf, node.ownerNodeId)
        v3CompilerCsgAppendText(buf, node.modulePath)
        v3CompilerCsgAppendText(buf, node.symbolText)
        v3CompilerCsgAppendText(buf, node.factText)
        lt.v3AppendU32BE(buf, node.resultLayoutKind)
        lt.v3AppendU32BE(buf, node.effectKind)
        lt.v3AppendU32BE(buf, node.capabilityKind)
        lt.v3AppendU32BE(buf, node.callConv)
        lt.v3AppendU32BE(buf, node.entryFlag)
        lt.v3AppendU32BE(buf, node.exportedFlag)
        v3CompilerCsgAppendText(buf, node.exportSymbolName)
        lt.v3AppendFixed32(buf, node.factCid)
    lt.v3AppendU32BE(buf, edges.len)
    for i in 0..<edges.len:
        let edge = edges[i]
        lt.v3AppendU32BE(buf, edge.edgeId)
        lt.v3AppendU32BE(buf, edge.fromNodeId)
        lt.v3AppendU32BE(buf, edge.toNodeId)
        lt.v3AppendU32BE(buf, edge.edgeKind)
        lt.v3AppendFixed32(buf, edge.edgeCid)
    return lt.v3FixedCidFromBuf(buf)

fn v3CompilerCsgCanonicalGraphCid(packageId: str,
                                  exprLayer: parser.V3NormalizedExprLayer,
                                  typedExprFacts: V3TypedExprFact[],
                                  nodes: V3CompilerCsgNode[],
                                  edges: V3CompilerCsgEdge[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(512)
    v3CompilerCsgAppendText(buf, "v3.compiler.csg.canonical_graph")
    v3CompilerCsgAppendText(buf, packageId)
    let _ = exprLayer
    let _ = typedExprFacts
    lt.v3AppendU32BE(buf, nodes.len)
    for i in 0..<nodes.len:
        let node = nodes[i]
        lt.v3AppendU32BE(buf, node.nodeId)
        lt.v3AppendU32BE(buf, node.nodeKind)
        lt.v3AppendU32BE(buf, node.ownerNodeId)
        v3CompilerCsgAppendText(buf, node.modulePath)
        v3CompilerCsgAppendText(buf, node.symbolText)
        v3CompilerCsgAppendText(buf, node.factText)
        lt.v3AppendU32BE(buf, node.resultLayoutKind)
        lt.v3AppendU32BE(buf, node.effectKind)
        lt.v3AppendU32BE(buf, node.capabilityKind)
        lt.v3AppendU32BE(buf, node.callConv)
        lt.v3AppendU32BE(buf, node.entryFlag)
        lt.v3AppendU32BE(buf, node.exportedFlag)
        v3CompilerCsgAppendText(buf, node.exportSymbolName)
        lt.v3AppendFixed32(buf, node.factCid)
    lt.v3AppendU32BE(buf, edges.len)
    for i in 0..<edges.len:
        let edge = edges[i]
        lt.v3AppendU32BE(buf, edge.edgeId)
        lt.v3AppendU32BE(buf, edge.fromNodeId)
        lt.v3AppendU32BE(buf, edge.toNodeId)
        lt.v3AppendU32BE(buf, edge.edgeKind)
        lt.v3AppendFixed32(buf, edge.edgeCid)
    return lt.v3FixedCidFromBuf(buf)

fn v3CompilerCsgAddUnique(items: var str[],
                          text: str) =
    for i in 0..<items.len:
        if items[i] == text:
            return
    add(items, text)

fn v3CompilerCsgStrLess(left: str,
                        right: str): bool =
    if left == right:
        return false
    let leftLen = len(left)
    let rightLen = len(right)
    let sharedLen = leftLen < rightLen ? leftLen : rightLen
    for i in 0..<sharedLen:
        if left[i] == right[i]:
            continue
        return left[i] < right[i]
    return leftLen < rightLen

fn v3CompilerCsgSortStrs(items: var str[]) =
    if items.len <= 1:
        return
    var i = 1
    while i < items.len:
        let value = items[i]
        var j = i
        while j > 0:
            if !v3CompilerCsgStrLess(value, items[j - 1]):
                break
            items[j] = items[j - 1]
            j = j - 1
        items[j] = value
        i = i + 1

fn v3CompilerCsgAddUniqueImportPair(pairs: var V3CompilerCsgImportPair[],
                                    ownerModulePath: str,
                                    targetModulePath: str) =
    for i in 0..<pairs.len:
        if pairs[i].ownerModulePath != ownerModulePath:
            continue
        if pairs[i].targetModulePath != targetModulePath:
            continue
        return
    add(pairs, V3CompilerCsgImportPair(ownerModulePath: ownerModulePath,
                                       targetModulePath: targetModulePath))

fn v3CompilerCsgImportPairLess(left: V3CompilerCsgImportPair,
                               right: V3CompilerCsgImportPair): bool =
    if left.ownerModulePath != right.ownerModulePath:
        return v3CompilerCsgStrLess(left.ownerModulePath, right.ownerModulePath)
    return v3CompilerCsgStrLess(left.targetModulePath, right.targetModulePath)

fn v3CompilerCsgSortImportPairs(pairs: var V3CompilerCsgImportPair[]) =
    if pairs.len <= 1:
        return
    var i = 1
    while i < pairs.len:
        let value = pairs[i]
        var j = i
        while j > 0:
            if !v3CompilerCsgImportPairLess(value, pairs[j - 1]):
                break
            pairs[j] = pairs[j - 1]
            j = j - 1
        pairs[j] = value
        i = i + 1

fn v3CompilerCsgFunctionNameFromLine(lineRaw: str): str =
    return parser.v3ParserFunctionNameFromLine(lineRaw)

fn v3CompilerCsgIsImportcAnnotation(lineRaw: str): bool =
    return parser.v3ParserIsImportcAnnotation(lineRaw)

fn v3CompilerCsgModuleNodeId(nodes: V3CompilerCsgNode[],
                             modulePath: str): int32 =
    for i in 0..<nodes.len:
        let node = nodes[i]
        if node.nodeKind != v3CompilerCsgNodeKindModule:
            continue
        if node.modulePath == modulePath:
            return node.nodeId
    return -1

fn v3CompilerCsgSymbolExported(functionName: str,
                               entryFlag: int32): bool =
    let _ = entryFlag
    if len(functionName) <= 0:
        return false
    let ch = functionName[0]
    return ch >= 'A' && ch <= 'Z'

fn v3CompilerCsgFindText(text: str,
                         needle: str): int32 =
    if needle.len <= 0:
        return 0
    if text.len < needle.len:
        return -1
    for i in 0..<(text.len - needle.len + 1):
        var matched = true
        for j in 0..<needle.len:
            if text[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn v3CompilerCsgExportNameFromAnnotation(lineRaw: str): str =
    return parser.v3ParserCompilerTopLevelExportName(lineRaw)

fn v3CompilerCsgExportcNameFromAnnotation(lineRaw: str): str =
    return parser.v3ParserExportcNameFromAnnotation(lineRaw)

fn v3CompilerCsgTargetExportName(symbolText: str,
                                 explicitExportName: str,
                                 functionName: str): str =
    if len(explicitExportName) > 0:
        return explicitExportName
    if len(functionName) > 0:
        return functionName
    let suffixPos = v3CompilerCsgFindText(symbolText, "::")
    if suffixPos < 0:
        return symbolText
    return v3path.V3TextSlice(symbolText, suffixPos + 2, symbolText.len - (suffixPos + 2))

fn v3CompilerCsgShouldExportSymbol(emitKind: creq.V3CompilerEmit,
                                   entrySourceFlag: bool,
                                   entryHasExplicitExports: bool,
                                   explicitExportName: str,
                                   functionName: str,
                                   entryFlag: int32): bool =
    if emitKind != creq.v3EmitShared && emitKind != creq.v3EmitObj:
        if len(explicitExportName) > 0:
            return true
        return v3CompilerCsgSymbolExported(functionName, entryFlag)
    if !entrySourceFlag:
        return false
    if entryHasExplicitExports:
        return len(explicitExportName) > 0
    return true

fn v3CompilerCsgSourceTextLookup(overrides: V3CompilerCsgSourceText[],
                                 sourcePath: str,
                                 out: var str): bool =
    for i in 0..<overrides.len:
        if overrides[i].sourcePath != sourcePath:
            continue
        out = overrides[i].text
        return true
    return false

fn v3CompilerCsgSourceModulePath(workspaceRoot: str,
                                 packageRoot: str,
                                 overrides: V3CompilerCsgSourceText[],
                                 sourcePath: str): str =
    for i in 0..<overrides.len:
        if overrides[i].sourcePath != sourcePath:
            continue
        if len(overrides[i].modulePath) > 0:
            return overrides[i].modulePath
    return parser.v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)

fn v3CompilerCsgAddBrowserAbiRulesForSource(rules: var V3BrowserAbiRule[],
                                            ownerModulePath: str,
                                            sourcePath: str) =
    if ownerModulePath != browsercodec.v3BrowserContentCodecModulePath():
        return
    let codecRules = browsercodec.v3BrowserContentCodecRules(sourcePath)
    for i in 0..<codecRules.len:
        add(rules, v3BrowserAbiRuleClone(codecRules[i]))

fn v3CompilerBrowserAbiRulesForLinkPlan(linkPlan: slplan.V3SystemLinkPlanStub): V3BrowserAbiRule[] =
    var out: V3BrowserAbiRule[] = []
    var orderedSources: str[] = []
    for i in 0..<linkPlan.sourceClosurePaths.len:
        add(orderedSources, linkPlan.sourceClosurePaths[i])
    v3CompilerCsgSortStrs(orderedSources)
    for i in 0..<orderedSources.len:
        let sourcePath = orderedSources[i]
        let ownerModulePath = parser.v3ParserSourcePathToModulePath(linkPlan.workspaceRoot,
                                                                    linkPlan.packageRoot,
                                                                    sourcePath)
        v3CompilerCsgAddBrowserAbiRulesForSource(out, ownerModulePath, sourcePath)
    return out

fn v3CompilerLegacyLineIndentAt(rawLine: str,
                                stop: int32): str =
    let n = len(rawLine)
    if stop >= n:
        return rawLine
    for i in stop..<n:
        let code = int32(rawLine[i])
        if code == 32 || code == 9:
            continue
        return v3path.V3TextSlice(rawLine, 0, i)
    return rawLine

fn v3CompilerLegacyLineIndent(rawLine: str): str =
    return v3CompilerLegacyLineIndentAt(rawLine, 0)

fn v3CompilerLegacyFindMatchingBracket(text: str,
                                       openIndex: int32): int32 =
    return v3CompilerLegacyFindMatchingBracketStep(text, openIndex, 0)

fn v3CompilerLegacyFindMatchingBracketStep(text: str,
                                           index: int32,
                                           depth: int32): int32 =
    let n = len(text)
    var currentDepth = depth
    for i in index..<n:
        let code = int32(text[i])
        if code == 91:
            currentDepth = currentDepth + 1
            continue
        if code == 93:
            let nextDepth = currentDepth - 1
            if nextDepth == 0:
                return i
            currentDepth = nextDepth
    return -1

fn v3CompilerLegacyTopLevelComma(text: str): int32 =
    return v3CompilerLegacyTopLevelCommaStep(text, 0, 0)

fn v3CompilerLegacyTopLevelCommaStep(text: str,
                                     index: int32,
                                     depth: int32): int32 =
    let n = len(text)
    var currentDepth = depth
    for i in index..<n:
        let code = int32(text[i])
        if code == 91:
            currentDepth = currentDepth + 1
            continue
        if code == 93:
            currentDepth = currentDepth - 1
            continue
        if code == 44 && currentDepth == 0:
            return i
    return -1

fn v3CompilerLegacyRewriteSeqTypes(textRaw: str,
                                   outAppliedCount: var int32): str =
    var text = textRaw
    outAppliedCount = 0
    var i = 0
    while i < len(text):
        if i + 4 > len(text):
            break
        if v3path.V3TextSlice(text, i, 4) != "seq[":
            i = i + 1
            continue
        let closePos = v3CompilerLegacyFindMatchingBracket(text, i + 3)
        if closePos <= i + 3:
            i = i + 1
            continue
        let inner = v3path.V3TextSlice(text, i + 4, closePos - (i + 4))
        let replacement = strutil.Strip(inner) + "[]"
        text = v3path.V3TextSlice(text, 0, i) +
               replacement +
               v3path.V3TextSlice(text, closePos + 1, len(text) - (closePos + 1))
        outAppliedCount = outAppliedCount + 1
        i = i + len(replacement)
    return text

fn v3CompilerLegacyRewriteArrayTypes(textRaw: str,
                                     outAppliedCount: var int32): str =
    var text = textRaw
    outAppliedCount = 0
    var i = 0
    while i < len(text):
        if i + 6 > len(text):
            break
        if v3path.V3TextSlice(text, i, 6) != "array[":
            i = i + 1
            continue
        let closePos = v3CompilerLegacyFindMatchingBracket(text, i + 5)
        if closePos <= i + 5:
            i = i + 1
            continue
        let inner = v3path.V3TextSlice(text, i + 6, closePos - (i + 6))
        let commaPos = v3CompilerLegacyTopLevelComma(inner)
        if commaPos <= 0:
            i = i + 1
            continue
        let elemText = strutil.Strip(v3path.V3TextSlice(inner, 0, commaPos))
        let lenText = strutil.Strip(v3path.V3TextSlice(inner, commaPos + 1, len(inner) - (commaPos + 1)))
        let replacement = elemText + "[" + lenText + "]"
        text = v3path.V3TextSlice(text, 0, i) +
               replacement +
               v3path.V3TextSlice(text, closePos + 1, len(text) - (closePos + 1))
        outAppliedCount = outAppliedCount + 1
        i = i + len(replacement)
    return text

fn v3CompilerLegacyNormalizeText(textRaw: str,
                                 outAppliedRules: var str[],
                                 outAppliedCount: var int32): str =
    outAppliedRules = []
    outAppliedCount = 0
    var text = textRaw
    let elseIfText = strutil.Replace(text, "else if", "elif")
    if elseIfText != text:
        v3CompilerCsgAddUnique(outAppliedRules, "else_if_to_elif")
        outAppliedCount = outAppliedCount + 1
        text = elseIfText
    let atListText = strutil.Replace(text, "@[]", "[]")
    if atListText != text:
        v3CompilerCsgAddUnique(outAppliedRules, "at_list_to_list")
        outAppliedCount = outAppliedCount + 1
        text = atListText
    var seqApplied = 0
    text = v3CompilerLegacyRewriteSeqTypes(text, seqApplied)
    if seqApplied > 0:
        v3CompilerCsgAddUnique(outAppliedRules, "seq_type_to_suffix")
        outAppliedCount = outAppliedCount + seqApplied
    var arrayApplied = 0
    text = v3CompilerLegacyRewriteArrayTypes(text, arrayApplied)
    if arrayApplied > 0:
        v3CompilerCsgAddUnique(outAppliedRules, "array_type_to_suffix")
        outAppliedCount = outAppliedCount + arrayApplied
    let lines = parser.v3ParserSplitChar(text, '\n')
    var out = ""
    for i in 0..<lines.len:
        var line = lines[i]
        let trimmed = v3path.V3PathTrim(line)
        let indent = v3CompilerLegacyLineIndent(line)
        if v3path.V3TextStartsWith(trimmed, "proc "):
            v3CompilerCsgAddUnique(outAppliedRules, "proc_to_fn")
            outAppliedCount = outAppliedCount + 1
            line = indent + "fn " + v3path.V3TextSlice(trimmed, len("proc "), len(trimmed) - len("proc "))
        elif v3path.V3TextStartsWith(trimmed, "method "):
            v3CompilerCsgAddUnique(outAppliedRules, "method_to_fn")
            outAppliedCount = outAppliedCount + 1
            line = indent + "fn " + v3path.V3TextSlice(trimmed, len("method "), len(trimmed) - len("method "))
        elif v3path.V3TextStartsWith(trimmed, "converter "):
            v3CompilerCsgAddUnique(outAppliedRules, "converter_to_fn")
            outAppliedCount = outAppliedCount + 1
            line = indent + "fn " + v3path.V3TextSlice(trimmed, len("converter "), len(trimmed) - len("converter "))
        if i > 0:
            out = out + "\n"
        out = out + line
    return out

fn v3CompilerLegacyPackageId(modulePathRaw: str): str =
    let parts = parser.v3ParserSplitChar(v3path.V3PathTrim(modulePathRaw), '/')
    if parts.len >= 2:
        return parts[0] + "/" + parts[1]
    if parts.len == 1:
        return parts[0]
    return "legacy"

fn v3CompilerCsgAddUniqueImportEdge(edges: var parser.V3ImportEdge[],
                                    edge: parser.V3ImportEdge) =
    for i in 0..<edges.len:
        if edges[i].ownerModulePath != edge.ownerModulePath:
            continue
        if edges[i].targetModulePath != edge.targetModulePath:
            continue
        return
    add(edges, edge)

fn v3CompilerLegacyCollectClosure(workspaceRoot: str,
                                  packageRoot: str,
                                  sourcePathRaw: str,
                                  entryModulePathOverride: str,
                                  seen: var str[],
                                  units: var V3CompilerLegacySourceUnit[],
                                  ownerModulePaths: var str[],
                                  importEdges: var parser.V3ImportEdge[],
                                  outAppliedRules: var str[],
                                  outAppliedCount: var int32,
                                  unresolvedImportCount: var int32,
                                  err: var str): bool =
    let sourcePath = v3path.V3PathTrim(sourcePathRaw)
    if sourcePath == "":
        err = "v3 compiler migration: missing legacy source path"
        return false
    for i in 0..<seen.len:
        if seen[i] == sourcePath:
            err = ""
            return true
    if !v3path.V3PathFileExists(sourcePath):
        err = "v3 compiler migration: missing legacy source: " + sourcePath
        return false
    add(seen, sourcePath)
    let legacyText = v3path.V3ReadTextFile("", sourcePath)
    var localRules: str[]
    var localAppliedCount = 0
    let migratedText = v3CompilerLegacyNormalizeText(legacyText, localRules, localAppliedCount)
    var modulePath = parser.v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)
    if len(entryModulePathOverride) > 0:
        if sourcePath == seen[0]:
            modulePath = entryModulePathOverride
    var unit: V3CompilerLegacySourceUnit
    unit.sourcePath = sourcePath
    unit.modulePath = modulePath
    unit.legacyText = legacyText
    unit.migratedText = migratedText
    add(units, unit)
    v3CompilerCsgAddUnique(ownerModulePaths, modulePath)
    for i in 0..<localRules.len:
        v3CompilerCsgAddUnique(outAppliedRules, localRules[i])
    outAppliedCount = outAppliedCount + localAppliedCount
    var localEdges: parser.V3ImportEdge[]
    if !parser.v3ParserReadImportEdges(workspaceRoot, packageRoot, modulePath, migratedText, localEdges, err):
        return false
    for i in 0..<localEdges.len:
        let edge = localEdges[i]
        v3CompilerCsgAddUniqueImportEdge(importEdges, edge)
        if edge.resolved:
            v3CompilerCsgAddUnique(ownerModulePaths, edge.targetModulePath)
            if !v3CompilerLegacyCollectClosure(workspaceRoot,
                                               packageRoot,
                                               edge.targetSourcePath,
                                               "",
                                               seen,
                                               units,
                                               ownerModulePaths,
                                               importEdges,
                                               outAppliedRules,
                                               outAppliedCount,
                                               unresolvedImportCount,
                                               err):
                return false
        else:
            unresolvedImportCount = unresolvedImportCount + 1
    err = ""
    return true

fn v3CompilerLegacyFindUnitText(units: V3CompilerLegacySourceUnit[],
                                sourcePath: str,
                                out: var str): bool =
    for i in 0..<units.len:
        if units[i].sourcePath != sourcePath:
            continue
        out = units[i].migratedText
        return true
    return false

fn v3CompilerLegacyBuildPlan(workspaceRoot: str,
                             packageRoot: str,
                             entrySourcePath: str,
                             packageId: str,
                             units: V3CompilerLegacySourceUnit[],
                             ownerModulePaths: str[],
                             importEdges: parser.V3ImportEdge[],
                             unresolvedImportCount: int32,
                             out: var slplan.V3SystemLinkPlanStub): bool =
    let entryModulePath = units.len > 0 ? units[0].modulePath : parser.v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, entrySourcePath)
    out.entryPath = entrySourcePath
    out.outputPath = ""
    out.targetTriple = "arm64-apple-darwin"
    out.emitKind = creq.v3EmitExe
    out.packageRoot = packageRoot
    out.workspaceRoot = workspaceRoot
    out.packageId = packageId
    out.moduleStem = parser.v3ParserFileStem(entrySourcePath)
    out.moduleKind = entryModulePath == "cheng/v3/tooling/compiler_main" ? slplan.v3SystemCompilerControlPlane : slplan.v3SystemOrdinaryProgram
    out.sourceClosurePaths = []
    for i in 0..<units.len:
        add(out.sourceClosurePaths, units[i].sourcePath)
    out.ownerModulePaths = ownerModulePaths
    out.importEdges = importEdges
    out.importEdgeCount = importEdges.len
    out.unresolvedImportCount = unresolvedImportCount
    out.hasCompilerTopLevel = true
    var entryText = ""
    let foundEntryText = v3CompilerLegacyFindUnitText(units, entrySourcePath, entryText)
    out.mainFunctionPresent = foundEntryText && parser.v3ParserMainFunctionPresent(entryText)
    if out.moduleKind == slplan.v3SystemCompilerControlPlane:
        out.runtimeTargets = ["runtime/compiler.tooling_argv_entry"]
    else:
        out.runtimeTargets = ["runtime/compiler.program_argv_entry"]
    var providerModules: str[]
    if out.moduleKind == slplan.v3SystemCompilerControlPlane:
        crun.v3RuntimeProviderModulesForTrack(crun.v3CompilerTrackTooling, providerModules)
    else:
        crun.v3RuntimeProviderModulesForTrack(crun.v3CompilerTrackProgram, providerModules)
    out.providerModules = providerModules
    out.entrySymbol = out.mainFunctionPresent ? "main" : ""
    out.missingReasons = []
    out.parserSyntaxTag = "v3.legacy_migrated_source"
    out.parserSourceKind = 1
    out.buildEntryPath = entrySourcePath
    out.buildSourceUnitCount = units.len
    out.linkMode = "system_link"
    out.pipelineStage = "legacy_source_to_canonical_csg"
    return true

fn v3BuildCompilerLegacyMigration(workspaceRoot: str,
                                  packageRoot: str,
                                  entrySourcePath: str,
                                  packageIdHint: str,
                                  entryModulePathOverride: str): Result[V3CompilerLegacyMigration] =
    var seen: str[] = []
    var units: V3CompilerLegacySourceUnit[] = []
    var ownerModulePaths: str[] = []
    var importEdges: parser.V3ImportEdge[] = []
    var appliedRules: str[] = []
    var appliedCount = 0
    var unresolvedImportCount = 0
    var err = ""
    if !v3CompilerLegacyCollectClosure(workspaceRoot,
                                       packageRoot,
                                       entrySourcePath,
                                       entryModulePathOverride,
                                       seen,
                                       units,
                                       ownerModulePaths,
                                       importEdges,
                                       appliedRules,
                                       appliedCount,
                                       unresolvedImportCount,
                                       err):
        return Err[V3CompilerLegacyMigration](err)
    v3CompilerCsgSortStrs(ownerModulePaths)
    var legacySourcePaths: str[] = []
    var legacyTexts: str[] = []
    var migratedSourcePaths: str[] = []
    var migratedTexts: str[] = []
    for i in 0..<units.len:
        add(legacySourcePaths, units[i].sourcePath)
        add(legacyTexts, units[i].legacyText)
        add(migratedSourcePaths, units[i].sourcePath)
        add(migratedTexts, units[i].migratedText)
    let packageId = len(packageIdHint) > 0 ? packageIdHint : v3CompilerLegacyPackageId(units[0].modulePath)
    let legacyBundleRes = cworld.v3CompilerWorldSourceBundleCidFromTexts(packageId, legacySourcePaths, legacyTexts)
    if IsErr(legacyBundleRes):
        return Err[V3CompilerLegacyMigration](Error(legacyBundleRes))
    let migratedBundleRes = cworld.v3CompilerWorldSourceBundleCidFromTexts(packageId, migratedSourcePaths, migratedTexts)
    if IsErr(migratedBundleRes):
        return Err[V3CompilerLegacyMigration](Error(migratedBundleRes))
    var plan: slplan.V3SystemLinkPlanStub
    if !v3CompilerLegacyBuildPlan(workspaceRoot,
                                  packageRoot,
                                  entrySourcePath,
                                  packageId,
                                  units,
                                  ownerModulePaths,
                                  importEdges,
                                  unresolvedImportCount,
                                  plan):
        return Err[V3CompilerLegacyMigration]("v3 compiler migration: failed to build legacy plan")
    var overrides: V3CompilerCsgSourceText[] = []
    for i in 0..<units.len:
        var override: V3CompilerCsgSourceText
        override.sourcePath = units[i].sourcePath
        override.modulePath = units[i].modulePath
        override.text = units[i].migratedText
        add(overrides, override)
    let csgRes = v3BuildCompilerCsgWithOverrides(plan, Value(migratedBundleRes), overrides)
    if IsErr(csgRes):
        return Err[V3CompilerLegacyMigration](Error(csgRes))
    let csg = v3CompilerCsgClone(Value(csgRes))
    let surface = v3CompilerExportSurfaceClone(v3CompilerExportSurfaceFromCsg(csg))
    var migBuf: layout.ByteBuf = layout.byteBufInit(256)
    v3CompilerCsgAppendText(migBuf, "v3.compiler.legacy_migration")
    v3CompilerCsgAppendText(migBuf, packageId)
    v3CompilerCsgAppendText(migBuf, entrySourcePath)
    lt.v3AppendFixed32(migBuf, Value(legacyBundleRes))
    lt.v3AppendFixed32(migBuf, Value(migratedBundleRes))
    lt.v3AppendFixed32(migBuf, csg.canonicalGraphCid)
    lt.v3AppendFixed32(migBuf, surface.surfaceCid)
    lt.v3AppendU32BE(migBuf, appliedRules.len)
    for i in 0..<appliedRules.len:
        v3CompilerCsgAppendText(migBuf, appliedRules[i])
    var out: V3CompilerLegacyMigration
    out.version = 1
    out.packageId = packageId
    out.entrySourcePath = entrySourcePath
    out.entryModulePath = units[0].modulePath
    out.unitCount = units.len
    out.appliedRuleCount = appliedCount
    out.appliedRules = appliedRules
    out.legacySourceBundleCid = Value(legacyBundleRes)
    out.migratedSourceBundleCid = Value(migratedBundleRes)
    out.compilerCsg = v3CompilerCsgClone(csg)
    out.exportSurface = v3CompilerExportSurfaceClone(surface)
    out.migrationCid = lt.v3FixedCidFromBuf(migBuf)
    return Ok[V3CompilerLegacyMigration](out)

fn v3CompilerLegacyMigrationReport(migration: V3CompilerLegacyMigration): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "package_id=" + migration.packageId + "\n"
    out = out + "entry_source_path=" + migration.entrySourcePath + "\n"
    out = out + "entry_module_path=" + migration.entryModulePath + "\n"
    out = out + "unit_count=" + intToStr(migration.unitCount) + "\n"
    out = out + "applied_rule_count=" + intToStr(migration.appliedRuleCount) + "\n"
    out = out + "legacy_source_bundle_cid=" + layout.fixedBytes32Hex(migration.legacySourceBundleCid) + "\n"
    out = out + "migrated_source_bundle_cid=" + layout.fixedBytes32Hex(migration.migratedSourceBundleCid) + "\n"
    out = out + "canonical_graph_cid=" + layout.fixedBytes32Hex(migration.compilerCsg.canonicalGraphCid) + "\n"
    out = out + "graph_cid=" + layout.fixedBytes32Hex(migration.compilerCsg.graphCid) + "\n"
    out = out + "surface_cid=" + layout.fixedBytes32Hex(migration.exportSurface.surfaceCid) + "\n"
    out = out + "migration_cid=" + layout.fixedBytes32Hex(migration.migrationCid)
    for i in 0..<migration.appliedRules.len:
        out = out + "\n" + "applied_rule[" + intToStr(i) + "]=" + migration.appliedRules[i]
    return out

fn v3CompilerCsgAddNode(nodes: var V3CompilerCsgNode[],
                        nodeKind: int32,
                        ownerNodeId: int32,
                        modulePath: str,
                        symbolText: str,
                        factText: str,
                        resultLayoutKind: int32,
                        effectKind: int32,
                        capabilityKind: int32,
                        callConv: int32,
                        entryFlag: int32,
                        exportedFlag: int32,
                        exportSymbolName: str): int32 =
    var node: V3CompilerCsgNode
    node.nodeId = nodes.len + 1
    node.nodeKind = nodeKind
    node.ownerNodeId = ownerNodeId
    node.modulePath = modulePath
    node.symbolText = symbolText
    node.factText = factText
    node.resultLayoutKind = resultLayoutKind
    node.effectKind = effectKind
    node.capabilityKind = capabilityKind
    node.callConv = callConv
    node.entryFlag = entryFlag
    node.exportedFlag = exportedFlag
    node.exportSymbolName = exportSymbolName
    node.factCid = v3CompilerCsgHashNode(nodeKind,
                                         ownerNodeId,
                                         modulePath,
                                         symbolText,
                                         factText,
                                         resultLayoutKind,
                                         effectKind,
                                         capabilityKind,
                                         callConv,
                                         entryFlag,
                                         exportedFlag,
                                         exportSymbolName)
    add(nodes, node)
    return node.nodeId

fn v3CompilerCsgAddEdge(edges: var V3CompilerCsgEdge[],
                        fromNodeId: int32,
                        toNodeId: int32,
                        edgeKind: int32) =
    var edge: V3CompilerCsgEdge
    edge.edgeId = edges.len + 1
    edge.fromNodeId = fromNodeId
    edge.toNodeId = toNodeId
    edge.edgeKind = edgeKind
    edge.edgeCid = v3CompilerCsgHashEdge(fromNodeId, toNodeId, edgeKind)
    add(edges, edge)

fn v3CompilerCsgExprLayerForText(sourcePath: str,
                                 text: str,
                                 layer: var parser.V3NormalizedExprLayer): Result[bool] =
    var err: str = ""
    if !parser.v3ParserReadNormalizedExprLayerFromText(sourcePath, text, layer, err):
        return Err[bool]("v3 compiler csg: expr layer read failed")
    return Ok[bool](true)

fn v3BuildCompilerCsgWithOverrides(linkPlan: slplan.V3SystemLinkPlanStub,
                                   sourceBundleCid: layout.FixedBytes32,
                                   sourceTextOverrides: V3CompilerCsgSourceText[]): Result[V3CompilerCsg] =
    var modules: str[] = []
    var importPairs: V3CompilerCsgImportPair[] = []
    for i in 0..<linkPlan.ownerModulePaths.len:
        v3CompilerCsgAddUnique(modules, linkPlan.ownerModulePaths[i])
    for i in 0..<linkPlan.importEdges.len:
        v3CompilerCsgAddUnique(modules, linkPlan.importEdges[i].ownerModulePath)
        if linkPlan.importEdges[i].resolved:
            v3CompilerCsgAddUnique(modules, linkPlan.importEdges[i].targetModulePath)
            v3CompilerCsgAddUniqueImportPair(importPairs,
                                             linkPlan.importEdges[i].ownerModulePath,
                                             linkPlan.importEdges[i].targetModulePath)
    v3CompilerCsgSortStrs(modules)
    v3CompilerCsgSortImportPairs(importPairs)
    var nodes: V3CompilerCsgNode[] = []
    var edges: V3CompilerCsgEdge[] = []
    var exprLayer = parser.v3NormalizedExprLayerZero()
    var packageNode: V3CompilerCsgNode
    packageNode.nodeId = nodes.len + 1
    packageNode.nodeKind = v3CompilerCsgNodeKindPackage
    packageNode.ownerNodeId = 0
    packageNode.modulePath = ""
    packageNode.symbolText = ""
    packageNode.factText = linkPlan.packageId
    packageNode.resultLayoutKind = 0
    packageNode.effectKind = 0
    packageNode.capabilityKind = 0
    packageNode.callConv = 0
    packageNode.entryFlag = 0
    packageNode.exportedFlag = 0
    packageNode.exportSymbolName = ""
    var packageBuf: layout.ByteBuf = layout.byteBufInit(256)
    v3CompilerCsgAppendText(packageBuf, "v3.compiler.csg.node")
    lt.v3AppendU32BE(packageBuf, packageNode.nodeKind)
    lt.v3AppendU32BE(packageBuf, packageNode.ownerNodeId)
    v3CompilerCsgAppendText(packageBuf, packageNode.modulePath)
    v3CompilerCsgAppendText(packageBuf, packageNode.symbolText)
    v3CompilerCsgAppendText(packageBuf, packageNode.factText)
    lt.v3AppendU32BE(packageBuf, packageNode.resultLayoutKind)
    lt.v3AppendU32BE(packageBuf, packageNode.effectKind)
    lt.v3AppendU32BE(packageBuf, packageNode.capabilityKind)
    lt.v3AppendU32BE(packageBuf, packageNode.callConv)
    lt.v3AppendU32BE(packageBuf, packageNode.entryFlag)
    lt.v3AppendU32BE(packageBuf, packageNode.exportedFlag)
    v3CompilerCsgAppendText(packageBuf, packageNode.exportSymbolName)
    packageNode.factCid = lt.v3FixedCidFromBuf(packageBuf)
    add(nodes, packageNode)
    let packageNodeId = packageNode.nodeId
    for i in 0..<modules.len:
        var moduleNode: V3CompilerCsgNode
        moduleNode.nodeId = nodes.len + 1
        moduleNode.nodeKind = v3CompilerCsgNodeKindModule
        moduleNode.ownerNodeId = packageNodeId
        moduleNode.modulePath = modules[i]
        moduleNode.symbolText = ""
        moduleNode.factText = modules[i]
        moduleNode.resultLayoutKind = 0
        moduleNode.effectKind = 0
        moduleNode.capabilityKind = 0
        moduleNode.callConv = 0
        moduleNode.entryFlag = 0
        moduleNode.exportedFlag = 0
        moduleNode.exportSymbolName = ""
        var moduleBuf: layout.ByteBuf = layout.byteBufInit(256)
        v3CompilerCsgAppendText(moduleBuf, "v3.compiler.csg.node")
        lt.v3AppendU32BE(moduleBuf, moduleNode.nodeKind)
        lt.v3AppendU32BE(moduleBuf, moduleNode.ownerNodeId)
        v3CompilerCsgAppendText(moduleBuf, moduleNode.modulePath)
        v3CompilerCsgAppendText(moduleBuf, moduleNode.symbolText)
        v3CompilerCsgAppendText(moduleBuf, moduleNode.factText)
        lt.v3AppendU32BE(moduleBuf, moduleNode.resultLayoutKind)
        lt.v3AppendU32BE(moduleBuf, moduleNode.effectKind)
        lt.v3AppendU32BE(moduleBuf, moduleNode.capabilityKind)
        lt.v3AppendU32BE(moduleBuf, moduleNode.callConv)
        lt.v3AppendU32BE(moduleBuf, moduleNode.entryFlag)
        lt.v3AppendU32BE(moduleBuf, moduleNode.exportedFlag)
        v3CompilerCsgAppendText(moduleBuf, moduleNode.exportSymbolName)
        moduleNode.factCid = lt.v3FixedCidFromBuf(moduleBuf)
        add(nodes, moduleNode)
        let moduleNodeId = moduleNode.nodeId
        v3CompilerCsgAddEdge(edges, packageNodeId, moduleNodeId, v3CompilerCsgEdgeKindContains)
    for i in 0..<importPairs.len:
        let pair = importPairs[i]
        let fromNodeId = v3CompilerCsgModuleNodeId(nodes, pair.ownerModulePath)
        let toNodeId = v3CompilerCsgModuleNodeId(nodes, pair.targetModulePath)
        if fromNodeId <= 0 || toNodeId <= 0:
            continue
        v3CompilerCsgAddEdge(edges, fromNodeId, toNodeId, v3CompilerCsgEdgeKindImports)
    var orderedSources: str[] = []
    var typedSourceTexts: V3TypedExprSourceText[] = []
    for i in 0..<linkPlan.sourceClosurePaths.len:
        add(orderedSources, linkPlan.sourceClosurePaths[i])
    v3CompilerCsgSortStrs(orderedSources)
    for sourceIndex in 0..<orderedSources.len:
        let sourcePath = orderedSources[sourceIndex]
        let ownerModulePath = v3CompilerCsgSourceModulePath(linkPlan.workspaceRoot,
                                                            linkPlan.packageRoot,
                                                            sourceTextOverrides,
                                                            sourcePath)
        let ownerModuleNodeId = v3CompilerCsgModuleNodeId(nodes, ownerModulePath)
        if ownerModuleNodeId <= 0:
            continue
        var text = ""
        if !v3CompilerCsgSourceTextLookup(sourceTextOverrides, sourcePath, text):
            text = v3path.V3ReadTextFile("", sourcePath)
        add(typedSourceTexts, v3CompilerCsgTypedSourceText(sourcePath, text))
        var sourceExprLayer = parser.v3NormalizedExprLayerZero()
        let sourceExprRes = v3CompilerCsgExprLayerForText(sourcePath, text, sourceExprLayer)
        if IsErr(sourceExprRes):
            return Err[V3CompilerCsg](Error(sourceExprRes))
        parser.v3NormalizedExprLayerAdd(exprLayer, sourceExprLayer)
        var decls: parser.V3NormalizedFunctionDecl[] = []
        var declErr = ""
        if !parser.v3ParserReadNormalizedFunctionDecls(text, decls, declErr):
            return Err[V3CompilerCsg]("v3 compiler csg: normalized decl read failed")
        let entrySourceFlag = sourcePath == linkPlan.entryPath
        var entryHasExplicitExports = false
        if entrySourceFlag && (linkPlan.emitKind == creq.v3EmitShared || linkPlan.emitKind == creq.v3EmitObj):
            for scanIndex in 0..<decls.len:
                if decls[scanIndex].importc:
                    continue
                if len(decls[scanIndex].explicitExportName) > 0:
                    entryHasExplicitExports = true
                    break
        for declIndex in 0..<decls.len:
            let decl = decls[declIndex]
            let functionName = decl.name
            if decl.importc:
                continue
            let pendingExportName = decl.explicitExportName
            var entryFlag = 0
            if sourcePath == linkPlan.entryPath && functionName == linkPlan.entrySymbol:
                entryFlag = 1
            var resultLayoutKind = 0
            if functionName == "main":
                resultLayoutKind = 5
            var effectKind = v3CompilerCsgEffectPure
            if entryFlag != 0:
                effectKind = v3CompilerCsgEffectProgramEntry
            var capabilityKind = v3CompilerCsgCapabilityInternal
            if entryFlag != 0:
                capabilityKind = v3CompilerCsgCapabilityEntrypoint
            let callConv = 1
            let symbolText = parser.v3ParserConcat3(ownerModulePath, "::", functionName)
            var exportedFlag = 0
            if v3CompilerCsgShouldExportSymbol(linkPlan.emitKind,
                                               entrySourceFlag,
                                               entryHasExplicitExports,
                                               pendingExportName,
                                               functionName,
                                               entryFlag):
                exportedFlag = 1
            var exportSymbolName = ""
            if exportedFlag != 0:
                exportSymbolName = v3CompilerCsgTargetExportName(symbolText,
                                                                 pendingExportName,
                                                                 functionName)
            var symbolNode: V3CompilerCsgNode
            symbolNode.nodeId = nodes.len + 1
            symbolNode.nodeKind = v3CompilerCsgNodeKindSymbol
            symbolNode.ownerNodeId = ownerModuleNodeId
            symbolNode.modulePath = ownerModulePath
            symbolNode.symbolText = symbolText
            symbolNode.factText = functionName
            symbolNode.resultLayoutKind = resultLayoutKind
            symbolNode.effectKind = effectKind
            symbolNode.capabilityKind = capabilityKind
            symbolNode.callConv = callConv
            symbolNode.entryFlag = entryFlag
            symbolNode.exportedFlag = exportedFlag
            symbolNode.exportSymbolName = exportSymbolName
            var symbolBuf: layout.ByteBuf = layout.byteBufInit(256)
            v3CompilerCsgAppendText(symbolBuf, "v3.compiler.csg.node")
            lt.v3AppendU32BE(symbolBuf, symbolNode.nodeKind)
            lt.v3AppendU32BE(symbolBuf, symbolNode.ownerNodeId)
            v3CompilerCsgAppendText(symbolBuf, symbolNode.modulePath)
            v3CompilerCsgAppendText(symbolBuf, symbolNode.symbolText)
            v3CompilerCsgAppendText(symbolBuf, symbolNode.factText)
            lt.v3AppendU32BE(symbolBuf, symbolNode.resultLayoutKind)
            lt.v3AppendU32BE(symbolBuf, symbolNode.effectKind)
            lt.v3AppendU32BE(symbolBuf, symbolNode.capabilityKind)
            lt.v3AppendU32BE(symbolBuf, symbolNode.callConv)
            lt.v3AppendU32BE(symbolBuf, symbolNode.entryFlag)
            lt.v3AppendU32BE(symbolBuf, symbolNode.exportedFlag)
            v3CompilerCsgAppendText(symbolBuf, symbolNode.exportSymbolName)
            symbolNode.factCid = lt.v3FixedCidFromBuf(symbolBuf)
            add(nodes, symbolNode)
            let symbolNodeId = symbolNode.nodeId
            v3CompilerCsgAddEdge(edges, ownerModuleNodeId, symbolNodeId, v3CompilerCsgEdgeKindContains)
            var layoutNode: V3CompilerCsgNode
            layoutNode.nodeId = nodes.len + 1
            layoutNode.nodeKind = v3CompilerCsgNodeKindLayout
            layoutNode.ownerNodeId = symbolNodeId
            layoutNode.modulePath = ownerModulePath
            layoutNode.symbolText = symbolText
            layoutNode.factText = parser.v3ParserConcat2("layout=", intToStr(resultLayoutKind))
            layoutNode.resultLayoutKind = resultLayoutKind
            layoutNode.effectKind = 0
            layoutNode.capabilityKind = 0
            layoutNode.callConv = callConv
            layoutNode.entryFlag = entryFlag
            layoutNode.exportedFlag = 0
            layoutNode.exportSymbolName = ""
            var layoutBuf: layout.ByteBuf = layout.byteBufInit(256)
            v3CompilerCsgAppendText(layoutBuf, "v3.compiler.csg.node")
            lt.v3AppendU32BE(layoutBuf, layoutNode.nodeKind)
            lt.v3AppendU32BE(layoutBuf, layoutNode.ownerNodeId)
            v3CompilerCsgAppendText(layoutBuf, layoutNode.modulePath)
            v3CompilerCsgAppendText(layoutBuf, layoutNode.symbolText)
            v3CompilerCsgAppendText(layoutBuf, layoutNode.factText)
            lt.v3AppendU32BE(layoutBuf, layoutNode.resultLayoutKind)
            lt.v3AppendU32BE(layoutBuf, layoutNode.effectKind)
            lt.v3AppendU32BE(layoutBuf, layoutNode.capabilityKind)
            lt.v3AppendU32BE(layoutBuf, layoutNode.callConv)
            lt.v3AppendU32BE(layoutBuf, layoutNode.entryFlag)
            lt.v3AppendU32BE(layoutBuf, layoutNode.exportedFlag)
            v3CompilerCsgAppendText(layoutBuf, layoutNode.exportSymbolName)
            layoutNode.factCid = lt.v3FixedCidFromBuf(layoutBuf)
            add(nodes, layoutNode)
            let layoutNodeId = layoutNode.nodeId
            v3CompilerCsgAddEdge(edges, symbolNodeId, layoutNodeId, v3CompilerCsgEdgeKindHasLayout)
            var effectNode: V3CompilerCsgNode
            effectNode.nodeId = nodes.len + 1
            effectNode.nodeKind = v3CompilerCsgNodeKindEffect
            effectNode.ownerNodeId = symbolNodeId
            effectNode.modulePath = ownerModulePath
            effectNode.symbolText = symbolText
            effectNode.factText = parser.v3ParserConcat2("effect=", intToStr(effectKind))
            effectNode.resultLayoutKind = resultLayoutKind
            effectNode.effectKind = effectKind
            effectNode.capabilityKind = 0
            effectNode.callConv = callConv
            effectNode.entryFlag = entryFlag
            effectNode.exportedFlag = 0
            effectNode.exportSymbolName = ""
            var effectBuf: layout.ByteBuf = layout.byteBufInit(256)
            v3CompilerCsgAppendText(effectBuf, "v3.compiler.csg.node")
            lt.v3AppendU32BE(effectBuf, effectNode.nodeKind)
            lt.v3AppendU32BE(effectBuf, effectNode.ownerNodeId)
            v3CompilerCsgAppendText(effectBuf, effectNode.modulePath)
            v3CompilerCsgAppendText(effectBuf, effectNode.symbolText)
            v3CompilerCsgAppendText(effectBuf, effectNode.factText)
            lt.v3AppendU32BE(effectBuf, effectNode.resultLayoutKind)
            lt.v3AppendU32BE(effectBuf, effectNode.effectKind)
            lt.v3AppendU32BE(effectBuf, effectNode.capabilityKind)
            lt.v3AppendU32BE(effectBuf, effectNode.callConv)
            lt.v3AppendU32BE(effectBuf, effectNode.entryFlag)
            lt.v3AppendU32BE(effectBuf, effectNode.exportedFlag)
            v3CompilerCsgAppendText(effectBuf, effectNode.exportSymbolName)
            effectNode.factCid = lt.v3FixedCidFromBuf(effectBuf)
            add(nodes, effectNode)
            let effectNodeId = effectNode.nodeId
            v3CompilerCsgAddEdge(edges, symbolNodeId, effectNodeId, v3CompilerCsgEdgeKindHasEffect)
            var capabilityNode: V3CompilerCsgNode
            capabilityNode.nodeId = nodes.len + 1
            capabilityNode.nodeKind = v3CompilerCsgNodeKindCapability
            capabilityNode.ownerNodeId = symbolNodeId
            capabilityNode.modulePath = ownerModulePath
            capabilityNode.symbolText = symbolText
            capabilityNode.factText = parser.v3ParserConcat2("capability=", intToStr(capabilityKind))
            capabilityNode.resultLayoutKind = resultLayoutKind
            capabilityNode.effectKind = effectKind
            capabilityNode.capabilityKind = capabilityKind
            capabilityNode.callConv = callConv
            capabilityNode.entryFlag = entryFlag
            capabilityNode.exportedFlag = 0
            capabilityNode.exportSymbolName = ""
            var capabilityBuf: layout.ByteBuf = layout.byteBufInit(256)
            v3CompilerCsgAppendText(capabilityBuf, "v3.compiler.csg.node")
            lt.v3AppendU32BE(capabilityBuf, capabilityNode.nodeKind)
            lt.v3AppendU32BE(capabilityBuf, capabilityNode.ownerNodeId)
            v3CompilerCsgAppendText(capabilityBuf, capabilityNode.modulePath)
            v3CompilerCsgAppendText(capabilityBuf, capabilityNode.symbolText)
            v3CompilerCsgAppendText(capabilityBuf, capabilityNode.factText)
            lt.v3AppendU32BE(capabilityBuf, capabilityNode.resultLayoutKind)
            lt.v3AppendU32BE(capabilityBuf, capabilityNode.effectKind)
            lt.v3AppendU32BE(capabilityBuf, capabilityNode.capabilityKind)
            lt.v3AppendU32BE(capabilityBuf, capabilityNode.callConv)
            lt.v3AppendU32BE(capabilityBuf, capabilityNode.entryFlag)
            lt.v3AppendU32BE(capabilityBuf, capabilityNode.exportedFlag)
            v3CompilerCsgAppendText(capabilityBuf, capabilityNode.exportSymbolName)
            capabilityNode.factCid = lt.v3FixedCidFromBuf(capabilityBuf)
            add(nodes, capabilityNode)
            let capabilityNodeId = capabilityNode.nodeId
            v3CompilerCsgAddEdge(edges, symbolNodeId, capabilityNodeId, v3CompilerCsgEdgeKindHasCapability)
    var typedExprFacts: V3TypedExprFact[] = []
    var typedErr = ""
    if !v3CompilerCsgBuildTypedExprFacts(typedSourceTexts, exprLayer, typedExprFacts, typedErr):
        return Err[V3CompilerCsg]("v3 compiler csg: typed expr build failed")
    var out: V3CompilerCsg
    out.version = 1
    out.packageId = linkPlan.packageId
    out.sourceBundleCid = sourceBundleCid
    out.exprLayer = parser.v3NormalizedExprLayerClone(exprLayer)
    out.typedExprFacts = v3CompilerCsgCloneTypedExprFacts(typedExprFacts)
    out.nodes = nodes
    out.edges = edges
    out.nodeCount = nodes.len
    out.edgeCount = edges.len
    out.canonicalGraphCid = v3CompilerCsgCanonicalGraphCid(out.packageId, out.exprLayer, out.typedExprFacts, out.nodes, out.edges)
    out.graphCid = v3CompilerCsgGraphCid(out.packageId, out.sourceBundleCid, out.exprLayer, out.typedExprFacts, out.nodes, out.edges)
    return Ok[V3CompilerCsg](out)

fn v3BuildCompilerCsg(linkPlan: slplan.V3SystemLinkPlanStub,
                      sourceBundleCid: layout.FixedBytes32): Result[V3CompilerCsg] =
    var sourceTextOverrides: V3CompilerCsgSourceText[]
    sourceTextOverrides = []
    return v3BuildCompilerCsgWithOverrides(linkPlan, sourceBundleCid, sourceTextOverrides)

fn v3CompilerExportSurfaceFromCsg(csg: V3CompilerCsg): V3CsgExportSurface =
    var out: V3CsgExportSurface
    out.version = 1
    out.packageId = csg.packageId
    out.exportedSymbols = []
    out.exportedTargetNames = []
    out.exportedLayouts = []
    out.exportedEffects = []
    out.exportedCapabilities = []
    for i in 0..<csg.nodes.len:
        let node = csg.nodes[i]
        if node.nodeKind != v3CompilerCsgNodeKindSymbol:
            continue
        if node.exportedFlag == 0:
            continue
        add(out.exportedSymbols, node.symbolText)
        add(out.exportedTargetNames, node.exportSymbolName)
        add(out.exportedLayouts, node.resultLayoutKind)
        add(out.exportedEffects, node.effectKind)
        add(out.exportedCapabilities, node.capabilityKind)
    out.exportedSymbolCount = out.exportedSymbols.len
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    v3CompilerCsgAppendText(buf, "v3.compiler.export_surface")
    v3CompilerCsgAppendText(buf, out.packageId)
    lt.v3AppendU32BE(buf, out.exportedSymbolCount)
    for i in 0..<out.exportedSymbols.len:
        v3CompilerCsgAppendText(buf, out.exportedSymbols[i])
        v3CompilerCsgAppendText(buf, out.exportedTargetNames[i])
        lt.v3AppendU32BE(buf, out.exportedLayouts[i])
        lt.v3AppendU32BE(buf, out.exportedEffects[i])
        lt.v3AppendU32BE(buf, out.exportedCapabilities[i])
    out.surfaceCid = lt.v3FixedCidFromBuf(buf)
    return out

fn v3CompilerExportSurfaceCompatible(base: V3CsgExportSurface,
                                     next: V3CsgExportSurface): bool =
    if base.packageId != next.packageId:
        return false
    if base.exportedSymbolCount != next.exportedSymbolCount:
        return false
    for i in 0..<base.exportedSymbolCount:
        if base.exportedSymbols[i] != next.exportedSymbols[i]:
            return false
        if base.exportedTargetNames[i] != next.exportedTargetNames[i]:
            return false
        if base.exportedLayouts[i] != next.exportedLayouts[i]:
            return false
        if base.exportedEffects[i] != next.exportedEffects[i]:
            return false
        if base.exportedCapabilities[i] != next.exportedCapabilities[i]:
            return false
    return true

fn v3CompileReceiptMake(worldHeadCid: layout.FixedBytes32,
                        compilerCsgCid: layout.FixedBytes32,
                        canonicalCompilerCsgCid: layout.FixedBytes32,
                        targetTriple: str,
                        outputDigest: layout.FixedBytes32,
                        canonicalOutputDigest: layout.FixedBytes32,
                        bootstrapStage: str,
                        runtimeProviderSet: str[]): V3CompileReceipt =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    v3CompilerCsgAppendText(buf, "v3.compiler.compile_receipt")
    lt.v3AppendFixed32(buf, worldHeadCid)
    lt.v3AppendFixed32(buf, compilerCsgCid)
    lt.v3AppendFixed32(buf, canonicalCompilerCsgCid)
    v3CompilerCsgAppendText(buf, targetTriple)
    lt.v3AppendFixed32(buf, outputDigest)
    lt.v3AppendFixed32(buf, canonicalOutputDigest)
    v3CompilerCsgAppendText(buf, bootstrapStage)
    lt.v3AppendU32BE(buf, runtimeProviderSet.len)
    for i in 0..<runtimeProviderSet.len:
        v3CompilerCsgAppendText(buf, runtimeProviderSet[i])
    var out: V3CompileReceipt
    out.version = 1
    out.worldHeadCid = worldHeadCid
    out.compilerCsgCid = compilerCsgCid
    out.canonicalCompilerCsgCid = canonicalCompilerCsgCid
    out.targetTriple = targetTriple
    out.outputDigest = outputDigest
    out.canonicalOutputDigest = canonicalOutputDigest
    out.bootstrapStage = bootstrapStage
    out.runtimeProviderSet = runtimeProviderSet
    out.receiptCid = lt.v3FixedCidFromBuf(buf)
    return out

fn v3CompileOutputDigest(outputPath: str,
                         targetTriple: str,
                         providerModules: str[],
                         csgCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    v3CompilerCsgAppendText(buf, "v3.compiler.output_digest")
    let _ = outputPath
    v3CompilerCsgAppendText(buf, targetTriple)
    lt.v3AppendFixed32(buf, csgCid)
    lt.v3AppendU32BE(buf, providerModules.len)
    for i in 0..<providerModules.len:
        v3CompilerCsgAppendText(buf, providerModules[i])
    return lt.v3FixedCidFromBuf(buf)

fn v3CompilerCsgReport(csg: V3CompilerCsg): str =
    var out = ""
    let typedExprFacts = csg.typedExprFacts
    let loweringRules = v3TypedExprLoweringRulesFromFacts(typedExprFacts)
    out = out + "version=1\n"
    out = out + "package_id=" + csg.packageId + "\n"
    out = out + "source_bundle_cid=" + layout.fixedBytes32Hex(csg.sourceBundleCid) + "\n"
    out = out + "expr_surface_source_count=" + intToStr(csg.exprLayer.sourceCount) + "\n"
    out = out + "expr_surface_expr_count=" + intToStr(parser.v3NormalizedExprLayerExprCount(csg.exprLayer)) + "\n"
    out = out + "expr_surface_if_count=" + intToStr(parser.v3NormalizedExprLayerIfCount(csg.exprLayer)) + "\n"
