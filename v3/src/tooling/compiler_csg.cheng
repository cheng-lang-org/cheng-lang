    V3CsgExportSurface =
        version: int32
        packageId: str
        exportedSymbolCount: int32
        exportedSymbols: str[]
        exportedTargetNames: str[]
        exportedLayouts: int32[]
        exportedEffects: int32[]
        exportedCapabilities: int32[]
        surfaceCid: layout.FixedBytes32

    V3CompileReceipt =
        version: int32
        worldHeadCid: layout.FixedBytes32
        compilerCsgCid: layout.FixedBytes32
        canonicalCompilerCsgCid: layout.FixedBytes32
        targetTriple: str
        outputDigest: layout.FixedBytes32
        canonicalOutputDigest: layout.FixedBytes32
        bootstrapStage: str
        runtimeProviderSet: str[]
        receiptCid: layout.FixedBytes32

    V3CompilerCsgSourceText =
        sourcePath: str
        modulePath: str
        text: str

    V3CompilerLegacySourceUnit =
        sourcePath: str
