        legacyText: str
        migratedText: str

    V3CompilerLegacyMigration =
        version: int32
        packageId: str
        entrySourcePath: str
        entryModulePath: str
        unitCount: int32
        appliedRuleCount: int32
        appliedRules: str[]
        legacySourceBundleCid: layout.FixedBytes32
        migratedSourceBundleCid: layout.FixedBytes32
        compilerCsg: V3CompilerCsg
        exportSurface: V3CsgExportSurface
        migrationCid: layout.FixedBytes32

fn v3CompilerCsgCloneStrSeq(items: str[]): str[] =
    var out: str[] = []
    for i in 0..<items.len:
        add(out, items[i])
    return out

fn v3CompilerCsgCloneInt32Seq(items: int32[]): int32[] =
    var out: int32[] = []
    for i in 0..<items.len:
        add(out, items[i])
    return out

