import std/cmdline as cmdline
import std/os
import std/result
import cheng/v3/tooling/bootstrap_contracts as contracts

type
    V3CompilerEmit = enum
        v3EmitExe

    V3CompilerRequest =
        rootDir: str
        sourcePath: str
        outputPath: str
        targetTriple: str
        emitKind: V3CompilerEmit
        reportPath: str

fn v3CompilerRequestNew(rootDir: str,
                        sourcePath: str,
                        outputPath: str,
                        targetTriple: str,
                        emitKind: V3CompilerEmit,
                        reportPath: str): V3CompilerRequest =
    return V3CompilerRequest(
        rootDir: rootDir,
        sourcePath: sourcePath,
        outputPath: outputPath,
        targetTriple: targetTriple,
        emitKind: emitKind,
        reportPath: reportPath
    )

fn v3CompilerRequestSourcePath(req: V3CompilerRequest): str =
    return req.sourcePath

fn v3CompilerRequestRootDir(req: V3CompilerRequest): str =
    return req.rootDir

fn v3CompilerRequestOutputPath(req: V3CompilerRequest): str =
    return req.outputPath

fn v3CompilerRequestTargetTriple(req: V3CompilerRequest): str =
    return req.targetTriple

fn v3CompilerRequestEmitKind(req: V3CompilerRequest): V3CompilerEmit =
    return req.emitKind

fn v3CompilerReadFlagOrDefault(key: str, defaultValue: str): str =
    let count = cmdline.paramCount()
    var out = defaultValue
    var value: str
    var nextIndex: int32 = 0
    for i in 2..count:
        if cmdline.readFlagValueAt(i, key, value, nextIndex):
            out = value
    return out

fn v3CompilerEmitText(kind: V3CompilerEmit): str =
    if kind == v3EmitExe:
        return "exe"
    return "unknown"

fn v3CompilerDefaultPackageRoot(workspaceRoot: str): str =
    return os.joinPath(workspaceRoot, "v3")

fn v3CompilerRequestFromCmdline(workspaceRoot: str): Result[V3CompilerRequest] =
    let packageRoot = v3CompilerReadFlagOrDefault("--root", v3CompilerDefaultPackageRoot(workspaceRoot))
    let sourcePath = v3CompilerReadFlagOrDefault("--in", "")
    if len(sourcePath) <= 0:
        return Err[V3CompilerRequest]("v3 compiler: missing --in")
    let outputPath = v3CompilerReadFlagOrDefault("--out", "")
    if len(outputPath) <= 0:
        return Err[V3CompilerRequest]("v3 compiler: missing --out")
    let targetTriple = v3CompilerReadFlagOrDefault("--target", contracts.v3BootstrapDefaultTarget())
    let emitText = v3CompilerReadFlagOrDefault("--emit", "exe")
    if emitText != "exe":
        return Err[V3CompilerRequest]("v3 compiler: unsupported --emit: " + emitText)
    let reportPath = v3CompilerReadFlagOrDefault("--report-out", "")
    return Ok[V3CompilerRequest](v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        targetTriple,
        v3EmitExe,
        reportPath
    ))
