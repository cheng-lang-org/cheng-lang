import cheng/v3/runtime/core_runtime_v3 as corun
import cheng/v3/runtime/compiler_runtime_v3 as comprun

type
    V3CompilerExecutionTrack = enum
        v3CompilerTrackProgram
        v3CompilerTrackTooling

    V3CompilerRuntimeContract =
        version: str
        executionModel: str
        bootstrapMode: str
        compilerEntry: str
        ordinaryCommand: str
        ordinaryPipelineState: str

fn v3CompilerRuntimePath(rootDir: str, rel: str): str =
    if rootDir == "":
        return rel
    if rel == "":
        return rootDir
    if rootDir[rootDir.len - 1] == '/':
        return rootDir + rel
    return rootDir + "/" + rel

fn v3CompilerExecutionTrackText(track: V3CompilerExecutionTrack): str =
    if track == v3CompilerTrackTooling:
        return "tooling"
    return "program"

fn v3CoreRuntimeProviderModule(): str =
    let out = "runtime/core_runtime_v3"
    return out

fn v3CompilerRuntimeProviderModule(): str =
    let out = "runtime/compiler_runtime_v3"
    return out

fn v3ProgramSupportProviderModule(): str =
    let out = "runtime/program_support_v3"
    return out

fn v3ProgramSupportHostProviderModule(): str =
    let out = "runtime/program_support_host_v3"
    return out

fn v3DebugRuntimeProviderModule(): str =
    let out = "runtime/debug_runtime_v3"
    return out

fn v3CompilerProgramArgvRuntimeTarget(): str =
    let out = "runtime/compiler.program_argv_entry"
    return out

fn v3CompilerToolingArgvRuntimeTarget(): str =
    let out = "runtime/compiler.tooling_argv_entry"
    return out

fn v3CoreRuntimeTargets(): str[] =
    let out = corun.v3CoreRuntimeTargets()
    return out

fn v3CompilerRuntimeTargetsForTrack(track: V3CompilerExecutionTrack, out: var str[]) =
    out = []
    if track == v3CompilerTrackTooling:
        let toolingTarget = v3CompilerToolingArgvRuntimeTarget()
        add(out, toolingTarget)
        return
    let programTarget = v3CompilerProgramArgvRuntimeTarget()
    add(out, programTarget)

fn v3RuntimeProviderModulesForTrack(track: V3CompilerExecutionTrack, out: var str[]) =
    let _ = track
    out = []
    add(out, "runtime/compiler_runtime_v3")
    add(out, "runtime/core_runtime_v3")
    add(out, "runtime/debug_runtime_v3")
    add(out, "runtime/program_support_v3")
    add(out, "runtime/program_support_host_v3")

fn v3CompilerRuntimeContract(rootDir: str): V3CompilerRuntimeContract =
    return V3CompilerRuntimeContract(
        version: "v3.compiler_runtime.v1",
        executionModel: "argv_control_plane",
        bootstrapMode: "v3_selfhost",
        compilerEntry: v3CompilerRuntimePath(rootDir, "v3/src/tooling/compiler_main.cheng"),
        ordinaryCommand: "system-link-exec",
        ordinaryPipelineState: "canonical_csg_verified_primary_object_codegen_missing"
    )

fn v3CompilerUsageLines(rootDir: str): str[] =
    let contract = v3CompilerRuntimeContract(rootDir)
    var out: str[]
    out = []
    add(out, "cheng_v3c")
    add(out, "usage: cheng_v3c <command>")
    add(out, "       cheng_v3c <input.cheng> --output:<path> [legacy backend_driver flags]")
    add(out, "")
    add(out, "commands:")
    add(out, "  help                         show this message")
    add(out, "  status                       print the current v3 compiler control-plane contract")
    add(out, "  print-build-plan             print the intended v3 backend build plan")
    add(out, "  print-bootstrap              print the current bootstrap snapshot")
    add(out, "  bootstrap-bridge             rebuild and install bootstrap stage0-stage3 via candidate artifacts")
    add(out, "  build-backend-driver         rebuild and verify the ordinary backend driver")
    add(out, "  run-smokes                   self-check stage0/stage1/stage2/stage3 bootstrap compilers")
    add(out, "  scan-hotpath                 scan v3/src for forbidden hotpath regressions")
    add(out, "  verify-x86-linux-remote     rebuild x86 backend on dmit/64, run x86 smoke suite, and self-test chain_node")
    add(out, "  verify-bft-validator-three-node deploy, sign off, and stop the 3-validator BFT cluster")
    add(out, "  host-bridge-audit            fail if legacy host-bridge surfaces leak back into the live path")
    add(out, "  slice-gate                  run the full v3 gate through stage3 forwarding, incl. chain_node/bft/x86 mainline")
    add(out, "  debug-report                emit the stable ordinary pipeline debug report")
    add(out, "  print-symbols               print lowering/primary/provider/link symbols")
    add(out, "  print-line-map              print source line mappings for the build output")
    add(out, "  print-object                inspect Mach-O/ELF/PE objects")
    add(out, "  print-elf                   compatibility alias of print-object")
    add(out, "  print-asm                   print the real emitted assembly text")
    add(out, "  profile-run                 compile and run with builtin statistical profiling")
    add(out, "  profile-report              convert v3_profile_raw_v1 into v3_profile_v1")
    add(out, "  crash-report                convert v3_crash_raw_v1 into v3_crash_report_v1")
    add(out, "  verify-orphan-guard         fail on tooling residue or new Cheng U/UE after bootstrap/build")
    add(out, "  verify-export-visibility    fail on cross-package lowercase private symbol use")
    add(out, "  verify-export-visibility-parallel fail when stage3/backend_driver parallel export checks drift")
