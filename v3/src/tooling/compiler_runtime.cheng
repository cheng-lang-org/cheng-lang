import cheng/v3/runtime/core_runtime_v3 as corun
import cheng/v3/runtime/compiler_runtime_v3 as comprun

type
    V3CompilerExecutionTrack = enum
        v3CompilerTrackProgram
        v3CompilerTrackTooling

    V3CompilerRuntimeContract =
        version: str
        executionModel: str
        bootstrapMode: str
        compilerEntry: str
        ordinaryCommand: str
        ordinaryPipelineState: str

fn v3CompilerRuntimePath(rootDir: str, rel: str): str =
    if rootDir == "":
        return rel
    if rel == "":
        return rootDir
    if rootDir[rootDir.len - 1] == '/':
        return rootDir + rel
    return rootDir + "/" + rel

fn v3CompilerExecutionTrackText(track: V3CompilerExecutionTrack): str =
    if track == v3CompilerTrackTooling:
        return "tooling"
    return "program"

fn v3CoreRuntimeProviderModule(): str =
    return "runtime/core_runtime_v3"

fn v3CompilerRuntimeProviderModule(): str =
    return "runtime/compiler_runtime_v3"

fn v3ProgramSupportProviderModule(): str =
    return "runtime/program_support_v3"

fn v3DebugRuntimeProviderModule(): str =
    return "runtime/debug_runtime_v3"

fn v3CompilerProgramArgvRuntimeTarget(): str =
    return "runtime/compiler.program_argv_entry"

fn v3CompilerToolingArgvRuntimeTarget(): str =
    return "runtime/compiler.tooling_argv_entry"

fn v3CoreRuntimeTargets(): str[] =
    return corun.v3CoreRuntimeTargets()

fn v3CompilerRuntimeTargetsForTrack(track: V3CompilerExecutionTrack, out: var str[]) =
    out = []
    if track == v3CompilerTrackTooling:
        add(out, v3CompilerToolingArgvRuntimeTarget())
        return
    add(out, v3CompilerProgramArgvRuntimeTarget())

fn v3RuntimeProviderModulesForTrack(track: V3CompilerExecutionTrack, out: var str[]) =
    let _ = track
    out = []
    add(out, v3CompilerRuntimeProviderModule())
    add(out, v3CoreRuntimeProviderModule())
    add(out, v3DebugRuntimeProviderModule())
    add(out, v3ProgramSupportProviderModule())

fn v3CompilerRuntimeContract(rootDir: str): V3CompilerRuntimeContract =
    return V3CompilerRuntimeContract(
        version: "v3.compiler_runtime.v1",
        executionModel: "argv_control_plane",
        bootstrapMode: "v3_seed",
        compilerEntry: v3CompilerRuntimePath(rootDir, "v3/src/tooling/compiler_main.cheng"),
        ordinaryCommand: "system-link-exec",
        ordinaryPipelineState: "canonical_csg_verified_primary_object_codegen_missing"
    )

fn v3CompilerUsageLines(rootDir: str): str[] =
    let contract = v3CompilerRuntimeContract(rootDir)
    var out: str[]
    out = []
    add(out, "cheng_v3c")
    add(out, "usage: cheng_v3c <command>")
    add(out, "")
    add(out, "commands:")
    add(out, "  help                         show this message")
    add(out, "  status                       print the current v3 compiler control-plane contract")
    add(out, "  print-build-plan             print the intended v3 backend build plan")
    add(out, "  system-link-exec             ordinary AOT compile entry (canonical CSG + provider object plan)")
    add(out, "  emit-csg                     emit the canonical compiler CSG report for a source closure")
    add(out, "  migrate-csg                  migrate legacy source text into the current canonical CSG")
    add(out, "  verify-world                 verify world-head, lock, and export-surface compatibility")
    add(out, "  world-sync                   materialize a world bundle report set for sync/distribution")
    add(out, "  prove-equivalence            prove old world reports are canonically equivalent to the current CSG")
    add(out, "  prove-migration             prove legacy source migrates into a canonically equivalent CSG")
    add(out, "  publish-world                publish a world bundle with stable/edge gate enforcement")
    add(out, "  fresh-node-selfhost          sync a published world into a fresh node and re-verify the receipt")
    add(out, "  selfhost-build               run the selfhost build gate pinned to a world head")
    add(out, "  scan-hotpath                 scan v3 source for forbidden hot-path patterns")
    add(out, "  c-ref                        run the same-machine C reference baseline")
    add(out, "  compare-bench                compare two benchmark reports against a max ratio")
    add(out, "  bootstrap-bridge             materialize stage0 -> stage3 bootstrap compilers")
    add(out, "  build-backend-driver         build the ordinary Cheng compiler from stage2")
    add(out, "  run-smokes                   run bootstrap self-check smokes")
    add(out, "  print-bootstrap              print the current bootstrap snapshot")
    add(out, "  slice-gate                   run the v3 gate slice")
    add(out, "  debug-report                 print the canonical debug pipeline report")
    add(out, "  print-symbols                print lowering and object/native symbols")
    add(out, "  print-line-map               print the source line mapping report")
    add(out, "  print-object                 print Mach-O / ELF / COFF object structure")
    add(out, "  print-elf                    compatibility alias of print-object")
    add(out, "  print-asm                    print the emitted assembly text")
    add(out, "  profile-run                  build, run, and dump the builtin profiler report")
    add(out, "  profile-report               transform a raw profiler dump into the final report")
    add(out, "  verify-orphan-guard          verify tooling scripts never bypass the orphan guard")
    add(out, "  verify-debug-tools           run the built-in debug tooling verification gate")
    add(out, "  verify-debug-runtime         run the built-in crash report verification gate")
    add(out, "  verify-debug-profile         run the built-in statistical profiler gate")
    add(out, "  verify-windows-builtin       verify the builtin Windows AArch64 executable path")
    add(out, "  verify-riscv64-builtin       verify the builtin Linux RISCV64 executable path")
    add(out, "  run-cross-target-smokes      run the builtin Windows and RISCV cross-target smokes")
    add(out, "  run-host-smokes              run the host smoke suite from the compiler entry")
    add(out, "  run-stage23-libp2p-smokes    run the stage2/stage3 libp2p smoke suite from the compiler entry")
    add(out, "  build-zero-exit              build and run the ordinary zero-exit fixture")
    add(out, "  build-panic-trace            build and verify the panic crash report fixture")
    add(out, "  build-bounds-trace           build and verify the bounds crash report fixture")
    add(out, "  build-signal-trace           build and verify the signal crash report fixture")
    add(out, "  build-call-chain             build and run the ordinary call-chain fixture")
    add(out, "  build-ffi-handle             build and verify the ffi handle fixture pair")
    add(out, "  build-bft-state-machine      build and run the standalone BFT state machine")
    add(out, "  build-browser-host-wasm      build the browser host wasm ABI probe")
    add(out, "  build-rwad-bft-state-machine build rwad_bft_state_machine for the selected target")
    add(out, "  build-program-selfhost       build and run the program selfhost fixture")
    add(out, "  build-chain-node             build the chain_node daemon and run self-test on host target")
    add(out, "  build-linux-nolibc-exe       build a generic Linux aarch64 nolibc executable from env")
    add(out, "  build-chain-node-linux       build chain_node for generic Linux aarch64 (obj or nolibc exe)")
    add(out, "  build-rwad-bft-linux         build rwad_bft_state_machine for generic Linux aarch64 (obj or nolibc exe)")
    add(out, "  run-linux-object-smokes      verify generic Linux aarch64 object emission for chain_node and rwad_bft")
    add(out, "  run-tcp-twoproc-smoke        build and run the libp2p tcp client/server two-process smoke")
    add(out, "  run-udp-importc-smoke        build and run the UDP importc smoke")
    add(out, "  run-wasm-smokes             build and run the builtin wasm smoke suite")
    add(out, "  run-browser-host-wasm-smoke build and run the browser host wasm ABI smoke")
    add(out, "  run-chain-node-cli-smoke     build and run the chain_node daemon CLI smoke")
    add(out, "  run-chain-node-process-smoke build and run the two-process chain_node sync smoke")
    add(out, "  run-chain-node-three-node-smoke build and run the three-node chain_node sync smoke")
    add(out, "  run-tailnet-control-smoke    build and run the tailnet control smoke")
    add(out, "  run-fresh-node-selfhost-gate build and verify the fresh node selfhost gate")
    add(out, "  run-migration-gate           build and verify the CSG migration gate")
    add(out, "  run-browser-webrtc-smokes    run the browser WebRTC smoke suite")
    add(out, "  r2c-react-v3                 run the React.js -> Cheng v3 controller")
    add(out, "")
    add(out, "compiler_entry=" + contract.compilerEntry)
    add(out, "ordinary_pipeline=" + contract.ordinaryPipelineState)
    return out
