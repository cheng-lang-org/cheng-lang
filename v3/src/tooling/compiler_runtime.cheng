    add(out, "  run-wasm-smokes             run wasm/browser host smokes with a chosen compiler")
    add(out, "  run-browser-host-wasm-smoke run the browser host wasm smoke")
    add(out, "  run-chain-node-cli-smoke    run the chain_node CLI smoke")
