    add(out, "  verify-debug-tools          verify debug-report/print-symbols/print-line-map/print-object/print-asm")
    add(out, "  verify-debug-runtime        verify panic/bounds/signal crash reports and debug provider objects")
    add(out, "  verify-debug-profile        verify builtin profiling reports")
    add(out, "  verify-diloco              verify Cheng v3 DiLoCo subpackage on host/stage2/stage3")
    add(out, "  run-host-smokes             run host ordinary/compiler/libp2p/chain smokes")
    add(out, "  run-stage23-libp2p-smokes   run stage2/stage3 libp2p smokes")
    add(out, "  run-tcp-twoproc-smoke       run real two-process tcp sync smoke")
