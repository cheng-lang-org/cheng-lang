import cheng/v3/runtime/core_runtime_v3 as corun
import cheng/v3/runtime/compiler_runtime_v3 as comprun

type
    V3CompilerExecutionTrack = enum
        v3CompilerTrackProgram
        v3CompilerTrackTooling

    V3CompilerRuntimeContract =
        version: str
        executionModel: str
        bootstrapMode: str
        compilerEntry: str
        ordinaryCommand: str
        ordinaryPipelineState: str

fn v3CompilerRuntimePath(rootDir: str, rel: str): str =
    if rootDir == "":
        return rel
    if rel == "":
        return rootDir
    if rootDir[rootDir.len - 1] == '/':
        return rootDir + rel
    return rootDir + "/" + rel

fn v3CompilerExecutionTrackText(track: V3CompilerExecutionTrack): str =
    if track == v3CompilerTrackTooling:
        return "tooling"
    return "program"

fn v3CoreRuntimeProviderModule(): str =
    return "runtime/core_runtime_v3"

fn v3CompilerRuntimeProviderModule(): str =
    return "runtime/compiler_runtime_v3"

fn v3ProgramSupportProviderModule(): str =
    return "runtime/program_support_v3"

fn v3DebugRuntimeProviderModule(): str =
    return "runtime/debug_runtime_v3"

fn v3CompilerProgramArgvRuntimeTarget(): str =
    return "runtime/compiler.program_argv_entry"

fn v3CompilerToolingArgvRuntimeTarget(): str =
    return "runtime/compiler.tooling_argv_entry"

fn v3CoreRuntimeTargets(): str[] =
    return corun.v3CoreRuntimeTargets()

fn v3CompilerRuntimeTargetsForTrack(track: V3CompilerExecutionTrack, out: var str[]) =
    out = []
    if track == v3CompilerTrackTooling:
        add(out, v3CompilerToolingArgvRuntimeTarget())
        return
    add(out, v3CompilerProgramArgvRuntimeTarget())

fn v3RuntimeProviderModulesForTrack(track: V3CompilerExecutionTrack, out: var str[]) =
    let _ = track
    out = []
    add(out, v3CompilerRuntimeProviderModule())
    add(out, v3CoreRuntimeProviderModule())
    add(out, v3DebugRuntimeProviderModule())
    add(out, v3ProgramSupportProviderModule())

fn v3CompilerRuntimeContract(rootDir: str): V3CompilerRuntimeContract =
    return V3CompilerRuntimeContract(
        version: "v3.compiler_runtime.v1",
        executionModel: "argv_control_plane",
        bootstrapMode: "v3_selfhost",
        compilerEntry: v3CompilerRuntimePath(rootDir, "v3/src/tooling/compiler_main.cheng"),
        ordinaryCommand: "system-link-exec",
        ordinaryPipelineState: "canonical_csg_verified_primary_object_codegen_missing"
    )

fn v3CompilerUsageLines(rootDir: str): str[] =
    let contract = v3CompilerRuntimeContract(rootDir)
    var out: str[]
    out = []
    add(out, "cheng_v3c")
    add(out, "usage: cheng_v3c <command>")
    add(out, "")
    add(out, "commands:")
    add(out, "  help                         show this message")
    add(out, "  status                       print the current v3 compiler control-plane contract")
    add(out, "  print-build-plan             print the intended v3 backend build plan")
    add(out, "  bootstrap-bridge             rebuild and install bootstrap stage0-stage3 via candidate artifacts")
    add(out, "  build-backend-driver         rebuild and verify the ordinary backend driver")
    add(out, "  host-bridge-audit            fail if legacy host-bridge surfaces leak back into the live path")
    add(out, "  r2c-react-v3-fresh-clean-gate run the fresh-clean native gui gate for core r2c routes")
    add(out, "  run-shared-emit-smokes       verify emit:shared builds a real shared library from a mainless fixture")
    add(out, "  system-link-exec             ordinary AOT compile entry (canonical CSG + provider object plan)")
    add(out, "  emit-csg                     emit the canonical compiler CSG report for a source closure")
    add(out, "  migrate-csg                  migrate legacy source text into the current canonical CSG")
    add(out, "  verify-world                 verify world-head, lock, and export-surface compatibility")
    add(out, "  world-sync                   materialize a world bundle report set for sync/distribution")
    add(out, "  prove-equivalence            prove old world reports are canonically equivalent to the current CSG")
    add(out, "  prove-migration             prove legacy source migrates into a canonically equivalent CSG")
    add(out, "  publish-world                publish a world bundle with stable/edge gate enforcement")
    add(out, "  fresh-node-selfhost          sync a published world into a fresh node and re-verify the receipt")
    add(out, "  selfhost-build               run the selfhost build gate pinned to a world head")
    add(out, "")
    add(out, "compiler_entry=" + contract.compilerEntry)
    add(out, "ordinary_pipeline=" + contract.ordinaryPipelineState)
    return out
