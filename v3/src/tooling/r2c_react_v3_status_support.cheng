import std/os
import std/strings
import cheng/v3/tooling/path as v3path

type
    V3R2cReactV3StatusContract =
        workspaceRoot: str
        experimentalRoot: str
        legacyPrototypePath: str
        tsxFrontendHelper: str
        staticSurfaceHelper: str
        semanticSurfaceHelper: str
        codegenSurfaceHelper: str
        execSurfaceHelper: str
        truthRuntimeHelper: str
        nativeGuiBundleHelper: str
        nativeGuiBundleFinalizer: str
        nativeGuiRuntimeHelper: str
        nativeGuiRuntimeMode: str
        nativeGuiRunHelper: str
        nativeGuiLayoutPayloadFinalizer: str
        nativeGuiLayoutItemCatalogMode: str
        nativeGuiLayoutItemCatalogPayloadProfile: str
        renderCompareHelper: str
        nativeGuiReplayHitInspectorHelper: str
        execRouteMatrixHelper: str
        truthRouteHelper: str
        truthCompareHelper: str
        truthCompareMatrixHelper: str
        nativeGuiHostSource: str
        nativeGuiHostSourceKind: str
        nativeGuiHostHelpers: str[]
        legacyShellWrapper: str
        legacyShellWrappers: str[]
        legacyWrapperRequired: bool
        legacyPrototypeRequired: bool
        compileNonChengBlockers: str[]
        guiRuntimeNonChengBlockers: str[]
        truthRuntimeNonChengBlockers: str[]
        optionalNonChengHelpers: str[]
        remainingNonChengBlockers: str[]
        activeNodeHelpers: str[]
        thinNodeHelpers: str[]
        retiredNodeHelpers: str[]
        standaloneNodeHelpers: str[]
        commands: str[]

fn v3R2cReactV3StatusJsonQuote(text: str): str =
    let quote: str = strings.CharToStr(char(34))
    var out = quote
    let total: int32 = strings.Len(text)
    var i: int32
    while i < total:
        let ch = text[i]
        if ch == char(34):
            out = out + "\\" + quote
        elif ch == '\\':
            out = out + "\\\\"
        elif ch == char(10):
            out = out + "\\n"
        elif ch == char(13):
            out = out + "\\r"
        elif ch == char(9):
            out = out + "\\t"
        else:
            out = out + strings.CharToStr(ch)
        i = i + 1
    out = out + quote
    return out

fn v3R2cReactV3StatusJsonArray(items: str[]): str =
    var out = "["
    for i in 0..<items.len:
        if i > 0:
            out = out + ", "
        out = out + v3R2cReactV3StatusJsonQuote(items[i])
    out = out + "]"
    return out

fn v3R2cReactV3StatusBoolText(value: bool): str =
    if value:
        return "true"
    return "false"

fn v3R2cReactV3StatusAppendUnique(items: var str[],
                                  item: str) =
    for i in 0..<items.len:
        if items[i] == item:
            return
    add(items, item)

fn v3R2cReactV3StatusContract(workspaceRootRaw: str): V3R2cReactV3StatusContract =
    let workspaceRoot = workspaceRootRaw
    let experimentalRoot = v3path.V3PathAbsolute(workspaceRoot, "v3/experimental/r2c-react-v3")
    var out: V3R2cReactV3StatusContract
    out.workspaceRoot = workspaceRoot
    out.experimentalRoot = experimentalRoot
    out.legacyPrototypePath = os.JoinPath(experimentalRoot, "r2c-react-v3.py")
    out.tsxFrontendHelper = os.JoinPath(experimentalRoot, "r2c-react-v3-ts-frontend.mjs")
    out.staticSurfaceHelper = ""
    out.semanticSurfaceHelper = ""
    out.codegenSurfaceHelper = os.JoinPath(experimentalRoot, "r2c-react-v3-codegen-surface.mjs")
    out.execSurfaceHelper = ""
    out.truthRuntimeHelper = os.JoinPath(experimentalRoot, "r2c-react-v3-truth-runtime.mjs")
    out.nativeGuiBundleHelper = os.JoinPath(experimentalRoot, "r2c-react-v3-native-gui-bundle.mjs")
    out.nativeGuiBundleFinalizer = "cheng_controller_native_gui_bundle_finalizer_v1"
    out.nativeGuiRuntimeHelper = ""
    out.nativeGuiRuntimeMode = "cheng_controller_compiled_json_v1"
    out.nativeGuiRunHelper = os.JoinPath(experimentalRoot, "r2c-react-v3-native-gui-run.mjs")
    out.nativeGuiLayoutPayloadFinalizer = "cheng_controller_layout_payload_finalizer_v1"
    out.nativeGuiLayoutItemCatalogMode = "cheng_streamed_typed_layout_items_v1"
    out.nativeGuiLayoutItemCatalogPayloadProfile = "cheng_runtime_layout_item_payload_v1"
    out.renderCompareHelper = os.JoinPath(experimentalRoot, "r2c-react-v3-render-compare.mjs")
    out.nativeGuiReplayHitInspectorHelper = ""
    out.execRouteMatrixHelper = os.JoinPath(experimentalRoot, "r2c-react-v3-exec-route-matrix.mjs")
    out.truthRouteHelper = os.JoinPath(experimentalRoot, "r2c-react-v3-discover-truth-routes.mjs")
    out.truthCompareHelper = ""
    out.truthCompareMatrixHelper = ""
    out.nativeGuiHostSource = os.JoinPath(experimentalRoot, "native_gui_host_macos.m")
    out.nativeGuiHostSourceKind = "objc_cocoa"
    out.nativeGuiHostHelpers = ["native_gui_host_source"]
    out.legacyShellWrapper = os.JoinPath(experimentalRoot, "r2c-react-v3")
    out.legacyShellWrappers = ["legacy_shell_wrapper"]
    out.legacyWrapperRequired = false
    out.legacyPrototypeRequired = false
    out.compileNonChengBlockers = [
        "tsx_frontend_helper",
        "codegen_surface_helper",
        "native_gui_bundle_helper"
    ]
    out.guiRuntimeNonChengBlockers = [
        "native_gui_host_source"
    ]
    out.truthRuntimeNonChengBlockers = [
        "truth_runtime_helper"
    ]
    out.optionalNonChengHelpers = [
        "legacy_shell_wrapper"
    ]
    out.remainingNonChengBlockers = []
    for i in 0..<out.compileNonChengBlockers.len:
        v3R2cReactV3StatusAppendUnique(out.remainingNonChengBlockers, out.compileNonChengBlockers[i])
    for i in 0..<out.guiRuntimeNonChengBlockers.len:
        v3R2cReactV3StatusAppendUnique(out.remainingNonChengBlockers, out.guiRuntimeNonChengBlockers[i])
    for i in 0..<out.truthRuntimeNonChengBlockers.len:
        v3R2cReactV3StatusAppendUnique(out.remainingNonChengBlockers, out.truthRuntimeNonChengBlockers[i])
    for i in 0..<out.optionalNonChengHelpers.len:
        v3R2cReactV3StatusAppendUnique(out.remainingNonChengBlockers, out.optionalNonChengHelpers[i])
    out.activeNodeHelpers = [
        "tsx_frontend_helper",
        "codegen_surface_helper"
    ]
    out.thinNodeHelpers = [
        "native_gui_bundle_helper",
        "exec_route_matrix_helper",
        "truth_route_helper"
    ]
    out.retiredNodeHelpers = [
        "native_gui_run_helper",
        "native_gui_runtime_helper",
        "native_gui_replay_hit_inspector_helper",
        "semantic_surface_helper",
        "static_surface_helper",
        "exec_surface_helper",
        "truth_compare_helper",
        "truth_compare_matrix_helper"
    ]
    out.standaloneNodeHelpers = [
        "truth_runtime_helper"
    ]
    out.commands = [
        "status",
        "frontend",
        "static-surface",
        "semantic-surface",
        "codegen-surface",
        "exec-surface",
        "native-gui-bundle",
        "run-native-gui",
        "render-compare",
        "render-compare-matrix",
        "replay-hit-inspector",
        "exec-route-matrix",
        "compile",
        "discover-truth-routes",
        "capture-truth",
        "compare-truth",
        "compare-truth-matrix",
        "prototype"
    ]
    return out

fn v3R2cReactV3PureChengCompileReady(contract: V3R2cReactV3StatusContract): bool =
    return contract.compileNonChengBlockers.len == 0

fn v3R2cReactV3PureChengGuiRuntimeReady(contract: V3R2cReactV3StatusContract): bool =
    return contract.guiRuntimeNonChengBlockers.len == 0

fn v3R2cReactV3PureChengTruthRuntimeReady(contract: V3R2cReactV3StatusContract): bool =
    return contract.truthRuntimeNonChengBlockers.len == 0

fn v3R2cReactV3PureChengGuiReady(contract: V3R2cReactV3StatusContract): bool =
    return v3R2cReactV3PureChengCompileReady(contract) &&
           v3R2cReactV3PureChengGuiRuntimeReady(contract) &&
           v3R2cReactV3PureChengTruthRuntimeReady(contract)

fn v3R2cReactV3StatusReportText(workspaceRootRaw: str): str =
    let contract = v3R2cReactV3StatusContract(workspaceRootRaw)
    var report = "{\n"
    report = report + "  \"format\": \"status_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"workspace_root\": " + v3R2cReactV3StatusJsonQuote(contract.workspaceRoot) + ",\n"
    report = report + "  \"experimental_root\": " + v3R2cReactV3StatusJsonQuote(contract.experimentalRoot) + ",\n"
    report = report + "  \"node_program\": \"node\",\n"
    report = report + "  \"legacy_prototype_path\": " + v3R2cReactV3StatusJsonQuote(contract.legacyPrototypePath) + ",\n"
    report = report + "  \"tsx_frontend_helper\": " + v3R2cReactV3StatusJsonQuote(contract.tsxFrontendHelper) + ",\n"
    report = report + "  \"static_surface_helper\": " + v3R2cReactV3StatusJsonQuote(contract.staticSurfaceHelper) + ",\n"
    report = report + "  \"semantic_surface_helper\": " + v3R2cReactV3StatusJsonQuote(contract.semanticSurfaceHelper) + ",\n"
    report = report + "  \"codegen_surface_helper\": " + v3R2cReactV3StatusJsonQuote(contract.codegenSurfaceHelper) + ",\n"
    report = report + "  \"exec_surface_helper\": " + v3R2cReactV3StatusJsonQuote(contract.execSurfaceHelper) + ",\n"
    report = report + "  \"truth_runtime_helper\": " + v3R2cReactV3StatusJsonQuote(contract.truthRuntimeHelper) + ",\n"
    report = report + "  \"native_gui_bundle_helper\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiBundleHelper) + ",\n"
    report = report + "  \"native_gui_bundle_finalizer\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiBundleFinalizer) + ",\n"
    report = report + "  \"native_gui_runtime_helper\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiRuntimeHelper) + ",\n"
    report = report + "  \"native_gui_runtime_mode\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiRuntimeMode) + ",\n"
    report = report + "  \"native_gui_run_helper\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiRunHelper) + ",\n"
    report = report + "  \"native_gui_layout_payload_finalizer\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiLayoutPayloadFinalizer) + ",\n"
    report = report + "  \"native_gui_layout_item_catalog_mode\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiLayoutItemCatalogMode) + ",\n"
    report = report + "  \"native_gui_layout_item_catalog_payload_profile\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiLayoutItemCatalogPayloadProfile) + ",\n"
    report = report + "  \"render_compare_helper\": " + v3R2cReactV3StatusJsonQuote(contract.renderCompareHelper) + ",\n"
    report = report + "  \"native_gui_replay_hit_inspector_helper\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiReplayHitInspectorHelper) + ",\n"
    report = report + "  \"exec_route_matrix_helper\": " + v3R2cReactV3StatusJsonQuote(contract.execRouteMatrixHelper) + ",\n"
    report = report + "  \"truth_route_helper\": " + v3R2cReactV3StatusJsonQuote(contract.truthRouteHelper) + ",\n"
    report = report + "  \"truth_compare_helper\": " + v3R2cReactV3StatusJsonQuote(contract.truthCompareHelper) + ",\n"
    report = report + "  \"truth_compare_matrix_helper\": " + v3R2cReactV3StatusJsonQuote(contract.truthCompareMatrixHelper) + ",\n"
    report = report + "  \"node_helper_surface_mode\": \"cheng_controller_min_surface_v1\",\n"
    report = report + "  \"native_gui_host_source\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiHostSource) + ",\n"
    report = report + "  \"native_gui_host_source_kind\": " + v3R2cReactV3StatusJsonQuote(contract.nativeGuiHostSourceKind) + ",\n"
    report = report + "  \"native_gui_host_helper_count\": " + intToStr(contract.nativeGuiHostHelpers.len) + ",\n"
    report = report + "  \"native_gui_host_helpers\": " + v3R2cReactV3StatusJsonArray(contract.nativeGuiHostHelpers) + ",\n"
    report = report + "  \"legacy_shell_wrapper\": " + v3R2cReactV3StatusJsonQuote(contract.legacyShellWrapper) + ",\n"
    report = report + "  \"legacy_shell_wrapper_count\": " + intToStr(contract.legacyShellWrappers.len) + ",\n"
    report = report + "  \"legacy_shell_wrappers\": " + v3R2cReactV3StatusJsonArray(contract.legacyShellWrappers) + ",\n"
    report = report + "  \"legacy_wrapper_required\": " + v3R2cReactV3StatusBoolText(contract.legacyWrapperRequired) + ",\n"
    report = report + "  \"legacy_prototype_required\": " + v3R2cReactV3StatusBoolText(contract.legacyPrototypeRequired) + ",\n"
    report = report + "  \"pure_cheng_compile_ready\": " + v3R2cReactV3StatusBoolText(v3R2cReactV3PureChengCompileReady(contract)) + ",\n"
    report = report + "  \"pure_cheng_gui_runtime_ready\": " + v3R2cReactV3StatusBoolText(v3R2cReactV3PureChengGuiRuntimeReady(contract)) + ",\n"
    report = report + "  \"pure_cheng_truth_runtime_ready\": " + v3R2cReactV3StatusBoolText(v3R2cReactV3PureChengTruthRuntimeReady(contract)) + ",\n"
    report = report + "  \"pure_cheng_gui_ready\": " + v3R2cReactV3StatusBoolText(v3R2cReactV3PureChengGuiReady(contract)) + ",\n"
    report = report + "  \"compile_non_cheng_blocker_count\": " + intToStr(contract.compileNonChengBlockers.len) + ",\n"
    report = report + "  \"compile_non_cheng_blockers\": " + v3R2cReactV3StatusJsonArray(contract.compileNonChengBlockers) + ",\n"
    report = report + "  \"gui_runtime_non_cheng_blocker_count\": " + intToStr(contract.guiRuntimeNonChengBlockers.len) + ",\n"
    report = report + "  \"gui_runtime_non_cheng_blockers\": " + v3R2cReactV3StatusJsonArray(contract.guiRuntimeNonChengBlockers) + ",\n"
    report = report + "  \"truth_runtime_non_cheng_blocker_count\": " + intToStr(contract.truthRuntimeNonChengBlockers.len) + ",\n"
    report = report + "  \"truth_runtime_non_cheng_blockers\": " + v3R2cReactV3StatusJsonArray(contract.truthRuntimeNonChengBlockers) + ",\n"
    report = report + "  \"optional_non_cheng_helper_count\": " + intToStr(contract.optionalNonChengHelpers.len) + ",\n"
    report = report + "  \"optional_non_cheng_helpers\": " + v3R2cReactV3StatusJsonArray(contract.optionalNonChengHelpers) + ",\n"
    report = report + "  \"remaining_non_cheng_blocker_count\": " + intToStr(contract.remainingNonChengBlockers.len) + ",\n"
    report = report + "  \"remaining_non_cheng_blockers\": " + v3R2cReactV3StatusJsonArray(contract.remainingNonChengBlockers) + ",\n"
    report = report + "  \"active_node_helper_count\": " + intToStr(contract.activeNodeHelpers.len) + ",\n"
    report = report + "  \"thin_node_helper_count\": " + intToStr(contract.thinNodeHelpers.len) + ",\n"
    report = report + "  \"retired_node_helper_count\": " + intToStr(contract.retiredNodeHelpers.len) + ",\n"
    report = report + "  \"retired_node_helpers\": " + v3R2cReactV3StatusJsonArray(contract.retiredNodeHelpers) + ",\n"
    report = report + "  \"standalone_node_helper_count\": " + intToStr(contract.standaloneNodeHelpers.len) + ",\n"
    report = report + "  \"standalone_node_helpers\": " + v3R2cReactV3StatusJsonArray(contract.standaloneNodeHelpers) + ",\n"
    report = report + "  \"active_node_helpers\": " + v3R2cReactV3StatusJsonArray(contract.activeNodeHelpers) + ",\n"
    report = report + "  \"thin_node_helpers\": " + v3R2cReactV3StatusJsonArray(contract.thinNodeHelpers) + ",\n"
    report = report + "  \"commands\": " + v3R2cReactV3StatusJsonArray(contract.commands) + "\n"
    report = report + "}\n"
    return report

fn v3R2cReactV3WriteStatusReport(reportPath: str,
                                 workspaceRootRaw: str): bool =
    let report = v3R2cReactV3StatusReportText(workspaceRootRaw)
    return v3path.V3WriteTextFile("", reportPath, report)

fn v3R2cReactV3ExpectedStatusNeedles(): str[] =
    return [
        "\"static_surface_helper\": \"\"",
        "\"semantic_surface_helper\": \"\"",
        "r2c-react-v3-truth-runtime.mjs",
        "\"exec_surface_helper\": \"\"",
        "\"native_gui_bundle_finalizer\": \"cheng_controller_native_gui_bundle_finalizer_v1\"",
        "\"native_gui_layout_payload_finalizer\": \"cheng_controller_layout_payload_finalizer_v1\"",
        "\"native_gui_layout_item_catalog_mode\": \"cheng_streamed_typed_layout_items_v1\"",
        "\"native_gui_layout_item_catalog_payload_profile\": \"cheng_runtime_layout_item_payload_v1\"",
        "\"native_gui_runtime_helper\": \"\"",
        "\"native_gui_replay_hit_inspector_helper\": \"\"",
        "\"native_gui_host_source_kind\": \"objc_cocoa\"",
        "\"legacy_shell_wrapper_count\": 1",
        "\"legacy_wrapper_required\": false",
        "\"pure_cheng_compile_ready\": false",
        "\"pure_cheng_gui_ready\": false",
        "\"compile_non_cheng_blocker_count\": 3",
        "\"optional_non_cheng_helper_count\": 1",
        "\"optional_non_cheng_helpers\": [\"legacy_shell_wrapper\"]",
        "\"remaining_non_cheng_blocker_count\": 6",
        "\"remaining_non_cheng_blockers\": [\"tsx_frontend_helper\", \"codegen_surface_helper\", \"native_gui_bundle_helper\", \"native_gui_host_source\", \"truth_runtime_helper\", \"legacy_shell_wrapper\"]",
        "\"active_node_helper_count\": 2",
        "\"thin_node_helper_count\": 3",
        "\"retired_node_helper_count\": 8",
        "\"standalone_node_helper_count\": 1",
        "\"retired_node_helpers\": [\"native_gui_run_helper\", \"native_gui_runtime_helper\", \"native_gui_replay_hit_inspector_helper\", \"semantic_surface_helper\", \"static_surface_helper\", \"exec_surface_helper\", \"truth_compare_helper\", \"truth_compare_matrix_helper\"]",
        "\"standalone_node_helpers\": [\"truth_runtime_helper\"]",
        "\"thin_node_helpers\": [\"native_gui_bundle_helper\", \"exec_route_matrix_helper\", \"truth_route_helper\"]"
    ]

fn V3R2cReactV3WriteStatusReport(reportPath: str,
                                 workspaceRootRaw: str): bool =
    return v3R2cReactV3WriteStatusReport(reportPath, workspaceRootRaw)

fn V3R2cReactV3ExpectedStatusNeedles(): str[] =
    return v3R2cReactV3ExpectedStatusNeedles()
