import std/os
import std/strings
import std/strutils as strutil
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

type
    V3MobileShellOptions =
        rootDir: str
        outDir: str
        appId: str
        appName: str
        libName: str
        runtimeMode: str
        runtimeContractPath: str
        runtimeBundlePath: str
        routeState: str
        emitAndroid: bool
        emitIos: bool
        emitHarmony: bool

fn v3MobileShellQuote(text: str): str =
    return "\"" + text + "\""

fn v3MobileShellJsonQuote(text: str): str =
    return "\"" + text + "\""

fn v3MobileShellJoin(items: var str[],
                     sep: str): str =
    var out: str = ""
    for i in 0..<items.len:
        if i > 0:
            out = out + sep
        out = out + items[i]
    return out

fn v3MobileShellAndroidPackagePath(appId: str): str =
    let parts: str[] = strutil.Split(appId, '.')
    return strutil.Join(parts, "/")

fn v3MobileShellDefaultOptions(rootDir: str): V3MobileShellOptions =
    var opts: V3MobileShellOptions
    opts.rootDir = rootDir
    opts.outDir = v3path.V3PathAbsolute(rootDir, "artifacts/mobile_shell_export")
    opts.appId = "org.cheng.generated.app"
    opts.appName = "ChengGeneratedApp"
    opts.libName = "cheng_mobile_app"
    opts.runtimeMode = "cheng_app_exports_v1"
    opts.runtimeContractPath = ""
    opts.runtimeBundlePath = ""
    opts.routeState = ""
    opts.emitAndroid = true
    opts.emitIos = true
    opts.emitHarmony = true
    return opts

