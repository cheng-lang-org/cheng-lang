fn v3MobileShellAndroidSettingsGradle(): str =
    var text: str = "pluginManagement {\n"
    text = text + "    repositories {\n"
    text = text + "        google()\n"
    text = text + "        mavenCentral()\n"
    text = text + "        gradlePluginPortal()\n"
    text = text + "    }\n"
    text = text + "}\n"
    text = text + "dependencyResolutionManagement {\n"
    text = text + "    repositoriesMode.set(RepositoriesMode.FAIL_ON_PROJECT_REPOS)\n"
    text = text + "    repositories {\n"
    text = text + "        google()\n"
    text = text + "        mavenCentral()\n"
    text = text + "    }\n"
    text = text + "}\n"
    text = text + "rootProject.name = \"cheng_mobile_shell\"\n"
    text = text + "include(\":app\")\n"
    return text

fn v3MobileShellAndroidTopBuildGradle(): str =
    var text: str = "plugins {\n"
    text = text + "    id(\"com.android.application\") version \"8.4.2\" apply false\n"
    text = text + "    id(\"org.jetbrains.kotlin.android\") version \"1.9.24\" apply false\n"
    text = text + "}\n"
    return text

fn v3MobileShellAndroidGradleProperties(): str =
    var text: str = "org.gradle.jvmargs=-Xmx2048m -Dfile.encoding=UTF-8\n"
    text = text + "android.useAndroidX=true\n"
    text = text + "kotlin.code.style=official\n"
    return text

fn v3MobileShellAndroidAppBuildGradle(opts: var V3MobileShellOptions): str =
    var text: str = "plugins {\n"
    text = text + "    id(\"com.android.application\")\n"
    text = text + "    id(\"org.jetbrains.kotlin.android\")\n"
    text = text + "}\n\n"
    text = text + "android {\n"
    text = text + "    namespace = " + v3MobileShellQuote(opts.appId) + "\n"
    text = text + "    compileSdk = 34\n\n"
    text = text + "    defaultConfig {\n"
    text = text + "        applicationId = " + v3MobileShellQuote(opts.appId) + "\n"
    text = text + "        minSdk = 28\n"
    text = text + "        targetSdk = 34\n"
    text = text + "        versionCode = 1\n"
    text = text + "        versionName = " + v3MobileShellQuote("1.0") + "\n"
    text = text + "        externalNativeBuild {\n"
    text = text + "            cmake {\n"
    text = text + "                cppFlags += " + v3MobileShellQuote("-std=c17") + "\n"
    text = text + "            }\n"
    text = text + "        }\n"
    text = text + "    }\n\n"
    text = text + "    buildTypes {\n"
    text = text + "        release {\n"
    text = text + "            isMinifyEnabled = false\n"
    text = text + "            proguardFiles(\n"
    text = text + "                getDefaultProguardFile(\"proguard-android-optimize.txt\"),\n"
    text = text + "                \"proguard-rules.pro\"\n"
    text = text + "            )\n"
    text = text + "        }\n"
    text = text + "    }\n\n"
    text = text + "    externalNativeBuild {\n"
    text = text + "        cmake {\n"
    text = text + "            path = file(\"src/main/cpp/CMakeLists.txt\")\n"
    text = text + "        }\n"
    text = text + "    }\n\n"
    text = text + "    buildFeatures {\n"
    text = text + "        prefab = false\n"
    text = text + "    }\n"
    text = text + "    compileOptions {\n"
    text = text + "        sourceCompatibility = JavaVersion.VERSION_17\n"
    text = text + "        targetCompatibility = JavaVersion.VERSION_17\n"
    text = text + "    }\n"
    text = text + "    kotlinOptions {\n"
    text = text + "        jvmTarget = " + v3MobileShellQuote("17") + "\n"
    text = text + "    }\n"
    text = text + "}\n\n"
    text = text + "dependencies {\n"
    text = text + "    implementation(" + v3MobileShellQuote("androidx.core:core-ktx:1.13.1") + ")\n"
    text = text + "}\n"
    return text

fn v3MobileShellAndroidManifest(opts: var V3MobileShellOptions): str =
    var text: str = "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n"
    text = text + "<manifest xmlns:android=\"http://schemas.android.com/apk/res/android\">\n"
    text = text + "    <application\n"
    text = text + "        android:allowBackup=\"false\"\n"
    text = text + "        android:label=\"@string/app_name\">\n"
    text = text + "        <activity\n"
    text = text + "            android:name=\".ChengMainActivity\"\n"
    text = text + "            android:configChanges=\"keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|smallestScreenSize|uiMode\"\n"
    text = text + "            android:exported=\"true\"\n"
    text = text + "            android:launchMode=\"singleTask\"\n"
    text = text + "            android:screenOrientation=\"portrait\">\n"
    text = text + "            <intent-filter>\n"
    text = text + "                <action android:name=\"android.intent.action.MAIN\" />\n"
    text = text + "                <category android:name=\"android.intent.category.LAUNCHER\" />\n"
    text = text + "            </intent-filter>\n"
    text = text + "        </activity>\n"
    text = text + "    </application>\n"
    text = text + "</manifest>\n"
    return text

fn v3MobileShellAndroidProguardRules(opts: var V3MobileShellOptions): str =
    var text: str = "# Generated by cheng mobile-shell export.\n"
    text = text + "-keep class " + opts.appId + ".** { *; }\n"
    text = text + "-keepclassmembers class * {\n"
    text = text + "    native <methods>;\n"
    text = text + "}\n"
    return text

fn v3MobileShellAndroidStringsXml(opts: var V3MobileShellOptions): str =
    var text: str = "<?xml version=\"1.0\" encoding=\"utf-8\"?>\n"
    text = text + "<resources>\n"
    text = text + "    <string name=\"app_name\">" + opts.appName + "</string>\n"
    text = text + "</resources>\n"
    return text

fn v3MobileShellAndroidActivity(opts: var V3MobileShellOptions): str =
    let runtimeManifestRel: str = "mobile_shell_runtime_contract_v1.json"
    let launchArgsKvRel: str = "runtime/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "runtime/mobile_shell_launch_args.json"
    var text: str = "package " + opts.appId + "\n\n"
    text = text + "import android.app.Activity\n"
    text = text + "import android.os.Bundle\n"
    text = text + "import android.os.SystemClock\n"
    text = text + "import android.view.MotionEvent\n"
    text = text + "import android.view.Surface\n"
    text = text + "import android.view.SurfaceHolder\n"
    text = text + "import android.view.SurfaceView\n"
    text = text + "import android.view.ViewGroup\n\n"
    text = text + "class ChengMainActivity : Activity(), SurfaceHolder.Callback {\n"
    text = text + "    companion object {\n"
    text = text + "        private const val CHENG_RUNTIME_MANIFEST = " + v3MobileShellQuote(runtimeManifestRel) + "\n"
    text = text + "        private const val CHENG_LAUNCH_ARGS_KV_REL = " + v3MobileShellQuote(launchArgsKvRel) + "\n"
    text = text + "        private const val CHENG_LAUNCH_ARGS_JSON_REL = " + v3MobileShellQuote(launchArgsJsonRel) + "\n"
    text = text + "        init {\n"
    text = text + "            System.loadLibrary(" + v3MobileShellQuote(opts.libName) + ")\n"
    text = text + "            System.loadLibrary(\"cheng_generated_android_host\")\n"
    text = text + "        }\n"
    text = text + "    }\n\n"
    text = text + "    private external fun nativeCreate(surface: Surface, width: Int, height: Int, density: Float, assetRoot: String, launchArgsKv: String, launchArgsJson: String): Long\n"
    text = text + "    private external fun nativeResize(handle: Long, surface: Surface, width: Int, height: Int, density: Float)\n"
    text = text + "    private external fun nativeTick(handle: Long, deltaSeconds: Float)\n"
    text = text + "    private external fun nativeTouch(handle: Long, action: Int, pointerId: Int, x: Float, y: Float)\n"
    text = text + "    private external fun nativePause(handle: Long)\n"
    text = text + "    private external fun nativeResume(handle: Long)\n\n"
    text = text + "    private lateinit var surfaceView: SurfaceView\n"
    text = text + "    private var runtimeHandle: Long = 0L\n"
    text = text + "    private var lastFrameMs: Long = 0L\n\n"
    text = text + "    private fun readAssetText(relPath: String): String {\n"
    text = text + "        return assets.open(relPath).bufferedReader().use { it.readText() }\n"
    text = text + "    }\n\n"
    text = text + "    override fun onCreate(savedInstanceState: Bundle?) {\n"
    text = text + "        super.onCreate(savedInstanceState)\n"
    text = text + "        surfaceView = SurfaceView(this)\n"
    text = text + "        surfaceView.holder.addCallback(this)\n"
    text = text + "        surfaceView.setOnTouchListener { _, event ->\n"
    text = text + "            if (runtimeHandle != 0L) {\n"
    text = text + "                val pointerId = event.getPointerId(event.actionIndex)\n"
    text = text + "                nativeTouch(runtimeHandle, event.actionMasked, pointerId, event.x, event.y)\n"
    text = text + "            }\n"
    text = text + "            true\n"
    text = text + "        }\n"
    text = text + "        setContentView(surfaceView, ViewGroup.LayoutParams(ViewGroup.LayoutParams.MATCH_PARENT, ViewGroup.LayoutParams.MATCH_PARENT))\n"
    text = text + "    }\n\n"
    text = text + "    override fun surfaceCreated(holder: SurfaceHolder) {\n"
    text = text + "        val density = resources.displayMetrics.density\n"
    text = text + "        val launchArgsKv = readAssetText(CHENG_LAUNCH_ARGS_KV_REL)\n"
    text = text + "        val launchArgsJson = readAssetText(CHENG_LAUNCH_ARGS_JSON_REL)\n"
    text = text + "        runtimeHandle = nativeCreate(holder.surface, surfaceView.width, surfaceView.height, density, filesDir.absolutePath, launchArgsKv, launchArgsJson)\n"
    text = text + "        lastFrameMs = SystemClock.uptimeMillis()\n"
    text = text + "        surfaceView.post(framePump)\n"
    text = text + "    }\n\n"
    text = text + "    override fun surfaceChanged(holder: SurfaceHolder, format: Int, width: Int, height: Int) {\n"
    text = text + "        if (runtimeHandle != 0L) {\n"
    text = text + "            nativeResize(runtimeHandle, holder.surface, width, height, resources.displayMetrics.density)\n"
    text = text + "        }\n"
    text = text + "    }\n\n"
    text = text + "    override fun surfaceDestroyed(holder: SurfaceHolder) {\n"
    text = text + "        if (runtimeHandle != 0L) {\n"
    text = text + "            nativePause(runtimeHandle)\n"
    text = text + "        }\n"
    text = text + "    }\n\n"
    text = text + "    override fun onResume() {\n"
    text = text + "        super.onResume()\n"
    text = text + "        if (runtimeHandle != 0L) {\n"
    text = text + "            nativeResume(runtimeHandle)\n"
    text = text + "        }\n"
    text = text + "    }\n\n"
    text = text + "    override fun onPause() {\n"
    text = text + "        if (runtimeHandle != 0L) {\n"
    text = text + "            nativePause(runtimeHandle)\n"
    text = text + "        }\n"
    text = text + "        super.onPause()\n"
    text = text + "    }\n\n"
    text = text + "    private val framePump = object : Runnable {\n"
    text = text + "        override fun run() {\n"
    text = text + "            if (runtimeHandle == 0L || !surfaceView.holder.surface.isValid) {\n"
    text = text + "                return\n"
    text = text + "            }\n"
    text = text + "            val now = SystemClock.uptimeMillis()\n"
    text = text + "            val delta = ((now - lastFrameMs).coerceAtLeast(1L)).toFloat() / 1000.0f\n"
    text = text + "            lastFrameMs = now\n"
    text = text + "            nativeTick(runtimeHandle, delta)\n"
    text = text + "            surfaceView.postOnAnimation(this)\n"
    text = text + "        }\n"
    text = text + "    }\n"
    text = text + "}\n"
    return text

fn v3MobileShellAndroidCmake(opts: var V3MobileShellOptions): str =
    var text: str = "cmake_minimum_required(VERSION 3.22.1)\n"
    text = text + "project(cheng_generated_android_host C)\n\n"
    text = text + "add_library(cheng_generated_android_host SHARED cheng_generated_android_host.c)\n"
    text = text + "target_compile_definitions(cheng_generated_android_host PRIVATE CHENG_APP_LIB_NAME=\\\"" + opts.libName + "\\\")\n"
    text = text + "find_library(log-lib log)\n"
    text = text + "find_library(android-lib android)\n"
    text = text + "target_link_libraries(cheng_generated_android_host ${log-lib} ${android-lib})\n"
    return text

fn v3MobileShellAndroidHostSource(opts: var V3MobileShellOptions): str =
    let runtimeManifestRel: str = "mobile_shell_runtime_contract_v1.json"
    let launchArgsKvRel: str = "runtime/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "runtime/mobile_shell_launch_args.json"
    var text: str = "#include <jni.h>\n"
    text = text + "#include <android/log.h>\n"
    text = text + "#include <android/native_window_jni.h>\n"
    text = text + "#include <dlfcn.h>\n"
    text = text + "#include <stdio.h>\n"
    text = text + "#include <stdint.h>\n"
    text = text + "#include <stdlib.h>\n"
    text = text + "#include <string.h>\n\n"
    text = text + "#ifndef CHENG_APP_LIB_NAME\n"
    text = text + "#define CHENG_APP_LIB_NAME \"" + opts.libName + "\"\n"
    text = text + "#endif\n\n"
    text = text + "typedef uint64_t (*cheng_app_init_fn)(void);\n"
    text = text + "typedef void (*cheng_app_set_window_fn)(uint64_t, uint64_t, int, int, float);\n"
    text = text + "typedef void (*cheng_app_tick_fn)(uint64_t, float);\n"
    text = text + "typedef void (*cheng_app_on_touch_fn)(uint64_t, int, int, float, float);\n"
    text = text + "typedef void (*cheng_app_pause_fn)(uint64_t);\n"
    text = text + "typedef void (*cheng_app_resume_fn)(uint64_t);\n\n"
    text = text + "typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);\n\n"
    text = text + "typedef struct ChengAndroidShellRuntime {\n"
    text = text + "  uint64_t app_id;\n"
    text = text + "  ANativeWindow* window;\n"
    text = text + "  int width;\n"
    text = text + "  int height;\n"
    text = text + "  float density;\n"
    text = text + "} ChengAndroidShellRuntime;\n\n"
    text = text + "static void* s_app_handle = NULL;\n"
    text = text + "static cheng_app_init_fn s_app_init = NULL;\n"
    text = text + "static cheng_app_set_window_fn s_app_set_window = NULL;\n"
    text = text + "static cheng_app_tick_fn s_app_tick = NULL;\n"
    text = text + "static cheng_app_on_touch_fn s_app_on_touch = NULL;\n"
    text = text + "static cheng_app_pause_fn s_app_pause = NULL;\n"
    text = text + "static cheng_app_resume_fn s_app_resume = NULL;\n\n"
    text = text + "static const char* kChengRuntimeManifest = \"" + runtimeManifestRel + "\";\n"
    text = text + "static const char* kChengLaunchArgsKvRel = \"" + launchArgsKvRel + "\";\n"
    text = text + "static const char* kChengLaunchArgsJsonRel = \"" + launchArgsJsonRel + "\";\n"
    text = text + "\n"
    text = text + "static void cheng_log(const char* msg) {\n"
    text = text + "  __android_log_print(ANDROID_LOG_INFO, \"cheng-mobile-shell\", \"%s\", msg);\n"
    text = text + "}\n\n"
    text = text + "static int cheng_resolve_exports(void) {\n"
    text = text + "  if (s_app_init != NULL) {\n"
    text = text + "    return 1;\n"
    text = text + "  }\n"
    text = text + "  char lib_path[256];\n"
    text = text + "  snprintf(lib_path, sizeof(lib_path), \"lib%s.so\", CHENG_APP_LIB_NAME);\n"
    text = text + "  s_app_handle = dlopen(lib_path, RTLD_NOW | RTLD_GLOBAL);\n"
    text = text + "  if (s_app_handle == NULL) {\n"
    text = text + "    cheng_log(dlerror());\n"
    text = text + "    return 0;\n"
    text = text + "  }\n"
    text = text + "  s_app_init = (cheng_app_init_fn)dlsym(s_app_handle, \"cheng_app_init\");\n"
    text = text + "  s_app_set_window = (cheng_app_set_window_fn)dlsym(s_app_handle, \"cheng_app_set_window\");\n"
    text = text + "  s_app_tick = (cheng_app_tick_fn)dlsym(s_app_handle, \"cheng_app_tick\");\n"
    text = text + "  s_app_on_touch = (cheng_app_on_touch_fn)dlsym(s_app_handle, \"cheng_app_on_touch\");\n"
    text = text + "  s_app_pause = (cheng_app_pause_fn)dlsym(s_app_handle, \"cheng_app_pause\");\n"
    text = text + "  s_app_resume = (cheng_app_resume_fn)dlsym(s_app_handle, \"cheng_app_resume\");\n"
    text = text + "  return s_app_init && s_app_set_window && s_app_tick && s_app_on_touch && s_app_pause && s_app_resume;\n"
    text = text + "}\n\n"
    text = text + "static void cheng_set_launch_args(JNIEnv* env, jstring launch_args_kv, jstring launch_args_json) {\n"
    text = text + "  if (env == NULL || s_app_handle == NULL) {\n"
    text = text + "    return;\n"
    text = text + "  }\n"
    text = text + "  cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(s_app_handle, \"cheng_mobile_host_runtime_set_launch_args\");\n"
    text = text + "  if (setLaunchArgs == NULL) {\n"
    text = text + "    return;\n"
    text = text + "  }\n"
    text = text + "  const char* kv = NULL;\n"
    text = text + "  const char* json = NULL;\n"
    text = text + "  if (launch_args_kv != NULL) {\n"
    text = text + "    kv = (*env)->GetStringUTFChars(env, launch_args_kv, NULL);\n"
    text = text + "  }\n"
    text = text + "  if (launch_args_json != NULL) {\n"
    text = text + "    json = (*env)->GetStringUTFChars(env, launch_args_json, NULL);\n"
    text = text + "  }\n"
    text = text + "  setLaunchArgs(kv, json);\n"
    text = text + "  if (launch_args_kv != NULL && kv != NULL) {\n"
    text = text + "    (*env)->ReleaseStringUTFChars(env, launch_args_kv, kv);\n"
    text = text + "  }\n"
    text = text + "  if (launch_args_json != NULL && json != NULL) {\n"
    text = text + "    (*env)->ReleaseStringUTFChars(env, launch_args_json, json);\n"
    text = text + "  }\n"
    text = text + "}\n\n"
    text = text + "static ChengAndroidShellRuntime* cheng_runtime_new(JNIEnv* env, jobject surface, jint width, jint height, jfloat density) {\n"
    text = text + "  env = env;\n"
    text = text + "  ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)calloc(1u, sizeof(ChengAndroidShellRuntime));\n"
    text = text + "  if (runtime == NULL) {\n"
    text = text + "    return NULL;\n"
    text = text + "  }\n"
    text = text + "  runtime->window = ANativeWindow_fromSurface(env, surface);\n"
    text = text + "  runtime->width = (int)width;\n"
    text = text + "  runtime->height = (int)height;\n"
    text = text + "  runtime->density = density;\n"
    text = text + "  runtime->app_id = s_app_init();\n"
    text = text + "  s_app_set_window(runtime->app_id, 1u, runtime->width, runtime->height, runtime->density);\n"
    text = text + "  return runtime;\n"
    text = text + "}\n\n"
    text = text + "static jlong native_create(JNIEnv* env, jobject thiz, jobject surface, jint width, jint height, jfloat density, jstring assetRoot, jstring launchArgsKv, jstring launchArgsJson) {\n"
    text = text + "  thiz = thiz;\n"
    text = text + "  assetRoot = assetRoot;\n"
    text = text + "  if (!cheng_resolve_exports()) {\n"
    text = text + "    return 0;\n"
    text = text + "  }\n"
    text = text + "  cheng_set_launch_args(env, launchArgsKv, launchArgsJson);\n"
    text = text + "  ChengAndroidShellRuntime* runtime = cheng_runtime_new(env, surface, width, height, density);\n"
    text = text + "  return (jlong)(uintptr_t)runtime;\n"
    text = text + "}\n\n"
    text = text + "static void native_resize(JNIEnv* env, jobject thiz, jlong handle, jobject surface, jint width, jint height, jfloat density) {\n"
    text = text + "  env = env;\n"
    text = text + "  thiz = thiz;\n"
    text = text + "  ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;\n"
    text = text + "  if (runtime == NULL) {\n"
    text = text + "    return;\n"
    text = text + "  }\n"
    text = text + "  if (runtime->window != NULL) {\n"
    text = text + "    ANativeWindow_release(runtime->window);\n"
    text = text + "  }\n"
    text = text + "  runtime->window = ANativeWindow_fromSurface(env, surface);\n"
    text = text + "  runtime->width = (int)width;\n"
    text = text + "  runtime->height = (int)height;\n"
    text = text + "  runtime->density = density;\n"
    text = text + "  s_app_set_window(runtime->app_id, 1u, runtime->width, runtime->height, runtime->density);\n"
    text = text + "}\n\n"
    text = text + "static void native_tick(JNIEnv* env, jobject thiz, jlong handle, jfloat delta_seconds) {\n"
    text = text + "  env = env;\n"
    text = text + "  thiz = thiz;\n"
    text = text + "  ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;\n"
    text = text + "  if (runtime == NULL) {\n"
    text = text + "    return;\n"
    text = text + "  }\n"
    text = text + "  s_app_tick(runtime->app_id, delta_seconds);\n"
    text = text + "}\n\n"
    text = text + "static void native_touch(JNIEnv* env, jobject thiz, jlong handle, jint action, jint pointer_id, jfloat x, jfloat y) {\n"
    text = text + "  env = env;\n"
    text = text + "  thiz = thiz;\n"
    text = text + "  ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;\n"
    text = text + "  if (runtime == NULL) {\n"
    text = text + "    return;\n"
    text = text + "  }\n"
    text = text + "  s_app_on_touch(runtime->app_id, action, pointer_id, x, y);\n"
    text = text + "}\n\n"
    text = text + "static void native_pause(JNIEnv* env, jobject thiz, jlong handle) {\n"
    text = text + "  env = env;\n"
    text = text + "  thiz = thiz;\n"
    text = text + "  ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;\n"
    text = text + "  if (runtime == NULL) {\n"
    text = text + "    return;\n"
    text = text + "  }\n"
    text = text + "  s_app_pause(runtime->app_id);\n"
    text = text + "}\n\n"
    text = text + "static void native_resume(JNIEnv* env, jobject thiz, jlong handle) {\n"
    text = text + "  env = env;\n"
    text = text + "  thiz = thiz;\n"
    text = text + "  ChengAndroidShellRuntime* runtime = (ChengAndroidShellRuntime*)(uintptr_t)handle;\n"
    text = text + "  if (runtime == NULL) {\n"
    text = text + "    return;\n"
    text = text + "  }\n"
    text = text + "  s_app_resume(runtime->app_id);\n"
    text = text + "}\n\n"
    text = text + "jint JNI_OnLoad(JavaVM* vm, void* reserved) {\n"
    text = text + "  reserved = reserved;\n"
    text = text + "  JNIEnv* env = NULL;\n"
    text = text + "  if ((*vm)->GetEnv(vm, (void**)&env, JNI_VERSION_1_6) != JNI_OK) {\n"
    text = text + "    return JNI_ERR;\n"
    text = text + "  }\n"
    text = text + "  const char* class_name = \"" + v3MobileShellAndroidPackagePath(opts.appId) + "/ChengMainActivity\";\n"
    text = text + "  jclass cls = (*env)->FindClass(env, class_name);\n"
    text = text + "  if (cls == NULL) {\n"
    text = text + "    return JNI_ERR;\n"
    text = text + "  }\n"
    text = text + "  const JNINativeMethod methods[] = {\n"
    text = text + "      {\"nativeCreate\", \"(Landroid/view/Surface;IIFLjava/lang/String;Ljava/lang/String;Ljava/lang/String;)J\", (void*)native_create},\n"
    text = text + "      {\"nativeResize\", \"(JLandroid/view/Surface;IIF)V\", (void*)native_resize},\n"
    text = text + "      {\"nativeTick\", \"(JF)V\", (void*)native_tick},\n"
    text = text + "      {\"nativeTouch\", \"(JIIFF)V\", (void*)native_touch},\n"
    text = text + "      {\"nativePause\", \"(J)V\", (void*)native_pause},\n"
    text = text + "      {\"nativeResume\", \"(J)V\", (void*)native_resume},\n"
    text = text + "  };\n"
    text = text + "  if ((*env)->RegisterNatives(env, cls, methods, (jint)(sizeof(methods) / sizeof(methods[0]))) != JNI_OK) {\n"
    text = text + "    return JNI_ERR;\n"
    text = text + "  }\n"
    text = text + "  return JNI_VERSION_1_6;\n"
    text = text + "}\n"
    return text

fn v3MobileShellIosInfoPlist(opts: var V3MobileShellOptions): str =
    var text: str = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
    text = text + "<!DOCTYPE plist PUBLIC \"-//Apple//DTD PLIST 1.0//EN\" \"http://www.apple.com/DTDs/PropertyList-1.0.dtd\">\n"
    text = text + "<plist version=\"1.0\">\n"
    text = text + "<dict>\n"
    text = text + "    <key>CFBundleDevelopmentRegion</key>\n"
    text = text + "    <string>en</string>\n"
    text = text + "    <key>CFBundleExecutable</key>\n"
    text = text + "    <string>$(EXECUTABLE_NAME)</string>\n"
    text = text + "    <key>CFBundleIdentifier</key>\n"
    text = text + "    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>\n"
    text = text + "    <key>CFBundleDisplayName</key>\n"
    text = text + "    <string>" + opts.appName + "</string>\n"
    text = text + "    <key>CFBundleName</key>\n"
    text = text + "    <string>$(PRODUCT_NAME)</string>\n"
    text = text + "    <key>CFBundlePackageType</key>\n"
    text = text + "    <string>APPL</string>\n"
    text = text + "    <key>LSRequiresIPhoneOS</key>\n"
    text = text + "    <true/>\n"
    text = text + "    <key>UIApplicationSceneManifest</key>\n"
    text = text + "    <dict/>\n"
    text = text + "    <key>UILaunchStoryboardName</key>\n"
    text = text + "    <string></string>\n"
    text = text + "</dict>\n"
    text = text + "</plist>\n"
    return text

fn v3MobileShellIosProjectPbxproj(opts: var V3MobileShellOptions): str =
    var text: str = "// !$*UTF8*$!\n"
    text = text + "{\n"
    text = text + "\tarchiveVersion = 1;\n"
    text = text + "\tclasses = {\n"
    text = text + "\t};\n"
    text = text + "\tobjectVersion = 56;\n"
    text = text + "\tobjects = {\n\n"
    text = text + "/* Begin PBXBuildFile section */\n"
    text = text + "\tA10000000000000000000001 /* main.m in Sources */ = {isa = PBXBuildFile; fileRef = A20000000000000000000001 /* main.m */; };\n"
    text = text + "\tA10000000000000000000002 /* ChengGeneratedAppDelegate.m in Sources */ = {isa = PBXBuildFile; fileRef = A20000000000000000000003 /* ChengGeneratedAppDelegate.m */; };\n"
    text = text + "\tA10000000000000000000003 /* ChengGeneratedMetalViewController.m in Sources */ = {isa = PBXBuildFile; fileRef = A20000000000000000000005 /* ChengGeneratedMetalViewController.m */; };\n"
    text = text + "\tA10000000000000000000004 /* Foundation.framework in Frameworks */ = {isa = PBXBuildFile; fileRef = A20000000000000000000008 /* Foundation.framework */; };\n"
    text = text + "\tA10000000000000000000005 /* UIKit.framework in Frameworks */ = {isa = PBXBuildFile; fileRef = A20000000000000000000009 /* UIKit.framework */; };\n"
    text = text + "\tA10000000000000000000006 /* Metal.framework in Frameworks */ = {isa = PBXBuildFile; fileRef = A2000000000000000000000A /* Metal.framework */; };\n"
    text = text + "\tA10000000000000000000007 /* QuartzCore.framework in Frameworks */ = {isa = PBXBuildFile; fileRef = A2000000000000000000000B /* QuartzCore.framework */; };\n"
    text = text + "\tA10000000000000000000008 /* mobile_shell_runtime_contract_v1.json in Resources */ = {isa = PBXBuildFile; fileRef = A2000000000000000000000C /* mobile_shell_runtime_contract_v1.json */; };\n"
    text = text + "\tA10000000000000000000009 /* mobile_shell_runtime_contract_payload.json in Resources */ = {isa = PBXBuildFile; fileRef = A2000000000000000000000D /* mobile_shell_runtime_contract_payload.json */; };\n"
    text = text + "\tA1000000000000000000000A /* mobile_shell_runtime_bundle_payload.json in Resources */ = {isa = PBXBuildFile; fileRef = A2000000000000000000000E /* mobile_shell_runtime_bundle_payload.json */; };\n"
    text = text + "\tA1000000000000000000000B /* mobile_shell_launch_args.kv in Resources */ = {isa = PBXBuildFile; fileRef = A2000000000000000000000F /* mobile_shell_launch_args.kv */; };\n"
    text = text + "\tA1000000000000000000000C /* mobile_shell_launch_args.json in Resources */ = {isa = PBXBuildFile; fileRef = A20000000000000000000010 /* mobile_shell_launch_args.json */; };\n"
    text = text + "/* End PBXBuildFile section */\n\n"
    text = text + "/* Begin PBXFileReference section */\n"
    text = text + "\tA20000000000000000000001 /* main.m */ = {isa = PBXFileReference; lastKnownFileType = sourcecode.c.objc; path = main.m; sourceTree = \"<group>\"; };\n"
    text = text + "\tA20000000000000000000002 /* ChengGeneratedAppDelegate.h */ = {isa = PBXFileReference; lastKnownFileType = sourcecode.c.h; path = ChengGeneratedAppDelegate.h; sourceTree = \"<group>\"; };\n"
    text = text + "\tA20000000000000000000003 /* ChengGeneratedAppDelegate.m */ = {isa = PBXFileReference; lastKnownFileType = sourcecode.c.objc; path = ChengGeneratedAppDelegate.m; sourceTree = \"<group>\"; };\n"
    text = text + "\tA20000000000000000000004 /* ChengGeneratedMetalViewController.h */ = {isa = PBXFileReference; lastKnownFileType = sourcecode.c.h; path = ChengGeneratedMetalViewController.h; sourceTree = \"<group>\"; };\n"
    text = text + "\tA20000000000000000000005 /* ChengGeneratedMetalViewController.m */ = {isa = PBXFileReference; lastKnownFileType = sourcecode.c.objc; path = ChengGeneratedMetalViewController.m; sourceTree = \"<group>\"; };\n"
    text = text + "\tA20000000000000000000006 /* Info.plist */ = {isa = PBXFileReference; lastKnownFileType = text.plist.xml; path = Info.plist; sourceTree = \"<group>\"; };\n"
    text = text + "\tA20000000000000000000007 /* ChengGeneratedApp.app */ = {isa = PBXFileReference; explicitFileType = wrapper.application; includeInIndex = 0; path = ChengGeneratedApp.app; sourceTree = BUILT_PRODUCTS_DIR; };\n"
    text = text + "\tA20000000000000000000008 /* Foundation.framework */ = {isa = PBXFileReference; lastKnownFileType = wrapper.framework; name = Foundation.framework; path = System/Library/Frameworks/Foundation.framework; sourceTree = SDKROOT; };\n"
    text = text + "\tA20000000000000000000009 /* UIKit.framework */ = {isa = PBXFileReference; lastKnownFileType = wrapper.framework; name = UIKit.framework; path = System/Library/Frameworks/UIKit.framework; sourceTree = SDKROOT; };\n"
    text = text + "\tA2000000000000000000000A /* Metal.framework */ = {isa = PBXFileReference; lastKnownFileType = wrapper.framework; name = Metal.framework; path = System/Library/Frameworks/Metal.framework; sourceTree = SDKROOT; };\n"
    text = text + "\tA2000000000000000000000B /* QuartzCore.framework */ = {isa = PBXFileReference; lastKnownFileType = wrapper.framework; name = QuartzCore.framework; path = System/Library/Frameworks/QuartzCore.framework; sourceTree = SDKROOT; };\n"
    text = text + "\tA2000000000000000000000C /* mobile_shell_runtime_contract_v1.json */ = {isa = PBXFileReference; lastKnownFileType = text.json; path = runtime/mobile_shell_runtime_contract_v1.json; sourceTree = \"<group>\"; };\n"
    text = text + "\tA2000000000000000000000D /* mobile_shell_runtime_contract_payload.json */ = {isa = PBXFileReference; lastKnownFileType = text.json; path = runtime/mobile_shell_runtime_contract_payload.json; sourceTree = \"<group>\"; };\n"
    text = text + "\tA2000000000000000000000E /* mobile_shell_runtime_bundle_payload.json */ = {isa = PBXFileReference; lastKnownFileType = text.json; path = runtime/mobile_shell_runtime_bundle_payload.json; sourceTree = \"<group>\"; };\n"
    text = text + "\tA2000000000000000000000F /* mobile_shell_launch_args.kv */ = {isa = PBXFileReference; lastKnownFileType = text; path = runtime/mobile_shell_launch_args.kv; sourceTree = \"<group>\"; };\n"
    text = text + "\tA20000000000000000000010 /* mobile_shell_launch_args.json */ = {isa = PBXFileReference; lastKnownFileType = text.json; path = runtime/mobile_shell_launch_args.json; sourceTree = \"<group>\"; };\n"
    text = text + "/* End PBXFileReference section */\n\n"
    text = text + "/* Begin PBXFrameworksBuildPhase section */\n"
    text = text + "\tA30000000000000000000001 /* Frameworks */ = {\n"
    text = text + "\t\tisa = PBXFrameworksBuildPhase;\n"
    text = text + "\t\tbuildActionMask = 2147483647;\n"
    text = text + "\t\tfiles = (\n"
    text = text + "\t\t\tA10000000000000000000004 /* Foundation.framework in Frameworks */,\n"
    text = text + "\t\t\tA10000000000000000000005 /* UIKit.framework in Frameworks */,\n"
    text = text + "\t\t\tA10000000000000000000006 /* Metal.framework in Frameworks */,\n"
    text = text + "\t\t\tA10000000000000000000007 /* QuartzCore.framework in Frameworks */,\n"
