fn v3MobileShellIosViewControllerImpl(opts: var V3MobileShellOptions): str =
    let runtimeManifestRel: str = "runtime/mobile_shell_runtime_contract_v1.json"
    let launchArgsKvRel: str = "runtime/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "runtime/mobile_shell_launch_args.json"
    var text: str = "#import \"ChengGeneratedMetalViewController.h\"\n"
    text = text + "#import <QuartzCore/CAMetalLayer.h>\n"
    text = text + "#import <Metal/Metal.h>\n"
    text = text + "#import <dlfcn.h>\n\n"
    text = text + "typedef unsigned long long (*cheng_app_init_fn)(void);\n"
    text = text + "typedef void (*cheng_app_set_window_fn)(unsigned long long, unsigned long long, int, int, float);\n"
    text = text + "typedef void (*cheng_app_tick_fn)(unsigned long long, float);\n"
    text = text + "typedef void (*cheng_app_on_touch_fn)(unsigned long long, int, int, float, float);\n"
    text = text + "typedef void (*cheng_app_pause_fn)(unsigned long long);\n"
    text = text + "typedef void (*cheng_app_resume_fn)(unsigned long long);\n\n"
    text = text + "typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);\n\n"
    text = text + "static const char* kChengRuntimeManifest = \"" + runtimeManifestRel + "\";\n"
    text = text + "static const char* kChengLaunchArgsKvRel = \"" + launchArgsKvRel + "\";\n"
    text = text + "static const char* kChengLaunchArgsJsonRel = \"" + launchArgsJsonRel + "\";\n"
    text = text + "\n"
    text = text + "static NSString* cheng_load_bundle_text(const char* relPath) {\n"
    text = text + "    if (relPath == NULL || relPath[0] == '\\0') {\n"
    text = text + "        return nil;\n"
    text = text + "    }\n"
    text = text + "    NSString* rel = [NSString stringWithUTF8String:relPath];\n"
    text = text + "    NSString* dir = [rel stringByDeletingLastPathComponent];\n"
    text = text + "    NSString* file = [rel lastPathComponent];\n"
    text = text + "    NSString* stem = [file stringByDeletingPathExtension];\n"
    text = text + "    NSString* ext = [file pathExtension];\n"
    text = text + "    NSString* full = [[NSBundle mainBundle] pathForResource:stem ofType:(ext.length > 0 ? ext : nil) inDirectory:(dir.length > 0 ? dir : nil)];\n"
    text = text + "    if (full == nil) {\n"
    text = text + "        return nil;\n"
    text = text + "    }\n"
    text = text + "    return [NSString stringWithContentsOfFile:full encoding:NSUTF8StringEncoding error:nil];\n"
    text = text + "}\n\n"
    text = text + "@interface ChengGeneratedMetalView : UIView\n"
    text = text + "@property(nonatomic) unsigned long long appId;\n"
    text = text + "@property(nonatomic, strong) CADisplayLink* displayLink;\n"
    text = text + "@end\n\n"
    text = text + "@implementation ChengGeneratedMetalView {\n"
    text = text + "    cheng_app_set_window_fn _setWindow;\n"
    text = text + "    cheng_app_tick_fn _tick;\n"
    text = text + "    cheng_app_on_touch_fn _touch;\n"
    text = text + "    cheng_app_pause_fn _pause;\n"
    text = text + "    cheng_app_resume_fn _resume;\n"
    text = text + "}\n\n"
    text = text + "+ (Class)layerClass {\n"
    text = text + "    return [CAMetalLayer class];\n"
    text = text + "}\n\n"
    text = text + "- (instancetype)initWithFrame:(CGRect)frame {\n"
    text = text + "    self = [super initWithFrame:frame];\n"
    text = text + "    if (self == nil) {\n"
    text = text + "        return nil;\n"
    text = text + "    }\n"
    text = text + "    CAMetalLayer* layer = (CAMetalLayer*)self.layer;\n"
    text = text + "    layer.device = MTLCreateSystemDefaultDevice();\n"
    text = text + "    layer.pixelFormat = MTLPixelFormatBGRA8Unorm;\n"
    text = text + "    void* handle = dlopen(NULL, RTLD_NOW);\n"
    text = text + "    cheng_app_init_fn initFn = (cheng_app_init_fn)dlsym(handle, \"cheng_app_init\");\n"
    text = text + "    _setWindow = (cheng_app_set_window_fn)dlsym(handle, \"cheng_app_set_window\");\n"
    text = text + "    _tick = (cheng_app_tick_fn)dlsym(handle, \"cheng_app_tick\");\n"
    text = text + "    _touch = (cheng_app_on_touch_fn)dlsym(handle, \"cheng_app_on_touch\");\n"
    text = text + "    _pause = (cheng_app_pause_fn)dlsym(handle, \"cheng_app_pause\");\n"
    text = text + "    _resume = (cheng_app_resume_fn)dlsym(handle, \"cheng_app_resume\");\n"
    text = text + "    cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(handle, \"cheng_mobile_host_runtime_set_launch_args\");\n"
    text = text + "    if (setLaunchArgs != NULL) {\n"
    text = text + "        NSString* launchArgsKv = cheng_load_bundle_text(kChengLaunchArgsKvRel);\n"
    text = text + "        NSString* launchArgsJson = cheng_load_bundle_text(kChengLaunchArgsJsonRel);\n"
    text = text + "        setLaunchArgs(launchArgsKv != nil ? [launchArgsKv UTF8String] : NULL,\n"
    text = text + "                      launchArgsJson != nil ? [launchArgsJson UTF8String] : NULL);\n"
    text = text + "    }\n"
    text = text + "    if (initFn != NULL) {\n"
    text = text + "        self.appId = initFn();\n"
    text = text + "    }\n"
    text = text + "    self.displayLink = [CADisplayLink displayLinkWithTarget:self selector:@selector(step:)];\n"
    text = text + "    [self.displayLink addToRunLoop:[NSRunLoop mainRunLoop] forMode:NSDefaultRunLoopMode];\n"
    text = text + "    return self;\n"
    text = text + "}\n\n"
    text = text + "- (void)layoutSubviews {\n"
    text = text + "    [super layoutSubviews];\n"
    text = text + "    if (_setWindow != NULL) {\n"
    text = text + "        CGFloat scale = self.window.screen.scale;\n"
    text = text + "        CGSize size = self.bounds.size;\n"
    text = text + "        _setWindow(self.appId, 1ull, (int)(size.width * scale), (int)(size.height * scale), (float)scale);\n"
    text = text + "    }\n"
    text = text + "}\n\n"
    text = text + "- (void)step:(CADisplayLink*)displayLink {\n"
    text = text + "    if (_tick != NULL) {\n"
    text = text + "        _tick(self.appId, (float)displayLink.duration);\n"
    text = text + "    }\n"
    text = text + "}\n\n"
    text = text + "- (void)touchesBegan:(NSSet<UITouch*>*)touches withEvent:(UIEvent*)event {\n"
    text = text + "    event = event;\n"
    text = text + "    UITouch* touch = [touches anyObject];\n"
    text = text + "    CGPoint point = [touch locationInView:self];\n"
    text = text + "    if (_touch != NULL) {\n"
    text = text + "        _touch(self.appId, 0, 0, (float)point.x, (float)point.y);\n"
    text = text + "    }\n"
    text = text + "}\n\n"
    text = text + "- (void)touchesMoved:(NSSet<UITouch*>*)touches withEvent:(UIEvent*)event {\n"
    text = text + "    event = event;\n"
    text = text + "    UITouch* touch = [touches anyObject];\n"
    text = text + "    CGPoint point = [touch locationInView:self];\n"
    text = text + "    if (_touch != NULL) {\n"
    text = text + "        _touch(self.appId, 2, 0, (float)point.x, (float)point.y);\n"
    text = text + "    }\n"
    text = text + "}\n\n"
    text = text + "- (void)touchesEnded:(NSSet<UITouch*>*)touches withEvent:(UIEvent*)event {\n"
    text = text + "    event = event;\n"
    text = text + "    UITouch* touch = [touches anyObject];\n"
    text = text + "    CGPoint point = [touch locationInView:self];\n"
    text = text + "    if (_touch != NULL) {\n"
    text = text + "        _touch(self.appId, 1, 0, (float)point.x, (float)point.y);\n"
    text = text + "    }\n"
    text = text + "}\n\n"
    text = text + "- (void)didMoveToWindow {\n"
    text = text + "    [super didMoveToWindow];\n"
    text = text + "    if (self.window == nil) {\n"
    text = text + "        if (_pause != NULL) {\n"
    text = text + "            _pause(self.appId);\n"
    text = text + "        }\n"
    text = text + "    } else {\n"
    text = text + "        if (_resume != NULL) {\n"
    text = text + "            _resume(self.appId);\n"
    text = text + "        }\n"
    text = text + "    }\n"
    text = text + "}\n\n"
    text = text + "@end\n\n"
    text = text + "@implementation ChengGeneratedMetalViewController\n\n"
    text = text + "- (void)loadView {\n"
    text = text + "    self.view = [[ChengGeneratedMetalView alloc] initWithFrame:[UIScreen mainScreen].bounds];\n"
    text = text + "}\n\n"
    text = text + "@end\n"
    return text

