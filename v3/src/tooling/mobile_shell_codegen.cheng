fn v3MobileShellHelpText(): str =
    var text: str = "usage: cheng mobile-shell <subcommand> [args]\n"
    text = text + "subcommands: help, export, build-probe\n"
    text = text + "export flags: [--platform android|ios|harmony|all] [--out-dir <dir>] [--app-id <id>] [--app-name <name>] [--lib-name <name>] [--runtime-mode <id>] [--runtime-contract <file>] [--runtime-bundle <file>] [--route-state <id>]\n"
    text = text + "build-probe flags: [--platform android|ios|harmony|all] [--out-dir <dir>] [--app-id <id>] [--app-name <name>] [--lib-name <name>] [--runtime-mode <id>] [--runtime-contract <file>] [--runtime-bundle <file>] [--route-state <id>]\n"
    return text

fn v3MobileShellResolvePlatforms(platformText: str,
                                 out: var str[]): bool =
    out = []
    let raw: str = strutil.Strip(platformText)
    let normalized: str = if len(raw) > 0: raw else: "all"
    if normalized == "all":
        add(out, "android")
        add(out, "ios")
        add(out, "harmony")
        return true
    if normalized == "android":
        add(out, normalized)
        return true
    if normalized == "ios":
        add(out, normalized)
        return true
    if normalized == "harmony":
        add(out, normalized)
        return true
    return false

fn v3MobileShellWriteFile(fullPath: str,
                          text: str,
                          relPath: str,
                          files: var str[],
                          outError: var str): bool =
    var payload: str = text
    var needsNewline: bool = false
    if len(payload) <= 0:
        needsNewline = true
    elif payload[payload.len - 1] != '\n':
        needsNewline = true
    if needsNewline:
        payload = payload + "\n"
    if !v3path.V3WriteTextFile("", fullPath, payload):
        outError = "mobile-shell: write failed: " + fullPath
        return false
    add(files, relPath)
    return true

fn v3MobileShellWriteRelativeFile(rootDir: str,
                                  relPath: str,
                                  text: str,
                                  files: var str[],
                                  outError: var str): bool =
    var payload: str = text
    var needsNewline: bool = false
    if len(payload) <= 0:
        needsNewline = true
    elif payload[payload.len - 1] != '\n':
        needsNewline = true
    if needsNewline:
        payload = payload + "\n"
    if !v3path.V3WriteTextFile(rootDir, relPath, payload):
        outError = "mobile-shell: write failed: " + v3path.V3PathJoin(rootDir, relPath)
        return false
    add(files, relPath)
    return true

fn v3MobileShellReadme(opts: V3MobileShellOptions,
                       runtimeManifestRel: str,
                       runtimeContractPayloadRel: str,
                       runtimeBundlePayloadRel: str,
                       launchArgsKvRel: str,
                       launchArgsJsonRel: str): str =
    var text: str = "# Cheng Mobile Shell Export\n\n"
    text = text + "This bundle is emitted by `cheng mobile-shell export`.\n\n"
    text = text + "App contract:\n"
    text = text + "- The Cheng app binary exports `cheng_app_init`, `cheng_app_set_window`, `cheng_app_tick`, `cheng_app_on_touch`, `cheng_app_pause`, `cheng_app_resume`.\n"
    text = text + "- The generated native shell is responsible for platform lifecycle, window creation, and input forwarding.\n"
    text = text + "- The shell is generated by Cheng; platform source still targets Android NDK, UIKit/Metal, and Harmony XComponent APIs.\n\n"
    text = text + "app_id=" + opts.appId + "\n"
    text = text + "app_name=" + opts.appName + "\n"
    text = text + "lib_name=" + opts.libName + "\n"
    text = text + "runtime_mode=" + opts.runtimeMode + "\n"
    text = text + "runtime_manifest=" + runtimeManifestRel + "\n"
    text = text + "runtime_contract_payload=" + runtimeContractPayloadRel + "\n"
    text = text + "runtime_bundle_payload=" + runtimeBundlePayloadRel + "\n"
    text = text + "launch_args_kv=" + launchArgsKvRel + "\n"
    text = text + "launch_args_json=" + launchArgsJsonRel + "\n"
    text = text + "initial_route_state=" + opts.routeState + "\n"
    return text

fn v3MobileShellManifest(opts: V3MobileShellOptions,
                         runtimeManifestRel: str,
                         runtimeContractPayloadRel: str,
                         runtimeBundlePayloadRel: str,
                         launchArgsKvRel: str,
                         launchArgsJsonRel: str,
                         files: var str[]): str =
    var text: str = "{\n"
    text = text + "  \"format\": \"mobile_shell_manifest_v1\",\n"
    text = text + "  \"generator\": \"cheng.v3.mobile_shell_codegen\",\n"
    text = text + "  \"workspace_root\": " + v3MobileShellJsonQuote(opts.rootDir) + ",\n"
    text = text + "  \"out_dir\": " + v3MobileShellJsonQuote(opts.outDir) + ",\n"
    text = text + "  \"app_id\": " + v3MobileShellJsonQuote(opts.appId) + ",\n"
    text = text + "  \"app_name\": " + v3MobileShellJsonQuote(opts.appName) + ",\n"
    text = text + "  \"lib_name\": " + v3MobileShellJsonQuote(opts.libName) + ",\n"
    text = text + "  \"runtime_mode\": " + v3MobileShellJsonQuote(opts.runtimeMode) + ",\n"
    text = text + "  \"runtime_manifest\": " + v3MobileShellJsonQuote(runtimeManifestRel) + ",\n"
    text = text + "  \"runtime_contract_payload\": " + v3MobileShellJsonQuote(runtimeContractPayloadRel) + ",\n"
    text = text + "  \"runtime_bundle_payload\": " + v3MobileShellJsonQuote(runtimeBundlePayloadRel) + ",\n"
    text = text + "  \"launch_args_kv\": " + v3MobileShellJsonQuote(launchArgsKvRel) + ",\n"
    text = text + "  \"launch_args_json\": " + v3MobileShellJsonQuote(launchArgsJsonRel) + ",\n"
    text = text + "  \"initial_route_state\": " + v3MobileShellJsonQuote(opts.routeState) + ",\n"
    text = text + "  \"app_exports\": [\n"
    text = text + "    \"cheng_app_init\",\n"
    text = text + "    \"cheng_app_set_window\",\n"
    text = text + "    \"cheng_app_tick\",\n"
    text = text + "    \"cheng_app_on_touch\",\n"
    text = text + "    \"cheng_app_pause\",\n"
    text = text + "    \"cheng_app_resume\"\n"
    text = text + "  ],\n"
    text = text + "  \"platforms\": [\n"
    var emittedPlatformCount: int32 = 0
    if opts.emitAndroid:
        emittedPlatformCount = emittedPlatformCount + 1
    if opts.emitIos:
        emittedPlatformCount = emittedPlatformCount + 1
    if opts.emitHarmony:
        emittedPlatformCount = emittedPlatformCount + 1
    var emittedPlatformIndex: int32 = 0
    if opts.emitAndroid:
        emittedPlatformIndex = emittedPlatformIndex + 1
        text = text + "    " + v3MobileShellJsonQuote("android")
        if emittedPlatformIndex < emittedPlatformCount:
            text = text + ","
        text = text + "\n"
    if opts.emitIos:
        emittedPlatformIndex = emittedPlatformIndex + 1
        text = text + "    " + v3MobileShellJsonQuote("ios")
        if emittedPlatformIndex < emittedPlatformCount:
            text = text + ","
        text = text + "\n"
    if opts.emitHarmony:
        emittedPlatformIndex = emittedPlatformIndex + 1
        text = text + "    " + v3MobileShellJsonQuote("harmony")
        if emittedPlatformIndex < emittedPlatformCount:
            text = text + ","
        text = text + "\n"
    text = text + "  ],\n"
    text = text + "  \"generated_files\": [\n"
    for i in 0..<files.len:
        text = text + "    " + v3MobileShellJsonQuote(files[i])
        if i + 1 < files.len:
            text = text + ","
        text = text + "\n"
    text = text + "  ]\n"
    text = text + "}\n"
    return text

