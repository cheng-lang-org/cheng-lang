fn v3MobileShellLaunchArgsKvText(opts: V3MobileShellOptions,
                                 runtimeManifestRel: str,
                                 runtimeContractPayloadRel: str,
                                 runtimeBundlePayloadRel: str): str =
    var text: str = ""
    text = text + "gate_mode=android-semantic-visual-1to1\n"
    text = text + "truth_mode=strict\n"
    text = text + "route_state=" + opts.routeState + "\n"
    text = text + "route_lock=1\n"
    text = text + "runtime_mode=" + opts.runtimeMode + "\n"
    text = text + "runtime_manifest=" + runtimeManifestRel + "\n"
    text = text + "runtime_contract_payload=" + runtimeContractPayloadRel + "\n"
    text = text + "runtime_bundle_payload=" + runtimeBundlePayloadRel + "\n"
    return text

