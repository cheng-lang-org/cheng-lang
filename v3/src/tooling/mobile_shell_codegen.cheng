fn v3MobileShellWriteHarmony(opts: var V3MobileShellOptions,
                             files: var str[],
                             outError: var str): bool =
    let buildProfileRel: str = "harmony/build-profile.json5"
    let buildProfileFull: str = v3path.V3PathJoin(opts.outDir, buildProfileRel)
    let buildProfileText: str = v3MobileShellHarmonyBuildProfile()
    if !v3MobileShellWriteFile(buildProfileFull, buildProfileText, buildProfileRel, files, outError):
        return false
    let hvigorRel: str = "harmony/hvigorfile.ts"
    let hvigorFull: str = v3path.V3PathJoin(opts.outDir, hvigorRel)
    let hvigorText: str = v3MobileShellHarmonyHvigorFile()
    if !v3MobileShellWriteFile(hvigorFull, hvigorText, hvigorRel, files, outError):
        return false
    let hvigorConfigRel: str = "harmony/hvigor/hvigor-config.json5"
    let hvigorConfigFull: str = v3path.V3PathJoin(opts.outDir, hvigorConfigRel)
    let hvigorConfigText: str = v3MobileShellHarmonyHvigorConfig()
    if !v3MobileShellWriteFile(hvigorConfigFull, hvigorConfigText, hvigorConfigRel, files, outError):
        return false
    let rootPackageRel: str = "harmony/oh-package.json5"
    let rootPackageFull: str = v3path.V3PathJoin(opts.outDir, rootPackageRel)
    let rootPackageText: str = v3MobileShellHarmonyRootPackageJson()
    if !v3MobileShellWriteFile(rootPackageFull, rootPackageText, rootPackageRel, files, outError):
        return false
    let entryPackageRel: str = "harmony/entry/oh-package.json5"
    let entryPackageFull: str = v3path.V3PathJoin(opts.outDir, entryPackageRel)
    let entryPackageText: str = v3MobileShellHarmonyEntryPackageJson()
    if !v3MobileShellWriteFile(entryPackageFull, entryPackageText, entryPackageRel, files, outError):
        return false
    let entryHvigorRel: str = "harmony/entry/hvigorfile.ts"
    let entryHvigorFull: str = v3path.V3PathJoin(opts.outDir, entryHvigorRel)
    let entryHvigorText: str = v3MobileShellHarmonyEntryHvigorFile()
    if !v3MobileShellWriteFile(entryHvigorFull, entryHvigorText, entryHvigorRel, files, outError):
        return false
    let entryBuildProfileRel: str = "harmony/entry/build-profile.json5"
    let entryBuildProfileFull: str = v3path.V3PathJoin(opts.outDir, entryBuildProfileRel)
    let entryBuildProfileText: str = v3MobileShellHarmonyEntryBuildProfile()
    if !v3MobileShellWriteFile(entryBuildProfileFull, entryBuildProfileText, entryBuildProfileRel, files, outError):
        return false
    let appScopeRel: str = "harmony/AppScope/app.json5"
    let appScopeFull: str = v3path.V3PathJoin(opts.outDir, appScopeRel)
    let appScopeText: str = v3MobileShellHarmonyAppJson(opts)
    if !v3MobileShellWriteFile(appScopeFull, appScopeText, appScopeRel, files, outError):
        return false
    let moduleRel: str = "harmony/entry/src/main/module.json5"
    let moduleFull: str = v3path.V3PathJoin(opts.outDir, moduleRel)
    let moduleText: str = v3MobileShellHarmonyModuleJson(opts)
    if !v3MobileShellWriteFile(moduleFull, moduleText, moduleRel, files, outError):
        return false
    let stringRel: str = "harmony/entry/src/main/resources/base/element/string.json"
    let stringFull: str = v3path.V3PathJoin(opts.outDir, stringRel)
    let stringText: str = v3MobileShellHarmonyStringJson(opts)
    if !v3MobileShellWriteFile(stringFull, stringText, stringRel, files, outError):
        return false
    let colorRel: str = "harmony/entry/src/main/resources/base/element/color.json"
    let colorFull: str = v3path.V3PathJoin(opts.outDir, colorRel)
    let colorText: str = v3MobileShellHarmonyColorJson()
    if !v3MobileShellWriteFile(colorFull, colorText, colorRel, files, outError):
        return false
    let appIconRel: str = "harmony/entry/src/main/resources/base/media/app_icon.svg"
    let appIconFull: str = v3path.V3PathJoin(opts.outDir, appIconRel)
    let appIconText: str = v3MobileShellHarmonyAppIconSvg()
    if !v3MobileShellWriteFile(appIconFull, appIconText, appIconRel, files, outError):
        return false
    let indexRel: str = "harmony/entry/src/main/ets/pages/Index.ets"
    let indexFull: str = v3path.V3PathJoin(opts.outDir, indexRel)
    let indexText: str = v3MobileShellHarmonyIndexEts(opts)
    if !v3MobileShellWriteFile(indexFull, indexText, indexRel, files, outError):
        return false
    let entryAbilityRel: str = "harmony/entry/src/main/ets/entryability/EntryAbility.ets"
    let entryAbilityFull: str = v3path.V3PathJoin(opts.outDir, entryAbilityRel)
    let entryAbilityText: str = v3MobileShellHarmonyEntryAbilityEts()
    if !v3MobileShellWriteFile(entryAbilityFull, entryAbilityText, entryAbilityRel, files, outError):
        return false
    let mainPagesRel: str = "harmony/entry/src/main/resources/base/profile/main_pages.json"
    let mainPagesFull: str = v3path.V3PathJoin(opts.outDir, mainPagesRel)
    let mainPagesText: str = v3MobileShellHarmonyMainPagesJson()
    if !v3MobileShellWriteFile(mainPagesFull, mainPagesText, mainPagesRel, files, outError):
        return false
    let cmakeRel: str = "harmony/entry/src/main/cpp/CMakeLists.txt"
    let cmakeFull: str = v3path.V3PathJoin(opts.outDir, cmakeRel)
    let cmakeText: str = v3MobileShellHarmonyCmake()
    if !v3MobileShellWriteFile(cmakeFull, cmakeText, cmakeRel, files, outError):
        return false
    let hostRel: str = "harmony/entry/src/main/cpp/cheng_generated_harmony_host.cpp"
    let hostFull: str = v3path.V3PathJoin(opts.outDir, hostRel)
    let hostText: str = v3MobileShellHarmonyHostSource(opts)
    return v3MobileShellWriteFile(hostFull, hostText, hostRel, files, outError)

fn v3MobileShellResolveOptions(rootDir: str,
                               args: str[],
                               outOpts: var V3MobileShellOptions,
                               outPlatforms: var str[],
                               outError: var str): bool =
    outOpts = v3MobileShellDefaultOptions(rootDir)
    outPlatforms = []
    outError = ""
    let outRaw: str = strutil.Strip(creq.v3CompilerReadFlagOrDefault(args, "--out-dir", outOpts.outDir))
    if len(outRaw) > 0:
        outOpts.outDir = v3path.V3PathAbsolute(rootDir, outRaw)
    let appIdRaw: str = strutil.Strip(creq.v3CompilerReadFlagOrDefault(args, "--app-id", outOpts.appId))
    if len(appIdRaw) > 0:
        outOpts.appId = appIdRaw
    let appNameRaw: str = strutil.Strip(creq.v3CompilerReadFlagOrDefault(args, "--app-name", outOpts.appName))
    if len(appNameRaw) > 0:
        outOpts.appName = appNameRaw
    let libNameRaw: str = strutil.Strip(creq.v3CompilerReadFlagOrDefault(args, "--lib-name", outOpts.libName))
    if len(libNameRaw) > 0:
        outOpts.libName = libNameRaw
    let runtimeModeRaw: str = strutil.Strip(creq.v3CompilerReadFlagOrDefault(args, "--runtime-mode", outOpts.runtimeMode))
    if len(runtimeModeRaw) > 0:
        outOpts.runtimeMode = runtimeModeRaw
    let runtimeContractRaw: str = strutil.Strip(creq.v3CompilerReadFlagOrDefault(args, "--runtime-contract", ""))
    if len(runtimeContractRaw) > 0:
        outOpts.runtimeContractPath = v3path.V3PathAbsolute(rootDir, runtimeContractRaw)
    let runtimeBundleRaw: str = strutil.Strip(creq.v3CompilerReadFlagOrDefault(args, "--runtime-bundle", ""))
    if len(runtimeBundleRaw) > 0:
        outOpts.runtimeBundlePath = v3path.V3PathAbsolute(rootDir, runtimeBundleRaw)
    let routeStateRaw: str = strutil.Strip(creq.v3CompilerReadFlagOrDefault(args, "--route-state", ""))
    if len(routeStateRaw) > 0:
        outOpts.routeState = routeStateRaw
    var platforms: str[] = []
    let platformText: str = creq.v3CompilerReadFlagOrDefault(args, "--platform", "all")
    if !v3MobileShellResolvePlatforms(platformText, platforms):
        outError = "mobile-shell: unsupported platform: " + platformText
        return false
    outOpts.emitAndroid = false
    outOpts.emitIos = false
    outOpts.emitHarmony = false
    for i in 0..<platforms.len:
        if platforms[i] == "android":
            outOpts.emitAndroid = true
        elif platforms[i] == "ios":
            outOpts.emitIos = true
        elif platforms[i] == "harmony":
            outOpts.emitHarmony = true
    outPlatforms = platforms
    return true

fn v3MobileShellExportResolved(opts: var V3MobileShellOptions,
                               outManifestPath: var str,
                               outError: var str): bool =
    outManifestPath = ""
    outError = ""
    if !v3path.V3MkdirP("", opts.outDir):
        outError = "mobile-shell: failed to create out dir: " + opts.outDir
        return false
    var files: str[] = []
    var runtimeContractPayloadRel: str = ""
    var runtimeBundlePayloadRel: str = ""
    var launchArgsKvRel: str = ""
    var launchArgsJsonRel: str = ""
    let runtimeManifestRel: str = v3MobileShellRuntimeManifestRelPath()
    if !v3MobileShellWriteRuntimePayloadFile(opts,
                                             opts.runtimeContractPath,
                                             "runtime_contract_payload.json",
                                             files,
                                             runtimeContractPayloadRel,
                                             outError):
        return false
    if !v3MobileShellWriteRuntimePayloadFile(opts,
                                             opts.runtimeBundlePath,
                                             "runtime_bundle_payload.json",
                                             files,
                                             runtimeBundlePayloadRel,
                                             outError):
        return false
    let readmePath = v3path.V3PathJoin(opts.outDir, "README.md")
    if !v3MobileShellWriteLaunchArgsFiles(opts,
                                          runtimeManifestRel,
                                          runtimeContractPayloadRel,
                                          runtimeBundlePayloadRel,
                                          files,
                                          launchArgsKvRel,
                                          launchArgsJsonRel,
                                          outError):
        return false
    if !v3MobileShellWriteFile(readmePath,
                               v3MobileShellReadme(opts,
                                                   runtimeManifestRel,
                                                   runtimeContractPayloadRel,
                                                   runtimeBundlePayloadRel,
                                                   launchArgsKvRel,
                                                   launchArgsJsonRel),
                               "README.md",
                               files,
                               outError):
        return false
    let runtimeManifestPath: str = v3path.V3PathJoin(opts.outDir, runtimeManifestRel)
    if !v3MobileShellWriteFile(runtimeManifestPath,
                               v3MobileShellRuntimeManifest(opts,
                                                            runtimeContractPayloadRel,
                                                            runtimeBundlePayloadRel,
                                                            launchArgsKvRel,
                                                            launchArgsJsonRel),
                               runtimeManifestRel,
                               files,
                               outError):
        return false
    if !v3MobileShellWritePlatformRuntimeMirrors(opts,
                                                 runtimeManifestPath,
                                                 runtimeContractPayloadRel,
                                                 runtimeBundlePayloadRel,
                                                 launchArgsKvRel,
                                                 launchArgsJsonRel,
                                                 files,
                                                 outError):
        return false
    if opts.emitAndroid:
        if !v3MobileShellWriteAndroid(opts, files, outError):
            return false
    if opts.emitIos:
        if !v3MobileShellWriteIos(opts, files, outError):
            return false
    if opts.emitHarmony:
        if !v3MobileShellWriteHarmony(opts, files, outError):
            return false
    let manifestRel = "mobile_shell_manifest_v1.json"
    let manifestPath = v3path.V3PathJoin(opts.outDir, manifestRel)
    if !v3MobileShellWriteFile(manifestPath,
                               v3MobileShellManifest(opts,
                                                     runtimeManifestRel,
                                                     runtimeContractPayloadRel,
                                                     runtimeBundlePayloadRel,
                                                     launchArgsKvRel,
                                                     launchArgsJsonRel,
                                                     files),
                               manifestRel,
                               files,
                               outError):
        return false
    outManifestPath = manifestPath
    return true

fn v3MobileShellExport(rootDir: str,
                       args: str[],
                       outOutput: var str,
                       outError: var str): int32 =
    outOutput = ""
    outError = ""
    var opts: V3MobileShellOptions
    var platforms: str[] = []
    if !v3MobileShellResolveOptions(rootDir, args, opts, platforms, outError):
        return 1
    var manifestPath: str = ""
    if !v3MobileShellExportResolved(opts, manifestPath, outError):
        return 1
    outOutput = "mobile-shell export ok\n"
    return 0

fn v3MobileShellBoolEnv(value: bool): str =
    if value:
        return "1"
    return "0"

fn v3MobileShellQuoteShell(value: str): str =
    return os.QuoteShell(value)

fn v3MobileShellBuildCommand(program: str,
                             args: str[]): str =
    var text: str = v3MobileShellQuoteShell(program)
    for i in 0..<args.len:
        text = text + " "
        text = text + v3MobileShellQuoteShell(args[i])
    return text

fn v3MobileShellRunCommandLogged(command: str,
                                 workingDir: str,
                                 logPath: str): os.ExecCmdResult =
    let res: os.ExecCmdResult = os.ExecCmdEx(command, uint64(1), workingDir)
    let output: str = os.ExecCmdResultOutput(res)
    let _logged: bool = v3path.V3WriteTextFile("", logPath, output)
    return res

fn v3MobileShellWriteBuildProbeSummary(summaryPath: str,
                                       androidSelected: bool,
                                       iosSelected: bool,
                                       harmonySelected: bool): bool =
    let parent: str = v3path.V3PathParentDir(summaryPath)
    if !v3path.V3MkdirP("", parent):
        return false
    let f: os.File = os.openImplWrite(summaryPath)
    if f == nil:
        return false
    os.Write(f, "format=mobile_shell_build_probe_summary_v1\n")
    if androidSelected:
        os.Write(f, "android_exit_code=0\n")
        os.Write(f, "android_apk_exists=1\n")
    else:
        os.Write(f, "android_exit_code=-1\n")
        os.Write(f, "android_apk_exists=0\n")
    if iosSelected:
        os.Write(f, "ios_exit_code=0\n")
        os.Write(f, "ios_app_exists=1\n")
    else:
        os.Write(f, "ios_exit_code=-1\n")
        os.Write(f, "ios_app_exists=0\n")
    if harmonySelected:
        os.Write(f, "harmony_exit_code=0\n")
        os.Write(f, "harmony_app_exists=1\n")
        os.Write(f, "harmony_hap_exists=1\n")
    else:
        os.Write(f, "harmony_exit_code=-1\n")
        os.Write(f, "harmony_app_exists=0\n")
        os.Write(f, "harmony_hap_exists=0\n")
    os.Close(f)
    return v3path.V3PathFileExists(summaryPath)

fn v3MobileShellBuildProbeFail(summaryPath: str,
                               message: str,
                               outError: var str): int32 =
    let _summaryPath = summaryPath
    outError = message
    return 1

fn v3MobileShellBuildProbe(rootDir: str,
                           args: str[],
                           outOutput: var str,
                           outError: var str): int32 =
    outOutput = ""
    outError = ""
    var opts: V3MobileShellOptions
    var platforms: str[] = []
    if !v3MobileShellResolveOptions(rootDir, args, opts, platforms, outError):
        return 1
    var manifestPath: str = ""
    if !v3MobileShellExportResolved(opts, manifestPath, outError):
        return 1
    let runtimeManifestPath: str = v3path.V3PathJoin(opts.outDir, v3MobileShellRuntimeManifestRelPath())
    let runtimeContractPayloadRel: str = v3MobileShellRuntimeContractPayloadRelPath()
    let runtimeBundlePayloadRel: str = v3MobileShellRuntimeBundlePayloadRelPath()
    let summaryPath: str = v3path.V3PathJoin(opts.outDir, "mobile_shell_build_probe.summary.env")
    let androidLog: str = v3path.V3PathJoin(opts.outDir, "android_build.log")
    let iosLog: str = v3path.V3PathJoin(opts.outDir, "ios_build.log")
    let harmonyLog: str = v3path.V3PathJoin(opts.outDir, "harmony_build.log")
    let androidApk: str = v3path.V3PathJoin(opts.outDir, "android/app/build/outputs/apk/debug/app-debug.apk")
    let iosApp: str = v3path.V3PathJoin(opts.outDir, "ios/.derived_data/Build/Products/Debug-iphonesimulator/ChengGeneratedApp.app/ChengGeneratedApp")
    let harmonyApp: str = v3path.V3PathJoin(opts.outDir, "harmony/build/outputs/default/harmony-default-unsigned.app")
    let harmonyHap: str = v3path.V3PathJoin(opts.outDir, "harmony/entry/build/default/outputs/default/app/entry-default.hap")
    let harmonyHvigorPath: str = "/Applications/DevEco-Studio.app/Contents/tools/hvigor/bin/hvigorw.js"
    var androidSelected: bool = false
    var iosSelected: bool = false
    var harmonySelected: bool = false
    var androidExitCode: int32 = -1
    var iosExitCode: int32 = -1
    var harmonyExitCode: int32 = -1
    for i in 0..<platforms.len:
        let platform: str = platforms[i]
        if platform == "android":
            androidSelected = true
            let command: str = v3MobileShellBuildCommand("gradle",
                                                         [
                                                             "-p",
                                                             v3path.V3PathJoin(opts.outDir, "android"),
                                                             ":app:assembleDebug"
                                                         ])
            let run: os.ExecCmdResult = v3MobileShellRunCommandLogged(command, rootDir, androidLog)
            androidExitCode = os.ExecCmdResultExitCode(run)
            if androidExitCode != 0:
                return v3MobileShellBuildProbeFail(summaryPath,
                                                   "mobile-shell: android build failed rc=" + intToStr(androidExitCode) + " log=" + androidLog,
                                                   outError)
            if !os.FileExists(androidApk):
                return v3MobileShellBuildProbeFail(summaryPath,
                                                   "mobile-shell: android artifact missing: " + androidApk,
                                                   outError)
        elif platform == "ios":
            iosSelected = true
            let command: str = v3MobileShellBuildCommand("xcodebuild",
                                                         [
                                                             "-project",
                                                             v3path.V3PathJoin(opts.outDir, "ios/ChengGeneratedApp.xcodeproj"),
                                                             "-scheme",
                                                             "ChengGeneratedApp",
                                                             "-configuration",
                                                             "Debug",
                                                             "-sdk",
                                                             "iphonesimulator",
                                                             "-derivedDataPath",
                                                             v3path.V3PathJoin(opts.outDir, "ios/.derived_data"),
                                                             "CODE_SIGNING_ALLOWED=NO",
                                                             "build"
                                                         ])
            let run: os.ExecCmdResult = v3MobileShellRunCommandLogged(command, rootDir, iosLog)
            iosExitCode = os.ExecCmdResultExitCode(run)
            if iosExitCode != 0:
                return v3MobileShellBuildProbeFail(summaryPath,
                                                   "mobile-shell: ios build failed rc=" + intToStr(iosExitCode) + " log=" + iosLog,
                                                   outError)
            if !os.FileExists(iosApp):
                return v3MobileShellBuildProbeFail(summaryPath,
                                                   "mobile-shell: ios artifact missing: " + iosApp,
                                                   outError)
        elif platform == "harmony":
            harmonySelected = true
            let command: str = v3MobileShellBuildCommand("node",
                                                         [
                                                             harmonyHvigorPath,
                                                             "assembleApp",
                                                             "-p",
                                                             "product=default",
                                                             "-p",
                                                             "buildMode=debug",
                                                             "--no-daemon"
                                                         ])
            let run: os.ExecCmdResult = v3MobileShellRunCommandLogged(command,
                                                                      v3path.V3PathJoin(opts.outDir, "harmony"),
                                                                      harmonyLog)
            harmonyExitCode = os.ExecCmdResultExitCode(run)
            if harmonyExitCode != 0:
                return v3MobileShellBuildProbeFail(summaryPath,
                                                   "mobile-shell: harmony build failed rc=" + intToStr(harmonyExitCode) + " log=" + harmonyLog,
                                                   outError)
            if !os.FileExists(harmonyApp):
                return v3MobileShellBuildProbeFail(summaryPath,
                                                   "mobile-shell: harmony app artifact missing: " + harmonyApp,
                                                   outError)
            if !os.FileExists(harmonyHap):
                return v3MobileShellBuildProbeFail(summaryPath,
                                                   "mobile-shell: harmony hap artifact missing: " + harmonyHap,
                                                   outError)
    if !v3MobileShellWriteBuildProbeSummary(summaryPath,
                                            androidSelected,
                                            iosSelected,
                                            harmonySelected):
        outError = "mobile-shell: failed to write summary: " + summaryPath
        return 1
    outOutput = "mobile-shell build-probe ok\n"
    return 0

fn v3MobileShellRun(rootDir: str,
                    args: str[],
                    outOutput: var str,
                    outError: var str): int32 =
    outOutput = ""
    outError = ""
    if args.len <= 0:
        outOutput = v3MobileShellHelpText()
        return 0
    let subcmd: str = strutil.Strip(args[0])
    if subcmd == "help":
        outOutput = v3MobileShellHelpText()
        return 0
    if subcmd == "--help":
        outOutput = v3MobileShellHelpText()
        return 0
    if subcmd == "-h":
        outOutput = v3MobileShellHelpText()
        return 0
    var tail: str[] = []
    for i in 1..<args.len:
        add(tail, args[i])
    if subcmd == "export":
        return v3MobileShellExport(rootDir, tail, outOutput, outError)
    if subcmd == "build-probe":
        return v3MobileShellBuildProbe(rootDir, tail, outOutput, outError)
    outOutput = v3MobileShellHelpText()
    outError = "mobile-shell: unknown subcommand: " + subcmd
    return 2
