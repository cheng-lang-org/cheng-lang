    return text

fn v3MobileShellHarmonyHostSource(opts: var V3MobileShellOptions): str =
    let runtimeManifestRel: str = "rawfile/mobile_shell_runtime_contract_v1.json"
    let launchArgsKvRel: str = "rawfile/mobile_shell_launch_args.kv"
    let launchArgsJsonRel: str = "rawfile/mobile_shell_launch_args.json"
    var text: str = "#include <ace/xcomponent/native_interface_xcomponent.h>\n"
    text = text + "#include <hilog/log.h>\n"
    text = text + "#include <native_window/external_window.h>\n"
    text = text + "#include <dlfcn.h>\n"
    text = text + "#include <stdint.h>\n"
    text = text + "#include <stdlib.h>\n\n"
    text = text + "typedef uint64_t (*cheng_app_init_fn)(void);\n"
    text = text + "typedef void (*cheng_app_set_window_fn)(uint64_t, uint64_t, int, int, float);\n"
    text = text + "typedef void (*cheng_app_tick_fn)(uint64_t, float);\n"
    text = text + "typedef void (*cheng_app_on_touch_fn)(uint64_t, int, int, float, float);\n"
    text = text + "typedef void (*cheng_app_pause_fn)(uint64_t);\n"
    text = text + "typedef void (*cheng_app_resume_fn)(uint64_t);\n\n"
    text = text + "typedef struct ChengHarmonyRuntime {\n"
    text = text + "  uint64_t app_id;\n"
    text = text + "  OHNativeWindow* window;\n"
    text = text + "  int width;\n"
    text = text + "  int height;\n"
    text = text + "} ChengHarmonyRuntime;\n\n"
    text = text + "static ChengHarmonyRuntime s_runtime = {0};\n"
    text = text + "static cheng_app_set_window_fn s_set_window = NULL;\n"
    text = text + "static cheng_app_tick_fn s_tick = NULL;\n"
    text = text + "static cheng_app_on_touch_fn s_touch = NULL;\n"
    text = text + "static cheng_app_pause_fn s_pause = NULL;\n"
    text = text + "static cheng_app_resume_fn s_resume = NULL;\n\n"
    text = text + "static const char* kChengRuntimeManifest = \"" + runtimeManifestRel + "\";\n"
    text = text + "static const char* kChengLaunchArgsKvRel = \"" + launchArgsKvRel + "\";\n"
    text = text + "static const char* kChengLaunchArgsJsonRel = \"" + launchArgsJsonRel + "\";\n"
    text = text + "\n"
    text = text + "static int cheng_harmony_init_runtime(void) {\n"
    text = text + "  if (s_runtime.app_id != 0u) {\n"
    text = text + "    return 1;\n"
    text = text + "  }\n"
    text = text + "  void* handle = dlopen(NULL, RTLD_NOW);\n"
    text = text + "  cheng_app_init_fn initFn = (cheng_app_init_fn)dlsym(handle, \"cheng_app_init\");\n"
    text = text + "  s_set_window = (cheng_app_set_window_fn)dlsym(handle, \"cheng_app_set_window\");\n"
    text = text + "  s_tick = (cheng_app_tick_fn)dlsym(handle, \"cheng_app_tick\");\n"
    text = text + "  s_touch = (cheng_app_on_touch_fn)dlsym(handle, \"cheng_app_on_touch\");\n"
    text = text + "  s_pause = (cheng_app_pause_fn)dlsym(handle, \"cheng_app_pause\");\n"
    text = text + "  s_resume = (cheng_app_resume_fn)dlsym(handle, \"cheng_app_resume\");\n"
    text = text + "  if (initFn == NULL || s_set_window == NULL || s_tick == NULL || s_touch == NULL || s_pause == NULL || s_resume == NULL) {\n"
    text = text + "    return 0;\n"
    text = text + "  }\n"
    text = text + "  s_runtime.app_id = initFn();\n"
    text = text + "  return 1;\n"
    text = text + "}\n\n"
    text = text + "static void OnSurfaceCreated(OH_NativeXComponent* component, void* window) {\n"
    text = text + "  component = component;\n"
    text = text + "  if (!cheng_harmony_init_runtime()) {\n"
    text = text + "    return;\n"
    text = text + "  }\n"
    text = text + "  s_runtime.window = (OHNativeWindow*)window;\n"
    text = text + "  s_runtime.width = 1080;\n"
    text = text + "  s_runtime.height = 1920;\n"
    text = text + "  s_set_window(s_runtime.app_id, 1u, s_runtime.width, s_runtime.height, 1.0f);\n"
    text = text + "}\n\n"
    text = text + "static void OnSurfaceDestroyed(OH_NativeXComponent* component, void* window) {\n"
    text = text + "  component = component;\n"
    text = text + "  window = window;\n"
    text = text + "  if (s_runtime.app_id != 0u && s_pause != NULL) {\n"
    text = text + "    s_pause(s_runtime.app_id);\n"
    text = text + "  }\n"
    text = text + "}\n\n"
    text = text + "static void OnDispatchTouchEvent(OH_NativeXComponent* component, void* window) {\n"
    text = text + "  component = component;\n"
    text = text + "  window = window;\n"
    text = text + "  if (s_runtime.app_id != 0u && s_touch != NULL) {\n"
    text = text + "    s_touch(s_runtime.app_id, 0, 0, 0.0f, 0.0f);\n"
    text = text + "  }\n"
    text = text + "}\n\n"
    text = text + "static OH_NativeXComponent_Callback s_callback = {\n"
    text = text + "  .OnSurfaceCreated = OnSurfaceCreated,\n"
    text = text + "  .OnSurfaceChanged = NULL,\n"
    text = text + "  .OnSurfaceDestroyed = OnSurfaceDestroyed,\n"
    text = text + "  .DispatchTouchEvent = OnDispatchTouchEvent,\n"
    text = text + "};\n\n"
    text = text + "extern \"C\" __attribute__((visibility(\"default\"))) void OH_NativeXComponent_OnLoad(OH_NativeXComponent* component, void* reserved) {\n"
    text = text + "  reserved = reserved;\n"
    text = text + "  OH_NativeXComponent_RegisterCallback(component, &s_callback);\n"
    text = text + "}\n"
    return text

fn v3MobileShellWriteRuntimePayloadFile(opts: V3MobileShellOptions,
                                        sourcePath: str,
                                        fallbackBaseName: str,
                                        files: var str[],
                                        outRelPath: var str,
                                        outError: var str): bool =
    outRelPath = ""
    let sourceAbs: str = v3path.V3PathAbsolute(opts.rootDir, sourcePath)
    if len(sourceAbs) <= 0:
        return true
    if !v3path.V3PathFileExists(sourceAbs):
        outError = "mobile-shell: runtime payload missing: " + sourceAbs
        return false
    var relPath: str = v3MobileShellRuntimeBundlePayloadRelPath()
    if fallbackBaseName == "runtime_contract_payload.json":
        relPath = v3MobileShellRuntimeContractPayloadRelPath()
    let targetPath: str = v3path.V3PathJoin(opts.outDir, relPath)
    let payloadText: str = v3path.V3ReadTextFile("", sourceAbs)
    if !v3MobileShellWriteFile(targetPath, payloadText, relPath, files, outError):
        return false
    outRelPath = relPath
    return true

fn v3MobileShellMirrorRuntimeFile(opts: V3MobileShellOptions,
                                  sourceFull: str,
                                  targetRel: str,
                                  files: var str[],
                                  outError: var str): bool =
    if !v3path.V3PathFileExists(sourceFull):
        outError = "mobile-shell: runtime mirror source missing: " + sourceFull
        return false
    let payloadText: str = v3path.V3ReadTextFile("", sourceFull)
    let targetFull: str = v3path.V3PathJoin(opts.outDir, targetRel)
    return v3MobileShellWriteFile(targetFull, payloadText, targetRel, files, outError)

fn v3MobileShellWriteRuntimeStubFile(opts: V3MobileShellOptions,
                                     targetRel: str,
                                     files: var str[],
                                     outError: var str): bool =
    let targetFull: str = v3path.V3PathJoin(opts.outDir, targetRel)
    return v3MobileShellWriteFile(targetFull, "{\n}\n", targetRel, files, outError)

fn v3MobileShellWriteLaunchArgsFiles(opts: V3MobileShellOptions,
                                     runtimeManifestRel: str,
                                     runtimeContractPayloadRel: str,
                                     runtimeBundlePayloadRel: str,
                                     files: var str[],
                                     outLaunchArgsKvRel: var str,
                                     outLaunchArgsJsonRel: var str,
                                     outError: var str): bool =
    outLaunchArgsKvRel = v3MobileShellLaunchArgsKvRelPath()
    outLaunchArgsJsonRel = v3MobileShellLaunchArgsJsonRelPath()
    let kvPath: str = v3path.V3PathJoin(opts.outDir, outLaunchArgsKvRel)
    let jsonPath: str = v3path.V3PathJoin(opts.outDir, outLaunchArgsJsonRel)
    if !v3MobileShellWriteFile(kvPath,
                               v3MobileShellLaunchArgsKvText(opts,
                                                             runtimeManifestRel,
                                                             runtimeContractPayloadRel,
                                                             runtimeBundlePayloadRel),
                               outLaunchArgsKvRel,
                               files,
                               outError):
        return false
    if !v3MobileShellWriteFile(jsonPath,
                               v3MobileShellLaunchArgsJsonText(opts,
                                                               runtimeManifestRel,
                                                               runtimeContractPayloadRel,
                                                               runtimeBundlePayloadRel),
                               outLaunchArgsJsonRel,
                               files,
                               outError):
        return false
    return true

fn v3MobileShellWritePlatformRuntimeMirrors(opts: V3MobileShellOptions,
                                            runtimeManifestPath: str,
                                            runtimeContractPayloadRel: str,
                                            runtimeBundlePayloadRel: str,
                                            launchArgsKvRel: str,
                                            launchArgsJsonRel: str,
                                            files: var str[],
                                            outError: var str): bool =
    if opts.emitAndroid:
        if !v3MobileShellMirrorRuntimeFile(opts,
                                           runtimeManifestPath,
                                           v3MobileShellAndroidRuntimeManifestRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeContractPayloadRel) > 0:
            if !v3MobileShellMirrorRuntimeFile(opts,
                                               v3path.V3PathJoin(opts.outDir, runtimeContractPayloadRel),
                                               v3MobileShellAndroidRuntimeContractPayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !v3MobileShellWriteRuntimeStubFile(opts,
                                                  v3MobileShellAndroidRuntimeContractPayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if len(runtimeBundlePayloadRel) > 0:
            if !v3MobileShellMirrorRuntimeFile(opts,
                                               v3path.V3PathJoin(opts.outDir, runtimeBundlePayloadRel),
                                               v3MobileShellAndroidRuntimeBundlePayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !v3MobileShellWriteRuntimeStubFile(opts,
                                                  v3MobileShellAndroidRuntimeBundlePayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if !v3MobileShellMirrorRuntimeFile(opts,
                                           v3path.V3PathJoin(opts.outDir, launchArgsKvRel),
                                           v3MobileShellAndroidLaunchArgsKvRelPath(),
                                           files,
                                           outError):
            return false
        if !v3MobileShellMirrorRuntimeFile(opts,
                                           v3path.V3PathJoin(opts.outDir, launchArgsJsonRel),
                                           v3MobileShellAndroidLaunchArgsJsonRelPath(),
                                           files,
                                           outError):
            return false
    if opts.emitIos:
        if !v3MobileShellMirrorRuntimeFile(opts,
                                           runtimeManifestPath,
                                           v3MobileShellIosRuntimeManifestRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeContractPayloadRel) > 0:
            if !v3MobileShellMirrorRuntimeFile(opts,
                                               v3path.V3PathJoin(opts.outDir, runtimeContractPayloadRel),
                                               v3MobileShellIosRuntimeContractPayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !v3MobileShellWriteRuntimeStubFile(opts,
                                                  v3MobileShellIosRuntimeContractPayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if len(runtimeBundlePayloadRel) > 0:
            if !v3MobileShellMirrorRuntimeFile(opts,
                                               v3path.V3PathJoin(opts.outDir, runtimeBundlePayloadRel),
                                               v3MobileShellIosRuntimeBundlePayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !v3MobileShellWriteRuntimeStubFile(opts,
                                                  v3MobileShellIosRuntimeBundlePayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if !v3MobileShellMirrorRuntimeFile(opts,
                                           v3path.V3PathJoin(opts.outDir, launchArgsKvRel),
                                           v3MobileShellIosLaunchArgsKvRelPath(),
                                           files,
                                           outError):
            return false
        if !v3MobileShellMirrorRuntimeFile(opts,
                                           v3path.V3PathJoin(opts.outDir, launchArgsJsonRel),
                                           v3MobileShellIosLaunchArgsJsonRelPath(),
                                           files,
                                           outError):
            return false
    if opts.emitHarmony:
        if !v3MobileShellMirrorRuntimeFile(opts,
                                           runtimeManifestPath,
                                           v3MobileShellHarmonyRuntimeManifestRelPath(),
                                           files,
                                           outError):
            return false
        if len(runtimeContractPayloadRel) > 0:
            if !v3MobileShellMirrorRuntimeFile(opts,
                                               v3path.V3PathJoin(opts.outDir, runtimeContractPayloadRel),
                                               v3MobileShellHarmonyRuntimeContractPayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !v3MobileShellWriteRuntimeStubFile(opts,
                                                  v3MobileShellHarmonyRuntimeContractPayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if len(runtimeBundlePayloadRel) > 0:
            if !v3MobileShellMirrorRuntimeFile(opts,
                                               v3path.V3PathJoin(opts.outDir, runtimeBundlePayloadRel),
                                               v3MobileShellHarmonyRuntimeBundlePayloadRelPath(),
                                               files,
                                               outError):
                return false
        else:
            if !v3MobileShellWriteRuntimeStubFile(opts,
                                                  v3MobileShellHarmonyRuntimeBundlePayloadRelPath(),
                                                  files,
                                                  outError):
                return false
        if !v3MobileShellMirrorRuntimeFile(opts,
                                           v3path.V3PathJoin(opts.outDir, launchArgsKvRel),
                                           v3MobileShellHarmonyLaunchArgsKvRelPath(),
                                           files,
                                           outError):
            return false
        if !v3MobileShellMirrorRuntimeFile(opts,
                                           v3path.V3PathJoin(opts.outDir, launchArgsJsonRel),
                                           v3MobileShellHarmonyLaunchArgsJsonRelPath(),
                                           files,
                                           outError):
            return false
    return true

