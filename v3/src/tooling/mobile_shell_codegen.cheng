    text = text + "  \"runtime_contract_payload\": " + v3MobileShellJsonQuote(runtimeContractPayloadRel) + ",\n"
    text = text + "  \"runtime_bundle_payload\": " + v3MobileShellJsonQuote(runtimeBundlePayloadRel) + "\n"
