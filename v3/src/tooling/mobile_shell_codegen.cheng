fn v3MobileShellWriteAndroid(opts: var V3MobileShellOptions,
                             files: var str[],
                             outError: var str): bool =
    if !v3MobileShellWriteAndroidSettingsFile(opts, files, outError):
        return false
    if !v3MobileShellWriteAndroidTopBuildFile(opts, files, outError):
        return false
    if !v3MobileShellWriteAndroidGradlePropertiesFile(opts, files, outError):
        return false
    if !v3MobileShellWriteAndroidAppBuildFile(opts, files, outError):
        return false
    if !v3MobileShellWriteAndroidManifestFile(opts, files, outError):
        return false
    if !v3MobileShellWriteAndroidProguardFile(opts, files, outError):
        return false
    if !v3MobileShellWriteAndroidStringsFile(opts, files, outError):
        return false
    if !v3MobileShellWriteAndroidActivityFile(opts, files, outError):
        return false
    if !v3MobileShellWriteAndroidCmakeFile(opts, files, outError):
        return false
    return v3MobileShellWriteAndroidHostFile(opts, files, outError)

fn v3MobileShellWriteIosInfoPlistFile(opts: var V3MobileShellOptions,
                                      files: var str[],
                                      outError: var str): bool =
    let rel: str = "ios/Info.plist"
    let full: str = v3path.V3PathJoin(opts.outDir, rel)
    let parent: str = v3path.V3PathParentDir(full)
    if !v3path.V3MkdirP("", parent):
        outError = "mobile-shell: mkdir failed: " + parent
        return false
    let f: os.File = os.openImplWrite(full)
    if f == nil:
        outError = "mobile-shell: open failed: " + full
        return false
    let text: str = v3MobileShellIosInfoPlist(opts)
    os.Write(f, text)
    if len(text) <= 0 || text[text.len - 1] != '\n':
        os.Write(f, "\n")
    os.Close(f)
    if !v3path.V3PathFileExists(full) || v3path.V3PathFileSize(full) <= int64(0):
        outError = "mobile-shell: write failed: " + full
        return false
    add(files, rel)
    return true

