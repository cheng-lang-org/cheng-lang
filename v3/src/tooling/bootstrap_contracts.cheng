import std/os
import std/strutils as strutil
import std/strings
import cheng/v3/tooling/path as v3path
import cheng/v3/lang/parser as parser

type
    V3BootstrapStage = enum
        v3Stage0
        v3Stage1
        v3Stage2
        v3Stage3

    V3BootstrapArtifactKind = enum
        v3ArtifactStage1Source
        v3ArtifactStage0Compiler
        v3ArtifactStage1Compiler
        v3ArtifactStage2Compiler
        v3ArtifactStage3Compiler
        v3ArtifactBootstrapEnv
        v3ArtifactBackendDriver
        v3ArtifactChainNode

    V3BootstrapArtifact =
        kind: V3BootstrapArtifactKind
        stage: V3BootstrapStage
        path: str
        executable: bool

    V3BootstrapSnapshot =
        rootDir: str
        targetTriple: str
        bootstrapMode: str
        stage1Source: V3BootstrapArtifact
        stage0Compiler: V3BootstrapArtifact
        stage1Compiler: V3BootstrapArtifact
        stage2Compiler: V3BootstrapArtifact
        stage3Compiler: V3BootstrapArtifact
        bootstrapEnv: V3BootstrapArtifact
        backendDriverOut: V3BootstrapArtifact
        chainNodeOut: V3BootstrapArtifact

fn v3BootstrapDetectHostTarget(): str =
    if os.ExecCmdStatus("test \"$(uname -s)\" = Darwin && test \"$(uname -m)\" = arm64", "") == 0:
        return "arm64-apple-darwin"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Darwin && test \"$(uname -m)\" = aarch64", "") == 0:
        return "arm64-apple-darwin"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Darwin && test \"$(uname -m)\" = x86_64", "") == 0:
        return "x86_64-apple-darwin"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Darwin && test \"$(uname -m)\" = amd64", "") == 0:
        return "x86_64-apple-darwin"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Linux && test \"$(uname -m)\" = aarch64", "") == 0:
        return "aarch64-unknown-linux-gnu"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Linux && test \"$(uname -m)\" = arm64", "") == 0:
        return "aarch64-unknown-linux-gnu"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Linux && test \"$(uname -m)\" = x86_64", "") == 0:
        return "x86_64-unknown-linux-gnu"
    if os.ExecCmdStatus("test \"$(uname -s)\" = Linux && test \"$(uname -m)\" = amd64", "") == 0:
        return "x86_64-unknown-linux-gnu"
    return ""

fn v3BootstrapNormalizeTargetAlias(targetRaw: str): str =
    let trimmed: str = strutil.Strip(targetRaw)
    if len(trimmed) <= 0 || trimmed == "auto" || trimmed == "host" || trimmed == "native":
        let detected = v3BootstrapDetectHostTarget()
        if len(detected) > 0:
            return detected
        return "arm64-apple-darwin"
    if trimmed == "darwin_arm64" || trimmed == "darwin_aarch64":
        return "arm64-apple-darwin"
    if trimmed == "darwin_x86_64" || trimmed == "darwin_amd64":
        return "x86_64-apple-darwin"
    if trimmed == "linux_arm64" || trimmed == "linux_aarch64":
        return "aarch64-unknown-linux-gnu"
    if trimmed == "linux_x86_64" || trimmed == "linux_amd64":
        return "x86_64-unknown-linux-gnu"
    if trimmed == "windows_arm64" || trimmed == "windows_aarch64":
        return "aarch64-pc-windows-msvc"
    if trimmed == "windows_x86_64" || trimmed == "windows_amd64":
        return "x86_64-pc-windows-msvc"
    return trimmed

fn v3BootstrapDefaultTarget(): str =
    if os.GetEnv("CHENG_V3_TARGET") != "":
        return os.GetEnv("CHENG_V3_TARGET")
    if os.GetEnv("BACKEND_TARGET") != "":
        return os.GetEnv("BACKEND_TARGET")
    if v3BootstrapDetectHostTarget() != "":
        return v3BootstrapDetectHostTarget()
    return "arm64-apple-darwin"

fn v3BootstrapOutDir(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap")

fn v3BootstrapSeedSourcePath(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "v3/bootstrap/cheng_v3_seed.c")

fn v3BootstrapStage1SourcePath(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "v3/bootstrap/stage1_bootstrap.cheng")

fn v3BootstrapCompilerEntrySourcePath(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "v3/src/tooling/compiler_main.cheng")

