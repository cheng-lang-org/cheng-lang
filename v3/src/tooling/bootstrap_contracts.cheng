fn v3BootstrapStage0Path(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage0")

fn v3BootstrapStage1Path(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage1")

fn v3BootstrapStage2Path(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage2")

fn v3BootstrapStage3Path(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage3")

fn v3BootstrapEnvPath(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/bootstrap.env")

