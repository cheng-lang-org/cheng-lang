import std/os
import cheng/v3/tooling/path as v3path

type
    V3BootstrapStage = enum
        v3Stage0
        v3Stage1
        v3Stage2
        v3Stage3

    V3BootstrapArtifactKind = enum
        v3ArtifactSeedSource
        v3ArtifactStage1Source
        v3ArtifactStage0Compiler
        v3ArtifactStage1Compiler
        v3ArtifactStage2Compiler
        v3ArtifactStage3Compiler
        v3ArtifactBootstrapEnv
        v3ArtifactBackendDriver
        v3ArtifactChainNode

    V3BootstrapArtifact =
        kind: V3BootstrapArtifactKind
        stage: V3BootstrapStage
        path: str
        executable: bool

    V3BootstrapSnapshot =
        rootDir: str
        targetTriple: str
        bootstrapMode: str
        seedSource: V3BootstrapArtifact
        stage1Source: V3BootstrapArtifact
        stage0Compiler: V3BootstrapArtifact
        stage1Compiler: V3BootstrapArtifact
        stage2Compiler: V3BootstrapArtifact
        stage3Compiler: V3BootstrapArtifact
        bootstrapEnv: V3BootstrapArtifact
        backendDriverOut: V3BootstrapArtifact
        chainNodeOut: V3BootstrapArtifact

fn v3BootstrapDefaultTarget(): str =
    return "arm64-apple-darwin"

fn v3BootstrapOutDir(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "artifacts/v3_bootstrap")

fn v3BootstrapSeedSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/bootstrap/cheng_v3_seed.c")

fn v3BootstrapStage1SourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/bootstrap/stage1_bootstrap.cheng")

fn v3BootstrapCompilerEntrySourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/tooling/compiler_main.cheng")

fn v3BootstrapCompilerRuntimeSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/tooling/compiler_runtime.cheng")

fn v3BootstrapCompilerRequestSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/tooling/compiler_request.cheng")

fn v3BootstrapGateMainSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/tooling/gate_main.cheng")

fn v3LangParserSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/lang/parser.cheng")

fn v3BackendSystemLinkExecSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/backend/system_link_exec.cheng")

fn v3BackendPrimaryObjectPlanSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/backend/primary_object_plan.cheng")

fn v3BackendSystemLinkPlanSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/backend/system_link_plan.cheng")

fn v3BackendLoweringPlanSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/backend/lowering_plan.cheng")

fn v3BackendObjectPlanSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/backend/object_plan.cheng")

fn v3BackendNativeLinkPlanSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/backend/native_link_plan.cheng")

fn v3RuntimeCoreRuntimeSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/runtime/core_runtime_v3.cheng")

fn v3RuntimeCompilerRuntimeSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/runtime/compiler_runtime_v3.cheng")

fn v3RuntimeDebugRuntimeSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/runtime/debug_runtime_v3.cheng")

fn v3BootstrapStage0Path(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage0")

fn v3BootstrapStage1Path(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage1")

fn v3BootstrapStage2Path(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage2")

fn v3BootstrapStage3Path(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage3")

fn v3BootstrapEnvPath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "artifacts/v3_bootstrap/bootstrap.env")

fn v3BootstrapSnapshotPath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "artifacts/v3_bootstrap/bootstrap_snapshot.txt")

fn v3BootstrapBackendDriverOutPath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/cheng")

fn v3BootstrapChainNodeOutPath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "artifacts/v3_chain_node/chain_node")

fn v3BootstrapArtifactNew(kind: V3BootstrapArtifactKind, stage: V3BootstrapStage,
                          path: str, executable: bool): V3BootstrapArtifact =
    return V3BootstrapArtifact(kind: kind, stage: stage, path: path, executable: executable)

fn v3BootstrapSnapshotDefault(rootDir: str): V3BootstrapSnapshot =
    return V3BootstrapSnapshot(
        rootDir: rootDir,
        targetTriple: v3BootstrapDefaultTarget(),
        bootstrapMode: "v3_seed",
        seedSource: v3BootstrapArtifactNew(
            v3ArtifactSeedSource, v3Stage0, v3BootstrapSeedSourcePath(rootDir), false),
        stage1Source: v3BootstrapArtifactNew(
            v3ArtifactStage1Source, v3Stage1, v3BootstrapStage1SourcePath(rootDir), false),
        stage0Compiler: v3BootstrapArtifactNew(
            v3ArtifactStage0Compiler, v3Stage0, v3BootstrapStage0Path(rootDir), true),
        stage1Compiler: v3BootstrapArtifactNew(
            v3ArtifactStage1Compiler, v3Stage1, v3BootstrapStage1Path(rootDir), true),
        stage2Compiler: v3BootstrapArtifactNew(
            v3ArtifactStage2Compiler, v3Stage2, v3BootstrapStage2Path(rootDir), true),
        stage3Compiler: v3BootstrapArtifactNew(
            v3ArtifactStage3Compiler, v3Stage3, v3BootstrapStage3Path(rootDir), true),
        bootstrapEnv: v3BootstrapArtifactNew(
            v3ArtifactBootstrapEnv, v3Stage3, v3BootstrapEnvPath(rootDir), false),
        backendDriverOut: v3BootstrapArtifactNew(
            v3ArtifactBackendDriver, v3Stage2, v3BootstrapBackendDriverOutPath(rootDir), true),
        chainNodeOut: v3BootstrapArtifactNew(
            v3ArtifactChainNode, v3Stage2, v3BootstrapChainNodeOutPath(rootDir), true)
    )

fn v3BootstrapStageText(stage: V3BootstrapStage): str =
    if stage == v3Stage0:
        return "stage0"
    if stage == v3Stage1:
        return "stage1"
    if stage == v3Stage2:
        return "stage2"
    return "stage3"

fn v3BootstrapArtifactKindText(kind: V3BootstrapArtifactKind): str =
    if kind == v3ArtifactSeedSource:
        return "seed_source"
    if kind == v3ArtifactStage1Source:
        return "stage1_source"
    if kind == v3ArtifactStage0Compiler:
        return "stage0"
    if kind == v3ArtifactStage1Compiler:
        return "stage1"
    if kind == v3ArtifactStage2Compiler:
        return "stage2"
    if kind == v3ArtifactStage3Compiler:
        return "stage3"
    if kind == v3ArtifactBootstrapEnv:
        return "bootstrap_env"
    if kind == v3ArtifactBackendDriver:
        return "backend_driver"
    return "chain_node"

fn v3BootstrapArtifactReady(artifact: V3BootstrapArtifact): bool =
    if !os.fileExists(artifact.path):
        return false
    if artifact.executable:
        return os.fileSize(artifact.path) > int64(0)
    return true

fn v3BootstrapBridgeReady(snapshot: V3BootstrapSnapshot): bool =
    return v3BootstrapArtifactReady(snapshot.stage2Compiler) &&
           v3BootstrapArtifactReady(snapshot.stage3Compiler) &&
           v3BootstrapArtifactReady(snapshot.bootstrapEnv)

fn v3BootstrapSnapshotReport(snapshot: V3BootstrapSnapshot): str =
    return (
        "target=" + snapshot.targetTriple + "\n" +
        "bootstrap_kind=" + snapshot.bootstrapMode + "\n" +
        "seed_source=" + snapshot.seedSource.path + "\n" +
        "stage1_source=" + snapshot.stage1Source.path + "\n" +
        "compiler_entry_source=" + v3BootstrapCompilerEntrySourcePath(snapshot.rootDir) + "\n" +
        "compiler_runtime_source=" + v3BootstrapCompilerRuntimeSourcePath(snapshot.rootDir) + "\n" +
        "compiler_request_source=" + v3BootstrapCompilerRequestSourcePath(snapshot.rootDir) + "\n" +
        "tooling_gate_source=" + v3BootstrapGateMainSourcePath(snapshot.rootDir) + "\n" +
        "lang_parser_source=" + v3LangParserSourcePath(snapshot.rootDir) + "\n" +
        "backend_system_link_plan_source=" + v3BackendSystemLinkPlanSourcePath(snapshot.rootDir) + "\n" +
        "backend_lowering_plan_source=" + v3BackendLoweringPlanSourcePath(snapshot.rootDir) + "\n" +
        "backend_primary_object_plan_source=" + v3BackendPrimaryObjectPlanSourcePath(snapshot.rootDir) + "\n" +
        "backend_object_plan_source=" + v3BackendObjectPlanSourcePath(snapshot.rootDir) + "\n" +
        "backend_native_link_plan_source=" + v3BackendNativeLinkPlanSourcePath(snapshot.rootDir) + "\n" +
        "backend_system_link_exec_source=" + v3BackendSystemLinkExecSourcePath(snapshot.rootDir) + "\n" +
        "runtime_core_runtime_source=" + v3RuntimeCoreRuntimeSourcePath(snapshot.rootDir) + "\n" +
        "runtime_compiler_runtime_source=" + v3RuntimeCompilerRuntimeSourcePath(snapshot.rootDir) + "\n" +
        "runtime_debug_runtime_source=" + v3RuntimeDebugRuntimeSourcePath(snapshot.rootDir) + "\n" +
        "stage0=" + snapshot.stage0Compiler.path + "\n" +
        "stage1=" + snapshot.stage1Compiler.path + "\n" +
        "stage2=" + snapshot.stage2Compiler.path + "\n" +
        "stage3=" + snapshot.stage3Compiler.path + "\n" +
        "bootstrap_env=" + snapshot.bootstrapEnv.path + "\n" +
        "bootstrap_snapshot=" + v3BootstrapSnapshotPath(snapshot.rootDir) + "\n" +
        "backend_driver_out=" + snapshot.backendDriverOut.path + "\n" +
        "chain_node_out=" + snapshot.chainNodeOut.path + "\n"
    )
