    return v3path.V3PathAbsolute(rootDir, "artifacts/v3_cheng_node_main/cheng_node_main")

fn v3BootstrapArtifactNew(kind: V3BootstrapArtifactKind, stage: V3BootstrapStage,
                          path: str, executable: bool): V3BootstrapArtifact =
    return V3BootstrapArtifact(kind: kind, stage: stage, path: path, executable: executable)

fn v3BootstrapSnapshotDefault(rootDir: str): V3BootstrapSnapshot =
    return V3BootstrapSnapshot(
        rootDir: rootDir,
        targetTriple: v3BootstrapDefaultTarget(),
        bootstrapMode: "v3_selfhost",
        stage1Source: v3BootstrapArtifactNew(
            v3ArtifactStage1Source, v3Stage1, v3BootstrapStage1SourcePath(rootDir), false),
        stage0Compiler: v3BootstrapArtifactNew(
            v3ArtifactStage0Compiler, v3Stage0, v3BootstrapStage0Path(rootDir), true),
        stage1Compiler: v3BootstrapArtifactNew(
            v3ArtifactStage1Compiler, v3Stage1, v3BootstrapStage1Path(rootDir), true),
        stage2Compiler: v3BootstrapArtifactNew(
            v3ArtifactStage2Compiler, v3Stage2, v3BootstrapStage2Path(rootDir), true),
        stage3Compiler: v3BootstrapArtifactNew(
            v3ArtifactStage3Compiler, v3Stage3, v3BootstrapStage3Path(rootDir), true),
        bootstrapEnv: v3BootstrapArtifactNew(
            v3ArtifactBootstrapEnv, v3Stage3, v3BootstrapEnvPath(rootDir), false),
        backendDriverOut: v3BootstrapArtifactNew(
            v3ArtifactBackendDriver, v3Stage2, v3BootstrapBackendDriverOutPath(rootDir), true),
        chainNodeOut: v3BootstrapArtifactNew(
            v3ArtifactChainNode, v3Stage2, v3BootstrapChainNodeOutPath(rootDir), true)
    )

fn v3BootstrapStageText(stage: V3BootstrapStage): str =
    if stage == v3Stage0:
        return "stage0"
    if stage == v3Stage1:
        return "stage1"
    if stage == v3Stage2:
        return "stage2"
    return "stage3"

fn v3BootstrapArtifactKindText(kind: V3BootstrapArtifactKind): str =
    if kind == v3ArtifactStage1Source:
        return "stage1_source"
    if kind == v3ArtifactStage0Compiler:
        return "stage0"
    if kind == v3ArtifactStage1Compiler:
        return "stage1"
    if kind == v3ArtifactStage2Compiler:
        return "stage2"
    if kind == v3ArtifactStage3Compiler:
        return "stage3"
    if kind == v3ArtifactBootstrapEnv:
        return "bootstrap_env"
    if kind == v3ArtifactBackendDriver:
        return "backend_driver"
    return "chain_node"

fn v3BootstrapArtifactReady(artifact: V3BootstrapArtifact): bool =
    if !os.FileExists(artifact.path):
        return false
    return os.FileSize(artifact.path) > int64(0)

fn v3BootstrapPathSetAdd(out: var str[], pathRaw: str) =
    let path: str = v3path.V3PathTrim(pathRaw)
    if len(path) <= 0:
        return
    for i in 0..<out.len:
        if out[i] == path:
            return
    add(out, path)

fn v3BootstrapAppendOrdinaryClosure(packageRoot: str,
                                    sourcePath: str,
                                    out: var str[],
                                    err: var str): bool =
    var parsed: parser.V3ParsedSourceStub
    if !parser.v3ParseOrdinarySourceStub(packageRoot, sourcePath, parsed, err):
        return false
    for i in 0..<parsed.orderedClosureSourcePaths.len:
        v3BootstrapPathSetAdd(out, parsed.orderedClosureSourcePaths[i])
    err = ""
    return true

fn v3BootstrapFreshInputPaths(rootDir: str, out: var str[], err: var str): bool =
    out = []
    err = ""
    v3BootstrapPathSetAdd(out, v3BootstrapSeedSourcePath(rootDir))
    v3BootstrapPathSetAdd(out, v3BootstrapStage1SourcePath(rootDir))
    let packageRoot: str = v3path.V3PathAbsolute(rootDir, "v3")
    if !v3BootstrapAppendOrdinaryClosure(packageRoot,
                                         v3BootstrapCompilerEntrySourcePath(rootDir),
                                         out,
                                         err):
        return false
    if !v3BootstrapAppendOrdinaryClosure(packageRoot,
                                         v3BootstrapGateMainSourcePath(rootDir),
                                         out,
                                         err):
        return false
    return true

fn v3BootstrapJoinCsv(items: str[]): str =
    var out = ""
    for i in 0..<items.len:
        if len(out) > 0:
            out = out + ","
        out = out + items[i]
    return out

fn v3BootstrapFreshInputPathsCsv(rootDir: str, err: var str): str =
    var paths: str[]
    if !v3BootstrapFreshInputPaths(rootDir, paths, err):
        return ""
    err = ""
    return v3BootstrapJoinCsv(paths)

fn v3BootstrapLineValue(text: str, key: str): str =
    let prefix = key + "="
    var start: int32
    var i: int32
    while i <= text.len:
        var lineEnd = false
        if i == text.len:
            lineEnd = true
        elif text[i] == '\n':
            lineEnd = true
        if lineEnd:
            let line = strings.SliceBytes(text, start, i - start)
            if len(line) >= len(prefix):
                if strings.SliceBytes(line, 0, len(prefix)) == prefix:
                    return strings.SliceBytes(line, len(prefix), len(line) - len(prefix))
            start = i + 1
        i = i + 1
    return ""

fn v3BootstrapCachedFreshInputPaths(rootDir: str, out: var str[]): bool =
    out = []
    let snapshotPath: str = v3BootstrapSnapshotPath(rootDir)
    if !v3path.V3PathFileExists(snapshotPath):
        return false
    let snapshotText: str = v3path.V3ReadTextFile(rootDir, snapshotPath)
    let raw: str = strutil.Strip(v3BootstrapLineValue(snapshotText, "fresh_input_paths"))
    if len(raw) <= 0:
        return false
    var start: int32
    for i in 0..len(raw):
        var itemEnd = false
        if i == len(raw):
            itemEnd = true
        elif raw[i] == ',':
            itemEnd = true
        if !itemEnd:
            continue
        let item: str = strutil.Strip(strings.SliceBytes(raw, start, i - start))
        if len(item) > 0:
            v3BootstrapPathSetAdd(out, item)
        start = i + 1
    return out.len > 0

fn v3BootstrapBridgeReady(snapshot: V3BootstrapSnapshot): bool =
    return v3BootstrapArtifactReady(snapshot.stage2Compiler) &&
           v3BootstrapArtifactReady(snapshot.stage3Compiler) &&
           v3BootstrapArtifactReady(snapshot.bootstrapEnv)

fn v3BootstrapSnapshotReport(snapshot: V3BootstrapSnapshot): str =
    var out = ""
    out = out + "target=" + snapshot.targetTriple + "\n"
    out = out + "bootstrap_kind=" + snapshot.bootstrapMode + "\n"
    out = out + "stage1_source=" + snapshot.stage1Source.path + "\n"
    out = out + "compiler_entry_source=" + v3BootstrapCompilerEntrySourcePath(snapshot.rootDir) + "\n"
    out = out + "compiler_runtime_source=" + v3BootstrapCompilerRuntimeSourcePath(snapshot.rootDir) + "\n"
    out = out + "compiler_support_matrix_source=" + v3BootstrapCompilerSupportMatrixSourcePath(snapshot.rootDir) + "\n"
    out = out + "compiler_request_source=" + v3BootstrapCompilerRequestSourcePath(snapshot.rootDir) + "\n"
    out = out + "tooling_gate_source=" + v3BootstrapGateMainSourcePath(snapshot.rootDir) + "\n"
    out = out + "lang_parser_source=" + v3LangParserSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_system_link_plan_source=" + v3BackendSystemLinkPlanSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_lowering_plan_source=" + v3BackendLoweringPlanSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_primary_object_plan_source=" + v3BackendPrimaryObjectPlanSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_object_plan_source=" + v3BackendObjectPlanSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_native_link_plan_source=" + v3BackendNativeLinkPlanSourcePath(snapshot.rootDir) + "\n"
    out = out + "backend_system_link_exec_source=" + v3BackendSystemLinkExecSourcePath(snapshot.rootDir) + "\n"
    out = out + "runtime_core_runtime_source=" + v3RuntimeCoreRuntimeSourcePath(snapshot.rootDir) + "\n"
    out = out + "runtime_compiler_runtime_source=" + v3RuntimeCompilerRuntimeSourcePath(snapshot.rootDir) + "\n"
    out = out + "runtime_debug_runtime_source=" + v3RuntimeDebugRuntimeSourcePath(snapshot.rootDir) + "\n"
    out = out + "stage0=" + snapshot.stage0Compiler.path + "\n"
    out = out + "stage1=" + snapshot.stage1Compiler.path + "\n"
    out = out + "stage2=" + snapshot.stage2Compiler.path + "\n"
    out = out + "stage3=" + snapshot.stage3Compiler.path + "\n"
    out = out + "bootstrap_env=" + snapshot.bootstrapEnv.path + "\n"
    out = out + "bootstrap_snapshot=" + v3BootstrapSnapshotPath(snapshot.rootDir) + "\n"
    out = out + "backend_driver_out=" + snapshot.backendDriverOut.path + "\n"
    out = out + "chain_node_out=" + snapshot.chainNodeOut.path + "\n"
    return out
