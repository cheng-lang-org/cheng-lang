import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/tooling/compiler_world as cworld
import cheng/v3/tooling/compiler_csg as ccsg

type
    V3CompilerEquivalenceProof =
        version: int32
        packageId: str
        channel: str
        baselineGraphCid: layout.FixedBytes32
        migratedGraphCid: layout.FixedBytes32
        baselineSurfaceCid: layout.FixedBytes32
        migratedSurfaceCid: layout.FixedBytes32
        baselineReceiptCid: layout.FixedBytes32
        migratedReceiptCid: layout.FixedBytes32
        targetTriple: str
        graphEquivalent: int32
        exportSurfaceCompatible: int32
        compileReceiptEquivalent: int32
        equivalenceKind: str
        proofCid: layout.FixedBytes32

    V3CompilerPublishDecision =
        version: int32
        channel: str
        stableGateRequired: int32
        equivalenceChecked: int32
        equivalencePassed: int32
        publishAllowed: int32
        worldHeadCid: layout.FixedBytes32
        proofCid: layout.FixedBytes32

fn v3CompilerEquivalenceAppendText(buf: var layout.ByteBuf, text: str) =
    lt.v3AppendU32BE(buf, len(text))
    for i in 0..<len(text):
        layout.byteBufAppendByte(buf, int32(text[i]) & 255)

fn v3CompilerEquivalenceFlag(value: bool): int32 =
    if value:
        return 1
    return 0

fn v3CompilerEquivalenceKind(graphEquivalent: bool,
                             exportSurfaceCompatible: bool,
                             compileReceiptEquivalent: bool): str =
    if graphEquivalent:
        if exportSurfaceCompatible:
            if compileReceiptEquivalent:
                return "canonical_semantic_identity"
    return "incompatible"

fn v3CompilerEquivalenceProofMake(packageId: str,
                                  channelRaw: str,
                                  baselineGraphCid: layout.FixedBytes32,
                                  migratedGraphCid: layout.FixedBytes32,
                                  baselineSurfaceCid: layout.FixedBytes32,
                                  migratedSurfaceCid: layout.FixedBytes32,
                                  baselineReceiptCid: layout.FixedBytes32,
                                  migratedReceiptCid: layout.FixedBytes32,
                                  targetTriple: str,
                                  graphEquivalent: int32,
                                  exportSurfaceCompatible: int32,
                                  compileReceiptEquivalent: int32,
                                  out: var V3CompilerEquivalenceProof): Result[bool] =
    let channelRes = cworld.v3CompilerWorldNormalizeChannel(channelRaw)
    if IsErr(channelRes):
        return Err[bool](Error(channelRes))
    let equivalenceKind = v3CompilerEquivalenceKind(graphEquivalent != 0,
                                                    exportSurfaceCompatible != 0,
                                                    compileReceiptEquivalent != 0)
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    v3CompilerEquivalenceAppendText(buf, "v3.compiler.equivalence_proof")
    v3CompilerEquivalenceAppendText(buf, packageId)
    v3CompilerEquivalenceAppendText(buf, Value(channelRes))
    lt.v3AppendFixed32(buf, baselineGraphCid)
    lt.v3AppendFixed32(buf, migratedGraphCid)
    lt.v3AppendFixed32(buf, baselineSurfaceCid)
    lt.v3AppendFixed32(buf, migratedSurfaceCid)
    lt.v3AppendFixed32(buf, baselineReceiptCid)
    lt.v3AppendFixed32(buf, migratedReceiptCid)
    v3CompilerEquivalenceAppendText(buf, targetTriple)
    lt.v3AppendU32BE(buf, graphEquivalent)
    lt.v3AppendU32BE(buf, exportSurfaceCompatible)
    lt.v3AppendU32BE(buf, compileReceiptEquivalent)
    v3CompilerEquivalenceAppendText(buf, equivalenceKind)
    out.version = 1
    out.packageId = packageId
    out.channel = Value(channelRes)
    out.baselineGraphCid = baselineGraphCid
    out.migratedGraphCid = migratedGraphCid
    out.baselineSurfaceCid = baselineSurfaceCid
    out.migratedSurfaceCid = migratedSurfaceCid
    out.baselineReceiptCid = baselineReceiptCid
    out.migratedReceiptCid = migratedReceiptCid
    out.targetTriple = targetTriple
    out.graphEquivalent = graphEquivalent
    out.exportSurfaceCompatible = exportSurfaceCompatible
    out.compileReceiptEquivalent = compileReceiptEquivalent
    out.equivalenceKind = equivalenceKind
    out.proofCid = lt.v3FixedCidFromBuf(buf)
    return Ok[bool](true)

fn v3CompilerEquivalenceGraphCidFromText(text: str,
                                         out: var layout.FixedBytes32): Result[bool] =
    let cidRes = ccsg.v3CompilerCsgCanonicalGraphCidFromReportText(text)
    if IsErr(cidRes):
        return Err[bool](Error(cidRes))
    out = Value(cidRes)
    return Ok[bool](true)

fn v3CompilerEquivalenceGraphCompareTexts(baselineCsgText: str,
                                          migratedCsgText: str,
                                          outBaselineCid: var layout.FixedBytes32,
                                          outMigratedCid: var layout.FixedBytes32,
                                          outEquivalent: var int32): Result[bool] =
    let baselineCidRes = v3CompilerEquivalenceGraphCidFromText(baselineCsgText, outBaselineCid)
    if IsErr(baselineCidRes):
        return Err[bool](Error(baselineCidRes))
    let migratedCidRes = v3CompilerEquivalenceGraphCidFromText(migratedCsgText, outMigratedCid)
    if IsErr(migratedCidRes):
        return Err[bool](Error(migratedCidRes))
    outEquivalent = v3CompilerEquivalenceFlag(layout.fixedBytes32Equal(outBaselineCid, outMigratedCid))
    return Ok[bool](true)

fn v3CompilerEquivalenceSurfaceCompareTexts(baselineSurfaceText: str,
                                            migratedSurfaceText: str,
                                            outBaselineCid: var layout.FixedBytes32,
                                            outMigratedCid: var layout.FixedBytes32,
                                            outCompatible: var int32): Result[bool] =
    var baselineSurface: ccsg.V3CsgExportSurface
    let baselineSurfaceRes = ccsg.v3CompilerExportSurfaceFromReportText(baselineSurfaceText, baselineSurface)
    if IsErr(baselineSurfaceRes):
        return Err[bool](Error(baselineSurfaceRes))
    var migratedSurface: ccsg.V3CsgExportSurface
    let migratedSurfaceRes = ccsg.v3CompilerExportSurfaceFromReportText(migratedSurfaceText, migratedSurface)
    if IsErr(migratedSurfaceRes):
        return Err[bool](Error(migratedSurfaceRes))
    outBaselineCid = baselineSurface.surfaceCid
    outMigratedCid = migratedSurface.surfaceCid
    outCompatible = v3CompilerEquivalenceFlag(ccsg.v3CompilerExportSurfaceCompatible(baselineSurface, migratedSurface))
    return Ok[bool](true)

fn v3CompilerEquivalenceReceiptCompareTexts(baselineReceiptText: str,
                                            migratedReceiptText: str,
                                            outBaselineCid: var layout.FixedBytes32,
                                            outMigratedCid: var layout.FixedBytes32,
                                            outTargetTriple: var str,
                                            outEquivalent: var int32): Result[bool] =
    var baselineReceipt: ccsg.V3CompileReceipt
    let baselineReceiptRes = ccsg.v3CompileReceiptFromReportText(baselineReceiptText, baselineReceipt)
    if IsErr(baselineReceiptRes):
        return Err[bool](Error(baselineReceiptRes))
    var migratedReceipt: ccsg.V3CompileReceipt
    let migratedReceiptRes = ccsg.v3CompileReceiptFromReportText(migratedReceiptText, migratedReceipt)
    if IsErr(migratedReceiptRes):
        return Err[bool](Error(migratedReceiptRes))
    outBaselineCid = baselineReceipt.receiptCid
    outMigratedCid = migratedReceipt.receiptCid
    outTargetTriple = migratedReceipt.targetTriple
    outEquivalent = v3CompilerEquivalenceFlag(ccsg.v3CompileReceiptEquivalent(baselineReceipt, migratedReceipt))
    return Ok[bool](true)

fn v3CompilerEquivalencePassed(proof: V3CompilerEquivalenceProof): bool =
    return proof.graphEquivalent != 0 &&
           proof.exportSurfaceCompatible != 0 &&
           proof.compileReceiptEquivalent != 0 &&
           proof.equivalenceKind == "canonical_semantic_identity"

fn v3CompilerEquivalenceProofReport(proof: V3CompilerEquivalenceProof): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "package_id=" + proof.packageId + "\n"
    out = out + "channel=" + proof.channel + "\n"
    out = out + "baseline_graph_cid=" + layout.fixedBytes32Hex(proof.baselineGraphCid) + "\n"
    out = out + "migrated_graph_cid=" + layout.fixedBytes32Hex(proof.migratedGraphCid) + "\n"
    out = out + "baseline_surface_cid=" + layout.fixedBytes32Hex(proof.baselineSurfaceCid) + "\n"
    out = out + "migrated_surface_cid=" + layout.fixedBytes32Hex(proof.migratedSurfaceCid) + "\n"
    out = out + "baseline_receipt_cid=" + layout.fixedBytes32Hex(proof.baselineReceiptCid) + "\n"
    out = out + "migrated_receipt_cid=" + layout.fixedBytes32Hex(proof.migratedReceiptCid) + "\n"
    out = out + "target=" + proof.targetTriple + "\n"
    out = out + "graph_equivalent=" + intToStr(proof.graphEquivalent) + "\n"
    out = out + "export_surface_compatible=" + intToStr(proof.exportSurfaceCompatible) + "\n"
    out = out + "compile_receipt_equivalent=" + intToStr(proof.compileReceiptEquivalent) + "\n"
    out = out + "equivalence_kind=" + proof.equivalenceKind + "\n"
    out = out + "proof_cid=" + layout.fixedBytes32Hex(proof.proofCid)
    return out

fn v3CompilerPublishDecisionMake(channelRaw: str,
                                 worldHeadCid: layout.FixedBytes32,
                                 equivalenceChecked: bool,
                                 proof: V3CompilerEquivalenceProof,
                                 out: var V3CompilerPublishDecision): Result[bool] =
    let channelRes = cworld.v3CompilerWorldNormalizeChannel(channelRaw)
    if IsErr(channelRes):
        return Err[bool](Error(channelRes))
    let channel = Value(channelRes)
    let stableGateRequired = channel == "stable" ? 1 : 0
    let equivalenceCheckedFlag = equivalenceChecked ? 1 : 0
    var equivalencePassed = 0
    if equivalenceChecked:
        if v3CompilerEquivalencePassed(proof):
            equivalencePassed = 1
    var publishAllowed = 1
    if stableGateRequired != 0:
        publishAllowed = equivalencePassed
    out.version = 1
    out.channel = channel
    out.stableGateRequired = stableGateRequired
    out.equivalenceChecked = equivalenceCheckedFlag
    out.equivalencePassed = equivalencePassed
    out.publishAllowed = publishAllowed
    out.worldHeadCid = worldHeadCid
    if equivalenceChecked:
        out.proofCid = proof.proofCid
    else:
        out.proofCid = layout.fixedBytes32Zero()
    return Ok[bool](true)

fn v3CompilerPublishDecisionReport(decision: V3CompilerPublishDecision): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "channel=" + decision.channel + "\n"
    out = out + "stable_gate_required=" + intToStr(decision.stableGateRequired) + "\n"
    out = out + "equivalence_checked=" + intToStr(decision.equivalenceChecked) + "\n"
    out = out + "equivalence_passed=" + intToStr(decision.equivalencePassed) + "\n"
    out = out + "publish_allowed=" + intToStr(decision.publishAllowed) + "\n"
    out = out + "world_head_cid=" + layout.fixedBytes32Hex(decision.worldHeadCid) + "\n"
    out = out + "proof_cid=" + layout.fixedBytes32Hex(decision.proofCid)
    return out
