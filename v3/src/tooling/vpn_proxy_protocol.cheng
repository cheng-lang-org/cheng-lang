import std/result
import std/rawbytes
import std/buffer
import cheng/v3/libp2p/core/types

type
    V3VpnProxyFrameKind = enum
        V3VpnProxyFrameUnknown = 0
        V3VpnProxyFrameOpen = 1
        V3VpnProxyFrameOpenOk = 2
        V3VpnProxyFrameData = 3
        V3VpnProxyFrameClose = 4
        V3VpnProxyFrameError = 5
        V3VpnProxyFramePing = 6
        V3VpnProxyFramePong = 7

    V3VpnProxyFrame =
        kind: V3VpnProxyFrameKind
        host: str
        port: int32
        payload: Bytes
        text: str
        token: int32

    V3VpnProxyFrameTry =
        ready: bool
        usedBytes: int32
        frame: V3VpnProxyFrame

const
    v3VpnProxyMaxFrameBytes = 1048576

fn v3VpnProxyProtocolId(): types.V3Libp2pProtocolId =
    return types.v3Libp2pProtocolProxyTcp

fn v3VpnProxyFrameZero(): V3VpnProxyFrame =
    var out: V3VpnProxyFrame
    out.kind = V3VpnProxyFrameUnknown
    out.host = ""
    out.port = 0
    out.payload = emptyBytes()
    out.text = ""
    out.token = 0
    return out

fn v3VpnProxyFrameKindText(kind: V3VpnProxyFrameKind): str =
    if kind == V3VpnProxyFrameOpen:
        return "OPEN"
    if kind == V3VpnProxyFrameOpenOk:
        return "OPEN_OK"
    if kind == V3VpnProxyFrameData:
        return "DATA"
    if kind == V3VpnProxyFrameClose:
        return "CLOSE"
    if kind == V3VpnProxyFrameError:
        return "ERROR"
    if kind == V3VpnProxyFramePing:
        return "PING"
    if kind == V3VpnProxyFramePong:
        return "PONG"
    return "UNKNOWN"

fn v3VpnProxyAppendU16(buf: var buffer.ByteBuffer, value: int32) =
    buffer.appendByte(buf, (value >> 8) & 0xff)
    buffer.appendByte(buf, value & 0xff)

fn v3VpnProxyAppendU32(buf: var buffer.ByteBuffer, value: int32) =
    buffer.appendByte(buf, (value >> 24) & 0xff)
    buffer.appendByte(buf, (value >> 16) & 0xff)
    buffer.appendByte(buf, (value >> 8) & 0xff)
    buffer.appendByte(buf, value & 0xff)

fn v3VpnProxyReadU16(data: Bytes, offset: int32): Result[int32] =
    if offset < 0 || offset + 2 > bytesLen(data):
        return Err[int32]("vpn proxy protocol: u16 out of range")
    let b0: int32 = bytesGet(data, offset)
    let b1: int32 = bytesGet(data, offset + 1)
    return Ok[int32]((b0 << 8) | b1)

fn v3VpnProxyReadU32(data: Bytes, offset: int32): Result[int32] =
    if offset < 0 || offset + 4 > bytesLen(data):
        return Err[int32]("vpn proxy protocol: u32 out of range")
    let b0: int32 = bytesGet(data, offset)
    let b1: int32 = bytesGet(data, offset + 1)
    let b2: int32 = bytesGet(data, offset + 2)
    let b3: int32 = bytesGet(data, offset + 3)
    return Ok[int32]((b0 << 24) | (b1 << 16) | (b2 << 8) | b3)

fn v3VpnProxyFrameOpen(host: str, port: int32): V3VpnProxyFrame =
    var out = v3VpnProxyFrameZero()
    out.kind = V3VpnProxyFrameOpen
    out.host = host
    out.port = port
    return out

fn v3VpnProxyFrameOpenOk(): V3VpnProxyFrame =
    var out = v3VpnProxyFrameZero()
    out.kind = V3VpnProxyFrameOpenOk
    return out

fn v3VpnProxyFrameData(payload: Bytes): V3VpnProxyFrame =
    var out = v3VpnProxyFrameZero()
    out.kind = V3VpnProxyFrameData
    out.payload = payload
    return out

fn v3VpnProxyFrameClose(): V3VpnProxyFrame =
    var out = v3VpnProxyFrameZero()
    out.kind = V3VpnProxyFrameClose
    return out

fn v3VpnProxyFrameError(text: str): V3VpnProxyFrame =
    var out = v3VpnProxyFrameZero()
    out.kind = V3VpnProxyFrameError
    out.text = text
    return out

fn v3VpnProxyFramePing(token: int32): V3VpnProxyFrame =
    var out = v3VpnProxyFrameZero()
    out.kind = V3VpnProxyFramePing
    out.token = token
    return out

fn v3VpnProxyFramePong(token: int32): V3VpnProxyFrame =
    var out = v3VpnProxyFrameZero()
    out.kind = V3VpnProxyFramePong
    out.token = token
    return out

fn v3VpnProxyEncodePayload(frame: V3VpnProxyFrame): Result[Bytes] =
    var out = buffer.newByteBuffer()
    let kindCode: int32 = int32(frame.kind)
    if kindCode <= 0 || kindCode > 7:
        return Err[Bytes]("vpn proxy protocol: invalid frame kind")
    buffer.appendByte(out, kindCode)
    if frame.kind == V3VpnProxyFrameOpen:
        let hostBytes: Bytes = bytesFromString(frame.host)
        if bytesLen(hostBytes) <= 0:
            return Err[Bytes]("vpn proxy protocol: open host missing")
        if bytesLen(hostBytes) > 65535:
            return Err[Bytes]("vpn proxy protocol: open host too long")
        if frame.port <= 0 || frame.port > 65535:
            return Err[Bytes]("vpn proxy protocol: open port invalid")
        v3VpnProxyAppendU16(out, bytesLen(hostBytes))
        buffer.appendBytes(out, hostBytes)
        v3VpnProxyAppendU16(out, frame.port)
        return Ok[Bytes](buffer.toBytes(out))
    if frame.kind == V3VpnProxyFrameData:
        if bytesLen(frame.payload) > 0:
            buffer.appendBytes(out, frame.payload)
        return Ok[Bytes](buffer.toBytes(out))
    if frame.kind == V3VpnProxyFrameError:
        let textBytes: Bytes = bytesFromString(frame.text)
        if bytesLen(textBytes) > 65535:
            return Err[Bytes]("vpn proxy protocol: error text too long")
        v3VpnProxyAppendU16(out, bytesLen(textBytes))
        if bytesLen(textBytes) > 0:
            buffer.appendBytes(out, textBytes)
        return Ok[Bytes](buffer.toBytes(out))
    if frame.kind == V3VpnProxyFramePing || frame.kind == V3VpnProxyFramePong:
        v3VpnProxyAppendU32(out, frame.token)
        return Ok[Bytes](buffer.toBytes(out))
    return Ok[Bytes](buffer.toBytes(out))

fn v3VpnProxyEncodeWire(frame: V3VpnProxyFrame): Result[Bytes] =
    let payloadRes: Result[Bytes] = v3VpnProxyEncodePayload(frame)
    if IsErr(payloadRes):
        return Err[Bytes](ErrorText(payloadRes))
    let payload: Bytes = Value(payloadRes)
    let payloadLen: int32 = bytesLen(payload)
    if payloadLen <= 0:
        return Err[Bytes]("vpn proxy protocol: empty payload")
    if payloadLen > v3VpnProxyMaxFrameBytes:
        return Err[Bytes]("vpn proxy protocol: frame too large")
    let out: Bytes = bytesAlloc(4 + payloadLen)
    bytesSet(out, 0, (payloadLen >> 24) & 0xff)
    bytesSet(out, 1, (payloadLen >> 16) & 0xff)
    bytesSet(out, 2, (payloadLen >> 8) & 0xff)
    bytesSet(out, 3, payloadLen & 0xff)
    for i in 0..<payloadLen:
        bytesSet(out, 4 + i, bytesGet(payload, i))
    return Ok[Bytes](out)

fn v3VpnProxyParsePayload(payload: Bytes): Result[V3VpnProxyFrame] =
    if bytesLen(payload) <= 0:
        return Err[V3VpnProxyFrame]("vpn proxy protocol: empty payload")
    var out = v3VpnProxyFrameZero()
    let kindCode: int32 = bytesGet(payload, 0)
    if kindCode == int32(V3VpnProxyFrameOpen):
        out.kind = V3VpnProxyFrameOpen
        let hostLenRes: Result[int32] = v3VpnProxyReadU16(payload, 1)
        if IsErr(hostLenRes):
            return Err[V3VpnProxyFrame](ErrorText(hostLenRes))
        let hostLen: int32 = Value(hostLenRes)
        let hostStart: int32 = 3
        let portStart: int32 = hostStart + hostLen
        if hostLen <= 0 || portStart + 2 > bytesLen(payload):
            return Err[V3VpnProxyFrame]("vpn proxy protocol: open payload invalid")
        out.host = bytesToString(bytesSlice(payload, hostStart, hostLen))
        let portRes: Result[int32] = v3VpnProxyReadU16(payload, portStart)
        if IsErr(portRes):
            return Err[V3VpnProxyFrame](ErrorText(portRes))
        out.port = Value(portRes)
        return Ok[V3VpnProxyFrame](out)
    if kindCode == int32(V3VpnProxyFrameOpenOk):
        out.kind = V3VpnProxyFrameOpenOk
        return Ok[V3VpnProxyFrame](out)
    if kindCode == int32(V3VpnProxyFrameData):
        out.kind = V3VpnProxyFrameData
        out.payload = bytesSlice(payload, 1, bytesLen(payload) - 1)
        return Ok[V3VpnProxyFrame](out)
    if kindCode == int32(V3VpnProxyFrameClose):
        out.kind = V3VpnProxyFrameClose
        return Ok[V3VpnProxyFrame](out)
    if kindCode == int32(V3VpnProxyFrameError):
        out.kind = V3VpnProxyFrameError
        let textLenRes: Result[int32] = v3VpnProxyReadU16(payload, 1)
        if IsErr(textLenRes):
            return Err[V3VpnProxyFrame](ErrorText(textLenRes))
        let textLen: int32 = Value(textLenRes)
        if 3 + textLen > bytesLen(payload):
            return Err[V3VpnProxyFrame]("vpn proxy protocol: error payload invalid")
        out.text = bytesToString(bytesSlice(payload, 3, textLen))
        return Ok[V3VpnProxyFrame](out)
    if kindCode == int32(V3VpnProxyFramePing) || kindCode == int32(V3VpnProxyFramePong):
        let tokenRes: Result[int32] = v3VpnProxyReadU32(payload, 1)
        if IsErr(tokenRes):
            return Err[V3VpnProxyFrame](ErrorText(tokenRes))
        out.token = Value(tokenRes)
        if kindCode == int32(V3VpnProxyFramePing):
            out.kind = V3VpnProxyFramePing
        else:
            out.kind = V3VpnProxyFramePong
        return Ok[V3VpnProxyFrame](out)
    return Err[V3VpnProxyFrame]("vpn proxy protocol: unknown frame kind")

fn v3VpnProxyTryParseWire(wire: Bytes): Result[V3VpnProxyFrameTry] =
    var out: V3VpnProxyFrameTry
    out.ready = false
    out.usedBytes = 0
    out.frame = v3VpnProxyFrameZero()
    if bytesLen(wire) < 4:
        return Ok[V3VpnProxyFrameTry](out)
    let payloadLenRes: Result[int32] = v3VpnProxyReadU32(wire, 0)
    if IsErr(payloadLenRes):
        return Err[V3VpnProxyFrameTry](ErrorText(payloadLenRes))
    let payloadLen: int32 = Value(payloadLenRes)
    if payloadLen <= 0 || payloadLen > v3VpnProxyMaxFrameBytes:
        return Err[V3VpnProxyFrameTry]("vpn proxy protocol: wire frame length invalid")
    if 4 + payloadLen > bytesLen(wire):
        return Ok[V3VpnProxyFrameTry](out)
    let payload: Bytes = bytesSlice(wire, 4, payloadLen)
    let frameRes: Result[V3VpnProxyFrame] = v3VpnProxyParsePayload(payload)
    if IsErr(frameRes):
        return Err[V3VpnProxyFrameTry](ErrorText(frameRes))
    out.ready = true
    out.usedBytes = 4 + payloadLen
    out.frame = Value(frameRes)
    return Ok[V3VpnProxyFrameTry](out)

fn V3VpnProxyProtocolId(): types.V3Libp2pProtocolId =
    return v3VpnProxyProtocolId()

fn V3VpnProxyFrameZero(): V3VpnProxyFrame =
    return v3VpnProxyFrameZero()

fn V3VpnProxyFrameKindText(kind: V3VpnProxyFrameKind): str =
    return v3VpnProxyFrameKindText(kind)

fn V3VpnProxyMakeOpenFrame(host: str, port: int32): V3VpnProxyFrame =
    return v3VpnProxyFrameOpen(host, port)

fn V3VpnProxyMakeOpenOkFrame(): V3VpnProxyFrame =
    return v3VpnProxyFrameOpenOk()

fn V3VpnProxyMakeDataFrame(payload: Bytes): V3VpnProxyFrame =
    return v3VpnProxyFrameData(payload)

fn V3VpnProxyMakeCloseFrame(): V3VpnProxyFrame =
    return v3VpnProxyFrameClose()

fn V3VpnProxyMakeErrorFrame(text: str): V3VpnProxyFrame =
    return v3VpnProxyFrameError(text)

fn V3VpnProxyMakePingFrame(token: int32): V3VpnProxyFrame =
    return v3VpnProxyFramePing(token)

fn V3VpnProxyMakePongFrame(token: int32): V3VpnProxyFrame =
    return v3VpnProxyFramePong(token)

fn V3VpnProxyEncodeWire(frame: V3VpnProxyFrame): Result[Bytes] =
    return v3VpnProxyEncodeWire(frame)

fn V3VpnProxyTryParseWire(wire: Bytes): Result[V3VpnProxyFrameTry] =
    return v3VpnProxyTryParseWire(wire)
