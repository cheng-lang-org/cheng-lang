@importc("get_stdout")
fn v3CompilerStdoutBridge(): os.File
@importc("get_stderr")
fn v3CompilerStderrBridge(): os.File
@importc("paramCount")
fn v3CompilerParamCountBridge(): int32

fn v3CompilerPrintLine(text: str) =
    os.WriteLine(v3CompilerStdoutBridge(), text)

fn v3CompilerPrintErr(text: str) =
    os.WriteLine(v3CompilerStderrBridge(), text)

fn v3CompilerPrintBlock(text: str) =
    var start: int32 = 0
    var i: int32 = 0
    while i <= text.len:
        let atEnd: bool = i == text.len
        if atEnd:
            let line: str = strings.SliceBytes(text, start, i - start)
            v3CompilerPrintLine(line)
            start = i + 1
        elif text[i] == '\n':
            let line: str = strings.SliceBytes(text, start, i - start)
            v3CompilerPrintLine(line)
            start = i + 1
        i = i + 1

fn v3CompilerRoot(): str =
    let fallbackRoot = os.GetCurrentDir()
    var rootDir: str = fallbackRoot
    let envRoot = os.GetEnv("CHENG_V3_ROOT")
    if len(envRoot) > 0:
        rootDir = envRoot
    return rootDir

fn v3CompilerUsage(rootDir: str) =
    let lines = crun.v3CompilerUsageLines(rootDir)
    for i in 0..<lines.len:
        v3CompilerPrintLine(lines[i])

fn v3CompilerR2cReactV3Help() =
    v3CompilerPrintLine("usage: cheng r2c-react-v3 <subcommand> [args]")
    v3CompilerPrintLine("subcommands: help, status, frontend, static-surface, semantic-surface, codegen-surface, discover-truth-routes, capture-truth, truth-compare, compare-truth, exec-route-matrix, compare-truth-matrix, native-gui-bundle, native-gui-runtime, run-native-gui, replay-hit-inspector, compile")
    v3CompilerPrintLine("frontend flags: --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...]")
    v3CompilerPrintLine("static-surface flags: --repo <path> [--tsx-ast <file>] [--out-dir <dir>] [--runtime-root <dir> ...] [--asset-root <dir> ...]")
    v3CompilerPrintLine("semantic-surface flags: --repo <path> [--tsx-ast <file>] [--out-dir <dir>] [--runtime-root <dir> ...]")
    v3CompilerPrintLine("discover-truth-routes flags: --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...]")
    v3CompilerPrintLine("capture-truth flags: --repo <path> --route <state> [--out-dir <dir>] [--base-url <url>] [--chrome <bin>] [--width <n>] [--height <n>] [--truth-flag <0|1>] [--debug-port <n>] [--wait-ms <n>]")
    v3CompilerPrintLine("compare-truth flags: --exec-snapshot <file> --truth-trace <file> [--codegen-manifest <file>] [--truth-state <state>] [--out <file>]")
    v3CompilerPrintLine("exec-route-matrix flags: (--route-catalog <file> | --tsx-ast <file>) --exec-snapshot <file> --truth-routes-file <file> [--codegen-manifest <file>] [--truth-trace <file>] [--out <file>]")
    v3CompilerPrintLine("compare-truth-matrix flags: --exec-route-matrix <file> --truth-trace <file> [--codegen-manifest <file>] [--out <file>]")
    v3CompilerPrintLine("native-gui-runtime flags: --runtime-contract <file> [--state-* ...] [--event-* ...]")
    v3CompilerPrintLine("run-native-gui flags: --click x,y --resize WxH --scroll-y <n> --wait-after-click-ms <n> --focus-item-id <id> --type-text <text> --send-key <key> --inspector-state-out <file> --open-source-on-click")
    v3CompilerPrintLine("replay-hit-inspector flags: --inspector-state <file> --out <file> --open-source")

fn v3CompilerStatus(rootDir: str) =
    let contract = crun.v3CompilerRuntimeContract(rootDir)
    v3CompilerPrintLine("cheng_v3c")
    v3CompilerPrintLine("version=" + contract.version)
    v3CompilerPrintLine("execution=" + contract.executionModel)
    v3CompilerPrintLine("bootstrap_mode=" + contract.bootstrapMode)
    v3CompilerPrintLine("compiler_entry=" + contract.compilerEntry)
    v3CompilerPrintLine("ordinary_command=" + contract.ordinaryCommand)
    v3CompilerPrintLine("ordinary_pipeline=" + contract.ordinaryPipelineState)

fn v3CompilerRequestedTarget(): str =
    var targetTriple: str
    if cmdline.ReadFirstFlagValue("--target", targetTriple):
        let trimmed = strutil.Strip(targetTriple)
        if len(trimmed) > 0:
            return trimmed
    return contracts.v3BootstrapDefaultTarget()

fn v3CompilerStage3CommandPath(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage3")

fn v3CompilerPrintBuildPlan(rootDir: str,
                            args: str[]): int32 =
    let stage3Path = v3CompilerStage3CommandPath(rootDir)
    let logPath = v3path.V3PathAbsolute(rootDir, "artifacts/v3_forward/print-build-plan.local.log")
    if !v3path.V3FileExistsNonEmpty(rootDir, stage3Path):
        v3CompilerPrintErr("v3 compiler: missing stage3 compiler for command: print-build-plan")
        return 2
    var forwardArgs: str[] = ["print-build-plan"]
    for i in 0..<args.len:
        add(forwardArgs, args[i])
    if !v3CompilerRunFileEnvLogged(rootDir,
                                   stage3Path,
                                   forwardArgs,
                                   ["CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"],
                                   logPath,
                                   "print-build-plan"):
        return 2
    let outputRaw = v3path.V3ReadTextFile("", logPath)
    let outputText = strutil.Strip(outputRaw)
    if len(outputText) > 0:
        v3CompilerPrintBlock(outputText)
    return 0

fn v3CompilerVerifyExportVisibility(rootDir: str): int32 =
    let stage3Path = v3CompilerStage3CommandPath(rootDir)
    let logPath = v3path.V3PathAbsolute(rootDir, "artifacts/v3_forward/verify-export-visibility.local.log")
    if !v3path.V3FileExistsNonEmpty(rootDir, stage3Path):
        v3CompilerPrintErr("v3 compiler: missing stage3 compiler for command: verify-export-visibility")
        return 2
    let smokeArgs = [
        "run-host-smokes",
        "--compiler:" + stage3Path,
        "--label:verify_export_stage3",
        "export_visibility_smoke",
        "export_visibility_negative_smoke",
        "strformat_export_negative_smoke"
    ]
    if !v3CompilerRunFileEnvLogged(rootDir,
                                   stage3Path,
                                   smokeArgs,
                                   ["CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"],
                                   logPath,
                                   "verify-export-visibility"):
        v3CompilerPrintErr("v3 compiler: verify-export-visibility failed")
        return 1
    let outputRaw = v3path.V3ReadTextFile("", logPath)
    let outputText = strutil.Strip(outputRaw)
    if len(outputText) > 0:
        v3CompilerPrintBlock(outputText)
    v3CompilerPrintLine("v3 verify-export-visibility ok")
    return 0

fn v3CompilerVerifyExportVisibilityParallel(rootDir: str): int32 =
    let stage3Path = v3CompilerStage3CommandPath(rootDir)
    let logPath = v3path.V3PathAbsolute(rootDir, "artifacts/v3_forward/verify-export-visibility-parallel.local.log")
    if !v3path.V3FileExistsNonEmpty(rootDir, stage3Path):
        v3CompilerPrintErr("v3 compiler: missing stage3 compiler for command: verify-export-visibility-parallel")
        return 2
    if !v3CompilerRunFileEnvLogged(rootDir,
                                   stage3Path,
                                   ["verify-export-visibility-parallel"],
                                   ["CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"],
                                   logPath,
                                   "verify-export-visibility-parallel"):
        v3CompilerPrintErr("v3 compiler: verify-export-visibility-parallel failed")
        return 1
    let outputRaw = v3path.V3ReadTextFile("", logPath)
    let outputText = strutil.Strip(outputRaw)
    if len(outputText) > 0:
        v3CompilerPrintBlock(outputText)
    v3CompilerPrintLine("v3 verify-export-visibility-parallel ok")
    return 0

fn v3CompilerWriteOptionalReport(rootDir: str,
                                 rawPath: str,
                                 report: str): bool =
    if len(rawPath) <= 0:
        return true
    var text = report
    text = text + "\n"
    return v3path.V3WriteTextFile(rootDir, rawPath, text)

fn v3CompilerBridgeCompilerPath(rootDir: str): str =
    let noHandoffText = strutil.Strip(os.GetEnv("CHENG_V3_NO_BACKEND_DRIVER_HANDOFF"))
    if len(noHandoffText) > 0 && noHandoffText != "0":
        return ""
    let stage3 = v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage3")
    if v3path.V3FileExistsNonEmpty(rootDir, stage3):
        return stage3
    let backendDriver = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver/cheng")
    if v3path.V3FileExistsNonEmpty(rootDir, backendDriver):
        return backendDriver
    let stage2 = v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage2")
    if v3path.V3FileExistsNonEmpty(rootDir, stage2):
        return stage2
    let stage1 = v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage1")
    if v3path.V3FileExistsNonEmpty(rootDir, stage1):
        return stage1
    let stage0 = v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage0")
    if v3path.V3FileExistsNonEmpty(rootDir, stage0):
        return stage0
    return ""

fn v3CompilerCurrentExecutablePath(rootDir: str): str =
    let raw = strutil.Strip(cmdline.ProgramName())
    if len(raw) <= 0:
        return ""
    return v3path.V3PathAbsolute(rootDir, raw)

fn v3CompilerBackendDriverReadyOverride(rootDir: str,
                                        backendDriverPath: str): bool =
    let readyText = strutil.Strip(os.GetEnv("CHENG_V3_BACKEND_DRIVER_READY"))
    if len(readyText) <= 0 || readyText == "0":
        return false
    let currentPath = v3CompilerCurrentExecutablePath(rootDir)
    if len(currentPath) <= 0:
        return false
    return currentPath == backendDriverPath &&
           v3path.V3FileExistsNonEmpty(rootDir, backendDriverPath)

fn v3CompilerEnsureBootstrapBridge(rootDir: str,
                                   context: str): bool =
    let snapshot = contracts.v3BootstrapSnapshotDefault(rootDir)
    if v3CompilerBootstrapBridgeFresh(rootDir, snapshot):
        return true
    if v3CompilerBootstrapBridge(rootDir) == 0:
        return true
    v3CompilerPrintErr("v3 compiler: bootstrap bridge failed inside " + context)
    return false

fn v3CompilerBackendDriverFresh(rootDir: str,
                                backendDriverPath: str): bool =
    if !v3path.V3FileExistsNonEmpty(rootDir, backendDriverPath):
        return false
    if !v3path.V3PathFileExists(backendDriverPath + ".v3.map"):
        return false
    let currentCompiler = v3CompilerBridgeCompilerPath(rootDir)
    if len(currentCompiler) > 0 &&
       currentCompiler != backendDriverPath &&
       v3CompilerPathNewerThan(rootDir, currentCompiler, backendDriverPath):
        return false
    let freshInputs = [
        v3path.V3PathAbsolute(rootDir, "v3/src/tooling/compiler_main.cheng"),
        buildplan.v3BackendBuildPlanBackendDriverEntryPath(rootDir),
        v3path.V3PathAbsolute(rootDir, "v3/src/tooling/compiler_runtime.cheng"),
        v3path.V3PathAbsolute(rootDir, "v3/src/tooling/compiler_request.cheng"),
        v3path.V3PathAbsolute(rootDir, "v3/src/tooling/host_ops.cheng"),
        v3path.V3PathAbsolute(rootDir, "v3/src/tooling/path.cheng"),
        v3path.V3PathAbsolute(rootDir, "v3/src/runtime/program_support_backend_v3.cheng"),
        v3path.V3PathAbsolute(rootDir, "v3/src/runtime/program_support_host_runtime_v3.cheng"),
        v3path.V3PathAbsolute(rootDir, "v3/src/runtime/debug_runtime_stub_v3.cheng"),
        v3path.V3PathAbsolute(rootDir, "v3/src/runtime/core_runtime_provider_darwin_v3.cheng"),
        v3path.V3PathAbsolute(rootDir, "v3/src/runtime/core_runtime_provider_linux_v3.cheng"),
        v3path.V3PathAbsolute(rootDir, "src/std/os_host_process.cheng"),
        v3path.V3PathAbsolute(rootDir, "src/std/os.Cheng")
    ]
    for i in 0..<freshInputs.len:
        if v3CompilerPathNewerThan(rootDir, freshInputs[i], backendDriverPath):
            return false
    return true

fn v3CompilerEnsureBackendDriver(rootDir: str,
                                 context: str): bool =
    if !v3CompilerEnsureBootstrapBridge(rootDir, context):
        return false
    let backendDriver = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver/cheng")
    if v3CompilerBackendDriverReadyOverride(rootDir, backendDriver):
        return true
    if v3CompilerBackendDriverFresh(rootDir, backendDriver):
        return true
    if v3CompilerBuildBackendDriver(rootDir) == 0:
        return true
    v3CompilerPrintErr("v3 compiler: backend driver build failed inside " + context)
    return false

fn v3CompilerBootstrapFreshInputsReady(rootDir: str,
                                       stage3Path: str): bool =
    let snapshotPath = contracts.v3BootstrapSnapshotPath(rootDir)
    if v3path.V3PathFileExists(snapshotPath):
        let snapshotText = v3path.V3ReadTextFile(rootDir, snapshotPath)
        let raw = strutil.Strip(contracts.v3BootstrapLineValue(snapshotText, "fresh_input_paths"))
        if len(raw) > 0:
            var start: int32 = 0
            for i in 0..len(raw):
                var itemEnd = false
                if i == len(raw):
                    itemEnd = true
                elif raw[i] == ',':
                    itemEnd = true
                if !itemEnd:
                    continue
                let item = strutil.Strip(strings.SliceBytes(raw, start, i - start))
                if len(item) > 0 && v3CompilerPathNewerThan(rootDir, item, stage3Path):
                    return false
                start = i + 1
            return true
    return !v3CompilerPathNewerThan(rootDir, contracts.v3BootstrapSeedSourcePath(rootDir), stage3Path) &&
           !v3CompilerPathNewerThan(rootDir, contracts.v3BootstrapStage1SourcePath(rootDir), stage3Path) &&
           !v3CompilerPathNewerThan(rootDir,
                                    contracts.v3BootstrapCompilerEntrySourcePath(rootDir),
                                    stage3Path) &&
           !v3CompilerPathNewerThan(rootDir,
                                    contracts.v3BootstrapCompilerRuntimeSourcePath(rootDir),
                                    stage3Path) &&
           !v3CompilerPathNewerThan(rootDir,
                                    contracts.v3BootstrapCompilerRequestSourcePath(rootDir),
                                    stage3Path) &&
           !v3CompilerPathNewerThan(rootDir,
                                    contracts.v3BootstrapGateMainSourcePath(rootDir),
                                    stage3Path)

fn v3CompilerForwardsToStage3(cmd: str): bool =
    if cmd == "scan-hotpath":
        return true
    if cmd == "run-smokes" || cmd == "print-bootstrap" ||
       cmd == "bootstrap-bridge" || cmd == "build-backend-driver" || cmd == "compile-exe":
        return true
    if cmd == "debug-report" || cmd == "print-symbols" || cmd == "print-line-map":
        return true
    if cmd == "print-object" || cmd == "print-elf" || cmd == "print-asm":
        return true
    if cmd == "verify-backend-driver-command-surface" ||
       cmd == "verify-chain-node-resilience" ||
       cmd == "verify-r2c-react-v3-surface" ||
       cmd == "verify-debug-tools" ||
       cmd == "verify-orphan-guard" ||
       cmd == "verify-debug-runtime" ||
       cmd == "verify-debug-profile":
        return true
    if cmd == "verify-diloco":
        return true
    if cmd == "profile-run" || cmd == "profile-report" || cmd == "crash-report":
        return true
    if cmd == "run-host-smokes" || cmd == "run-stage23-libp2p-smokes" || cmd == "slice-gate":
        return true
    if cmd == "build-zero-exit" || cmd == "build-panic-trace" || cmd == "build-bounds-trace":
        return true
    if cmd == "build-signal-trace" || cmd == "build-call-chain" || cmd == "build-ffi-handle":
        return true
    if cmd == "build-bft-state-machine" || cmd == "deploy-bft-validator-three-node":
        return true
    if cmd == "verify-bft-validator-three-node" || cmd == "status-bft-validator-three-node":
        return true
    if cmd == "stop-bft-validator-three-node" || cmd == "bench-bft-validator-three-node":
        return true
    if cmd == "build-browser-host-wasm" || cmd == "build-rwad-bft-state-machine":
        return true
    if cmd == "build-program-selfhost" || cmd == "build-chain-node":
        return true
    if cmd == "build-linux-nolibc-exe" || cmd == "build-chain-node-linux":
        return true
    if cmd == "build-rwad-bft-linux" || cmd == "run-linux-object-smokes":
        return true
    if cmd == "run-udp-importc-smoke" || cmd == "run-wasm-smokes":
        return true
    if cmd == "run-browser-host-wasm-smoke" || cmd == "run-chain-node-cli-smoke":
        return true
    if cmd == "run-chain-node-process-smoke" || cmd == "run-chain-node-three-node-smoke":
        return true
    if cmd == "run-chain-node-resilience-smoke":
        return true
    if cmd == "run-tailnet-control-smoke" || cmd == "run-fresh-node-selfhost-gate":
        return true
    if cmd == "run-migration-gate" || cmd == "run-browser-webrtc-smokes":
        return true
    if cmd == "r2c-react-v3" || cmd == "r2c-react-v3-controller" || cmd == "vpn-proxy":
        return true
    if cmd == "emit-csg" || cmd == "migrate-csg" || cmd == "verify-world" ||
       cmd == "world-sync" || cmd == "prove-equivalence" || cmd == "prove-migration" ||
       cmd == "publish-world" || cmd == "fresh-node-selfhost" || cmd == "selfhost-build":
        return true
    if cmd == "system-link-exec":
        return true
    if cmd == "run-tcp-twoproc-smoke" || cmd == "run-quic-twoproc-smoke":
        return true
    return false

fn v3CompilerForwardStage3Command(rootDir: str,
                                  cmd: str,
                                  args: str[]): int32 =
    let stage3Path = contracts.v3BootstrapStage3Path(rootDir)
    if !v3path.V3FileExistsNonEmpty(rootDir, stage3Path):
        v3CompilerPrintErr("v3 compiler: missing stage3 compiler for command: " + cmd)
        return 2
    return v3CompilerForwardToBridge(rootDir, stage3Path, cmd, args)

fn v3CompilerForwardToBridgeEnv(rootDir: str,
                                bridgeCompiler: str,
                                cmd: str,
                                args: str[],
                                envOverrides: str[]): int32 =
    let logDir = v3path.V3PathAbsolute(rootDir, "artifacts/v3_forward")
    if !v3path.V3PathDirExists(logDir):
        let _ = v3path.V3MkdirP(rootDir, logDir)
    var logName = "forward."
    logName = logName + cmd
    logName = logName + ".log"
    let logPath = os.JoinPath(logDir, logName)
    var forwardArgs: str[] = []
    add(forwardArgs, cmd)
    for i in 0..<args.len:
        add(forwardArgs, args[i])
    var forwardEnv: str[] = []
    add(forwardEnv, "CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1")
    for i in 0..<envOverrides.len:
        add(forwardEnv, envOverrides[i])
    let run = hostops.v3RunFileLogged(rootDir,
                                      "forward_" + cmd,
                                      bridgeCompiler,
                                      forwardArgs,
                                      forwardEnv,
                                      rootDir,
                                      0,
                                      logPath)
    var output = run.output
    output = strutil.Strip(output)
    if len(output) > 0:
        v3CompilerPrintErr(output)
    elif run.exitCode != 0:
        v3CompilerPrintErr("v3 compiler: forward command failed: " + cmd)
    return run.exitCode

fn v3CompilerForwardToBridge(rootDir: str,
                             bridgeCompiler: str,
                             cmd: str,
                             args: str[]): int32 =
    return v3CompilerForwardToBridgeEnv(rootDir, bridgeCompiler, cmd, args, [])

fn v3CompilerQuoteShell(value: str): str =
    if len(value) <= 0:
        return "''"
    var out = "'"
    for i in 0..<len(value):
        if value[i] == '\'':
            out = out + "'\"'\"'"
        else:
            out = out + strings.CharToStr(value[i])
    out = out + "'"
    return out

fn v3CompilerFileCommand(filePath: str,
                         argv: str[]): str =
    var command = v3CompilerQuoteShell(filePath)
    for i in 0..<argv.len:
        command = command + " " + v3CompilerQuoteShell(argv[i])
    return command

fn v3CompilerEnvLineValue(text: str, key: str): str =
    let prefix = key + "="
    var start: int32 = 0
    var i: int32 = 0
    while i <= text.len:
        var lineEnd = false
        if i == text.len:
            lineEnd = true
        elif text[i] == '\n':
            lineEnd = true
        if lineEnd:
            let line = strings.SliceBytes(text, start, i - start)
            if line.len >= prefix.len:
                if strings.SliceBytes(line, 0, prefix.len) == prefix:
                    return strings.SliceBytes(line, prefix.len, line.len - prefix.len)
            start = i + 1
        i = i + 1
    return ""

fn v3CompilerAppendKeyValueLine(out: var str,
                                key: str,
                                value: str) =
    out = out + key
    out = out + "="
    out = out + value
    out = out + "\n"

fn v3CompilerAppendSectionLabel(out: var str,
                                label: str) =
    out = out + "\n["
    out = out + label
    out = out + "]\n"

fn v3CompilerPipePair(left: str,
                      right: str): str =
    var out = left
    out = out + "|"
    out = out + right
    return out

fn v3CompilerUnavailableInBackendDriver(cmd: str): int32 =
    v3CompilerPrintErr("v3 compiler: command unavailable in backend_driver: " + cmd)
    return 2

fn v3CompilerSmokeOkText(smokeName: str): str =
    var out = "v3 "
    out = out + smokeName
    out = out + " ok"
    return out

fn v3CompilerJoinCsv(values: str[]): str =
    var out = ""
    for i in 0..<values.len:
        if i > 0:
            out = out + ","
        out = out + values[i]
    return out

fn v3CompilerBoolText(value: bool): str =
    if value:
        return "true"
    return "false"

fn v3CompilerJsonQuote(text: str): str =
    let quote: str = strings.CharToStr(char(34))
    return quote + text + quote

fn v3CompilerR2cReactV3EffectiveRoot(rootDir: str): str =
    let rawRoot = strutil.Strip(cmdline.ReadFlagOrDefault("--root", rootDir))
    if len(rawRoot) <= 0:
        return rootDir
    return v3path.V3PathAbsolute(rootDir, rawRoot)

fn v3CompilerWriteR2cReactV3StatusReport(reportPath: str,
                                         rootDir: str): bool =
    let effectiveRoot = v3CompilerR2cReactV3EffectiveRoot(rootDir)
    let experimentalRoot = v3path.V3PathAbsolute(effectiveRoot, "v3/experimental/r2c-react-v3")
    var report = "{\n"
    report = report + "  \"format\": \"status_report_v1\",\n"
    report = report + "  \"controller\": \"cheng.live_controller\",\n"
    report = report + "  \"workspace_root\": " + v3CompilerJsonQuote(effectiveRoot) + ",\n"
    report = report + "  \"experimental_root\": " + v3CompilerJsonQuote(experimentalRoot) + ",\n"
    report = report + "  \"node_program\": \"node\",\n"
    report = report + "  \"legacy_prototype_path\": " + v3CompilerJsonQuote(os.JoinPath(experimentalRoot, "r2c-react-v3.py")) + ",\n"
    report = report + "  \"tsx_frontend_helper\": " + v3CompilerJsonQuote(os.JoinPath(experimentalRoot, "r2c-react-v3-ts-frontend.mjs")) + ",\n"
    report = report + "  \"static_surface_helper\": " + v3CompilerJsonQuote("") + ",\n"
    report = report + "  \"semantic_surface_helper\": " + v3CompilerJsonQuote("") + ",\n"
    report = report + "  \"codegen_surface_helper\": " + v3CompilerJsonQuote(os.JoinPath(experimentalRoot, "r2c-react-v3-codegen-surface.mjs")) + ",\n"
    report = report + "  \"exec_surface_helper\": " + v3CompilerJsonQuote("") + ",\n"
    report = report + "  \"truth_runtime_helper\": " + v3CompilerJsonQuote(os.JoinPath(experimentalRoot, "r2c-react-v3-truth-runtime.mjs")) + ",\n"
