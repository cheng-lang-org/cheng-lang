fn v3CompilerVerifyDebugRuntime(rootDir: str): int32 =
    let hostTarget = v3CompilerHostTarget()
    if len(hostTarget) <= 0:
        v3CompilerPrintErr("v3 debug runtime: unsupported host target")
        return 1
    let packageRoot = v3path.V3PathAbsolute(rootDir, "v3")
    let ordinarySource = v3path.V3PathAbsolute(rootDir, "v3/src/tests/ordinary_panic_fixture.cheng")
    let toolingSource = v3path.V3PathAbsolute(rootDir, "v3/src/tooling/compiler_main.cheng")
    let ordinaryOutput = v3path.V3PathAbsolute(rootDir, "artifacts/v3_debug_runtime_verify/provider_plan_ordinary")
    let toolingOutput = v3path.V3PathAbsolute(rootDir, "artifacts/v3_debug_runtime_verify/provider_plan_tooling")
    var expectedCoreSource = ""
    if hostTarget == "arm64-apple-darwin" || hostTarget == "x86_64-apple-darwin":
        expectedCoreSource = v3path.V3PathAbsolute(rootDir, "v3/src/runtime/core_runtime_provider_darwin_v3.cheng")
    else:
        expectedCoreSource = v3path.V3PathAbsolute(rootDir, "v3/src/runtime/core_runtime_provider_linux_v3.cheng")
    let expectedDebugSource = v3path.V3PathAbsolute(rootDir, "v3/src/runtime/debug_runtime_stub_v3.cheng")
    let expectedProgramSupportSource = v3path.V3PathAbsolute(rootDir, "v3/src/runtime/program_support_backend_v3.cheng")
    let expectedProgramSupportHostSource = v3path.V3PathAbsolute(rootDir, "v3/src/runtime/program_support_host_runtime_v3.cheng")
    let expectedProgramArgvSource = v3path.V3PathAbsolute(rootDir, "v3/src/runtime/compiler_runtime_program_entry_provider_v3.cheng")
    let expectedToolingArgvSource = v3path.V3PathAbsolute(rootDir, "v3/src/runtime/compiler_runtime_tooling_entry_provider_v3.cheng")
    var ordinarySources: str[] = []
    add(ordinarySources, expectedProgramArgvSource)
    add(ordinarySources, expectedCoreSource)
    add(ordinarySources, expectedDebugSource)
    add(ordinarySources, expectedProgramSupportSource)
    add(ordinarySources, expectedProgramSupportHostSource)
    if !v3CompilerVerifyPureChengProviderPlan(rootDir,
                                              packageRoot,
                                              ordinarySource,
                                              ordinaryOutput,
                                              hostTarget,
                                              ordinarySources):
        return 1
    var toolingSources: str[] = []
    add(toolingSources, expectedToolingArgvSource)
    add(toolingSources, expectedCoreSource)
    add(toolingSources, expectedDebugSource)
    add(toolingSources, expectedProgramSupportSource)
    add(toolingSources, expectedProgramSupportHostSource)
    if !v3CompilerVerifyPureChengProviderPlan(rootDir,
                                              packageRoot,
                                              toolingSource,
                                              toolingOutput,
                                              hostTarget,
                                              toolingSources):
        return 1
    if v3CompilerBuildPanicTrace(rootDir) != 0:
        return 1
    if v3CompilerBuildBoundsTrace(rootDir) != 0:
        return 1
    if v3CompilerBuildSignalTrace(rootDir) != 0:
        return 1
    v3CompilerPrintLine("v3 debug runtime: ok")
    return 0

fn v3CompilerVerifyDebugProfile(rootDir: str): int32 =
    var compiler = ""
    if !v3CompilerEnsureBackendDriverPath(rootDir, "verify-debug-profile", compiler):
        return 1
    let outDir = v3path.V3PathAbsolute(rootDir, "artifacts/v3_debug_profile_verify")
    let packageRoot = v3path.V3PathAbsolute(rootDir, "v3")
    let src = v3path.V3PathAbsolute(rootDir, "v3/src/tests/ordinary_profile_hotspots_fixture.cheng")
    let outBin = os.JoinPath(outDir, "ordinary_profile_hotspots_fixture")
    let report = os.JoinPath(outDir, "profile.txt")
    let rawReport = os.JoinPath(outDir, "profile.raw.txt")
    let compileRun = v3CompilerCompileExe(rootDir,
                                          "verify_debug_profile",
                                          compiler,
                                          packageRoot,
                                          src,
                                          outBin,
                                          "arm64-apple-darwin",
                                          "artifacts/v3_debug_profile_verify/ordinary_profile_hotspots_fixture.compile.log")
    if v3CompilerLoggedRunFailed(compileRun):
        return compileRun.exitCode
    let run = v3CompilerRunFileLoggedEnv(rootDir,
                                         "verify_debug_profile_run",
                                         outBin,
                                         [],
                                         [
                                             "CHENG_V3_PROFILE_ENABLE=1",
                                             "CHENG_V3_PROFILE_HZ=200",
                                             "CHENG_V3_PROFILE_RAW_OUT=" + rawReport
                                         ],
                                         20,
                                         "artifacts/v3_debug_profile_verify/ordinary_profile_hotspots_fixture.run.log")
    if v3CompilerLoggedRunFailed(run):
        return run.exitCode
    if !os.FileExists(rawReport):
        v3CompilerPrintErr("v3 debug profile: missing raw report")
        return 1
    let rawReportText = v3path.V3ReadTextFile("", rawReport)
    if !v3CompilerOutputContains(rawReportText, "v3_profile_raw_v1") ||
       !v3CompilerOutputContains(rawReportText, "sample\t0x"):
        v3CompilerPrintErr("v3 debug profile: invalid raw report")
        return 1
    let transformRun = v3CompilerRunFileLoggedEnv(rootDir,
                                                  "verify_debug_profile_transform",
                                                  compiler,
                                                  [
                                                      "profile-report",
                                                      "--in:" + rawReport,
                                                      "--out:" + report
                                                  ],
                                                  [],
                                                  20,
                                                  "artifacts/v3_debug_profile_verify/profile-report.run.log")
    if v3CompilerLoggedRunFailed(transformRun):
        return transformRun.exitCode
    if !os.FileExists(report):
        v3CompilerPrintErr("v3 debug profile: missing report")
        return 1
    let reportText = v3path.V3ReadTextFile("", report)
    if !v3CompilerOutputContains(reportText, "v3_profile_v1") ||
       !v3CompilerOutputContains(reportText, "hot_function[0]=") ||
       !v3CompilerOutputContains(reportText, "hot_pc[0]=") ||
       !v3CompilerOutputContains(reportText, "ordinary_profile_hotspots_fixture.cheng"):
        v3CompilerPrintErr("v3 debug profile: invalid report")
        return 1
    v3CompilerPrintLine(strutil.Strip(reportText))
    v3CompilerPrintLine("v3 debug profile: ok")
    return 0

fn v3CompilerVerifyLiveBackendDriverSmoke(rootDir: str,
                                          sourcePath: str,
                                          stem: str,
                                          expectedOutput: str,
                                          successText: str): int32 =
    if v3CompilerRequestedTarget() != contracts.v3BootstrapDefaultTarget():
        v3CompilerPrintErr("v3 compiler: verify command only supports host backend_driver target")
        return 1
    var compiler = ""
    if !v3CompilerEnsureBackendDriverPath(rootDir, successText, compiler):
        return 1
    let packageRoot = v3path.V3PathAbsolute(rootDir, "v3")
    let hostTarget = v3CompilerHostTarget()
    var targetTriple = contracts.v3BootstrapDefaultTarget()
    if len(hostTarget) > 0:
        targetTriple = hostTarget
    var smokeOut = ""
    var smokeCompileReportPath = ""
    var smokeCompileLogPath = ""
    var smokeRunLogPath = ""
    if !v3CompilerRunBackendDriverSelftest(rootDir,
                                           packageRoot,
                                           compiler,
                                           targetTriple,
                                           sourcePath,
                                           stem,
                                           expectedOutput,
                                           smokeOut,
                                           smokeCompileReportPath,
                                           smokeCompileLogPath,
                                           smokeRunLogPath):
        return 1
    v3CompilerPrintLine(successText)
    return 0

