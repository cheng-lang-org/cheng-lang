fn v3CompilerTextContainsLegacyToolingMarker(text: str): bool =
    let markers = v3CompilerLegacyToolingMarkers()
    var start = 0
    var i = 0
    while i <= len(markers):
        var lineEnd = false
        if i == len(markers):
            lineEnd = true
        elif markers[i] == '\n':
            lineEnd = true
        if lineEnd:
            let marker = strings.SliceBytes(markers, start, i - start)
            if len(marker) > 0 && strutil.Contains(text, marker):
                return true
            start = i + 1
        i = i + 1
    return false

fn v3CompilerVerifyOrphanGuard(rootDir: str): int32 =
    let toolingDir = v3path.V3PathAbsolute(rootDir, "v3/tooling")
    let shellScan = v3CompilerRunShellLogged(rootDir,
                                             "verify_orphan_guard_shell_scan",
                                             "find " + v3CompilerQuoteShell(toolingDir) + " -maxdepth 1 -type f -name '*.sh'",
                                             "artifacts/v3_gate/orphan_guard_shell_scan.log",
                                             10)
    if v3CompilerLoggedRunFailed(shellScan):
        return shellScan.exitCode
    let shellText = strutil.Strip(shellScan.output)
    if len(shellText) > 0:
        v3CompilerPrintErr("verify_orphan_guard_v3: shell tooling entry not allowed: " + shellText)
        return 1
    let pyScan = v3CompilerRunShellLogged(rootDir,
                                          "verify_orphan_guard_py_scan",
                                          "find " + v3CompilerQuoteShell(toolingDir) + " -maxdepth 1 -type f -name '*.py'",
                                          "artifacts/v3_gate/orphan_guard_py_scan.log",
                                          10)
    if v3CompilerLoggedRunFailed(pyScan):
        return pyScan.exitCode
    var pathStart = 0
    for i in 0..len(pyScan.output):
        var lineEnd = false
        if i == len(pyScan.output):
            lineEnd = true
        elif pyScan.output[i] == '\n':
            lineEnd = true
        elif pyScan.output[i] == '\r':
            lineEnd = true
        if !lineEnd:
            continue
        let path = strutil.Strip(strings.SliceBytes(pyScan.output, pathStart, i - pathStart))
        if len(path) > 0:
            let parts = os.SplitFile(path)
            let fileName = parts.name + parts.ext
            if v3CompilerTextContainsLegacyToolingMarker(fileName):
                v3CompilerPrintErr("verify_orphan_guard_v3: banned tooling entry name: " + path)
                return 1
            let text = v3path.V3ReadTextFile("", path)
            if v3CompilerTextContainsLegacyToolingMarker(text):
                v3CompilerPrintErr("verify_orphan_guard_v3: banned direct process guard ref in " + path)
                return 1
        pathStart = i + 1
    var orphanBefore: str[] = []
    if v3CompilerReadChengOrphanSnapshot(rootDir,
                                         "orphan_guard_before",
                                         "artifacts/v3_gate/orphan_guard_before.log",
                                         orphanBefore) != 0:
        return 1
    if v3CompilerBootstrapBridge(rootDir) != 0:
        return 1
    if v3CompilerBuildBackendDriver(rootDir) != 0:
        return 1
    var orphanAfter: str[] = []
    if v3CompilerReadChengOrphanSnapshot(rootDir,
                                         "orphan_guard_after",
                                         "artifacts/v3_gate/orphan_guard_after.log",
                                         orphanAfter) != 0:
        return 1
    let orphanDelta = v3CompilerCollectNewOrphanKeys(orphanBefore, orphanAfter)
    if orphanDelta.len > 0:
        v3CompilerPrintErr("verify_orphan_guard_v3: new Cheng U/UE process leaked after bootstrap/build")
        for i in 0..<orphanDelta.len:
            v3CompilerPrintErr(orphanDelta[i])
        return 1
    v3CompilerPrintLine("verify_orphan_guard_v3 ok")
    return 0

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let rootDir = v3CompilerRoot()
    let count: int32 = v3CompilerParamCountBridge()
    if count <= 0:
        v3CompilerUsage(rootDir)
        return 0
    let cmd = cmdline.ParamStr(1)
    let args = v3CompilerCollectArgsFrom(2, count)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        v3CompilerUsage(rootDir)
        return 0
    if cmd == "status":
        v3CompilerStatus(rootDir)
        return 0
    if cmd == "print-build-plan":
        return v3CompilerPrintBuildPlan(rootDir, args)
    if cmd == "verify-export-visibility":
        return v3CompilerVerifyExportVisibility(rootDir)
    if cmd == "verify-export-visibility-parallel":
        return v3CompilerVerifyExportVisibilityParallel(rootDir)
    if cmd == "verify-mobile-shell-build-probe":
        return v3CompilerVerifyMobileShellBuildProbe(rootDir)
    if cmd == "host-bridge-audit":
        return v3CompilerHostBridgeAudit(rootDir)
    if cmd == "mobile-shell":
        var outputText: str = ""
        var errorText: str = ""
        let mobileCode: int32 = mshell.v3MobileShellRun(rootDir, args, outputText, errorText)
        let outputTrimmed = strutil.Strip(outputText)
        if len(outputTrimmed) > 0:
            v3CompilerPrintBlock(outputTrimmed)
        let errorTrimmed = strutil.Strip(errorText)
        if len(errorTrimmed) > 0:
            v3CompilerPrintErr(errorTrimmed)
        return mobileCode
    if cmd == "r2c-react-v3":
        if args.len <= 0:
            v3CompilerR2cReactV3Help()
            return 0
        let subcmd = args[0]
        if subcmd == "help" || subcmd == "--help" || subcmd == "-h":
            v3CompilerR2cReactV3Help()
            return 0
        if subcmd == "status":
            return v3CompilerR2cReactV3Status(rootDir)
    if cmd == "verify-x86-linux-remote" ||
       cmd == "run-shared-emit-smokes" ||
       cmd == "r2c-react-v3-fresh-clean-gate" ||
       cmd == "r2c-react-v3-codegen-surface-smoke" ||
       cmd == "r2c-react-v3-truth-compare-smoke" ||
       cmd == "r2c-react-v3-compile-smoke" ||
       cmd == "r2c-react-v3-native-gui-bundle-smoke":
        return v3CompilerUnavailableInBackendDriver(cmd)
    if v3CompilerForwardsToStage3(cmd):
        return v3CompilerForwardStage3Command(rootDir, cmd, args)
    v3CompilerPrintErr("v3 compiler: unknown command: " + cmd)
    v3CompilerUsage(rootDir)
    return 2
