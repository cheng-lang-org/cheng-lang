                return 2
        else:
            let proofRes = v3CompilerEquivalenceProofFromRuntimeFlags(rootDir, plan, proof)
            if IsErr(proofRes):
                v3CompilerPrintErr(Error(proofRes))
                return 2
        proofReport = ceq.v3CompilerEquivalenceProofReport(proof)
        equivalenceChecked = true
    else:
        proof.proofCid = layout.fixedBytes32Zero()
    var decision: ceq.V3CompilerPublishDecision
    let decisionRes = ceq.v3CompilerPublishDecisionMake(channel,
                                                        plan.localUniverse.worldHead.headCid,
                                                        equivalenceChecked,
                                                        proof,
                                                        decision)
    if IsErr(decisionRes):
        v3CompilerPrintErr(Error(decisionRes))
        return 2
    let decisionReport = ceq.v3CompilerPublishDecisionReport(decision)
    if decision.publishAllowed == 0:
        if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, decisionReport):
            v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
            return 2
        v3CompilerPrintErr("v3 compiler: publish blocked by canonical equivalence gate")
        v3CompilerPrintErr(decisionReport)
        if equivalenceChecked:
            if len(migrationReport) > 0:
                v3CompilerPrintErr(migrationReport)
            v3CompilerPrintErr(proofReport)
        return 2
    if !v3CompilerWorldSyncWriteBundle(rootDir, req.outputPath, plan):
        v3CompilerPrintErr("v3 compiler: failed to materialize world bundle: " + req.outputPath)
        return 2
    if equivalenceChecked:
        if !v3path.V3WriteTextFile(rootDir, req.outputPath + ".proof.txt", proofReport + "\n"):
            v3CompilerPrintErr("v3 compiler: failed to write proof: " + req.outputPath + ".proof.txt")
            return 2
    if !v3path.V3WriteTextFile(rootDir, req.outputPath + ".publish.txt", decisionReport + "\n"):
        v3CompilerPrintErr("v3 compiler: failed to write publish gate report: " + req.outputPath + ".publish.txt")
        return 2
    let freshRes = cwlp.v3CompilerWorldFreshNodeSelfhostReport(rootDir, req, plan)
    if IsErr(freshRes):
        v3CompilerPrintErr(Error(freshRes))
        return 2
    let freshReport = Value(freshRes)
    if !v3path.V3WriteTextFile(rootDir, req.outputPath + ".fresh.txt", freshReport + "\n"):
        v3CompilerPrintErr("v3 compiler: failed to write fresh-node report: " + req.outputPath + ".fresh.txt")
        return 2
    let summary = v3CompilerPublishSummary(req.outputPath,
                                           channel,
                                           plan,
                                           proofMode,
                                           equivalenceChecked,
                                           decision) + "\n" + freshReport
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, summary):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    v3CompilerPrintLine(summary)
    return 0

fn v3CompilerSelfhostBuild(rootDir: str,
                           args: str[]): int32 =
    let reqRes = v3CompilerRequestFromRuntimeFlags(rootDir, true)
    if IsErr(reqRes):
        v3CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let planRes = v3CompilerBuildSystemPlanFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        v3CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let report = sexec.v3SystemLinkExecPlanReport(plan)
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    let bridgeCompiler = v3CompilerBridgeCompilerPath(rootDir)
    if len(bridgeCompiler) > 0:
        return v3CompilerForwardToBridge(rootDir, bridgeCompiler, "selfhost-build", args)
    if sexec.v3SystemLinkExecPlanReady(plan):
        v3CompilerPrintErr("v3 compiler: missing live Cheng bridge for selfhost-build")
        v3CompilerPrintErr(report)
        return 2
    elif plan.primaryObjectPlan.missingReasons.len > 0:
        v3CompilerPrintErr("v3 compiler: selfhost primary object machine code not emitted")
    else:
        v3CompilerPrintErr("v3 compiler: selfhost build blocked")
    v3CompilerPrintErr(report)
    return 2

fn v3CompilerTextEndsWith(text: str, suffix: str): bool =
    if len(suffix) > len(text):
        return false
    let start = len(text) - len(suffix)
    for i in 0..<len(suffix):
        if text[start + i] != suffix[i]:
            return false
    return true

fn v3CompilerOutputContains(text: str, needle: str): bool =
    return strutil.Contains(text, needle)

fn v3CompilerRequireOutput(run: hostops.V3LoggedRun,
                           needle: str,
                           label: str): bool =
    if v3CompilerOutputContains(run.output, needle):
        return true
    v3CompilerPrintErr(label + ": missing output: " + needle)
    return false

fn v3CompilerLoggedRunFailed(run: hostops.V3LoggedRun): bool =
    if hostops.v3LoggedRunOk(run):
        return false
    v3CompilerPrintErr(hostops.v3LoggedRunSummary(run))
    let outputText = strutil.Strip(run.output)
    if len(outputText) > 0:
        v3CompilerPrintErr(outputText)
    return true

fn v3CompilerEnsureFileParentDir(rootDir: str, path: str): bool =
    let parts = os.SplitFile(path)
    if len(parts.dir) <= 0:
        return true
    return v3path.V3MkdirP(rootDir, parts.dir)

fn v3CompilerBackendDriverPath(rootDir: str): str =
    let snapshot = contracts.v3BootstrapSnapshotDefault(rootDir)
    return snapshot.backendDriverOut.path

fn v3CompilerEnsureBackendDriverPath(rootDir: str,
                                     context: str,
                                     outCompiler: var str): bool =
    outCompiler = v3CompilerBackendDriverPath(rootDir)
    if v3path.V3FileExistsNonEmpty(rootDir, outCompiler):
        return true
    if !v3CompilerEnsureBackendDriver(rootDir, context):
        return false
    return v3path.V3FileExistsNonEmpty(rootDir, outCompiler)

fn v3CompilerCompileTimeoutSec(): int32 =
    return 300

fn v3CompilerCommandText(filePath: str,
                         argv: str[],
                         envOverrides: str[]): str =
    var out = ""
    if envOverrides.len > 0:
        out = "env"
        for i in 0..<envOverrides.len:
            let envText = envOverrides[i]
            if len(envText) > 0:
                out = out + " "
                out = out + v3CompilerQuoteShell(envText)
    if len(filePath) > 0:
        if len(out) > 0:
            out = out + " "
        out = out + v3CompilerQuoteShell(filePath)
    for i in 0..<argv.len:
        out = out + " "
        out = out + v3CompilerQuoteShell(argv[i])
    return out

fn v3CompilerRunCommandCaptureLogged(rootDir: str,
                                     label: str,
                                     filePath: str,
                                     command: str,
                                     logPath: str): hostops.V3LoggedRun =
    let _ = v3CompilerEnsureFileParentDir(rootDir, logPath)
    let fullCommand = command + " > " + v3CompilerQuoteShell(logPath) + " 2>&1"
    let exitCode = os.ExecCmdStatus(fullCommand, rootDir)
    let outputText = v3path.V3ReadTextFile("", logPath)
    let _logged = v3path.V3WriteTextFile(rootDir, logPath, outputText)
    return hostops.v3LoggedRunZero(label, filePath, logPath, exitCode, outputText)

fn v3CompilerRunFileLoggedEnv(rootDir: str,
                              label: str,
                              filePath: str,
                              argv: str[],
                              envOverrides: str[],
                              timeoutSec: int32,
                              logPath: str): hostops.V3LoggedRun =
    let _ = v3CompilerEnsureFileParentDir(rootDir, logPath)
    let filePathAbs = v3path.V3PathAbsolute(rootDir, filePath)
    if !v3path.V3FileExistsNonEmpty(rootDir, filePathAbs):
        let missingText = hostops.v3HostOpsMissingExecutableText(filePathAbs)
        let _logged = v3path.V3WriteTextFile(rootDir, logPath, missingText)
        return hostops.v3LoggedRunZero(label, filePathAbs, logPath, 127, missingText)
    return hostops.v3RunFileLogged(rootDir,
                                   label,
                                   filePathAbs,
                                   argv,
                                   envOverrides,
                                   rootDir,
                                   timeoutSec,
                                   logPath)

fn v3CompilerCompileExeEnv(rootDir: str,
                           label: str,
                           compilerPath: str,
                           packageRoot: str,
                           sourcePath: str,
                           outPath: str,
                           target: str,
                           logPath: str,
                           envOverrides: str[]): hostops.V3LoggedRun =
    let compilerAbs = v3path.V3PathAbsolute(rootDir, compilerPath)
    let _ = v3CompilerEnsureFileParentDir(rootDir, outPath)
    let _ = v3CompilerEnsureFileParentDir(rootDir, logPath)
    let run = v3CompilerRunFileLoggedEnv(rootDir,
                                         label,
                                         compilerAbs,
                                         [
                                             "system-link-exec",
                                             "--root", packageRoot,
                                             "--in", sourcePath,
                                             "--emit", "exe",
                                             "--target", target,
                                             "--out", outPath
                                         ],
                                         envOverrides,
                                         v3CompilerCompileTimeoutSec(),
                                         logPath)
    if hostops.v3LoggedRunOk(run) && !os.FileExists(outPath):
        let outputText = run.output + "v3 compiler: compile missing output: " + outPath + "\n"
        let _logged = v3path.V3WriteTextFile(rootDir, logPath, outputText)
        return hostops.v3LoggedRunZero(label, compilerAbs, logPath, 1, outputText)
    return run

fn v3CompilerCompileExe(rootDir: str,
                        label: str,
                        compilerPath: str,
                        packageRoot: str,
                        sourcePath: str,
                        outPath: str,
                        target: str,
                        logPath: str): hostops.V3LoggedRun =
    return v3CompilerCompileExeEnv(rootDir,
                                   label,
                                   compilerPath,
                                   packageRoot,
                                   sourcePath,
                                   outPath,
                                   target,
                                   logPath,
                                   [])

fn v3CompilerProviderSourcesAllPureCheng(paths: str[]): bool =
    if paths.len <= 0:
        return false
    for i in 0..<paths.len:
        if !v3CompilerTextEndsWith(paths[i], ".cheng"):
            return false
    return true

fn v3CompilerProviderSourcesContain(paths: str[], expected: str): bool =
    for i in 0..<paths.len:
        if paths[i] == expected:
            return true
    return false

fn v3CompilerVerifyPureChengProviderPlan(rootDir: str,
                                         packageRoot: str,
                                         sourcePath: str,
                                         outputPath: str,
                                         target: str,
                                         expectedSources: str[]): bool =
    let req = creq.v3CompilerRequestNew(packageRoot,
                                        sourcePath,
                                        outputPath,
                                        target,
                                        creq.v3EmitExe,
                                        "")
    let planRes = sexec.v3BuildSystemLinkExecPlan(rootDir, req)
    if IsErr(planRes):
        v3CompilerPrintErr("v3 pure provider plan: " + Error(planRes))
        return false
    let plan = Value(planRes)
    if !v3CompilerProviderSourcesAllPureCheng(plan.objectPlan.providerSourcePaths):
        v3CompilerPrintErr("v3 pure provider plan: non-Cheng provider source detected")
        return false
    for i in 0..<expectedSources.len:
        if !v3CompilerProviderSourcesContain(plan.objectPlan.providerSourcePaths, expectedSources[i]):
            v3CompilerPrintErr("v3 pure provider plan: missing provider source: " + expectedSources[i])
            return false
    return true

fn v3CompilerHostTarget(): str =
    let detected = contracts.v3BootstrapDetectHostTarget()
    if detected == "arm64-apple-darwin" ||
       detected == "x86_64-apple-darwin" ||
       detected == "x86_64-unknown-linux-gnu" ||
       detected == "aarch64-unknown-linux-gnu":
        return detected
    return ""

fn v3CompilerBuildPanicTrace(rootDir: str): int32 =
    var compiler = ""
    if !v3CompilerEnsureBackendDriverPath(rootDir, "verify-debug-runtime panic", compiler):
        return 1
    let outDir = v3path.V3PathAbsolute(rootDir, "artifacts/v3_panic_trace")
    let packageRoot = v3path.V3PathAbsolute(rootDir, "v3")
    let src = v3path.V3PathAbsolute(rootDir, "v3/src/tests/ordinary_panic_fixture.cheng")
    let outBin = os.JoinPath(outDir, "ordinary_panic_fixture")
    let reportPath = os.JoinPath(outDir, "ordinary_panic_fixture.report.txt")
    let compileRun = v3CompilerCompileExe(rootDir,
                                          "build_panic_trace",
                                          compiler,
                                          packageRoot,
                                          src,
                                          outBin,
                                          "arm64-apple-darwin",
                                          "artifacts/v3_panic_trace/ordinary_panic_fixture.compile.log")
    if v3CompilerLoggedRunFailed(compileRun):
        return compileRun.exitCode
    let lineMap = outBin + ".v3.map"
    if !os.FileExists(lineMap):
        v3CompilerPrintErr("v3 panic-trace: missing line-map sidecar")
        return 1
    let lineMapText = v3path.V3ReadTextFile("", lineMap)
    if !v3CompilerOutputContains(lineMapText, "v3_line_map_v1") ||
       !v3CompilerOutputContains(lineMapText, "ordinary_panic_fixture.cheng"):
        v3CompilerPrintErr("v3 panic-trace: invalid line-map")
        return 1
    let run = v3CompilerRunFileLoggedEnv(rootDir,
                                         "build_panic_trace_run",
                                         outBin,
                                         [],
                                         [],
                                         20,
                                         "artifacts/v3_panic_trace/ordinary_panic_fixture.run.log")
    let runText = strutil.Strip(run.output)
    if len(runText) > 0:
        v3CompilerPrintLine(runText)
    if run.exitCode == 0:
        v3CompilerPrintErr("v3 panic-trace: expected non-zero exit")
        return 1
    let transformRun = v3CompilerRunFileLoggedEnv(rootDir,
                                                  "build_panic_trace_report",
                                                  compiler,
                                                  [
                                                      "crash-report",
                                                      "--in:" + run.logPath,
                                                      "--out:" + reportPath
                                                  ],
                                                  [],
                                                  20,
                                                  "artifacts/v3_panic_trace/ordinary_panic_fixture.crash-report.log")
    if v3CompilerLoggedRunFailed(transformRun):
        return transformRun.exitCode
    if !os.FileExists(reportPath):
        v3CompilerPrintErr("v3 panic-trace: missing report")
        return 1
    let reportText = v3path.V3ReadTextFile("", reportPath)
    if !v3CompilerRequireOutput(run, "v3 panic fixture", "v3 panic-trace") ||
       !v3CompilerRequireOutput(run, "v3_crash_raw_v1", "v3 panic-trace") ||
       !v3CompilerRequireOutput(run, "reason=panic mode=backtrace", "v3 panic-trace") ||
       !v3CompilerRequireOutput(run, "ordinary_panic_fixture.cheng:", "v3 panic-trace") ||
       !v3CompilerOutputContains(reportText, "[cheng-v3] v3_crash_report_v1") ||
       !v3CompilerOutputContains(reportText, "[cheng-v3] reason=panic mode=backtrace") ||
       !v3CompilerOutputContains(reportText, "ordinary_panic_fixture.cheng:"):
        return 1
    v3CompilerPrintLine(strutil.Strip(reportText))
    return 0

