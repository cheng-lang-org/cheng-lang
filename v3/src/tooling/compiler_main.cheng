fn v3CompilerForwardStage3Command(rootDir: str,
                                  cmd: str,
                                  args: str[]): int32 =
    if !v3CompilerEnsureBootstrapBridge(rootDir, cmd):
        return 2
    let stage3Path = contracts.v3BootstrapStage3Path(rootDir)
    if !v3path.v3FileExistsNonEmpty(rootDir, stage3Path):
        v3CompilerPrintErr("v3 compiler: missing stage3 compiler for command: " + cmd)
        return 2
    return v3CompilerForwardToBridge(rootDir, stage3Path, cmd, args)

fn v3CompilerForwardToBridge(rootDir: str,
                             bridgeCompiler: str,
                             cmd: str,
                             args: str[]): int32 =
    var command = v3CompilerQuoteShell(bridgeCompiler)
    let quotedCmd = v3CompilerQuoteShell(cmd)
    command = command + " "
    command = command + quotedCmd
    for i in 0..<args.len:
        let quotedArg = v3CompilerQuoteShell(args[i])
        command = command + " "
        command = command + quotedArg
    let directRc = os.execCmdStatus(command, rootDir)
    if directRc == 0 || directRc == 124:
        return directRc
    let capture = os.execCmdEx(command, uint64(1), rootDir)
    let output = strutil.strip(os.execCmdResultOutput(capture))
    if len(output) > 0:
        v3CompilerPrintErr(output)
    return os.execCmdResultExitCode(capture)

fn v3CompilerQuoteShell(value: str): str =
    if len(value) <= 0:
        return "''"
    var out = "'"
    out = out + value
    out = out + "'"
    return out

fn v3CompilerEnvLineValue(text: str, key: str): str =
    let prefix = key + "="
    var start: int32 = 0
    var i: int32 = 0
    while i <= text.len:
        let atEnd: bool = i == text.len
        if atEnd || text[i] == '\n':
            let line = strings.sliceBytes(text, start, i - start)
            if line.len >= prefix.len &&
               strings.sliceBytes(line, 0, prefix.len) == prefix:
                return strings.sliceBytes(line, prefix.len, line.len - prefix.len)
            start = i + 1
        i = i + 1
    return ""

fn v3CompilerAppendKeyValueLine(out: var str,
                                key: str,
                                value: str) =
    out = out + key
    out = out + "="
    out = out + value
    out = out + "\n"

fn v3CompilerAppendSectionLabel(out: var str,
                                label: str) =
    out = out + "\n["
    out = out + label
    out = out + "]\n"

fn v3CompilerPipePair(left: str,
                      right: str): str =
    var out = left
    out = out + "|"
    out = out + right
    return out

fn v3CompilerSmokeOkText(smokeName: str): str =
    var out = "v3 "
    out = out + smokeName
    out = out + " ok"
    return out

fn v3CompilerJoinCsv(values: str[]): str =
    var out = ""
    for i in 0..<values.len:
        if i > 0:
            out = out + ","
        out = out + values[i]
    return out

fn v3CompilerBoolText(value: bool): str =
    if value:
        return "true"
    return "false"

fn v3CompilerRemoteSummaryPath(outDir: str,
                               hostLabel: str): str =
    return os.joinPath(outDir, hostLabel + ".summary.txt")

fn v3CompilerRemoteLogPath(outDir: str,
                           hostLabel: str,
                           stem: str): str =
    return os.joinPath(outDir, hostLabel + "." + stem + ".log")

fn v3CompilerRemoteOrdinarySmokeNames(): str[] =
    let singleRaw = cmdline.readFlagOrDefault("--smoke-name", "")
    let singleSmoke = strutil.strip(singleRaw)
    var out: str[] = []
    if len(singleSmoke) > 0:
        add(out, singleSmoke)
        return out
    add(out, "ordinary_zero_exit_fixture")
    add(out, "host_process_exec_file_direct_seq_smoke")
    add(out, "host_process_exec_file_capture_smoke")
    add(out, "msquic_bindtext_expr_smoke")
    return out

fn v3CompilerRemoteSmokeExpectedText(smokeName: str): str =
    if smokeName == "ordinary_zero_exit_fixture":
        return ""
    return v3CompilerSmokeOkText(smokeName)

fn v3CompilerRemoteSmokeRequireEmptyOutput(smokeName: str): bool =
    return smokeName == "ordinary_zero_exit_fixture"

fn v3CompilerRemotePlanMatches(stage3Text: str,
                               backendText: str): bool =
    let left = strutil.strip(stage3Text)
    let right = strutil.strip(backendText)
    return left == right

fn v3CompilerRunProgramCaptureLogged(rootDir: str,
                                     label: str,
                                     programName: str,
                                     argv: str[],
                                     logPath: str,
                                     context: str,
                                     outputOut: var str): bool =
    let run = hostops.v3RunProgramLogged(rootDir,
                                         label,
                                         programName,
                                         argv,
                                         [],
                                         rootDir,
                                         0,
                                         logPath)
    outputOut = run.output
    if hostops.v3LoggedRunOk(run):
        return true
    let output = strutil.strip(run.output)
    if len(output) > 0:
        v3CompilerPrintErr(output)
    else:
        v3CompilerPrintErr("v3 compiler: " + context + " failed")
    return false

fn v3CompilerRemoteTransportRetryable(output: str): bool =
    let trimmed = strutil.strip(output)
    return strutil.contains(trimmed, "Connection timed out during banner exchange") ||
           (strutil.contains(trimmed, "Connection to ") && strutil.contains(trimmed, " timed out")) ||
           strutil.contains(trimmed, "No route to host") ||
           strutil.contains(trimmed, "Connection reset by peer") ||
           strutil.contains(trimmed, "kex_exchange_identification") ||
           strutil.contains(trimmed, "Connection closed by remote host")

fn v3CompilerRunRemoteTransportCommand(rootDir: str,
                                       label: str,
                                       programName: str,
                                       argv: str[],
                                       logPath: str,
                                       context: str,
                                       outputOut: var str): bool =
    var lastOutput = ""
    for attempt in 0..<3:
        if v3CompilerRunProgramCaptureLogged(rootDir,
                                             label,
                                             programName,
                                             argv,
                                             logPath,
                                             context,
                                             lastOutput):
            outputOut = lastOutput
            return true
        if attempt >= 2 || !v3CompilerRemoteTransportRetryable(lastOutput):
            outputOut = lastOutput
            return false
        v3CompilerPrintLine("remote transport retry " + intToStr(attempt + 1) + " " + context)
        os.sleepMs((attempt + 1) * 1000)
    outputOut = lastOutput
    return false

fn v3CompilerRunRemoteCommand(rootDir: str,
                              sshTarget: str,
                              label: str,
                              remoteArgv: str[],
                              logPath: str,
                              context: str,
                              outputOut: var str): bool =
    var argv: str[] = []
    add(argv, "-n")
    add(argv, "-o")
    add(argv, "BatchMode=yes")
    add(argv, "-o")
    add(argv, "ConnectTimeout=8")
    add(argv, "-o")
    add(argv, "ServerAliveInterval=5")
    add(argv, "-o")
    add(argv, "ServerAliveCountMax=3")
    add(argv, sshTarget)
    for i in 0..<remoteArgv.len:
        add(argv, remoteArgv[i])
    return v3CompilerRunRemoteTransportCommand(rootDir,
                                               label,
                                               "ssh",
                                               argv,
                                               logPath,
                                               context,
                                               outputOut)

fn v3CompilerRunRemoteRsync(rootDir: str,
                            sshTarget: str,
                            label: str,
                            localSource: str,
                            remoteRoot: str,
                            logPath: str,
                            context: str,
                            outputOut: var str): bool =
    let remoteShell = "ssh -o BatchMode=yes -o ConnectTimeout=8 -o ServerAliveInterval=5 -o ServerAliveCountMax=3"
    let rsyncDest = sshTarget + ":" + remoteRoot + "/"
    let argv = [
        "-a",
        "-e", remoteShell,
        "--delete",
        "--exclude", ".git",
        "--exclude", "artifacts",
        "--exclude", "chengcache",
        "--exclude", "node_modules",
        localSource,
        rsyncDest
    ]
    return v3CompilerRunRemoteTransportCommand(rootDir,
                                               label,
                                               "rsync",
                                               argv,
                                               logPath,
                                               context,
                                               outputOut)

fn v3CompilerWriteRemoteSummary(rootDir: str,
                                summaryPath: str,
                                summaryText: str,
                                verified: bool): bool =
    var out = summaryText
    v3CompilerAppendKeyValueLine(out, "verified", v3CompilerBoolText(verified))
    return v3path.v3WriteTextFile(rootDir, summaryPath, out)

fn v3CompilerVerifyRemoteExeSmoke(rootDir: str,
                                  outDir: str,
                                  hostLabel: str,
                                  sshTarget: str,
                                  remoteRoot: str,
                                  smokeName: str,
                                  summaryText: var str): bool =
    let remotePackageRoot = remoteRoot + "/v3"
    let remoteBackend = remoteRoot + "/artifacts/v3_backend_driver/cheng"
    var remoteSmokeOut = remoteRoot
    remoteSmokeOut = remoteSmokeOut + "/artifacts/v3_backend_driver/"
    remoteSmokeOut = remoteSmokeOut + smokeName
    remoteSmokeOut = remoteSmokeOut + ".selftest"
    let compileLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, smokeName + ".compile")
    let runLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, smokeName + ".run")
    let reportPath = remoteSmokeOut + ".report.txt"
    var remoteSmokeSource = remotePackageRoot
    remoteSmokeSource = remoteSmokeSource + "/src/tests/"
    remoteSmokeSource = remoteSmokeSource + smokeName
    remoteSmokeSource = remoteSmokeSource + ".cheng"
    let remoteEnvRoot = "CHENG_V3_ROOT=" + remoteRoot
    var compileLabel = hostLabel
    compileLabel = compileLabel + "_"
    compileLabel = compileLabel + smokeName
    compileLabel = compileLabel + "_compile"
    var runLabel = hostLabel
    runLabel = runLabel + "_"
    runLabel = runLabel + smokeName
    runLabel = runLabel + "_run"
    var compileArgv: str[] = []
    add(compileArgv, "env")
    add(compileArgv, remoteEnvRoot)
    add(compileArgv, remoteBackend)
    add(compileArgv, "system-link-exec")
    add(compileArgv, "--root:" + remotePackageRoot)
    add(compileArgv, "--in:" + remoteSmokeSource)
    add(compileArgv, "--emit:exe")
    add(compileArgv, "--target:x86_64-unknown-linux-gnu")
    add(compileArgv, "--out:" + remoteSmokeOut)
    add(compileArgv, "--report-out:" + reportPath)
    var compileOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   compileLabel,
                                   compileArgv,
                                   compileLogPath,
                                   "remote x86 smoke compile " + smokeName,
                                   compileOut):
        v3CompilerAppendKeyValueLine(summaryText, smokeName + "_compile_log", compileLogPath)
        v3CompilerAppendKeyValueLine(summaryText, smokeName + "_run_log", runLogPath)
        v3CompilerAppendKeyValueLine(summaryText, smokeName + "_ok", "false")
        return false
    let runArgv = [remoteSmokeOut]
    var runOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   runLabel,
                                   runArgv,
                                   runLogPath,
                                   "remote x86 smoke run " + smokeName,
                                   runOut):
        v3CompilerAppendKeyValueLine(summaryText, smokeName + "_compile_log", compileLogPath)
        v3CompilerAppendKeyValueLine(summaryText, smokeName + "_run_log", runLogPath)
        v3CompilerAppendKeyValueLine(summaryText, smokeName + "_ok", "false")
        return false
    let runTrimmed = strutil.strip(runOut)
    let requireEmpty = v3CompilerRemoteSmokeRequireEmptyOutput(smokeName)
    let expected = v3CompilerRemoteSmokeExpectedText(smokeName)
    if requireEmpty:
        if len(runTrimmed) > 0:
            v3CompilerPrintErr("v3 compiler: remote x86 smoke expected empty stdout: " + smokeName)
            v3CompilerPrintErr(runTrimmed)
            v3CompilerAppendKeyValueLine(summaryText, smokeName + "_compile_log", compileLogPath)
            v3CompilerAppendKeyValueLine(summaryText, smokeName + "_run_log", runLogPath)
            v3CompilerAppendKeyValueLine(summaryText, smokeName + "_ok", "false")
            return false
    elif !strutil.contains(runTrimmed, expected):
        v3CompilerPrintErr("v3 compiler: remote x86 smoke output drifted: " + smokeName)
        v3CompilerPrintErr(runTrimmed)
        v3CompilerAppendKeyValueLine(summaryText, smokeName + "_compile_log", compileLogPath)
        v3CompilerAppendKeyValueLine(summaryText, smokeName + "_run_log", runLogPath)
        v3CompilerAppendKeyValueLine(summaryText, smokeName + "_ok", "false")
        return false
    v3CompilerAppendKeyValueLine(summaryText, smokeName + "_compile_log", compileLogPath)
    v3CompilerAppendKeyValueLine(summaryText, smokeName + "_run_log", runLogPath)
    v3CompilerAppendKeyValueLine(summaryText, smokeName + "_ok", "true")
    return true

fn v3CompilerVerifyRemoteChainNodeSelfTest(rootDir: str,
                                           outDir: str,
                                           hostLabel: str,
                                           sshTarget: str,
                                           remoteRoot: str,
                                           summaryText: var str): bool =
    let remotePackageRoot = remoteRoot + "/v3"
    let remoteBackend = remoteRoot + "/artifacts/v3_backend_driver/cheng"
    let remoteOut = remoteRoot + "/artifacts/v3_backend_driver/chain_node.remote_selftest"
    let compileLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "chain_node_self_test.compile")
    let runLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "chain_node_self_test.run")
    let reportPath = remoteOut + ".report.txt"
    var remoteSource = remotePackageRoot
    remoteSource = remoteSource + "/src/project/chain_node_main.cheng"
    let remoteEnvRoot = "CHENG_V3_ROOT=" + remoteRoot
    var compileArgv: str[] = []
    add(compileArgv, "env")
    add(compileArgv, remoteEnvRoot)
    add(compileArgv, remoteBackend)
    add(compileArgv, "system-link-exec")
    add(compileArgv, "--root:" + remotePackageRoot)
    add(compileArgv, "--in:" + remoteSource)
    add(compileArgv, "--emit:exe")
    add(compileArgv, "--target:x86_64-unknown-linux-gnu")
    add(compileArgv, "--out:" + remoteOut)
    add(compileArgv, "--report-out:" + reportPath)
    var compileOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_chain_node_compile",
                                   compileArgv,
                                   compileLogPath,
                                   "remote x86 chain_node compile",
                                   compileOut):
        v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_compile_log", compileLogPath)
        v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_run_log", runLogPath)
        v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_ok", "false")
        return false
    let runArgv = [remoteOut, "self-test"]
    var runOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_chain_node_run",
                                   runArgv,
                                   runLogPath,
                                   "remote x86 chain_node self-test",
                                   runOut):
        v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_compile_log", compileLogPath)
        v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_run_log", runLogPath)
        v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_ok", "false")
        return false
    let runTrimmed = strutil.strip(runOut)
    if !strutil.contains(runTrimmed, "v3 chain_node self-test ok"):
        v3CompilerPrintErr("v3 compiler: remote x86 chain_node self-test drifted")
        v3CompilerPrintErr(runTrimmed)
        v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_compile_log", compileLogPath)
        v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_run_log", runLogPath)
        v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_ok", "false")
        return false
    v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_compile_log", compileLogPath)
    v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_run_log", runLogPath)
    v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test_ok", "true")
    return true

fn v3CompilerVerifyX86RemoteHost(rootDir: str,
                                 outDir: str,
                                 hostLabel: str,
                                 sshTarget: str,
                                 remoteRoot: str,
                                 ordinarySmokes: str[],
                                 chainNodeSelfTest: bool): bool =
    let summaryPath = v3CompilerRemoteSummaryPath(outDir, hostLabel)
    let mkdirLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "mkdir")
    let rsyncLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "rsync")
    let cleanLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "clean")
    let stage0DirLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "stage0_dir")
    let stage0CcLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "stage0_cc")
    let bootstrapLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "bootstrap_bridge")
    let buildBackendLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "build_backend_driver")
    let stage3PlanLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "stage3_plan")
    let backendPlanLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "backend_plan")
    let smokeDirLogPath = v3CompilerRemoteLogPath(outDir, hostLabel, "smoke_mkdir")
    let remoteStage0 = remoteRoot + "/artifacts/v3_bootstrap/cheng.stage0"
    let remoteStage3 = remoteRoot + "/artifacts/v3_bootstrap/cheng.stage3"
    let remoteBackend = remoteRoot + "/artifacts/v3_backend_driver/cheng"
    var summaryText = ""
    v3CompilerAppendKeyValueLine(summaryText, "host", hostLabel)
    v3CompilerAppendKeyValueLine(summaryText, "ssh_target", sshTarget)
    v3CompilerAppendKeyValueLine(summaryText, "remote_root", remoteRoot)
    v3CompilerAppendKeyValueLine(summaryText, "ordinary_smoke_count", intToStr(ordinarySmokes.len))
    v3CompilerAppendKeyValueLine(summaryText, "ordinary_smoke_names", v3CompilerJoinCsv(ordinarySmokes))
    v3CompilerAppendKeyValueLine(summaryText, "chain_node_self_test", v3CompilerBoolText(chainNodeSelfTest))
    var mkdirOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_mkdir",
                                   ["mkdir", "-p", remoteRoot],
                                   mkdirLogPath,
                                   "remote x86 mkdir " + hostLabel,
                                   mkdirOut):
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let rsyncSource = rootDir + "/"
    var rsyncOut = ""
    if !v3CompilerRunRemoteRsync(rootDir,
                                 sshTarget,
                                 hostLabel + "_rsync",
                                 rsyncSource,
                                 remoteRoot,
                                 rsyncLogPath,
                                 "remote x86 rsync " + hostLabel,
                                 rsyncOut):
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let cleanArgv = [
        "rm",
        "-rf",
        remoteRoot + "/chengcache",
        remoteRoot + "/artifacts/v3_backend_driver",
        remoteRoot + "/artifacts/v3_bootstrap"
    ]
    var cleanOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_clean",
                                   cleanArgv,
                                   cleanLogPath,
                                   "remote x86 clean " + hostLabel,
                                   cleanOut):
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    var stage0DirOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_stage0_dir",
                                   ["mkdir", "-p", remoteRoot + "/artifacts/v3_bootstrap"],
                                   stage0DirLogPath,
                                   "remote x86 stage0 dir " + hostLabel,
                                   stage0DirOut):
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let ccArgv = [
        "cc",
        "-std=c11",
        "-O2",
        "-Wall",
        "-Wextra",
        "-pedantic",
        remoteRoot + "/v3/bootstrap/cheng_v3_seed.c",
        "-o",
        remoteStage0
    ]
    var stage0CcOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_stage0_cc",
                                   ccArgv,
                                   stage0CcLogPath,
                                   "remote x86 stage0 cc " + hostLabel,
                                   stage0CcOut):
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let bootstrapArgv = [
        "env",
        "CHENG_V3_ROOT=" + remoteRoot,
        "CHENG_V3_TARGET=x86_64-unknown-linux-gnu",
        remoteStage0,
        "bootstrap-bridge"
    ]
    var bootstrapOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_bootstrap",
                                   bootstrapArgv,
                                   bootstrapLogPath,
                                   "remote x86 bootstrap-bridge " + hostLabel,
                                   bootstrapOut):
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let backendBuildArgv = [
        "env",
        "CHENG_V3_ROOT=" + remoteRoot,
        "CHENG_V3_TARGET=x86_64-unknown-linux-gnu",
        remoteStage3,
        "build-backend-driver",
        "--target:x86_64-unknown-linux-gnu"
    ]
    var backendBuildOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_build_backend_driver",
                                   backendBuildArgv,
                                   buildBackendLogPath,
                                   "remote x86 build-backend-driver " + hostLabel,
                                   backendBuildOut):
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let stage3PlanArgv = [
        "env",
        "CHENG_V3_ROOT=" + remoteRoot,
        remoteStage3,
        "print-build-plan",
        "--target:x86_64-unknown-linux-gnu"
    ]
    var stage3PlanOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_stage3_plan",
                                   stage3PlanArgv,
                                   stage3PlanLogPath,
                                   "remote x86 stage3 plan " + hostLabel,
                                   stage3PlanOut):
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    var backendPlanOut = ""
    let backendPlanArgv = [
        "env",
        "CHENG_V3_ROOT=" + remoteRoot,
        remoteBackend,
        "print-build-plan",
        "--target:x86_64-unknown-linux-gnu"
    ]
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_backend_plan",
                                   backendPlanArgv,
                                   backendPlanLogPath,
                                   "remote x86 backend plan " + hostLabel,
                                   backendPlanOut):
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    let planCoreMatch = v3CompilerRemotePlanMatches(stage3PlanOut, backendPlanOut)
    v3CompilerAppendKeyValueLine(summaryText, "stage3_plan_log", stage3PlanLogPath)
    v3CompilerAppendKeyValueLine(summaryText, "backend_plan_log", backendPlanLogPath)
    v3CompilerAppendKeyValueLine(summaryText, "plan_core_match", v3CompilerBoolText(planCoreMatch))
    if !planCoreMatch:
        v3CompilerPrintErr("v3 compiler: remote x86 plan drifted on " + hostLabel)
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    var smokeDirOut = ""
    if !v3CompilerRunRemoteCommand(rootDir,
                                   sshTarget,
                                   hostLabel + "_smoke_dir",
                                   ["mkdir", "-p", remoteRoot + "/artifacts/v3_backend_driver"],
                                   smokeDirLogPath,
                                   "remote x86 smoke dir " + hostLabel,
                                   smokeDirOut):
        let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
        return false
    for i in 0..<ordinarySmokes.len:
        if !v3CompilerVerifyRemoteExeSmoke(rootDir,
                                           outDir,
                                           hostLabel,
                                           sshTarget,
                                           remoteRoot,
                                           ordinarySmokes[i],
                                           summaryText):
            let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
            return false
    if chainNodeSelfTest:
        if !v3CompilerVerifyRemoteChainNodeSelfTest(rootDir,
                                                    outDir,
                                                    hostLabel,
                                                    sshTarget,
                                                    remoteRoot,
                                                    summaryText):
            let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, false)
            return false
    let _ = v3CompilerWriteRemoteSummary(rootDir, summaryPath, summaryText, true)
    return true

fn v3CompilerVerifyX86LinuxRemote(rootDir: str,
                                  args: str[]): int32 =
    args
    let outDir = v3path.v3PathAbsolute(rootDir, "artifacts/v3_x86_remote_gate")
    let reportPath = os.joinPath(outDir, "verify_x86_linux_remote.report.txt")
    let dmitSsh = strutil.strip(cmdline.readFlagOrDefault("--dmit-ssh", "dmit"))
    let dmitRoot = strutil.strip(cmdline.readFlagOrDefault("--dmit-root", "/root/cheng-lang-deploy"))
    let host64Ssh = strutil.strip(cmdline.readFlagOrDefault("--remote64-ssh", "root@64.176.84.12"))
    let host64Root = strutil.strip(cmdline.readFlagOrDefault("--remote64-root", "/root/cheng-lang-deploy"))
    let chainNodeSelfTestText = strutil.strip(cmdline.readFlagOrDefault("--chain-node-self-test", "1"))
    let chainNodeSelfTest = chainNodeSelfTestText != "0"
    let ordinarySmokes = v3CompilerRemoteOrdinarySmokeNames()
    if ordinarySmokes.len <= 0:
        v3CompilerPrintErr("v3 compiler: remote x86 smoke suite is empty")
        return 2
    if !v3CompilerRemovePathTree(outDir):
        v3CompilerPrintErr("v3 compiler: failed to clear remote x86 gate dir: " + outDir)
        return 2
    if !v3path.v3MkdirP(rootDir, outDir):
        v3CompilerPrintErr("v3 compiler: failed to create remote x86 gate dir: " + outDir)
        return 2
    var reportText = ""
    v3CompilerAppendKeyValueLine(reportText, "host_count", "2")
    v3CompilerAppendKeyValueLine(reportText, "host_a", v3CompilerPipePair("dmit", dmitSsh))
    v3CompilerAppendKeyValueLine(reportText, "host_b", v3CompilerPipePair("64", host64Ssh))
    v3CompilerAppendKeyValueLine(reportText, "ordinary_smoke_count", intToStr(ordinarySmokes.len))
    v3CompilerAppendKeyValueLine(reportText, "ordinary_smoke_names", v3CompilerJoinCsv(ordinarySmokes))
    v3CompilerAppendKeyValueLine(reportText, "chain_node_self_test", v3CompilerBoolText(chainNodeSelfTest))
    if !v3CompilerVerifyX86RemoteHost(rootDir,
                                      outDir,
                                      "dmit",
                                      dmitSsh,
                                      dmitRoot,
                                      ordinarySmokes,
                                      chainNodeSelfTest):
        let dmitSummaryPath = v3CompilerRemoteSummaryPath(outDir, "dmit")
        let dmitSummaryText = v3path.v3ReadTextFile("", dmitSummaryPath)
        v3CompilerAppendSectionLabel(reportText, "dmit")
        reportText = reportText + dmitSummaryText
        let _ = v3path.v3WriteTextFile(rootDir, reportPath, reportText)
        return 2
    let dmitSummaryPath = v3CompilerRemoteSummaryPath(outDir, "dmit")
    let dmitSummaryText = v3path.v3ReadTextFile("", dmitSummaryPath)
    v3CompilerAppendSectionLabel(reportText, "dmit")
    reportText = reportText + dmitSummaryText
    if !v3CompilerVerifyX86RemoteHost(rootDir,
                                      outDir,
                                      "64",
                                      host64Ssh,
                                      host64Root,
                                      ordinarySmokes,
                                      chainNodeSelfTest):
        let host64SummaryPath = v3CompilerRemoteSummaryPath(outDir, "64")
        let host64SummaryText = v3path.v3ReadTextFile("", host64SummaryPath)
        v3CompilerAppendSectionLabel(reportText, "64")
        reportText = reportText + host64SummaryText
        let _ = v3path.v3WriteTextFile(rootDir, reportPath, reportText)
        return 2
    let host64SummaryPath = v3CompilerRemoteSummaryPath(outDir, "64")
    let host64SummaryText = v3path.v3ReadTextFile("", host64SummaryPath)
    v3CompilerAppendSectionLabel(reportText, "64")
    reportText = reportText + host64SummaryText
    if !v3path.v3WriteTextFile(rootDir, reportPath, reportText):
        v3CompilerPrintErr("v3 compiler: failed to write remote x86 report: " + reportPath)
        return 2
    v3CompilerPrintLine("verify-x86-linux-remote: ok")
    v3CompilerPrintLine("report=" + reportPath)
    return 0

fn v3CompilerRuntimeAbiContractText(rootDir: str): str =
    return v3path.v3ReadTextFile(
        "",
        v3path.v3PathAbsolute(rootDir, "v3/tooling/backend_runtime_abi_contract.env")
    )

fn v3CompilerRuntimeAbiPath(rootDir: str,
                            contractText: str,
                            key: str,
                            fallbackRel: str): str =
    let relPath = strutil.strip(v3CompilerEnvLineValue(contractText, key))
    if len(relPath) > 0:
        return v3path.v3PathAbsolute(rootDir, relPath)
    return v3path.v3PathAbsolute(rootDir, fallbackRel)

fn v3CompilerRunCommandLogged(rootDir: str,
                              command: str,
                              logPath: str,
                              context: str): bool =
    let fullCommand = command + " > " + v3CompilerQuoteShell(logPath) + " 2>&1"
    let rc = os.execCmdStatus(fullCommand, rootDir)
    if rc == 0:
        return true
    let output = strutil.strip(v3path.v3ReadTextFile("", logPath))
    if len(output) > 0:
        v3CompilerPrintErr(output)
    else:
        v3CompilerPrintErr("v3 compiler: " + context + " failed")
    return false

fn v3CompilerRunFileLogged(rootDir: str,
                           filePath: str,
                           argv: str[],
                           logPath: str,
                           context: str): bool =
    let run = hostops.v3RunFileLogged(rootDir, context, filePath, argv, [], rootDir, 0, logPath)
    if hostops.v3LoggedRunOk(run):
        return true
    let output = strutil.strip(run.output)
    if len(output) > 0:
        v3CompilerPrintErr(output)
    else:
        v3CompilerPrintErr("v3 compiler: " + context + " failed")
    return false

fn v3CompilerRunProgramLogged(rootDir: str,
                              programName: str,
                              argv: str[],
                              logPath: str,
                              context: str): bool =
    let run = hostops.v3RunProgramLogged(rootDir, context, programName, argv, [], rootDir, 0, logPath)
    if hostops.v3LoggedRunOk(run):
        return true
    let output = strutil.strip(run.output)
    if len(output) > 0:
        v3CompilerPrintErr(output)
    else:
        v3CompilerPrintErr("v3 compiler: " + context + " failed")
    return false

fn v3CompilerSharedEmitExtension(targetTriple: str): str =
    if slplan.v3SystemLinkPlanTargetIsWindows(targetTriple):
        return ".dll"
    if targetTriple == "arm64-apple-darwin":
        return ".dylib"
    return ".so"

fn v3CompilerSharedEmitFileHint(targetTriple: str): str =
    if slplan.v3SystemLinkPlanTargetIsWindows(targetTriple):
        return "PE32+"
    if targetTriple == "arm64-apple-darwin":
        return "shared library"
    return "shared object"

fn v3CompilerRunSharedEmitSmokes(rootDir: str): int32 =
    let packageRoot = v3path.v3PathAbsolute(rootDir, "v3")
    let fixtureSource = v3path.v3PathAbsolute(rootDir, "v3/src/tests/shared_emit_fixture.cheng")
    let outDir = v3path.v3PathAbsolute(rootDir, "artifacts/v3_shared_emit_smokes")
    let targetTriple = v3CompilerRequestedTarget()
    let extension = v3CompilerSharedEmitExtension(targetTriple)
    let outLib = v3path.v3PathAbsolute(rootDir, "artifacts/v3_shared_emit_smokes/shared_emit_fixture" + extension)
    let reportPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_shared_emit_smokes/shared_emit_fixture.report.txt")
    let compileLogPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_shared_emit_smokes/shared_emit_fixture.compile.log")
    let fileLogPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_shared_emit_smokes/shared_emit_fixture.file.txt")
    var currentCompiler = cmdline.programName()
    if len(currentCompiler) <= 0:
        currentCompiler = v3CompilerBridgeCompilerPath(rootDir)
    if len(currentCompiler) <= 0:
        v3CompilerPrintErr("v3 compiler: missing current compiler for run-shared-emit-smokes")
        return 2
    if !v3path.v3MkdirP(rootDir, outDir):
        v3CompilerPrintErr("v3 compiler: failed to create shared emit smoke dir")
        return 2
    if v3path.v3PathFileExists(outLib):
        os.removeFile(outLib)
    if v3path.v3PathFileExists(reportPath):
        os.removeFile(reportPath)
    let compileCommand = v3CompilerQuoteShell(currentCompiler) +
                         " " + v3CompilerQuoteShell("system-link-exec") +
                         " " + v3CompilerQuoteShell("--root:" + packageRoot) +
                         " " + v3CompilerQuoteShell("--in:" + fixtureSource) +
                         " " + v3CompilerQuoteShell("--emit:shared") +
                         " " + v3CompilerQuoteShell("--target:" + targetTriple) +
                         " " + v3CompilerQuoteShell("--out:" + outLib) +
                         " " + v3CompilerQuoteShell("--report-out:" + reportPath)
    if !v3CompilerRunCommandLogged(rootDir, compileCommand, compileLogPath, "run-shared-emit-smokes compile"):
        return 2
    if !v3path.v3FileExistsNonEmpty(rootDir, outLib):
        v3CompilerPrintErr("v3 compiler: shared emit smoke missing output: " + outLib)
        return 2
    if !v3path.v3FileExistsNonEmpty(rootDir, reportPath):
        v3CompilerPrintErr("v3 compiler: shared emit smoke missing report: " + reportPath)
        return 2
    let reportText = v3path.v3ReadTextFile("", reportPath)
    if !v3path.v3TextContains(reportText, "emit=shared") ||
       !v3path.v3TextContains(reportText, "main_function_present=0") ||
       !v3path.v3TextContains(reportText, "missing_reasons=-") ||
       !v3path.v3TextContains(reportText, "native_link_missing_reasons=-"):
        v3CompilerPrintErr("v3 compiler: shared emit smoke report shape mismatch: " + reportPath)
        return 2
    let fileCommand = "file " + v3CompilerQuoteShell(outLib)
    if !v3CompilerRunCommandLogged(rootDir, fileCommand, fileLogPath, "run-shared-emit-smokes file"):
        return 2
    let fileText = v3path.v3ReadTextFile("", fileLogPath)
    let expectedHint = v3CompilerSharedEmitFileHint(targetTriple)
    if len(expectedHint) > 0 && !v3path.v3TextContains(fileText, expectedHint):
        v3CompilerPrintErr("v3 compiler: shared emit smoke expected `" + expectedHint + "` in file output")
        v3CompilerPrintErr(strutil.strip(fileText))
        return 2
    v3CompilerPrintLine("v3 shared emit smokes: ok")
    v3CompilerPrintLine("target=" + targetTriple)
    v3CompilerPrintLine("out=" + outLib)
    v3CompilerPrintLine("report=" + reportPath)
    return 0

fn v3CompilerR2cReactNativeGuiBundleSmoke(rootDir: str,
                                          args: str[]): int32 =
    args
    let repoRaw = cmdline.readFlagOrDefault("--repo", "/Users/lbcheng/UniMaker/React.js")
    let routeState = cmdline.readFlagOrDefault("--route-state", "home_default")
    let outDirRaw = cmdline.readFlagOrDefault("--out-dir", "/tmp/r2c-native-gui-bundle-smoke-" + routeState)
    let repo = v3path.v3PathAbsolute(rootDir, repoRaw)
    let outDir = v3path.v3PathAbsolute(rootDir, outDirRaw)
    let bundleReport = os.joinPath(outDir, "native_gui_bundle_report_v1.json")
    let bundleSummary = os.joinPath(outDir, "native_gui_bundle.summary.env")
    let bundleJson = os.joinPath(outDir, "native_gui_bundle_v1.json")
    if !os.dirExists(repo):
        v3CompilerPrintErr("v3 compiler: missing React.js repo: " + repo)
        return 2
    if !v3CompilerRemovePathTree(outDir):
        v3CompilerPrintErr("v3 compiler: failed to clear native gui bundle smoke dir: " + outDir)
        return 2
    if !v3CompilerEnsureBackendDriver(rootDir, "native gui bundle smoke"):
        return 2
    let bootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(rootDir)
    let stage3Path = bootstrapSnapshot.stage3Compiler.path
    if !v3path.v3FileExistsNonEmpty(rootDir, stage3Path):
        v3CompilerPrintErr("v3 compiler: missing stage3 for native gui bundle smoke: " + stage3Path)
        return 2
    if v3CompilerForwardToBridge(rootDir,
                                 stage3Path,
                                 "r2c-react-v3",
                                 [
                                     "native-gui-bundle",
                                     "--repo", repo,
                                     "--out-dir", outDir,
                                     "--route-state", routeState
                                 ]) != 0:
        v3CompilerPrintErr("v3 compiler: native-gui-bundle failed inside smoke for route: " + routeState)
        return 2
    if !v3path.v3PathFileExists(bundleReport) || !v3path.v3PathFileExists(bundleSummary) || !v3path.v3PathFileExists(bundleJson):
        v3CompilerPrintErr("v3 compiler: missing native gui bundle smoke artifacts for route: " + routeState)
        return 2
    let reportText = v3path.v3ReadTextFile("", bundleReport)
    let summaryText = v3path.v3ReadTextFile("", bundleSummary)
    if !strutil.contains(reportText, "\"ok\": true") ||
       !strutil.contains(reportText, "\"native_gui_host_ready\": true") ||
       !strutil.contains(reportText, "\"native_gui_renderer_ready\": true"):
        v3CompilerPrintErr("v3 compiler: native gui bundle smoke report drifted for route: " + routeState)
        return 2
    if !strutil.contains(summaryText, "native_gui_runtime_mode=cheng_compiled_json_v1") ||
       !strutil.contains(summaryText, "native_gui_route_state=" + routeState) ||
       !strutil.contains(summaryText, "native_gui_exec_snapshot_path=") ||
       !strutil.contains(summaryText, "native_gui_route_catalog_path="):
        v3CompilerPrintErr("v3 compiler: native gui bundle smoke summary drifted for route: " + routeState)
        return 2
    v3CompilerPrintLine("r2c-react-v3 native gui bundle smoke: ok")
    v3CompilerPrintLine("route_state=" + routeState)
    v3CompilerPrintLine("bundle_report=" + bundleReport)
    v3CompilerPrintLine("bundle_summary=" + bundleSummary)
    v3CompilerPrintLine("bundle_json=" + bundleJson)
    return 0

fn v3CompilerR2cReactCodegenSurfaceSmoke(rootDir: str,
                                         args: str[]): int32 =
    args
    let repoRaw = cmdline.readFlagOrDefault("--repo", "/Users/lbcheng/UniMaker/React.js")
    let outDirRaw = cmdline.readFlagOrDefault("--out-dir", "/tmp/r2c-codegen-surface-smoke")
    let repo = v3path.v3PathAbsolute(rootDir, repoRaw)
    let outDir = v3path.v3PathAbsolute(rootDir, outDirRaw)
    let tsxAstPath = os.joinPath(outDir, "tsx_ast_v1.json")
    let tsxSummaryPath = os.joinPath(outDir, "tsx_ast_v1.summary.env")
    let codegenSummaryPath = os.joinPath(outDir, "codegen_surface.summary.env")
    let reportPath = os.joinPath(outDir, "codegen_surface_report_v1.json")
    let manifestPath = os.joinPath(outDir, "cheng_codegen_v1.json")
    let routeCatalogPath = os.joinPath(outDir, "cheng_codegen_route_catalog_v1.json")
    let smokePath = os.joinPath(outDir, "cheng_codegen_smoke_v1.json")
    if !os.dirExists(repo):
        v3CompilerPrintErr("v3 compiler: missing React.js repo: " + repo)
        return 2
    if !v3CompilerRemovePathTree(outDir):
        v3CompilerPrintErr("v3 compiler: failed to clear codegen surface smoke dir: " + outDir)
        return 2
    if !v3path.v3MkdirP(rootDir, outDir):
        v3CompilerPrintErr("v3 compiler: failed to create codegen surface smoke dir: " + outDir)
        return 2
    if !v3CompilerEnsureBackendDriver(rootDir, "codegen surface smoke"):
        return 2
    let bootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(rootDir)
    let stage3Path = bootstrapSnapshot.stage3Compiler.path
    if !v3path.v3FileExistsNonEmpty(rootDir, stage3Path):
        v3CompilerPrintErr("v3 compiler: missing stage3 for codegen surface smoke: " + stage3Path)
        return 2
    if v3CompilerForwardToBridge(rootDir,
                                 stage3Path,
                                 "r2c-react-v3",
                                 [
                                     "codegen-surface",
                                     "--repo", repo,
                                     "--out-dir", outDir
                                 ]) != 0:
        v3CompilerPrintErr("v3 compiler: codegen-surface failed inside smoke")
        return 2
    if !v3path.v3PathFileExists(tsxAstPath) || !v3path.v3PathFileExists(tsxSummaryPath):
        v3CompilerPrintErr("v3 compiler: missing frontend smoke artifacts")
        return 2
    if !v3path.v3PathFileExists(codegenSummaryPath) ||
       !v3path.v3PathFileExists(reportPath) ||
       !v3path.v3PathFileExists(manifestPath) ||
       !v3path.v3PathFileExists(routeCatalogPath) ||
       !v3path.v3PathFileExists(smokePath):
        v3CompilerPrintErr("v3 compiler: missing codegen surface smoke artifacts")
        return 2
    let reportText = v3path.v3ReadTextFile("", reportPath)
    let summaryText = v3path.v3ReadTextFile("", codegenSummaryPath)
    let manifestText = v3path.v3ReadTextFile("", manifestPath)
    let routeCatalogText = v3path.v3ReadTextFile("", routeCatalogPath)
    if !strutil.contains(reportText, "\"command\": \"codegen-surface\"") ||
       !strutil.contains(reportText, "\"ok\": true"):
        v3CompilerPrintErr("v3 compiler: codegen surface smoke report drifted")
        return 2
    if !strutil.contains(summaryText, "smoke_ok=true") ||
       !strutil.contains(summaryText, "codegen_manifest_path=" + manifestPath) ||
       !strutil.contains(summaryText, "route_catalog_path=" + routeCatalogPath) ||
       !strutil.contains(summaryText, "codegen_smoke_path=" + smokePath):
        v3CompilerPrintErr("v3 compiler: codegen surface smoke summary drifted")
        return 2
    if !strutil.contains(manifestText, "\"format\": \"cheng_codegen_v1\"") ||
       !strutil.contains(routeCatalogText, "\"format\": \"cheng_codegen_route_catalog_v1\""):
        v3CompilerPrintErr("v3 compiler: codegen surface smoke JSON contract drifted")
        return 2
    v3CompilerPrintLine("r2c-react-v3 codegen surface smoke: ok")
    v3CompilerPrintLine("tsx_ast=" + tsxAstPath)
    v3CompilerPrintLine("codegen_summary=" + codegenSummaryPath)
    v3CompilerPrintLine("codegen_manifest=" + manifestPath)
    v3CompilerPrintLine("route_catalog=" + routeCatalogPath)
    v3CompilerPrintLine("codegen_smoke=" + smokePath)
    return 0

fn v3CompilerR2cReactTruthCompareSmoke(rootDir: str,
                                       args: str[]): int32 =
    args
    let repoRaw = cmdline.readFlagOrDefault("--repo", "/Users/lbcheng/UniMaker/React.js")
    let outDirRaw = cmdline.readFlagOrDefault("--out-dir", "/tmp/r2c-truth-compare-smoke")
    let truthTraceRaw = cmdline.readFlagOrDefault("--truth-trace", "v3/testdata/r2c_truth_trace_home_default_smoke_v1.json")
    let repo = v3path.v3PathAbsolute(rootDir, repoRaw)
    let outDir = v3path.v3PathAbsolute(rootDir, outDirRaw)
    let truthTracePath = v3path.v3PathAbsolute(rootDir, truthTraceRaw)
    let reportPath = os.joinPath(outDir, "truth_compare_report_v1.json")
    let summaryPath = os.joinPath(outDir, "truth_compare.summary.env")
    let comparePath = os.joinPath(outDir, "truth_compare_v1.json")
    let bundleReport = os.joinPath(outDir, "native_gui_bundle_report_v1.json")
    let execSnapshotPath = os.joinPath(outDir, "cheng_codegen_exec_snapshot_v1.json")
    let manifestPath = os.joinPath(outDir, "cheng_codegen_v1.json")
    if !os.dirExists(repo):
        v3CompilerPrintErr("v3 compiler: missing React.js repo: " + repo)
        return 2
    if !v3path.v3PathFileExists(truthTracePath):
        v3CompilerPrintErr("v3 compiler: missing truth compare smoke trace: " + truthTracePath)
        return 2
    if !v3CompilerRemovePathTree(outDir):
        v3CompilerPrintErr("v3 compiler: failed to clear truth compare smoke dir: " + outDir)
        return 2
    if !v3path.v3MkdirP(rootDir, outDir):
        v3CompilerPrintErr("v3 compiler: failed to create truth compare smoke dir: " + outDir)
        return 2
    if !v3CompilerEnsureBackendDriver(rootDir, "truth compare smoke"):
        return 2
    let bootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(rootDir)
    let stage3Path = bootstrapSnapshot.stage3Compiler.path
    if !v3path.v3FileExistsNonEmpty(rootDir, stage3Path):
        v3CompilerPrintErr("v3 compiler: missing stage3 for truth compare smoke: " + stage3Path)
        return 2
    if v3CompilerForwardToBridge(rootDir,
                                 stage3Path,
                                 "r2c-react-v3",
                                 [
                                     "native-gui-bundle",
                                     "--repo", repo,
                                     "--out-dir", outDir,
                                     "--route-state", "home_default"
                                 ]) != 0:
        v3CompilerPrintErr("v3 compiler: native-gui-bundle failed inside truth compare smoke")
        return 2
    if v3CompilerForwardToBridge(rootDir,
                                 stage3Path,
                                 "r2c-react-v3",
                                 [
                                     "truth-compare",
                                     "--repo", repo,
                                     "--out-dir", outDir,
                                     "--truth-trace", truthTracePath,
                                     "--truth-state", "home_default"
                                 ]) != 0:
        v3CompilerPrintErr("v3 compiler: truth-compare failed inside smoke")
        return 2
    if !v3path.v3PathFileExists(bundleReport) ||
       !v3path.v3PathFileExists(execSnapshotPath) ||
       !v3path.v3PathFileExists(manifestPath) ||
       !v3path.v3PathFileExists(reportPath) ||
       !v3path.v3PathFileExists(summaryPath) ||
       !v3path.v3PathFileExists(comparePath):
        v3CompilerPrintErr("v3 compiler: missing truth compare smoke artifacts")
        return 2
    let reportText = v3path.v3ReadTextFile("", reportPath)
    let summaryText = v3path.v3ReadTextFile("", summaryPath)
    let compareText = v3path.v3ReadTextFile("", comparePath)
    if !strutil.contains(reportText, "\"command\": \"truth-compare\"") ||
       !strutil.contains(reportText, "\"ok\": true") ||
       !strutil.contains(reportText, "\"truth_compare_ok\": true"):
        v3CompilerPrintErr("v3 compiler: truth compare smoke report drifted")
        return 2
    if !strutil.contains(summaryText, "truth_compare_ok=true") ||
       !strutil.contains(summaryText, "truth_compare_reason=ok") ||
       !strutil.contains(summaryText, "matched_snapshot_index=0"):
        v3CompilerPrintErr("v3 compiler: truth compare smoke summary drifted")
        return 2
    if !strutil.contains(compareText, "\"format\": \"truth_compare_v1\"") ||
       !strutil.contains(compareText, "\"ok\": true") ||
       !strutil.contains(compareText, "\"reason\": \"ok\"") ||
       !strutil.contains(compareText, "\"exec_route_state\": \"home_default\""):
        v3CompilerPrintErr("v3 compiler: truth compare smoke JSON contract drifted")
        return 2
    v3CompilerPrintLine("r2c-react-v3 truth compare smoke: ok")
    v3CompilerPrintLine("truth_trace=" + truthTracePath)
    v3CompilerPrintLine("bundle_report=" + bundleReport)
    v3CompilerPrintLine("truth_compare_report=" + reportPath)
    v3CompilerPrintLine("truth_compare_summary=" + summaryPath)
    v3CompilerPrintLine("truth_compare_json=" + comparePath)
    return 0

fn v3CompilerR2cReactCompileSmoke(rootDir: str,
                                  args: str[]): int32 =
    args
    let repoRaw = cmdline.readFlagOrDefault("--repo", "/Users/lbcheng/UniMaker/React.js")
    let outDirRaw = cmdline.readFlagOrDefault("--out-dir", "/tmp/r2c-compile-smoke")
    let truthTraceRaw = cmdline.readFlagOrDefault("--truth-trace", "v3/testdata/r2c_truth_trace_home_default_smoke_v1.json")
    let truthRoutesRaw = cmdline.readFlagOrDefault("--truth-routes-file", "v3/testdata/r2c_truth_routes_home_default_smoke_v1.json")
    let repo = v3path.v3PathAbsolute(rootDir, repoRaw)
    let outDir = v3path.v3PathAbsolute(rootDir, outDirRaw)
    let truthTracePath = v3path.v3PathAbsolute(rootDir, truthTraceRaw)
    let truthRoutesPath = v3path.v3PathAbsolute(rootDir, truthRoutesRaw)
    let reportPath = os.joinPath(outDir, "compile_report_v1.json")
    let bundlePath = os.joinPath(outDir, "native_gui_bundle_v1.json")
    let compareSummaryPath = os.joinPath(outDir, "truth_compare.summary.env")
    let compareMatrixSummaryPath = os.joinPath(outDir, "truth_compare_matrix.summary.env")
    let comparePath = os.joinPath(outDir, "truth_compare_v1.json")
    let compareMatrixPath = os.joinPath(outDir, "truth_compare_matrix_v1.json")
    if !os.dirExists(repo):
        v3CompilerPrintErr("v3 compiler: missing React.js repo: " + repo)
        return 2
    if !v3path.v3PathFileExists(truthTracePath):
        v3CompilerPrintErr("v3 compiler: missing compile smoke truth trace: " + truthTracePath)
        return 2
    if !v3path.v3PathFileExists(truthRoutesPath):
        v3CompilerPrintErr("v3 compiler: missing compile smoke truth routes: " + truthRoutesPath)
        return 2
    if !v3CompilerRemovePathTree(outDir):
        v3CompilerPrintErr("v3 compiler: failed to clear compile smoke dir: " + outDir)
        return 2
    if !v3path.v3MkdirP(rootDir, outDir):
        v3CompilerPrintErr("v3 compiler: failed to create compile smoke dir: " + outDir)
        return 2
    if !v3CompilerEnsureBackendDriver(rootDir, "compile smoke"):
        return 2
    let bootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(rootDir)
    let stage3Path = bootstrapSnapshot.stage3Compiler.path
    if !v3path.v3FileExistsNonEmpty(rootDir, stage3Path):
        v3CompilerPrintErr("v3 compiler: missing stage3 for compile smoke: " + stage3Path)
        return 2
    if v3CompilerForwardToBridge(rootDir,
                                 stage3Path,
                                 "r2c-react-v3",
                                 [
                                     "compile",
                                     "--repo", repo,
                                     "--out-dir", outDir,
                                     "--truth-trace", truthTracePath,
                                     "--truth-state", "home_default",
                                     "--truth-routes-file", truthRoutesPath
                                 ]) != 0:
        v3CompilerPrintErr("v3 compiler: compile failed inside smoke")
        return 2
    if !v3path.v3PathFileExists(reportPath) ||
       !v3path.v3PathFileExists(bundlePath) ||
       !v3path.v3PathFileExists(compareSummaryPath) ||
       !v3path.v3PathFileExists(compareMatrixSummaryPath) ||
       !v3path.v3PathFileExists(comparePath) ||
       !v3path.v3PathFileExists(compareMatrixPath):
        v3CompilerPrintErr("v3 compiler: missing compile smoke artifacts")
        return 2
    let reportText = v3path.v3ReadTextFile("", reportPath)
    let compareSummaryText = v3path.v3ReadTextFile("", compareSummaryPath)
    let compareMatrixSummaryText = v3path.v3ReadTextFile("", compareMatrixSummaryPath)
    let compareText = v3path.v3ReadTextFile("", comparePath)
    let compareMatrixText = v3path.v3ReadTextFile("", compareMatrixPath)
    if !strutil.contains(reportText, "\"command\": \"compile\"") ||
       !strutil.contains(reportText, "\"ok\": true") ||
       !strutil.contains(reportText, "\"truth_compare_ok\": true") ||
       !strutil.contains(reportText, "\"truth_compare_matrix_ok\": true") ||
       !strutil.contains(reportText, "\"route_count\": 1"):
        v3CompilerPrintErr("v3 compiler: compile smoke report drifted")
        return 2
    if !strutil.contains(compareSummaryText, "truth_compare_ok=true") ||
       !strutil.contains(compareSummaryText, "truth_compare_reason=ok") ||
       !strutil.contains(compareSummaryText, "matched_snapshot_index=0"):
        v3CompilerPrintErr("v3 compiler: compile smoke truth compare summary drifted")
        return 2
    if !strutil.contains(compareMatrixSummaryText, "truth_compare_matrix_ok=true") ||
       !strutil.contains(compareMatrixSummaryText, "truth_compare_matrix_reason=ok") ||
       !strutil.contains(compareMatrixSummaryText, "route_count=1") ||
       !strutil.contains(compareMatrixSummaryText, "ok_count=1") ||
       !strutil.contains(compareMatrixSummaryText, "mismatch_count=0"):
        v3CompilerPrintErr("v3 compiler: compile smoke truth compare matrix summary drifted")
        return 2
    if !strutil.contains(compareText, "\"format\": \"truth_compare_v1\"") ||
       !strutil.contains(compareText, "\"ok\": true") ||
       !strutil.contains(compareText, "\"reason\": \"ok\"") ||
       !strutil.contains(compareText, "\"exec_route_state\": \"home_default\""):
        v3CompilerPrintErr("v3 compiler: compile smoke truth compare JSON contract drifted")
        return 2
    if !strutil.contains(compareMatrixText, "\"format\": \"truth_compare_matrix_v1\"") ||
       !strutil.contains(compareMatrixText, "\"ok\": true") ||
       !strutil.contains(compareMatrixText, "\"routeCount\": 1") ||
       !strutil.contains(compareMatrixText, "\"okCount\": 1"):
        v3CompilerPrintErr("v3 compiler: compile smoke truth compare matrix JSON contract drifted")
        return 2
    v3CompilerPrintLine("r2c-react-v3 compile smoke: ok")
    v3CompilerPrintLine("truth_trace=" + truthTracePath)
    v3CompilerPrintLine("truth_routes=" + truthRoutesPath)
    v3CompilerPrintLine("compile_report=" + reportPath)
    v3CompilerPrintLine("native_gui_bundle=" + bundlePath)
    v3CompilerPrintLine("truth_compare_summary=" + compareSummaryPath)
    v3CompilerPrintLine("truth_compare_matrix_summary=" + compareMatrixSummaryPath)
    return 0

fn v3CompilerTextContainsAll(text: str,
                             needles: str[]): bool =
    for i in 0..<needles.len:
        if !strutil.contains(text, needles[i]):
            return false
    return true

fn v3CompilerRemovePathTree(path: str): bool =
    if !v3path.v3PathNonEmpty(path):
        return true
    let command = "rm -rf " + v3CompilerQuoteShell(path)
    return os.execCmdStatus(command, "") == 0

fn v3CompilerCleanHostrunArtifacts(rootDir: str,
                                   smokeNames: str[]): bool =
    let hostrunDir = v3path.v3PathAbsolute(rootDir, "artifacts/v3_hostrun")
    if !os.dirExists(hostrunDir):
        return true
    var command = "rm -rf"
    for i in 0..<smokeNames.len:
        command = command + " "
        command = command + v3CompilerQuoteShell(hostrunDir + "/" + smokeNames[i])
        command = command + "*"
    return os.execCmdStatus(command, "") == 0

fn v3CompilerRequestFromRuntimeFlags(workspaceRoot: str,
                                     requireOutput: bool): Result[creq.V3CompilerRequest] =
    let sourcePath = cmdline.readFlagOrDefault("--in", "")
    if len(sourcePath) <= 0:
        return Err[creq.V3CompilerRequest]("v3 compiler: missing --in")
    let packageRootRaw = cmdline.readFlagOrDefault("--root", creq.v3CompilerDefaultPackageRoot(workspaceRoot))
    let packageRoot = creq.v3CompilerResolvePackageRoot(workspaceRoot, sourcePath, packageRootRaw)
    let outputPath = cmdline.readFlagOrDefault("--out", "")
    if requireOutput && len(outputPath) <= 0:
        return Err[creq.V3CompilerRequest]("v3 compiler: missing --out")
    let targetTriple = v3CompilerRequestedTarget()
    let emitText = cmdline.readFlagOrDefault("--emit", "exe")
    let emitKindRes = creq.v3CompilerEmitFromText(emitText)
    if IsErr(emitKindRes):
        return Err[creq.V3CompilerRequest](Error(emitKindRes))
    let reportPath = cmdline.readFlagOrDefault("--report-out", "")
    return Ok[creq.V3CompilerRequest](creq.v3CompilerRequestNew(packageRoot,
                                                                sourcePath,
                                                                outputPath,
                                                                targetTriple,
                                                                Value(emitKindRes),
                                                                reportPath))

fn v3CompilerBuildSystemPlanFromRuntimeFlags(rootDir: str,
                                             req: creq.V3CompilerRequest): Result[sexec.V3SystemLinkExecPlan] =
    return sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                              req,
                                                              cmdline.readFlagOrDefault("--world-head", ""),
                                                              cmdline.readFlagOrDefault("--lock", ""),
                                                              cmdline.readFlagOrDefault("--baseline-surface", ""),
                                                              cmdline.readFlagOrDefault("--channel", "stable"))

fn v3CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir: str,
                                                           req: creq.V3CompilerRequest): Result[sexec.V3SystemLinkExecPlan] =
    return sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                              req,
                                                              cmdline.readFlagOrDefault("--world-head", ""),
                                                              cmdline.readFlagOrDefault("--lock", ""),
                                                              "",
                                                              cmdline.readFlagOrDefault("--channel", "stable"))

fn v3CompilerCollectArgsFrom(startIndex: int32,
                             count: int32): str[] =
    var out: str[] = []
    if startIndex > count:
        return out
    for i in startIndex..count:
        let arg = cmdline.paramStr(i)
        if len(arg) > 0:
            add(out, arg)
    return out

fn v3CompilerBuildSystemPlan(rootDir: str,
                             req: creq.V3CompilerRequest,
                             args: str[]): Result[sexec.V3SystemLinkExecPlan] =
    return sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                              req,
                                                              creq.v3CompilerWorldHeadFromArgs(args),
                                                              creq.v3CompilerLockPathFromArgs(args),
                                                              creq.v3CompilerBaselineSurfacePathFromArgs(args),
                                                              creq.v3CompilerChannelFromArgs(args))

fn v3CompilerRunSystemLinkExec(rootDir: str,
                               req: creq.V3CompilerRequest,
                               args: str[]): int32 =
    let planRes: Result[sexec.V3SystemLinkExecPlan] = v3CompilerBuildSystemPlan(rootDir, req, args)
    if IsErr(planRes):
        v3CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let report = sexec.v3SystemLinkExecPlanReport(plan)
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    let bridgeCompiler = v3CompilerBridgeCompilerPath(rootDir)
    if len(bridgeCompiler) > 0:
        return v3CompilerForwardToBridge(rootDir, bridgeCompiler, "system-link-exec", args)
    if sexec.v3SystemLinkExecPlanReady(plan):
        v3CompilerPrintErr("v3 compiler: missing live Cheng bridge for system-link-exec")
        v3CompilerPrintErr(report)
        return 2
    elif plan.primaryObjectPlan.missingReasons.len > 0:
        v3CompilerPrintErr("v3 compiler: primary object machine code not emitted")
    else:
        v3CompilerPrintErr("v3 compiler: ordinary pipeline blocked")
    v3CompilerPrintErr(report)
    return 2

fn v3CompilerRunLegacyCompatSystemLinkExec(rootDir: str,
                                           req: creq.V3CompilerRequest,
                                           rawArgs: str[]): int32 =
    rawArgs
    let compatArgs = creq.v3CompilerSystemLinkCompatArgs(req)
    let planRes: Result[sexec.V3SystemLinkExecPlan] = sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                                                          req,
                                                                                                          "",
                                                                                                          "",
                                                                                                          "",
                                                                                                          "stable")
    if IsErr(planRes):
        v3CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let report = sexec.v3SystemLinkExecPlanReport(plan)
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    let bridgeCompiler = v3CompilerBridgeCompilerPath(rootDir)
    if len(bridgeCompiler) > 0:
        return v3CompilerForwardToBridge(rootDir, bridgeCompiler, "system-link-exec", compatArgs)
    if sexec.v3SystemLinkExecPlanReady(plan):
        v3CompilerPrintErr("v3 compiler: missing live Cheng bridge for system-link-exec")
        v3CompilerPrintErr(report)
        return 2
    elif plan.primaryObjectPlan.missingReasons.len > 0:
        v3CompilerPrintErr("v3 compiler: primary object machine code not emitted")
    else:
        v3CompilerPrintErr("v3 compiler: ordinary pipeline blocked")
    v3CompilerPrintErr(report)
    return 2

fn v3CompilerBuildSystemPlanForEquivalence(rootDir: str,
                                           req: creq.V3CompilerRequest,
                                           args: str[]): Result[sexec.V3SystemLinkExecPlan] =
    return sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                              req,
                                                              creq.v3CompilerWorldHeadFromArgs(args),
                                                              creq.v3CompilerLockPathFromArgs(args),
                                                              "",
                                                              creq.v3CompilerChannelFromArgs(args))

fn v3CompilerEquivalenceInputsReadyFromRuntimeFlags(required: bool): Result[bool] =
    let baselineCsgPath = cmdline.readFlagOrDefault("--baseline-csg", "")
    let baselineSurfacePath = cmdline.readFlagOrDefault("--baseline-surface", "")
    let baselineReceiptPath = cmdline.readFlagOrDefault("--baseline-receipt", "")
    let anyProvided = len(baselineCsgPath) > 0 ||
                      len(baselineSurfacePath) > 0 ||
                      len(baselineReceiptPath) > 0
    let allProvided = len(baselineCsgPath) > 0 &&
                      len(baselineSurfacePath) > 0 &&
                      len(baselineReceiptPath) > 0
    if anyProvided && !allProvided:
        return Err[bool]("v3 compiler equivalence: require --baseline-csg --baseline-surface --baseline-receipt together")
    if required && !allProvided:
        return Err[bool]("v3 compiler equivalence: missing --baseline-csg/--baseline-surface/--baseline-receipt")
    return Ok[bool](allProvided)

fn v3CompilerEquivalenceInputsReady(args: str[],
                                    required: bool): Result[bool] =
    let baselineCsgPath = creq.v3CompilerBaselineCsgPathFromArgs(args)
    let baselineSurfacePath = creq.v3CompilerBaselineSurfacePathFromArgs(args)
    let baselineReceiptPath = creq.v3CompilerBaselineReceiptPathFromArgs(args)
    let anyProvided = len(baselineCsgPath) > 0 ||
                      len(baselineSurfacePath) > 0 ||
                      len(baselineReceiptPath) > 0
    let allProvided = len(baselineCsgPath) > 0 &&
                      len(baselineSurfacePath) > 0 &&
                      len(baselineReceiptPath) > 0
    if anyProvided && !allProvided:
        return Err[bool]("v3 compiler equivalence: require --baseline-csg --baseline-surface --baseline-receipt together")
    if required && !allProvided:
        return Err[bool]("v3 compiler equivalence: missing --baseline-csg/--baseline-surface/--baseline-receipt")
    return Ok[bool](allProvided)

fn v3CompilerEquivalenceProofFromArgs(rootDir: str,
                                      args: str[],
                                      plan: sexec.V3SystemLinkExecPlan,
                                      out: var ceq.V3CompilerEquivalenceProof): Result[bool] =
    let baselineCsgPath = v3path.v3PathAbsolute(rootDir, creq.v3CompilerBaselineCsgPathFromArgs(args))
    if !v3path.v3PathFileExists(baselineCsgPath):
        return Err[bool]("v3 compiler equivalence: missing baseline csg: " + baselineCsgPath)
    let baselineSurfacePath = v3path.v3PathAbsolute(rootDir, creq.v3CompilerBaselineSurfacePathFromArgs(args))
    if !v3path.v3PathFileExists(baselineSurfacePath):
        return Err[bool]("v3 compiler equivalence: missing baseline surface: " + baselineSurfacePath)
    let baselineReceiptPath = v3path.v3PathAbsolute(rootDir, creq.v3CompilerBaselineReceiptPathFromArgs(args))
    if !v3path.v3PathFileExists(baselineReceiptPath):
        return Err[bool]("v3 compiler equivalence: missing baseline receipt: " + baselineReceiptPath)
    let baselineCsgText = v3path.v3ReadTextFile("", baselineCsgPath)
    let baselineSurfaceText = v3path.v3ReadTextFile("", baselineSurfacePath)
    let baselineReceiptText = v3path.v3ReadTextFile("", baselineReceiptPath)
    let migratedCsgText = ccsg.v3CompilerCsgReport(plan.compilerCsg)
    let migratedSurfaceText = ccsg.v3CompilerExportSurfaceReport(plan.exportSurface)
    let migratedReceiptText = ccsg.v3CompileReceiptReport(plan.compileReceipt)
    var baselineGraphCid = layout.fixedBytes32Zero()
    var migratedGraphCid = layout.fixedBytes32Zero()
    var graphEquivalent = 0
    let graphRes = ceq.v3CompilerEquivalenceGraphCompareTexts(baselineCsgText,
                                                              migratedCsgText,
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[bool](Error(graphRes))
    var baselineSurfaceCid = layout.fixedBytes32Zero()
    var migratedSurfaceCid = layout.fixedBytes32Zero()
    var exportSurfaceCompatible = 0
    let surfaceRes = ceq.v3CompilerEquivalenceSurfaceCompareTexts(baselineSurfaceText,
                                                                  migratedSurfaceText,
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[bool](Error(surfaceRes))
    var baselineReceiptCid = layout.fixedBytes32Zero()
    var migratedReceiptCid = layout.fixedBytes32Zero()
    var targetTriple = ""
    var compileReceiptEquivalent = 0
    let receiptRes = ceq.v3CompilerEquivalenceReceiptCompareTexts(baselineReceiptText,
                                                                  migratedReceiptText,
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[bool](Error(receiptRes))
    let packageId = plan.systemLinkPlan.packageId
    let channel = plan.localUniverse.worldHead.channel
    return ceq.v3CompilerEquivalenceProofMake(packageId,
                                              channel,
                                              baselineGraphCid,
                                              migratedGraphCid,
                                              baselineSurfaceCid,
                                              migratedSurfaceCid,
                                              baselineReceiptCid,
                                              migratedReceiptCid,
                                              targetTriple,
                                              graphEquivalent,
                                              exportSurfaceCompatible,
                                              compileReceiptEquivalent,
                                              out)

fn v3CompilerEquivalenceProofFromRuntimeFlags(rootDir: str,
                                              plan: sexec.V3SystemLinkExecPlan,
                                              out: var ceq.V3CompilerEquivalenceProof): Result[bool] =
    let baselineCsgPath = v3path.v3PathAbsolute(rootDir, cmdline.readFlagOrDefault("--baseline-csg", ""))
    if !v3path.v3PathFileExists(baselineCsgPath):
        return Err[bool]("v3 compiler equivalence: missing baseline csg: " + baselineCsgPath)
    let baselineSurfacePath = v3path.v3PathAbsolute(rootDir, cmdline.readFlagOrDefault("--baseline-surface", ""))
    if !v3path.v3PathFileExists(baselineSurfacePath):
        return Err[bool]("v3 compiler equivalence: missing baseline surface: " + baselineSurfacePath)
    let baselineReceiptPath = v3path.v3PathAbsolute(rootDir, cmdline.readFlagOrDefault("--baseline-receipt", ""))
    if !v3path.v3PathFileExists(baselineReceiptPath):
        return Err[bool]("v3 compiler equivalence: missing baseline receipt: " + baselineReceiptPath)
    let baselineCsgText = v3path.v3ReadTextFile("", baselineCsgPath)
    let baselineSurfaceText = v3path.v3ReadTextFile("", baselineSurfacePath)
    let baselineReceiptText = v3path.v3ReadTextFile("", baselineReceiptPath)
    let migratedCsgText = ccsg.v3CompilerCsgReport(plan.compilerCsg)
    let migratedSurfaceText = ccsg.v3CompilerExportSurfaceReport(plan.exportSurface)
    let migratedReceiptText = ccsg.v3CompileReceiptReport(plan.compileReceipt)
    var baselineGraphCid = layout.fixedBytes32Zero()
    var migratedGraphCid = layout.fixedBytes32Zero()
    var graphEquivalent = 0
    let graphRes = ceq.v3CompilerEquivalenceGraphCompareTexts(baselineCsgText,
                                                              migratedCsgText,
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[bool](Error(graphRes))
    var baselineSurfaceCid = layout.fixedBytes32Zero()
    var migratedSurfaceCid = layout.fixedBytes32Zero()
    var exportSurfaceCompatible = 0
    let surfaceRes = ceq.v3CompilerEquivalenceSurfaceCompareTexts(baselineSurfaceText,
                                                                  migratedSurfaceText,
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[bool](Error(surfaceRes))
    var baselineReceiptCid = layout.fixedBytes32Zero()
    var migratedReceiptCid = layout.fixedBytes32Zero()
    var targetTriple = ""
    var compileReceiptEquivalent = 0
    let receiptRes = ceq.v3CompilerEquivalenceReceiptCompareTexts(baselineReceiptText,
                                                                  migratedReceiptText,
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[bool](Error(receiptRes))
    let packageId = plan.systemLinkPlan.packageId
    let channel = plan.localUniverse.worldHead.channel
    return ceq.v3CompilerEquivalenceProofMake(packageId,
                                              channel,
                                              baselineGraphCid,
                                              migratedGraphCid,
                                              baselineSurfaceCid,
                                              migratedSurfaceCid,
                                              baselineReceiptCid,
                                              migratedReceiptCid,
                                              targetTriple,
                                              graphEquivalent,
                                              exportSurfaceCompatible,
                                              compileReceiptEquivalent,
                                              out)

fn v3CompilerPackageRootFromArgs(rootDir: str,
                                 args: str[]): str =
    let sourcePath = creq.v3CompilerReadFlagOrDefault(args, "--in", creq.v3CompilerLegacyInPathFromArgs(args))
    let packageRootRaw = creq.v3CompilerReadFlagOrDefault(args,
                                                          "--root",
                                                          creq.v3CompilerDefaultPackageRoot(rootDir))
    return creq.v3CompilerResolvePackageRoot(rootDir, sourcePath, packageRootRaw)

fn v3CompilerPackageRootFromRuntimeFlags(rootDir: str): str =
    let sourcePath = cmdline.readFlagOrDefault("--in", cmdline.readFlagOrDefault("--legacy-in", ""))
    let packageRootRaw = cmdline.readFlagOrDefault("--root", creq.v3CompilerDefaultPackageRoot(rootDir))
    return creq.v3CompilerResolvePackageRoot(rootDir, sourcePath, packageRootRaw)

fn v3CompilerBuildBackendDriver(rootDir: str): int32 =
    let outDir = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver")
    if !v3path.v3MkdirP(rootDir, outDir):
        v3CompilerPrintErr("v3 compiler: failed to create backend driver dir")
        return 2
    let packageRoot = v3path.v3PathAbsolute(rootDir, "v3")
    let compilerEntrySource = v3path.v3PathAbsolute(rootDir, "v3/src/tooling/compiler_main.cheng")
    let compilerRuntimeSource = v3path.v3PathAbsolute(rootDir, "v3/src/tooling/compiler_runtime.cheng")
    let compilerRequestSource = v3path.v3PathAbsolute(rootDir, "v3/src/tooling/compiler_request.cheng")
    let backendDriverOut = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/cheng")
    let backendDriverMapOut = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/cheng.v3.map")
    let backendDriverCandidateOut = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/cheng.next")
    let backendDriverCandidateMapOut = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/cheng.next.v3.map")
    let compileReportPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/build_backend_driver_v3.compile.report.txt")
    let compileLogPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/build_backend_driver_v3.log")
    let reportPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/build_backend_driver_v3.report.txt")
    let statusLogPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/build_backend_driver_v3.status.txt")
    let planLogPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/build_backend_driver_v3.plan.txt")
    let referencePlanLogPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/reference_backend_driver.plan.txt")
    let planCorePath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/build_backend_driver_v3.plan.core.txt")
    let referencePlanCorePath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/reference_backend_driver.plan.core.txt")
    let installLogPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/build_backend_driver_v3.install.txt")
    let smokeSource = v3path.v3PathAbsolute(rootDir, "v3/src/tests/ordinary_zero_exit_fixture.cheng")
    let smokeOut = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/ordinary_zero_exit_fixture.selftest")
    let smokeCompileReportPath = smokeOut + ".report.txt"
    let smokeCompileLogPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/ordinary_zero_exit_fixture.selftest.compile.log")
    let smokeRunLogPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/ordinary_zero_exit_fixture.selftest.run.log")
    let targetTriple = v3CompilerRequestedTarget()
    var currentCompiler = v3CompilerBridgeCompilerPath(rootDir)
    if len(currentCompiler) <= 0:
        currentCompiler = cmdline.programName()
    if len(currentCompiler) <= 0:
        v3CompilerPrintErr("v3 compiler: missing current compiler for build-backend-driver")
        return 2
    var compileArgs: str[] = []
    add(compileArgs, "system-link-exec")
    add(compileArgs, "--root:" + packageRoot)
    add(compileArgs, "--in:" + compilerEntrySource)
    add(compileArgs, "--emit:exe")
    add(compileArgs, "--target:" + targetTriple)
    add(compileArgs, "--out:" + backendDriverCandidateOut)
    add(compileArgs, "--report-out:" + compileReportPath)
    if !v3CompilerRunFileLogged(rootDir, currentCompiler, compileArgs, compileLogPath, "build-backend-driver compile"):
        return 2
    if !v3path.v3PathFileExists(backendDriverCandidateOut):
        v3CompilerPrintErr("v3 compiler: missing backend driver candidate output: " + backendDriverCandidateOut)
        return 2
    if !v3path.v3PathFileExists(backendDriverCandidateMapOut):
        v3CompilerPrintErr("v3 compiler: missing backend driver candidate map: " + backendDriverCandidateMapOut)
        return 2
    let statusArgs = ["status"]
    if !v3CompilerRunFileLogged(rootDir, backendDriverCandidateOut, statusArgs, statusLogPath, "build-backend-driver status"):
        return 2
    let planArgs = ["print-build-plan", "--target:" + targetTriple]
    if !v3CompilerRunFileLogged(rootDir, backendDriverCandidateOut, planArgs, planLogPath, "build-backend-driver plan"):
        return 2
    let bootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(rootDir)
    var referenceCompiler = currentCompiler
    let referencePlanArgs = ["print-build-plan", "--target:" + targetTriple]
    if !v3CompilerRunFileLogged(rootDir, referenceCompiler, referencePlanArgs, referencePlanLogPath, "build-backend-driver reference-plan"):
        return 2
    let currentPlanText = v3path.v3ReadTextFile("", referencePlanLogPath)
    if !v3CompilerTextContainsAll(currentPlanText, ["target=" + targetTriple]):
        let bootstrapReference = v3CompilerBootstrapCompilerPath(rootDir, bootstrapSnapshot)
        if len(bootstrapReference) > 0 && bootstrapReference != currentCompiler:
            referenceCompiler = bootstrapReference
            if !v3CompilerRunFileLogged(rootDir,
                                        referenceCompiler,
                                        referencePlanArgs,
                                        referencePlanLogPath,
                                        "build-backend-driver reference-plan"):
                return 2
    let referencePlanText = v3path.v3ReadTextFile("", referencePlanLogPath)
    var referencePlanCheck = "skip_target_mismatch"
    if v3CompilerTextContainsAll(referencePlanText, ["target=" + targetTriple]):
        let planCorePattern = "^(target=|linker=|stage2_compiler=|entry=|output=|source\\[)"
        var planCompareCommand = "grep -E "
        planCompareCommand = planCompareCommand + v3CompilerQuoteShell(planCorePattern)
        planCompareCommand = planCompareCommand + " "
        planCompareCommand = planCompareCommand + v3CompilerQuoteShell(planLogPath)
        planCompareCommand = planCompareCommand + " > "
        planCompareCommand = planCompareCommand + v3CompilerQuoteShell(planCorePath)
        planCompareCommand = planCompareCommand + " && grep -E "
        planCompareCommand = planCompareCommand + v3CompilerQuoteShell(planCorePattern)
        planCompareCommand = planCompareCommand + " "
        planCompareCommand = planCompareCommand + v3CompilerQuoteShell(referencePlanLogPath)
        planCompareCommand = planCompareCommand + " > "
        planCompareCommand = planCompareCommand + v3CompilerQuoteShell(referencePlanCorePath)
        planCompareCommand = planCompareCommand + " && cmp -s "
        planCompareCommand = planCompareCommand + v3CompilerQuoteShell(planCorePath)
        planCompareCommand = planCompareCommand + " "
        planCompareCommand = planCompareCommand + v3CompilerQuoteShell(referencePlanCorePath)
        if os.execCmdStatus(planCompareCommand, rootDir) != 0:
            v3CompilerPrintErr("v3 compiler: backend driver build plan drift vs current compiler")
            return 2
        referencePlanCheck = "ok"
    var smokeCompileArgs: str[] = []
    add(smokeCompileArgs, "system-link-exec")
    add(smokeCompileArgs, "--root:" + packageRoot)
    add(smokeCompileArgs, "--in:" + smokeSource)
    add(smokeCompileArgs, "--emit:exe")
    add(smokeCompileArgs, "--target:" + targetTriple)
    add(smokeCompileArgs, "--out:" + smokeOut)
    add(smokeCompileArgs, "--report-out:" + smokeCompileReportPath)
    if !v3CompilerRunFileLogged(rootDir,
                                backendDriverCandidateOut,
                                smokeCompileArgs,
                                smokeCompileLogPath,
                                "build-backend-driver zero-exit compile"):
        return 2
    if !v3path.v3PathFileExists(smokeOut) || !v3path.v3PathFileExists(smokeOut + ".v3.map"):
        v3CompilerPrintErr("v3 compiler: backend driver zero-exit smoke missing output: " + smokeOut)
        return 2
    let smokeRunArgs: str[] = []
    if !v3CompilerRunFileLogged(rootDir, smokeOut, smokeRunArgs, smokeRunLogPath, "build-backend-driver zero-exit run"):
        return 2
    let smokeRunText = strutil.strip(v3path.v3ReadTextFile("", smokeRunLogPath))
    if len(smokeRunText) > 0:
        v3CompilerPrintErr("v3 compiler: backend driver zero-exit smoke expected empty stdout")
        return 2
    var installReport = ""
    if v3path.v3PathFileExists(backendDriverMapOut):
        if !os.removeFile(backendDriverMapOut):
            installReport = installReport + "map_remove_existing=failed\n"
            v3path.v3WriteTextFile(rootDir, installLogPath, installReport)
            v3CompilerPrintErr("v3 compiler: failed to remove existing backend driver map: " + backendDriverMapOut)
            return 2
        installReport = installReport + "map_remove_existing=ok\n"
    if !os.renameFile(backendDriverCandidateMapOut, backendDriverMapOut):
        installReport = installReport + "map_rename=failed\n"
        v3path.v3WriteTextFile(rootDir, installLogPath, installReport)
        v3CompilerPrintErr("v3 compiler: failed to install backend driver map: " + backendDriverMapOut)
        return 2
    installReport = installReport + "map_rename=ok\n"
    if v3path.v3PathFileExists(backendDriverOut):
        if !os.removeFile(backendDriverOut):
            installReport = installReport + "binary_remove_existing=failed\n"
            v3path.v3WriteTextFile(rootDir, installLogPath, installReport)
            v3CompilerPrintErr("v3 compiler: failed to remove existing backend driver output: " + backendDriverOut)
            return 2
        installReport = installReport + "binary_remove_existing=ok\n"
    if !os.renameFile(backendDriverCandidateOut, backendDriverOut):
        installReport = installReport + "binary_rename=failed\n"
        v3path.v3WriteTextFile(rootDir, installLogPath, installReport)
        v3CompilerPrintErr("v3 compiler: failed to install backend driver output: " + backendDriverOut)
        return 2
    installReport = installReport + "binary_rename=ok\n"
    if !v3path.v3WriteTextFile(rootDir, installLogPath, installReport):
        v3CompilerPrintErr("v3 compiler: failed to write backend driver install log: " + installLogPath)
        return 2
    var report = ""
    report = report + "target=" + targetTriple + "\n"
    report = report + "bootstrap_kind=v3_selfhost\n"
    report = report + "compiler_class=ordinary_compiler\n"
    report = report + "current_compiler=" + currentCompiler + "\n"
    report = report + "reference_compiler=" + referenceCompiler + "\n"
    report = report + "reference_plan_check=" + referencePlanCheck + "\n"
    report = report + "planned_entry_source=" + compilerEntrySource + "\n"
    report = report + "planned_runtime_source=" + compilerRuntimeSource + "\n"
    report = report + "planned_request_source=" + compilerRequestSource + "\n"
    report = report + "materialized_source=" + compilerEntrySource + "\n"
    report = report + "candidate_output=" + backendDriverCandidateOut + "\n"
    report = report + "candidate_map=" + backendDriverCandidateMapOut + "\n"
    report = report + "output=" + backendDriverOut + "\n"
    report = report + "output_map=" + backendDriverMapOut + "\n"
    report = report + "status_log=" + statusLogPath + "\n"
    report = report + "plan_log=" + planLogPath + "\n"
    report = report + "reference_plan_log=" + referencePlanLogPath + "\n"
    report = report + "log=" + compileLogPath + "\n"
    report = report + "install_log=" + installLogPath + "\n"
    report = report + "zero_exit_smoke_source=" + smokeSource + "\n"
    report = report + "zero_exit_smoke_output=" + smokeOut + "\n"
    report = report + "zero_exit_smoke_report=" + smokeCompileReportPath + "\n"
    report = report + "zero_exit_smoke_compile_log=" + smokeCompileLogPath + "\n"
    report = report + "zero_exit_smoke_run_log=" + smokeRunLogPath + "\n"
    if !v3path.v3WriteTextFile(rootDir, reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write backend driver report: " + reportPath)
        return 2
    v3CompilerPrintLine("v3 backend driver ok: " + backendDriverOut)
    return 0

fn v3CompilerBootstrapTarget(rootDir: str): str =
    let ignoredRootDir = rootDir
    return v3CompilerRequestedTarget()

fn v3CompilerBootstrapLog(rootDir: str,
                          name: str): str =
    return v3path.v3PathAbsolute(rootDir, "artifacts/v3_bootstrap/" + name)

fn v3CompilerPathNewerThan(rootDir: str,
                           leftPath: str,
                           rightPath: str): bool =
    if !v3path.v3PathFileExists(leftPath):
        return false
    let command = "test " + v3CompilerQuoteShell(leftPath) + " -nt " + v3CompilerQuoteShell(rightPath)
    return os.execCmdStatus(command, rootDir) == 0

fn v3CompilerBootstrapEnvText(rootDir: str,
                              snapshot: contracts.V3BootstrapSnapshot): str =
    var out = ""
    out = out + "V3_ROOT=" + rootDir + "\n"
    out = out + "V3_TARGET=" + v3CompilerBootstrapTarget(rootDir) + "\n"
    out = out + "V3_BOOTSTRAP_KIND=" + snapshot.bootstrapMode + "\n"
    out = out + "V3_BOOTSTRAP_STAGE1_SOURCE=" + snapshot.stage1Source.path + "\n"
    out = out + "V3_COMPILER_ENTRY_SOURCE=" + contracts.v3BootstrapCompilerEntrySourcePath(rootDir) + "\n"
    out = out + "V3_COMPILER_RUNTIME_SOURCE=" + contracts.v3BootstrapCompilerRuntimeSourcePath(rootDir) + "\n"
    out = out + "V3_COMPILER_REQUEST_SOURCE=" + contracts.v3BootstrapCompilerRequestSourcePath(rootDir) + "\n"
    out = out + "V3_BOOTSTRAP_STAGE0=" + snapshot.stage0Compiler.path + "\n"
    out = out + "V3_BOOTSTRAP_STAGE1=" + snapshot.stage1Compiler.path + "\n"
    out = out + "V3_BOOTSTRAP_STAGE2=" + snapshot.stage2Compiler.path + "\n"
    out = out + "V3_BOOTSTRAP_STAGE3=" + snapshot.stage3Compiler.path + "\n"
    out = out + "V3_BOOTSTRAP_ENV=" + snapshot.bootstrapEnv.path + "\n"
    out = out + "V3_BOOTSTRAP_SNAPSHOT=" + contracts.v3BootstrapSnapshotPath(rootDir) + "\n"
    out = out + "V3_BOOTSTRAP_STAGE1_REPORT=" + v3CompilerBootstrapLog(rootDir, "cheng.stage1.report.txt") + "\n"
    out = out + "V3_BOOTSTRAP_STAGE2_REPORT=" + v3CompilerBootstrapLog(rootDir, "cheng.stage2.report.txt") + "\n"
    out = out + "V3_BOOTSTRAP_STAGE3_REPORT=" + v3CompilerBootstrapLog(rootDir, "cheng.stage3.report.txt") + "\n"
    return out

fn v3CompilerBootstrapSnapshotText(rootDir: str,
                                   snapshot: contracts.V3BootstrapSnapshot): str =
    var out = ""
    out = out + "target=" + v3CompilerBootstrapTarget(rootDir) + "\n"
    out = out + "bootstrap_kind=" + snapshot.bootstrapMode + "\n"
    out = out + "stage1_source=" + snapshot.stage1Source.path + "\n"
    out = out + "compiler_entry_source=" + contracts.v3BootstrapCompilerEntrySourcePath(rootDir) + "\n"
    out = out + "compiler_runtime_source=" + contracts.v3BootstrapCompilerRuntimeSourcePath(rootDir) + "\n"
    out = out + "compiler_request_source=" + contracts.v3BootstrapCompilerRequestSourcePath(rootDir) + "\n"
    out = out + "stage0=" + snapshot.stage0Compiler.path + "\n"
    out = out + "stage1=" + snapshot.stage1Compiler.path + "\n"
    out = out + "stage2=" + snapshot.stage2Compiler.path + "\n"
    out = out + "stage3=" + snapshot.stage3Compiler.path + "\n"
    out = out + "stage1_report=" + v3CompilerBootstrapLog(rootDir, "cheng.stage1.report.txt") + "\n"
    out = out + "stage2_report=" + v3CompilerBootstrapLog(rootDir, "cheng.stage2.report.txt") + "\n"
    out = out + "stage3_report=" + v3CompilerBootstrapLog(rootDir, "cheng.stage3.report.txt") + "\n"
    out = out + "stage0_build_log=" + v3CompilerBootstrapLog(rootDir, "cheng.stage0.build.log") + "\n"
    out = out + "stage0_self_check_log=" + v3CompilerBootstrapLog(rootDir, "cheng.stage0.self-check.log") + "\n"
    out = out + "stage1_build_log=" + v3CompilerBootstrapLog(rootDir, "cheng.stage1.compile.log") + "\n"
    out = out + "stage1_self_check_log=" + v3CompilerBootstrapLog(rootDir, "cheng.stage1.self-check.log") + "\n"
    out = out + "stage2_build_log=" + v3CompilerBootstrapLog(rootDir, "cheng.stage2.compile.log") + "\n"
    out = out + "stage2_self_check_log=" + v3CompilerBootstrapLog(rootDir, "cheng.stage2.self-check.log") + "\n"
    out = out + "stage3_build_log=" + v3CompilerBootstrapLog(rootDir, "cheng.stage3.compile.log") + "\n"
    out = out + "stage3_self_check_log=" + v3CompilerBootstrapLog(rootDir, "cheng.stage3.self-check.log") + "\n"
    out = out + "stage2_contract_log=" + v3CompilerBootstrapLog(rootDir, "cheng.stage2.contract.txt") + "\n"
    out = out + "stage3_contract_log=" + v3CompilerBootstrapLog(rootDir, "cheng.stage3.contract.txt") + "\n"
    out = out + "bootstrap_install_log=" + v3CompilerBootstrapLog(rootDir, "bootstrap_bridge_v3.install.txt") + "\n"
    out = out + "fixed_point=stage2_stage3_contract_match\n"
    return out

fn v3CompilerBootstrapStageRun(rootDir: str,
                               label: str,
                               binPath: str,
                               args: str[],
                               logPath: str): bool =
    var command = v3CompilerQuoteShell(binPath)
    for i in 0..<args.len:
        command = command + " " + v3CompilerQuoteShell(args[i])
    return v3CompilerRunCommandLogged(rootDir, command, logPath, "bootstrap-bridge " + label)

fn v3CompilerBootstrapCompilerPath(rootDir: str,
                                   snapshot: contracts.V3BootstrapSnapshot): str =
    if v3path.v3FileExistsNonEmpty(rootDir, snapshot.stage3Compiler.path):
        return snapshot.stage3Compiler.path
    if v3path.v3FileExistsNonEmpty(rootDir, snapshot.stage2Compiler.path):
        return snapshot.stage2Compiler.path
    if v3path.v3FileExistsNonEmpty(rootDir, snapshot.stage1Compiler.path):
        return snapshot.stage1Compiler.path
    if v3path.v3FileExistsNonEmpty(rootDir, snapshot.stage0Compiler.path):
        return snapshot.stage0Compiler.path
    return ""

fn v3CompilerBootstrapBridgeFresh(rootDir: str,
                                  snapshot: contracts.V3BootstrapSnapshot): bool =
    return v3path.v3FileExistsNonEmpty(rootDir, snapshot.stage2Compiler.path) &&
           v3path.v3FileExistsNonEmpty(rootDir, snapshot.stage3Compiler.path) &&
           v3path.v3PathFileExists(snapshot.bootstrapEnv.path) &&
           !v3CompilerPathNewerThan(rootDir, snapshot.stage1Source.path, snapshot.stage3Compiler.path) &&
           !v3CompilerPathNewerThan(rootDir,
                                    contracts.v3BootstrapCompilerEntrySourcePath(rootDir),
                                    snapshot.stage3Compiler.path) &&
           !v3CompilerPathNewerThan(rootDir,
                                    contracts.v3BootstrapCompilerRuntimeSourcePath(rootDir),
                                    snapshot.stage3Compiler.path) &&
           !v3CompilerPathNewerThan(rootDir,
                                    contracts.v3BootstrapCompilerRequestSourcePath(rootDir),
                                    snapshot.stage3Compiler.path) &&
           !v3CompilerPathNewerThan(rootDir,
                                    contracts.v3BootstrapGateMainSourcePath(rootDir),
                                    snapshot.stage3Compiler.path)

fn v3CompilerBootstrapMaterializeStage0Candidate(rootDir: str,
                                                 compilerPath: str,
                                                 candidatePath: str): bool =
    let logPath = v3CompilerBootstrapLog(rootDir, "cheng.stage0.materialize.log")
    let linkCommand = "rm -f " + v3CompilerQuoteShell(candidatePath) + " && ln -s " +
                      v3CompilerQuoteShell(compilerPath) + " " + v3CompilerQuoteShell(candidatePath)
    if !v3CompilerRunCommandLogged(rootDir, linkCommand, logPath, "bootstrap-bridge stage0-symlink"):
        return false
    if !v3path.v3WriteTextFile(rootDir,
                               v3CompilerBootstrapLog(rootDir, "cheng.stage0.build.log"),
                               "stage0_symlinked_from=" + compilerPath + "\n"):
        return false
    return v3path.v3PathFileExists(candidatePath)

fn v3CompilerBootstrapInstallCandidate(rootDir: str,
                                       candidatePath: str,
                                       finalPath: str,
                                       installLogPath: str,
                                       label: str,
                                       installReport: var str): bool =
    if !v3path.v3PathFileExists(candidatePath):
        installReport = installReport + label + "_rename=missing_candidate\n"
        let ignoredWriteInstallLog = v3path.v3WriteTextFile(rootDir, installLogPath, installReport)
        return false
    if !os.renameFile(candidatePath, finalPath):
        installReport = installReport + label + "_rename=failed\n"
        let ignoredWriteInstallLog = v3path.v3WriteTextFile(rootDir, installLogPath, installReport)
        return false
    installReport = installReport + label + "_rename=ok\n"
    return v3path.v3WriteTextFile(rootDir, installLogPath, installReport)

fn v3CompilerBootstrapBridge(rootDir: str): int32 =
    let snapshot = contracts.v3BootstrapSnapshotDefault(rootDir)
    let outDir = contracts.v3BootstrapOutDir(rootDir)
    if !v3path.v3MkdirP(rootDir, outDir):
        v3CompilerPrintErr("v3 compiler: failed to create bootstrap dir")
        return 2
    if !v3path.v3PathFileExists(snapshot.stage1Source.path):
        v3CompilerPrintErr("v3 compiler: missing stage1 source: " + snapshot.stage1Source.path)
        return 2
    if v3CompilerBootstrapBridgeFresh(rootDir, snapshot):
        if !v3path.v3WriteTextFile(rootDir, snapshot.bootstrapEnv.path, v3CompilerBootstrapEnvText(rootDir, snapshot)):
            v3CompilerPrintErr("v3 compiler: failed to write bootstrap env: " + snapshot.bootstrapEnv.path)
            return 2
        if !v3path.v3WriteTextFile(rootDir,
                                   contracts.v3BootstrapSnapshotPath(rootDir),
                                   v3CompilerBootstrapSnapshotText(rootDir, snapshot)):
            v3CompilerPrintErr("v3 compiler: failed to write bootstrap snapshot: " +
                               contracts.v3BootstrapSnapshotPath(rootDir))
            return 2
        v3CompilerPrintLine("v3 bootstrap bridge ok: " + snapshot.stage2Compiler.path)
        return 0
    let bootstrapCompiler = v3CompilerBootstrapCompilerPath(rootDir, snapshot)
    if len(bootstrapCompiler) <= 0:
        v3CompilerPrintErr("v3 compiler: missing live bootstrap compiler")
        return 2
    if v3CompilerPathNewerThan(rootDir, contracts.v3BootstrapSeedSourcePath(rootDir), bootstrapCompiler):
        v3CompilerPrintErr("v3 compiler: seed source newer than live bootstrap compiler; rebuild stage0 and rerun bootstrap-bridge")
        return 2
    let stage0Candidate = snapshot.stage0Compiler.path + ".next"
    let stage1Candidate = snapshot.stage1Compiler.path + ".next"
    let stage2Candidate = snapshot.stage2Compiler.path + ".next"
    let stage3Candidate = snapshot.stage3Compiler.path + ".next"
    let stage1ReportPath = v3CompilerBootstrapLog(rootDir, "cheng.stage1.report.txt")
    let stage2ReportPath = v3CompilerBootstrapLog(rootDir, "cheng.stage2.report.txt")
    let stage3ReportPath = v3CompilerBootstrapLog(rootDir, "cheng.stage3.report.txt")
    let installLogPath = v3CompilerBootstrapLog(rootDir, "bootstrap_bridge_v3.install.txt")
    if !v3CompilerBootstrapMaterializeStage0Candidate(rootDir, bootstrapCompiler, stage0Candidate):
        v3CompilerPrintErr("v3 compiler: failed to materialize stage0 candidate: " + stage0Candidate)
        return 2
    if !v3CompilerBootstrapStageRun(rootDir,
                                    "stage0_self_check",
                                    stage0Candidate,
                                    ["self-check", "--in:" + snapshot.stage1Source.path],
                                    v3CompilerBootstrapLog(rootDir, "cheng.stage0.self-check.log")):
        return 2
    if !v3CompilerBootstrapStageRun(rootDir,
                                    "stage1_compile",
                                    stage0Candidate,
                                    [
                                        "compile-bootstrap",
                                        "--in:" + snapshot.stage1Source.path,
                                        "--out:" + stage1Candidate,
                                        "--report-out:" + stage1ReportPath
                                    ],
                                    v3CompilerBootstrapLog(rootDir, "cheng.stage1.compile.log")):
        return 2
    if !v3CompilerBootstrapStageRun(rootDir,
                                    "stage1_self_check",
                                    stage1Candidate,
                                    ["self-check", "--in:" + snapshot.stage1Source.path],
                                    v3CompilerBootstrapLog(rootDir, "cheng.stage1.self-check.log")):
        return 2
    if !v3CompilerBootstrapStageRun(rootDir,
                                    "stage2_compile",
                                    stage1Candidate,
                                    [
                                        "compile-bootstrap",
                                        "--in:" + snapshot.stage1Source.path,
                                        "--out:" + stage2Candidate,
                                        "--report-out:" + stage2ReportPath
                                    ],
                                    v3CompilerBootstrapLog(rootDir, "cheng.stage2.compile.log")):
        return 2
    if !v3CompilerBootstrapStageRun(rootDir,
                                    "stage2_self_check",
                                    stage2Candidate,
                                    ["self-check", "--in:" + snapshot.stage1Source.path],
                                    v3CompilerBootstrapLog(rootDir, "cheng.stage2.self-check.log")):
        return 2
    if !v3CompilerBootstrapStageRun(rootDir,
                                    "stage3_compile",
                                    stage2Candidate,
                                    [
                                        "compile-bootstrap",
                                        "--in:" + snapshot.stage1Source.path,
                                        "--out:" + stage3Candidate,
                                        "--report-out:" + stage3ReportPath
                                    ],
                                    v3CompilerBootstrapLog(rootDir, "cheng.stage3.compile.log")):
        return 2
    if !v3CompilerBootstrapStageRun(rootDir,
                                    "stage3_self_check",
                                    stage3Candidate,
                                    ["self-check", "--in:" + snapshot.stage1Source.path],
                                    v3CompilerBootstrapLog(rootDir, "cheng.stage3.self-check.log")):
        return 2
    if !v3CompilerBootstrapStageRun(rootDir,
                                    "stage2_contract",
                                    stage2Candidate,
                                    ["print-contract", "--in:" + snapshot.stage1Source.path],
                                    v3CompilerBootstrapLog(rootDir, "cheng.stage2.contract.txt")):
        return 2
    if !v3CompilerBootstrapStageRun(rootDir,
                                    "stage3_contract",
                                    stage3Candidate,
                                    ["print-contract", "--in:" + snapshot.stage1Source.path],
                                    v3CompilerBootstrapLog(rootDir, "cheng.stage3.contract.txt")):
        return 2
    let stage2Contract = v3path.v3ReadTextFile("", v3CompilerBootstrapLog(rootDir, "cheng.stage2.contract.txt"))
    let stage3Contract = v3path.v3ReadTextFile("", v3CompilerBootstrapLog(rootDir, "cheng.stage3.contract.txt"))
    if stage2Contract != stage3Contract:
        v3CompilerPrintErr("v3 compiler: fixed point mismatch stage2/stage3 contract drift")
        return 2
    var installReport = ""
    if !v3CompilerBootstrapInstallCandidate(rootDir,
                                            stage0Candidate,
                                            snapshot.stage0Compiler.path,
                                            installLogPath,
                                            "stage0",
                                            installReport):
        v3CompilerPrintErr("v3 compiler: failed to install bootstrap stage0: " + snapshot.stage0Compiler.path)
        return 2
    if !v3CompilerBootstrapInstallCandidate(rootDir,
                                            stage1Candidate,
                                            snapshot.stage1Compiler.path,
                                            installLogPath,
                                            "stage1",
                                            installReport):
        v3CompilerPrintErr("v3 compiler: failed to install bootstrap stage1: " + snapshot.stage1Compiler.path)
        return 2
    if !v3CompilerBootstrapInstallCandidate(rootDir,
                                            stage2Candidate,
                                            snapshot.stage2Compiler.path,
                                            installLogPath,
                                            "stage2",
                                            installReport):
        v3CompilerPrintErr("v3 compiler: failed to install bootstrap stage2: " + snapshot.stage2Compiler.path)
        return 2
    if !v3CompilerBootstrapInstallCandidate(rootDir,
                                            stage3Candidate,
                                            snapshot.stage3Compiler.path,
                                            installLogPath,
                                            "stage3",
                                            installReport):
        v3CompilerPrintErr("v3 compiler: failed to install bootstrap stage3: " + snapshot.stage3Compiler.path)
        return 2
    if !v3path.v3WriteTextFile(rootDir, snapshot.bootstrapEnv.path, v3CompilerBootstrapEnvText(rootDir, snapshot)):
        v3CompilerPrintErr("v3 compiler: failed to write bootstrap env: " + snapshot.bootstrapEnv.path)
        return 2
    if !v3path.v3WriteTextFile(rootDir,
                               contracts.v3BootstrapSnapshotPath(rootDir),
                               v3CompilerBootstrapSnapshotText(rootDir, snapshot)):
        v3CompilerPrintErr("v3 compiler: failed to write bootstrap snapshot: " +
                           contracts.v3BootstrapSnapshotPath(rootDir))
        return 2
    v3CompilerPrintLine("v3 bootstrap bridge ok: " + snapshot.stage2Compiler.path)
    return 0

fn v3CompilerHostBridgeAuditText(rootDir: str): str =
    let stdOsPath = v3path.v3PathAbsolute(rootDir, "src/std/os.cheng")
    let hostProcessPath = v3path.v3PathAbsolute(rootDir, "src/std/os_host_process.cheng")
    let backendPath = v3path.v3PathAbsolute(rootDir, "v3/src/runtime/program_support_backend_v3.cheng")
    let peerIdPath = v3path.v3PathAbsolute(rootDir, "v3/src/libp2p/core/peer_id.cheng")
    let runtimeContractText = v3CompilerRuntimeAbiContractText(rootDir)
    let runtimeAuthorityPath = v3CompilerRuntimeAbiPath(
        rootDir,
        runtimeContractText,
        "BACKEND_RUNTIME_ABI_AUTHORITY",
        "src/std/system_helpers_backend.cheng"
    )
    let stdOsText = v3path.v3ReadTextFile("", stdOsPath)
    let hostProcessText = v3path.v3ReadTextFile("", hostProcessPath)
    let backendText = v3path.v3ReadTextFile("", backendPath)
    let peerIdText = v3path.v3ReadTextFile("", peerIdPath)
    let legacyExecFileCaptureBridge = strutil.contains(hostProcessText, "@importc(\"cheng_exec_file_capture_bridge\")") ||
                                      strutil.contains(backendText, "@exportc(\"cheng_exec_file_capture_bridge\")")
    let legacyExecFilePipeBridge = strutil.contains(hostProcessText, "cheng_exec_file_pipe_spawn_bridge")
    let legacyExecFilePipeImport = strutil.contains(backendText, "@importc(\"cheng_exec_file_pipe_spawn\")")
    let legacyExecCmdFileRaw = strutil.contains(stdOsText, "cheng_exec_file_capture_raw")
    let directProgramRuntimeC = strutil.contains(backendText, "system_helpers_program_runtime_bridge.c")
    let legacyPeerIdBase58Bridge = strutil.contains(peerIdText, "cheng_v3_base58btc_encode_bridge") ||
                                   strutil.contains(peerIdText, "cheng_v3_base58btc_decode_bridge") ||
                                   strutil.contains(backendText, "@exportc(\"cheng_v3_base58btc_encode_bridge\")") ||
                                   strutil.contains(backendText, "@exportc(\"cheng_v3_base58btc_decode_bridge\")") ||
                                   strutil.contains(backendText, "fn cheng_base58btc_value(") ||
                                   strutil.contains(backendText, "fn cheng_base58btc_encode_raw(") ||
                                   strutil.contains(backendText, "fn cheng_base58btc_decode_raw(")
    let pureFsReady = strutil.contains(backendText, "@exportc(\"cheng_getcwd\")") &&
                      strutil.contains(backendText, "@exportc(\"cheng_file_exists\")") &&
                      strutil.contains(backendText, "@exportc(\"cheng_dir_exists\")") &&
                      strutil.contains(backendText, "@exportc(\"cheng_mkdir1\")") &&
                      strutil.contains(backendText, "@exportc(\"cheng_file_size\")") &&
                      strutil.contains(backendText, "@exportc(\"cheng_file_mtime\")")
    let pureSocketReady = strutil.contains(backendText, "@exportc(\"libc_socket\")") &&
                          strutil.contains(backendText, "@exportc(\"libc_bind\")") &&
                          strutil.contains(backendText, "@exportc(\"libc_getsockname\")") &&
                          strutil.contains(backendText, "@exportc(\"cheng_recvfrom_fd_ex\")") &&
                          strutil.contains(backendText, "@exportc(\"cheng_v3_udp_recvfrom_addr_bridge\")") &&
                          strutil.contains(backendText, "@exportc(\"cheng_v3_udp_bind_fd_bridge\")") &&
                          strutil.contains(backendText, "@exportc(\"cheng_v3_udp_bound_port_bridge\")") &&
                          strutil.contains(backendText, "@exportc(\"cheng_v3_udp_platform_use_len_field_bridge\")") &&
                          strutil.contains(backendText, "@exportc(\"cheng_v3_udp_platform_msg_dontwait_bridge\")")
    let pureEntropyReady = strutil.contains(backendText, "@exportc(\"cheng_system_entropy_fill\")")
    let legacyProcessImportsRaw = strutil.contains(hostProcessText, "@importc(\"cheng_pipe_spawn\")") ||
                                  strutil.contains(hostProcessText, "@importc(\"cheng_pty_spawn\")") ||
                                  strutil.contains(hostProcessText, "@importc(\"cheng_pty_read\")") ||
                                  strutil.contains(hostProcessText, "@importc(\"cheng_fd_read\")") ||
                                  strutil.contains(hostProcessText, "@importc(\"cheng_fd_read_wait\")") ||
                                  strutil.contains(hostProcessText, "@importc(\"cheng_pty_wait\")")
    let processBridgeImportsReady = strutil.contains(hostProcessText, "@importc(\"cheng_pty_is_supported_bridge\")") &&
                                    strutil.contains(hostProcessText, "@importc(\"cheng_pipe_spawn_bridge\")") &&
                                    strutil.contains(hostProcessText, "@importc(\"cheng_pty_spawn_bridge\")") &&
                                    strutil.contains(hostProcessText, "@importc(\"cheng_pty_read_bridge\")") &&
                                    strutil.contains(hostProcessText, "@importc(\"cheng_fd_read_bridge\")") &&
                                    strutil.contains(hostProcessText, "@importc(\"cheng_fd_read_wait_bridge\")") &&
                                    strutil.contains(hostProcessText, "@importc(\"cheng_pty_write_bridge\")") &&
                                    strutil.contains(hostProcessText, "@importc(\"cheng_pty_close_bridge\")") &&
                                    strutil.contains(hostProcessText, "@importc(\"cheng_pty_wait_bridge\")")
    let processBridgeExportsReady = strutil.contains(backendText, "@exportc(\"cheng_pty_is_supported_bridge\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pty_spawn_bridge\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pty_spawn_bridge_last_master_fd\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pty_spawn_bridge_last_pid\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pipe_spawn_bridge\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pipe_spawn_bridge_last_read_fd\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pipe_spawn_bridge_last_write_fd\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pipe_spawn_bridge_last_pid\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pty_read_bridge\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pty_read_bridge_last_eof\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_fd_read_bridge\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_fd_read_bridge_last_eof\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_fd_read_wait_bridge\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_fd_read_wait_bridge_last_eof\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pty_write_bridge\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pty_close_bridge\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pty_wait_bridge\")") &&
                                    strutil.contains(backendText, "@exportc(\"cheng_pty_wait_bridge_last_exit_code\")")
    let pureProcessReady = !legacyProcessImportsRaw && processBridgeImportsReady && processBridgeExportsReady
    var remainingBoundary = ""
    if !pureProcessReady:
        remainingBoundary = "process"
    if !pureFsReady:
        if len(remainingBoundary) > 0:
            remainingBoundary = remainingBoundary + "_"
        remainingBoundary = remainingBoundary + "fs"
    if !pureSocketReady:
        if len(remainingBoundary) > 0:
            remainingBoundary = remainingBoundary + "_"
        remainingBoundary = remainingBoundary + "socket"
    if !pureEntropyReady:
        if len(remainingBoundary) > 0:
            remainingBoundary = remainingBoundary + "_"
        remainingBoundary = remainingBoundary + "entropy"
    if len(remainingBoundary) == 0:
        remainingBoundary = "none"
    var out = ""
    out = out + "v3_host_bridge_audit_v1\n"
    out = out + "std_os_path=" + stdOsPath + "\n"
    out = out + "host_process_path=" + hostProcessPath + "\n"
    out = out + "peer_id_path=" + peerIdPath + "\n"
    out = out + "program_support_backend_path=" + backendPath + "\n"
    out = out + "runtime_authority_path=" + runtimeAuthorityPath + "\n"
    if legacyExecCmdFileRaw:
        out = out + "legacy_exec_file_capture_raw_present=1\n"
    else:
        out = out + "legacy_exec_file_capture_raw_present=0\n"
    if legacyExecFileCaptureBridge:
        out = out + "legacy_exec_file_capture_bridge_present=1\n"
    else:
        out = out + "legacy_exec_file_capture_bridge_present=0\n"
    if legacyExecFilePipeBridge:
        out = out + "legacy_exec_file_pipe_bridge_present=1\n"
    else:
        out = out + "legacy_exec_file_pipe_bridge_present=0\n"
    if legacyExecFilePipeImport:
        out = out + "legacy_exec_file_pipe_import_present=1\n"
    else:
        out = out + "legacy_exec_file_pipe_import_present=0\n"
    if directProgramRuntimeC:
        out = out + "direct_program_runtime_c_path_present=1\n"
    else:
        out = out + "direct_program_runtime_c_path_present=0\n"
    if legacyPeerIdBase58Bridge:
        out = out + "legacy_peer_id_base58_bridge_present=1\n"
        out = out + "libp2p_peer_id_pure_cheng_ready=0\n"
    else:
        out = out + "legacy_peer_id_base58_bridge_present=0\n"
        out = out + "libp2p_peer_id_pure_cheng_ready=1\n"
    if pureFsReady:
        out = out + "pure_cheng_fs_ready=1\n"
    else:
        out = out + "pure_cheng_fs_ready=0\n"
    if pureSocketReady:
        out = out + "pure_cheng_socket_ready=1\n"
    else:
        out = out + "pure_cheng_socket_ready=0\n"
    if pureEntropyReady:
        out = out + "pure_cheng_entropy_ready=1\n"
    else:
        out = out + "pure_cheng_entropy_ready=0\n"
    if pureProcessReady:
        out = out + "pure_cheng_process_ready=1\n"
    else:
        out = out + "pure_cheng_process_ready=0\n"
    out = out + "remaining_non_pure_cheng_boundary=" + remainingBoundary + "\n"
    if remainingBoundary == "none":
        out = out + "pure_cheng_zero_c_ready=1\n"
    else:
        out = out + "pure_cheng_zero_c_ready=0\n"
    return strutil.strip(out)

fn v3CompilerHostBridgeAudit(rootDir: str): int32 =
    let out = v3CompilerHostBridgeAuditText(rootDir)
    v3CompilerPrintBlock(out)
    if strutil.contains(out, "legacy_exec_file_capture_raw_present=1") ||
       strutil.contains(out, "legacy_exec_file_capture_bridge_present=1") ||
       strutil.contains(out, "legacy_exec_file_pipe_bridge_present=1") ||
       strutil.contains(out, "legacy_exec_file_pipe_import_present=1") ||
       strutil.contains(out, "legacy_peer_id_base58_bridge_present=1"):
        return 2
    return 0

fn v3CompilerR2cReactFreshCleanGate(rootDir: str,
                                    args: str[]): int32 =
    let repoRaw = cmdline.readFlagOrDefault("--repo", "/Users/lbcheng/UniMaker/React.js")
    let repo = v3path.v3PathAbsolute(rootDir, repoRaw)
    if !os.dirExists(repo):
        v3CompilerPrintErr("v3 compiler: missing React.js repo: " + repo)
        return 2
    let statusOut = "/tmp/r2c-status-fresh-clean-gate.json"
    let smokeNames: str[] = [
        "compiler_runtime_smoke",
        "host_process_pipe_spawn_bridge_smoke",
        "host_process_pipe_spawn_api_smoke",
        "host_process_exec_file_capture_smoke",
        "host_process_exec_file_direct_seq_smoke"
    ]
    let routeStates: str[] = ["home_default", "content_detail", "publish_selector"]
    let codegenSmokeOutDir = "/tmp/r2c-codegen-surface-fresh-clean-gate"
    let statusNeedles: str[] = [
        "\"static_surface_helper\": \"\"",
        "\"semantic_surface_helper\": \"\"",
        "r2c-react-v3-truth-runtime.mjs",
        "\"exec_surface_helper\": \"\"",
        "\"native_gui_runtime_helper\": \"\"",
        "\"native_gui_replay_hit_inspector_helper\": \"\"",
        "\"legacy_wrapper_required\": false",
        "\"active_node_helper_count\": 6",
        "\"retired_node_helper_count\": 7",
        "\"standalone_node_helper_count\": 1",
        "\"retired_node_helpers\": [\"native_gui_runtime_helper\", \"native_gui_replay_hit_inspector_helper\", \"semantic_surface_helper\", \"static_surface_helper\", \"exec_surface_helper\", \"truth_compare_helper\", \"truth_compare_matrix_helper\"]",
        "\"standalone_node_helpers\": [\"truth_runtime_helper\"]"
    ]
    let reportNeedles: str[] = [
        "\"ok\": true",
        "\"native_gui_host_ready\": true",
        "\"native_gui_renderer_ready\": true"
    ]
    if !v3CompilerRemovePathTree(statusOut):
        v3CompilerPrintErr("v3 compiler: failed to clear status report: " + statusOut)
        return 2
    for i in 0..<routeStates.len:
        let bundleOutDir = "/tmp/r2c-native-gui-fresh-clean-gate-" + routeStates[i]
        if !v3CompilerRemovePathTree(bundleOutDir):
            v3CompilerPrintErr("v3 compiler: failed to clear bundle dir: " + bundleOutDir)
            return 2
    if !v3CompilerRemovePathTree(codegenSmokeOutDir):
        v3CompilerPrintErr("v3 compiler: failed to clear codegen smoke dir: " + codegenSmokeOutDir)
        return 2
    if !v3CompilerCleanHostrunArtifacts(rootDir, smokeNames):
        v3CompilerPrintErr("v3 compiler: failed to clear stale hostrun artifacts")
        return 2
    if !v3CompilerEnsureBackendDriver(rootDir, "r2c fresh gate"):
        return 2
    let backendDriverPath = v3path.v3PathAbsolute(rootDir, "artifacts/v3_backend_driver/cheng")
    if !v3path.v3FileExistsNonEmpty(rootDir, backendDriverPath):
        v3CompilerPrintErr("v3 compiler: missing backend driver for r2c fresh gate: " + backendDriverPath)
        return 2
    let bootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(rootDir)
    let stage3Path = bootstrapSnapshot.stage3Compiler.path
    if !v3path.v3FileExistsNonEmpty(rootDir, stage3Path):
        v3CompilerPrintErr("v3 compiler: missing stage3 for r2c fresh gate: " + stage3Path)
        return 2
    if v3CompilerForwardToBridge(rootDir, stage3Path, "run-host-smokes", smokeNames) != 0:
        v3CompilerPrintErr("v3 compiler: run-host-smokes failed inside r2c fresh gate")
        return 2
    let auditText = v3CompilerHostBridgeAuditText(rootDir)
    v3CompilerPrintLine(auditText)
    if !strutil.contains(auditText, "pure_cheng_zero_c_ready=1") ||
       !strutil.contains(auditText, "remaining_non_pure_cheng_boundary=none"):
        v3CompilerPrintErr("v3 compiler: host bridge audit not ready for r2c fresh gate")
        return 2
    if v3CompilerForwardToBridge(rootDir,
                                 stage3Path,
                                 "r2c-react-v3",
                                 ["status", "--out", statusOut]) != 0:
        v3CompilerPrintErr("v3 compiler: r2c-react-v3 status failed inside fresh gate")
        return 2
    if !v3path.v3PathFileExists(statusOut):
        v3CompilerPrintErr("v3 compiler: missing r2c status report: " + statusOut)
        return 2
    let statusText = v3path.v3ReadTextFile("", statusOut)
    if !v3CompilerTextContainsAll(statusText, statusNeedles):
        v3CompilerPrintErr("v3 compiler: r2c status report drifted from expected helper contract")
        return 2
    if v3CompilerForwardToBridge(rootDir,
                                 backendDriverPath,
                                 "r2c-react-v3-codegen-surface-smoke",
                                 [
                                     "--repo", repo,
                                     "--out-dir", codegenSmokeOutDir
                                 ]) != 0:
        v3CompilerPrintErr("v3 compiler: r2c codegen surface smoke failed inside fresh gate")
        return 2
    for i in 0..<routeStates.len:
        let routeState = routeStates[i]
        let bundleOutDir = "/tmp/r2c-native-gui-fresh-clean-gate-" + routeState
        if v3CompilerForwardToBridge(rootDir,
                                     stage3Path,
                                     "r2c-react-v3",
                                     [
                                         "native-gui-bundle",
                                         "--repo", repo,
                                         "--out-dir", bundleOutDir,
                                         "--route-state", routeState
                                     ]) != 0:
            v3CompilerPrintErr("v3 compiler: native-gui-bundle failed for route: " + routeState)
            return 2
        let bundleReport = os.joinPath(bundleOutDir, "native_gui_bundle_report_v1.json")
        let bundleSummary = os.joinPath(bundleOutDir, "native_gui_bundle.summary.env")
        let bundleJson = os.joinPath(bundleOutDir, "native_gui_bundle_v1.json")
        if !v3path.v3PathFileExists(bundleReport) || !v3path.v3PathFileExists(bundleSummary) || !v3path.v3PathFileExists(bundleJson):
            v3CompilerPrintErr("v3 compiler: missing bundle artifacts for route: " + routeState)
            return 2
        let reportText = v3path.v3ReadTextFile("", bundleReport)
        let summaryText = v3path.v3ReadTextFile("", bundleSummary)
        if !v3CompilerTextContainsAll(reportText, reportNeedles):
            v3CompilerPrintErr("v3 compiler: bundle report drifted for route: " + routeState)
            return 2
        if !strutil.contains(summaryText, "native_gui_runtime_mode=cheng_compiled_json_v1") ||
           !strutil.contains(summaryText, "native_gui_route_state=" + routeState):
            v3CompilerPrintErr("v3 compiler: bundle runtime mode drifted for route: " + routeState)
            return 2
    v3CompilerPrintLine("r2c-react-v3 fresh clean gate: ok")
    v3CompilerPrintLine("status_report=" + statusOut)
    for i in 0..<routeStates.len:
        let routeState = routeStates[i]
        let bundleOutDir = "/tmp/r2c-native-gui-fresh-clean-gate-" + routeState
        let bundleReport = os.joinPath(bundleOutDir, "native_gui_bundle_report_v1.json")
        var bundleLine = "bundle_report_"
        bundleLine = bundleLine + routeState
        bundleLine = bundleLine + "="
        bundleLine = bundleLine + bundleReport
        v3CompilerPrintLine(bundleLine)
    return 0

fn v3CompilerLegacyMigrationBuild(rootDir: str,
                                  packageRoot: str,
                                  legacySourcePathRaw: str,
                                  packageIdHint: str,
                                  entryModulePath: str,
                                  out: var ccsg.V3CompilerLegacyMigration): Result[bool] =
    let legacySourcePath = v3path.v3PathAbsolute(rootDir, legacySourcePathRaw)
    if len(legacySourcePath) <= 0:
        return Err[bool]("v3 compiler migration: missing --legacy-in")
    let migrationRes = ccsg.v3BuildCompilerLegacyMigration(rootDir,
                                                           packageRoot,
                                                           legacySourcePath,
                                                           packageIdHint,
                                                           entryModulePath)
    if IsErr(migrationRes):
        return Err[bool](Error(migrationRes))
    out = Value(migrationRes)
    return Ok[bool](true)

fn v3CompilerMigrationReceipt(plan: sexec.V3SystemLinkExecPlan,
                              migration: ccsg.V3CompilerLegacyMigration): ccsg.V3CompileReceipt =
    let outputDigest = ccsg.v3CompileOutputDigest(plan.systemLinkPlan.outputPath,
                                                  plan.systemLinkPlan.targetTriple,
                                                  plan.systemLinkPlan.providerModules,
                                                  migration.compilerCsg.graphCid)
    let canonicalOutputDigest = ccsg.v3CompileOutputDigest(plan.systemLinkPlan.outputPath,
                                                           plan.systemLinkPlan.targetTriple,
                                                           plan.systemLinkPlan.providerModules,
                                                           migration.compilerCsg.canonicalGraphCid)
    return ccsg.v3CompileReceiptMake(plan.localUniverse.worldHead.headCid,
                                     migration.compilerCsg.graphCid,
                                     migration.compilerCsg.canonicalGraphCid,
                                     plan.systemLinkPlan.targetTriple,
                                     outputDigest,
                                     canonicalOutputDigest,
                                     plan.compileReceipt.bootstrapStage,
                                     plan.systemLinkPlan.providerModules)

fn v3CompilerMigrationProofFromArgs(rootDir: str,
                                    args: str[],
                                    req: creq.V3CompilerRequest,
                                    plan: sexec.V3SystemLinkExecPlan,
                                    outMigration: var ccsg.V3CompilerLegacyMigration,
                                    out: var ceq.V3CompilerEquivalenceProof): Result[bool] =
    let legacySourcePath = creq.v3CompilerLegacyInPathFromArgs(args)
    if len(legacySourcePath) <= 0:
        return Err[bool]("v3 compiler migration: missing --legacy-in")
    let packageRoot = creq.v3CompilerRequestRootDir(req)
    let sourcePath = creq.v3CompilerRequestSourcePath(req)
    let entryModulePath = parser.v3ParserSourcePathToModulePath(rootDir,
                                                                packageRoot,
                                                                sourcePath)
    let migrationRes = v3CompilerLegacyMigrationBuild(rootDir,
                                                      packageRoot,
                                                      legacySourcePath,
                                                      plan.systemLinkPlan.packageId,
                                                      entryModulePath,
                                                      outMigration)
    if IsErr(migrationRes):
        return Err[bool](Error(migrationRes))
    let baselineCsgText = ccsg.v3CompilerCsgReport(plan.compilerCsg)
    let migratedCsgText = ccsg.v3CompilerCsgReport(outMigration.compilerCsg)
    let baselineSurfaceText = ccsg.v3CompilerExportSurfaceReport(plan.exportSurface)
    let migratedSurfaceText = ccsg.v3CompilerExportSurfaceReport(outMigration.exportSurface)
    let migratedReceipt = v3CompilerMigrationReceipt(plan, outMigration)
    let baselineReceiptText = ccsg.v3CompileReceiptReport(plan.compileReceipt)
    let migratedReceiptText = ccsg.v3CompileReceiptReport(migratedReceipt)
    var baselineGraphCid = layout.fixedBytes32Zero()
    var migratedGraphCid = layout.fixedBytes32Zero()
    var graphEquivalent = 0
    let graphRes = ceq.v3CompilerEquivalenceGraphCompareTexts(baselineCsgText,
                                                              migratedCsgText,
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[bool](Error(graphRes))
    var baselineSurfaceCid = layout.fixedBytes32Zero()
    var migratedSurfaceCid = layout.fixedBytes32Zero()
    var exportSurfaceCompatible = 0
    let surfaceRes = ceq.v3CompilerEquivalenceSurfaceCompareTexts(baselineSurfaceText,
                                                                  migratedSurfaceText,
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[bool](Error(surfaceRes))
    var baselineReceiptCid = layout.fixedBytes32Zero()
    var migratedReceiptCid = layout.fixedBytes32Zero()
    var targetTriple = ""
    var compileReceiptEquivalent = 0
    let receiptRes = ceq.v3CompilerEquivalenceReceiptCompareTexts(baselineReceiptText,
                                                                  migratedReceiptText,
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[bool](Error(receiptRes))
    let packageId = plan.systemLinkPlan.packageId
    let channel = plan.localUniverse.worldHead.channel
    return ceq.v3CompilerEquivalenceProofMake(packageId,
                                              channel,
                                              baselineGraphCid,
                                              migratedGraphCid,
                                              baselineSurfaceCid,
                                              migratedSurfaceCid,
                                              baselineReceiptCid,
                                              migratedReceiptCid,
                                              targetTriple,
                                              graphEquivalent,
                                              exportSurfaceCompatible,
                                              compileReceiptEquivalent,
                                              out)

fn v3CompilerMigrationProofFromRuntimeFlags(rootDir: str,
                                            req: creq.V3CompilerRequest,
                                            plan: sexec.V3SystemLinkExecPlan,
                                            outMigration: var ccsg.V3CompilerLegacyMigration,
                                            out: var ceq.V3CompilerEquivalenceProof): Result[bool] =
    let legacySourcePath = cmdline.readFlagOrDefault("--legacy-in", "")
    if len(legacySourcePath) <= 0:
        return Err[bool]("v3 compiler migration: missing --legacy-in")
    let packageRoot = creq.v3CompilerRequestRootDir(req)
    let sourcePath = creq.v3CompilerRequestSourcePath(req)
    let entryModulePath = parser.v3ParserSourcePathToModulePath(rootDir,
                                                                packageRoot,
                                                                sourcePath)
    let migrationRes = v3CompilerLegacyMigrationBuild(rootDir,
                                                      packageRoot,
                                                      legacySourcePath,
                                                      plan.systemLinkPlan.packageId,
                                                      entryModulePath,
                                                      outMigration)
    if IsErr(migrationRes):
        return Err[bool](Error(migrationRes))
    let baselineCsgText = ccsg.v3CompilerCsgReport(plan.compilerCsg)
    let migratedCsgText = ccsg.v3CompilerCsgReport(outMigration.compilerCsg)
    let baselineSurfaceText = ccsg.v3CompilerExportSurfaceReport(plan.exportSurface)
    let migratedSurfaceText = ccsg.v3CompilerExportSurfaceReport(outMigration.exportSurface)
    let migratedReceipt = v3CompilerMigrationReceipt(plan, outMigration)
    let baselineReceiptText = ccsg.v3CompileReceiptReport(plan.compileReceipt)
    let migratedReceiptText = ccsg.v3CompileReceiptReport(migratedReceipt)
    var baselineGraphCid = layout.fixedBytes32Zero()
    var migratedGraphCid = layout.fixedBytes32Zero()
    var graphEquivalent = 0
    let graphRes = ceq.v3CompilerEquivalenceGraphCompareTexts(baselineCsgText,
                                                              migratedCsgText,
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[bool](Error(graphRes))
    var baselineSurfaceCid = layout.fixedBytes32Zero()
    var migratedSurfaceCid = layout.fixedBytes32Zero()
    var exportSurfaceCompatible = 0
    let surfaceRes = ceq.v3CompilerEquivalenceSurfaceCompareTexts(baselineSurfaceText,
                                                                  migratedSurfaceText,
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[bool](Error(surfaceRes))
    var baselineReceiptCid = layout.fixedBytes32Zero()
    var migratedReceiptCid = layout.fixedBytes32Zero()
    var targetTriple = ""
    var compileReceiptEquivalent = 0
    let receiptRes = ceq.v3CompilerEquivalenceReceiptCompareTexts(baselineReceiptText,
                                                                  migratedReceiptText,
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[bool](Error(receiptRes))
    let packageId = plan.systemLinkPlan.packageId
    let channel = plan.localUniverse.worldHead.channel
    return ceq.v3CompilerEquivalenceProofMake(packageId,
                                              channel,
                                              baselineGraphCid,
                                              migratedGraphCid,
                                              baselineSurfaceCid,
                                              migratedSurfaceCid,
                                              baselineReceiptCid,
                                              migratedReceiptCid,
                                              targetTriple,
                                              graphEquivalent,
                                              exportSurfaceCompatible,
                                              compileReceiptEquivalent,
                                              out)

fn v3CompilerProofModeFromArgs(args: str[],
                               required: bool,
                               outMode: var str): Result[bool] =
    let equivalenceInputsRes = v3CompilerEquivalenceInputsReady(args, false)
    if IsErr(equivalenceInputsRes):
        return Err[bool](Error(equivalenceInputsRes))
    let equivalenceEnabled = Value(equivalenceInputsRes)
    let legacySourcePath = creq.v3CompilerLegacyInPathFromArgs(args)
    let legacySourcePathLen = len(legacySourcePath)
    var migrationEnabled = false
    if legacySourcePathLen > 0:
        migrationEnabled = true
    if equivalenceEnabled && migrationEnabled:
        return Err[bool]("v3 compiler proof: choose either --legacy-in or --baseline-csg/--baseline-surface/--baseline-receipt")
    if required && !equivalenceEnabled && !migrationEnabled:
        return Err[bool]("v3 compiler proof: stable requires --legacy-in or --baseline-csg/--baseline-surface/--baseline-receipt")
    outMode = ""
    if migrationEnabled:
        outMode = "migration"
    elif equivalenceEnabled:
        outMode = "equivalence"
    return Ok[bool](migrationEnabled || equivalenceEnabled)

fn v3CompilerProofModeFromRuntimeFlags(required: bool,
                                       outMode: var str): Result[bool] =
    let equivalenceInputsRes = v3CompilerEquivalenceInputsReadyFromRuntimeFlags(false)
    if IsErr(equivalenceInputsRes):
        return Err[bool](Error(equivalenceInputsRes))
    let equivalenceEnabled = Value(equivalenceInputsRes)
    let legacySourcePath = cmdline.readFlagOrDefault("--legacy-in", "")
    let legacySourcePathLen = len(legacySourcePath)
    var migrationEnabled = false
    if legacySourcePathLen > 0:
        migrationEnabled = true
    if equivalenceEnabled && migrationEnabled:
        return Err[bool]("v3 compiler proof: choose either --legacy-in or --baseline-csg/--baseline-surface/--baseline-receipt")
    if required && !equivalenceEnabled && !migrationEnabled:
        return Err[bool]("v3 compiler proof: stable requires --legacy-in or --baseline-csg/--baseline-surface/--baseline-receipt")
    outMode = ""
    if migrationEnabled:
        outMode = "migration"
    elif equivalenceEnabled:
        outMode = "equivalence"
    return Ok[bool](migrationEnabled || equivalenceEnabled)

fn v3CompilerLegacyArtifactsWrite(rootDir: str,
                                  prefix: str,
                                  migration: ccsg.V3CompilerLegacyMigration,
                                  receipt: ccsg.V3CompileReceipt): bool =
    if len(prefix) <= 0:
        return true
    if !v3path.v3WriteTextFile(rootDir, prefix + ".migration.txt", ccsg.v3CompilerLegacyMigrationReport(migration) + "\n"):
        return false
    if !v3path.v3WriteTextFile(rootDir, prefix + ".migration.csg.txt", ccsg.v3CompilerCsgReport(migration.compilerCsg) + "\n"):
        return false
    if !v3path.v3WriteTextFile(rootDir, prefix + ".migration.surface.txt", ccsg.v3CompilerExportSurfaceReport(migration.exportSurface) + "\n"):
        return false
    if !v3path.v3WriteTextFile(rootDir, prefix + ".migration.receipt.txt", ccsg.v3CompileReceiptReport(receipt) + "\n"):
        return false
    return true

fn v3CompilerPublishSummary(prefix: str,
                            channel: str,
                            plan: sexec.V3SystemLinkExecPlan,
                            proofMode: str,
                            equivalenceChecked: bool,
                            decision: ceq.V3CompilerPublishDecision): str =
    var checked = "0"
    var passed = intToStr(decision.equivalencePassed)
    var proofModeText = "-"
    if equivalenceChecked:
        checked = "1"
    if len(proofMode) > 0:
        proofModeText = proofMode
    var out = ""
    out = out + "bundle_prefix=" + prefix + "\n"
    out = out + "channel=" + channel + "\n"
    out = out + "world_head_cid=" + layout.fixedBytes32Hex(plan.localUniverse.worldHead.headCid) + "\n"
    out = out + "csg_root_cid=" + layout.fixedBytes32Hex(plan.compilerCsg.graphCid) + "\n"
    out = out + "surface_cid=" + layout.fixedBytes32Hex(plan.exportSurface.surfaceCid) + "\n"
    out = out + "receipt_cid=" + layout.fixedBytes32Hex(plan.compileReceipt.receiptCid) + "\n"
    out = out + "proof_mode=" + proofModeText + "\n"
    out = out + "equivalence_checked=" + checked + "\n"
    out = out + "equivalence_passed=" + passed + "\n"
    out = out + "publish_allowed=" + intToStr(decision.publishAllowed) + "\n"
    out = out + "proof_cid=" + layout.fixedBytes32Hex(decision.proofCid)
    return out

fn v3CompilerEmitCsg(rootDir: str,
                     args: str[]): int32 =
    args
    let reqRes = v3CompilerRequestFromRuntimeFlags(rootDir, false)
    if IsErr(reqRes):
        v3CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    if !slplan.v3BuildSystemLinkPlanStub(rootDir, req, linkPlan, err):
        v3CompilerPrintErr(err)
        return 2
    let sourceBundleCid = cworld.v3CompilerWorldSourceBundleCid(linkPlan.packageId,
                                                                linkPlan.sourceClosurePaths)
    let csgRes = ccsg.v3BuildCompilerCsg(linkPlan, sourceBundleCid)
    if IsErr(csgRes):
        v3CompilerPrintErr(Error(csgRes))
        return 2
    let report = ccsg.v3CompilerCsgReport(Value(csgRes))
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    v3CompilerPrintLine(report)
    return 0

fn v3CompilerMigrateCsg(rootDir: str,
                        args: str[]): int32 =
    args
    let packageRoot = v3CompilerPackageRootFromRuntimeFlags(rootDir)
    let legacySourcePath = cmdline.readFlagOrDefault("--legacy-in", "")
    if len(legacySourcePath) <= 0:
        v3CompilerPrintErr("v3 compiler migration: missing --legacy-in")
        return 2
    let currentSourcePath = cmdline.readFlagOrDefault("--in", "")
    var entryModulePath = ""
    if len(currentSourcePath) > 0:
        entryModulePath = parser.v3ParserSourcePathToModulePath(rootDir,
                                                                packageRoot,
                                                                v3path.v3PathAbsolute(rootDir, currentSourcePath))
    var migration: ccsg.V3CompilerLegacyMigration
    let migrationRes = v3CompilerLegacyMigrationBuild(rootDir,
                                                      packageRoot,
                                                      legacySourcePath,
                                                      parser.v3ParserPackageId(packageRoot),
                                                      entryModulePath,
                                                      migration)
    if IsErr(migrationRes):
        v3CompilerPrintErr(Error(migrationRes))
        return 2
    let prefix = cmdline.readFlagOrDefault("--out", "")
    var providers: str[]
    if entryModulePath == "cheng/v3/tooling/compiler_main":
        crun.v3RuntimeProviderModulesForTrack(crun.v3CompilerTrackTooling, providers)
    else:
        crun.v3RuntimeProviderModulesForTrack(crun.v3CompilerTrackProgram, providers)
    let receipt = ccsg.v3CompileReceiptMake(layout.fixedBytes32Zero(),
                                            migration.compilerCsg.graphCid,
                                            migration.compilerCsg.canonicalGraphCid,
                                            contracts.v3BootstrapDefaultTarget(),
                                            ccsg.v3CompileOutputDigest(prefix,
                                                                      contracts.v3BootstrapDefaultTarget(),
                                                                      providers,
                                                                      migration.compilerCsg.graphCid),
                                            ccsg.v3CompileOutputDigest(prefix,
                                                                      contracts.v3BootstrapDefaultTarget(),
                                                                      providers,
                                                                      migration.compilerCsg.canonicalGraphCid),
                                            "legacy_migration",
                                            providers)
    if !v3CompilerLegacyArtifactsWrite(rootDir, prefix, migration, receipt):
        v3CompilerPrintErr("v3 compiler migration: failed to write migration artifacts: " + prefix)
        return 2
    let report = ccsg.v3CompilerLegacyMigrationReport(migration)
    let reportPath = cmdline.readFlagOrDefault("--report-out", "")
    if !v3CompilerWriteOptionalReport(rootDir, reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + reportPath)
        return 2
    v3CompilerPrintLine(report)
    return 0

fn v3CompilerVerifyWorld(rootDir: str,
                         args: str[]): int32 =
    args
    let reqRes = v3CompilerRequestFromRuntimeFlags(rootDir, false)
    if IsErr(reqRes):
        v3CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let planRes = v3CompilerBuildSystemPlanFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        v3CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let report = sexec.v3SystemLinkExecPlanReport(plan)
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    v3CompilerPrintLine(report)
    return 0

fn v3CompilerWorldSyncWriteBundle(rootDir: str,
                                  prefix: str,
                                  plan: sexec.V3SystemLinkExecPlan): bool =
    if !v3path.v3WriteTextFile(rootDir, prefix + ".world.txt", cworld.v3CompilerWorldHeadReport(plan.localUniverse.worldHead) + "\n"):
        return false
    if !v3path.v3WriteTextFile(rootDir, prefix + ".compiler.snapshot.txt", cworld.v3CompilerPackageSnapshotReport(plan.localUniverse.compilerSnapshot) + "\n"):
        return false
    if !v3path.v3WriteTextFile(rootDir, prefix + ".std.snapshot.txt", cworld.v3CompilerPackageSnapshotReport(plan.localUniverse.stdSnapshot) + "\n"):
        return false
    if !v3path.v3WriteTextFile(rootDir, prefix + ".runtime.snapshot.txt", cworld.v3CompilerPackageSnapshotReport(plan.localUniverse.runtimeSnapshot) + "\n"):
        return false
    if !v3path.v3WriteTextFile(rootDir, prefix + ".csg.txt", ccsg.v3CompilerCsgReport(plan.compilerCsg) + "\n"):
        return false
    if !v3path.v3WriteTextFile(rootDir, prefix + ".surface.txt", ccsg.v3CompilerExportSurfaceReport(plan.exportSurface) + "\n"):
        return false
    if !v3path.v3WriteTextFile(rootDir, prefix + ".receipt.txt", ccsg.v3CompileReceiptReport(plan.compileReceipt) + "\n"):
        return false
    if !v3path.v3WriteTextFile(rootDir, prefix + ".lock.toml", cworld.v3CompilerLockText(plan.localUniverse)):
        return false
    return true

fn v3CompilerWorldSync(rootDir: str,
                       args: str[]): int32 =
    args
    let reqRes = v3CompilerRequestFromRuntimeFlags(rootDir, true)
    if IsErr(reqRes):
        v3CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let planRes = v3CompilerBuildSystemPlanFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        v3CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    if !v3CompilerWorldSyncWriteBundle(rootDir, req.outputPath, plan):
        v3CompilerPrintErr("v3 compiler: failed to materialize world bundle: " + req.outputPath)
        return 2
    var report = ""
    report = report + "bundle_prefix=" + req.outputPath + "\n"
    report = report + "world_head_cid=" + layout.fixedBytes32Hex(plan.localUniverse.worldHead.headCid) + "\n"
    report = report + "csg_root_cid=" + layout.fixedBytes32Hex(plan.compilerCsg.graphCid) + "\n"
    report = report + "surface_cid=" + layout.fixedBytes32Hex(plan.exportSurface.surfaceCid) + "\n"
    report = report + "receipt_cid=" + layout.fixedBytes32Hex(plan.compileReceipt.receiptCid)
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    v3CompilerPrintLine(report)
    return 0

fn v3CompilerProveEquivalence(rootDir: str,
                              args: str[]): int32 =
    args
    let reqRes = v3CompilerRequestFromRuntimeFlags(rootDir, false)
    if IsErr(reqRes):
        v3CompilerPrintErr(Error(reqRes))
        return 2
    let proofInputsRes = v3CompilerEquivalenceInputsReadyFromRuntimeFlags(true)
    if IsErr(proofInputsRes):
        v3CompilerPrintErr(Error(proofInputsRes))
        return 2
    let req = Value(reqRes)
    let planRes = v3CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        v3CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    var proof: ceq.V3CompilerEquivalenceProof
    let proofRes = v3CompilerEquivalenceProofFromRuntimeFlags(rootDir, plan, proof)
    if IsErr(proofRes):
        v3CompilerPrintErr(Error(proofRes))
        return 2
    let report = ceq.v3CompilerEquivalenceProofReport(proof)
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    v3CompilerPrintLine(report)
    return 0

fn v3CompilerProveMigration(rootDir: str,
                            args: str[]): int32 =
    args
    let reqRes = v3CompilerRequestFromRuntimeFlags(rootDir, false)
    if IsErr(reqRes):
        v3CompilerPrintErr(Error(reqRes))
        return 2
    let legacySourcePath = cmdline.readFlagOrDefault("--legacy-in", "")
    if len(legacySourcePath) <= 0:
        v3CompilerPrintErr("v3 compiler migration: missing --legacy-in")
        return 2
    let req = Value(reqRes)
    let planRes = v3CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        v3CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    var migration: ccsg.V3CompilerLegacyMigration
    var proof: ceq.V3CompilerEquivalenceProof
    let proofRes = v3CompilerMigrationProofFromRuntimeFlags(rootDir, req, plan, migration, proof)
    if IsErr(proofRes):
        v3CompilerPrintErr(Error(proofRes))
        return 2
    let migrationReceipt = v3CompilerMigrationReceipt(plan, migration)
    let prefix = req.outputPath
    if !v3CompilerLegacyArtifactsWrite(rootDir, prefix, migration, migrationReceipt):
        v3CompilerPrintErr("v3 compiler migration: failed to write migration artifacts: " + prefix)
        return 2
    let proofReport = ceq.v3CompilerEquivalenceProofReport(proof)
    if len(prefix) > 0:
        if !v3path.v3WriteTextFile(rootDir, prefix + ".proof.txt", proofReport + "\n"):
            v3CompilerPrintErr("v3 compiler: failed to write proof: " + prefix + ".proof.txt")
            return 2
    let report = ccsg.v3CompilerLegacyMigrationReport(migration) + "\n" + proofReport
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    v3CompilerPrintLine(report)
    return 0

fn v3CompilerPublishWorld(rootDir: str,
                          args: str[]): int32 =
    args
    let reqRes = v3CompilerRequestFromRuntimeFlags(rootDir, true)
    if IsErr(reqRes):
        v3CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let planRes = v3CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        v3CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let channel = plan.localUniverse.worldHead.channel
    var proofMode = ""
    let proofModeRes = v3CompilerProofModeFromRuntimeFlags(channel == "stable", proofMode)
    if IsErr(proofModeRes):
        v3CompilerPrintErr(Error(proofModeRes))
        return 2
    let proofEnabled = Value(proofModeRes)
    var equivalenceChecked = false
    var proof: ceq.V3CompilerEquivalenceProof
    var proofReport = ""
    var migrationReport = ""
    var migrationReceipt: ccsg.V3CompileReceipt
    if proofEnabled:
        if proofMode == "migration":
            var migration: ccsg.V3CompilerLegacyMigration
            let proofRes = v3CompilerMigrationProofFromRuntimeFlags(rootDir, req, plan, migration, proof)
            if IsErr(proofRes):
                v3CompilerPrintErr(Error(proofRes))
                return 2
            migrationReceipt = v3CompilerMigrationReceipt(plan, migration)
            migrationReport = ccsg.v3CompilerLegacyMigrationReport(migration)
            if !v3CompilerLegacyArtifactsWrite(rootDir, req.outputPath, migration, migrationReceipt):
                v3CompilerPrintErr("v3 compiler migration: failed to write migration artifacts: " + req.outputPath)
                return 2
        else:
            let proofRes = v3CompilerEquivalenceProofFromRuntimeFlags(rootDir, plan, proof)
            if IsErr(proofRes):
                v3CompilerPrintErr(Error(proofRes))
                return 2
        proofReport = ceq.v3CompilerEquivalenceProofReport(proof)
        equivalenceChecked = true
    else:
        proof.proofCid = layout.fixedBytes32Zero()
    var decision: ceq.V3CompilerPublishDecision
    let decisionRes = ceq.v3CompilerPublishDecisionMake(channel,
                                                        plan.localUniverse.worldHead.headCid,
                                                        equivalenceChecked,
                                                        proof,
                                                        decision)
    if IsErr(decisionRes):
        v3CompilerPrintErr(Error(decisionRes))
        return 2
    let decisionReport = ceq.v3CompilerPublishDecisionReport(decision)
    if decision.publishAllowed == 0:
        if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, decisionReport):
            v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
            return 2
        v3CompilerPrintErr("v3 compiler: publish blocked by canonical equivalence gate")
        v3CompilerPrintErr(decisionReport)
        if equivalenceChecked:
            if len(migrationReport) > 0:
                v3CompilerPrintErr(migrationReport)
            v3CompilerPrintErr(proofReport)
        return 2
    if !v3CompilerWorldSyncWriteBundle(rootDir, req.outputPath, plan):
        v3CompilerPrintErr("v3 compiler: failed to materialize world bundle: " + req.outputPath)
        return 2
    if equivalenceChecked:
        if !v3path.v3WriteTextFile(rootDir, req.outputPath + ".proof.txt", proofReport + "\n"):
            v3CompilerPrintErr("v3 compiler: failed to write proof: " + req.outputPath + ".proof.txt")
            return 2
    if !v3path.v3WriteTextFile(rootDir, req.outputPath + ".publish.txt", decisionReport + "\n"):
        v3CompilerPrintErr("v3 compiler: failed to write publish gate report: " + req.outputPath + ".publish.txt")
        return 2
    let summary = v3CompilerPublishSummary(req.outputPath,
                                           channel,
                                           plan,
                                           proofMode,
                                           equivalenceChecked,
                                           decision)
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, summary):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    v3CompilerPrintLine(summary)
    return 0

fn v3CompilerFreshNodeSelfhost(rootDir: str,
                               args: str[]): int32 =
    args
    let reqRes = v3CompilerRequestFromRuntimeFlags(rootDir, true)
    if IsErr(reqRes):
        v3CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let planRes = v3CompilerBuildSystemPlanForEquivalenceFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        v3CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let channel = plan.localUniverse.worldHead.channel
    var proofMode = ""
    let proofModeRes = v3CompilerProofModeFromRuntimeFlags(channel == "stable", proofMode)
    if IsErr(proofModeRes):
        v3CompilerPrintErr(Error(proofModeRes))
        return 2
    let proofEnabled = Value(proofModeRes)
    var equivalenceChecked = false
    var proof: ceq.V3CompilerEquivalenceProof
    var proofReport = ""
    var migrationReport = ""
    var migrationReceipt: ccsg.V3CompileReceipt
    if proofEnabled:
        if proofMode == "migration":
            var migration: ccsg.V3CompilerLegacyMigration
            let proofRes = v3CompilerMigrationProofFromRuntimeFlags(rootDir, req, plan, migration, proof)
            if IsErr(proofRes):
                v3CompilerPrintErr(Error(proofRes))
                return 2
            migrationReceipt = v3CompilerMigrationReceipt(plan, migration)
            migrationReport = ccsg.v3CompilerLegacyMigrationReport(migration)
            if !v3CompilerLegacyArtifactsWrite(rootDir, req.outputPath, migration, migrationReceipt):
                v3CompilerPrintErr("v3 compiler migration: failed to write migration artifacts: " + req.outputPath)
                return 2
        else:
            let proofRes = v3CompilerEquivalenceProofFromRuntimeFlags(rootDir, plan, proof)
            if IsErr(proofRes):
                v3CompilerPrintErr(Error(proofRes))
                return 2
        proofReport = ceq.v3CompilerEquivalenceProofReport(proof)
        equivalenceChecked = true
    else:
        proof.proofCid = layout.fixedBytes32Zero()
    var decision: ceq.V3CompilerPublishDecision
    let decisionRes = ceq.v3CompilerPublishDecisionMake(channel,
                                                        plan.localUniverse.worldHead.headCid,
                                                        equivalenceChecked,
                                                        proof,
                                                        decision)
    if IsErr(decisionRes):
        v3CompilerPrintErr(Error(decisionRes))
        return 2
    let decisionReport = ceq.v3CompilerPublishDecisionReport(decision)
    if decision.publishAllowed == 0:
        if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, decisionReport):
            v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
            return 2
        v3CompilerPrintErr("v3 compiler: publish blocked by canonical equivalence gate")
        v3CompilerPrintErr(decisionReport)
        if equivalenceChecked:
            if len(migrationReport) > 0:
                v3CompilerPrintErr(migrationReport)
            v3CompilerPrintErr(proofReport)
        return 2
    if !v3CompilerWorldSyncWriteBundle(rootDir, req.outputPath, plan):
        v3CompilerPrintErr("v3 compiler: failed to materialize world bundle: " + req.outputPath)
        return 2
    if equivalenceChecked:
        if !v3path.v3WriteTextFile(rootDir, req.outputPath + ".proof.txt", proofReport + "\n"):
            v3CompilerPrintErr("v3 compiler: failed to write proof: " + req.outputPath + ".proof.txt")
            return 2
    if !v3path.v3WriteTextFile(rootDir, req.outputPath + ".publish.txt", decisionReport + "\n"):
        v3CompilerPrintErr("v3 compiler: failed to write publish gate report: " + req.outputPath + ".publish.txt")
        return 2
    let freshRes = cwlp.v3CompilerWorldFreshNodeSelfhostReport(rootDir, req, plan)
    if IsErr(freshRes):
        v3CompilerPrintErr(Error(freshRes))
        return 2
    let freshReport = Value(freshRes)
    if !v3path.v3WriteTextFile(rootDir, req.outputPath + ".fresh.txt", freshReport + "\n"):
        v3CompilerPrintErr("v3 compiler: failed to write fresh-node report: " + req.outputPath + ".fresh.txt")
        return 2
    let summary = v3CompilerPublishSummary(req.outputPath,
                                           channel,
                                           plan,
                                           proofMode,
                                           equivalenceChecked,
                                           decision) + "\n" + freshReport
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, summary):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    v3CompilerPrintLine(summary)
    return 0

fn v3CompilerSelfhostBuild(rootDir: str,
                           args: str[]): int32 =
    let reqRes = v3CompilerRequestFromRuntimeFlags(rootDir, true)
    if IsErr(reqRes):
        v3CompilerPrintErr(Error(reqRes))
        return 2
    let req = Value(reqRes)
    let planRes = v3CompilerBuildSystemPlanFromRuntimeFlags(rootDir, req)
    if IsErr(planRes):
        v3CompilerPrintErr(Error(planRes))
        return 2
    let plan = Value(planRes)
    let report = sexec.v3SystemLinkExecPlanReport(plan)
    if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, report):
        v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
        return 2
    let bridgeCompiler = v3CompilerBridgeCompilerPath(rootDir)
    if len(bridgeCompiler) > 0:
        return v3CompilerForwardToBridge(rootDir, bridgeCompiler, "selfhost-build", args)
    if sexec.v3SystemLinkExecPlanReady(plan):
        v3CompilerPrintErr("v3 compiler: missing live Cheng bridge for selfhost-build")
        v3CompilerPrintErr(report)
        return 2
    elif plan.primaryObjectPlan.missingReasons.len > 0:
        v3CompilerPrintErr("v3 compiler: selfhost primary object machine code not emitted")
    else:
        v3CompilerPrintErr("v3 compiler: selfhost build blocked")
    v3CompilerPrintErr(report)
    return 2

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let rootDir = v3CompilerRoot()
    let count: int32 = cmdline.paramCount()
    if count <= 0:
        v3CompilerUsage(rootDir)
        return 0
    let cmd = cmdline.paramStr(1)
    let args = v3CompilerCollectArgsFrom(2, count)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        v3CompilerUsage(rootDir)
        return 0
    if cmd == "status":
        v3CompilerStatus(rootDir)
        return 0
    if cmd == "print-build-plan":
        v3CompilerPrintBuildPlan(rootDir)
        return 0
    if cmd == "bootstrap-bridge":
        return v3CompilerBootstrapBridge(rootDir)
    if cmd == "build-backend-driver":
        return v3CompilerBuildBackendDriver(rootDir)
    if cmd == "verify-x86-linux-remote":
        return v3CompilerVerifyX86LinuxRemote(rootDir, args)
    if cmd == "host-bridge-audit":
        return v3CompilerHostBridgeAudit(rootDir)
    if cmd == "r2c-react-v3-fresh-clean-gate":
        return v3CompilerR2cReactFreshCleanGate(rootDir, args)
    if cmd == "r2c-react-v3-codegen-surface-smoke":
        return v3CompilerR2cReactCodegenSurfaceSmoke(rootDir, args)
    if cmd == "r2c-react-v3-truth-compare-smoke":
        return v3CompilerR2cReactTruthCompareSmoke(rootDir, args)
    if cmd == "r2c-react-v3-compile-smoke":
        return v3CompilerR2cReactCompileSmoke(rootDir, args)
    if cmd == "r2c-react-v3-native-gui-bundle-smoke":
        return v3CompilerR2cReactNativeGuiBundleSmoke(rootDir, args)
    if cmd == "run-shared-emit-smokes":
        return v3CompilerRunSharedEmitSmokes(rootDir)
    if cmd == "emit-csg":
        return v3CompilerEmitCsg(rootDir, args)
    if cmd == "migrate-csg":
        return v3CompilerMigrateCsg(rootDir, args)
    if cmd == "verify-world":
        return v3CompilerVerifyWorld(rootDir, args)
    if cmd == "world-sync":
        return v3CompilerWorldSync(rootDir, args)
    if cmd == "prove-equivalence":
        return v3CompilerProveEquivalence(rootDir, args)
    if cmd == "prove-migration":
        return v3CompilerProveMigration(rootDir, args)
    if cmd == "publish-world":
        return v3CompilerPublishWorld(rootDir, args)
    if cmd == "fresh-node-selfhost":
        return v3CompilerFreshNodeSelfhost(rootDir, args)
    if cmd == "selfhost-build":
        return v3CompilerSelfhostBuild(rootDir, args)
    if v3CompilerForwardsToStage3(cmd):
        return v3CompilerForwardStage3Command(rootDir, cmd, args)
    if cmd == "system-link-exec":
        let reqRes: Result[creq.V3CompilerRequest] = v3CompilerRequestFromRuntimeFlags(rootDir, true)
        if IsErr(reqRes):
            v3CompilerPrintErr(Error(reqRes))
            return 2
        let req = Value(reqRes)
        let planRes: Result[sexec.V3SystemLinkExecPlan] = v3CompilerBuildSystemPlanFromRuntimeFlags(rootDir, req)
        if IsErr(planRes):
            v3CompilerPrintErr(Error(planRes))
            return 2
        let plan = Value(planRes)
        let report = sexec.v3SystemLinkExecPlanReport(plan)
        if !v3CompilerWriteOptionalReport(rootDir, req.reportPath, report):
            v3CompilerPrintErr("v3 compiler: failed to write report: " + req.reportPath)
            return 2
        let bridgeCompiler = v3CompilerBridgeCompilerPath(rootDir)
        if len(bridgeCompiler) > 0:
            return v3CompilerForwardToBridge(rootDir, bridgeCompiler, cmd, args)
        if sexec.v3SystemLinkExecPlanReady(plan):
            v3CompilerPrintErr("v3 compiler: missing live Cheng bridge for system-link-exec")
            v3CompilerPrintErr(report)
            return 2
        elif plan.primaryObjectPlan.missingReasons.len > 0:
            v3CompilerPrintErr("v3 compiler: primary object machine code not emitted")
        else:
            v3CompilerPrintErr("v3 compiler: ordinary pipeline blocked")
        v3CompilerPrintErr(report)
        return 2
    let rawArgs = v3CompilerCollectArgsFrom(1, count)
    if creq.v3CompilerLegacyBackendCompatLooksLikeCompile(rawArgs):
        let reqRes = creq.v3CompilerLegacyBackendCompatRequest(rootDir, rawArgs)
        if IsErr(reqRes):
            v3CompilerPrintErr(Error(reqRes))
            return 2
        let req = Value(reqRes)
        return v3CompilerRunLegacyCompatSystemLinkExec(rootDir, req, rawArgs)
    v3CompilerPrintErr("v3 compiler: unknown command: " + cmd)
    v3CompilerUsage(rootDir)
    return 2
