import std/cmdline as cmdline
import std/strings
import cheng/v3/tooling/r2c_react_v3_controller_main as live
import cheng/v3/tooling/path as v3path

@importc("paramCount")
fn r2cParamCountBridge(): int32

fn r2cOwnArgText(text: str): str =
    if strings.Len(text) <= 0:
        return ""
    return v3path.V3TextSlice(text, 0, strings.Len(text))

fn v3R2cReactV3Main(root: str,
                    args: str[]): int32 =
    return live.v3R2cReactV3Main(root, args)

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let rootDir: str = v3path.V3PathCurrentDir()
    let count: int32 = r2cParamCountBridge()
    var args: str[]
    for i in 1..count:
        let raw: str = cmdline.ParamStr(i)
        add(args, r2cOwnArgText(raw))
    return v3R2cReactV3Main(rootDir, args)
