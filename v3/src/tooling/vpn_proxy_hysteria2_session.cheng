import std/os
import std/result
import std/strutils as strutil
import cheng/v3/http3/frame as http3
import cheng/v3/quic/connection as qconn
import cheng/v3/tooling/hysteria2_protocol as hy2

type
    V3VpnProxyHy2TcpStream =
        conn: qconn.Connection
        rxBuf: Bytes

const
    v3VpnProxyHy2AuthStreamId = 4
    v3VpnProxyHy2TcpStreamFirst = 8
    v3VpnProxyHy2ClientControlStreamId = 2
    v3VpnProxyHy2ClientQpackEncoderStreamId = 6
    v3VpnProxyHy2ClientQpackDecoderStreamId = 10
    v3VpnProxyHy2ServerControlStreamId = 3
    v3VpnProxyHy2ServerQpackEncoderStreamId = 7
    v3VpnProxyHy2ServerQpackDecoderStreamId = 11
    v3VpnProxyHy2ReadChunkBytes = 4096
    v3VpnProxyHy2ReadPollMs = 10
    v3VpnProxyHy2ReadAttempts = 400

fn v3VpnProxyHy2BytesAppend(dst: var Bytes, extra: Bytes) =
    if bytesLen(extra) <= 0:
        return
    dst = bytesConcat(dst, extra)

fn v3VpnProxyHy2BytesDropPrefix(data: Bytes, count: int32): Bytes =
    let total: int32 = bytesLen(data)
    var start: int32 = 0
    if count > 0:
        if count < total:
            start = count
        else:
            start = total
    return bytesSlice(data, start, total - start)

fn v3VpnProxyHy2BytesTakePrefix(data: var Bytes, count: int32): Bytes =
    let total: int32 = bytesLen(data)
    if count <= 0:
        var out: Bytes
        out.data = nil
        out.len = 0
        return out
    if total <= 0:
        var out: Bytes
        out.data = nil
        out.len = 0
        return out
    var take: int32 = count
    if take > total:
        take = total
    let out: Bytes = bytesSlice(data, 0, take)
    data = v3VpnProxyHy2BytesDropPrefix(data, take)
    return out

fn v3VpnProxyHy2BytesEq(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn v3VpnProxyHy2WouldBlock(err: str): bool =
    return err == "msquic udp: queue empty" ||
           err == "pipe: empty" ||
           err == "connection: empty"

fn v3VpnProxyHy2Partial(err: str): bool =
    return strutil.Contains(err, "truncated")

fn v3VpnProxyHy2Settings(): http3.V3Http3Setting[] =
    var out: http3.V3Http3Setting[] = []
    add(out, http3.V3Http3MakeSetting(http3.v3Http3SettingQpackMaxTableCapacity, 0))
    add(out, http3.V3Http3MakeSetting(http3.v3Http3SettingQpackBlockedStreams, 0))
    add(out, http3.V3Http3MakeSetting(http3.v3Http3SettingMaxFieldSectionSize, 65535))
    return out

fn v3VpnProxyHy2Stream(base: qconn.Connection,
                       sendStreamId: int64,
                       recvStreamId: int64): Result[qconn.Connection] =
    return qconn.newNativeConnectionForStreams(base.localAddr,
                                               base.remoteAddr,
                                               base.dir,
                                               base.pipeSide,
                                               sendStreamId,
                                               recvStreamId)

fn v3VpnProxyHy2ReadExact(conn: var qconn.Connection, count: int32): Result[Bytes] =
    return qconn.connRead(conn, count)

fn v3VpnProxyHy2ReadHttp3Frame(conn: var qconn.Connection): Result[http3.V3Http3FrameDecoded] =
    var buf: Bytes
    buf.data = nil
    buf.len = 0
    for _attempt in 0..<v3VpnProxyHy2ReadAttempts:
        let frameRes: Result[http3.V3Http3FrameDecoded] = http3.V3Http3DecodeFrame(buf, 0)
        if IsOk(frameRes):
            return frameRes
        if !v3VpnProxyHy2Partial(ErrorText(frameRes)):
            return Err[http3.V3Http3FrameDecoded](ErrorText(frameRes))
        let readRes: Result[Bytes] = qconn.connReadNonblocking(conn, v3VpnProxyHy2ReadChunkBytes)
        if IsErr(readRes):
            if v3VpnProxyHy2WouldBlock(ErrorText(readRes)):
                os.SleepMs(v3VpnProxyHy2ReadPollMs)
                continue
            return Err[http3.V3Http3FrameDecoded](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) > 0:
            v3VpnProxyHy2BytesAppend(buf, chunk)
            continue
        os.SleepMs(v3VpnProxyHy2ReadPollMs)
    return Err[http3.V3Http3FrameDecoded]("vpn proxy hysteria2: read http3 frame timeout")

fn v3VpnProxyHy2ReadTcpRequestPrefix(conn: var qconn.Connection): Result[hy2.V3Hysteria2TcpRequestDecoded] =
    var buf: Bytes
    buf.data = nil
    buf.len = 0
    for _attempt in 0..<v3VpnProxyHy2ReadAttempts:
        let decodeRes: Result[hy2.V3Hysteria2TcpRequestDecoded] = hy2.V3Hysteria2DecodeTcpRequestPrefix(buf)
        if IsOk(decodeRes):
            return decodeRes
        if !v3VpnProxyHy2Partial(ErrorText(decodeRes)):
            return Err[hy2.V3Hysteria2TcpRequestDecoded](ErrorText(decodeRes))
        let readRes: Result[Bytes] = qconn.connReadNonblocking(conn, v3VpnProxyHy2ReadChunkBytes)
        if IsErr(readRes):
            if v3VpnProxyHy2WouldBlock(ErrorText(readRes)):
                os.SleepMs(v3VpnProxyHy2ReadPollMs)
                continue
            return Err[hy2.V3Hysteria2TcpRequestDecoded](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) > 0:
            v3VpnProxyHy2BytesAppend(buf, chunk)
            continue
        os.SleepMs(v3VpnProxyHy2ReadPollMs)
    return Err[hy2.V3Hysteria2TcpRequestDecoded]("vpn proxy hysteria2: read tcp request timeout")

fn v3VpnProxyHy2ReadTcpResponsePrefix(conn: var qconn.Connection): Result[hy2.V3Hysteria2TcpResponseDecoded] =
    var buf: Bytes
    buf.data = nil
    buf.len = 0
    for _attempt in 0..<v3VpnProxyHy2ReadAttempts:
        let decodeRes: Result[hy2.V3Hysteria2TcpResponseDecoded] = hy2.V3Hysteria2DecodeTcpResponsePrefix(buf)
        if IsOk(decodeRes):
            return decodeRes
        if !v3VpnProxyHy2Partial(ErrorText(decodeRes)):
            return Err[hy2.V3Hysteria2TcpResponseDecoded](ErrorText(decodeRes))
        let readRes: Result[Bytes] = qconn.connReadNonblocking(conn, v3VpnProxyHy2ReadChunkBytes)
        if IsErr(readRes):
            if v3VpnProxyHy2WouldBlock(ErrorText(readRes)):
                os.SleepMs(v3VpnProxyHy2ReadPollMs)
                continue
            return Err[hy2.V3Hysteria2TcpResponseDecoded](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) > 0:
            v3VpnProxyHy2BytesAppend(buf, chunk)
            continue
        os.SleepMs(v3VpnProxyHy2ReadPollMs)
    return Err[hy2.V3Hysteria2TcpResponseDecoded]("vpn proxy hysteria2: read tcp response timeout")

fn v3VpnProxyHy2ReadTcpRequestFromStream(stream: var V3VpnProxyHy2TcpStream): Result[hy2.V3Hysteria2TcpRequest] =
    for _attempt in 0..<v3VpnProxyHy2ReadAttempts:
        let decodeRes: Result[hy2.V3Hysteria2TcpRequestDecoded] = hy2.V3Hysteria2DecodeTcpRequestPrefix(stream.rxBuf)
        if IsOk(decodeRes):
            let decoded = Value(decodeRes)
            stream.rxBuf = v3VpnProxyHy2BytesDropPrefix(stream.rxBuf, decoded.next)
            return Ok[hy2.V3Hysteria2TcpRequest](decoded.req)
        if !v3VpnProxyHy2Partial(ErrorText(decodeRes)):
            return Err[hy2.V3Hysteria2TcpRequest](ErrorText(decodeRes))
        let readRes: Result[Bytes] = qconn.connReadNonblocking(stream.conn, v3VpnProxyHy2ReadChunkBytes)
        if IsErr(readRes):
            if v3VpnProxyHy2WouldBlock(ErrorText(readRes)):
                os.SleepMs(v3VpnProxyHy2ReadPollMs)
                continue
            return Err[hy2.V3Hysteria2TcpRequest](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) > 0:
            v3VpnProxyHy2BytesAppend(stream.rxBuf, chunk)
            continue
        os.SleepMs(v3VpnProxyHy2ReadPollMs)
    return Err[hy2.V3Hysteria2TcpRequest]("vpn proxy hysteria2: read tcp request timeout")

fn v3VpnProxyHy2ReadTcpResponseFromStream(stream: var V3VpnProxyHy2TcpStream): Result[hy2.V3Hysteria2TcpResponse] =
    for _attempt in 0..<v3VpnProxyHy2ReadAttempts:
        let decodeRes: Result[hy2.V3Hysteria2TcpResponseDecoded] = hy2.V3Hysteria2DecodeTcpResponsePrefix(stream.rxBuf)
        if IsOk(decodeRes):
            let decoded = Value(decodeRes)
            stream.rxBuf = v3VpnProxyHy2BytesDropPrefix(stream.rxBuf, decoded.next)
            return Ok[hy2.V3Hysteria2TcpResponse](decoded.resp)
        if !v3VpnProxyHy2Partial(ErrorText(decodeRes)):
            return Err[hy2.V3Hysteria2TcpResponse](ErrorText(decodeRes))
        let readRes: Result[Bytes] = qconn.connReadNonblocking(stream.conn, v3VpnProxyHy2ReadChunkBytes)
        if IsErr(readRes):
            if v3VpnProxyHy2WouldBlock(ErrorText(readRes)):
                os.SleepMs(v3VpnProxyHy2ReadPollMs)
                continue
            return Err[hy2.V3Hysteria2TcpResponse](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) > 0:
            v3VpnProxyHy2BytesAppend(stream.rxBuf, chunk)
            continue
        os.SleepMs(v3VpnProxyHy2ReadPollMs)
    return Err[hy2.V3Hysteria2TcpResponse]("vpn proxy hysteria2: read tcp response timeout")

fn v3VpnProxyHy2SendPreamble(base: qconn.Connection,
                             controlStreamId: int64,
                             encoderStreamId: int64,
                             decoderStreamId: int64): Result[bool] =
    let preambleRes: Result[http3.V3Http3Preamble] = http3.V3Http3EncodeClientPreamble(v3VpnProxyHy2Settings())
    if IsErr(preambleRes):
        return Err[bool](ErrorText(preambleRes))
    let preamble: http3.V3Http3Preamble = Value(preambleRes)
    let controlConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, controlStreamId, controlStreamId)
    if IsErr(controlConnRes):
        return Err[bool](ErrorText(controlConnRes))
    var controlConn = Value(controlConnRes)
    let encoderConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, encoderStreamId, encoderStreamId)
    if IsErr(encoderConnRes):
        return Err[bool](ErrorText(encoderConnRes))
    var encoderConn = Value(encoderConnRes)
    let decoderConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, decoderStreamId, decoderStreamId)
    if IsErr(decoderConnRes):
        return Err[bool](ErrorText(decoderConnRes))
    var decoderConn = Value(decoderConnRes)
    let controlWriteRes: Result[int32] = qconn.connWrite(controlConn, preamble.control)
    if IsErr(controlWriteRes):
        return Err[bool](ErrorText(controlWriteRes))
    let encoderWriteRes: Result[int32] = qconn.connWrite(encoderConn, preamble.qpackEncoder)
    if IsErr(encoderWriteRes):
        return Err[bool](ErrorText(encoderWriteRes))
    let decoderWriteRes: Result[int32] = qconn.connWrite(decoderConn, preamble.qpackDecoder)
    if IsErr(decoderWriteRes):
        return Err[bool](ErrorText(decoderWriteRes))
    return Ok[bool](true)

fn v3VpnProxyHy2ExpectPreamble(base: qconn.Connection,
                               controlStreamId: int64,
                               encoderStreamId: int64,
                               decoderStreamId: int64): Result[bool] =
    let preambleRes: Result[http3.V3Http3Preamble] = http3.V3Http3EncodeClientPreamble(v3VpnProxyHy2Settings())
    if IsErr(preambleRes):
        return Err[bool](ErrorText(preambleRes))
    let preamble: http3.V3Http3Preamble = Value(preambleRes)
    let controlConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, controlStreamId, controlStreamId)
    if IsErr(controlConnRes):
        return Err[bool](ErrorText(controlConnRes))
    var controlConn = Value(controlConnRes)
    let encoderConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, encoderStreamId, encoderStreamId)
    if IsErr(encoderConnRes):
        return Err[bool](ErrorText(encoderConnRes))
    var encoderConn = Value(encoderConnRes)
    let decoderConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, decoderStreamId, decoderStreamId)
    if IsErr(decoderConnRes):
        return Err[bool](ErrorText(decoderConnRes))
    var decoderConn = Value(decoderConnRes)
    let controlReadRes: Result[Bytes] = v3VpnProxyHy2ReadExact(controlConn, bytesLen(preamble.control))
    if IsErr(controlReadRes):
        return Err[bool](ErrorText(controlReadRes))
    let encoderReadRes: Result[Bytes] = v3VpnProxyHy2ReadExact(encoderConn, bytesLen(preamble.qpackEncoder))
    if IsErr(encoderReadRes):
        return Err[bool](ErrorText(encoderReadRes))
    let decoderReadRes: Result[Bytes] = v3VpnProxyHy2ReadExact(decoderConn, bytesLen(preamble.qpackDecoder))
    if IsErr(decoderReadRes):
        return Err[bool](ErrorText(decoderReadRes))
    if !v3VpnProxyHy2BytesEq(Value(controlReadRes), preamble.control):
        return Err[bool]("vpn proxy hysteria2: control preamble mismatch")
    if !v3VpnProxyHy2BytesEq(Value(encoderReadRes), preamble.qpackEncoder):
        return Err[bool]("vpn proxy hysteria2: qpack encoder preamble mismatch")
    if !v3VpnProxyHy2BytesEq(Value(decoderReadRes), preamble.qpackDecoder):
        return Err[bool]("vpn proxy hysteria2: qpack decoder preamble mismatch")
    return Ok[bool](true)

fn v3VpnProxyHy2ClientSendPreamble(base: qconn.Connection): Result[bool] =
    return v3VpnProxyHy2SendPreamble(base,
                                     v3VpnProxyHy2ClientControlStreamId,
                                     v3VpnProxyHy2ClientQpackEncoderStreamId,
                                     v3VpnProxyHy2ClientQpackDecoderStreamId)

fn v3VpnProxyHy2ServerSendPreamble(base: qconn.Connection): Result[bool] =
    return v3VpnProxyHy2SendPreamble(base,
                                     v3VpnProxyHy2ServerControlStreamId,
                                     v3VpnProxyHy2ServerQpackEncoderStreamId,
                                     v3VpnProxyHy2ServerQpackDecoderStreamId)

fn v3VpnProxyHy2ServerExpectClientPreamble(base: qconn.Connection): Result[bool] =
    return v3VpnProxyHy2ExpectPreamble(base,
                                       v3VpnProxyHy2ClientControlStreamId,
                                       v3VpnProxyHy2ClientQpackEncoderStreamId,
                                       v3VpnProxyHy2ClientQpackDecoderStreamId)

fn v3VpnProxyHy2ClientExpectServerPreamble(base: qconn.Connection): Result[bool] =
    return v3VpnProxyHy2ExpectPreamble(base,
                                       v3VpnProxyHy2ServerControlStreamId,
                                       v3VpnProxyHy2ServerQpackEncoderStreamId,
                                       v3VpnProxyHy2ServerQpackDecoderStreamId)

fn v3VpnProxyHy2ClientWriteAuth(base: qconn.Connection,
                                authority: str,
                                auth: str,
                                ccRx: int64,
                                padding: str): Result[bool] =
    let authConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base,
                                                                    v3VpnProxyHy2AuthStreamId,
                                                                    v3VpnProxyHy2AuthStreamId)
    if IsErr(authConnRes):
        return Err[bool](ErrorText(authConnRes))
    var authConn = Value(authConnRes)
    let wireRes: Result[Bytes] = hy2.V3Hysteria2EncodeAuthRequestFrame(hy2.V3Hysteria2MakeAuthRequest(authority,
                                                                                                       auth,
                                                                                                       ccRx,
                                                                                                       padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(authConn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn v3VpnProxyHy2ClientReadAuthResponse(base: qconn.Connection): Result[hy2.V3Hysteria2AuthResponse] =
    let authConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base,
                                                                    v3VpnProxyHy2AuthStreamId,
                                                                    v3VpnProxyHy2AuthStreamId)
    if IsErr(authConnRes):
        return Err[hy2.V3Hysteria2AuthResponse](ErrorText(authConnRes))
    var authConn = Value(authConnRes)
    let frameRes: Result[http3.V3Http3FrameDecoded] = v3VpnProxyHy2ReadHttp3Frame(authConn)
    if IsErr(frameRes):
        return Err[hy2.V3Hysteria2AuthResponse](ErrorText(frameRes))
    let wireBackRes: Result[Bytes] = http3.V3Http3EncodeFrame(Value(frameRes).frame)
    if IsErr(wireBackRes):
        return Err[hy2.V3Hysteria2AuthResponse](ErrorText(wireBackRes))
    return hy2.V3Hysteria2DecodeAuthResponseFrame(Value(wireBackRes))

fn v3VpnProxyHy2ClientAuth(base: qconn.Connection,
                           authority: str,
                           auth: str,
                           ccRx: int64,
                           padding: str): Result[hy2.V3Hysteria2AuthResponse] =
    let writeRes: Result[bool] = v3VpnProxyHy2ClientWriteAuth(base, authority, auth, ccRx, padding)
    if IsErr(writeRes):
        return Err[hy2.V3Hysteria2AuthResponse](ErrorText(writeRes))
    return v3VpnProxyHy2ClientReadAuthResponse(base)

fn v3VpnProxyHy2ServerReadAuth(base: qconn.Connection): Result[hy2.V3Hysteria2AuthRequest] =
    let authConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base,
                                                                    v3VpnProxyHy2AuthStreamId,
                                                                    v3VpnProxyHy2AuthStreamId)
    if IsErr(authConnRes):
        return Err[hy2.V3Hysteria2AuthRequest](ErrorText(authConnRes))
    var authConn = Value(authConnRes)
    let frameRes: Result[http3.V3Http3FrameDecoded] = v3VpnProxyHy2ReadHttp3Frame(authConn)
    if IsErr(frameRes):
        return Err[hy2.V3Hysteria2AuthRequest](ErrorText(frameRes))
    let wireRes: Result[Bytes] = http3.V3Http3EncodeFrame(Value(frameRes).frame)
    if IsErr(wireRes):
        return Err[hy2.V3Hysteria2AuthRequest](ErrorText(wireRes))
    return hy2.V3Hysteria2DecodeAuthRequestFrame(Value(wireRes))

fn v3VpnProxyHy2ServerWriteAuthResponse(base: qconn.Connection,
                                        statusCode: int32,
                                        udpEnabled: bool,
                                        ccRxText: str,
                                        padding: str): Result[bool] =
    let authConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base,
                                                                    v3VpnProxyHy2AuthStreamId,
                                                                    v3VpnProxyHy2AuthStreamId)
    if IsErr(authConnRes):
        return Err[bool](ErrorText(authConnRes))
    var authConn = Value(authConnRes)
    let wireRes: Result[Bytes] = hy2.V3Hysteria2EncodeAuthResponseFrame(hy2.V3Hysteria2MakeAuthResponse(statusCode,
                                                                                                         udpEnabled,
                                                                                                         ccRxText,
                                                                                                         padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(authConn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn v3VpnProxyHy2ClientWriteTcpRequest(base: qconn.Connection,
                                      streamId: int64,
                                      address: str,
                                      padding: Bytes): Result[bool] =
    let reqConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, streamId, streamId)
    if IsErr(reqConnRes):
        return Err[bool](ErrorText(reqConnRes))
    var reqConn = Value(reqConnRes)
    let wireRes: Result[Bytes] = hy2.V3Hysteria2EncodeTcpRequest(hy2.V3Hysteria2MakeTcpRequest(address, padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(reqConn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn v3VpnProxyHy2ServerReadTcpRequest(base: qconn.Connection,
                                     streamId: int64): Result[hy2.V3Hysteria2TcpRequestDecoded] =
    let reqConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, streamId, streamId)
    if IsErr(reqConnRes):
        return Err[hy2.V3Hysteria2TcpRequestDecoded](ErrorText(reqConnRes))
    var reqConn = Value(reqConnRes)
    return v3VpnProxyHy2ReadTcpRequestPrefix(reqConn)

fn v3VpnProxyHy2ServerWriteTcpResponse(base: qconn.Connection,
                                       streamId: int64,
                                       ok: bool,
                                       message: str,
                                       padding: Bytes): Result[bool] =
    let reqConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, streamId, streamId)
    if IsErr(reqConnRes):
        return Err[bool](ErrorText(reqConnRes))
    var reqConn = Value(reqConnRes)
    let wireRes: Result[Bytes] = hy2.V3Hysteria2EncodeTcpResponse(hy2.V3Hysteria2MakeTcpResponse(ok,
                                                                                                  message,
                                                                                                  padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(reqConn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn v3VpnProxyHy2ClientReadTcpResponse(base: qconn.Connection,
                                      streamId: int64): Result[hy2.V3Hysteria2TcpResponseDecoded] =
    let reqConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, streamId, streamId)
    if IsErr(reqConnRes):
        return Err[hy2.V3Hysteria2TcpResponseDecoded](ErrorText(reqConnRes))
    var reqConn = Value(reqConnRes)
    return v3VpnProxyHy2ReadTcpResponsePrefix(reqConn)

fn v3VpnProxyHy2OpenTcpStream(base: qconn.Connection,
                              streamId: int64): Result[V3VpnProxyHy2TcpStream] =
    let streamConnRes: Result[qconn.Connection] = v3VpnProxyHy2Stream(base, streamId, streamId)
    if IsErr(streamConnRes):
        return Err[V3VpnProxyHy2TcpStream](ErrorText(streamConnRes))
    var out: V3VpnProxyHy2TcpStream
    out.conn = Value(streamConnRes)
    out.rxBuf.data = nil
    out.rxBuf.len = 0
    return Ok[V3VpnProxyHy2TcpStream](out)

fn v3VpnProxyHy2TcpStreamWrite(stream: var V3VpnProxyHy2TcpStream,
                               data: Bytes): Result[int32] =
    return qconn.connWrite(stream.conn, data)

fn v3VpnProxyHy2TcpStreamReadNonblocking(stream: var V3VpnProxyHy2TcpStream,
                                         count: int32): Result[Bytes] =
    if count <= 0:
        var out: Bytes
        out.data = nil
        out.len = 0
        return Ok[Bytes](out)
    let buffered: Bytes = v3VpnProxyHy2BytesTakePrefix(stream.rxBuf, count)
    if bytesLen(buffered) > 0:
        return Ok[Bytes](buffered)
    return qconn.connReadNonblocking(stream.conn, count)

fn v3VpnProxyHy2TcpStreamShutdownWrite(stream: var V3VpnProxyHy2TcpStream): Result[bool] =
    return qconn.connShutdownWrite(stream.conn)

fn v3VpnProxyHy2TcpStreamClose(stream: var V3VpnProxyHy2TcpStream) =
    qconn.connClose(stream.conn)
    stream.rxBuf.data = nil
    stream.rxBuf.len = 0

fn v3VpnProxyHy2TcpStreamWriteRequest(stream: var V3VpnProxyHy2TcpStream,
                                      address: str,
                                      padding: Bytes): Result[bool] =
    let wireRes: Result[Bytes] = hy2.V3Hysteria2EncodeTcpRequest(hy2.V3Hysteria2MakeTcpRequest(address, padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(stream.conn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn v3VpnProxyHy2TcpStreamReadRequest(stream: var V3VpnProxyHy2TcpStream): Result[hy2.V3Hysteria2TcpRequest] =
    return v3VpnProxyHy2ReadTcpRequestFromStream(stream)

fn v3VpnProxyHy2TcpStreamTryReadRequest(stream: var V3VpnProxyHy2TcpStream,
                                        out: var hy2.V3Hysteria2TcpRequest): Result[bool] =
    let decodeRes: Result[hy2.V3Hysteria2TcpRequestDecoded] = hy2.V3Hysteria2DecodeTcpRequestPrefix(stream.rxBuf)
    if IsOk(decodeRes):
        let decoded = Value(decodeRes)
        stream.rxBuf = v3VpnProxyHy2BytesDropPrefix(stream.rxBuf, decoded.next)
        out = decoded.req
        return Ok[bool](true)
    if !v3VpnProxyHy2Partial(ErrorText(decodeRes)):
        return Err[bool](ErrorText(decodeRes))
    let readRes: Result[Bytes] = qconn.connReadNonblocking(stream.conn, v3VpnProxyHy2ReadChunkBytes)
    if IsErr(readRes):
        if v3VpnProxyHy2WouldBlock(ErrorText(readRes)):
            return Ok[bool](false)
        return Err[bool](ErrorText(readRes))
    let chunk: Bytes = Value(readRes)
    if bytesLen(chunk) <= 0:
        return Err[bool]("msquic: stream closed")
    v3VpnProxyHy2BytesAppend(stream.rxBuf, chunk)
    let decodeAfterRes: Result[hy2.V3Hysteria2TcpRequestDecoded] = hy2.V3Hysteria2DecodeTcpRequestPrefix(stream.rxBuf)
    if IsOk(decodeAfterRes):
        let decoded = Value(decodeAfterRes)
        stream.rxBuf = v3VpnProxyHy2BytesDropPrefix(stream.rxBuf, decoded.next)
        out = decoded.req
        return Ok[bool](true)
    if v3VpnProxyHy2Partial(ErrorText(decodeAfterRes)):
        return Ok[bool](false)
    return Err[bool](ErrorText(decodeAfterRes))

fn v3VpnProxyHy2TcpStreamWriteResponse(stream: var V3VpnProxyHy2TcpStream,
                                       ok: bool,
                                       message: str,
                                       padding: Bytes): Result[bool] =
    let wireRes: Result[Bytes] = hy2.V3Hysteria2EncodeTcpResponse(hy2.V3Hysteria2MakeTcpResponse(ok,
                                                                                                  message,
                                                                                                  padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(stream.conn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

