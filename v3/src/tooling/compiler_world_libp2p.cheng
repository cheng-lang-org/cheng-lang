import std/result
import std/rawbytes
import std/strutils as strutil
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/binary_types as btypes
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/pubsub
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types as core
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host
import cheng/v3/libp2p/protocols/gossipsub as gossip
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/compiler_world as cworld
import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/backend/system_link_exec as sexec

type
    V3CompilerManagedMirrorBundleUnit =
        relSourcePath: str
        sourceText: str

    V3CompilerManagedMirrorBundle =
        version: int32
        channel: str
        packageId: str
        migrationProofCid: layout.FixedBytes32
        unitCount: int32
        units: V3CompilerManagedMirrorBundleUnit[]
        migrationText: str
        migrationCsgText: str
        migrationSurfaceText: str
        migrationReceiptText: str
        proofText: str
        lockText: str

    V3CompilerWorldFreshNodeSyncState =
        syncedEntryCount: int32
        syncedHead: cworld.V3CompilerWorldHead
        syncedManifest: cworld.V3CompilerUniverseManifest
        syncedReceipt: ccsg.V3CompileReceipt
        materializedMirrorCount: int32

fn v3CompilerWorldTopicScope(): overlay.V3OverlayTopicScope =
    return overlay.v3OverlayScopeGlobal

fn v3CompilerWorldAddress(): btypes.V3LsmrAddress =
    return btypes.V3LsmrAddress()

fn v3CompilerWorldQuery(sourcePeerId: core.V3Libp2pPeerId): overlay.V3StoreQuery =
    var query = overlay.V3StoreQuery()
    query.sourcePeerId = sourcePeerId.value
    query.topicScope = v3CompilerWorldTopicScope()
    query.address = v3CompilerWorldAddress()
    return query

fn v3CompilerWorldPayloadCid(payload: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(bytesLen(payload) + 32)
    layout.byteBufAppendBytes(buf, payload)
    return lt.v3FixedCidFromBuf(buf)

fn v3CompilerWorldIngress(sourcePeerId: core.V3Libp2pPeerId,
                          payloadKind: int32,
                          payloadReport: str,
                          stampEpoch: int32,
                          stampGanzhi: int32): overlay.V3IngressEnvelope =
    let payload = cworld.v3CompilerWorldOwnedBytesFromText(payloadReport)
    var ingress = overlay.V3IngressEnvelope()
    ingress.sourcePeerId = sourcePeerId.value
    ingress.topicScope = v3CompilerWorldTopicScope()
    ingress.address = v3CompilerWorldAddress()
    ingress.payloadKind = payloadKind
    ingress.payload = payload
    ingress.payloadCid = v3CompilerWorldPayloadCid(payload)
    ingress.payloadLen = bytesLen(payload)
    ingress.stampEpoch = stampEpoch
    ingress.stampGanzhi = stampGanzhi
    return ingress

fn v3CompilerWorldMirrorPackageManifestText(packageIdRaw: str): str =
    let packageId = v3path.V3PathTrim(packageIdRaw)
    var modulePrefix = v3path.V3PathBaseName(packageId)
    if len(modulePrefix) <= 0:
        modulePrefix = "pkg"
    return "package_id = \"pkg://" + packageId + "\"\nmodule_prefix = \"" + modulePrefix + "\"\n"

fn v3CompilerWorldHexTextEncode(text: str): str =
    return rawbytes.BytesToHex(rawbytes.BytesFromString(text))

fn v3CompilerWorldHexValue(ch: uint8): int32 =
    if ch >= uint8('0') && ch <= uint8('9'):
        return int32(ch) - int32('0')
    if ch >= uint8('a') && ch <= uint8('f'):
        return 10 + (int32(ch) - int32('a'))
    if ch >= uint8('A') && ch <= uint8('F'):
        return 10 + (int32(ch) - int32('A'))
    return -1

fn v3CompilerWorldHexTextDecode(textRaw: str,
                                outText: var str): Result[bool] =
    let text = v3path.V3PathTrim(textRaw)
    if len(text) <= 0:
        outText = ""
        return Ok[bool](true)
    if (len(text) % 2) != 0:
        return Err[bool]("v3 compiler world libp2p: invalid hex length")
    var outBytes = rawbytes.BytesAlloc(len(text) / 2)
    var i: int32
    while i < len(text):
        let hi = v3CompilerWorldHexValue(uint8(text[i]))
        let lo = v3CompilerWorldHexValue(uint8(text[i + 1]))
        if hi < 0 || lo < 0:
            return Err[bool]("v3 compiler world libp2p: invalid hex payload")
        rawbytes.BytesSet(outBytes, i / 2, (hi * 16) + lo)
        i = i + 2
    outText = rawbytes.BytesToString(outBytes)
    return Ok[bool](true)

fn v3CompilerWorldLineValue(text: str,
                            key: str): str =
    let lines = strutil.Split(text, '\n')
    let prefix = key + "="
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if !strutil.StartsWith(line, prefix):
            continue
        return v3path.V3TextSlice(line, len(prefix), len(line) - len(prefix))
    return ""

fn v3CompilerWorldManagedMirrorBundleReport(bundle: V3CompilerManagedMirrorBundle): str =
    var out = ""
    out = out + "version=1\n"
    out = out + "channel=" + bundle.channel + "\n"
    out = out + "package_id=" + bundle.packageId + "\n"
    out = out + "migration_proof_cid=" + layout.fixedBytes32Hex(bundle.migrationProofCid) + "\n"
    out = out + "unit_count=" + intToStr(bundle.unitCount) + "\n"
    for i in 0..<bundle.units.len:
        out = out + "unit[" + intToStr(i) + "].rel_source_path=" + bundle.units[i].relSourcePath + "\n"
        out = out + "unit[" + intToStr(i) + "].source_text_hex=" + v3CompilerWorldHexTextEncode(bundle.units[i].sourceText) + "\n"
    out = out + "migration_text_hex=" + v3CompilerWorldHexTextEncode(bundle.migrationText) + "\n"
    out = out + "migration_csg_text_hex=" + v3CompilerWorldHexTextEncode(bundle.migrationCsgText) + "\n"
    out = out + "migration_surface_text_hex=" + v3CompilerWorldHexTextEncode(bundle.migrationSurfaceText) + "\n"
    out = out + "migration_receipt_text_hex=" + v3CompilerWorldHexTextEncode(bundle.migrationReceiptText) + "\n"
    out = out + "proof_text_hex=" + v3CompilerWorldHexTextEncode(bundle.proofText) + "\n"
    out = out + "lock_text_hex=" + v3CompilerWorldHexTextEncode(bundle.lockText)
    return out

fn v3CompilerWorldManagedMirrorBundleFromReportText(text: str,
                                                    out: var V3CompilerManagedMirrorBundle): Result[bool] =
    let channelRes = cworld.v3CompilerWorldNormalizeChannel(v3CompilerWorldLineValue(text, "channel"))
    if IsErr(channelRes):
        return Err[bool](Error(channelRes))
    let packageId = v3CompilerWorldLineValue(text, "package_id")
    if len(packageId) <= 0:
        return Err[bool]("v3 compiler world libp2p: mirror bundle package_id missing")
    let proofRes = layout.fixedBytes32FromHex(v3CompilerWorldLineValue(text, "migration_proof_cid"))
    if IsErr(proofRes):
        return Err[bool]("v3 compiler world libp2p: invalid mirror bundle proof cid")
    let unitCountText = v3CompilerWorldLineValue(text, "unit_count")
    if len(unitCountText) <= 0:
        return Err[bool]("v3 compiler world libp2p: mirror bundle unit_count missing")
    let unitCount = int32(strutil.ParseInt(unitCountText))
    var units: V3CompilerManagedMirrorBundleUnit[]
    for i in 0..<unitCount:
        let relSourcePath = v3CompilerWorldLineValue(text, "unit[" + intToStr(i) + "].rel_source_path")
        if len(relSourcePath) <= 0:
            return Err[bool]("v3 compiler world libp2p: mirror bundle rel source path missing")
        var sourceText = ""
        let decodeSourceRes = v3CompilerWorldHexTextDecode(v3CompilerWorldLineValue(text,
                                                                                    "unit[" + intToStr(i) + "].source_text_hex"),
                                                           sourceText)
        if IsErr(decodeSourceRes):
            return Err[bool](Error(decodeSourceRes))
        var unit: V3CompilerManagedMirrorBundleUnit
        unit.relSourcePath = relSourcePath
        unit.sourceText = sourceText
        add(units, unit)
    var migrationText = ""
    let migrationTextRes = v3CompilerWorldHexTextDecode(v3CompilerWorldLineValue(text, "migration_text_hex"),
                                                        migrationText)
    if IsErr(migrationTextRes):
        return Err[bool](Error(migrationTextRes))
    var migrationCsgText = ""
    let migrationCsgRes = v3CompilerWorldHexTextDecode(v3CompilerWorldLineValue(text, "migration_csg_text_hex"),
                                                       migrationCsgText)
    if IsErr(migrationCsgRes):
        return Err[bool](Error(migrationCsgRes))
    var migrationSurfaceText = ""
    let migrationSurfaceRes = v3CompilerWorldHexTextDecode(v3CompilerWorldLineValue(text, "migration_surface_text_hex"),
                                                           migrationSurfaceText)
    if IsErr(migrationSurfaceRes):
        return Err[bool](Error(migrationSurfaceRes))
    var migrationReceiptText = ""
    let migrationReceiptRes = v3CompilerWorldHexTextDecode(v3CompilerWorldLineValue(text, "migration_receipt_text_hex"),
                                                           migrationReceiptText)
    if IsErr(migrationReceiptRes):
        return Err[bool](Error(migrationReceiptRes))
    var proofText = ""
    let proofTextRes = v3CompilerWorldHexTextDecode(v3CompilerWorldLineValue(text, "proof_text_hex"),
                                                    proofText)
    if IsErr(proofTextRes):
        return Err[bool](Error(proofTextRes))
    var lockText = ""
    let lockTextRes = v3CompilerWorldHexTextDecode(v3CompilerWorldLineValue(text, "lock_text_hex"),
                                                   lockText)
    if IsErr(lockTextRes):
        return Err[bool](Error(lockTextRes))
    out.version = 1
    out.channel = Value(channelRes)
    out.packageId = packageId
    out.migrationProofCid = Value(proofRes)
    out.unitCount = unitCount
    out.units = units
    out.migrationText = migrationText
    out.migrationCsgText = migrationCsgText
    out.migrationSurfaceText = migrationSurfaceText
    out.migrationReceiptText = migrationReceiptText
    out.proofText = proofText
    out.lockText = lockText
    return Ok[bool](true)

fn v3CompilerWorldRegister(hostRef: var host.V3Libp2pHost) =
    host.v3Libp2pRegisterHandler(hostRef, core.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(hostRef, core.v3Libp2pProtocolIngress)

fn v3CompilerWorldPublishEntry(hostRef: var host.V3Libp2pHost,
                               ingress: overlay.V3IngressEnvelope,
                               announceHead: bool) =
    host.v3Libp2pStorePut(hostRef, ingress)
    host.v3Libp2pKadProvide(hostRef, ingress.payloadCid)
    if !announceHead:
        return
    let pubRecord = gossip.v3Libp2pPubRecordFromIngress(hostRef.selfPeerId, ingress)
    host.v3Libp2pPublish(hostRef, pubRecord)

fn v3CompilerWorldManagedMirrorProofCid(manifest: cworld.V3CompilerUniverseManifest,
                                        packageId: str): layout.FixedBytes32 =
    for i in 0..<manifest.entries.len:
        if manifest.entries[i].packageId == packageId:
            return manifest.entries[i].migrationProofCid
    return layout.FixedBytes32()

fn v3CompilerWorldManagedMirrorSourceList(rootDir: str,
                                          mirrorRoot: str): Result[str[]] =
    let sourceListPath = v3path.V3PathJoin(mirrorRoot, "sources.list.txt")
    if !v3path.V3PathFileExists(sourceListPath):
        return Err[str[]]("v3 compiler world libp2p: missing managed mirror sources list: " + sourceListPath)
    let lines = strutil.Split(v3path.V3ReadTextFile("", sourceListPath), '\n')
    var out: str[]
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if len(line) <= 0:
            continue
        add(out, line)
    return Ok[str[]](out)

fn v3CompilerWorldManagedMirrorOptionalText(path: str): str =
    if !v3path.V3PathFileExists(path):
        return ""
    return v3path.V3ReadTextFile("", path)

fn v3CompilerWorldManagedMirrorBundlesForPlan(plan: sexec.V3SystemLinkExecPlan): Result[V3CompilerManagedMirrorBundle[]] =
    let externalPackageRoots = slplan.v3SystemLinkPlanExternalPackageRoots(plan.systemLinkPlan)
    var out: V3CompilerManagedMirrorBundle[]
    for i in 0..<externalPackageRoots.len:
        let mirrorRoot = v3path.V3PathAbsolute("", externalPackageRoots[i].packageRoot)
        let sourcesRes = v3CompilerWorldManagedMirrorSourceList("", mirrorRoot)
        if IsErr(sourcesRes):
            return Err[V3CompilerManagedMirrorBundle[]](Error(sourcesRes))
        let relSourcePaths = Value(sourcesRes)
        var units: V3CompilerManagedMirrorBundleUnit[]
        for j in 0..<relSourcePaths.len:
            let sourcePath = v3path.V3PathJoin(mirrorRoot, relSourcePaths[j])
            if !v3path.V3PathFileExists(sourcePath):
                return Err[V3CompilerManagedMirrorBundle[]]("v3 compiler world libp2p: missing managed mirror source: " + sourcePath)
            var unit: V3CompilerManagedMirrorBundleUnit
            unit.relSourcePath = relSourcePaths[j]
            unit.sourceText = v3path.V3ReadTextFile("", sourcePath)
            add(units, unit)
        var bundle: V3CompilerManagedMirrorBundle
        bundle.version = 1
        bundle.channel = plan.localUniverse.worldHead.channel
        bundle.packageId = externalPackageRoots[i].packageId
        bundle.migrationProofCid = v3CompilerWorldManagedMirrorProofCid(plan.localUniverse.manifest,
                                                                        bundle.packageId)
        bundle.unitCount = units.len
        bundle.units = units
        bundle.migrationText = v3CompilerWorldManagedMirrorOptionalText(v3path.V3PathJoin(mirrorRoot, "migration.txt"))
        bundle.migrationCsgText = v3CompilerWorldManagedMirrorOptionalText(v3path.V3PathJoin(mirrorRoot, "migration.csg.txt"))
        bundle.migrationSurfaceText = v3CompilerWorldManagedMirrorOptionalText(v3path.V3PathJoin(mirrorRoot, "migration.surface.txt"))
        bundle.migrationReceiptText = v3CompilerWorldManagedMirrorOptionalText(v3path.V3PathJoin(mirrorRoot, "migration.receipt.txt"))
        bundle.proofText = v3CompilerWorldManagedMirrorOptionalText(v3path.V3PathJoin(mirrorRoot, "proof.txt"))
        bundle.lockText = v3CompilerWorldManagedMirrorOptionalText(v3path.V3PathJoin(mirrorRoot, "cheng.lock.toml"))
        add(out, bundle)
    return Ok[V3CompilerManagedMirrorBundle[]](out)

fn v3CompilerWorldWriteManagedMirrorBundleFiles(rootDir: str,
                                                prefix: str,
                                                bundles: V3CompilerManagedMirrorBundle[]): bool =
    if bundles.len <= 0:
        return true
    var indexText = "count=" + intToStr(bundles.len)
    for i in 0..<bundles.len:
        let bundlePath = prefix + ".managed_mirror." + intToStr(i) + ".txt"
        if !v3path.V3WriteTextFile(rootDir,
                                   bundlePath,
                                   v3CompilerWorldManagedMirrorBundleReport(bundles[i]) + "\n"):
            return false
        indexText = indexText + "\npackage[" + intToStr(i) + "].package_id=" + bundles[i].packageId
        indexText = indexText + "\npackage[" + intToStr(i) + "].migration_proof_cid=" + layout.fixedBytes32Hex(bundles[i].migrationProofCid)
        indexText = indexText + "\npackage[" + intToStr(i) + "].bundle_path=" + bundlePath
    return v3path.V3WriteTextFile(rootDir, prefix + ".managed_mirror.index.txt", indexText + "\n")

fn v3CompilerWorldManagedMirrorBundlePathsFromIndexText(text: str): Result[str[]] =
    let countText = v3CompilerWorldLineValue(text, "count")
    if len(countText) <= 0:
        return Err[str[]]("v3 compiler world libp2p: mirror bundle index count missing")
    let count = int32(strutil.ParseInt(countText))
    var out: str[]
    for i in 0..<count:
        let bundlePath = v3CompilerWorldLineValue(text, "package[" + intToStr(i) + "].bundle_path")
        if len(bundlePath) <= 0:
            return Err[str[]]("v3 compiler world libp2p: mirror bundle index path missing")
        add(out, bundlePath)
    return Ok[str[]](out)

fn v3CompilerWorldManagedMirrorBundlesFromBundlePrefix(rootDir: str,
                                                       prefix: str): Result[V3CompilerManagedMirrorBundle[]] =
    let indexPath = prefix + ".managed_mirror.index.txt"
    if !v3path.V3PathFileExists(v3path.V3PathAbsolute(rootDir, indexPath)):
        var empty: V3CompilerManagedMirrorBundle[]
        return Ok[V3CompilerManagedMirrorBundle[]](empty)
    let bundlePathsRes = v3CompilerWorldManagedMirrorBundlePathsFromIndexText(v3path.V3ReadTextFile(rootDir, indexPath))
    if IsErr(bundlePathsRes):
        return Err[V3CompilerManagedMirrorBundle[]](Error(bundlePathsRes))
    var out: V3CompilerManagedMirrorBundle[]
    let bundlePaths = Value(bundlePathsRes)
    for i in 0..<bundlePaths.len:
        if !v3path.V3PathFileExists(v3path.V3PathAbsolute(rootDir, bundlePaths[i])):
            return Err[V3CompilerManagedMirrorBundle[]]("v3 compiler world libp2p: missing mirror bundle file: " + bundlePaths[i])
        var bundle: V3CompilerManagedMirrorBundle
        let parseRes = v3CompilerWorldManagedMirrorBundleFromReportText(v3path.V3ReadTextFile(rootDir, bundlePaths[i]),
                                                                        bundle)
        if IsErr(parseRes):
            return Err[V3CompilerManagedMirrorBundle[]](Error(parseRes))
        add(out, bundle)
    return Ok[V3CompilerManagedMirrorBundle[]](out)

fn v3CompilerWorldManagedMirrorMaterialize(rootDir: str,
                                           bundle: V3CompilerManagedMirrorBundle): Result[str] =
    let mirrorRoot = cworld.v3CompilerManagedMirrorRoot(rootDir,
                                                        bundle.channel,
                                                        bundle.packageId,
                                                        bundle.migrationProofCid)
    if !v3path.V3MkdirP("", v3path.V3PathJoin(mirrorRoot, "src")):
        return Err[str]("v3 compiler world libp2p: failed to mkdir managed mirror: " + mirrorRoot)
    if !v3path.V3WriteTextFile(rootDir,
                               v3path.V3PathJoin(mirrorRoot, "cheng-package.toml"),
                               v3CompilerWorldMirrorPackageManifestText(bundle.packageId)):
        return Err[str]("v3 compiler world libp2p: failed to write managed mirror manifest")
    var sourcesList = ""
    for i in 0..<bundle.units.len:
        let sourcePath = v3path.V3PathJoin(mirrorRoot, bundle.units[i].relSourcePath)
        let sourceDir = v3path.V3PathParentDir(sourcePath)
        if !v3path.V3MkdirP("", sourceDir):
            return Err[str]("v3 compiler world libp2p: failed to mkdir mirror source dir")
        if !v3path.V3WriteTextFile(rootDir, sourcePath, bundle.units[i].sourceText):
            return Err[str]("v3 compiler world libp2p: failed to write mirror source: " + sourcePath)
        if len(sourcesList) > 0:
            sourcesList = sourcesList + "\n"
        sourcesList = sourcesList + bundle.units[i].relSourcePath
    if !v3path.V3WriteTextFile(rootDir,
                               v3path.V3PathJoin(mirrorRoot, "sources.list.txt"),
                               sourcesList + "\n"):
        return Err[str]("v3 compiler world libp2p: failed to write mirror source list")
    if len(bundle.migrationText) > 0 &&
       !v3path.V3WriteTextFile(rootDir, v3path.V3PathJoin(mirrorRoot, "migration.txt"), bundle.migrationText):
        return Err[str]("v3 compiler world libp2p: failed to write mirror migration report")
    if len(bundle.migrationCsgText) > 0 &&
       !v3path.V3WriteTextFile(rootDir, v3path.V3PathJoin(mirrorRoot, "migration.csg.txt"), bundle.migrationCsgText):
        return Err[str]("v3 compiler world libp2p: failed to write mirror migration csg")
    if len(bundle.migrationSurfaceText) > 0 &&
       !v3path.V3WriteTextFile(rootDir, v3path.V3PathJoin(mirrorRoot, "migration.surface.txt"), bundle.migrationSurfaceText):
        return Err[str]("v3 compiler world libp2p: failed to write mirror migration surface")
    if len(bundle.migrationReceiptText) > 0 &&
       !v3path.V3WriteTextFile(rootDir, v3path.V3PathJoin(mirrorRoot, "migration.receipt.txt"), bundle.migrationReceiptText):
        return Err[str]("v3 compiler world libp2p: failed to write mirror migration receipt")
    if len(bundle.proofText) > 0 &&
       !v3path.V3WriteTextFile(rootDir, v3path.V3PathJoin(mirrorRoot, "proof.txt"), bundle.proofText):
        return Err[str]("v3 compiler world libp2p: failed to write mirror proof")
    if len(bundle.lockText) > 0 &&
       !v3path.V3WriteTextFile(rootDir, v3path.V3PathJoin(mirrorRoot, "cheng.lock.toml"), bundle.lockText):
        return Err[str]("v3 compiler world libp2p: failed to write mirror lock")
    return Ok[str](mirrorRoot)

fn v3CompilerWorldManagedMirrorBundlesFromHost(hostRef: host.V3Libp2pHost): Result[V3CompilerManagedMirrorBundle[]] =
    var out: V3CompilerManagedMirrorBundle[]
    for i in 0..<hostRef.storeEntries.len:
        let ingress = hostRef.storeEntries[i].ingress
        if ingress.payloadKind != pubsub.v3PubSubPayloadKindCompilerManagedMirrorBundle:
            continue
        var bundle: V3CompilerManagedMirrorBundle
        let parseRes = v3CompilerWorldManagedMirrorBundleFromReportText(cworld.v3CompilerWorldOwnText(rawbytes.BytesToString(ingress.payload)),
                                                                        bundle)
        if IsErr(parseRes):
            return Err[V3CompilerManagedMirrorBundle[]](Error(parseRes))
        add(out, bundle)
    return Ok[V3CompilerManagedMirrorBundle[]](out)

fn v3CompilerWorldMaterializeManagedMirrorBundles(rootDir: str,
                                                  bundles: V3CompilerManagedMirrorBundle[]): Result[int32] =
    var count = 0
    for i in 0..<bundles.len:
        let materializeRes = v3CompilerWorldManagedMirrorMaterialize(rootDir, bundles[i])
        if IsErr(materializeRes):
            return Err[int32](Error(materializeRes))
        count = count + 1
    return Ok[int32](count)

fn v3CompilerWorldMaterializeManagedMirrorBundlesFromBundlePrefix(rootDir: str,
                                                                  prefix: str): Result[int32] =
    let bundlesRes = v3CompilerWorldManagedMirrorBundlesFromBundlePrefix(rootDir, prefix)
    if IsErr(bundlesRes):
        return Err[int32](Error(bundlesRes))
    return v3CompilerWorldMaterializeManagedMirrorBundles(rootDir, Value(bundlesRes))

fn v3CompilerWorldManagedMirrorMaterializeReport(prefix: str,
                                                 materializedMirrorCount: int32): str =
    var out = ""
    out = out + "bundle_prefix=" + prefix + "\n"
    out = out + "managed_mirror_count=" + intToStr(materializedMirrorCount)
    return out

fn v3CompilerWorldPublishUniverseWithManagedMirrorBundles(hostRef: var host.V3Libp2pHost,
                                                          universe: cworld.V3CompilerLocalUniverse,
                                                          compilerCsg: ccsg.V3CompilerCsg,
                                                          exportSurface: ccsg.V3CsgExportSurface,
                                                          receipt: ccsg.V3CompileReceipt,
                                                          managedMirrorBundles: V3CompilerManagedMirrorBundle[]) =
    let stampEpoch = universe.worldHead.headEpoch
    let stampGanzhi = 1
    let worldIngress = v3CompilerWorldIngress(hostRef.selfPeerId,
                                              pubsub.v3PubSubPayloadKindCompilerWorldHead,
                                              cworld.v3CompilerWorldHeadReport(universe.worldHead),
                                              stampEpoch,
                                              stampGanzhi)
    v3CompilerWorldPublishEntry(hostRef, worldIngress, true)
    let manifestIngress = v3CompilerWorldIngress(hostRef.selfPeerId,
                                                 pubsub.v3PubSubPayloadKindCompilerUniverseManifest,
                                                 cworld.v3CompilerUniverseManifestReport(universe.manifest),
                                                 stampEpoch,
                                                 stampGanzhi)
    v3CompilerWorldPublishEntry(hostRef, manifestIngress, false)
    let compilerIngress = v3CompilerWorldIngress(hostRef.selfPeerId,
                                                 pubsub.v3PubSubPayloadKindCompilerPackageSnapshot,
                                                 cworld.v3CompilerPackageSnapshotReport(universe.compilerSnapshot),
                                                 stampEpoch,
                                                 stampGanzhi)
    v3CompilerWorldPublishEntry(hostRef, compilerIngress, false)
    let stdIngress = v3CompilerWorldIngress(hostRef.selfPeerId,
                                            pubsub.v3PubSubPayloadKindCompilerPackageSnapshot,
                                            cworld.v3CompilerPackageSnapshotReport(universe.stdSnapshot),
                                            stampEpoch,
                                            stampGanzhi)
    v3CompilerWorldPublishEntry(hostRef, stdIngress, false)
    let runtimeIngress = v3CompilerWorldIngress(hostRef.selfPeerId,
                                                pubsub.v3PubSubPayloadKindCompilerPackageSnapshot,
                                                cworld.v3CompilerPackageSnapshotReport(universe.runtimeSnapshot),
                                                stampEpoch,
                                                stampGanzhi)
    v3CompilerWorldPublishEntry(hostRef, runtimeIngress, false)
    let csgIngress = v3CompilerWorldIngress(hostRef.selfPeerId,
                                            pubsub.v3PubSubPayloadKindCompilerCsg,
                                            ccsg.v3CompilerCsgWireReport(compilerCsg),
                                            stampEpoch,
                                            stampGanzhi)
    v3CompilerWorldPublishEntry(hostRef, csgIngress, false)
    let surfaceIngress = v3CompilerWorldIngress(hostRef.selfPeerId,
                                                pubsub.v3PubSubPayloadKindCompilerExportSurface,
                                                ccsg.v3CompilerExportSurfaceReport(exportSurface),
                                                stampEpoch,
                                                stampGanzhi)
    v3CompilerWorldPublishEntry(hostRef, surfaceIngress, false)
    let receiptIngress = v3CompilerWorldIngress(hostRef.selfPeerId,
                                                pubsub.v3PubSubPayloadKindCompilerCompileReceipt,
                                                ccsg.v3CompileReceiptReport(receipt),
                                                stampEpoch,
                                                stampGanzhi)
    v3CompilerWorldPublishEntry(hostRef, receiptIngress, false)
    for i in 0..<managedMirrorBundles.len:
        let mirrorIngress = v3CompilerWorldIngress(hostRef.selfPeerId,
                                                   pubsub.v3PubSubPayloadKindCompilerManagedMirrorBundle,
                                                   v3CompilerWorldManagedMirrorBundleReport(managedMirrorBundles[i]),
                                                   stampEpoch,
                                                   stampGanzhi)
        v3CompilerWorldPublishEntry(hostRef, mirrorIngress, false)

fn v3CompilerWorldPublishUniverse(hostRef: var host.V3Libp2pHost,
                                  universe: cworld.V3CompilerLocalUniverse,
                                  compilerCsg: ccsg.V3CompilerCsg,
                                  exportSurface: ccsg.V3CsgExportSurface,
                                  receipt: ccsg.V3CompileReceipt) =
    var managedMirrorBundles: V3CompilerManagedMirrorBundle[]
    v3CompilerWorldPublishUniverseWithManagedMirrorBundles(hostRef,
                                                           universe,
                                                           compilerCsg,
                                                           exportSurface,
                                                           receipt,
                                                           managedMirrorBundles)

fn v3CompilerWorldStoredEntryCount(hostRef: host.V3Libp2pHost): int32 =
    let query = v3CompilerWorldQuery(hostRef.selfPeerId)
    return host.v3Libp2pStoreQueryCount(hostRef, query)

fn v3CompilerWorldPublishedHeadCount(hostRef: host.V3Libp2pHost): int32 =
    var out = 0
    for i in 0..<hostRef.publishLog.len:
        if hostRef.publishLog[i].payloadKind == pubsub.v3PubSubPayloadKindCompilerWorldHead:
            out = out + 1
    return out

fn v3CompilerWorldFirstPayloadTextByKind(hostRef: host.V3Libp2pHost,
                                         payloadKind: int32,
                                         outText: var str): bool =
    for i in 0..<hostRef.storeEntries.len:
        let ingress = hostRef.storeEntries[i].ingress
        if ingress.payloadKind != payloadKind:
            continue
        outText = cworld.v3CompilerWorldOwnText(rawbytes.BytesToString(ingress.payload))
        return true
    outText = ""
    return false

fn v3CompilerWorldSync(localHost: var host.V3Libp2pHost,
                       remoteHost: var host.V3Libp2pHost,
                       remotePeerId: core.V3Libp2pPeerId): Result[int32] =
    var entries: overlay.V3IngressEnvelope[]
    let query = v3CompilerWorldQuery(localHost.selfPeerId)
    let syncRes = host.v3Libp2pSyncRequest(localHost, remoteHost, remotePeerId, query, entries)
    if IsErr(syncRes):
        return Err[int32](Error(syncRes))
    for i in 0..<entries.len:
        host.v3Libp2pStorePut(localHost, entries[i])
    return Ok[int32](entries.len)

fn v3CompilerWorldSyncSmokeReport(rootDir: str,
                                  sourcePath: str,
                                  outputPath: str): Result[str] =
    let packageRoot = v3path.V3PathJoin(rootDir, "v3")
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    let planRes = sexec.v3BuildSystemLinkExecPlan(rootDir, req)
    if IsErr(planRes):
        return Err[str](Error(planRes))
    let plan = Value(planRes)
    let mirrorBundlesRes = v3CompilerWorldManagedMirrorBundlesForPlan(plan)
    if IsErr(mirrorBundlesRes):
        return Err[str](Error(mirrorBundlesRes))
    let mirrorBundles = Value(mirrorBundlesRes)
    var seedHost = host.v3Libp2pHostInit("compiler-world-seed")
    var syncHost = host.v3Libp2pHostInit("compiler-world-sync")
    v3CompilerWorldRegister(seedHost)
    v3CompilerWorldRegister(syncHost)
    var seedAddr: core.V3Libp2pMultiaddr
    var syncAddr: core.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(seedAddr, "127.0.0.1", 6461)
    multiaddr.v3Libp2pMultiaddrFillTcp(syncAddr, "127.0.0.1", 6462)
    let seedListenRes = host.v3Libp2pListen(seedHost, seedAddr)
    if IsErr(seedListenRes):
        return Err[str](Error(seedListenRes))
    let syncListenRes = host.v3Libp2pListen(syncHost, syncAddr)
    if IsErr(syncListenRes):
        return Err[str](Error(syncListenRes))
    let dialSeedRes = host.v3Libp2pDial(syncHost, seedHost.selfPeerId, seedAddr, 1)
    if IsErr(dialSeedRes):
        return Err[str](Error(dialSeedRes))
    let dialSyncRes = host.v3Libp2pDial(seedHost, syncHost.selfPeerId, syncAddr, 1)
    if IsErr(dialSyncRes):
        return Err[str](Error(dialSyncRes))
    v3CompilerWorldPublishUniverseWithManagedMirrorBundles(seedHost,
                                                           plan.localUniverse,
                                                           plan.compilerCsg,
                                                           plan.exportSurface,
                                                           plan.compileReceipt,
                                                           mirrorBundles)
    let syncRes = v3CompilerWorldSync(syncHost, seedHost, seedHost.selfPeerId)
    if IsErr(syncRes):
        return Err[str](Error(syncRes))
    var worldText = ""
    if !v3CompilerWorldFirstPayloadTextByKind(syncHost,
                                              pubsub.v3PubSubPayloadKindCompilerWorldHead,
                                              worldText):
        return Err[str]("v3 compiler world libp2p: missing synced world head")
    var parsedHead: cworld.V3CompilerWorldHead
    let parseHeadRes = cworld.v3CompilerWorldHeadFromReportText(worldText, parsedHead)
    if IsErr(parseHeadRes):
        return Err[str](Error(parseHeadRes))
    if !layout.fixedBytes32Equal(parsedHead.headCid, plan.localUniverse.worldHead.headCid):
        return Err[str]("v3 compiler world libp2p: synced head cid mismatch")
    var manifestText = ""
    if !v3CompilerWorldFirstPayloadTextByKind(syncHost,
                                              pubsub.v3PubSubPayloadKindCompilerUniverseManifest,
                                              manifestText):
        return Err[str]("v3 compiler world libp2p: missing synced manifest")
    var parsedManifest: cworld.V3CompilerUniverseManifest
    let parseManifestRes = cworld.v3CompilerUniverseManifestFromReportText(manifestText, parsedManifest)
    if IsErr(parseManifestRes):
        return Err[str]("v3 compiler world libp2p: parse manifest failed: " + Error(parseManifestRes))
    if !layout.fixedBytes32Equal(parsedManifest.manifestCid, plan.localUniverse.manifest.manifestCid):
        return Err[str]("v3 compiler world libp2p: synced manifest cid mismatch")
    return Ok[str](
        "seed_entries=" + intToStr(v3CompilerWorldStoredEntryCount(seedHost)) + "\n" +
        "sync_entries=" + intToStr(v3CompilerWorldStoredEntryCount(syncHost)) + "\n" +
        "published_heads=" + intToStr(v3CompilerWorldPublishedHeadCount(seedHost)) + "\n" +
        "synced_entries=" + intToStr(Value(syncRes)) + "\n" +
        "world_head_cid=" + layout.fixedBytes32Hex(plan.localUniverse.worldHead.headCid) + "\n" +
        "manifest_root_cid=" + layout.fixedBytes32Hex(parsedManifest.manifestCid) + "\n" +
        "manifest_entry_count=" + intToStr(parsedManifest.entryCount) + "\n" +
        "managed_mirror_count=" + intToStr(mirrorBundles.len) + "\n" +
        "receipt_cid=" + layout.fixedBytes32Hex(plan.compileReceipt.receiptCid)
    )

fn v3CompilerWorldFreshNodeSyncPublished(seedHost: var host.V3Libp2pHost,
                                         freshHost: var host.V3Libp2pHost,
                                         localUniverse: cworld.V3CompilerLocalUniverse,
                                         compilerCsg: ccsg.V3CompilerCsg,
                                         exportSurface: ccsg.V3CsgExportSurface,
                                         receipt: ccsg.V3CompileReceipt,
                                         mirrorBundles: V3CompilerManagedMirrorBundle[]): Result[int32] =
    v3CompilerWorldPublishUniverseWithManagedMirrorBundles(seedHost,
                                                           localUniverse,
                                                           compilerCsg,
                                                           exportSurface,
                                                           receipt,
                                                           mirrorBundles)
    return v3CompilerWorldSync(freshHost, seedHost, seedHost.selfPeerId)

fn v3CompilerWorldFreshNodeSyncedState(rootDir: str,
                                       freshHost: host.V3Libp2pHost,
                                       localUniverse: cworld.V3CompilerLocalUniverse,
                                       receipt: ccsg.V3CompileReceipt,
                                       syncedEntryCount: int32): Result[V3CompilerWorldFreshNodeSyncState] =
    var worldText = ""
    if !v3CompilerWorldFirstPayloadTextByKind(freshHost,
                                              pubsub.v3PubSubPayloadKindCompilerWorldHead,
                                              worldText):
        return Err[V3CompilerWorldFreshNodeSyncState]("v3 compiler world libp2p: missing fresh world head")
    worldText = cworld.v3CompilerWorldOwnText(worldText)
    var receiptText = ""
    if !v3CompilerWorldFirstPayloadTextByKind(freshHost,
                                              pubsub.v3PubSubPayloadKindCompilerCompileReceipt,
                                              receiptText):
        return Err[V3CompilerWorldFreshNodeSyncState]("v3 compiler world libp2p: missing fresh receipt")
    receiptText = cworld.v3CompilerWorldOwnText(receiptText)
    var syncedHead: cworld.V3CompilerWorldHead
    let parseHeadRes = cworld.v3CompilerWorldHeadFromReportText(worldText, syncedHead)
    if IsErr(parseHeadRes):
        return Err[V3CompilerWorldFreshNodeSyncState]("v3 compiler world libp2p: parse fresh head failed: " + Error(parseHeadRes))
    if !layout.fixedBytes32Equal(syncedHead.headCid, localUniverse.worldHead.headCid):
        return Err[V3CompilerWorldFreshNodeSyncState]("v3 compiler world libp2p: fresh node head cid mismatch")
    var manifestText = ""
    if !v3CompilerWorldFirstPayloadTextByKind(freshHost,
                                              pubsub.v3PubSubPayloadKindCompilerUniverseManifest,
                                              manifestText):
        return Err[V3CompilerWorldFreshNodeSyncState]("v3 compiler world libp2p: missing fresh manifest")
    manifestText = cworld.v3CompilerWorldOwnText(manifestText)
    var syncedManifest: cworld.V3CompilerUniverseManifest
    let parseManifestRes = cworld.v3CompilerUniverseManifestFromReportText(manifestText, syncedManifest)
    if IsErr(parseManifestRes):
        return Err[V3CompilerWorldFreshNodeSyncState]("v3 compiler world libp2p: parse fresh manifest failed: " + Error(parseManifestRes))
    if !layout.fixedBytes32Equal(syncedManifest.manifestCid, localUniverse.manifest.manifestCid):
        return Err[V3CompilerWorldFreshNodeSyncState]("v3 compiler world libp2p: fresh manifest cid mismatch")
    var syncedReceipt: ccsg.V3CompileReceipt
    let parseReceiptRes = ccsg.v3CompileReceiptFromReportText(receiptText, syncedReceipt)
    if IsErr(parseReceiptRes):
        return Err[V3CompilerWorldFreshNodeSyncState]("v3 compiler world libp2p: parse fresh receipt failed: " + Error(parseReceiptRes))
    if !ccsg.v3CompileReceiptEquivalent(receipt, syncedReceipt):
        return Err[V3CompilerWorldFreshNodeSyncState]("v3 compiler world libp2p: synced receipt drift")
    let syncedMirrorBundlesRes = v3CompilerWorldManagedMirrorBundlesFromHost(freshHost)
    if IsErr(syncedMirrorBundlesRes):
        return Err[V3CompilerWorldFreshNodeSyncState](Error(syncedMirrorBundlesRes))
    let materializeRes = v3CompilerWorldMaterializeManagedMirrorBundles(rootDir, Value(syncedMirrorBundlesRes))
    if IsErr(materializeRes):
        return Err[V3CompilerWorldFreshNodeSyncState](Error(materializeRes))
    var state: V3CompilerWorldFreshNodeSyncState
    state.syncedEntryCount = syncedEntryCount
    state.syncedHead = syncedHead
    state.syncedManifest = syncedManifest
    state.syncedReceipt = syncedReceipt
    state.materializedMirrorCount = Value(materializeRes)
    return Ok[V3CompilerWorldFreshNodeSyncState](state)

fn v3CompilerWorldFreshNodeRebuild(rootDir: str,
                                   req: creq.V3CompilerRequest,
                                   localUniverse: cworld.V3CompilerLocalUniverse,
                                   syncedHead: cworld.V3CompilerWorldHead,
                                   channelRaw: str): Result[ccsg.V3CompileReceipt] =
    let requestedWorldHead = cworld.v3CompilerWorldOwnText(layout.fixedBytes32Hex(syncedHead.headCid))
    let sourcePath = cworld.v3CompilerWorldOwnText(req.sourcePath)
    let freshOutputPath = cworld.v3CompilerWorldOwnText(req.outputPath + ".fresh_node")
    let freshLockPath = cworld.v3CompilerWorldOwnText(freshOutputPath + ".lock.toml")
    let targetTriple = cworld.v3CompilerWorldOwnText(req.targetTriple)
    if !v3path.V3WriteTextFile(rootDir, freshLockPath, cworld.v3CompilerLockText(localUniverse)):
        return Err[ccsg.V3CompileReceipt]("v3 compiler world libp2p: failed to write fresh rebuild lock: " + freshLockPath)
    let freshReq = creq.v3CompilerRequestNew(req.rootDir,
                                             sourcePath,
                                             freshOutputPath,
                                             targetTriple,
                                             req.emitKind,
                                             "")
    let freshPlanRes = sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                          freshReq,
                                                                          requestedWorldHead,
                                                                          freshLockPath,
                                                                          "",
                                                                          channelRaw)
    if IsErr(freshPlanRes):
        return Err[ccsg.V3CompileReceipt]("v3 compiler world libp2p: fresh rebuild plan failed: " + Error(freshPlanRes))
    return Ok[ccsg.V3CompileReceipt](Value(freshPlanRes).compileReceipt)

fn v3CompilerWorldFreshNodeReportText(seedHost: host.V3Libp2pHost,
                                      freshHost: host.V3Libp2pHost,
                                      receipt: ccsg.V3CompileReceipt,
                                      state: V3CompilerWorldFreshNodeSyncState,
                                      freshReceipt: ccsg.V3CompileReceipt): str =
    var out = ""
    out = out + "seed_entries=" + intToStr(v3CompilerWorldStoredEntryCount(seedHost)) + "\n"
    out = out + "fresh_entries=" + intToStr(v3CompilerWorldStoredEntryCount(freshHost)) + "\n"
    out = out + "published_heads=" + intToStr(v3CompilerWorldPublishedHeadCount(seedHost)) + "\n"
    out = out + "synced_entries=" + intToStr(state.syncedEntryCount) + "\n"
    out = out + "world_head_cid=" + layout.fixedBytes32Hex(state.syncedHead.headCid) + "\n"
    out = out + "manifest_root_cid=" + layout.fixedBytes32Hex(state.syncedManifest.manifestCid) + "\n"
    out = out + "manifest_entry_count=" + intToStr(state.syncedManifest.entryCount) + "\n"
    out = out + "managed_mirror_count=" + intToStr(state.materializedMirrorCount) + "\n"
    out = out + "seed_receipt_cid=" + layout.fixedBytes32Hex(receipt.receiptCid) + "\n"
    out = out + "synced_receipt_cid=" + layout.fixedBytes32Hex(state.syncedReceipt.receiptCid) + "\n"
    out = out + "fresh_receipt_cid=" + layout.fixedBytes32Hex(freshReceipt.receiptCid) + "\n"
    out = out + "receipt_equivalent=1\n"
    out = out + "receipt_cid_match=1"
    return out

fn v3CompilerWorldFreshNodeSelfhostReport(rootDir: str,
                                          req: creq.V3CompilerRequest,
                                          plan: sexec.V3SystemLinkExecPlan): Result[str] =
    var seedHost = host.v3Libp2pHostInit("compiler-world-seed")
    var freshHost = host.v3Libp2pHostInit("compiler-world-fresh")
    v3CompilerWorldRegister(seedHost)
    v3CompilerWorldRegister(freshHost)
    let localUniverse = plan.localUniverse
    let compilerCsg = plan.compilerCsg
    let exportSurface = plan.exportSurface
    let receipt = plan.compileReceipt
    let mirrorBundlesRes = v3CompilerWorldManagedMirrorBundlesForPlan(plan)
    if IsErr(mirrorBundlesRes):
        return Err[str](Error(mirrorBundlesRes))
    let mirrorBundles = Value(mirrorBundlesRes)
    let channelRaw = localUniverse.worldHead.channel
    var seedAddr: core.V3Libp2pMultiaddr
    var freshAddr: core.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(seedAddr, "127.0.0.1", 6463)
    multiaddr.v3Libp2pMultiaddrFillTcp(freshAddr, "127.0.0.1", 6464)
    let seedListenRes = host.v3Libp2pListen(seedHost, seedAddr)
    if IsErr(seedListenRes):
        return Err[str](Error(seedListenRes))
    let freshListenRes = host.v3Libp2pListen(freshHost, freshAddr)
    if IsErr(freshListenRes):
        return Err[str](Error(freshListenRes))
    let dialSeedRes = host.v3Libp2pDial(freshHost, seedHost.selfPeerId, seedAddr, 1)
    if IsErr(dialSeedRes):
        return Err[str](Error(dialSeedRes))
    let dialFreshRes = host.v3Libp2pDial(seedHost, freshHost.selfPeerId, freshAddr, 1)
    if IsErr(dialFreshRes):
        return Err[str](Error(dialFreshRes))
    let syncRes = v3CompilerWorldFreshNodeSyncPublished(seedHost,
                                                        freshHost,
                                                        localUniverse,
                                                        compilerCsg,
                                                        exportSurface,
                                                        receipt,
                                                        mirrorBundles)
    if IsErr(syncRes):
        return Err[str](Error(syncRes))
    let stateRes = v3CompilerWorldFreshNodeSyncedState(rootDir,
                                                       freshHost,
                                                       localUniverse,
                                                       receipt,
                                                       Value(syncRes))
    if IsErr(stateRes):
        return Err[str](Error(stateRes))
    let state = Value(stateRes)
    let freshReceiptRes = v3CompilerWorldFreshNodeRebuild(rootDir,
                                                          req,
                                                          localUniverse,
                                                          state.syncedHead,
                                                          channelRaw)
    if IsErr(freshReceiptRes):
        return Err[str](Error(freshReceiptRes))
    let freshReceipt = Value(freshReceiptRes)
    if !ccsg.v3CompileReceiptEquivalent(state.syncedReceipt, freshReceipt):
        return Err[str]("v3 compiler world libp2p: fresh rebuild receipt drift")
    if !layout.fixedBytes32Equal(state.syncedReceipt.receiptCid, freshReceipt.receiptCid):
        return Err[str]("v3 compiler world libp2p: fresh rebuild receipt cid mismatch")
    return Ok[str](v3CompilerWorldFreshNodeReportText(seedHost,
                                                      freshHost,
                                                      receipt,
                                                      state,
                                                      freshReceipt))

fn V3CompilerWorldMaterializeManagedMirrorBundlesFromBundlePrefix(rootDir: str,
                                                                  prefix: str): Result[int32] =
    return v3CompilerWorldMaterializeManagedMirrorBundlesFromBundlePrefix(rootDir, prefix)

fn V3CompilerWorldManagedMirrorMaterializeReport(prefix: str,
                                                 materializedMirrorCount: int32): str =
    return v3CompilerWorldManagedMirrorMaterializeReport(prefix, materializedMirrorCount)
