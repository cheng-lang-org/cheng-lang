import std/cmdline as cmdline
import std/os
import std/strutils as strutil
import std/strings
import cheng/v3/tooling/bootstrap_contracts as contracts
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn v3VpnProxyGuiToolPrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn v3VpnProxyGuiToolPrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn v3VpnProxyGuiToolUsage() =
    v3VpnProxyGuiToolPrintLine("usage: cheng vpn-gui [--config:<path>] [--runtime-tool:<path>]")
    v3VpnProxyGuiToolPrintLine("builds gui runtime + local runtime, then opens the desktop gui window")

fn v3VpnProxyGuiToolRoot(): str =
    let envRoot: str = os.GetEnv("CHENG_V3_ROOT")
    if len(envRoot) > 0:
        return envRoot
    return os.GetCurrentDir()

fn v3VpnProxyGuiToolCollectArgsFrom(startIndex: int32,
                                    count: int32): str[] =
    var out: str[]
    if startIndex > count:
        return out
    for i in startIndex..count:
        let arg: str = cmdline.ParamStr(i)
        if len(arg) > 0:
            add(out, arg)
    return out

fn v3VpnProxyGuiToolHostTarget(): str =
    let detected: str = contracts.v3BootstrapDetectHostTarget()
    if len(detected) > 0:
        return detected
    return contracts.v3BootstrapDefaultTarget()

fn v3VpnProxyGuiToolCompiler(rootDir: str): str =
    let envCompilerRaw: str = os.GetEnvDefault("CHENG_V3_VPN_PROXY_COMPILER", "")
    let envCompiler: str = strutil.Strip(envCompilerRaw)
    if len(envCompiler) > 0:
        return v3path.V3PathAbsolute(rootDir, envCompiler)
    let backendDriver: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver/cheng")
    if v3path.V3FileExistsNonEmpty(rootDir, backendDriver):
        return backendDriver
    let stage3Path: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage3")
    if v3path.V3FileExistsNonEmpty(rootDir, stage3Path):
        return stage3Path
    return ""

fn v3VpnProxyGuiToolRunFailed(context: str,
                              run: hostops.V3LoggedRun): bool =
    if run.exitCode == 0:
        return false
    v3VpnProxyGuiToolPrintErr(context + " rc=" + intToStr(run.exitCode) + " log=" + run.logPath)
    let outputText: str = strutil.Strip(run.output)
    if len(outputText) > 0:
        v3VpnProxyGuiToolPrintErr(outputText)
    return true

fn v3VpnProxyGuiToolReadFlag(args: str[],
                             key: str,
                             defaultValue: str): str =
    let colonPrefix: str = key + ":"
    let eqPrefix: str = key + "="
    for i in 0..<args.len:
        let arg: str = args[i]
        if strutil.StartsWith(arg, colonPrefix):
            return strutil.Strip(strings.SliceBytes(arg, len(colonPrefix), len(arg) - len(colonPrefix)))
        if strutil.StartsWith(arg, eqPrefix):
            return strutil.Strip(strings.SliceBytes(arg, len(eqPrefix), len(arg) - len(eqPrefix)))
        if arg == key && i + 1 < args.len:
            return strutil.Strip(args[i + 1])
    return defaultValue

fn v3VpnProxyGuiToolHasFlag(args: str[],
                            key: str): bool =
    let colonPrefix: str = key + ":"
    let eqPrefix: str = key + "="
    for i in 0..<args.len:
        let arg: str = args[i]
        if arg == key:
            return true
        if strutil.StartsWith(arg, colonPrefix):
            return true
        if strutil.StartsWith(arg, eqPrefix):
            return true
    return false

fn v3VpnProxyGuiToolCompile(rootDir: str,
                            compilerPath: str,
                            label: str,
                            sourcePathRaw: str,
                            outDirRaw: str,
                            binName: str): str =
    let sourcePath: str = v3path.V3PathAbsolute(rootDir, sourcePathRaw)
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRaw)
    if !v3path.V3MkdirP(rootDir, outDir):
        v3VpnProxyGuiToolPrintErr("vpn gui: failed to create tool dir: " + outDir)
        return ""
    let outBin: str = os.JoinPath(outDir, binName)
    let reportPath: str = os.JoinPath(outDir, binName + ".report.txt")
    let compileLogPath: str = os.JoinPath(outDir, binName + ".compile.log")
    let packageRoot: str = v3path.V3PathAbsolute(rootDir, "v3")
    let compileArgs: str[] = [
        "system-link-exec",
        "--root:" + packageRoot,
        "--in:" + sourcePath,
        "--emit:exe",
        "--target:" + v3VpnProxyGuiToolHostTarget(),
        "--out:" + outBin,
        "--report-out:" + reportPath
    ]
    let compileRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                                  label + "_compile",
                                                                  compilerPath,
                                                                  compileArgs,
                                                                  [],
                                                                  rootDir,
                                                                  300,
                                                                  compileLogPath)
    if v3VpnProxyGuiToolRunFailed("vpn gui: compile " + binName, compileRun):
        return ""
    if !v3path.V3FileExistsNonEmpty(rootDir, outBin):
        v3VpnProxyGuiToolPrintErr("vpn gui: output missing: " + outBin)
        return ""
    return outBin

fn v3VpnProxyGuiToolRun(rootDir: str,
                        args: str[]): int32 =
    let compilerPath: str = v3VpnProxyGuiToolCompiler(rootDir)
    if len(compilerPath) <= 0:
        v3VpnProxyGuiToolPrintErr("vpn gui: missing compiler path")
        return 1
    let runtimeToolOverride: str = v3VpnProxyGuiToolReadFlag(args, "--runtime-tool", "")
    var runtimeToolPath: str
    if len(runtimeToolOverride) > 0:
        runtimeToolPath = v3path.V3PathAbsolute(rootDir, runtimeToolOverride)
    else:
        runtimeToolPath = v3VpnProxyGuiToolCompile(rootDir,
                                                   compilerPath,
                                                   "vpn_proxy_runtime_tool",
                                                   "v3/src/tooling/vpn_proxy_runtime_tool_main.cheng",
                                                   "artifacts/v3_backend_driver_tools/vpn_proxy_runtime_tool",
                                                   "vpn_proxy_runtime_tool")
    if len(runtimeToolPath) <= 0:
        return 1
    let guiRuntimePath: str = v3VpnProxyGuiToolCompile(rootDir,
                                                       compilerPath,
                                                       "vpn_proxy_gui_runtime_tool",
                                                       "v3/src/tooling/vpn_proxy_gui_runtime_tool_main.cheng",
                                                       "artifacts/v3_backend_driver_tools/vpn_proxy_gui_runtime_tool",
                                                       "vpn_proxy_gui_runtime_tool")
    if len(guiRuntimePath) <= 0:
        return 1
    var runArgs: str[]
    if !v3VpnProxyGuiToolHasFlag(args, "--runtime-tool"):
        add(runArgs, "--runtime-tool:" + runtimeToolPath)
    for i in 0..<args.len:
        add(runArgs, args[i])
    let runLogPath: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver_tools/vpn_proxy_gui_runtime_tool/vpn_proxy_gui_runtime_tool.run.log")
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                           "vpn_proxy_gui_runtime_tool_run",
                                                           guiRuntimePath,
                                                           runArgs,
                                                           [],
                                                           rootDir,
                                                           0,
                                                           runLogPath)
    let outputText: str = strutil.Strip(run.output)
    if len(outputText) > 0:
        if run.exitCode == 0:
            v3VpnProxyGuiToolPrintLine(outputText)
        else:
            v3VpnProxyGuiToolPrintErr(outputText)
    return run.exitCode

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let rootDir: str = v3VpnProxyGuiToolRoot()
    let count: int32 = cmdline.ParamCount()
    let args: str[] = v3VpnProxyGuiToolCollectArgsFrom(1, count)
    if args.len > 0:
        let cmd: str = args[0]
        if cmd == "help" || cmd == "--help" || cmd == "-h":
            v3VpnProxyGuiToolUsage()
            return 0
    return v3VpnProxyGuiToolRun(rootDir, args)
