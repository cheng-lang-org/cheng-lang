fn v3BackendDriverRunChainNodeResilienceSmoke(rootDir: str,
                                              args: str[]): int32 =
    return v3BackendDriverRunChainNodeResilienceScenario(rootDir,
                                                         args,
                                                         "host_resilience",
                                                         "v3 chain_node resilience smoke ok")

fn v3BackendDriverVerifyChainNodeResilience(rootDir: str,
                                            args: str[]): int32 =
    return v3BackendDriverRunChainNodeResilienceScenario(rootDir,
                                                         args,
                                                         "host_resilience_gate",
                                                         "verify-chain-node-resilience: ok")

fn v3BackendDriverR2cCodegenSurfaceSmokeAt(rootDir: str,
                                           repo: str,
                                           outDir: str,
                                           printSummary: bool): bool =
    let tsxAstPath: str = os.JoinPath(outDir, "tsx_ast_v1.json")
    let tsxSummaryPath: str = os.JoinPath(outDir, "tsx_ast_v1.summary.env")
    let frontendLogPath: str = v3path.V3PathAbsolute(rootDir,
                                                     "artifacts/v3_backend_driver/r2c_react_v3_ts_frontend.log")
    let frontendScriptPath: str = v3BackendDriverR2cTsFrontendScript(rootDir)
    let frontendRun: hostops.V3LoggedRun = hostops.v3RunProgramLogged(rootDir,
                                                                      "r2c_react_v3_ts_frontend",
                                                                      "node",
                                                                      [
                                                                          frontendScriptPath,
                                                                          "--repo", repo,
                                                                          "--out", tsxAstPath,
                                                                          "--summary-out", tsxSummaryPath
                                                                      ],
                                                                      [],
                                                                      rootDir,
                                                                      0,
                                                                      frontendLogPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: r2c-react-v3-ts-frontend", frontendRun):
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, tsxAstPath):
        v3BackendDriverPrintErr("v3 backend driver: missing tsx ast: " + tsxAstPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, tsxSummaryPath):
        v3BackendDriverPrintErr("v3 backend driver: missing tsx summary: " + tsxSummaryPath)
        return false
    let logPath: str = v3path.V3PathAbsolute(rootDir,
                                             "artifacts/v3_backend_driver/r2c_react_v3_codegen_surface_smoke.log")
    let scriptPath: str = v3BackendDriverR2cCodegenSurfaceScript(rootDir)
    let summaryPath: str = os.JoinPath(outDir, "codegen_surface.summary.env")
    let run: hostops.V3LoggedRun = hostops.v3RunProgramLogged(rootDir,
                                                              "r2c_react_v3_codegen_surface_smoke",
                                                              "node",
                                                              [
                                                                  scriptPath,
                                                                  "--repo", repo,
                                                                  "--out-dir", outDir,
                                                                  "--summary-out", summaryPath
                                                              ],
                                                              [],
                                                              rootDir,
                                                              0,
                                                              logPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: r2c-react-v3-codegen-surface-smoke", run):
        return false
    let reportPath: str = os.JoinPath(outDir, "codegen_surface_report_v1.json")
    let manifestPath: str = os.JoinPath(outDir, "cheng_codegen_v1.json")
    let routeCatalogPath: str = os.JoinPath(outDir, "cheng_codegen_route_catalog_v1.json")
    let smokePath: str = os.JoinPath(outDir, "cheng_codegen_smoke_v1.json")
    if !v3path.V3FileExistsNonEmpty(rootDir, reportPath):
        v3BackendDriverPrintErr("v3 backend driver: missing codegen surface report: " + reportPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, summaryPath):
        v3BackendDriverPrintErr("v3 backend driver: missing codegen surface summary: " + summaryPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, manifestPath):
        v3BackendDriverPrintErr("v3 backend driver: missing codegen manifest: " + manifestPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, routeCatalogPath):
        v3BackendDriverPrintErr("v3 backend driver: missing codegen route catalog: " + routeCatalogPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, smokePath):
        v3BackendDriverPrintErr("v3 backend driver: missing codegen smoke artifact: " + smokePath)
        return false
    let reportText: str = v3path.V3ReadTextFile("", reportPath)
    let summaryText: str = v3path.V3ReadTextFile("", summaryPath)
    let manifestText: str = v3path.V3ReadTextFile("", manifestPath)
    let routeCatalogText: str = v3path.V3ReadTextFile("", routeCatalogPath)
    let reportCommandNeedle: str = "\"command\": \"codegen-surface\""
    let reportOkNeedle: str = "\"ok\": true"
    let summarySmokeNeedle: str = "smoke_ok=true"
    let summaryManifestNeedle: str = "codegen_manifest_path=" + manifestPath
    let summaryCatalogNeedle: str = "route_catalog_path=" + routeCatalogPath
    let summarySmokePathNeedle: str = "codegen_smoke_path=" + smokePath
    if !v3path.V3TextContains(reportText, reportCommandNeedle) ||
       !v3path.V3TextContains(reportText, reportOkNeedle):
        v3BackendDriverPrintErr("v3 backend driver: codegen surface report drifted: " + reportPath)
        return false
    if !v3path.V3TextContains(summaryText, summarySmokeNeedle) ||
       !v3path.V3TextContains(summaryText, summaryManifestNeedle) ||
       !v3path.V3TextContains(summaryText, summaryCatalogNeedle) ||
       !v3path.V3TextContains(summaryText, summarySmokePathNeedle):
        v3BackendDriverPrintErr("v3 backend driver: codegen surface summary drifted: " + summaryPath)
        return false
    if !v3path.V3TextContains(manifestText, "\"format\": \"cheng_codegen_v1\"") ||
       !v3path.V3TextContains(routeCatalogText, "\"format\": \"cheng_codegen_route_catalog_v1\""):
        v3BackendDriverPrintErr("v3 backend driver: codegen surface JSON contract drifted")
        return false
    if printSummary:
        v3BackendDriverPrintLine("r2c-react-v3 codegen surface smoke: ok")
        v3BackendDriverPrintLine("tsx_ast=" + tsxAstPath)
        v3BackendDriverPrintLine("codegen_summary=" + summaryPath)
        v3BackendDriverPrintLine("codegen_manifest=" + manifestPath)
        v3BackendDriverPrintLine("route_catalog=" + routeCatalogPath)
        v3BackendDriverPrintLine("codegen_smoke=" + smokePath)
    return true

fn v3BackendDriverR2cNativeGuiBundleSmokeAt(rootDir: str,
                                            repo: str,
                                            routeState: str,
                                            outDir: str,
                                            printSummary: bool): bool =
    let compileLogPath: str = v3path.V3PathAbsolute(rootDir,
                                                    "artifacts/v3_backend_driver/r2c_react_v3_compile_smoke.log")
    let prototypePath: str = v3BackendDriverR2cPrototypeScript(rootDir)
    let compileRun: hostops.V3LoggedRun = hostops.v3RunProgramLogged(rootDir,
                                                                     "r2c_react_v3_compile_smoke",
                                                                     "python3",
                                                                     [
                                                                         prototypePath,
                                                                         "compile",
                                                                         repo,
                                                                         "--out-dir", outDir,
                                                                         "--allow-blockers"
                                                                     ],
                                                                     [],
                                                                     rootDir,
                                                                     0,
                                                                     compileLogPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: r2c-react-v3 compile", compileRun):
        return false
    let hostContractPath: str = os.JoinPath(outDir, "unimaker_host_v1.json")
    let assetManifestPath: str = os.JoinPath(outDir, "asset_manifest_v1.json")
    let tailwindManifestPath: str = os.JoinPath(outDir, "tailwind_style_manifest_v1.json")
    let compileReportPath: str = os.JoinPath(outDir, "compile_report_v1.json")
    if !v3path.V3FileExistsNonEmpty(rootDir, hostContractPath) ||
       !v3path.V3FileExistsNonEmpty(rootDir, assetManifestPath) ||
       !v3path.V3FileExistsNonEmpty(rootDir, tailwindManifestPath) ||
       !v3path.V3FileExistsNonEmpty(rootDir, compileReportPath):
        v3BackendDriverPrintErr("v3 backend driver: r2c-react-v3 compile missing bundle prerequisites")
        return false
    if !v3BackendDriverR2cCodegenSurfaceSmokeAt(rootDir, repo, outDir, false):
        return false
    let logPath: str = v3path.V3PathAbsolute(rootDir,
                                             "artifacts/v3_backend_driver/r2c_react_v3_native_gui_bundle_smoke.log")
    let scriptPath: str = v3BackendDriverR2cNativeGuiBundleScript(rootDir)
    let stage3Path: str = v3BackendDriverStage3Path(rootDir)
    let run: hostops.V3LoggedRun = hostops.v3RunProgramLogged(rootDir,
                                                              "r2c_react_v3_native_gui_bundle_smoke",
                                                              "node",
                                                              [
                                                                  scriptPath,
                                                                  "--repo", repo,
                                                                  "--route-state", routeState,
                                                                  "--out-dir", outDir
                                                              ],
                                                              [
                                                                  "R2C_REACT_V3_TOOLING_BIN=" + stage3Path,
                                                                  "CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"
                                                              ],
                                                              rootDir,
                                                              0,
                                                              logPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: r2c-react-v3-native-gui-bundle-smoke", run):
        return false
    let reportPath: str = os.JoinPath(outDir, "native_gui_bundle_report_v1.json")
    let summaryPath: str = os.JoinPath(outDir, "native_gui_bundle.summary.env")
    let bundleJsonPath: str = os.JoinPath(outDir, "native_gui_bundle_v1.json")
    if !v3path.V3FileExistsNonEmpty(rootDir, reportPath):
        v3BackendDriverPrintErr("v3 backend driver: missing native gui bundle report: " + reportPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, summaryPath):
        v3BackendDriverPrintErr("v3 backend driver: missing native gui bundle summary: " + summaryPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, bundleJsonPath):
        v3BackendDriverPrintErr("v3 backend driver: missing native gui bundle json: " + bundleJsonPath)
        return false
    let reportText: str = v3path.V3ReadTextFile("", reportPath)
    let summaryText: str = v3path.V3ReadTextFile("", summaryPath)
    if !v3path.V3TextContains(reportText, "\"ok\": true") ||
       !v3path.V3TextContains(reportText, "\"native_gui_host_ready\": true") ||
       !v3path.V3TextContains(reportText, "\"native_gui_renderer_ready\": true"):
        v3BackendDriverPrintErr("v3 backend driver: native gui bundle report drifted: " + reportPath)
        return false
    let runtimeModeNeedle: str = "native_gui_runtime_mode=cheng_compiled_json_v1"
    let routeStateNeedle: str = "native_gui_route_state=" + routeState
    let execSnapshotNeedle: str = "native_gui_exec_snapshot_path="
    let routeCatalogNeedle: str = "native_gui_route_catalog_path="
    if !v3path.V3TextContains(summaryText, runtimeModeNeedle):
        v3BackendDriverPrintErr("v3 backend driver: native gui bundle summary drifted: " + summaryPath)
        return false
    if !v3path.V3TextContains(summaryText, routeStateNeedle):
        v3BackendDriverPrintErr("v3 backend driver: native gui bundle summary drifted: " + summaryPath)
        return false
    if !v3path.V3TextContains(summaryText, execSnapshotNeedle) ||
       !v3path.V3TextContains(summaryText, routeCatalogNeedle):
        v3BackendDriverPrintErr("v3 backend driver: native gui bundle summary drifted: " + summaryPath)
        return false
    if printSummary:
        v3BackendDriverPrintLine("r2c-react-v3 native gui bundle smoke: ok")
        v3BackendDriverPrintLine("route_state=" + routeState)
        v3BackendDriverPrintLine("bundle_report=" + reportPath)
        v3BackendDriverPrintLine("bundle_summary=" + summaryPath)
        v3BackendDriverPrintLine("bundle_json=" + bundleJsonPath)
    return true

fn v3BackendDriverR2cReactV3CodegenSurfaceSmoke(rootDir: str,
                                                count: int32): int32 =
    let repoRaw: str = v3BackendDriverReadFlagOrDefault(count, "--repo", "/Users/lbcheng/UniMaker/React.js")
    let outDirRaw: str = v3BackendDriverReadFlagOrDefault(count, "--out-dir", "/tmp/r2c-codegen-surface-smoke")
    let repo: str = v3path.V3PathAbsolute(rootDir, repoRaw)
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRaw)
    if !os.DirExists(repo):
        v3BackendDriverPrintErr("v3 backend driver: missing React.js repo: " + repo)
        return 2
    if !v3BackendDriverR2cCodegenSurfaceSmokeAt(rootDir, repo, outDir, true):
        return 1
    return 0

fn v3BackendDriverR2cReactV3NativeGuiBundleSmoke(rootDir: str,
                                                 count: int32): int32 =
    let repoRaw: str = v3BackendDriverReadFlagOrDefault(count, "--repo", "/Users/lbcheng/UniMaker/React.js")
    let routeStateRaw: str = v3BackendDriverReadFlagOrDefault(count, "--route-state", "home_default")
    let outDirRaw: str = v3BackendDriverReadFlagOrDefault(count, "--out-dir", "/tmp/r2c-native-gui-bundle-smoke")
    let repo: str = v3path.V3PathAbsolute(rootDir, repoRaw)
    let routeState: str = strutil.Strip(routeStateRaw)
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRaw)
    if !os.DirExists(repo):
        v3BackendDriverPrintErr("v3 backend driver: missing React.js repo: " + repo)
        return 2
    if len(routeState) <= 0:
        v3BackendDriverPrintErr("v3 backend driver: missing --route-state for native gui bundle smoke")
        return 2
    if !v3BackendDriverR2cNativeGuiBundleSmokeAt(rootDir, repo, routeState, outDir, true):
        return 1
    return 0

fn v3BackendDriverR2cReactV3FreshCleanGate(rootDir: str,
                                           count: int32): int32 =
    let repoRaw: str = v3BackendDriverReadFlagOrDefault(count, "--repo", "/Users/lbcheng/UniMaker/React.js")
    let repo: str = v3path.V3PathAbsolute(rootDir, repoRaw)
    if !os.DirExists(repo):
        v3BackendDriverPrintErr("v3 backend driver: missing React.js repo: " + repo)
        return 2
    let statusOut: str = "/tmp/r2c-status-fresh-clean-gate.json"
    let codegenOutDir: str = "/tmp/r2c-codegen-surface-fresh-clean-gate"
    let routeStates: str[] = ["home_default", "content_detail", "publish_selector"]
    let hostAuditText: str = v3BackendDriverHostBridgeAuditText(rootDir)
    v3BackendDriverPrintStdoutBlock(hostAuditText)
    if !v3path.V3TextContains(hostAuditText, "pure_cheng_zero_c_ready=1") ||
       !v3path.V3TextContains(hostAuditText, "remaining_non_pure_cheng_boundary=none"):
        v3BackendDriverPrintErr("v3 backend driver: host bridge audit not ready for r2c fresh clean gate")
        return 2
    let statusLogPath: str = v3path.V3PathAbsolute(rootDir,
                                                   "artifacts/v3_backend_driver/r2c_react_v3_fresh_clean_gate.status.log")
    let wrapperPath: str = v3BackendDriverR2cWrapperPath(rootDir)
    let statusRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                                 "r2c_react_v3_status",
                                                                 wrapperPath,
                                                                 [
                                                                     "status",
                                                                     "--out", statusOut
                                                                 ],
                                                                 ["R2C_REACT_V3_NO_STAGE3_HANDOFF=1"],
                                                                 rootDir,
                                                                 0,
                                                                 statusLogPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: r2c-react-v3-fresh-clean-gate status", statusRun):
        return 1
    if !v3path.V3FileExistsNonEmpty(rootDir, statusOut):
        v3BackendDriverPrintErr("v3 backend driver: missing r2c status report: " + statusOut)
        return 1
    let statusText: str = v3path.V3ReadTextFile("", statusOut)
    if !v3path.V3TextContains(statusText, "\"static_surface_helper\": \"\"") ||
       !v3path.V3TextContains(statusText, "\"semantic_surface_helper\": \"\"") ||
       !v3path.V3TextContains(statusText, "r2c-react-v3-truth-runtime.mjs") ||
       !v3path.V3TextContains(statusText, "\"exec_surface_helper\": \"\"") ||
       !v3path.V3TextContains(statusText, "\"native_gui_runtime_helper\": \"\"") ||
       !v3path.V3TextContains(statusText, "\"native_gui_replay_hit_inspector_helper\": \"\"") ||
       !v3path.V3TextContains(statusText, "\"legacy_wrapper_required\": false") ||
       !v3path.V3TextContains(statusText, "\"active_node_helper_count\": 6") ||
       !v3path.V3TextContains(statusText, "\"retired_node_helper_count\": 7") ||
       !v3path.V3TextContains(statusText, "\"standalone_node_helper_count\": 1") ||
       !v3path.V3TextContains(statusText, "\"truth_compare_helper\"") ||
       !v3path.V3TextContains(statusText, "\"truth_compare_matrix_helper\"") ||
       !v3path.V3TextContains(statusText, "\"standalone_node_helpers\": [") ||
       !v3path.V3TextContains(statusText, "\"truth_runtime_helper\""):
        v3BackendDriverPrintErr("v3 backend driver: r2c status report drifted: " + statusOut)
        return 1
    if !v3BackendDriverR2cCodegenSurfaceSmokeAt(rootDir, repo, codegenOutDir, false):
        return 1
    for i in 0..<routeStates.len:
        let routeState: str = routeStates[i]
        let bundleOutDir: str = "/tmp/r2c-native-gui-fresh-clean-gate-" + routeState
        if !v3BackendDriverR2cNativeGuiBundleSmokeAt(rootDir, repo, routeState, bundleOutDir, false):
            return 1
    v3BackendDriverPrintLine("r2c-react-v3 fresh clean gate: ok")
    v3BackendDriverPrintLine("status_report=" + statusOut)
    for i in 0..<routeStates.len:
        let routeState: str = routeStates[i]
        let bundleReportPath: str = "/tmp/r2c-native-gui-fresh-clean-gate-" + routeState +
            "/native_gui_bundle_report_v1.json"
        v3BackendDriverPrintLine("bundle_report_" + routeState + "=" + bundleReportPath)
    return 0


fn v3BackendDriverVerifyExportVisibility(rootDir: str): int32 =
    let selfPath: str = v3BackendDriverSelfPath(rootDir)
    if len(selfPath) <= 0:
        v3BackendDriverPrintErr("v3 backend driver: missing self path for verify-export-visibility")
        return 2
    let label: str = v3BackendDriverVerifyExportLabel(selfPath)
    let smokes: str[] = ["export_visibility_smoke", "export_visibility_negative_smoke", "strformat_export_negative_smoke"]
    let logPath: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver/verify_export_visibility.log")
    let run: hostops.V3LoggedRun = v3BackendDriverRunHostSmokesLogged(rootDir,
                                                                      v3BackendDriverStage3Path(rootDir),
                                                                      selfPath,
                                                                      label,
                                                                      smokes,
                                                                      logPath)
    v3BackendDriverMaybePrintRunOutput(run)
    if v3BackendDriverRunFailed("v3 backend driver: verify-export-visibility", run):
        return run.exitCode
    return 0

fn v3BackendDriverVerifyExportVisibilityParallel(rootDir: str): int32 =
    let selfPath: str = v3BackendDriverSelfPath(rootDir)
    if len(selfPath) <= 0:
        v3BackendDriverPrintErr("v3 backend driver: missing self path for verify-export-visibility-parallel")
        return 2
    let label: str = v3BackendDriverVerifyExportParallelLabel(selfPath)
    let stage3Path: str = v3BackendDriverStage3Path(rootDir)
    if !v3path.V3FileExistsNonEmpty(rootDir, stage3Path):
        v3BackendDriverPrintErr("v3 backend driver: missing stage3 compiler for verify-export-visibility-parallel")
        return 2
    let smokes: str[] = ["export_visibility_smoke", "export_visibility_negative_smoke", "strformat_export_negative_smoke"]
    let stage3Label: str = "verify_export_stage3_parallel"
    let backendLabel: str = "verify_export_backend_driver_parallel"
    let stage3Log: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver/verify_export_visibility_parallel.stage3.log")
    let backendLog: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver/verify_export_visibility_parallel.backend.log")
    let stage3Run: hostops.V3LoggedRun = v3BackendDriverRunHostSmokesLogged(rootDir,
                                                                            stage3Path,
                                                                            stage3Path,
                                                                            stage3Label,
                                                                            smokes,
                                                                            stage3Log)
    v3BackendDriverMaybePrintRunOutput(stage3Run)
    if v3BackendDriverRunFailed("v3 backend driver: verify-export-visibility-parallel stage3", stage3Run):
        return stage3Run.exitCode
    let backendRun: hostops.V3LoggedRun = v3BackendDriverRunHostSmokesLogged(rootDir,
                                                                              stage3Path,
                                                                              selfPath,
                                                                              backendLabel,
                                                                              smokes,
                                                                              backendLog)
    v3BackendDriverMaybePrintRunOutput(backendRun)
    if v3BackendDriverRunFailed("v3 backend driver: verify-export-visibility-parallel backend", backendRun):
        return backendRun.exitCode
    let stage3TextRaw: str = v3path.V3ReadTextFile("", stage3Log)
    let stage3Text: str = strutil.Strip(stage3TextRaw)
    let backendTextRaw: str = v3path.V3ReadTextFile("", backendLog)
    let backendText: str = strutil.Strip(backendTextRaw)
    if !v3path.V3TextContains(stage3Text, "v3 host smokes: ok") ||
       !v3path.V3TextContains(backendText, "v3 host smokes: ok"):
        v3BackendDriverPrintErr("v3 backend driver: verify-export-visibility-parallel output drift")
        return 1
    v3BackendDriverPrintLine("v3 host smokes: ok")
    return 0

