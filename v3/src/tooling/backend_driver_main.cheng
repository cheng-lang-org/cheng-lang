    v3BackendDriverPrintLine("usage: cheng r2c-react-v3 <subcommand> [args]")
    v3BackendDriverPrintLine("subcommands: help, status, frontend, static-surface, semantic-surface, codegen-surface, discover-truth-routes, capture-truth, truth-compare, compare-truth, exec-route-matrix, compare-truth-matrix, native-gui-bundle, native-gui-runtime, run-native-gui, replay-hit-inspector, compile")
    v3BackendDriverPrintLine("frontend flags: --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...]")
    v3BackendDriverPrintLine("static-surface flags: --repo <path> [--tsx-ast <file>] [--out-dir <dir>] [--runtime-root <dir> ...] [--asset-root <dir> ...]")
    v3BackendDriverPrintLine("semantic-surface flags: --repo <path> [--tsx-ast <file>] [--out-dir <dir>] [--runtime-root <dir> ...]")
    v3BackendDriverPrintLine("discover-truth-routes flags: --repo <path> [--out-dir <dir>] [--runtime-root <dir> ...]")
    v3BackendDriverPrintLine("capture-truth flags: --repo <path> --route <state> [--out-dir <dir>] [--base-url <url>] [--chrome <bin>] [--width <n>] [--height <n>] [--truth-flag <0|1>] [--debug-port <n>] [--wait-ms <n>]")
    v3BackendDriverPrintLine("compare-truth flags: --exec-snapshot <file> --truth-trace <file> [--codegen-manifest <file>] [--truth-state <state>] [--out <file>]")
    v3BackendDriverPrintLine("exec-route-matrix flags: (--route-catalog <file> | --tsx-ast <file>) --exec-snapshot <file> --truth-routes-file <file> [--codegen-manifest <file>] [--truth-trace <file>] [--out <file>]")
    v3BackendDriverPrintLine("compare-truth-matrix flags: --exec-route-matrix <file> --truth-trace <file> [--codegen-manifest <file>] [--out <file>]")
    v3BackendDriverPrintLine("native-gui-runtime flags: --runtime-contract <file> [--state-* ...] [--event-* ...]")
    v3BackendDriverPrintLine("run-native-gui flags: --click x,y --resize WxH --scroll-y <n> --wait-after-click-ms <n> --focus-item-id <id> --type-text <text> --send-key <key> --inspector-state-out <file> --open-source-on-click")
