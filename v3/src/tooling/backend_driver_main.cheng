fn v3BackendDriverR2cReactV3Status(rootDir: str,
                                   count: int32): int32 =
    let effectiveRoot: str = v3BackendDriverR2cReactV3EffectiveRoot(rootDir, count)
    let outPathValue: str = v3BackendDriverReadFlagOrDefault(count, "--out", "")
    let outPathRaw: str = strutil.Strip(outPathValue)
    if len(outPathRaw) > 0:
        let outPath: str = v3path.V3PathAbsolute(effectiveRoot, outPathRaw)
        if !v3BackendDriverWriteR2cReactV3StatusReport(outPath, effectiveRoot, count):
            v3BackendDriverPrintErr("v3 backend driver: failed to write r2c-react-v3 status report")
            return 1
        v3BackendDriverPrintLine(outPath)
        return 0
    let outPath: str = os.JoinPath(effectiveRoot, "artifacts/r2c_react_v3_status_report_v1.json")
    if !v3BackendDriverWriteR2cReactV3StatusReport(outPath, effectiveRoot, count):
        v3BackendDriverPrintErr("v3 backend driver: failed to write r2c-react-v3 status report")
        return 1
    let body: str = v3path.V3ReadTextFile("", outPath)
    v3BackendDriverPrintLine(body)
    return 0

fn v3BackendDriverRequestedTarget(count: int32): str =
    let defaultTarget: str = contracts.v3BootstrapDefaultTarget()
    var targetRaw: str = defaultTarget
    var i: int32 = 2
    while i <= count:
        let arg: str = cmdline.ParamStr(i)
        let colonPrefix: str = "--target:"
        let equalPrefix: str = "--target="
        if arg.len >= colonPrefix.len:
            if strings.SliceBytes(arg, 0, colonPrefix.len) == colonPrefix:
                targetRaw = strings.SliceBytes(arg, colonPrefix.len, arg.len - colonPrefix.len)
        if arg.len >= equalPrefix.len:
            if strings.SliceBytes(arg, 0, equalPrefix.len) == equalPrefix:
                targetRaw = strings.SliceBytes(arg, equalPrefix.len, arg.len - equalPrefix.len)
        i = i + 1
    let trimmed: str = strutil.Strip(targetRaw)
    if len(trimmed) > 0:
        return trimmed
    return defaultTarget

fn v3BackendDriverPrintBuildPlan(rootDir: str,
                                 count: int32): int32 =
    let targetTriple: str = v3BackendDriverRequestedTarget(count)
    let plan: buildplan.V3BackendBuildPlan = buildplan.v3BackendBuildPlanBackendDriverForTarget(rootDir, targetTriple)
    let reportRaw: str = buildplan.v3BackendBuildPlanReport(plan)
    let report: str = strutil.Strip(reportRaw)
    v3BackendDriverPrintLine(report)
    return 0

fn v3BackendDriverSharedEmitExtension(targetTriple: str): str =
    if slplan.v3SystemLinkPlanTargetIsWindows(targetTriple):
        return ".dll"
    if targetTriple == "arm64-apple-darwin":
        return ".dylib"
    return ".so"

fn v3BackendDriverSharedEmitFileHint(targetTriple: str): str =
    if slplan.v3SystemLinkPlanTargetIsWindows(targetTriple):
        return "PE32+"
    if targetTriple == "arm64-apple-darwin":
        return "shared library"
    return "shared object"

fn v3BackendDriverHostTarget(): str =
    let detected: str = contracts.v3BootstrapDetectHostTarget()
    if detected == "arm64-apple-darwin" ||
       detected == "x86_64-apple-darwin" ||
       detected == "x86_64-unknown-linux-gnu" ||
       detected == "aarch64-unknown-linux-gnu":
        return detected
    return ""

fn v3BackendDriverResolveVerifyTarget(count: int32,
                                      context: str,
                                      outTarget: var str): bool =
    let requested: str = v3BackendDriverRequestedTarget(count)
    let defaultTarget: str = contracts.v3BootstrapDefaultTarget()
    if requested != defaultTarget:
        v3BackendDriverPrintErr(v3BackendDriverConcat3("v3 backend driver: ",
                                                       context,
                                                       " only supports host backend_driver target"))
        outTarget = ""
        return false
    let hostTarget: str = v3BackendDriverHostTarget()
    if len(hostTarget) > 0:
        outTarget = hostTarget
        return true
    outTarget = defaultTarget
    return true

fn v3BackendDriverPrintRunFailure(context: str,
                                  run: hostops.V3LoggedRun): bool =
    if run.exitCode == 0:
        return false
    v3BackendDriverPrintErr(context + " rc=" + intToStr(run.exitCode) + " log=" + run.logPath)
    let outputRaw: str = run.output
    let outputText: str = strutil.Strip(outputRaw)
    if len(outputText) > 0:
        v3BackendDriverPrintErr(outputText)
    return true

fn v3BackendDriverRunSelftest(rootDir: str,
                              selfPath: str,
                              targetTriple: str,
                              sourcePath: str,
                              stem: str,
                              expectedOutput: str): bool =
    let packageRoot: str = v3path.V3PathAbsolute(rootDir, "v3")
    let outBinRelRaw: str = "artifacts/v3_backend_driver/" + stem + ".selftest"
    let outReportRelRaw: str = outBinRelRaw + ".report.txt"
    let outCompileLogRelRaw: str = "artifacts/v3_backend_driver/" + stem + ".selftest.compile.log"
    let outRunLogRelRaw: str = "artifacts/v3_backend_driver/" + stem + ".selftest.run.log"
    let outBinRel: str = newStringCopy(strDataPtr(outBinRelRaw), strLenFast(outBinRelRaw))
    let outReportRel: str = newStringCopy(strDataPtr(outReportRelRaw), strLenFast(outReportRelRaw))
    let outCompileLogRel: str = newStringCopy(strDataPtr(outCompileLogRelRaw), strLenFast(outCompileLogRelRaw))
    let outRunLogRel: str = newStringCopy(strDataPtr(outRunLogRelRaw), strLenFast(outRunLogRelRaw))
    let outBin: str = v3path.V3PathAbsolute(rootDir, outBinRel)
    let outReportPath: str = v3path.V3PathAbsolute(rootDir, outReportRel)
    let outCompileLogPath: str = v3path.V3PathAbsolute(rootDir, outCompileLogRel)
    let outRunLogPath: str = v3path.V3PathAbsolute(rootDir, outRunLogRel)
    let compileArgs: str[] = [
        "system-link-exec",
        "--root:" + packageRoot,
        "--in:" + sourcePath,
        "--emit:exe",
        "--target:" + targetTriple,
        "--out:" + outBin,
        "--report-out:" + outReportPath
    ]
    let compileRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                                  "backend_driver_selftest_compile",
                                                                  selfPath,
                                                                  compileArgs,
                                                                  [],
                                                                  rootDir,
                                                                  0,
                                                                  outCompileLogPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: selftest compile", compileRun):
        return false
    let compileText: str = v3path.V3ReadTextFile("", outCompileLogPath)
    if strutil.Contains(compileText, "[cheng_v3_seed]"):
        v3BackendDriverPrintErr("v3 backend driver: selftest emitted internal seed diagnostics")
        return false
    let lineMapPathRaw: str = outBin + ".v3.map"
    let lineMapPath: str = newStringCopy(strDataPtr(lineMapPathRaw), strLenFast(lineMapPathRaw))
    if !v3path.V3FileExistsNonEmpty(rootDir, outBin):
        v3BackendDriverPrintErr("v3 backend driver: selftest missing output: " + outBin)
        return false
    if !v3path.V3PathFileExists(lineMapPath):
        v3BackendDriverPrintErr("v3 backend driver: selftest missing line map: " + lineMapPath)
        return false
    let runArgs: str[] = []
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                           "backend_driver_selftest_run",
                                                           outBin,
                                                           runArgs,
                                                           [],
                                                           rootDir,
                                                           0,
                                                           outRunLogPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: selftest run", run):
        return false
    let runTextRaw: str = v3path.V3ReadTextFile("", outRunLogPath)
    let runText: str = strutil.Strip(runTextRaw)
    if len(expectedOutput) <= 0:
        if len(runText) > 0:
            v3BackendDriverPrintErr("v3 backend driver: selftest expected empty stdout")
            return false
    elif runText != expectedOutput:
        v3BackendDriverPrintErr("v3 backend driver: selftest output drifted")
        if len(runText) > 0:
            v3BackendDriverPrintErr(runText)
        return false
    return true

fn v3BackendDriverVerifyLiveSmoke(rootDir: str,
                                  count: int32,
                                  sourceRel: str,
                                  stem: str,
                                  expectedOutput: str,
                                  successText: str): int32 =
    var targetTriple: str = ""
    if !v3BackendDriverResolveVerifyTarget(count, successText, targetTriple):
        return 1
    var selfPath: str = ""
    selfPath = v3BackendDriverSelfPath(rootDir)
    if len(selfPath) <= 0:
        v3BackendDriverPrintErr("v3 backend driver: missing self path for " + successText)
        return 2
    let sourcePath: str = v3path.V3PathAbsolute(rootDir, sourceRel)
    if !v3BackendDriverRunSelftest(rootDir,
                                   selfPath,
                                   targetTriple,
                                   sourcePath,
                                   stem,
                                   expectedOutput):
        return 1
    v3BackendDriverPrintLine(successText)
    return 0

fn v3BackendDriverSharedEmitRunDirRel(): str =
    var now: monotimes.MonoTime
    now = monotimes.GetMonoTime()
    let nowNs: int64 = monotimes.MonoTimeNs(now)
    return "artifacts/v3_shared_emit_smokes/" + int64ToStr(nowNs)

fn v3BackendDriverRunSharedEmitSmokes(rootDir: str,
                                      count: int32): int32 =
    var selfPath: str = ""
    selfPath = v3BackendDriverSelfPath(rootDir)
    if len(selfPath) <= 0:
        v3BackendDriverPrintErr("v3 backend driver: missing self path for run-shared-emit-smokes")
        return 2
    let packageRoot: str = v3path.V3PathAbsolute(rootDir, "v3")
    let fixtureSource: str = v3path.V3PathAbsolute(rootDir, "v3/src/tests/shared_emit_fixture.cheng")
    let targetTriple: str = v3BackendDriverRequestedTarget(count)
    let extension: str = v3BackendDriverSharedEmitExtension(targetTriple)
    let outDirRelRaw: str = v3BackendDriverSharedEmitRunDirRel()
    let outDirRel: str = newStringCopy(strDataPtr(outDirRelRaw), strLenFast(outDirRelRaw))
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRel)
    let outLibRelRaw: str = outDirRel + "/shared_emit_fixture" + extension
    let outLibRel: str = newStringCopy(strDataPtr(outLibRelRaw), strLenFast(outLibRelRaw))
    let outLib: str = v3path.V3PathAbsolute(rootDir, outLibRel)
    let reportRelRaw: str = outDirRel + "/shared_emit_fixture.report.txt"
    let compileLogRelRaw: str = outDirRel + "/shared_emit_fixture.compile.log"
    let fileLogRelRaw: str = outDirRel + "/shared_emit_fixture.file.txt"
    let reportRel: str = newStringCopy(strDataPtr(reportRelRaw), strLenFast(reportRelRaw))
    let compileLogRel: str = newStringCopy(strDataPtr(compileLogRelRaw), strLenFast(compileLogRelRaw))
    let fileLogRel: str = newStringCopy(strDataPtr(fileLogRelRaw), strLenFast(fileLogRelRaw))
    let reportPath: str = v3path.V3PathAbsolute(rootDir, reportRel)
    let compileLogPath: str = v3path.V3PathAbsolute(rootDir, compileLogRel)
    let fileLogPath: str = v3path.V3PathAbsolute(rootDir, fileLogRel)
    if !v3path.V3MkdirP(rootDir, outDir):
        v3BackendDriverPrintErr("v3 backend driver: failed to create shared emit smoke dir")
        return 2
    if v3path.V3PathFileExists(outLib):
        os.RemoveFile(outLib)
    if v3path.V3PathFileExists(reportPath):
        os.RemoveFile(reportPath)
    let compileArgs: str[] = [
        "system-link-exec",
        "--root:" + packageRoot,
        "--in:" + fixtureSource,
        "--emit:shared",
        "--target:" + targetTriple,
        "--out:" + outLib,
        "--report-out:" + reportPath
    ]
    let compileRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                                  "backend_driver_shared_emit_compile",
                                                                  selfPath,
                                                                  compileArgs,
                                                                  [],
                                                                  rootDir,
                                                                  0,
                                                                  compileLogPath)
    if compileRun.exitCode != 0:
        v3BackendDriverPrintErr("backend_driver_shared_emit_compile rc=" + intToStr(compileRun.exitCode) + " log=" + compileRun.logPath)
        let compileOutputRaw: str = compileRun.output
        let compileOutput: str = strutil.Strip(compileOutputRaw)
        if len(compileOutput) > 0:
            v3BackendDriverPrintErr(compileOutput)
        else:
            v3BackendDriverPrintErr("v3 backend driver: run-shared-emit-smokes compile failed")
        return 2
    if !v3path.V3FileExistsNonEmpty(rootDir, outLib):
        v3BackendDriverPrintErr("v3 backend driver: shared emit smoke missing output: " + outLib)
        return 2
    if !v3path.V3FileExistsNonEmpty(rootDir, reportPath):
        v3BackendDriverPrintErr("v3 backend driver: shared emit smoke missing report: " + reportPath)
        return 2
    let reportText: str = v3path.V3ReadTextFile("", reportPath)
    if !v3path.V3TextContains(reportText, "emit=shared") ||
       !v3path.V3TextContains(reportText, "main_function_present=0") ||
       !v3path.V3TextContains(reportText, "missing_reasons=-") ||
       !v3path.V3TextContains(reportText, "native_link_missing_reasons=-"):
        v3BackendDriverPrintErr("v3 backend driver: shared emit smoke report shape mismatch: " + reportPath)
        return 2
    let fileRun: hostops.V3LoggedRun = hostops.v3RunProgramLogged(rootDir,
                                                                  "backend_driver_shared_emit_file",
                                                                  "file",
                                                                  [outLib],
                                                                  [],
                                                                  rootDir,
                                                                  0,
                                                                  fileLogPath)
    if fileRun.exitCode != 0:
        v3BackendDriverPrintErr("backend_driver_shared_emit_file rc=" + intToStr(fileRun.exitCode) + " log=" + fileRun.logPath)
        let fileOutputRaw: str = fileRun.output
        let fileOutput: str = strutil.Strip(fileOutputRaw)
        if len(fileOutput) > 0:
            v3BackendDriverPrintErr(fileOutput)
        else:
            v3BackendDriverPrintErr("v3 backend driver: run-shared-emit-smokes file failed")
        return 2
    let fileText: str = v3path.V3ReadTextFile("", fileLogPath)
    let expectedHint: str = v3BackendDriverSharedEmitFileHint(targetTriple)
    if len(expectedHint) > 0:
        if !v3path.V3TextContains(fileText, expectedHint):
            v3BackendDriverPrintErr(v3BackendDriverConcat3("v3 backend driver: shared emit smoke expected `",
                                                           expectedHint,
                                                           "` in file output"))
            let trimmedFileText: str = strutil.Strip(fileText)
            if len(trimmedFileText) > 0:
                v3BackendDriverPrintErr(trimmedFileText)
            return 2
    v3BackendDriverPrintLine("v3 shared emit smokes: ok")
    v3BackendDriverPrintLine("target=" + targetTriple)
    v3BackendDriverPrintLine("out=" + outLib)
    v3BackendDriverPrintLine("report=" + reportPath)
    return 0

fn v3BackendDriverEnvLineValue(text: str,
                               key: str): str =
    let prefix: str = key + "="
    var start: int32 = 0
    var i: int32 = 0
    while i <= text.len:
        var lineEnd: bool = false
        if i == text.len:
            lineEnd = true
        elif text[i] == '\n':
            lineEnd = true
        if lineEnd:
            let line: str = strings.SliceBytes(text, start, i - start)
            if line.len >= prefix.len:
                if strings.SliceBytes(line, 0, prefix.len) == prefix:
                    return strings.SliceBytes(line, prefix.len, line.len - prefix.len)
            start = i + 1
        i = i + 1
    return ""

fn v3BackendDriverRuntimeAbiContractText(rootDir: str): str =
    let relPath: str = "v3/tooling/backend_runtime_abi_contract.env"
    let absPath: str = v3path.V3PathAbsolute(rootDir, relPath)
    return v3path.V3ReadTextFile("", absPath)

fn v3BackendDriverRuntimeAbiPath(rootDir: str,
                                 contractText: str,
                                 key: str,
                                 fallbackRel: str): str =
    var relPath: str = v3BackendDriverEnvLineValue(contractText, key)
    relPath = strutil.Strip(relPath)
    if len(relPath) > 0:
        return v3path.V3PathAbsolute(rootDir, relPath)
    return v3path.V3PathAbsolute(rootDir, fallbackRel)

fn v3BackendDriverHostBridgeAuditText(rootDir: str): str =
    let backendDriverMainPath: str = v3path.V3PathAbsolute(rootDir, "v3/src/tooling/backend_driver_main.cheng")
    let compilerMainPath: str = v3path.V3PathAbsolute(rootDir, "v3/src/tooling/compiler_main.cheng")
    let compilerRuntimePath: str = v3path.V3PathAbsolute(rootDir, "v3/src/tooling/compiler_runtime.cheng")
    let gateMainPath: str = v3path.V3PathAbsolute(rootDir, "v3/src/tooling/gate_main.cheng")
    let seedPath: str = v3path.V3PathAbsolute(rootDir, "v3/bootstrap/cheng_v3_seed.c")
    let backendDriverMainText: str = v3path.V3ReadTextFile("", backendDriverMainPath)
    let compilerMainText: str = v3path.V3ReadTextFile("", compilerMainPath)
    let compilerRuntimeText: str = v3path.V3ReadTextFile("", compilerRuntimePath)
    let gateMainText: str = v3path.V3ReadTextFile("", gateMainPath)
    let seedText: str = v3path.V3ReadTextFile("", seedPath)
    let buildRuntimeObjCmd = "build-program" + "-runtime-obj"
    let verifyRuntimeObjCmd = "verify-program" + "-runtime-obj"
    let runtimeObjImportNeedle = "runtime_program_obj as " + "runtimeobj"
    let runtimeCombinedSmoke = "runtime_program_" + "combined_smoke"
    let runtimeCombinedNegativeSmoke = "runtime_program_" + "combined_negative_smoke"
    let runtimeNativeSourceNeedle = "src/runtime/" + "native/"
    let backendDriverNodeHostNeedle = "v3BackendDriverRun" + "NodeSource("
    let gateNodeHostNeedle = "v3GateRun" + "NodeSource("
    let gateWasmRunnerNeedle = "v3GateWasmSmokes" + "RunnerSource("
    let browserHostWasmRunnerPathRel: str = "v3/tooling/browser_host_" + "wasm_runner.js"
    let browserHostWasmRunnerPath: str = v3path.V3PathAbsolute(rootDir, browserHostWasmRunnerPathRel)
    let browserHostWasmRunnerPathNeedle: str = "tooling/browser_host_" + "wasm_runner.js"
    let legacyRuntimeProgramObjCommandPresent = strutil.Contains(compilerRuntimeText, buildRuntimeObjCmd) ||
                                                strutil.Contains(compilerRuntimeText, verifyRuntimeObjCmd) ||
                                                strutil.Contains(compilerMainText, buildRuntimeObjCmd) ||
                                                strutil.Contains(compilerMainText, verifyRuntimeObjCmd)
    let legacyRuntimeProgramObjImportPresent = strutil.Contains(compilerMainText, runtimeObjImportNeedle)
    let legacyRuntimeProgramCombinedSmokePresent = strutil.Contains(gateMainText, runtimeCombinedSmoke) ||
                                                   strutil.Contains(gateMainText, runtimeCombinedNegativeSmoke) ||
                                                   strutil.Contains(seedText, runtimeCombinedSmoke) ||
                                                   strutil.Contains(seedText, runtimeCombinedNegativeSmoke)
    let legacyRuntimeNativeSourcePathPresent = strutil.Contains(compilerMainText, runtimeNativeSourceNeedle) ||
                                               strutil.Contains(compilerRuntimeText, runtimeNativeSourceNeedle) ||
                                               strutil.Contains(gateMainText, runtimeNativeSourceNeedle) ||
                                               strutil.Contains(seedText, runtimeNativeSourceNeedle)
    let legacyRuntimeCombinedFallbackPresent = false
    let legacyBrowserHostWasmRunnerPresent: bool = v3path.V3PathFileExists(browserHostWasmRunnerPath) ||
                                                   strutil.Contains(compilerMainText, browserHostWasmRunnerPathNeedle) ||
                                                   strutil.Contains(compilerRuntimeText, browserHostWasmRunnerPathNeedle) ||
                                                   strutil.Contains(gateMainText, browserHostWasmRunnerPathNeedle) ||
                                                   strutil.Contains(seedText, browserHostWasmRunnerPathNeedle)
    let legacyNodeWasmHostPresent: bool = strutil.Contains(backendDriverMainText, backendDriverNodeHostNeedle) ||
                                           strutil.Contains(gateMainText, gateNodeHostNeedle) ||
                                           strutil.Contains(gateMainText, gateWasmRunnerNeedle)
    var remainingBoundary: str = "none"
    if legacyRuntimeProgramObjCommandPresent:
        remainingBoundary = "runtime_program_obj_command_surface"
    elif legacyRuntimeProgramObjImportPresent:
        remainingBoundary = "runtime_program_obj_import_surface"
    elif legacyRuntimeProgramCombinedSmokePresent:
        remainingBoundary = "runtime_program_combined_smoke_surface"
    elif legacyRuntimeNativeSourcePathPresent:
        remainingBoundary = "runtime_native_source_surface"
    elif legacyRuntimeCombinedFallbackPresent:
        remainingBoundary = "runtime_combined_fallback_surface"
    elif legacyNodeWasmHostPresent:
        remainingBoundary = "node_wasm_host_surface"
    elif legacyBrowserHostWasmRunnerPresent:
        remainingBoundary = "browser_host_wasm_runner_surface"
    var out = ""
    if legacyRuntimeProgramObjCommandPresent:
        out = out + "legacy_runtime_program_obj_command_present=1\n"
    else:
        out = out + "legacy_runtime_program_obj_command_present=0\n"
    if legacyRuntimeProgramObjImportPresent:
        out = out + "legacy_runtime_program_obj_import_present=1\n"
    else:
        out = out + "legacy_runtime_program_obj_import_present=0\n"
    if legacyRuntimeProgramCombinedSmokePresent:
        out = out + "legacy_runtime_program_combined_smoke_present=1\n"
    else:
        out = out + "legacy_runtime_program_combined_smoke_present=0\n"
    if legacyRuntimeNativeSourcePathPresent:
        out = out + "legacy_runtime_native_source_path_present=1\n"
    else:
        out = out + "legacy_runtime_native_source_path_present=0\n"
    if legacyRuntimeCombinedFallbackPresent:
        out = out + "legacy_runtime_combined_fallback_present=1\n"
    else:
        out = out + "legacy_runtime_combined_fallback_present=0\n"
    if legacyNodeWasmHostPresent:
        out = out + "legacy_node_wasm_host_present=1\n"
    else:
        out = out + "legacy_node_wasm_host_present=0\n"
    if legacyBrowserHostWasmRunnerPresent:
        out = out + "legacy_browser_host_wasm_runner_present=1\n"
    else:
        out = out + "legacy_browser_host_wasm_runner_present=0\n"
    out = out + "remaining_non_pure_cheng_boundary=" + remainingBoundary + "\n"
    if remainingBoundary == "none":
        out = out + "pure_cheng_zero_c_ready=1\n"
    else:
        out = out + "pure_cheng_zero_c_ready=0\n"
    return strutil.Strip(out)

fn v3BackendDriverHostBridgeAuditRun(rootDir: str,
                                     outText: var str): int32 =
    outText = v3BackendDriverHostBridgeAuditText(rootDir)
    if v3path.V3TextContains(outText, "pure_cheng_zero_c_ready=1"):
        return 0
    return 2

fn v3BackendDriverHostBridgeAudit(rootDir: str): int32 =
    var out: str = ""
    let code: int32 = v3BackendDriverHostBridgeAuditRun(rootDir, out)
    if len(out) > 0:
        v3BackendDriverPrintStdoutBlock(out)
    return code

fn v3BackendDriverCollectArgsFrom(startIndex: int32,
                                  count: int32): str[] =
    var out: str[] = []
    if startIndex > count:
        return out
    for i in startIndex..count:
        let arg: str = cmdline.ParamStr(i)
        if len(arg) > 0:
            add(out, arg)
    return out

fn v3BackendDriverForward(rootDir: str,
                          args: str[]): int32 =
    let stage3Path: str = v3BackendDriverStage3Path(rootDir)
    if !v3path.V3FileExistsNonEmpty(rootDir, stage3Path):
        v3BackendDriverPrintErr("v3 backend driver: missing stage3 compiler: " + stage3Path)
        return 2
    let logDir: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_forward")
    let _made: bool = v3path.V3MkdirP(rootDir, logDir)
    let logPath: str = os.JoinPath(logDir, "backend_driver.forward.log")
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                           "backend_driver_forward",
                                                           stage3Path,
                                                           args,
                                                           ["CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"],
                                                           rootDir,
                                                           0,
                                                           logPath)
    var outputText: str = run.output
    if len(outputText) > 0:
        if run.exitCode == 0:
            v3BackendDriverPrintStdoutBlock(outputText)
        else:
            v3BackendDriverPrintStderrBlock(outputText)
    elif run.exitCode != 0:
        v3BackendDriverPrintErr("v3 backend driver: forward failed")
    return run.exitCode

fn v3BackendDriverRunHostSmokesArgs(compilerPath: str,
                                    label: str,
                                    smokes: str[]): str[] =
    var out: str[] = []
    add(out, "run-host-smokes")
    add(out, "--compiler:" + compilerPath)
    add(out, "--label:" + label)
    for i in 0..<smokes.len:
        add(out, smokes[i])
    return out

fn v3BackendDriverRunHostSmokesLogged(rootDir: str,
                                      runnerPath: str,
                                      compilerPath: str,
                                      label: str,
                                      smokes: str[],
                                      logPath: str): hostops.V3LoggedRun =
    let args: str[] = v3BackendDriverRunHostSmokesArgs(compilerPath, label, smokes)
    return hostops.v3RunFileLogged(rootDir,
                                   "backend_driver_run_host_smokes",
                                   runnerPath,
                                   args,
                                   ["CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"],
                                   rootDir,
                                   0,
                                   logPath)

fn v3BackendDriverReadFlagOrDefault(count: int32,
                                    flagName: str,
                                    defaultValue: str): str =
    let colonPrefix: str = flagName + ":"
    let equalPrefix: str = flagName + "="
    var i: int32 = 2
    while i <= count:
        let arg: str = cmdline.ParamStr(i)
        if arg == flagName:
            if i < count:
                let nextValue: str = cmdline.ParamStr(i + 1)
                if len(nextValue) > 0:
                    return nextValue
            return defaultValue
        if arg.len >= colonPrefix.len:
            if strings.SliceBytes(arg, 0, colonPrefix.len) == colonPrefix:
                return strings.SliceBytes(arg, colonPrefix.len, arg.len - colonPrefix.len)
        if arg.len >= equalPrefix.len:
            if strings.SliceBytes(arg, 0, equalPrefix.len) == equalPrefix:
                return strings.SliceBytes(arg, equalPrefix.len, arg.len - equalPrefix.len)
        i = i + 1
    return defaultValue

fn v3BackendDriverTextContainsAll(text: str,
                                  needles: str[]): bool =
    var i: int32 = 0
    while i < needles.len:
        let needle: str = needles[i]
        if !v3path.V3TextContains(text, needle):
            return false
        i = i + 1
    return true

fn v3BackendDriverRunStage3Logged(rootDir: str,
                                  label: str,
                                  args: str[],
                                  logPath: str): hostops.V3LoggedRun =
    let stage3Path: str = v3BackendDriverStage3Path(rootDir)
    return hostops.v3RunFileLogged(rootDir,
                                   label,
                                   stage3Path,
                                   args,
                                   ["CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"],
                                   rootDir,
                                   0,
                                   logPath)

fn v3BackendDriverR2cExperimentalRoot(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "v3/experimental/r2c-react-v3")

fn v3BackendDriverR2cWrapperPath(rootDir: str): str =
    let expRoot: str = v3BackendDriverR2cExperimentalRoot(rootDir)
    return os.JoinPath(expRoot, "r2c-react-v3")

fn v3BackendDriverR2cCodegenSurfaceScript(rootDir: str): str =
    let expRoot: str = v3BackendDriverR2cExperimentalRoot(rootDir)
    return os.JoinPath(expRoot, "r2c-react-v3-codegen-surface.mjs")

fn v3BackendDriverR2cTsFrontendScript(rootDir: str): str =
    let expRoot: str = v3BackendDriverR2cExperimentalRoot(rootDir)
    return os.JoinPath(expRoot, "r2c-react-v3-ts-frontend.mjs")

fn v3BackendDriverR2cNativeGuiBundleScript(rootDir: str): str =
    let expRoot: str = v3BackendDriverR2cExperimentalRoot(rootDir)
    return os.JoinPath(expRoot, "r2c-react-v3-native-gui-bundle.mjs")

fn v3BackendDriverR2cPrototypeScript(rootDir: str): str =
    let expRoot: str = v3BackendDriverR2cExperimentalRoot(rootDir)
    return os.JoinPath(expRoot, "r2c-react-v3.py")

fn v3BackendDriverMaybePrintRunOutput(run: hostops.V3LoggedRun) =
    let outputRaw: str = run.output
    let outputText: str = strutil.Strip(outputRaw)
    if len(outputText) > 0:
        v3BackendDriverPrintLine(outputText)

fn v3BackendDriverRunFailed(context: str,
                            run: hostops.V3LoggedRun): bool =
    if run.exitCode == 0:
        return false
    return v3BackendDriverPrintRunFailure(context, run)

fn v3BackendDriverOutputContains(text: str,
                                 needle: str): bool =
    return strutil.Contains(text, needle)

fn v3BackendDriverRequireOutput(run: hostops.V3LoggedRun,
                                needle: str,
                                context: str): bool =
    if v3BackendDriverOutputContains(run.output, needle):
        return true
    v3BackendDriverPrintErr(context + ": missing output: " + needle)
    let outputRaw: str = run.output
    let outputText: str = strutil.Strip(outputRaw)
    if len(outputText) > 0:
        v3BackendDriverPrintErr(outputText)
    return false

fn v3BackendDriverIsDigits(text: str): bool =
    if len(text) <= 0:
        return false
    for i in 0..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return false
    return true

fn v3BackendDriverTextValue(text: str,
                            key: str): str =
    let prefixRaw: str = key + "="
    let prefix: str = newStringCopy(strDataPtr(prefixRaw), strLenFast(prefixRaw))
    var start: int32 = 0
    while start < len(text):
        var stop: int32 = start
        while stop < len(text):
            if text[stop] == '\n':
                break
            if text[stop] == '\r':
                break
            stop = stop + 1
        let line: str = strings.SliceBytes(text, start, stop - start)
        if line.len >= prefix.len:
            let head: str = strings.SliceBytes(line, 0, prefix.len)
            if head == prefix:
                return strings.SliceBytes(line, prefix.len, line.len - prefix.len)
        start = stop + 1
        while start < len(text):
            if text[start] != '\n':
                if text[start] != '\r':
                    break
            start = start + 1
    return ""

fn v3BackendDriverRequireTextValue(text: str,
                                   key: str,
                                   expected: str,
                                   context: str): bool =
    let rawValue: str = v3BackendDriverTextValue(text, key)
    let actual: str = strutil.Strip(rawValue)
    if actual == expected:
        return true
    var message = context
    message = message + ": expected "
    message = message + key
    message = message + "="
    message = message + expected
    message = message + ", got "
    message = message + actual
    v3BackendDriverPrintErr(message)
    return false

fn v3BackendDriverRequireRunValue(run: hostops.V3LoggedRun,
                                  key: str,
                                  expected: str,
                                  context: str): bool =
    return v3BackendDriverRequireTextValue(run.output, key, expected, context)

fn v3BackendDriverRequireMatchingRunValue(leftRun: hostops.V3LoggedRun,
                                          rightRun: hostops.V3LoggedRun,
                                          key: str,
                                          context: str): bool =
    let leftRaw: str = v3BackendDriverTextValue(leftRun.output, key)
    let rightRaw: str = v3BackendDriverTextValue(rightRun.output, key)
    let leftValue: str = strutil.Strip(leftRaw)
    let rightValue: str = strutil.Strip(rightRaw)
    if len(leftValue) > 0:
        if leftValue == rightValue:
            return true
    v3BackendDriverPrintErr(context + ": mismatched " + key + ": left=" + leftValue + " right=" + rightValue)
    return false

fn v3BackendDriverRequireStateParity(authorRun: hostops.V3LoggedRun,
                                     replicaRun: hostops.V3LoggedRun,
                                     context: str): bool =
    if !v3BackendDriverRequireMatchingRunValue(authorRun, replicaRun, "event_count", context):
        return false
    if !v3BackendDriverRequireMatchingRunValue(authorRun, replicaRun, "tip_event_cid", context):
        return false
    if !v3BackendDriverRequireMatchingRunValue(authorRun, replicaRun, "forest_cid", context):
        return false
    return true

fn v3BackendDriverReadFlag(args: str[],
                           key: str,
                           defaultValue: str): str =
    let colonPrefixRaw: str = key + ":"
    let equalPrefixRaw: str = key + "="
    let colonPrefix: str = newStringCopy(strDataPtr(colonPrefixRaw), strLenFast(colonPrefixRaw))
    let equalPrefix: str = newStringCopy(strDataPtr(equalPrefixRaw), strLenFast(equalPrefixRaw))
    var i: int32 = 0
    while i < args.len:
        let arg: str = args[i]
        if arg == key:
            let nextIndex: int32 = i + 1
            if nextIndex < args.len:
                return args[nextIndex]
        if arg.len >= colonPrefix.len:
            let prefix: str = strings.SliceBytes(arg, 0, colonPrefix.len)
            if prefix == colonPrefix:
                return strings.SliceBytes(arg, colonPrefix.len, arg.len - colonPrefix.len)
        if arg.len >= equalPrefix.len:
            let prefix: str = strings.SliceBytes(arg, 0, equalPrefix.len)
            if prefix == equalPrefix:
                return strings.SliceBytes(arg, equalPrefix.len, arg.len - equalPrefix.len)
        i = i + 1
    return defaultValue

fn v3BackendDriverResolveSmokeLabel(args: str[],
                                    envKey: str,
                                    defaultLabel: str): str =
    let explicitRaw: str = v3BackendDriverReadFlag(args, "--label", "")
    let explicit: str = strutil.Strip(explicitRaw)
    if len(explicit) > 0:
        return explicit
    let envValueRaw: str = os.GetEnvDefault(envKey, defaultLabel)
    let envValue: str = strutil.Strip(envValueRaw)
    if len(envValue) > 0:
        return envValue
    return defaultLabel

fn v3BackendDriverResolveChainNodeCompiler(rootDir: str,
                                           args: str[],
                                           outCompiler: var str): bool =
    let explicitRaw: str = v3BackendDriverReadFlag(args, "--compiler", "")
    let explicit: str = strutil.Strip(explicitRaw)
    if len(explicit) > 0:
        outCompiler = v3path.V3PathAbsolute(rootDir, explicit)
        return true
    let selfPath: str = v3BackendDriverSelfPath(rootDir)
    if len(selfPath) > 0:
        outCompiler = selfPath
        return true
    outCompiler = ""
    v3BackendDriverPrintErr("v3 chain_node resilience smoke: missing compiler path")
    return false

fn v3BackendDriverToolTarget(): str =
    var targetTriple: str = v3BackendDriverHostTarget()
    if len(targetTriple) <= 0:
        targetTriple = contracts.v3BootstrapDefaultTarget()
    return targetTriple

fn v3BackendDriverResolveToolCompiler(rootDir: str,
                                      toolName: str,
                                      outCompiler: var str): bool =
    let selfPath: str = v3BackendDriverSelfPath(rootDir)
    if len(selfPath) > 0:
        outCompiler = selfPath
        return true
    let stage3Path: str = v3BackendDriverStage3Path(rootDir)
    if v3path.V3FileExistsNonEmpty(rootDir, stage3Path):
        outCompiler = stage3Path
        return true
    outCompiler = ""
    v3BackendDriverPrintErr("v3 backend driver: missing compiler path for " + toolName)
    return false

fn v3BackendDriverCompileEmit(rootDir: str,
                              label: str,
                              compilerPath: str,
                              sourcePath: str,
                              emitKind: str,
                              outPath: str,
                              target: str,
                              logPath: str): hostops.V3LoggedRun =
    let packageRoot: str = v3path.V3PathAbsolute(rootDir, "v3")
    let outParts: os.SplitFileResult = os.SplitFile(outPath)
    if len(outParts.dir) > 0:
        let outDirPath: str = outParts.dir
        let _made: bool = v3path.V3MkdirP(rootDir, outDirPath)
    let logParts: os.SplitFileResult = os.SplitFile(logPath)
    if len(logParts.dir) > 0:
        let logDirPath: str = logParts.dir
        let _made: bool = v3path.V3MkdirP(rootDir, logDirPath)
    let timeoutText: str = os.GetEnvDefault("CHENG_V3_COMPILE_TIMEOUT_SEC", "300")
    let timeoutSec: int32 = int32(strutil.ParseInt(timeoutText))
    var compileArgs: str[] = []
    add(compileArgs, "system-link-exec")
    add(compileArgs, "--root")
    add(compileArgs, packageRoot)
    add(compileArgs, "--in")
    add(compileArgs, sourcePath)
    add(compileArgs, "--emit")
    add(compileArgs, emitKind)
    add(compileArgs, "--target")
    add(compileArgs, target)
    add(compileArgs, "--out")
    add(compileArgs, outPath)
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                           label,
                                                           compilerPath,
                                                           compileArgs,
                                                           [],
                                                           rootDir,
                                                           timeoutSec,
                                                           logPath)
    if run.exitCode == 0:
        if !os.FileExists(outPath):
            let outputText: str = run.output + "v3 backend driver: compile missing output: " + outPath + "\n"
            let _logged: bool = v3path.V3WriteTextFile(rootDir, logPath, outputText)
            return hostops.v3LoggedRunZero(label, compilerPath, logPath, 1, outputText)
    return run

fn v3BackendDriverCompileExe(rootDir: str,
                             label: str,
                             compilerPath: str,
                             sourcePath: str,
                             outPath: str,
                             target: str,
                             logPath: str): hostops.V3LoggedRun =
    return v3BackendDriverCompileEmit(rootDir,
                                      label,
                                      compilerPath,
                                      sourcePath,
                                      "exe",
                                      outPath,
                                      target,
                                      logPath)

fn v3BackendDriverRunBinary(rootDir: str,
                            label: str,
                            binPath: str,
                            args: str[],
                            timeoutSec: int32,
                            logPath: str): hostops.V3LoggedRun =
    return v3BackendDriverRunBinaryEnv(rootDir, label, binPath, args, [], timeoutSec, logPath)

fn v3BackendDriverRunBinaryEnv(rootDir: str,
                               label: str,
                               binPath: str,
                               args: str[],
                               envOverrides: str[],
                               timeoutSec: int32,
                               logPath: str): hostops.V3LoggedRun =
    let logParts: os.SplitFileResult = os.SplitFile(logPath)
    if len(logParts.dir) > 0:
        let logDirPath: str = logParts.dir
        let _made: bool = v3path.V3MkdirP(rootDir, logDirPath)
    return hostops.v3RunFileLogged(rootDir, label, binPath, args, envOverrides, rootDir, timeoutSec, logPath)

fn v3BackendDriverRunToolFromSourceWithCompiler(rootDir: str,
                                                toolName: str,
                                                sourceRel: str,
                                                compilerPath: str,
                                                args: str[],
                                                envOverrides: str[]): int32 =
    let outDir: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver_tools/" + toolName)
    if !v3path.V3MkdirP(rootDir, outDir):
        v3BackendDriverPrintErr("v3 backend driver: failed to create tool dir for " + toolName)
        return 1
    let sourcePath: str = v3path.V3PathAbsolute(rootDir, sourceRel)
    let outBin: str = os.JoinPath(outDir, toolName)
    let compileLogPath: str = os.JoinPath(outDir, toolName + ".compile.log")
    let runLogPath: str = os.JoinPath(outDir, toolName + ".run.log")
    let compileLabel: str = v3BackendDriverConcat3("backend_driver_", toolName, "_compile")
    let compileRun: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                    compileLabel,
                                                                    compilerPath,
                                                                    sourcePath,
                                                                    outBin,
                                                                    v3BackendDriverToolTarget(),
                                                                    compileLogPath)
    let compileContext: str = v3BackendDriverConcat3("v3 backend driver: ", toolName, " compile")
    if v3BackendDriverRunFailed(compileContext, compileRun):
        return compileRun.exitCode
    let runLabel: str = v3BackendDriverConcat3("backend_driver_", toolName, "_run")
    let run: hostops.V3LoggedRun = v3BackendDriverRunBinaryEnv(rootDir,
                                                               runLabel,
                                                               outBin,
                                                               args,
                                                               envOverrides,
                                                               0,
                                                               runLogPath)
    if run.exitCode != 0:
        let runContext: str = v3BackendDriverConcat2("v3 backend driver: ", toolName)
        let _printed: bool = v3BackendDriverPrintRunFailure(runContext, run)
        return run.exitCode
    let outputText: str = strutil.Strip(run.output)
    if len(outputText) > 0:
        v3BackendDriverPrintStdoutBlock(outputText)
    return 0

fn v3BackendDriverRunToolFromSource(rootDir: str,
                                    toolName: str,
                                    sourceRel: str,
                                    args: str[]): int32 =
    var compilerPath: str = ""
    if !v3BackendDriverResolveToolCompiler(rootDir, toolName, compilerPath):
        return 1
    return v3BackendDriverRunToolFromSourceWithCompiler(rootDir,
                                                        toolName,
                                                        sourceRel,
                                                        compilerPath,
                                                        args,
                                                        [])

fn v3BackendDriverRunVpnProxy(rootDir: str,
                              count: int32): int32 =
    let args: str[] = v3BackendDriverCollectArgsFrom(2, count)
    var compilerPath: str = ""
    if !v3BackendDriverResolveToolCompiler(rootDir, "vpn-proxy", compilerPath):
        return 1
    let envOverrides: str[] = [
        "CHENG_V3_ROOT=" + rootDir,
        "CHENG_V3_VPN_PROXY_COMPILER=" + compilerPath
    ]
    return v3BackendDriverRunToolFromSourceWithCompiler(rootDir,
                                                        "vpn_proxy_tool",
                                                        "v3/src/tooling/vpn_proxy_tool_main.cheng",
                                                        compilerPath,
                                                        args,
                                                        envOverrides)

fn v3BackendDriverRunMobileShell(rootDir: str,
                                 count: int32): int32 =
    let outDirRel: str = "artifacts/v3_mobile_shell"
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRel)
    let toolPath: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver_tools/mobile_shell_tool/mobile_shell_tool")
    if !v3path.V3FileExistsNonEmpty(rootDir, toolPath):
        v3BackendDriverPrintErr("v3 mobile-shell: missing tool binary: " + toolPath)
        return 2
    let logPath: str = os.JoinPath(outDir, "mobile_shell.forward.log")
    var forwardArgs: str[] = []
    var i: int32 = 2
    while i <= count:
        let arg: str = cmdline.ParamStr(i)
        if len(arg) > 0:
            add(forwardArgs, arg)
        i = i + 1
    let run: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                            "v3 mobile-shell",
                                                            toolPath,
                                                            forwardArgs,
                                                            120,
                                                            logPath)
    v3BackendDriverMaybePrintRunOutput(run)
    if v3BackendDriverRunFailed("v3 mobile-shell", run):
        return run.exitCode
    return 0

fn v3BackendDriverRunGateTool(rootDir: str,
                              count: int32): int32 =
    let args: str[] = v3BackendDriverCollectArgsFrom(1, count)
    return v3BackendDriverRunToolFromSource(rootDir,
                                            "gate_tool",
                                            "v3/src/tooling/gate_main.cheng",
                                            args)

fn v3BackendDriverRunHostSmokes(rootDir: str,
                                count: int32): int32 =
    let args: str[] = v3BackendDriverCollectArgsFrom(2, count)
    return v3BackendDriverRunHostSmokesLocal(rootDir, args)

fn v3BackendDriverArgsWithoutFlag(args: str[],
                                  key: str): str[] =
    let colonPrefixRaw: str = key + ":"
    let equalPrefixRaw: str = key + "="
    let colonPrefix: str = newStringCopy(strDataPtr(colonPrefixRaw), strLenFast(colonPrefixRaw))
    let equalPrefix: str = newStringCopy(strDataPtr(equalPrefixRaw), strLenFast(equalPrefixRaw))
    var out: str[] = []
    var i: int32 = 0
    while i < args.len:
        let arg: str = args[i]
        if arg == key:
            i = i + 1
            if i < args.len:
                i = i + 1
            continue
        if arg.len >= colonPrefix.len:
            let prefix: str = strings.SliceBytes(arg, 0, colonPrefix.len)
            if prefix == colonPrefix:
                i = i + 1
                continue
        if arg.len >= equalPrefix.len:
            let prefix: str = strings.SliceBytes(arg, 0, equalPrefix.len)
            if prefix == equalPrefix:
                i = i + 1
                continue
        add(out, arg)
        i = i + 1
    return out

fn v3BackendDriverCollectPositionals(args: str[]): str[] =
    var out: str[] = []
    for i in 0..<args.len:
        let arg: str = args[i]
        if arg.len >= 2 && arg[0] == '-' && arg[1] == '-':
            continue
        add(out, arg)
    return out

fn v3BackendDriverResolveHostSmokeCompiler(rootDir: str,
                                           args: str[],
                                           outCompiler: var str): bool =
    let explicitRaw: str = v3BackendDriverReadFlag(args, "--compiler", "")
    let explicit: str = strutil.Strip(explicitRaw)
    if len(explicit) > 0:
        outCompiler = v3path.V3PathAbsolute(rootDir, explicit)
        return true
    return v3BackendDriverResolveToolCompiler(rootDir, "run-host-smokes", outCompiler)

fn v3BackendDriverWriteProcessSnapshot(rootDir: str,
                                       proc: hostops.V3SpawnedProcess,
                                       logPath: str,
                                       exitCode: int32): hostops.V3LoggedRun =
    let logParts: os.SplitFileResult = os.SplitFile(logPath)
    if len(logParts.dir) > 0:
        let _made: bool = v3path.V3MkdirP(rootDir, logParts.dir)
    let _logged: bool = v3path.V3WriteTextFile(rootDir, logPath, proc.output)
    return hostops.V3LoggedRun(label: proc.label,
                               filePath: proc.filePath,
                               logPath: logPath,
                               exitCode: exitCode,
                               output: proc.output)

fn v3BackendDriverRequireFileContains(path: str,
                                      needle: str,
                                      context: str): bool =
    if !os.FileExists(path):
        v3BackendDriverPrintErr(context + ": missing artifact: " + path)
        return false
    let text: str = v3path.V3ReadTextFile("", path)
    if v3BackendDriverOutputContains(text, needle):
        return true
    v3BackendDriverPrintErr(context + ": missing text in " + path + ": " + needle)
    return false

fn v3BackendDriverRequirePrefixArtifacts(prefix: str,
                                         suffixes: str[],
                                         context: str): bool =
    for i in 0..<suffixes.len:
        let path: str = prefix + suffixes[i]
        if !os.FileExists(path):
            v3BackendDriverPrintErr(context + ": missing artifact: " + path)
            return false
    return true

fn v3BackendDriverRequireAnyOutput(text: str,
                                   needles: str[],
                                   context: str): bool =
    for i in 0..<needles.len:
        if v3BackendDriverOutputContains(text, needles[i]):
            return true
    v3BackendDriverPrintErr(context + ": missing expected output")
    return false

fn v3BackendDriverRunSingleFixtureSmoke(rootDir: str,
                                        suiteLabel: str,
                                        compilerPath: str,
                                        smokeName: str,
                                        outBin: str,
                                        stageLabel: str): int32 =
    let srcRel: str = v3BackendDriverConcat3("v3/src/tests/", smokeName, ".cheng")
    let src: str = v3path.V3PathAbsolute(rootDir, srcRel)
    if !os.FileExists(src):
        v3BackendDriverPrintErr(suiteLabel + ": missing source: " + src)
        return 1
    let targetTriple: str = v3BackendDriverHostTarget()
    if len(targetTriple) <= 0:
        v3BackendDriverPrintErr(suiteLabel + ": unsupported host target")
        return 2
    let compileLabel: str = suiteLabel + " compile " + stageLabel + " " + smokeName
    let compileRun: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                    compileLabel,
                                                                    compilerPath,
                                                                    src,
                                                                    outBin,
                                                                    targetTriple,
                                                                    outBin + ".compile.log")
    if v3BackendDriverRunFailed(suiteLabel + " compile " + smokeName, compileRun):
        return compileRun.exitCode
    let runLabel: str = suiteLabel + " run " + stageLabel + " " + smokeName
    let run: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                            runLabel,
                                                            outBin,
                                                            [],
                                                            int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_SMOKE_RUN_TIMEOUT_SEC", "60"))),
                                                            outBin + ".run.log")
    v3BackendDriverMaybePrintRunOutput(run)
    if v3BackendDriverRunFailed(suiteLabel + " run " + smokeName, run):
        return run.exitCode
    return 0

