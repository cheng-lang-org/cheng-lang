fn v3BackendDriverBuildChainNodeCliCommandBinary(rootDir: str,
                                                 compilerPath: str,
                                                 outDir: str,
                                                 label: str,
                                                 moduleStem: str,
                                                 outBin: var str): int32 =
    let srcRel: str = v3BackendDriverConcat3("v3/src/project/", moduleStem, ".cheng")
    let src: str = v3path.V3PathAbsolute(rootDir, srcRel)
    outBin = os.JoinPath(outDir, moduleStem)
    let targetTriple: str = v3BackendDriverHostTarget()
    if len(targetTriple) <= 0:
        v3BackendDriverPrintErr("v3 chain_node cli smoke: unsupported host target")
        return 2
    let compileRun: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                    label,
                                                                    compilerPath,
                                                                    src,
                                                                    outBin,
                                                                    targetTriple,
                                                                    os.JoinPath(outDir, moduleStem + ".compile.log"))
    if v3BackendDriverRunFailed("v3 chain_node cli compile " + moduleStem, compileRun):
        return compileRun.exitCode
    if !os.FileExists(outBin):
        v3BackendDriverPrintErr("v3 chain_node cli smoke: missing command binary: " + outBin)
        return 1
    return 0

fn v3BackendDriverRunChainNodeCliSyncBinary(rootDir: str,
                                            label: str,
                                            syncBin: str,
                                            clientState: str,
                                            serverPort: str,
                                            syncLog: str): hostops.V3LoggedRun =
    return v3BackendDriverRunBinary(rootDir,
                                    "v3 chain_node cli daemon-sync " + label,
                                    syncBin,
                                    ["--state:" + clientState, "--node-id:node-b", "--address-seed:chain-node-b", "--host:127.0.0.1", "--port:" + serverPort],
                                    20,
                                    syncLog)

fn v3BackendDriverRunChainNodeCliBalanceBinary(rootDir: str,
                                               runLabel: str,
                                               balanceBin: str,
                                               statePath: str,
                                               account: str,
                                               logPath: str): hostops.V3LoggedRun =
    return v3BackendDriverRunBinary(rootDir,
                                    runLabel,
                                    balanceBin,
                                    ["--state:" + statePath, "--asset:7", "--account:" + account],
                                    20,
                                    logPath)

fn v3BackendDriverRunChainNodeCliShowBinary(rootDir: str,
                                            runLabel: str,
                                            showBin: str,
