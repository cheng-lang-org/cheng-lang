@importc("get_stdout")
fn v3BackendDriverStdoutBridge(): os.File
@importc("get_stderr")
fn v3BackendDriverStderrBridge(): os.File
@importc("paramCount")
fn v3BackendDriverParamCountBridge(): int32

fn v3BackendDriverPrintLine(text: str) =
    os.WriteLine(v3BackendDriverStdoutBridge(), text)

fn v3BackendDriverPrintErr(text: str) =
    os.WriteLine(v3BackendDriverStderrBridge(), text)

fn v3BackendDriverPrintBlock(file: os.File,
                             text: str) =
    var start: int32 = 0
    var i: int32 = 0
    while i < text.len:
        if text[i] == '\n':
            let line: str = strings.SliceBytes(text, start, i - start)
            os.WriteLine(file, line)
            start = i + 1
        i = i + 1
    if start < text.len:
        let line: str = strings.SliceBytes(text, start, text.len - start)
        os.WriteLine(file, line)

fn v3BackendDriverPrintStdoutBlock(text: str) =
    v3BackendDriverPrintBlock(v3BackendDriverStdoutBridge(), text)

fn v3BackendDriverPrintStderrBlock(text: str) =
    v3BackendDriverPrintBlock(v3BackendDriverStderrBridge(), text)

fn v3BackendDriverConcat2(a: str, b: str): str =
    var out: buffer.ByteBuffer
    out.data = rawbytes.emptyBytes()
    buffer.AppendBytes(out, a)
    buffer.AppendBytes(out, b)
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn v3BackendDriverConcat3(a: str, b: str, c: str): str =
    var out: buffer.ByteBuffer
    out.data = rawbytes.emptyBytes()
    buffer.AppendBytes(out, a)
    buffer.AppendBytes(out, b)
    buffer.AppendBytes(out, c)
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn v3BackendDriverAppendAssign(out: var str, part: str) =
    out = v3BackendDriverConcat2(out, part)

fn v3BackendDriverRoot(): str =
    let envRoot: str = os.GetEnv("CHENG_V3_ROOT")
    if len(envRoot) > 0:
        return envRoot
    let cwd: str = os.GetCurrentDir()
    let rootSeed: str = os.JoinPath(cwd, "v3/bootstrap/cheng_v3_seed.c")
    if v3path.V3PathFileExists(rootSeed):
        return cwd
    let v3Seed: str = os.JoinPath(cwd, "bootstrap/cheng_v3_seed.c")
    if v3path.V3PathFileExists(v3Seed):
        let parts = os.SplitFile(cwd)
        if len(parts.dir) > 0:
            return parts.dir
    return cwd

fn v3BackendDriverEntrySource(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "v3/src/tooling/backend_driver_main.cheng")

fn v3BackendDriverStage3Path(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "artifacts/v3_bootstrap/cheng.stage3")

fn v3BackendDriverSelfPath(rootDir: str): str =
    let resolved: str = hostops.v3ResolveProgram(rootDir, cmdline.ProgramName())
    if len(resolved) > 0:
        return resolved
    let raw: str = cmdline.ProgramName()
    if len(raw) > 0:
        return v3path.V3PathAbsolute(rootDir, raw)
    return ""

fn v3BackendDriverVerifyExportLabel(selfPath: str): str =
    if len(selfPath) > 0 && strings.StrContains(selfPath, "cheng.next"):
        return "verify_export_backend_driver_candidate"
    return "verify_export_backend_driver"

fn v3BackendDriverVerifyExportParallelLabel(selfPath: str): str =
    if len(selfPath) > 0 && strings.StrContains(selfPath, "cheng.next"):
        return "verify_export_parallel_backend_driver_candidate"
    return "verify_export_parallel_backend_driver"

fn v3BackendDriverUsage(rootDir: str) =
    let lines: str[] = crun.v3CompilerUsageLines(rootDir)
    for i in 0..<lines.len:
        let line: str = lines[i]
        if len(line) >= 15 && strings.SliceBytes(line, 0, 15) == "compiler_entry=":
            v3BackendDriverPrintLine("compiler_entry=" + v3BackendDriverEntrySource(rootDir))
        else:
            v3BackendDriverPrintLine(line)

fn v3BackendDriverStatus(rootDir: str) =
    let contract = crun.v3CompilerRuntimeContract(rootDir)
    v3BackendDriverPrintLine("cheng_v3c")
    v3BackendDriverPrintLine("version=" + contract.version)
    v3BackendDriverPrintLine("execution=" + contract.executionModel)
    v3BackendDriverPrintLine("bootstrap_mode=" + contract.bootstrapMode)
    v3BackendDriverPrintLine("compiler_entry=" + v3BackendDriverEntrySource(rootDir))
    v3BackendDriverPrintLine("ordinary_command=" + contract.ordinaryCommand)
    v3BackendDriverPrintLine("ordinary_pipeline=" + contract.ordinaryPipelineState)

