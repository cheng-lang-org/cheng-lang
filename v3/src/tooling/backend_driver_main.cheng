fn v3BackendDriverRunChainNodeThreeNodeSmoke(rootDir: str,
                                             compilerPath: str,
                                             label: str): int32 =
    let outDirRel: str = v3BackendDriverConcat2("artifacts/v3_chain_node_three_node/", label)
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRel)
    let serverSrc: str = v3path.V3PathAbsolute(rootDir, "v3/src/tests/chain_node_process_server_smoke.cheng")
    let relaySrc: str = v3path.V3PathAbsolute(rootDir, "v3/src/tests/chain_node_process_relay_smoke.cheng")
    let clientSrc: str = v3path.V3PathAbsolute(rootDir, "v3/src/tests/chain_node_process_client_smoke.cheng")
    let serverBin: str = os.JoinPath(outDir, "chain_node_process_server")
    let relayBin: str = os.JoinPath(outDir, "chain_node_process_relay")
    let clientBin: str = os.JoinPath(outDir, "chain_node_process_client")
    let targetTriple: str = v3BackendDriverHostTarget()
    if len(targetTriple) <= 0:
        v3BackendDriverPrintErr("v3 chain_node three-node smoke: unsupported host target")
        return 2
    let serverCompile: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                       "run_chain_node_three_node_server_build " + label,
                                                                       compilerPath,
                                                                       serverSrc,
                                                                       serverBin,
                                                                       targetTriple,
                                                                       os.JoinPath(outDir, "chain_node_process_server.compile.log"))
    if v3BackendDriverRunFailed("v3 chain_node three-node server compile", serverCompile):
        return serverCompile.exitCode
    let relayCompile: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                      "run_chain_node_three_node_relay_build " + label,
                                                                      compilerPath,
                                                                      relaySrc,
                                                                      relayBin,
                                                                      targetTriple,
                                                                      os.JoinPath(outDir, "chain_node_process_relay.compile.log"))
    if v3BackendDriverRunFailed("v3 chain_node three-node relay compile", relayCompile):
        return relayCompile.exitCode
    let clientCompile: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                       "run_chain_node_three_node_client_build " + label,
                                                                       compilerPath,
                                                                       clientSrc,
                                                                       clientBin,
                                                                       targetTriple,
                                                                       os.JoinPath(outDir, "chain_node_process_client.compile.log"))
    if v3BackendDriverRunFailed("v3 chain_node three-node client compile", clientCompile):
        return clientCompile.exitCode
    let serverReady: str = os.JoinPath(outDir, "server.ready")
    let relayReady: str = os.JoinPath(outDir, "relay.ready")
    let _ = os.RemoveFile(serverReady)
    let _ = os.RemoveFile(relayReady)
    let serverSpawn = hostops.v3SpawnFile(rootDir,
                                          "chain_node_three_node_server " + label,
                                          serverBin,
                                          ["--port:0", "--ready-path:" + serverReady],
                                          [],
                                          rootDir)
    if IsErr(serverSpawn):
        v3BackendDriverPrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var serverPort = ""
    if !v3BackendDriverWaitReadyPort(rootDir, serverReady, serverProc, serverPort):
        let serverRun: hostops.V3LoggedRun = v3BackendDriverWriteProcessSnapshot(rootDir, serverProc, os.JoinPath(outDir, "server.log"), 1)
        v3BackendDriverMaybePrintRunOutput(serverRun)
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    let relaySpawn = hostops.v3SpawnFile(rootDir,
                                         "chain_node_three_node_relay " + label,
                                         relayBin,
                                         ["--upstream-port:" + serverPort, "--port:0", "--ready-path:" + relayReady],
                                         [],
                                         rootDir)
    if IsErr(relaySpawn):
        v3BackendDriverPrintErr(Error(relaySpawn))
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    var relayProc = Value(relaySpawn)
    var relayPort = ""
    if !v3BackendDriverWaitReadyPort(rootDir, relayReady, relayProc, relayPort):
        let relayRun: hostops.V3LoggedRun = v3BackendDriverWriteProcessSnapshot(rootDir, relayProc, os.JoinPath(outDir, "relay.log"), 1)
        v3BackendDriverMaybePrintRunOutput(relayRun)
        hostops.v3SpawnedProcessKill(relayProc)
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    let clientRun: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                                  "chain_node_three_node_client " + label,
                                                                  clientBin,
                                                                  ["--port:" + relayPort],
                                                                  20,
                                                                  os.JoinPath(outDir, "client.log"))
    if v3BackendDriverRunFailed("v3 chain_node three-node client run", clientRun):
        let relayRun: hostops.V3LoggedRun = hostops.v3SpawnedProcessWaitLogged(rootDir, relayProc, 1, os.JoinPath(outDir, "relay.log"))
        let serverRun: hostops.V3LoggedRun = hostops.v3SpawnedProcessWaitLogged(rootDir, serverProc, 1, os.JoinPath(outDir, "server.log"))
        v3BackendDriverMaybePrintRunOutput(serverRun)
        v3BackendDriverMaybePrintRunOutput(relayRun)
        return clientRun.exitCode
    let relayRun: hostops.V3LoggedRun = hostops.v3SpawnedProcessWaitLogged(rootDir, relayProc, 20, os.JoinPath(outDir, "relay.log"))
    let serverRun: hostops.V3LoggedRun = hostops.v3SpawnedProcessWaitLogged(rootDir, serverProc, 20, os.JoinPath(outDir, "server.log"))
    v3BackendDriverMaybePrintRunOutput(serverRun)
    v3BackendDriverMaybePrintRunOutput(relayRun)
    v3BackendDriverMaybePrintRunOutput(clientRun)
    if v3BackendDriverRunFailed("v3 chain_node three-node relay run", relayRun):
        return relayRun.exitCode
    if v3BackendDriverRunFailed("v3 chain_node three-node server run", serverRun):
        return serverRun.exitCode
    let okText: str = v3BackendDriverConcat3("v3 chain_node three-node smoke ok (", label, ")")
    v3BackendDriverPrintLine(okText)
    return 0

fn v3BackendDriverRunTailnetControlSmoke(rootDir: str,
                                         compilerPath: str,
                                         label: str): int32 =
    let outDir: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_tailnet_control")
    let controlProbeEndpoint: str = v3path.V3PathAbsolute(rootDir, "v3/testdata/tailnet/headscale_control_ready.json")
    let relayProbeEndpoint: str = v3path.V3PathAbsolute(rootDir, "v3/testdata/tailnet/derp_ready.json")
    let baselineSrc: str = v3path.V3PathAbsolute(rootDir, "v3/src/tests/libp2p_tailnet_transport_smoke.cheng")
    let baselineBin: str = os.JoinPath(outDir, "libp2p_tailnet_transport_smoke." + label)
    let targetTriple: str = v3BackendDriverHostTarget()
    if len(targetTriple) <= 0:
        v3BackendDriverPrintErr("v3 tailnet control: unsupported host target")
        return 2
    let baselineRun: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                     "v3 tailnet control compile baseline " + label,
                                                                     compilerPath,
                                                                     baselineSrc,
                                                                     baselineBin,
                                                                     targetTriple,
                                                                     baselineBin + ".compile.log")
    if v3BackendDriverRunFailed("v3 tailnet control baseline compile", baselineRun):
        return baselineRun.exitCode
    let baselineRunLogName: str = v3BackendDriverConcat3("libp2p_tailnet_transport_smoke.", label, ".run.log")
    let baselineRunLogPath: str = os.JoinPath(outDir, baselineRunLogName)
    let baselineExec: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                                     "v3 tailnet control run baseline " + label,
                                                                     baselineBin,
                                                                     [],
                                                                     20,
                                                                     baselineRunLogPath)
    if v3BackendDriverRunFailed("v3 tailnet control baseline run", baselineExec):
        return baselineExec.exitCode
    let coreSmokeSrc: str = v3path.V3PathAbsolute(rootDir, "v3/src/tests/tailnet_control_core_smoke.cheng")
    let coreSmokeBin: str = os.JoinPath(outDir, "tailnet_control_core_smoke." + label)
    let coreSmokeCompile: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                          "v3 tailnet control compile decode smoke " + label,
                                                                          compilerPath,
                                                                          coreSmokeSrc,
                                                                          coreSmokeBin,
                                                                          targetTriple,
                                                                          coreSmokeBin + ".compile.log")
    if v3BackendDriverRunFailed("v3 tailnet control core smoke compile", coreSmokeCompile):
        return coreSmokeCompile.exitCode
    let coreSmokeRunLogName: str = v3BackendDriverConcat3("tailnet_control_core_smoke.", label, ".run.log")
    let coreSmokeRunLogPath: str = os.JoinPath(outDir, coreSmokeRunLogName)
    let coreSmokeRun: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                                     "v3 tailnet control run decode smoke " + label,
                                                                     coreSmokeBin,
                                                                     [],
                                                                     20,
                                                                     coreSmokeRunLogPath)
    if v3BackendDriverRunFailed("v3 tailnet control core smoke run", coreSmokeRun):
        return coreSmokeRun.exitCode
    let coreSrc: str = v3path.V3PathAbsolute(rootDir, "v3/src/project/tailnet_control_core.cheng")
    let coreBin: str = os.JoinPath(outDir, "tailnet_control_core." + label)
    let coreCompile: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                     "v3 tailnet control compile core " + label,
                                                                     compilerPath,
                                                                     coreSrc,
                                                                     coreBin,
                                                                     targetTriple,
                                                                     coreBin + ".compile.log")
    if v3BackendDriverRunFailed("v3 tailnet control core compile", coreCompile):
        return coreCompile.exitCode
    var configureArgs: str[] = []
    add(configureArgs, "--command")
    add(configureArgs, "configure")
    add(configureArgs, "--provider-headscale")
    add(configureArgs, "1")
    add(configureArgs, "--control-url")
    add(configureArgs, "https://headscale.example")
    add(configureArgs, "--control-endpoint")
    add(configureArgs, "https://headscale.example/control")
    add(configureArgs, "--relay-endpoint")
    add(configureArgs, "https://derp.sfo.example:443")
    add(configureArgs, "--control-probe-endpoint")
    add(configureArgs, controlProbeEndpoint)
    add(configureArgs, "--relay-probe-endpoint")
    add(configureArgs, relayProbeEndpoint)
    add(configureArgs, "--namespace")
    add(configureArgs, "infra")
    add(configureArgs, "--noise-public-key")
    add(configureArgs, "noise-pub-cli")
    add(configureArgs, "--derp-region-code")
    add(configureArgs, "sfo")
    add(configureArgs, "--derp-region-name")
    add(configureArgs, "SanFrancisco")
    add(configureArgs, "--derp-hostname")
    add(configureArgs, "derp.sfo.example")
    add(configureArgs, "--synthetic-ipv4")
    add(configureArgs, "100.64.0.44")
    add(configureArgs, "--synthetic-ipv6")
    add(configureArgs, "fd7a:115c:a1e0::44")
    add(configureArgs, "--local-peer-id")
    add(configureArgs, "tailnet-control-test")
    add(configureArgs, "--exact-routing")
    add(configureArgs, "1")
    add(configureArgs, "--provider-ready")
    add(configureArgs, "1")
    add(configureArgs, "--proxy-ready")
    add(configureArgs, "1")
    let configureLogName: str = v3BackendDriverConcat3("tailnet_control_configure.", label, ".run.log")
    let configureLogPath: str = os.JoinPath(outDir, configureLogName)
    let configureRun: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                                     "v3 tailnet control configure " + label,
                                                                     coreBin,
                                                                     configureArgs,
                                                                     20,
                                                                     configureLogPath)
    if v3BackendDriverRunFailed("v3 tailnet control configure", configureRun):
        return configureRun.exitCode
    if !v3BackendDriverRequireOutput(configureRun, "configured=1", "v3 tailnet control") ||
       !v3BackendDriverRequireOutput(configureRun, "providerKind=headscale", "v3 tailnet control") ||
       !v3BackendDriverRequireOutput(configureRun, "controlProbeEndpoint=" + controlProbeEndpoint, "v3 tailnet control") ||
       !v3BackendDriverRequireOutput(configureRun, "controlPlane=headscale", "v3 tailnet control") ||
       !v3BackendDriverRequireOutput(configureRun, "providerReady=1", "v3 tailnet control") ||
       !v3BackendDriverRequireOutput(configureRun, "proxyListenersReady=1", "v3 tailnet control") ||
       !v3BackendDriverRequireOutput(configureRun, "providerRuntimeActive=1", "v3 tailnet control"):
