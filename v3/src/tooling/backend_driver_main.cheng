    let listenLogName: str = v3BackendDriverConcat3("tailnet_control_listen.", label, ".run.log")
    let listenLogPath: str = os.JoinPath(outDir, listenLogName)
    let listenRun: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                                  "v3 tailnet control listen " + label,
                                                                  coreBin,
