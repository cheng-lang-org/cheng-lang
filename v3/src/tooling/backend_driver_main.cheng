fn v3BackendDriverRunChainNodeResilienceRound1(rootDir: str,
                                               chainNodeBin: str,
                                               serverState: str,
                                               relayState: str,
                                               clientState: str,
                                               outDir: str,
                                               label: str): int32 =
    let round1MintRun = v3BackendDriverChainNodeMintRun(rootDir, chainNodeBin, serverState, "1001", "100", outDir, "round1_mint", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 mint", round1MintRun):
        return round1MintRun.exitCode
    let round1TransferRun = v3BackendDriverChainNodeTransferRun(rootDir, chainNodeBin, serverState, "1001", "2002", "40", outDir, "round1_transfer", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 transfer", round1TransferRun):
        return round1TransferRun.exitCode
    let serverShowRound1 = v3BackendDriverChainNodeShowRun(rootDir, chainNodeBin, serverState, outDir, "round1_server_show", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 server show", serverShowRound1):
        return serverShowRound1.exitCode
    let serverAliceRound1 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, serverState, "1001", outDir, "round1_server_alice", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 server alice", serverAliceRound1):
        return serverAliceRound1.exitCode
    let serverBobRound1 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, serverState, "2002", outDir, "round1_server_bob", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 server bob", serverBobRound1):
        return serverBobRound1.exitCode
    let serverSnapshotRound1 = v3BackendDriverChainNodeDumpSnapshotRun(rootDir, chainNodeBin, serverState, outDir, "round1_server_snapshot", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 server snapshot", serverSnapshotRound1):
        return serverSnapshotRound1.exitCode
    if !v3BackendDriverRequireRunValue(serverShowRound1, "node_id", "node-a", "v3 chain_node resilience round1 server show"):
        return 1
    if !v3BackendDriverRequireRunValue(serverShowRound1, "event_count", "2", "v3 chain_node resilience round1 server show"):
        return 1
    if !v3BackendDriverRequireRunValue(serverAliceRound1, "balance", "60", "v3 chain_node resilience round1 server alice"):
        return 1
    if !v3BackendDriverRequireRunValue(serverBobRound1, "balance", "40", "v3 chain_node resilience round1 server bob"):
        return 1
    if !v3BackendDriverRequireOutput(serverSnapshotRound1, "payload_hex=", "v3 chain_node resilience smoke"):
        return 1
    if v3BackendDriverRunChainNodeServeAndSync(rootDir, label, chainNodeBin, serverState, relayState, "node-b", "chain-node-b", outDir, "round1_server_to_relay", true) != 0:
        return 1
    let relayShowRound1 = v3BackendDriverChainNodeShowRun(rootDir, chainNodeBin, relayState, outDir, "round1_relay_show", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 relay show", relayShowRound1):
        return relayShowRound1.exitCode
    let relayAliceRound1 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, relayState, "1001", outDir, "round1_relay_alice", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 relay alice", relayAliceRound1):
        return relayAliceRound1.exitCode
    let relayBobRound1 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, relayState, "2002", outDir, "round1_relay_bob", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 relay bob", relayBobRound1):
        return relayBobRound1.exitCode
    if !v3BackendDriverRequireRunValue(relayShowRound1, "node_id", "node-b", "v3 chain_node resilience round1 relay show"):
        return 1
    if !v3BackendDriverRequireRunValue(relayAliceRound1, "balance", "60", "v3 chain_node resilience round1 relay alice"):
        return 1
    if !v3BackendDriverRequireRunValue(relayBobRound1, "balance", "40", "v3 chain_node resilience round1 relay bob"):
        return 1
    if !v3BackendDriverRequireStateParity(serverShowRound1, relayShowRound1, "v3 chain_node resilience round1 server relay parity"):
        return 1
