fn v3BackendDriverRunChainNodeResilienceScenario(rootDir: str,
                                                 args: str[],
                                                 defaultLabel: str,
                                                 successText: str): int32 =
    let label: str = v3BackendDriverResolveSmokeLabel(args,
                                                      "CHENG_V3_CHAIN_NODE_RESILIENCE_LABEL",
                                                      defaultLabel)
    let outDirRelRaw: str = "artifacts/v3_chain_node_resilience/" + label
    let outDirRel: str = newStringCopy(strDataPtr(outDirRelRaw), strLenFast(outDirRelRaw))
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRel)
    let tmpDir: str = os.JoinPath(outDir, "resilience_gate")
    if !v3path.V3MkdirP(rootDir, tmpDir):
        v3BackendDriverPrintErr("v3 chain_node resilience smoke: failed to create tmp dir: " + tmpDir)
        return 1
    var compilerPath = ""
    if !v3BackendDriverResolveChainNodeCompiler(rootDir, args, compilerPath):
        return 2
    var chainNodeBin = ""
    if v3BackendDriverBuildChainNodeBinary(rootDir,
                                           compilerPath,
                                           outDir,
                                           "v3 chain_node resilience compile " + label,
                                           chainNodeBin) != 0:
        return 1
    let serverState: str = os.JoinPath(tmpDir, "server.state")
    let relayState: str = os.JoinPath(tmpDir, "relay.state")
    let clientState: str = os.JoinPath(tmpDir, "client.state")
    let observerState: str = os.JoinPath(tmpDir, "observer.state")
    let _ = os.RemoveFile(serverState)
    let _ = os.RemoveFile(relayState)
    let _ = os.RemoveFile(clientState)
    let _ = os.RemoveFile(observerState)

    let initRun = v3BackendDriverChainNodeInitRun(rootDir,
                                                  chainNodeBin,
                                                  serverState,
                                                  "node-a",
                                                  "chain-node-a",
                                                  outDir,
                                                  "init",
                                                  label)
    if v3BackendDriverRunFailed("v3 chain_node resilience init", initRun):
        return initRun.exitCode
    if !v3BackendDriverRequireOutput(initRun, "node_id=node-a", "v3 chain_node resilience smoke"):
        return 1

    let round1MintRun = v3BackendDriverChainNodeMintRun(rootDir, chainNodeBin, serverState, "1001", "100", outDir, "round1_mint", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 mint", round1MintRun):
        return round1MintRun.exitCode
    let round1TransferRun = v3BackendDriverChainNodeTransferRun(rootDir, chainNodeBin, serverState, "1001", "2002", "40", outDir, "round1_transfer", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 transfer", round1TransferRun):
        return round1TransferRun.exitCode
    let serverShowRound1 = v3BackendDriverChainNodeShowRun(rootDir, chainNodeBin, serverState, outDir, "round1_server_show", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 server show", serverShowRound1):
        return serverShowRound1.exitCode
    let serverAliceRound1 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, serverState, "1001", outDir, "round1_server_alice", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 server alice", serverAliceRound1):
        return serverAliceRound1.exitCode
    let serverBobRound1 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, serverState, "2002", outDir, "round1_server_bob", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 server bob", serverBobRound1):
        return serverBobRound1.exitCode
    let serverSnapshotRound1 = v3BackendDriverChainNodeDumpSnapshotRun(rootDir, chainNodeBin, serverState, outDir, "round1_server_snapshot", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 server snapshot", serverSnapshotRound1):
        return serverSnapshotRound1.exitCode
    if !v3BackendDriverRequireRunValue(serverShowRound1, "node_id", "node-a", "v3 chain_node resilience round1 server show"):
        return 1
    if !v3BackendDriverRequireRunValue(serverShowRound1, "event_count", "2", "v3 chain_node resilience round1 server show"):
        return 1
    if !v3BackendDriverRequireRunValue(serverAliceRound1, "balance", "60", "v3 chain_node resilience round1 server alice"):
        return 1
    if !v3BackendDriverRequireRunValue(serverBobRound1, "balance", "40", "v3 chain_node resilience round1 server bob"):
        return 1
    if !v3BackendDriverRequireOutput(serverSnapshotRound1, "payload_hex=", "v3 chain_node resilience smoke"):
        return 1
    if v3BackendDriverRunChainNodeServeAndSync(rootDir, label, chainNodeBin, serverState, relayState, "node-b", "chain-node-b", outDir, "round1_server_to_relay", true) != 0:
        return 1
    let relayShowRound1 = v3BackendDriverChainNodeShowRun(rootDir, chainNodeBin, relayState, outDir, "round1_relay_show", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 relay show", relayShowRound1):
        return relayShowRound1.exitCode
    let relayAliceRound1 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, relayState, "1001", outDir, "round1_relay_alice", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 relay alice", relayAliceRound1):
        return relayAliceRound1.exitCode
    let relayBobRound1 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, relayState, "2002", outDir, "round1_relay_bob", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 relay bob", relayBobRound1):
        return relayBobRound1.exitCode
    if !v3BackendDriverRequireRunValue(relayShowRound1, "node_id", "node-b", "v3 chain_node resilience round1 relay show"):
        return 1
    if !v3BackendDriverRequireRunValue(relayAliceRound1, "balance", "60", "v3 chain_node resilience round1 relay alice"):
        return 1
    if !v3BackendDriverRequireRunValue(relayBobRound1, "balance", "40", "v3 chain_node resilience round1 relay bob"):
        return 1
    if !v3BackendDriverRequireStateParity(serverShowRound1, relayShowRound1, "v3 chain_node resilience round1 server relay parity"):
        return 1
    if v3BackendDriverRunChainNodeServeAndSync(rootDir, label, chainNodeBin, serverState, relayState, "node-b", "chain-node-b", outDir, "round1_server_to_relay_idle", false) != 0:
        return 1
    if v3BackendDriverRunChainNodeServeAndSync(rootDir, label, chainNodeBin, relayState, clientState, "node-c", "chain-node-c", outDir, "round1_relay_to_client", true) != 0:
        return 1
    let clientShowRound1 = v3BackendDriverChainNodeShowRun(rootDir, chainNodeBin, clientState, outDir, "round1_client_show", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 client show", clientShowRound1):
        return clientShowRound1.exitCode
    let clientAliceRound1 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, clientState, "1001", outDir, "round1_client_alice", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 client alice", clientAliceRound1):
        return clientAliceRound1.exitCode
    let clientBobRound1 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, clientState, "2002", outDir, "round1_client_bob", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round1 client bob", clientBobRound1):
        return clientBobRound1.exitCode
    if !v3BackendDriverRequireRunValue(clientShowRound1, "node_id", "node-c", "v3 chain_node resilience round1 client show"):
        return 1
    if !v3BackendDriverRequireRunValue(clientAliceRound1, "balance", "60", "v3 chain_node resilience round1 client alice"):
        return 1
    if !v3BackendDriverRequireRunValue(clientBobRound1, "balance", "40", "v3 chain_node resilience round1 client bob"):
        return 1
    if !v3BackendDriverRequireStateParity(relayShowRound1, clientShowRound1, "v3 chain_node resilience round1 relay client parity"):
        return 1
    if v3BackendDriverRunChainNodeServeAndSync(rootDir, label, chainNodeBin, relayState, clientState, "node-c", "chain-node-c", outDir, "round1_relay_to_client_idle", false) != 0:
        return 1

    let round2MintRun = v3BackendDriverChainNodeMintRun(rootDir, chainNodeBin, serverState, "2002", "25", outDir, "round2_mint", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round2 mint", round2MintRun):
        return round2MintRun.exitCode
    let round2TransferRun = v3BackendDriverChainNodeTransferRun(rootDir, chainNodeBin, serverState, "2002", "1001", "15", outDir, "round2_transfer", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round2 transfer", round2TransferRun):
        return round2TransferRun.exitCode
    let serverShowRound2 = v3BackendDriverChainNodeShowRun(rootDir, chainNodeBin, serverState, outDir, "round2_server_show", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round2 server show", serverShowRound2):
        return serverShowRound2.exitCode
    let serverAliceRound2 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, serverState, "1001", outDir, "round2_server_alice", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round2 server alice", serverAliceRound2):
        return serverAliceRound2.exitCode
    let serverBobRound2 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, serverState, "2002", outDir, "round2_server_bob", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round2 server bob", serverBobRound2):
        return serverBobRound2.exitCode
    if !v3BackendDriverRequireRunValue(serverShowRound2, "event_count", "4", "v3 chain_node resilience round2 server show"):
        return 1
    if !v3BackendDriverRequireRunValue(serverAliceRound2, "balance", "75", "v3 chain_node resilience round2 server alice"):
        return 1
    if !v3BackendDriverRequireRunValue(serverBobRound2, "balance", "50", "v3 chain_node resilience round2 server bob"):
        return 1
    if v3BackendDriverRunChainNodeServeAndSync(rootDir, label, chainNodeBin, serverState, relayState, "node-b", "chain-node-b", outDir, "round2_server_to_relay", true) != 0:
        return 1
    let relayShowRound2 = v3BackendDriverChainNodeShowRun(rootDir, chainNodeBin, relayState, outDir, "round2_relay_show", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round2 relay show", relayShowRound2):
        return relayShowRound2.exitCode
    let relayAliceRound2 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, relayState, "1001", outDir, "round2_relay_alice", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round2 relay alice", relayAliceRound2):
        return relayAliceRound2.exitCode
    let relayBobRound2 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, relayState, "2002", outDir, "round2_relay_bob", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round2 relay bob", relayBobRound2):
