    let clientBobRound5 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, clientState, "2002", outDir, "round5_client_bob", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round5 client bob", clientBobRound5):
        return clientBobRound5.exitCode
    let clientSnapshotRound5 = v3BackendDriverChainNodeDumpSnapshotRun(rootDir, chainNodeBin, clientState, outDir, "round5_client_snapshot", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round5 client snapshot", clientSnapshotRound5):
        return clientSnapshotRound5.exitCode
    if !v3BackendDriverRequireRunValue(clientAliceRound5, "balance", "92", "v3 chain_node resilience round5 client alice"):
        return 1
    if !v3BackendDriverRequireRunValue(clientBobRound5, "balance", "88", "v3 chain_node resilience round5 client bob"):
        return 1
    if !v3BackendDriverRequireStateParity(relayShowRound5, clientShowRound5, "v3 chain_node resilience round5 relay client parity"):
        return 1
    if !v3BackendDriverRequireOutput(clientSnapshotRound5, "payload_hex=", "v3 chain_node resilience smoke"):
        return 1
    if v3BackendDriverRunChainNodeServeAndSync(rootDir, label, chainNodeBin, relayState, clientState, "node-c", "chain-node-c", outDir, "round5_relay_to_client_idle", false) != 0:
        return 1
    let _round5ObserverReset = os.RemoveFile(observerState)
    _round5ObserverReset
    if v3BackendDriverRunChainNodeServeAndSync(rootDir, label, chainNodeBin, clientState, observerState, "node-d", "chain-node-d", outDir, "round5_client_to_observer_recover", true) != 0:
        return 1
    let observerShowRound5 = v3BackendDriverChainNodeShowRun(rootDir, chainNodeBin, observerState, outDir, "round5_observer_show", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round5 observer show", observerShowRound5):
        return observerShowRound5.exitCode
    let observerAliceRound5 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, observerState, "1001", outDir, "round5_observer_alice", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round5 observer alice", observerAliceRound5):
        return observerAliceRound5.exitCode
    let observerBobRound5 = v3BackendDriverChainNodeBalanceRun(rootDir, chainNodeBin, observerState, "2002", outDir, "round5_observer_bob", label)
    if v3BackendDriverRunFailed("v3 chain_node resilience round5 observer bob", observerBobRound5):
        return observerBobRound5.exitCode
    if !v3BackendDriverRequireRunValue(observerShowRound5, "node_id", "node-d", "v3 chain_node resilience round5 observer show"):
        return 1
    if !v3BackendDriverRequireRunValue(observerAliceRound5, "balance", "92", "v3 chain_node resilience round5 observer alice"):
        return 1
    if !v3BackendDriverRequireRunValue(observerBobRound5, "balance", "88", "v3 chain_node resilience round5 observer bob"):
        return 1
    if !v3BackendDriverRequireStateParity(clientShowRound5, observerShowRound5, "v3 chain_node resilience round5 client observer parity"):
        return 1
    if v3BackendDriverRunChainNodeServeAndSync(rootDir, label, chainNodeBin, clientState, observerState, "node-d", "chain-node-d", outDir, "round5_client_to_observer_idle", false) != 0:
        return 1
    return 0

fn v3BackendDriverRunChainNodeResilienceScenario(rootDir: str,
                                                 args: str[],
                                                 defaultLabel: str,
                                                 successText: str): int32 =
    let labelRaw: str = v3BackendDriverResolveSmokeLabel(args,
                                                         "CHENG_V3_CHAIN_NODE_RESILIENCE_LABEL",
                                                         defaultLabel)
    let label: str = newStringCopy(strDataPtr(labelRaw), strLenFast(labelRaw))
    let outDirRelRaw: str = "artifacts/v3_chain_node_resilience/" + label
    let outDirRel: str = newStringCopy(strDataPtr(outDirRelRaw), strLenFast(outDirRelRaw))
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRel)
    let tmpDir: str = os.JoinPath(outDir, "resilience_gate")
    if !v3path.V3MkdirP(rootDir, tmpDir):
        v3BackendDriverPrintErr("v3 chain_node resilience smoke: failed to create tmp dir: " + tmpDir)
        return 1
    var compilerPath = ""
    if !v3BackendDriverResolveChainNodeCompiler(rootDir, args, compilerPath):
        return 2
    var chainNodeBin = ""
    if v3BackendDriverBuildChainNodeBinary(rootDir,
                                           compilerPath,
                                           outDir,
                                           "v3 chain_node resilience compile " + label,
                                           chainNodeBin) != 0:
        return 1
    let serverState: str = os.JoinPath(tmpDir, "server.state")
    let relayState: str = os.JoinPath(tmpDir, "relay.state")
    let clientState: str = os.JoinPath(tmpDir, "client.state")
    let observerState: str = os.JoinPath(tmpDir, "observer.state")
    let _ = os.RemoveFile(serverState)
    let _ = os.RemoveFile(relayState)
    let _ = os.RemoveFile(clientState)
    let _ = os.RemoveFile(observerState)
    let initRun = v3BackendDriverChainNodeInitRun(rootDir,
                                                  chainNodeBin,
                                                  serverState,
                                                  "node-a",
                                                  "chain-node-a",
                                                  outDir,
                                                  "init",
                                                  label)
    if v3BackendDriverRunFailed("v3 chain_node resilience init", initRun):
        return initRun.exitCode
    if !v3BackendDriverRequireOutput(initRun, "node_id=node-a", "v3 chain_node resilience smoke"):
        return 1
    let round1Status: int32 = v3BackendDriverRunChainNodeResilienceRound1(rootDir, chainNodeBin, serverState, relayState, clientState, outDir, label)
    if round1Status != 0:
        return round1Status
    let round2Status: int32 = v3BackendDriverRunChainNodeResilienceRound2(rootDir, chainNodeBin, serverState, relayState, clientState, observerState, outDir, label)
    if round2Status != 0:
        return round2Status
    let round3Status: int32 = v3BackendDriverRunChainNodeResilienceRound3(rootDir, chainNodeBin, serverState, relayState, clientState, outDir, label)
    if round3Status != 0:
        return round3Status
    let round4Status: int32 = v3BackendDriverRunChainNodeResilienceRound4(rootDir, chainNodeBin, serverState, relayState, clientState, outDir, label)
    if round4Status != 0:
        return round4Status
    let round5Status: int32 = v3BackendDriverRunChainNodeResilienceRound5(rootDir, chainNodeBin, serverState, relayState, clientState, observerState, outDir, label)
    if round5Status != 0:
        return round5Status
    v3BackendDriverPrintLine(successText + " (" + label + ")")
    return 0

fn v3BackendDriverRunChainNodeResilienceSmoke(rootDir: str,
                                              args: str[]): int32 =
    return v3BackendDriverRunChainNodeResilienceScenario(rootDir,
                                                         args,
                                                         "host_resilience",
                                                         "v3 chain_node resilience smoke ok")

fn v3BackendDriverVerifyChainNodeResilience(rootDir: str,
                                            args: str[]): int32 =
    return v3BackendDriverRunChainNodeResilienceScenario(rootDir,
                                                         args,
                                                         "host_resilience_gate",
                                                         "verify-chain-node-resilience: ok")

fn v3BackendDriverR2cCodegenSurfaceSmokeAt(rootDir: str,
                                           repo: str,
                                           outDir: str,
                                           printSummary: bool): bool =
    let tsxAstPath: str = os.JoinPath(outDir, "tsx_ast_v1.json")
    let tsxSummaryPath: str = os.JoinPath(outDir, "tsx_ast_v1.summary.env")
    let frontendLogPath: str = v3path.V3PathAbsolute(rootDir,
                                                     "artifacts/v3_backend_driver/r2c_react_v3_ts_frontend.log")
    let frontendScriptPath: str = v3BackendDriverR2cTsFrontendScript(rootDir)
    let frontendRun: hostops.V3LoggedRun = hostops.v3RunProgramLogged(rootDir,
                                                                      "r2c_react_v3_ts_frontend",
                                                                      "node",
                                                                      [
                                                                          frontendScriptPath,
                                                                          "--repo", repo,
                                                                          "--out", tsxAstPath,
                                                                          "--summary-out", tsxSummaryPath
                                                                      ],
                                                                      [],
                                                                      rootDir,
                                                                      0,
                                                                      frontendLogPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: r2c-react-v3-ts-frontend", frontendRun):
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, tsxAstPath):
        v3BackendDriverPrintErr("v3 backend driver: missing tsx ast: " + tsxAstPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, tsxSummaryPath):
        v3BackendDriverPrintErr("v3 backend driver: missing tsx summary: " + tsxSummaryPath)
        return false
    let logPath: str = v3path.V3PathAbsolute(rootDir,
                                             "artifacts/v3_backend_driver/r2c_react_v3_codegen_surface_smoke.log")
    let scriptPath: str = v3BackendDriverR2cCodegenSurfaceScript(rootDir)
    let summaryPath: str = os.JoinPath(outDir, "codegen_surface.summary.env")
    let run: hostops.V3LoggedRun = hostops.v3RunProgramLogged(rootDir,
                                                              "r2c_react_v3_codegen_surface_smoke",
                                                              "node",
                                                              [
                                                                  scriptPath,
                                                                  "--repo", repo,
                                                                  "--out-dir", outDir,
                                                                  "--summary-out", summaryPath
                                                              ],
                                                              [],
                                                              rootDir,
                                                              0,
                                                              logPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: r2c-react-v3-codegen-surface-smoke", run):
        return false
    let reportPath: str = os.JoinPath(outDir, "codegen_surface_report_v1.json")
    let manifestPath: str = os.JoinPath(outDir, "cheng_codegen_v1.json")
    let routeCatalogPath: str = os.JoinPath(outDir, "cheng_codegen_route_catalog_v1.json")
    let smokePath: str = os.JoinPath(outDir, "cheng_codegen_smoke_v1.json")
    if !v3path.V3FileExistsNonEmpty(rootDir, reportPath):
        v3BackendDriverPrintErr("v3 backend driver: missing codegen surface report: " + reportPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, summaryPath):
        v3BackendDriverPrintErr("v3 backend driver: missing codegen surface summary: " + summaryPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, manifestPath):
        v3BackendDriverPrintErr("v3 backend driver: missing codegen manifest: " + manifestPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, routeCatalogPath):
        v3BackendDriverPrintErr("v3 backend driver: missing codegen route catalog: " + routeCatalogPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, smokePath):
        v3BackendDriverPrintErr("v3 backend driver: missing codegen smoke artifact: " + smokePath)
        return false
    let reportText: str = v3path.V3ReadTextFile("", reportPath)
    let summaryText: str = v3path.V3ReadTextFile("", summaryPath)
    let manifestText: str = v3path.V3ReadTextFile("", manifestPath)
    let routeCatalogText: str = v3path.V3ReadTextFile("", routeCatalogPath)
    let reportCommandNeedle: str = "\"command\": \"codegen-surface\""
    let reportOkNeedle: str = "\"ok\": true"
    let summarySmokeNeedle: str = "smoke_ok=true"
    let summaryManifestNeedle: str = "codegen_manifest_path=" + manifestPath
    let summaryCatalogNeedle: str = "route_catalog_path=" + routeCatalogPath
    let summarySmokePathNeedle: str = "codegen_smoke_path=" + smokePath
    if !v3path.V3TextContains(reportText, reportCommandNeedle) ||
       !v3path.V3TextContains(reportText, reportOkNeedle):
        v3BackendDriverPrintErr("v3 backend driver: codegen surface report drifted: " + reportPath)
        return false
    if !v3path.V3TextContains(summaryText, summarySmokeNeedle) ||
       !v3path.V3TextContains(summaryText, summaryManifestNeedle) ||
       !v3path.V3TextContains(summaryText, summaryCatalogNeedle) ||
       !v3path.V3TextContains(summaryText, summarySmokePathNeedle):
        v3BackendDriverPrintErr("v3 backend driver: codegen surface summary drifted: " + summaryPath)
        return false
    if !v3path.V3TextContains(manifestText, "\"format\": \"cheng_codegen_v1\"") ||
       !v3path.V3TextContains(routeCatalogText, "\"format\": \"cheng_codegen_route_catalog_v1\""):
        v3BackendDriverPrintErr("v3 backend driver: codegen surface JSON contract drifted")
        return false
    if printSummary:
        v3BackendDriverPrintLine("r2c-react-v3 codegen surface smoke: ok")
        v3BackendDriverPrintLine("tsx_ast=" + tsxAstPath)
        v3BackendDriverPrintLine("codegen_summary=" + summaryPath)
        v3BackendDriverPrintLine("codegen_manifest=" + manifestPath)
        v3BackendDriverPrintLine("route_catalog=" + routeCatalogPath)
        v3BackendDriverPrintLine("codegen_smoke=" + smokePath)
    return true

fn v3BackendDriverR2cNativeGuiBundleSmokeAt(rootDir: str,
                                            repo: str,
                                            routeState: str,
                                            outDir: str,
                                            printSummary: bool): bool =
    let compileLogPath: str = v3path.V3PathAbsolute(rootDir,
                                                    "artifacts/v3_backend_driver/r2c_react_v3_compile_smoke.log")
    let prototypePath: str = v3BackendDriverR2cPrototypeScript(rootDir)
    let compileRun: hostops.V3LoggedRun = hostops.v3RunProgramLogged(rootDir,
                                                                     "r2c_react_v3_compile_smoke",
                                                                     "python3",
                                                                     [
                                                                         prototypePath,
                                                                         "compile",
                                                                         repo,
                                                                         "--out-dir", outDir,
                                                                         "--allow-blockers"
                                                                     ],
                                                                     [],
                                                                     rootDir,
                                                                     0,
                                                                     compileLogPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: r2c-react-v3 compile", compileRun):
        return false
    let hostContractPath: str = os.JoinPath(outDir, "unimaker_host_v1.json")
    let assetManifestPath: str = os.JoinPath(outDir, "asset_manifest_v1.json")
    let tailwindManifestPath: str = os.JoinPath(outDir, "tailwind_style_manifest_v1.json")
    let compileReportPath: str = os.JoinPath(outDir, "compile_report_v1.json")
    if !v3path.V3FileExistsNonEmpty(rootDir, hostContractPath) ||
       !v3path.V3FileExistsNonEmpty(rootDir, assetManifestPath) ||
       !v3path.V3FileExistsNonEmpty(rootDir, tailwindManifestPath) ||
       !v3path.V3FileExistsNonEmpty(rootDir, compileReportPath):
        v3BackendDriverPrintErr("v3 backend driver: r2c-react-v3 compile missing bundle prerequisites")
        return false
    if !v3BackendDriverR2cCodegenSurfaceSmokeAt(rootDir, repo, outDir, false):
        return false
    let logPath: str = v3path.V3PathAbsolute(rootDir,
                                             "artifacts/v3_backend_driver/r2c_react_v3_native_gui_bundle_smoke.log")
    let scriptPath: str = v3BackendDriverR2cNativeGuiBundleScript(rootDir)
    let stage3Path: str = v3BackendDriverStage3Path(rootDir)
    let run: hostops.V3LoggedRun = hostops.v3RunProgramLogged(rootDir,
                                                              "r2c_react_v3_native_gui_bundle_smoke",
                                                              "node",
                                                              [
                                                                  scriptPath,
                                                                  "--repo", repo,
                                                                  "--route-state", routeState,
                                                                  "--out-dir", outDir
                                                              ],
                                                              [
                                                                  "R2C_REACT_V3_TOOLING_BIN=" + stage3Path,
                                                                  "CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"
                                                              ],
                                                              rootDir,
                                                              0,
                                                              logPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: r2c-react-v3-native-gui-bundle-smoke", run):
        return false
    let reportPath: str = os.JoinPath(outDir, "native_gui_bundle_report_v1.json")
    let summaryPath: str = os.JoinPath(outDir, "native_gui_bundle.summary.env")
    let bundleJsonPath: str = os.JoinPath(outDir, "native_gui_bundle_v1.json")
    if !v3path.V3FileExistsNonEmpty(rootDir, reportPath):
        v3BackendDriverPrintErr("v3 backend driver: missing native gui bundle report: " + reportPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, summaryPath):
        v3BackendDriverPrintErr("v3 backend driver: missing native gui bundle summary: " + summaryPath)
        return false
    if !v3path.V3FileExistsNonEmpty(rootDir, bundleJsonPath):
        v3BackendDriverPrintErr("v3 backend driver: missing native gui bundle json: " + bundleJsonPath)
        return false
    let reportText: str = v3path.V3ReadTextFile("", reportPath)
    let summaryText: str = v3path.V3ReadTextFile("", summaryPath)
    if !v3path.V3TextContains(reportText, "\"ok\": true") ||
       !v3path.V3TextContains(reportText, "\"native_gui_host_ready\": true") ||
       !v3path.V3TextContains(reportText, "\"native_gui_renderer_ready\": true"):
        v3BackendDriverPrintErr("v3 backend driver: native gui bundle report drifted: " + reportPath)
        return false
    let runtimeModeNeedle: str = "native_gui_runtime_mode=cheng_compiled_json_v1"
    let routeStateNeedle: str = "native_gui_route_state=" + routeState
    let execSnapshotNeedle: str = "native_gui_exec_snapshot_path="
    let routeCatalogNeedle: str = "native_gui_route_catalog_path="
    if !v3path.V3TextContains(summaryText, runtimeModeNeedle):
        v3BackendDriverPrintErr("v3 backend driver: native gui bundle summary drifted: " + summaryPath)
        return false
    if !v3path.V3TextContains(summaryText, routeStateNeedle):
        v3BackendDriverPrintErr("v3 backend driver: native gui bundle summary drifted: " + summaryPath)
        return false
    if !v3path.V3TextContains(summaryText, execSnapshotNeedle) ||
       !v3path.V3TextContains(summaryText, routeCatalogNeedle):
        v3BackendDriverPrintErr("v3 backend driver: native gui bundle summary drifted: " + summaryPath)
        return false
    if printSummary:
        v3BackendDriverPrintLine("r2c-react-v3 native gui bundle smoke: ok")
        v3BackendDriverPrintLine("route_state=" + routeState)
        v3BackendDriverPrintLine("bundle_report=" + reportPath)
        v3BackendDriverPrintLine("bundle_summary=" + summaryPath)
        v3BackendDriverPrintLine("bundle_json=" + bundleJsonPath)
    return true

fn v3BackendDriverR2cReactV3CodegenSurfaceSmoke(rootDir: str,
                                                count: int32): int32 =
    let repoRaw: str = v3BackendDriverReadFlagOrDefault(count, "--repo", "/Users/lbcheng/UniMaker/React.js")
    let outDirRaw: str = v3BackendDriverReadFlagOrDefault(count, "--out-dir", "/tmp/r2c-codegen-surface-smoke")
    let repo: str = v3path.V3PathAbsolute(rootDir, repoRaw)
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRaw)
    if !os.DirExists(repo):
        v3BackendDriverPrintErr("v3 backend driver: missing React.js repo: " + repo)
        return 2
    if !v3BackendDriverR2cCodegenSurfaceSmokeAt(rootDir, repo, outDir, true):
        return 1
    return 0

fn v3BackendDriverR2cReactV3NativeGuiBundleSmoke(rootDir: str,
                                                 count: int32): int32 =
    let repoRaw: str = v3BackendDriverReadFlagOrDefault(count, "--repo", "/Users/lbcheng/UniMaker/React.js")
    let routeStateRaw: str = v3BackendDriverReadFlagOrDefault(count, "--route-state", "home_default")
    let outDirRaw: str = v3BackendDriverReadFlagOrDefault(count, "--out-dir", "/tmp/r2c-native-gui-bundle-smoke")
    let repo: str = v3path.V3PathAbsolute(rootDir, repoRaw)
    let routeState: str = strutil.Strip(routeStateRaw)
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRaw)
    if !os.DirExists(repo):
        v3BackendDriverPrintErr("v3 backend driver: missing React.js repo: " + repo)
        return 2
    if len(routeState) <= 0:
        v3BackendDriverPrintErr("v3 backend driver: missing --route-state for native gui bundle smoke")
        return 2
    if !v3BackendDriverR2cNativeGuiBundleSmokeAt(rootDir, repo, routeState, outDir, true):
        return 1
    return 0

fn v3BackendDriverR2cReactV3FreshCleanGate(rootDir: str,
                                           count: int32): int32 =
    let repoRaw: str = v3BackendDriverReadFlagOrDefault(count, "--repo", "/Users/lbcheng/UniMaker/React.js")
    let repo: str = v3path.V3PathAbsolute(rootDir, repoRaw)
    if !os.DirExists(repo):
        v3BackendDriverPrintErr("v3 backend driver: missing React.js repo: " + repo)
        return 2
    let statusOut: str = "/tmp/r2c-status-fresh-clean-gate.json"
    let codegenOutDir: str = "/tmp/r2c-codegen-surface-fresh-clean-gate"
    let routeStates: str[] = ["home_default", "content_detail", "publish_selector"]
    var hostAuditText: str = ""
    if v3BackendDriverHostBridgeAuditRun(rootDir, hostAuditText) != 0:
        if len(hostAuditText) > 0:
            v3BackendDriverPrintStdoutBlock(hostAuditText)
        v3BackendDriverPrintErr("v3 backend driver: host bridge audit forward failed for r2c fresh clean gate")
        return 2
    v3BackendDriverPrintStdoutBlock(hostAuditText)
    if !v3path.V3TextContains(hostAuditText, "pure_cheng_zero_c_ready=1") ||
       !v3path.V3TextContains(hostAuditText, "remaining_non_pure_cheng_boundary=none"):
        v3BackendDriverPrintErr("v3 backend driver: host bridge audit not ready for r2c fresh clean gate")
        return 2
    let statusLogPath: str = v3path.V3PathAbsolute(rootDir,
                                                   "artifacts/v3_backend_driver/r2c_react_v3_fresh_clean_gate.status.log")
    let wrapperPath: str = v3BackendDriverR2cWrapperPath(rootDir)
    let statusRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                                 "r2c_react_v3_status",
                                                                 wrapperPath,
                                                                 [
                                                                     "status",
                                                                     "--out", statusOut
                                                                 ],
                                                                 ["R2C_REACT_V3_NO_STAGE3_HANDOFF=1"],
                                                                 rootDir,
                                                                 0,
                                                                 statusLogPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: r2c-react-v3-fresh-clean-gate status", statusRun):
        return 1
    if !v3path.V3FileExistsNonEmpty(rootDir, statusOut):
        v3BackendDriverPrintErr("v3 backend driver: missing r2c status report: " + statusOut)
        return 1
    let statusText: str = v3path.V3ReadTextFile("", statusOut)
    if !v3path.V3TextContains(statusText, "\"static_surface_helper\": \"\"") ||
       !v3path.V3TextContains(statusText, "\"semantic_surface_helper\": \"\"") ||
       !v3path.V3TextContains(statusText, "r2c-react-v3-truth-runtime.mjs") ||
       !v3path.V3TextContains(statusText, "\"exec_surface_helper\": \"\"") ||
       !v3path.V3TextContains(statusText, "\"native_gui_runtime_helper\": \"\"") ||
       !v3path.V3TextContains(statusText, "\"native_gui_replay_hit_inspector_helper\": \"\"") ||
       !v3path.V3TextContains(statusText, "\"native_gui_host_source_kind\": \"objc_cocoa\"") ||
       !v3path.V3TextContains(statusText, "\"legacy_shell_wrapper_count\": 1") ||
       !v3path.V3TextContains(statusText, "\"legacy_wrapper_required\": false") ||
       !v3path.V3TextContains(statusText, "\"pure_cheng_gui_ready\": false") ||
       !v3path.V3TextContains(statusText, "\"compile_non_cheng_blocker_count\": 3") ||
       !v3path.V3TextContains(statusText, "\"remaining_non_cheng_blocker_count\": 7") ||
       !v3path.V3TextContains(statusText, "\"active_node_helper_count\": 6") ||
       !v3path.V3TextContains(statusText, "\"retired_node_helper_count\": 7") ||
       !v3path.V3TextContains(statusText, "\"standalone_node_helper_count\": 1") ||
       !v3path.V3TextContains(statusText, "\"truth_compare_helper\"") ||
       !v3path.V3TextContains(statusText, "\"truth_compare_matrix_helper\"") ||
       !v3path.V3TextContains(statusText, "\"standalone_node_helpers\": [") ||
       !v3path.V3TextContains(statusText, "\"truth_runtime_helper\""):
        v3BackendDriverPrintErr("v3 backend driver: r2c status report drifted: " + statusOut)
        return 1
    if !v3BackendDriverR2cCodegenSurfaceSmokeAt(rootDir, repo, codegenOutDir, false):
        return 1
    for i in 0..<routeStates.len:
        let routeState: str = routeStates[i]
        let bundleOutDir: str = "/tmp/r2c-native-gui-fresh-clean-gate-" + routeState
        if !v3BackendDriverR2cNativeGuiBundleSmokeAt(rootDir, repo, routeState, bundleOutDir, false):
            return 1
    v3BackendDriverPrintLine("r2c-react-v3 fresh clean gate: ok")
    v3BackendDriverPrintLine("status_report=" + statusOut)
    for i in 0..<routeStates.len:
        let routeState: str = routeStates[i]
        let bundleReportPath: str = "/tmp/r2c-native-gui-fresh-clean-gate-" + routeState +
            "/native_gui_bundle_report_v1.json"
        v3BackendDriverPrintLine("bundle_report_" + routeState + "=" + bundleReportPath)
    return 0


fn v3BackendDriverVerifyExportVisibility(rootDir: str): int32 =
    let selfPath: str = v3BackendDriverSelfPath(rootDir)
    if len(selfPath) <= 0:
        v3BackendDriverPrintErr("v3 backend driver: missing self path for verify-export-visibility")
        return 2
    let label: str = v3BackendDriverVerifyExportLabel(selfPath)
    let logPath: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver/verify_export_visibility.log")
    var args: str[] = []
    add(args, "--compiler:" + selfPath)
    add(args, "--label:" + label)
    add(args, "export_visibility_smoke")
    add(args, "export_visibility_negative_smoke")
    add(args, "strformat_export_negative_smoke")
    let runCode: int32 = v3BackendDriverRunHostSmokesLocal(rootDir, args)
    if runCode != 0:
        return runCode
    let _logged: bool = v3path.V3WriteTextFile(rootDir, logPath, "v3 host smokes: ok\n")
    return 0

fn v3BackendDriverVerifyExportVisibilityParallel(rootDir: str): int32 =
    let selfPath: str = v3BackendDriverSelfPath(rootDir)
    if len(selfPath) <= 0:
        v3BackendDriverPrintErr("v3 backend driver: missing self path for verify-export-visibility-parallel")
        return 2
    let label: str = v3BackendDriverVerifyExportParallelLabel(selfPath)
    let stage3Path: str = v3BackendDriverStage3Path(rootDir)
    if !v3path.V3FileExistsNonEmpty(rootDir, stage3Path):
        v3BackendDriverPrintErr("v3 backend driver: missing stage3 compiler for verify-export-visibility-parallel")
        return 2
    let smokes: str[] = ["export_visibility_smoke", "export_visibility_negative_smoke", "strformat_export_negative_smoke"]
    let stage3Label: str = "verify_export_stage3_parallel"
    let backendLabel: str = "verify_export_backend_driver_parallel"
    let stage3Log: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver/verify_export_visibility_parallel.stage3.log")
    let backendLog: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver/verify_export_visibility_parallel.backend.log")
    let stage3Run: hostops.V3LoggedRun = v3BackendDriverRunHostSmokesLogged(rootDir,
                                                                            stage3Path,
                                                                            stage3Path,
                                                                            stage3Label,
                                                                            smokes,
                                                                            stage3Log)
    v3BackendDriverMaybePrintRunOutput(stage3Run)
    if v3BackendDriverRunFailed("v3 backend driver: verify-export-visibility-parallel stage3", stage3Run):
        return stage3Run.exitCode
    var backendArgs: str[] = []
    add(backendArgs, "--compiler:" + selfPath)
    add(backendArgs, "--label:" + backendLabel)
    add(backendArgs, "export_visibility_smoke")
    add(backendArgs, "export_visibility_negative_smoke")
    add(backendArgs, "strformat_export_negative_smoke")
    let backendCode: int32 = v3BackendDriverRunHostSmokesLocal(rootDir, backendArgs)
    if backendCode != 0:
        return backendCode
    let _logged: bool = v3path.V3WriteTextFile(rootDir, backendLog, "v3 host smokes: ok\n")
    let stage3TextRaw: str = v3path.V3ReadTextFile("", stage3Log)
    let stage3Text: str = strutil.Strip(stage3TextRaw)
    let backendTextRaw: str = v3path.V3ReadTextFile("", backendLog)
    let backendText: str = strutil.Strip(backendTextRaw)
    if !v3path.V3TextContains(stage3Text, "v3 host smokes: ok") ||
       !v3path.V3TextContains(backendText, "v3 host smokes: ok"):
        v3BackendDriverPrintErr("v3 backend driver: verify-export-visibility-parallel output drift")
        return 1
    v3BackendDriverPrintLine("v3 host smokes: ok")
    return 0

fn v3BackendDriverVerifyDebugTools(rootDir: str,
                                   count: int32): int32 =
    return v3BackendDriverVerifyLiveSmoke(rootDir,
                                          count,
                                          "v3/src/tests/debug_tools_surface_smoke.cheng",
                                          "debug_tools_surface_smoke",
                                          "v3 debug_tools_surface_smoke ok",
                                          "v3 debug tools: ok")

fn v3BackendDriverVerifyBackendDriverCommandSurface(rootDir: str,
                                                    count: int32): int32 =
    return v3BackendDriverVerifyLiveSmoke(rootDir,
                                          count,
                                          "v3/src/tests/backend_driver_command_surface_smoke.cheng",
                                          "backend_driver_command_surface_smoke",
                                          "v3 backend_driver_command_surface_smoke ok",
                                          "verify-backend-driver-command-surface: ok")

fn v3BackendDriverVerifyMobileShellBuildProbe(rootDir: str): int32 =
    let selfPath: str = v3BackendDriverSelfPath(rootDir)
    if len(selfPath) <= 0:
        v3BackendDriverPrintErr("v3 backend driver: missing self path for verify-mobile-shell-build-probe")
        return 2
    var now: monotimes.MonoTime
    now = monotimes.GetMonoTime()
    let stamp: str = int64ToStr(monotimes.MonoTimeNs(now))
    let outDir: str = os.JoinPath("/tmp", "v3_mobile_shell_verify_" + stamp)
    let logDir: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_backend_driver")
    let _made: bool = v3path.V3MkdirP(rootDir, logDir)
    let logPath: str = os.JoinPath(logDir, "verify_mobile_shell_build_probe.log")
    let args: str[] = [
        "mobile-shell",
        "build-probe",
        "--platform", "all",
        "--out-dir", outDir,
        "--app-id", "org.cheng.verify.mobileshell",
        "--app-name", "ChengVerifyMobileShell",
        "--lib-name", "cheng_verify_mobile_shell_app"
    ]
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                           "verify_mobile_shell_build_probe",
                                                           selfPath,
                                                           args,
                                                           [],
                                                           rootDir,
                                                           0,
                                                           logPath)
    if v3BackendDriverPrintRunFailure("v3 backend driver: verify-mobile-shell-build-probe", run):
        return run.exitCode
    v3BackendDriverMaybePrintRunOutput(run)
    let outputText: str = strutil.Strip(run.output)
    if !v3BackendDriverOutputContains(outputText, "mobile-shell build-probe ok"):
        v3BackendDriverPrintErr("v3 backend driver: verify-mobile-shell-build-probe missing success output")
        return 1
    let summaryPath: str = os.JoinPath(outDir, "mobile_shell_build_probe.summary.env")
    let manifestPath: str = os.JoinPath(outDir, "mobile_shell_manifest_v1.json")
    let androidApk: str = os.JoinPath(outDir, "android/app/build/outputs/apk/debug/app-debug.apk")
    let iosApp: str = os.JoinPath(outDir, "ios/.derived_data/Build/Products/Debug-iphonesimulator/ChengGeneratedApp.app/ChengGeneratedApp")
    let harmonyApp: str = os.JoinPath(outDir, "harmony/build/outputs/default/harmony-default-unsigned.app")
    let harmonyHap: str = os.JoinPath(outDir, "harmony/entry/build/default/outputs/default/app/entry-default.hap")
    if !os.FileExists(summaryPath) ||
       !os.FileExists(manifestPath) ||
       !os.FileExists(androidApk) ||
       !os.FileExists(iosApp) ||
       !os.FileExists(harmonyApp) ||
       !os.FileExists(harmonyHap):
        v3BackendDriverPrintErr("v3 backend driver: verify-mobile-shell-build-probe missing build artifacts")
        return 1
    let summaryText: str = v3path.V3ReadTextFile("", summaryPath)
    if !v3BackendDriverOutputContains(summaryText, "format=mobile_shell_build_probe_summary_v1") ||
       !v3BackendDriverOutputContains(summaryText, "android_exit_code=0") ||
       !v3BackendDriverOutputContains(summaryText, "ios_exit_code=0") ||
       !v3BackendDriverOutputContains(summaryText, "harmony_exit_code=0") ||
       !v3BackendDriverOutputContains(summaryText, "android_apk_exists=1") ||
       !v3BackendDriverOutputContains(summaryText, "ios_app_exists=1") ||
       !v3BackendDriverOutputContains(summaryText, "harmony_app_exists=1") ||
       !v3BackendDriverOutputContains(summaryText, "harmony_hap_exists=1"):
        v3BackendDriverPrintErr("v3 backend driver: verify-mobile-shell-build-probe summary drifted")
        return 1
    v3BackendDriverPrintLine("verify-mobile-shell-build-probe: ok")
    return 0

fn v3BackendDriverVerifyChainNodeResilienceSurface(rootDir: str,
                                                   count: int32): int32 =
    count
    let args: str[] = v3BackendDriverCollectArgsFrom(2, count)
    return v3BackendDriverVerifyChainNodeResilience(rootDir, args)

fn v3BackendDriverVerifyR2cReactV3Surface(rootDir: str,
                                          count: int32): int32 =
    return v3BackendDriverVerifyLiveSmoke(rootDir,
                                          count,
                                          "v3/src/tests/r2c_react_v3_surface_smoke.cheng",
                                          "r2c_react_v3_surface_smoke",
                                          "v3 r2c_react_v3_surface_smoke ok",
                                          "verify-r2c-react-v3-surface: ok")

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let rootDir: str = v3BackendDriverRoot()
    let count: int32 = v3BackendDriverParamCountBridge()
    if count <= 0:
        v3BackendDriverUsage(rootDir)
        return 0
    let cmd: str = cmdline.ParamStr(1)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        v3BackendDriverUsage(rootDir)
        return 0
    if cmd == "status":
        v3BackendDriverStatus(rootDir)
        return 0
    if cmd == "mobile-shell":
        return v3BackendDriverRunMobileShell(rootDir, count)
    if cmd == "r2c-react-v3":
        if count <= 1:
            v3BackendDriverR2cReactV3Help()
            return 0
        let subcmd: str = cmdline.ParamStr(2)
        if subcmd == "help" || subcmd == "--help" || subcmd == "-h":
            v3BackendDriverR2cReactV3Help()
            return 0
        if subcmd == "status":
            return v3BackendDriverR2cReactV3Status(rootDir, count)
    if cmd == "vpn-proxy":
        return v3BackendDriverRunVpnProxy(rootDir, count)
    if cmd == "print-build-plan":
        return v3BackendDriverPrintBuildPlan(rootDir, count)
    if cmd == "host-bridge-audit":
        return v3BackendDriverHostBridgeAudit(rootDir)
    if cmd == "run-shared-emit-smokes":
        return v3BackendDriverRunSharedEmitSmokes(rootDir, count)
    if cmd == "verify-export-visibility":
        return v3BackendDriverVerifyExportVisibility(rootDir)
    if cmd == "verify-export-visibility-parallel":
        return v3BackendDriverVerifyExportVisibilityParallel(rootDir)
    if cmd == "verify-debug-tools":
        return v3BackendDriverVerifyDebugTools(rootDir, count)
    if cmd == "status-bft-validator-three-node" ||
       cmd == "stop-bft-validator-three-node" ||
       cmd == "build-bft-state-machine" ||
       cmd == "deploy-bft-validator-three-node" ||
       cmd == "verify-bft-validator-three-node" ||
       cmd == "bench-bft-validator-three-node":
        return v3BackendDriverRunGateTool(rootDir, count)
    if cmd == "build-browser-host-wasm" ||
       cmd == "run-browser-host-wasm-smoke":
        return v3BackendDriverRunBrowserHostWasmCommand(rootDir, count, cmd)
    if cmd == "run-wasm-smokes":
        let args: str[] = v3BackendDriverCollectArgsFrom(2, count)
        return v3BackendDriverRunWasmSmokes(rootDir, args)
    if cmd == "run-host-smokes":
        return v3BackendDriverRunHostSmokes(rootDir, count)
    if cmd == "verify-backend-driver-command-surface":
        return v3BackendDriverVerifyBackendDriverCommandSurface(rootDir, count)
    if cmd == "verify-mobile-shell-build-probe":
        return v3BackendDriverVerifyMobileShellBuildProbe(rootDir)
    if cmd == "verify-chain-node-resilience":
        return v3BackendDriverVerifyChainNodeResilienceSurface(rootDir, count)
    if cmd == "verify-r2c-react-v3-surface":
        return v3BackendDriverVerifyR2cReactV3Surface(rootDir, count)
    if cmd == "r2c-react-v3-codegen-surface-smoke":
        return v3BackendDriverR2cReactV3CodegenSurfaceSmoke(rootDir, count)
    if cmd == "r2c-react-v3-native-gui-bundle-smoke":
        return v3BackendDriverR2cReactV3NativeGuiBundleSmoke(rootDir, count)
    if cmd == "r2c-react-v3-fresh-clean-gate":
        return v3BackendDriverR2cReactV3FreshCleanGate(rootDir, count)
    if cmd == "run-chain-node-resilience-smoke":
        let args: str[] = v3BackendDriverCollectArgsFrom(2, count)
        return v3BackendDriverRunChainNodeResilienceSmoke(rootDir, args)
    let args: str[] = v3BackendDriverCollectArgsFrom(1, count)
    return v3BackendDriverForward(rootDir, args)
