fn v3BackendDriverRunFreshNodeSelfhostGate(rootDir: str,
                                           compilerPath: str,
                                           label: str): int32 =
    let src: str = v3path.V3PathAbsolute(rootDir, "v3/src/tests/program_selfhost_smoke.cheng")
    let outDirRel: str = v3BackendDriverConcat2("artifacts/v3_fresh_node_gate/", label)
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRel)
    let syncPrefix: str = os.JoinPath(outDir, "program_selfhost_smoke.sync")
    let freshPrefix: str = os.JoinPath(outDir, "program_selfhost_smoke.fresh")
    let packageRoot: str = v3path.V3PathAbsolute(rootDir, "v3")
    if !os.FileExists(src):
        v3BackendDriverPrintErr("v3 fresh-node selfhost gate: missing source: " + src)
        return 1
    let syncRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                               "v3 fresh-node selfhost world-sync " + label,
                                                               compilerPath,
                                                               ["world-sync",
                                                                "--root:" + packageRoot,
                                                                "--in:" + src,
                                                                "--target:arm64-apple-darwin",
                                                                "--out:" + syncPrefix,
                                                                "--channel:stable"],
                                                               [],
                                                               rootDir,
                                                               0,
                                                               os.JoinPath(outDir, "world_sync.log"))
    if v3BackendDriverRunFailed("v3 fresh-node selfhost world-sync", syncRun):
        return syncRun.exitCode
    if !v3BackendDriverRequirePrefixArtifacts(syncPrefix,
                                              [".world.txt",
                                               ".compiler.snapshot.txt",
                                               ".std.snapshot.txt",
                                               ".runtime.snapshot.txt",
                                               ".csg.txt",
                                               ".surface.txt",
                                               ".receipt.txt",
                                               ".lock.toml"],
                                              "v3 fresh-node selfhost gate"):
        return 1
    var freshArgs: str[] = []
    add(freshArgs, "fresh-node-selfhost")
    add(freshArgs, "--root:" + packageRoot)
    add(freshArgs, "--in:" + src)
    add(freshArgs, "--target:arm64-apple-darwin")
    add(freshArgs, "--out:" + freshPrefix)
    add(freshArgs, "--channel:stable")
    add(freshArgs, v3BackendDriverConcat3("--baseline-csg:", syncPrefix, ".csg.txt"))
    add(freshArgs, v3BackendDriverConcat3("--baseline-surface:", syncPrefix, ".surface.txt"))
    add(freshArgs, v3BackendDriverConcat3("--baseline-receipt:", syncPrefix, ".receipt.txt"))
    let freshRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                                "v3 fresh-node selfhost fresh " + label,
                                                                compilerPath,
                                                                freshArgs,
                                                                [],
                                                                rootDir,
                                                                0,
                                                                os.JoinPath(outDir, "fresh_node.log"))
    if v3BackendDriverRunFailed("v3 fresh-node selfhost fresh", freshRun):
        return freshRun.exitCode
    if !v3BackendDriverRequireOutput(freshRun, "equivalence_passed=1", "v3 fresh-node selfhost gate") ||
       !v3BackendDriverRequireOutput(freshRun, "publish_allowed=1", "v3 fresh-node selfhost gate") ||
       !v3BackendDriverRequireOutput(freshRun, "receipt_equivalent=1", "v3 fresh-node selfhost gate") ||
       !v3BackendDriverRequireOutput(freshRun, "receipt_cid_match=1", "v3 fresh-node selfhost gate") ||
       !v3BackendDriverRequireFileContains(freshPrefix + ".fresh.txt", "receipt_equivalent=1", "v3 fresh-node selfhost gate") ||
       !v3BackendDriverRequireFileContains(freshPrefix + ".fresh.txt", "receipt_cid_match=1", "v3 fresh-node selfhost gate"):
        return 1
    v3BackendDriverMaybePrintRunOutput(syncRun)
    v3BackendDriverMaybePrintRunOutput(freshRun)
    let okText: str = v3BackendDriverConcat3("v3 fresh-node selfhost gate ok (", label, ")")
    v3BackendDriverPrintLine(okText)
    return 0

fn v3BackendDriverRunMigrationGate(rootDir: str,
                                   compilerPath: str,
                                   label: str): int32 =
    let currentSrc: str = v3path.V3PathAbsolute(rootDir, "v3/src/tests/compiler_migration_fixture.cheng")
    let legacySrc: str = v3path.V3PathAbsolute(rootDir, "v3/testdata/compiler_migration/compiler_migration_fixture_legacy.cheng")
    let outDirRel: str = v3BackendDriverConcat2("artifacts/v3_migration_gate/", label)
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRel)
    let migratePrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.migrate")
    let proofPrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.prove")
    let blockedPrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.blocked")
    let publishPrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.publish")
    let packageRoot: str = v3path.V3PathAbsolute(rootDir, "v3")
    if !os.FileExists(currentSrc) || !os.FileExists(legacySrc):
        v3BackendDriverPrintErr("v3 migration gate: missing fixture sources")
        return 1
    let migrateRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                                  "v3 migration gate migrate-csg " + label,
                                                                  compilerPath,
                                                                  ["migrate-csg",
                                                                   "--root:" + packageRoot,
                                                                   "--in:" + currentSrc,
                                                                   "--legacy-in:" + legacySrc,
                                                                   "--out:" + migratePrefix],
                                                                  [],
                                                                  rootDir,
                                                                  0,
                                                                  os.JoinPath(outDir, "migrate_csg.log"))
    if v3BackendDriverRunFailed("v3 migration gate migrate-csg", migrateRun):
        return migrateRun.exitCode
    if !v3BackendDriverRequirePrefixArtifacts(migratePrefix,
                                              [".migration.txt", ".migration.csg.txt", ".migration.surface.txt", ".migration.receipt.txt"],
                                              "v3 migration gate") ||
       !v3BackendDriverRequireOutput(migrateRun, "canonical_graph_cid=", "v3 migration gate"):
        return 1
    let proveRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                                "v3 migration gate prove-migration " + label,
                                                                compilerPath,
                                                                ["prove-migration",
                                                                 "--root:" + packageRoot,
                                                                 "--in:" + currentSrc,
                                                                 "--legacy-in:" + legacySrc,
                                                                 "--target:arm64-apple-darwin",
                                                                 "--channel:stable",
                                                                 "--out:" + proofPrefix],
                                                                [],
                                                                rootDir,
                                                                0,
                                                                os.JoinPath(outDir, "prove_migration.log"))
    if v3BackendDriverRunFailed("v3 migration gate prove-migration", proveRun):
        return proveRun.exitCode
    if !v3BackendDriverRequirePrefixArtifacts(proofPrefix,
                                              [".migration.txt", ".migration.csg.txt", ".migration.surface.txt", ".migration.receipt.txt", ".proof.txt"],
                                              "v3 migration gate") ||
       !v3BackendDriverRequireOutput(proveRun, "equivalence_kind=canonical_semantic_identity", "v3 migration gate") ||
       !v3BackendDriverRequireOutput(proveRun, "graph_equivalent=1", "v3 migration gate") ||
       !v3BackendDriverRequireOutput(proveRun, "export_surface_compatible=1", "v3 migration gate") ||
       !v3BackendDriverRequireOutput(proveRun, "compile_receipt_equivalent=1", "v3 migration gate"):
        return 1
    let blockedRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                                  "v3 migration gate publish-blocked " + label,
                                                                  compilerPath,
                                                                  ["publish-world",
                                                                   "--root:" + packageRoot,
                                                                   "--in:" + currentSrc,
                                                                   "--target:arm64-apple-darwin",
                                                                   "--out:" + blockedPrefix,
                                                                   "--channel:stable"],
                                                                  [],
                                                                  rootDir,
                                                                  0,
                                                                  os.JoinPath(outDir, "publish_blocked.log"))
    if blockedRun.exitCode == 0:
        v3BackendDriverPrintErr("v3 migration gate: stable publish unexpectedly passed without proof")
        return 1
    if !v3BackendDriverRequireAnyOutput(blockedRun.output,
                                        ["stable requires", "publish blocked", "missing --baseline"],
                                        "v3 migration gate"):
        return 1
    let publishRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(rootDir,
                                                                  "v3 migration gate publish-world " + label,
                                                                  compilerPath,
                                                                  ["publish-world",
                                                                   "--root:" + packageRoot,
                                                                   "--in:" + currentSrc,
                                                                   "--legacy-in:" + legacySrc,
                                                                   "--target:arm64-apple-darwin",
                                                                   "--out:" + publishPrefix,
                                                                   "--channel:stable"],
                                                                  [],
                                                                  rootDir,
                                                                  0,
                                                                  os.JoinPath(outDir, "publish_migration.log"))
    if v3BackendDriverRunFailed("v3 migration gate publish-world", publishRun):
        return publishRun.exitCode
    if !v3BackendDriverRequirePrefixArtifacts(publishPrefix,
                                              [".world.txt",
                                               ".compiler.snapshot.txt",
                                               ".std.snapshot.txt",
                                               ".runtime.snapshot.txt",
                                               ".csg.txt",
                                               ".surface.txt",
                                               ".receipt.txt",
                                               ".lock.toml",
                                               ".migration.txt",
                                               ".migration.csg.txt",
                                               ".migration.surface.txt",
                                               ".migration.receipt.txt",
                                               ".proof.txt",
                                               ".publish.txt"],
                                              "v3 migration gate") ||
       !v3BackendDriverRequireOutput(publishRun, "proof_mode=migration", "v3 migration gate") ||
       !v3BackendDriverRequireOutput(publishRun, "equivalence_passed=1", "v3 migration gate") ||
       !v3BackendDriverRequireOutput(publishRun, "publish_allowed=1", "v3 migration gate"):
        return 1
    v3BackendDriverMaybePrintRunOutput(migrateRun)
    v3BackendDriverMaybePrintRunOutput(proveRun)
    v3BackendDriverMaybePrintRunOutput(blockedRun)
    v3BackendDriverMaybePrintRunOutput(publishRun)
    let okText: str = v3BackendDriverConcat3("v3 migration gate ok (", label, ")")
    v3BackendDriverPrintLine(okText)
    return 0

fn v3BackendDriverRunHostSmokesLocal(rootDir: str,
                                     args: str[]): int32 =
    var compilerPath = ""
    if !v3BackendDriverResolveHostSmokeCompiler(rootDir, args, compilerPath):
        return 1
    let tailOnly: str = strutil.Strip(v3BackendDriverReadFlag(args, "--tail-only", ""))
    let positionals: str[] = v3BackendDriverCollectPositionals(args)
    let label: str = v3BackendDriverResolveSmokeLabel(args, "CHENG_V3_SMOKE_LABEL", "host")
    let hostrunRoot: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_hostrun")
    var outDir: str = hostrunRoot
    if label != "host":
        outDir = os.JoinPath(hostrunRoot, label)
    if len(tailOnly) > 0:
        if tailOnly == "wasm":
            return v3BackendDriverRunWasmSmokes(rootDir, args)
        if tailOnly == "browser_host_wasm":
            return v3BackendDriverRunBrowserHostWasmSmoke(rootDir, args)
        if tailOnly == "chain_node_cli":
            return v3BackendDriverRunChainNodeCliSmoke(rootDir, compilerPath, label)
        if tailOnly == "chain_node_process":
            return v3BackendDriverRunChainNodeProcessSmoke(rootDir, compilerPath, label)
        if tailOnly == "chain_node_three_node":
            return v3BackendDriverRunChainNodeThreeNodeSmoke(rootDir, compilerPath, label)
        if tailOnly == "chain_node_resilience":
            return v3BackendDriverRunChainNodeResilienceSmoke(rootDir, args)
        if tailOnly == "tailnet_control":
            return v3BackendDriverRunTailnetControlSmoke(rootDir, compilerPath, label)
        if tailOnly == "fresh_node_selfhost":
            return v3BackendDriverRunFreshNodeSelfhostGate(rootDir, compilerPath, label)
        if tailOnly == "migration":
            return v3BackendDriverRunMigrationGate(rootDir, compilerPath, label)
        v3BackendDriverPrintErr("v3 host smokes: unknown --tail-only: " + tailOnly)
        return 1
    var tests: str[] = v3BackendDriverDefaultHostSmokes()
    var runTail: bool = true
    if positionals.len > 0:
        tests = positionals
        runTail = false
    for i in 0..<tests.len:
        let smokeName: str = tests[i]
        let outBin: str = os.JoinPath(outDir, smokeName)
        if v3BackendDriverRunSingleFixtureSmoke(rootDir, "v3 host smokes", compilerPath, smokeName, outBin, label) != 0:
            return 1
        if smokeName == "chain_node_libp2p_smoke":
            if v3BackendDriverRunTcpTwoprocSmoke(rootDir, compilerPath, label) != 0:
                return 1
        if smokeName == "libp2p_quic_tls_smoke":
            if v3BackendDriverRunQuicTwoprocSmoke(rootDir, compilerPath, label) != 0:
                return 1
    if runTail:
        if v3BackendDriverRunChainNodeCliSmoke(rootDir, compilerPath, label) != 0:
            return 1
        if v3BackendDriverRunChainNodeProcessSmoke(rootDir, compilerPath, label) != 0:
            return 1
        if v3BackendDriverRunChainNodeThreeNodeSmoke(rootDir, compilerPath, label) != 0:
            return 1
        if v3BackendDriverRunTailnetControlSmoke(rootDir, compilerPath, label) != 0:
            return 1
        if v3BackendDriverRunFreshNodeSelfhostGate(rootDir, compilerPath, label) != 0:
            return 1
        if v3BackendDriverRunMigrationGate(rootDir, compilerPath, label) != 0:
            return 1
    v3BackendDriverPrintLine("v3 host smokes: ok")
    return 0

fn v3BackendDriverRequireWasmAudit(label: str,
                                   wasmPath: str,
                                   expectedExports: str[],
                                   expectedImports: str[],
                                   minExportCount: int32): bool =
    let infoRes = wasmaudit.v3WasmBinaryInspect(wasmPath)
    if IsErr(infoRes):
        v3BackendDriverPrintErr(label + ": " + Error(infoRes))
        return false
    let info = Value(infoRes)
    if info.exportNames.len < minExportCount:
        v3BackendDriverPrintErr(label + ": wasm export count too small: " + strings.IntToStr(info.exportNames.len))
        return false
    for i in 0..<expectedExports.len:
        if !wasmaudit.v3WasmBinaryHasExport(info, expectedExports[i]):
            v3BackendDriverPrintErr(label + ": missing wasm export: " + expectedExports[i])
            return false
    for i in 0..<expectedImports.len:
        if !wasmaudit.v3WasmBinaryHasImport(info, expectedImports[i]):
            v3BackendDriverPrintErr(label + ": missing wasm import: " + expectedImports[i])
            return false
    return true

fn v3BackendDriverResolveBrowserHostWasmCompiler(rootDir: str,
                                                 args: str[],
                                                 outCompiler: var str): bool =
    let explicitRaw: str = v3BackendDriverReadFlag(args, "--compiler", "")
    let explicit: str = strutil.Strip(explicitRaw)
    if len(explicit) > 0:
        outCompiler = v3path.V3PathAbsolute(rootDir, explicit)
        return true
    return v3BackendDriverResolveToolCompiler(rootDir, "browser-host-wasm", outCompiler)

fn v3BackendDriverBuildBrowserHostWasmArtifact(rootDir: str,
                                               compilerPath: str,
                                               outWasm: str,
                                               logPath: str,
                                               label: str): int32 =
    let sourcePath: str = v3path.V3PathAbsolute(rootDir, "v3/src/libp2p/browser/browser_host_wasm_probe.cheng")
    let run: hostops.V3LoggedRun = v3BackendDriverCompileEmit(rootDir,
                                                              label,
                                                              compilerPath,
                                                              sourcePath,
                                                              "shared",
                                                              outWasm,
                                                              "wasm32-unknown-unknown",
                                                              logPath)
    if v3BackendDriverRunFailed("v3 browser host wasm build", run):
        return run.exitCode
    if !os.FileExists(outWasm):
        v3BackendDriverPrintErr("v3 browser host wasm: missing wasm output: " + outWasm)
        return 1
    return 0

fn v3BackendDriverBuildBrowserHostWasm(rootDir: str,
                                       args: str[]): int32 =
    var compilerPath: str = ""
    if !v3BackendDriverResolveBrowserHostWasmCompiler(rootDir, args, compilerPath):
        return 2
    let filteredArgs: str[] = v3BackendDriverArgsWithoutFlag(args, "--compiler")
    let positionals: str[] = v3BackendDriverCollectPositionals(filteredArgs)
    let outDir: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_browser_host_wasm")
    var outWasm: str = os.GetEnvDefault("CHENG_V3_BROWSER_HOST_WASM_OUT", "")
    if len(outWasm) <= 0 && positionals.len > 0:
        outWasm = positionals[0]
    if len(outWasm) <= 0:
        outWasm = os.JoinPath(outDir, "cheng_browser_host_abi.wasm")
    else:
        outWasm = v3path.V3PathAbsolute(rootDir, outWasm)
    return v3BackendDriverBuildBrowserHostWasmArtifact(rootDir,
                                                       compilerPath,
                                                       outWasm,
                                                       os.JoinPath(outDir, "cheng_browser_host_abi.compile.log"),
                                                       "build_browser_host_wasm")

fn v3BackendDriverRunWasmSmokes(rootDir: str,
                                args: str[]): int32 =
    let outDir: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_wasm_smokes")
    if !v3path.V3MkdirP(rootDir, outDir):
        v3BackendDriverPrintErr("v3 wasm smokes: failed to create out dir")
        return 2
    var compilerPath: str = ""
    if !v3BackendDriverResolveBrowserHostWasmCompiler(rootDir, args, compilerPath):
        return 2
    let label: str = v3BackendDriverResolveSmokeLabel(args, "CHENG_V3_WASM_LABEL", "host")
    let hostTarget: str = v3BackendDriverHostTarget()
    if len(hostTarget) <= 0:
        v3BackendDriverPrintErr("v3 wasm smokes: unsupported host target")
        return 2
    let smokeNames: str[] = [
        "wasm_zero_smoke",
        "wasm_internal_call_smoke",
        "wasm_importc_noarg_i32_smoke"
    ]
    for i in 0..<smokeNames.len:
        let smokeName: str = smokeNames[i]
        let wasmSourceRel: str = v3BackendDriverConcat3("v3/src/tests/", smokeName, ".cheng")
        let wasmSource: str = v3path.V3PathAbsolute(rootDir, wasmSourceRel)
        let smokeLabelBase: str = v3BackendDriverConcat3(smokeName, ".", label)
        let wasmName: str = v3BackendDriverConcat2(smokeLabelBase, ".wasm")
        let wasmPath: str = os.JoinPath(outDir, wasmName)
        let compileLogName: str = v3BackendDriverConcat2(smokeLabelBase, ".compile.log")
        let compileLogPath: str = os.JoinPath(outDir, compileLogName)
        let compileLabelBase: str = v3BackendDriverConcat3("v3_wasm_smokes_compile_", smokeName, "_")
        let compileLabel: str = v3BackendDriverConcat2(compileLabelBase, label)
        let wasmTarget: str = "wasm32-unknown-unknown"
        let compileRun: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                        compileLabel,
                                                                        compilerPath,
                                                                        wasmSource,
                                                                        wasmPath,
                                                                        wasmTarget,
                                                                        compileLogPath)
        let compileContext: str = v3BackendDriverConcat3("v3 wasm smokes compile ", smokeName, "")
        if v3BackendDriverRunFailed(compileContext, compileRun):
            return compileRun.exitCode
        if !os.FileExists(wasmPath):
            v3BackendDriverPrintErr("v3 wasm smokes: missing wasm output: " + wasmPath)
            return 1
        var expectedExports: str[] = []
        add(expectedExports, "main")
        var expectedImports: str[] = []
        if smokeName == "wasm_importc_noarg_i32_smoke":
            add(expectedImports, "env.cheng_test_zero")
        let wasmAuditLabel: str = v3BackendDriverConcat3("v3 wasm audit ", smokeName, "")
        if !v3BackendDriverRequireWasmAudit(wasmAuditLabel,
                                            wasmPath,
                                            expectedExports,
                                            expectedImports,
                                            1):
            return 1
        if smokeName == "wasm_importc_noarg_i32_smoke":
            let okText: str = v3BackendDriverConcat3(smokeName, ": ok", "")
            v3BackendDriverPrintLine(okText)
            continue
        var hostSource: str = wasmSource
        let hostBinName: str = v3BackendDriverConcat2(smokeLabelBase, ".host")
        let hostBinPath: str = os.JoinPath(outDir, hostBinName)
        let hostCompileLogName: str = v3BackendDriverConcat2(smokeLabelBase, ".host.compile.log")
        let hostCompileLogPath: str = os.JoinPath(outDir, hostCompileLogName)
        let hostCompileLabelBase: str = v3BackendDriverConcat3("v3_wasm_smokes_host_compile_", smokeName, "_")
        let hostCompileLabel: str = v3BackendDriverConcat2(hostCompileLabelBase, label)
        let hostCompileRun: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                            hostCompileLabel,
                                                                            compilerPath,
                                                                            hostSource,
                                                                            hostBinPath,
                                                                            hostTarget,
                                                                            hostCompileLogPath)
        let hostCompileContext: str = v3BackendDriverConcat3("v3 wasm host compile ", smokeName, "")
        if v3BackendDriverRunFailed(hostCompileContext, hostCompileRun):
            return hostCompileRun.exitCode
        let hostRunLogName: str = v3BackendDriverConcat2(smokeLabelBase, ".host.run.log")
        let hostRunLogPath: str = os.JoinPath(outDir, hostRunLogName)
        let hostRunLabelBase: str = v3BackendDriverConcat3("v3_wasm_smokes_host_run_", smokeName, "_")
        let hostRunLabel: str = v3BackendDriverConcat2(hostRunLabelBase, label)
        let hostRun: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                                    hostRunLabel,
                                                                    hostBinPath,
                                                                    [],
                                                                    0,
                                                                    hostRunLogPath)
        let hostRunContext: str = v3BackendDriverConcat3("v3 wasm host run ", smokeName, "")
        if v3BackendDriverRunFailed(hostRunContext, hostRun):
            return hostRun.exitCode
        let okText: str = v3BackendDriverConcat3(smokeName, ": ok", "")
        v3BackendDriverPrintLine(okText)
    v3BackendDriverPrintLine("v3 wasm smokes: ok")
    return 0

fn v3BackendDriverRunBrowserHostWasmSmoke(rootDir: str,
                                          args: str[]): int32 =
    var compilerPath = ""
    if !v3BackendDriverResolveBrowserHostWasmCompiler(rootDir, args, compilerPath):
        return 1
    let filteredArgs: str[] = v3BackendDriverArgsWithoutFlag(args, "--compiler")
    let label: str = v3BackendDriverResolveSmokeLabel(filteredArgs, "CHENG_V3_WASM_LABEL", "host")
    let outDir: str = v3path.V3PathAbsolute(rootDir, "artifacts/v3_browser_host_wasm")
    let outWasmName: str = v3BackendDriverConcat3("cheng_browser_host_abi.", label, ".wasm")
    let outWasm: str = os.JoinPath(outDir, outWasmName)
    let compileLogName: str = v3BackendDriverConcat3("cheng_browser_host_abi.", label, ".compile.log")
    let compileLabel: str = v3BackendDriverConcat2("v3_browser_host_wasm_compile_", label)
    let buildCode: int32 = v3BackendDriverBuildBrowserHostWasmArtifact(rootDir,
                                                                       compilerPath,
                                                                       outWasm,
                                                                       os.JoinPath(outDir, compileLogName),
                                                                       compileLabel)
    if buildCode != 0:
        return buildCode
    var expectedExports: str[] = []
    add(expectedExports, "main")
    add(expectedExports, "browserNowMs")
    add(expectedExports, "browserEchoI32")
    add(expectedExports, "browserPeerHandle")
    add(expectedExports, "browserDistributedVideoBuild")
    add(expectedExports, "browserDistributedVideoRebuild")
    add(expectedExports, "browserMoqFountainBuild")
    add(expectedExports, "browserMoqFountainRebuild")
    add(expectedExports, "browserMoqBuildLongBlobComputedBundleCidLenProbe")
    add(expectedExports, "browserMoqPeerCsvCountProbe")
    var expectedImports: str[] = []
    add(expectedImports, "env.cheng_v3_browser_now_ms_bridge")
    add(expectedImports, "env.cheng_v3_browser_echo_i32_bridge")
    add(expectedImports, "env.cheng_v3_browser_peer_handle_bridge")
    add(expectedImports, "env.cheng_v3_browser_did_handle_bridge")
    add(expectedImports, "env.cheng_v3_browser_dm_active_count_bridge")
    add(expectedImports, "env.cheng_v3_browser_dm_connect_start_bridge")
    add(expectedImports, "env.cheng_v3_browser_dm_wait_start_bridge")
    add(expectedImports, "env.cheng_v3_browser_dm_send_start_bridge")
    add(expectedImports, "env.cheng_v3_browser_distributed_video_build_bridge")
    add(expectedImports, "env.cheng_v3_browser_distributed_video_rebuild_bridge")
    add(expectedImports, "env.cheng_v3_browser_distributed_video_last_error_handle_bridge")
    add(expectedImports, "env.cheng_v3_browser_input_len_bridge")
    add(expectedImports, "env.cheng_v3_browser_input_copy_bridge")
    add(expectedImports, "env.cheng_v3_buffer_handle_from_text_bridge")
    add(expectedImports, "env.cheng_v3_browser_buffer_handle_len_bridge")
    add(expectedImports, "env.cheng_v3_browser_buffer_handle_byte_bridge")
    add(expectedImports, "env.cheng_v3_browser_buffer_handle_release_bridge")
    add(expectedImports, "env.cheng_v3_browser_moq_fountain_last_error_store_bridge")
    add(expectedImports, "env.cheng_v3_browser_moq_fountain_last_error_handle_bridge")
    if !v3BackendDriverRequireWasmAudit("v3 browser host wasm audit",
                                        outWasm,
                                        expectedExports,
                                        expectedImports,
                                        40):
        return 1
    let hostTarget: str = v3BackendDriverHostTarget()
    if len(hostTarget) <= 0:
        v3BackendDriverPrintErr("v3 browser host wasm smoke: unsupported host target")
        return 1
    let hostSrc: str = v3path.V3PathAbsolute(rootDir, "v3/src/tests/browser_host_native_contract_smoke.cheng")
    let hostBinName: str = v3BackendDriverConcat2("browser_host_native_contract_smoke.", label)
    let hostBin: str = os.JoinPath(outDir, hostBinName)
    let hostCompileLabel: str = v3BackendDriverConcat2("v3 browser host native compile ", label)
    let hostCompileLogName: str = v3BackendDriverConcat3("browser_host_native_contract_smoke.", label, ".compile.log")
    let hostCompile = v3BackendDriverCompileExe(rootDir,
                                                hostCompileLabel,
                                                compilerPath,
                                                hostSrc,
                                                hostBin,
                                                hostTarget,
                                                os.JoinPath(outDir, hostCompileLogName))
    if v3BackendDriverRunFailed("v3 browser host native compile", hostCompile):
        return hostCompile.exitCode
    let runLabel: str = v3BackendDriverConcat2("v3 browser host wasm smoke run ", label)
    let runLogName: str = v3BackendDriverConcat3("browser_host_wasm.", label, ".run.log")
    let run: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                            runLabel,
                                                            hostBin,
                                                            [],
                                                            0,
                                                            os.JoinPath(outDir, runLogName))
    v3BackendDriverMaybePrintRunOutput(run)
    if v3BackendDriverRunFailed("v3 browser host wasm smoke", run):
        return run.exitCode
    if !v3BackendDriverRequireOutput(run,
                                     "v3 browser host wasm smoke: ok",
                                     "v3 browser host wasm smoke"):
        return 1
    return 0

fn v3BackendDriverRunBrowserHostWasmCommand(rootDir: str,
                                            count: int32,
                                            commandName: str): int32 =
    let args: str[] = v3BackendDriverCollectArgsFrom(2, count)
    if commandName == "build-browser-host-wasm":
        return v3BackendDriverBuildBrowserHostWasm(rootDir, args)
    if commandName == "run-browser-host-wasm-smoke":
        return v3BackendDriverRunBrowserHostWasmSmoke(rootDir, args)
    v3BackendDriverPrintErr("v3 backend driver: unknown browser host wasm command: " + commandName)
    return 2

fn v3BackendDriverBuildChainNodeBinary(rootDir: str,
                                       compilerPath: str,
                                       outDir: str,
                                       label: str,
                                       outBin: var str): int32 =
    let sourcePath: str = v3path.V3PathAbsolute(rootDir, "v3/src/project/chain_node_main.cheng")
    outBin = os.JoinPath(outDir, "chain_node")
    var targetTriple: str = v3BackendDriverHostTarget()
    if len(targetTriple) <= 0:
        targetTriple = contracts.v3BootstrapDefaultTarget()
    let compileLog: str = os.JoinPath(outDir, "chain_node.compile.log")
    let compileRun: hostops.V3LoggedRun = v3BackendDriverCompileExe(rootDir,
                                                                    label,
                                                                    compilerPath,
                                                                    sourcePath,
                                                                    outBin,
                                                                    targetTriple,
                                                                    compileLog)
    if v3BackendDriverRunFailed("v3 chain_node resilience compile", compileRun):
        return compileRun.exitCode
    if !os.FileExists(outBin):
        v3BackendDriverPrintErr("v3 chain_node resilience smoke: missing chain_node binary: " + outBin)
        return 1
    return 0

fn v3BackendDriverWaitReadyPort(rootDir: str,
                                readyPath: str,
                                proc: var hostops.V3SpawnedProcess,
                                outPort: var str): bool =
    rootDir
    outPort = ""
    for i in 0..<400:
        i
        hostops.v3SpawnedProcessDrain(proc, 0)
        if os.FileExists(readyPath):
            let candidateRaw: str = v3path.V3ReadTextFile("", readyPath)
            let candidate: str = strutil.Strip(candidateRaw)
            if v3BackendDriverIsDigits(candidate):
                outPort = candidate
                return true
        if !hostops.v3SpawnedProcessRunning(proc):
            return false
        os.SleepMs(50)
    return false

fn v3BackendDriverRunChainNodeServeAndSync(rootDir: str,
                                           label: str,
                                           chainNodeBin: str,
                                           serverState: str,
                                           clientState: str,
                                           clientNodeId: str,
                                           clientAddressSeed: str,
                                           outDir: str,
                                           roundTag: str,
                                           expectChanged: bool): int32 =
    let readyNameRaw: str = roundTag + ".ready"
    let readyName: str = newStringCopy(strDataPtr(readyNameRaw), strLenFast(readyNameRaw))
    let readyPath: str = os.JoinPath(outDir, readyName)
    let serverLogNameRaw: str = roundTag + ".server.log"
    let serverLogName: str = newStringCopy(strDataPtr(serverLogNameRaw), strLenFast(serverLogNameRaw))
    let serverLog: str = os.JoinPath(outDir, serverLogName)
    let syncLogNameRaw: str = roundTag + ".sync.log"
    let syncLogName: str = newStringCopy(strDataPtr(syncLogNameRaw), strLenFast(syncLogNameRaw))
    let syncLog: str = os.JoinPath(outDir, syncLogName)
    let _ = os.RemoveFile(readyPath)
    var serveArgs: str[] = []
    add(serveArgs, "daemon-serve")
    add(serveArgs, "--state:" + serverState)
    add(serveArgs, "--port:0")
    add(serveArgs, "--ready-path:" + readyPath)
    let serverSpawn = hostops.v3SpawnFile(rootDir,
                                          "v3 chain_node resilience serve " + label + " " + roundTag,
                                          chainNodeBin,
                                          serveArgs,
                                          [],
                                          rootDir)
    if IsErr(serverSpawn):
        v3BackendDriverPrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var serverPort = ""
    if !v3BackendDriverWaitReadyPort(rootDir, readyPath, serverProc, serverPort):
        let serverRun: hostops.V3LoggedRun = hostops.v3SpawnedProcessWaitLogged(rootDir, serverProc, 1, serverLog)
        v3BackendDriverMaybePrintRunOutput(serverRun)
        return 1
    var syncArgs: str[] = []
    add(syncArgs, "daemon-sync")
    add(syncArgs, "--state:" + clientState)
    if len(clientNodeId) > 0:
        add(syncArgs, "--node-id:" + clientNodeId)
    if len(clientAddressSeed) > 0:
        add(syncArgs, "--address-seed:" + clientAddressSeed)
    add(syncArgs, "--host:127.0.0.1")
    add(syncArgs, "--port:" + serverPort)
    let syncRun: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                                "v3 chain_node resilience sync " + label + " " + roundTag,
                                                                chainNodeBin,
                                                                syncArgs,
                                                                20,
                                                                syncLog)
    if v3BackendDriverRunFailed("v3 chain_node resilience sync", syncRun):
        let serverRun: hostops.V3LoggedRun = hostops.v3SpawnedProcessWaitLogged(rootDir, serverProc, 1, serverLog)
        v3BackendDriverMaybePrintRunOutput(serverRun)
        return syncRun.exitCode
    let serverRun: hostops.V3LoggedRun = hostops.v3SpawnedProcessWaitLogged(rootDir, serverProc, 20, serverLog)
    v3BackendDriverMaybePrintRunOutput(serverRun)
    v3BackendDriverMaybePrintRunOutput(syncRun)
    if v3BackendDriverRunFailed("v3 chain_node resilience serve", serverRun):
        return serverRun.exitCode
    if expectChanged:
        if !v3BackendDriverRequireOutput(syncRun, "changed=1", "v3 chain_node resilience smoke"):
            return 1
    else:
        if !v3BackendDriverRequireOutput(syncRun, "changed=0", "v3 chain_node resilience smoke"):
            return 1
    return 0

fn v3BackendDriverChainNodeLogPath(outDir: str,
                                   stem: str,
                                   label: str): str =
    let nameRaw: str = stem + "." + label + ".log"
    let name: str = newStringCopy(strDataPtr(nameRaw), strLenFast(nameRaw))
    return os.JoinPath(outDir, name)

fn v3BackendDriverChainNodeRun(rootDir: str,
                               runLabel: str,
                               chainNodeBin: str,
                               args: str[],
                               outDir: str,
                               logStem: str,
                               label: str): hostops.V3LoggedRun =
    let logPath: str = v3BackendDriverChainNodeLogPath(outDir, logStem, label)
    return v3BackendDriverRunBinary(rootDir, runLabel, chainNodeBin, args, 20, logPath)

