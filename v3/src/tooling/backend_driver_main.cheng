                                    runLabel,
                                    showBin,
                                    ["--state:" + statePath],
                                    20,
                                    logPath)

fn v3BackendDriverRunChainNodeCliSyncCheck(rootDir: str,
                                           label: str,
                                           syncBin: str,
                                           clientState: str,
                                           serverPort: str,
                                           syncLog: str): int32 =
    let run: hostops.V3LoggedRun = v3BackendDriverRunChainNodeCliSyncBinary(rootDir,
                                                                             label,
                                                                             syncBin,
                                                                             clientState,
                                                                             serverPort,
                                                                             syncLog)
    v3BackendDriverMaybePrintRunOutput(run)
    if v3BackendDriverRunFailed("v3 chain_node cli daemon-sync", run):
        return run.exitCode
    if !v3BackendDriverRequireOutput(run, "changed=1", "v3 chain_node cli smoke"):
        return 1
    return 0

fn v3BackendDriverRunChainNodeCliBalanceCheck(rootDir: str,
                                              label: str,
                                              stageName: str,
                                              balanceBin: str,
                                              statePath: str,
                                              account: str,
                                              logPath: str,
                                              expectedText: str): int32 =
    let runLabelBase: str = v3BackendDriverConcat3("v3 chain_node cli ", stageName, " ")
    let runLabel: str = v3BackendDriverConcat2(runLabelBase, label)
    let run: hostops.V3LoggedRun = v3BackendDriverRunChainNodeCliBalanceBinary(rootDir,
                                                                                runLabel,
                                                                                balanceBin,
                                                                                statePath,
                                                                                account,
                                                                                logPath)
    v3BackendDriverMaybePrintRunOutput(run)
    if v3BackendDriverRunFailed(runLabel, run):
        return run.exitCode
    if !v3BackendDriverRequireOutput(run, expectedText, "v3 chain_node cli smoke"):
        return 1
    return 0

