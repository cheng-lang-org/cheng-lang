fn v3BackendDriverJsonQuote(text: str): str =
    let quote: str = strings.CharToStr(char(34))
    return quote + text + quote

fn v3BackendDriverR2cReactV3EffectiveRoot(rootDir: str,
                                          count: int32): str =
    let rawRootValue: str = v3BackendDriverReadFlagOrDefault(count, "--root", rootDir)
    let rawRoot: str = strutil.Strip(rawRootValue)
    if len(rawRoot) <= 0:
        return rootDir
    return v3path.V3PathAbsolute(rootDir, rawRoot)

