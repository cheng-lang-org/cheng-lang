fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let rootDir: str = v3BackendDriverRoot()
    let count: int32 = v3BackendDriverParamCountBridge()
    if count <= 0:
        v3BackendDriverUsage(rootDir)
        return 0
    let cmd: str = cmdline.ParamStr(1)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        v3BackendDriverUsage(rootDir)
        return 0
    if cmd == "status":
        v3BackendDriverStatus(rootDir)
        return 0
    if cmd == "print-build-plan":
        return v3BackendDriverPrintBuildPlan(rootDir, count)
    if cmd == "host-bridge-audit":
        return v3BackendDriverHostBridgeAudit(rootDir)
    if cmd == "run-shared-emit-smokes":
        return v3BackendDriverRunSharedEmitSmokes(rootDir, count)
    if cmd == "verify-export-visibility":
        return v3BackendDriverVerifyExportVisibility(rootDir)
    if cmd == "verify-export-visibility-parallel":
        return v3BackendDriverVerifyExportVisibilityParallel(rootDir)
    if cmd == "verify-debug-tools":
        return v3BackendDriverVerifyDebugTools(rootDir, count)
    if cmd == "verify-backend-driver-command-surface":
        return v3BackendDriverVerifyBackendDriverCommandSurface(rootDir, count)
    if cmd == "verify-chain-node-resilience":
        return v3BackendDriverVerifyChainNodeResilienceSurface(rootDir, count)
    if cmd == "verify-r2c-react-v3-surface":
        return v3BackendDriverVerifyR2cReactV3Surface(rootDir, count)
    if cmd == "r2c-react-v3-codegen-surface-smoke":
        return v3BackendDriverR2cReactV3CodegenSurfaceSmoke(rootDir, count)
    if cmd == "r2c-react-v3-native-gui-bundle-smoke":
        return v3BackendDriverR2cReactV3NativeGuiBundleSmoke(rootDir, count)
    if cmd == "r2c-react-v3-fresh-clean-gate":
        return v3BackendDriverR2cReactV3FreshCleanGate(rootDir, count)
    if cmd == "run-chain-node-resilience-smoke":
        let args: str[] = v3BackendDriverCollectArgsFrom(2, count)
        return v3BackendDriverRunChainNodeResilienceSmoke(rootDir, args)
    let args: str[] = v3BackendDriverCollectArgsFrom(1, count)
    return v3BackendDriverForward(rootDir, args)
