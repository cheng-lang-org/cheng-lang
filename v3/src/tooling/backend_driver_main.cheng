fn v3BackendDriverRunChainNodeCliSmoke(rootDir: str,
                                       compilerPath: str,
                                       label: str): int32 =
    let outDirRel: str = v3BackendDriverConcat2("artifacts/v3_chain_node_cli/", label)
    let outDir: str = v3path.V3PathAbsolute(rootDir, outDirRel)
    let logName: str = v3BackendDriverConcat3("forward.", label, ".log")
    let logPath: str = os.JoinPath(outDir, logName)
    let stage3Path: str = v3BackendDriverStage3Path(rootDir)
    let compilerArg: str = v3BackendDriverConcat2("--compiler:", compilerPath)
    let labelArg: str = v3BackendDriverConcat2("--label:", label)
    let run: hostops.V3LoggedRun = v3BackendDriverRunBinary(rootDir,
                                                            "v3 chain_node cli smoke " + label,
                                                            stage3Path,
                                                            ["run-chain-node-cli-smoke", compilerArg, labelArg],
                                                            120,
                                                            logPath)
    v3BackendDriverMaybePrintRunOutput(run)
    if v3BackendDriverRunFailed("v3 chain_node cli smoke", run):
        return run.exitCode
    let okText: str = v3BackendDriverConcat3("v3 chain_node cli smoke ok (", label, ")")
    if !v3BackendDriverRequireOutput(run, okText, "v3 chain_node cli smoke"):
        return 1
    return 0

