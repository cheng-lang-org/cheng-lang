    if v3BackendDriverRunFailed("v3 tailnet control listen", listenRun):
        return listenRun.exitCode
    if !v3BackendDriverRequireOutput(listenRun, "publishedAddr=/ip4/100.64.0.44/tcp/7101", "v3 tailnet control") ||
       !v3BackendDriverRequireOutput(listenRun, "listener.0.raw=/ip4/127.0.0.1/tcp/7101", "v3 tailnet control") ||
       !v3BackendDriverRequireOutput(listenRun, "providerKind=headscale", "v3 tailnet control") ||
       !v3BackendDriverRequireOutput(listenRun, "tailnetDerpMapSummary=headscale/infra@https://headscale.example#sfo/derp.sfo.example", "v3 tailnet control") ||
       !v3BackendDriverRequireOutput(listenRun, "providerRuntimeActive=1", "v3 tailnet control"):
