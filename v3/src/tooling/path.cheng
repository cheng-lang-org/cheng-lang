import std/os
import std/strings
import std/strutils as strutil

type
    V3PathSplitFileResult =
        dir: str
        name: str
        ext: str

fn v3PathTrim(raw: str): str =
    return strutil.strip(raw)

fn v3PathNonEmpty(raw: str): bool =
    return v3PathTrim(raw) != ""

fn v3TextSlice(text: str, start: int32, count: int32): str =
    if count <= 0:
        return ""
    return strings.sliceBytes(text, start, count)

fn v3TextStartsWith(text: str, prefix: str): bool =
    if prefix.len > text.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn v3TextContains(text: str, sub: str): bool =
    if sub == "":
        return true
    if text.len < sub.len:
        return false
    for i in 0..<(text.len - sub.len + 1):
        var matched = true
        for j in 0..<sub.len:
            if text[i + j] != sub[j]:
                matched = false
                break
        if matched:
            return true
    return false

fn v3PathCurrentDir(): str =
    return os.getCurrentDir()

fn v3PathIsAbsolute(raw: str): bool =
    let path = v3PathTrim(raw)
    if !v3PathNonEmpty(path):
        return false
    let first = path[0]
    if first == '/':
        return true
    if first == '\\':
        return true
    if path.len > 1:
        let second = path[1]
        if second == char(58):
            return true
    return false

fn v3PathJoin(left: str, right: str): str =
    let leftPath = v3PathTrim(left)
    let rightPath = v3PathTrim(right)
    return os.joinPath(leftPath, rightPath)

fn v3PathAbsolute(root: str, raw: str): str =
    let text: str = v3PathTrim(raw)
    if !v3PathNonEmpty(text):
        return ""
    if v3PathIsAbsolute(text):
        return text
    return v3PathJoin(root, text)

fn v3PathFileExists(pathRaw: str): bool =
    let path = v3PathTrim(pathRaw)
    if !v3PathNonEmpty(path):
        return false
    let f: os.File = os.openRead(path)
    if f == nil:
        return false
    os.close(f)
    return true

fn v3PathDirExists(pathRaw: str): bool =
    let path = v3PathTrim(pathRaw)
    if !v3PathNonEmpty(path):
        return false
    return os.dirExists(path)

fn v3PathFileSize(pathRaw: str): int64 =
    let path = v3PathTrim(pathRaw)
    if !v3PathNonEmpty(path):
        return int64(0)
    return os.fileSize(path)

fn v3PathExists(root: str, raw: str): bool =
    let path: str = v3PathAbsolute(root, raw)
    if !v3PathNonEmpty(path):
        return false
    return v3PathFileExists(path) || v3PathDirExists(path)

fn v3FileExistsNonEmpty(root: str, raw: str): bool =
    let path: str = v3PathAbsolute(root, raw)
    if !v3PathFileExists(path):
        return false
    return v3PathFileSize(path) > int64(0)

fn v3PathLastSep(path: str): int32 =
    var last: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            last = i
    return last

fn v3PathLastDot(name: str): int32 =
    var last: int32 = -1
    for i in 0..<name.len:
        if name[i] == '.':
            last = i
    return last

fn v3PathBaseName(pathRaw: str): str =
    let path = v3PathTrim(pathRaw)
    if !v3PathNonEmpty(path):
        return ""
    let lastSep = v3PathLastSep(path)
    if lastSep < 0:
        return path
    return v3TextSlice(path, lastSep + 1, path.len - (lastSep + 1))

fn v3PathParentDir(pathRaw: str): str =
    let path = v3PathTrim(pathRaw)
    if !v3PathNonEmpty(path):
        return ""
    let lastSep = v3PathLastSep(path)
    if lastSep < 0:
        return ""
    if lastSep == 0:
        return ""
    return v3TextSlice(path, 0, lastSep)

fn v3PathSplitFile(pathRaw: str): V3PathSplitFileResult =
    let path = v3PathTrim(pathRaw)
    let base = v3PathBaseName(path)
    let dir = v3PathParentDir(path)
    if !v3PathNonEmpty(base):
        return V3PathSplitFileResult(dir: dir, name: "", ext: "")
    let lastDot = v3PathLastDot(base)
    if lastDot <= 0:
        return V3PathSplitFileResult(dir: dir, name: base, ext: "")
    return V3PathSplitFileResult(
        dir: dir,
        name: v3TextSlice(base, 0, lastDot),
        ext: v3TextSlice(base, lastDot, base.len - lastDot)
    )

fn v3PathCreateDirAll(path: str): bool =
    if !v3PathNonEmpty(path):
        return false
    if os.dirExists(path):
        return true
    let parent = os.parentDir(path)
    if v3PathNonEmpty(parent) && parent != path && !os.dirExists(parent):
        if !v3PathCreateDirAll(parent):
            return false
    if !os.dirExists(path):
        os.createDir(path)
    return os.dirExists(path)

fn v3MkdirP(root: str, raw: str): bool =
    let path: str = v3PathAbsolute(root, raw)
    if !v3PathNonEmpty(path):
        return false
    return v3PathCreateDirAll(path)

fn v3WriteTextFile(root: str, raw: str, text: str): bool =
    let path: str = v3PathAbsolute(root, raw)
    if !v3PathNonEmpty(path):
        return false
    let parent: str = v3PathParentDir(path)
    if v3PathNonEmpty(parent):
        if !v3PathCreateDirAll(parent):
            return false
    os.writeFile(path, text)
    return v3PathFileExists(path)

fn v3ReadTextFile(root: str, raw: str): str =
    let path: str = v3PathAbsolute(root, raw)
    if !v3PathFileExists(path):
        return ""
    return os.readFile(path)
