    return [
        "usage: cheng_v3 <command> [args]",
        "",
        "commands:",
        "  scan-hotpath",
        "  c-ref",
        "  compare-bench --baseline:<file> --candidate:<file> [--max-ratio-milli:<N>]",
        "  bootstrap-bridge",
        "  build-backend-driver",
        "  run-smokes",
        "  print-bootstrap",
        "  print-build-plan",
        "  slice-gate",
        "  debug-report [seed-flags...]",
        "  print-symbols [seed-flags...]",
        "  print-line-map [seed-flags...]",
        "  print-object --object:<path> [--report-out:<path>]",
        "  print-elf --object:<path> [--report-out:<path>]",
        "  print-asm [seed-flags...]",
        "  profile-run [seed-flags...]",
        "  verify-orphan-guard",
        "  verify-debug-tools",
        "  verify-debug-runtime",
        "  verify-debug-profile",
        "  verify-windows-builtin",
        "  verify-riscv64-builtin",
        "  run-cross-target-smokes",
        "  run-host-smokes [smoke_name ...]",
        "  run-stage23-libp2p-smokes [smoke_name ...]",
        "  compile-exe",
        "  build-zero-exit",
        "  build-panic-trace",
        "  build-bounds-trace",
        "  build-signal-trace",
        "  build-call-chain",
        "  build-ffi-handle",
        "  build-bft-state-machine",
        "  build-rwad-bft-state-machine",
        "  build-program-selfhost",
        "  build-chain-node",
        "  build-linux-nolibc-exe",
        "  build-chain-node-linux",
        "  build-rwad-bft-linux",
        "  run-linux-object-smokes",
        "  run-tcp-twoproc-smoke",
        "  run-udp-importc-smoke",
        "  run-wasm-smokes",
        "  run-browser-host-wasm-smoke",
        "  run-chain-node-cli-smoke",
        "  run-chain-node-process-smoke",
        "  run-chain-node-three-node-smoke",
        "  run-tailnet-control-smoke",
        "  run-fresh-node-selfhost-gate",
        "  run-migration-gate",
        "  run-browser-webrtc-smokes",
        "  r2c-react-v3 <subcommand> [args]"
    ]

fn v3GateReadFlag(args: str[], key: str, defaultValue: str): str =
    for i in 0..<args.len:
        let arg: str = args[i]
        if strutil.startsWith(arg, key + ":"):
            return strings.dropPrefix(arg, key + ":")
        if strutil.startsWith(arg, key + "="):
            return strings.dropPrefix(arg, key + "=")
    return defaultValue

fn v3GateCollectArgsFrom(startIndex: int32, count: int32): str[] =
    var out: str[] = []
    if startIndex > count:
        return out
    for i in startIndex..count:
        out.add(cmdline.paramStr(i))
    return out

fn v3GateRunFailed(run: hostops.V3LoggedRun): bool =
    if hostops.v3LoggedRunOk(run):
        return false
    v3GatePrintErr(hostops.v3LoggedRunSummary(run))
    if len(strutil.strip(run.output)) > 0:
        v3GatePrintErr(strutil.strip(run.output))
    return true

fn v3GateMaybePrintRunOutput(run: hostops.V3LoggedRun) =
    if len(strutil.strip(run.output)) > 0:
        v3GatePrintLine(strutil.strip(run.output))

fn v3GateBootstrapOutDir(root: str): str =
    return contracts.v3BootstrapOutDir(root)

fn v3GateBootstrapLog(root: str, name: str): str =
    return v3path.v3PathAbsolute(root, "artifacts/v3_bootstrap/" + name)

fn v3GateBootstrapTarget(): str =
    return os.getEnvDefault("V3_TARGET", contracts.v3BootstrapDefaultTarget())

fn v3GateBootstrapEnvText(root: str,
                          snapshot: contracts.V3BootstrapSnapshot): str =
    let outDir: str = v3GateBootstrapOutDir(root)
    return (
        "V3_ROOT=" + root + "\n" +
        "V3_TARGET=" + v3GateBootstrapTarget() + "\n" +
        "V3_BOOTSTRAP_KIND=v3_seed\n" +
        "V3_BOOTSTRAP_SEED_SOURCE=" + snapshot.seedSource.path + "\n" +
        "V3_BOOTSTRAP_STAGE1_SOURCE=" + snapshot.stage1Source.path + "\n" +
        "V3_COMPILER_ENTRY_SOURCE=" + contracts.v3BootstrapCompilerEntrySourcePath(root) + "\n" +
        "V3_COMPILER_RUNTIME_SOURCE=" + contracts.v3BootstrapCompilerRuntimeSourcePath(root) + "\n" +
        "V3_COMPILER_REQUEST_SOURCE=" + contracts.v3BootstrapCompilerRequestSourcePath(root) + "\n" +
        "V3_BOOTSTRAP_STAGE0=" + snapshot.stage0Compiler.path + "\n" +
        "V3_BOOTSTRAP_STAGE1=" + snapshot.stage1Compiler.path + "\n" +
        "V3_BOOTSTRAP_STAGE2=" + snapshot.stage2Compiler.path + "\n" +
        "V3_BOOTSTRAP_STAGE3=" + snapshot.stage3Compiler.path + "\n" +
        "V3_BOOTSTRAP_ENV=" + snapshot.bootstrapEnv.path + "\n" +
        "V3_BOOTSTRAP_SNAPSHOT=" + contracts.v3BootstrapSnapshotPath(root) + "\n" +
        "V3_BOOTSTRAP_STAGE1_REPORT=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage1.report.txt") + "\n" +
        "V3_BOOTSTRAP_STAGE2_REPORT=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage2.report.txt") + "\n" +
        "V3_BOOTSTRAP_STAGE3_REPORT=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage3.report.txt") + "\n"
    )

fn v3GateBootstrapSnapshotText(root: str,
                               snapshot: contracts.V3BootstrapSnapshot): str =
    let outDir: str = v3GateBootstrapOutDir(root)
    return (
        "target=" + v3GateBootstrapTarget() + "\n" +
        "bootstrap_kind=v3_seed\n" +
        "seed_source=" + snapshot.seedSource.path + "\n" +
        "stage1_source=" + snapshot.stage1Source.path + "\n" +
        "compiler_entry_source=" + contracts.v3BootstrapCompilerEntrySourcePath(root) + "\n" +
        "compiler_runtime_source=" + contracts.v3BootstrapCompilerRuntimeSourcePath(root) + "\n" +
        "compiler_request_source=" + contracts.v3BootstrapCompilerRequestSourcePath(root) + "\n" +
        "stage0=" + snapshot.stage0Compiler.path + "\n" +
        "stage1=" + snapshot.stage1Compiler.path + "\n" +
        "stage2=" + snapshot.stage2Compiler.path + "\n" +
        "stage3=" + snapshot.stage3Compiler.path + "\n" +
        "stage1_report=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage1.report.txt") + "\n" +
        "stage2_report=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage2.report.txt") + "\n" +
        "stage3_report=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage3.report.txt") + "\n" +
        "stage0_build_log=" + v3GateBootstrapLog(root, "cheng.stage0.build.log") + "\n" +
        "stage0_self_check_log=" + v3GateBootstrapLog(root, "cheng.stage0.self-check.log") + "\n" +
        "stage1_build_log=" + v3GateBootstrapLog(root, "cheng.stage1.compile.log") + "\n" +
        "stage1_self_check_log=" + v3GateBootstrapLog(root, "cheng.stage1.self-check.log") + "\n" +
        "stage2_build_log=" + v3GateBootstrapLog(root, "cheng.stage2.compile.log") + "\n" +
        "stage2_self_check_log=" + v3GateBootstrapLog(root, "cheng.stage2.self-check.log") + "\n" +
        "stage3_build_log=" + v3GateBootstrapLog(root, "cheng.stage3.compile.log") + "\n" +
        "stage3_self_check_log=" + v3GateBootstrapLog(root, "cheng.stage3.self-check.log") + "\n" +
        "stage2_contract_log=" + v3GateBootstrapLog(root, "cheng.stage2.contract.txt") + "\n" +
        "stage3_contract_log=" + v3GateBootstrapLog(root, "cheng.stage3.contract.txt") + "\n" +
        "fixed_point=stage2_stage3_contract_match\n"
    )

fn v3GateBootstrapStageRun(root: str,
                           label: str,
                           binPath: str,
                           args: str[],
                           logPath: str): int32 =
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root, label, binPath, args, [], root, 0, logPath)
    if v3GateRunFailed(run):
        return run.exitCode
    return 0

fn v3GateBootstrapBridge(root: str): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
    let outDir: str = v3GateBootstrapOutDir(root)
    let ccBin: str = os.getEnvDefault("CC", "cc")
    if !v3path.v3MkdirP(root, outDir):
        v3GatePrintErr("v3 gate: failed to create bootstrap dir")
        return 1
    if !v3path.v3PathFileExists(snapshot.seedSource.path):
        v3GatePrintErr("v3 gate: missing seed source: " + snapshot.seedSource.path)
        return 1
    if !v3path.v3PathFileExists(snapshot.stage1Source.path):
        v3GatePrintErr("v3 gate: missing stage1 source: " + snapshot.stage1Source.path)
        return 1
    var ccArgs: str[] = []
    ccArgs.add("-std=c11")
    ccArgs.add("-O2")
    ccArgs.add("-Wall")
    ccArgs.add("-Wextra")
    ccArgs.add("-pedantic")
    ccArgs.add(snapshot.seedSource.path)
    ccArgs.add("-o")
    ccArgs.add(snapshot.stage0Compiler.path)
    let ccRun: hostops.V3LoggedRun = hostops.v3RunProgramLogged(root,
                                                                "stage0_cc",
                                                                ccBin,
                                                                ccArgs,
                                                                [],
                                                                root,
                                                                0,
                                                                "artifacts/v3_bootstrap/cheng.stage0.build.log")
    if v3GateRunFailed(ccRun):
        return ccRun.exitCode
    if !contracts.v3BootstrapArtifactReady(snapshot.stage0Compiler):
        v3GatePrintErr("v3 gate: missing stage0 compiler: " + snapshot.stage0Compiler.path)
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage0_self_check",
                               snapshot.stage0Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage0.self-check.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage1_compile",
                               snapshot.stage0Compiler.path,
                               [
                                   "compile-bootstrap",
                                   "--in:" + snapshot.stage1Source.path,
                                   "--out:" + snapshot.stage1Compiler.path,
                                   "--report-out:" + v3GateBootstrapLog(root, "cheng.stage1.report.txt")
                               ],
                               "artifacts/v3_bootstrap/cheng.stage1.compile.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage1_self_check",
                               snapshot.stage1Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage1.self-check.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage2_compile",
                               snapshot.stage1Compiler.path,
                               [
                                   "compile-bootstrap",
                                   "--in:" + snapshot.stage1Source.path,
                                   "--out:" + snapshot.stage2Compiler.path,
                                   "--report-out:" + v3GateBootstrapLog(root, "cheng.stage2.report.txt")
                               ],
                               "artifacts/v3_bootstrap/cheng.stage2.compile.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage2_self_check",
                               snapshot.stage2Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage2.self-check.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage3_compile",
                               snapshot.stage2Compiler.path,
                               [
                                   "compile-bootstrap",
                                   "--in:" + snapshot.stage1Source.path,
                                   "--out:" + snapshot.stage3Compiler.path,
                                   "--report-out:" + v3GateBootstrapLog(root, "cheng.stage3.report.txt")
                               ],
                               "artifacts/v3_bootstrap/cheng.stage3.compile.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage3_self_check",
                               snapshot.stage3Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage3.self-check.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage2_contract",
                               snapshot.stage2Compiler.path,
                               ["print-contract", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage2.contract.txt") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage3_contract",
                               snapshot.stage3Compiler.path,
                               ["print-contract", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage3.contract.txt") != 0:
        return 1
    let stage2Contract: str = v3path.v3ReadTextFile(root, "artifacts/v3_bootstrap/cheng.stage2.contract.txt")
    let stage3Contract: str = v3path.v3ReadTextFile(root, "artifacts/v3_bootstrap/cheng.stage3.contract.txt")
    if stage2Contract != stage3Contract:
        v3GatePrintErr("v3 gate: fixed point mismatch stage2/stage3 contract drift")
        return 1
    if !v3path.v3WriteTextFile(root, snapshot.bootstrapEnv.path, v3GateBootstrapEnvText(root, snapshot)):
        v3GatePrintErr("v3 gate: failed to write bootstrap env: " + snapshot.bootstrapEnv.path)
        return 1
    if !v3path.v3WriteTextFile(root,
                               contracts.v3BootstrapSnapshotPath(root),
                               v3GateBootstrapSnapshotText(root, snapshot)):
        v3GatePrintErr("v3 gate: failed to write bootstrap snapshot: " + contracts.v3BootstrapSnapshotPath(root))
        return 1
    v3GatePrintLine("v3 bootstrap bridge ok: " + snapshot.stage2Compiler.path)
    return 0

fn v3GateEnsureBootstrapBridge(root: str): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
    let stage3Mtime: int64 = os.fileMtime(snapshot.stage3Compiler.path)
    if contracts.v3BootstrapBridgeReady(snapshot) &&
       stage3Mtime > int64(0) &&
       os.fileMtime(snapshot.seedSource.path) <= stage3Mtime &&
       os.fileMtime(snapshot.stage1Source.path) <= stage3Mtime:
        return 0
    return v3GateBootstrapBridge(root)

fn v3GateBuildBackendDriver(root: str): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
    let outDir: str = v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver")
    if v3GateEnsureBootstrapBridge(root) != 0:
        return 1
    if !v3path.v3MkdirP(root, outDir):
        v3GatePrintErr("v3 gate: failed to create backend driver dir")
        return 1
    if !contracts.v3BootstrapArtifactReady(snapshot.stage2Compiler):
        v3GatePrintErr("v3 gate: missing stage2 compiler: " + snapshot.stage2Compiler.path)
        return 1
    if !v3path.v3PathFileExists(snapshot.stage1Source.path):
        v3GatePrintErr("v3 gate: missing stage1 source: " + snapshot.stage1Source.path)
        return 1
    if v3GateBootstrapStageRun(root,
                               "build_backend_driver",
                               snapshot.stage2Compiler.path,
                               [
                                   "compile-bootstrap",
                                   "--in:" + snapshot.stage1Source.path,
                                   "--out:" + snapshot.backendDriverOut.path,
                                   "--report-out:" + v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver/build_backend_driver_v3.compile.report.txt")
                               ],
                               "artifacts/v3_backend_driver/build_backend_driver_v3.log") != 0:
        return 1
    if !contracts.v3BootstrapArtifactReady(snapshot.backendDriverOut):
        v3GatePrintErr("v3 gate: missing backend driver output: " + snapshot.backendDriverOut.path)
        return 1
    if v3GateBootstrapStageRun(root,
                               "backend_driver_contract",
                               snapshot.backendDriverOut.path,
                               ["print-contract", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_backend_driver/build_backend_driver_v3.contract.txt") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "backend_driver_status",
                               snapshot.backendDriverOut.path,
                               ["status"],
                               "artifacts/v3_backend_driver/build_backend_driver_v3.status.txt") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "backend_driver_plan",
                               snapshot.backendDriverOut.path,
                               ["print-build-plan"],
                               "artifacts/v3_backend_driver/build_backend_driver_v3.plan.txt") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "reference_stage3_contract",
                               snapshot.stage3Compiler.path,
                               ["print-contract", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_backend_driver/reference_stage3.contract.txt") != 0:
        return 1
    let builtContract: str = v3path.v3ReadTextFile(root, "artifacts/v3_backend_driver/build_backend_driver_v3.contract.txt")
    let stage3Contract: str = v3path.v3ReadTextFile(root, "artifacts/v3_backend_driver/reference_stage3.contract.txt")
    if builtContract != stage3Contract:
        v3GatePrintErr("v3 gate: backend driver contract drift vs stage3: " + snapshot.backendDriverOut.path)
        return 1
    let report: str =
        "target=" + v3GateBootstrapTarget() + "\n" +
        "bootstrap_kind=v3_seed\n" +
        "compiler_class=ordinary_compiler\n" +
        "stage0_compiler=" + snapshot.stage0Compiler.path + "\n" +
        "stage1_compiler=" + snapshot.stage1Compiler.path + "\n" +
        "stage2_compiler=" + snapshot.stage2Compiler.path + "\n" +
        "stage3_compiler=" + snapshot.stage3Compiler.path + "\n" +
        "bootstrap_contract_source=" + snapshot.stage1Source.path + "\n" +
        "planned_entry_source=" + contracts.v3BootstrapCompilerEntrySourcePath(root) + "\n" +
        "planned_runtime_source=" + contracts.v3BootstrapCompilerRuntimeSourcePath(root) + "\n" +
        "planned_request_source=" + contracts.v3BootstrapCompilerRequestSourcePath(root) + "\n" +
        "materialized_source=" + snapshot.stage1Source.path + "\n" +
        "output=" + snapshot.backendDriverOut.path + "\n" +
        "contract_log=" + v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver/build_backend_driver_v3.contract.txt") + "\n" +
        "status_log=" + v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver/build_backend_driver_v3.status.txt") + "\n" +
        "plan_log=" + v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver/build_backend_driver_v3.plan.txt") + "\n" +
        "log=" + v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver/build_backend_driver_v3.log") + "\n"
    if !v3path.v3WriteTextFile(root,
                               "artifacts/v3_backend_driver/build_backend_driver_v3.report.txt",
                               report):
        v3GatePrintErr("v3 gate: failed to write backend driver report")
        return 1
    v3GatePrintLine("v3 backend driver ok: " + snapshot.backendDriverOut.path)
    return 0

fn v3GateScanHotpath(root: str): int32 =
    let hits: hotscan.V3ForbiddenHit[] = hotscan.v3ScanForbiddenSourceDir(root, "v3/src")
    let report: str = hotscan.v3ForbiddenHitReport(hits)
    v3GatePrintLine(strutil.strip(report))
    if hotscan.v3ForbiddenHitsOk(hits):
        return 0
    return 1

fn v3GateRunCRef(root: str): int32 =
    if !v3GateEnsureArtifactsDir(root):
        v3GatePrintErr("v3 gate: failed to create artifacts dir")
        return 1
    let outPath: str = v3path.v3PathAbsolute(root, "artifacts/v3_gate/c_ref_latest.txt")
    var args: str[] = []
    args.add("-C")
    args.add(v3path.v3PathAbsolute(root, "v3/bench/c_ref"))
    args.add("clean")
    args.add("run")
    let run: hostops.V3LoggedRun = hostops.v3RunProgramLogged(root, "c_ref", "make", args, [], root, 0, outPath)
    if len(strutil.strip(run.output)) > 0:
        v3GatePrintLine(strutil.strip(run.output))
    if !hostops.v3LoggedRunOk(run):
        v3GatePrintErr(hostops.v3LoggedRunSummary(run))
        return run.exitCode
    return 0

fn v3GateCompareBench(root: str, baselinePath: str, candidatePath: str, maxRatioMilli: int64): int32 =
    let pool: langintern.V3InternPool = langintern.v3InternPoolNew()
    let base: perfgate.V3BenchDataset = perfgate.v3BenchDatasetLoadFile(pool, baselinePath)
    let candidate: perfgate.V3BenchDataset = perfgate.v3BenchDatasetLoadFile(pool, candidatePath)
    let compare: perfgate.V3BenchCompare = perfgate.v3BenchCompare(base, candidate, maxRatioMilli)
    let report: str = perfgate.v3BenchCompareReport(pool, compare)
    v3GatePrintLine(strutil.strip(report))
    if compare.ok:
        return 0
    return 1

fn v3GateArgsContainFlag(args: str[], key: str): bool =
    for i in 0..<args.len:
        let arg = args[i]
        if arg == key:
            return true
        if strutil.startsWith(arg, key + ":"):
            return true
        if strutil.startsWith(arg, key + "="):
            return true
    return false

fn v3GateRunStage3Command(root: str,
                          label: str,
                          cmd: str,
                          args: str[],
                          logName: str,
                          injectContract: bool): int32 =
    if v3GateEnsureBootstrapBridge(root) != 0:
        return 1
    let stage3: str = contracts.v3BootstrapStage3Path(root)
    if !os.fileExists(stage3):
        v3GatePrintErr("v3 gate: missing stage3 compiler: " + stage3)
        return 1
    var stageArgs: str[] = []
    stageArgs.add(cmd)
    if injectContract && !v3GateArgsContainFlag(args, "--contract-in"):
        stageArgs.add("--contract-in:" + contracts.v3BootstrapStage1SourcePath(root))
    for i in 0..<args.len:
        stageArgs.add(args[i])
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                           label,
                                                           stage3,
                                                           stageArgs,
                                                           [],
                                                           root,
                                                           0,
                                                           "artifacts/v3_gate/" + logName)
    v3GateMaybePrintRunOutput(run)
    if v3GateRunFailed(run):
        return run.exitCode
    return 0

fn v3GateRunSmokes(root: str): int32 =
    if !v3GateEnsureArtifactsDir(root):
        v3GatePrintErr("v3 gate: failed to create artifacts dir")
        return 1
    if v3GateEnsureBootstrapBridge(root) != 0:
        return 1
    let stage1Source: str = contracts.v3BootstrapStage1SourcePath(root)
    var bins: str[] = []
    bins.add(contracts.v3BootstrapStage0Path(root))
    bins.add(contracts.v3BootstrapStage1Path(root))
    bins.add(contracts.v3BootstrapStage2Path(root))
    bins.add(contracts.v3BootstrapStage3Path(root))
    for i in 0..<bins.len:
        let binPath: str = bins[i]
        if !os.fileExists(binPath):
            v3GatePrintErr("v3 gate: missing bootstrap compiler: " + binPath)
            return 1
        let binParts: os.SplitFileResult = os.splitFile(binPath)
        let logPath: str = v3path.v3PathAbsolute(root, "artifacts/v3_gate/" + binParts.name + ".self-check.log")
        var args: str[] = []
        args.add("self-check")
        args.add("--in:" + stage1Source)
        let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root, binParts.name, binPath, args, [], root, 0, logPath)
        if len(strutil.strip(run.output)) > 0:
            v3GatePrintLine(strutil.strip(run.output))
        if !hostops.v3LoggedRunOk(run):
            v3GatePrintErr(hostops.v3LoggedRunSummary(run))
            return run.exitCode
    return 0

fn v3GateEnsureBackendDriverReady(root: str, outCompiler: var str): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
    outCompiler = snapshot.backendDriverOut.path
    if contracts.v3BootstrapArtifactReady(snapshot.backendDriverOut):
        return 0
    return v3GateBuildBackendDriver(root)

fn v3GateCompileExeEnv(root: str,
                       label: str,
                       compilerPath: str,
                       sourcePath: str,
                       outPath: str,
                       target: str,
                       logRelPath: str,
                       envOverrides: str[]): hostops.V3LoggedRun =
    let packageRoot: str = v3path.v3PathAbsolute(root, "v3")
    let outParts: os.SplitFileResult = os.splitFile(outPath)
    if len(outParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, outParts.dir)
    let logAbs: str = v3path.v3PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.splitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, logParts.dir)
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                           label,
                                                           compilerPath,
                                                           [
                                                               "system-link-exec",
                                                               "--root", packageRoot,
                                                               "--in", sourcePath,
                                                               "--emit", "exe",
                                                               "--target", target,
                                                               "--out", outPath
                                                           ],
                                                           envOverrides,
                                                           root,
                                                           int32(strutil.parseInt(os.getEnvDefault("CHENG_V3_COMPILE_TIMEOUT_SEC", "300"))),
                                                           logRelPath)
    return run

fn v3GateCompileExe(root: str,
                    label: str,
                    compilerPath: str,
                    sourcePath: str,
                    outPath: str,
                    target: str,
                    logRelPath: str): hostops.V3LoggedRun =
    return v3GateCompileExeEnv(root, label, compilerPath, sourcePath, outPath, target, logRelPath, [])

fn v3GateCompileExeSpawnEnv(root: str,
                            label: str,
                            compilerPath: str,
                            sourcePath: str,
                            outPath: str,
                            target: str,
                            logRelPath: str,
                            envOverrides: str[]): Result[hostops.V3ParallelJob] =
    let packageRoot: str = v3path.v3PathAbsolute(root, "v3")
    let outParts: os.SplitFileResult = os.splitFile(outPath)
    if len(outParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, outParts.dir)
    let logAbs: str = v3path.v3PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.splitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, logParts.dir)
    return hostops.v3ParallelSpawnFile(root,
                                       label,
                                       compilerPath,
                                       [
                                           "system-link-exec",
                                           "--root", packageRoot,
                                           "--in", sourcePath,
                                           "--emit", "exe",
                                           "--target", target,
                                           "--out", outPath
                                       ],
                                       envOverrides,
                                       root,
                                       logRelPath)

fn v3GateRunBinary(root: str,
                   label: str,
                   binPath: str,
                   args: str[],
                   timeoutSec: int32,
                   logRelPath: str): hostops.V3LoggedRun =
    let logAbs: str = v3path.v3PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.splitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, logParts.dir)
    return hostops.v3RunFileLogged(root, label, binPath, args, [], root, timeoutSec, logRelPath)

fn v3GateWriteProcessSnapshot(root: str,
                              proc: hostops.V3SpawnedProcess,
                              logRelPath: str,
                              exitCode: int32): hostops.V3LoggedRun =
    let logPath: str = v3path.v3PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.splitFile(logPath)
    if len(logParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, logParts.dir)
    let _logged: bool = v3path.v3WriteTextFile(root, logRelPath, proc.output)
    return hostops.V3LoggedRun(label: proc.label,
                               filePath: proc.filePath,
                               logPath: logPath,
                               exitCode: exitCode,
                               output: proc.output)

fn v3GateIsDigits(text: str): bool =
    if len(text) <= 0:
        return false
    for i in 0..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return false
    return true

fn v3GateWaitReadyPort(root: str,
                       readyPath: str,
                       proc: var hostops.V3SpawnedProcess,
                       outPort: var str): bool =
    outPort = ""
    root
    for i in 0..<400:
        i
        hostops.v3SpawnedProcessDrain(proc, 0)
        if os.fileExists(readyPath):
            let candidate = strutil.strip(v3path.v3ReadTextFile("", readyPath))
            if v3GateIsDigits(candidate):
                outPort = candidate
                return true
        let waitRes = os.ptyWait(proc.pid)
        if waitRes[0] == 1:
            proc.pid = 0
            hostops.v3SpawnedProcessDrain(proc, 0)
            return false
        if waitRes[0] < 0:
            proc.pid = 0
            hostops.v3SpawnedProcessDrain(proc, 0)
            return false
        os.sleepMs(50)
    return false

fn v3GateOutputContains(text: str, needle: str): bool =
    return strutil.contains(text, needle)

fn v3GateRequireOutput(run: hostops.V3LoggedRun,
                       needle: str,
                       context: str): bool =
    if v3GateOutputContains(run.output, needle):
        return true
    v3GatePrintErr(context + ": missing output: " + needle)
    if len(strutil.strip(run.output)) > 0:
        v3GatePrintErr(strutil.strip(run.output))
    return false

fn v3GateCollectPositionals(args: str[]): str[] =
    var out: str[] = []
    for i in 0..<args.len:
        let arg: str = args[i]
        if !strutil.startsWith(arg, "--"):
            out.add(arg)
    return out

fn v3GateRequireFile(path: str, context: str): bool =
    if os.fileExists(path):
        return true
    v3GatePrintErr(context + ": missing file: " + path)
    return false

fn v3GateRequireFileContains(path: str,
                             needle: str,
                             context: str): bool =
    if !v3GateRequireFile(path, context):
        return false
    let text: str = v3path.v3ReadTextFile("", path)
    if v3GateOutputContains(text, needle):
        return true
    v3GatePrintErr(context + ": missing output: " + needle)
    if len(strutil.strip(text)) > 0:
        v3GatePrintErr(strutil.strip(text))
    return false

fn v3GateRequirePrefixArtifacts(prefix: str,
                                suffixes: str[],
                                context: str): bool =
    for i in 0..<suffixes.len:
        if !v3GateRequireFile(prefix + suffixes[i], context):
            return false
    return true

fn v3GateRequireAnyOutput(text: str,
                          needles: str[],
                          context: str): bool =
    if v3GateTextContainsAny(text, needles):
        return true
    v3GatePrintErr(context + ": missing expected output set")
    if len(strutil.strip(text)) > 0:
        v3GatePrintErr(strutil.strip(text))
    return false

fn v3GateResolveSmokeCompiler(root: str,
                              explicitPath: str,
                              primaryEnvKey: str,
                              fallbackEnvKey: str,
                              outCompiler: var str): int32 =
    outCompiler = strutil.strip(explicitPath)
    if len(outCompiler) <= 0 && len(primaryEnvKey) > 0:
        outCompiler = strutil.strip(os.getEnvDefault(primaryEnvKey, ""))
    if len(outCompiler) <= 0 && len(fallbackEnvKey) > 0:
        outCompiler = strutil.strip(os.getEnvDefault(fallbackEnvKey, ""))
    if len(outCompiler) <= 0:
        return v3GateEnsureBackendDriverReady(root, outCompiler)
    outCompiler = v3path.v3PathAbsolute(root, outCompiler)
    if !os.fileExists(outCompiler):
        v3GatePrintErr("v3 gate: missing compiler: " + outCompiler)
        return 1
    return 0

fn v3GateResolveSmokeLabel(args: str[],
                           envKey: str,
                           defaultLabel: str): str =
    let explicit: str = strutil.strip(v3GateReadFlag(args, "--label", ""))
    if len(explicit) > 0:
        return explicit
    let keyed: str = strutil.strip(os.getEnvDefault(envKey, ""))
    if len(keyed) > 0:
        return keyed
    let shared: str = strutil.strip(os.getEnvDefault("CHENG_V3_SMOKE_LABEL", ""))
    if len(shared) > 0:
        return shared
    return defaultLabel

fn v3GateTextContainsAny(text: str, needles: str[]): bool =
    for i in 0..<needles.len:
        if v3path.v3TextContains(text, needles[i]):
            return true
    return false

fn v3GateVerifyOrphanGuard(root: str): int32 =
    let toolingDir: str = v3path.v3PathAbsolute(root, "v3/tooling")
    let bannedText: str[] = ["guarded_exec_v3.py", "orphan_guard_run.sh"]
    let bannedNames: str[] = ["guarded_exec_v3.py", "orphan_guard_run.sh"]
    let entries: str[] = os.walkDir(toolingDir)
    for i in 0..<entries.len:
        let entry: os.WalkDirEntry = os.walkDirEntry(entries, i)
        let kind: os.PathComponent = os.walkDirEntryKind(entry)
        if kind != os.PathComponent(0) &&
           kind != os.PathComponent(2):
            continue
        let path: str = os.walkDirEntryPath(entry)
        let parts: os.SplitFileResult = os.splitFile(path)
        if parts.ext != ".sh" && parts.ext != ".py":
            continue
        let fileName: str = parts.name + parts.ext
        if v3GateTextContainsAny(fileName, bannedNames):
            v3GatePrintErr("verify_orphan_guard_v3: banned tooling entry name: " + path)
            return 1
        let text: str = v3path.v3ReadTextFile("", path)
        if v3GateTextContainsAny(text, bannedText):
            v3GatePrintErr("verify_orphan_guard_v3: banned direct process guard ref in " + path)
            return 1
    v3GatePrintLine("verify_orphan_guard_v3 ok")
    return 0

