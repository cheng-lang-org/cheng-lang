fn v3GateStage23EnvOverrides(): str[] =
    return ["BACKEND_INCREMENTAL=0", "BACKEND_MULTI_MODULE_CACHE=0"]

fn v3GateSmokeRunTimeoutSec(): int32 =
    return int32(strutil.parseInt(os.getEnvDefault("CHENG_V3_SMOKE_RUN_TIMEOUT_SEC", "60")))

fn v3GateRunSingleFixtureSmoke(root: str,
                               suiteLabel: str,
                               compilerPath: str,
                               smokeName: str,
                               outBin: str,
                               stageLabel: str,
                               envOverrides: str[]): int32 =
    let src: str = v3path.v3PathAbsolute(root, "v3/src/tests/" + smokeName + ".cheng")
    if !os.fileExists(src):
        v3GatePrintErr(suiteLabel + ": missing source: " + src)
        return 1
    let compileLabel: str = suiteLabel + " compile " + stageLabel + " " + smokeName
    let runLabel: str = suiteLabel + " run " + stageLabel + " " + smokeName
    let compileRun = v3GateCompileExeEnv(root,
                                         compileLabel,
                                         compilerPath,
                                         src,
                                         outBin,
                                         "arm64-apple-darwin",
                                         outBin + ".compile.log",
                                         envOverrides)
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    let run = v3GateRunBinary(root,
                              runLabel,
                              outBin,
                              [],
                              v3GateSmokeRunTimeoutSec(),
                              outBin + ".run.log")
    v3GateMaybePrintRunOutput(run)
    if v3GateRunFailed(run):
        return run.exitCode
    return 0

fn v3GateRunTcpTwoprocSmoke(root: str,
                            compilerPath: str,
                            stageName: str,
                            envOverrides: str[]): int32 =
    let outDir: str = v3path.v3PathAbsolute(root, "artifacts/v3_tcp_twoproc")
    let serverSrc: str = v3path.v3PathAbsolute(root, "v3/src/tests/libp2p_tcp_twoproc_server_smoke.cheng")
    let clientSrc: str = v3path.v3PathAbsolute(root, "v3/src/tests/libp2p_tcp_twoproc_client_smoke.cheng")
    let serverBin: str = os.joinPath(outDir, "libp2p_tcp_twoproc_server." + stageName)
    let clientBin: str = os.joinPath(outDir, "libp2p_tcp_twoproc_client." + stageName)
    let readyPath: str = os.joinPath(outDir, "libp2p_tcp_twoproc_server." + stageName + ".ready")
    let _ = os.removeFile(readyPath)
    if !os.fileExists(serverSrc) || !os.fileExists(clientSrc):
        v3GatePrintErr("v3 libp2p tcp twoproc: missing source fixture")
        return 1
    let serverCompile = v3GateCompileExeEnv(root,
                                            "v3 libp2p tcp twoproc compile " + stageName + " server",
                                            compilerPath,
                                            serverSrc,
                                            serverBin,
                                            "arm64-apple-darwin",
                                            serverBin + ".compile.log",
                                            envOverrides)
    if v3GateRunFailed(serverCompile):
        return serverCompile.exitCode
    let clientCompile = v3GateCompileExeEnv(root,
                                            "v3 libp2p tcp twoproc compile " + stageName + " client",
                                            compilerPath,
                                            clientSrc,
                                            clientBin,
                                            "arm64-apple-darwin",
                                            clientBin + ".compile.log",
                                            envOverrides)
    if v3GateRunFailed(clientCompile):
        return clientCompile.exitCode
    let serverSpawn = hostops.v3SpawnFile(root,
                                          "v3 libp2p tcp twoproc server " + stageName,
                                          serverBin,
                                          ["--port:0", "--ready-path:" + readyPath],
                                          [],
                                          root)
    if IsErr(serverSpawn):
        v3GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var port = ""
    if !v3GateWaitReadyPort(root, readyPath, serverProc, port):
        let serverRun = v3GateWriteProcessSnapshot(root, serverProc, serverBin + ".run.log", 1)
        v3GatePrintErr("v3 libp2p tcp twoproc: invalid ready port: " + port)
        v3GateMaybePrintRunOutput(serverRun)
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    let clientRun = v3GateRunBinary(root,
                                    "v3 libp2p tcp twoproc client " + stageName,
                                    clientBin,
                                    ["--port:" + port],
                                    20,
                                    clientBin + ".run.log")
    if v3GateRunFailed(clientRun):
        let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 1, serverBin + ".run.log")
        v3GateMaybePrintRunOutput(serverRun)
        return clientRun.exitCode
    let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 20, serverBin + ".run.log")
    v3GateMaybePrintRunOutput(serverRun)
    if v3GateRunFailed(serverRun):
        return serverRun.exitCode
    v3GateMaybePrintRunOutput(clientRun)
    v3GatePrintLine("v3 libp2p_tcp_twoproc_smoke ok")
    return 0

fn v3GateRunQuicTwoprocSmoke(root: str,
                             compilerPath: str,
                             stageName: str,
