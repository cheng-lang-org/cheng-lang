fn v3GateBftRemoteBuildReadyCommand(repoRoot: str): str =
    let compiler = v3GateBftRemoteBackendDriver(repoRoot)
    let src = os.JoinPath(repoRoot, "v3/src/project/bft_state_machine_main.cheng")
    let outBin = v3GateBftRemoteBin(repoRoot)
    let runLog = v3GateBftRemoteRunLog(repoRoot)
    var command = ""
    command = command + "test -x " + os.QuoteShell(outBin)
    command = command + " && test -x " + os.QuoteShell(compiler)
    command = command + " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(outBin)
    command = command + " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(outBin)
    command = command + " && test " + os.QuoteShell(outBin) + " -ot " + os.QuoteShell(runLog)
    command = command + " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(runLog)
    command = command + " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(runLog)
    command = command + " && grep -qF " + os.QuoteShell("v3 bft_state_machine self-test ok")
    command = command + " " + os.QuoteShell(runLog)
    return command

fn v3GateBftRemoteStage3FreshCommand(repoRoot: str): str =
    let stage3 = v3GateBftRemoteStage3(repoRoot)
    let snapshot = v3GateBftRemoteSnapshot(repoRoot)
    let seed = os.JoinPath(repoRoot, "v3/bootstrap/cheng_v3_seed.c")
    let stage1 = os.JoinPath(repoRoot, "v3/bootstrap/stage1_bootstrap.cheng")
    let compilerMain = os.JoinPath(repoRoot, "v3/src/tooling/compiler_main.cheng")
    let compilerRuntime = os.JoinPath(repoRoot, "v3/src/tooling/compiler_runtime.cheng")
    let compilerRequest = os.JoinPath(repoRoot, "v3/src/tooling/compiler_request.cheng")
    let gateMain = os.JoinPath(repoRoot, "v3/src/tooling/gate_main.cheng")
    var command = ""
    command = command + "test -x " + os.QuoteShell(stage3)
    command = command + " && snapshot=" + os.QuoteShell(snapshot)
    command = command + " && stage3=" + os.QuoteShell(stage3)
    command = command + " && if [ -f \"$snapshot\" ]; then"
    command = command + " fresh=$(grep \"^fresh_input_paths=\" \"$snapshot\" | tail -n 1 | cut -d= -f2-);"
    command = command + " if [ -n \"$fresh\" ]; then"
    command = command + " old_ifs=\"$IFS\"; IFS=,; set -- $fresh; IFS=\"$old_ifs\";"
    command = command + " for input in \"$@\"; do"
    command = command + " if [ -n \"$input\" ] && ! test \"$input\" -ot \"$stage3\"; then exit 1; fi;"
    command = command + " done; exit 0; fi; fi"
    command = command + " && test " + os.QuoteShell(seed) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(stage1) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(compilerMain) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(compilerRuntime) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(compilerRequest) + " -ot \"$stage3\""
    command = command + " && test " + os.QuoteShell(gateMain) + " -ot \"$stage3\""
    return command

fn v3GateBftRemoteLockedShell(repoRoot: str,
                              innerCommand: str): str =
    var command = ""
    command = command + "set -eu && cd " + os.QuoteShell(repoRoot)
    command = command + " && mkdir -p artifacts/v3_gate"
    command = command + " && lock_dir=artifacts/v3_gate/bft_remote_build.lock"
    command = command + " && lock_pid=\"$lock_dir/pid\""
    command = command + " && while ! mkdir \"$lock_dir\" 2>/dev/null; do holder=\"\";"
    command = command + " if [ -f \"$lock_pid\" ]; then holder=$(cat \"$lock_pid\" 2>/dev/null || true); fi;"
    command = command + " if [ -z \"$holder\" ] || ! kill -0 \"$holder\" 2>/dev/null; then"
    command = command + " rm -f \"$lock_pid\" 2>/dev/null || true; rmdir \"$lock_dir\" 2>/dev/null || true; continue;"
    command = command + " fi; sleep 0.1; done"
    command = command + " && printf \"%s\\n\" \"$$\" > \"$lock_pid\""
    command = command + " && trap 'rm -f \"$lock_pid\" 2>/dev/null || true; rmdir \"$lock_dir\" 2>/dev/null || true' EXIT INT TERM"
    command = command + " && " + innerCommand
    return command

