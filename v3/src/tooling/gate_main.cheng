fn v3GateReadFlag(args: str[], key: str, defaultValue: str): str =
    for i in 0..<args.len:
        let arg: str = args[i]
        if strutil.startsWith(arg, key + ":"):
            return strings.dropPrefix(arg, key + ":")
        if strutil.startsWith(arg, key + "="):
            return strings.dropPrefix(arg, key + "=")
    return defaultValue

fn v3GateCollectArgsFrom(startIndex: int32, count: int32): str[] =
    var out: str[] = []
    if startIndex > count:
        return out
    for i in startIndex..count:
        add(out, cmdline.paramStr(i))
    return out

fn v3GateRunFailed(run: hostops.V3LoggedRun): bool =
    if hostops.v3LoggedRunOk(run):
        return false
    v3GatePrintErr(hostops.v3LoggedRunSummary(run))
    let outputText = strutil.strip(run.output)
    if len(outputText) > 0:
        v3GatePrintErr(outputText)
    return true

fn v3GateTextEndsWith(text: str, suffix: str): bool =
    if len(suffix) > len(text):
        return false
    let start = len(text) - len(suffix)
    for i in 0..<len(suffix):
        if text[start + i] != suffix[i]:
            return false
    return true

fn v3GateProviderSourcesAllPureCheng(paths: str[]): bool =
    if paths.len <= 0:
        return false
    for i in 0..<paths.len:
        if !v3GateTextEndsWith(paths[i], ".cheng"):
            return false
    return true

fn v3GateProviderSourcesContain(paths: str[], expected: str): bool =
    for i in 0..<paths.len:
        if paths[i] == expected:
            return true
    return false

fn v3GateVerifyPureChengProviderPlan(root: str,
                                     packageRoot: str,
                                     sourcePath: str,
                                     outputPath: str,
                                     target: str,
                                     expectedSources: str[]): bool =
    let req = creq.v3CompilerRequestNew(packageRoot,
                                        sourcePath,
                                        outputPath,
                                        target,
                                        creq.v3EmitExe,
                                        "")
    let planRes = sexec.v3BuildSystemLinkExecPlan(root, req)
    if IsErr(planRes):
        v3GatePrintErr("v3 pure provider plan: " + Error(planRes))
        return false
    let plan = Value(planRes)
    if !v3GateProviderSourcesAllPureCheng(plan.objectPlan.providerSourcePaths):
        v3GatePrintErr("v3 pure provider plan: non-Cheng provider source detected")
        return false
    for i in 0..<expectedSources.len:
        if !v3GateProviderSourcesContain(plan.objectPlan.providerSourcePaths, expectedSources[i]):
            v3GatePrintErr("v3 pure provider plan: missing provider source: " + expectedSources[i])
            return false
    return true

fn v3GateMaybePrintRunOutput(run: hostops.V3LoggedRun) =
    let outputText = strutil.strip(run.output)
    if len(outputText) > 0:
        v3GatePrintLine(outputText)

fn v3GateBootstrapOutDir(root: str): str =
    return contracts.v3BootstrapOutDir(root)

fn v3GateBootstrapLog(root: str, name: str): str =
    return v3path.v3PathAbsolute(root, "artifacts/v3_bootstrap/" + name)

fn v3GateBootstrapTarget(): str =
    var target = contracts.v3BootstrapDefaultTarget()
    let envTarget = os.getEnv("V3_TARGET")
    if len(envTarget) > 0:
        target = envTarget
    return target

fn v3GateBootstrapEnvText(root: str,
                          snapshot: contracts.V3BootstrapSnapshot): str =
    let outDir = v3GateBootstrapOutDir(root)
    var out = ""
    out = out + "V3_ROOT=" + root + "\n"
    out = out + "V3_TARGET=" + v3GateBootstrapTarget() + "\n"
    out = out + "V3_BOOTSTRAP_KIND=" + snapshot.bootstrapMode + "\n"
    out = out + "V3_BOOTSTRAP_STAGE1_SOURCE=" + snapshot.stage1Source.path + "\n"
    out = out + "V3_COMPILER_ENTRY_SOURCE=" + contracts.v3BootstrapCompilerEntrySourcePath(root) + "\n"
    out = out + "V3_COMPILER_RUNTIME_SOURCE=" + contracts.v3BootstrapCompilerRuntimeSourcePath(root) + "\n"
    out = out + "V3_COMPILER_REQUEST_SOURCE=" + contracts.v3BootstrapCompilerRequestSourcePath(root) + "\n"
    out = out + "V3_BOOTSTRAP_STAGE0=" + snapshot.stage0Compiler.path + "\n"
    out = out + "V3_BOOTSTRAP_STAGE1=" + snapshot.stage1Compiler.path + "\n"
    out = out + "V3_BOOTSTRAP_STAGE2=" + snapshot.stage2Compiler.path + "\n"
    out = out + "V3_BOOTSTRAP_STAGE3=" + snapshot.stage3Compiler.path + "\n"
    out = out + "V3_BOOTSTRAP_ENV=" + snapshot.bootstrapEnv.path + "\n"
    out = out + "V3_BOOTSTRAP_SNAPSHOT=" + contracts.v3BootstrapSnapshotPath(root) + "\n"
    out = out + "V3_BOOTSTRAP_STAGE1_REPORT=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage1.report.txt") + "\n"
    out = out + "V3_BOOTSTRAP_STAGE2_REPORT=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage2.report.txt") + "\n"
    out = out + "V3_BOOTSTRAP_STAGE3_REPORT=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage3.report.txt") + "\n"
    return out

fn v3GateBootstrapSnapshotText(root: str,
                               snapshot: contracts.V3BootstrapSnapshot): str =
    let outDir = v3GateBootstrapOutDir(root)
    var out = ""
    out = out + "target=" + v3GateBootstrapTarget() + "\n"
    out = out + "bootstrap_kind=" + snapshot.bootstrapMode + "\n"
    out = out + "stage1_source=" + snapshot.stage1Source.path + "\n"
    out = out + "compiler_entry_source=" + contracts.v3BootstrapCompilerEntrySourcePath(root) + "\n"
    out = out + "compiler_runtime_source=" + contracts.v3BootstrapCompilerRuntimeSourcePath(root) + "\n"
    out = out + "compiler_request_source=" + contracts.v3BootstrapCompilerRequestSourcePath(root) + "\n"
    out = out + "stage0=" + snapshot.stage0Compiler.path + "\n"
    out = out + "stage1=" + snapshot.stage1Compiler.path + "\n"
    out = out + "stage2=" + snapshot.stage2Compiler.path + "\n"
    out = out + "stage3=" + snapshot.stage3Compiler.path + "\n"
    out = out + "stage1_report=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage1.report.txt") + "\n"
    out = out + "stage2_report=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage2.report.txt") + "\n"
    out = out + "stage3_report=" + v3path.v3PathAbsolute(root, outDir + "/cheng.stage3.report.txt") + "\n"
    out = out + "stage0_build_log=" + v3GateBootstrapLog(root, "cheng.stage0.build.log") + "\n"
    out = out + "stage0_self_check_log=" + v3GateBootstrapLog(root, "cheng.stage0.self-check.log") + "\n"
    out = out + "stage1_build_log=" + v3GateBootstrapLog(root, "cheng.stage1.compile.log") + "\n"
    out = out + "stage1_self_check_log=" + v3GateBootstrapLog(root, "cheng.stage1.self-check.log") + "\n"
    out = out + "stage2_build_log=" + v3GateBootstrapLog(root, "cheng.stage2.compile.log") + "\n"
    out = out + "stage2_self_check_log=" + v3GateBootstrapLog(root, "cheng.stage2.self-check.log") + "\n"
    out = out + "stage3_build_log=" + v3GateBootstrapLog(root, "cheng.stage3.compile.log") + "\n"
    out = out + "stage3_self_check_log=" + v3GateBootstrapLog(root, "cheng.stage3.self-check.log") + "\n"
    out = out + "stage2_contract_log=" + v3GateBootstrapLog(root, "cheng.stage2.contract.txt") + "\n"
    out = out + "stage3_contract_log=" + v3GateBootstrapLog(root, "cheng.stage3.contract.txt") + "\n"
    out = out + "fixed_point=stage2_stage3_contract_match\n"
    return out

fn v3GateBootstrapStageRun(root: str,
                           label: str,
                           binPath: str,
                           args: str[],
                           logPath: str): int32 =
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root, label, binPath, args, [], root, 0, logPath)
    if v3GateRunFailed(run):
        return run.exitCode
    return 0

fn v3GateBootstrapCompilerPath(root: str,
                               snapshot: contracts.V3BootstrapSnapshot): str =
    let current: str = hostops.v3ResolveProgram(root, cmdline.programName())
    if v3path.v3FileExistsNonEmpty(root, current):
        return current
    if contracts.v3BootstrapArtifactReady(snapshot.stage3Compiler):
        return snapshot.stage3Compiler.path
    if contracts.v3BootstrapArtifactReady(snapshot.stage2Compiler):
        return snapshot.stage2Compiler.path
    if contracts.v3BootstrapArtifactReady(snapshot.stage1Compiler):
        return snapshot.stage1Compiler.path
    if contracts.v3BootstrapArtifactReady(snapshot.stage0Compiler):
        return snapshot.stage0Compiler.path
    return ""

fn v3GateBootstrapMaterializeStage0(root: str,
                                    snapshot: contracts.V3BootstrapSnapshot,
                                    compilerPath: str): bool =
    if !v3path.v3PathNonEmpty(compilerPath):
        return false
    if compilerPath == snapshot.stage0Compiler.path &&
       contracts.v3BootstrapArtifactReady(snapshot.stage0Compiler):
        return v3path.v3WriteTextFile(root,
                                      "artifacts/v3_bootstrap/cheng.stage0.build.log",
                                      "stage0_reused_from=" + compilerPath + "\n")
    let copyRun = hostops.v3RunProgramLogged(root,
                                             "bootstrap_stage0_copy",
                                             "cp",
                                             [compilerPath, snapshot.stage0Compiler.path],
                                             [],
                                             root,
                                             0,
                                             "artifacts/v3_bootstrap/cheng.stage0.materialize.log")
    if v3GateRunFailed(copyRun):
        return false
    let chmodRun = hostops.v3RunProgramLogged(root,
                                              "bootstrap_stage0_chmod",
                                              "chmod",
                                              ["755", snapshot.stage0Compiler.path],
                                              [],
                                              root,
                                              0,
                                              "artifacts/v3_bootstrap/cheng.stage0.materialize.log")
    if v3GateRunFailed(chmodRun):
        return false
    if !contracts.v3BootstrapArtifactReady(snapshot.stage0Compiler):
        return false
    return v3path.v3WriteTextFile(root,
                                  "artifacts/v3_bootstrap/cheng.stage0.build.log",
                                  "stage0_materialized_from=" + compilerPath + "\n")

fn v3GateBootstrapBridge(root: str): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
    let outDir: str = v3GateBootstrapOutDir(root)
    let bootstrapCompiler: str = v3GateBootstrapCompilerPath(root, snapshot)
    if !v3path.v3MkdirP(root, outDir):
        v3GatePrintErr("v3 gate: failed to create bootstrap dir")
        return 1
    if !v3path.v3PathFileExists(snapshot.stage1Source.path):
        v3GatePrintErr("v3 gate: missing stage1 source: " + snapshot.stage1Source.path)
        return 1
    if !v3path.v3PathNonEmpty(bootstrapCompiler):
        v3GatePrintErr("v3 gate: missing live bootstrap compiler")
        return 1
    if !v3GateBootstrapMaterializeStage0(root, snapshot, bootstrapCompiler):
        v3GatePrintErr("v3 gate: failed to materialize stage0 compiler: " + bootstrapCompiler)
        return 1
    if !contracts.v3BootstrapArtifactReady(snapshot.stage0Compiler):
        v3GatePrintErr("v3 gate: missing stage0 compiler: " + snapshot.stage0Compiler.path)
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage0_self_check",
                               snapshot.stage0Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage0.self-check.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage1_compile",
                               snapshot.stage0Compiler.path,
                               [
                                   "compile-bootstrap",
                                   "--in:" + snapshot.stage1Source.path,
                                   "--out:" + snapshot.stage1Compiler.path,
                                   "--report-out:" + v3GateBootstrapLog(root, "cheng.stage1.report.txt")
                               ],
                               "artifacts/v3_bootstrap/cheng.stage1.compile.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage1_self_check",
                               snapshot.stage1Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage1.self-check.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage2_compile",
                               snapshot.stage1Compiler.path,
                               [
                                   "compile-bootstrap",
                                   "--in:" + snapshot.stage1Source.path,
                                   "--out:" + snapshot.stage2Compiler.path,
                                   "--report-out:" + v3GateBootstrapLog(root, "cheng.stage2.report.txt")
                               ],
                               "artifacts/v3_bootstrap/cheng.stage2.compile.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage2_self_check",
                               snapshot.stage2Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage2.self-check.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage3_compile",
                               snapshot.stage2Compiler.path,
                               [
                                   "compile-bootstrap",
                                   "--in:" + snapshot.stage1Source.path,
                                   "--out:" + snapshot.stage3Compiler.path,
                                   "--report-out:" + v3GateBootstrapLog(root, "cheng.stage3.report.txt")
                               ],
                               "artifacts/v3_bootstrap/cheng.stage3.compile.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage3_self_check",
                               snapshot.stage3Compiler.path,
                               ["self-check", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage3.self-check.log") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage2_contract",
                               snapshot.stage2Compiler.path,
                               ["print-contract", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage2.contract.txt") != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "stage3_contract",
                               snapshot.stage3Compiler.path,
                               ["print-contract", "--in:" + snapshot.stage1Source.path],
                               "artifacts/v3_bootstrap/cheng.stage3.contract.txt") != 0:
        return 1
    let stage2Contract: str = v3path.v3ReadTextFile(root, "artifacts/v3_bootstrap/cheng.stage2.contract.txt")
    let stage3Contract: str = v3path.v3ReadTextFile(root, "artifacts/v3_bootstrap/cheng.stage3.contract.txt")
    if stage2Contract != stage3Contract:
        v3GatePrintErr("v3 gate: fixed point mismatch stage2/stage3 contract drift")
        return 1
    if !v3path.v3WriteTextFile(root, snapshot.bootstrapEnv.path, v3GateBootstrapEnvText(root, snapshot)):
        v3GatePrintErr("v3 gate: failed to write bootstrap env: " + snapshot.bootstrapEnv.path)
        return 1
    if !v3path.v3WriteTextFile(root,
                               contracts.v3BootstrapSnapshotPath(root),
                               v3GateBootstrapSnapshotText(root, snapshot)):
        v3GatePrintErr("v3 gate: failed to write bootstrap snapshot: " + contracts.v3BootstrapSnapshotPath(root))
        return 1
    v3GatePrintLine("v3 bootstrap bridge ok: " + snapshot.stage2Compiler.path)
    return 0

fn v3GateEnsureBootstrapBridge(root: str): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
    let stage3Mtime: int64 = os.fileMtime(snapshot.stage3Compiler.path)
    if contracts.v3BootstrapBridgeReady(snapshot) &&
       stage3Mtime > int64(0) &&
       os.fileMtime(contracts.v3BootstrapSeedSourcePath(root)) <= stage3Mtime &&
       os.fileMtime(snapshot.stage1Source.path) <= stage3Mtime &&
       os.fileMtime(contracts.v3BootstrapCompilerEntrySourcePath(root)) <= stage3Mtime &&
       os.fileMtime(contracts.v3BootstrapCompilerRuntimeSourcePath(root)) <= stage3Mtime &&
       os.fileMtime(contracts.v3BootstrapCompilerRequestSourcePath(root)) <= stage3Mtime &&
       os.fileMtime(contracts.v3BootstrapGateMainSourcePath(root)) <= stage3Mtime:
        return 0
    return v3GateBootstrapBridge(root)

fn v3GateBuildBackendDriver(root: str): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
    let outDir: str = v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver")
    let packageRoot: str = v3path.v3PathAbsolute(root, "v3")
    let compilerEntrySource: str = contracts.v3BootstrapCompilerEntrySourcePath(root)
    let compileReportPath: str =
        v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver/build_backend_driver_v3.compile.report.txt")
    let compileLogPath: str =
        "artifacts/v3_backend_driver/build_backend_driver_v3.log"
    let statusLogPath: str =
        "artifacts/v3_backend_driver/build_backend_driver_v3.status.txt"
    let planLogPath: str =
        "artifacts/v3_backend_driver/build_backend_driver_v3.plan.txt"
    let referencePlanLogPath: str =
        "artifacts/v3_backend_driver/reference_stage3.plan.txt"
    let smokeSource: str = v3path.v3PathAbsolute(root, "v3/src/tests/ordinary_zero_exit_fixture.cheng")
    let smokeOut: str = v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver/ordinary_zero_exit_fixture.selftest")
    let smokeCompileReportPath: str = smokeOut + ".report.txt"
    let smokeCompileLogPath: str =
        "artifacts/v3_backend_driver/ordinary_zero_exit_fixture.selftest.compile.log"
    let smokeRunLogPath: str =
        "artifacts/v3_backend_driver/ordinary_zero_exit_fixture.selftest.run.log"
    if v3GateEnsureBootstrapBridge(root) != 0:
        return 1
    if !v3path.v3MkdirP(root, outDir):
        v3GatePrintErr("v3 gate: failed to create backend driver dir")
        return 1
    if !contracts.v3BootstrapArtifactReady(snapshot.stage2Compiler):
        v3GatePrintErr("v3 gate: missing stage2 compiler: " + snapshot.stage2Compiler.path)
        return 1
    if !v3path.v3PathFileExists(compilerEntrySource):
        v3GatePrintErr("v3 gate: missing compiler entry source: " + compilerEntrySource)
        return 1
    if v3GateBootstrapStageRun(root,
                               "build_backend_driver",
                               snapshot.stage2Compiler.path,
                               [
                                   "system-link-exec",
                                   "--root:" + packageRoot,
                                   "--in:" + compilerEntrySource,
                                   "--emit:exe",
                                   "--target:" + snapshot.targetTriple,
                                   "--out:" + snapshot.backendDriverOut.path,
                                   "--report-out:" + compileReportPath
                               ],
                               compileLogPath) != 0:
        return 1
    if !contracts.v3BootstrapArtifactReady(snapshot.backendDriverOut):
        v3GatePrintErr("v3 gate: missing backend driver output: " + snapshot.backendDriverOut.path)
        return 1
    if v3GateBootstrapStageRun(root,
                               "backend_driver_status",
                               snapshot.backendDriverOut.path,
                               ["status"],
                               statusLogPath) != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "backend_driver_plan",
                               snapshot.backendDriverOut.path,
                               ["print-build-plan"],
                               planLogPath) != 0:
        return 1
    if v3GateBootstrapStageRun(root,
                               "reference_stage3_plan",
                               snapshot.stage3Compiler.path,
                               ["print-build-plan"],
                               referencePlanLogPath) != 0:
        return 1
    let builtPlan: str = v3path.v3ReadTextFile(root, planLogPath)
    let stage3Plan: str = v3path.v3ReadTextFile(root, referencePlanLogPath)
    if v3GateBuildPlanComparableText(builtPlan) != v3GateBuildPlanComparableText(stage3Plan):
        v3GatePrintErr("v3 gate: backend driver build plan drift vs stage3: " + snapshot.backendDriverOut.path)
        return 1
    if v3GateBootstrapStageRun(root,
                               "backend_driver_zero_exit_compile",
                               snapshot.backendDriverOut.path,
                               [
                                   "system-link-exec",
                                   "--root:" + packageRoot,
                                   "--in:" + smokeSource,
                                   "--emit:exe",
                                   "--target:" + snapshot.targetTriple,
                                   "--out:" + smokeOut,
                                   "--report-out:" + smokeCompileReportPath
                               ],
                               smokeCompileLogPath) != 0:
        return 1
    if !v3path.v3PathFileExists(smokeOut) || !v3path.v3PathFileExists(smokeOut + ".v3.map"):
        v3GatePrintErr("v3 gate: backend driver zero-exit smoke missing output: " + smokeOut)
        return 1
    if v3GateBootstrapStageRun(root,
                               "backend_driver_zero_exit_run",
                               smokeOut,
                               [],
                               smokeRunLogPath) != 0:
        return 1
    if v3path.v3ReadTextFile(root, smokeRunLogPath) != "":
        v3GatePrintErr("v3 gate: backend driver zero-exit smoke expected empty stdout: " + smokeRunLogPath)
        return 1
    var report = ""
    report = report + "target=" + v3GateBootstrapTarget() + "\n"
    report = report + "bootstrap_kind=" + snapshot.bootstrapMode + "\n"
    report = report + "compiler_class=ordinary_compiler\n"
    report = report + "stage0_compiler=" + snapshot.stage0Compiler.path + "\n"
    report = report + "stage1_compiler=" + snapshot.stage1Compiler.path + "\n"
    report = report + "stage2_compiler=" + snapshot.stage2Compiler.path + "\n"
    report = report + "stage3_compiler=" + snapshot.stage3Compiler.path + "\n"
    report = report + "bootstrap_contract_source=" + snapshot.stage1Source.path + "\n"
    report = report + "planned_entry_source=" + compilerEntrySource + "\n"
    report = report + "planned_runtime_source=" + contracts.v3BootstrapCompilerRuntimeSourcePath(root) + "\n"
    report = report + "planned_request_source=" + contracts.v3BootstrapCompilerRequestSourcePath(root) + "\n"
    report = report + "materialized_source=" + compilerEntrySource + "\n"
    report = report + "output=" + snapshot.backendDriverOut.path + "\n"
    report = report + "status_log=" + v3path.v3PathAbsolute(root, statusLogPath) + "\n"
    report = report + "plan_log=" + v3path.v3PathAbsolute(root, planLogPath) + "\n"
    report = report + "reference_plan_log=" + v3path.v3PathAbsolute(root, referencePlanLogPath) + "\n"
    report = report + "log=" + v3path.v3PathAbsolute(root, compileLogPath) + "\n"
    report = report + "zero_exit_smoke_source=" + smokeSource + "\n"
    report = report + "zero_exit_smoke_output=" + smokeOut + "\n"
    report = report + "zero_exit_smoke_report=" + smokeCompileReportPath + "\n"
    report = report + "zero_exit_smoke_compile_log=" + v3path.v3PathAbsolute(root, smokeCompileLogPath) + "\n"
    report = report + "zero_exit_smoke_run_log=" + v3path.v3PathAbsolute(root, smokeRunLogPath) + "\n"
    if !v3path.v3WriteTextFile(root,
                               "artifacts/v3_backend_driver/build_backend_driver_v3.report.txt",
                               report):
        v3GatePrintErr("v3 gate: failed to write backend driver report")
        return 1
    v3GatePrintLine("v3 backend driver ok: " + snapshot.backendDriverOut.path)
    return 0

fn v3GateScanHotpath(root: str): int32 =
    let hits: hotscan.V3ForbiddenHit[] = hotscan.v3ScanForbiddenSourceDir(root, "v3/src")
    let report: str = hotscan.v3ForbiddenHitReport(hits)
    v3GatePrintLine(strutil.strip(report))
    if hotscan.v3ForbiddenHitsOk(hits):
        return 0
    return 1

fn v3GateRunCRef(root: str): int32 =
    if !v3GateEnsureArtifactsDir(root):
        v3GatePrintErr("v3 gate: failed to create artifacts dir")
        return 1
    let outPath: str = v3path.v3PathAbsolute(root, "artifacts/v3_gate/c_ref_latest.txt")
    var args: str[] = []
    add(args, "-C")
    add(args, v3path.v3PathAbsolute(root, "v3/bench/c_ref"))
    add(args, "clean")
    add(args, "run")
    let run: hostops.V3LoggedRun = hostops.v3RunProgramLogged(root, "c_ref", "make", args, [], root, 0, outPath)
    let outputText = strutil.strip(run.output)
    if len(outputText) > 0:
        v3GatePrintLine(outputText)
    if !hostops.v3LoggedRunOk(run):
        v3GatePrintErr(hostops.v3LoggedRunSummary(run))
        return run.exitCode
    return 0

fn v3GateCompareBench(root: str, baselinePath: str, candidatePath: str, maxRatioMilli: int64): int32 =
    let pool: langintern.V3InternPool = langintern.v3InternPoolNew()
    let base: perfgate.V3BenchDataset = perfgate.v3BenchDatasetLoadFile(pool, baselinePath)
    let candidate: perfgate.V3BenchDataset = perfgate.v3BenchDatasetLoadFile(pool, candidatePath)
    let compare: perfgate.V3BenchCompare = perfgate.v3BenchCompare(base, candidate, maxRatioMilli)
    let report: str = perfgate.v3BenchCompareReport(pool, compare)
    v3GatePrintLine(strutil.strip(report))
    if compare.ok:
        return 0
    return 1

fn v3GateArgsContainFlag(args: str[], key: str): bool =
    for i in 0..<args.len:
        let arg = args[i]
        if arg == key:
            return true
        if strutil.startsWith(arg, key + ":"):
            return true
        if strutil.startsWith(arg, key + "="):
            return true
    return false

fn v3GateRunStage3Command(root: str,
                          label: str,
                          cmd: str,
                          args: str[],
                          logName: str,
                          injectContract: bool): int32 =
    if v3GateEnsureBootstrapBridge(root) != 0:
        return 1
    let stage3: str = contracts.v3BootstrapStage3Path(root)
    if !os.fileExists(stage3):
        v3GatePrintErr("v3 gate: missing stage3 compiler: " + stage3)
        return 1
    var stageArgs: str[] = []
    add(stageArgs, cmd)
    if injectContract && !v3GateArgsContainFlag(args, "--contract-in"):
        add(stageArgs, "--contract-in:" + contracts.v3BootstrapStage1SourcePath(root))
    for i in 0..<args.len:
        add(stageArgs, args[i])
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                           label,
                                                           stage3,
                                                           stageArgs,
                                                           [],
                                                           root,
                                                           0,
                                                           "artifacts/v3_gate/" + logName)
    v3GateMaybePrintRunOutput(run)
    if v3GateRunFailed(run):
        return run.exitCode
    return 0

fn v3GateRunStage3CommandWithEnv(root: str,
                                 label: str,
                                 cmd: str,
                                 args: str[],
                                 logName: str,
                                 injectContract: bool,
                                 envOverrides: str[]): int32 =
    if v3GateEnsureBootstrapBridge(root) != 0:
        return 1
    let stage3: str = contracts.v3BootstrapStage3Path(root)
    if !os.fileExists(stage3):
        v3GatePrintErr("v3 gate: missing stage3 compiler: " + stage3)
        return 1
    var stageArgs: str[] = []
    add(stageArgs, cmd)
    if injectContract && !v3GateArgsContainFlag(args, "--contract-in"):
        add(stageArgs, "--contract-in:" + contracts.v3BootstrapStage1SourcePath(root))
    for i in 0..<args.len:
        add(stageArgs, args[i])
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                           label,
                                                           stage3,
                                                           stageArgs,
                                                           envOverrides,
                                                           root,
                                                           0,
                                                           "artifacts/v3_gate/" + logName)
    v3GateMaybePrintRunOutput(run)
    if v3GateRunFailed(run):
        return run.exitCode
    return 0

fn v3GateRunSmokes(root: str): int32 =
    if !v3GateEnsureArtifactsDir(root):
        v3GatePrintErr("v3 gate: failed to create artifacts dir")
        return 1
    if v3GateEnsureBootstrapBridge(root) != 0:
        return 1
    let stage1Source: str = contracts.v3BootstrapStage1SourcePath(root)
    var bins: str[] = []
    add(bins, contracts.v3BootstrapStage0Path(root))
    add(bins, contracts.v3BootstrapStage1Path(root))
    add(bins, contracts.v3BootstrapStage2Path(root))
    add(bins, contracts.v3BootstrapStage3Path(root))
    for i in 0..<bins.len:
        let binPath: str = bins[i]
        if !os.fileExists(binPath):
            v3GatePrintErr("v3 gate: missing bootstrap compiler: " + binPath)
            return 1
        let binParts: os.SplitFileResult = os.splitFile(binPath)
        let logPath: str = v3path.v3PathAbsolute(root, "artifacts/v3_gate/" + binParts.name + ".self-check.log")
        var args: str[] = []
        add(args, "self-check")
        add(args, "--in:" + stage1Source)
        let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                               binParts.name,
                                                               binPath,
                                                               args,
                                                               [],
                                                               root,
                                                               0,
                                                               logPath)
        let outputText = strutil.strip(run.output)
        if len(outputText) > 0:
            v3GatePrintLine(outputText)
        if !hostops.v3LoggedRunOk(run):
            v3GatePrintErr(hostops.v3LoggedRunSummary(run))
            return run.exitCode
    return 0

fn v3GateVerifyTcpBioLinuxRegression(root: str): int32 =
    v3GatePrintLine("[v3 gate] tcp/bio/linux early regression: bio_same_person_smoke")
    if v3GateRunHostSmokes(root, ["bio_same_person_smoke"]) != 0:
        return 1
    v3GatePrintLine("[v3 gate] tcp/bio/linux early regression: chain_node linux exe")
    return v3GateRunStage3CommandWithEnv(root,
                                         "build_chain_node_linux_regression",
                                         "build-chain-node-linux",
                                         [],
                                         "build_chain_node_linux_regression.log",
                                         false,
                                         ["CHAIN_NODE_LINUX_ARTIFACT=exe", "CHAIN_NODE_RUN_SELF_TEST=0"])

fn v3GateEnsureBackendDriverReady(root: str, outCompiler: var str): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
    outCompiler = snapshot.backendDriverOut.path
    if contracts.v3BootstrapArtifactReady(snapshot.backendDriverOut):
        return 0
    return v3GateBuildBackendDriver(root)

fn v3GateVerifyX86LinuxRemote(root: str): int32 =
    var compiler = ""
    if v3GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let run = v3GateRunBinary(root,
                              "verify_x86_linux_remote",
                              compiler,
                              ["verify-x86-linux-remote"],
                              1800,
                              "artifacts/v3_gate/verify_x86_linux_remote.log")
    v3GateMaybePrintRunOutput(run)
    if v3GateRunFailed(run):
        return run.exitCode
    return 0

fn v3GateEnsureCompilerReady(root: str, compilerPath: str, outCompiler: var str): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
    outCompiler = v3path.v3PathAbsolute(root, compilerPath)
    if outCompiler == snapshot.backendDriverOut.path:
        if !os.fileExists(outCompiler):
            return v3GateEnsureBackendDriverReady(root, outCompiler)
        return 0
    if outCompiler == snapshot.stage0Compiler.path ||
       outCompiler == snapshot.stage1Compiler.path ||
       outCompiler == snapshot.stage2Compiler.path ||
       outCompiler == snapshot.stage3Compiler.path:
        if !os.fileExists(outCompiler):
            return v3GateEnsureBootstrapBridge(root)
        return 0
    if os.fileExists(outCompiler):
        return 0
    v3GatePrintErr("v3 gate: missing compiler: " + outCompiler)
    return 1

fn v3GateCompileExeEnv(root: str,
                       label: str,
                       compilerPath: str,
                       sourcePath: str,
                       outPath: str,
                       target: str,
                       logRelPath: str,
                       envOverrides: str[]): hostops.V3LoggedRun =
    let packageRoot = v3path.v3PathAbsolute(root, "v3")
    var compilerAbs: str = ""
    let outParts: os.SplitFileResult = os.splitFile(outPath)
    if len(outParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, outParts.dir)
    let logAbs: str = v3path.v3PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.splitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, logParts.dir)
    if v3GateEnsureCompilerReady(root, compilerPath, compilerAbs) != 0:
        return hostops.v3LoggedRunZero(label,
                                       compilerAbs,
                                       logAbs,
                                       1,
                                       "v3 gate: compiler missing during compile: " + compilerAbs + "\n")
    let timeoutText = os.getEnvDefault("CHENG_V3_COMPILE_TIMEOUT_SEC", "300")
    let timeoutSec = int32(strutil.parseInt(timeoutText))
    let run = hostops.v3RunFileLogged(root,
                                      label,
                                      compilerAbs,
                                      [
                                          "system-link-exec",
                                          "--root", packageRoot,
                                          "--in", sourcePath,
                                          "--emit", "exe",
                                          "--target", target,
                                          "--out", outPath
                                      ],
                                      envOverrides,
                                      root,
                                      timeoutSec,
                                      logRelPath)
    if hostops.v3LoggedRunOk(run) && !os.fileExists(outPath):
        let outputText = run.output + "v3 gate: compile missing output: " + outPath + "\n"
        let _logged: bool = v3path.v3WriteTextFile(root, logAbs, outputText)
        return hostops.v3LoggedRunZero(label, compilerAbs, logAbs, 1, outputText)
    return run

fn v3GateCompileExe(root: str,
                    label: str,
                    compilerPath: str,
                    sourcePath: str,
                    outPath: str,
                    target: str,
                    logRelPath: str): hostops.V3LoggedRun =
    return v3GateCompileExeEnv(root, label, compilerPath, sourcePath, outPath, target, logRelPath, [])

fn v3GateCompileExeEnvAtRoot(root: str,
                             label: str,
                             compilerPath: str,
                             packageRoot: str,
                             sourcePath: str,
                             outPath: str,
                             target: str,
                             logRelPath: str,
                             envOverrides: str[]): hostops.V3LoggedRun =
    var compilerAbs: str = ""
    let outParts: os.SplitFileResult = os.splitFile(outPath)
    if len(outParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, outParts.dir)
    let logAbs: str = v3path.v3PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.splitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, logParts.dir)
    if v3GateEnsureCompilerReady(root, compilerPath, compilerAbs) != 0:
        return hostops.v3LoggedRunZero(label,
                                       compilerAbs,
                                       logAbs,
                                       1,
                                       "v3 gate: compiler missing during compile: " + compilerAbs + "\n")
    let timeoutText = os.getEnvDefault("CHENG_V3_COMPILE_TIMEOUT_SEC", "300")
    let timeoutSec = int32(strutil.parseInt(timeoutText))
    let run = hostops.v3RunFileLogged(root,
                                      label,
                                      compilerAbs,
                                      [
                                          "system-link-exec",
                                          "--root", packageRoot,
                                          "--in", sourcePath,
                                          "--emit", "exe",
                                          "--target", target,
                                          "--out", outPath
                                      ],
                                      envOverrides,
                                      root,
                                      timeoutSec,
                                      logRelPath)
    if hostops.v3LoggedRunOk(run) && !os.fileExists(outPath):
        let outputText = run.output + "v3 gate: compile missing output: " + outPath + "\n"
        let _logged: bool = v3path.v3WriteTextFile(root, logAbs, outputText)
        return hostops.v3LoggedRunZero(label, compilerAbs, logAbs, 1, outputText)
    return run

fn v3GateCompileExeSpawnEnv(root: str,
                            label: str,
                            compilerPath: str,
                            sourcePath: str,
                            outPath: str,
                            target: str,
                            logRelPath: str,
                            envOverrides: str[]): Result[hostops.V3ParallelJob] =
    let packageRoot: str = v3path.v3PathAbsolute(root, "v3")
    let outParts: os.SplitFileResult = os.splitFile(outPath)
    if len(outParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, outParts.dir)
    let logAbs: str = v3path.v3PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.splitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, logParts.dir)
    return hostops.v3ParallelSpawnFile(root,
                                       label,
                                       compilerPath,
                                       [
                                           "system-link-exec",
                                           "--root", packageRoot,
                                           "--in", sourcePath,
                                           "--emit", "exe",
                                           "--target", target,
                                           "--out", outPath
                                       ],
                                       envOverrides,
                                       root,
                                       logRelPath)

fn v3GateRunBinary(root: str,
                   label: str,
                   binPath: str,
                   args: str[],
                   timeoutSec: int32,
                   logRelPath: str): hostops.V3LoggedRun =
    let logAbs: str = v3path.v3PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.splitFile(logAbs)
    if len(logParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, logParts.dir)
    return hostops.v3RunFileLogged(root, label, binPath, args, [], root, timeoutSec, logRelPath)

fn v3GateWriteProcessSnapshot(root: str,
                              proc: hostops.V3SpawnedProcess,
                              logRelPath: str,
                              exitCode: int32): hostops.V3LoggedRun =
    let logPath: str = v3path.v3PathAbsolute(root, logRelPath)
    let logParts: os.SplitFileResult = os.splitFile(logPath)
    if len(logParts.dir) > 0:
        let _ = v3path.v3MkdirP(root, logParts.dir)
    let _logged: bool = v3path.v3WriteTextFile(root, logRelPath, proc.output)
    return hostops.V3LoggedRun(label: proc.label,
                               filePath: proc.filePath,
                               logPath: logPath,
                               exitCode: exitCode,
                               output: proc.output)

fn v3GateIsDigits(text: str): bool =
    if len(text) <= 0:
        return false
    for i in 0..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return false
    return true

fn v3GateWaitReadyPort(root: str,
                       readyPath: str,
                       proc: var hostops.V3SpawnedProcess,
                       outPort: var str): bool =
    outPort = ""
    root
    for i in 0..<400:
        i
        hostops.v3SpawnedProcessDrain(proc, 0)
        if os.fileExists(readyPath):
            let candidate = strutil.strip(v3path.v3ReadTextFile("", readyPath))
            if v3GateIsDigits(candidate):
                outPort = candidate
                return true
        if !hostops.v3SpawnedProcessRunning(proc):
            return false
        os.sleepMs(50)
    return false

fn v3GateOutputContains(text: str, needle: str): bool =
    return strutil.contains(text, needle)

fn v3GateOutputLineValue(text: str, key: str): str =
    let prefix = key + "="
    var start: int32 = 0
    var i: int32 = 0
    while i <= text.len:
        if i == text.len || text[i] == '\n':
            let line = strings.sliceBytes(text, start, i - start)
            if strutil.startsWith(line, prefix):
                return strings.sliceBytes(line, prefix.len, line.len - prefix.len)
            start = i + 1
        i = i + 1
    return ""

fn v3GateBuildPlanLineRelevant(line: str): bool =
    return strutil.startsWith(line, "target=") ||
           strutil.startsWith(line, "linker=") ||
           strutil.startsWith(line, "stage2_compiler=") ||
           strutil.startsWith(line, "entry=") ||
           strutil.startsWith(line, "output=") ||
           strutil.startsWith(line, "source[")

fn v3GateBuildPlanComparableText(text: str): str =
    var out = ""
    var start: int32 = 0
    var i: int32 = 0
    while i <= text.len:
        if i == text.len || text[i] == '\n':
            let line = strings.sliceBytes(text, start, i - start)
            if v3GateBuildPlanLineRelevant(line):
                out = out + line + "\n"
            start = i + 1
        i = i + 1
    return out

fn v3GateRequireOutput(run: hostops.V3LoggedRun,
                       needle: str,
                       context: str): bool =
    if v3GateOutputContains(run.output, needle):
        return true
    v3GatePrintErr(context + ": missing output: " + needle)
    let outputText = strutil.strip(run.output)
    if len(outputText) > 0:
        v3GatePrintErr(outputText)
    return false

fn v3GateCollectPositionals(args: str[]): str[] =
    var out: str[] = []
    for i in 0..<args.len:
        let arg: str = args[i]
        if !strutil.startsWith(arg, "--"):
            add(out, arg)
    return out

fn v3GateShellArgv(args: str[]): str =
    var out = ""
    for i in 0..<args.len:
        if i > 0:
            out = out + " "
        out = out + os.quoteShell(args[i])
    return out

fn v3GateTextValue(text: str, key: str): str =
    let prefix = key + "="
    var start = 0
    while start < len(text):
        var end = start
        while end < len(text) && text[end] != '\n' && text[end] != '\r':
            end = end + 1
        let line = v3path.v3TextSlice(text, start, end - start)
        if v3path.v3TextStartsWith(line, prefix):
            return v3path.v3TextSlice(line, len(prefix), len(line) - len(prefix))
        start = end + 1
        while start < len(text) && (text[start] == '\n' || text[start] == '\r'):
            start = start + 1
    return ""

fn v3GateRunShellLogged(root: str,
                        label: str,
                        command: str,
                        logPath: str,
                        timeoutSec: int32): hostops.V3LoggedRun =
    return hostops.v3RunProgramLogged(root,
                                      label,
                                      "sh",
                                      ["-lc", command],
                                      [],
                                      root,
                                      timeoutSec,
                                      logPath)

fn v3GateRemoteTransportRetryable(text: str): bool =
    let trimmed = strutil.strip(text)
    return strutil.contains(trimmed, "Connection timed out during banner exchange") ||
           (strutil.contains(trimmed, "Connection to ") && strutil.contains(trimmed, " timed out")) ||
           strutil.contains(trimmed, "No route to host") ||
           strutil.contains(trimmed, "Connection reset by peer") ||
           strutil.contains(trimmed, "kex_exchange_identification") ||
           strutil.contains(trimmed, "Connection closed by remote host")

fn v3GateRemoteSshArgv(sshHost: str, remoteCmd: str): str[] =
    return [
        "-n",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=8",
        "-o", "ServerAliveInterval=5",
        "-o", "ServerAliveCountMax=3",
        sshHost,
        remoteCmd
    ]

fn v3GateRunRemoteShellLogged(root: str,
                              label: str,
                              sshHost: str,
                              command: str,
                              logPath: str,
                              timeoutSec: int32): hostops.V3LoggedRun =
    let remoteCmd = "sh -lc " + os.quoteShell(command)
    var lastRun = hostops.v3LoggedRunZero(label, "ssh", logPath, 255, "")
    for attempt in 0..<3:
        let run = hostops.v3RunProgramLogged(root,
                                             label,
                                             "ssh",
                                             v3GateRemoteSshArgv(sshHost, remoteCmd),
                                             [],
                                             root,
                                             timeoutSec,
                                             logPath)
        lastRun = run
        if !v3GateRunFailed(run):
            return run
        if attempt >= 2 || !v3GateRemoteTransportRetryable(run.output):
            return run
        v3GatePrintLine("[v3 gate] remote ssh retry " + intToStr(attempt + 1) + " " + label)
        os.sleepMs((attempt + 1) * 1000)
    return lastRun

fn v3GateShellCheckOk(root: str, command: str): bool =
    let res = os.execCmdEx("sh -lc " + os.quoteShell(command), uint64(7), root)
    return os.execCmdResultExitCode(res) == 0

fn v3GateBftBuildReady(root: str,
                       compiler: str,
                       src: str,
                       outBin: str,
                       runLog: str,
                       runSelfTest: str): bool =
    if !os.fileExists(outBin):
        return false
    var command = "test -x " + os.quoteShell(outBin) +
                  " && test " + os.quoteShell(compiler) + " -ot " + os.quoteShell(outBin) +
                  " && test " + os.quoteShell(src) + " -ot " + os.quoteShell(outBin)
    if runSelfTest != "0":
        if !os.fileExists(runLog):
            return false
        command = command +
                  " && test " + os.quoteShell(outBin) + " -ot " + os.quoteShell(runLog) +
                  " && test " + os.quoteShell(compiler) + " -ot " + os.quoteShell(runLog) +
                  " && test " + os.quoteShell(src) + " -ot " + os.quoteShell(runLog) +
                  " && grep -q " + os.quoteShell("v3 bft_state_machine self-test ok") + " " + os.quoteShell(runLog)
    return v3GateShellCheckOk(root, command)

