    if v3GateRunFailed(clientBobRound3):
        return clientBobRound3.exitCode
    if !v3GateChainNodeRequireRunValue(clientAliceRound3, "balance", "85", "v3 chain_node resilience round3 client alice") ||
       !v3GateChainNodeRequireRunValue(clientBobRound3, "balance", "70", "v3 chain_node resilience round3 client bob") ||
       !v3GateChainNodeRequireStateParity(relayShowRound3,
                                          clientShowRound3,
                                          "v3 chain_node resilience round3 relay client parity"):
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round3_relay_to_client_idle",
                                      false) != 0:
        return 1
    v3GatePrintLine("v3 chain_node resilience smoke ok (" + label + ")")
    return 0

fn v3GateRunTailnetControlSmoke(root: str,
                                compilerPath: str,
                                stageName: str,
                                envOverrides: str[]): int32 =
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_tailnet_control")
    let controlProbeEndpoint: str = v3path.V3PathAbsolute(root, "v3/testdata/tailnet/headscale_control_ready.json")
    let relayProbeEndpoint: str = v3path.V3PathAbsolute(root, "v3/testdata/tailnet/derp_ready.json")
    let baselineSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/libp2p_tailnet_transport_smoke.cheng")
    let baselineBin: str = os.JoinPath(outDir, "libp2p_tailnet_transport_smoke." + stageName)
    let baselineRun = v3GateCompileExeEnv(root,
                                          "v3 tailnet control compile baseline " + stageName,
                                          compilerPath,
                                          baselineSrc,
                                          baselineBin,
                                          "arm64-apple-darwin",
                                          baselineBin + ".compile.log",
                                          envOverrides)
    if v3GateRunFailed(baselineRun):
        return baselineRun.exitCode
    let baselineExec = v3GateRunBinary(root,
                                       "v3 tailnet control run baseline " + stageName,
                                       baselineBin,
                                       [],
                                       20,
                                       os.JoinPath(outDir, "libp2p_tailnet_transport_smoke." + stageName + ".run.log"))
    if v3GateRunFailed(baselineExec):
        return baselineExec.exitCode
    let coreSmokeSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/tailnet_control_core_smoke.cheng")
    let coreSmokeBin: str = os.JoinPath(outDir, "tailnet_control_core_smoke." + stageName)
    let coreSmokeCompile = v3GateCompileExeEnv(root,
                                               "v3 tailnet control compile decode smoke " + stageName,
                                               compilerPath,
                                               coreSmokeSrc,
                                               coreSmokeBin,
                                               "arm64-apple-darwin",
                                               coreSmokeBin + ".compile.log",
                                               envOverrides)
    if v3GateRunFailed(coreSmokeCompile):
        return coreSmokeCompile.exitCode
    let coreSmokeRun = v3GateRunBinary(root,
                                       "v3 tailnet control run decode smoke " + stageName,
                                       coreSmokeBin,
                                       [],
                                       20,
                                       os.JoinPath(outDir, "tailnet_control_core_smoke." + stageName + ".run.log"))
    if v3GateRunFailed(coreSmokeRun):
        return coreSmokeRun.exitCode
    let coreSrc: str = v3path.V3PathAbsolute(root, "v3/src/project/tailnet_control_core.cheng")
    let coreBin: str = os.JoinPath(outDir, "tailnet_control_core." + stageName)
    let coreCompile = v3GateCompileExeEnv(root,
                                          "v3 tailnet control compile core " + stageName,
                                          compilerPath,
                                          coreSrc,
                                          coreBin,
                                          "arm64-apple-darwin",
                                          coreBin + ".compile.log",
                                          envOverrides)
    if v3GateRunFailed(coreCompile):
        return coreCompile.exitCode
    let configureRun = v3GateRunBinary(root,
                                       "v3 tailnet control configure " + stageName,
                                       coreBin,
                                       [
                                           "--command", "configure",
                                           "--provider-headscale", "1",
                                           "--control-url", "https://headscale.example",
                                           "--control-endpoint", "https://headscale.example/control",
                                           "--relay-endpoint", "https://derp.sfo.example:443",
                                           "--control-probe-endpoint", controlProbeEndpoint,
                                           "--relay-probe-endpoint", relayProbeEndpoint,
                                           "--namespace", "infra",
                                           "--noise-public-key", "noise-pub-cli",
                                           "--derp-region-code", "sfo",
                                           "--derp-region-name", "SanFrancisco",
                                           "--derp-hostname", "derp.sfo.example",
                                           "--synthetic-ipv4", "100.64.0.44",
                                           "--synthetic-ipv6", "fd7a:115c:a1e0::44",
                                           "--local-peer-id", "tailnet-control-test",
                                           "--exact-routing", "1",
                                           "--provider-ready", "1",
                                           "--proxy-ready", "1"
                                       ],
                                       20,
                                       os.JoinPath(outDir, "tailnet_control_configure." + stageName + ".run.log"))
    if v3GateRunFailed(configureRun):
        return configureRun.exitCode
    if !v3GateRequireOutput(configureRun, "configured=1", "v3 tailnet control") ||
       !v3GateRequireOutput(configureRun, "providerKind=headscale", "v3 tailnet control") ||
       !v3GateRequireOutput(configureRun, "controlProbeEndpoint=" + controlProbeEndpoint, "v3 tailnet control") ||
       !v3GateRequireOutput(configureRun, "controlPlane=headscale", "v3 tailnet control") ||
       !v3GateRequireOutput(configureRun, "providerReady=1", "v3 tailnet control") ||
       !v3GateRequireOutput(configureRun, "proxyListenersReady=1", "v3 tailnet control") ||
       !v3GateRequireOutput(configureRun, "providerRuntimeActive=1", "v3 tailnet control"):
        return 1
    let listenRun = v3GateRunBinary(root,
                                    "v3 tailnet control listen " + stageName,
                                    coreBin,
                                    [
                                        "--command", "listen",
                                        "--provider-headscale", "1",
                                        "--control-url", "https://headscale.example",
                                        "--control-endpoint", "https://headscale.example/control",
                                        "--relay-endpoint", "https://derp.sfo.example:443",
                                        "--control-probe-endpoint", controlProbeEndpoint,
                                        "--relay-probe-endpoint", relayProbeEndpoint,
                                        "--namespace", "infra",
                                        "--noise-public-key", "noise-pub-cli",
                                        "--derp-region-code", "sfo",
                                        "--derp-region-name", "SanFrancisco",
                                        "--derp-hostname", "derp.sfo.example",
                                        "--synthetic-ipv4", "100.64.0.44",
                                        "--synthetic-ipv6", "fd7a:115c:a1e0::44",
                                        "--local-peer-id", "tailnet-control-test",
                                        "--exact-routing", "1",
                                        "--provider-ready", "1",
                                        "--proxy-ready", "1",
                                        "--host", "127.0.0.1",
                                        "--port", "7101",
                                        "--transport", "tcp"
                                    ],
                                    20,
                                    os.JoinPath(outDir, "tailnet_control_listen." + stageName + ".run.log"))
    if v3GateRunFailed(listenRun):
        return listenRun.exitCode
    if !v3GateRequireOutput(listenRun, "publishedAddr=/ip4/100.64.0.44/tcp/7101", "v3 tailnet control") ||
       !v3GateRequireOutput(listenRun, "listener.0.raw=/ip4/127.0.0.1/tcp/7101", "v3 tailnet control") ||
       !v3GateRequireOutput(listenRun, "providerKind=headscale", "v3 tailnet control") ||
       !v3GateRequireOutput(listenRun,
                            "tailnetDerpMapSummary=headscale/infra@https://headscale.example#sfo/derp.sfo.example",
                            "v3 tailnet control") ||
       !v3GateRequireOutput(listenRun, "providerRuntimeActive=1", "v3 tailnet control"):
        return 1
    let dialRun = v3GateRunBinary(root,
                                  "v3 tailnet control dial-plan " + stageName,
                                  coreBin,
                                  [
                                      "--command", "dial-plan",
                                      "--provider-headscale", "1",
                                      "--control-url", "https://headscale.example",
                                      "--control-endpoint", "https://headscale.example/control",
                                      "--relay-endpoint", "https://derp.sfo.example:443",
                                      "--control-probe-endpoint", controlProbeEndpoint,
                                      "--relay-probe-endpoint", relayProbeEndpoint,
                                      "--namespace", "infra",
                                      "--noise-public-key", "noise-pub-cli",
                                      "--derp-region-code", "sfo",
                                      "--derp-region-name", "SanFrancisco",
                                      "--derp-hostname", "derp.sfo.example",
                                      "--synthetic-ipv4", "100.64.0.44",
                                      "--synthetic-ipv6", "fd7a:115c:a1e0::44",
                                      "--local-peer-id", "tailnet-control-test",
                                      "--exact-routing", "1",
                                      "--provider-ready", "1",
                                      "--proxy-ready", "1",
                                      "--derp-healthy", "1",
                                      "--bootstrap-listen-count", "1",
                                      "--bootstrap-listen-raw-0", "/ip4/127.0.0.1/tcp/7101",
                                      "--bootstrap-peer-count", "1",
                                      "--bootstrap-peer-id-0", "peer-direct",
                                      "--bootstrap-peer-remote-tailnet-ip-0", "100.64.0.88",
                                      "--bootstrap-peer-direct-reachable-0", "1",
                                      "--bootstrap-peer-relay-allowed-0", "1",
                                      "--bootstrap-peer-relay-only-0", "0",
                                      "--bootstrap-peer-derp-region-code-0", "sfo",
                                      "--bootstrap-peer-signed-preface-0", "test-preface",
                                      "--bootstrap-peer-bound-addr-text-0", "/ip4/127.0.0.1/tcp/7101",
                                      "--bootstrap-peer-last-path-0", "direct",
                                      "--bootstrap-peer-last-error-0", "",
                                      "--peer-id", "peer-direct",
                                      "--addr", "/ip4/100.64.0.44/tcp/7101"
                                  ],
                                  20,
                                  os.JoinPath(outDir, "tailnet_control_dial." + stageName + ".run.log"))
    if v3GateRunFailed(dialRun):
        return dialRun.exitCode
    if !v3GateRequireOutput(dialRun, "dial.pathKind=direct", "v3 tailnet control") ||
       !v3GateRequireOutput(dialRun, "dial.routeText=/ip4/127.0.0.1/tcp/7101", "v3 tailnet control") ||
       !v3GateRequireOutput(dialRun, "sessionCount=1", "v3 tailnet control") ||
       !v3GateRequireOutput(dialRun, "relayHealthy=1", "v3 tailnet control") ||
       !v3GateRequireOutput(dialRun, "startupStage=derp-ready", "v3 tailnet control") ||
       !v3GateRequireOutput(dialRun,
                            "tailnetDerpMapSummary=headscale/infra@https://headscale.example#sfo/derp.sfo.example",
                            "v3 tailnet control") ||
       !v3GateRequireOutput(dialRun, "peer.0.lastPath=direct", "v3 tailnet control") ||
       !v3GateRequireOutput(dialRun, "providerRuntimeActive=1", "v3 tailnet control") ||
       !v3GateRequireOutput(dialRun, "providerRuntimeCommands=3", "v3 tailnet control"):
        return 1
    v3GateMaybePrintRunOutput(baselineExec)
    v3GateMaybePrintRunOutput(coreSmokeRun)
    v3GateMaybePrintRunOutput(configureRun)
    v3GateMaybePrintRunOutput(listenRun)
    v3GateMaybePrintRunOutput(dialRun)
    v3GatePrintLine("v3 tailnet_control_smoke ok")
    return 0

fn v3GateRunFreshNodeSelfhostGate(root: str,
                                  compilerPath: str,
                                  label: str,
                                  envOverrides: str[]): int32 =
    let src: str = v3path.V3PathAbsolute(root, "v3/src/tests/program_selfhost_smoke.cheng")
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_fresh_node_gate/" + label)
    let syncPrefix: str = os.JoinPath(outDir, "program_selfhost_smoke.sync")
    let freshPrefix: str = os.JoinPath(outDir, "program_selfhost_smoke.fresh")
    if !os.FileExists(src):
        v3GatePrintErr("v3 fresh-node selfhost gate: missing source: " + src)
        return 1
    let syncRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                               "v3 fresh-node selfhost world-sync " + label,
                                                               compilerPath,
                                                               [
                                                                   "world-sync",
                                                                   "--root:" + v3path.V3PathAbsolute(root, "v3"),
                                                                   "--in:" + src,
                                                                   "--target:arm64-apple-darwin",
                                                                   "--out:" + syncPrefix,
                                                                   "--channel:stable"
                                                               ],
                                                               envOverrides,
                                                               root,
                                                               0,
                                                               os.JoinPath(outDir, "world_sync.log"))
    if v3GateRunFailed(syncRun):
        return syncRun.exitCode
    if !v3GateRequirePrefixArtifacts(syncPrefix,
                                     [
                                         ".world.txt",
                                         ".compiler.snapshot.txt",
                                         ".std.snapshot.txt",
                                         ".runtime.snapshot.txt",
                                         ".csg.txt",
                                         ".surface.txt",
                                         ".receipt.txt",
                                         ".lock.toml"
                                     ],
                                     "v3 fresh-node selfhost gate"):
        return 1
    let freshRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                                "v3 fresh-node selfhost fresh " + label,
                                                                compilerPath,
                                                                [
                                                                    "fresh-node-selfhost",
                                                                    "--root:" + v3path.V3PathAbsolute(root, "v3"),
                                                                    "--in:" + src,
                                                                    "--target:arm64-apple-darwin",
                                                                    "--out:" + freshPrefix,
                                                                    "--channel:stable",
                                                                    "--baseline-csg:" + syncPrefix + ".csg.txt",
                                                                    "--baseline-surface:" +
                                                                        syncPrefix + ".surface.txt",
                                                                    "--baseline-receipt:" + syncPrefix + ".receipt.txt"
                                                                ],
                                                                envOverrides,
                                                                root,
                                                                0,
                                                                os.JoinPath(outDir, "fresh_node.log"))
    if v3GateRunFailed(freshRun):
        return freshRun.exitCode
    if !v3GateRequireOutput(freshRun, "equivalence_passed=1", "v3 fresh-node selfhost gate") ||
       !v3GateRequireOutput(freshRun, "publish_allowed=1", "v3 fresh-node selfhost gate") ||
       !v3GateRequireOutput(freshRun, "receipt_equivalent=1", "v3 fresh-node selfhost gate") ||
       !v3GateRequireOutput(freshRun, "receipt_cid_match=1", "v3 fresh-node selfhost gate") ||
       !v3GateRequireFileContains(freshPrefix + ".fresh.txt", "receipt_equivalent=1", "v3 fresh-node selfhost gate") ||
       !v3GateRequireFileContains(freshPrefix + ".fresh.txt", "receipt_cid_match=1", "v3 fresh-node selfhost gate"):
        return 1
    v3GateMaybePrintRunOutput(syncRun)
    v3GateMaybePrintRunOutput(freshRun)
    v3GatePrintLine("v3 fresh-node selfhost gate ok (" + label + ")")
    return 0

fn v3GateRunMigrationGate(root: str,
                          compilerPath: str,
                          label: str,
                          envOverrides: str[]): int32 =
    let currentSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/compiler_migration_fixture.cheng")
    let legacySrc: str = v3path.V3PathAbsolute(root,
                                               "v3/testdata/compiler_migration/" +
                                                   "compiler_migration_fixture_legacy.cheng")
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_migration_gate/" + label)
    let migratePrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.migrate")
    let proofPrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.prove")
    let blockedPrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.blocked")
    let publishPrefix: str = os.JoinPath(outDir, "compiler_migration_fixture.publish")
    if !os.FileExists(currentSrc) || !os.FileExists(legacySrc):
        v3GatePrintErr("v3 migration gate: missing fixture sources")
        return 1
    let migrateRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                                  "v3 migration gate migrate-csg " + label,
                                                                  compilerPath,
                                                                  [
                                                                      "migrate-csg",
                                                                      "--root:" + v3path.V3PathAbsolute(root, "v3"),
                                                                      "--in:" + currentSrc,
                                                                      "--legacy-in:" + legacySrc,
                                                                      "--out:" + migratePrefix
                                                                  ],
                                                                  envOverrides,
                                                                  root,
                                                                  0,
                                                                  os.JoinPath(outDir, "migrate_csg.log"))
    if v3GateRunFailed(migrateRun):
        return migrateRun.exitCode
    if !v3GateRequirePrefixArtifacts(migratePrefix,
                                     [".migration.txt",
                                      ".migration.csg.txt",
                                      ".migration.surface.txt",
                                      ".migration.receipt.txt"],
                                     "v3 migration gate") ||
       !v3GateRequireOutput(migrateRun, "canonical_graph_cid=", "v3 migration gate"):
        return 1
    let proveRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                                "v3 migration gate prove-migration " + label,
                                                                compilerPath,
                                                                [
                                                                    "prove-migration",
                                                                    "--root:" + v3path.V3PathAbsolute(root, "v3"),
                                                                    "--in:" + currentSrc,
                                                                    "--legacy-in:" + legacySrc,
                                                                    "--target:arm64-apple-darwin",
                                                                    "--channel:stable",
                                                                    "--out:" + proofPrefix
                                                                ],
                                                                envOverrides,
                                                                root,
                                                                0,
                                                                os.JoinPath(outDir, "prove_migration.log"))
    if v3GateRunFailed(proveRun):
        return proveRun.exitCode
    if !v3GateRequirePrefixArtifacts(proofPrefix,
                                     [".migration.txt",
                                      ".migration.csg.txt",
                                      ".migration.surface.txt",
                                      ".migration.receipt.txt",
                                      ".proof.txt"],
                                     "v3 migration gate") ||
       !v3GateRequireOutput(proveRun, "equivalence_kind=canonical_semantic_identity", "v3 migration gate") ||
       !v3GateRequireOutput(proveRun, "graph_equivalent=1", "v3 migration gate") ||
       !v3GateRequireOutput(proveRun, "export_surface_compatible=1", "v3 migration gate") ||
       !v3GateRequireOutput(proveRun, "compile_receipt_equivalent=1", "v3 migration gate"):
        return 1
    let blockedRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                                  "v3 migration gate publish-blocked " + label,
                                                                  compilerPath,
                                                                  [
                                                                      "publish-world",
                                                                      "--root:" + v3path.V3PathAbsolute(root, "v3"),
                                                                      "--in:" + currentSrc,
                                                                      "--target:arm64-apple-darwin",
                                                                      "--out:" + blockedPrefix,
                                                                      "--channel:stable"
                                                                  ],
                                                                  envOverrides,
                                                                  root,
                                                                  0,
                                                                  os.JoinPath(outDir, "publish_blocked.log"))
    if blockedRun.exitCode == 0:
        v3GatePrintErr("v3 migration gate: stable publish unexpectedly passed without proof")
        return 1
    if !v3GateRequireAnyOutput(blockedRun.output,
                               ["stable requires", "publish blocked", "missing --baseline"],
                               "v3 migration gate"):
        return 1
    let publishRun: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                                  "v3 migration gate publish-world " + label,
                                                                  compilerPath,
                                                                  [
                                                                      "publish-world",
                                                                      "--root:" + v3path.V3PathAbsolute(root, "v3"),
                                                                      "--in:" + currentSrc,
                                                                      "--legacy-in:" + legacySrc,
                                                                      "--target:arm64-apple-darwin",
                                                                      "--out:" + publishPrefix,
                                                                      "--channel:stable"
                                                                  ],
                                                                  envOverrides,
                                                                  root,
                                                                  0,
                                                                  os.JoinPath(outDir, "publish_migration.log"))
    if v3GateRunFailed(publishRun):
        return publishRun.exitCode
    if !v3GateRequirePrefixArtifacts(publishPrefix,
                                     [
                                         ".world.txt",
                                         ".compiler.snapshot.txt",
                                         ".std.snapshot.txt",
                                         ".runtime.snapshot.txt",
                                         ".csg.txt",
                                         ".surface.txt",
                                         ".receipt.txt",
                                         ".lock.toml",
                                         ".migration.txt",
                                         ".migration.csg.txt",
                                         ".migration.surface.txt",
                                         ".migration.receipt.txt",
                                         ".proof.txt",
                                         ".publish.txt"
                                     ],
                                     "v3 migration gate") ||
       !v3GateRequireOutput(publishRun, "proof_mode=migration", "v3 migration gate") ||
       !v3GateRequireOutput(publishRun, "equivalence_passed=1", "v3 migration gate") ||
       !v3GateRequireOutput(publishRun, "publish_allowed=1", "v3 migration gate"):
        return 1
    v3GateMaybePrintRunOutput(migrateRun)
    v3GateMaybePrintRunOutput(proveRun)
    v3GateMaybePrintRunOutput(blockedRun)
    v3GateMaybePrintRunOutput(publishRun)
    v3GatePrintLine("v3 migration gate ok (" + label + ")")
    return 0

fn v3GateRunBrowserWebrtcSmokes(root: str,
                                tests: str[],
                                envOverrides: str[]): int32 =
    let browserDir: str = v3path.V3PathAbsolute(root, "v3/tooling/browser_webrtc")
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_browser_webrtc")
    var hostCompiler = ""
    if v3GateResolveSmokeCompiler(root, "", "CHENG_V3_SMOKE_COMPILER", "", hostCompiler) != 0:
        return 1
    if v3GateEnsureBootstrapBridge(root) != 0:
        return 1
    let stage2: str = contracts.v3BootstrapStage2Path(root)
    let stage3: str = contracts.v3BootstrapStage3Path(root)
    if !os.FileExists(stage2) || !os.FileExists(stage3):
        v3GatePrintErr("v3 browser webrtc smokes: missing bootstrap compiler")
        return 1
    if !os.DirExists(os.JoinPath(browserDir, "node_modules/playwright")):
        let npmRun: hostops.V3LoggedRun = hostops.v3RunProgramLogged(root,
                                                                     "v3 browser webrtc npm-install",
                                                                     "npm",
                                                                     ["install", "--no-fund", "--no-audit"],
                                                                     [],
                                                                     browserDir,
                                                                     600,
                                                                     os.JoinPath(outDir, "npm_install.log"))
        if v3GateRunFailed(npmRun):
            return npmRun.exitCode
    let playwrightRun: hostops.V3LoggedRun = hostops.v3RunProgramLogged(root,
                                                                        "v3 browser webrtc playwright-install",
                                                                        "npx",
                                                                        ["playwright", "install", "chromium"],
                                                                        [],
                                                                        browserDir,
                                                                        600,
                                                                        os.JoinPath(outDir, "playwright_install.log"))
    if v3GateRunFailed(playwrightRun):
        return playwrightRun.exitCode
    var names: str[] = v3GateDefaultBrowserWebrtcSmokes()
    if tests.len > 0:
        names = tests
    for i in 0..<names.len:
        let smokeName: str = names[i]
        let hostBin: str = os.JoinPath(outDir, smokeName + ".host")
        if v3GateRunSingleFixtureSmoke(root,
                                       "v3 browser webrtc",
                                       hostCompiler,
                                       smokeName,
                                       hostBin,
                                       "host",
                                       envOverrides) != 0:
            return 1
        let stage2Bin: str = os.JoinPath(outDir, smokeName + ".stage2")
        if v3GateRunSingleFixtureSmoke(root,
                                       "v3 browser webrtc",
                                       stage2,
                                       smokeName,
                                       stage2Bin,
                                       "stage2",
                                       envOverrides) != 0:
            return 1
        let stage3Bin: str = os.JoinPath(outDir, smokeName + ".stage3")
        if v3GateRunSingleFixtureSmoke(root,
                                       "v3 browser webrtc",
                                       stage3,
                                       smokeName,
                                       stage3Bin,
                                       "stage3",
                                       envOverrides) != 0:
            return 1
    v3GatePrintLine("v3 browser webrtc smokes: ok")
    return 0

fn v3GateRunChainNodeProcessSmokeWithCompiler(root: str,
                                              compilerPath: str,
                                              label: str,
                                              envOverrides: str[]): int32 =
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_chain_node_process/" + label)
    let serverSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/chain_node_process_server_smoke.cheng")
    let clientSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/chain_node_process_client_smoke.cheng")
    let serverBin: str = os.JoinPath(outDir, "chain_node_process_server")
    let clientBin: str = os.JoinPath(outDir, "chain_node_process_client")
    let serverCompile = v3GateCompileExeEnv(root,
                                            "run_chain_node_process_server_build " + label,
                                            compilerPath,
                                            serverSrc,
                                            serverBin,
                                            "arm64-apple-darwin",
                                            os.JoinPath(outDir, "chain_node_process_server.compile.log"),
                                            envOverrides)
    if v3GateRunFailed(serverCompile):
        return serverCompile.exitCode
    let clientCompile = v3GateCompileExeEnv(root,
                                            "run_chain_node_process_client_build " + label,
                                            compilerPath,
                                            clientSrc,
                                            clientBin,
                                            "arm64-apple-darwin",
                                            os.JoinPath(outDir, "chain_node_process_client.compile.log"),
                                            envOverrides)
    if v3GateRunFailed(clientCompile):
        return clientCompile.exitCode
    let readyPath: str = os.JoinPath(outDir, "server.ready")
    let _ = os.RemoveFile(readyPath)
    let spawnRes = hostops.v3SpawnFile(root,
                                       "chain_node_process_server " + label,
                                       serverBin,
                                       ["--port:0", "--ready-path:" + readyPath],
                                       [],
                                       root)
    if IsErr(spawnRes):
        v3GatePrintErr(Error(spawnRes))
        return 1
    var serverProc = Value(spawnRes)
    var port = ""
    if !v3GateWaitReadyPort(root, readyPath, serverProc, port):
        let serverRun = v3GateWriteProcessSnapshot(root, serverProc, os.JoinPath(outDir, "server.log"), 1)
        v3GatePrintErr("v3 chain_node process smoke: invalid ready port")
        v3GateMaybePrintRunOutput(serverRun)
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    let clientRun = v3GateRunBinary(root,
                                    "chain_node_process_client " + label,
                                    clientBin,
                                    ["--port:" + port],
                                    20,
                                    os.JoinPath(outDir, "client.log"))
    if v3GateRunFailed(clientRun):
        let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 1, os.JoinPath(outDir, "server.log"))
        v3GateMaybePrintRunOutput(serverRun)
        return clientRun.exitCode
    let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 20, os.JoinPath(outDir, "server.log"))
    v3GateMaybePrintRunOutput(serverRun)
    if v3GateRunFailed(serverRun):
        return serverRun.exitCode
    v3GateMaybePrintRunOutput(clientRun)
    v3GatePrintLine("v3 chain_node process smoke ok (" + label + ")")
    return 0

fn v3GateRunChainNodeThreeNodeSmokeWithCompiler(root: str,
                                                compilerPath: str,
                                                label: str,
                                                envOverrides: str[]): int32 =
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_chain_node_three_node/" + label)
    let serverSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/chain_node_process_server_smoke.cheng")
    let relaySrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/chain_node_process_relay_smoke.cheng")
    let clientSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/chain_node_process_client_smoke.cheng")
    let serverBin: str = os.JoinPath(outDir, "chain_node_process_server")
    let relayBin: str = os.JoinPath(outDir, "chain_node_process_relay")
    let clientBin: str = os.JoinPath(outDir, "chain_node_process_client")
    let serverCompile = v3GateCompileExeEnv(root,
                                            "run_chain_node_three_node_server_build " + label,
                                            compilerPath,
                                            serverSrc,
                                            serverBin,
                                            "arm64-apple-darwin",
                                            os.JoinPath(outDir, "chain_node_process_server.compile.log"),
                                            envOverrides)
    if v3GateRunFailed(serverCompile):
        return serverCompile.exitCode
    let relayCompile = v3GateCompileExeEnv(root,
                                           "run_chain_node_three_node_relay_build " + label,
                                           compilerPath,
                                           relaySrc,
                                           relayBin,
                                           "arm64-apple-darwin",
                                           os.JoinPath(outDir, "chain_node_process_relay.compile.log"),
                                           envOverrides)
    if v3GateRunFailed(relayCompile):
        return relayCompile.exitCode
    let clientCompile = v3GateCompileExeEnv(root,
                                            "run_chain_node_three_node_client_build " + label,
                                            compilerPath,
                                            clientSrc,
                                            clientBin,
                                            "arm64-apple-darwin",
                                            os.JoinPath(outDir, "chain_node_process_client.compile.log"),
                                            envOverrides)
    if v3GateRunFailed(clientCompile):
        return clientCompile.exitCode
    let serverReady: str = os.JoinPath(outDir, "server.ready")
    let relayReady: str = os.JoinPath(outDir, "relay.ready")
    let _ = os.RemoveFile(serverReady)
    let _ = os.RemoveFile(relayReady)
    let serverArgs = ["--port:0", "--ready-path:" + serverReady]
    let serverSpawn = hostops.v3SpawnFile(root,
                                          "chain_node_three_node_server " + label,
                                          serverBin,
                                          serverArgs,
                                          [],
                                          root)
    if IsErr(serverSpawn):
        v3GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var serverPort = ""
    if !v3GateWaitReadyPort(root, serverReady, serverProc, serverPort):
        let serverRun = v3GateWriteProcessSnapshot(root, serverProc, os.JoinPath(outDir, "server.log"), 1)
        v3GateMaybePrintRunOutput(serverRun)
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    let relayArgs = ["--upstream-port:" + serverPort,
                     "--port:0",
                     "--ready-path:" + relayReady]
    let relaySpawn = hostops.v3SpawnFile(root,
                                         "chain_node_three_node_relay " + label,
                                         relayBin,
                                         relayArgs,
                                         [],
                                         root)
    if IsErr(relaySpawn):
        v3GatePrintErr(Error(relaySpawn))
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    var relayProc = Value(relaySpawn)
    var relayPort = ""
    if !v3GateWaitReadyPort(root, relayReady, relayProc, relayPort):
        let relayRun = v3GateWriteProcessSnapshot(root, relayProc, os.JoinPath(outDir, "relay.log"), 1)
        v3GateMaybePrintRunOutput(relayRun)
        hostops.v3SpawnedProcessKill(relayProc)
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    let clientRun = v3GateRunBinary(root,
                                    "chain_node_three_node_client " + label,
                                    clientBin,
                                    ["--port:" + relayPort],
                                    20,
                                    os.JoinPath(outDir, "client.log"))
    if v3GateRunFailed(clientRun):
        let relayRun = hostops.v3SpawnedProcessWaitLogged(root, relayProc, 1, os.JoinPath(outDir, "relay.log"))
        let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 1, os.JoinPath(outDir, "server.log"))
        v3GateMaybePrintRunOutput(serverRun)
        v3GateMaybePrintRunOutput(relayRun)
        return clientRun.exitCode
    let relayRun = hostops.v3SpawnedProcessWaitLogged(root, relayProc, 20, os.JoinPath(outDir, "relay.log"))
    let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 20, os.JoinPath(outDir, "server.log"))
    v3GateMaybePrintRunOutput(serverRun)
    v3GateMaybePrintRunOutput(relayRun)
    v3GateMaybePrintRunOutput(clientRun)
    if v3GateRunFailed(relayRun):
        return relayRun.exitCode
    if v3GateRunFailed(serverRun):
        return serverRun.exitCode
    v3GatePrintLine("v3 chain_node three-node smoke ok (" + label + ")")
    return 0

fn v3GateRunHostSmokes(root: str, args: str[]): int32 =
    if v3GateVerifyExportVisibility(root) != 0:
        return 1
    let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_SMOKE_COMPILER", "", compiler) != 0:
        return 1
    let tailOnly: str = strutil.Strip(v3GateReadFlag(args, "--tail-only", ""))
    let positionals: str[] = v3GateCollectPositionals(args)
    let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_SMOKE_LABEL", "host")
    let hostrunRoot: str = v3path.V3PathAbsolute(root, "artifacts/v3_hostrun")
    var outDir: str = hostrunRoot
    if label != "host":
        outDir = os.JoinPath(hostrunRoot, label)
    if len(tailOnly) > 0:
        if tailOnly == "wasm":
            return v3GateRunWasmSmokes(root, compiler, label, [])
        if tailOnly == "browser_host_wasm":
            return v3GateRunBrowserHostWasmSmoke(root, compiler, label, [])
        if tailOnly == "chain_node_cli":
            return v3GateRunChainNodeCliSmoke(root, compiler, label, [])
        if tailOnly == "chain_node_process":
            return v3GateRunChainNodeProcessSmokeWithCompiler(root, compiler, label, [])
        if tailOnly == "chain_node_three_node":
            return v3GateRunChainNodeThreeNodeSmokeWithCompiler(root, compiler, label, [])
        if tailOnly == "chain_node_resilience":
            return v3GateRunChainNodeResilienceSmoke(root, compiler, label, [])
        if tailOnly == "tailnet_control":
            return v3GateRunTailnetControlSmoke(root, compiler, label, [])
        if tailOnly == "fresh_node_selfhost":
            return v3GateRunFreshNodeSelfhostGate(root, compiler, label, [])
        if tailOnly == "migration":
            return v3GateRunMigrationGate(root, compiler, label, [])
        v3GatePrintErr("v3 host smokes: unknown --tail-only: " + tailOnly)
        return 1
    var tests: str[] = v3GateDefaultHostSmokes()
    var runTail: bool = true
    if positionals.len > 0:
        tests = positionals
        runTail = false
    for i in 0..<tests.len:
        let smokeName: str = tests[i]
        let outBin: str = os.JoinPath(outDir, smokeName)
        if v3GateRunSingleFixtureSmoke(root, "v3 host smokes", compiler, smokeName, outBin, label, []) != 0:
            return 1
        if smokeName == "chain_node_libp2p_smoke":
            if v3GateRunTcpTwoprocSmoke(root, compiler, label, []) != 0:
                return 1
        if smokeName == "libp2p_quic_tls_smoke":
            if v3GateRunQuicTwoprocSmoke(root, compiler, label, []) != 0:
                return 1
    if runTail:
        if v3GateRunChainNodeCliSmoke(root, compiler, label, []) != 0:
            return 1
        if v3GateRunChainNodeProcessSmokeWithCompiler(root, compiler, label, []) != 0:
            return 1
        if v3GateRunChainNodeThreeNodeSmokeWithCompiler(root, compiler, label, []) != 0:
            return 1
        if v3GateRunTailnetControlSmoke(root, compiler, label, []) != 0:
            return 1
        if v3GateRunFreshNodeSelfhostGate(root, compiler, label, []) != 0:
            return 1
        if v3GateRunMigrationGate(root, compiler, label, []) != 0:
            return 1
    v3GatePrintLine("v3 host smokes: ok")
    return 0

fn v3GateRunStage23Libp2pSmokes(root: str, args: str[]): int32 =
    if v3GateEnsureBootstrapBridge(root) != 0:
        return 1
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_stage23_libp2p")
    let stage2: str = contracts.v3BootstrapStage2Path(root)
    let stage3: str = contracts.v3BootstrapStage3Path(root)
    if !os.FileExists(stage2) || !os.FileExists(stage3):
        v3GatePrintErr("v3 stage2/stage3 libp2p: missing bootstrap compiler")
        return 1
    let envOverrides: str[] = v3GateStage23EnvOverrides()
    let tailOnly: str = strutil.Strip(v3GateReadFlag(args, "--tail-only", ""))
    let positionals: str[] = v3GateCollectPositionals(args)
    if tailOnly == "browser_webrtc":
        return v3GateRunBrowserWebrtcSmokes(root, positionals, envOverrides)
    if len(tailOnly) > 0:
        v3GatePrintErr("v3 stage2/stage3 libp2p: unknown --tail-only: " + tailOnly)
        return 1
    var tests: str[] = v3GateDefaultStage23Smokes()
    var runTail: bool = true
    if positionals.len > 0:
        tests = positionals
        runTail = false
    for i in 0..<tests.len:
        let smokeName: str = tests[i]
        let stage2Bin: str = os.JoinPath(outDir, smokeName + ".stage2")
        if v3GateRunSingleFixtureSmoke(root,
                                       "v3 stage2/stage3 libp2p",
                                       stage2,
                                       smokeName,
                                       stage2Bin,
                                       "stage2",
                                       envOverrides) != 0:
            return 1
        if smokeName == "libp2p_tcp_smoke":
            if v3GateRunTcpTwoprocSmoke(root, stage2, "stage2", envOverrides) != 0:
                return 1
        if smokeName == "libp2p_quic_tls_smoke":
            if v3GateRunQuicTwoprocSmoke(root, stage2, "stage2", envOverrides) != 0:
                return 1
        let stage3Bin: str = os.JoinPath(outDir, smokeName + ".stage3")
        if v3GateRunSingleFixtureSmoke(root,
                                       "v3 stage2/stage3 libp2p",
                                       stage3,
                                       smokeName,
                                       stage3Bin,
                                       "stage3",
                                       envOverrides) != 0:
            return 1
        if smokeName == "libp2p_tcp_smoke":
            if v3GateRunTcpTwoprocSmoke(root, stage3, "stage3", envOverrides) != 0:
                return 1
        if smokeName == "libp2p_quic_tls_smoke":
            if v3GateRunQuicTwoprocSmoke(root, stage3, "stage3", envOverrides) != 0:
                return 1
    if runTail:
        if v3GateRunChainNodeCliSmoke(root, stage2, "stage2", envOverrides) != 0:
            return 1
        if v3GateRunChainNodeCliSmoke(root, stage3, "stage3", envOverrides) != 0:
            return 1
        if v3GateRunChainNodeProcessSmokeWithCompiler(root, stage2, "stage2", envOverrides) != 0:
            return 1
        if v3GateRunChainNodeProcessSmokeWithCompiler(root, stage3, "stage3", envOverrides) != 0:
            return 1
        if v3GateRunChainNodeThreeNodeSmokeWithCompiler(root, stage2, "stage2", envOverrides) != 0:
            return 1
        if v3GateRunChainNodeThreeNodeSmokeWithCompiler(root, stage3, "stage3", envOverrides) != 0:
            return 1
        if v3GateRunTailnetControlSmoke(root, stage2, "stage2", envOverrides) != 0:
            return 1
        if v3GateRunTailnetControlSmoke(root, stage3, "stage3", envOverrides) != 0:
            return 1
        if v3GateRunFreshNodeSelfhostGate(root, stage2, "stage2", envOverrides) != 0:
            return 1
        if v3GateRunFreshNodeSelfhostGate(root, stage3, "stage3", envOverrides) != 0:
            return 1
        if v3GateRunMigrationGate(root, stage2, "stage2", envOverrides) != 0:
            return 1
        if v3GateRunMigrationGate(root, stage3, "stage3", envOverrides) != 0:
            return 1
        if v3GateRunBrowserWebrtcSmokes(root, [], envOverrides) != 0:
            return 1
    v3GatePrintLine("v3 stage2/stage3 libp2p: ok")
    return 0

fn v3GateBuildZeroExit(root: str): int32 =
    var compiler = ""
    if v3GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_zero_exit")
    let src: str = v3path.V3PathAbsolute(root, "v3/src/tests/ordinary_zero_exit_fixture.cheng")
    let outBin: str = os.JoinPath(outDir, "ordinary_zero_exit_fixture")
    let compileLog = "artifacts/v3_zero_exit/ordinary_zero_exit_fixture.compile.log"
    let compileRun = v3GateCompileExe(root,
                                      "build_zero_exit",
                                      compiler,
                                      src,
                                      outBin,
                                      "arm64-apple-darwin",
                                      compileLog)
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outBin) || !os.FileExists(outBin + ".v3.map"):
        v3GatePrintErr("v3 zero-exit: missing output or line-map")
        return 1
    let run = v3GateRunBinary(root,
                              "build_zero_exit_run",
                              outBin,
                              [],
                              20,
                              "artifacts/v3_zero_exit/ordinary_zero_exit_fixture.run.log")
    v3GateMaybePrintRunOutput(run)
    if v3GateRunFailed(run):
        return run.exitCode
    return 0

