fn v3GateBuildFfiHandle(root: str): int32 =
    var compiler = ""
    if v3GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_ffi_handle")
    let okSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/ffi_handle_smoke.cheng")
    let reuseSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/ffi_handle_generation_reuse_smoke.cheng")
    let trapSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/ffi_handle_stale_trap_smoke.cheng")
    let staleReuseSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/ffi_handle_generation_stale_trap_smoke.cheng")
    let okBin: str = os.JoinPath(outDir, "ffi_handle_smoke")
    let reuseBin: str = os.JoinPath(outDir, "ffi_handle_generation_reuse_smoke")
    let trapBin: str = os.JoinPath(outDir, "ffi_handle_stale_trap_smoke")
    let staleReuseBin: str = os.JoinPath(outDir, "ffi_handle_generation_stale_trap_smoke")
    let okCompileLog = "artifacts/v3_ffi_handle/ffi_handle_smoke.compile.log"
    let okCompile = v3GateCompileExe(root,
                                     "build_ffi_handle_ok",
                                     compiler,
                                     okSrc,
                                     okBin,
                                     "arm64-apple-darwin",
                                     okCompileLog)
    if v3GateRunFailed(okCompile):
        return okCompile.exitCode
    let reuseCompileLog = "artifacts/v3_ffi_handle/ffi_handle_generation_reuse_smoke.compile.log"
    let reuseCompile = v3GateCompileExe(root,
                                        "build_ffi_handle_generation_reuse",
                                        compiler,
                                        reuseSrc,
                                        reuseBin,
                                        "arm64-apple-darwin",
                                        reuseCompileLog)
    if v3GateRunFailed(reuseCompile):
        return reuseCompile.exitCode
    let trapCompileLog = "artifacts/v3_ffi_handle/ffi_handle_stale_trap_smoke.compile.log"
    let trapCompile = v3GateCompileExe(root,
                                       "build_ffi_handle_trap",
                                       compiler,
                                       trapSrc,
                                       trapBin,
                                       "arm64-apple-darwin",
                                       trapCompileLog)
    if v3GateRunFailed(trapCompile):
        return trapCompile.exitCode
    let staleReuseCompileLog = "artifacts/v3_ffi_handle/ffi_handle_generation_stale_trap_smoke.compile.log"
    let staleReuseCompile = v3GateCompileExe(root,
                                             "build_ffi_handle_stale_reuse_trap",
                                             compiler,
                                             staleReuseSrc,
                                             staleReuseBin,
                                             "arm64-apple-darwin",
                                             staleReuseCompileLog)
    if v3GateRunFailed(staleReuseCompile):
        return staleReuseCompile.exitCode
    if !os.FileExists(okBin + ".v3.map") || !os.FileExists(reuseBin + ".v3.map") ||
       !os.FileExists(trapBin + ".v3.map") ||
       !os.FileExists(staleReuseBin + ".v3.map"):
        v3GatePrintErr("v3 ffi-handle: missing line-map sidecar")
        return 1
    let okRun = v3GateRunBinary(root,
                                "build_ffi_handle_ok_run",
                                okBin,
                                [],
                                20,
                                "artifacts/v3_ffi_handle/ffi_handle_smoke.run.log")
    v3GateMaybePrintRunOutput(okRun)
    if v3GateRunFailed(okRun):
        return okRun.exitCode
    let reuseRun = v3GateRunBinary(root,
                                   "build_ffi_handle_generation_reuse_run",
                                   reuseBin,
                                   [],
                                   20,
                                   "artifacts/v3_ffi_handle/ffi_handle_generation_reuse_smoke.run.log")
    v3GateMaybePrintRunOutput(reuseRun)
    if v3GateRunFailed(reuseRun):
        return reuseRun.exitCode
    let trapRun = v3GateRunBinary(root,
                                  "build_ffi_handle_trap_run",
                                  trapBin,
                                  [],
                                  20,
                                  "artifacts/v3_ffi_handle/ffi_handle_stale_trap_smoke.run.log")
    v3GateMaybePrintRunOutput(trapRun)
    if trapRun.exitCode == 0:
        v3GatePrintErr("v3 ffi-handle: stale trap unexpectedly exited 0")
        return 1
    if !v3GateRequireOutput(trapRun, "ffi handle invalid", "v3 ffi-handle") ||
       !v3GateRequireOutput(trapRun, "reason=ffi_handle", "v3 ffi-handle") ||
       !v3GateRequireOutput(trapRun, "ffi_handle_stale_trap_smoke.cheng:", "v3 ffi-handle"):
        return 1
    let staleReuseRun = v3GateRunBinary(root,
                                        "build_ffi_handle_stale_reuse_trap_run",
                                        staleReuseBin,
                                        [],
                                        20,
                                        "artifacts/v3_ffi_handle/ffi_handle_generation_stale_trap_smoke.run.log")
    v3GateMaybePrintRunOutput(staleReuseRun)
    if staleReuseRun.exitCode == 0:
        v3GatePrintErr("v3 ffi-handle: stale reuse trap unexpectedly exited 0")
        return 1
    if !v3GateRequireOutput(staleReuseRun, "ffi handle invalid", "v3 ffi-handle") ||
       !v3GateRequireOutput(staleReuseRun, "detail=stale", "v3 ffi-handle") ||
       !v3GateRequireOutput(staleReuseRun, "reason=ffi_handle", "v3 ffi-handle") ||
       !v3GateRequireOutput(staleReuseRun, "ffi_handle_generation_stale_trap_smoke.cheng:", "v3 ffi-handle"):
        return 1
    return 0

fn v3GateReadProgramTrim(root: str,
                         label: str,
                         programName: str,
                         args: str[],
                         logRelPath: str): str =
    let run: hostops.V3LoggedRun = hostops.v3RunProgramLogged(root,
                                                              label,
                                                              programName,
                                                              args,
                                                              [],
                                                              root,
                                                              20,
                                                              logRelPath)
    if v3GateRunFailed(run):
        return ""
    return strutil.Strip(run.output)

fn v3GateHostTarget(root: str): str =
    let hostOs: str = v3GateReadProgramTrim(root, "v3 host uname-s", "uname", ["-s"], "artifacts/v3_gate/uname_s.log")
    let hostArch: str = v3GateReadProgramTrim(root,
                                              "v3 host uname-m",
                                              "uname",
                                              ["-m"],
                                              "artifacts/v3_gate/uname_m.log")
    if hostOs == "Darwin" && hostArch == "arm64":
        return "arm64-apple-darwin"
    if hostOs == "Linux" && hostArch == "x86_64":
        return "x86_64-unknown-linux-gnu"
    if hostOs == "Linux" && (hostArch == "aarch64" || hostArch == "arm64"):
        return "aarch64-unknown-linux-gnu"
    return ""

fn v3GateCompileExeFromEnv(root: str): int32 =
    let explicitCompiler: str = os.GetEnvDefault("CHENG_V3_COMPILE_COMPILER", "")
    var compiler = ""
    if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_COMPILE_COMPILER", "", compiler) != 0:
        return 1
    let packageRoot: str = v3path.V3PathAbsolute(root, os.GetEnvDefault("CHENG_V3_COMPILE_ROOT", "v3"))
    let src: str = v3path.V3PathAbsolute(root, os.GetEnvDefault("CHENG_V3_COMPILE_SOURCE", ""))
    let outBin: str = v3path.V3PathAbsolute(root, os.GetEnvDefault("CHENG_V3_COMPILE_OUT", ""))
    let target: str = strutil.Strip(os.GetEnvDefault("CHENG_V3_COMPILE_TARGET", "arm64-apple-darwin"))
    let label: str = os.GetEnvDefault("CHENG_V3_COMPILE_LABEL", "v3 compile-exe")
    let logPath: str = os.GetEnvDefault("CHENG_V3_COMPILE_LOG", outBin + ".compile.log")
    let reportPath: str = strutil.Strip(os.GetEnvDefault("CHENG_V3_COMPILE_REPORT", ""))
    if len(src) <= 0 || !os.FileExists(src):
        v3GatePrintErr("v3 compile-exe: missing source: " + src)
        return 1
    if len(outBin) <= 0:
        v3GatePrintErr("v3 compile-exe: missing out path")
        return 1
    var args: str[] = [
        "system-link-exec",
        "--root", packageRoot,
        "--in", src,
        "--emit", "exe",
        "--target", target,
        "--out", outBin
    ]
    if len(reportPath) > 0:
        add(args, "--report-out")
        add(args, v3path.V3PathAbsolute(root, reportPath))
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                           label,
                                                           compiler,
                                                           args,
                                                           [],
                                                           root,
                                                           int32(strutil.ParseInt(
                                                               os.GetEnvDefault("CHENG_V3_COMPILE_TIMEOUT_SEC",
                                                                                "300"))),
                                                           logPath)
    if v3GateRunFailed(run):
        return run.exitCode
    return 0

fn v3GateBuildLinuxNolibcExe(root: str): int32 =
    let targetRaw: str = strutil.Strip(os.GetEnvDefault("CHENG_V3_LINUX_EXE_TARGET", "aarch64-unknown-linux-gnu"))
    let sourcePath: str = strutil.Strip(os.GetEnvDefault("CHENG_V3_LINUX_EXE_SOURCE", ""))
    let outBin: str = strutil.Strip(os.GetEnvDefault("CHENG_V3_LINUX_EXE_OUT", ""))
    if len(sourcePath) <= 0:
        v3GatePrintErr("v3 linux exe: missing CHENG_V3_LINUX_EXE_SOURCE")
        return 1
    if len(outBin) <= 0:
        v3GatePrintErr("v3 linux exe: missing CHENG_V3_LINUX_EXE_OUT")
        return 1
    var target = targetRaw
    if target == "arm64-unknown-linux-gnu":
        target = "aarch64-unknown-linux-gnu"
    if target != "aarch64-unknown-linux-gnu":
        v3GatePrintErr("v3 linux exe: unsupported target=" + targetRaw)
        return 1
    let explicitCompiler: str = os.GetEnvDefault("CHENG_V3_LINUX_EXE_COMPILER", "")
    var compiler = ""
    if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_LINUX_EXE_COMPILER", "", compiler) != 0:
        return 1
    let packageRoot: str = v3path.V3PathAbsolute(root, "v3")
    let reportPath: str = strutil.Strip(os.GetEnvDefault("CHENG_V3_LINUX_EXE_REPORT", ""))
    var args: str[] = [
        "system-link-exec",
        "--root", packageRoot,
        "--in", v3path.V3PathAbsolute(root, sourcePath),
        "--emit", "exe",
        "--target", target,
        "--out", v3path.V3PathAbsolute(root, outBin)
    ]
    if len(reportPath) > 0:
        add(args, "--report-out")
        add(args, v3path.V3PathAbsolute(root, reportPath))
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                           "v3 linux exe",
                                                           compiler,
                                                           args,
                                                           [],
                                                           root,
                                                           int32(strutil.ParseInt(
                                                               os.GetEnvDefault("CHENG_V3_COMPILE_TIMEOUT_SEC",
                                                                                "300"))),
                                                           v3path.V3PathAbsolute(root, outBin) + ".compile.log")
    if v3GateRunFailed(run):
        return run.exitCode
    return 0

fn v3GateBuildBftStateMachine(root: str): int32 =
    var compiler = ""
    if v3GateResolveSmokeCompiler(root, "", "CHENG_V3_BFT_COMPILER", "", compiler) != 0:
        return 1
    let target: str = os.GetEnvDefault("BFT_STATE_TARGET", "arm64-apple-darwin")
    var defaultOutDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_bft_state_machine")
    if target != "arm64-apple-darwin":
        defaultOutDir = os.JoinPath(defaultOutDir, target)
    let outDir: str = os.GetEnvDefault("BFT_STATE_OUT_DIR", defaultOutDir)
    let src: str = v3path.V3PathAbsolute(root, "v3/src/project/bft_state_machine_main.cheng")
    let outBin: str = os.GetEnvDefault("BFT_STATE_OUT_BIN", os.JoinPath(outDir, "bft_state_machine"))
    var runSelfTestDefault = "0"
    if target == v3GateHostTarget(root):
        runSelfTestDefault = "1"
    let runSelfTest: str = os.GetEnvDefault("BFT_STATE_RUN_SELF_TEST", runSelfTestDefault)
    let runLog = os.JoinPath(outDir, "bft_state_machine.self-test.log")
    if v3GateBftBuildReady(root, compiler, src, outBin, runLog, runSelfTest):
        if runSelfTest != "0":
            let cached = v3path.V3ReadTextFile("", runLog)
            if len(cached) > 0:
                v3GatePrintLine(strutil.Strip(cached))
            else:
                v3GatePrintLine("v3 bft_state_machine self-test ok")
        else:
            v3GatePrintLine("v3 bft_state_machine: build ok target=" + target + " out=" + outBin)
        return 0
    let compileRun = v3GateCompileExe(root,
                                      "build_bft_state_machine",
                                      compiler,
                                      src,
                                      outBin,
                                      target,
                                      os.JoinPath(outDir, "bft_state_machine.compile.log"))
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    if runSelfTest != "0":
        let run = v3GateRunBinary(root,
                                  "build_bft_state_machine_run",
                                  outBin,
                                  ["self-test"],
                                  60,
                                  runLog)
        v3GateMaybePrintRunOutput(run)
        if v3GateRunFailed(run):
            return run.exitCode
    else:
        v3GatePrintLine("v3 bft_state_machine: build ok target=" + target + " out=" + outBin)
    return 0

fn v3GateOracleBftPairText(): str =
    return "BTC/USD"

fn v3GateOracleBftQueryNowRound(): int64 =
    return int64(22)

fn v3GateOracleBftTwapWindowRounds(): int32 =
    return 3

fn v3GateOracleBftExpectedRound(): int64 =
    return int64(22)

fn v3GateOracleBftPairId(): int32 =
    return oracle_fixture.oracleSmokePairId(oracle_types.v3OracleAssetBtc, oracle_types.v3OracleQuoteUsd)

fn v3GateOracleBftExpectedLatestPrice(): int64 =
    let pairIndex = oracle_types.v3OraclePairIndex(v3GateOracleBftPairId())
    return oracle_fixture.oracleSmokePrice(v3GateOracleBftExpectedRound(), pairIndex, 3)

fn v3GateOracleBftExpectedTwapPrice(): int64 =
    let pairIndex = oracle_types.v3OraclePairIndex(v3GateOracleBftPairId())
    return (oracle_fixture.oracleSmokePrice(int64(20), pairIndex, 3) +
            oracle_fixture.oracleSmokePrice(int64(21), pairIndex, 3) +
            oracle_fixture.oracleSmokePrice(int64(22), pairIndex, 3)) / int64(3)

fn v3GateOracleBftThreeNodeConfig(root: str): V3OracleBftThreeNodeDeploy =
    var deployRel = ""
    var remoteDeployRel = ""
    var out: V3OracleBftThreeNodeDeploy
    deployRel = os.GetEnvDefault("CHENG_V3_ORACLE_BFT_DEPLOY_DIR", "artifacts/v3_oracle_bft_deploy")
    remoteDeployRel = os.GetEnvDefault("CHENG_V3_ORACLE_BFT_REMOTE_DEPLOY_REL", "artifacts/v3_oracle_bft_deploy")
    out.appId = os.GetEnvDefault("CHENG_V3_ORACLE_BFT_APP_ID", "cheng-oracle-live-20260419")
    out.serverSsh = os.GetEnvDefault("CHENG_V3_ORACLE_BFT_SERVER_SSH", "root@64.176.84.12")
    out.relaySsh = os.GetEnvDefault("CHENG_V3_ORACLE_BFT_RELAY_SSH", "dmit")
    out.serverRepoRoot = os.GetEnvDefault("CHENG_V3_ORACLE_BFT_SERVER_ROOT", "/root/cheng-lang-deploy")
    out.relayRepoRoot = os.GetEnvDefault("CHENG_V3_ORACLE_BFT_RELAY_ROOT", "/root/cheng-lang-deploy")
    out.localDeployDir = v3path.V3PathAbsolute(root, deployRel)
    out.remoteDeployRel = remoteDeployRel
    return out

fn v3GateOracleBftManifestPath(cfg: V3OracleBftThreeNodeDeploy): str =
    return os.JoinPath(cfg.localDeployDir, "deploy.env")

fn v3GateOracleBftManifestText(cfg: V3OracleBftThreeNodeDeploy): str =
    var out = ""
    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "server_ssh=" + cfg.serverSsh + "\n"
    out = out + "relay_ssh=" + cfg.relaySsh + "\n"
    out = out + "server_root=" + cfg.serverRepoRoot + "\n"
    out = out + "relay_root=" + cfg.relayRepoRoot + "\n"
    out = out + "local_deploy_dir=" + cfg.localDeployDir + "\n"
    out = out + "remote_deploy_rel=" + cfg.remoteDeployRel + "\n"
    return out

fn v3GateOracleBftConfigLoad(root: str): V3OracleBftThreeNodeDeploy =
    var cfg = v3GateOracleBftThreeNodeConfig(root)
    let manifestPath = v3GateOracleBftManifestPath(cfg)
    if !os.FileExists(manifestPath):
        return cfg
    let text = v3path.V3ReadTextFile("", manifestPath)
    let appId = v3GateTextValue(text, "app_id")
    if len(appId) > 0:
        cfg.appId = appId
    let serverSsh = v3GateTextValue(text, "server_ssh")
    if len(serverSsh) > 0:
        cfg.serverSsh = serverSsh
    let relaySsh = v3GateTextValue(text, "relay_ssh")
    if len(relaySsh) > 0:
        cfg.relaySsh = relaySsh
    let serverRoot = v3GateTextValue(text, "server_root")
    if len(serverRoot) > 0:
        cfg.serverRepoRoot = serverRoot
    let relayRoot = v3GateTextValue(text, "relay_root")
    if len(relayRoot) > 0:
        cfg.relayRepoRoot = relayRoot
    let localDir = v3GateTextValue(text, "local_deploy_dir")
    if len(localDir) > 0:
        cfg.localDeployDir = localDir
    let remoteRel = v3GateTextValue(text, "remote_deploy_rel")
    if len(remoteRel) > 0:
        cfg.remoteDeployRel = remoteRel
    return cfg

fn v3GateOracleBftRemoteDeployDir(repoRoot: str, cfg: V3OracleBftThreeNodeDeploy): str =
    return v3path.V3PathAbsolute(repoRoot, cfg.remoteDeployRel)

fn v3GateOracleBftRemoteBin(repoRoot: str): str =
    return os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "v3_oracle_bft_state_machine"),
                       os.JoinPath("x86_64-unknown-linux-gnu", "oracle_bft_state_machine"))

fn v3GateOracleBftLocalBin(root: str): str =
    return v3path.V3PathAbsolute(root, "artifacts/v3_oracle_bft_state_machine/oracle_bft_state_machine")

fn v3GateOracleBftRemoteRunLog(repoRoot: str): str =
    let outDir = os.JoinPath(os.JoinPath(os.JoinPath(repoRoot, "artifacts"), "v3_oracle_bft_state_machine"),
                             "x86_64-unknown-linux-gnu")
    return os.JoinPath(outDir, "oracle_bft_state_machine.self-test.log")

fn v3GateOracleBftBuildReady(root: str,
                             compiler: str,
                             src: str,
                             outBin: str,
                             runLog: str,
                             runSelfTest: str): bool =
    if !os.FileExists(outBin):
        return false
    var command = "test -x " + os.QuoteShell(outBin) +
                  " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(outBin) +
                  " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(outBin)
    if runSelfTest != "0":
        if !os.FileExists(runLog):
            return false
        command = command +
                  " && test " + os.QuoteShell(outBin) + " -ot " + os.QuoteShell(runLog) +
                  " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(runLog) +
                  " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(runLog) +
                  " && grep -q " + os.QuoteShell("v3 oracle_bft_state_machine self-test ok") + " " + os.QuoteShell(runLog)
    return v3GateShellCheckOk(root, command)

fn v3GateBuildOracleBftStateMachine(root: str): int32 =
    var compiler = ""
    if v3GateResolveSmokeCompiler(root, "", "CHENG_V3_ORACLE_BFT_COMPILER", "", compiler) != 0:
        return 1
    let target = os.GetEnvDefault("ORACLE_BFT_STATE_TARGET", "arm64-apple-darwin")
    var defaultOutDir = v3path.V3PathAbsolute(root, "artifacts/v3_oracle_bft_state_machine")
    if target != "arm64-apple-darwin":
        defaultOutDir = os.JoinPath(defaultOutDir, target)
    let outDir = os.GetEnvDefault("ORACLE_BFT_STATE_OUT_DIR", defaultOutDir)
    let src = v3path.V3PathAbsolute(root, "v3/src/project/oracle_bft_state_machine_main.cheng")
    let outBin = os.GetEnvDefault("ORACLE_BFT_STATE_OUT_BIN", os.JoinPath(outDir, "oracle_bft_state_machine"))
    var runSelfTestDefault = "0"
    if target == v3GateHostTarget(root):
        runSelfTestDefault = "1"
    let runSelfTest = os.GetEnvDefault("ORACLE_BFT_STATE_RUN_SELF_TEST", runSelfTestDefault)
    let runLog = os.JoinPath(outDir, "oracle_bft_state_machine.self-test.log")
    if v3GateOracleBftBuildReady(root, compiler, src, outBin, runLog, runSelfTest):
        if runSelfTest != "0":
            let cached = v3path.V3ReadTextFile("", runLog)
            if len(cached) > 0:
                v3GatePrintLine(strutil.Strip(cached))
            else:
                v3GatePrintLine("v3 oracle_bft_state_machine self-test ok")
        else:
            v3GatePrintLine("v3 oracle_bft_state_machine: build ok target=" + target + " out=" + outBin)
        return 0
    let compileRun = v3GateCompileExe(root,
                                      "build_oracle_bft_state_machine",
                                      compiler,
                                      src,
                                      outBin,
                                      target,
                                      os.JoinPath(outDir, "oracle_bft_state_machine.compile.log"))
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    if runSelfTest != "0":
        let run = v3GateRunBinary(root,
                                  "build_oracle_bft_state_machine_run",
                                  outBin,
                                  ["self-test"],
                                  60,
                                  runLog)
        v3GateMaybePrintRunOutput(run)
        if v3GateRunFailed(run):
            return run.exitCode
    else:
        v3GatePrintLine("v3 oracle_bft_state_machine: build ok target=" + target + " out=" + outBin)
    return 0

fn v3GateOracleBftRemoteBuildReadyCommand(repoRoot: str): str =
    let compiler = v3GateBftRemoteBackendDriver(repoRoot)
    let src = os.JoinPath(repoRoot, "v3/src/project/oracle_bft_state_machine_main.cheng")
    let outBin = v3GateOracleBftRemoteBin(repoRoot)
    let runLog = v3GateOracleBftRemoteRunLog(repoRoot)
    return "test -x " + os.QuoteShell(outBin) +
           " && test -x " + os.QuoteShell(compiler) +
           " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(outBin) +
           " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(outBin) +
           " && test " + os.QuoteShell(outBin) + " -ot " + os.QuoteShell(runLog) +
           " && test " + os.QuoteShell(compiler) + " -ot " + os.QuoteShell(runLog) +
           " && test " + os.QuoteShell(src) + " -ot " + os.QuoteShell(runLog) +
           " && grep -qF " + os.QuoteShell("v3 oracle_bft_state_machine self-test ok") +
           " " + os.QuoteShell(runLog)

fn v3GateOracleBftBuildRemote(root: str,
                              sshHost: str,
                              remoteRoot: str,
                              logPath: str): int32 =
    let readyRun = v3GateRunRemoteShellLogged(root,
                                              "oracle_bft_remote_ready",
                                              sshHost,
                                              "set -eu && " + v3GateOracleBftRemoteBuildReadyCommand(remoteRoot),
                                              logPath + ".ready.log",
                                              30)
    if !v3GateRunFailed(readyRun):
        v3GatePrintLine("[v3 gate] remote oracle bft reuse " + sshHost)
        return 0
    let stage3FreshRun = v3GateRunRemoteShellLogged(root,
                                                    "oracle_bft_remote_stage3_fresh",
                                                    sshHost,
                                                    "set -eu && " + v3GateBftRemoteStage3FreshCommand(remoteRoot),
                                                    logPath + ".stage3.log",
                                                    30)
    if !v3GateRunFailed(stage3FreshRun):
        let incrementalCommand = v3GateBftRemoteLockedShell(
            remoteRoot,
            "ORACLE_BFT_STATE_TARGET=x86_64-unknown-linux-gnu" +
            " ORACLE_BFT_STATE_RUN_SELF_TEST=1" +
            " artifacts/v3_bootstrap/cheng.stage3 build-oracle-bft-state-machine")
        let incrementalRun = v3GateRunRemoteShellLogged(root,
                                                        "oracle_bft_remote_build_incremental",
                                                        sshHost,
                                                        incrementalCommand,
                                                        logPath,
                                                        900)
        if v3GateRunFailed(incrementalRun):
            return incrementalRun.exitCode
        v3GatePrintLine("[v3 gate] remote oracle bft incremental " + sshHost)
        return 0
    let fullCommand = v3GateBftRemoteLockedShell(
        remoteRoot,
        "mkdir -p artifacts/v3_bootstrap" +
        " && cc -std=c11 -O2 -Wall -Wextra -pedantic" +
        " v3/bootstrap/cheng_v3_seed.c -o artifacts/v3_bootstrap/cheng.stage0" +
        " && CHENG_V3_ROOT=" + os.QuoteShell(remoteRoot) +
        " CHENG_V3_TARGET=x86_64-unknown-linux-gnu" +
        " artifacts/v3_bootstrap/cheng.stage0 bootstrap-bridge >/dev/null" +
        " && ORACLE_BFT_STATE_TARGET=x86_64-unknown-linux-gnu" +
        " ORACLE_BFT_STATE_RUN_SELF_TEST=1" +
        " artifacts/v3_bootstrap/cheng.stage3 build-oracle-bft-state-machine")
    let run = v3GateRunRemoteShellLogged(root, "oracle_bft_remote_build", sshHost, fullCommand, logPath, 900)
    if v3GateRunFailed(run):
        return run.exitCode
    v3GatePrintLine("[v3 gate] remote oracle bft rebuild " + sshHost)
    return 0

fn v3GateOracleBftNodeStatusZero(name: str): V3OracleBftNodeStatus =
    var out: V3OracleBftNodeStatus
    out.name = name
    out.summary = ""
    out.latestQuery = ""
    out.twapQuery = ""
    out.height = ""
    out.lastFinalizedRoundId = ""
    out.appHash = ""
    out.latestCode = ""
    out.latestRoundId = ""
    out.latestPriceE8 = ""
    out.twapCode = ""
    out.twapPriceE8 = ""
    return out

fn v3GateOracleBftCollectLocalNodeStatus(root: str,
                                         nodeName: str,
                                         statePath: str,
                                         logPrefix: str): Result[V3OracleBftNodeStatus] =
    let binPath = v3GateOracleBftLocalBin(root)
    let summaryRun = hostops.v3RunFileLogged(root,
                                             nodeName + "_oracle_show_state",
                                             binPath,
                                             ["show-state", "--state:" + statePath],
                                             [],
                                             root,
                                             20,
                                             logPrefix + ".show.log")
    if !hostops.v3LoggedRunOk(summaryRun):
        return Err[V3OracleBftNodeStatus](summaryRun.output)
    let latestRun = hostops.v3RunFileLogged(root,
                                            nodeName + "_oracle_latest",
                                            binPath,
                                            ["query-latest",
                                             "--state:" + statePath,
                                             "--pair:" + v3GateOracleBftPairText(),
                                             "--now-round:" + strings.Int64ToStr(v3GateOracleBftQueryNowRound())],
                                            [],
                                            root,
                                            20,
                                            logPrefix + ".latest.log")
    if !hostops.v3LoggedRunOk(latestRun):
        return Err[V3OracleBftNodeStatus](latestRun.output)
    let twapRun = hostops.v3RunFileLogged(root,
                                          nodeName + "_oracle_twap",
                                          binPath,
                                          ["query-twap",
                                           "--state:" + statePath,
                                           "--pair:" + v3GateOracleBftPairText(),
                                           "--window-rounds:" + intToStr(v3GateOracleBftTwapWindowRounds()),
                                           "--now-round:" + strings.Int64ToStr(v3GateOracleBftQueryNowRound())],
                                          [],
                                          root,
                                          20,
                                          logPrefix + ".twap.log")
    if !hostops.v3LoggedRunOk(twapRun):
        return Err[V3OracleBftNodeStatus](twapRun.output)
    return Ok[V3OracleBftNodeStatus](V3OracleBftNodeStatus(
        name: nodeName,
        summary: summaryRun.output,
        latestQuery: latestRun.output,
        twapQuery: twapRun.output,
        height: strutil.Strip(v3GateTextValue(summaryRun.output, "height")),
        lastFinalizedRoundId: strutil.Strip(v3GateTextValue(summaryRun.output, "last_finalized_round_id")),
        appHash: strutil.Strip(v3GateTextValue(summaryRun.output, "app_hash")),
        latestCode: strutil.Strip(v3GateTextValue(latestRun.output, "code")),
        latestRoundId: strutil.Strip(v3GateTextValue(latestRun.output, "round_id")),
        latestPriceE8: strutil.Strip(v3GateTextValue(latestRun.output, "price_e8")),
        twapCode: strutil.Strip(v3GateTextValue(twapRun.output, "code")),
        twapPriceE8: strutil.Strip(v3GateTextValue(twapRun.output, "price_e8"))
    ))

