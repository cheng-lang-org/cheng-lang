    return 0

fn v3GateVerifyDiLoCoStage(root: str,
                           compilerPath: str,
                           stageName: str,
                           packageRoot: str,
                           envOverrides: str[]): int32 =
    let singleSmokes = ["diloco_state_smoke", "diloco_wire_smoke"]
    for i in 0..<singleSmokes.len:
        let smokeName = singleSmokes[i]
        if v3GateRunDiLoCoSingleSmoke(root,
                                      compilerPath,
                                      stageName,
                                      packageRoot,
                                      smokeName,
                                      envOverrides) != 0:
            return 1
    return v3GateRunDiLoCoQuicTwoprocSmoke(root,
                                           compilerPath,
                                           stageName,
                                           packageRoot,
                                           envOverrides)

fn v3GateVerifyDiLoCo(root: str): int32 =
    if v3GateEnsureBootstrapBridge(root) != 0:
        return 1
    let packageRoot: str = v3path.V3PathAbsolute(root, "v3/DiLoCo")
    if !os.FileExists(os.JoinPath(packageRoot, "cheng-package.toml")):
        v3GatePrintErr("v3 diloco verify: missing package root: " + packageRoot)
        return 1
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_diloco")
    if !v3path.V3MkdirP(root, outDir):
        v3GatePrintErr("v3 diloco verify: failed to create out dir")
        return 1
    let stage2: str = contracts.v3BootstrapStage2Path(root)
    let stage3: str = contracts.v3BootstrapStage3Path(root)
    if !os.FileExists(stage2) || !os.FileExists(stage3):
        v3GatePrintErr("v3 diloco verify: missing bootstrap compiler")
        return 1
    if v3GateVerifyDiLoCoStage(root, stage3, "host", packageRoot, []) != 0:
        return 1
    let stage23Env: str[] = v3GateStage23EnvOverrides()
    if v3GateVerifyDiLoCoStage(root, stage2, "stage2", packageRoot, stage23Env) != 0:
        return 1
    if v3GateVerifyDiLoCoStage(root, stage3, "stage3", packageRoot, stage23Env) != 0:
        return 1
    v3GatePrintLine("v3 verify-diloco ok")
    return 0

fn v3GateRequireWasmAudit(label: str,
                          wasmPath: str,
                          expectedExports: str[],
                          expectedImports: str[],
                          minExportCount: int32): bool =
    let infoRes = wasmaudit.v3WasmBinaryInspect(wasmPath)
    if IsErr(infoRes):
        v3GatePrintErr(label + ": " + Error(infoRes))
        return false
    let info = Value(infoRes)
    if info.exportNames.len < minExportCount:
        v3GatePrintErr(label + ": wasm export count too small: " + strings.IntToStr(info.exportNames.len))
        return false
    for i in 0..<expectedExports.len:
        if !wasmaudit.v3WasmBinaryHasExport(info, expectedExports[i]):
            v3GatePrintErr(label + ": missing wasm export: " + expectedExports[i])
            return false
    for i in 0..<expectedImports.len:
        if !wasmaudit.v3WasmBinaryHasImport(info, expectedImports[i]):
            v3GatePrintErr(label + ": missing wasm import: " + expectedImports[i])
            return false
    return true

fn v3GateRunWasmSmokes(root: str,
                       compilerPath: str,
                       label: str,
                       envOverrides: str[]): int32 =
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_wasm_smokes")
    let names: str[] = [
        "wasm_zero_smoke",
        "wasm_internal_call_smoke",
        "wasm_importc_noarg_i32_smoke",
        "wasm_shadowed_local_scope_smoke"
    ]
    var jobs: hostops.V3ParallelJob[] = []
    for i in 0..<names.len:
        let smokeName: str = names[i]
        let src: str = v3path.V3PathAbsolute(root, "v3/src/tests/" + smokeName + ".cheng")
        let outWasm: str = os.JoinPath(outDir, smokeName + "." + label + ".wasm")
        let spawnRes = v3GateCompileExeSpawnEnv(root,
                                                "v3 wasm smokes compile " + smokeName + " " + label,
                                                compilerPath,
                                                src,
                                                outWasm,
                                                "wasm32-unknown-unknown",
                                                os.JoinPath(outDir, smokeName + "." + label + ".compile.log"),
                                                envOverrides)
        if IsErr(spawnRes):
            v3GatePrintErr(Error(spawnRes))
            hostops.v3ParallelStopAll(root, jobs, 124)
            return 1
        add(jobs, Value(spawnRes))
    var failedRun = hostops.v3LoggedRunZero("", "", "", 0, "")
    if !hostops.v3ParallelWaitFailfast(root,
                                       jobs,
                                       int32(strutil.ParseInt(
                                           os.GetEnvDefault("CHENG_V3_COMPILE_TIMEOUT_SEC",
                                                            "300"))),
                                       failedRun):
        if v3GateRunFailed(failedRun):
            return failedRun.exitCode
        return 1
    for i in 0..<names.len:
        let smokeName: str = names[i]
        let outWasm: str = os.JoinPath(outDir, smokeName + "." + label + ".wasm")
        if !os.FileExists(outWasm):
            v3GatePrintErr("v3 wasm smokes: missing wasm output: " + outWasm)
            return 1
    var expectedExports: str[] = []
    add(expectedExports, "main")
    if !v3GateRequireWasmAudit("v3 wasm audit zero",
                               os.JoinPath(outDir, "wasm_zero_smoke." + label + ".wasm"),
                               expectedExports,
                               [],
                               1):
        return 1
    if !v3GateRequireWasmAudit("v3 wasm audit internal",
                               os.JoinPath(outDir, "wasm_internal_call_smoke." + label + ".wasm"),
                               expectedExports,
                               [],
                               1):
        return 1
    if !v3GateRequireWasmAudit("v3 wasm audit importc",
                               os.JoinPath(outDir, "wasm_importc_noarg_i32_smoke." + label + ".wasm"),
                               expectedExports,
                               ["env.cheng_test_zero"],
                               1):
        return 1
    let hostTarget = v3GateHostTarget(root)
    if len(hostTarget) <= 0:
        v3GatePrintErr("v3 wasm smokes: unsupported host target")
        return 1
    for i in 0..<names.len:
        let smokeName: str = names[i]
        if smokeName == "wasm_importc_noarg_i32_smoke":
            v3GatePrintLine(smokeName + ": ok")
            continue
        var hostSrc: str = v3path.V3PathAbsolute(root, "v3/src/tests/" + smokeName + ".cheng")
        let hostBin = os.JoinPath(outDir, smokeName + "." + label + ".host")
        let hostCompile = v3GateCompileExeEnv(root,
                                              "v3 wasm host compile " + smokeName + " " + label,
                                              compilerPath,
                                              hostSrc,
                                              hostBin,
                                              hostTarget,
                                              os.JoinPath(outDir, smokeName + "." + label + ".host.compile.log"),
                                              envOverrides)
        if v3GateRunFailed(hostCompile):
            return hostCompile.exitCode
        let run = hostops.v3RunFileLogged(root,
                                          "v3 wasm host run " + smokeName + " " + label,
                                          hostBin,
                                          [],
                                          [],
                                          root,
                                          0,
                                          os.JoinPath(outDir, smokeName + "." + label + ".host.run.log"))
        if v3GateRunFailed(run):
            return run.exitCode
        v3GatePrintLine(smokeName + ": ok")
    v3GatePrintLine("v3 wasm smokes: ok")
    return 0

fn v3GateRunBrowserHostWasmSmoke(root: str,
                                 compilerPath: str,
                                 label: str,
                                 envOverrides: str[]): int32 =
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_browser_host_wasm")
    let src: str = v3path.V3PathAbsolute(root, "v3/src/libp2p/browser/browser_host_wasm_probe.cheng")
    let outWasm: str = os.JoinPath(outDir, "cheng_browser_host_abi." + label + ".wasm")
    let compileRun = v3GateCompileEmitEnv(root,
                                          "v3 browser host wasm compile " + label,
                                          compilerPath,
                                          src,
                                          "shared",
                                          outWasm,
                                          "wasm32-unknown-unknown",
                                          os.JoinPath(outDir, "cheng_browser_host_abi." + label + ".compile.log"),
                                          envOverrides)
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outWasm):
        v3GatePrintErr("v3 browser host wasm smoke: missing wasm output: " + outWasm)
        return 1
    var expectedExports: str[] = []
    add(expectedExports, "main")
    add(expectedExports, "browserNowMs")
    add(expectedExports, "browserEchoI32")
    add(expectedExports, "browserPeerHandle")
    add(expectedExports, "browserDistributedVideoBuild")
    add(expectedExports, "browserDistributedVideoRebuild")
    add(expectedExports, "browserMoqFountainBuild")
    add(expectedExports, "browserMoqFountainBuildBytes")
    add(expectedExports, "browserMoqFountainRebuild")
    add(expectedExports, "browserMoqBuildLongBlobComputedBundleCidLenProbe")
    add(expectedExports, "browserMoqPeerCsvCountProbe")
    var expectedImports: str[] = []
    add(expectedImports, "env.cheng_v3_browser_now_ms_bridge")
    add(expectedImports, "env.cheng_v3_browser_echo_i32_bridge")
    add(expectedImports, "env.cheng_v3_browser_peer_handle_bridge")
    add(expectedImports, "env.cheng_v3_browser_did_handle_bridge")
    add(expectedImports, "env.cheng_v3_browser_dm_active_count_bridge")
    add(expectedImports, "env.cheng_v3_browser_dm_connect_start_bridge")
    add(expectedImports, "env.cheng_v3_browser_dm_wait_start_bridge")
    add(expectedImports, "env.cheng_v3_browser_dm_send_start_bridge")
    add(expectedImports, "env.cheng_v3_browser_distributed_video_build_bridge")
    add(expectedImports, "env.cheng_v3_browser_distributed_video_rebuild_bridge")
    add(expectedImports, "env.cheng_v3_browser_distributed_video_last_error_handle_bridge")
    add(expectedImports, "env.cheng_v3_browser_input_len_bridge")
    add(expectedImports, "env.cheng_v3_browser_input_copy_bridge")
    add(expectedImports, "env.cheng_v3_buffer_handle_from_raw_bridge")
    add(expectedImports, "env.cheng_v3_buffer_handle_from_text_bridge")
    add(expectedImports, "env.cheng_v3_browser_buffer_handle_len_bridge")
    add(expectedImports, "env.cheng_v3_browser_buffer_handle_byte_bridge")
    add(expectedImports, "env.cheng_v3_browser_buffer_handle_release_bridge")
    add(expectedImports, "env.cheng_v3_browser_moq_fountain_last_error_store_bridge")
    add(expectedImports, "env.cheng_v3_browser_moq_fountain_last_error_handle_bridge")
    if !v3GateRequireWasmAudit("v3 browser host wasm audit",
                               outWasm,
                               expectedExports,
                               expectedImports,
                               40):
        return 1
    let hostTarget = v3GateHostTarget(root)
    if len(hostTarget) <= 0:
        v3GatePrintErr("v3 browser host wasm smoke: unsupported host target")
        return 1
    let hostSrc = v3path.V3PathAbsolute(root, "v3/src/tests/browser_host_native_contract_smoke.cheng")
    let hostBin = os.JoinPath(outDir, "browser_host_native_contract_smoke." + label)
    let hostCompile = v3GateCompileExeEnv(root,
                                          "v3 browser host native compile " + label,
                                          compilerPath,
                                          hostSrc,
                                          hostBin,
                                          hostTarget,
                                          os.JoinPath(outDir, "browser_host_native_contract_smoke." + label + ".compile.log"),
                                          envOverrides)
    if v3GateRunFailed(hostCompile):
        return hostCompile.exitCode
    let run = hostops.v3RunFileLogged(root,
                                      "v3 browser host wasm smoke run " + label,
                                      hostBin,
                                      [],
                                      [],
                                      root,
                                      0,
                                      os.JoinPath(outDir, "browser_host_wasm." + label + ".run.log"))
    v3GateMaybePrintRunOutput(run)
    if v3GateRunFailed(run):
        return run.exitCode
    if !v3GateRequireOutput(run, "v3 browser host wasm smoke: ok", "v3 browser host wasm smoke"):
        return 1
    return 0

fn v3GateRunUdpImportcSmoke(root: str, args: str[]): int32 =
    let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_SMOKE_COMPILER", "", compiler) != 0:
        return 1
    let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_udp_importc")
    let src: str = v3path.V3PathAbsolute(root, "v3/src/tests/udp_importc_smoke.cheng")
    let bin: str = os.JoinPath(outDir, "udp_importc_smoke." + label)
    let compileRun = v3GateCompileExeEnv(root,
                                         "v3 udp importc compile " + label,
                                         compiler,
                                         src,
                                         bin,
                                         "arm64-apple-darwin",
                                         os.JoinPath(outDir, "udp_importc_smoke." + label + ".compile.log"),
                                         [])
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    let run = v3GateRunBinary(root,
                              "v3 udp importc run " + label,
                              bin,
                              [],
                              20,
                              os.JoinPath(outDir, "udp_importc_smoke." + label + ".run.log"))
    v3GateMaybePrintRunOutput(run)
    if v3GateRunFailed(run):
        return run.exitCode
    if !v3GateRequireOutput(run, "v3 udp_importc_smoke ok", "v3 udp importc smoke"):
        return 1
    return 0

fn v3GateBuildChainNodeBinary(root: str,
                              compilerPath: str,
                              outDir: str,
                              label: str,
                              envOverrides: str[],
                              outBin: var str): int32 =
    let src: str = v3path.V3PathAbsolute(root, "v3/src/project/cheng_node_main.cheng")
    outBin = os.JoinPath(outDir, "cheng_node_main")
    let compileRun = v3GateCompileExeEnv(root,
                                         label,
                                         compilerPath,
                                         src,
                                         outBin,
                                         "arm64-apple-darwin",
                                         os.JoinPath(outDir, "cheng_node_main.compile.log"),
                                         envOverrides)
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outBin):
        v3GatePrintErr("v3 chain_node cli smoke: missing cheng_node_main binary: " + outBin)
        return 1
    return 0

fn v3GateChainNodeRequireTextValue(text: str,
                                   key: str,
                                   expected: str,
                                   context: str): bool =
    let actual: str = strutil.Strip(v3GateTextValue(text, key))
    if actual == expected:
        return true
    v3GatePrintErr(context + ": expected " + key + "=" + expected + ", got " + actual)
    return false

fn v3GateChainNodeRequireRunValue(run: hostops.V3LoggedRun,
                                  key: str,
                                  expected: str,
                                  context: str): bool =
    return v3GateChainNodeRequireTextValue(run.output, key, expected, context)

fn v3GateChainNodeRequireMatchingRunValue(leftRun: hostops.V3LoggedRun,
                                          rightRun: hostops.V3LoggedRun,
                                          key: str,
                                          context: str): bool =
    let leftValue: str = strutil.Strip(v3GateTextValue(leftRun.output, key))
    let rightValue: str = strutil.Strip(v3GateTextValue(rightRun.output, key))
    if len(leftValue) > 0:
        if leftValue == rightValue:
            return true
    v3GatePrintErr(context + ": mismatched " + key + ": left=" + leftValue + " right=" + rightValue)
    return false

fn v3GateChainNodeRequireStateParity(authorRun: hostops.V3LoggedRun,
                                     replicaRun: hostops.V3LoggedRun,
                                     context: str): bool =
    if !v3GateChainNodeRequireMatchingRunValue(authorRun, replicaRun, "event_count", context):
        return false
    if !v3GateChainNodeRequireMatchingRunValue(authorRun, replicaRun, "tip_event_cid", context):
        return false
    if !v3GateChainNodeRequireMatchingRunValue(authorRun, replicaRun, "forest_cid", context):
        return false
    return true

fn v3GateRunChainNodeServeAndSync(root: str,
                                  label: str,
                                  chainNodeBin: str,
                                  serverState: str,
                                  clientState: str,
                                  clientNodeId: str,
                                  clientAddressSeed: str,
                                  outDir: str,
                                  roundTag: str,
                                  expectChanged: bool): int32 =
    let readyPath: str = os.JoinPath(outDir, roundTag + ".ready")
    let serverLog: str = os.JoinPath(outDir, roundTag + ".server.log")
    let syncLog: str = os.JoinPath(outDir, roundTag + ".sync.log")
    let _ = os.RemoveFile(readyPath)
    let serverSpawn = hostops.v3SpawnFile(root,
                                          "v3 chain_node resilience serve " + label + " " + roundTag,
                                          chainNodeBin,
                                          [
                                              "chain-daemon-serve",
                                              "--state:" + serverState,
                                              "--port:0",
                                              "--ready-path:" + readyPath
                                          ],
                                          [],
                                          root)
    if IsErr(serverSpawn):
        v3GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var serverPort = ""
    if !v3GateWaitReadyPort(root, readyPath, serverProc, serverPort):
        let serverRun = v3GateWriteProcessSnapshot(root, serverProc, serverLog, 1)
        v3GateMaybePrintRunOutput(serverRun)
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    var syncArgs: str[] = []
    add(syncArgs, "chain-daemon-sync")
    add(syncArgs, "--state:" + clientState)
    if len(clientNodeId) > 0:
        add(syncArgs, "--node-id:" + clientNodeId)
    if len(clientAddressSeed) > 0:
        add(syncArgs, "--address-seed:" + clientAddressSeed)
    add(syncArgs, "--host:127.0.0.1")
    add(syncArgs, "--port:" + serverPort)
    let syncRun = v3GateRunBinary(root,
                                  "v3 chain_node resilience sync " + label + " " + roundTag,
                                  chainNodeBin,
                                  syncArgs,
                                  20,
                                  syncLog)
    if v3GateRunFailed(syncRun):
        let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 1, serverLog)
        v3GateMaybePrintRunOutput(serverRun)
        return syncRun.exitCode
    let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 20, serverLog)
    v3GateMaybePrintRunOutput(serverRun)
    v3GateMaybePrintRunOutput(syncRun)
    if v3GateRunFailed(serverRun):
        return serverRun.exitCode
    if expectChanged:
        if !v3GateRequireOutput(syncRun, "changed=1", "v3 chain_node resilience smoke"):
            return 1
    else:
        if !v3GateRequireOutput(syncRun, "changed=0", "v3 chain_node resilience smoke"):
            return 1
    return 0

fn v3GateRunChainNodeCliSmoke(root: str,
                              compilerPath: str,
                              label: str,
                              envOverrides: str[]): int32 =
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_chain_node_cli/" + label)
    let tmpDir: str = os.JoinPath(outDir, "cli_smoke")
    if !v3path.V3MkdirP(root, tmpDir):
        v3GatePrintErr("v3 chain_node cli smoke: failed to create tmp dir: " + tmpDir)
        return 1
    var chainNodeBin = ""
    if v3GateBuildChainNodeBinary(root,
                                  compilerPath,
                                  outDir,
                                  "v3 chain_node cli unified compile " + label,
                                  envOverrides,
                                  chainNodeBin) != 0:
        return 1
    let serverState: str = os.JoinPath(tmpDir, "server.state")
    let clientState: str = os.JoinPath(tmpDir, "client.state")
    let readyPath: str = os.JoinPath(tmpDir, "server.ready")
    let serverLog: str = os.JoinPath(outDir, "server." + label + ".log")
    let syncLog: str = os.JoinPath(outDir, "sync." + label + ".log")
    let _ = os.RemoveFile(serverState)
    let _ = os.RemoveFile(clientState)
    let _ = os.RemoveFile(readyPath)
    let initRun = v3GateRunBinary(root,
                                  "v3 chain_node cli init " + label,
                                  chainNodeBin,
                                  ["chain-init",
                                   "--state:" + serverState,
                                   "--node-id:node-a",
                                   "--address-seed:chain-node-a"],
                                  20,
                                  os.JoinPath(outDir, "init." + label + ".log"))
    if v3GateRunFailed(initRun):
        return initRun.exitCode
    let mintRun = v3GateRunBinary(root,
                                  "v3 chain_node cli mint " + label,
                                  chainNodeBin,
                                  ["chain-mint", "--state:" + serverState, "--asset:7", "--account:1001", "--amount:100"],
                                  20,
                                  os.JoinPath(outDir, "mint." + label + ".log"))
    if v3GateRunFailed(mintRun):
        return mintRun.exitCode
    let transferRun = v3GateRunBinary(root,
                                      "v3 chain_node cli transfer " + label,
                                      chainNodeBin,
                                      ["chain-transfer",
                                       "--state:" + serverState,
                                       "--asset:7",
                                       "--from:1001",
                                       "--to:2002",
                                       "--amount:40"],
                                      20,
                                      os.JoinPath(outDir, "transfer." + label + ".log"))
    if v3GateRunFailed(transferRun):
        return transferRun.exitCode
    let balanceARun = v3GateRunBinary(root,
                                      "v3 chain_node cli balance-a " + label,
                                      chainNodeBin,
                                      ["chain-balance", "--state:" + serverState, "--asset:7", "--account:1001"],
                                      20,
                                      os.JoinPath(outDir, "balance_a." + label + ".log"))
    if v3GateRunFailed(balanceARun):
        return balanceARun.exitCode
    let balanceBRun = v3GateRunBinary(root,
                                      "v3 chain_node cli balance-b " + label,
                                      chainNodeBin,
                                      ["chain-balance", "--state:" + serverState, "--asset:7", "--account:2002"],
                                      20,
                                      os.JoinPath(outDir, "balance_b." + label + ".log"))
    if v3GateRunFailed(balanceBRun):
        return balanceBRun.exitCode
    let showRun = v3GateRunBinary(root,
                                  "v3 chain_node cli show-state " + label,
                                  chainNodeBin,
                                  ["chain-show-state", "--state:" + serverState],
                                  20,
                                  os.JoinPath(outDir, "show." + label + ".log"))
    if v3GateRunFailed(showRun):
        return showRun.exitCode
    let snapshotRun = v3GateRunBinary(root,
                                      "v3 chain_node cli dump-snapshot " + label,
                                      chainNodeBin,
                                      ["chain-dump-snapshot", "--state:" + serverState],
                                      20,
                                      os.JoinPath(outDir, "snapshot." + label + ".log"))
    if v3GateRunFailed(snapshotRun):
        return snapshotRun.exitCode
    let serverSpawn = hostops.v3SpawnFile(root,
                                          "v3 chain_node cli daemon-serve " + label,
                                          chainNodeBin,
                                          [
                                              "chain-daemon-serve",
                                              "--state:" + serverState,
                                              "--port:0",
                                              "--ready-path:" + readyPath
                                          ],
                                          [],
                                          root)
    if IsErr(serverSpawn):
        v3GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var serverPort = ""
    if !v3GateWaitReadyPort(root, readyPath, serverProc, serverPort):
        let serverRun = v3GateWriteProcessSnapshot(root, serverProc, serverLog, 1)
        v3GatePrintErr("v3 chain_node cli smoke: invalid ready port: " + serverPort)
        v3GateMaybePrintRunOutput(serverRun)
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    let syncRun = v3GateRunBinary(root,
                                  "v3 chain_node cli daemon-sync " + label,
                                  chainNodeBin,
                                  [
                                      "chain-daemon-sync",
                                      "--state:" + clientState,
                                      "--node-id:node-b",
                                      "--address-seed:chain-node-b",
                                      "--host:127.0.0.1",
                                      "--port:" + serverPort
                                  ],
                                  20,
                                  syncLog)
    if v3GateRunFailed(syncRun):
        let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 1, serverLog)
        v3GateMaybePrintRunOutput(serverRun)
        return syncRun.exitCode
    let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 20, serverLog)
    if v3GateRunFailed(serverRun):
        return serverRun.exitCode
    let clientBalanceARun = v3GateRunBinary(root,
                                            "v3 chain_node cli client-balance-a " + label,
                                            chainNodeBin,
                                            ["chain-balance", "--state:" + clientState, "--asset:7", "--account:1001"],
                                            20,
                                            os.JoinPath(outDir, "client_balance_a." + label + ".log"))
    if v3GateRunFailed(clientBalanceARun):
        return clientBalanceARun.exitCode
    let clientBalanceBRun = v3GateRunBinary(root,
                                            "v3 chain_node cli client-balance-b " + label,
                                            chainNodeBin,
                                            ["chain-balance", "--state:" + clientState, "--asset:7", "--account:2002"],
                                            20,
                                            os.JoinPath(outDir, "client_balance_b." + label + ".log"))
    if v3GateRunFailed(clientBalanceBRun):
        return clientBalanceBRun.exitCode
    let clientShowRun = v3GateRunBinary(root,
                                        "v3 chain_node cli client-show " + label,
                                        chainNodeBin,
                                        ["chain-show-state", "--state:" + clientState],
                                        20,
                                        os.JoinPath(outDir, "client_show." + label + ".log"))
    if v3GateRunFailed(clientShowRun):
        return clientShowRun.exitCode
    if !v3GateRequireOutput(initRun, "node_id=node-a", "v3 chain_node cli smoke") ||
       !v3GateRequireOutput(balanceARun, "balance=60", "v3 chain_node cli smoke") ||
       !v3GateRequireOutput(balanceBRun, "balance=40", "v3 chain_node cli smoke") ||
       !v3GateRequireOutput(showRun, "node_id=node-a", "v3 chain_node cli smoke") ||
       !v3GateRequireOutput(snapshotRun, "payload_hex=", "v3 chain_node cli smoke") ||
       !v3GateRequireOutput(syncRun, "changed=1", "v3 chain_node cli smoke") ||
       !v3GateRequireOutput(clientBalanceARun, "balance=60", "v3 chain_node cli smoke") ||
       !v3GateRequireOutput(clientBalanceBRun, "balance=40", "v3 chain_node cli smoke") ||
       !v3GateRequireOutput(clientShowRun, "node_id=node-b", "v3 chain_node cli smoke"):
        return 1
    v3GateMaybePrintRunOutput(initRun)
    v3GateMaybePrintRunOutput(mintRun)
    v3GateMaybePrintRunOutput(transferRun)
    v3GateMaybePrintRunOutput(balanceARun)
    v3GateMaybePrintRunOutput(balanceBRun)
    v3GateMaybePrintRunOutput(showRun)
    v3GateMaybePrintRunOutput(snapshotRun)
    v3GateMaybePrintRunOutput(serverRun)
    v3GateMaybePrintRunOutput(syncRun)
    v3GateMaybePrintRunOutput(clientBalanceARun)
    v3GateMaybePrintRunOutput(clientBalanceBRun)
    v3GateMaybePrintRunOutput(clientShowRun)
    v3GatePrintLine("v3 chain_node cli smoke ok (" + label + ")")
    return 0

fn v3GateRunChainNodeResilienceSmoke(root: str,
                                     compilerPath: str,
                                     label: str,
                                     envOverrides: str[]): int32 =
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_chain_node_resilience/" + label)
    let tmpDir: str = os.JoinPath(outDir, "resilience_smoke")
    if !v3path.V3MkdirP(root, tmpDir):
        v3GatePrintErr("v3 chain_node resilience smoke: failed to create tmp dir: " + tmpDir)
        return 1
    var chainNodeBin = ""
    if v3GateBuildChainNodeBinary(root,
                                  compilerPath,
                                  outDir,
                                  "v3 chain_node resilience compile " + label,
                                  envOverrides,
                                  chainNodeBin) != 0:
        return 1
    let serverState: str = os.JoinPath(tmpDir, "server.state")
    let relayState: str = os.JoinPath(tmpDir, "relay.state")
    let clientState: str = os.JoinPath(tmpDir, "client.state")
    let _ = os.RemoveFile(serverState)
    let _ = os.RemoveFile(relayState)
    let _ = os.RemoveFile(clientState)

    let initRun = v3GateRunBinary(root,
                                  "v3 chain_node resilience init " + label,
                                  chainNodeBin,
                                  ["chain-init",
                                   "--state:" + serverState,
                                   "--node-id:node-a",
                                   "--address-seed:chain-node-a"],
                                  20,
                                  os.JoinPath(outDir, "init." + label + ".log"))
    if v3GateRunFailed(initRun):
        return initRun.exitCode
    if !v3GateRequireOutput(initRun, "node_id=node-a", "v3 chain_node resilience smoke"):
        return 1

    let round1MintRun = v3GateRunBinary(root,
                                        "v3 chain_node resilience round1 mint " + label,
                                        chainNodeBin,
                                        ["chain-mint", "--state:" + serverState, "--asset:7", "--account:1001", "--amount:100"],
                                        20,
                                        os.JoinPath(outDir, "round1_mint." + label + ".log"))
    if v3GateRunFailed(round1MintRun):
        return round1MintRun.exitCode
    let round1TransferRun = v3GateRunBinary(root,
                                            "v3 chain_node resilience round1 transfer " + label,
                                            chainNodeBin,
                                            ["chain-transfer",
                                             "--state:" + serverState,
                                             "--asset:7",
                                             "--from:1001",
                                             "--to:2002",
                                             "--amount:40"],
                                            20,
                                            os.JoinPath(outDir, "round1_transfer." + label + ".log"))
    if v3GateRunFailed(round1TransferRun):
        return round1TransferRun.exitCode
    let serverAliceRound1 = v3GateRunBinary(root,
                                            "v3 chain_node resilience round1 server alice " + label,
                                            chainNodeBin,
                                            ["chain-balance", "--state:" + serverState, "--asset:7", "--account:1001"],
                                            20,
                                            os.JoinPath(outDir, "round1_server_alice." + label + ".log"))
    if v3GateRunFailed(serverAliceRound1):
        return serverAliceRound1.exitCode
    let serverBobRound1 = v3GateRunBinary(root,
                                          "v3 chain_node resilience round1 server bob " + label,
                                          chainNodeBin,
                                          ["chain-balance", "--state:" + serverState, "--asset:7", "--account:2002"],
                                          20,
                                          os.JoinPath(outDir, "round1_server_bob." + label + ".log"))
    if v3GateRunFailed(serverBobRound1):
        return serverBobRound1.exitCode
    let serverShowRound1 = v3GateRunBinary(root,
                                           "v3 chain_node resilience round1 server show " + label,
                                           chainNodeBin,
                                           ["chain-show-state", "--state:" + serverState],
                                           20,
                                           os.JoinPath(outDir, "round1_server_show." + label + ".log"))
    if v3GateRunFailed(serverShowRound1):
        return serverShowRound1.exitCode
    let serverSnapshotRound1 = v3GateRunBinary(root,
                                               "v3 chain_node resilience round1 server snapshot " + label,
                                               chainNodeBin,
                                               ["chain-dump-snapshot", "--state:" + serverState],
                                               20,
                                               os.JoinPath(outDir, "round1_server_snapshot." + label + ".log"))
    if v3GateRunFailed(serverSnapshotRound1):
        return serverSnapshotRound1.exitCode
    if !v3GateChainNodeRequireRunValue(serverAliceRound1, "balance", "60", "v3 chain_node resilience round1 server alice") ||
       !v3GateChainNodeRequireRunValue(serverBobRound1, "balance", "40", "v3 chain_node resilience round1 server bob") ||
       !v3GateChainNodeRequireRunValue(serverShowRound1, "node_id", "node-a", "v3 chain_node resilience round1 server show") ||
       !v3GateChainNodeRequireRunValue(serverShowRound1, "event_count", "2", "v3 chain_node resilience round1 server show") ||
       !v3GateRequireOutput(serverSnapshotRound1, "payload_hex=", "v3 chain_node resilience smoke"):
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round1_server_to_relay",
                                      true) != 0:
        return 1
    let relayShowRound1 = v3GateRunBinary(root,
                                          "v3 chain_node resilience round1 relay show " + label,
                                          chainNodeBin,
                                          ["chain-show-state", "--state:" + relayState],
                                          20,
                                          os.JoinPath(outDir, "round1_relay_show." + label + ".log"))
    if v3GateRunFailed(relayShowRound1):
        return relayShowRound1.exitCode
    let relayAliceRound1 = v3GateRunBinary(root,
                                           "v3 chain_node resilience round1 relay alice " + label,
                                           chainNodeBin,
                                           ["chain-balance", "--state:" + relayState, "--asset:7", "--account:1001"],
                                           20,
                                           os.JoinPath(outDir, "round1_relay_alice." + label + ".log"))
    if v3GateRunFailed(relayAliceRound1):
        return relayAliceRound1.exitCode
    let relayBobRound1 = v3GateRunBinary(root,
                                         "v3 chain_node resilience round1 relay bob " + label,
                                         chainNodeBin,
                                         ["chain-balance", "--state:" + relayState, "--asset:7", "--account:2002"],
                                         20,
                                         os.JoinPath(outDir, "round1_relay_bob." + label + ".log"))
    if v3GateRunFailed(relayBobRound1):
        return relayBobRound1.exitCode
    if !v3GateChainNodeRequireRunValue(relayShowRound1, "node_id", "node-b", "v3 chain_node resilience round1 relay show") ||
       !v3GateChainNodeRequireRunValue(relayAliceRound1, "balance", "60", "v3 chain_node resilience round1 relay alice") ||
       !v3GateChainNodeRequireRunValue(relayBobRound1, "balance", "40", "v3 chain_node resilience round1 relay bob") ||
       !v3GateChainNodeRequireStateParity(serverShowRound1,
                                          relayShowRound1,
                                          "v3 chain_node resilience round1 server relay parity"):
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round1_server_to_relay_idle",
                                      false) != 0:
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round1_relay_to_client",
                                      true) != 0:
        return 1
    let clientShowRound1 = v3GateRunBinary(root,
                                           "v3 chain_node resilience round1 client show " + label,
                                           chainNodeBin,
                                           ["chain-show-state", "--state:" + clientState],
                                           20,
                                           os.JoinPath(outDir, "round1_client_show." + label + ".log"))
    if v3GateRunFailed(clientShowRound1):
        return clientShowRound1.exitCode
    let clientAliceRound1 = v3GateRunBinary(root,
                                            "v3 chain_node resilience round1 client alice " + label,
                                            chainNodeBin,
                                            ["chain-balance", "--state:" + clientState, "--asset:7", "--account:1001"],
                                            20,
                                            os.JoinPath(outDir, "round1_client_alice." + label + ".log"))
    if v3GateRunFailed(clientAliceRound1):
        return clientAliceRound1.exitCode
    let clientBobRound1 = v3GateRunBinary(root,
                                          "v3 chain_node resilience round1 client bob " + label,
                                          chainNodeBin,
                                          ["chain-balance", "--state:" + clientState, "--asset:7", "--account:2002"],
                                          20,
                                          os.JoinPath(outDir, "round1_client_bob." + label + ".log"))
    if v3GateRunFailed(clientBobRound1):
        return clientBobRound1.exitCode
    if !v3GateChainNodeRequireRunValue(clientShowRound1, "node_id", "node-c", "v3 chain_node resilience round1 client show") ||
       !v3GateChainNodeRequireRunValue(clientAliceRound1, "balance", "60", "v3 chain_node resilience round1 client alice") ||
       !v3GateChainNodeRequireRunValue(clientBobRound1, "balance", "40", "v3 chain_node resilience round1 client bob") ||
       !v3GateChainNodeRequireStateParity(relayShowRound1,
                                          clientShowRound1,
                                          "v3 chain_node resilience round1 relay client parity"):
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round1_relay_to_client_idle",
                                      false) != 0:
        return 1

    let round2MintRun = v3GateRunBinary(root,
                                        "v3 chain_node resilience round2 mint " + label,
                                        chainNodeBin,
                                        ["chain-mint", "--state:" + serverState, "--asset:7", "--account:2002", "--amount:25"],
                                        20,
                                        os.JoinPath(outDir, "round2_mint." + label + ".log"))
    if v3GateRunFailed(round2MintRun):
        return round2MintRun.exitCode
    let round2TransferRun = v3GateRunBinary(root,
                                            "v3 chain_node resilience round2 transfer " + label,
                                            chainNodeBin,
                                            ["chain-transfer",
                                             "--state:" + serverState,
                                             "--asset:7",
                                             "--from:2002",
                                             "--to:1001",
                                             "--amount:15"],
                                            20,
                                            os.JoinPath(outDir, "round2_transfer." + label + ".log"))
    if v3GateRunFailed(round2TransferRun):
        return round2TransferRun.exitCode
    let serverShowRound2 = v3GateRunBinary(root,
                                           "v3 chain_node resilience round2 server show " + label,
                                           chainNodeBin,
                                           ["chain-show-state", "--state:" + serverState],
                                           20,
                                           os.JoinPath(outDir, "round2_server_show." + label + ".log"))
    if v3GateRunFailed(serverShowRound2):
        return serverShowRound2.exitCode
    let serverAliceRound2 = v3GateRunBinary(root,
                                            "v3 chain_node resilience round2 server alice " + label,
                                            chainNodeBin,
                                            ["chain-balance", "--state:" + serverState, "--asset:7", "--account:1001"],
                                            20,
                                            os.JoinPath(outDir, "round2_server_alice." + label + ".log"))
    if v3GateRunFailed(serverAliceRound2):
        return serverAliceRound2.exitCode
    let serverBobRound2 = v3GateRunBinary(root,
                                          "v3 chain_node resilience round2 server bob " + label,
                                          chainNodeBin,
                                          ["chain-balance", "--state:" + serverState, "--asset:7", "--account:2002"],
                                          20,
                                          os.JoinPath(outDir, "round2_server_bob." + label + ".log"))
    if v3GateRunFailed(serverBobRound2):
        return serverBobRound2.exitCode
    if !v3GateChainNodeRequireRunValue(serverShowRound2, "event_count", "4", "v3 chain_node resilience round2 server show") ||
       !v3GateChainNodeRequireRunValue(serverAliceRound2, "balance", "75", "v3 chain_node resilience round2 server alice") ||
       !v3GateChainNodeRequireRunValue(serverBobRound2, "balance", "50", "v3 chain_node resilience round2 server bob"):
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round2_server_to_relay",
                                      true) != 0:
        return 1
    let relayShowRound2 = v3GateRunBinary(root,
                                          "v3 chain_node resilience round2 relay show " + label,
                                          chainNodeBin,
                                          ["chain-show-state", "--state:" + relayState],
                                          20,
                                          os.JoinPath(outDir, "round2_relay_show." + label + ".log"))
    if v3GateRunFailed(relayShowRound2):
        return relayShowRound2.exitCode
    let relayAliceRound2 = v3GateRunBinary(root,
                                           "v3 chain_node resilience round2 relay alice " + label,
                                           chainNodeBin,
                                           ["chain-balance", "--state:" + relayState, "--asset:7", "--account:1001"],
                                           20,
                                           os.JoinPath(outDir, "round2_relay_alice." + label + ".log"))
    if v3GateRunFailed(relayAliceRound2):
        return relayAliceRound2.exitCode
    let relayBobRound2 = v3GateRunBinary(root,
                                         "v3 chain_node resilience round2 relay bob " + label,
                                         chainNodeBin,
                                         ["chain-balance", "--state:" + relayState, "--asset:7", "--account:2002"],
                                         20,
                                         os.JoinPath(outDir, "round2_relay_bob." + label + ".log"))
    if v3GateRunFailed(relayBobRound2):
        return relayBobRound2.exitCode
    if !v3GateChainNodeRequireRunValue(relayAliceRound2, "balance", "75", "v3 chain_node resilience round2 relay alice") ||
       !v3GateChainNodeRequireRunValue(relayBobRound2, "balance", "50", "v3 chain_node resilience round2 relay bob") ||
       !v3GateChainNodeRequireStateParity(serverShowRound2,
                                          relayShowRound2,
                                          "v3 chain_node resilience round2 server relay parity"):
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round2_server_to_relay_idle",
                                      false) != 0:
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round2_relay_to_client",
                                      true) != 0:
        return 1
    let clientShowRound2 = v3GateRunBinary(root,
                                           "v3 chain_node resilience round2 client show " + label,
                                           chainNodeBin,
                                           ["chain-show-state", "--state:" + clientState],
                                           20,
                                           os.JoinPath(outDir, "round2_client_show." + label + ".log"))
    if v3GateRunFailed(clientShowRound2):
        return clientShowRound2.exitCode
    let clientAliceRound2 = v3GateRunBinary(root,
                                            "v3 chain_node resilience round2 client alice " + label,
                                            chainNodeBin,
                                            ["chain-balance", "--state:" + clientState, "--asset:7", "--account:1001"],
                                            20,
                                            os.JoinPath(outDir, "round2_client_alice." + label + ".log"))
    if v3GateRunFailed(clientAliceRound2):
        return clientAliceRound2.exitCode
    let clientBobRound2 = v3GateRunBinary(root,
                                          "v3 chain_node resilience round2 client bob " + label,
                                          chainNodeBin,
                                          ["chain-balance", "--state:" + clientState, "--asset:7", "--account:2002"],
                                          20,
                                          os.JoinPath(outDir, "round2_client_bob." + label + ".log"))
    if v3GateRunFailed(clientBobRound2):
        return clientBobRound2.exitCode
    if !v3GateChainNodeRequireRunValue(clientAliceRound2, "balance", "75", "v3 chain_node resilience round2 client alice") ||
       !v3GateChainNodeRequireRunValue(clientBobRound2, "balance", "50", "v3 chain_node resilience round2 client bob") ||
       !v3GateChainNodeRequireStateParity(relayShowRound2,
                                          clientShowRound2,
                                          "v3 chain_node resilience round2 relay client parity"):
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round2_relay_to_client_idle",
                                      false) != 0:
        return 1

    let round3TransferRun = v3GateRunBinary(root,
                                            "v3 chain_node resilience round3 transfer " + label,
                                            chainNodeBin,
                                            ["chain-transfer",
                                             "--state:" + serverState,
                                             "--asset:7",
                                             "--from:1001",
                                             "--to:2002",
                                             "--amount:20"],
                                            20,
                                            os.JoinPath(outDir, "round3_transfer." + label + ".log"))
    if v3GateRunFailed(round3TransferRun):
        return round3TransferRun.exitCode
    let round3MintRun = v3GateRunBinary(root,
                                        "v3 chain_node resilience round3 mint " + label,
                                        chainNodeBin,
                                        ["chain-mint", "--state:" + serverState, "--asset:7", "--account:1001", "--amount:30"],
                                        20,
                                        os.JoinPath(outDir, "round3_mint." + label + ".log"))
    if v3GateRunFailed(round3MintRun):
        return round3MintRun.exitCode
    let serverShowRound3 = v3GateRunBinary(root,
                                           "v3 chain_node resilience round3 server show " + label,
                                           chainNodeBin,
                                           ["chain-show-state", "--state:" + serverState],
                                           20,
                                           os.JoinPath(outDir, "round3_server_show." + label + ".log"))
    if v3GateRunFailed(serverShowRound3):
        return serverShowRound3.exitCode
    let serverAliceRound3 = v3GateRunBinary(root,
                                            "v3 chain_node resilience round3 server alice " + label,
                                            chainNodeBin,
                                            ["chain-balance", "--state:" + serverState, "--asset:7", "--account:1001"],
                                            20,
                                            os.JoinPath(outDir, "round3_server_alice." + label + ".log"))
    if v3GateRunFailed(serverAliceRound3):
        return serverAliceRound3.exitCode
    let serverBobRound3 = v3GateRunBinary(root,
                                          "v3 chain_node resilience round3 server bob " + label,
                                          chainNodeBin,
                                          ["chain-balance", "--state:" + serverState, "--asset:7", "--account:2002"],
                                          20,
                                          os.JoinPath(outDir, "round3_server_bob." + label + ".log"))
    if v3GateRunFailed(serverBobRound3):
        return serverBobRound3.exitCode
    let serverSnapshotRound3 = v3GateRunBinary(root,
                                               "v3 chain_node resilience round3 server snapshot " + label,
                                               chainNodeBin,
                                               ["chain-dump-snapshot", "--state:" + serverState],
                                               20,
                                               os.JoinPath(outDir, "round3_server_snapshot." + label + ".log"))
    if v3GateRunFailed(serverSnapshotRound3):
        return serverSnapshotRound3.exitCode
    if !v3GateChainNodeRequireRunValue(serverShowRound3, "event_count", "6", "v3 chain_node resilience round3 server show") ||
       !v3GateChainNodeRequireRunValue(serverAliceRound3, "balance", "85", "v3 chain_node resilience round3 server alice") ||
       !v3GateChainNodeRequireRunValue(serverBobRound3, "balance", "70", "v3 chain_node resilience round3 server bob") ||
       !v3GateRequireOutput(serverSnapshotRound3, "payload_hex=", "v3 chain_node resilience smoke"):
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round3_server_to_relay",
                                      true) != 0:
        return 1
    let relayShowRound3 = v3GateRunBinary(root,
                                          "v3 chain_node resilience round3 relay show " + label,
                                          chainNodeBin,
                                          ["chain-show-state", "--state:" + relayState],
                                          20,
                                          os.JoinPath(outDir, "round3_relay_show." + label + ".log"))
    if v3GateRunFailed(relayShowRound3):
        return relayShowRound3.exitCode
    let relayAliceRound3 = v3GateRunBinary(root,
                                           "v3 chain_node resilience round3 relay alice " + label,
                                           chainNodeBin,
                                           ["chain-balance", "--state:" + relayState, "--asset:7", "--account:1001"],
                                           20,
                                           os.JoinPath(outDir, "round3_relay_alice." + label + ".log"))
    if v3GateRunFailed(relayAliceRound3):
        return relayAliceRound3.exitCode
    let relayBobRound3 = v3GateRunBinary(root,
                                         "v3 chain_node resilience round3 relay bob " + label,
                                         chainNodeBin,
                                         ["chain-balance", "--state:" + relayState, "--asset:7", "--account:2002"],
                                         20,
                                         os.JoinPath(outDir, "round3_relay_bob." + label + ".log"))
    if v3GateRunFailed(relayBobRound3):
        return relayBobRound3.exitCode
    if !v3GateChainNodeRequireRunValue(relayAliceRound3, "balance", "85", "v3 chain_node resilience round3 relay alice") ||
       !v3GateChainNodeRequireRunValue(relayBobRound3, "balance", "70", "v3 chain_node resilience round3 relay bob") ||
       !v3GateChainNodeRequireStateParity(serverShowRound3,
                                          relayShowRound3,
                                          "v3 chain_node resilience round3 server relay parity"):
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      serverState,
                                      relayState,
                                      "node-b",
                                      "chain-node-b",
                                      outDir,
                                      "round3_server_to_relay_idle",
                                      false) != 0:
        return 1
    if v3GateRunChainNodeServeAndSync(root,
                                      label,
                                      chainNodeBin,
                                      relayState,
                                      clientState,
                                      "node-c",
                                      "chain-node-c",
                                      outDir,
                                      "round3_relay_to_client",
                                      true) != 0:
