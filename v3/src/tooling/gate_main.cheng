    out.serverSsh = os.GetEnvDefault("CHENG_V3_BFT_SERVER_SSH", "root@64.176.84.12")
    out.relaySsh = os.GetEnvDefault("CHENG_V3_BFT_RELAY_SSH", "dmit")
    out.serverAddress = os.GetEnvDefault("CHENG_V3_BFT_SERVER_ADDR", "64.176.84.12")
    out.serverRepoRoot = os.GetEnvDefault("CHENG_V3_BFT_SERVER_ROOT", "/root/cheng-lang-deploy")
    out.relayRepoRoot = os.GetEnvDefault("CHENG_V3_BFT_RELAY_ROOT", "/root/cheng-lang-deploy")
