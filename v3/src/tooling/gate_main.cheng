    let clientShowRound3 = v3GateRunBinary(root,
                                           "v3 chain_node resilience round3 client show " + label,
                                           chainNodeBin,
                                           ["chain-show-state", "--state:" + clientState],
                                           20,
                                           os.JoinPath(outDir, "round3_client_show." + label + ".log"))
    if v3GateRunFailed(clientShowRound3):
        return clientShowRound3.exitCode
    let clientAliceRound3 = v3GateRunBinary(root,
                                            "v3 chain_node resilience round3 client alice " + label,
                                            chainNodeBin,
                                            ["chain-balance", "--state:" + clientState, "--asset:7", "--account:1001"],
                                            20,
                                            os.JoinPath(outDir, "round3_client_alice." + label + ".log"))
    if v3GateRunFailed(clientAliceRound3):
