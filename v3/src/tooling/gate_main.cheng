                                            compilerPath,
                                            clientSrc,
                                            clientBin,
                                            "arm64-apple-darwin",
                                            clientBin + ".compile.log",
                                            envOverrides)
    if v3GateRunFailed(clientCompile):
        return clientCompile.exitCode
    let serverSpawn = hostops.v3SpawnFile(root,
                                          "v3 libp2p quic twoproc server " + stageName,
                                          serverBin,
                                          ["--port:0", "--ready-path:" + readyPath],
                                          [],
                                          root)
    if IsErr(serverSpawn):
        v3GatePrintErr(Error(serverSpawn))
        return 1
    var serverProc = Value(serverSpawn)
    var port = ""
    if !v3GateWaitReadyPort(root, readyPath, serverProc, port):
        let serverRun = v3GateWriteProcessSnapshot(root, serverProc, serverBin + ".run.log", 1)
        v3GatePrintErr("v3 libp2p quic twoproc: invalid ready port: " + port)
        v3GateMaybePrintRunOutput(serverRun)
        hostops.v3SpawnedProcessKill(serverProc)
        return 1
    let clientRun = v3GateRunBinary(root,
                                    "v3 libp2p quic twoproc client " + stageName,
                                    clientBin,
                                    ["--port:" + port],
                                    20,
                                    clientBin + ".run.log")
    if v3GateRunFailed(clientRun):
        let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 1, serverBin + ".run.log")
        v3GateMaybePrintRunOutput(serverRun)
        return clientRun.exitCode
    let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 20, serverBin + ".run.log")
    v3GateMaybePrintRunOutput(serverRun)
    if v3GateRunFailed(serverRun):
        return serverRun.exitCode
    v3GateMaybePrintRunOutput(clientRun)
    v3GatePrintLine("v3 libp2p_quic_twoproc_smoke ok")
    return 0

fn v3GateRunDiLoCoSingleSmoke(root: str,
                              compilerPath: str,
                              stageName: str,
                              packageRoot: str,
                              smokeName: str,
                              envOverrides: str[]): int32 =
    let outDir: str = v3path.v3PathAbsolute(root, "artifacts/v3_diloco")
    let src: str = v3path.v3PathAbsolute(root, "v3/DiLoCo/src/tests/" + smokeName + ".cheng")
    let outBin: str = os.joinPath(outDir, smokeName + "." + stageName)
    if !os.fileExists(src):
        v3GatePrintErr("v3 diloco verify: missing source: " + src)
        return 1
    let compileRun = v3GateCompileExeEnvAtRoot(root,
                                               "v3 diloco compile " + smokeName + " " + stageName,
                                               compilerPath,
                                               packageRoot,
                                               src,
                                               outBin,
                                               "arm64-apple-darwin",
                                               outBin + ".compile.log",
                                               envOverrides)
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    let runRun = v3GateRunBinary(root,
                                 "v3 diloco run " + smokeName + " " + stageName,
                                 outBin,
                                 [],
                                 v3GateSmokeRunTimeoutSec(),
                                 outBin + ".run.log")
    v3GateMaybePrintRunOutput(runRun)
    if v3GateRunFailed(runRun):
        return runRun.exitCode
    return 0

fn v3GateRunDiLoCoQuicTwoprocSmoke(root: str,
                                   compilerPath: str,
                                   stageName: str,
                                   packageRoot: str,
                                   envOverrides: str[]): int32 =
    let outDir: str = v3path.v3PathAbsolute(root, "artifacts/v3_diloco")
    let serverSrc: str = v3path.v3PathAbsolute(root, "v3/DiLoCo/src/tests/diloco_quic_twoproc_server_smoke.cheng")
    let clientSrc: str = v3path.v3PathAbsolute(root, "v3/DiLoCo/src/tests/diloco_quic_twoproc_client_smoke.cheng")
    let serverBin: str = os.joinPath(outDir, "diloco_quic_twoproc_server." + stageName)
    let clientBin: str = os.joinPath(outDir, "diloco_quic_twoproc_client." + stageName)
    let readyPath: str = os.joinPath(outDir, "diloco_quic_twoproc_server." + stageName + ".ready")
    let _ = os.removeFile(readyPath)
    if !os.fileExists(serverSrc) || !os.fileExists(clientSrc):
        v3GatePrintErr("v3 diloco quic twoproc: missing source fixture")
