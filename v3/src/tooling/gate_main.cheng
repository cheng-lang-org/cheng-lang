    add(out, "commands:")
    add(out, "  scan-hotpath")
    add(out, "  c-ref")
    add(out, "  compare-bench --baseline:<file> --candidate:<file> [--max-ratio-milli:<N>]")
    add(out, "  bootstrap-bridge")
    add(out, "  build-backend-driver")
    add(out, "  run-smokes")
    add(out, "  print-bootstrap")
    add(out, "  print-build-plan")
