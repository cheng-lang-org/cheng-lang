fn v3GateVerifyDebugRuntime(root: str): int32 =
    let hostTarget: str = v3GateHostTarget(root)
    if len(hostTarget) <= 0:
        v3GatePrintErr("v3 debug runtime: unsupported host target")
        return 1
    let packageRoot: str = v3path.V3PathAbsolute(root, "v3")
    let ordinarySource: str = v3path.V3PathAbsolute(root, "v3/src/tests/ordinary_panic_fixture.cheng")
    let toolingSource: str = v3path.V3PathAbsolute(root, "v3/src/tooling/compiler_main.cheng")
    let ordinaryOutput: str = v3path.V3PathAbsolute(root, "artifacts/v3_debug_runtime_verify/provider_plan_ordinary")
    let toolingOutput: str = v3path.V3PathAbsolute(root, "artifacts/v3_debug_runtime_verify/provider_plan_tooling")
    let expectedCoreSource: str = hostTarget == "arm64-apple-darwin" ?
        v3path.V3PathAbsolute(root, "v3/src/runtime/core_runtime_provider_darwin_v3.cheng") :
        v3path.V3PathAbsolute(root, "v3/src/runtime/core_runtime_provider_linux_v3.cheng")
    let expectedDebugSource: str = v3path.V3PathAbsolute(root, "v3/src/runtime/debug_runtime_stub_v3.cheng")
    let expectedProgramSupportSource: str =
        v3path.V3PathAbsolute(root, "v3/src/runtime/program_support_backend_v3.cheng")
    let expectedProgramSupportHostSource: str =
        v3path.V3PathAbsolute(root, "v3/src/runtime/program_support_host_runtime_v3.cheng")
    let expectedProgramArgvSource: str =
        v3path.V3PathAbsolute(root, "v3/src/runtime/compiler_runtime_program_entry_provider_v3.cheng")
    let expectedToolingArgvSource: str =
        v3path.V3PathAbsolute(root, "v3/src/runtime/compiler_runtime_tooling_entry_provider_v3.cheng")
    if !v3GateVerifyPureChengProviderPlan(root,
                                          packageRoot,
                                          ordinarySource,
                                          ordinaryOutput,
                                          hostTarget,
                                          [
                                              expectedProgramArgvSource,
                                              expectedCoreSource,
                                              expectedDebugSource,
                                              expectedProgramSupportSource,
                                              expectedProgramSupportHostSource
                                          ]):
        return 1
    if !v3GateVerifyPureChengProviderPlan(root,
                                          packageRoot,
                                          toolingSource,
                                          toolingOutput,
                                          hostTarget,
                                          [
                                              expectedToolingArgvSource,
                                              expectedCoreSource,
                                              expectedDebugSource,
                                              expectedProgramSupportSource,
                                              expectedProgramSupportHostSource
                                          ]):
        return 1
    if v3GateBuildPanicTrace(root) != 0:
        return 1
    if v3GateBuildBoundsTrace(root) != 0:
        return 1
    if v3GateBuildSignalTrace(root) != 0:
        return 1
    v3GatePrintLine("v3 debug runtime: ok")
    return 0

fn v3GateVerifyDebugProfile(root: str): int32 =
    var compiler = ""
    if v3GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_debug_profile_verify")
    let src: str = v3path.V3PathAbsolute(root, "v3/src/tests/ordinary_profile_hotspots_fixture.cheng")
    let outBin: str = os.JoinPath(outDir, "ordinary_profile_hotspots_fixture")
    let report: str = os.JoinPath(outDir, "profile.txt")
    let rawReport: str = os.JoinPath(outDir, "profile.raw.txt")
    let compileLog = "artifacts/v3_debug_profile_verify/ordinary_profile_hotspots_fixture.compile.log"
    let compileRun = v3GateCompileExe(root,
                                      "verify_debug_profile",
                                      compiler,
                                      src,
                                      outBin,
                                      "arm64-apple-darwin",
                                      compileLog)
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    let run = hostops.v3RunFileLogged(root,
                                      "verify_debug_profile_run",
                                      outBin,
                                      [],
                                      [
                                          "CHENG_V3_PROFILE_ENABLE=1",
                                          "CHENG_V3_PROFILE_HZ=200",
                                          "CHENG_V3_PROFILE_RAW_OUT=" + rawReport
                                      ],
                                      root,
                                      20,
                                      "artifacts/v3_debug_profile_verify/ordinary_profile_hotspots_fixture.run.log")
    if v3GateRunFailed(run):
        return run.exitCode
    if !os.FileExists(rawReport):
        v3GatePrintErr("v3 debug profile: missing raw report")
        return 1
    let rawReportText: str = v3path.V3ReadTextFile("", rawReport)
    if !v3GateOutputContains(rawReportText, "v3_profile_raw_v1") ||
       !v3GateOutputContains(rawReportText, "sample\t0x"):
        v3GatePrintErr("v3 debug profile: invalid raw report")
        return 1
    let transformRun = hostops.v3RunFileLogged(root,
                                               "verify_debug_profile_transform",
                                               compiler,
                                               [
                                                   "profile-report",
                                                   "--in:" + rawReport,
                                                   "--out:" + report
                                               ],
                                               [],
                                               root,
                                               20,
                                               "artifacts/v3_debug_profile_verify/profile-report.run.log")
    if v3GateRunFailed(transformRun):
        return transformRun.exitCode
    if !os.FileExists(report):
        v3GatePrintErr("v3 debug profile: missing report")
        return 1
    let reportText: str = v3path.V3ReadTextFile("", report)
    if !v3GateOutputContains(reportText, "v3_profile_v1") ||
       !v3GateOutputContains(reportText, "hot_function[0]=") ||
       !v3GateOutputContains(reportText, "hot_pc[0]=") ||
       !v3GateOutputContains(reportText, "ordinary_profile_hotspots_fixture.cheng"):
        v3GatePrintErr("v3 debug profile: invalid report")
        return 1
    v3GatePrintLine(strutil.Strip(reportText))
    v3GatePrintLine("v3 debug profile: ok")
    return 0

fn v3GateBuildChainNode(root: str): int32 =
    var compiler = os.GetEnvDefault("CHENG_V3_CHAIN_NODE_COMPILER", "")
    if len(compiler) <= 0:
        if v3GateEnsureBackendDriverReady(root, compiler) != 0:
            return 1
    else:
        compiler = v3path.V3PathAbsolute(root, compiler)
    let src: str = v3path.V3PathAbsolute(root, "v3/src/project/cheng_node_main.cheng")
    let target: str = os.GetEnvDefault("CHAIN_NODE_TARGET", "arm64-apple-darwin")
    var defaultOutDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_cheng_node_main")
    if target != "arm64-apple-darwin":
        defaultOutDir = os.JoinPath(defaultOutDir, target)
    let outDir: str = os.GetEnvDefault("CHAIN_NODE_OUT_DIR", defaultOutDir)
    let outBin: str = os.GetEnvDefault("CHAIN_NODE_OUT_BIN", os.JoinPath(outDir, "cheng_node_main"))
    let compileRun = v3GateCompileExe(root,
                                      "build_chain_node",
                                      compiler,
                                      src,
                                      outBin,
                                      target,
                                      os.JoinPath(outDir, "cheng_node_main.compile.log"))
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    var runSelfTestDefault = "0"
    if target == "arm64-apple-darwin":
        runSelfTestDefault = "1"
    let runSelfTestText: str = os.GetEnvDefault("CHAIN_NODE_RUN_SELF_TEST", runSelfTestDefault)
    if runSelfTestText != "0":
        let run = v3GateRunBinary(root,
                                  "build_chain_node_self_test",
                                  outBin,
                                  ["chain-self-test"],
                                  20,
                                  os.JoinPath(outDir, "cheng_node_main.self-test.log"))
        v3GateMaybePrintRunOutput(run)
        if v3GateRunFailed(run):
            return run.exitCode
    else:
        v3GatePrintLine("v3 chain_node: build ok target=" + target + " out=" + outBin)
    return 0

fn v3GateRunChainNodeProcessSmoke(root: str, args: str[]): int32 =
    let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if v3GateResolveSmokeCompiler(root,
                                  explicitCompiler,
                                  "CHENG_V3_CHAIN_NODE_COMPILER",
                                  "CHENG_V3_SMOKE_COMPILER",
                                  compiler) != 0:
        return 1
    let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_CHAIN_NODE_LABEL", "host")
    return v3GateRunChainNodeProcessSmokeWithCompiler(root, compiler, label, [])

fn v3GateRunChainNodeThreeNodeSmoke(root: str, args: str[]): int32 =
    let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if v3GateResolveSmokeCompiler(root,
                                  explicitCompiler,
                                  "CHENG_V3_CHAIN_NODE_COMPILER",
                                  "CHENG_V3_SMOKE_COMPILER",
                                  compiler) != 0:
        return 1
    let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_CHAIN_NODE_LABEL", "host")
    return v3GateRunChainNodeThreeNodeSmokeWithCompiler(root, compiler, label, [])

fn v3GateSlice(root: str): int32 =
    v3GatePrintLine("[v3 gate] hot-path forbidden scan")
    if v3GateScanHotpath(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] orphan guard + bootstrap path")
    if v3GateVerifyOrphanGuard(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] zero-exit ordinary compile")
    if v3GateBuildZeroExit(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] panic-trace ordinary compile")
    if v3GateBuildPanicTrace(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] bounds-trace ordinary compile")
    if v3GateBuildBoundsTrace(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] signal-trace ordinary compile")
    if v3GateBuildSignalTrace(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] debug tools")
    if v3GateRunStage3Command(root,
                              "verify_debug_tools",
                              "verify-debug-tools",
                              [],
                              "verify-debug-tools.log",
                              false) != 0:
        return 1
    v3GatePrintLine("[v3 gate] debug runtime")
    if v3GateVerifyDebugRuntime(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] debug profile")
    if v3GateVerifyDebugProfile(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] call-chain ordinary compile")
    if v3GateBuildCallChain(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] ffi-handle ordinary compile")
    if v3GateBuildFfiHandle(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] program-selfhost")
    if v3GateBuildProgramSelfhost(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] chain_node")
    if v3GateBuildChainNode(root) != 0:
        return 1
    if v3GateVerifyTcpBioLinuxRegression(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] bootstrap subset self-checks")
    if v3GateRunSmokes(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] host fixed256 sha256 smoke")
    if v3GateRunHostSmokes(root, ["fixed256_sha256_smoke"]) != 0:
        return 1
    v3GatePrintLine("[v3 gate] host default-init literals smoke")
    if v3GateRunHostSmokes(root, ["default_init_literals_smoke"]) != 0:
        return 1
    v3GatePrintLine("[v3 gate] backend_driver command surface")
    if v3GateRunHostSmokes(root, ["backend_driver_command_surface_smoke"]) != 0:
        return 1
    v3GatePrintLine("[v3 gate] cross-target builtin smokes")
    if v3GateRunStage3Command(root,
                              "run_cross_target_smokes",
                              "run-cross-target-smokes",
                              [],
                              "run-cross-target-smokes.log",
                              false) != 0:
        return 1
    v3GatePrintLine("[v3 gate] v3 host smokes")
    if v3GateRunHostSmokes(root, []) != 0:
        return 1
    v3GatePrintLine("[v3 gate] stage2/stage3 libp2p smokes")
    if v3GateRunStage23Libp2pSmokes(root, []) != 0:
        return 1
    v3GatePrintLine("[v3 gate] remote x86 linux release gate")
    if v3GateVerifyX86LinuxRemote(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] chain_node three-node smoke")
    if v3GateRunChainNodeThreeNodeSmoke(root, []) != 0:
        return 1
    v3GatePrintLine("[v3 gate] bft three-node verify")
    if v3GateVerifyBftValidatorThreeNode(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] ok")
    return 0

fn v3GateHandlesCommandBase(cmd: str): bool =
    return cmd == "scan-hotpath" ||
           cmd == "bootstrap-bridge" ||
           cmd == "build-backend-driver" ||
           cmd == "run-smokes" ||
           cmd == "print-bootstrap" ||
           cmd == "support-matrix" ||
           cmd == "print-build-plan" ||
           cmd == "slice-gate" ||
           cmd == "debug-report" ||
           cmd == "print-symbols" ||
           cmd == "print-line-map" ||
           cmd == "print-object" ||
           cmd == "print-elf" ||
           cmd == "print-asm" ||
           cmd == "profile-run" ||
           cmd == "crash-report" ||
           cmd == "verify-orphan-guard" ||
           cmd == "verify-export-visibility" ||
           cmd == "verify-export-visibility-parallel" ||
           cmd == "verify-backend-driver-command-surface" ||
           cmd == "verify-mobile-shell-build-probe" ||
           cmd == "verify-chain-node-resilience" ||
           cmd == "verify-oracle-resilience" ||
           cmd == "verify-oracle-bft-three-node" ||
           cmd == "verify-r2c-react-v3-surface" ||
           cmd == "verify-debug-tools" ||
           cmd == "verify-debug-runtime" ||
           cmd == "verify-debug-profile" ||
           cmd == "verify-diloco" ||
           cmd == "verify-windows-builtin" ||
           cmd == "verify-riscv64-builtin" ||
           cmd == "run-cross-target-smokes" ||
           cmd == "run-host-smokes" ||
           cmd == "run-stage23-libp2p-smokes" ||
           cmd == "compile-exe"

fn v3GateHandlesCommandBuild(cmd: str): bool =
    return cmd == "build-zero-exit" ||
           cmd == "build-panic-trace" ||
           cmd == "build-bounds-trace" ||
           cmd == "build-signal-trace" ||
           cmd == "build-call-chain" ||
           cmd == "build-ffi-handle" ||
           cmd == "build-bft-state-machine" ||
           cmd == "deploy-bft-validator-three-node" ||
           cmd == "verify-bft-validator-three-node" ||
           cmd == "status-bft-validator-three-node" ||
           cmd == "stop-bft-validator-three-node" ||
           cmd == "bench-bft-validator-three-node" ||
           cmd == "build-oracle-bft-state-machine" ||
           cmd == "deploy-oracle-bft-three-node" ||
           cmd == "status-oracle-bft-three-node" ||
           cmd == "stop-oracle-bft-three-node" ||
           cmd == "build-rwad-bft-state-machine" ||
           cmd == "build-program-selfhost" ||
           cmd == "build-chain-node" ||
           cmd == "build-linux-nolibc-exe" ||
           cmd == "build-chain-node-linux" ||
           cmd == "build-rwad-bft-linux"

fn v3GateHandlesCommandRuntime(cmd: str): bool =
    return cmd == "run-linux-object-smokes" ||
           cmd == "run-tcp-twoproc-smoke" ||
           cmd == "run-quic-twoproc-smoke" ||
           cmd == "run-udp-importc-smoke" ||
           cmd == "run-wasm-smokes" ||
           cmd == "run-browser-host-wasm-smoke" ||
           cmd == "run-chain-node-cli-smoke" ||
           cmd == "run-chain-node-process-smoke" ||
           cmd == "run-chain-node-three-node-smoke" ||
           cmd == "run-chain-node-resilience-smoke" ||
           cmd == "run-oracle-resilience-smoke" ||
           cmd == "oracle-fixture-query" ||
           cmd == "run-tailnet-control-smoke" ||
           cmd == "run-fresh-node-selfhost-gate" ||
           cmd == "run-migration-gate" ||
           cmd == "run-browser-webrtc-smokes" ||
           cmd == "r2c-react-v3" ||
           cmd == "r2c-react-v3-controller" ||
           cmd == "vpn-gui" ||
           cmd == "vpn-proxy"

fn v3GateHandlesCommand(cmd: str): bool =
    return v3GateHandlesCommandBase(cmd) ||
           v3GateHandlesCommandBuild(cmd) ||
           v3GateHandlesCommandRuntime(cmd)

fn v3GateMain(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let count: int32 = cmdline.ParamCount()
    if count <= 0:
        v3GateUsage()
        return 1
    let root: str = v3GateRoot()
    let cmd: str = cmdline.ParamStr(1)
    let args: str[] = v3GateCollectArgsFrom(2, count)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        v3GateUsage()
        return 0
    if cmd == "scan-hotpath":
        return v3GateScanHotpath(root)
    if cmd == "bootstrap-bridge":
        return v3GateBootstrapBridge(root)
    if cmd == "build-backend-driver":
        return v3GateBuildBackendDriver(root)
    if cmd == "run-smokes":
        return v3GateRunSmokes(root)
    if cmd == "print-bootstrap":
        let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
        v3GatePrintLine(strutil.Strip(contracts.v3BootstrapSnapshotReport(snapshot)))
        return 0
    if cmd == "support-matrix":
        v3GatePrintLine(strutil.Strip(smatrix.v3SupportMatrixReport(root)))
        return 0
    if cmd == "print-build-plan":
        let plan: buildplan.V3BackendBuildPlan = buildplan.v3BackendBuildPlanDefault(root)
        v3GatePrintLine(strutil.Strip(buildplan.v3BackendBuildPlanReport(plan)))
        return 0
    if cmd == "slice-gate":
        return v3GateSlice(root)
    if cmd == "debug-report":
        return v3GateRunStage3Command(root, "debug_report", cmd, args, "debug-report.log", true)
    if cmd == "print-symbols":
        return v3GateRunStage3Command(root, "print_symbols", cmd, args, "print-symbols.log", true)
    if cmd == "print-line-map":
        return v3GateRunStage3Command(root, "print_line_map", cmd, args, "print-line-map.log", true)
    if cmd == "print-object":
        return v3GateRunStage3Command(root, "print_object", cmd, args, "print-object.log", false)
    if cmd == "print-elf":
        return v3GateRunStage3Command(root, "print_elf", cmd, args, "print-elf.log", false)
    if cmd == "print-asm":
        return v3GateRunStage3Command(root, "print_asm", cmd, args, "print-asm.log", true)
    if cmd == "profile-run":
