    out.remoteDeployRel = remoteDeployRel
    out.proposalPort = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_PROPOSAL_PORT", "42061")))
    out.commitPort = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_COMMIT_PORT", "42062")))
    out.votePort = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_VOTE_PORT", "42063")))
    out.statePort = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_STATE_PORT", "42064")))
    out.proposerIntervalMs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_PROPOSER_INTERVAL_MS", "20")))
    out.followerIntervalMs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_FOLLOWER_INTERVAL_MS", "20")))
    out.proposalWindowMs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_PROPOSAL_WINDOW_MS", "1000")))
    out.voteWindowMs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_VOTE_WINDOW_MS", "1000")))
    out.commitWindowMs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_COMMIT_WINDOW_MS", "1000")))
    out.defaultMaxTxs = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_DEFAULT_MAX_TXS", "128")))
    out.assetId = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_ASSET_ID", "7")))
    out.aliceId = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_ALICE_ID", "1001")))
    out.bobId = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_V3_BFT_BOB_ID", "2002")))
