fn v3GateBuildSignalTrace(root: str): int32 =
    var compiler = ""
    if v3GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = v3path.v3PathAbsolute(root, "artifacts/v3_signal_trace")
    let src: str = v3path.v3PathAbsolute(root, "v3/src/tests/ordinary_signal_trace_fixture.cheng")
