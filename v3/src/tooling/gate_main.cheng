fn v3GatePrintLine(text: str) =
    os.writeLine(os.get_stdout(), text)

fn v3GatePrintErr(text: str) =
    os.writeLine(os.get_stderr(), text)

fn v3GateRoot(): str =
    return os.getEnvDefault("CHENG_V3_ROOT", os.getCurrentDir())

fn v3GateBootstrapBin(root: str, name: str): str =
    return v3path.v3PathAbsolute(root, "artifacts/v3_bootstrap/" + name)

fn v3GateArtifactsDir(root: str): str =
    return v3path.v3PathAbsolute(root, "artifacts/v3_gate")

fn v3GateEnsureArtifactsDir(root: str): bool =
    return v3path.v3MkdirP(root, v3GateArtifactsDir(root))

fn v3GateUsage() =
    let lines: str[] = v3GateUsageLines()
    for i in 0..<lines.len:
        v3GatePrintLine(lines[i])

