fn v3GatePrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn v3GatePrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn v3GatePrintBlock(text: str) =
    var start: int32 = 0
    var i: int32 = 0
    while i <= text.len:
        let atEnd: bool = i == text.len
        if atEnd:
            let line: str = strings.SliceBytes(text, start, i - start)
            v3GatePrintLine(line)
            start = i + 1
        elif text[i] == '\n':
            let line: str = strings.SliceBytes(text, start, i - start)
            v3GatePrintLine(line)
            start = i + 1
        i = i + 1

fn v3GateRoot(): str =
    let fallbackRoot = os.GetCurrentDir()
    var rootDir = fallbackRoot
    let envRoot = os.GetEnv("CHENG_V3_ROOT")
    if len(envRoot) > 0:
        rootDir = envRoot
    return rootDir

fn v3GateJoin2(a: str, b: str): str =
    return a + b

fn v3GateJoin3(a: str, b: str, c: str): str =
    return a + b + c

fn v3GateVerifyExportVisibility(root: str): int32 =
    var report = ""
    let ok: bool = frontend.stage1VerifyExportVisibilityCompat(root, report)
    let trimmed: str = strutil.Strip(report)
    if len(trimmed) > 0:
        if ok:
            v3GatePrintBlock(trimmed)
        else:
            v3GatePrintErr(trimmed)
    if !ok:
        v3GatePrintErr("v3 gate: verify-export-visibility failed")
        return 1
    v3GatePrintLine("v3 verify-export-visibility ok")
    return 0

fn v3GateVerifyExportVisibilityParallel(root: str): int32 =
    return v3GateRunStage3Command(root,
                                  "verify_export_visibility_parallel",
                                  "verify-export-visibility-parallel",
                                  [],
                                  "verify-export-visibility-parallel.log",
                                  false)

fn v3GateBootstrapBin(root: str, name: str): str =
    return v3path.V3PathAbsolute(root, "artifacts/v3_bootstrap/" + name)

fn v3GateArtifactsDir(root: str): str =
    return v3path.V3PathAbsolute(root, "artifacts/v3_gate")

fn v3GateEnsureArtifactsDir(root: str): bool =
    return v3path.V3MkdirP(root, v3GateArtifactsDir(root))

fn v3GateUsage() =
    let lines: str[] = v3GateUsageLines()
    for i in 0..<lines.len:
        v3GatePrintLine(lines[i])

