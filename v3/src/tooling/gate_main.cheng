fn v3GateBftConfigLoad(root: str): V3BftThreeNodeDeploy =
    var cfg = v3GateBftThreeNodeConfig(root)
    let manifestPath = v3GateBftManifestPath(cfg)
    if !os.FileExists(manifestPath):
        return cfg
    let text = v3path.V3ReadTextFile("", manifestPath)
    let appId = v3GateTextValue(text, "app_id")
    if len(appId) > 0:
        cfg.appId = appId
    let serverSsh = v3GateTextValue(text, "server_ssh")
    if len(serverSsh) > 0:
        cfg.serverSsh = serverSsh
    let relaySsh = v3GateTextValue(text, "relay_ssh")
    if len(relaySsh) > 0:
        cfg.relaySsh = relaySsh
    let serverAddr = v3GateTextValue(text, "server_addr")
    if len(serverAddr) > 0:
        cfg.serverAddress = serverAddr
    let serverRoot = v3GateTextValue(text, "server_root")
    if len(serverRoot) > 0:
        cfg.serverRepoRoot = serverRoot
    let relayRoot = v3GateTextValue(text, "relay_root")
    if len(relayRoot) > 0:
        cfg.relayRepoRoot = relayRoot
    let localDir = v3GateTextValue(text, "local_deploy_dir")
    if len(localDir) > 0:
        cfg.localDeployDir = localDir
    let remoteRel = v3GateTextValue(text, "remote_deploy_rel")
    if len(remoteRel) > 0:
        cfg.remoteDeployRel = remoteRel
    let proposalPort = v3GateTextValue(text, "proposal_port")
    if len(proposalPort) > 0:
        cfg.proposalPort = int32(strutil.ParseInt(proposalPort))
    let commitPort = v3GateTextValue(text, "commit_port")
    if len(commitPort) > 0:
        cfg.commitPort = int32(strutil.ParseInt(commitPort))
    let votePort = v3GateTextValue(text, "vote_port")
    if len(votePort) > 0:
        cfg.votePort = int32(strutil.ParseInt(votePort))
    let statePort = v3GateTextValue(text, "state_port")
    if len(statePort) > 0:
        cfg.statePort = int32(strutil.ParseInt(statePort))
    let proposerIntervalMs = v3GateTextValue(text, "proposer_interval_ms")
    if len(proposerIntervalMs) > 0:
        cfg.proposerIntervalMs = int32(strutil.ParseInt(proposerIntervalMs))
    let followerIntervalMs = v3GateTextValue(text, "follower_interval_ms")
    if len(followerIntervalMs) > 0:
        cfg.followerIntervalMs = int32(strutil.ParseInt(followerIntervalMs))
    let proposalWindowMs = v3GateTextValue(text, "proposal_window_ms")
    if len(proposalWindowMs) > 0:
        cfg.proposalWindowMs = int32(strutil.ParseInt(proposalWindowMs))
    let voteWindowMs = v3GateTextValue(text, "vote_window_ms")
    if len(voteWindowMs) > 0:
        cfg.voteWindowMs = int32(strutil.ParseInt(voteWindowMs))
    let commitWindowMs = v3GateTextValue(text, "commit_window_ms")
    if len(commitWindowMs) > 0:
        cfg.commitWindowMs = int32(strutil.ParseInt(commitWindowMs))
    let defaultMaxTxs = v3GateTextValue(text, "default_max_txs")
    if len(defaultMaxTxs) > 0:
        cfg.defaultMaxTxs = int32(strutil.ParseInt(defaultMaxTxs))
    let assetId = v3GateTextValue(text, "asset_id")
    if len(assetId) > 0:
        cfg.assetId = int32(strutil.ParseInt(assetId))
    let aliceId = v3GateTextValue(text, "alice_id")
    if len(aliceId) > 0:
        cfg.aliceId = int32(strutil.ParseInt(aliceId))
    let bobId = v3GateTextValue(text, "bob_id")
    if len(bobId) > 0:
        cfg.bobId = int32(strutil.ParseInt(bobId))
    let mintAmount = v3GateTextValue(text, "mint_amount")
    if len(mintAmount) > 0:
        cfg.mintAmount = int64(strutil.ParseInt(mintAmount))
    let transferAmount = v3GateTextValue(text, "transfer_amount")
    if len(transferAmount) > 0:
        cfg.transferAmount = int64(strutil.ParseInt(transferAmount))
    return cfg

fn v3GateBftNodeStatusZero(name: str): V3BftNodeStatus =
    return V3BftNodeStatus(name: name,
                           summary: "",
                           aliceQuery: "",
                           bobQuery: "",
                           height: "",
                           appHash: "",
                           aliceBalance: "",
                           bobBalance: "")

fn v3GateBftCollectLocalNodeStatus(root: str,
                                   cfg: V3BftThreeNodeDeploy,
                                   nodeName: str,
                                   statePath: str,
                                   logPrefix: str): Result[V3BftNodeStatus] =
    let binPath = v3GateBftLocalBin(root)
    let summaryRun = hostops.v3RunFileLogged(root,
                                             nodeName + "_show_state",
                                             binPath,
                                             ["show-state", "--state:" + statePath],
                                             [],
                                             root,
                                             20,
                                             logPrefix + ".show.log")
    if !hostops.v3LoggedRunOk(summaryRun):
        return Err[V3BftNodeStatus](summaryRun.output)
    let aliceRun = hostops.v3RunFileLogged(root,
                                           nodeName + "_alice_balance",
                                           binPath,
                                           ["query-balance",
                                            "--state:" + statePath,
                                            "--asset:" + intToStr(cfg.assetId),
                                            "--account:" + intToStr(cfg.aliceId)],
                                           [],
                                           root,
                                           20,
                                           logPrefix + ".alice.log")
    if !hostops.v3LoggedRunOk(aliceRun):
        return Err[V3BftNodeStatus](aliceRun.output)
    let bobRun = hostops.v3RunFileLogged(root,
                                         nodeName + "_bob_balance",
                                         binPath,
                                         ["query-balance",
                                          "--state:" + statePath,
                                          "--asset:" + intToStr(cfg.assetId),
                                          "--account:" + intToStr(cfg.bobId)],
                                         [],
                                         root,
                                         20,
                                         logPrefix + ".bob.log")
    if !hostops.v3LoggedRunOk(bobRun):
        return Err[V3BftNodeStatus](bobRun.output)
    return Ok[V3BftNodeStatus](V3BftNodeStatus(
        name: nodeName,
        summary: summaryRun.output,
        aliceQuery: aliceRun.output,
        bobQuery: bobRun.output,
        height: strutil.Strip(v3GateTextValue(summaryRun.output, "height")),
        appHash: strutil.Strip(v3GateTextValue(summaryRun.output, "app_hash")),
        aliceBalance: strutil.Strip(v3GateTextValue(aliceRun.output, "balance")),
        bobBalance: strutil.Strip(v3GateTextValue(bobRun.output, "balance"))
    ))

fn v3GateBftCollectRemoteNodeStatus(root: str,
                                    cfg: V3BftThreeNodeDeploy,
                                    nodeName: str,
                                    sshHost: str,
                                    repoRoot: str,
                                    statePath: str,
                                    logPrefix: str): Result[V3BftNodeStatus] =
    let binPath = v3GateBftRemoteBin(repoRoot)
    let summaryRun = v3GateRunRemoteShellLogged(root,
                                                nodeName + "_show_state",
                                                sshHost,
                                                "set -eu && " +
                                                    v3GateShellArgv([binPath,
                                                                     "show-state",
                                                                     "--state:" + statePath]),
                                                logPrefix + ".show.log",
                                                20)
    if !hostops.v3LoggedRunOk(summaryRun):
        return Err[V3BftNodeStatus](summaryRun.output)
    let aliceRun = v3GateRunRemoteShellLogged(root,
                                              nodeName + "_alice_balance",
                                              sshHost,
                                              "set -eu && " + v3GateShellArgv([binPath,
                                                                               "query-balance",
                                                                               "--state:" + statePath,
                                                                               "--asset:" + intToStr(cfg.assetId),
                                                                               "--account:" + intToStr(cfg.aliceId)]),
                                              logPrefix + ".alice.log",
                                              20)
    if !hostops.v3LoggedRunOk(aliceRun):
        return Err[V3BftNodeStatus](aliceRun.output)
    let bobRun = v3GateRunRemoteShellLogged(root,
                                            nodeName + "_bob_balance",
                                            sshHost,
                                            "set -eu && " + v3GateShellArgv([binPath,
                                                                             "query-balance",
                                                                             "--state:" + statePath,
                                                                             "--asset:" + intToStr(cfg.assetId),
                                                                             "--account:" + intToStr(cfg.bobId)]),
                                            logPrefix + ".bob.log",
                                            20)
    if !hostops.v3LoggedRunOk(bobRun):
        return Err[V3BftNodeStatus](bobRun.output)
    return Ok[V3BftNodeStatus](V3BftNodeStatus(
        name: nodeName,
        summary: summaryRun.output,
        aliceQuery: aliceRun.output,
        bobQuery: bobRun.output,
        height: strutil.Strip(v3GateTextValue(summaryRun.output, "height")),
        appHash: strutil.Strip(v3GateTextValue(summaryRun.output, "app_hash")),
        aliceBalance: strutil.Strip(v3GateTextValue(aliceRun.output, "balance")),
        bobBalance: strutil.Strip(v3GateTextValue(bobRun.output, "balance"))
    ))

fn v3GateBftPrintNodeStatus(status: V3BftNodeStatus) =
    v3GatePrintLine("node=" + status.name)
    v3GatePrintLine("height=" + status.height)
    v3GatePrintLine("app_hash=" + status.appHash)
    v3GatePrintLine("alice_balance=" + status.aliceBalance)
    v3GatePrintLine("bob_balance=" + status.bobBalance)

fn v3GateBftClusterMatches(serverStatus: V3BftNodeStatus,
                           relayStatus: V3BftNodeStatus,
                           localStatus: V3BftNodeStatus,
                           wantHeight: str,
                           wantAlice: str,
                           wantBob: str): bool =
    return serverStatus.height == wantHeight &&
           relayStatus.height == wantHeight &&
           localStatus.height == wantHeight &&
           len(serverStatus.appHash) > 0 &&
           serverStatus.appHash == relayStatus.appHash &&
           serverStatus.appHash == localStatus.appHash &&
           serverStatus.aliceBalance == wantAlice &&
           relayStatus.aliceBalance == wantAlice &&
           localStatus.aliceBalance == wantAlice &&
           serverStatus.bobBalance == wantBob &&
           relayStatus.bobBalance == wantBob &&
           localStatus.bobBalance == wantBob

fn v3GateBftVerifyReportPath(root: str): str =
    return v3path.V3PathAbsolute(root, "artifacts/v3_gate/verify_bft_validator_three_node.report.txt")

fn v3GateBftVerifyReportAppendNode(out: var str,
                                   prefix: str,
                                   status: V3BftNodeStatus) =
    out = out + prefix + "_name=" + status.name + "\n"
    out = out + prefix + "_height=" + status.height + "\n"
    out = out + prefix + "_app_hash=" + status.appHash + "\n"
    out = out + prefix + "_alice_balance=" + status.aliceBalance + "\n"
    out = out + prefix + "_bob_balance=" + status.bobBalance + "\n"

fn v3GateBftVerifyReportText(cfg: V3BftThreeNodeDeploy,
                             verified: bool,
                             serverStatus: V3BftNodeStatus,
                             relayStatus: V3BftNodeStatus,
                             localStatus: V3BftNodeStatus): str =
    let wantHeight = "1"
    let wantAlice = strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount)
    let wantBob = strings.Int64ToStr(cfg.transferAmount)
    var out = ""
    out = out + "version=v3.bft_three_node_verify.v1\n"
    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "server_ssh=" + cfg.serverSsh + "\n"
    out = out + "relay_ssh=" + cfg.relaySsh + "\n"
    out = out + "want_height=" + wantHeight + "\n"
    out = out + "want_alice_balance=" + wantAlice + "\n"
    out = out + "want_bob_balance=" + wantBob + "\n"
    v3GateBftVerifyReportAppendNode(out, "server", serverStatus)
    v3GateBftVerifyReportAppendNode(out, "relay", relayStatus)
    v3GateBftVerifyReportAppendNode(out, "local", localStatus)
    out = out + "verified=" + (verified ? "true" : "false") + "\n"
    return out

fn v3GateFormatMilli(valueMilli: int64): str =
    let whole = valueMilli / int64(1000)
    let frac = valueMilli % int64(1000)
    var fracText = strings.Int64ToStr(frac)
    if len(fracText) == 1:
        fracText = "00" + fracText
    elif len(fracText) == 2:
        fracText = "0" + fracText
    return strings.Int64ToStr(whole) + "." + fracText

fn v3GateBftDaemonMaxTxs(cfg: V3BftThreeNodeDeploy): int32 =
    var text = ""
    text = os.GetEnvDefault("CHENG_V3_BFT_MAX_TXS", intToStr(cfg.defaultMaxTxs))
    if len(text) <= 0:
        return cfg.defaultMaxTxs
    let value = int32(strutil.ParseInt(text))
    if value > 0:
        return value
    return cfg.defaultMaxTxs

fn v3GateBftWaitClusterState(root: str,
                             cfg: V3BftThreeNodeDeploy,
                             serverDir: str,
                             relayDir: str,
                             localDir: str,
                             wantHeight: str,
                             wantAlice: str,
                             wantBob: str,
                             logPrefix: str,
                             serverStatus: var V3BftNodeStatus,
                             relayStatus: var V3BftNodeStatus,
                             localStatus: var V3BftNodeStatus): bool =
    for i in 0..<300:
        i
        let serverRes = v3GateBftCollectRemoteNodeStatus(root,
                                                         cfg,
                                                         "server",
                                                         cfg.serverSsh,
                                                         cfg.serverRepoRoot,
                                                         os.JoinPath(serverDir, "server.state"),
                                                         logPrefix + "_server")
        if IsErr(serverRes):
            os.SleepMs(200)
            continue
        let relayRes = v3GateBftCollectRemoteNodeStatus(root,
                                                        cfg,
                                                        "relay",
                                                        cfg.relaySsh,
                                                        cfg.relayRepoRoot,
                                                        os.JoinPath(relayDir, "relay.state"),
                                                        logPrefix + "_relay")
        if IsErr(relayRes):
            os.SleepMs(200)
            continue
        let localRes = v3GateBftCollectLocalNodeStatus(root,
                                                       cfg,
                                                       "local",
                                                       os.JoinPath(localDir, "local.state"),
                                                       logPrefix + "_local")
        if IsErr(localRes):
            os.SleepMs(200)
            continue
        serverStatus = Value(serverRes)
        relayStatus = Value(relayRes)
        localStatus = Value(localRes)
        if v3GateBftClusterMatches(serverStatus,
                                   relayStatus,
                                   localStatus,
                                   wantHeight,
                                   wantAlice,
                                   wantBob):
            return true
        os.SleepMs(200)
    return false

fn v3GateBftBenchReportPath(root: str): str =
    return v3path.V3PathAbsolute(root, "artifacts/v3_gate/bench_bft_validator_three_node.report.txt")

fn v3GateBftBenchRestartTargetValid(target: str): bool =
    return target == "none" || target == "server" || target == "relay" || target == "local"

fn v3GateBftBenchStartServer(root: str,
                             cfg: V3BftThreeNodeDeploy,
                             serverDir: str,
                             serverBin: str,
                             localBin: str,
                             logPrefix: str): int32 =
    let proposerRun = v3GateRunRemoteShellLogged(root,
                                                 "bft_bench_start_server_proposer",
                                                 cfg.serverSsh,
                                                 v3GateBftStartDetachedShell(serverBin,
                                                                             ["validator-proposer-daemon",
                                                                              "--state:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.state"),
                                                                              "--queue:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.queue"),
                                                                              "--proposal-host:0.0.0.0",
                                                                              "--proposal-port:" +
                                                                                  intToStr(cfg.proposalPort),
                                                                              "--vote-host:0.0.0.0",
                                                                              "--vote-port:" +
                                                                                  intToStr(cfg.votePort),
                                                                              "--commit-host:0.0.0.0",
                                                                              "--commit-port:" +
                                                                                  intToStr(cfg.commitPort),
                                                                              "--proposal-file:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.proposal.hex"),
                                                                              "--commit-file:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.commit.hex"),
                                                                              "--state-sync-file:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.machine.hex"),
                                                                              "--proposal-ready-path:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.proposal.ready"),
                                                                              "--vote-ready-path:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.vote.ready"),
                                                                              "--commit-ready-path:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.commit.ready"),
                                                                              "--interval-ms:" +
                                                                                  intToStr(cfg.proposerIntervalMs),
                                                                              "--proposal-window-ms:" +
                                                                                  intToStr(cfg.proposalWindowMs),
                                                                              "--vote-window-ms:" +
                                                                                  intToStr(cfg.voteWindowMs),
                                                                              "--commit-window-ms:" +
                                                                                  intToStr(cfg.commitWindowMs),
                                                                              "--max-txs:" +
                                                                                  intToStr(v3GateBftDaemonMaxTxs(cfg))],
                                                                             os.JoinPath(serverDir,
                                                                                         "server_proposer.pid"),
                                                                             os.JoinPath(serverDir,
                                                                                         "server.proposer.log"),
                                                                             os.JoinPath(serverDir,
                                                                                         "server.proposal.ready"),
                                                                             true),
                                                 logPrefix + ".server_proposer.log",
                                                 30)
    if v3GateRunFailed(proposerRun):
        return proposerRun.exitCode
    let stateRun = v3GateRunRemoteShellLogged(root,
                                              "bft_bench_start_server_state",
                                              cfg.serverSsh,
                                              v3GateBftStartDetachedShell(serverBin,
                                                                          ["state-serve-daemon",
                                                                           "--file:" +
                                                                               os.JoinPath(serverDir,
                                                                                           "server.machine.hex"),
                                                                           "--host:0.0.0.0",
                                                                           "--port:" + intToStr(cfg.statePort),
                                                                           "--interval-ms:" +
                                                                               intToStr(cfg.followerIntervalMs)],
                                                                          os.JoinPath(serverDir, "server_state.pid"),
                                                                          os.JoinPath(serverDir, "server.state.log"),
                                                                          "",
                                                                          true),
                                              logPrefix + ".server_state.log",
                                              30)
    if v3GateRunFailed(stateRun):
        return stateRun.exitCode
    let probeRun = v3GateRunShellLogged(root,
                                        "bft_bench_probe_server_proposal",
                                        v3GateShellArgv([localBin,
                                                         "probe-proposal",
                                                         "--host:" + cfg.serverAddress,
                                                         "--port:" + intToStr(cfg.proposalPort),
                                                         "--attempts:3",
                                                         "--interval-ms:100",
                                                         "--handshake-only:1"]),
                                        logPrefix + ".server_probe.log",
                                        30)
    if v3GateRunFailed(probeRun):
        return probeRun.exitCode
    return 0

fn v3GateBftBenchStartRelay(root: str,
                            cfg: V3BftThreeNodeDeploy,
                            relayDir: str,
                            relayBin: str,
                            logPrefix: str): int32 =
    let relayRun = v3GateRunRemoteShellLogged(root,
                                              "bft_bench_start_relay_follower",
                                              cfg.relaySsh,
                                              v3GateBftStartDetachedShell(relayBin,
                                                                          ["validator-follower-daemon",
                                                                           "--state:" +
                                                                               os.JoinPath(relayDir, "relay.state"),
                                                                           "--proposal-host:" + cfg.serverAddress,
                                                                           "--proposal-port:" +
                                                                               intToStr(cfg.proposalPort),
                                                                           "--vote-host:" + cfg.serverAddress,
                                                                           "--vote-port:" +
                                                                               intToStr(cfg.votePort),
                                                                           "--commit-host:" + cfg.serverAddress,
                                                                           "--commit-port:" +
                                                                               intToStr(cfg.commitPort),
                                                                           "--sync-host:" + cfg.serverAddress,
                                                                           "--sync-port:" +
                                                                               intToStr(cfg.statePort),
                                                                           "--interval-ms:" +
                                                                               intToStr(cfg.followerIntervalMs)],
                                                                          os.JoinPath(relayDir, "relay_follower.pid"),
                                                                          os.JoinPath(relayDir, "relay.follower.log"),
                                                                          "",
                                                                          true),
                                              logPrefix + ".relay_start.log",
                                              30)
    if v3GateRunFailed(relayRun):
        return relayRun.exitCode
    return 0

fn v3GateBftBenchStartLocal(root: str,
                            cfg: V3BftThreeNodeDeploy,
                            localDir: str,
                            localBin: str,
                            logPrefix: str): int32 =
    let localRun = v3GateRunShellLogged(root,
                                        "bft_bench_start_local_follower",
                                        v3GateBftStartDetachedShell(localBin,
                                                                    ["validator-follower-daemon",
                                                                     "--state:" +
                                                                         os.JoinPath(localDir, "local.state"),
                                                                     "--proposal-host:" + cfg.serverAddress,
                                                                     "--proposal-port:" +
                                                                         intToStr(cfg.proposalPort),
                                                                     "--vote-host:" + cfg.serverAddress,
                                                                     "--vote-port:" + intToStr(cfg.votePort),
                                                                     "--commit-host:" + cfg.serverAddress,
                                                                     "--commit-port:" + intToStr(cfg.commitPort),
                                                                     "--sync-host:" + cfg.serverAddress,
                                                                     "--sync-port:" + intToStr(cfg.statePort),
                                                                     "--interval-ms:" +
                                                                         intToStr(cfg.followerIntervalMs)],
                                                                    os.JoinPath(localDir, "local_follower.pid"),
                                                                    os.JoinPath(localDir, "local.follower.log"),
                                                                    "",
                                                                    false),
                                        logPrefix + ".local_start.log",
                                        30)
    if v3GateRunFailed(localRun):
        return localRun.exitCode
    return 0

fn v3GateBftBenchRestartNode(root: str,
                             cfg: V3BftThreeNodeDeploy,
                             serverDir: str,
                             relayDir: str,
                             localDir: str,
                             serverBin: str,
                             relayBin: str,
                             localBin: str,
                             restartNode: str,
                             restartPauseMs: int32,
                             logPrefix: str): int32 =
    if restartNode == "none":
        return 0
    if restartNode == "server":
        let stopRun = v3GateRunRemoteShellLogged(root,
                                                 "bft_bench_restart_server_stop",
                                                 cfg.serverSsh,
                                                 v3GateBftStopShell([
                                                     os.JoinPath(serverDir, "server_proposer.pid"),
                                                     os.JoinPath(serverDir, "server_state.pid")
                                                 ], [
                                                     "[v]alidator-proposer-daemon --state:" +
                                                         os.JoinPath(serverDir, "server.state"),
                                                     "[s]tate-serve-daemon --file:" +
                                                         os.JoinPath(serverDir, "server.machine.hex")
                                                 ]),
                                                 logPrefix + ".server_stop.log",
                                                 30)
        if v3GateRunFailed(stopRun):
            return stopRun.exitCode
        os.SleepMs(restartPauseMs)
        return v3GateBftBenchStartServer(root, cfg, serverDir, serverBin, localBin, logPrefix)
    if restartNode == "relay":
        let stopRun = v3GateRunRemoteShellLogged(root,
                                                 "bft_bench_restart_relay_stop",
                                                 cfg.relaySsh,
                                                 v3GateBftStopShell([os.JoinPath(relayDir, "relay_follower.pid")],
                                                                    [
                                                                        "[v]alidator-follower-daemon --state:" +
                                                                            os.JoinPath(relayDir, "relay.state")
                                                                    ]),
                                                 logPrefix + ".relay_stop.log",
                                                 30)
        if v3GateRunFailed(stopRun):
            return stopRun.exitCode
        os.SleepMs(restartPauseMs)
        return v3GateBftBenchStartRelay(root, cfg, relayDir, relayBin, logPrefix)
    if restartNode == "local":
        let stopRun = v3GateRunShellLogged(root,
                                           "bft_bench_restart_local_stop",
                                           v3GateBftStopShell([os.JoinPath(localDir, "local_follower.pid")],
                                                              [
                                                                  "[v]alidator-follower-daemon --state:" +
                                                                      os.JoinPath(localDir, "local.state")
                                                              ]),
                                           logPrefix + ".local_stop.log",
                                           30)
        if v3GateRunFailed(stopRun):
            return stopRun.exitCode
        os.SleepMs(restartPauseMs)
        return v3GateBftBenchStartLocal(root, cfg, localDir, localBin, logPrefix)
    v3GatePrintErr("v3 bft bench: invalid restart node: " + restartNode)
    return 1

fn v3GateBftBenchReportText(cfg: V3BftThreeNodeDeploy,
                            txCountPerWave: int64,
                            waveCount: int32,
                            transferAmount: int64,
                            maxTxsPerBlock: int32,
                            restartNode: str,
                            restartWave: int32,
                            restartPauseMs: int32,
                            totalTxCount: int64,
                            txWireBytes: int64,
                            committedBytes: int64,
                            blockCount: int64,
                            elapsedMs: int64,
                            tpsMilli: int64,
                            bytesPerSec: int64,
                            kibPerSecMilli: int64,
                            waveElapsed: int64[],
                            waveTps: int64[],
                            waveBlocks: int64[],
                            waveRestarted: bool[],
                            finalServer: V3BftNodeStatus): str =
    var out = ""
    out = out + "version=v3.bft_three_node_bench.v2\n"
    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "tx_count_per_wave=" + strings.Int64ToStr(txCountPerWave) + "\n"
    out = out + "wave_count=" + intToStr(waveCount) + "\n"
    out = out + "transfer_amount=" + strings.Int64ToStr(transferAmount) + "\n"
    out = out + "max_txs_per_block=" + intToStr(maxTxsPerBlock) + "\n"
    out = out + "restart_node=" + restartNode + "\n"
    out = out + "restart_wave=" + intToStr(restartWave) + "\n"
    out = out + "restart_pause_ms=" + intToStr(restartPauseMs) + "\n"
    out = out + "tx_count=" + strings.Int64ToStr(totalTxCount) + "\n"
    out = out + "tx_wire_bytes=" + strings.Int64ToStr(txWireBytes) + "\n"
    out = out + "committed_bytes=" + strings.Int64ToStr(committedBytes) + "\n"
    out = out + "block_count=" + strings.Int64ToStr(blockCount) + "\n"
    out = out + "elapsed_ms=" + strings.Int64ToStr(elapsedMs) + "\n"
    out = out + "tps=" + v3GateFormatMilli(tpsMilli) + "\n"
    out = out + "throughput_bytes_per_sec=" + strings.Int64ToStr(bytesPerSec) + "\n"
    out = out + "throughput_kib_per_sec=" + v3GateFormatMilli(kibPerSecMilli) + "\n"
    out = out + "final_height=" + finalServer.height + "\n"
    out = out + "app_hash=" + finalServer.appHash + "\n"
    out = out + "alice_balance=" + finalServer.aliceBalance + "\n"
    out = out + "bob_balance=" + finalServer.bobBalance + "\n"
    for i in 0..<waveElapsed.len:
        let waveIndex = intToStr(i + 1)
        out = out + "wave_" + waveIndex + "_elapsed_ms=" + strings.Int64ToStr(waveElapsed[i]) + "\n"
        out = out + "wave_" + waveIndex + "_tps=" + v3GateFormatMilli(waveTps[i]) + "\n"
        out = out + "wave_" + waveIndex + "_block_count=" + strings.Int64ToStr(waveBlocks[i]) + "\n"
        out = out + "wave_" + waveIndex + "_restarted=" + (waveRestarted[i] ? "true" : "false") + "\n"
    return out

fn v3GateBftStopShell(pidPaths: str[], killPatterns: str[]): str =
    var out = "set -u"
    for i in 0..<pidPaths.len:
        let pidPath = pidPaths[i]
        out = out +
            " ; if [ -f " + os.QuoteShell(pidPath) + " ]; then" +
            " pid=$(cat " + os.QuoteShell(pidPath) + ");" +
            " if [ -n \"$pid\" ]; then" +
            " kill \"$pid\" >/dev/null 2>&1 || true;" +
            " sleep 1;" +
            " kill -9 \"$pid\" >/dev/null 2>&1 || true;" +
            " fi;" +
            " rm -f " + os.QuoteShell(pidPath) + ";" +
            " fi"
    for i in 0..<killPatterns.len:
        out = out + " ; pkill -f -- " + os.QuoteShell(killPatterns[i]) + " >/dev/null 2>&1 || true"
    return out

fn v3GateBftStartDetachedShell(binPath: str,
                               args: str[],
                               pidPath: str,
                               logPath: str,
                               readyPath: str,
                               useSetsid: bool): str =
    var out = "set -eu && mkdir -p " + os.QuoteShell(v3path.V3PathParentDir(logPath))
    var inner = "echo $$ > " + os.QuoteShell(pidPath) +
        " && exec " + v3GateShellArgv([binPath]) +
        " " + v3GateShellArgv(args)
    inner = inner + " > " + os.QuoteShell(logPath) + " 2>&1 < /dev/null"
    if len(readyPath) > 0:
        out = out + " && rm -f " + os.QuoteShell(readyPath)
    out = out + " && rm -f " + os.QuoteShell(pidPath)
    if useSetsid:
        out = out + " && setsid -f sh -lc " + os.QuoteShell(inner)
    else:
        out = out + " && sh -lc " + os.QuoteShell(inner) + " &"
    out = out +
        " && i=0 && while [ ! -f " + os.QuoteShell(pidPath) +
        " ] && [ \"$i\" -lt 50 ]; do i=$((i + 1)); sleep 0.1; done"
    out = out + " && test -f " + os.QuoteShell(pidPath)
    return out

fn v3GateBftWaitReadyShell(paths: str[], timeoutSec: int32): str =
    var out = "set -eu && i=0 && while [ \"$i\" -lt " + intToStr(timeoutSec * 10) + " ]; do"
    var checks = ""
    for i in 0..<paths.len:
        if i > 0:
            checks = checks + " && "
        checks = checks + "[ -f " + os.QuoteShell(paths[i]) + " ]"
    out = out + " if " + checks + "; then exit 0; fi; i=$((i + 1)); sleep 0.1; done; exit 1"
    return out

fn v3GateBftSyncRemoteRepo(root: str,
                           sshHost: str,
                           remoteRoot: str,
                           logPath: str): int32 =
    let ensureRun = v3GateRunRemoteShellLogged(root,
                                               "bft_remote_repo_mkdir",
                                               sshHost,
                                               "set -eu && mkdir -p " + os.QuoteShell(remoteRoot),
                                               logPath + ".mkdir.log",
                                               20)
    if v3GateRunFailed(ensureRun):
        return ensureRun.exitCode
    let remoteShell = "ssh -o BatchMode=yes -o ConnectTimeout=20 -o ServerAliveInterval=5 -o ServerAliveCountMax=3"
    var lastRun = hostops.v3LoggedRunZero("bft_remote_rsync", "rsync", logPath, 255, "")
    for attempt in 0..<3:
        let run = hostops.v3RunProgramLogged(root,
                                             "bft_remote_rsync",
                                             "rsync",
                                             ["-az",
                                              "-e", remoteShell,
                                              "--delete",
                                              "--exclude", ".git",
                                              "--exclude", "artifacts",
                                              "--exclude", "chengcache",
                                              "--exclude", "node_modules",
                                              root + "/",
                                              sshHost + ":" + remoteRoot + "/"],
                                             [],
                                             root,
                                             0,
                                             logPath)
        lastRun = run
        if !v3GateRunFailed(run):
            return 0
        if attempt >= 2 || !v3GateRemoteTransportRetryable(run.output):
            return run.exitCode
        v3GatePrintLine("[v3 gate] remote rsync retry " + intToStr(attempt + 1) + " " + sshHost)
        os.SleepMs((attempt + 1) * 1000)
    return lastRun.exitCode

fn v3GateBftBuildRemote(root: str,
                        sshHost: str,
                        remoteRoot: str,
                        logPath: str): int32 =
    let readyRun = v3GateRunRemoteShellLogged(root,
                                              "bft_remote_ready",
                                              sshHost,
                                              "set -eu && " + v3GateBftRemoteBuildReadyCommand(remoteRoot),
                                              logPath + ".ready.log",
                                              30)
    if !v3GateRunFailed(readyRun):
        v3GatePrintLine("[v3 gate] remote bft reuse " + sshHost)
        return 0
    let stage3FreshRun = v3GateRunRemoteShellLogged(root,
                                                    "bft_remote_stage3_fresh",
                                                    sshHost,
                                                    "set -eu && " + v3GateBftRemoteStage3FreshCommand(remoteRoot),
                                                    logPath + ".stage3.log",
                                                    30)
    if !v3GateRunFailed(stage3FreshRun):
        let incrementalCommand = v3GateBftRemoteLockedShell(
            remoteRoot,
            "BFT_STATE_TARGET=x86_64-unknown-linux-gnu" +
            " BFT_STATE_RUN_SELF_TEST=1" +
            " artifacts/v3_bootstrap/cheng.stage3 build-bft-state-machine")
        let incrementalRun = v3GateRunRemoteShellLogged(root,
                                                        "bft_remote_build_incremental",
                                                        sshHost,
                                                        incrementalCommand,
                                                        logPath,
                                                        900)
        if v3GateRunFailed(incrementalRun):
            return incrementalRun.exitCode
        v3GatePrintLine("[v3 gate] remote bft incremental " + sshHost)
        return 0
    let fullCommand = v3GateBftRemoteLockedShell(
        remoteRoot,
        "mkdir -p artifacts/v3_bootstrap" +
        " && cc -std=c11 -O2 -Wall -Wextra -pedantic" +
        " v3/bootstrap/cheng_v3_seed.c -o artifacts/v3_bootstrap/cheng.stage0" +
        " && CHENG_V3_ROOT=" + os.QuoteShell(remoteRoot) +
        " CHENG_V3_TARGET=x86_64-unknown-linux-gnu" +
        " artifacts/v3_bootstrap/cheng.stage0 bootstrap-bridge >/dev/null" +
        " && BFT_STATE_TARGET=x86_64-unknown-linux-gnu" +
        " BFT_STATE_RUN_SELF_TEST=1" +
        " artifacts/v3_bootstrap/cheng.stage3 build-bft-state-machine")
    let run = v3GateRunRemoteShellLogged(root, "bft_remote_build", sshHost, fullCommand, logPath, 900)
    if v3GateRunFailed(run):
        return run.exitCode
    v3GatePrintLine("[v3 gate] remote bft rebuild " + sshHost)
    return 0

fn v3GateStatusBftValidatorThreeNode(root: str): int32 =
    let cfg = v3GateBftConfigLoad(root)
    let serverDir = v3GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = v3GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverRes = v3GateBftCollectRemoteNodeStatus(root,
                                                     cfg,
                                                     "server",
                                                     cfg.serverSsh,
                                                     cfg.serverRepoRoot,
                                                     os.JoinPath(serverDir, "server.state"),
                                                     "artifacts/v3_gate/bft_server_status")
    if IsErr(serverRes):
        v3GatePrintErr("v3 bft deploy: server status failed")
        v3GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    let relayRes = v3GateBftCollectRemoteNodeStatus(root,
                                                    cfg,
                                                    "relay",
                                                    cfg.relaySsh,
                                                    cfg.relayRepoRoot,
                                                    os.JoinPath(relayDir, "relay.state"),
                                                    "artifacts/v3_gate/bft_relay_status")
    if IsErr(relayRes):
        v3GatePrintErr("v3 bft deploy: relay status failed")
        v3GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    let localRes = v3GateBftCollectLocalNodeStatus(root,
                                                   cfg,
                                                   "local",
                                                   os.JoinPath(localDir, "local.state"),
                                                   "artifacts/v3_gate/bft_local_status")
    if IsErr(localRes):
        v3GatePrintErr("v3 bft deploy: local status failed")
        v3GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    v3GateBftPrintNodeStatus(Value(serverRes))
    v3GatePrintLine("---")
    v3GateBftPrintNodeStatus(Value(relayRes))
    v3GatePrintLine("---")
    v3GateBftPrintNodeStatus(Value(localRes))
    return 0

fn v3GateStopBftValidatorThreeNode(root: str): int32 =
    let cfg = v3GateBftConfigLoad(root)
    let serverDir = v3GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = v3GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverRun = v3GateRunRemoteShellLogged(root,
                                               "bft_stop_server",
                                               cfg.serverSsh,
                                               v3GateBftStopShell([
                                                   os.JoinPath(serverDir, "server_proposer.pid"),
                                                   os.JoinPath(serverDir, "server_state.pid")
                                               ], [
                                                   "[v]alidator-proposer-daemon --state:" +
                                                       os.JoinPath(serverDir, "server.state"),
                                                   "[s]tate-serve-daemon --file:" +
                                                       os.JoinPath(serverDir, "server.machine.hex")
                                               ]),
                                               "artifacts/v3_gate/bft_stop_server.log",
                                               30)
    if v3GateRunFailed(serverRun):
        return serverRun.exitCode
    let relayRun = v3GateRunRemoteShellLogged(root,
                                              "bft_stop_relay",
                                              cfg.relaySsh,
                                              v3GateBftStopShell([os.JoinPath(relayDir, "relay_follower.pid")],
                                                                 [
                                                                     "[v]alidator-follower-daemon --state:" +
                                                                         os.JoinPath(relayDir, "relay.state")
                                                                 ]),
                                              "artifacts/v3_gate/bft_stop_relay.log",
                                              30)
    if v3GateRunFailed(relayRun):
        return relayRun.exitCode
    let localRun = v3GateRunShellLogged(root,
                                        "bft_stop_local",
                                        v3GateBftStopShell([os.JoinPath(localDir, "local_follower.pid")],
                                                           [
                                                               "[v]alidator-follower-daemon --state:" +
                                                                   os.JoinPath(localDir, "local.state")
                                                           ]),
                                        "artifacts/v3_gate/bft_stop_local.log",
                                        30)
    if v3GateRunFailed(localRun):
        return localRun.exitCode
    v3GatePrintLine("v3 bft deploy: stopped")
    return 0

fn v3GateDeployBftValidatorThreeNode(root: str): int32 =
    let cfg = v3GateBftThreeNodeConfig(root)
    if !v3path.V3MkdirP(root, cfg.localDeployDir):
        v3GatePrintErr("v3 bft deploy: failed to create local deploy dir")
        return 1
    if !v3path.V3WriteTextFile(root, v3GateBftManifestPath(cfg), v3GateBftManifestText(cfg)):
        v3GatePrintErr("v3 bft deploy: failed to write manifest")
        return 1
    if v3GateStopBftValidatorThreeNode(root) != 0:
        return 1
    if v3GateBftSyncRemoteRepo(root,
                               cfg.serverSsh,
                               cfg.serverRepoRoot,
                               "artifacts/v3_gate/bft_sync_server.log") != 0:
        return 1
    if v3GateBftSyncRemoteRepo(root,
                               cfg.relaySsh,
                               cfg.relayRepoRoot,
                               "artifacts/v3_gate/bft_sync_relay.log") != 0:
        return 1
    if v3GateBuildBftStateMachine(root) != 0:
        return 1
    if v3GateBftBuildRemote(root,
                            cfg.serverSsh,
                            cfg.serverRepoRoot,
                            "artifacts/v3_gate/bft_build_server.log") != 0:
        return 1
    if v3GateBftBuildRemote(root,
                            cfg.relaySsh,
                            cfg.relayRepoRoot,
                            "artifacts/v3_gate/bft_build_relay.log") != 0:
        return 1
    let serverDir = v3GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = v3GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverBin = v3GateBftRemoteBin(cfg.serverRepoRoot)
    let relayBin = v3GateBftRemoteBin(cfg.relayRepoRoot)
    let localBin = v3GateBftLocalBin(root)
    let serverInit = v3GateRunRemoteShellLogged(root,
                                                "bft_init_server",
                                                cfg.serverSsh,
                                                "set -eu && mkdir -p " + os.QuoteShell(serverDir) +
                                                " && rm -f " +
                                                os.QuoteShell(os.JoinPath(serverDir, "server.proposal.ready")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.commit.ready")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.vote.ready")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.state.ready")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.state.vote_lock")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.queue.cursor")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server.machine.hex")) +
                                                " " + os.QuoteShell(os.JoinPath(serverDir, "server_state.pid")) +
                                                " && rm -rf " +
                                                    os.QuoteShell(os.JoinPath(serverDir,
                                                                              "server.machine.hex.snapshots")) +
                                                " && : > " + os.QuoteShell(os.JoinPath(serverDir, "server.queue")) +
                                                " && : > " +
                                                    os.QuoteShell(os.JoinPath(serverDir, "server.proposal.hex")) +
                                                " && : > " +
                                                    os.QuoteShell(os.JoinPath(serverDir, "server.commit.hex")) +
                                                " && : > " + os.QuoteShell(os.JoinPath(serverDir, "server.votes")) +
                                                " && " + v3GateShellArgv([serverBin,
                                                                          "init",
                                                                          "--state:" +
                                                                              os.JoinPath(serverDir, "server.state"),
                                                                          "--app-id:" + cfg.appId,
                                                                          "--validator-slot:1",
                                                                          "--force"]),
                                                "artifacts/v3_gate/bft_init_server.log",
                                                30)
    if v3GateRunFailed(serverInit):
        return serverInit.exitCode
    let relayInit = v3GateRunRemoteShellLogged(root,
                                               "bft_init_relay",
                                               cfg.relaySsh,
                                               "set -eu && mkdir -p " + os.QuoteShell(relayDir) +
                                               " && " + v3GateShellArgv([relayBin,
                                                                         "init",
                                                                         "--state:" +
                                                                             os.JoinPath(relayDir, "relay.state"),
                                                                         "--app-id:" + cfg.appId,
                                                                         "--validator-slot:2",
                                                                         "--force"]),
                                               "artifacts/v3_gate/bft_init_relay.log",
                                               30)
    if v3GateRunFailed(relayInit):
        return relayInit.exitCode
    let localInit = v3GateRunShellLogged(root,
                                         "bft_init_local",
                                         "set -eu && mkdir -p " + os.QuoteShell(localDir) +
                                         " && " + v3GateShellArgv([localBin,
                                                                   "init",
                                                                   "--state:" + os.JoinPath(localDir, "local.state"),
                                                                   "--app-id:" + cfg.appId,
                                                                   "--validator-slot:3",
                                                                   "--force"]),
                                         "artifacts/v3_gate/bft_init_local.log",
                                         30)
    if v3GateRunFailed(localInit):
        return localInit.exitCode
    let queueRun = v3GateRunRemoteShellLogged(root,
                                              "bft_seed_queue",
                                              cfg.serverSsh,
                                              "set -eu && " +
                                              v3GateShellArgv([serverBin,
                                                               "submit-mint",
                                                               "--queue:" + os.JoinPath(serverDir, "server.queue"),
                                                               "--asset:" + intToStr(cfg.assetId),
                                                               "--account:" + intToStr(cfg.aliceId),
                                                               "--amount:" + strings.Int64ToStr(cfg.mintAmount)]) +
                                              " && " +
                                              v3GateShellArgv([serverBin,
                                                               "submit-transfer",
                                                               "--queue:" + os.JoinPath(serverDir, "server.queue"),
                                                               "--asset:" + intToStr(cfg.assetId),
                                                               "--from:" + intToStr(cfg.aliceId),
                                                               "--to:" + intToStr(cfg.bobId),
                                                               "--amount:" + strings.Int64ToStr(cfg.transferAmount)]),
                                              "artifacts/v3_gate/bft_seed_queue.log",
                                              30)
    if v3GateRunFailed(queueRun):
        return queueRun.exitCode
    let serverProposerRun = v3GateRunRemoteShellLogged(root,
                                                       "bft_start_server_proposer",
                                                       cfg.serverSsh,
                                                       v3GateBftStartDetachedShell(serverBin,
                                                                                ["validator-proposer-daemon",
                                                                                 "--state:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.state"),
                                                                                 "--queue:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.queue"),
                                                                                 "--proposal-host:0.0.0.0",
                                                                                 "--proposal-port:" +
                                                                                     intToStr(cfg.proposalPort),
                                                                                 "--vote-host:0.0.0.0",
                                                                                 "--vote-port:" +
                                                                                     intToStr(cfg.votePort),
                                                                                 "--commit-host:0.0.0.0",
                                                                                 "--commit-port:" +
                                                                                     intToStr(cfg.commitPort),
                                                                                 "--proposal-file:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.proposal." +
                                                                                                     "hex"),
                                                                                 "--commit-file:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.commit.hex"),
                                                                                 "--state-sync-file:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.machine.hex"),
                                                                                 "--proposal-ready-path:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.proposal.ready"),
                                                                                 "--vote-ready-path:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.vote.ready"),
                                                                                 "--commit-ready-path:" +
                                                                                     os.JoinPath(serverDir,
                                                                                                 "server.commit.ready"),
                                                                                 "--interval-ms:" +
                                                                                     intToStr(cfg.proposerIntervalMs),
                                                                                 "--proposal-window-ms:" +
                                                                                     intToStr(cfg.proposalWindowMs),
                                                                                 "--vote-window-ms:" +
                                                                                     intToStr(cfg.voteWindowMs),
                                                                                 "--commit-window-ms:" +
                                                                                     intToStr(cfg.commitWindowMs),
                                                                                 "--max-txs:" +
                                                                                     intToStr(
                                                                                         v3GateBftDaemonMaxTxs(cfg))],
                                                                                os.JoinPath(serverDir,
                                                                                            "server_proposer.pid"),
                                                                                os.JoinPath(serverDir,
                                                                                            "server.proposer.log"),
                                                                                os.JoinPath(serverDir,
                                                                                            "server.proposal.ready"),
                                                                                true),
                                                       "artifacts/v3_gate/bft_start_server_proposer.log",
                                                       30)
    if v3GateRunFailed(serverProposerRun):
        return serverProposerRun.exitCode
    let serverStateRun = v3GateRunRemoteShellLogged(root,
                                                    "bft_start_server_state",
                                                    cfg.serverSsh,
                                                    v3GateBftStartDetachedShell(serverBin,
                                                                             ["state-serve-daemon",
                                                                              "--file:" +
                                                                                  os.JoinPath(serverDir,
                                                                                              "server.machine.hex"),
                                                                              "--host:0.0.0.0",
                                                                              "--port:" +
                                                                                  intToStr(cfg.statePort),
                                                                              "--interval-ms:" +
                                                                                  intToStr(cfg.followerIntervalMs)],
                                                                             os.JoinPath(serverDir,
                                                                                         "server_state.pid"),
                                                                             os.JoinPath(serverDir,
                                                                                         "server.state.log"),
                                                                             "",
                                                                             true),
                                                    "artifacts/v3_gate/bft_start_server_state.log",
                                                    30)
    if v3GateRunFailed(serverStateRun):
        return serverStateRun.exitCode
    let serverReadyRun = v3GateRunRemoteShellLogged(root,
                                                    "bft_wait_server_ready",
                                                    cfg.serverSsh,
                                                    "set -eu && i=0 && while { [ ! -f " +
                                                        os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.proposal.ready")) +
                                                        " ] || [ ! -f " +
                                                        os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.vote.ready")) +
                                                        " ]; } && [ \"$i\" -lt 200 ]; do i=$((i + 1)); sleep 0.05; done && test -f " +
                                                        os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.proposal.ready")) +
                                                        " && test -f " +
                                                        os.QuoteShell(os.JoinPath(serverDir,
                                                                                  "server.vote.ready")),
                                                    "artifacts/v3_gate/bft_wait_server_ready.log",
                                                    30)
    if v3GateRunFailed(serverReadyRun):
        return serverReadyRun.exitCode
    let relayFollowerRun = v3GateRunRemoteShellLogged(root,
                                                      "bft_start_relay_follower",
                                                      cfg.relaySsh,
                                                      v3GateBftStartDetachedShell(relayBin,
                                                                               ["validator-follower-daemon",
                                                                                "--state:" +
                                                                                    os.JoinPath(relayDir,
                                                                                                "relay.state"),
                                                                                "--proposal-host:" + cfg.serverAddress,
                                                                                 "--proposal-port:" +
                                                                                     intToStr(cfg.proposalPort),
                                                                                "--vote-host:" + cfg.serverAddress,
                                                                                "--vote-port:" +
                                                                                    intToStr(cfg.votePort),
                                                                                "--commit-host:" + cfg.serverAddress,
                                                                                "--commit-port:" +
                                                                                    intToStr(cfg.commitPort),
                                                                                "--sync-host:" + cfg.serverAddress,
                                                                                "--sync-port:" +
                                                                                    intToStr(cfg.statePort),
                                                                                "--interval-ms:" +
                                                                                    intToStr(cfg.followerIntervalMs)],
                                                                               os.JoinPath(relayDir,
                                                                                           "relay_follower.pid"),
                                                                               os.JoinPath(relayDir,
                                                                                           "relay.follower.log"),
                                                                               "",
                                                                               true),
                                                      "artifacts/v3_gate/bft_start_relay_follower.log",
                                                      30)
    if v3GateRunFailed(relayFollowerRun):
        return relayFollowerRun.exitCode
    let localFollowerRun = v3GateRunShellLogged(root,
                                                "bft_start_local_follower",
                                                v3GateBftStartDetachedShell(localBin,
                                                                         ["validator-follower-daemon",
                                                                          "--state:" +
                                                                              os.JoinPath(localDir, "local.state"),
                                                                          "--proposal-host:" + cfg.serverAddress,
                                                                          "--proposal-port:" +
                                                                              intToStr(cfg.proposalPort),
                                                                          "--vote-host:" + cfg.serverAddress,
                                                                          "--vote-port:" + intToStr(cfg.votePort),
                                                                          "--commit-host:" + cfg.serverAddress,
                                                                          "--commit-port:" + intToStr(cfg.commitPort),
                                                                          "--sync-host:" + cfg.serverAddress,
                                                                          "--sync-port:" +
                                                                              intToStr(cfg.statePort),
                                                                          "--interval-ms:" +
                                                                              intToStr(cfg.followerIntervalMs)],
                                                                         os.JoinPath(localDir, "local_follower.pid"),
                                                                         os.JoinPath(localDir, "local.follower.log"),
                                                                         "",
                                                                         false),
                                                "artifacts/v3_gate/bft_start_local_follower.log",
                                                30)
    if v3GateRunFailed(localFollowerRun):
        return localFollowerRun.exitCode
    let wantHeight = "1"
    let wantAlice = strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount)
    let wantBob = strings.Int64ToStr(cfg.transferAmount)
    var converged = false
    var lastServer = v3GateBftNodeStatusZero("server")
    var lastRelay = v3GateBftNodeStatusZero("relay")
    var lastLocal = v3GateBftNodeStatusZero("local")
    for i in 0..<200:
        i
        let serverRes = v3GateBftCollectRemoteNodeStatus(root,
                                                         cfg,
                                                         "server",
                                                         cfg.serverSsh,
                                                         cfg.serverRepoRoot,
                                                         os.JoinPath(serverDir, "server.state"),
                                                         "artifacts/v3_gate/bft_server_wait")
        if IsErr(serverRes):
            os.SleepMs(200)
            continue
        let relayRes = v3GateBftCollectRemoteNodeStatus(root,
                                                        cfg,
                                                        "relay",
                                                        cfg.relaySsh,
                                                        cfg.relayRepoRoot,
                                                        os.JoinPath(relayDir, "relay.state"),
                                                        "artifacts/v3_gate/bft_relay_wait")
        if IsErr(relayRes):
            os.SleepMs(200)
            continue
        let localRes = v3GateBftCollectLocalNodeStatus(root,
                                                       cfg,
                                                       "local",
                                                       os.JoinPath(localDir, "local.state"),
                                                       "artifacts/v3_gate/bft_local_wait")
        if IsErr(localRes):
            os.SleepMs(200)
            continue
        lastServer = Value(serverRes)
        lastRelay = Value(relayRes)
        lastLocal = Value(localRes)
        if lastServer.height == wantHeight &&
           lastRelay.height == wantHeight &&
           lastLocal.height == wantHeight &&
           len(lastServer.appHash) > 0 &&
           lastServer.appHash == lastRelay.appHash &&
           lastServer.appHash == lastLocal.appHash &&
           lastServer.aliceBalance == wantAlice &&
           lastRelay.aliceBalance == wantAlice &&
           lastLocal.aliceBalance == wantAlice &&
           lastServer.bobBalance == wantBob &&
           lastRelay.bobBalance == wantBob &&
           lastLocal.bobBalance == wantBob:
            converged = true
            break
        os.SleepMs(200)
    if !converged:
        v3GatePrintErr("v3 bft deploy: three-node cluster did not converge")
        v3GateBftPrintNodeStatus(lastServer)
        v3GatePrintLine("---")
        v3GateBftPrintNodeStatus(lastRelay)
        v3GatePrintLine("---")
        v3GateBftPrintNodeStatus(lastLocal)
        return 1
    let ueRun = v3GateRunShellLogged(root,
                                     "bft_ue_check",
                                     "ps -Ao pid=,ppid=,state=,etime=,command= |" +
                                         " awk '$2==1 && $3 ~ /^U/ && $5 ~ /bft_state_machine/'",
                                     "artifacts/v3_gate/bft_ue_check.log",
                                     10)
    if v3GateRunFailed(ueRun):
        return ueRun.exitCode
    v3GateBftPrintNodeStatus(lastServer)
    v3GatePrintLine("---")
    v3GateBftPrintNodeStatus(lastRelay)
    v3GatePrintLine("---")
    v3GateBftPrintNodeStatus(lastLocal)
    let ueText = strutil.Strip(ueRun.output)
    if len(ueText) > 0:
        v3GatePrintErr("v3 bft deploy: unexpected UE process")
        v3GatePrintErr(ueText)
        return 1
    return 0

fn v3GateVerifyBftValidatorThreeNode(root: str): int32 =
    if v3GateDeployBftValidatorThreeNode(root) != 0:
        return 1
    let cfg = v3GateBftConfigLoad(root)
    let serverDir = v3GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = v3GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let wantHeight = "1"
    let wantAlice = strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount)
    let wantBob = strings.Int64ToStr(cfg.transferAmount)
    var serverStatus = v3GateBftNodeStatusZero("server")
    var relayStatus = v3GateBftNodeStatusZero("relay")
    var localStatus = v3GateBftNodeStatusZero("local")
    var verified = false
    let serverRes = v3GateBftCollectRemoteNodeStatus(root,
                                                     cfg,
                                                     "server",
                                                     cfg.serverSsh,
                                                     cfg.serverRepoRoot,
                                                     os.JoinPath(serverDir, "server.state"),
                                                     "artifacts/v3_gate/bft_verify_server")
    let relayRes = v3GateBftCollectRemoteNodeStatus(root,
                                                    cfg,
                                                    "relay",
                                                    cfg.relaySsh,
                                                    cfg.relayRepoRoot,
                                                    os.JoinPath(relayDir, "relay.state"),
                                                    "artifacts/v3_gate/bft_verify_relay")
    let localRes = v3GateBftCollectLocalNodeStatus(root,
                                                   cfg,
                                                   "local",
                                                   os.JoinPath(localDir, "local.state"),
                                                   "artifacts/v3_gate/bft_verify_local")
    if !IsErr(serverRes):
        serverStatus = Value(serverRes)
    if !IsErr(relayRes):
        relayStatus = Value(relayRes)
    if !IsErr(localRes):
        localStatus = Value(localRes)
    if !IsErr(serverRes) && !IsErr(relayRes) && !IsErr(localRes):
        verified = v3GateBftClusterMatches(serverStatus,
                                           relayStatus,
                                           localStatus,
                                           wantHeight,
                                           wantAlice,
                                           wantBob)
    let reportPath = v3GateBftVerifyReportPath(root)
    let reportText = v3GateBftVerifyReportText(cfg,
                                               verified,
                                               serverStatus,
                                               relayStatus,
                                               localStatus)
    if !v3path.V3WriteTextFile(root, reportPath, reportText):
        v3GatePrintErr("v3 bft verify: failed to write report: " + reportPath)
        let _ = v3GateStopBftValidatorThreeNode(root)
        return 1
    let stopCode = v3GateStopBftValidatorThreeNode(root)
    if IsErr(serverRes):
        v3GatePrintErr("v3 bft verify: server status failed")
        v3GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    if IsErr(relayRes):
        v3GatePrintErr("v3 bft verify: relay status failed")
        v3GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    if IsErr(localRes):
        v3GatePrintErr("v3 bft verify: local status failed")
        v3GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    if !verified:
        v3GatePrintErr("v3 bft verify: three-node cluster drifted")
        v3GateBftPrintNodeStatus(serverStatus)
        v3GatePrintLine("---")
        v3GateBftPrintNodeStatus(relayStatus)
        v3GatePrintLine("---")
        v3GateBftPrintNodeStatus(localStatus)
        return 1
    if stopCode != 0:
        v3GatePrintErr("v3 bft verify: stop failed after verification")
        return stopCode
    v3GatePrintLine("v3 bft verify ok")
    v3GatePrintLine("report=" + reportPath)
    return 0

fn v3GateBenchBftValidatorThreeNode(root: str,
                                    args: str[]): int32 =
    let txCountText = v3GateReadFlag(args, "--tx-count", "64")
    let waveCountText = v3GateReadFlag(args, "--wave-count", "1")
    let transferAmountText = v3GateReadFlag(args, "--transfer-amount", "1")
    let txCount = int32(strutil.ParseInt(txCountText))
    let waveCount = int32(strutil.ParseInt(waveCountText))
    let transferAmount = int64(strutil.ParseInt(transferAmountText))
    let maxTxsText = v3GateReadFlag(args, "--max-txs-per-block", intToStr(txCount))
    let maxTxsPerBlock = int32(strutil.ParseInt(maxTxsText))
    let restartNode = strutil.Strip(v3GateReadFlag(args, "--restart-node", "none"))
    let restartPauseMsText = v3GateReadFlag(args, "--restart-pause-ms", "1000")
    let restartPauseMs = int32(strutil.ParseInt(restartPauseMsText))
    let defaultRestartWave = waveCount >= 2 ? 2 : 1
    let restartWaveText = v3GateReadFlag(args, "--restart-wave", intToStr(defaultRestartWave))
    var restartWave = int32(strutil.ParseInt(restartWaveText))
    if txCount <= 0 || waveCount <= 0 || transferAmount <= int64(0) || maxTxsPerBlock <= 0 || restartPauseMs < 0:
        v3GatePrintErr("v3 bft bench: --tx-count --wave-count --transfer-amount --max-txs-per-block must be positive, --restart-pause-ms must be non-negative")
        return 1
    if !v3GateBftBenchRestartTargetValid(restartNode):
        v3GatePrintErr("v3 bft bench: --restart-node must be none/server/relay/local")
        return 1
    if restartNode == "none":
        restartWave = 0
    elif restartWave <= 0 || restartWave > waveCount:
        v3GatePrintErr("v3 bft bench: --restart-wave must be within 1..wave-count when restart is enabled")
        return 1
    var savedMaxTxs = ""
    savedMaxTxs = os.GetEnvDefault("CHENG_V3_BFT_MAX_TXS", "")
    os.SetEnv("CHENG_V3_BFT_MAX_TXS", intToStr(maxTxsPerBlock))
    if v3GateDeployBftValidatorThreeNode(root) != 0:
        os.SetEnv("CHENG_V3_BFT_MAX_TXS", savedMaxTxs)
        return 1
    os.SetEnv("CHENG_V3_BFT_MAX_TXS", savedMaxTxs)
    let cfg = v3GateBftConfigLoad(root)
    let serverDir = v3GateBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = v3GateBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverBin = v3GateBftRemoteBin(cfg.serverRepoRoot)
    let relayBin = v3GateBftRemoteBin(cfg.relayRepoRoot)
    let localBin = v3GateBftLocalBin(root)
    var baseServer = v3GateBftNodeStatusZero("server")
    var baseRelay = v3GateBftNodeStatusZero("relay")
    var baseLocal = v3GateBftNodeStatusZero("local")
    if !v3GateBftWaitClusterState(root,
                                  cfg,
                                  serverDir,
                                  relayDir,
                                  localDir,
                                  "1",
                                  strings.Int64ToStr(cfg.mintAmount - cfg.transferAmount),
                                  strings.Int64ToStr(cfg.transferAmount),
                                  "artifacts/v3_gate/bft_bench_bootstrap_wait",
                                  baseServer,
                                  baseRelay,
                                  baseLocal):
        v3GatePrintErr("v3 bft bench: baseline cluster wait failed")
        return 1
    var baseHeight = int64(strutil.ParseInt(baseServer.height))
    var baseAlice = int64(strutil.ParseInt(baseServer.aliceBalance))
    var baseBob = int64(strutil.ParseInt(baseServer.bobBalance))
    let totalRequiredAmount = int64(txCount) * int64(waveCount) * transferAmount
    if baseAlice < totalRequiredAmount:
        let topupAmount = totalRequiredAmount - baseAlice + transferAmount
        let topupRun = v3GateRunRemoteShellLogged(root,
                                                  "bft_bench_topup",
                                                  cfg.serverSsh,
                                                  "set -eu && " + v3GateShellArgv([serverBin,
                                                                                   "submit-mint",
                                                                                   "--queue:" +
                                                                                       os.JoinPath(serverDir,
                                                                                                   "server.queue"),
                                                                                   "--asset:" + intToStr(cfg.assetId),
                                                                                   "--account:" +
                                                                                       intToStr(cfg.aliceId),
                                                                                   "--amount:" +
                                                                                       strings.Int64ToStr(
                                                                                           topupAmount)]),
                                                  "artifacts/v3_gate/bft_bench_topup.log",
                                                  30)
        if v3GateRunFailed(topupRun):
            return topupRun.exitCode
        baseHeight = baseHeight + int64(1)
        baseAlice = baseAlice + topupAmount
        if !v3GateBftWaitClusterState(root,
                                      cfg,
                                      serverDir,
                                      relayDir,
                                      localDir,
                                      strings.Int64ToStr(baseHeight),
                                      strings.Int64ToStr(baseAlice),
                                      strings.Int64ToStr(baseBob),
                                      "artifacts/v3_gate/bft_bench_topup_wait",
                                      baseServer,
                                      baseRelay,
                                      baseLocal):
            v3GatePrintErr("v3 bft bench: topup did not converge")
            return 1
    let benchStart = monotimes.GetMonoTime()
    var waveElapsedMs: int64[] = []
    var waveTpsMilli: int64[] = []
    var waveBlockCounts: int64[] = []
    var waveRestarted: bool[] = []
    var totalQueuedCount = int64(0)
    var totalQueuedBytes = int64(0)
    var txWireBytes = int64(0)
    var totalBlocks = int64(0)
    var expectedHeight = baseHeight
    var expectedAlice = baseAlice
    var expectedBob = baseBob
    var finalServer = baseServer
    var finalRelay = baseRelay
    var finalLocal = baseLocal
    let requiredPerWave = int64(txCount) * transferAmount
    for wave in 0..<waveCount:
        let waveIndex = wave + 1
        let waveStart = monotimes.GetMonoTime()
        let wavePrefix = "artifacts/v3_gate/bft_bench_wave_" + intToStr(waveIndex)
        let queueRun = v3GateRunRemoteShellLogged(root,
                                                  "bft_bench_submit_series_wave_" + intToStr(waveIndex),
                                                  cfg.serverSsh,
                                                  "set -eu && " + v3GateShellArgv([serverBin,
                                                                                   "submit-transfer-series",
                                                                                   "--queue:" +
                                                                                       os.JoinPath(serverDir,
                                                                                                   "server.queue"),
                                                                                   "--asset:" +
                                                                                       intToStr(cfg.assetId),
                                                                                   "--from:" +
                                                                                       intToStr(cfg.aliceId),
                                                                                   "--to:" +
                                                                                       intToStr(cfg.bobId),
                                                                                   "--amount:" +
                                                                                       strings.Int64ToStr(
                                                                                           transferAmount),
                                                                                   "--count:" +
                                                                                       intToStr(txCount)]),
                                                  wavePrefix + ".submit.log",
                                                  30)
        if v3GateRunFailed(queueRun):
            return queueRun.exitCode
        let queuedCount = int64(strutil.ParseInt(v3GateTextValue(queueRun.output, "queued_count")))
        let queuedBytes = int64(strutil.ParseInt(v3GateTextValue(queueRun.output, "queued_bytes")))
        let txWireBytesWave = int64(strutil.ParseInt(v3GateTextValue(queueRun.output, "tx_wire_bytes")))
        if queuedCount != int64(txCount) || queuedBytes <= 0 || txWireBytesWave <= 0:
            v3GatePrintErr("v3 bft bench: invalid submit-transfer-series report")
            v3GatePrintErr(strutil.Strip(queueRun.output))
            return 1
        if txWireBytes <= int64(0):
            txWireBytes = txWireBytesWave
        let blocksNeeded = int64((txCount + maxTxsPerBlock - 1) / maxTxsPerBlock)
        totalQueuedCount = totalQueuedCount + queuedCount
        totalQueuedBytes = totalQueuedBytes + queuedBytes
        totalBlocks = totalBlocks + blocksNeeded
        expectedHeight = expectedHeight + blocksNeeded
        expectedAlice = expectedAlice - requiredPerWave
        expectedBob = expectedBob + requiredPerWave
        var restarted = false
        if restartNode != "none" && waveIndex == restartWave:
            if v3GateBftBenchRestartNode(root,
                                         cfg,
                                         serverDir,
                                         relayDir,
                                         localDir,
                                         serverBin,
                                         relayBin,
                                         localBin,
                                         restartNode,
                                         restartPauseMs,
                                         wavePrefix + ".restart") != 0:
                return 1
            restarted = true
        if !v3GateBftWaitClusterState(root,
                                      cfg,
                                      serverDir,
                                      relayDir,
                                      localDir,
                                      strings.Int64ToStr(expectedHeight),
                                      strings.Int64ToStr(expectedAlice),
                                      strings.Int64ToStr(expectedBob),
                                      wavePrefix + ".wait",
                                      finalServer,
                                      finalRelay,
                                      finalLocal):
            v3GatePrintErr("v3 bft bench: benchmark transactions did not converge")
            v3GatePrintErr("wave=" + intToStr(waveIndex))
            return 1
        var waveElapsedNs: int64 = monotimes.MonoTimeNs(monotimes.GetMonoTime()) - monotimes.MonoTimeNs(waveStart)
        var waveElapsed = waveElapsedNs / 1000000
        if waveElapsed <= int64(0):
            waveElapsed = int64(1)
        let waveTps = queuedCount * int64(1000000) / waveElapsed
        add(waveElapsedMs, waveElapsed)
        add(waveTpsMilli, waveTps)
        add(waveBlockCounts, blocksNeeded)
        add(waveRestarted, restarted)
    var elapsedNs: int64 = monotimes.MonoTimeNs(monotimes.GetMonoTime()) - monotimes.MonoTimeNs(benchStart)
    var elapsedMs = elapsedNs / 1000000
    if elapsedMs <= int64(0):
        elapsedMs = int64(1)
    let tpsMilli = totalQueuedCount * int64(1000000) / elapsedMs
    let bytesPerSec = totalQueuedBytes * int64(1000) / elapsedMs
    let kibPerSecMilli = totalQueuedBytes * int64(1000 * 1000) / (elapsedMs * int64(1024))
    let ueRun = v3GateRunShellLogged(root,
                                     "bft_bench_ue_check",
                                     "ps -Ao pid=,ppid=,state=,etime=,command= |" +
                                         " awk '$2==1 && $3 ~ /^U/ && $5 ~ /bft_state_machine/'",
                                     "artifacts/v3_gate/bft_bench_ue_check.log",
                                     10)
    if v3GateRunFailed(ueRun):
        return ueRun.exitCode
    let ueText = strutil.Strip(ueRun.output)
    if len(ueText) > 0:
        v3GatePrintErr("v3 bft bench: unexpected UE process")
        v3GatePrintErr(ueText)
        return 1
    let reportPath = v3GateBftBenchReportPath(root)
    let reportText = v3GateBftBenchReportText(cfg,
                                              int64(txCount),
                                              waveCount,
                                              transferAmount,
                                              maxTxsPerBlock,
                                              restartNode,
                                              restartWave,
                                              restartPauseMs,
                                              totalQueuedCount,
                                              txWireBytes,
                                              totalQueuedBytes,
                                              totalBlocks,
                                              elapsedMs,
                                              tpsMilli,
                                              bytesPerSec,
                                              kibPerSecMilli,
                                              waveElapsedMs,
                                              waveTpsMilli,
                                              waveBlockCounts,
                                              waveRestarted,
                                              finalServer)
    if !v3path.V3WriteTextFile(root, reportPath, reportText):
        v3GatePrintErr("v3 bft bench: failed to write report: " + reportPath)
        return 1
    v3GatePrintLine("tx_count_per_wave=" + strings.Int64ToStr(int64(txCount)))
    v3GatePrintLine("wave_count=" + intToStr(waveCount))
    v3GatePrintLine("restart_node=" + restartNode)
    v3GatePrintLine("restart_wave=" + intToStr(restartWave))
    v3GatePrintLine("restart_pause_ms=" + intToStr(restartPauseMs))
    v3GatePrintLine("tx_count=" + strings.Int64ToStr(totalQueuedCount))
    v3GatePrintLine("tx_wire_bytes=" + strings.Int64ToStr(txWireBytes))
    v3GatePrintLine("committed_bytes=" + strings.Int64ToStr(totalQueuedBytes))
    v3GatePrintLine("block_count=" + strings.Int64ToStr(totalBlocks))
    v3GatePrintLine("elapsed_ms=" + strings.Int64ToStr(elapsedMs))
    v3GatePrintLine("tps=" + v3GateFormatMilli(tpsMilli))
    v3GatePrintLine("throughput_bytes_per_sec=" + strings.Int64ToStr(bytesPerSec))
    v3GatePrintLine("throughput_kib_per_sec=" + v3GateFormatMilli(kibPerSecMilli))
    v3GatePrintLine("final_height=" + finalServer.height)
    v3GatePrintLine("app_hash=" + finalServer.appHash)
    v3GatePrintLine("alice_balance=" + finalServer.aliceBalance)
    v3GatePrintLine("bob_balance=" + finalServer.bobBalance)
    for i in 0..<waveElapsedMs.len:
        let waveIndex = intToStr(i + 1)
        v3GatePrintLine("wave_" + waveIndex + "_elapsed_ms=" + strings.Int64ToStr(waveElapsedMs[i]))
        v3GatePrintLine("wave_" + waveIndex + "_tps=" + v3GateFormatMilli(waveTpsMilli[i]))
        v3GatePrintLine("wave_" + waveIndex + "_block_count=" + strings.Int64ToStr(waveBlockCounts[i]))
        v3GatePrintLine("wave_" + waveIndex + "_restarted=" + (waveRestarted[i] ? "true" : "false"))
    v3GatePrintLine("report=" + reportPath)
    return 0

fn v3GateRequireFile(path: str, context: str): bool =
    if os.FileExists(path):
        return true
    v3GatePrintErr(context + ": missing file: " + path)
    return false

fn v3GateRequireFileContains(path: str,
                             needle: str,
                             context: str): bool =
    if !v3GateRequireFile(path, context):
        return false
    let text: str = v3path.V3ReadTextFile("", path)
    if v3GateOutputContains(text, needle):
        return true
    v3GatePrintErr(context + ": missing output: " + needle)
    let outputText = strutil.Strip(text)
    if len(outputText) > 0:
        v3GatePrintErr(outputText)
    return false

fn v3GateRequirePrefixArtifacts(prefix: str,
                                suffixes: str[],
                                context: str): bool =
    for i in 0..<suffixes.len:
        if !v3GateRequireFile(prefix + suffixes[i], context):
            return false
    return true

fn v3GateRequireAnyOutput(text: str,
                          needles: str[],
                          context: str): bool =
    if v3GateTextContainsAny(text, needles):
        return true
    v3GatePrintErr(context + ": missing expected output set")
    let outputText = strutil.Strip(text)
    if len(outputText) > 0:
        v3GatePrintErr(outputText)
    return false

fn v3GateResolveSmokeCompiler(root: str,
                              explicitPath: str,
                              primaryEnvKey: str,
                              fallbackEnvKey: str,
                              outCompiler: var str): int32 =
    outCompiler = strutil.Strip(explicitPath)
    if len(outCompiler) <= 0 && len(primaryEnvKey) > 0:
        let envCompiler = os.GetEnvDefault(primaryEnvKey, "")
        outCompiler = strutil.Strip(envCompiler)
    if len(outCompiler) <= 0 && len(fallbackEnvKey) > 0:
        let envCompiler = os.GetEnvDefault(fallbackEnvKey, "")
        outCompiler = strutil.Strip(envCompiler)
    if len(outCompiler) <= 0:
        return v3GateEnsureBackendDriverReady(root, outCompiler)
    outCompiler = v3path.V3PathAbsolute(root, outCompiler)
    if !os.FileExists(outCompiler):
        v3GatePrintErr("v3 gate: missing compiler: " + outCompiler)
        return 1
    return 0

fn v3GateResolveSmokeLabel(args: str[],
                           envKey: str,
                           defaultLabel: str): str =
    let explicit = strutil.Strip(v3GateReadFlag(args, "--label", ""))
    if len(explicit) > 0:
        return explicit
    let keyedEnv = os.GetEnvDefault(envKey, "")
    let keyed = strutil.Strip(keyedEnv)
    if len(keyed) > 0:
        return keyed
    let sharedEnv = os.GetEnvDefault("CHENG_V3_SMOKE_LABEL", "")
    let shared = strutil.Strip(sharedEnv)
    if len(shared) > 0:
        return shared
    return defaultLabel

fn v3GateTextContainsAny(text: str, needles: str[]): bool =
    for i in 0..<needles.len:
        if v3path.V3TextContains(text, needles[i]):
            return true
    return false

fn v3GateAsciiSpace(ch: char): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn v3GateOrphanSnapshotKey(lineRaw: str): str =
    let line = strutil.Strip(lineRaw)
    if len(line) <= 0:
        return ""
    let total = len(line)
    var cursor = 0
    while cursor < total:
        if !v3GateAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    let pidStart = cursor
    while cursor < total:
        if v3GateAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    if cursor <= pidStart:
        return ""
    let pidText = v3path.V3TextSlice(line, pidStart, cursor - pidStart)
    for skip in 0..<3:
        let _ = skip
        while cursor < total:
            if !v3GateAsciiSpace(line[cursor]):
                break
            cursor = cursor + 1
        let fieldStart = cursor
        while cursor < total:
            if v3GateAsciiSpace(line[cursor]):
                break
            cursor = cursor + 1
        if cursor <= fieldStart:
            return ""
    while cursor < total:
        if !v3GateAsciiSpace(line[cursor]):
            break
        cursor = cursor + 1
    if cursor >= total:
        return ""
    let commandText = v3path.V3TextSlice(line, cursor, total - cursor)
    return pidText + "|" + commandText

fn v3GateNormalizeOrphanSnapshot(text: str): str[] =
    var out: str[] = []
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let key = v3GateOrphanSnapshotKey(lines[i])
        if len(key) > 0:
            add(out, key)
    return out

fn v3GateSeqContainsStr(items: str[], value: str): bool =
    for i in 0..<items.len:
        if items[i] == value:
            return true
    return false

fn v3GateCollectNewOrphanKeys(before: str[], after: str[]): str[] =
    var out: str[] = []
    for i in 0..<after.len:
        let key = after[i]
        if !v3GateSeqContainsStr(before, key) && !v3GateSeqContainsStr(out, key):
            add(out, key)
    return out

fn v3GateReadChengOrphanSnapshot(root: str,
                                 label: str,
                                 logPath: str,
                                 outLines: var str[]): int32 =
    let command = "ps -Ao pid=,ppid=,state=,etime=,command= | " +
                  "awk -v root=" + os.QuoteShell(root) +
                  " '$2==1 && $3 ~ /^U/ && index($0, root) > 0'"
    let run = v3GateRunShellLogged(root, label, command, logPath, 10)
    if v3GateRunFailed(run):
        outLines = []
        return run.exitCode
    outLines = v3GateNormalizeOrphanSnapshot(run.output)
    return 0

fn v3GateVerifyOrphanGuard(root: str): int32 =
    let toolingDir: str = v3path.V3PathAbsolute(root, "v3/tooling")
    let bannedEntries: str[] = [
        "guarded_exec_v3.py",
        "orphan_guard_run.sh",
        "failfast_parallel.sh",
        "bootstrap_bridge_v3.sh",
        "build_bft_state_machine_v3.sh",
        "build_backend_driver_v3.sh",
        "build_bounds_trace_v3.sh",
        "build_browser_host_wasm_v3.sh",
        "browser_host_wasm_runner.js",
        "build_call_chain_v3.sh",
        "build_chain_node_linux_obj_v3.sh",
        "build_chain_node_linux_v3.sh",
        "build_chain_node_v3.sh",
        "build_ffi_handle_v3.sh",
        "build_linux_nolibc_exe_v3.sh",
        "build_panic_trace_v3.sh",
        "build_program_selfhost_v3.sh",
        "build_rwad_bft_state_machine_linux_obj_v3.sh",
        "build_rwad_bft_state_machine_linux_v3.sh",
        "build_rwad_bft_state_machine_v3.sh",
        "build_signal_trace_v3.sh",
        "build_twoway_search_smoke_v3.sh",
        "build_zero_exit_v3.sh",
        "cheng_tooling_repo_dispatch.sh",
        "cheng_v3.sh",
        "compare_bench.sh",
        "profile_run_v3.sh",
        "r2c_react_v3_fresh_clean_gate.sh",
        "run_slice_gate.sh",
        "run_v3_browser_host_wasm_smoke.sh",
        "run_v3_browser_webrtc_smokes.sh",
        "run_v3_chain_node_cli_smoke.sh",
        "run_v3_chain_node_process_smoke.sh",
        "run_v3_chain_node_three_node_smoke.sh",
        "run_v3_compile_exe.sh",
        "run_v3_fresh_node_selfhost_gate.sh",
        "run_v3_host_smokes.sh",
        "run_v3_linux_object_smokes.sh",
        "run_v3_migration_gate.sh",
        "run_v3_single_smoke.sh",
        "run_v3_stage23_libp2p_smokes.sh",
        "run_v3_tailnet_control_smoke.sh",
        "run_v3_tcp_twoproc_smoke.sh",
        "run_v3_quic_twoproc_smoke.sh",
        "run_v3_udp_importc_smoke.sh",
        "run_v3_wasm_smokes.sh",
        "run_v3_windows_riscv_builtin_smokes.sh",
        "scan_forbidden_hotpath.sh",
        "verify_debug_profile_v3.sh",
        "verify_debug_runtime_v3.sh",
        "verify_debug_tools_v3.sh",
        "verify_orphan_guard_v3.sh",
        "verify_riscv64_builtin_linker_v3.sh",
        "verify_windows_builtin_linker_v3.sh"
    ]
    let entries: str[] = os.WalkDir(toolingDir)
    for i in 0..<entries.len:
        let entry: os.WalkDirEntry = os.WalkDirEntry(entries, i)
        let kind: os.PathComponent = os.WalkDirEntryKind(entry)
        if kind != os.PathComponent(0) &&
           kind != os.PathComponent(2):
            continue
        let path: str = os.WalkDirEntryPath(entry)
        let parts: os.SplitFileResult = os.SplitFile(path)
        let fileName: str = parts.name + parts.ext
        if v3GateTextContainsAny(fileName, bannedEntries):
            v3GatePrintErr("verify_orphan_guard_v3: banned tooling entry name: " + path)
            return 1
        if parts.ext == ".sh":
            v3GatePrintErr("verify_orphan_guard_v3: shell tooling entry not allowed: " + path)
            return 1
        if parts.ext != ".py":
            continue
        let text: str = v3path.V3ReadTextFile("", path)
        if v3GateTextContainsAny(text, bannedEntries):
            v3GatePrintErr("verify_orphan_guard_v3: banned direct process guard ref in " + path)
            return 1
    var orphanBefore: str[] = []
    if v3GateReadChengOrphanSnapshot(root,
                                     "orphan_guard_before",
                                     "artifacts/v3_gate/orphan_guard_before.log",
                                     orphanBefore) != 0:
        return 1
    if v3GateBootstrapBridge(root) != 0:
        return 1
    if v3GateBuildBackendDriver(root) != 0:
        return 1
    var orphanAfter: str[] = []
    if v3GateReadChengOrphanSnapshot(root,
                                     "orphan_guard_after",
                                     "artifacts/v3_gate/orphan_guard_after.log",
                                     orphanAfter) != 0:
        return 1
    let orphanDelta = v3GateCollectNewOrphanKeys(orphanBefore, orphanAfter)
    if orphanDelta.len > 0:
        v3GatePrintErr("verify_orphan_guard_v3: new Cheng U/UE process leaked after bootstrap/build")
        for i in 0..<orphanDelta.len:
            v3GatePrintErr(orphanDelta[i])
        return 1
    v3GatePrintLine("verify_orphan_guard_v3 ok")
    return 0

