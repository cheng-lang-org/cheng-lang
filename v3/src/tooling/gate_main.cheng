        name: nodeName,
        summary: summaryRun.output,
        latestQuery: latestRun.output,
        twapQuery: twapRun.output,
        height: strutil.Strip(v3GateTextValue(summaryRun.output, "height")),
        lastFinalizedRoundId: strutil.Strip(v3GateTextValue(summaryRun.output, "last_finalized_round_id")),
        appHash: strutil.Strip(v3GateTextValue(summaryRun.output, "app_hash")),
        latestCode: strutil.Strip(v3GateTextValue(latestRun.output, "code")),
        latestRoundId: strutil.Strip(v3GateTextValue(latestRun.output, "round_id")),
        latestPriceE8: strutil.Strip(v3GateTextValue(latestRun.output, "price_e8")),
        twapCode: strutil.Strip(v3GateTextValue(twapRun.output, "code")),
        twapPriceE8: strutil.Strip(v3GateTextValue(twapRun.output, "price_e8"))
    ))

fn v3GateOracleBftPrintNodeStatus(status: V3OracleBftNodeStatus) =
    v3GatePrintLine("node=" + status.name)
    v3GatePrintLine("height=" + status.height)
    v3GatePrintLine("last_finalized_round_id=" + status.lastFinalizedRoundId)
    v3GatePrintLine("app_hash=" + status.appHash)
    v3GatePrintLine("latest_code=" + status.latestCode)
    v3GatePrintLine("latest_round_id=" + status.latestRoundId)
    v3GatePrintLine("latest_price_e8=" + status.latestPriceE8)
    v3GatePrintLine("twap_code=" + status.twapCode)
    v3GatePrintLine("twap_price_e8=" + status.twapPriceE8)

fn v3GateOracleBftClusterMatches(serverStatus: V3OracleBftNodeStatus,
                                 relayStatus: V3OracleBftNodeStatus,
                                 localStatus: V3OracleBftNodeStatus): bool =
    let wantHeight = "3"
    let wantRound = strings.Int64ToStr(v3GateOracleBftExpectedRound())
    let wantLatestPrice = strings.Int64ToStr(v3GateOracleBftExpectedLatestPrice())
    let wantTwapPrice = strings.Int64ToStr(v3GateOracleBftExpectedTwapPrice())
    return serverStatus.height == wantHeight &&
           relayStatus.height == wantHeight &&
           localStatus.height == wantHeight &&
           serverStatus.lastFinalizedRoundId == wantRound &&
           relayStatus.lastFinalizedRoundId == wantRound &&
           localStatus.lastFinalizedRoundId == wantRound &&
           len(serverStatus.appHash) > 0 &&
           serverStatus.appHash == relayStatus.appHash &&
           serverStatus.appHash == localStatus.appHash &&
           serverStatus.latestCode == "0" &&
           relayStatus.latestCode == "0" &&
           localStatus.latestCode == "0" &&
           serverStatus.latestRoundId == wantRound &&
           relayStatus.latestRoundId == wantRound &&
           localStatus.latestRoundId == wantRound &&
           serverStatus.latestPriceE8 == wantLatestPrice &&
           relayStatus.latestPriceE8 == wantLatestPrice &&
           localStatus.latestPriceE8 == wantLatestPrice &&
           serverStatus.twapCode == "0" &&
           relayStatus.twapCode == "0" &&
           localStatus.twapCode == "0" &&
           serverStatus.twapPriceE8 == wantTwapPrice &&
           relayStatus.twapPriceE8 == wantTwapPrice &&
           localStatus.twapPriceE8 == wantTwapPrice

fn v3GateOracleBftStatePath(dir: str): str =
    return os.JoinPath(dir, "oracle.state")

fn v3GateOracleBftInitCommand(binPath: str,
                              statePath: str,
                              appId: str): str =
    return v3GateShellArgv([binPath,
                            "init",
                            "--state:" + statePath,
                            "--app-id:" + appId,
                            "--force"])

fn v3GateOracleBftFixtureFinalizeCommand(binPath: str,
                                         statePath: str,
                                         height: int64,
                                         roundId: int64): str =
    return v3GateShellArgv([binPath,
                            "fixture-finalize",
                            "--state:" + statePath,
                            "--height:" + strings.Int64ToStr(height),
                            "--round:" + strings.Int64ToStr(roundId),
                            "--reporter-start:1",
                            "--reporter-end:5",
                            "--time-hint-ms:" + strings.Int64ToStr(oracle_types.v3OracleRoundEndMs(roundId) + int64(1))])

fn v3GateOracleBftDeployShell(binPath: str,
                              dir: str,
                              appId: str): str =
    let statePath = v3GateOracleBftStatePath(dir)
    return "set -eu && mkdir -p " + os.QuoteShell(dir) +
           " && " + v3GateOracleBftInitCommand(binPath, statePath, appId) +
           " && " + v3GateOracleBftFixtureFinalizeCommand(binPath, statePath, int64(1), int64(20)) +
           " && " + v3GateOracleBftFixtureFinalizeCommand(binPath, statePath, int64(2), int64(21)) +
           " && " + v3GateOracleBftFixtureFinalizeCommand(binPath, statePath, int64(3), int64(22))

fn v3GateOracleBftVerifyReportPath(root: str): str =
    return v3path.V3PathAbsolute(root, "artifacts/v3_gate/verify_oracle_bft_three_node.report.txt")

fn v3GateOracleBftVerifyReportAppendNode(out: var str,
                                         prefix: str,
                                         status: V3OracleBftNodeStatus) =
    out = out + prefix + "_name=" + status.name + "\n"
    out = out + prefix + "_height=" + status.height + "\n"
    out = out + prefix + "_last_finalized_round_id=" + status.lastFinalizedRoundId + "\n"
    out = out + prefix + "_app_hash=" + status.appHash + "\n"
    out = out + prefix + "_latest_code=" + status.latestCode + "\n"
    out = out + prefix + "_latest_round_id=" + status.latestRoundId + "\n"
    out = out + prefix + "_latest_price_e8=" + status.latestPriceE8 + "\n"
    out = out + prefix + "_twap_code=" + status.twapCode + "\n"
    out = out + prefix + "_twap_price_e8=" + status.twapPriceE8 + "\n"

fn v3GateOracleBftVerifyReportText(cfg: V3OracleBftThreeNodeDeploy,
                                   verified: bool,
                                   serverStatus: V3OracleBftNodeStatus,
                                   relayStatus: V3OracleBftNodeStatus,
                                   localStatus: V3OracleBftNodeStatus): str =
    var out = ""
    out = out + "version=v3.oracle_bft_three_node_verify.v1\n"
    out = out + "app_id=" + cfg.appId + "\n"
    out = out + "pair=" + v3GateOracleBftPairText() + "\n"
    out = out + "want_height=3\n"
    out = out + "want_round=" + strings.Int64ToStr(v3GateOracleBftExpectedRound()) + "\n"
    out = out + "want_latest_price_e8=" + strings.Int64ToStr(v3GateOracleBftExpectedLatestPrice()) + "\n"
    out = out + "want_twap_price_e8=" + strings.Int64ToStr(v3GateOracleBftExpectedTwapPrice()) + "\n"
    v3GateOracleBftVerifyReportAppendNode(out, "server", serverStatus)
    v3GateOracleBftVerifyReportAppendNode(out, "relay", relayStatus)
    v3GateOracleBftVerifyReportAppendNode(out, "local", localStatus)
    if verified:
        out = out + "verified=true\n"
    else:
        out = out + "verified=false\n"
    return out

fn v3GateStopOracleBftThreeNode(root: str): int32 =
    let cfg = v3GateOracleBftConfigLoad(root)
    let serverDir = v3GateOracleBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = v3GateOracleBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverRun = v3GateRunRemoteShellLogged(root,
                                               "oracle_bft_stop_server",
                                               cfg.serverSsh,
                                               "set -eu && rm -rf " + os.QuoteShell(serverDir),
                                               "artifacts/v3_gate/oracle_bft_stop_server.log",
                                               30)
    if v3GateRunFailed(serverRun):
        return serverRun.exitCode
    let relayRun = v3GateRunRemoteShellLogged(root,
                                              "oracle_bft_stop_relay",
                                              cfg.relaySsh,
                                              "set -eu && rm -rf " + os.QuoteShell(relayDir),
                                              "artifacts/v3_gate/oracle_bft_stop_relay.log",
                                              30)
    if v3GateRunFailed(relayRun):
        return relayRun.exitCode
    let localRun = v3GateRunShellLogged(root,
                                        "oracle_bft_stop_local",
                                        "set -eu && rm -rf " + os.QuoteShell(localDir),
                                        "artifacts/v3_gate/oracle_bft_stop_local.log",
                                        30)
    if v3GateRunFailed(localRun):
        return localRun.exitCode
    v3GatePrintLine("v3 oracle bft deploy: stopped")
    return 0

fn v3GateDeployOracleBftThreeNode(root: str): int32 =
    let cfg = v3GateOracleBftThreeNodeConfig(root)
    if v3GateStopOracleBftThreeNode(root) != 0:
        return 1
    if !v3path.V3MkdirP(root, cfg.localDeployDir):
        v3GatePrintErr("v3 oracle bft deploy: failed to create local deploy dir")
        return 1
    if !v3path.V3WriteTextFile(root, v3GateOracleBftManifestPath(cfg), v3GateOracleBftManifestText(cfg)):
        v3GatePrintErr("v3 oracle bft deploy: failed to write manifest")
        return 1
    if v3GateBftSyncRemoteRepo(root,
                               cfg.serverSsh,
                               cfg.serverRepoRoot,
                               "artifacts/v3_gate/oracle_bft_sync_server.log") != 0:
        return 1
    if v3GateBftSyncRemoteRepo(root,
                               cfg.relaySsh,
                               cfg.relayRepoRoot,
                               "artifacts/v3_gate/oracle_bft_sync_relay.log") != 0:
        return 1
    if v3GateBuildOracleBftStateMachine(root) != 0:
        return 1
    if v3GateOracleBftBuildRemote(root,
                                  cfg.serverSsh,
                                  cfg.serverRepoRoot,
                                  "artifacts/v3_gate/oracle_bft_build_server.log") != 0:
        return 1
    if v3GateOracleBftBuildRemote(root,
                                  cfg.relaySsh,
                                  cfg.relayRepoRoot,
                                  "artifacts/v3_gate/oracle_bft_build_relay.log") != 0:
        return 1
    let serverDir = v3GateOracleBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = v3GateOracleBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverBin = v3GateOracleBftRemoteBin(cfg.serverRepoRoot)
    let relayBin = v3GateOracleBftRemoteBin(cfg.relayRepoRoot)
    let localBin = v3GateOracleBftLocalBin(root)
    let serverRun = v3GateRunRemoteShellLogged(root,
                                               "oracle_bft_deploy_server",
                                               cfg.serverSsh,
                                               v3GateOracleBftDeployShell(serverBin, serverDir, cfg.appId),
                                               "artifacts/v3_gate/oracle_bft_deploy_server.log",
                                               30)
    if v3GateRunFailed(serverRun):
        return serverRun.exitCode
    let relayRun = v3GateRunRemoteShellLogged(root,
                                              "oracle_bft_deploy_relay",
                                              cfg.relaySsh,
                                              v3GateOracleBftDeployShell(relayBin, relayDir, cfg.appId),
                                              "artifacts/v3_gate/oracle_bft_deploy_relay.log",
                                              30)
    if v3GateRunFailed(relayRun):
        return relayRun.exitCode
    let localRun = v3GateRunShellLogged(root,
                                        "oracle_bft_deploy_local",
                                        v3GateOracleBftDeployShell(localBin, localDir, cfg.appId),
                                        "artifacts/v3_gate/oracle_bft_deploy_local.log",
                                        30)
    if v3GateRunFailed(localRun):
        return localRun.exitCode
    var serverStatus = v3GateOracleBftNodeStatusZero("server")
    var relayStatus = v3GateOracleBftNodeStatusZero("relay")
    var localStatus = v3GateOracleBftNodeStatusZero("local")
    let serverRes = v3GateOracleBftCollectRemoteNodeStatus(root,
                                                           "server",
                                                           cfg.serverSsh,
                                                           cfg.serverRepoRoot,
                                                           v3GateOracleBftStatePath(serverDir),
                                                           "artifacts/v3_gate/oracle_bft_server_status")
    if IsErr(serverRes):
        v3GatePrintErr("v3 oracle bft deploy: server status failed")
        v3GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    serverStatus = Value(serverRes)
    let relayRes = v3GateOracleBftCollectRemoteNodeStatus(root,
                                                          "relay",
                                                          cfg.relaySsh,
                                                          cfg.relayRepoRoot,
                                                          v3GateOracleBftStatePath(relayDir),
                                                          "artifacts/v3_gate/oracle_bft_relay_status")
    if IsErr(relayRes):
        v3GatePrintErr("v3 oracle bft deploy: relay status failed")
        v3GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    relayStatus = Value(relayRes)
    let localRes = v3GateOracleBftCollectLocalNodeStatus(root,
                                                         "local",
                                                         v3GateOracleBftStatePath(localDir),
                                                         "artifacts/v3_gate/oracle_bft_local_status")
    if IsErr(localRes):
        v3GatePrintErr("v3 oracle bft deploy: local status failed")
        v3GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    localStatus = Value(localRes)
    if !v3GateOracleBftClusterMatches(serverStatus, relayStatus, localStatus):
        v3GatePrintErr("v3 oracle bft deploy: three-node cluster drifted")
        v3GateOracleBftPrintNodeStatus(serverStatus)
        v3GatePrintLine("---")
        v3GateOracleBftPrintNodeStatus(relayStatus)
        v3GatePrintLine("---")
        v3GateOracleBftPrintNodeStatus(localStatus)
        return 1
    v3GateOracleBftPrintNodeStatus(serverStatus)
    v3GatePrintLine("---")
    v3GateOracleBftPrintNodeStatus(relayStatus)
    v3GatePrintLine("---")
    v3GateOracleBftPrintNodeStatus(localStatus)
    return 0

fn v3GateStatusOracleBftThreeNode(root: str): int32 =
    let cfg = v3GateOracleBftConfigLoad(root)
    let serverDir = v3GateOracleBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = v3GateOracleBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    let serverRes = v3GateOracleBftCollectRemoteNodeStatus(root,
                                                           "server",
                                                           cfg.serverSsh,
                                                           cfg.serverRepoRoot,
                                                           v3GateOracleBftStatePath(serverDir),
                                                           "artifacts/v3_gate/oracle_bft_server_live")
    if IsErr(serverRes):
        v3GatePrintErr("v3 oracle bft status: server failed")
        v3GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    let relayRes = v3GateOracleBftCollectRemoteNodeStatus(root,
                                                          "relay",
                                                          cfg.relaySsh,
                                                          cfg.relayRepoRoot,
                                                          v3GateOracleBftStatePath(relayDir),
                                                          "artifacts/v3_gate/oracle_bft_relay_live")
    if IsErr(relayRes):
        v3GatePrintErr("v3 oracle bft status: relay failed")
        v3GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    let localRes = v3GateOracleBftCollectLocalNodeStatus(root,
                                                         "local",
                                                         v3GateOracleBftStatePath(localDir),
                                                         "artifacts/v3_gate/oracle_bft_local_live")
    if IsErr(localRes):
        v3GatePrintErr("v3 oracle bft status: local failed")
        v3GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    v3GateOracleBftPrintNodeStatus(Value(serverRes))
    v3GatePrintLine("---")
    v3GateOracleBftPrintNodeStatus(Value(relayRes))
    v3GatePrintLine("---")
    v3GateOracleBftPrintNodeStatus(Value(localRes))
    return 0

fn v3GateVerifyOracleBftThreeNode(root: str): int32 =
    if v3GateDeployOracleBftThreeNode(root) != 0:
        return 1
    let cfg = v3GateOracleBftConfigLoad(root)
    let serverDir = v3GateOracleBftRemoteDeployDir(cfg.serverRepoRoot, cfg)
    let relayDir = v3GateOracleBftRemoteDeployDir(cfg.relayRepoRoot, cfg)
    let localDir = cfg.localDeployDir
    var serverStatus = v3GateOracleBftNodeStatusZero("server")
    var relayStatus = v3GateOracleBftNodeStatusZero("relay")
    var localStatus = v3GateOracleBftNodeStatusZero("local")
    let serverRes = v3GateOracleBftCollectRemoteNodeStatus(root,
                                                           "server",
                                                           cfg.serverSsh,
                                                           cfg.serverRepoRoot,
                                                           v3GateOracleBftStatePath(serverDir),
                                                           "artifacts/v3_gate/oracle_bft_verify_server")
    let relayRes = v3GateOracleBftCollectRemoteNodeStatus(root,
                                                          "relay",
                                                          cfg.relaySsh,
                                                          cfg.relayRepoRoot,
                                                          v3GateOracleBftStatePath(relayDir),
                                                          "artifacts/v3_gate/oracle_bft_verify_relay")
    let localRes = v3GateOracleBftCollectLocalNodeStatus(root,
                                                         "local",
                                                         v3GateOracleBftStatePath(localDir),
                                                         "artifacts/v3_gate/oracle_bft_verify_local")
    if !IsErr(serverRes):
        serverStatus = Value(serverRes)
    if !IsErr(relayRes):
        relayStatus = Value(relayRes)
    if !IsErr(localRes):
        localStatus = Value(localRes)
    var verified = false
    if !IsErr(serverRes) && !IsErr(relayRes) && !IsErr(localRes):
        verified = v3GateOracleBftClusterMatches(serverStatus, relayStatus, localStatus)
    let reportPath = v3GateOracleBftVerifyReportPath(root)
    let reportText = v3GateOracleBftVerifyReportText(cfg, verified, serverStatus, relayStatus, localStatus)
    if !v3path.V3WriteTextFile(root, reportPath, reportText):
        v3GatePrintErr("v3 oracle bft verify: failed to write report")
        let _ = v3GateStopOracleBftThreeNode(root)
        return 1
    let stopCode = v3GateStopOracleBftThreeNode(root)
    if IsErr(serverRes):
        v3GatePrintErr("v3 oracle bft verify: server status failed")
        v3GatePrintErr(strutil.Strip(Error(serverRes)))
        return 1
    if IsErr(relayRes):
        v3GatePrintErr("v3 oracle bft verify: relay status failed")
        v3GatePrintErr(strutil.Strip(Error(relayRes)))
        return 1
    if IsErr(localRes):
        v3GatePrintErr("v3 oracle bft verify: local status failed")
        v3GatePrintErr(strutil.Strip(Error(localRes)))
        return 1
    if !verified:
        v3GatePrintErr("v3 oracle bft verify: three-node cluster drifted")
        v3GateOracleBftPrintNodeStatus(serverStatus)
        v3GatePrintLine("---")
        v3GateOracleBftPrintNodeStatus(relayStatus)
        v3GatePrintLine("---")
        v3GateOracleBftPrintNodeStatus(localStatus)
        return 1
    if stopCode != 0:
        v3GatePrintErr("v3 oracle bft verify: stop failed after verification")
        return stopCode
    v3GatePrintLine("v3 oracle bft verify ok")
    v3GatePrintLine("report=" + reportPath)
    return 0

fn v3GateBuildBrowserHostWasm(root: str, args: str[]): int32 =
    let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_WASM_COMPILER", "", compiler) != 0:
        return 1
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_browser_host_wasm")
    let src: str = v3path.V3PathAbsolute(root, "v3/src/libp2p/browser/browser_host_wasm_probe.cheng")
    let positionals: str[] = v3GateCollectPositionals(args)
    var outWasm: str = os.GetEnvDefault("CHENG_V3_BROWSER_HOST_WASM_OUT", "")
    if len(outWasm) <= 0 && positionals.len > 0:
        outWasm = positionals[0]
    if len(outWasm) <= 0:
        outWasm = os.JoinPath(outDir, "cheng_browser_host_abi.wasm")
    else:
        outWasm = v3path.V3PathAbsolute(root, outWasm)
    let compileRun = v3GateCompileEmitEnv(root,
                                          "build_browser_host_wasm",
                                          compiler,
                                          src,
                                          "shared",
                                          outWasm,
                                          "wasm32-unknown-unknown",
                                          os.JoinPath(outDir, "cheng_browser_host_abi.compile.log"),
                                          [])
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outWasm):
        v3GatePrintErr("v3 browser host wasm: missing wasm output: " + outWasm)
        return 1
    v3GatePrintLine("v3 browser host wasm: build ok out=" + outWasm)
    return 0

fn v3GateBuildRwadBftStateMachine(root: str): int32 =
    var compiler = ""
    if v3GateResolveSmokeCompiler(root, "", "CHENG_V3_RWAD_COMPILER", "", compiler) != 0:
        return 1
    let target: str = os.GetEnvDefault("RWAD_BFT_TARGET", "arm64-apple-darwin")
    var defaultOutDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_rwad_bft_state_machine")
    if target != "arm64-apple-darwin":
        defaultOutDir = os.JoinPath(defaultOutDir, target)
    let outDir: str = os.GetEnvDefault("RWAD_BFT_OUT_DIR", defaultOutDir)
    let outBin: str = os.GetEnvDefault("RWAD_BFT_OUT_BIN", os.JoinPath(outDir, "rwad_bft_state_machine"))
    let src: str = v3path.V3PathAbsolute(root, "v3/src/project/rwad_bft_state_machine_main.cheng")
    let compileRun = v3GateCompileExe(root,
                                      "build_rwad_bft_state_machine",
                                      compiler,
                                      src,
                                      outBin,
                                      target,
                                      os.JoinPath(outDir, "rwad_bft_state_machine.compile.log"))
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    var runSelfTestDefault = "0"
    if target == v3GateHostTarget(root):
        runSelfTestDefault = "1"
    let runSelfTest: str = os.GetEnvDefault("RWAD_BFT_RUN_SELF_TEST", runSelfTestDefault)
    if runSelfTest != "0":
        let run = v3GateRunBinary(root,
                                  "build_rwad_bft_state_machine_run",
                                  outBin,
                                  ["self-test"],
                                  20,
                                  os.JoinPath(outDir, "rwad_bft_state_machine.self-test.log"))
        v3GateMaybePrintRunOutput(run)
        if v3GateRunFailed(run):
            return run.exitCode
    else:
        v3GatePrintLine("v3 rwad_bft_state_machine: build ok target=" + target + " out=" + outBin)
    return 0

fn v3GateBuildPanicTrace(root: str): int32 =
    var compiler = ""
    if v3GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_panic_trace")
    let src: str = v3path.V3PathAbsolute(root, "v3/src/tests/ordinary_panic_fixture.cheng")
    let outBin: str = os.JoinPath(outDir, "ordinary_panic_fixture")
    let reportPath: str = os.JoinPath(outDir, "ordinary_panic_fixture.report.txt")
    let compileLog = "artifacts/v3_panic_trace/ordinary_panic_fixture.compile.log"
    let compileRun = v3GateCompileExe(root,
                                      "build_panic_trace",
                                      compiler,
                                      src,
                                      outBin,
                                      "arm64-apple-darwin",
                                      compileLog)
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    let lineMap: str = outBin + ".v3.map"
    if !os.FileExists(lineMap):
        v3GatePrintErr("v3 panic-trace: missing line-map sidecar")
        return 1
    let lineMapText: str = v3path.V3ReadTextFile("", lineMap)
    if !v3GateOutputContains(lineMapText, "v3_line_map_v1") ||
       !v3GateOutputContains(lineMapText, "ordinary_panic_fixture.cheng"):
        v3GatePrintErr("v3 panic-trace: invalid line-map")
        return 1
    let run = v3GateRunBinary(root,
                              "build_panic_trace_run",
                              outBin,
                              [],
                              20,
                              "artifacts/v3_panic_trace/ordinary_panic_fixture.run.log")
    v3GateMaybePrintRunOutput(run)
    if run.exitCode == 0:
        v3GatePrintErr("v3 panic-trace: expected non-zero exit")
        return 1
    let transformRun = hostops.v3RunFileLogged(root,
                                               "build_panic_trace_report",
                                               compiler,
                                               [
                                                   "crash-report",
                                                   "--in:" + run.logPath,
                                                   "--out:" + reportPath
                                               ],
                                               [],
                                               root,
                                               20,
                                               "artifacts/v3_panic_trace/ordinary_panic_fixture.crash-report.log")
    if v3GateRunFailed(transformRun):
        return transformRun.exitCode
    if !os.FileExists(reportPath):
        v3GatePrintErr("v3 panic-trace: missing report")
        return 1
    let reportText: str = v3path.V3ReadTextFile("", reportPath)
    if !v3GateRequireOutput(run, "v3 panic fixture", "v3 panic-trace") ||
       !v3GateRequireOutput(run, "v3_crash_raw_v1", "v3 panic-trace") ||
       !v3GateRequireOutput(run, "reason=panic mode=backtrace", "v3 panic-trace") ||
       !v3GateRequireOutput(run, "ordinary_panic_fixture.cheng:", "v3 panic-trace") ||
       !v3GateOutputContains(reportText, "[cheng-v3] v3_crash_report_v1") ||
       !v3GateOutputContains(reportText, "[cheng-v3] reason=panic mode=backtrace") ||
       !v3GateOutputContains(reportText, "ordinary_panic_fixture.cheng:"):
        return 1
    v3GatePrintLine(strutil.Strip(reportText))
    return 0

fn v3GateBuildBoundsTrace(root: str): int32 =
    var compiler = ""
    if v3GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_bounds_trace")
    let src: str = v3path.V3PathAbsolute(root, "v3/src/tests/ordinary_bounds_trace_fixture.cheng")
    let outBin: str = os.JoinPath(outDir, "ordinary_bounds_trace_fixture")
    let reportPath: str = os.JoinPath(outDir, "ordinary_bounds_trace_fixture.report.txt")
    let compileLog = "artifacts/v3_bounds_trace/ordinary_bounds_trace_fixture.compile.log"
    let compileRun = v3GateCompileExe(root,
                                      "build_bounds_trace",
                                      compiler,
                                      src,
                                      outBin,
                                      "arm64-apple-darwin",
                                      compileLog)
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    if !os.FileExists(outBin + ".v3.map"):
        v3GatePrintErr("v3 bounds-trace: missing line-map sidecar")
        return 1
    let run = v3GateRunBinary(root,
                              "build_bounds_trace_run",
                              outBin,
                              [],
                              20,
                              "artifacts/v3_bounds_trace/ordinary_bounds_trace_fixture.run.log")
    v3GateMaybePrintRunOutput(run)
    if run.exitCode == 0:
        v3GatePrintErr("v3 bounds-trace: expected non-zero exit")
        return 1
    let transformRun = hostops.v3RunFileLogged(root,
                                               "build_bounds_trace_report",
                                               compiler,
                                               [
                                                   "crash-report",
                                                   "--in:" + run.logPath,
                                                   "--out:" + reportPath
                                               ],
                                               [],
                                               root,
                                               20,
                                               "artifacts/v3_bounds_trace/" +
                                                   "ordinary_bounds_trace_fixture.crash-report.log")
    if v3GateRunFailed(transformRun):
        return transformRun.exitCode
    if !os.FileExists(reportPath):
        v3GatePrintErr("v3 bounds-trace: missing report")
        return 1
    let reportText: str = v3path.V3ReadTextFile("", reportPath)
    if !v3GateRequireOutput(run, "bounds check failed", "v3 bounds-trace") ||
       !v3GateRequireOutput(run, "v3_crash_raw_v1", "v3 bounds-trace") ||
       !v3GateRequireOutput(run, "reason=bounds mode=backtrace", "v3 bounds-trace") ||
       !v3GateRequireOutput(run, "ordinary_bounds_trace_fixture.cheng:", "v3 bounds-trace") ||
       !v3GateOutputContains(reportText, "[cheng-v3] v3_crash_report_v1") ||
       !v3GateOutputContains(reportText, "[cheng-v3] reason=bounds mode=backtrace") ||
       !v3GateOutputContains(reportText, "ordinary_bounds_trace_fixture.cheng:"):
        return 1
    v3GatePrintLine(strutil.Strip(reportText))
    return 0

