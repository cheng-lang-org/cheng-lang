    add(out, "  debug-report [seed-flags...]")
    add(out, "  print-symbols [seed-flags...]")
    add(out, "  print-line-map [seed-flags...]")
    add(out, "  print-object --object:<path> [--report-out:<path>]")
    add(out, "  print-elf --object:<path> [--report-out:<path>]")
    add(out, "  print-asm [seed-flags...]")
    add(out, "  profile-run [seed-flags...]")
    add(out, "  crash-report --in:<raw-log> [--out:<final-report>]")
    add(out, "  verify-orphan-guard")
    add(out, "  verify-backend-driver-command-surface")
    add(out, "  verify-r2c-react-v3-surface")
    add(out, "  verify-debug-tools")
    add(out, "  verify-debug-runtime")
    add(out, "  verify-debug-profile")
    add(out, "  verify-diloco")
    add(out, "  verify-windows-builtin")
    add(out, "  verify-riscv64-builtin")
    add(out, "  run-cross-target-smokes")
    add(out, "  run-host-smokes [smoke_name ...]")
    add(out, "  run-stage23-libp2p-smokes [smoke_name ...]")
    add(out, "  compile-exe")
    add(out, "  build-zero-exit")
    add(out, "  build-panic-trace")
    add(out, "  build-bounds-trace")
    add(out, "  build-signal-trace")
    add(out, "  build-call-chain")
    add(out, "  build-ffi-handle")
    add(out, "  build-bft-state-machine")
    add(out, "  deploy-bft-validator-three-node")
    add(out, "  verify-bft-validator-three-node")
    add(out, "  status-bft-validator-three-node")
    add(out, "  stop-bft-validator-three-node")
    add(out, "  bench-bft-validator-three-node [--tx-count:<n>] [--transfer-amount:<n>] [--max-txs-per-block:<n>]")
    add(out, "  build-rwad-bft-state-machine")
