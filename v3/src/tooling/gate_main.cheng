    let compileRun = v3GateCompileExe(root, "build_signal_trace", compiler, src, outBin, "arm64-apple-darwin", "artifacts/v3_signal_trace/ordinary_signal_trace_fixture.compile.log")
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    if !os.fileExists(outBin + ".v3.map"):
        v3GatePrintErr("v3 signal-trace: missing line-map sidecar")
        return 1
    let run = v3GateRunBinary(root, "build_signal_trace_run", outBin, [], 20, "artifacts/v3_signal_trace/ordinary_signal_trace_fixture.run.log")
    v3GateMaybePrintRunOutput(run)
    if run.exitCode == 0:
        v3GatePrintErr("v3 signal-trace: expected non-zero exit")
        return 1
    if !v3GateRequireOutput(run, "[cheng-v3] v3_crash_report_v1", "v3 signal-trace") ||
       !v3GateRequireOutput(run, "reason=signal mode=signal", "v3 signal-trace") ||
       !v3GateRequireOutput(run, "ordinary_signal_trace_fixture.cheng:", "v3 signal-trace"):
        return 1
    return 0

fn v3GateVerifyDebugRuntime(root: str): int32 =
    if v3GateBuildPanicTrace(root) != 0:
        return 1
    if v3GateBuildBoundsTrace(root) != 0:
        return 1
    if v3GateBuildSignalTrace(root) != 0:
        return 1
    v3GatePrintLine("v3 debug runtime: ok")
    return 0

fn v3GateVerifyDebugProfile(root: str): int32 =
    var compiler = ""
    if v3GateEnsureBackendDriverReady(root, compiler) != 0:
        return 1
    let outDir: str = v3path.v3PathAbsolute(root, "artifacts/v3_debug_profile_verify")
    let src: str = v3path.v3PathAbsolute(root, "v3/src/tests/ordinary_profile_hotspots_fixture.cheng")
    let outBin: str = os.joinPath(outDir, "ordinary_profile_hotspots_fixture")
    let report: str = os.joinPath(outDir, "profile.txt")
    let compileRun = v3GateCompileExe(root, "verify_debug_profile", compiler, src, outBin, "arm64-apple-darwin", "artifacts/v3_debug_profile_verify/ordinary_profile_hotspots_fixture.compile.log")
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    let run = hostops.v3RunFileLogged(root,
                                      "verify_debug_profile_run",
                                      outBin,
                                      [],
                                      [
                                          "CHENG_V3_PROFILE_ENABLE=1",
                                          "CHENG_V3_PROFILE_HZ=200",
                                          "CHENG_V3_PROFILE_OUT=" + report
                                      ],
                                      root,
                                      20,
                                      "artifacts/v3_debug_profile_verify/ordinary_profile_hotspots_fixture.run.log")
    if v3GateRunFailed(run):
        return run.exitCode
    if !os.fileExists(report):
        v3GatePrintErr("v3 debug profile: missing report")
        return 1
    let reportText: str = v3path.v3ReadTextFile("", report)
    if !v3GateOutputContains(reportText, "v3_profile_v1") ||
       !v3GateOutputContains(reportText, "hot_function[0]=") ||
       !v3GateOutputContains(reportText, "hot_pc[0]=") ||
       !v3GateOutputContains(reportText, "ordinary_profile_hotspots_fixture.cheng"):
        v3GatePrintErr("v3 debug profile: invalid report")
        return 1
    v3GatePrintLine(strutil.strip(reportText))
    v3GatePrintLine("v3 debug profile: ok")
    return 0

fn v3GateBuildChainNode(root: str): int32 =
    var compiler = os.getEnvDefault("CHENG_V3_CHAIN_NODE_COMPILER", "")
    if len(compiler) <= 0:
        if v3GateEnsureBackendDriverReady(root, compiler) != 0:
            return 1
    else:
        compiler = v3path.v3PathAbsolute(root, compiler)
    let src: str = v3path.v3PathAbsolute(root, "v3/src/project/chain_node_main.cheng")
    let target: str = os.getEnvDefault("CHAIN_NODE_TARGET", "arm64-apple-darwin")
    var defaultOutDir: str = v3path.v3PathAbsolute(root, "artifacts/v3_chain_node")
    if target != "arm64-apple-darwin":
        defaultOutDir = os.joinPath(defaultOutDir, target)
    let outDir: str = os.getEnvDefault("CHAIN_NODE_OUT_DIR", defaultOutDir)
    let outBin: str = os.getEnvDefault("CHAIN_NODE_OUT_BIN", os.joinPath(outDir, "chain_node"))
    let compileRun = v3GateCompileExe(root, "build_chain_node", compiler, src, outBin, target, os.joinPath(outDir, "chain_node.compile.log"))
    if v3GateRunFailed(compileRun):
        return compileRun.exitCode
    var runSelfTestDefault = "0"
    if target == "arm64-apple-darwin":
        runSelfTestDefault = "1"
    let runSelfTestText: str = os.getEnvDefault("CHAIN_NODE_RUN_SELF_TEST", runSelfTestDefault)
    if runSelfTestText != "0":
        let run = v3GateRunBinary(root, "build_chain_node_self_test", outBin, ["self-test"], 20, os.joinPath(outDir, "chain_node.self-test.log"))
        v3GateMaybePrintRunOutput(run)
        if v3GateRunFailed(run):
            return run.exitCode
    else:
        v3GatePrintLine("v3 chain_node: build ok target=" + target + " out=" + outBin)
    return 0

fn v3GateRunChainNodeProcessSmoke(root: str, args: str[]): int32 =
    let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_CHAIN_NODE_COMPILER", "CHENG_V3_SMOKE_COMPILER", compiler) != 0:
        return 1
    let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_CHAIN_NODE_LABEL", "host")
    return v3GateRunChainNodeProcessSmokeWithCompiler(root, compiler, label, [])

fn v3GateRunChainNodeThreeNodeSmoke(root: str, args: str[]): int32 =
    let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
    var compiler = ""
    if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_CHAIN_NODE_COMPILER", "CHENG_V3_SMOKE_COMPILER", compiler) != 0:
        return 1
    let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_CHAIN_NODE_LABEL", "host")
    return v3GateRunChainNodeThreeNodeSmokeWithCompiler(root, compiler, label, [])

fn v3GateSlice(root: str): int32 =
    v3GatePrintLine("[v3 gate] hot-path forbidden scan")
    if v3GateScanHotpath(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] same-machine C baseline")
    if v3GateRunCRef(root) != 0:
        return 1
    let baselinePath: str = v3path.v3PathAbsolute(root, "v3/bench/c_ref/baseline_arm64_apple_darwin.txt")
    let candidatePath: str = v3path.v3PathAbsolute(root, "artifacts/v3_gate/c_ref_latest.txt")
    if os.fileExists(baselinePath):
        v3GatePrintLine("[v3 gate] frozen-vs-latest C baseline")
        if v3GateCompareBench(root, baselinePath, candidatePath, int64(0)) != 0:
            return 1
    v3GatePrintLine("[v3 gate] bootstrap bridge")
    if v3GateBootstrapBridge(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] canonical backend driver")
    if v3GateBuildBackendDriver(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] zero-exit ordinary compile")
    if v3GateBuildZeroExit(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] panic-trace ordinary compile")
    if v3GateBuildPanicTrace(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] bounds-trace ordinary compile")
    if v3GateBuildBoundsTrace(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] signal-trace ordinary compile")
    if v3GateBuildSignalTrace(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] orphan guard")
    if v3GateVerifyOrphanGuard(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] debug tools")
    if v3GateRunStage3Command(root, "verify_debug_tools", "verify-debug-tools", [], "verify-debug-tools.log", false) != 0:
        return 1
    v3GatePrintLine("[v3 gate] debug runtime")
    if v3GateVerifyDebugRuntime(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] debug profile")
    if v3GateVerifyDebugProfile(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] call-chain ordinary compile")
    if v3GateBuildCallChain(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] ffi-handle ordinary compile")
    if v3GateBuildFfiHandle(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] program-selfhost")
    if v3GateBuildProgramSelfhost(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] chain_node")
    if v3GateBuildChainNode(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] bootstrap subset self-checks")
    if v3GateRunSmokes(root) != 0:
        return 1
    v3GatePrintLine("[v3 gate] host fixed256 sha256 smoke")
    if v3GateRunHostSmokes(root, ["fixed256_sha256_smoke"]) != 0:
        return 1
    v3GatePrintLine("[v3 gate] host default-init literals smoke")
    if v3GateRunHostSmokes(root, ["default_init_literals_smoke"]) != 0:
        return 1
    v3GatePrintLine("[v3 gate] cross-target builtin smokes")
    if v3GateRunStage3Command(root, "run_cross_target_smokes", "run-cross-target-smokes", [], "run-cross-target-smokes.log", false) != 0:
        return 1
    v3GatePrintLine("[v3 gate] v3 host smokes")
    if v3GateRunHostSmokes(root, []) != 0:
        return 1
    v3GatePrintLine("[v3 gate] stage2/stage3 libp2p smokes")
    if v3GateRunStage23Libp2pSmokes(root, []) != 0:
        return 1
    v3GatePrintLine("[v3 gate] ok")
    return 0

fn v3GateHandlesCommand(cmd: str): bool =
    return cmd == "scan-hotpath" ||
           cmd == "c-ref" ||
           cmd == "compare-bench" ||
           cmd == "bootstrap-bridge" ||
           cmd == "build-backend-driver" ||
           cmd == "run-smokes" ||
           cmd == "print-bootstrap" ||
           cmd == "print-build-plan" ||
           cmd == "slice-gate" ||
           cmd == "debug-report" ||
           cmd == "print-symbols" ||
           cmd == "print-line-map" ||
           cmd == "print-object" ||
           cmd == "print-elf" ||
           cmd == "print-asm" ||
           cmd == "profile-run" ||
           cmd == "verify-orphan-guard" ||
           cmd == "verify-debug-tools" ||
           cmd == "verify-debug-runtime" ||
           cmd == "verify-debug-profile" ||
           cmd == "verify-windows-builtin" ||
           cmd == "verify-riscv64-builtin" ||
           cmd == "run-cross-target-smokes" ||
           cmd == "run-host-smokes" ||
           cmd == "run-stage23-libp2p-smokes" ||
           cmd == "compile-exe" ||
           cmd == "build-zero-exit" ||
           cmd == "build-panic-trace" ||
           cmd == "build-bounds-trace" ||
           cmd == "build-signal-trace" ||
           cmd == "build-call-chain" ||
           cmd == "build-ffi-handle" ||
           cmd == "build-bft-state-machine" ||
           cmd == "build-rwad-bft-state-machine" ||
           cmd == "build-program-selfhost" ||
           cmd == "build-chain-node" ||
           cmd == "build-linux-nolibc-exe" ||
           cmd == "build-chain-node-linux" ||
           cmd == "build-rwad-bft-linux" ||
           cmd == "run-linux-object-smokes" ||
           cmd == "run-tcp-twoproc-smoke" ||
           cmd == "run-udp-importc-smoke" ||
           cmd == "run-wasm-smokes" ||
           cmd == "run-browser-host-wasm-smoke" ||
           cmd == "run-chain-node-cli-smoke" ||
           cmd == "run-chain-node-process-smoke" ||
           cmd == "run-chain-node-three-node-smoke" ||
           cmd == "run-tailnet-control-smoke" ||
           cmd == "run-fresh-node-selfhost-gate" ||
           cmd == "run-migration-gate" ||
           cmd == "run-browser-webrtc-smokes" ||
           cmd == "r2c-react-v3"

fn v3GateMain(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let count: int32 = cmdline.paramCount()
    if count <= 0:
        v3GateUsage()
        return 1
    let root: str = v3GateRoot()
    let cmd: str = cmdline.paramStr(1)
    let args: str[] = v3GateCollectArgsFrom(2, count)
    if cmd == "--help" || cmd == "-h" || cmd == "help":
        v3GateUsage()
        return 0
    if cmd == "scan-hotpath":
        return v3GateScanHotpath(root)
    if cmd == "c-ref":
        return v3GateRunCRef(root)
    if cmd == "compare-bench":
        let baselinePath: str = v3GateReadFlag(args, "--baseline", "")
        let candidatePath: str = v3GateReadFlag(args, "--candidate", "")
        let maxRatioText: str = v3GateReadFlag(args, "--max-ratio-milli", "0")
        return v3GateCompareBench(root, baselinePath, candidatePath, int64(strutil.parseInt(maxRatioText)))
    if cmd == "bootstrap-bridge":
        return v3GateBootstrapBridge(root)
    if cmd == "build-backend-driver":
        return v3GateBuildBackendDriver(root)
    if cmd == "run-smokes":
        return v3GateRunSmokes(root)
    if cmd == "print-bootstrap":
        let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault(root)
        v3GatePrintLine(strutil.strip(contracts.v3BootstrapSnapshotReport(snapshot)))
        return 0
    if cmd == "print-build-plan":
        let plan: buildplan.V3BackendBuildPlan = buildplan.v3BackendBuildPlanDefault(root)
        v3GatePrintLine(strutil.strip(buildplan.v3BackendBuildPlanReport(plan)))
        return 0
    if cmd == "slice-gate":
        return v3GateSlice(root)
    if cmd == "debug-report":
        return v3GateRunStage3Command(root, "debug_report", cmd, args, "debug-report.log", true)
    if cmd == "print-symbols":
        return v3GateRunStage3Command(root, "print_symbols", cmd, args, "print-symbols.log", true)
    if cmd == "print-line-map":
        return v3GateRunStage3Command(root, "print_line_map", cmd, args, "print-line-map.log", true)
    if cmd == "print-object":
        return v3GateRunStage3Command(root, "print_object", cmd, args, "print-object.log", false)
    if cmd == "print-elf":
        return v3GateRunStage3Command(root, "print_elf", cmd, args, "print-elf.log", false)
    if cmd == "print-asm":
        return v3GateRunStage3Command(root, "print_asm", cmd, args, "print-asm.log", true)
    if cmd == "profile-run":
        return v3GateRunStage3Command(root, "profile_run", cmd, args, "profile-run.log", true)
    if cmd == "verify-orphan-guard":
        return v3GateVerifyOrphanGuard(root)
    if cmd == "verify-debug-tools":
        return v3GateRunStage3Command(root, "verify_debug_tools", cmd, args, "verify-debug-tools.log", false)
    if cmd == "verify-debug-runtime":
        return v3GateVerifyDebugRuntime(root)
    if cmd == "verify-debug-profile":
        return v3GateVerifyDebugProfile(root)
    if cmd == "verify-windows-builtin":
        return v3GateRunStage3Command(root, "verify_windows_builtin", cmd, args, "verify-windows-builtin.log", false)
    if cmd == "verify-riscv64-builtin":
        return v3GateRunStage3Command(root, "verify_riscv64_builtin", cmd, args, "verify-riscv64-builtin.log", false)
    if cmd == "run-cross-target-smokes":
        return v3GateRunStage3Command(root, "run_cross_target_smokes", cmd, args, "run-cross-target-smokes.log", false)
    if cmd == "run-host-smokes":
        return v3GateRunHostSmokes(root, args)
    if cmd == "run-stage23-libp2p-smokes":
        return v3GateRunStage23Libp2pSmokes(root, args)
    if cmd == "compile-exe":
        return v3GateCompileExeFromEnv(root)
    if cmd == "build-zero-exit":
        return v3GateBuildZeroExit(root)
    if cmd == "build-panic-trace":
        return v3GateBuildPanicTrace(root)
    if cmd == "build-bounds-trace":
        return v3GateBuildBoundsTrace(root)
    if cmd == "build-signal-trace":
        return v3GateBuildSignalTrace(root)
    if cmd == "build-call-chain":
        return v3GateBuildCallChain(root)
    if cmd == "build-ffi-handle":
        return v3GateBuildFfiHandle(root)
    if cmd == "build-bft-state-machine":
        return v3GateBuildBftStateMachine(root)
    if cmd == "build-rwad-bft-state-machine":
        return v3GateBuildRwadBftStateMachine(root)
    if cmd == "build-program-selfhost":
        return v3GateBuildProgramSelfhost(root)
    if cmd == "build-chain-node":
        return v3GateBuildChainNode(root)
    if cmd == "build-linux-nolibc-exe":
        return v3GateBuildLinuxNolibcExe(root)
    if cmd == "build-chain-node-linux":
        return v3GateRunStage3Command(root, "build_chain_node_linux", cmd, args, "build_chain_node_linux_v3.log", false)
    if cmd == "build-rwad-bft-linux":
        return v3GateRunStage3Command(root, "build_rwad_bft_linux", cmd, args, "build_rwad_bft_linux_v3.log", false)
    if cmd == "run-linux-object-smokes":
        return v3GateRunStage3Command(root, "run_linux_object_smokes", cmd, args, "run_linux_object_smokes_v3.log", false)
    if cmd == "run-tcp-twoproc-smoke":
        let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_SMOKE_COMPILER", "", compiler) != 0:
            return 1
        let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_SMOKE_LABEL", "host")
        return v3GateRunTcpTwoprocSmoke(root, compiler, label, [])
    if cmd == "run-udp-importc-smoke":
        return v3GateRunUdpImportcSmoke(root, args)
    if cmd == "run-wasm-smokes":
        let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_WASM_COMPILER", "CHENG_V3_SMOKE_COMPILER", compiler) != 0:
            return 1
        let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_WASM_LABEL", "host")
        return v3GateRunWasmSmokes(root, compiler, label, [])
    if cmd == "run-browser-host-wasm-smoke":
        let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_WASM_COMPILER", "CHENG_V3_SMOKE_COMPILER", compiler) != 0:
            return 1
        let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_WASM_LABEL", "host")
        return v3GateRunBrowserHostWasmSmoke(root, compiler, label, [])
    if cmd == "run-chain-node-cli-smoke":
        let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_CHAIN_NODE_COMPILER", "CHENG_V3_SMOKE_COMPILER", compiler) != 0:
            return 1
        let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_CHAIN_NODE_LABEL", "host")
        return v3GateRunChainNodeCliSmoke(root, compiler, label, [])
    if cmd == "run-chain-node-process-smoke":
        return v3GateRunChainNodeProcessSmoke(root, args)
    if cmd == "run-chain-node-three-node-smoke":
        return v3GateRunChainNodeThreeNodeSmoke(root, args)
    if cmd == "run-tailnet-control-smoke":
        let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_TAILNET_COMPILER", "CHENG_V3_SMOKE_COMPILER", compiler) != 0:
            return 1
        let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_TAILNET_LABEL", "host")
        return v3GateRunTailnetControlSmoke(root, compiler, label, [])
    if cmd == "run-fresh-node-selfhost-gate":
        let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_FRESH_NODE_COMPILER", "CHENG_V3_SMOKE_COMPILER", compiler) != 0:
            return 1
        let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_FRESH_NODE_LABEL", "host")
        return v3GateRunFreshNodeSelfhostGate(root, compiler, label, [])
    if cmd == "run-migration-gate":
        let explicitCompiler: str = v3GateReadFlag(args, "--compiler", "")
        var compiler = ""
        if v3GateResolveSmokeCompiler(root, explicitCompiler, "CHENG_V3_MIGRATION_COMPILER", "CHENG_V3_SMOKE_COMPILER", compiler) != 0:
            return 1
        let label: str = v3GateResolveSmokeLabel(args, "CHENG_V3_MIGRATION_LABEL", "host")
        return v3GateRunMigrationGate(root, compiler, label, [])
    if cmd == "run-browser-webrtc-smokes":
        return v3GateRunBrowserWebrtcSmokes(root, v3GateCollectPositionals(args), v3GateStage23EnvOverrides())
    if cmd == "r2c-react-v3":
        return r2c.v3R2cReactV3Main(root, args)
    v3GateUsage()
    return 1

fn main(argc: int32, argv: str*): int32 =
    return v3GateMain(argc, argv)
