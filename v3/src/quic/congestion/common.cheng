# MsQuic congestion common definitions.

const
    bwUnit = 8
    gainUnit = 256
    gainCycleLength = 8
    quantaFactor = 3
    minCwndInMss = 4
    defaultRecoveryCwndInMss = 2000
    microSecsInSec = 1000000
    milliSecsInSec = 1000
    lowPacingRateThresholdBps = 1200000
    highPacingRateThresholdBps = 24000000
    bbrHighGain = 739
    bbrDrainGain = 88
    bbrCwndGain = 512
    bbrStartupGrowthTarget = 320
    bbrStartupSlowGrowRoundLimit = 3
    probeRttTimeUs = 200000
    bbrMinRttExpirationUs = 10000000
    bbrMaxBandwidthFilterLen = 10
    bbrMaxAckHeightFilterLen = 10
    bbrDefaultFilterCapacity = 3
    quicInitialWindowPackets = 10
    minAckSendNumber = 2
    packetReorderThreshold = 3
    minReorderingThreshold = 1
    maxRangeDuplicatePackets = 4096
    maxRangeAckPackets = 2048
    maxRangeDecodeAcks = 4096
    maxAckDelayDefaultMs = 25
    persistentCongestionThreshold = 2
    closePtoCount = 3
    persistentCongestionWindowPackets = 2
    maxSlidingWindowEntries = 32
    maxInt64Value = 9223372036854775807

fn bbrPacingGainAt(index: int32): int64 =
    let idx: int32 = index % gainCycleLength
    if idx == 0:
        return 320
    if idx == 1:
        return 192
    return gainUnit

type
    SlidingWindowMode = enum
        swMax
        swMin

    BbrState = enum
        bbrStartup
        bbrDrain
        bbrProbeBandwidth
        bbrProbeRtt

    BbrRecoveryState = enum
        recoveryNone
        recoveryConservative
        recoveryGrowth

    HyStartState = enum
        hyStartNotStarted
        hyStartActive
        hyStartDone

    CongestionAlgorithm = enum
        caCubic
        caBbr

    CryptoEpoch = enum
        ceInitial
        ceZeroRtt
        ceHandshake
        ceOneRtt

    QuicVarInt = int64

    SlidingWindowExtremumEntry =
        value: int64
        time: int64

    SlidingWindowExtremumModel =
        capacity: int32
        lifetime: int64
        mode: SlidingWindowMode
        count: int32
        entries: SlidingWindowExtremumEntry[maxSlidingWindowEntries]

    AckDelayInfo =
        ackDelayUs: int64
        maxAckDelayMs: int32
        ackDelayExponent: int32

    AckEcnSummary =
        ect0Count: QuicVarInt
        ect1Count: QuicVarInt
        ceCount: QuicVarInt

    AckEventSnapshot =
        timeNow: int64
        largestAck: int64
        largestSentPacketNumber: int64
        totalAckedRetransmittableBytes: int64
        ackedRetransmittableBytes: int64
        smoothedRtt: int64
        minRtt: int64
        oneWayDelay: int64
        adjustedAckTime: int64
        implicitAck: bool
        hasLoss: bool
        largestAckAppLimited: bool
        minRttValid: bool

    LossEventSnapshot =
        largestPacketNumberLost: int64
        largestSentPacketNumber: int64
        retransmittableBytesLost: int64
        persistentCongestion: bool

    EcnEventSnapshot =
        largestPacketNumberAcked: int64
        largestSentPacketNumber: int64

    AckType = enum
        ackTypeNonAckEliciting
        ackTypeAckEliciting
        ackTypeAckImmediate

    AckTrackerCounters =
        ackElicitingPacketsToAck: int32
        alreadyWrittenAckFrame: bool
        nonZeroRecvEcn: bool

fn timeReorderThreshold(rttUs: int64): int64 =
    return rttUs + (rttUs >> 3)

fn initSlidingWindowExtremum(
    lifetime: int64,
    capacity: int32,
    mode: SlidingWindowMode
): SlidingWindowExtremumModel =
    var cap: int32 = capacity
    if cap < 0:
        cap = 0
    if cap > maxSlidingWindowEntries:
        cap = maxSlidingWindowEntries
    var model: SlidingWindowExtremumModel
    model.capacity = cap
    model.lifetime = lifetime
    model.mode = mode
    model.count = 0
    return model

fn slidingWindowReset(model: var SlidingWindowExtremumModel) =
    model.count = 0

fn slidingWindowIsEmpty(model: SlidingWindowExtremumModel): bool =
    return model.count == 0

fn slidingWindowExpireEntries(model: var SlidingWindowExtremumModel, now: int64) =
    if model.count <= 0:
        return
    var removed: int32
    while removed < model.count:
        let head: SlidingWindowExtremumEntry = model.entries[removed]
        if now >= head.time && now - head.time > model.lifetime:
            removed = removed + 1
        else:
            break
    if removed <= 0:
        return
    var i: int32 = removed
    var j: int32
    while i < model.count:
        model.entries[j] = model.entries[i]
        i = i + 1
        j = j + 1
    model.count = j

fn slidingWindowUpdate(
    model: var SlidingWindowExtremumModel,
    value: int64,
    timestamp: int64
) =
    if model.capacity <= 0:
        return
    if model.count > 0:
        let last: SlidingWindowExtremumEntry = model.entries[model.count - 1]
        if timestamp < last.time:
            return
    slidingWindowExpireEntries(model, timestamp)
    while model.count > 0:
        let tail: SlidingWindowExtremumEntry = model.entries[model.count - 1]
        if timestamp >= tail.time && timestamp - tail.time > model.lifetime:
            model.count = model.count - 1
            continue
        var dominated: bool
        if model.mode == swMax:
            dominated = value >= tail.value
        else:
            dominated = value <= tail.value
        if dominated:
            model.count = model.count - 1
        else:
            break
    if model.count >= model.capacity:
        for i in 1..<model.count:
            model.entries[i - 1] = model.entries[i]
        model.count = model.count - 1
    model.entries[model.count] = SlidingWindowExtremumEntry(value: value, time: timestamp)
    model.count = model.count + 1

fn slidingWindowPeek(
    model: SlidingWindowExtremumModel,
    entry: var SlidingWindowExtremumEntry
): bool =
    if model.count <= 0:
        return false
    entry = model.entries[0]
    return true

fn slidingWindowCurrentValue(
    model: SlidingWindowExtremumModel,
    defaultValue: int64
): int64 =
    if model.count <= 0:
        return defaultValue
    return model.entries[0].value
