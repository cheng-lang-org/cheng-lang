fn msquicNativeEnqueueClientDatagram(data: Bytes): Result[bool] =
    let count: int32 = msquicNativeClientDatagramCount
    if count >= msquicNativeDatagramQueue:
        return Err[bool]("msquic native: datagram queue full")
    msquicNativeClientDatagramSet(count, msquicNativeCopyBytes(data))
    msquicNativeClientDatagramCount = count + 1
    return Ok[bool](true)

fn msquicNativeEnqueueServerDatagram(data: Bytes): Result[bool] =
    let count: int32 = msquicNativeServerDatagramCount
    if count >= msquicNativeDatagramQueue:
        return Err[bool]("msquic native: datagram queue full")
    msquicNativeServerDatagramSet(count, msquicNativeCopyBytes(data))
    msquicNativeServerDatagramCount = count + 1
    return Ok[bool](true)

fn msquicNativeEnqueueDatagram(side: int32, data: Bytes): Result[bool] =
    if side == msquicNativeClientSide:
        return msquicNativeEnqueueClientDatagram(data)
    if side == msquicNativeServerSide:
        return msquicNativeEnqueueServerDatagram(data)
    return Err[bool]("msquic native: invalid side")

fn msquicNativeDequeueDatagram(side: int32): Result[Bytes] =
    if side == msquicNativeClientSide:
        if msquicNativeClientDatagramCount <= 0:
            return Err[Bytes]("msquic udp: queue empty")
        let out: Bytes = msquicNativeClientDatagramGet(0)
        for i in 1..<msquicNativeClientDatagramCount:
            msquicNativeClientDatagramSet(i - 1, msquicNativeClientDatagramGet(i))
        msquicNativeClientDatagramSet(msquicNativeClientDatagramCount - 1, emptyBytes())
        msquicNativeClientDatagramCount = msquicNativeClientDatagramCount - 1
        return Ok[Bytes](out)
    if side == msquicNativeServerSide:
        if msquicNativeServerDatagramCount <= 0:
            return Err[Bytes]("msquic udp: queue empty")
        let out: Bytes = msquicNativeServerDatagramGet(0)
        for i in 1..<msquicNativeServerDatagramCount:
            msquicNativeServerDatagramSet(i - 1, msquicNativeServerDatagramGet(i))
        msquicNativeServerDatagramSet(msquicNativeServerDatagramCount - 1, emptyBytes())
        msquicNativeServerDatagramCount = msquicNativeServerDatagramCount - 1
        return Ok[Bytes](out)
    return Err[Bytes]("msquic native: invalid side")

fn msquicNativeConnWindow(settings: MsQuicSettings): int64 =
    if settings.connFlowControlWindow > 0:
        return int64(settings.connFlowControlWindow)
    return 1048576

fn msquicNativeStreamWindow(settings: MsQuicSettings): int64 =
    if settings.streamRecvWindowDefault > 0:
        return int64(settings.streamRecvWindowDefault)
    if settings.streamRecvBufferDefault > 0:
        return int64(settings.streamRecvBufferDefault)
    return 1048576

fn msquicNativePacketMtu(settings: MsQuicSettings): int32 =
    if settings.minimumMtu >= 1200:
        return settings.minimumMtu
    return 1200

fn msquicNativeInitialWindowPackets(settings: MsQuicSettings): int32 =
    if settings.initialWindowPackets > 0:
        return settings.initialWindowPackets
    return 10

fn msquicNativeResetClientDatagrams() =
    msquicNativeClientDatagramCount = 0
    for i in 0..<msquicNativeDatagramQueue:
        msquicNativeClientDatagramSet(i, emptyBytes())

fn msquicNativeResetServerDatagrams() =
    msquicNativeServerDatagramCount = 0
    for i in 0..<msquicNativeDatagramQueue:
        msquicNativeServerDatagramSet(i, emptyBytes())

fn msquicNativeResetClientEndpointState() =
    msquicNativeClientSendOffset = 0
    msquicNativeClientReady = 0
    msquicNativeClientMaxDataSent = false
    msquicNativeClientMaxStreamDataSent = false

fn msquicNativeResetServerEndpointState() =
    msquicNativeServerSendOffset = 0
    msquicNativeServerReady = 0
    msquicNativeServerMaxDataSent = false
    msquicNativeServerMaxStreamDataSent = false

fn msquicNativeResetClientEndpoint(
    settings: var MsQuicSettings,
    requireCert: bool
) =
    msquicTls13ResetClientDefault(requireCert)
    let clientMaxData: int64 = msquicNativeConnWindow(settings)
    let clientMaxStreamData: int64 = msquicNativeStreamWindow(settings)
    initMsQuicFlowControlInto(msquicNativeClientFlow, clientMaxData, clientMaxStreamData)
    initMsQuicConnImpl(msquicNativeClientImpl,
                       0,
                       msquicNativeClientFlow,
                       msquicNativePacketMtu(settings),
                       msquicNativeInitialWindowPackets(settings))
    initMsQuicCryptoStreamInto(msquicNativeClientInitialCrypto)
    initMsQuicCryptoStreamInto(msquicNativeClientHandshakeCrypto)
    msquicNativeClientAppRecvReady = emptyBytes()
    msquicNativeClientAppRecvNextOffset = 0
    msquicNativeClientAppRecvPendingCount = 0
    for i in 0..<msquicNativeAppRecvMaxChunks:
        msquicNativeClientAppRecvUsed[i] = false
        msquicNativeClientAppRecvOffset[i] = 0
        msquicNativeClientAppRecvData[i] = emptyBytes()
    msquicNativeResetClientDatagrams()
    msquicNativeResetClientEndpointState()

fn msquicNativeResetServerEndpoint(
    settings: var MsQuicSettings,
    requireCert: bool
) =
    msquicTls13ResetServerDefault(requireCert)
    let serverMaxData: int64 = msquicNativeConnWindow(settings)
    let serverMaxStreamData: int64 = msquicNativeStreamWindow(settings)
    initMsQuicFlowControlInto(msquicNativeServerFlow, serverMaxData, serverMaxStreamData)
    initMsQuicConnImpl(msquicNativeServerImpl,
                       1,
                       msquicNativeServerFlow,
                       msquicNativePacketMtu(settings),
                       msquicNativeInitialWindowPackets(settings))
    initMsQuicCryptoStreamInto(msquicNativeServerInitialCrypto)
    initMsQuicCryptoStreamInto(msquicNativeServerHandshakeCrypto)
    msquicNativeServerAppRecvReady = emptyBytes()
    msquicNativeServerAppRecvNextOffset = 0
    msquicNativeServerAppRecvPendingCount = 0
    for i in 0..<msquicNativeAppRecvMaxChunks:
        msquicNativeServerAppRecvUsed[i] = false
        msquicNativeServerAppRecvOffset[i] = 0
        msquicNativeServerAppRecvData[i] = emptyBytes()
    msquicNativeResetServerDatagrams()
    msquicNativeResetServerEndpointState()

fn msquicNativeCryptoStreamAvailableByCode(side: int32, packetTypeCode: int32): int32 =
    if side == msquicNativeClientSide:
        if packetTypeCode == msquicNativePacketInitialCode:
            return msquicCryptoStreamAvailable(msquicNativeClientInitialCrypto)
        if packetTypeCode == msquicNativePacketHandshakeCode:
            return msquicCryptoStreamAvailable(msquicNativeClientHandshakeCrypto)
        return 0
    if side == msquicNativeServerSide:
        if packetTypeCode == msquicNativePacketInitialCode:
            return msquicCryptoStreamAvailable(msquicNativeServerInitialCrypto)
        if packetTypeCode == msquicNativePacketHandshakeCode:
            return msquicCryptoStreamAvailable(msquicNativeServerHandshakeCrypto)
        return 0
    return 0

fn msquicNativeCryptoStreamConsumeByCode(side: int32, packetTypeCode: int32, length: int32): Bytes =
    if side == msquicNativeClientSide:
        if packetTypeCode == msquicNativePacketInitialCode:
            var stream = msquicNativeClientInitialCrypto
            let out: Bytes = msquicCryptoStreamConsume(stream, length)
            msquicNativeClientInitialCrypto = stream
            return out
        if packetTypeCode == msquicNativePacketHandshakeCode:
            var stream = msquicNativeClientHandshakeCrypto
            let out: Bytes = msquicCryptoStreamConsume(stream, length)
            msquicNativeClientHandshakeCrypto = stream
            return out
        return emptyBytes()
    if side == msquicNativeServerSide:
        if packetTypeCode == msquicNativePacketInitialCode:
            var stream = msquicNativeServerInitialCrypto
            let out: Bytes = msquicCryptoStreamConsume(stream, length)
            msquicNativeServerInitialCrypto = stream
            return out
        if packetTypeCode == msquicNativePacketHandshakeCode:
            var stream = msquicNativeServerHandshakeCrypto
            let out: Bytes = msquicCryptoStreamConsume(stream, length)
            msquicNativeServerHandshakeCrypto = stream
            return out
        return emptyBytes()
    return emptyBytes()

fn msquicNativeCryptoStreamAddByCode(side: int32, packetTypeCode: int32, offset: int64, data: Bytes): Result[bool] =
    if side == msquicNativeClientSide:
        if packetTypeCode == msquicNativePacketInitialCode:
            var stream = msquicNativeClientInitialCrypto
            let addRes: Result[bool] = msquicCryptoStreamAdd(stream, offset, data)
            msquicNativeClientInitialCrypto = stream
            return addRes
        if packetTypeCode == msquicNativePacketHandshakeCode:
            var stream = msquicNativeClientHandshakeCrypto
            let addRes: Result[bool] = msquicCryptoStreamAdd(stream, offset, data)
            msquicNativeClientHandshakeCrypto = stream
            return addRes
        return Ok[bool](true)
    if side == msquicNativeServerSide:
        if packetTypeCode == msquicNativePacketInitialCode:
            var stream = msquicNativeServerInitialCrypto
            let addRes: Result[bool] = msquicCryptoStreamAdd(stream, offset, data)
            msquicNativeServerInitialCrypto = stream
            return addRes
        if packetTypeCode == msquicNativePacketHandshakeCode:
            var stream = msquicNativeServerHandshakeCrypto
            let addRes: Result[bool] = msquicCryptoStreamAdd(stream, offset, data)
            msquicNativeServerHandshakeCrypto = stream
            return addRes
        return Ok[bool](true)
    return Err[bool]("msquic native: invalid side")

fn msquicNativeAppRecvAvailable(side: int32): int32 =
    if side == msquicNativeClientSide:
        return bytesLen(msquicNativeClientAppRecvReady)
    if side == msquicNativeServerSide:
        return bytesLen(msquicNativeServerAppRecvReady)
    return 0

fn msquicNativeAppRecvConsume(side: int32, length: int32): Bytes =
    if side == msquicNativeClientSide:
        return msquicNativeBytesTakePrefix(msquicNativeClientAppRecvReady, length)
    if side == msquicNativeServerSide:
        return msquicNativeBytesTakePrefix(msquicNativeServerAppRecvReady, length)
    return emptyBytes()

fn msquicNativeClientAppRecvNormalize() =
    for i in 0..<msquicNativeAppRecvMaxChunks:
        if msquicNativeClientAppRecvUsed[i] &&
           msquicNativeClientAppRecvOffset[i] < msquicNativeClientAppRecvNextOffset:
            let trim64: int64 = msquicNativeClientAppRecvNextOffset - msquicNativeClientAppRecvOffset[i]
            if trim64 >= int64(bytesLen(msquicNativeClientAppRecvData[i])):
                msquicNativeClientAppRecvUsed[i] = false
                msquicNativeClientAppRecvOffset[i] = 0
                msquicNativeClientAppRecvData[i] = emptyBytes()
                msquicNativeClientAppRecvPendingCount = msquicNativeClientAppRecvPendingCount - 1
            else:
                let trim: int32 = int32(trim64)
                msquicNativeClientAppRecvData[i] = bytesSlice(msquicNativeClientAppRecvData[i],
                                                              trim,
                                                              bytesLen(msquicNativeClientAppRecvData[i]) - trim)
                msquicNativeClientAppRecvOffset[i] = msquicNativeClientAppRecvNextOffset

fn msquicNativeServerAppRecvNormalize() =
    for i in 0..<msquicNativeAppRecvMaxChunks:
        if msquicNativeServerAppRecvUsed[i] &&
           msquicNativeServerAppRecvOffset[i] < msquicNativeServerAppRecvNextOffset:
            let trim64: int64 = msquicNativeServerAppRecvNextOffset - msquicNativeServerAppRecvOffset[i]
            if trim64 >= int64(bytesLen(msquicNativeServerAppRecvData[i])):
                msquicNativeServerAppRecvUsed[i] = false
                msquicNativeServerAppRecvOffset[i] = 0
                msquicNativeServerAppRecvData[i] = emptyBytes()
                msquicNativeServerAppRecvPendingCount = msquicNativeServerAppRecvPendingCount - 1
            else:
                let trim: int32 = int32(trim64)
                msquicNativeServerAppRecvData[i] = bytesSlice(msquicNativeServerAppRecvData[i],
                                                              trim,
                                                              bytesLen(msquicNativeServerAppRecvData[i]) - trim)
                msquicNativeServerAppRecvOffset[i] = msquicNativeServerAppRecvNextOffset

fn msquicNativeClientAppRecvDrain() =
    var advanced = true
    while advanced:
        advanced = false
        msquicNativeClientAppRecvNormalize()
        for i in 0..<msquicNativeAppRecvMaxChunks:
            if msquicNativeClientAppRecvUsed[i] &&
               msquicNativeClientAppRecvOffset[i] == msquicNativeClientAppRecvNextOffset:
                let data: Bytes = msquicNativeClientAppRecvData[i]
                msquicNativeBytesAppend(msquicNativeClientAppRecvReady, data)
                msquicNativeClientAppRecvNextOffset = msquicNativeClientAppRecvNextOffset + int64(bytesLen(data))
                msquicNativeClientAppRecvUsed[i] = false
                msquicNativeClientAppRecvOffset[i] = 0
                msquicNativeClientAppRecvData[i] = emptyBytes()
                msquicNativeClientAppRecvPendingCount = msquicNativeClientAppRecvPendingCount - 1
                advanced = true
                break

fn msquicNativeServerAppRecvDrain() =
    var advanced = true
    while advanced:
        advanced = false
        msquicNativeServerAppRecvNormalize()
        for i in 0..<msquicNativeAppRecvMaxChunks:
            if msquicNativeServerAppRecvUsed[i] &&
               msquicNativeServerAppRecvOffset[i] == msquicNativeServerAppRecvNextOffset:
                let data: Bytes = msquicNativeServerAppRecvData[i]
                msquicNativeBytesAppend(msquicNativeServerAppRecvReady, data)
                msquicNativeServerAppRecvNextOffset = msquicNativeServerAppRecvNextOffset + int64(bytesLen(data))
                msquicNativeServerAppRecvUsed[i] = false
                msquicNativeServerAppRecvOffset[i] = 0
                msquicNativeServerAppRecvData[i] = emptyBytes()
                msquicNativeServerAppRecvPendingCount = msquicNativeServerAppRecvPendingCount - 1
                advanced = true
                break

fn msquicNativeLogAppRecv(side: int32, offset: int64, data: Bytes) =
    if ! msquicNativeDebugTls13:
        return
    var msg = "msquic_native_debug app_recv_add side="
    if side == msquicNativeClientSide:
        msg = msg + "client"
        msg = msg + " offset=" + int64ToStr(offset)
        msg = msg + " len=" + intToStr(bytesLen(data))
        msg = msg + " avail=" + intToStr(bytesLen(msquicNativeClientAppRecvReady))
        msg = msg + " next=" + int64ToStr(msquicNativeClientAppRecvNextOffset)
        msg = msg + " pending=" + intToStr(msquicNativeClientAppRecvPendingCount)
        os.WriteLine(os.Get_stderr(), msg)
        return
    if side == msquicNativeServerSide:
        msg = msg + "server"
        msg = msg + " offset=" + int64ToStr(offset)
        msg = msg + " len=" + intToStr(bytesLen(data))
        msg = msg + " avail=" + intToStr(bytesLen(msquicNativeServerAppRecvReady))
        msg = msg + " next=" + int64ToStr(msquicNativeServerAppRecvNextOffset)
        msg = msg + " pending=" + intToStr(msquicNativeServerAppRecvPendingCount)
        os.WriteLine(os.Get_stderr(), msg)

fn msquicNativeAppRecvAdd(side: int32, offset: int64, data: Bytes): Result[bool] =
    if offset < 0:
        return Err[bool]("msquic native: negative app recv offset")
    if bytesLen(data) <= 0:
        return Ok[bool](true)
    if side == msquicNativeClientSide:
        var off: int64 = offset
        var payload: Bytes = data
        if off < msquicNativeClientAppRecvNextOffset:
            let trim64: int64 = msquicNativeClientAppRecvNextOffset - off
            if trim64 >= int64(bytesLen(payload)):
                msquicNativeLogAppRecv(side, offset, data)
                return Ok[bool](true)
            let trim: int32 = int32(trim64)
            payload = bytesSlice(payload, trim, bytesLen(payload) - trim)
            off = msquicNativeClientAppRecvNextOffset
        if off == msquicNativeClientAppRecvNextOffset:
            msquicNativeBytesAppend(msquicNativeClientAppRecvReady, payload)
            msquicNativeClientAppRecvNextOffset = msquicNativeClientAppRecvNextOffset + int64(bytesLen(payload))
            msquicNativeClientAppRecvDrain()
            msquicNativeLogAppRecv(side, offset, data)
            return Ok[bool](true)
        var freeIdx: int32 = -1
        for i in 0..<msquicNativeAppRecvMaxChunks:
            if msquicNativeClientAppRecvUsed[i]:
                if msquicNativeClientAppRecvOffset[i] == off:
                    if bytesLen(msquicNativeClientAppRecvData[i]) >= bytesLen(payload):
                        msquicNativeLogAppRecv(side, offset, data)
                        return Ok[bool](true)
                    msquicNativeClientAppRecvData[i] = payload
                    msquicNativeClientAppRecvDrain()
                    msquicNativeLogAppRecv(side, offset, data)
                    return Ok[bool](true)
            elif freeIdx < 0:
                freeIdx = i
        if freeIdx < 0:
            return Err[bool]("msquic native: app recv chunk list full")
        msquicNativeClientAppRecvUsed[freeIdx] = true
        msquicNativeClientAppRecvOffset[freeIdx] = off
        msquicNativeClientAppRecvData[freeIdx] = payload
        msquicNativeClientAppRecvPendingCount = msquicNativeClientAppRecvPendingCount + 1
        msquicNativeClientAppRecvDrain()
        msquicNativeLogAppRecv(side, offset, data)
        return Ok[bool](true)
    if side == msquicNativeServerSide:
        var off: int64 = offset
        var payload: Bytes = data
        if off < msquicNativeServerAppRecvNextOffset:
            let trim64: int64 = msquicNativeServerAppRecvNextOffset - off
            if trim64 >= int64(bytesLen(payload)):
                msquicNativeLogAppRecv(side, offset, data)
                return Ok[bool](true)
            let trim: int32 = int32(trim64)
            payload = bytesSlice(payload, trim, bytesLen(payload) - trim)
            off = msquicNativeServerAppRecvNextOffset
        if off == msquicNativeServerAppRecvNextOffset:
            msquicNativeBytesAppend(msquicNativeServerAppRecvReady, payload)
            msquicNativeServerAppRecvNextOffset = msquicNativeServerAppRecvNextOffset + int64(bytesLen(payload))
            msquicNativeServerAppRecvDrain()
            msquicNativeLogAppRecv(side, offset, data)
            return Ok[bool](true)
        var freeIdx: int32 = -1
        for i in 0..<msquicNativeAppRecvMaxChunks:
            if msquicNativeServerAppRecvUsed[i]:
                if msquicNativeServerAppRecvOffset[i] == off:
                    if bytesLen(msquicNativeServerAppRecvData[i]) >= bytesLen(payload):
                        msquicNativeLogAppRecv(side, offset, data)
                        return Ok[bool](true)
                    msquicNativeServerAppRecvData[i] = payload
                    msquicNativeServerAppRecvDrain()
                    msquicNativeLogAppRecv(side, offset, data)
                    return Ok[bool](true)
            elif freeIdx < 0:
                freeIdx = i
        if freeIdx < 0:
            return Err[bool]("msquic native: app recv chunk list full")
        msquicNativeServerAppRecvUsed[freeIdx] = true
        msquicNativeServerAppRecvOffset[freeIdx] = off
        msquicNativeServerAppRecvData[freeIdx] = payload
        msquicNativeServerAppRecvPendingCount = msquicNativeServerAppRecvPendingCount + 1
        msquicNativeServerAppRecvDrain()
        msquicNativeLogAppRecv(side, offset, data)
        return Ok[bool](true)
    return Err[bool]("msquic native: invalid side")

fn msquicNativeDrainCryptoStream(side: int32, packetTypeCode: int32): Result[bool] =
    var tlsSide: int32 = 0
    if side == msquicNativeServerSide:
        tlsSide = 1
    elif side != msquicNativeClientSide:
        return Err[bool]("msquic native: invalid side")
    while msquicNativeCryptoStreamAvailableByCode(side, packetTypeCode) > 0:
        let chunkLen: int32 = msquicNativeCryptoStreamAvailableByCode(side, packetTypeCode)
        let chunk: Bytes = msquicNativeCryptoStreamConsumeByCode(side, packetTypeCode, chunkLen)
        if bytesLen(chunk) <= 0:
            break
        let feedRes: Result[int32] = msquicTls13SideFeed(tlsSide, chunk)
        if IsErr(feedRes):
            return Err[bool](ErrorText(feedRes))
    return Ok[bool](true)

fn msquicNativeHandleCryptoData(side: int32, packetTypeCode: int32, offset: int64, data: Bytes): Result[bool] =
    let addRes: Result[bool] = msquicNativeCryptoStreamAddByCode(side, packetTypeCode, offset, data)
    if IsErr(addRes):
        return Err[bool](ErrorText(addRes))
    return msquicNativeDrainCryptoStream(side, packetTypeCode)

fn msquicNativeHandleCryptoFrame(side: int32, packetTypeCode: int32, frame: MsQuicFrame): Result[bool] =
    let frameKind: int64 = msquicNativeFrameTypeCode(frame)
    if frameKind != int64(msquicNativeFrameCryptoCode):
        return Ok[bool](true)
    let feedRes: Result[bool] = msquicNativeHandleCryptoData(side, packetTypeCode, frame.offset, frame.data)
    if IsErr(feedRes):
        return Err[bool](ErrorText(feedRes))
    return Ok[bool](true)

fn msquicNativeResetServerHandshake(requireCert: bool) =
    handshake13.msquicTls13ResetServerDefault(requireCert)

fn msquicNativeFeedServerHandshake(data: Bytes): Result[int32] =
    return handshake13.msquicTls13SideFeed(1, data)

fn msquicNativeServerClientKeyShareGroup(): int32 =
    return handshake13.msquicTls13ServerClientKeyShareGroup()

fn msquicNativeResetSession() =
    msquicNativeSession.active = false
    msquicNativeSession.closed = false
    msquicNativeSession.serverBound = false
    msquicNativeSession.serverFlightSent = false
    msquicNativeSession.clientFinishedSent = false
    msquicNativeSession.clientAddrText = ""
    msquicNativeSession.listenerAddrText = ""
    msquicNativeSession.clientDatapathId = 0
    msquicNativeSession.listenerDatapathId = 0
    msquicNativeSession.dialAddr = msquicNativeEmptyAddr()
    msquicNativeSession.listenAddr = msquicNativeEmptyAddr()
    var clientSettings = initMsQuicSettings()
    var serverSettings = initMsQuicSettings()
    msquicNativeClientCidCache = emptyBytes()
    msquicNativeServerCidCache = emptyBytes()
    msquicNativeResetClientPolicyCache()
    msquicNativeResetServerPolicyCache()
    msquicNativeClientInitialNext = 1
    msquicNativeServerInitialNext = 1
    msquicNativeClientHandshakeNext = 1
    msquicNativeServerHandshakeNext = 1
    msquicNativeClientAppNext = 1
    msquicNativeServerAppNext = 1
    msquicNativeServerLargestInitialRecv = 0
    msquicNativeClientLargestHandshakeRecv = 0
    msquicNativeClientLargestAppRecv = 0
    msquicNativeServerLargestAppRecv = 0
    msquicNativeClientInitialPendingActive = false
    msquicNativeClientInitialPendingWire = emptyBytes()
    msquicNativeClientInitialPendingSentAtMs = 0
    msquicNativeClientHandshakePendingActive = false
    msquicNativeClientHandshakePendingWire = emptyBytes()
    msquicNativeClientHandshakePendingSentAtMs = 0
    msquicNativeServerHandshakePendingActive = false
    msquicNativeServerHandshakePendingWire = emptyBytes()
    msquicNativeServerHandshakePendingSentAtMs = 0
    msquicNativeServerHandshakeDoneSent = false
    msquicNativeDebugHandshakePendingLogged = false
    msquicNativeResetClientEndpoint(clientSettings, true)
    msquicNativeResetServerEndpoint(serverSettings, false)

fn msquicNativeStartsWith(text: str, prefix: str): bool =
    let tlen: int32 = len(text)
    let plen: int32 = len(prefix)
    if plen <= 0:
        return true
    if tlen < plen:
        return false
    for i in 0..<plen:
        if text[i] != prefix[i]:
            return false
    return true

fn msquicNativeAddrFromDatapathText(text: str, fallback: MultiAddress): MultiAddress =
    let parsedRes: Result[MultiAddress] = parseMultiAddress(text)
    if IsOk(parsedRes):
        return Value(parsedRes)
    let udpParsedRes: Result[datapath_udp.MsQuicUdpParsedAddr] = datapath_udp.udpParseAddr(text)
    if IsErr(udpParsedRes):
        return fallback
    let udpParsed: datapath_udp.MsQuicUdpParsedAddr = Value(udpParsedRes)
    var multiaddrText: str = if udpParsed.isV6: "/ip6/" else: "/ip4/"
    multiaddrText = multiaddrText + udpParsed.host
    multiaddrText = multiaddrText + "/udp/"
    multiaddrText = multiaddrText + strings.IntToStr(udpParsed.port)
    multiaddrText = multiaddrText + "/quic-v1"
    let multiaddrRes: Result[MultiAddress] = parseMultiAddress(multiaddrText)
    if IsOk(multiaddrRes):
        return Value(multiaddrRes)
    return fallback

fn msquicNativeTaggedAddr(addr: MultiAddress): bool =
    if bytesLen(addr.data) < 4:
        return false
    let head: int32 = bytesGet(addr.data, 0)
    let delta: int32 = head - 81
    if delta != 0:
        return false
    return true

fn msquicNativeMultiAddressBindTextFromText(text: str): str =
    if len(text) <= 0:
        return "/ip4/127.0.0.1/udp/0/quic-v1"
    if text[0] == '/':
        return text
    if msquicNativeStartsWith(text, "udp://"):
        return text
    return text

fn msquicNativeMultiAddressBindText(addr: MultiAddress): str =
    if len(addr.raw) > 0:
        return msquicNativeMultiAddressBindTextFromText(addr.raw)
    if bytesLen(addr.data) > 0:
        return msquicNativeMultiAddressBindTextFromText(bytesToString(addr.data))
    return msquicNativeMultiAddressBindTextFromText("")

var
    msquicNativeDebugTls13: bool = false
    msquicNativeReady: bool = false
    msquicNativeListenerRunning: bool = false
    msquicNativeAcceptPending: bool = false
    msquicNativeDropNextAppSend: bool = false
    msquicNativeLocalRole: int32 = msquicNativeRoleNone
    msquicNativeListenerDatapathId: int32 = 0
    msquicNativeDatapathRt: MsQuicDatapathRuntime
    msquicNativeListenerSettings: MsQuicSettings
    msquicNativeListenerTlsPolicy: MsQuicTlsPolicy
    msquicNativeListenAddr: MultiAddress
