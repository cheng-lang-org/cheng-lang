const
    msquicNativePipeBase = 1000000
    msquicNativePipeToken = msquicNativePipeBase + 1
    msquicNativeDatagramQueue = 16
    msquicNativeConnIdLen = 8
    msquicNativeShortPacketFlushBudget = 128
    msquicNativeVersion = 1
    msquicNativeClientSide = 0
    msquicNativeServerSide = 1
    msquicNativeRoleNone = 0
    msquicNativeRoleClient = 1
    msquicNativeRoleServer = 2
    msquicNativeStreamClient = 0
    msquicNativeStreamServer = 1
    msquicNativeAlpn = "dm"
    msquicNativePumpBudget = 32
    msquicNativeDialReadyTimeoutMs = 20000
    msquicNativePipeReadTimeoutMs = 20000
    msquicNativeLongPacketRetransmitMs = 250
    msquicNativePacketShortCode = 0
    msquicNativePacketInitialCode = 1
    msquicNativePacket0RttCode = 2
    msquicNativePacketHandshakeCode = 3
    msquicNativePacketRetryCode = 4
    msquicNativeProcessOutcomeNone = 0
    msquicNativeProcessOutcomeServerAccept = 1
    msquicNativeProcessOutcomeClientReady = 2
    msquicNativeFramePingCode = 0x01
    msquicNativeFrameAckCode = 0x02
    msquicNativeFrameCryptoCode = 0x06
    msquicNativeFrameDataCode = 0x0e
    msquicNativeFrameMaxDataCode = 0x10
    msquicNativeFrameMaxStreamDataCode = 0x11
    msquicNativeFrameConnectionCloseCode = 0x1c
    msquicNativeFrameConnectionCloseAppCode = 0x1d
    msquicNativeFrameHandshakeDoneCode = 0x1e
    msquicNativeFrameDatagramCode = 0x30
    msquicNativeAppRecvMaxChunks = 64

type
    MsQuicNativeEndpoint =
        datagramCount: int32
        sendOffset: int64
        ready: bool
        maxDataSent: bool
        maxStreamDataSent: bool

    MsQuicNativeSession =
        active: bool
        closed: bool
        serverBound: bool
        serverFlightSent: bool
        clientFinishedSent: bool
        clientAddrText: str
        listenerAddrText: str
        clientDatapathId: int32
        listenerDatapathId: int32
        dialAddr: MultiAddress
        listenAddr: MultiAddress
        clientSettings: MsQuicSettings
        serverSettings: MsQuicSettings
        clientTlsPolicy: MsQuicTlsPolicy
        serverTlsPolicy: MsQuicTlsPolicy
        clientCid: Bytes
        serverCid: Bytes
        clientInitialNext: int64
        serverInitialNext: int64
        clientHandshakeNext: int64
        serverHandshakeNext: int64
        clientAppNext: int64
        serverAppNext: int64
        serverLargestInitialRecv: int64
        clientLargestHandshakeRecv: int64
        clientLargestAppRecv: int64
        serverLargestAppRecv: int64
        client: MsQuicNativeEndpoint
        server: MsQuicNativeEndpoint

fn msquicNativeEmptyAddr(): MultiAddress =
    var out: MultiAddress
    out.raw = ""
    out.data = emptyBytes()
    return out

fn msquicNativePacketTypeCode(packetType: QuicPacketType): int32 =
    if packetType == QuicPacketInitial:
        return msquicNativePacketInitialCode
    if packetType == QuicPacket0Rtt:
        return msquicNativePacket0RttCode
    if packetType == QuicPacketHandshake:
        return msquicNativePacketHandshakeCode
    if packetType == QuicPacketRetry:
        return msquicNativePacketRetryCode
    return msquicNativePacketShortCode

fn msquicNativeFrameTypeCode(frame: MsQuicFrame): int64 =
    return msquicFrameTypeWireCode(frame.kind)

fn msquicNativeCopyBytes(src: Bytes): Bytes =
    let srcLen: int32 = bytesLen(src)
    if srcLen <= 0:
        return emptyBytes()
    let out: Bytes = bytesAlloc(srcLen)
    for i in 0..<srcLen:
        bytesSet(out, i, bytesGet(src, i))
    return out

fn msquicNativeBytesAppend(dst: var Bytes, extra: Bytes) =
    let oldLen: int32 = bytesLen(dst)
    let addLen: int32 = bytesLen(extra)
    if addLen <= 0:
        return
    let out: Bytes = bytesAlloc(oldLen + addLen)
    for i in 0..<oldLen:
        bytesSet(out, i, bytesGet(dst, i))
    for j in 0..<addLen:
        bytesSet(out, oldLen + j, bytesGet(extra, j))
    dst = out

fn msquicNativeBytesTakePrefix(buf: var Bytes, count: int32): Bytes =
    if count <= 0:
        return emptyBytes()
    let curLen: int32 = bytesLen(buf)
    if curLen <= 0:
        return emptyBytes()
    var take: int32 = count
    if take > curLen:
        take = curLen
    let out: Bytes = bytesSlice(buf, 0, take)
    let remain: int32 = curLen - take
    if remain <= 0:
        buf = emptyBytes()
        return out
    let rest: Bytes = bytesAlloc(remain)
    for i in 0..<remain:
        bytesSet(rest, i, bytesGet(buf, take + i))
    buf = rest
    return out

fn msquicNativeDebugWriteLine(text: str) =
    let stderrOut = os.Get_stderr()
    os.WriteLine(stderrOut, text)

