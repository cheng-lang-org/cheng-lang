    msquicNativeServerAppNext: int64 = 1
    msquicNativeServerLargestInitialRecv: int64 = 0
    msquicNativeClientLargestHandshakeRecv: int64 = 0
    msquicNativeClientLargestAppRecv: int64 = 0
    msquicNativeServerLargestAppRecv: int64 = 0

fn msquicNativeSetDebugTls13(enabled: bool) =
    msquicNativeDebugTls13 = enabled

fn msquicNativeResetResultScratch() =
    msquicNativeResultErrorScratch = ""
    msquicNativeProcessOutcomeScratch = msquicNativeProcessOutcomeNone

fn msquicNativeResetClientPolicyCache() =
    msquicNativeClientServerNameCache = ""
    msquicNativeClientTrustRootsCountCache = 0
    msquicNativeClientTrustRoot0Cache = emptyBytes()
    msquicNativeClientTrustRoot1Cache = emptyBytes()
    msquicNativeClientTrustRoot2Cache = emptyBytes()
    msquicNativeClientTrustRoot3Cache = emptyBytes()

fn msquicNativeSetClientPolicyCache(policy: MsQuicTlsPolicy) =
    msquicNativeClientServerNameCache = policy.serverName
    msquicNativeClientTrustRootsCountCache = policy.trustRootsCount
    msquicNativeClientTrustRoot0Cache = policy.trustRoot0
    msquicNativeClientTrustRoot1Cache = policy.trustRoot1
    msquicNativeClientTrustRoot2Cache = policy.trustRoot2
    msquicNativeClientTrustRoot3Cache = policy.trustRoot3

fn msquicNativeClientTrustRootAtCache(idx: int32): Bytes =
    if idx == 0:
        return msquicNativeClientTrustRoot0Cache
    if idx == 1:
        return msquicNativeClientTrustRoot1Cache
    if idx == 2:
        return msquicNativeClientTrustRoot2Cache
    if idx == 3:
        return msquicNativeClientTrustRoot3Cache
    return emptyBytes()

fn msquicNativeResetServerPolicyCache() =
    msquicNativeServerLeafDerCache = emptyBytes()
    msquicNativeServerPrivateKeyCache = emptyBytes()

fn msquicNativeSetServerPolicyCache(policy: MsQuicTlsPolicy) =
    msquicNativeServerLeafKeyKindCache = policy.certLeafKeyKind
    msquicNativeServerPrivateKeyCache = policy.certPrivateKey
    if policy.certChainCount > 0:
        msquicNativeServerLeafDerCache = policy.certChain0
        return
    msquicNativeServerLeafDerCache = emptyBytes()

fn msquicNativeSeededBytes(tag: int32): Bytes =
    let out: Bytes = bytesAlloc(32)
    for i in 0..<32:
        let v: int32 = (tag * 41 + i * 17 + 29) & 255
        bytesSet(out, i, v)
    return out

fn msquicNativeConnId(tag: int32): Bytes =
    let out: Bytes = bytesAlloc(msquicNativeConnIdLen)
    for i in 0..<msquicNativeConnIdLen:
        let shift: int32 = (msquicNativeConnIdLen - 1 - i) * 8
        bytesSet(out, i, int32((int64(tag) >> shift) & 0xff))
    return out

fn msquicNativeEnsureInit() =
    if msquicNativeReady:
        return
    datapath_runtime.initMsQuicDatapathRuntimeInto(msquicNativeDatapathRt)
    msquicNativeListenerSettings = initMsQuicSettings()
    msquicNativeListenAddr = msquicNativeEmptyAddr()
    msquicNativeReady = true

fn msquicNativeResetListenerOnly() =
    msquicNativeEnsureInit()
    if msquicNativeListenerDatapathId > 0:
        datapath_runtime.msquicDatapathUnbindUdp(msquicNativeDatapathRt, msquicNativeListenerDatapathId)
        let _ = datapath_runtime.msquicDatapathStop(msquicNativeDatapathRt, msquicNativeListenerDatapathId)
    msquicNativeListenerRunning = false
    msquicNativeListenerDatapathId = 0
    msquicNativeListenAddr = msquicNativeEmptyAddr()
    msquicNativeListenerSettings = initMsQuicSettings()

fn msquicNativeResetAll() =
    msquicNativeEnsureInit()
    if msquicNativeSession.clientDatapathId > 0:
        datapath_runtime.msquicDatapathUnbindUdp(msquicNativeDatapathRt, msquicNativeSession.clientDatapathId)
        let _ = datapath_runtime.msquicDatapathStop(msquicNativeDatapathRt, msquicNativeSession.clientDatapathId)
    if msquicNativeListenerDatapathId > 0:
        datapath_runtime.msquicDatapathUnbindUdp(msquicNativeDatapathRt, msquicNativeListenerDatapathId)
        let _ = datapath_runtime.msquicDatapathStop(msquicNativeDatapathRt, msquicNativeListenerDatapathId)
    datapath_runtime.initMsQuicDatapathRuntimeInto(msquicNativeDatapathRt)
    msquicNativeListenerRunning = false
    msquicNativeAcceptPending = false
    msquicNativeDropNextAppSend = false
    msquicNativeLocalRole = msquicNativeRoleNone
    msquicNativeListenerDatapathId = 0
    msquicNativeListenAddr = msquicNativeEmptyAddr()
    msquicNativeResetSession()

fn msquicNativeClientNextPacketNumber(packetTypeCode: int32): int64 =
    if packetTypeCode == msquicNativePacketInitialCode:
        let pn: int64 = msquicNativeClientInitialNext
        msquicNativeClientInitialNext = pn + 1
        return pn
    if packetTypeCode == msquicNativePacketHandshakeCode:
        let pn: int64 = msquicNativeClientHandshakeNext
        msquicNativeClientHandshakeNext = pn + 1
        return pn
    let pn: int64 = msquicNativeClientAppNext
    msquicNativeClientAppNext = pn + 1
    return pn

fn msquicNativeServerNextPacketNumber(packetTypeCode: int32): int64 =
    if packetTypeCode == msquicNativePacketInitialCode:
        let pn: int64 = msquicNativeServerInitialNext
        msquicNativeServerInitialNext = pn + 1
        return pn
    if packetTypeCode == msquicNativePacketHandshakeCode:
        let pn: int64 = msquicNativeServerHandshakeNext
        msquicNativeServerHandshakeNext = pn + 1
        return pn
    let pn: int64 = msquicNativeServerAppNext
    msquicNativeServerAppNext = pn + 1
    return pn

fn msquicNativeNextPacketNumber(side: int32, packetTypeCode: int32): int64 =
    if side == msquicNativeClientSide:
        return msquicNativeClientNextPacketNumber(packetTypeCode)
    return msquicNativeServerNextPacketNumber(packetTypeCode)

fn msquicNativeHeaderDestCid(side: int32): Bytes =
    if side == msquicNativeClientSide:
        return msquicNativeServerCidCache
    return msquicNativeClientCidCache

fn msquicNativeHeaderSrcCid(side: int32): Bytes =
    if side == msquicNativeClientSide:
        return msquicNativeClientCidCache
    return msquicNativeServerCidCache

fn msquicNativePacketTypeFromCode(packetTypeCode: int32): QuicPacketType =
    var out: QuicPacketType
    if packetTypeCode == msquicNativePacketInitialCode:
        return quicPacketTypeFromBits(0)
    if packetTypeCode == msquicNativePacket0RttCode:
        return quicPacketTypeFromBits(1)
    if packetTypeCode == msquicNativePacketHandshakeCode:
        return quicPacketTypeFromBits(2)
    if packetTypeCode == msquicNativePacketRetryCode:
        return quicPacketTypeFromBits(3)
    return out

fn msquicNativeBuildHeaderCommon(
    out: var QuicPacketHeader,
    side: int32,
    packetTypeCode: int32,
    longHeader: bool,
    packetNumber: int64,
    payloadLen: int32
) =
    out.longHeader = longHeader
    out.packetType = msquicNativePacketTypeFromCode(packetTypeCode)
    if longHeader:
        out.version = msquicNativeVersion
        out.scid = msquicNativeHeaderSrcCid(side)
        out.payloadLength = int64(payloadLen + 2)
    else:
        out.version = 0
        out.scid = emptyBytes()
        out.payloadLength = 0
    out.dcid = msquicNativeHeaderDestCid(side)
    out.token = emptyBytes()
    out.packetNumber = packetNumber
    out.packetNumberLen = 2
    out.spinBit = false
    out.keyPhase = false

fn msquicNativeBuildShortHeaderInto(out: var QuicPacketHeader, side: int32, packetNumber: int64) =
    msquicNativeBuildHeaderCommon(out, side, msquicNativePacketShortCode, false, packetNumber, 0)

fn msquicNativeBuildInitialHeaderInto(out: var QuicPacketHeader, side: int32, packetNumber: int64, payloadLen: int32) =
    msquicNativeBuildHeaderCommon(out, side, msquicNativePacketInitialCode, true, packetNumber, payloadLen)

fn msquicNativeBuildHandshakeHeaderInto(out: var QuicPacketHeader, side: int32, packetNumber: int64, payloadLen: int32) =
    msquicNativeBuildHeaderCommon(out, side, msquicNativePacketHandshakeCode, true, packetNumber, payloadLen)

fn msquicNativeBuildRetryHeaderInto(out: var QuicPacketHeader, side: int32, packetNumber: int64, payloadLen: int32) =
    msquicNativeBuildHeaderCommon(out, side, msquicNativePacketRetryCode, true, packetNumber, payloadLen)

fn msquicNativeBuild0RttHeaderInto(out: var QuicPacketHeader, side: int32, packetNumber: int64, payloadLen: int32) =
    msquicNativeBuildHeaderCommon(out, side, msquicNativePacket0RttCode, true, packetNumber, payloadLen)

fn msquicNativeBuildHeader(side: int32, packetTypeCode: int32, packetNumber: int64, payloadLen: int32): QuicPacketHeader =
    var out: QuicPacketHeader
    if packetTypeCode == msquicNativePacketShortCode:
        msquicNativeBuildShortHeaderInto(out, side, packetNumber)
        return out
    if packetTypeCode == msquicNativePacketInitialCode:
        msquicNativeBuildInitialHeaderInto(out, side, packetNumber, payloadLen)
        return out
    if packetTypeCode == msquicNativePacketHandshakeCode:
        msquicNativeBuildHandshakeHeaderInto(out, side, packetNumber, payloadLen)
        return out
    if packetTypeCode == msquicNativePacketRetryCode:
        msquicNativeBuildRetryHeaderInto(out, side, packetNumber, payloadLen)
        return out
    msquicNativeBuild0RttHeaderInto(out, side, packetNumber, payloadLen)
    return out

fn msquicNativeFrameAckEliciting(frameCode: int64): bool =
    if frameCode == int64(msquicNativeFrameAckCode):
        return false
    if frameCode == 0x00:
        return false
    if frameCode == int64(msquicNativeFrameConnectionCloseCode):
        return false
    if frameCode == int64(msquicNativeFrameConnectionCloseAppCode):
        return false
    return true

fn msquicNativePacketAppendFrame(pkt: var MsQuicPacket, frame: MsQuicFrame): Result[bool] =
    if pkt.framesCount >= 32:
        return Err[bool]("msquic packet: frame list full")
    pkt.frames[pkt.framesCount] = frame
    pkt.framesCount = pkt.framesCount + 1
    let frameCode: int64 = msquicNativeFrameTypeCode(frame)
    if msquicNativeFrameAckEliciting(frameCode):
        pkt.ackEliciting = true
    return Ok[bool](true)

fn msquicNativePacketAddCryptoFrame(pkt: var MsQuicPacket, offset: int64, data: Bytes): Result[bool] =
    let frame: MsQuicFrame = msquicFrameCrypto(offset, data)
    return msquicNativePacketAppendFrame(pkt, frame)

fn msquicNativePacketAddAckFrame(pkt: var MsQuicPacket, number: int64): Result[bool] =
    let frame: MsQuicFrame = msquicFrameAckNumber(number)
    return msquicNativePacketAppendFrame(pkt, frame)

fn msquicNativePacketAddConnectionCloseFrame(pkt: var MsQuicPacket, reason: Bytes): Result[bool] =
    let frame: MsQuicFrame = msquicFrameConnectionClose(0, 0, reason)
    return msquicNativePacketAppendFrame(pkt, frame)

fn msquicNativeSendWire(side: int32, wire: Bytes, dropAppSend: bool): Result[bool] =
    var fromId: int32 = msquicNativeSession.listenerDatapathId
    var toAddr: str = msquicNativeSession.clientAddrText
    if side == msquicNativeClientSide:
        fromId = msquicNativeSession.clientDatapathId
        toAddr = msquicNativeSession.listenerAddrText
    if fromId <= 0:
        panic("msquic native send: from id")
    if len(toAddr) <= 0:
        panic("msquic native send: to addr")
    if msquicNativeDebugTls13:
        var msg = "msquic_native_debug send_wire side="
        if side == msquicNativeClientSide:
            msg = msg + "client"
        else:
            msg = msg + "server"
        msg = msg + " from_id=" + intToStr(fromId)
        msg = msg + " to=" + toAddr
        msg = msg + " len=" + intToStr(bytesLen(wire))
        os.WriteLine(os.Get_stderr(), msg)
    if dropAppSend && msquicNativeDropNextAppSend:
        msquicNativeDropNextAppSend = false
        return Ok[bool](true)
    let sendRes: Result[bool] = datapath_runtime.msquicDatapathSendUdp(msquicNativeDatapathRt, fromId, toAddr, wire, -1)
    if IsErr(sendRes):
        return Err[bool](ErrorText(sendRes))
    return Ok[bool](true)

fn msquicNativeRememberLongPacket(side: int32, packetTypeCode: int32, wire: Bytes, ackEliciting: bool) =
    if !ackEliciting:
        return
    let nowMs: int64 = msquicNowMs()
    if side == msquicNativeClientSide && packetTypeCode == msquicNativePacketInitialCode:
        msquicNativeClientInitialPendingActive = true
        msquicNativeClientInitialPendingWire = wire
        msquicNativeClientInitialPendingSentAtMs = nowMs
        return
    if side == msquicNativeClientSide && packetTypeCode == msquicNativePacketHandshakeCode:
        msquicNativeClientHandshakePendingActive = true
        msquicNativeClientHandshakePendingWire = wire
        msquicNativeClientHandshakePendingSentAtMs = nowMs
        if msquicNativeDebugTls13:
            let debugText: str = "msquic_native_debug remember=client-handshake len=" + intToStr(bytesLen(wire))
            msquicNativeDebugWriteLine(debugText)
        return
    if side == msquicNativeServerSide && packetTypeCode == msquicNativePacketHandshakeCode:
        msquicNativeServerHandshakePendingActive = true
        msquicNativeServerHandshakePendingWire = wire
        msquicNativeServerHandshakePendingSentAtMs = nowMs

fn msquicNativeRetransmitClientInitial(nowMs: int64): Result[bool] =
    if !msquicNativeClientInitialPendingActive || bytesLen(msquicNativeClientInitialPendingWire) <= 0:
        return Ok[bool](false)
    if nowMs - msquicNativeClientInitialPendingSentAtMs < int64(msquicNativeLongPacketRetransmitMs):
        return Ok[bool](false)
    if msquicNativeDebugTls13:
        os.WriteLine(os.Get_stderr(), "msquic_native_debug retransmit=initial side=client")
    let sendRes: Result[bool] = msquicNativeSendWire(msquicNativeClientSide,
                                                     msquicNativeClientInitialPendingWire,
                                                     false)
    if IsErr(sendRes):
        return Err[bool](ErrorText(sendRes))
    msquicNativeClientInitialPendingSentAtMs = nowMs
    return Ok[bool](true)

fn msquicNativeRetransmitClientHandshake(nowMs: int64): Result[bool] =
    if !msquicNativeClientHandshakePendingActive || bytesLen(msquicNativeClientHandshakePendingWire) <= 0:
        return Ok[bool](false)
    if nowMs - msquicNativeClientHandshakePendingSentAtMs < int64(msquicNativeLongPacketRetransmitMs):
        return Ok[bool](false)
    if msquicNativeDebugTls13:
        os.WriteLine(os.Get_stderr(), "msquic_native_debug retransmit=handshake side=client")
    let sendRes: Result[bool] = msquicNativeSendWire(msquicNativeClientSide,
                                                     msquicNativeClientHandshakePendingWire,
                                                     false)
    if IsErr(sendRes):
        return Err[bool](ErrorText(sendRes))
    msquicNativeClientHandshakePendingSentAtMs = nowMs
    return Ok[bool](true)

fn msquicNativeRetransmitServerHandshake(nowMs: int64): Result[bool] =
    if !msquicNativeServerHandshakePendingActive || bytesLen(msquicNativeServerHandshakePendingWire) <= 0:
        return Ok[bool](false)
    if nowMs - msquicNativeServerHandshakePendingSentAtMs < int64(msquicNativeLongPacketRetransmitMs):
        return Ok[bool](false)
    if msquicNativeDebugTls13:
        os.WriteLine(os.Get_stderr(), "msquic_native_debug retransmit=handshake side=server")
    let sendRes: Result[bool] = msquicNativeSendWire(msquicNativeServerSide,
                                                     msquicNativeServerHandshakePendingWire,
                                                     false)
    if IsErr(sendRes):
        return Err[bool](ErrorText(sendRes))
    msquicNativeServerHandshakePendingSentAtMs = nowMs
    return Ok[bool](true)

fn msquicNativeSendPayload(
    side: int32,
    packetTypeCode: int32,
    packetNumber: int64,
    payload: Bytes,
    ackEliciting: bool
): Result[bool] =
    let header: QuicPacketHeader = msquicNativeBuildHeader(side, packetTypeCode, packetNumber, bytesLen(payload))
    let encRes: Result[Bytes] = quicPacketHeaderEncode(header)
    if IsErr(encRes):
        return Err[bool](ErrorText(encRes))
    let wire: Bytes = bytesConcat3(Value(encRes), payload, emptyBytes())
    let sendRes: Result[bool] = msquicNativeSendWire(side,
                                                     wire,
                                                     packetTypeCode == msquicNativePacketShortCode && ackEliciting)
    if IsErr(sendRes):
        return sendRes
    msquicNativeRememberLongPacket(side, packetTypeCode, wire, ackEliciting)
    return Ok[bool](true)

fn msquicNativeQueueTransportCredit(side: int32, peerStreamId: int64): Result[bool] =
    if side == msquicNativeClientSide:
        if msquicNativeClientMaxDataSent:
            return Ok[bool](true)
        let maxDataRes: Result[bool] = msquicConnImplQueueFrame(msquicNativeClientImpl, msquicFrameMaxData(msquicConnImplFlowMaxData(msquicNativeClientImpl)))
        if IsErr(maxDataRes):
            return Err[bool](ErrorText(maxDataRes))
        let maxStreamRes: Result[bool] = msquicConnImplQueueFrame(msquicNativeClientImpl, msquicFrameMaxStreamData(peerStreamId, msquicConnImplFlowMaxStreamData(msquicNativeClientImpl)))
        if IsErr(maxStreamRes):
            return Err[bool](ErrorText(maxStreamRes))
        msquicNativeClientMaxDataSent = true
        msquicNativeClientMaxStreamDataSent = true
        return Ok[bool](true)
    if side == msquicNativeServerSide:
        if msquicNativeServerMaxDataSent:
            return Ok[bool](true)
        let maxDataRes: Result[bool] = msquicConnImplQueueFrame(msquicNativeServerImpl, msquicFrameMaxData(msquicConnImplFlowMaxData(msquicNativeServerImpl)))
        if IsErr(maxDataRes):
            return Err[bool](ErrorText(maxDataRes))
        let maxStreamRes: Result[bool] = msquicConnImplQueueFrame(msquicNativeServerImpl, msquicFrameMaxStreamData(peerStreamId, msquicConnImplFlowMaxStreamData(msquicNativeServerImpl)))
        if IsErr(maxStreamRes):
            return Err[bool](ErrorText(maxStreamRes))
        msquicNativeServerMaxDataSent = true
        msquicNativeServerMaxStreamDataSent = true
        return Ok[bool](true)
    return Err[bool]("msquic native: invalid side")

fn msquicNativeFlushClientShortPacketsFill(): bool =
    msquicNativeResetResultScratch()
    let creditRes = msquicNativeQueueTransportCredit(msquicNativeClientSide, msquicNativeStreamServer)
    if IsErr(creditRes):
        msquicNativeResultErrorScratch = ErrorText(creditRes)
        return false
    for flushIdx in 0..<msquicNativeShortPacketFlushBudget:
        if ! msquicConnImplHasQueued(msquicNativeClientImpl):
            return true
        let canSend: bool = msquicConnImplCanSend(msquicNativeClientImpl)
        let ackOnly: bool = msquicConnImplQueuedAckOnly(msquicNativeClientImpl)
        if ! canSend && ! ackOnly:
            if msquicNativeDebugTls13:
                let debugText: str = "msquic_native_debug flush_short_blocked side=client in_flight=" +
                                     int64ToStr(msquicConnImplBytesInFlight(msquicNativeClientImpl))
                msquicNativeDebugWriteLine(debugText)
            return true
        var pkt: MsQuicPacket = initMsQuicPacket(0)
        let pktRes: Result[bool] = msquicConnImplBuildPacketInto(pkt, msquicNativeClientImpl)
        if IsErr(pktRes):
            msquicNativeResultErrorScratch = ErrorText(pktRes)
            return false
        let payloadRes: Result[Bytes] = msquicPacketPayloadEncode(pkt)
        if IsErr(payloadRes):
            msquicNativeResultErrorScratch = ErrorText(payloadRes)
            return false
        let payload: Bytes = Value(payloadRes)
        if msquicNativeDebugTls13:
            let debugText: str = "msquic_native_debug flush_short_send side=client pn=" +
                                 int64ToStr(pkt.number) +
                                 " len=" +
                                 intToStr(bytesLen(payload)) +
                                 " frames=" +
                                 intToStr(pkt.framesCount)
            msquicNativeDebugWriteLine(debugText)
        let sendRes: Result[bool] = msquicNativeSendPayload(msquicNativeClientSide, msquicNativePacketShortCode, pkt.number, payload, msquicPacketAckEliciting(pkt))
        if IsErr(sendRes):
            msquicNativeResultErrorScratch = ErrorText(sendRes)
            return false
        let recRes: Result[bool] = msquicConnImplRecordSent(msquicNativeClientImpl, pkt, payload)
        if IsErr(recRes):
            msquicNativeResultErrorScratch = ErrorText(recRes)
            return false
    return true

fn msquicNativeFlushClientShortPackets(): Result[bool] =
    let ok: bool = msquicNativeFlushClientShortPacketsFill()
    if ! ok:
        return Err[bool](msquicNativeResultErrorScratch)
    return Ok[bool](true)

fn msquicNativeFlushServerShortPacketsFill(): bool =
    msquicNativeResetResultScratch()
    let creditRes = msquicNativeQueueTransportCredit(msquicNativeServerSide, msquicNativeStreamClient)
    if IsErr(creditRes):
        msquicNativeResultErrorScratch = ErrorText(creditRes)
        return false
    for flushIdx in 0..<msquicNativeShortPacketFlushBudget:
        if ! msquicConnImplHasQueued(msquicNativeServerImpl):
            return true
        let canSend: bool = msquicConnImplCanSend(msquicNativeServerImpl)
        let ackOnly: bool = msquicConnImplQueuedAckOnly(msquicNativeServerImpl)
        if ! canSend && ! ackOnly:
            if msquicNativeDebugTls13:
                let debugText: str = "msquic_native_debug flush_short_blocked side=server in_flight=" +
                                     int64ToStr(msquicConnImplBytesInFlight(msquicNativeServerImpl))
                msquicNativeDebugWriteLine(debugText)
            return true
        var pkt: MsQuicPacket = initMsQuicPacket(0)
        let pktRes: Result[bool] = msquicConnImplBuildPacketInto(pkt, msquicNativeServerImpl)
        if IsErr(pktRes):
            msquicNativeResultErrorScratch = ErrorText(pktRes)
            return false
        let payloadRes: Result[Bytes] = msquicPacketPayloadEncode(pkt)
        if IsErr(payloadRes):
            msquicNativeResultErrorScratch = ErrorText(payloadRes)
            return false
        let payload: Bytes = Value(payloadRes)
        if msquicNativeDebugTls13:
            let debugText: str = "msquic_native_debug flush_short_send side=server pn=" +
                                 int64ToStr(pkt.number) +
                                 " len=" +
                                 intToStr(bytesLen(payload)) +
                                 " frames=" +
                                 intToStr(pkt.framesCount)
            msquicNativeDebugWriteLine(debugText)
        let sendRes: Result[bool] = msquicNativeSendPayload(msquicNativeServerSide, msquicNativePacketShortCode, pkt.number, payload, msquicPacketAckEliciting(pkt))
        if IsErr(sendRes):
            msquicNativeResultErrorScratch = ErrorText(sendRes)
            return false
        let recRes: Result[bool] = msquicConnImplRecordSent(msquicNativeServerImpl, pkt, payload)
        if IsErr(recRes):
            msquicNativeResultErrorScratch = ErrorText(recRes)
            return false
    return true

fn msquicNativeFlushServerShortPackets(): Result[bool] =
    let ok: bool = msquicNativeFlushServerShortPacketsFill()
    if ! ok:
        return Err[bool](msquicNativeResultErrorScratch)
    return Ok[bool](true)

fn msquicNativeFlushShortPackets(side: int32): Result[bool] =
    if ! msquicNativeSession.active || msquicNativeSession.closed:
        return Ok[bool](false)
    if side == msquicNativeClientSide && msquicNativeClientReady <= 0:
        if msquicNativeDebugTls13:
            os.WriteLine(os.Get_stderr(), "msquic_native_debug flush_short_skip side=client ready=false")
        return Ok[bool](false)
    if side == msquicNativeServerSide && msquicNativeServerReady <= 0:
        if msquicNativeDebugTls13:
            os.WriteLine(os.Get_stderr(), "msquic_native_debug flush_short_skip side=server ready=false")
        return Ok[bool](false)
    if side == msquicNativeClientSide:
        return msquicNativeFlushClientShortPackets()
    return msquicNativeFlushServerShortPackets()

fn msquicNativeSendClientHelloFill(): bool =
    msquicNativeResetResultScratch()
    let genRes: Result[bool] = msquicTls13ClientGenerateX25519()
    if IsErr(genRes):
        panic("msquic native client hello: x25519")
    if msquicNativeDebugTls13:
        let clientPrivText: str = "msquic_native_debug client_priv=" + bytesToHex(handshake13.msquicTls13ClientLocalKeySharePriv())
        msquicNativeDebugWriteLine(clientPrivText)
        let clientPubText: str = "msquic_native_debug client_pub=" + bytesToHex(handshake13.msquicTls13ClientLocalKeySharePub())
        msquicNativeDebugWriteLine(clientPubText)
    msquicTls13ClientSetServerName(msquicNativeClientServerNameCache)
    let randomSeed: Bytes = msquicNativeSeededBytes(17)
    let emptyContext: Bytes = emptyBytes()
    let helloRes: Result[Bytes] = msquicTls13ClientBuildClientHello(
        randomSeed,
        "dm",
        msquicNativeClientServerNameCache,
        emptyContext
    )
    if IsErr(helloRes):
        panic("msquic native client hello: build")
    let raw: Bytes = Value(helloRes)
    msquicTls13ClientAppendTranscript(raw)
    var pkt: MsQuicPacket = initMsQuicPacket(0)
    msquicPacketReset(pkt, msquicNativeNextPacketNumber(msquicNativeClientSide, msquicNativePacketInitialCode))
    let addRes: Result[bool] = msquicNativePacketAddCryptoFrame(pkt, 0, raw)
    if IsErr(addRes):
        panic("msquic native client hello: frame")
    let payloadRes: Result[Bytes] = msquicPacketPayloadEncode(pkt)
    if IsErr(payloadRes):
        msquicNativeResultErrorScratch = ErrorText(payloadRes)
        return false
    let sendRes: Result[bool] = msquicNativeSendPayload(
        msquicNativeClientSide,
        msquicNativePacketInitialCode,
        pkt.number,
        Value(payloadRes),
        msquicPacketAckEliciting(pkt)
    )
    if IsErr(sendRes):
        msquicNativeResultErrorScratch = ErrorText(sendRes)
        return false
    return true

fn msquicNativeSendClientHello(): Result[bool] =
    let ok: bool = msquicNativeSendClientHelloFill()
    if ! ok:
        return Err[bool](msquicNativeResultErrorScratch)
    return Ok[bool](true)

fn msquicNativeDebugBuildClientHelloPayload(): Result[Bytes] =
    let clientServerName: str = msquicNativeClientServerNameCache
    let genRes: Result[bool] = msquicTls13ClientGenerateX25519()
    if IsErr(genRes):
        return Err[Bytes](ErrorText(genRes))
    msquicTls13ClientSetServerName(clientServerName)
    let randomSeed: Bytes = msquicNativeSeededBytes(17)
    let helloRes: Result[Bytes] = msquicTls13ClientBuildClientHello(
        randomSeed,
        "dm",
        clientServerName,
        emptyBytes()
    )
    if IsErr(helloRes):
        return Err[Bytes](ErrorText(helloRes))
    let raw: Bytes = Value(helloRes)
    var pkt: MsQuicPacket
    msquicPacketReset(pkt, 1)
    let addRes: Result[bool] = msquicNativePacketAddCryptoFrame(pkt, 0, raw)
    if IsErr(addRes):
        return Err[Bytes](ErrorText(addRes))
    return msquicPacketPayloadEncode(pkt)

fn msquicNativeDebugBuildClientHelloWire(): Result[Bytes] =
    if bytesLen(msquicNativeClientCidCache) <= 0:
        msquicNativeClientCidCache = msquicNativeConnId(0x11111111)
    if bytesLen(msquicNativeServerCidCache) <= 0:
        msquicNativeServerCidCache = msquicNativeConnId(0x22222222)
    let payloadRes: Result[Bytes] = msquicNativeDebugBuildClientHelloPayload()
    if IsErr(payloadRes):
        return Err[Bytes](ErrorText(payloadRes))
    let payload: Bytes = Value(payloadRes)
    let header: QuicPacketHeader = msquicNativeBuildHeader(
        msquicNativeClientSide,
        msquicNativePacketInitialCode,
        1,
        bytesLen(payload)
    )
    let headerRes: Result[Bytes] = quicPacketHeaderEncode(header)
    if IsErr(headerRes):
        return Err[Bytes](ErrorText(headerRes))
    return Ok[Bytes](bytesConcat3(Value(headerRes), payload, emptyBytes()))

fn msquicNativeDebugExtractFirstCryptoData(payload: Bytes): Result[Bytes] =
    let kindRes: Result[QuicVarIntDecoded] = quicVarIntDecode(payload, 0)
    if IsErr(kindRes):
        return Err[Bytes](ErrorText(kindRes))
    let kindDec: QuicVarIntDecoded = Value(kindRes)
    if kindDec.value != int64(msquicNativeFrameCryptoCode):
        return Err[Bytes]("msquic native: debug first frame ! crypto")
    let streamRes: Result[QuicVarIntDecoded] = quicVarIntDecode(payload, kindDec.next)
    if IsErr(streamRes):
        return Err[Bytes](ErrorText(streamRes))
    let streamDec: QuicVarIntDecoded = Value(streamRes)
    let offsetRes: Result[QuicVarIntDecoded] = quicVarIntDecode(payload, streamDec.next)
    if IsErr(offsetRes):
        return Err[Bytes](ErrorText(offsetRes))
    let offsetDec: QuicVarIntDecoded = Value(offsetRes)
    let lenRes: Result[QuicVarIntDecoded] = quicVarIntDecode(payload, offsetDec.next)
    if IsErr(lenRes):
        return Err[Bytes](ErrorText(lenRes))
    let lenDec: QuicVarIntDecoded = Value(lenRes)
    let dataLen: int32 = int32(lenDec.value)
    if dataLen <= 0:
        return Err[Bytes]("msquic native: debug crypto payload empty")
    let dataStart: int32 = lenDec.next
    let dataEnd: int32 = dataStart + dataLen
    if dataEnd > bytesLen(payload):
        return Err[Bytes]("msquic native: debug crypto payload truncated")
    let out: Bytes = bytesSlice(payload, dataStart, dataLen)
    return Ok[Bytes](out)

fn msquicNativeDebugFeedClientHelloPayload(): Result[bool] =
    msquicNativeResetServerHandshake(false)
    let payloadRes: Result[Bytes] = msquicNativeDebugBuildClientHelloPayload()
    if IsErr(payloadRes):
        return Err[bool](ErrorText(payloadRes))
    let payload: Bytes = Value(payloadRes)
    let helloRes: Result[Bytes] = msquicNativeDebugExtractFirstCryptoData(payload)
    if IsErr(helloRes):
        return Err[bool](ErrorText(helloRes))
    let hello: Bytes = Value(helloRes)
    let feedRes: Result[int32] = msquicNativeFeedServerHandshake(hello)
    if IsErr(feedRes):
        return Err[bool](ErrorText(feedRes))
    let messageCount: int32 = Value(feedRes)
    if messageCount != 1:
        return Err[bool]("msquic native: debug initial expected one handshake message")
    let keyShareGroup: int32 = msquicNativeServerClientKeyShareGroup()
    if keyShareGroup <= 0:
        return Err[bool]("msquic native: debug initial missing server client key share")
    return Ok[bool](true)

fn msquicNativeDebugRoundtripClientHelloInitial(): Result[bool] =
    msquicNativeResetServerHandshake(false)
    let wireRes: Result[Bytes] = msquicNativeDebugBuildClientHelloWire()
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let wire: Bytes = Value(wireRes)
    let decodeHeaderRes: Result[QuicPacketHeaderDecoded] = quicPacketHeaderDecode(wire, msquicNativeConnIdLen)
    if IsErr(decodeHeaderRes):
        return Err[bool](ErrorText(decodeHeaderRes))
    let headerDec: QuicPacketHeaderDecoded = Value(decodeHeaderRes)
    let payloadOffset: int32 = headerDec.next
    let payloadLen: int32 = int32(headerDec.header.payloadLength) - headerDec.header.packetNumberLen
    if payloadLen <= 0:
        return Err[bool]("msquic native: debug roundtrip payload empty")
    let payload: Bytes = bytesSlice(wire, payloadOffset, payloadLen)
    let helloRes: Result[Bytes] = msquicNativeDebugExtractFirstCryptoData(payload)
    if IsErr(helloRes):
        return Err[bool](ErrorText(helloRes))
    let hello: Bytes = Value(helloRes)
    let feedRes: Result[int32] = msquicNativeFeedServerHandshake(hello)
    if IsErr(feedRes):
        return Err[bool](ErrorText(feedRes))
    let messageCount: int32 = Value(feedRes)
    if messageCount != 1:
        return Err[bool]("msquic native: debug roundtrip expected one handshake message")
    let keyShareGroup: int32 = msquicNativeServerClientKeyShareGroup()
    if keyShareGroup <= 0:
        return Err[bool]("msquic native: debug roundtrip missing server client key share")
    return Ok[bool](true)

fn msquicNativeSendServerFlightFill(): bool =
    msquicNativeResetResultScratch()
    let alreadySent: bool = msquicNativeSession.serverFlightSent
    if alreadySent:
        return true
    let genRes: Result[bool] = msquicTls13ServerGenerateX25519()
    if IsErr(genRes):
        msquicNativeResultErrorScratch = ErrorText(genRes)
        return false
    let serverClientGroup: int32 = handshake13.msquicTls13ServerClientKeyShareGroup()
    let serverLocalGroup: int32 = handshake13.msquicTls13ServerLocalKeyShareGroup()
    if serverClientGroup <= 0:
        msquicNativeResultErrorScratch = "msquic native: server client key share missing before flight"
        return false
    if serverLocalGroup != serverClientGroup:
        msquicNativeResultErrorScratch = "msquic native: server key share diverged local=" +
                                         intToStr(serverLocalGroup) +
                                         " client=" +
                                         intToStr(serverClientGroup)
        return false
    if msquicNativeDebugTls13:
        let serverPrivText: str = "msquic_native_debug server_priv=" + bytesToHex(handshake13.msquicTls13ServerLocalKeySharePriv())
        msquicNativeDebugWriteLine(serverPrivText)
        let serverPubText: str = "msquic_native_debug server_pub=" + bytesToHex(handshake13.msquicTls13ServerLocalKeySharePub())
        msquicNativeDebugWriteLine(serverPubText)
        let serverClientPubText: str = "msquic_native_debug server_client_pub=" + bytesToHex(handshake13.msquicTls13ServerClientKeyShare())
        msquicNativeDebugWriteLine(serverClientPubText)
        let sharedRes = curve25519.curve25519SharedKey(handshake13.msquicTls13ServerLocalKeySharePriv(),
                                                       handshake13.msquicTls13ServerClientKeyShare())
        if IsOk(sharedRes):
            let serverSharedText: str = "msquic_native_debug server_shared=" + bytesToHex(Value(sharedRes))
            msquicNativeDebugWriteLine(serverSharedText)

    var ackPkt: MsQuicPacket = initMsQuicPacket(0)
    msquicPacketReset(ackPkt, msquicNativeNextPacketNumber(msquicNativeServerSide, msquicNativePacketInitialCode))
    let ackRes: Result[bool] = msquicNativePacketAddAckFrame(ackPkt, msquicNativeServerLargestInitialRecv)
    if IsErr(ackRes):
        msquicNativeResultErrorScratch = ErrorText(ackRes)
        return false
    let ackPayloadRes: Result[Bytes] = msquicPacketPayloadEncode(ackPkt)
    if IsErr(ackPayloadRes):
        msquicNativeResultErrorScratch = ErrorText(ackPayloadRes)
        return false
    let sendAckRes: Result[bool] = msquicNativeSendPayload(
        msquicNativeServerSide,
        msquicNativePacketInitialCode,
        ackPkt.number,
        Value(ackPayloadRes),
        msquicPacketAckEliciting(ackPkt)
    )
    if IsErr(sendAckRes):
        msquicNativeResultErrorScratch = ErrorText(sendAckRes)
        return false

    let serverRandomSeed: Bytes = msquicNativeSeededBytes(23)
    let shRes: Result[Bytes] = msquicTls13ServerBuildServerHello(serverRandomSeed, false)
    if IsErr(shRes):
        msquicNativeResultErrorScratch = ErrorText(shRes)
        return false
    let sh: Bytes = Value(shRes)
    msquicTls13ServerAppendTranscript(sh)
    let secRes: Result[bool] = msquicTls13SideComputeHandshakeSecrets(1)
    if IsErr(secRes):
        msquicNativeResultErrorScratch = ErrorText(secRes)
        return false

    let emptyExtensions: Bytes = emptyBytes()
    let eeRes: Result[Bytes] = msquicTls13BuildEncryptedExtensions("dm", emptyExtensions)
    if IsErr(eeRes):
        msquicNativeResultErrorScratch = ErrorText(eeRes)
        return false
    let ee: Bytes = Value(eeRes)
    msquicTls13ServerAppendTranscript(ee)

    if bytesLen(msquicNativeServerLeafDerCache) <= 0:
        msquicNativeResultErrorScratch = "msquic tls policy: leaf certificate missing"
        return false
    let certRes: Result[Bytes] = msquicTls13BuildCertificate(msquicNativeServerLeafDerCache)
    if IsErr(certRes):
        msquicNativeResultErrorScratch = ErrorText(certRes)
        return false
    let cert: Bytes = Value(certRes)
    msquicTls13ServerAppendTranscript(cert)

    let cvRes: Result[Bytes] = msquicTls13ServerBuildCertificateVerify(msquicNativeServerLeafKeyKindCache, msquicNativeServerPrivateKeyCache, true)
    if IsErr(cvRes):
        msquicNativeResultErrorScratch = ErrorText(cvRes)
        return false
    let cv: Bytes = Value(cvRes)
    msquicTls13ServerAppendTranscript(cv)

    let finRes: Result[Bytes] = msquicTls13ServerBuildFinished(true)
    if IsErr(finRes):
        msquicNativeResultErrorScratch = ErrorText(finRes)
        return false
    let fin: Bytes = Value(finRes)
    if msquicNativeDebugTls13:
        let serverTranscriptText: str = "msquic_native_debug server_transcript=" + bytesToHex(handshake13.msquicTls13ServerTranscriptHash())
        msquicNativeDebugWriteLine(serverTranscriptText)
        let serverFinishedText: str = "msquic_native_debug server_finished=" + bytesToHex(fin)
        msquicNativeDebugWriteLine(serverFinishedText)
    msquicTls13ServerAppendTranscript(fin)

    var crypto: ByteBuffer = newByteBuffer()
    appendBytes(crypto, sh)
    appendBytes(crypto, ee)
    appendBytes(crypto, cert)
    appendBytes(crypto, cv)
    appendBytes(crypto, fin)

    var pkt: MsQuicPacket = initMsQuicPacket(0)
    msquicPacketReset(pkt, msquicNativeNextPacketNumber(msquicNativeServerSide, msquicNativePacketHandshakeCode))
    let addCryptoRes: Result[bool] = msquicNativePacketAddCryptoFrame(pkt, 0, toBytes(crypto))
    if IsErr(addCryptoRes):
        msquicNativeResultErrorScratch = ErrorText(addCryptoRes)
        return false
    let payloadRes: Result[Bytes] = msquicPacketPayloadEncode(pkt)
    if IsErr(payloadRes):
        msquicNativeResultErrorScratch = ErrorText(payloadRes)
        return false
    let sendRes: Result[bool] = msquicNativeSendPayload(
        msquicNativeServerSide,
        msquicNativePacketHandshakeCode,
        pkt.number,
        Value(payloadRes),
        msquicPacketAckEliciting(pkt)
    )
    if IsErr(sendRes):
        msquicNativeResultErrorScratch = ErrorText(sendRes)
        return false
    msquicNativeSession.serverFlightSent = true
    return true

fn msquicNativeSendServerFlight(): Result[bool] =
    let ok: bool = msquicNativeSendServerFlightFill()
    if ! ok:
        return Err[bool](msquicNativeResultErrorScratch)
    return Ok[bool](true)

fn msquicNativeSendClientFinishedFill(): bool =
    msquicNativeResetResultScratch()
    let alreadySent: bool = msquicNativeSession.clientFinishedSent
    if alreadySent:
        return true
    let finRes: Result[Bytes] = msquicTls13ClientBuildFinished(false)
    if IsErr(finRes):
        msquicNativeResultErrorScratch = ErrorText(finRes)
        return false
    let fin: Bytes = Value(finRes)
    if msquicNativeDebugTls13:
        let clientTranscriptText: str = "msquic_native_debug client_transcript=" + bytesToHex(handshake13.msquicTls13ClientTranscriptHash())
        msquicNativeDebugWriteLine(clientTranscriptText)
        let clientFinishedText: str = "msquic_native_debug client_finished=" + bytesToHex(fin)
        msquicNativeDebugWriteLine(clientFinishedText)
    msquicTls13ClientAppendTranscript(fin)
    var pkt: MsQuicPacket = initMsQuicPacket(0)
    msquicPacketReset(pkt, msquicNativeNextPacketNumber(msquicNativeClientSide, msquicNativePacketHandshakeCode))
    if msquicNativeClientLargestHandshakeRecv > 0:
        let ackRes: Result[bool] = msquicNativePacketAddAckFrame(pkt, msquicNativeClientLargestHandshakeRecv)
        if IsErr(ackRes):
            msquicNativeResultErrorScratch = ErrorText(ackRes)
            return false
    let addRes: Result[bool] = msquicNativePacketAddCryptoFrame(pkt, 0, fin)
    if IsErr(addRes):
        msquicNativeResultErrorScratch = ErrorText(addRes)
        return false
    let payloadRes: Result[Bytes] = msquicPacketPayloadEncode(pkt)
    if IsErr(payloadRes):
        msquicNativeResultErrorScratch = ErrorText(payloadRes)
        return false
    let sendRes: Result[bool] = msquicNativeSendPayload(
        msquicNativeClientSide,
        msquicNativePacketHandshakeCode,
        pkt.number,
        Value(payloadRes),
        msquicPacketAckEliciting(pkt)
    )
    if IsErr(sendRes):
        msquicNativeResultErrorScratch = ErrorText(sendRes)
        return false
    msquicNativeClientReady = 1
    msquicNativeSession.clientFinishedSent = true
    return true

fn msquicNativeSendClientFinished(): Result[bool] =
    let ok: bool = msquicNativeSendClientFinishedFill()
    if ! ok:
        return Err[bool](msquicNativeResultErrorScratch)
    return Ok[bool](true)

fn msquicNativeSendServerHandshakeDoneFill(): bool =
    msquicNativeResetResultScratch()
    let alreadySent: bool = msquicNativeServerHandshakeDoneSent
    if alreadySent:
        return true
    var pkt: MsQuicPacket = initMsQuicPacket(0)
    msquicPacketReset(pkt,
                      msquicNativeNextPacketNumber(msquicNativeServerSide,
                                                   msquicNativePacketShortCode))
    let addRes: Result[bool] = msquicNativePacketAppendFrame(pkt, msquicFrameHandshakeDone())
    if IsErr(addRes):
        msquicNativeResultErrorScratch = ErrorText(addRes)
        return false
    let payloadRes: Result[Bytes] = msquicPacketPayloadEncode(pkt)
    if IsErr(payloadRes):
        msquicNativeResultErrorScratch = ErrorText(payloadRes)
        return false
    let sendRes: Result[bool] = msquicNativeSendPayload(
        msquicNativeServerSide,
        msquicNativePacketShortCode,
        pkt.number,
        Value(payloadRes),
        msquicPacketAckEliciting(pkt)
    )
    if IsErr(sendRes):
        msquicNativeResultErrorScratch = ErrorText(sendRes)
        return false
    msquicNativeServerHandshakeDoneSent = true
    return true

fn msquicNativeSendServerHandshakeDone(): Result[bool] =
    let ok: bool = msquicNativeSendServerHandshakeDoneFill()
    if ! ok:
        return Err[bool](msquicNativeResultErrorScratch)
    return Ok[bool](true)

fn msquicNativeSessionReady(): bool =
    if ! msquicNativeSession.active:
        return false
    if msquicNativeSession.closed:
        return false
    if msquicNativeLocalRole == msquicNativeRoleClient:
        return msquicNativeClientReady > 0
    if msquicNativeLocalRole == msquicNativeRoleServer:
        return msquicNativeServerReady > 0
    return false

fn msquicNativeSideReady(side: int32): bool =
    if ! msquicNativeSession.active:
        return false
    if msquicNativeSession.closed:
        return false
    if side == msquicNativeClientSide:
        return msquicNativeClientReady > 0
    if side == msquicNativeServerSide:
        return msquicNativeServerReady > 0
    return false

fn msquicNativeQueueAcceptIfReady() =
    if msquicNativeDebugTls13:
        var msg = "msquic_native_debug queue_accept listener="
        if msquicNativeListenerRunning:
            msg = msg + "true"
        else:
            msg = msg + "false"
        msg = msg + " active="
        if msquicNativeSession.active:
            msg = msg + "true"
        else:
            msg = msg + "false"
        msg = msg + " closed="
        if msquicNativeSession.closed:
            msg = msg + "true"
        else:
            msg = msg + "false"
        msg = msg + " ready="
        if msquicNativeServerReady > 0:
            msg = msg + "true"
        else:
            msg = msg + "false"
        os.WriteLine(os.Get_stderr(), msg)
    if ! msquicNativeListenerRunning:
        return
    if ! msquicNativeSession.active:
        return
    if msquicNativeSession.closed:
        return
    if msquicNativeServerReady > 0:
        msquicNativeAcceptPending = true
        if msquicNativeDebugTls13:
            os.WriteLine(os.Get_stderr(), "msquic_native_debug accept_pending=true")

fn msquicNativeAcceptReady(): bool =
    if !msquicNativeListenerRunning:
        return false
    if !msquicNativeSession.active:
        return false
    if msquicNativeSession.closed:
        return false
    if msquicNativeAcceptPending:
        return true
    return handshake13.msquicTls13ServerFinishedOk()

fn msquicNativeInitServerSession(fromAddr: str, header: QuicPacketHeader): Result[bool] =
    if msquicNativeSession.clientDatapathId <= 0:
        msquicNativeResetSession()
    msquicNativeSession.active = true
    msquicNativeSession.closed = false
    if msquicNativeLocalRole == msquicNativeRoleNone:
        msquicNativeLocalRole = msquicNativeRoleServer
    msquicNativeSession.listenAddr = msquicNativeListenAddr
    let peerAddrRes = parseMultiAddress(fromAddr)
    if IsOk(peerAddrRes):
        msquicNativeSession.dialAddr = Value(peerAddrRes)
    else:
        msquicNativeSession.dialAddr = msquicNativeEmptyAddr()
    var serverSettingsLocal = msquicNativeListenerSettings
    msquicNativeSetServerPolicyCache(msquicNativeListenerTlsPolicy)
    msquicNativeSession.listenerDatapathId = msquicNativeListenerDatapathId
    msquicNativeSession.listenerAddrText = datapath_runtime.msquicDatapathUdpAddr(msquicNativeDatapathRt, msquicNativeListenerDatapathId)
    msquicNativeSession.clientAddrText = fromAddr
    msquicNativeClientCidCache = msquicNativeCopyBytes(header.scid)
    msquicNativeServerCidCache = msquicNativeCopyBytes(header.dcid)
    msquicNativeResetServerEndpoint(serverSettingsLocal, false)
    msquicNativeSession.serverBound = true
    return Ok[bool](true)

fn msquicNativeHandleAppFrame(recvSide: int32, frame: MsQuicFrame): Result[bool] =
    let frameKind: int64 = msquicNativeFrameTypeCode(frame)
    if frameKind == int64(msquicNativeFrameAckCode):
        if recvSide == msquicNativeClientSide:
            msquicConnImplAck(msquicNativeClientImpl, frame.value, 0)
        else:
            msquicConnImplAck(msquicNativeServerImpl, frame.value, 0)
        return Ok[bool](true)
    if frameKind == int64(msquicNativeFrameDataCode):
        if msquicNativeDebugTls13:
            var msg = "msquic_native_debug data_frame side="
            if recvSide == msquicNativeClientSide:
                msg = msg + "client"
            else:
                msg = msg + "server"
            msg = msg + " len=" + intToStr(bytesLen(frame.data))
            msg = msg + " offset=" + int64ToStr(frame.offset)
            os.WriteLine(os.Get_stderr(), msg)
        let addRes: Result[bool] = msquicNativeAppRecvAdd(recvSide, frame.offset, frame.data)
        if IsErr(addRes):
            return Err[bool](ErrorText(addRes))
        return Ok[bool](true)
    if frameKind == int64(msquicNativeFrameDatagramCode):
        if recvSide == msquicNativeClientSide:
            return msquicNativeEnqueueDatagram(msquicNativeClientSide, frame.data)
        return msquicNativeEnqueueDatagram(msquicNativeServerSide, frame.data)
    if frameKind == int64(msquicNativeFrameMaxDataCode):
        if recvSide == msquicNativeClientSide:
            msquicConnImplUpdateMaxData(msquicNativeClientImpl, frame.value)
        else:
            msquicConnImplUpdateMaxData(msquicNativeServerImpl, frame.value)
        return Ok[bool](true)
    if frameKind == int64(msquicNativeFrameMaxStreamDataCode):
        if recvSide == msquicNativeClientSide:
            msquicConnImplRaiseMaxStreamData(msquicNativeClientImpl, frame.value)
        else:
            msquicConnImplRaiseMaxStreamData(msquicNativeServerImpl, frame.value)
        return Ok[bool](true)
    if frameKind == int64(msquicNativeFrameHandshakeDoneCode):
        if recvSide == msquicNativeClientSide:
            msquicNativeClientHandshakePendingActive = false
            if msquicNativeDebugTls13:
                os.WriteLine(os.Get_stderr(), "msquic_native_debug client_handshake_done")
        return Ok[bool](true)
    if frameKind == int64(msquicNativeFramePingCode):
        return Ok[bool](true)
    if frameKind == int64(msquicNativeFrameConnectionCloseCode) || frameKind == int64(msquicNativeFrameConnectionCloseAppCode):
        msquicNativeSession.closed = true
        return Ok[bool](true)
    return Ok[bool](true)

fn msquicNativeProcessPacketFill(
    recvSide: int32,
    fromAddr: str,
    wire: Bytes
): bool =
    msquicNativeResetResultScratch()
    let headerRes = quicPacketHeaderDecode(wire, msquicNativeConnIdLen)
    if IsErr(headerRes):
        msquicNativeResultErrorScratch = ErrorText(headerRes)
        return false
    let headerDec = Value(headerRes)
    let packetTypeCode: int32 = msquicNativePacketTypeCode(headerDec.header.packetType)
    if recvSide == msquicNativeServerSide:
        if packetTypeCode == msquicNativePacketInitialCode:
            if !msquicNativeSession.active || msquicNativeSession.closed || !msquicNativeSession.serverBound:
                let initRes: Result[bool] = msquicNativeInitServerSession(fromAddr, headerDec.header)
                if IsErr(initRes):
                    msquicNativeResultErrorScratch = ErrorText(initRes)
                    return false
        elif !msquicNativeSession.active || msquicNativeSession.closed || !msquicNativeSession.serverBound:
            return true
    let payloadOffset: int32 = headerDec.next
    let wireLen: int32 = bytesLen(wire)
    var payloadLen: int32 = wireLen - payloadOffset
    if headerDec.header.longHeader:
        let declared: int32 = int32(headerDec.header.payloadLength) - headerDec.header.packetNumberLen
        if declared < 0 || payloadOffset + declared > wireLen:
            msquicNativeResultErrorScratch = "msquic native: packet payload truncated"
            return false
        payloadLen = declared
    if payloadLen < 0:
        msquicNativeResultErrorScratch = "msquic native: negative payload length"
        return false
    let payload: Bytes = if payloadLen > 0: bytesSlice(wire, payloadOffset, payloadLen) else: emptyBytes()
    var pkt: MsQuicPacket = initMsQuicPacket(0)
    let pktRes: Result[bool] = msquicPacketPayloadDecodeInto(pkt, payload, headerDec.header.packetNumber)
    if IsErr(pktRes):
        msquicNativeResultErrorScratch = ErrorText(pktRes)
        return false

    if packetTypeCode == msquicNativePacketInitialCode:
        if recvSide != msquicNativeServerSide:
            return true
        msquicNativeServerLargestInitialRecv = headerDec.header.packetNumber
        var cryptoBytesSeen: int32 = 0
        var firstFrameKind: int64 = -1
        var firstFrameLen: int32 = -1
        for i in 0..<pkt.framesCount:
            let frameKind: int64 = msquicNativeFrameTypeCode(pkt.frames[i])
            if i == 0:
                firstFrameKind = frameKind
                firstFrameLen = bytesLen(pkt.frames[i].data)
            if frameKind == int64(msquicNativeFrameCryptoCode):
                cryptoBytesSeen = cryptoBytesSeen + bytesLen(pkt.frames[i].data)
                let feedRes: Result[bool] = msquicNativeHandleCryptoData(
                    msquicNativeServerSide,
                    msquicNativePacketInitialCode,
                    pkt.frames[i].offset,
                    pkt.frames[i].data
                )
                if IsErr(feedRes):
                    msquicNativeResultErrorScratch = ErrorText(feedRes)
                    return false
        if handshake13.msquicTls13ServerClientKeyShareGroup() <= 0:
            msquicNativeResultErrorScratch = "msquic native: server client key share missing after initial"
            msquicNativeResultErrorScratch = msquicNativeResultErrorScratch + " crypto=" + intToStr(cryptoBytesSeen)
            msquicNativeResultErrorScratch = msquicNativeResultErrorScratch + " frames=" + intToStr(pkt.framesCount)
            msquicNativeResultErrorScratch = msquicNativeResultErrorScratch + " firstKind=" + int64ToStr(firstFrameKind)
            msquicNativeResultErrorScratch = msquicNativeResultErrorScratch + " firstLen=" + intToStr(firstFrameLen)
            msquicNativeResultErrorScratch = msquicNativeResultErrorScratch + " messages=" + intToStr(handshake13.msquicTls13ServerHandshakeMessageCount())
            msquicNativeResultErrorScratch = msquicNativeResultErrorScratch + " buffered=" + intToStr(handshake13.msquicTls13ServerBufferedHandshakeBytes())
            msquicNativeResultErrorScratch = msquicNativeResultErrorScratch + " last=" + handshake13.msquicTls13ServerLastErrorText()
            return false
        let flightRes: Result[bool] = msquicNativeSendServerFlight()
        if IsErr(flightRes):
            msquicNativeResultErrorScratch = ErrorText(flightRes)
            return false
        return true

    if packetTypeCode == msquicNativePacketHandshakeCode:
        if recvSide == msquicNativeClientSide:
            msquicNativeClientInitialPendingActive = false
            msquicNativeClientLargestHandshakeRecv = headerDec.header.packetNumber
            for i in 0..<pkt.framesCount:
                let frameKind: int64 = msquicNativeFrameTypeCode(pkt.frames[i])
                if frameKind == int64(msquicNativeFrameCryptoCode):
                    let feedRes: Result[bool] = msquicNativeHandleCryptoData(
                        msquicNativeClientSide,
                        msquicNativePacketHandshakeCode,
                        pkt.frames[i].offset,
                        pkt.frames[i].data
                    )
                    if IsErr(feedRes):
                        msquicNativeResultErrorScratch = ErrorText(feedRes)
                        return false
            let clientServerKeyShare: Bytes = handshake13.msquicTls13ClientServerKeyShare()
            if msquicNativeDebugTls13 && bytesLen(clientServerKeyShare) > 0:
                let clientServerPubText: str = "msquic_native_debug client_server_pub=" + bytesToHex(clientServerKeyShare)
                msquicNativeDebugWriteLine(clientServerPubText)
                let sharedRes = curve25519.curve25519SharedKey(handshake13.msquicTls13ClientLocalKeySharePriv(),
                                                               clientServerKeyShare)
                if IsOk(sharedRes):
                    let clientSharedText: str = "msquic_native_debug client_shared=" + bytesToHex(Value(sharedRes))
                    msquicNativeDebugWriteLine(clientSharedText)
            if msquicTls13ClientFinishedOk():
                let finRes: Result[bool] = msquicNativeSendClientFinished()
                if IsErr(finRes):
                    msquicNativeResultErrorScratch = ErrorText(finRes)
                    return false
            return true

        for i in 0..<pkt.framesCount:
            let frameKind: int64 = msquicNativeFrameTypeCode(pkt.frames[i])
            if frameKind == int64(msquicNativeFrameCryptoCode):
                let feedRes: Result[bool] = msquicNativeHandleCryptoData(
                    msquicNativeServerSide,
                    msquicNativePacketHandshakeCode,
                    pkt.frames[i].offset,
                    pkt.frames[i].data
                )
                if IsErr(feedRes):
                    msquicNativeResultErrorScratch = ErrorText(feedRes)
                    return false
        if msquicTls13ServerFinishedOk():
            msquicNativeServerHandshakePendingActive = false
            msquicNativeServerReady = 1
            if msquicNativeDebugTls13:
                let debugText: str = "msquic_native_debug server_finished_ok=true"
                msquicNativeDebugWriteLine(debugText)
            let doneRes: Result[bool] = msquicNativeSendServerHandshakeDone()
            if IsErr(doneRes):
                msquicNativeResultErrorScratch = ErrorText(doneRes)
                return false
            msquicNativeQueueAcceptIfReady()
            msquicNativeProcessOutcomeScratch = msquicNativeProcessOutcomeServerAccept
            return true
        return true

    if packetTypeCode != msquicNativePacketShortCode:
        return true

    if recvSide == msquicNativeClientSide:
        msquicNativeClientLargestAppRecv = headerDec.header.packetNumber
    else:
        msquicNativeServerLargestAppRecv = headerDec.header.packetNumber

    var clientReadyNow: bool = false
    for i in 0..<pkt.framesCount:
        if recvSide == msquicNativeClientSide &&
           msquicNativeFrameTypeCode(pkt.frames[i]) == int64(msquicNativeFrameHandshakeDoneCode):
            clientReadyNow = true
        let frameRes: Result[bool] = msquicNativeHandleAppFrame(recvSide, pkt.frames[i])
        if IsErr(frameRes):
            msquicNativeResultErrorScratch = ErrorText(frameRes)
            return false
    if pkt.ackEliciting && ! msquicNativeSession.closed:
        if recvSide == msquicNativeClientSide:
            let ackRes: Result[bool] = msquicConnImplQueueAck(msquicNativeClientImpl, headerDec.header.packetNumber)
            if IsErr(ackRes):
                msquicNativeResultErrorScratch = ErrorText(ackRes)
                return false
            let flushRes: Result[bool] = msquicNativeFlushShortPackets(msquicNativeClientSide)
            if IsErr(flushRes):
                msquicNativeResultErrorScratch = ErrorText(flushRes)
                return false
            if clientReadyNow:
                msquicNativeProcessOutcomeScratch = msquicNativeProcessOutcomeClientReady
            return true
        let ackRes: Result[bool] = msquicConnImplQueueAck(msquicNativeServerImpl, headerDec.header.packetNumber)
        if IsErr(ackRes):
            msquicNativeResultErrorScratch = ErrorText(ackRes)
            return false
        let flushRes: Result[bool] = msquicNativeFlushShortPackets(msquicNativeServerSide)
        if IsErr(flushRes):
            msquicNativeResultErrorScratch = ErrorText(flushRes)
            return false
        return true
    if clientReadyNow:
        msquicNativeProcessOutcomeScratch = msquicNativeProcessOutcomeClientReady
    return true

fn msquicNativeProcessPacket(recvSide: int32, fromAddr: str, wire: Bytes): Result[int32] =
    let ok: bool = msquicNativeProcessPacketFill(recvSide, fromAddr, wire)
    if ! ok:
        return Err[int32](msquicNativeResultErrorScratch)
    return Ok[int32](msquicNativeProcessOutcomeScratch)

fn msquicNativePumpDatapath(id: int32, recvSide: int32): Result[int32] =
    if id <= 0:
        return Ok[int32](msquicNativeProcessOutcomeNone)
    let recvRes: Result[datapath_udp.MsQuicUdpDatagram] = datapath_runtime.msquicDatapathRecvUdp(msquicNativeDatapathRt, id)
    if IsErr(recvRes):
        if strContains(ErrorText(recvRes), "queue empty"):
            return Ok[int32](msquicNativeProcessOutcomeNone)
        return Err[int32](ErrorText(recvRes))
    let datagram: datapath_udp.MsQuicUdpDatagram = Value(recvRes)
    if msquicNativeDebugTls13:
        var msg = "msquic_native_debug recv_wire side="
        if recvSide == msquicNativeClientSide:
            msg = msg + "client"
        else:
            msg = msg + "server"
        msg = msg + " from=" + datagram.fromAddr
        msg = msg + " len=" + intToStr(bytesLen(datagram.data))
        os.WriteLine(os.Get_stderr(), msg)
    let procRes: Result[int32] = msquicNativeProcessPacket(recvSide, datagram.fromAddr, datagram.data)
    if IsErr(procRes):
        return Err[int32](ErrorText(procRes))
    return procRes

fn msquicNativePumpRetransmit(side: int32): Result[bool] =
    let nowMs: int64 = msquicNowMs()
    if side == msquicNativeClientSide:
        let rtInitialRes: Result[bool] = msquicNativeRetransmitClientInitial(nowMs)
        if IsErr(rtInitialRes):
            return rtInitialRes
        let rtHandshakeRes: Result[bool] = msquicNativeRetransmitClientHandshake(nowMs)
        if IsErr(rtHandshakeRes):
            return rtHandshakeRes
        let rt: MsQuicRetransmitPacket = msquicConnImplNextRetransmit(msquicNativeClientImpl, nowMs)
        if rt.number > 0 && bytesLen(rt.payload) > 0:
            if msquicNativeDebugTls13:
                os.WriteLine(os.Get_stderr(), "msquic_native_debug retransmit=short side=client")
            return msquicNativeSendPayload(msquicNativeClientSide, msquicNativePacketShortCode, rt.number, rt.payload, true)
        return Ok[bool](false)
    let rtHandshakeRes: Result[bool] = msquicNativeRetransmitServerHandshake(nowMs)
    if IsErr(rtHandshakeRes):
        return rtHandshakeRes
    let rt: MsQuicRetransmitPacket = msquicConnImplNextRetransmit(msquicNativeServerImpl, nowMs)
    if rt.number > 0 && bytesLen(rt.payload) > 0:
        if msquicNativeDebugTls13:
            os.WriteLine(os.Get_stderr(), "msquic_native_debug retransmit=short side=server")
        return msquicNativeSendPayload(msquicNativeServerSide, msquicNativePacketShortCode, rt.number, rt.payload, true)
    return Ok[bool](false)

fn msquicNativePump(count: int32): Result[int32] =
    if ! msquicNativeSession.active:
        return Ok[int32](msquicNativeProcessOutcomeNone)
    if msquicNativeSession.closed:
        return Ok[int32](msquicNativeProcessOutcomeNone)
    var budget: int32 = count
    if budget <= 0:
        budget = msquicNativePumpBudget
    var outcome: int32 = msquicNativeProcessOutcomeNone
    for i in 0..<budget:
        if msquicNativeSession.clientDatapathId > 0:
            let clientRes: Result[int32] = msquicNativePumpDatapath(msquicNativeSession.clientDatapathId, msquicNativeClientSide)
            if IsErr(clientRes):
                return clientRes
            if Value(clientRes) > outcome:
                outcome = Value(clientRes)
            let rtClient: Result[bool] = msquicNativePumpRetransmit(msquicNativeClientSide)
            if IsErr(rtClient):
                return Err[int32](ErrorText(rtClient))
        if msquicNativeSession.listenerDatapathId > 0:
            let listenerRes: Result[int32] = msquicNativePumpDatapath(msquicNativeSession.listenerDatapathId, msquicNativeServerSide)
            if IsErr(listenerRes):
                return listenerRes
            if Value(listenerRes) > outcome:
                outcome = Value(listenerRes)
            let rtServer: Result[bool] = msquicNativePumpRetransmit(msquicNativeServerSide)
            if IsErr(rtServer):
                return Err[int32](ErrorText(rtServer))
        if outcome == msquicNativeProcessOutcomeClientReady:
            return Ok[int32](outcome)
    return Ok[int32](outcome)

fn msquicNativePumpClientBlocking(): Result[int32] =
    if msquicNativeSession.clientDatapathId <= 0:
        return Err[int32]("msquic native: client datapath ! ready")
    let recvRes: Result[datapath_udp.MsQuicUdpDatagram] = datapath_runtime.msquicDatapathRecvUdpBlocking(msquicNativeDatapathRt, msquicNativeSession.clientDatapathId)
    if IsErr(recvRes):
        return Err[int32](ErrorText(recvRes))
    let procRes: Result[int32] = msquicNativeProcessPacket(msquicNativeClientSide, Value(recvRes).fromAddr, Value(recvRes).data)
    if IsErr(procRes):
        return procRes
    let rtRes: Result[bool] = msquicNativePumpRetransmit(msquicNativeClientSide)
    if IsErr(rtRes):
        return Err[int32](ErrorText(rtRes))
    return procRes

fn msquicNativePumpSideBlocking(side: int32): Result[int32] =
    if side == msquicNativeClientSide:
        return msquicNativePumpClientBlocking()
    if side == msquicNativeServerSide:
        if msquicNativeListenerDatapathId <= 0:
            return Err[int32]("msquic native: listener datapath ! ready")
        let recvRes: Result[datapath_udp.MsQuicUdpDatagram] = datapath_runtime.msquicDatapathRecvUdpBlocking(msquicNativeDatapathRt, msquicNativeListenerDatapathId)
        if IsErr(recvRes):
            return Err[int32](ErrorText(recvRes))
        let procRes: Result[int32] = msquicNativeProcessPacket(msquicNativeServerSide, Value(recvRes).fromAddr, Value(recvRes).data)
        if IsErr(procRes):
            return procRes
        let rtRes: Result[bool] = msquicNativePumpRetransmit(msquicNativeServerSide)
        if IsErr(rtRes):
            return Err[int32](ErrorText(rtRes))
        return procRes
    return Err[int32]("msquic native: local role ! ready")

fn msquicNativePumpHandshakeBlocking(): Result[bool] =
    let pumpRes: Result[int32] = msquicNativePump(msquicNativePumpBudget)
    if IsErr(pumpRes):
        return Err[bool](ErrorText(pumpRes))
    if msquicNativeSessionReady():
        return Ok[bool](true)
    if msquicNativeServerReady <= 0:
        let serverRes: Result[int32] = msquicNativePumpSideBlocking(msquicNativeServerSide)
        if IsErr(serverRes):
            return Err[bool](ErrorText(serverRes))
        if msquicNativeSessionReady():
            return Ok[bool](true)
    if msquicNativeClientReady <= 0:
        let clientRes: Result[int32] = msquicNativePumpSideBlocking(msquicNativeClientSide)
        if IsErr(clientRes):
            return Err[bool](ErrorText(clientRes))
    return Ok[bool](true)

fn msquicNativeStartListener(addr: MultiAddress, settings: MsQuicSettings, tlsPolicy: MsQuicTlsPolicy): Result[int32] =
    msquicNativeEnsureInit()
    let serverRes: Result[bool] = msquicTlsPolicyValidateForServer(tlsPolicy)
    if IsErr(serverRes):
        return Err[int32](ErrorText(serverRes))
    msquicNativeResetAll()
    let addRes: Result[int32] = datapath_runtime.msquicDatapathAdd(msquicNativeDatapathRt, 0)
    if IsErr(addRes):
        return Err[int32](ErrorText(addRes))
    let id: int32 = Value(addRes)
    let startRes: Result[bool] = datapath_runtime.msquicDatapathStart(msquicNativeDatapathRt, id)
    if IsErr(startRes):
        return Err[int32](ErrorText(startRes))
    var bindText: str = "/ip4/127.0.0.1/udp/0/quic-v1"
    if len(addr.raw) > 0:
        bindText = addr.raw
    elif bytesLen(addr.data) > 0:
        bindText = bytesToString(addr.data)
    let bindRes: Result[bool] = datapath_runtime.msquicDatapathBindUdp(msquicNativeDatapathRt, id, bindText)
    if IsErr(bindRes):
        return Err[int32](ErrorText(bindRes))
    msquicNativeListenerDatapathId = id
    msquicNativeListenerRunning = true
    msquicNativeListenerSettings = settings
    msquicNativeListenerTlsPolicy = tlsPolicy
    let boundText: str = datapath_runtime.msquicDatapathUdpAddr(msquicNativeDatapathRt, id)
    msquicNativeListenAddr = msquicNativeAddrFromDatapathText(boundText, addr)
    return Ok[int32](id)

fn msquicNativeStopListener() =
    msquicNativeResetListenerOnly()

fn msquicNativeListenerStartErrorText(code: int32): str =
    if code == -1:
        return "msquic tls policy: serverName missing"
    if code == -2:
        return "msquic tls policy: certificate missing"
    if code == -3:
        return "msquic tls policy: private key missing"
    if code == -4:
        return "msquic native: listener datapath add failed"
    if code == -5:
        return "msquic native: listener datapath start failed"
    if code == -6:
        return "msquic native: listener bind failed"
    return "msquic native: listener start failed"

fn msquicNativeStartListenerServerInputsCode(
    addr: MultiAddress,
    settings: MsQuicSettings,
    serverName: str,
    certDer: Bytes,
    keyDer: Bytes
): int32 =
    if ! msquicNativeReady:
        datapath_runtime.initMsQuicDatapathRuntimeInto(msquicNativeDatapathRt)
        msquicNativeListenerSettings = initMsQuicSettings()
        msquicNativeListenAddr = msquicNativeEmptyAddr()
        msquicNativeReady = true
    if len(serverName) <= 0:
        return -1
    if bytesLen(certDer) <= 0:
        return -2
    if bytesLen(keyDer) <= 0:
        return -3
    msquicNativeResetListenerOnly()
    let addRes: Result[int32] = datapath_runtime.msquicDatapathAdd(msquicNativeDatapathRt, 0)
    if IsErr(addRes):
        return -4
    let id: int32 = Value(addRes)
    let startRes: Result[bool] = datapath_runtime.msquicDatapathStart(msquicNativeDatapathRt, id)
    if IsErr(startRes):
        return -5
    var bindText: str = "/ip4/127.0.0.1/udp/0/quic-v1"
    if len(addr.raw) > 0:
        bindText = addr.raw
    elif bytesLen(addr.data) > 0:
        bindText = bytesToString(addr.data)
    let bindRes: Result[bool] = datapath_runtime.msquicDatapathBindUdp(msquicNativeDatapathRt, id, bindText)
    if IsErr(bindRes):
        return -6
    msquicNativeListenerDatapathId = id
    msquicNativeListenerRunning = true
    msquicNativeListenerSettings = settings
    let boundText: str = datapath_runtime.msquicDatapathUdpAddr(msquicNativeDatapathRt, id)
    msquicNativeListenAddr = msquicNativeAddrFromDatapathText(boundText, addr)
    return id

fn msquicNativeStartListenerServerInputs(
    addr: MultiAddress,
    settings: MsQuicSettings,
    serverName: str,
    certDer: Bytes,
    keyDer: Bytes
): Result[int32] =
    let code: int32 = msquicNativeStartListenerServerInputsCode(addr, settings, serverName, certDer, keyDer)
    if code > 0:
        return Ok[int32](code)
    return Err[int32](msquicNativeListenerStartErrorText(code))

fn msquicNativeStartListenerServerInputsMust(
    addr: MultiAddress,
    settings: MsQuicSettings,
    serverName: str,
    certDer: Bytes,
    keyDer: Bytes
): int32 =
    let startRes: Result[int32] = msquicNativeStartListenerServerInputs(addr, settings, serverName, certDer, keyDer)
    if IsErr(startRes):
        panic(ErrorText(startRes))
    return Value(startRes)

fn msquicNativeDialAllocClientDatapath(): Result[int32] =
    let addRes: Result[int32] = datapath_runtime.msquicDatapathAdd(msquicNativeDatapathRt, 0)
    if IsErr(addRes):
        return Err[int32](ErrorText(addRes))
    return Ok[int32](Value(addRes))

fn msquicNativeDialStartClientDatapath(clientId: int32): Result[bool] =
    let startRes: Result[bool] = datapath_runtime.msquicDatapathStart(msquicNativeDatapathRt, clientId)
    if IsErr(startRes):
        return Err[bool](ErrorText(startRes))
    return Ok[bool](true)

fn msquicNativeDialBindUdp(clientId: int32, bindText: str): Result[bool] =
    let bindRes: Result[bool] = datapath_runtime.msquicDatapathBindUdp(msquicNativeDatapathRt, clientId, bindText)
    if IsErr(bindRes):
        return Err[bool](ErrorText(bindRes))
    return Ok[bool](true)

fn msquicNativeDialSetupSession(
    clientId: int32,
    clientSettings: MsQuicSettings,
    clientTlsPolicy: MsQuicTlsPolicy,
    addr: MultiAddress
): Result[bool] =
    var remoteAddrText: str = "/ip4/127.0.0.1/udp/0/quic-v1"
    if len(addr.raw) > 0:
        remoteAddrText = addr.raw
    elif bytesLen(addr.data) > 0:
        remoteAddrText = bytesToString(addr.data)
    msquicNativeResetSession()
    var clientSettingsLocal = clientSettings
    msquicNativeLocalRole = msquicNativeRoleClient
    msquicNativeSession.active = true
    msquicNativeSession.listenAddr = msquicNativeListenAddr
    msquicNativeSession.dialAddr = addr
    msquicNativeSetClientPolicyCache(clientTlsPolicy)
    msquicNativeResetServerPolicyCache()
    msquicNativeSession.listenerDatapathId = 0
    msquicNativeSession.clientDatapathId = clientId
    msquicNativeSession.listenerAddrText = remoteAddrText
    msquicNativeSession.clientAddrText = datapath_runtime.msquicDatapathUdpAddr(msquicNativeDatapathRt, clientId)
    msquicNativeClientCidCache = msquicNativeConnId(0x11111111)
    msquicNativeServerCidCache = msquicNativeConnId(0x22222222)
    let clientAddrRes = parseMultiAddress(msquicNativeSession.clientAddrText)
    var clientAddr = msquicNativeEmptyAddr()
    if IsOk(clientAddrRes):
        clientAddr = Value(clientAddrRes)
    if msquicNativeListenerRunning && msquicNativeListenerDatapathId > 0:
        msquicNativeSession.listenerDatapathId = msquicNativeListenerDatapathId
    msquicNativeResetClientEndpoint(clientSettingsLocal, true)
    handshake13.msquicTls13ClientSetServerName(msquicNativeClientServerNameCache)
    handshake13.msquicTls13ClientClearTrustRoots()
    for i in 0..<msquicNativeClientTrustRootsCountCache:
        let addRes: Result[bool] = handshake13.msquicTls13ClientAddTrustRoot(msquicNativeClientTrustRootAtCache(i))
        if IsErr(addRes):
            return Err[bool](ErrorText(addRes))
    return Ok[bool](true)

fn msquicNativeDialSendHello(): Result[bool] =
    return msquicNativeSendClientHello()

fn msquicNativeDialPumpReady(): Result[int32] =
    let deadlineMs: int64 = msquicNowMs() + int64(msquicNativeDialReadyTimeoutMs)
    while msquicNowMs() <= deadlineMs:
        let pumpRes: Result[int32] = msquicNativePump(msquicNativePumpBudget)
        if IsErr(pumpRes):
            return Err[int32](ErrorText(pumpRes))
        if Value(pumpRes) == msquicNativeProcessOutcomeClientReady:
            if msquicNativeDebugTls13:
                os.WriteLine(os.Get_stderr(), "msquic_native_debug dial_return=client_ready")
            msquicNativeQueueAcceptIfReady()
            return Ok[int32](1)
        if msquicNativeSessionReady():
            msquicNativeQueueAcceptIfReady()
            return Ok[int32](1)
        if msquicNowMs() <= deadlineMs:
            os.SleepMs(10)
    return Err[int32]("msquic native: handshake ! ready")

fn msquicNativeStopClientDatapathIfAny() =
    if msquicNativeSession.clientDatapathId <= 0:
        return
    datapath_runtime.msquicDatapathUnbindUdp(msquicNativeDatapathRt, msquicNativeSession.clientDatapathId)
    let _ = datapath_runtime.msquicDatapathStop(msquicNativeDatapathRt, msquicNativeSession.clientDatapathId)
    msquicNativeSession.clientDatapathId = 0

fn msquicNativeAbortDialAttempt() =
    msquicNativeSession.closed = true
    msquicNativeStopClientDatapathIfAny()
    msquicNativeAcceptPending = false
    msquicNativeResetSession()

fn msquicNativeRecycleClosedSession() =
    if ! msquicNativeSession.active:
        return
    if ! msquicNativeSession.closed:
        return
    msquicNativeStopClientDatapathIfAny()
    msquicNativeAcceptPending = false
    msquicNativeResetSession()

fn msquicNativeDial(clientSettings: MsQuicSettings, clientTlsPolicy: MsQuicTlsPolicy, addr: MultiAddress): Result[int32] =
    msquicNativeEnsureInit()
    msquicNativeRecycleClosedSession()
    if msquicNativeSession.active && ! msquicNativeSession.closed:
        return Err[int32]("msquic native: active session exists")
    let clientRes: Result[bool] = msquicTlsPolicyValidateForClient(clientTlsPolicy)
    if IsErr(clientRes):
        return Err[int32](ErrorText(clientRes))
    let clientIdRes: Result[int32] = msquicNativeDialAllocClientDatapath()
    if IsErr(clientIdRes):
        return Err[int32](ErrorText(clientIdRes))
    let clientId: int32 = Value(clientIdRes)
    let startRes: Result[bool] = msquicNativeDialStartClientDatapath(clientId)
    if IsErr(startRes):
        msquicNativeAbortDialAttempt()
        return Err[int32](ErrorText(startRes))
    var remoteAddrText: str = "/ip4/127.0.0.1/udp/0/quic-v1"
    if len(addr.raw) > 0:
        remoteAddrText = addr.raw
    elif bytesLen(addr.data) > 0:
        remoteAddrText = bytesToString(addr.data)
    var bindText: str = "/ip4/0.0.0.0/udp/0/quic-v1"
    if msquicNativeStartsWith(remoteAddrText, "/ip6/"):
        bindText = "/ip6/::/udp/0/quic-v1"
    elif msquicNativeStartsWith(remoteAddrText, "udp://["):
        bindText = "/ip6/::/udp/0/quic-v1"
    let bindRes: Result[bool] = msquicNativeDialBindUdp(clientId, bindText)
    if IsErr(bindRes):
        msquicNativeAbortDialAttempt()
        return Err[int32](ErrorText(bindRes))
    if !datapath_runtime.msquicDatapathUdpBound(msquicNativeDatapathRt, clientId):
        msquicNativeAbortDialAttempt()
        panic("msquic native dial: bind lost")
    let setupRes: Result[bool] = msquicNativeDialSetupSession(clientId, clientSettings, clientTlsPolicy, addr)
    if IsErr(setupRes):
        msquicNativeAbortDialAttempt()
        return Err[int32](ErrorText(setupRes))
    if !datapath_runtime.msquicDatapathUdpBound(msquicNativeDatapathRt, clientId):
        msquicNativeAbortDialAttempt()
        panic("msquic native dial: bind lost after setup")
    let helloRes: Result[bool] = msquicNativeDialSendHello()
    if IsErr(helloRes):
        msquicNativeAbortDialAttempt()
        return Err[int32](ErrorText(helloRes))
    let readyRes: Result[int32] = msquicNativeDialPumpReady()
    if IsErr(readyRes):
        msquicNativeAbortDialAttempt()
        return Err[int32](ErrorText(readyRes))
    return readyRes

fn msquicNativeAcceptTimed(waitMs: int32): Result[int32] =
    if ! msquicNativeListenerRunning:
        return Err[int32]("msquic native: listener ! running")
    msquicNativeRecycleClosedSession()
    if msquicNativeAcceptReady():
        msquicNativeAcceptPending = false
        if msquicNativeDebugTls13:
            os.WriteLine(os.Get_stderr(), "msquic_native_debug accept_return=ready_preloop")
        return Ok[int32](1)
    if waitMs < 0:
        while true:
            let recvRes: Result[datapath_udp.MsQuicUdpDatagram] = datapath_runtime.msquicDatapathRecvUdpBlocking(msquicNativeDatapathRt, msquicNativeListenerDatapathId)
            if IsErr(recvRes):
                return Err[int32](ErrorText(recvRes))
            let datagram: datapath_udp.MsQuicUdpDatagram = Value(recvRes)
            let procRes: Result[int32] = msquicNativeProcessPacket(msquicNativeServerSide, datagram.fromAddr, datagram.data)
            if IsErr(procRes):
                return Err[int32](ErrorText(procRes))
            if Value(procRes) == msquicNativeProcessOutcomeServerAccept:
                msquicNativeAcceptPending = false
                if msquicNativeDebugTls13:
                    os.WriteLine(os.Get_stderr(), "msquic_native_debug accept_return=proc")
                return Ok[int32](1)
            if msquicNativeAcceptReady():
                msquicNativeAcceptPending = false
                if msquicNativeDebugTls13:
                    os.WriteLine(os.Get_stderr(), "msquic_native_debug accept_return=ready")
                return Ok[int32](1)
            if msquicNativeSession.closed:
                msquicNativeRecycleClosedSession()
        return Err[int32]("msquic native: accept failed")
    let idleDeadlineMs: int64 = msquicNowMs() + int64(waitMs)
    var handshakeDeadlineMs: int64 = 0
    while true:
        let recvRes: Result[datapath_udp.MsQuicUdpDatagram] = datapath_runtime.msquicDatapathRecvUdp(msquicNativeDatapathRt, msquicNativeListenerDatapathId)
        if IsErr(recvRes):
            if strContains(ErrorText(recvRes), "queue empty"):
                let nowMs: int64 = msquicNowMs()
                if msquicNativeSession.active &&
                   !msquicNativeSession.closed &&
                   msquicNativeSession.serverBound &&
                   !msquicNativeAcceptReady():
                    if handshakeDeadlineMs <= 0:
                        handshakeDeadlineMs = nowMs + int64(msquicNativeDialReadyTimeoutMs)
                    if nowMs > handshakeDeadlineMs:
                        return Err[int32]("msquic native: accept handshake ! ready")
                    os.SleepMs(10)
                    continue
                if nowMs > idleDeadlineMs:
                    return Ok[int32](0)
                os.SleepMs(10)
                continue
            return Err[int32](ErrorText(recvRes))
        let datagram: datapath_udp.MsQuicUdpDatagram = Value(recvRes)
        let procRes: Result[int32] = msquicNativeProcessPacket(msquicNativeServerSide, datagram.fromAddr, datagram.data)
        if IsErr(procRes):
            return Err[int32](ErrorText(procRes))
        if msquicNativeSession.active &&
           !msquicNativeSession.closed &&
           msquicNativeSession.serverBound &&
           !msquicNativeAcceptReady() &&
           handshakeDeadlineMs <= 0:
            handshakeDeadlineMs = msquicNowMs() + int64(msquicNativeDialReadyTimeoutMs)
        if Value(procRes) == msquicNativeProcessOutcomeServerAccept:
            msquicNativeAcceptPending = false
            if msquicNativeDebugTls13:
                os.WriteLine(os.Get_stderr(), "msquic_native_debug accept_return=proc")
            return Ok[int32](1)
        if msquicNativeAcceptReady():
            msquicNativeAcceptPending = false
            if msquicNativeDebugTls13:
                os.WriteLine(os.Get_stderr(), "msquic_native_debug accept_return=ready")
            return Ok[int32](1)
        if msquicNativeSession.closed:
            msquicNativeRecycleClosedSession()
            handshakeDeadlineMs = 0
        if !(msquicNativeSession.active &&
             !msquicNativeSession.closed &&
             msquicNativeSession.serverBound &&
             !msquicNativeAcceptReady()) &&
           msquicNowMs() > idleDeadlineMs:
            return Ok[int32](0)
    return Err[int32]("msquic native: accept timed failed")

fn msquicNativeAccept(): Result[int32] =
    return msquicNativeAcceptTimed(-1)

fn msquicNativeClientBoundAddr(): MultiAddress =
    if ! msquicNativeSession.active:
        return msquicNativeEmptyAddr()
    return msquicNativeAddrFromDatapathText(msquicNativeSession.clientAddrText, msquicNativeEmptyAddr())

fn msquicNativeListenerBoundAddr(): MultiAddress =
    if msquicNativeListenerRunning:
        return msquicNativeListenAddr
    return msquicNativeEmptyAddr()

fn msquicNativePeerDialAddr(): MultiAddress =
    let clientAddrTextLen: int32 = len(msquicNativeSession.clientAddrText)
    if clientAddrTextLen > 0:
        let fallbackAddr: MultiAddress = msquicNativeEmptyAddr()
        let clientAddr: MultiAddress = msquicNativeAddrFromDatapathText(msquicNativeSession.clientAddrText,
                                                                        fallbackAddr)
        if len(clientAddr.raw) > 0 || bytesLen(clientAddr.data) > 0:
            return clientAddr
    if msquicNativeSession.active:
        return msquicNativeSession.dialAddr
    return msquicNativeEmptyAddr()

fn msquicNativePipeIdxForSession(token: int32): int32 =
    if token <= 0:
        return -1
    return 1000001

fn msquicNativeIsPipeIdx(pipeIdx: int32): bool =
    if pipeIdx == 1000001:
        return true
    return false

fn msquicNativePipeIsClosed(pipeIdx: int32): bool =
    if ! msquicNativeIsPipeIdx(pipeIdx):
        return true
    if ! msquicNativeSession.active:
        return true
    return msquicNativeSession.closed

fn msquicNativePipeWrite(pipeIdx: int32, side: int32, data: Bytes): Result[int32] =
    if ! msquicNativeIsPipeIdx(pipeIdx):
        return Err[int32]("msquic native: invalid pipe")
    if ! msquicNativeSideReady(side):
        return Err[int32]("msquic native: session ! ready")
    if msquicNativeDebugTls13:
        var msg = "msquic_native_debug pipe_write side="
        if side == msquicNativeClientSide:
            msg = msg + "client"
        else:
            msg = msg + "server"
        msg = msg + " len=" + intToStr(bytesLen(data))
        os.WriteLine(os.Get_stderr(), msg)
    var remaining: int32 = bytesLen(data)
    var cursor: int32 = 0
    while remaining > 0:
        var batchLen: int32 = 0
        if side == msquicNativeClientSide:
            let frameBudget: int32 = msquicConnImplFrameBudget(msquicNativeClientImpl)
            let batchCap: int32 = if frameBudget > 32: frameBudget - 32 else: 0
            if batchCap <= 0:
                return Err[int32]("msquic native: send queue stalled")
            batchLen = if remaining < batchCap: remaining else: batchCap
            let chunk: Bytes = bytesSlice(data, cursor, batchLen)
            let qRes: Result[bool] = msquicConnImplQueueFrame(msquicNativeClientImpl,
                                                              msquicFrameData(msquicNativeStreamClient,
                                                                              msquicNativeClientSendOffset,
                                                                              chunk))
            if IsErr(qRes):
                return Err[int32](ErrorText(qRes))
            if msquicNativeDebugTls13:
                var dbg = "msquic_native_debug pipe_queue side=client batch="
                dbg = dbg + intToStr(batchLen)
                dbg = dbg + " has_queued="
                if msquicConnImplHasQueued(msquicNativeClientImpl):
                    dbg = dbg + "true"
                else:
                    dbg = dbg + "false"
                dbg = dbg + " ack_only="
                if msquicConnImplQueuedAckOnly(msquicNativeClientImpl):
                    dbg = dbg + "true"
                else:
                    dbg = dbg + "false"
                os.WriteLine(os.Get_stderr(), dbg)
            msquicNativeClientSendOffset = msquicNativeClientSendOffset + int64(batchLen)
            let flushRes: Result[bool] = msquicNativeFlushShortPackets(msquicNativeClientSide)
            if IsErr(flushRes):
                return Err[int32](ErrorText(flushRes))
        elif side == msquicNativeServerSide:
            let frameBudget: int32 = msquicConnImplFrameBudget(msquicNativeServerImpl)
            let batchCap: int32 = if frameBudget > 32: frameBudget - 32 else: 0
            if batchCap <= 0:
                return Err[int32]("msquic native: send queue stalled")
            batchLen = if remaining < batchCap: remaining else: batchCap
            let chunk: Bytes = bytesSlice(data, cursor, batchLen)
            let qRes: Result[bool] = msquicConnImplQueueFrame(msquicNativeServerImpl,
                                                              msquicFrameData(msquicNativeStreamServer,
                                                                              msquicNativeServerSendOffset,
                                                                              chunk))
            if IsErr(qRes):
                return Err[int32](ErrorText(qRes))
            if msquicNativeDebugTls13:
                var dbg = "msquic_native_debug pipe_queue side=server batch="
                dbg = dbg + intToStr(batchLen)
                dbg = dbg + " has_queued="
                if msquicConnImplHasQueued(msquicNativeServerImpl):
                    dbg = dbg + "true"
                else:
                    dbg = dbg + "false"
                dbg = dbg + " ack_only="
                if msquicConnImplQueuedAckOnly(msquicNativeServerImpl):
                    dbg = dbg + "true"
                else:
                    dbg = dbg + "false"
                os.WriteLine(os.Get_stderr(), dbg)
            msquicNativeServerSendOffset = msquicNativeServerSendOffset + int64(batchLen)
            let flushRes: Result[bool] = msquicNativeFlushShortPackets(msquicNativeServerSide)
            if IsErr(flushRes):
                return Err[int32](ErrorText(flushRes))
        else:
            return Err[int32]("msquic native: local role ! ready")
        cursor = cursor + batchLen
        remaining = remaining - batchLen
        let pumpMidRes: Result[int32] = msquicNativePump(msquicNativePumpBudget)
        if IsErr(pumpMidRes):
            return Err[int32](ErrorText(pumpMidRes))
    let pumpTailRes: Result[int32] = msquicNativePump(msquicNativePumpBudget)
    if IsErr(pumpTailRes):
        return Err[int32](ErrorText(pumpTailRes))
    return Ok[int32](bytesLen(data))

fn msquicNativePipeRead(pipeIdx: int32, side: int32, count: int32): Result[Bytes] =
    if ! msquicNativeIsPipeIdx(pipeIdx):
        return Err[Bytes]("msquic native: invalid pipe")
    if ! msquicNativeSession.active:
        return Err[Bytes]("msquic native: session ! active")
    if count <= 0:
        return Ok[Bytes](emptyBytes())
    let buffered: Bytes = msquicNativeAppRecvConsume(side, count)
    if bytesLen(buffered) > 0:
        if msquicNativeDebugTls13:
            var msg = "msquic_native_debug pipe_read_ready side="
            if side == msquicNativeClientSide:
                msg = msg + "client"
            else:
                msg = msg + "server"
            msg = msg + " avail=" + intToStr(bytesLen(buffered))
            os.WriteLine(os.Get_stderr(), msg)
        return Ok[Bytes](buffered)
    if msquicNativeDebugTls13:
        var enter = "msquic_native_debug pipe_read_enter side="
        if side == msquicNativeClientSide:
            enter = enter + "client"
        else:
            enter = enter + "server"
        enter = enter + " count=" + intToStr(count)
        enter = enter + " avail=" + intToStr(msquicNativeAppRecvAvailable(side))
        os.WriteLine(os.Get_stderr(), enter)
    let deadlineMs: int64 = msquicNowMs() + int64(msquicNativePipeReadTimeoutMs)
    while msquicNowMs() <= deadlineMs:
        if msquicNativeDebugTls13 &&
           side == msquicNativeClientSide &&
           msquicNativeSession.clientFinishedSent &&
           !msquicNativeDebugHandshakePendingLogged:
            var dbg = "msquic_native_debug pending_handshake active="
            if msquicNativeClientHandshakePendingActive:
                dbg = dbg + "true"
            else:
                dbg = dbg + "false"
            dbg = dbg + " len=" + intToStr(bytesLen(msquicNativeClientHandshakePendingWire))
            dbg = dbg + " age_ms=" + int64ToStr(msquicNowMs() - msquicNativeClientHandshakePendingSentAtMs)
            os.WriteLine(os.Get_stderr(), dbg)
            msquicNativeDebugHandshakePendingLogged = true
        let pumpRes: Result[int32] = msquicNativePump(msquicNativePumpBudget)
        if IsErr(pumpRes):
            return Err[Bytes](ErrorText(pumpRes))
        let chunk: Bytes = msquicNativeAppRecvConsume(side, count)
        if bytesLen(chunk) > 0:
            if msquicNativeDebugTls13:
                var msg = "msquic_native_debug pipe_read_ready side="
                if side == msquicNativeClientSide:
                    msg = msg + "client"
                else:
                    msg = msg + "server"
                msg = msg + " avail=" + intToStr(bytesLen(chunk))
                os.WriteLine(os.Get_stderr(), msg)
            return Ok[Bytes](chunk)
        if msquicNativeSession.closed:
            return Err[Bytes]("msquic: pipe closed")
        if msquicNowMs() <= deadlineMs:
            os.SleepMs(10)
            continue
    return Err[Bytes]("msquic native: pipe read timeout")

fn msquicNativeSendConnectionClosePacketFill(side: int32, reason: str): bool =
    msquicNativeResetResultScratch()
    let reasonBytes: Bytes = bytesFromString(reason)
    var pkt: MsQuicPacket = initMsQuicPacket(0)
    if side == msquicNativeClientSide:
        msquicPacketReset(pkt, msquicNativeNextPacketNumber(msquicNativeClientSide, msquicNativePacketShortCode))
    else:
        msquicPacketReset(pkt, msquicNativeNextPacketNumber(msquicNativeServerSide, msquicNativePacketShortCode))
    let closeRes: Result[bool] = msquicNativePacketAddConnectionCloseFrame(pkt, reasonBytes)
    if IsErr(closeRes):
        msquicNativeResultErrorScratch = ErrorText(closeRes)
        return false
    let payloadRes: Result[Bytes] = msquicPacketPayloadEncode(pkt)
    if IsErr(payloadRes):
        msquicNativeResultErrorScratch = ErrorText(payloadRes)
        return false
    if side == msquicNativeClientSide:
        let sendRes: Result[bool] = msquicNativeSendPayload(
            msquicNativeClientSide,
            msquicNativePacketShortCode,
            pkt.number,
            Value(payloadRes),
            msquicPacketAckEliciting(pkt)
        )
        if IsErr(sendRes):
            msquicNativeResultErrorScratch = ErrorText(sendRes)
            return false
    else:
        let sendRes: Result[bool] = msquicNativeSendPayload(
            msquicNativeServerSide,
            msquicNativePacketShortCode,
            pkt.number,
            Value(payloadRes),
            msquicPacketAckEliciting(pkt)
        )
        if IsErr(sendRes):
            msquicNativeResultErrorScratch = ErrorText(sendRes)
            return false
    let _ = msquicNativePump(msquicNativePumpBudget)
    return true

fn msquicNativeSendConnectionCloseFill(reason: str): bool =
    msquicNativeResetResultScratch()
    let sessionInactive: bool = ! msquicNativeSession.active || msquicNativeSession.closed
    if sessionInactive:
        msquicNativeSession.closed = true
        return true
    let role: int32 = msquicNativeLocalRole
    let clientReady: bool = role == msquicNativeRoleClient && msquicNativeClientReady > 0
    if clientReady:
        if ! msquicNativeSendConnectionClosePacketFill(msquicNativeClientSide, reason):
            return false
    let serverReady: bool = role == msquicNativeRoleServer && msquicNativeServerReady > 0
    if serverReady:
        if ! msquicNativeSendConnectionClosePacketFill(msquicNativeServerSide, reason):
            return false
    msquicNativeSession.closed = true
    return true

fn msquicNativeSendConnectionClose(reason: str): Result[bool] =
    let ok: bool = msquicNativeSendConnectionCloseFill(reason)
    if ! ok:
        return Err[bool](msquicNativeResultErrorScratch)
    return Ok[bool](true)

fn msquicNativePipeClose(pipeIdx: int32) =
    if ! msquicNativeIsPipeIdx(pipeIdx):
        return
    let _ = msquicNativeSendConnectionClose("closed")
    msquicNativeRecycleClosedSession()

fn msquicNativeDatagramWrite(pipeIdx: int32, side: int32, data: Bytes): Result[int32] =
    if ! msquicNativeIsPipeIdx(pipeIdx):
        return Err[int32]("msquic native: invalid pipe")
    if ! msquicNativeSideReady(side):
        return Err[int32]("msquic native: session ! ready")
    if side == msquicNativeClientSide:
        let qRes: Result[bool] = msquicConnImplQueueFrame(msquicNativeClientImpl, msquicFrameDatagram(data))
        if IsErr(qRes):
            return Err[int32](ErrorText(qRes))
        let flushRes: Result[bool] = msquicNativeFlushShortPackets(msquicNativeClientSide)
        if IsErr(flushRes):
            return Err[int32](ErrorText(flushRes))
    elif side == msquicNativeServerSide:
        let qRes: Result[bool] = msquicConnImplQueueFrame(msquicNativeServerImpl, msquicFrameDatagram(data))
        if IsErr(qRes):
            return Err[int32](ErrorText(qRes))
        let flushRes: Result[bool] = msquicNativeFlushShortPackets(msquicNativeServerSide)
        if IsErr(flushRes):
            return Err[int32](ErrorText(flushRes))
    else:
        return Err[int32]("msquic native: local role ! ready")
    let pumpRes: Result[int32] = msquicNativePump(msquicNativePumpBudget)
    if IsErr(pumpRes):
        return Err[int32](ErrorText(pumpRes))
    return Ok[int32](bytesLen(data))

fn msquicNativeDatagramRead(pipeIdx: int32, side: int32): Result[Bytes] =
    if ! msquicNativeIsPipeIdx(pipeIdx):
        return Err[Bytes]("msquic native: invalid pipe")
    let pumpRes: Result[int32] = msquicNativePump(msquicNativePumpBudget)
    if IsErr(pumpRes):
        return Err[Bytes](ErrorText(pumpRes))
    if msquicNativeSession.closed:
        return Err[Bytes]("msquic: pipe closed")
    if side == msquicNativeClientSide:
        return msquicNativeDequeueDatagram(msquicNativeClientSide)
    if side == msquicNativeServerSide:
        return msquicNativeDequeueDatagram(msquicNativeServerSide)
    return Err[Bytes]("msquic native: local role ! ready")

fn msquicNativeTestDropNextAppPacket() =
    msquicNativeDropNextAppSend = true

fn msquicNativeTestForceRetransmit(pipeIdx: int32): Result[bool] =
    if ! msquicNativeIsPipeIdx(pipeIdx):
        return Err[bool]("msquic native: invalid pipe")
    let nowMs: int64 = msquicNowMs()
    if msquicNativeLocalRole == msquicNativeRoleClient:
        msquicConnImplForceRetransmit(msquicNativeClientImpl, nowMs)
    elif msquicNativeLocalRole == msquicNativeRoleServer:
        msquicConnImplForceRetransmit(msquicNativeServerImpl, nowMs)
    let pumpRes: Result[int32] = msquicNativePump(msquicNativePumpBudget)
    if IsErr(pumpRes):
        return Err[bool](ErrorText(pumpRes))
    return Ok[bool](true)
