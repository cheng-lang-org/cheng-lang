    msquicNativeServerInitialCrypto: MsQuicCryptoStream
    msquicNativeClientHandshakeCrypto: MsQuicCryptoStream
    msquicNativeServerHandshakeCrypto: MsQuicCryptoStream
    msquicNativeClientAppRecvReady: Bytes
    msquicNativeServerAppRecvReady: Bytes
    msquicNativeClientAppRecvNextOffset: int64 = 0
    msquicNativeServerAppRecvNextOffset: int64 = 0
    msquicNativeClientAppRecvPendingCount: int32 = 0
    msquicNativeServerAppRecvPendingCount: int32 = 0
    msquicNativeClientAppRecvUsed: bool[msquicNativeAppRecvMaxChunks]
    msquicNativeServerAppRecvUsed: bool[msquicNativeAppRecvMaxChunks]
