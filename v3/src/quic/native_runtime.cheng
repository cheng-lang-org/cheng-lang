    msquicNativeServerDatagram12: Bytes
    msquicNativeServerDatagram13: Bytes
    msquicNativeServerDatagram14: Bytes
    msquicNativeServerDatagram15: Bytes
    msquicNativeClientSendOffset: int64 = 0
    msquicNativeServerSendOffset: int64 = 0
    msquicNativeClientReady: int32 = 0
    msquicNativeServerReady: int32 = 0
    msquicNativeClientMaxDataSent: bool = false
    msquicNativeServerMaxDataSent: bool = false
    msquicNativeClientMaxStreamDataSent: bool = false
    msquicNativeServerMaxStreamDataSent: bool = false
    msquicNativeClientInitialPendingActive: bool = false
    msquicNativeClientInitialPendingWire: Bytes
    msquicNativeClientInitialPendingSentAtMs: int64 = 0
