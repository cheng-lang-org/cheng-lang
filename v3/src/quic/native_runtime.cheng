    msquicNativeServerPrivateKeyCache: Bytes
    msquicNativeClientInitialNext: int64 = 1
    msquicNativeServerInitialNext: int64 = 1
    msquicNativeClientHandshakeNext: int64 = 1
    msquicNativeServerHandshakeNext: int64 = 1
