# MsQuic platform matrix(minimal).

import cheng/v3/quic/platform/common

const
    maxMsQuicPlatforms = 8

type
    MsQuicPlatformMatrix =
        count: int32
        kinds: common.MsQuicPlatformKind[maxMsQuicPlatforms]
        names: str[maxMsQuicPlatforms]
        supportsDatapath: bool[maxMsQuicPlatforms]
        supportsHighPerf: bool[maxMsQuicPlatforms]

fn initMsQuicPlatformMatrix(): MsQuicPlatformMatrix =
    var matrix: MsQuicPlatformMatrix = MsQuicPlatformMatrix(count: 0)
    matrix.kinds[matrix.count] = common.MsQuicPlatformMacos
    matrix.names[matrix.count] = "macos"
    matrix.supportsDatapath[matrix.count] = true
    matrix.supportsHighPerf[matrix.count] = false
    matrix.count = matrix.count + 1
    matrix.kinds[matrix.count] = common.MsQuicPlatformLinux
    matrix.names[matrix.count] = "linux"
    matrix.supportsDatapath[matrix.count] = true
    matrix.supportsHighPerf[matrix.count] = true
    matrix.count = matrix.count + 1
    matrix.kinds[matrix.count] = common.MsQuicPlatformWindows
    matrix.names[matrix.count] = "windows"
    matrix.supportsDatapath[matrix.count] = true
    matrix.supportsHighPerf[matrix.count] = true
    matrix.count = matrix.count + 1
    return matrix

fn msquicPlatformMatrixHas(matrix: MsQuicPlatformMatrix, kind: common.MsQuicPlatformKind): bool =
    for i in 0..<matrix.count:
        if matrix.kinds[i] == kind:
            return true
    return false

fn msquicPlatformMatrixDescribe(matrix: MsQuicPlatformMatrix, kind: common.MsQuicPlatformKind): str =
    for i in 0..<matrix.count:
        if matrix.kinds[i] == kind:
            var out = matrix.names[i]
            if matrix.supportsHighPerf[i]:
                out = out + " highperf"
            else:
                out = out + " basic"
            return out
    return ""

fn msquicPlatformMatrixSupportsHighPerf(matrix: MsQuicPlatformMatrix,
                                        kind: common.MsQuicPlatformKind): bool =
    for i in 0..<matrix.count:
        if matrix.kinds[i] == kind:
            return matrix.supportsHighPerf[i]
    return false
