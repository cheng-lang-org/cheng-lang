# MsQuic platform release validation(minimal).

import std/result
import std/strings
import cheng/v3/quic/platform/common
import cheng/v3/quic/platform/platform_matrix
import cheng/v3/quic/msquicruntime

fn msquicReleaseValidatePlatform(kind: common.MsQuicPlatformKind): Result[bool] =
    let matrix = platform_matrix.initMsQuicPlatformMatrix()
    if !platform_matrix.msquicPlatformMatrixHas(matrix, kind):
        return Err[bool]("msquic release: unsupported platform")
    return Ok[bool](true)

fn msquicReleaseValidateSettings(settings: msquicruntime.MsQuicSettings): Result[bool] =
    var next = settings
    return msquicruntime.validateMsQuicSettings(next)

fn msquicReleaseValidationSummary(kind: common.MsQuicPlatformKind,
                                  settings: msquicruntime.MsQuicSettings): str =
    var out = "msquic release"
    out = out + " platform=" + common.msquicPlatformKindToString(kind)
    out = out + " maxPending=" + strings.IntToStr(settings.maxPending)
    out = out + " idleTimeoutMs=" + strings.Int64ToStr(settings.idleTimeoutMs)
    out = out + " maxDatagram=" + strings.IntToStr(settings.maxDatagram)
    out = out + " allowDatagram=" + if settings.allowDatagram: "true" else: "false"
    out = out + " allow0Rtt=" + if settings.allow0Rtt: "true" else: "false"
    out = out + " useBbr=" + if settings.useBbr: "true" else: "false"
    return out
