# MsQuic core frame model(pure Cheng, in-process).

import std/result
import std/rawbytes
import cheng/v3/quic/core/quic_varint
type
    MsQuicFrameType = enum
        # Values follow QUIC frame type ids (RFC 9000 + extensions used here).
        FramePadding = 0x00
        FramePing = 0x01
        FrameAck = 0x02
        FrameReset = 0x04
        FrameStopSending = 0x05
        FrameCrypto = 0x06
        FrameNewToken = 0x07
        FrameData = 0x0e
        FrameMaxData = 0x10
        FrameMaxStreamData = 0x11
        FrameMaxStreamsBidi = 0x12
        FrameMaxStreamsUni = 0x13
        FrameDataBlocked = 0x14
        FrameStreamDataBlocked = 0x15
        FrameStreamsBlockedBidi = 0x16
        FrameStreamsBlockedUni = 0x17
        FrameNewConnectionId = 0x18
        FrameRetireConnectionId = 0x19
        FramePathChallenge = 0x1a
        FramePathResponse = 0x1b
        FrameConnectionClose = 0x1c
        FrameConnectionCloseApp = 0x1d
        FrameHandshakeDone = 0x1e
        FrameImmediateAck = 0x1f
        FrameDatagram = 0x30
        FrameAckFrequency = 0xaf

    MsQuicFrame =
        kind: MsQuicFrameType
        streamId: int64
        offset: int64
        value: int64
        data: Bytes

fn msquicFrameSize(frame: MsQuicFrame): int32 =
    let kindLen: int32 = quicVarIntEncodedLen(msquicFrameTypeWireCode(frame.kind))
    let streamLen: int32 = quicVarIntEncodedLen(frame.streamId)
    let offsetLen: int32 = quicVarIntEncodedLen(frame.offset)
    let valueLen: int32 = quicVarIntEncodedLen(frame.value)
    let dataLen: int32 = bytesLen(frame.data)
    let payloadLenLen: int32 = quicVarIntEncodedLen(int64(dataLen))
    if kindLen <= 0 || streamLen <= 0 || offsetLen <= 0 || valueLen <= 0 || payloadLenLen <= 0:
        return 0
    return kindLen + streamLen + offsetLen + valueLen + payloadLenLen + dataLen

fn msquicFrameTypeWireCode(kind: MsQuicFrameType): int64 =
    if kind == FramePadding:
        return 0x00
    if kind == FramePing:
        return 0x01
    if kind == FrameAck:
        return 0x02
    if kind == FrameReset:
        return 0x04
    if kind == FrameStopSending:
        return 0x05
    if kind == FrameCrypto:
        return 0x06
    if kind == FrameNewToken:
        return 0x07
    if kind == FrameData:
        return 0x0e
    if kind == FrameMaxData:
        return 0x10
    if kind == FrameMaxStreamData:
        return 0x11
    if kind == FrameMaxStreamsBidi:
        return 0x12
    if kind == FrameMaxStreamsUni:
        return 0x13
    if kind == FrameDataBlocked:
        return 0x14
    if kind == FrameStreamDataBlocked:
        return 0x15
    if kind == FrameStreamsBlockedBidi:
        return 0x16
    if kind == FrameStreamsBlockedUni:
        return 0x17
    if kind == FrameNewConnectionId:
        return 0x18
    if kind == FrameRetireConnectionId:
        return 0x19
    if kind == FramePathChallenge:
        return 0x1a
    if kind == FramePathResponse:
        return 0x1b
    if kind == FrameConnectionClose:
        return 0x1c
    if kind == FrameConnectionCloseApp:
        return 0x1d
    if kind == FrameHandshakeDone:
        return 0x1e
    if kind == FrameImmediateAck:
        return 0x1f
    if kind == FrameDatagram:
        return 0x30
    if kind == FrameAckFrequency:
        return 0xaf
    return -1

fn msquicFrameTypeFromInt(value: int64): Result[MsQuicFrameType] =
    if value == 0x00:
        return Ok[MsQuicFrameType](FramePadding)
    if value == 0x01:
        return Ok[MsQuicFrameType](FramePing)
    if value == 0x02:
        return Ok[MsQuicFrameType](FrameAck)
    if value == 0x04:
        return Ok[MsQuicFrameType](FrameReset)
    if value == 0x05:
        return Ok[MsQuicFrameType](FrameStopSending)
    if value == 0x06:
        return Ok[MsQuicFrameType](FrameCrypto)
    if value == 0x07:
        return Ok[MsQuicFrameType](FrameNewToken)
    if value == 0x0e:
        return Ok[MsQuicFrameType](FrameData)
    if value == 0x10:
        return Ok[MsQuicFrameType](FrameMaxData)
    if value == 0x11:
        return Ok[MsQuicFrameType](FrameMaxStreamData)
    if value == 0x12:
        return Ok[MsQuicFrameType](FrameMaxStreamsBidi)
    if value == 0x13:
        return Ok[MsQuicFrameType](FrameMaxStreamsUni)
    if value == 0x14:
        return Ok[MsQuicFrameType](FrameDataBlocked)
    if value == 0x15:
        return Ok[MsQuicFrameType](FrameStreamDataBlocked)
    if value == 0x16:
        return Ok[MsQuicFrameType](FrameStreamsBlockedBidi)
    if value == 0x17:
        return Ok[MsQuicFrameType](FrameStreamsBlockedUni)
    if value == 0x18:
        return Ok[MsQuicFrameType](FrameNewConnectionId)
    if value == 0x19:
        return Ok[MsQuicFrameType](FrameRetireConnectionId)
    if value == 0x1a:
        return Ok[MsQuicFrameType](FramePathChallenge)
    if value == 0x1b:
        return Ok[MsQuicFrameType](FramePathResponse)
    if value == 0x1c:
        return Ok[MsQuicFrameType](FrameConnectionClose)
    if value == 0x1d:
        return Ok[MsQuicFrameType](FrameConnectionCloseApp)
    if value == 0x1e:
        return Ok[MsQuicFrameType](FrameHandshakeDone)
    if value == 0x1f:
        return Ok[MsQuicFrameType](FrameImmediateAck)
    if value == 0x30:
        return Ok[MsQuicFrameType](FrameDatagram)
    if value == 0xaf:
        return Ok[MsQuicFrameType](FrameAckFrequency)
    return Err[MsQuicFrameType]("msquic frame: invalid type")

fn msquicFrameAck(): MsQuicFrame =
    MsQuicFrame(kind: FrameAck, streamId: 0, offset: 0, value: 0, data: emptyBytes())

fn msquicFrameAckNumber(number: int64): MsQuicFrame =
    MsQuicFrame(kind: FrameAck, streamId: 0, offset: 0, value: number, data: emptyBytes())

fn msquicFramePing(): MsQuicFrame =
    MsQuicFrame(kind: FramePing, streamId: 0, offset: 0, value: 0, data: emptyBytes())

fn msquicFrameData(streamId: int64, offset: int64, data: Bytes): MsQuicFrame =
    MsQuicFrame(kind: FrameData, streamId: streamId, offset: offset, value: 0, data: data)

fn msquicFrameMaxData(value: int64): MsQuicFrame =
    MsQuicFrame(kind: FrameMaxData, streamId: 0, offset: 0, value: value, data: emptyBytes())

fn msquicFrameMaxStreamData(streamId: int64, value: int64): MsQuicFrame =
    MsQuicFrame(kind: FrameMaxStreamData, streamId: streamId, offset: 0, value: value, data: emptyBytes())

fn msquicFrameReset(streamId: int64, errCode: int64): MsQuicFrame =
    MsQuicFrame(kind: FrameReset, streamId: streamId, offset: 0, value: errCode, data: emptyBytes())

fn msquicFrameStopSending(streamId: int64, errCode: int64): MsQuicFrame =
    MsQuicFrame(kind: FrameStopSending, streamId: streamId, offset: 0, value: errCode, data: emptyBytes())

fn msquicFrameResetFinal(streamId: int64, errCode: int64, finalSize: int64): MsQuicFrame =
    MsQuicFrame(kind: FrameReset, streamId: streamId, offset: finalSize, value: errCode, data: emptyBytes())

fn msquicFrameCrypto(offset: int64, data: Bytes): MsQuicFrame =
    MsQuicFrame(kind: FrameCrypto, streamId: 0, offset: offset, value: 0, data: data)

fn msquicFrameDatagram(data: Bytes): MsQuicFrame =
    MsQuicFrame(kind: FrameDatagram, streamId: 0, offset: 0, value: 0, data: data)

fn msquicFrameHandshakeDone(): MsQuicFrame =
    MsQuicFrame(kind: FrameHandshakeDone, streamId: 0, offset: 0, value: 0, data: emptyBytes())

fn msquicFrameImmediateAck(): MsQuicFrame =
    MsQuicFrame(kind: FrameImmediateAck, streamId: 0, offset: 0, value: 0, data: emptyBytes())

fn msquicFrameMaxStreamsBidi(value: int64): MsQuicFrame =
    MsQuicFrame(kind: FrameMaxStreamsBidi, streamId: 0, offset: 0, value: value, data: emptyBytes())

fn msquicFrameMaxStreamsUni(value: int64): MsQuicFrame =
    MsQuicFrame(kind: FrameMaxStreamsUni, streamId: 0, offset: 0, value: value, data: emptyBytes())

fn msquicFramePathResponse(token: Bytes): MsQuicFrame =
    MsQuicFrame(kind: FramePathResponse, streamId: 0, offset: 0, value: 0, data: token)

fn msquicFrameConnectionClose(errCode: int64, frameType: int64, reason: Bytes): MsQuicFrame =
    MsQuicFrame(kind: FrameConnectionClose, streamId: 0, offset: frameType, value: errCode, data: reason)

fn msquicFrameConnectionCloseApp(errCode: int64, reason: Bytes): MsQuicFrame =
    MsQuicFrame(kind: FrameConnectionCloseApp, streamId: 0, offset: 0, value: errCode, data: reason)

fn msquicFrameAckFrequency(seq: int64, ackThreshold: int64, maxDelayUs: int64, reorderThreshold: int64): MsQuicFrame =
    let encRes: Result[Bytes] = quicVarIntEncode(reorderThreshold)
    let data: Bytes = if IsErr(encRes): emptyBytes() else: Value(encRes)
    MsQuicFrame(kind: FrameAckFrequency, streamId: ackThreshold, offset: maxDelayUs, value: seq, data: data)
