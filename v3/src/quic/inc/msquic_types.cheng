# MsQuic public types(port scaffold).

import std/rawbytes
type
    HQUIC = int64

    QUIC_BUFFER =
        length: int32
        data: Bytes

    QUIC_ADDR =
        raw: Bytes

    QUIC_NEW_CONNECTION_INFO =
        quicVersion: int32
        localAddress: QUIC_ADDR
        remoteAddress: QUIC_ADDR
        cryptoBuffer: Bytes
        clientAlpnList: Bytes
        negotiatedAlpn: Bytes
        serverName: str

const
    maxQuicSupportedVersions = 8
    maxQuicTicketKeys = 8
    maxQuicStreamIdTypes = 4
    maxQuicStatisticsV2Sizes = 8
    maxQuicExecutionProcessors = 64
    quicStatisticsV2Size1 = 188
    quicStatisticsV2Size2 = 196
    quicStatisticsV2Size3 = 200
    quicStatisticsV2Size4 = 208

type
    QUIC_SUPPORTED_VERSIONS =
        count: int32
        versions: int32[maxQuicSupportedVersions]

    QUIC_LIBRARY_VERSION =
        major: int32
        minor: int32
        patch: int32
        revision: int32

    QUIC_PERF_COUNTERS =
        connectionsCreated: int64
        connectionsActive: int64
        connectionsClosed: int64
        streamsOpened: int64
        streamsClosed: int64
        streamsActive: int64
        packetsSent: int64
        packetsRecv: int64
        bytesSent: int64
        bytesRecv: int64
        datagramsSent: int64
        datagramsRecv: int64
        datagramBytesSent: int64
        datagramBytesRecv: int64
        packetsDropped: int64
        bytesDropped: int64
        errors: int64

    QUIC_STATISTICS_TIMING =
        start: int64
        initialFlightEnd: int64
        handshakeFlightEnd: int64

    QUIC_STATISTICS_HANDSHAKE =
        clientFlight1Bytes: int32
        serverFlight1Bytes: int32
        clientFlight2Bytes: int32

    QUIC_STATISTICS_SEND =
        pathMtu: int32
        totalPackets: int64
        retransmittablePackets: int64
        suspectedLostPackets: int64
        spuriousLostPackets: int64
        totalBytes: int64
        totalStreamBytes: int64
        congestionCount: int32
        persistentCongestionCount: int32

    QUIC_STATISTICS_RECV =
        totalPackets: int64
        reorderedPackets: int64
        droppedPackets: int64
        duplicatePackets: int64
        totalBytes: int64
        totalStreamBytes: int64
        decryptionFailures: int64
        validAckFrames: int64

    QUIC_STATISTICS_MISC =
        keyUpdateCount: int32

    QUIC_STATISTICS =
        correlationId: int64
        versionNegotiation: bool
        statelessRetry: bool
        resumptionAttempted: bool
        resumptionSucceeded: bool
        rttUs: int32
        minRttUs: int32
        maxRttUs: int32
        timing: QUIC_STATISTICS_TIMING
        handshake: QUIC_STATISTICS_HANDSHAKE
        send: QUIC_STATISTICS_SEND
        recv: QUIC_STATISTICS_RECV
        misc: QUIC_STATISTICS_MISC

    QUIC_STATISTICS_V2 =
        correlationId: int64
        versionNegotiation: bool
        statelessRetry: bool
        resumptionAttempted: bool
        resumptionSucceeded: bool
        greaseBitNegotiated: bool
        ecnCapable: bool
        encryptionOffloaded: bool
        rttUs: int32
        minRttUs: int32
        maxRttUs: int32
        timingStart: int64
        timingInitialFlightEnd: int64
        timingHandshakeFlightEnd: int64
        handshakeClientFlight1Bytes: int32
        handshakeServerFlight1Bytes: int32
        handshakeClientFlight2Bytes: int32
        sendPathMtu: int32
        sendTotalPackets: int64
        sendRetransmittablePackets: int64
        sendSuspectedLostPackets: int64
        sendSpuriousLostPackets: int64
        sendTotalBytes: int64
        sendTotalStreamBytes: int64
        sendCongestionCount: int32
        sendPersistentCongestionCount: int32
        recvTotalPackets: int64
        recvReorderedPackets: int64
        recvDroppedPackets: int64
        recvDuplicatePackets: int64
        recvTotalBytes: int64
        recvTotalStreamBytes: int64
        recvDecryptionFailures: int64
        recvValidAckFrames: int64
        keyUpdateCount: int32
        sendCongestionWindow: int32
        destCidUpdateCount: int32
        sendEcnCongestionCount: int32
        handshakeHopLimitTTL: int32
        rttVariance: int32

    QUIC_MAX_STREAM_IDS =
        ids: int64[maxQuicStreamIdTypes]

    QUIC_STATISTICS_V2_SIZES =
        count: int32
        sizes: int32[maxQuicStatisticsV2Sizes]

    QUIC_GLOBAL_EXECUTION_CONFIG =
        flags: int32
        pollingIdleTimeoutUs: int32
        processorCount: int32
        processorList: int32[maxQuicExecutionProcessors]

    QUIC_NETWORK_STATISTICS =
        bytesInFlight: int32
        postedBytes: int64
        idealBytes: int64
        smoothedRttUs: int64
        congestionWindow: int32
        bandwidth: int64
        bandwidthOut: int64
        bandwidthIn: int64
        deliveryRateOut: int64
        deliveryRateIn: int64

    QUIC_LISTENER_STATISTICS =
        totalAcceptedConnections: int64
        totalRejectedConnections: int64
        bindingRecvDroppedPackets: int64

    QUIC_VERSION_SETTINGS =
        enabled: QUIC_SUPPORTED_VERSIONS
        defaultVersion: int32

    QUIC_TICKET_KEY_CONFIG =
        secretLength: int32
        secret: Bytes
        name: Bytes

    QUIC_TICKET_KEY_CONFIGS =
        count: int32
        keys: QUIC_TICKET_KEY_CONFIG[maxQuicTicketKeys]

    QUIC_SCHANNEL_CREDENTIAL_ATTRIBUTE_W =
        attribute: str
        value: str

    QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_W =
        attribute: str
        value: str

    QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_EX_W =
        attribute: str
        bufferLength: int32
        buffer: Bytes

    QUIC_SCHANNEL_SECURITY_CONTEXT_TOKEN =
        token: Bytes

fn initQuicBuffer(data: Bytes): QUIC_BUFFER =
    var out: QUIC_BUFFER
    out.length = bytesLen(data)
    out.data = data
    return out

fn initQuicAddr(raw: Bytes): QUIC_ADDR =
    var out: QUIC_ADDR
    out.raw = raw
    return out

fn initQuicNewConnectionInfo(): QUIC_NEW_CONNECTION_INFO =
    var out: QUIC_NEW_CONNECTION_INFO
    out.quicVersion = 0
    out.localAddress = initQuicAddr(emptyBytes())
    out.remoteAddress = initQuicAddr(emptyBytes())
    out.cryptoBuffer = emptyBytes()
    out.clientAlpnList = emptyBytes()
    out.negotiatedAlpn = emptyBytes()
    out.serverName = ""
    return out

fn initQuicSupportedVersions(): QUIC_SUPPORTED_VERSIONS =
    var out: QUIC_SUPPORTED_VERSIONS
    out.count = 0
    return out

fn initQuicLibraryVersion(): QUIC_LIBRARY_VERSION =
    var out: QUIC_LIBRARY_VERSION
    out.major = 0
    out.minor = 0
    out.patch = 0
    out.revision = 0
    return out

fn initQuicPerfCounters(): QUIC_PERF_COUNTERS =
    var out: QUIC_PERF_COUNTERS
    out.connectionsCreated = 0
    out.connectionsActive = 0
    out.connectionsClosed = 0
    out.streamsOpened = 0
    out.streamsClosed = 0
    out.streamsActive = 0
    out.packetsSent = 0
    out.packetsRecv = 0
    out.bytesSent = 0
    out.bytesRecv = 0
    out.datagramsSent = 0
    out.datagramsRecv = 0
    out.datagramBytesSent = 0
    out.datagramBytesRecv = 0
    out.packetsDropped = 0
    out.bytesDropped = 0
    out.errors = 0
    return out

fn initQuicStatisticsTiming(): QUIC_STATISTICS_TIMING =
    var out: QUIC_STATISTICS_TIMING
    out.start = 0
    out.initialFlightEnd = 0
    out.handshakeFlightEnd = 0
    return out

fn initQuicStatisticsHandshake(): QUIC_STATISTICS_HANDSHAKE =
    var out: QUIC_STATISTICS_HANDSHAKE
    out.clientFlight1Bytes = 0
    out.serverFlight1Bytes = 0
    out.clientFlight2Bytes = 0
    return out

fn initQuicStatisticsSend(): QUIC_STATISTICS_SEND =
    var out: QUIC_STATISTICS_SEND
    out.pathMtu = 0
    out.totalPackets = 0
    out.retransmittablePackets = 0
    out.suspectedLostPackets = 0
    out.spuriousLostPackets = 0
    out.totalBytes = 0
    out.totalStreamBytes = 0
    out.congestionCount = 0
    out.persistentCongestionCount = 0
    return out

fn initQuicStatisticsRecv(): QUIC_STATISTICS_RECV =
    var out: QUIC_STATISTICS_RECV
    out.totalPackets = 0
    out.reorderedPackets = 0
    out.droppedPackets = 0
    out.duplicatePackets = 0
    out.totalBytes = 0
    out.totalStreamBytes = 0
    out.decryptionFailures = 0
    out.validAckFrames = 0
    return out

fn initQuicStatisticsMisc(): QUIC_STATISTICS_MISC =
    var out: QUIC_STATISTICS_MISC
    out.keyUpdateCount = 0
    return out

fn initQuicStatistics(): QUIC_STATISTICS =
    var out: QUIC_STATISTICS
    out.correlationId = 0
    out.versionNegotiation = false
    out.statelessRetry = false
    out.resumptionAttempted = false
    out.resumptionSucceeded = false
    out.rttUs = 0
    out.minRttUs = 0
    out.maxRttUs = 0
    out.timing = initQuicStatisticsTiming()
    out.handshake = initQuicStatisticsHandshake()
    out.send = initQuicStatisticsSend()
    out.recv = initQuicStatisticsRecv()
    out.misc = initQuicStatisticsMisc()
    return out

fn initQuicStatisticsV2(): QUIC_STATISTICS_V2 =
    var out: QUIC_STATISTICS_V2
    out.correlationId = 0
    out.versionNegotiation = false
    out.statelessRetry = false
    out.resumptionAttempted = false
    out.resumptionSucceeded = false
    out.greaseBitNegotiated = false
    out.ecnCapable = false
    out.encryptionOffloaded = false
    out.rttUs = 0
    out.minRttUs = 0
    out.maxRttUs = 0
    out.timingStart = 0
    out.timingInitialFlightEnd = 0
    out.timingHandshakeFlightEnd = 0
    out.handshakeClientFlight1Bytes = 0
    out.handshakeServerFlight1Bytes = 0
    out.handshakeClientFlight2Bytes = 0
    out.sendPathMtu = 0
    out.sendTotalPackets = 0
    out.sendRetransmittablePackets = 0
    out.sendSuspectedLostPackets = 0
    out.sendSpuriousLostPackets = 0
    out.sendTotalBytes = 0
    out.sendTotalStreamBytes = 0
    out.sendCongestionCount = 0
    out.sendPersistentCongestionCount = 0
    out.recvTotalPackets = 0
    out.recvReorderedPackets = 0
    out.recvDroppedPackets = 0
    out.recvDuplicatePackets = 0
    out.recvTotalBytes = 0
    out.recvTotalStreamBytes = 0
    out.recvDecryptionFailures = 0
    out.recvValidAckFrames = 0
    out.keyUpdateCount = 0
    out.sendCongestionWindow = 0
    out.destCidUpdateCount = 0
    out.sendEcnCongestionCount = 0
    out.handshakeHopLimitTTL = 0
    out.rttVariance = 0
    return out

fn initQuicMaxStreamIds(): QUIC_MAX_STREAM_IDS =
    var out: QUIC_MAX_STREAM_IDS
    return out

fn initQuicStatisticsV2Sizes(): QUIC_STATISTICS_V2_SIZES =
    var out: QUIC_STATISTICS_V2_SIZES
    out.count = 4
    out.sizes[0] = quicStatisticsV2Size1
    out.sizes[1] = quicStatisticsV2Size2
    out.sizes[2] = quicStatisticsV2Size3
    out.sizes[3] = quicStatisticsV2Size4
    return out

fn initQuicGlobalExecutionConfig(): QUIC_GLOBAL_EXECUTION_CONFIG =
    var out: QUIC_GLOBAL_EXECUTION_CONFIG
    out.flags = 0
    out.pollingIdleTimeoutUs = 0
    out.processorCount = 0
    return out

fn initQuicNetworkStatistics(): QUIC_NETWORK_STATISTICS =
    var out: QUIC_NETWORK_STATISTICS
    out.bytesInFlight = 0
    out.postedBytes = 0
    out.idealBytes = 0
    out.smoothedRttUs = 0
    out.congestionWindow = 0
    out.bandwidth = 0
    out.bandwidthOut = 0
    out.bandwidthIn = 0
    out.deliveryRateOut = 0
    out.deliveryRateIn = 0
    return out

fn initQuicListenerStatistics(): QUIC_LISTENER_STATISTICS =
    var out: QUIC_LISTENER_STATISTICS
    out.totalAcceptedConnections = 0
    out.totalRejectedConnections = 0
    out.bindingRecvDroppedPackets = 0
    return out

fn initQuicVersionSettings(): QUIC_VERSION_SETTINGS =
    var out: QUIC_VERSION_SETTINGS
    out.enabled = initQuicSupportedVersions()
    out.defaultVersion = 0
    return out

fn initQuicTicketKeyConfig(): QUIC_TICKET_KEY_CONFIG =
    var out: QUIC_TICKET_KEY_CONFIG
    out.secretLength = 0
    out.secret = emptyBytes()
    out.name = emptyBytes()
    return out

fn initQuicTicketKeyConfigs(): QUIC_TICKET_KEY_CONFIGS =
    var out: QUIC_TICKET_KEY_CONFIGS
    out.count = 0
    return out

fn initQuicSchannelCredentialAttribute(): QUIC_SCHANNEL_CREDENTIAL_ATTRIBUTE_W =
    var out: QUIC_SCHANNEL_CREDENTIAL_ATTRIBUTE_W
    out.attribute = ""
    out.value = ""
    return out

fn initQuicSchannelContextAttribute(): QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_W =
    var out: QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_W
    out.attribute = ""
    out.value = ""
    return out

fn initQuicSchannelContextAttributeEx(): QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_EX_W =
    var out: QUIC_SCHANNEL_CONTEXT_ATTRIBUTE_EX_W
    out.attribute = ""
    out.bufferLength = 0
    out.buffer = emptyBytes()
    return out

fn initQuicSchannelSecurityContextToken(): QUIC_SCHANNEL_SECURITY_CONTEXT_TOKEN =
    var out: QUIC_SCHANNEL_SECURITY_CONTEXT_TOKEN
    out.token = emptyBytes()
    return out
