# Local MultiAddress implementation for Cheng-QUIC.
#
# This module intentionally avoids std/multiformats/multiaddress so ZRPC
# no-pointer std policy does not pull non-exempt std crypto chains.

import std/result
import std/strings as ustrings
import std/rawbytes
import std/os as os

type
    MultiAddress =
        raw: str
        data: Bytes

    SegmentRead =
        seg: str
        next: int32

    HostPortPair =
        host: str
        port: str

const
    quicAddrTagMagic = 0x51
    quicAddrKindUnknown = 0
    quicAddrKindMsQuic = 1
    quicAddrKindQuic = 2
    quicAddrKindQuicTls = 3
    quicAddrAfInet6Linux = 10
    quicAddrAfInet6Bsd = 30

fn protoCodeByName(name: str): Result[int64] =
    if name == "ip4": return Ok[int64](0x04)
    if name == "ip6": return Ok[int64](0x29)
    if name == "ip6zone": return Ok[int64](0x2A)
    if name == "dccp": return Ok[int64](0x21)
    if name == "sctp": return Ok[int64](0x84)
    if name == "udt": return Ok[int64](0x012D)
    if name == "utp": return Ok[int64](0x012E)
    if name == "tcp": return Ok[int64](0x06)
    if name == "udp": return Ok[int64](0x0111)
    if name == "dns": return Ok[int64](0x35)
    if name == "dns4": return Ok[int64](0x36)
    if name == "dns6": return Ok[int64](0x37)
    if name == "dnsaddr": return Ok[int64](0x38)
    if name == "unix": return Ok[int64](0x0190)
    if name == "http": return Ok[int64](0x01E0)
    if name == "https": return Ok[int64](0x01BB)
    if name == "tls": return Ok[int64](0x01C0)
    if name == "quic": return Ok[int64](0x01CC)
    if name == "quic-v1": return Ok[int64](0x01CD)
    if name == "webtransport": return Ok[int64](0x01D1)
    if name == "certhash": return Ok[int64](0x01D2)
    if name == "ws": return Ok[int64](0x01DD)
    if name == "wss": return Ok[int64](0x01DE)
    if name == "p2p-circuit": return Ok[int64](0x0122)
    if name == "p2p-websocket-star": return Ok[int64](0x01DF)
    if name == "p2p-webrtc-star": return Ok[int64](0x0113)
    if name == "p2p-webrtc-direct": return Ok[int64](0x0114)
    if name == "webrtc-direct": return Ok[int64](0x0118)
    if name == "onion": return Ok[int64](0x01BC)
    if name == "onion3": return Ok[int64](0x01BD)
    if name == "ipfs": return Ok[int64](0xE3)
    if name == "p2p": return Ok[int64](0x01A5)
    if name == "memory": return Ok[int64](0x0309)
    return Err[int64]("multiaddress: unknown protocol")

fn protoSizeByCode(code: int64): int32 =
    if code == 0x04:
        return 4
    if code == 0x29:
        return 16
    if code == 0x06:
        return 2
    if code == 0x0111:
        return 2
    if code == 0x21:
        return 2
    if code == 0x84:
        return 2
    if code == 0x012D:
        return 0
    if code == 0x012E:
        return 0
    if code == 0x01E0:
        return 0
    if code == 0x01BB:
        return 0
    if code == 0x01C0:
        return 0
    if code == 0x01CC:
        return 0
    if code == 0x01CD:
        return 0
    if code == 0x01D1:
        return 0
    if code == 0x01DD:
        return 0
    if code == 0x01DE:
        return 0
    if code == 0x0122:
        return 0
    if code == 0x01DF:
        return 0
    if code == 0x0113:
        return 0
    if code == 0x0114:
        return 0
    if code == 0x0118:
        return 0
    if code == 0x2A:
        return -1
    if code == 0x35:
        return -1
    if code == 0x36:
        return -1
    if code == 0x37:
        return -1
    if code == 0x38:
        return -1
    if code == 0x0190:
        return -1
    if code == 0x01D2:
        return -1
    if code == 0x01BC:
        return -1
    if code == 0x01BD:
        return -1
    if code == 0xE3:
        return -1
    if code == 0x01A5:
        return -1
    if code == 0x0309:
        return -1
    return -2

fn readSegment(text: str, start: int32): Result[SegmentRead] =
    if start >= len(text):
        return Err[SegmentRead]("multiaddress: trailing slash")
    var i: int32 = start
    while i < len(text):
        if text[i] == '/':
            break
        i = i + 1
    let seg: str = ustrings.SliceBytes(text, start, i - start)
    var next: int32 = i
    if i < len(text):
        if text[i] == '/':
            next = i + 1
    var out: SegmentRead
    out.seg = seg
    out.next = next
    return Ok[SegmentRead](out)

fn parseUIntRange(text: str, start: int32, count: int32): Result[int32] =
    if count <= 0:
        return Err[int32]("multiaddress: empty number")
    var value: int32 = 0
    for i in 0..<count:
        let c: char = text[start + i]
        if c < '0' || c > '9':
            return Err[int32]("multiaddress: invalid number")
        value = value * 10 + (int32(c) - int32('0'))
    return Ok[int32](value)

fn parsePort(text: str): Result[Bytes] =
    let valueRes: Result[int32] = parseUIntRange(text, 0, len(text))
    if IsErr(valueRes):
        return Err[Bytes](ErrorText(valueRes))
    let value: int32 = Value(valueRes)
    if value < 0 || value > 65535:
        return Err[Bytes]("multiaddress: invalid port")
    var out: Bytes = bytesAlloc(2)
    bytesSet(out, 0, (value >> 8) & 255)
    bytesSet(out, 1, value & 255)
    return Ok[Bytes](out)

fn parseIPv4(text: str): Result[Bytes] =
    var out: Bytes = bytesAlloc(4)
    var start: int32 = 0
    var parts: int32 = 0
    for i in 0..<len(text):
        if text[i] == '.':
            let count: int32 = i - start
            let partRes: Result[int32] = parseUIntRange(text, start, count)
            if IsErr(partRes):
                return Err[Bytes](ErrorText(partRes))
            let value: int32 = Value(partRes)
            if value < 0 || value > 255:
                return Err[Bytes]("multiaddress: ip4 out of range")
            if parts >= 4:
                return Err[Bytes]("multiaddress: ip4 parts")
            bytesSet(out, parts, value)
            parts = parts + 1
            start = i + 1
    let tailCount: int32 = len(text) - start
    let tailRes: Result[int32] = parseUIntRange(text, start, tailCount)
    if IsErr(tailRes):
        return Err[Bytes](ErrorText(tailRes))
    let tailValue: int32 = Value(tailRes)
    if tailValue < 0 || tailValue > 255:
        return Err[Bytes]("multiaddress: ip4 out of range")
    if parts >= 4:
        return Err[Bytes]("multiaddress: ip4 parts")
    bytesSet(out, parts, tailValue)
    parts = parts + 1
    if parts != 4:
        return Err[Bytes]("multiaddress: ip4 parts")
    return Ok[Bytes](out)

fn hexValue(c: char): int32 =
    if c >= '0' && c <= '9':
        return int32(c) - int32('0')
    if c >= 'a' && c <= 'f':
        return 10 + (int32(c) - int32('a'))
    if c >= 'A' && c <= 'F':
        return 10 + (int32(c) - int32('A'))
    return -1

fn parseHexSegment(text: str, start: int32, count: int32): Result[int32] =
    if count <= 0 || count > 4:
        return Err[int32]("multiaddress: ip6 part length")
    var value: int32 = 0
    for i in 0..<count:
        let v: int32 = hexValue(text[start + i])
        if v < 0:
            return Err[int32]("multiaddress: ip6 invalid hex")
        value = (value << 4) + v
    return Ok[int32](value)

fn quicWriteHextet(buf: var Bytes, idx: int32, value: int32) =
    bytesSet(buf, idx * 2, (value >> 8) & 255)
    bytesSet(buf, idx * 2 + 1, value & 255)

fn parseIPv6(text: str): Result[Bytes] =
    if len(text) <= 0:
        return Err[Bytes]("multiaddress: ip6 empty")
    var out: Bytes = bytesAlloc(16)
    let bsdRc: int32 = os.udpInetPton(quicAddrAfInet6Bsd, text, out)
    if bsdRc == 1:
        return Ok[Bytes](out)
    let linuxRc: int32 = os.udpInetPton(quicAddrAfInet6Linux, text, out)
    if linuxRc == 1:
        return Ok[Bytes](out)
    return Err[Bytes]("multiaddress: invalid ipv6")

fn splitHostPort(text: str): Result[HostPortPair] =
    if len(text) <= 0:
        return Err[HostPortPair]("multiaddress: empty host:port")
    if text[0] == '[':
        var close: int32 = 1
        while close < len(text):
            if text[close] == ']':
                break
            close = close + 1
        if close >= len(text):
            return Err[HostPortPair]("multiaddress: invalid ipv6 host:port")
        if close + 1 >= len(text):
            return Err[HostPortPair]("multiaddress: invalid ipv6 host:port")
        if text[close + 1] != ':':
            return Err[HostPortPair]("multiaddress: invalid ipv6 host:port")
        var out: HostPortPair
        out.host = ustrings.SliceBytes(text, 1, close - 1)
        out.port = ustrings.SliceBytes(text, close + 2, len(text) - (close + 2))
        return Ok[HostPortPair](out)
    var colon: int32 = -1
    for i in 0..<len(text):
        if text[i] == ':':
            colon = i
    if colon <= 0 || colon >= len(text) - 1:
        return Err[HostPortPair]("multiaddress: invalid host:port")
    var out2: HostPortPair
    out2.host = ustrings.SliceBytes(text, 0, colon)
    out2.port = ustrings.SliceBytes(text, colon + 1, len(text) - (colon + 1))
    return Ok[HostPortPair](out2)

fn parseProtocolValue(protoCode: int64, value: str): Result[Bytes] =
    if protoCode == 0x04:
        return parseIPv4(value)
    if protoCode == 0x29:
        return parseIPv6(value)
    if protoCode == 0x06:
        return parsePort(value)
    if protoCode == 0x0111:
        return parsePort(value)
    if protoCode == 0x21:
        return parsePort(value)
    if protoCode == 0x84:
        return parsePort(value)
    if len(value) <= 0:
        return Err[Bytes]("multiaddress: empty value")
    return Ok[Bytes](bytesFromString(value))

fn parseMultiAddress(text: str): Result[MultiAddress] =
    if len(text) <= 0:
        return Err[MultiAddress]("multiaddress: empty")
    if text[0] != '/':
        return Err[MultiAddress]("multiaddress: must start with '/'")
    var idx: int32 = 1
    while idx < len(text):
        let segRes: Result[SegmentRead] = readSegment(text, idx)
        if IsErr(segRes):
            return Err[MultiAddress](ErrorText(segRes))
        let seg: SegmentRead = Value(segRes)
        let protoCodeRes: Result[int64] = protoCodeByName(seg.seg)
        if IsErr(protoCodeRes):
            return Err[MultiAddress](ErrorText(protoCodeRes))
        let protoCode: int64 = Value(protoCodeRes)
        let protoSize: int32 = protoSizeByCode(protoCode)
        if protoSize < -1:
            return Err[MultiAddress]("multiaddress: unknown protocol")
        idx = seg.next
        if protoSize == 0:
            continue
        if idx >= len(text):
            return Err[MultiAddress]("multiaddress: missing value")
        let valSegRes: Result[SegmentRead] = readSegment(text, idx)
        if IsErr(valSegRes):
            return Err[MultiAddress](ErrorText(valSegRes))
        let valSeg: SegmentRead = Value(valSegRes)
        let valueBytesRes: Result[Bytes] = parseProtocolValue(protoCode, valSeg.seg)
        if IsErr(valueBytesRes):
            return Err[MultiAddress](ErrorText(valueBytesRes))
        let valueBytes: Bytes = Value(valueBytesRes)
        if protoSize > 0 && bytesLen(valueBytes) != protoSize:
            return Err[MultiAddress]("multiaddress: size mismatch")
        idx = valSeg.next
    var out: MultiAddress
    out.raw = text
    out.data = bytesFromString(text)
    return Ok[MultiAddress](out)

fn parseMultiAddressBytes(data: Bytes): Result[MultiAddress] =
    if bytesLen(data) <= 0:
        return Err[MultiAddress]("multiaddress: empty")
    let text: str = bytesToString(data)
    let parsedRes: Result[MultiAddress] = parseMultiAddress(text)
    if IsErr(parsedRes):
        return Err[MultiAddress](ErrorText(parsedRes))
    var out: MultiAddress = Value(parsedRes)
    out.data = data
    return Ok[MultiAddress](out)

fn quicMultiAddressToString(addr: MultiAddress): str =
    if len(addr.raw) > 0:
        return addr.raw
    if bytesLen(addr.data) > 0:
        return bytesToString(addr.data)
    return ""

fn quicMultiAddressBindText(addr: MultiAddress): str =
    return quicMultiAddressToString(addr)

fn quicMultiAddressToBytes(addr: MultiAddress): Bytes =
    if bytesLen(addr.data) > 0:
        return addr.data
    if len(addr.raw) <= 0:
        return emptyBytes()
    return bytesFromString(addr.raw)

fn makeInprocMultiAddress(kind: int32, port: int32): MultiAddress =
    var safeKind: int32 = kind
    if safeKind < quicAddrKindMsQuic || safeKind > quicAddrKindQuicTls:
        safeKind = quicAddrKindMsQuic
    var safePort: int32 = port
    if safePort < 0:
        safePort = 0
    if safePort > 65535:
        safePort = 65535
    var out: MultiAddress
    out.raw = ""
    out.data = bytesAlloc(4)
    bytesSet(out.data, 0, quicAddrTagMagic)
    bytesSet(out.data, 1, safeKind)
    bytesSet(out.data, 2, (safePort >> 8) & 0xff)
    bytesSet(out.data, 3, safePort & 0xff)
    return out

fn bytesContains(haystack: Bytes, needle: Bytes): bool =
    let hayLen: int32 = bytesLen(haystack)
    let needleLen: int32 = bytesLen(needle)
    if hayLen <= 0 || needleLen <= 0 || needleLen > hayLen:
        return false
    for i in 0..<(hayLen - needleLen + 1):
        var same: bool = true
        for j in 0..<needleLen:
            if bytesGet(haystack, i + j) != bytesGet(needle, j):
                same = false
                break
        if same:
            return true
    return false

fn quicMultiAddressKind(addr: MultiAddress): int32 =
    if bytesLen(addr.data) >= 2:
        if bytesGet(addr.data, 0) == quicAddrTagMagic:
            return bytesGet(addr.data, 1)
    let data: Bytes = quicMultiAddressToBytes(addr)
    if bytesContains(data, bytesFromString("/quic-v1/tls")):
        return quicAddrKindQuicTls
    if bytesContains(data, bytesFromString("/quic-v1")):
        return quicAddrKindMsQuic
    if bytesContains(data, bytesFromString("/quic")):
        return quicAddrKindQuic
    return quicAddrKindUnknown

fn quicMultiAddressPort(addr: MultiAddress): int32 =
    if bytesLen(addr.data) >= 4:
        if bytesGet(addr.data, 0) == quicAddrTagMagic:
            return (bytesGet(addr.data, 2) << 8) | bytesGet(addr.data, 3)
    return 0
