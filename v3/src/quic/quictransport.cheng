# QUIC transport adapter (delegates to MsQuicTransport).

import std/result
import cheng/v3/quic/multiaddress
import cheng/v3/quic/connection
import cheng/v3/quic/msquictransport

type
    QuicTransport =
        msquic: MsQuicTransport

fn initQuicTransport(): QuicTransport =
    QuicTransport(msquic: initMsQuicTransport())

fn start(t: var QuicTransport, addr: MultiAddress) =
    start(t.msquic, addr)

fn stop(t: var QuicTransport) =
    stop(t.msquic)

fn accept(t: var QuicTransport): Result[Connection] =
    return accept(t.msquic)

fn handles(t: QuicTransport, addr: MultiAddress): bool =
    if ! handles(t.msquic, addr):
        return false
    return quicMultiAddressKind(addr) == quicAddrKindQuic

fn dial(t: var QuicTransport, addr: MultiAddress): Result[Connection] =
    if ! handles(t, addr):
        return Err[Connection]("quictransport: unsupported address")
    return dial(t.msquic, addr)

fn dropQuicPendingByPipe(t: QuicTransport, addr: MultiAddress, pipeIdx: int32): Result[bool] =
    return dropMsQuicPendingByPipe(t.msquic, addr, pipeIdx)
