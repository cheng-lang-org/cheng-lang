import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/binary_types as binary
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/pubsub
import cheng/v3/chain/dag_mempool as dag
import cheng/v3/chain/erasure_swarm as swarm
import cheng/v3/chain/content_plane as content
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types as core
import cheng/v3/libp2p/host/host
import cheng/v3/libp2p/protocols/gossipsub as gossip

fn v3Libp2pScoreNeighbor(candidate: overlay.V3NeighborCandidate): int64 =
    let scoreInput = candidate.scoreInput
    return overlay.v3OverlayTrustScore(scoreInput)

fn v3Libp2pSelectNextHop(candidates: overlay.V3NeighborCandidate[]): Result[core.V3Libp2pPeerId] =
    var bestScore: int64 = int64(0)
    var found = false
    var bestPeerValue: layout.FixedBytes32
    for i in 0..<candidates.len:
        let candidate = candidates[i]
        if !overlay.v3OverlayNeighborEligible(candidate):
            continue
        let score = v3Libp2pScoreNeighbor(candidate)
        if !found || score < bestScore:
            found = true
            bestScore = score
            bestPeerValue = candidate.peerId
    if !found:
        return Err[core.V3Libp2pPeerId]("v3 overlay libp2p: no eligible next hop")
    let bestPeer = core.V3Libp2pPeerId(value: bestPeerValue)
    return Ok[core.V3Libp2pPeerId](bestPeer)

fn v3Libp2pRelayPublish(hostState: var host.V3Libp2pHost,
                        ingress: overlay.V3IngressEnvelope) =
    let sourcePeerId = hostState.selfPeerId
    var pubEntry: gossip.V3Libp2pPubRecord
    gossip.v3Libp2pPubRecordFillFromIngress(pubEntry, sourcePeerId, ingress)
    host.v3Libp2pPublish(hostState, pubEntry)
    host.v3Libp2pStorePut(hostState, ingress)

fn v3Libp2pTopicId(scope: overlay.V3OverlayTopicScope,
                   address: binary.V3LsmrAddress): core.V3Libp2pTopicId =
    return gossip.v3Libp2pTopicForScope(scope, address)

fn v3Libp2pScopeFromLayerId(layerId: int32): overlay.V3OverlayTopicScope =
    if layerId == lt.v3LayerGlobal:
        return overlay.v3OverlayScopeGlobal
    if layerId == lt.v3LayerRegional:
        return overlay.v3OverlayScopeRegion
    return overlay.v3OverlayScopeCell

fn v3Libp2pIngressMake(sourcePeerId: core.V3Libp2pPeerId,
                       scope: overlay.V3OverlayTopicScope,
                       address: binary.V3LsmrAddress,
                       payloadKind: int32,
                       payloadCid: layout.FixedBytes32,
                       payload: Bytes,
                       stampEpoch: int32,
                       stampGanzhi: int32): overlay.V3IngressEnvelope =
    var out = overlay.v3OverlayIngressEnvelopeZero()
    out.sourcePeerId = sourcePeerId.value
    out.topicScope = scope
    out.address = address
    out.payloadKind = payloadKind
    out.payload = payload
    out.payloadCid = payloadCid
    out.payloadLen = bytesLen(payload)
    out.stampEpoch = stampEpoch
    out.stampGanzhi = stampGanzhi
    return out

fn v3Libp2pRelayPublishContent(hostState: var host.V3Libp2pHost,
                               artifacts: content.V3ContentPublishArtifacts): Result[bool] =
    let artifactsOk = content.v3ContentPublishArtifactsValidate(artifacts)
    if IsErr(artifactsOk):
        return Err[bool](Error(artifactsOk))
    let stubRes = content.v3ContentStubFromArtifacts(artifacts)
    if IsErr(stubRes):
        return Err[bool](Error(stubRes))
    let stub = Value(stubRes)
    let scope = v3Libp2pScopeFromLayerId(artifacts.topic.layerId)
    let address = artifacts.topic.centerAddress
    let sourcePeerId = hostState.selfPeerId
    let stampEpoch = artifacts.publishAdvert.stampEpoch
    let stampGanzhi = artifacts.publishAdvert.stampGanzhi
    let manifestPayload = swarm.v3ErasureShardManifestEncode(artifacts.erasureManifest)
    let manifestPayloadOk = swarm.v3ErasureShardManifestValidatePayload(manifestPayload,
                                                                        artifacts.erasureManifest.manifestCid)
    if IsErr(manifestPayloadOk):
        return Err[bool](Error(manifestPayloadOk))
    let recoveryPlanPayload = swarm.v3ErasureRecoveryPlanEncode(artifacts.recoveryPlan)
    let recoveryPlanPayloadOk = swarm.v3ErasureRecoveryPlanValidatePayload(recoveryPlanPayload,
                                                                           artifacts.recoveryPlan.planCid)
    if IsErr(recoveryPlanPayloadOk):
        return Err[bool](Error(recoveryPlanPayloadOk))

    let stubIngress = v3Libp2pIngressMake(sourcePeerId,
                                          scope,
                                          address,
                                          pubsub.v3PubSubPayloadKindContentStub,
                                          stub.stubCid,
                                          content.v3ContentStubEncode(stub),
                                          stampEpoch,
                                          stampGanzhi)
    let advertIngress = v3Libp2pIngressMake(sourcePeerId,
                                            scope,
                                            address,
                                            pubsub.v3PubSubPayloadKindDagAdvert,
                                            artifacts.publishAdvert.advertCid,
                                            dag.v3DagPublishAdvertEncode(artifacts.publishAdvert),
                                            stampEpoch,
                                            stampGanzhi)
    let manifestIngress = v3Libp2pIngressMake(sourcePeerId,
                                              scope,
                                              address,
                                              pubsub.v3PubSubPayloadKindErasureManifest,
                                              artifacts.erasureManifest.manifestCid,
                                              manifestPayload,
                                              stampEpoch,
                                              stampGanzhi)
    let recoveryPlanIngress = v3Libp2pIngressMake(sourcePeerId,
                                                  scope,
                                                  address,
                                                  pubsub.v3PubSubPayloadKindErasureRecoveryPlan,
                                                  artifacts.recoveryPlan.planCid,
                                                  recoveryPlanPayload,
                                                  stampEpoch,
                                                  stampGanzhi)

    v3Libp2pRelayPublish(hostState, stubIngress)
    host.v3Libp2pStorePut(hostState, advertIngress)
    host.v3Libp2pStorePut(hostState, manifestIngress)
    host.v3Libp2pStorePut(hostState, recoveryPlanIngress)
    host.v3Libp2pKadProvide(hostState, artifacts.bundleCid)
    host.v3Libp2pKadProvide(hostState, artifacts.blobSummary.blobCid)
    host.v3Libp2pKadProvide(hostState, artifacts.erasureManifest.manifestCid)
    return Ok[bool](true)
