import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr_types as lt

const
    v3CsgNodeKindSource: int32 = 1
    v3CsgNodeKindRewrite: int32 = 2
    v3CsgNodeKindSink: int32 = 3

    v3CsgCapabilityPure: int32 = 1
    v3CsgCapabilityRead: int32 = 2
    v3CsgCapabilityEmit: int32 = 3
    v3CsgCapabilityRoute: int32 = 4
    v3CsgCapabilityMerge: int32 = 5
    v3CsgCapabilitySensor: int32 = 6
    v3CsgCapabilityRegionalBatch: int32 = 7
    v3CsgCapabilityGlobalAnchor: int32 = 8
    v3CsgCapabilityPtrWrite: int32 = 9
    v3CsgCapabilityRawmemWrite: int32 = 10
    v3CsgCapabilityImportc: int32 = 11
    v3CsgCapabilityFsWrite: int32 = 12
    v3CsgCapabilityNetAdmin: int32 = 13

    v3CsgEdgeKindData: int32 = 1
    v3CsgEdgeKindEmit: int32 = 2
    v3CsgEdgeKindUnsafeWrite: int32 = 3

    v3CsgBarrierModeObserve: int32 = 1
    v3CsgBarrierModeGen: int32 = 2

    v3CsgReasonOk: int32 = 1
    v3CsgReasonDeniedCapability: int32 = 2
    v3CsgReasonUnsupportedCapability: int32 = 3
    v3CsgReasonUnsafeEdge: int32 = 4

type
    V3CsgSubgraph =
        version: int32
        graphKeyId: int32
        nodeCount: int32
        edgeCount: int32
        nodeIds: int32[]
        nodeKinds: int32[]
        nodeCapabilities: int32[]
        nodePayloadCids: layout.FixedBytes32[]
        edgeFromIds: int32[]
        edgeToIds: int32[]
        edgeKinds: int32[]
        graphCid: layout.FixedBytes32

    V3CsgDelta =
        version: int32
        baseGraphCid: layout.FixedBytes32
        subgraphCid: layout.FixedBytes32
        nodeCount: int32
        edgeCount: int32
        deltaCid: layout.FixedBytes32

    V3CsgBarrierFilter =
        version: int32
        layerId: int32
        modeId: int32
        allowedCapabilities: int32[]
        deniedCapabilities: int32[]
        filterCid: layout.FixedBytes32

    V3CsgFilterDecision =
        version: int32
        accepted: bool
        reasonCode: int32
        acceptedNodeCount: int32
        deniedNodeIds: int32[]
        decisionCid: layout.FixedBytes32

fn v3CsgSubgraphZero(): V3CsgSubgraph =
    var out: V3CsgSubgraph
    out.version = 1
    out.nodeIds = []
    out.nodeKinds = []
    out.nodeCapabilities = []
    out.nodePayloadCids = []
    out.edgeFromIds = []
    out.edgeToIds = []
    out.edgeKinds = []
    out.graphCid = layout.fixedBytes32Zero()
    return out

fn v3CsgDeltaZero(): V3CsgDelta =
    var out: V3CsgDelta
    out.version = 1
    out.baseGraphCid = layout.fixedBytes32Zero()
    out.subgraphCid = layout.fixedBytes32Zero()
    out.deltaCid = layout.fixedBytes32Zero()
    return out

fn v3CsgBarrierFilterZero(): V3CsgBarrierFilter =
    var out: V3CsgBarrierFilter
    out.version = 1
    out.allowedCapabilities = []
    out.deniedCapabilities = []
    out.filterCid = layout.fixedBytes32Zero()
    return out

fn v3CsgFilterDecisionZero(): V3CsgFilterDecision =
    var out: V3CsgFilterDecision
    out.version = 1
    out.accepted = true
    out.reasonCode = v3CsgReasonOk
    out.deniedNodeIds = []
    out.decisionCid = layout.fixedBytes32Zero()
    return out

fn v3CsgNodeLess(aId: int32, aKind: int32, bId: int32, bKind: int32): bool =
    if aId != bId:
        return aId < bId
    return aKind < bKind

fn v3CsgEdgeLess(aFrom: int32, aTo: int32, aKind: int32,
                 bFrom: int32, bTo: int32, bKind: int32): bool =
    if aFrom != bFrom:
        return aFrom < bFrom
    if aTo != bTo:
        return aTo < bTo
    return aKind < bKind

fn v3CsgSortNodes(nodeIds: var int32[],
                  nodeKinds: var int32[],
                  nodeCapabilities: var int32[],
                  nodePayloadCids: var layout.FixedBytes32[]) =
    for i in 1..<nodeIds.len:
        let nodeId = nodeIds[i]
        let nodeKind = nodeKinds[i]
        let capability = nodeCapabilities[i]
        let payloadCid = nodePayloadCids[i]
        var j = i - 1
        while j >= 0:
            if !v3CsgNodeLess(nodeId, nodeKind, nodeIds[j], nodeKinds[j]):
                break
            nodeIds[j + 1] = nodeIds[j]
            nodeKinds[j + 1] = nodeKinds[j]
            nodeCapabilities[j + 1] = nodeCapabilities[j]
            nodePayloadCids[j + 1] = nodePayloadCids[j]
            j = j - 1
        nodeIds[j + 1] = nodeId
        nodeKinds[j + 1] = nodeKind
        nodeCapabilities[j + 1] = capability
        nodePayloadCids[j + 1] = payloadCid

fn v3CsgSortEdges(edgeFromIds: var int32[],
                  edgeToIds: var int32[],
                  edgeKinds: var int32[]) =
    for i in 1..<edgeFromIds.len:
        let edgeFromId = edgeFromIds[i]
        let edgeToId = edgeToIds[i]
        let edgeKind = edgeKinds[i]
        var j = i - 1
        while j >= 0:
            if !v3CsgEdgeLess(edgeFromId, edgeToId, edgeKind, edgeFromIds[j], edgeToIds[j], edgeKinds[j]):
                break
            edgeFromIds[j + 1] = edgeFromIds[j]
            edgeToIds[j + 1] = edgeToIds[j]
            edgeKinds[j + 1] = edgeKinds[j]
            j = j - 1
        edgeFromIds[j + 1] = edgeFromId
        edgeToIds[j + 1] = edgeToId
        edgeKinds[j + 1] = edgeKind

fn v3CsgNodePos(nodeIds: int32[], nodeId: int32): int32 =
    for i in 0..<nodeIds.len:
        if nodeIds[i] == nodeId:
            return i
    return -1

fn v3CsgCapabilityIn(values: int32[], value: int32): bool =
    for i in 0..<values.len:
        if values[i] == value:
            return true
    return false

fn v3CsgPushUniqueNodeId(values: var int32[], value: int32) =
    if v3CsgCapabilityIn(values, value):
        return
    add(values, value)

fn v3CsgSubgraphCid(graphKeyId: int32,
                    nodeIds: int32[],
                    nodeKinds: int32[],
                    nodeCapabilities: int32[],
                    nodePayloadCids: layout.FixedBytes32[],
                    edgeFromIds: int32[],
                    edgeToIds: int32[],
                    edgeKinds: int32[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.csg.subgraph"))
    lt.v3AppendU32BE(buf, graphKeyId)
    lt.v3AppendU32BE(buf, nodeIds.len)
    for i in 0..<nodeIds.len:
        lt.v3AppendU32BE(buf, nodeIds[i])
        lt.v3AppendU32BE(buf, nodeKinds[i])
        lt.v3AppendU32BE(buf, nodeCapabilities[i])
        lt.v3AppendFixed32(buf, nodePayloadCids[i])
    lt.v3AppendU32BE(buf, edgeFromIds.len)
    for i in 0..<edgeFromIds.len:
        lt.v3AppendU32BE(buf, edgeFromIds[i])
        lt.v3AppendU32BE(buf, edgeToIds[i])
        lt.v3AppendU32BE(buf, edgeKinds[i])
    return lt.v3FixedCidFromBuf(buf)

fn v3BuildCsgSubgraph(graphKeyId: int32,
                      nodeIds: int32[],
                      nodeKinds: int32[],
                      nodeCapabilities: int32[],
                      nodePayloadCids: layout.FixedBytes32[],
                      edgeFromIds: int32[],
                      edgeToIds: int32[],
                      edgeKinds: int32[]): Result[V3CsgSubgraph] =
    if graphKeyId <= 0:
        return Err[V3CsgSubgraph]("v3 csg: missing graph key")
    if nodeIds.len != nodeKinds.len || nodeIds.len != nodeCapabilities.len || nodeIds.len != nodePayloadCids.len:
        return Err[V3CsgSubgraph]("v3 csg: node column mismatch")
    if edgeFromIds.len != edgeToIds.len || edgeFromIds.len != edgeKinds.len:
        return Err[V3CsgSubgraph]("v3 csg: edge column mismatch")
    var out: V3CsgSubgraph = v3CsgSubgraphZero()
    out.graphKeyId = graphKeyId
    out.nodeIds = nodeIds
    out.nodeKinds = nodeKinds
    out.nodeCapabilities = nodeCapabilities
    out.nodePayloadCids = nodePayloadCids
    out.edgeFromIds = edgeFromIds
    out.edgeToIds = edgeToIds
    out.edgeKinds = edgeKinds
    v3CsgSortNodes(out.nodeIds, out.nodeKinds, out.nodeCapabilities, out.nodePayloadCids)
    for i in 0..<out.nodeIds.len:
        if out.nodeIds[i] <= 0 || out.nodeKinds[i] <= 0 || out.nodeCapabilities[i] <= 0:
            return Err[V3CsgSubgraph]("v3 csg: invalid node")
        if i > 0:
            if out.nodeIds[i] == out.nodeIds[i - 1]:
                return Err[V3CsgSubgraph]("v3 csg: duplicate node id")
    v3CsgSortEdges(out.edgeFromIds, out.edgeToIds, out.edgeKinds)
    for i in 0..<out.edgeFromIds.len:
        if out.edgeFromIds[i] <= 0 || out.edgeToIds[i] <= 0 || out.edgeKinds[i] <= 0:
            return Err[V3CsgSubgraph]("v3 csg: invalid edge")
        if v3CsgNodePos(out.nodeIds, out.edgeFromIds[i]) < 0:
            return Err[V3CsgSubgraph]("v3 csg: unknown edge source")
        if v3CsgNodePos(out.nodeIds, out.edgeToIds[i]) < 0:
            return Err[V3CsgSubgraph]("v3 csg: unknown edge target")
    out.nodeCount = out.nodeIds.len
    out.edgeCount = out.edgeFromIds.len
    out.graphCid = v3CsgSubgraphCid(out.graphKeyId,
                                    out.nodeIds,
                                    out.nodeKinds,
                                    out.nodeCapabilities,
                                    out.nodePayloadCids,
                                    out.edgeFromIds,
                                    out.edgeToIds,
                                    out.edgeKinds)
    return Ok[V3CsgSubgraph](out)

fn v3CsgDeltaFromSubgraph(baseGraphCid: layout.FixedBytes32, subgraph: V3CsgSubgraph): V3CsgDelta =
    var out: V3CsgDelta = v3CsgDeltaZero()
    out.baseGraphCid = baseGraphCid
    out.subgraphCid = subgraph.graphCid
    out.nodeCount = subgraph.nodeCount
    out.edgeCount = subgraph.edgeCount
    var buf: layout.ByteBuf = layout.byteBufInit(128)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.csg.delta"))
    lt.v3AppendFixed32(buf, baseGraphCid)
    lt.v3AppendFixed32(buf, subgraph.graphCid)
    lt.v3AppendU32BE(buf, out.nodeCount)
    lt.v3AppendU32BE(buf, out.edgeCount)
    out.deltaCid = lt.v3FixedCidFromBuf(buf)
    return out

fn v3DefaultCsgBarrierFilter(layerId: int32, modeId: int32): V3CsgBarrierFilter =
    var out: V3CsgBarrierFilter = v3CsgBarrierFilterZero()
    out.layerId = layerId
    out.modeId = modeId
    add(out.deniedCapabilities, v3CsgCapabilityPtrWrite)
    add(out.deniedCapabilities, v3CsgCapabilityRawmemWrite)
    add(out.deniedCapabilities, v3CsgCapabilityImportc)
    add(out.deniedCapabilities, v3CsgCapabilityFsWrite)
    add(out.deniedCapabilities, v3CsgCapabilityNetAdmin)
    add(out.allowedCapabilities, v3CsgCapabilityPure)
    add(out.allowedCapabilities, v3CsgCapabilityRead)
    add(out.allowedCapabilities, v3CsgCapabilityEmit)
    add(out.allowedCapabilities, v3CsgCapabilityRoute)
    add(out.allowedCapabilities, v3CsgCapabilityMerge)
    add(out.allowedCapabilities, v3CsgCapabilitySensor)
    if layerId == lt.v3LayerRegional || layerId == lt.v3LayerGlobal:
        add(out.allowedCapabilities, v3CsgCapabilityRegionalBatch)
    if layerId == lt.v3LayerGlobal:
        add(out.allowedCapabilities, v3CsgCapabilityGlobalAnchor)
    var buf: layout.ByteBuf = layout.byteBufInit(128)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.csg.filter"))
    lt.v3AppendU32BE(buf, layerId)
    lt.v3AppendU32BE(buf, modeId)
    for i in 0..<out.allowedCapabilities.len:
        lt.v3AppendU32BE(buf, out.allowedCapabilities[i])
    for i in 0..<out.deniedCapabilities.len:
        lt.v3AppendU32BE(buf, out.deniedCapabilities[i])
    out.filterCid = lt.v3FixedCidFromBuf(buf)
    return out

fn v3ApplyCsgBarrierFilter(filter: V3CsgBarrierFilter,
                           subgraph: V3CsgSubgraph): V3CsgFilterDecision =
    var out: V3CsgFilterDecision = v3CsgFilterDecisionZero()
    out.acceptedNodeCount = subgraph.nodeCount
    for i in 0..<subgraph.nodeCount:
        let capability = subgraph.nodeCapabilities[i]
        if v3CsgCapabilityIn(filter.deniedCapabilities, capability):
            out.accepted = false
            out.reasonCode = v3CsgReasonDeniedCapability
            v3CsgPushUniqueNodeId(out.deniedNodeIds, subgraph.nodeIds[i])
        elif filter.modeId == v3CsgBarrierModeGen:
            if filter.allowedCapabilities.len > 0:
                if !v3CsgCapabilityIn(filter.allowedCapabilities, capability):
                    out.accepted = false
                    out.reasonCode = v3CsgReasonUnsupportedCapability
                    v3CsgPushUniqueNodeId(out.deniedNodeIds, subgraph.nodeIds[i])
        if filter.modeId != v3CsgBarrierModeGen:
            continue
        for edgePos in 0..<subgraph.edgeCount:
            if subgraph.edgeFromIds[edgePos] != subgraph.nodeIds[i]:
                continue
            if subgraph.edgeKinds[edgePos] == v3CsgEdgeKindUnsafeWrite:
                out.accepted = false
                out.reasonCode = v3CsgReasonUnsafeEdge
                v3CsgPushUniqueNodeId(out.deniedNodeIds, subgraph.nodeIds[i])
        
    var buf: layout.ByteBuf = layout.byteBufInit(128)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.csg.decision"))
    lt.v3AppendU32BE(buf, out.accepted ? 1 : 0)
    lt.v3AppendU32BE(buf, out.reasonCode)
    lt.v3AppendU32BE(buf, out.acceptedNodeCount)
    for i in 0..<out.deniedNodeIds.len:
        lt.v3AppendU32BE(buf, out.deniedNodeIds[i])
    out.decisionCid = lt.v3FixedCidFromBuf(buf)
    return out
