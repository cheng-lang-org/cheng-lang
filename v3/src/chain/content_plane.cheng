import std/result
import std/rawbytes
import std/crypto/rsa
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/codec_binary as codec
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/pubsub
import cheng/v3/chain/dag_mempool as dag
import cheng/v3/chain/plumtree
import cheng/v3/chain/erasure_swarm as swarm

const
    v3ContentStubMagic: str = "v3.content.stub"
    v3ContentManifestMagic: str = "v3.content.manifest"

    v3ContentAccessPublic: int32 = 1
    v3ContentAccessPaid: int32 = 2
    v3ContentAccessRestricted: int32 = 3

type
    V3ContentStub =
        version: int32
        topicCid: layout.FixedBytes32
        bundleCid: layout.FixedBytes32
        blobSummaryCid: layout.FixedBytes32
        advertCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        recoveryPlanCid: layout.FixedBytes32
        payloadLen: int32
        stubCid: layout.FixedBytes32

    V3ContentManifest =
        version: int32
        postCid: layout.FixedBytes32
        authorId: layout.FixedBytes32
        publishEpoch: int32
        publishGanzhi: int32
        previewCid: layout.FixedBytes32
        manifestRoot: layout.FixedBytes32
        chunkMapRoot: layout.FixedBytes32
        contentCid: layout.FixedBytes32
        accessMode: int32
        priceUnits: int32
        authorModulusLen: int32
        authorModulus: Bytes
        authorExponentLen: int32
        authorExponent: Bytes
        signatureLen: int32
        signature: Bytes
        manifestCid: layout.FixedBytes32

    V3ContentPublishArtifacts =
        version: int32
        topic: pubsub.V3PubSubTopic
        root: pubsub.V3PubSubSubscription
        subscriptionCount: int32
        subscriptions: pubsub.V3PubSubSubscription[]
        blobSummary: dag.V3DagBlobSummary
        availabilityProofCount: int32
        availabilityProofs: dag.V3DagAvailabilityProof[]
        availabilityCert: dag.V3DagAvailabilityCert
        publishAdvert: dag.V3DagPublishAdvert
        envelope: pubsub.V3PubSubEnvelope
        pubsubPlan: pubsub.V3PubSubPlan
        plumtreePlan: plumtree.V3PlumtreePlan
        erasureParams: swarm.V3ErasureEncodingParams
        erasureManifest: swarm.V3ErasureShardManifest
        peerAdvertCount: int32
        peerAdverts: swarm.V3ErasurePeerAdvert[]
        recoveryPlan: swarm.V3ErasureRecoveryPlan
        bundleCid: layout.FixedBytes32

fn v3ContentStubZero(): V3ContentStub =
    return V3ContentStub(
        version: 1,
        topicCid: layout.fixedBytes32Zero(),
        bundleCid: layout.fixedBytes32Zero(),
        blobSummaryCid: layout.fixedBytes32Zero(),
        advertCid: layout.fixedBytes32Zero(),
        manifestCid: layout.fixedBytes32Zero(),
        recoveryPlanCid: layout.fixedBytes32Zero(),
        payloadLen: 0,
        stubCid: layout.fixedBytes32Zero()
    )

fn v3ContentManifestZero(): V3ContentManifest =
    var out: V3ContentManifest
    out.version = 1
    out.postCid = layout.fixedBytes32Zero()
    out.authorId = layout.fixedBytes32Zero()
    out.publishEpoch = 0
    out.publishGanzhi = 0
    out.previewCid = layout.fixedBytes32Zero()
    out.manifestRoot = layout.fixedBytes32Zero()
    out.chunkMapRoot = layout.fixedBytes32Zero()
    out.contentCid = layout.fixedBytes32Zero()
    out.accessMode = 0
    out.priceUnits = 0
    out.authorModulusLen = 0
    out.authorModulus = emptyBytes()
    out.authorExponentLen = 0
    out.authorExponent = emptyBytes()
    out.signatureLen = 0
    out.signature = emptyBytes()
    out.manifestCid = layout.fixedBytes32Zero()
    return out

fn v3ContentPublishArtifactsZero(): V3ContentPublishArtifacts =
    var out: V3ContentPublishArtifacts
    out.version = 1
    out.topic = pubsub.v3PubSubTopicZero()
    out.root = pubsub.v3PubSubSubscriptionZero()
    out.subscriptionCount = 0
    out.subscriptions = []
    out.blobSummary = dag.v3DagBlobSummaryZero()
    out.availabilityProofCount = 0
    out.availabilityProofs = []
    out.availabilityCert = dag.v3DagAvailabilityCertZero()
    out.publishAdvert = dag.v3DagPublishAdvertZero()
    out.envelope = pubsub.v3PubSubEnvelopeZero()
    out.pubsubPlan = pubsub.v3PubSubPlanZero()
    out.plumtreePlan = plumtree.v3PlumtreePlanZero()
    out.erasureParams = swarm.v3ErasureEncodingParamsZero()
    out.erasureManifest = swarm.v3ErasureShardManifestZero()
    out.peerAdvertCount = 0
    out.peerAdverts = []
    out.recoveryPlan = swarm.v3ErasureRecoveryPlanZero()
    out.bundleCid = layout.fixedBytes32Zero()
    return out

fn v3ContentCidSet(value: layout.FixedBytes32): bool =
    return !layout.fixedBytes32Equal(value, layout.fixedBytes32Zero())

fn v3ContentAccessModeValid(accessMode: int32): bool =
    if accessMode == v3ContentAccessPublic:
        return true
    if accessMode == v3ContentAccessPaid:
        return true
    if accessMode == v3ContentAccessRestricted:
        return true
    return false

fn v3ContentAuthorId(authorModulus: Bytes, authorExponent: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(224)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.content.author"))
    lt.v3AppendU32BE(buf, bytesLen(authorModulus))
    layout.byteBufAppendBytes(buf, authorModulus)
    lt.v3AppendU32BE(buf, bytesLen(authorExponent))
    layout.byteBufAppendBytes(buf, authorExponent)
    return lt.v3FixedCidFromBuf(buf)

fn v3ContentManifestPostCid(authorId: Bytes,
                            publishEpoch: int32,
                            publishGanzhi: int32,
                            previewCid: Bytes,
                            manifestRoot: Bytes,
                            chunkMapRoot: Bytes,
                            contentCid: Bytes,
                            accessMode: int32,
                            priceUnits: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(224)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.content.post"))
    lt.v3AppendU32BE(buf, 1)
    layout.byteBufAppendBytes(buf, authorId)
    lt.v3AppendU32BE(buf, publishEpoch)
    lt.v3AppendU32BE(buf, publishGanzhi)
    layout.byteBufAppendBytes(buf, previewCid)
    layout.byteBufAppendBytes(buf, manifestRoot)
    layout.byteBufAppendBytes(buf, chunkMapRoot)
    layout.byteBufAppendBytes(buf, contentCid)
    lt.v3AppendU32BE(buf, accessMode)
    lt.v3AppendU32BE(buf, priceUnits)
    return lt.v3FixedCidFromBuf(buf)

fn v3ContentManifestSignableBytes(postCid: Bytes,
                                  authorId: Bytes,
                                  publishEpoch: int32,
                                  publishGanzhi: int32,
                                  previewCid: Bytes,
                                  manifestRoot: Bytes,
                                  chunkMapRoot: Bytes,
                                  contentCid: Bytes,
                                  accessMode: int32,
                                  priceUnits: int32,
                                  authorPublicKey: Bytes): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(320)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.content.manifest.sign"))
    lt.v3AppendU32BE(buf, 1)
    layout.byteBufAppendBytes(buf, postCid)
    layout.byteBufAppendBytes(buf, authorId)
    lt.v3AppendU32BE(buf, publishEpoch)
    lt.v3AppendU32BE(buf, publishGanzhi)
    layout.byteBufAppendBytes(buf, previewCid)
    layout.byteBufAppendBytes(buf, manifestRoot)
    layout.byteBufAppendBytes(buf, chunkMapRoot)
    layout.byteBufAppendBytes(buf, contentCid)
    lt.v3AppendU32BE(buf, accessMode)
    lt.v3AppendU32BE(buf, priceUnits)
    lt.v3AppendU32BE(buf, bytesLen(authorPublicKey))
    layout.byteBufAppendBytes(buf, authorPublicKey)
    return layout.byteBufToBytes(buf)

fn v3ContentManifestCid(postCid: Bytes,
                        authorId: Bytes,
                        publishEpoch: int32,
                        publishGanzhi: int32,
                        previewCid: Bytes,
                        manifestRoot: Bytes,
                        chunkMapRoot: Bytes,
                        contentCid: Bytes,
                        accessMode: int32,
                        priceUnits: int32,
                        authorPublicKey: Bytes,
                        signature: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(448)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.content.manifest.cid"))
    lt.v3AppendU32BE(buf, 1)
    layout.byteBufAppendBytes(buf, postCid)
    layout.byteBufAppendBytes(buf, authorId)
    lt.v3AppendU32BE(buf, publishEpoch)
    lt.v3AppendU32BE(buf, publishGanzhi)
    layout.byteBufAppendBytes(buf, previewCid)
    layout.byteBufAppendBytes(buf, manifestRoot)
    layout.byteBufAppendBytes(buf, chunkMapRoot)
    layout.byteBufAppendBytes(buf, contentCid)
    lt.v3AppendU32BE(buf, accessMode)
    lt.v3AppendU32BE(buf, priceUnits)
    lt.v3AppendU32BE(buf, bytesLen(authorPublicKey))
    layout.byteBufAppendBytes(buf, authorPublicKey)
    lt.v3AppendU32BE(buf, bytesLen(signature))
    layout.byteBufAppendBytes(buf, signature)
    return lt.v3FixedCidFromBuf(buf)

fn v3ContentStubCid(topicCid: layout.FixedBytes32,
                    bundleCid: layout.FixedBytes32,
                    blobSummaryCid: layout.FixedBytes32,
                    advertCid: layout.FixedBytes32,
                    manifestCid: layout.FixedBytes32,
                    recoveryPlanCid: layout.FixedBytes32,
                    payloadLen: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.content.stub.cid"))
    lt.v3AppendU32BE(buf, 1)
    lt.v3AppendFixed32(buf, topicCid)
    lt.v3AppendFixed32(buf, bundleCid)
    lt.v3AppendFixed32(buf, blobSummaryCid)
    lt.v3AppendFixed32(buf, advertCid)
    lt.v3AppendFixed32(buf, manifestCid)
    lt.v3AppendFixed32(buf, recoveryPlanCid)
    lt.v3AppendU32BE(buf, payloadLen)
    return lt.v3FixedCidFromBuf(buf)

fn v3ContentStubFill(out: var V3ContentStub,
                     topicCid: layout.FixedBytes32,
                     bundleCid: layout.FixedBytes32,
                     blobSummaryCid: layout.FixedBytes32,
                     advertCid: layout.FixedBytes32,
                     manifestCid: layout.FixedBytes32,
                     recoveryPlanCid: layout.FixedBytes32,
                     payloadLen: int32): Result[bool] =
    if !v3ContentCidSet(topicCid):
        return Err[bool]("v3 content plane: missing stub topic cid")
    if !v3ContentCidSet(bundleCid):
        return Err[bool]("v3 content plane: missing stub bundle cid")
    if !v3ContentCidSet(blobSummaryCid):
        return Err[bool]("v3 content plane: missing stub blob summary cid")
    if !v3ContentCidSet(advertCid):
        return Err[bool]("v3 content plane: missing stub advert cid")
    if !v3ContentCidSet(manifestCid):
        return Err[bool]("v3 content plane: missing stub manifest cid")
    if !v3ContentCidSet(recoveryPlanCid):
        return Err[bool]("v3 content plane: missing stub recovery plan cid")
    if payloadLen < 0:
        return Err[bool]("v3 content plane: invalid stub payload length")
    out = v3ContentStubZero()
    out.topicCid = topicCid
    out.bundleCid = bundleCid
    out.blobSummaryCid = blobSummaryCid
    out.advertCid = advertCid
    out.manifestCid = manifestCid
    out.recoveryPlanCid = recoveryPlanCid
    out.payloadLen = payloadLen
    out.stubCid = v3ContentStubCid(out.topicCid,
                                   out.bundleCid,
                                   out.blobSummaryCid,
                                   out.advertCid,
                                   out.manifestCid,
                                   out.recoveryPlanCid,
                                   out.payloadLen)
    return Ok[bool](true)

fn v3ContentStubMake(topicCid: layout.FixedBytes32,
                     bundleCid: layout.FixedBytes32,
                     blobSummaryCid: layout.FixedBytes32,
                     advertCid: layout.FixedBytes32,
                     manifestCid: layout.FixedBytes32,
                     recoveryPlanCid: layout.FixedBytes32,
                     payloadLen: int32): Result[V3ContentStub] =
    var out: V3ContentStub
    let fillRes = v3ContentStubFill(out,
                                    topicCid,
                                    bundleCid,
                                    blobSummaryCid,
                                    advertCid,
                                    manifestCid,
                                    recoveryPlanCid,
                                    payloadLen)
    if IsErr(fillRes):
        return Err[V3ContentStub](Error(fillRes))
    return Ok[V3ContentStub](out)

fn v3ContentStubFromArtifactsFill(out: var V3ContentStub,
                                  artifacts: V3ContentPublishArtifacts): Result[bool] =
    let artifactsOk = v3ContentPublishArtifactsValidate(artifacts)
    if IsErr(artifactsOk):
        return Err[bool](Error(artifactsOk))
    return v3ContentStubFill(out,
                             artifacts.topic.topicCid,
                             artifacts.bundleCid,
                             artifacts.blobSummary.summaryCid,
                             artifacts.publishAdvert.advertCid,
                             artifacts.erasureManifest.manifestCid,
                             artifacts.recoveryPlan.planCid,
                             artifacts.blobSummary.payloadLen)

fn v3ContentStubFromArtifacts(artifacts: V3ContentPublishArtifacts): Result[V3ContentStub] =
    var out: V3ContentStub
    let fillRes = v3ContentStubFromArtifactsFill(out, artifacts)
    if IsErr(fillRes):
        return Err[V3ContentStub](Error(fillRes))
    return Ok[V3ContentStub](out)

fn v3ContentStubValidate(stub: V3ContentStub): Result[bool] =
    if stub.version != 1:
        return Err[bool]("v3 content plane: unsupported stub version")
    if !v3ContentCidSet(stub.topicCid):
        return Err[bool]("v3 content plane: missing stub topic cid")
    if !v3ContentCidSet(stub.bundleCid):
        return Err[bool]("v3 content plane: missing stub bundle cid")
    if !v3ContentCidSet(stub.blobSummaryCid):
        return Err[bool]("v3 content plane: missing stub blob summary cid")
    if !v3ContentCidSet(stub.advertCid):
        return Err[bool]("v3 content plane: missing stub advert cid")
    if !v3ContentCidSet(stub.manifestCid):
        return Err[bool]("v3 content plane: missing stub manifest cid")
    if !v3ContentCidSet(stub.recoveryPlanCid):
        return Err[bool]("v3 content plane: missing stub recovery plan cid")
    if stub.payloadLen < 0:
        return Err[bool]("v3 content plane: invalid stub payload length")
    let expectedCid = v3ContentStubCid(stub.topicCid,
                                       stub.bundleCid,
                                       stub.blobSummaryCid,
                                       stub.advertCid,
                                       stub.manifestCid,
                                       stub.recoveryPlanCid,
                                       stub.payloadLen)
    if !layout.fixedBytes32Equal(stub.stubCid, expectedCid):
        return Err[bool]("v3 content plane: stub cid mismatch")
    return Ok[bool](true)

fn v3ContentPayloadHasMagic(payload: Bytes, magic: str): bool =
    let magicBytes = bytesFromString(magic)
    if bytesLen(payload) < bytesLen(magicBytes):
        return false
    for i in 0..<bytesLen(magicBytes):
        if bytesGet(payload, i) != bytesGet(magicBytes, i):
            return false
    return true

fn v3ContentStubEncode(stub: V3ContentStub): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString(v3ContentStubMagic))
    lt.v3AppendU32BE(buf, stub.version)
    lt.v3AppendFixed32(buf, stub.topicCid)
    lt.v3AppendFixed32(buf, stub.bundleCid)
    lt.v3AppendFixed32(buf, stub.blobSummaryCid)
    lt.v3AppendFixed32(buf, stub.advertCid)
    lt.v3AppendFixed32(buf, stub.manifestCid)
    lt.v3AppendFixed32(buf, stub.recoveryPlanCid)
    lt.v3AppendU32BE(buf, stub.payloadLen)
    lt.v3AppendFixed32(buf, stub.stubCid)
    return layout.byteBufToBytes(buf)

fn v3ContentStubDecode(payload: Bytes): Result[V3ContentStub] =
    if !v3ContentPayloadHasMagic(payload, v3ContentStubMagic):
        return Err[V3ContentStub]("v3 content plane: invalid stub magic")
    let magicLen = bytesLen(bytesFromString(v3ContentStubMagic))
    let span = layout.byteSpanFromBytes(payload)
    let versionRes = codec.v3ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[V3ContentStub](Error(versionRes))
    let topicCidRes = codec.v3ReadFixed32(span, magicLen + 4)
    if IsErr(topicCidRes):
        return Err[V3ContentStub](Error(topicCidRes))
    let bundleCidRes = codec.v3ReadFixed32(span, magicLen + 36)
    if IsErr(bundleCidRes):
        return Err[V3ContentStub](Error(bundleCidRes))
    let blobSummaryCidRes = codec.v3ReadFixed32(span, magicLen + 68)
    if IsErr(blobSummaryCidRes):
        return Err[V3ContentStub](Error(blobSummaryCidRes))
    let advertCidRes = codec.v3ReadFixed32(span, magicLen + 100)
    if IsErr(advertCidRes):
        return Err[V3ContentStub](Error(advertCidRes))
    let manifestCidRes = codec.v3ReadFixed32(span, magicLen + 132)
    if IsErr(manifestCidRes):
        return Err[V3ContentStub](Error(manifestCidRes))
    let recoveryPlanCidRes = codec.v3ReadFixed32(span, magicLen + 164)
    if IsErr(recoveryPlanCidRes):
        return Err[V3ContentStub](Error(recoveryPlanCidRes))
    let payloadLenRes = codec.v3ReadU32BE(span, magicLen + 196)
    if IsErr(payloadLenRes):
        return Err[V3ContentStub](Error(payloadLenRes))
    let stubCidRes = codec.v3ReadFixed32(span, magicLen + 200)
    if IsErr(stubCidRes):
        return Err[V3ContentStub](Error(stubCidRes))
    var out = v3ContentStubZero()
    out.version = int32(Value(versionRes))
    out.topicCid = Value(topicCidRes)
    out.bundleCid = Value(bundleCidRes)
    out.blobSummaryCid = Value(blobSummaryCidRes)
    out.advertCid = Value(advertCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.recoveryPlanCid = Value(recoveryPlanCidRes)
    out.payloadLen = int32(Value(payloadLenRes))
    out.stubCid = Value(stubCidRes)
    let stubOk = v3ContentStubValidate(out)
    if IsErr(stubOk):
        return Err[V3ContentStub](Error(stubOk))
    return Ok[V3ContentStub](out)

fn v3ContentManifestValidate(manifest: V3ContentManifest): Result[bool] =
    if manifest.version != 1:
        return Err[bool]("v3 content plane: unsupported manifest version")
    if !v3ContentCidSet(manifest.postCid):
        return Err[bool]("v3 content plane: missing manifest post cid")
    if !v3ContentCidSet(manifest.authorId):
        return Err[bool]("v3 content plane: missing manifest author id")
    if manifest.publishEpoch < 0:
        return Err[bool]("v3 content plane: invalid manifest publish epoch")
    if manifest.publishGanzhi < 0:
        return Err[bool]("v3 content plane: invalid manifest publish ganzhi")
    if !v3ContentCidSet(manifest.previewCid):
        return Err[bool]("v3 content plane: missing manifest preview cid")
    if !v3ContentCidSet(manifest.manifestRoot):
        return Err[bool]("v3 content plane: missing manifest root")
    if !v3ContentCidSet(manifest.chunkMapRoot):
        return Err[bool]("v3 content plane: missing chunk map root")
    if !v3ContentCidSet(manifest.contentCid):
        return Err[bool]("v3 content plane: missing content cid")
    if !v3ContentAccessModeValid(manifest.accessMode):
        return Err[bool]("v3 content plane: invalid access mode")
    if manifest.priceUnits < 0:
        return Err[bool]("v3 content plane: invalid price units")
    if manifest.authorModulusLen != bytesLen(manifest.authorModulus):
        return Err[bool]("v3 content plane: author modulus length mismatch")
    if manifest.authorModulusLen <= 0:
        return Err[bool]("v3 content plane: missing author modulus")
    if manifest.authorExponentLen != bytesLen(manifest.authorExponent):
        return Err[bool]("v3 content plane: author exponent length mismatch")
    if manifest.authorExponentLen <= 0:
        return Err[bool]("v3 content plane: missing author exponent")
    if manifest.signatureLen != bytesLen(manifest.signature):
        return Err[bool]("v3 content plane: signature length mismatch")
    if manifest.signatureLen <= 0:
        return Err[bool]("v3 content plane: missing manifest signature")
    if !rsa.validateRsaSignatureBytes(manifest.signature):
        return Err[bool]("v3 content plane: invalid manifest signature")
    if !rsa.rsaPublicKeyPartsValid(manifest.authorModulus, manifest.authorExponent):
        return Err[bool]("v3 content plane: invalid author key parts")
    let authorIdBytes = layout.fixedBytes32ToBytes(manifest.authorId)
    let previewCidBytes = layout.fixedBytes32ToBytes(manifest.previewCid)
    let manifestRootBytes = layout.fixedBytes32ToBytes(manifest.manifestRoot)
    let chunkMapRootBytes = layout.fixedBytes32ToBytes(manifest.chunkMapRoot)
    let contentCidBytes = layout.fixedBytes32ToBytes(manifest.contentCid)
    let expectedAuthorId = v3ContentAuthorId(manifest.authorModulus, manifest.authorExponent)
    if !layout.fixedBytes32Equal(manifest.authorId, expectedAuthorId):
        return Err[bool]("v3 content plane: author id mismatch")
    var postBuf: layout.ByteBuf = layout.byteBufInit(224)
    layout.byteBufAppendBytes(postBuf, bytesFromString("v3.content.post"))
    lt.v3AppendU32BE(postBuf, 1)
    layout.byteBufAppendBytes(postBuf, authorIdBytes)
    lt.v3AppendU32BE(postBuf, manifest.publishEpoch)
    lt.v3AppendU32BE(postBuf, manifest.publishGanzhi)
    layout.byteBufAppendBytes(postBuf, previewCidBytes)
    layout.byteBufAppendBytes(postBuf, manifestRootBytes)
    layout.byteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(postBuf, contentCidBytes)
    lt.v3AppendU32BE(postBuf, manifest.accessMode)
    lt.v3AppendU32BE(postBuf, manifest.priceUnits)
    let expectedPostCid = lt.v3FixedCidFromBuf(postBuf)
    if !layout.fixedBytes32Equal(manifest.postCid, expectedPostCid):
        return Err[bool]("v3 content plane: post cid mismatch")
    let postCidBytes = layout.fixedBytes32ToBytes(manifest.postCid)
    var signBuf: layout.ByteBuf = layout.byteBufInit(352)
    layout.byteBufAppendBytes(signBuf, bytesFromString("v3.content.manifest.sign"))
    lt.v3AppendU32BE(signBuf, 1)
    layout.byteBufAppendBytes(signBuf, postCidBytes)
    layout.byteBufAppendBytes(signBuf, authorIdBytes)
    lt.v3AppendU32BE(signBuf, manifest.publishEpoch)
    lt.v3AppendU32BE(signBuf, manifest.publishGanzhi)
    layout.byteBufAppendBytes(signBuf, previewCidBytes)
    layout.byteBufAppendBytes(signBuf, manifestRootBytes)
    layout.byteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(signBuf, contentCidBytes)
    lt.v3AppendU32BE(signBuf, manifest.accessMode)
    lt.v3AppendU32BE(signBuf, manifest.priceUnits)
    lt.v3AppendU32BE(signBuf, bytesLen(manifest.authorModulus))
    layout.byteBufAppendBytes(signBuf, manifest.authorModulus)
    lt.v3AppendU32BE(signBuf, bytesLen(manifest.authorExponent))
    layout.byteBufAppendBytes(signBuf, manifest.authorExponent)
    let signable = layout.byteBufToBytes(signBuf)
    let verifyRes = rsa.rsaVerifyPkcs1Bytes(manifest.authorModulus,
                                            manifest.authorExponent,
                                            signable,
                                            manifest.signature,
                                            false)
    if IsErr(verifyRes) || !Value(verifyRes):
        return Err[bool]("v3 content plane: manifest signature mismatch")
    var cidBuf: layout.ByteBuf = layout.byteBufInit(480 + manifest.signatureLen)
    layout.byteBufAppendBytes(cidBuf, bytesFromString("v3.content.manifest.cid"))
    lt.v3AppendU32BE(cidBuf, 1)
    layout.byteBufAppendBytes(cidBuf, postCidBytes)
    layout.byteBufAppendBytes(cidBuf, authorIdBytes)
    lt.v3AppendU32BE(cidBuf, manifest.publishEpoch)
    lt.v3AppendU32BE(cidBuf, manifest.publishGanzhi)
    layout.byteBufAppendBytes(cidBuf, previewCidBytes)
    layout.byteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.byteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(cidBuf, contentCidBytes)
    lt.v3AppendU32BE(cidBuf, manifest.accessMode)
    lt.v3AppendU32BE(cidBuf, manifest.priceUnits)
    lt.v3AppendU32BE(cidBuf, bytesLen(manifest.authorModulus))
    layout.byteBufAppendBytes(cidBuf, manifest.authorModulus)
    lt.v3AppendU32BE(cidBuf, bytesLen(manifest.authorExponent))
    layout.byteBufAppendBytes(cidBuf, manifest.authorExponent)
    lt.v3AppendU32BE(cidBuf, bytesLen(manifest.signature))
    layout.byteBufAppendBytes(cidBuf, manifest.signature)
    let expectedCid = lt.v3FixedCidFromBuf(cidBuf)
    if !layout.fixedBytes32Equal(manifest.manifestCid, expectedCid):
        return Err[bool]("v3 content plane: manifest cid mismatch")
    return Ok[bool](true)

fn v3ContentManifestMakeFill(out: var V3ContentManifest,
                             previewCidBytesIn: Bytes,
                             manifestRootBytesIn: Bytes,
                             chunkMapRootBytesIn: Bytes,
                             contentCidBytesIn: Bytes,
                             authorModulus: Bytes,
                             authorExponent: Bytes,
                             authorPrivateKey: Bytes,
                             publishEpoch: int32,
                             publishGanzhi: int32,
                             accessMode: int32,
                             priceUnits: int32): Result[bool] =
    let previewCidRes = layout.fixedBytes32FromBytes(previewCidBytesIn)
    if IsErr(previewCidRes):
        return Err[bool]("v3 content plane: preview cid bytes: " + Error(previewCidRes))
    let manifestRootRes = layout.fixedBytes32FromBytes(manifestRootBytesIn)
    if IsErr(manifestRootRes):
        return Err[bool]("v3 content plane: manifest root bytes: " + Error(manifestRootRes))
    let chunkMapRootRes = layout.fixedBytes32FromBytes(chunkMapRootBytesIn)
    if IsErr(chunkMapRootRes):
        return Err[bool]("v3 content plane: chunk map root bytes: " + Error(chunkMapRootRes))
    let contentCidRes = layout.fixedBytes32FromBytes(contentCidBytesIn)
    if IsErr(contentCidRes):
        return Err[bool]("v3 content plane: content cid bytes: " + Error(contentCidRes))
    let previewCid = Value(previewCidRes)
    let manifestRoot = Value(manifestRootRes)
    let chunkMapRoot = Value(chunkMapRootRes)
    let contentCid = Value(contentCidRes)
    if !v3ContentCidSet(previewCid):
        return Err[bool]("v3 content plane: missing manifest preview cid")
    if !v3ContentCidSet(manifestRoot):
        return Err[bool]("v3 content plane: missing manifest root")
    if !v3ContentCidSet(chunkMapRoot):
        return Err[bool]("v3 content plane: missing chunk map root")
    if !v3ContentCidSet(contentCid):
        return Err[bool]("v3 content plane: missing manifest content cid")
    if publishEpoch < 0:
        return Err[bool]("v3 content plane: invalid manifest publish epoch")
    if publishGanzhi < 0:
        return Err[bool]("v3 content plane: invalid manifest publish ganzhi")
    if !v3ContentAccessModeValid(accessMode):
        return Err[bool]("v3 content plane: invalid manifest access mode")
    if priceUnits < 0:
        return Err[bool]("v3 content plane: invalid manifest price units")
    let authorModulusLocal = bytesSlice(authorModulus, 0, bytesLen(authorModulus))
    let authorExponentLocal = bytesSlice(authorExponent, 0, bytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        return Err[bool]("v3 content plane: invalid author key parts")
    let authorPrivateKeyLocal = bytesSlice(authorPrivateKey, 0, bytesLen(authorPrivateKey))
    let authorId = v3ContentAuthorId(authorModulusLocal, authorExponentLocal)
    let authorIdBytes = layout.fixedBytes32ToBytes(authorId)
    let previewCidBytes = layout.fixedBytes32ToBytes(previewCid)
    let manifestRootBytes = layout.fixedBytes32ToBytes(manifestRoot)
    let chunkMapRootBytes = layout.fixedBytes32ToBytes(chunkMapRoot)
    let contentCidBytes = layout.fixedBytes32ToBytes(contentCid)
    var postBuf: layout.ByteBuf = layout.byteBufInit(224)
    layout.byteBufAppendBytes(postBuf, bytesFromString("v3.content.post"))
    lt.v3AppendU32BE(postBuf, 1)
    layout.byteBufAppendBytes(postBuf, authorIdBytes)
    lt.v3AppendU32BE(postBuf, publishEpoch)
    lt.v3AppendU32BE(postBuf, publishGanzhi)
    layout.byteBufAppendBytes(postBuf, previewCidBytes)
    layout.byteBufAppendBytes(postBuf, manifestRootBytes)
    layout.byteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(postBuf, contentCidBytes)
    lt.v3AppendU32BE(postBuf, accessMode)
    lt.v3AppendU32BE(postBuf, priceUnits)
    let postCid = lt.v3FixedCidFromBuf(postBuf)
    let postCidBytes = layout.fixedBytes32ToBytes(postCid)
    var signBuf: layout.ByteBuf = layout.byteBufInit(352)
    layout.byteBufAppendBytes(signBuf, bytesFromString("v3.content.manifest.sign"))
    lt.v3AppendU32BE(signBuf, 1)
    layout.byteBufAppendBytes(signBuf, postCidBytes)
    layout.byteBufAppendBytes(signBuf, authorIdBytes)
    lt.v3AppendU32BE(signBuf, publishEpoch)
    lt.v3AppendU32BE(signBuf, publishGanzhi)
    layout.byteBufAppendBytes(signBuf, previewCidBytes)
    layout.byteBufAppendBytes(signBuf, manifestRootBytes)
    layout.byteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(signBuf, contentCidBytes)
    lt.v3AppendU32BE(signBuf, accessMode)
    lt.v3AppendU32BE(signBuf, priceUnits)
    lt.v3AppendU32BE(signBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(signBuf, authorModulusLocal)
    lt.v3AppendU32BE(signBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.byteBufToBytes(signBuf)
    let signatureBytesRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureBytesRes):
        return Err[bool](Error(signatureBytesRes))
    let signatureBytesRaw = Value(signatureBytesRes)
    let signatureBytes = bytesSlice(signatureBytesRaw, 0, bytesLen(signatureBytesRaw))
    out = v3ContentManifestZero()
    out.postCid = postCid
    out.authorId = authorId
    out.publishEpoch = publishEpoch
    out.publishGanzhi = publishGanzhi
    out.previewCid = previewCid
    out.manifestRoot = manifestRoot
    out.chunkMapRoot = chunkMapRoot
    out.contentCid = contentCid
    out.accessMode = accessMode
    out.priceUnits = priceUnits
    out.authorModulusLen = bytesLen(authorModulusLocal)
    out.authorModulus = authorModulusLocal
    out.authorExponentLen = bytesLen(authorExponentLocal)
    out.authorExponent = authorExponentLocal
    out.signature = signatureBytes
    out.signatureLen = bytesLen(out.signature)
    var cidBuf: layout.ByteBuf = layout.byteBufInit(480 + out.signatureLen)
    layout.byteBufAppendBytes(cidBuf, bytesFromString("v3.content.manifest.cid"))
    lt.v3AppendU32BE(cidBuf, 1)
    layout.byteBufAppendBytes(cidBuf, postCidBytes)
    layout.byteBufAppendBytes(cidBuf, authorIdBytes)
    lt.v3AppendU32BE(cidBuf, out.publishEpoch)
    lt.v3AppendU32BE(cidBuf, out.publishGanzhi)
    layout.byteBufAppendBytes(cidBuf, previewCidBytes)
    layout.byteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.byteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(cidBuf, contentCidBytes)
    lt.v3AppendU32BE(cidBuf, out.accessMode)
    lt.v3AppendU32BE(cidBuf, out.priceUnits)
    lt.v3AppendU32BE(cidBuf, bytesLen(out.authorModulus))
    layout.byteBufAppendBytes(cidBuf, out.authorModulus)
    lt.v3AppendU32BE(cidBuf, bytesLen(out.authorExponent))
    layout.byteBufAppendBytes(cidBuf, out.authorExponent)
    lt.v3AppendU32BE(cidBuf, bytesLen(out.signature))
    layout.byteBufAppendBytes(cidBuf, out.signature)
    out.manifestCid = lt.v3FixedCidFromBuf(cidBuf)
    let manifestOk = v3ContentManifestValidate(out)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    return Ok[bool](true)

fn v3ContentManifestMake(previewCidBytesIn: Bytes,
                         manifestRootBytesIn: Bytes,
                         chunkMapRootBytesIn: Bytes,
                         contentCidBytesIn: Bytes,
                         authorModulus: Bytes,
                         authorExponent: Bytes,
                         authorPrivateKey: Bytes,
                         publishEpoch: int32,
                         publishGanzhi: int32,
                         accessMode: int32,
                         priceUnits: int32): Result[V3ContentManifest] =
    var out: V3ContentManifest
    let fillRes = v3ContentManifestMakeFill(out,
                                            previewCidBytesIn,
                                            manifestRootBytesIn,
                                            chunkMapRootBytesIn,
                                            contentCidBytesIn,
                                            authorModulus,
                                            authorExponent,
                                            authorPrivateKey,
                                            publishEpoch,
                                            publishGanzhi,
                                            accessMode,
                                            priceUnits)
    if IsErr(fillRes):
        return Err[V3ContentManifest](Error(fillRes))
    return Ok[V3ContentManifest](out)

fn v3ContentManifestMakeFromFixedFill(out: var V3ContentManifest,
                                      previewCid: layout.FixedBytes32,
                                      manifestRoot: layout.FixedBytes32,
                                      chunkMapRoot: layout.FixedBytes32,
                                      contentCid: layout.FixedBytes32,
                                      authorModulus: Bytes,
                                      authorExponent: Bytes,
                                      authorPrivateKey: Bytes,
                                      publishEpoch: int32,
                                      publishGanzhi: int32,
                                      accessMode: int32,
                                      priceUnits: int32): Result[bool] =
    if !v3ContentCidSet(previewCid):
        return Err[bool]("v3 content plane: missing manifest preview cid")
    if !v3ContentCidSet(manifestRoot):
        return Err[bool]("v3 content plane: missing manifest root")
    if !v3ContentCidSet(chunkMapRoot):
        return Err[bool]("v3 content plane: missing chunk map root")
    if !v3ContentCidSet(contentCid):
        return Err[bool]("v3 content plane: missing manifest content cid")
    if publishEpoch < 0:
        return Err[bool]("v3 content plane: invalid manifest publish epoch")
    if publishGanzhi < 0:
        return Err[bool]("v3 content plane: invalid manifest publish ganzhi")
    if !v3ContentAccessModeValid(accessMode):
        return Err[bool]("v3 content plane: invalid manifest access mode")
    if priceUnits < 0:
        return Err[bool]("v3 content plane: invalid manifest price units")
    let authorModulusLocal = bytesSlice(authorModulus, 0, bytesLen(authorModulus))
    let authorExponentLocal = bytesSlice(authorExponent, 0, bytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        return Err[bool]("v3 content plane: invalid author key parts")
    let authorPrivateKeyLocal = bytesSlice(authorPrivateKey, 0, bytesLen(authorPrivateKey))
    let authorId = v3ContentAuthorId(authorModulusLocal, authorExponentLocal)
    var authorIdBytes: Bytes
    var previewCidBytes: Bytes
    var manifestRootBytes: Bytes
    var chunkMapRootBytes: Bytes
    var contentCidBytes: Bytes
    var postCidBytes: Bytes
    layout.fixedBytes32ToBytesInto(authorIdBytes, authorId)
    layout.fixedBytes32ToBytesInto(previewCidBytes, previewCid)
    layout.fixedBytes32ToBytesInto(manifestRootBytes, manifestRoot)
    layout.fixedBytes32ToBytesInto(chunkMapRootBytes, chunkMapRoot)
    layout.fixedBytes32ToBytesInto(contentCidBytes, contentCid)
    var postBuf: layout.ByteBuf = layout.byteBufInit(224)
    layout.byteBufAppendBytes(postBuf, bytesFromString("v3.content.post"))
    lt.v3AppendU32BE(postBuf, 1)
    layout.byteBufAppendBytes(postBuf, authorIdBytes)
    lt.v3AppendU32BE(postBuf, publishEpoch)
    lt.v3AppendU32BE(postBuf, publishGanzhi)
    layout.byteBufAppendBytes(postBuf, previewCidBytes)
    layout.byteBufAppendBytes(postBuf, manifestRootBytes)
    layout.byteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(postBuf, contentCidBytes)
    lt.v3AppendU32BE(postBuf, accessMode)
    lt.v3AppendU32BE(postBuf, priceUnits)
    let postCid = lt.v3FixedCidFromBuf(postBuf)
    layout.fixedBytes32ToBytesInto(postCidBytes, postCid)
    var signBuf: layout.ByteBuf = layout.byteBufInit(352)
    layout.byteBufAppendBytes(signBuf, bytesFromString("v3.content.manifest.sign"))
    lt.v3AppendU32BE(signBuf, 1)
    layout.byteBufAppendBytes(signBuf, postCidBytes)
    layout.byteBufAppendBytes(signBuf, authorIdBytes)
    lt.v3AppendU32BE(signBuf, publishEpoch)
    lt.v3AppendU32BE(signBuf, publishGanzhi)
    layout.byteBufAppendBytes(signBuf, previewCidBytes)
    layout.byteBufAppendBytes(signBuf, manifestRootBytes)
    layout.byteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(signBuf, contentCidBytes)
    lt.v3AppendU32BE(signBuf, accessMode)
    lt.v3AppendU32BE(signBuf, priceUnits)
    lt.v3AppendU32BE(signBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(signBuf, authorModulusLocal)
    lt.v3AppendU32BE(signBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.byteBufToBytes(signBuf)
    let signatureBytesRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureBytesRes):
        return Err[bool](Error(signatureBytesRes))
    let signatureBytesRaw = Value(signatureBytesRes)
    let signatureBytes = bytesSlice(signatureBytesRaw, 0, bytesLen(signatureBytesRaw))
    out = v3ContentManifestZero()
    out.postCid = postCid
    out.authorId = authorId
    out.publishEpoch = publishEpoch
    out.publishGanzhi = publishGanzhi
    out.previewCid = previewCid
    out.manifestRoot = manifestRoot
    out.chunkMapRoot = chunkMapRoot
    out.contentCid = contentCid
    out.accessMode = accessMode
    out.priceUnits = priceUnits
    out.authorModulusLen = bytesLen(authorModulusLocal)
    out.authorModulus = authorModulusLocal
    out.authorExponentLen = bytesLen(authorExponentLocal)
    out.authorExponent = authorExponentLocal
    out.signature = signatureBytes
    out.signatureLen = bytesLen(out.signature)
    var cidBuf: layout.ByteBuf = layout.byteBufInit(480 + out.signatureLen)
    layout.byteBufAppendBytes(cidBuf, bytesFromString("v3.content.manifest.cid"))
    lt.v3AppendU32BE(cidBuf, 1)
    layout.byteBufAppendBytes(cidBuf, postCidBytes)
    layout.byteBufAppendBytes(cidBuf, authorIdBytes)
    lt.v3AppendU32BE(cidBuf, out.publishEpoch)
    lt.v3AppendU32BE(cidBuf, out.publishGanzhi)
    layout.byteBufAppendBytes(cidBuf, previewCidBytes)
    layout.byteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.byteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(cidBuf, contentCidBytes)
    lt.v3AppendU32BE(cidBuf, out.accessMode)
    lt.v3AppendU32BE(cidBuf, out.priceUnits)
    lt.v3AppendU32BE(cidBuf, bytesLen(out.authorModulus))
    layout.byteBufAppendBytes(cidBuf, out.authorModulus)
    lt.v3AppendU32BE(cidBuf, bytesLen(out.authorExponent))
    layout.byteBufAppendBytes(cidBuf, out.authorExponent)
    lt.v3AppendU32BE(cidBuf, bytesLen(out.signature))
    layout.byteBufAppendBytes(cidBuf, out.signature)
    out.manifestCid = lt.v3FixedCidFromBuf(cidBuf)
    let manifestOk = v3ContentManifestValidate(out)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    return Ok[bool](true)

fn v3ContentManifestPayloadBuildFill(out: var Bytes,
                                     previewCid: layout.FixedBytes32,
                                     manifestRoot: layout.FixedBytes32,
                                     chunkMapRoot: layout.FixedBytes32,
                                     contentCid: layout.FixedBytes32,
                                     authorModulus: Bytes,
                                     authorExponent: Bytes,
                                     authorPrivateKey: Bytes,
                                     publishEpoch: int32,
                                     publishGanzhi: int32,
                                     accessMode: int32,
                                     priceUnits: int32): Result[bool] =
    var previewCidSet = false
    var manifestRootSet = false
    var chunkMapRootSet = false
    var contentCidSet = false
    for i in 0..<layout.fixedBytes32Size:
        if previewCid.data[i] != 0:
            previewCidSet = true
        if manifestRoot.data[i] != 0:
            manifestRootSet = true
        if chunkMapRoot.data[i] != 0:
            chunkMapRootSet = true
        if contentCid.data[i] != 0:
            contentCidSet = true
    if !previewCidSet:
        return Err[bool]("v3 content plane: missing manifest preview cid")
    if !manifestRootSet:
        return Err[bool]("v3 content plane: missing manifest root")
    if !chunkMapRootSet:
        return Err[bool]("v3 content plane: missing chunk map root")
    if !contentCidSet:
        return Err[bool]("v3 content plane: missing manifest content cid")
    if publishEpoch < 0:
        return Err[bool]("v3 content plane: invalid manifest publish epoch")
    if publishGanzhi < 0:
        return Err[bool]("v3 content plane: invalid manifest publish ganzhi")
    if !v3ContentAccessModeValid(accessMode):
        return Err[bool]("v3 content plane: invalid manifest access mode")
    if priceUnits < 0:
        return Err[bool]("v3 content plane: invalid manifest price units")
    let authorModulusLocal = bytesSlice(authorModulus, 0, bytesLen(authorModulus))
    let authorExponentLocal = bytesSlice(authorExponent, 0, bytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        return Err[bool]("v3 content plane: invalid author key parts")
    let authorPrivateKeyLocal = bytesSlice(authorPrivateKey, 0, bytesLen(authorPrivateKey))
    let authorId = v3ContentAuthorId(authorModulusLocal, authorExponentLocal)
    var authorIdBytes: Bytes
    var previewCidBytes: Bytes
    var manifestRootBytes: Bytes
    var chunkMapRootBytes: Bytes
    var contentCidBytes: Bytes
    var postCidBytes: Bytes
    authorIdBytes = bytesAlloc(layout.fixedBytes32Size)
    previewCidBytes = bytesAlloc(layout.fixedBytes32Size)
    manifestRootBytes = bytesAlloc(layout.fixedBytes32Size)
    chunkMapRootBytes = bytesAlloc(layout.fixedBytes32Size)
    contentCidBytes = bytesAlloc(layout.fixedBytes32Size)
    for i in 0..<layout.fixedBytes32Size:
        bytesSet(authorIdBytes, i, int32(authorId.data[i]) & 255)
        bytesSet(previewCidBytes, i, int32(previewCid.data[i]) & 255)
        bytesSet(manifestRootBytes, i, int32(manifestRoot.data[i]) & 255)
        bytesSet(chunkMapRootBytes, i, int32(chunkMapRoot.data[i]) & 255)
        bytesSet(contentCidBytes, i, int32(contentCid.data[i]) & 255)
    var postBuf: layout.ByteBuf = layout.byteBufInit(224)
    layout.byteBufAppendBytes(postBuf, bytesFromString("v3.content.post"))
    lt.v3AppendU32BE(postBuf, 1)
    layout.byteBufAppendBytes(postBuf, authorIdBytes)
    lt.v3AppendU32BE(postBuf, publishEpoch)
    lt.v3AppendU32BE(postBuf, publishGanzhi)
    layout.byteBufAppendBytes(postBuf, previewCidBytes)
    layout.byteBufAppendBytes(postBuf, manifestRootBytes)
    layout.byteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(postBuf, contentCidBytes)
    lt.v3AppendU32BE(postBuf, accessMode)
    lt.v3AppendU32BE(postBuf, priceUnits)
    let postCid = lt.v3FixedCidFromBuf(postBuf)
    postCidBytes = bytesAlloc(layout.fixedBytes32Size)
    for i in 0..<layout.fixedBytes32Size:
        bytesSet(postCidBytes, i, int32(postCid.data[i]) & 255)
    var signBuf: layout.ByteBuf = layout.byteBufInit(352)
    layout.byteBufAppendBytes(signBuf, bytesFromString("v3.content.manifest.sign"))
    lt.v3AppendU32BE(signBuf, 1)
    layout.byteBufAppendBytes(signBuf, postCidBytes)
    layout.byteBufAppendBytes(signBuf, authorIdBytes)
    lt.v3AppendU32BE(signBuf, publishEpoch)
    lt.v3AppendU32BE(signBuf, publishGanzhi)
    layout.byteBufAppendBytes(signBuf, previewCidBytes)
    layout.byteBufAppendBytes(signBuf, manifestRootBytes)
    layout.byteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(signBuf, contentCidBytes)
    lt.v3AppendU32BE(signBuf, accessMode)
    lt.v3AppendU32BE(signBuf, priceUnits)
    lt.v3AppendU32BE(signBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(signBuf, authorModulusLocal)
    lt.v3AppendU32BE(signBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.byteBufToBytes(signBuf)
    let signatureRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureRes):
        return Err[bool](Error(signatureRes))
    let signature = Value(signatureRes)
    var cidBuf: layout.ByteBuf = layout.byteBufInit(480 + bytesLen(signature))
    layout.byteBufAppendBytes(cidBuf, bytesFromString("v3.content.manifest.cid"))
    lt.v3AppendU32BE(cidBuf, 1)
    layout.byteBufAppendBytes(cidBuf, postCidBytes)
    layout.byteBufAppendBytes(cidBuf, authorIdBytes)
    lt.v3AppendU32BE(cidBuf, publishEpoch)
    lt.v3AppendU32BE(cidBuf, publishGanzhi)
    layout.byteBufAppendBytes(cidBuf, previewCidBytes)
    layout.byteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.byteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(cidBuf, contentCidBytes)
    lt.v3AppendU32BE(cidBuf, accessMode)
    lt.v3AppendU32BE(cidBuf, priceUnits)
    lt.v3AppendU32BE(cidBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(cidBuf, authorModulusLocal)
    lt.v3AppendU32BE(cidBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(cidBuf, authorExponentLocal)
    lt.v3AppendU32BE(cidBuf, bytesLen(signature))
    layout.byteBufAppendBytes(cidBuf, signature)
    let manifestCid = lt.v3FixedCidFromBuf(cidBuf)
    var payloadBuf: layout.ByteBuf = layout.byteBufInit(
        576 +
        bytesLen(authorModulusLocal) +
        bytesLen(authorExponentLocal) +
        bytesLen(signature)
    )
    layout.byteBufAppendBytes(payloadBuf, bytesFromString(v3ContentManifestMagic))
    lt.v3AppendU32BE(payloadBuf, 1)
    layout.byteBufAppendBytes(payloadBuf, postCidBytes)
    layout.byteBufAppendBytes(payloadBuf, authorIdBytes)
    lt.v3AppendU32BE(payloadBuf, publishEpoch)
    lt.v3AppendU32BE(payloadBuf, publishGanzhi)
    layout.byteBufAppendBytes(payloadBuf, previewCidBytes)
    layout.byteBufAppendBytes(payloadBuf, manifestRootBytes)
    layout.byteBufAppendBytes(payloadBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(payloadBuf, contentCidBytes)
    lt.v3AppendU32BE(payloadBuf, accessMode)
    lt.v3AppendU32BE(payloadBuf, priceUnits)
    lt.v3AppendU32BE(payloadBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(payloadBuf, authorModulusLocal)
    lt.v3AppendU32BE(payloadBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(payloadBuf, authorExponentLocal)
    lt.v3AppendU32BE(payloadBuf, bytesLen(signature))
    layout.byteBufAppendBytes(payloadBuf, signature)
    var manifestCidBytes: Bytes
    manifestCidBytes = bytesAlloc(layout.fixedBytes32Size)
    for i in 0..<layout.fixedBytes32Size:
        bytesSet(manifestCidBytes, i, int32(manifestCid.data[i]) & 255)
    layout.byteBufAppendBytes(payloadBuf, manifestCidBytes)
    out = layout.byteBufToBytes(payloadBuf)
    return Ok[bool](true)

fn v3ContentManifestPayloadBuild(out: var Bytes,
                                 previewCid: layout.FixedBytes32,
                                 manifestRoot: layout.FixedBytes32,
                                 chunkMapRoot: layout.FixedBytes32,
                                 contentCid: layout.FixedBytes32,
                                 authorModulus: Bytes,
                                 authorExponent: Bytes,
                                 authorPrivateKey: Bytes,
                                 publishEpoch: int32,
                                 publishGanzhi: int32,
                                 accessMode: int32,
                                 priceUnits: int32): bool =
    var previewCidSet = false
    var manifestRootSet = false
    var chunkMapRootSet = false
    var contentCidSet = false
    for i in 0..<layout.fixedBytes32Size:
        if previewCid.data[i] != 0:
            previewCidSet = true
        if manifestRoot.data[i] != 0:
            manifestRootSet = true
        if chunkMapRoot.data[i] != 0:
            chunkMapRootSet = true
        if contentCid.data[i] != 0:
            contentCidSet = true
    if !previewCidSet:
        return false
    if !manifestRootSet:
        return false
    if !chunkMapRootSet:
        return false
    if !contentCidSet:
        return false
    if publishEpoch < 0:
        return false
    if publishGanzhi < 0:
        return false
    if !v3ContentAccessModeValid(accessMode):
        return false
    if priceUnits < 0:
        return false
    let authorModulusLocal = bytesSlice(authorModulus, 0, bytesLen(authorModulus))
    let authorExponentLocal = bytesSlice(authorExponent, 0, bytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        return false
    let authorPrivateKeyLocal = bytesSlice(authorPrivateKey, 0, bytesLen(authorPrivateKey))
    let authorId = v3ContentAuthorId(authorModulusLocal, authorExponentLocal)
    var authorIdBytes: Bytes
    var previewCidBytes: Bytes
    var manifestRootBytes: Bytes
    var chunkMapRootBytes: Bytes
    var contentCidBytes: Bytes
    var postCidBytes: Bytes
    authorIdBytes = bytesAlloc(layout.fixedBytes32Size)
    previewCidBytes = bytesAlloc(layout.fixedBytes32Size)
    manifestRootBytes = bytesAlloc(layout.fixedBytes32Size)
    chunkMapRootBytes = bytesAlloc(layout.fixedBytes32Size)
    contentCidBytes = bytesAlloc(layout.fixedBytes32Size)
    for i in 0..<layout.fixedBytes32Size:
        bytesSet(authorIdBytes, i, int32(authorId.data[i]) & 255)
        bytesSet(previewCidBytes, i, int32(previewCid.data[i]) & 255)
        bytesSet(manifestRootBytes, i, int32(manifestRoot.data[i]) & 255)
        bytesSet(chunkMapRootBytes, i, int32(chunkMapRoot.data[i]) & 255)
        bytesSet(contentCidBytes, i, int32(contentCid.data[i]) & 255)
    var postBuf: layout.ByteBuf = layout.byteBufInit(224)
    layout.byteBufAppendBytes(postBuf, bytesFromString("v3.content.post"))
    lt.v3AppendU32BE(postBuf, 1)
    layout.byteBufAppendBytes(postBuf, authorIdBytes)
    lt.v3AppendU32BE(postBuf, publishEpoch)
    lt.v3AppendU32BE(postBuf, publishGanzhi)
    layout.byteBufAppendBytes(postBuf, previewCidBytes)
    layout.byteBufAppendBytes(postBuf, manifestRootBytes)
    layout.byteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(postBuf, contentCidBytes)
    lt.v3AppendU32BE(postBuf, accessMode)
    lt.v3AppendU32BE(postBuf, priceUnits)
    let postCid = lt.v3FixedCidFromBuf(postBuf)
    postCidBytes = bytesAlloc(layout.fixedBytes32Size)
    for i in 0..<layout.fixedBytes32Size:
        bytesSet(postCidBytes, i, int32(postCid.data[i]) & 255)
    var signBuf: layout.ByteBuf = layout.byteBufInit(352)
    layout.byteBufAppendBytes(signBuf, bytesFromString("v3.content.manifest.sign"))
    lt.v3AppendU32BE(signBuf, 1)
    layout.byteBufAppendBytes(signBuf, postCidBytes)
    layout.byteBufAppendBytes(signBuf, authorIdBytes)
    lt.v3AppendU32BE(signBuf, publishEpoch)
    lt.v3AppendU32BE(signBuf, publishGanzhi)
    layout.byteBufAppendBytes(signBuf, previewCidBytes)
    layout.byteBufAppendBytes(signBuf, manifestRootBytes)
    layout.byteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(signBuf, contentCidBytes)
    lt.v3AppendU32BE(signBuf, accessMode)
    lt.v3AppendU32BE(signBuf, priceUnits)
    lt.v3AppendU32BE(signBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(signBuf, authorModulusLocal)
    lt.v3AppendU32BE(signBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.byteBufToBytes(signBuf)
    let signatureRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureRes):
        return false
    let signature = Value(signatureRes)
    var cidBuf: layout.ByteBuf = layout.byteBufInit(480 + bytesLen(signature))
    layout.byteBufAppendBytes(cidBuf, bytesFromString("v3.content.manifest.cid"))
    lt.v3AppendU32BE(cidBuf, 1)
    layout.byteBufAppendBytes(cidBuf, postCidBytes)
    layout.byteBufAppendBytes(cidBuf, authorIdBytes)
    lt.v3AppendU32BE(cidBuf, publishEpoch)
    lt.v3AppendU32BE(cidBuf, publishGanzhi)
    layout.byteBufAppendBytes(cidBuf, previewCidBytes)
    layout.byteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.byteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(cidBuf, contentCidBytes)
    lt.v3AppendU32BE(cidBuf, accessMode)
    lt.v3AppendU32BE(cidBuf, priceUnits)
    lt.v3AppendU32BE(cidBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(cidBuf, authorModulusLocal)
    lt.v3AppendU32BE(cidBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(cidBuf, authorExponentLocal)
    lt.v3AppendU32BE(cidBuf, bytesLen(signature))
    layout.byteBufAppendBytes(cidBuf, signature)
    let manifestCid = lt.v3FixedCidFromBuf(cidBuf)
    var payloadBuf: layout.ByteBuf = layout.byteBufInit(
        576 +
        bytesLen(authorModulusLocal) +
        bytesLen(authorExponentLocal) +
        bytesLen(signature)
    )
    layout.byteBufAppendBytes(payloadBuf, bytesFromString(v3ContentManifestMagic))
    lt.v3AppendU32BE(payloadBuf, 1)
    layout.byteBufAppendBytes(payloadBuf, postCidBytes)
    layout.byteBufAppendBytes(payloadBuf, authorIdBytes)
    lt.v3AppendU32BE(payloadBuf, publishEpoch)
    lt.v3AppendU32BE(payloadBuf, publishGanzhi)
    layout.byteBufAppendBytes(payloadBuf, previewCidBytes)
    layout.byteBufAppendBytes(payloadBuf, manifestRootBytes)
    layout.byteBufAppendBytes(payloadBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(payloadBuf, contentCidBytes)
    lt.v3AppendU32BE(payloadBuf, accessMode)
    lt.v3AppendU32BE(payloadBuf, priceUnits)
    lt.v3AppendU32BE(payloadBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(payloadBuf, authorModulusLocal)
    lt.v3AppendU32BE(payloadBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(payloadBuf, authorExponentLocal)
    lt.v3AppendU32BE(payloadBuf, bytesLen(signature))
    layout.byteBufAppendBytes(payloadBuf, signature)
    var manifestCidBytes: Bytes
    manifestCidBytes = bytesAlloc(layout.fixedBytes32Size)
    for i in 0..<layout.fixedBytes32Size:
        bytesSet(manifestCidBytes, i, int32(manifestCid.data[i]) & 255)
    layout.byteBufAppendBytes(payloadBuf, manifestCidBytes)
    out = layout.byteBufToBytes(payloadBuf)
    return true

fn v3ContentManifestPayloadMakeFill(out: var Bytes,
                                    previewCidBytesIn: Bytes,
                                    manifestRootBytesIn: Bytes,
                                    chunkMapRootBytesIn: Bytes,
                                    contentCidBytesIn: Bytes,
                                    authorModulus: Bytes,
                                    authorExponent: Bytes,
                                    authorPrivateKey: Bytes,
                                    publishEpoch: int32,
                                    publishGanzhi: int32,
                                    accessMode: int32,
                                    priceUnits: int32): Result[bool] =
    if bytesLen(previewCidBytesIn) != layout.fixedBytes32Size:
        return Err[bool]("v3 content plane: preview cid bytes length")
    if bytesLen(manifestRootBytesIn) != layout.fixedBytes32Size:
        return Err[bool]("v3 content plane: manifest root bytes length")
    if bytesLen(chunkMapRootBytesIn) != layout.fixedBytes32Size:
        return Err[bool]("v3 content plane: chunk map root bytes length")
    if bytesLen(contentCidBytesIn) != layout.fixedBytes32Size:
        return Err[bool]("v3 content plane: content cid bytes length")
    var previewCidSet = false
    var manifestRootSet = false
    var chunkMapRootSet = false
    var contentCidSet = false
    for i in 0..<layout.fixedBytes32Size:
        if bytesGet(previewCidBytesIn, i) != 0:
            previewCidSet = true
        if bytesGet(manifestRootBytesIn, i) != 0:
            manifestRootSet = true
        if bytesGet(chunkMapRootBytesIn, i) != 0:
            chunkMapRootSet = true
        if bytesGet(contentCidBytesIn, i) != 0:
            contentCidSet = true
    if !previewCidSet:
        return Err[bool]("v3 content plane: missing manifest preview cid")
    if !manifestRootSet:
        return Err[bool]("v3 content plane: missing manifest root")
    if !chunkMapRootSet:
        return Err[bool]("v3 content plane: missing chunk map root")
    if !contentCidSet:
        return Err[bool]("v3 content plane: missing manifest content cid")
    if publishEpoch < 0:
        return Err[bool]("v3 content plane: invalid manifest publish epoch")
    if publishGanzhi < 0:
        return Err[bool]("v3 content plane: invalid manifest publish ganzhi")
    if !v3ContentAccessModeValid(accessMode):
        return Err[bool]("v3 content plane: invalid manifest access mode")
    if priceUnits < 0:
        return Err[bool]("v3 content plane: invalid manifest price units")
    let previewCidBytes = bytesSlice(previewCidBytesIn, 0, bytesLen(previewCidBytesIn))
    let manifestRootBytes = bytesSlice(manifestRootBytesIn, 0, bytesLen(manifestRootBytesIn))
    let chunkMapRootBytes = bytesSlice(chunkMapRootBytesIn, 0, bytesLen(chunkMapRootBytesIn))
    let contentCidBytes = bytesSlice(contentCidBytesIn, 0, bytesLen(contentCidBytesIn))
    let authorModulusLocal = bytesSlice(authorModulus, 0, bytesLen(authorModulus))
    let authorExponentLocal = bytesSlice(authorExponent, 0, bytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        return Err[bool]("v3 content plane: invalid author key parts")
    let authorPrivateKeyLocal = bytesSlice(authorPrivateKey, 0, bytesLen(authorPrivateKey))
    let authorId = v3ContentAuthorId(authorModulusLocal, authorExponentLocal)
    var authorIdBytes: Bytes
    var postCidBytes: Bytes
    layout.fixedBytes32ToBytesInto(authorIdBytes, authorId)
    var postBuf: layout.ByteBuf = layout.byteBufInit(224)
    layout.byteBufAppendBytes(postBuf, bytesFromString("v3.content.post"))
    lt.v3AppendU32BE(postBuf, 1)
    layout.byteBufAppendBytes(postBuf, authorIdBytes)
    lt.v3AppendU32BE(postBuf, publishEpoch)
    lt.v3AppendU32BE(postBuf, publishGanzhi)
    layout.byteBufAppendBytes(postBuf, previewCidBytes)
    layout.byteBufAppendBytes(postBuf, manifestRootBytes)
    layout.byteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(postBuf, contentCidBytes)
    lt.v3AppendU32BE(postBuf, accessMode)
    lt.v3AppendU32BE(postBuf, priceUnits)
    let postCid = lt.v3FixedCidFromBuf(postBuf)
    layout.fixedBytes32ToBytesInto(postCidBytes, postCid)
    var signBuf: layout.ByteBuf = layout.byteBufInit(352)
    layout.byteBufAppendBytes(signBuf, bytesFromString("v3.content.manifest.sign"))
    lt.v3AppendU32BE(signBuf, 1)
    layout.byteBufAppendBytes(signBuf, postCidBytes)
    layout.byteBufAppendBytes(signBuf, authorIdBytes)
    lt.v3AppendU32BE(signBuf, publishEpoch)
    lt.v3AppendU32BE(signBuf, publishGanzhi)
    layout.byteBufAppendBytes(signBuf, previewCidBytes)
    layout.byteBufAppendBytes(signBuf, manifestRootBytes)
    layout.byteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(signBuf, contentCidBytes)
    lt.v3AppendU32BE(signBuf, accessMode)
    lt.v3AppendU32BE(signBuf, priceUnits)
    lt.v3AppendU32BE(signBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(signBuf, authorModulusLocal)
    lt.v3AppendU32BE(signBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.byteBufToBytes(signBuf)
    let signatureRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureRes):
        return Err[bool](Error(signatureRes))
    let signature = Value(signatureRes)
    var cidBuf: layout.ByteBuf = layout.byteBufInit(480 + bytesLen(signature))
    layout.byteBufAppendBytes(cidBuf, bytesFromString("v3.content.manifest.cid"))
    lt.v3AppendU32BE(cidBuf, 1)
    layout.byteBufAppendBytes(cidBuf, postCidBytes)
    layout.byteBufAppendBytes(cidBuf, authorIdBytes)
    lt.v3AppendU32BE(cidBuf, publishEpoch)
    lt.v3AppendU32BE(cidBuf, publishGanzhi)
    layout.byteBufAppendBytes(cidBuf, previewCidBytes)
    layout.byteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.byteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(cidBuf, contentCidBytes)
    lt.v3AppendU32BE(cidBuf, accessMode)
    lt.v3AppendU32BE(cidBuf, priceUnits)
    lt.v3AppendU32BE(cidBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(cidBuf, authorModulusLocal)
    lt.v3AppendU32BE(cidBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(cidBuf, authorExponentLocal)
    lt.v3AppendU32BE(cidBuf, bytesLen(signature))
    layout.byteBufAppendBytes(cidBuf, signature)
    let manifestCid = lt.v3FixedCidFromBuf(cidBuf)
    var manifestCidBytes: Bytes
    layout.fixedBytes32ToBytesInto(manifestCidBytes, manifestCid)
    var payloadBuf: layout.ByteBuf = layout.byteBufInit(
        576 +
        bytesLen(authorModulusLocal) +
        bytesLen(authorExponentLocal) +
        bytesLen(signature)
    )
    layout.byteBufAppendBytes(payloadBuf, bytesFromString(v3ContentManifestMagic))
    lt.v3AppendU32BE(payloadBuf, 1)
    layout.byteBufAppendBytes(payloadBuf, postCidBytes)
    layout.byteBufAppendBytes(payloadBuf, authorIdBytes)
    lt.v3AppendU32BE(payloadBuf, publishEpoch)
    lt.v3AppendU32BE(payloadBuf, publishGanzhi)
    layout.byteBufAppendBytes(payloadBuf, previewCidBytes)
    layout.byteBufAppendBytes(payloadBuf, manifestRootBytes)
    layout.byteBufAppendBytes(payloadBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(payloadBuf, contentCidBytes)
    lt.v3AppendU32BE(payloadBuf, accessMode)
    lt.v3AppendU32BE(payloadBuf, priceUnits)
    lt.v3AppendU32BE(payloadBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(payloadBuf, authorModulusLocal)
    lt.v3AppendU32BE(payloadBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(payloadBuf, authorExponentLocal)
    lt.v3AppendU32BE(payloadBuf, bytesLen(signature))
    layout.byteBufAppendBytes(payloadBuf, signature)
    layout.byteBufAppendBytes(payloadBuf, manifestCidBytes)
    out = layout.byteBufToBytes(payloadBuf)
    return Ok[bool](true)

fn v3ContentManifestPayloadMake(previewCidBytesIn: Bytes,
                                manifestRootBytesIn: Bytes,
                                chunkMapRootBytesIn: Bytes,
                                contentCidBytesIn: Bytes,
                                authorModulus: Bytes,
                                authorExponent: Bytes,
                                authorPrivateKey: Bytes,
                                publishEpoch: int32,
                                publishGanzhi: int32,
                                accessMode: int32,
                                priceUnits: int32): Result[Bytes] =
    var out: Bytes
    let fillRes = v3ContentManifestPayloadMakeFill(out,
                                                   previewCidBytesIn,
                                                   manifestRootBytesIn,
                                                   chunkMapRootBytesIn,
                                                   contentCidBytesIn,
                                                   authorModulus,
                                                   authorExponent,
                                                   authorPrivateKey,
                                                   publishEpoch,
                                                   publishGanzhi,
                                                   accessMode,
                                                   priceUnits)
    if IsErr(fillRes):
        return Err[Bytes](Error(fillRes))
    return Ok[Bytes](out)

fn v3ContentManifestFromArtifacts(artifacts: V3ContentPublishArtifacts,
                                  authorModulus: Bytes,
                                  authorExponent: Bytes,
                                  authorPrivateKey: Bytes,
                                  publishEpoch: int32,
                                  publishGanzhi: int32,
                                  accessMode: int32,
                                  priceUnits: int32): Result[V3ContentManifest] =
    let artifactsOk = v3ContentPublishArtifactsValidate(artifacts)
    if IsErr(artifactsOk):
        return Err[V3ContentManifest](Error(artifactsOk))
    var previewCidBytes: Bytes
    var manifestRootBytes: Bytes
    var chunkMapRootBytes: Bytes
    var contentCidBytes: Bytes
    layout.fixedBytes32ToBytesInto(previewCidBytes, artifacts.blobSummary.summaryCid)
    layout.fixedBytes32ToBytesInto(manifestRootBytes, artifacts.bundleCid)
    layout.fixedBytes32ToBytesInto(chunkMapRootBytes, artifacts.erasureManifest.manifestCid)
    layout.fixedBytes32ToBytesInto(contentCidBytes, artifacts.blobSummary.blobCid)
    return v3ContentManifestMake(previewCidBytes,
                                 manifestRootBytes,
                                 chunkMapRootBytes,
                                 contentCidBytes,
                                 authorModulus,
                                 authorExponent,
                                 authorPrivateKey,
                                 publishEpoch,
                                 publishGanzhi,
                                 accessMode,
                                 priceUnits)

fn v3ContentManifestPayloadFromStubFill(out: var Bytes,
                                        stub: V3ContentStub,
                                        contentCid: layout.FixedBytes32,
                                        authorModulus: Bytes,
                                        authorExponent: Bytes,
                                        authorPrivateKey: Bytes,
                                        publishEpoch: int32,
                                        publishGanzhi: int32,
                                        accessMode: int32,
                                        priceUnits: int32): Result[bool] =
    let stubOk = v3ContentStubValidate(stub)
    if IsErr(stubOk):
        return Err[bool](Error(stubOk))
    if !v3ContentCidSet(contentCid):
        return Err[bool]("v3 content plane: missing manifest content cid")
    return v3ContentManifestPayloadBuildFill(out,
                                             stub.blobSummaryCid,
                                             stub.bundleCid,
                                             stub.manifestCid,
                                             contentCid,
                                             authorModulus,
                                             authorExponent,
                                             authorPrivateKey,
                                             publishEpoch,
                                             publishGanzhi,
                                             accessMode,
                                             priceUnits)

fn v3ContentManifestPayloadFromStub(stub: V3ContentStub,
                                    contentCid: layout.FixedBytes32,
                                    authorModulus: Bytes,
                                    authorExponent: Bytes,
                                    authorPrivateKey: Bytes,
                                    publishEpoch: int32,
                                    publishGanzhi: int32,
                                    accessMode: int32,
                                    priceUnits: int32): Result[Bytes] =
    var out: Bytes
    let fillRes = v3ContentManifestPayloadFromStubFill(out,
                                                       stub,
                                                       contentCid,
                                                       authorModulus,
                                                       authorExponent,
                                                       authorPrivateKey,
                                                       publishEpoch,
                                                       publishGanzhi,
                                                       accessMode,
                                                       priceUnits)
    if IsErr(fillRes):
        return Err[Bytes](Error(fillRes))
    return Ok[Bytes](out)

fn v3ContentManifestPayloadFromStubFieldsFill(out: var Bytes,
                                              topicCid: layout.FixedBytes32,
                                              bundleCid: layout.FixedBytes32,
                                              blobSummaryCid: layout.FixedBytes32,
                                              advertCid: layout.FixedBytes32,
                                              manifestCid: layout.FixedBytes32,
                                              recoveryPlanCid: layout.FixedBytes32,
                                              payloadLen: int32,
                                              contentCid: layout.FixedBytes32,
                                              authorModulus: Bytes,
                                              authorExponent: Bytes,
                                              authorPrivateKey: Bytes,
                                              publishEpoch: int32,
                                              publishGanzhi: int32,
                                              accessMode: int32,
                                              priceUnits: int32): Result[bool] =
    var stub: V3ContentStub
    let stubRes = v3ContentStubFill(stub,
                                    topicCid,
                                    bundleCid,
                                    blobSummaryCid,
                                    advertCid,
                                    manifestCid,
                                    recoveryPlanCid,
                                    payloadLen)
    if IsErr(stubRes):
        return Err[bool](Error(stubRes))
    return v3ContentManifestPayloadFromStubFill(out,
                                                stub,
                                                contentCid,
                                                authorModulus,
                                                authorExponent,
                                                authorPrivateKey,
                                                publishEpoch,
                                                publishGanzhi,
                                                accessMode,
                                                priceUnits)

fn v3ContentManifestPayloadFromStubFields(topicCid: layout.FixedBytes32,
                                          bundleCid: layout.FixedBytes32,
                                          blobSummaryCid: layout.FixedBytes32,
                                          advertCid: layout.FixedBytes32,
                                          manifestCid: layout.FixedBytes32,
                                          recoveryPlanCid: layout.FixedBytes32,
                                          payloadLen: int32,
                                          contentCid: layout.FixedBytes32,
                                          authorModulus: Bytes,
                                          authorExponent: Bytes,
                                          authorPrivateKey: Bytes,
                                          publishEpoch: int32,
                                          publishGanzhi: int32,
                                          accessMode: int32,
                                          priceUnits: int32): Result[Bytes] =
    var out: Bytes
    let fillRes = v3ContentManifestPayloadFromStubFieldsFill(out,
                                                             topicCid,
                                                             bundleCid,
                                                             blobSummaryCid,
                                                             advertCid,
                                                             manifestCid,
                                                             recoveryPlanCid,
                                                             payloadLen,
                                                             contentCid,
                                                             authorModulus,
                                                             authorExponent,
                                                             authorPrivateKey,
                                                             publishEpoch,
                                                             publishGanzhi,
                                                             accessMode,
                                                             priceUnits)
    if IsErr(fillRes):
        return Err[Bytes](Error(fillRes))
    return Ok[Bytes](out)

fn v3ContentManifestPayloadFromStubFieldsBuild(out: var Bytes,
                                               topicCid: layout.FixedBytes32,
                                               bundleCid: layout.FixedBytes32,
                                               blobSummaryCid: layout.FixedBytes32,
                                               advertCid: layout.FixedBytes32,
                                               manifestCid: layout.FixedBytes32,
                                               recoveryPlanCid: layout.FixedBytes32,
                                               payloadLen: int32,
                                               contentCid: layout.FixedBytes32,
                                               authorModulus: Bytes,
                                               authorExponent: Bytes,
                                               authorPrivateKey: Bytes,
                                               publishEpoch: int32,
                                               publishGanzhi: int32,
                                               accessMode: int32,
                                               priceUnits: int32): bool =
    if !v3ContentCidSet(topicCid):
        return false
    if !v3ContentCidSet(bundleCid):
        return false
    if !v3ContentCidSet(blobSummaryCid):
        return false
    if !v3ContentCidSet(advertCid):
        return false
    if !v3ContentCidSet(manifestCid):
        return false
    if !v3ContentCidSet(recoveryPlanCid):
        return false
    if payloadLen < 0:
        return false
    return v3ContentManifestPayloadBuild(out,
                                         blobSummaryCid,
                                         bundleCid,
                                         manifestCid,
                                         contentCid,
                                         authorModulus,
                                         authorExponent,
                                         authorPrivateKey,
                                         publishEpoch,
                                         publishGanzhi,
                                         accessMode,
                                         priceUnits)

fn v3ContentManifestPayloadFromStubFieldsMustFill(out: var Bytes,
                                                  topicCid: layout.FixedBytes32,
                                                  bundleCid: layout.FixedBytes32,
                                                  blobSummaryCid: layout.FixedBytes32,
                                                  advertCid: layout.FixedBytes32,
                                                  manifestCid: layout.FixedBytes32,
                                                  recoveryPlanCid: layout.FixedBytes32,
                                                  payloadLen: int32,
                                                  contentCid: layout.FixedBytes32,
                                                  authorModulus: Bytes,
                                                  authorExponent: Bytes,
                                                  authorPrivateKey: Bytes,
                                                  publishEpoch: int32,
                                                  publishGanzhi: int32,
                                                  accessMode: int32,
                                                  priceUnits: int32) =
    if !v3ContentCidSet(topicCid):
        panic("v3 content plane: missing stub topic cid")
    if !v3ContentCidSet(bundleCid):
        panic("v3 content plane: missing stub bundle cid")
    if !v3ContentCidSet(blobSummaryCid):
        panic("v3 content plane: missing stub blob summary cid")
    if !v3ContentCidSet(advertCid):
        panic("v3 content plane: missing stub advert cid")
    if !v3ContentCidSet(manifestCid):
        panic("v3 content plane: missing stub manifest cid")
    if !v3ContentCidSet(recoveryPlanCid):
        panic("v3 content plane: missing stub recovery plan cid")
    if payloadLen < 0:
        panic("v3 content plane: invalid stub payload length")
    if !v3ContentCidSet(contentCid):
        panic("v3 content plane: missing manifest content cid")
    if publishEpoch < 0:
        panic("v3 content plane: invalid manifest publish epoch")
    if publishGanzhi < 0:
        panic("v3 content plane: invalid manifest publish ganzhi")
    if !v3ContentAccessModeValid(accessMode):
        panic("v3 content plane: invalid manifest access mode")
    if priceUnits < 0:
        panic("v3 content plane: invalid manifest price units")
    let authorModulusLocal = bytesSlice(authorModulus, 0, bytesLen(authorModulus))
    let authorExponentLocal = bytesSlice(authorExponent, 0, bytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        panic("v3 content plane: invalid author key parts")
    let authorPrivateKeyLocal = bytesSlice(authorPrivateKey, 0, bytesLen(authorPrivateKey))
    let authorId = v3ContentAuthorId(authorModulusLocal, authorExponentLocal)
    var authorIdBytes: Bytes
    var previewCidBytes: Bytes
    var manifestRootBytes: Bytes
    var chunkMapRootBytes: Bytes
    var contentCidBytes: Bytes
    var postCidBytes: Bytes
    authorIdBytes = bytesAlloc(layout.fixedBytes32Size)
    previewCidBytes = bytesAlloc(layout.fixedBytes32Size)
    manifestRootBytes = bytesAlloc(layout.fixedBytes32Size)
    chunkMapRootBytes = bytesAlloc(layout.fixedBytes32Size)
    contentCidBytes = bytesAlloc(layout.fixedBytes32Size)
    for i in 0..<layout.fixedBytes32Size:
        bytesSet(authorIdBytes, i, int32(authorId.data[i]) & 255)
        bytesSet(previewCidBytes, i, int32(blobSummaryCid.data[i]) & 255)
        bytesSet(manifestRootBytes, i, int32(bundleCid.data[i]) & 255)
        bytesSet(chunkMapRootBytes, i, int32(manifestCid.data[i]) & 255)
        bytesSet(contentCidBytes, i, int32(contentCid.data[i]) & 255)
    var postBuf: layout.ByteBuf = layout.byteBufInit(224)
    layout.byteBufAppendBytes(postBuf, bytesFromString("v3.content.post"))
    lt.v3AppendU32BE(postBuf, 1)
    layout.byteBufAppendBytes(postBuf, authorIdBytes)
    lt.v3AppendU32BE(postBuf, publishEpoch)
    lt.v3AppendU32BE(postBuf, publishGanzhi)
    layout.byteBufAppendBytes(postBuf, previewCidBytes)
    layout.byteBufAppendBytes(postBuf, manifestRootBytes)
    layout.byteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(postBuf, contentCidBytes)
    lt.v3AppendU32BE(postBuf, accessMode)
    lt.v3AppendU32BE(postBuf, priceUnits)
    let postCid = lt.v3FixedCidFromBuf(postBuf)
    postCidBytes = bytesAlloc(layout.fixedBytes32Size)
    for i in 0..<layout.fixedBytes32Size:
        bytesSet(postCidBytes, i, int32(postCid.data[i]) & 255)
    var signBuf: layout.ByteBuf = layout.byteBufInit(352)
    layout.byteBufAppendBytes(signBuf, bytesFromString("v3.content.manifest.sign"))
    lt.v3AppendU32BE(signBuf, 1)
    layout.byteBufAppendBytes(signBuf, postCidBytes)
    layout.byteBufAppendBytes(signBuf, authorIdBytes)
    lt.v3AppendU32BE(signBuf, publishEpoch)
    lt.v3AppendU32BE(signBuf, publishGanzhi)
    layout.byteBufAppendBytes(signBuf, previewCidBytes)
    layout.byteBufAppendBytes(signBuf, manifestRootBytes)
    layout.byteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(signBuf, contentCidBytes)
    lt.v3AppendU32BE(signBuf, accessMode)
    lt.v3AppendU32BE(signBuf, priceUnits)
    lt.v3AppendU32BE(signBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(signBuf, authorModulusLocal)
    lt.v3AppendU32BE(signBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.byteBufToBytes(signBuf)
    let signatureRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureRes):
        panic("v3 content plane: manifest signature failed")
    let signature = Value(signatureRes)
    var cidBuf: layout.ByteBuf = layout.byteBufInit(480 + bytesLen(signature))
    layout.byteBufAppendBytes(cidBuf, bytesFromString("v3.content.manifest.cid"))
    lt.v3AppendU32BE(cidBuf, 1)
    layout.byteBufAppendBytes(cidBuf, postCidBytes)
    layout.byteBufAppendBytes(cidBuf, authorIdBytes)
    lt.v3AppendU32BE(cidBuf, publishEpoch)
    lt.v3AppendU32BE(cidBuf, publishGanzhi)
    layout.byteBufAppendBytes(cidBuf, previewCidBytes)
    layout.byteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.byteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(cidBuf, contentCidBytes)
    lt.v3AppendU32BE(cidBuf, accessMode)
    lt.v3AppendU32BE(cidBuf, priceUnits)
    lt.v3AppendU32BE(cidBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(cidBuf, authorModulusLocal)
    lt.v3AppendU32BE(cidBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(cidBuf, authorExponentLocal)
    lt.v3AppendU32BE(cidBuf, bytesLen(signature))
    layout.byteBufAppendBytes(cidBuf, signature)
    let manifestCidOut = lt.v3FixedCidFromBuf(cidBuf)
    var payloadBuf: layout.ByteBuf = layout.byteBufInit(
        576 +
        bytesLen(authorModulusLocal) +
        bytesLen(authorExponentLocal) +
        bytesLen(signature)
    )
    layout.byteBufAppendBytes(payloadBuf, bytesFromString(v3ContentManifestMagic))
    lt.v3AppendU32BE(payloadBuf, 1)
    layout.byteBufAppendBytes(payloadBuf, postCidBytes)
    layout.byteBufAppendBytes(payloadBuf, authorIdBytes)
    lt.v3AppendU32BE(payloadBuf, publishEpoch)
    lt.v3AppendU32BE(payloadBuf, publishGanzhi)
    layout.byteBufAppendBytes(payloadBuf, previewCidBytes)
    layout.byteBufAppendBytes(payloadBuf, manifestRootBytes)
    layout.byteBufAppendBytes(payloadBuf, chunkMapRootBytes)
    layout.byteBufAppendBytes(payloadBuf, contentCidBytes)
    lt.v3AppendU32BE(payloadBuf, accessMode)
    lt.v3AppendU32BE(payloadBuf, priceUnits)
    lt.v3AppendU32BE(payloadBuf, bytesLen(authorModulusLocal))
    layout.byteBufAppendBytes(payloadBuf, authorModulusLocal)
    lt.v3AppendU32BE(payloadBuf, bytesLen(authorExponentLocal))
    layout.byteBufAppendBytes(payloadBuf, authorExponentLocal)
    lt.v3AppendU32BE(payloadBuf, bytesLen(signature))
    layout.byteBufAppendBytes(payloadBuf, signature)
    var manifestCidBytes: Bytes
    manifestCidBytes = bytesAlloc(layout.fixedBytes32Size)
    for i in 0..<layout.fixedBytes32Size:
        bytesSet(manifestCidBytes, i, int32(manifestCidOut.data[i]) & 255)
    layout.byteBufAppendBytes(payloadBuf, manifestCidBytes)
    out = layout.byteBufToBytes(payloadBuf)

fn v3ContentManifestEncode(manifest: V3ContentManifest): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(
        576 +
        manifest.authorModulusLen +
        manifest.authorExponentLen +
        manifest.signatureLen
    )
    layout.byteBufAppendBytes(buf, bytesFromString(v3ContentManifestMagic))
    lt.v3AppendU32BE(buf, manifest.version)
    lt.v3AppendFixed32(buf, manifest.postCid)
    lt.v3AppendFixed32(buf, manifest.authorId)
    lt.v3AppendU32BE(buf, manifest.publishEpoch)
    lt.v3AppendU32BE(buf, manifest.publishGanzhi)
    lt.v3AppendFixed32(buf, manifest.previewCid)
    lt.v3AppendFixed32(buf, manifest.manifestRoot)
    lt.v3AppendFixed32(buf, manifest.chunkMapRoot)
    lt.v3AppendFixed32(buf, manifest.contentCid)
    lt.v3AppendU32BE(buf, manifest.accessMode)
    lt.v3AppendU32BE(buf, manifest.priceUnits)
    lt.v3AppendU32BE(buf, manifest.authorModulusLen)
    layout.byteBufAppendBytes(buf, manifest.authorModulus)
    lt.v3AppendU32BE(buf, manifest.authorExponentLen)
    layout.byteBufAppendBytes(buf, manifest.authorExponent)
    lt.v3AppendU32BE(buf, manifest.signatureLen)
    layout.byteBufAppendBytes(buf, manifest.signature)
    lt.v3AppendFixed32(buf, manifest.manifestCid)
    return layout.byteBufToBytes(buf)

fn v3ContentManifestDecodeFill(out: var V3ContentManifest,
                               payload: Bytes): Result[bool] =
    if !v3ContentPayloadHasMagic(payload, v3ContentManifestMagic):
        return Err[bool]("v3 content plane: invalid manifest magic")
    let magicLen = bytesLen(bytesFromString(v3ContentManifestMagic))
    let span = layout.byteSpanFromBytes(payload)
    let versionRes = codec.v3ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[bool](Error(versionRes))
    let postCidRes = codec.v3ReadFixed32(span, magicLen + 4)
    if IsErr(postCidRes):
        return Err[bool](Error(postCidRes))
    let authorIdRes = codec.v3ReadFixed32(span, magicLen + 36)
    if IsErr(authorIdRes):
        return Err[bool](Error(authorIdRes))
    let publishEpochRes = codec.v3ReadU32BE(span, magicLen + 68)
    if IsErr(publishEpochRes):
        return Err[bool](Error(publishEpochRes))
    let publishGanzhiRes = codec.v3ReadU32BE(span, magicLen + 72)
    if IsErr(publishGanzhiRes):
        return Err[bool](Error(publishGanzhiRes))
    let previewCidRes = codec.v3ReadFixed32(span, magicLen + 76)
    if IsErr(previewCidRes):
        return Err[bool](Error(previewCidRes))
    let manifestRootRes = codec.v3ReadFixed32(span, magicLen + 108)
    if IsErr(manifestRootRes):
        return Err[bool](Error(manifestRootRes))
    let chunkMapRootRes = codec.v3ReadFixed32(span, magicLen + 140)
    if IsErr(chunkMapRootRes):
        return Err[bool](Error(chunkMapRootRes))
    let contentCidRes = codec.v3ReadFixed32(span, magicLen + 172)
    if IsErr(contentCidRes):
        return Err[bool](Error(contentCidRes))
    let accessModeRes = codec.v3ReadU32BE(span, magicLen + 204)
    if IsErr(accessModeRes):
        return Err[bool](Error(accessModeRes))
    let priceUnitsRes = codec.v3ReadU32BE(span, magicLen + 208)
    if IsErr(priceUnitsRes):
        return Err[bool](Error(priceUnitsRes))
    let authorModulusLenRes = codec.v3ReadU32BE(span, magicLen + 212)
    if IsErr(authorModulusLenRes):
        return Err[bool](Error(authorModulusLenRes))
    let authorModulusLen = int32(Value(authorModulusLenRes))
    if authorModulusLen <= 0:
        return Err[bool]("v3 content plane: invalid author modulus length")
    let authorModulusStart = magicLen + 216
    let authorModulusEnd = authorModulusStart + authorModulusLen
    if authorModulusEnd + 4 + 4 + layout.fixedBytes32Size > bytesLen(payload):
        return Err[bool]("v3 content plane: truncated manifest payload")
    let authorExponentLenRes = codec.v3ReadU32BE(span, authorModulusEnd)
    if IsErr(authorExponentLenRes):
        return Err[bool](Error(authorExponentLenRes))
    let authorExponentLen = int32(Value(authorExponentLenRes))
    if authorExponentLen <= 0:
        return Err[bool]("v3 content plane: invalid author exponent length")
    let authorExponentStart = authorModulusEnd + 4
    let authorExponentEnd = authorExponentStart + authorExponentLen
    if authorExponentEnd + 4 + layout.fixedBytes32Size > bytesLen(payload):
        return Err[bool]("v3 content plane: truncated manifest payload")
    let signatureLenRes = codec.v3ReadU32BE(span, authorExponentEnd)
    if IsErr(signatureLenRes):
        return Err[bool](Error(signatureLenRes))
    let signatureLen = int32(Value(signatureLenRes))
    if signatureLen <= 0:
        return Err[bool]("v3 content plane: invalid signature length")
    let signatureStart = authorExponentEnd + 4
    let signatureEnd = signatureStart + signatureLen
    if signatureEnd + layout.fixedBytes32Size > bytesLen(payload):
        return Err[bool]("v3 content plane: truncated manifest signature")
    let authorModulus = bytesSlice(payload, authorModulusStart, authorModulusLen)
    let authorExponent = bytesSlice(payload, authorExponentStart, authorExponentLen)
    let manifestCidRes = layout.fixedBytes32FromBytes(bytesSlice(payload,
                                                                 signatureEnd,
                                                                 layout.fixedBytes32Size))
    if IsErr(manifestCidRes):
        return Err[bool]("v3 content plane: manifest cid bytes: " + Error(manifestCidRes))
    out = v3ContentManifestZero()
    out.version = int32(Value(versionRes))
    out.postCid = Value(postCidRes)
    out.authorId = Value(authorIdRes)
    out.publishEpoch = int32(Value(publishEpochRes))
    out.publishGanzhi = int32(Value(publishGanzhiRes))
    out.previewCid = Value(previewCidRes)
    out.manifestRoot = Value(manifestRootRes)
    out.chunkMapRoot = Value(chunkMapRootRes)
    out.contentCid = Value(contentCidRes)
    out.accessMode = int32(Value(accessModeRes))
    out.priceUnits = int32(Value(priceUnitsRes))
    out.authorModulusLen = authorModulusLen
    out.authorModulus = authorModulus
    out.authorExponentLen = authorExponentLen
    out.authorExponent = authorExponent
    out.signatureLen = signatureLen
    out.signature = bytesSlice(payload, signatureStart, signatureLen)
    out.manifestCid = Value(manifestCidRes)
    let manifestOk = v3ContentManifestValidate(out)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    return Ok[bool](true)

fn v3ContentManifestDecode(payload: Bytes): Result[V3ContentManifest] =
    var out: V3ContentManifest
    let fillRes = v3ContentManifestDecodeFill(out, payload)
    if IsErr(fillRes):
        return Err[V3ContentManifest](Error(fillRes))
    return Ok[V3ContentManifest](out)

fn v3ContentManifestValidatePayload(payload: Bytes,
                                    expectedPreviewCid: layout.FixedBytes32): Result[bool] =
    var manifest: V3ContentManifest
    let manifestRes = v3ContentManifestDecodeFill(manifest, payload)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    if !layout.fixedBytes32Equal(manifest.previewCid, expectedPreviewCid):
        return Err[bool]("v3 content plane: preview payload cid mismatch")
    return Ok[bool](true)

fn v3ContentPublishArtifactsCid(topicCid: layout.FixedBytes32,
                                envelopeCid: layout.FixedBytes32,
                                advertCid: layout.FixedBytes32,
                                pubsubPlanCid: layout.FixedBytes32,
                                plumtreePlanCid: layout.FixedBytes32,
                                manifestCid: layout.FixedBytes32,
                                recoveryPlanCid: layout.FixedBytes32,
                                subscriptionCount: int32,
                                proofCount: int32,
                                peerAdvertCount: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.content.publish"))
    lt.v3AppendU32BE(buf, 1)
    lt.v3AppendFixed32(buf, topicCid)
    lt.v3AppendFixed32(buf, envelopeCid)
    lt.v3AppendFixed32(buf, advertCid)
    lt.v3AppendFixed32(buf, pubsubPlanCid)
    lt.v3AppendFixed32(buf, plumtreePlanCid)
    lt.v3AppendFixed32(buf, manifestCid)
    lt.v3AppendFixed32(buf, recoveryPlanCid)
    lt.v3AppendU32BE(buf, subscriptionCount)
    lt.v3AppendU32BE(buf, proofCount)
    lt.v3AppendU32BE(buf, peerAdvertCount)
    return lt.v3FixedCidFromBuf(buf)

fn v3ContentPublishArtifactsExpectedBundleCid(artifacts: V3ContentPublishArtifacts): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.content.publish"))
    lt.v3AppendU32BE(buf, 1)
    lt.v3AppendFixed32(buf, artifacts.topic.topicCid)
    lt.v3AppendFixed32(buf, artifacts.envelope.envelopeCid)
    lt.v3AppendFixed32(buf, artifacts.publishAdvert.advertCid)
    lt.v3AppendFixed32(buf, artifacts.pubsubPlan.planCid)
    lt.v3AppendFixed32(buf, artifacts.plumtreePlan.planCid)
    lt.v3AppendFixed32(buf, artifacts.erasureManifest.manifestCid)
    lt.v3AppendFixed32(buf, artifacts.recoveryPlan.planCid)
    lt.v3AppendU32BE(buf, artifacts.subscriptionCount)
    lt.v3AppendU32BE(buf, artifacts.availabilityProofCount)
    lt.v3AppendU32BE(buf, artifacts.peerAdvertCount)
    return lt.v3FixedCidFromBuf(buf)

fn v3ContentBuildAvailabilityProofs(summary: dag.V3DagBlobSummary,
                                    providerPeerIds: layout.FixedBytes32[],
                                    retainedUntilEpochs: int32[]): Result[dag.V3DagAvailabilityProof[]] =
    if providerPeerIds.len <= 0:
        return Err[dag.V3DagAvailabilityProof[]]("v3 content plane: empty availability providers")
    if providerPeerIds.len != retainedUntilEpochs.len:
        return Err[dag.V3DagAvailabilityProof[]]("v3 content plane: provider/retained count mismatch")
    var out: dag.V3DagAvailabilityProof[]
    out = []
    for i in 0..<providerPeerIds.len:
        let proofRes = dag.v3DagAvailabilityProofMake(summary, providerPeerIds[i], retainedUntilEpochs[i])
        if IsErr(proofRes):
            return Err[dag.V3DagAvailabilityProof[]](Error(proofRes))
        add(out, Value(proofRes))
    return Ok[dag.V3DagAvailabilityProof[]](out)

fn v3ContentPublishArtifactsFill(out: var V3ContentPublishArtifacts,
                                 topic: pubsub.V3PubSubTopic,
                                 root: pubsub.V3PubSubSubscription,
                                 subscriptions: pubsub.V3PubSubSubscription[],
                                 publisherPeerId: layout.FixedBytes32,
                                 blob: Bytes,
                                 dagChunkSize: int32,
                                 providerPeerIds: layout.FixedBytes32[],
                                 retainedUntilEpochs: int32[],
                                 stampEpoch: int32,
                                 stampGanzhi: int32,
                                 erasureDataShardCount: int32,
                                 erasureParityShardCount: int32,
                                 erasureShardPayloadBytes: int32,
                                 shardPayloadCids: layout.FixedBytes32[],
                                 peerAdverts: swarm.V3ErasurePeerAdvert[]): Result[bool] =
    if !layout.fixedBytes32Equal(root.topicCid, topic.topicCid):
        return Err[bool]("v3 content plane: root topic mismatch")
    let summaryRes = dag.v3DagBlobSummaryFromBytes(blob, dagChunkSize)
    if IsErr(summaryRes):
        return Err[bool](Error(summaryRes))
    let summary = Value(summaryRes)
    let proofsRes = v3ContentBuildAvailabilityProofs(summary, providerPeerIds, retainedUntilEpochs)
    if IsErr(proofsRes):
        return Err[bool](Error(proofsRes))
    let proofs = Value(proofsRes)
    let certRes = dag.v3DagAvailabilityCertMake(summary, proofs)
    if IsErr(certRes):
        return Err[bool](Error(certRes))
    let cert = Value(certRes)
    let advertRes = dag.v3DagPublishAdvertMake(topic.topicCid,
                                               publisherPeerId,
                                               summary,
                                               cert,
                                               stampEpoch,
                                               stampGanzhi)
    if IsErr(advertRes):
        return Err[bool](Error(advertRes))
    let advert = Value(advertRes)
    let envelope = pubsub.v3PubSubEnvelopeMake(topic.topicCid,
                                               pubsub.v3PubSubPayloadKindDagAdvert,
                                               advert.advertCid,
                                               summary.summaryCid)
    let pubsubPlanRes = pubsub.v3PubSubBuildPlan(topic, envelope, subscriptions)
    if IsErr(pubsubPlanRes):
        return Err[bool](Error(pubsubPlanRes))
    let pubsubPlan = Value(pubsubPlanRes)
    let plumtreePlanRes = plumtree.v3PlumtreeBuildPlan(topic, root, pubsubPlan, subscriptions)
    if IsErr(plumtreePlanRes):
        return Err[bool](Error(plumtreePlanRes))
    let plumtreePlan = Value(plumtreePlanRes)
    let erasureParamsRes = swarm.v3ErasureEncodingParamsMake(swarm.v3ErasureLayoutRsSystematic,
                                                             erasureDataShardCount,
                                                             erasureParityShardCount,
                                                             erasureShardPayloadBytes)
    if IsErr(erasureParamsRes):
        return Err[bool](Error(erasureParamsRes))
    let erasureParams = Value(erasureParamsRes)
    let manifestRes = swarm.v3ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       erasureParams,
                                                       shardPayloadCids)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    let manifest = Value(manifestRes)
    let recoveryPlanRes = swarm.v3ErasureBuildRecoveryPlan(manifest, erasureParams, peerAdverts)
    if IsErr(recoveryPlanRes):
        return Err[bool](Error(recoveryPlanRes))
    let recoveryPlan = Value(recoveryPlanRes)

    out = v3ContentPublishArtifactsZero()
    out.topic = topic
    out.root = root
    out.subscriptionCount = subscriptions.len
    out.subscriptions = subscriptions
    out.blobSummary = summary
    out.availabilityProofCount = proofs.len
    out.availabilityProofs = proofs
    out.availabilityCert = cert
    out.publishAdvert = advert
    out.envelope = envelope
    out.pubsubPlan = pubsubPlan
    out.plumtreePlan = plumtreePlan
    out.erasureParams = erasureParams
    out.erasureManifest = manifest
    out.peerAdvertCount = peerAdverts.len
    out.peerAdverts = peerAdverts
    out.recoveryPlan = recoveryPlan
    out.bundleCid = v3ContentPublishArtifactsExpectedBundleCid(out)
    return Ok[bool](true)

fn v3ContentPublishArtifactsMake(topic: pubsub.V3PubSubTopic,
                                 root: pubsub.V3PubSubSubscription,
                                 subscriptions: pubsub.V3PubSubSubscription[],
                                 publisherPeerId: layout.FixedBytes32,
                                 blob: Bytes,
                                 dagChunkSize: int32,
                                 providerPeerIds: layout.FixedBytes32[],
                                 retainedUntilEpochs: int32[],
                                 stampEpoch: int32,
                                 stampGanzhi: int32,
                                 erasureDataShardCount: int32,
                                 erasureParityShardCount: int32,
                                 erasureShardPayloadBytes: int32,
                                 shardPayloadCids: layout.FixedBytes32[],
                                 peerAdverts: swarm.V3ErasurePeerAdvert[]): Result[V3ContentPublishArtifacts] =
    var out = v3ContentPublishArtifactsZero()
    let fillRes = v3ContentPublishArtifactsFill(out,
                                                topic,
                                                root,
                                                subscriptions,
                                                publisherPeerId,
                                                blob,
                                                dagChunkSize,
                                                providerPeerIds,
                                                retainedUntilEpochs,
                                                stampEpoch,
                                                stampGanzhi,
                                                erasureDataShardCount,
                                                erasureParityShardCount,
                                                erasureShardPayloadBytes,
                                                shardPayloadCids,
                                                peerAdverts)
    if IsErr(fillRes):
        return Err[V3ContentPublishArtifacts](Error(fillRes))
    return Ok[V3ContentPublishArtifacts](out)

fn v3ContentPublishArtifactsValidate(artifacts: V3ContentPublishArtifacts): Result[bool] =
    if artifacts.version != 1:
        return Err[bool]("v3 content plane: unsupported artifacts version")
    if artifacts.subscriptionCount != artifacts.subscriptions.len:
        return Err[bool]("v3 content plane: subscription count mismatch")
    if artifacts.availabilityProofCount != artifacts.availabilityProofs.len:
        return Err[bool]("v3 content plane: proof count mismatch")
    if artifacts.peerAdvertCount != artifacts.peerAdverts.len:
        return Err[bool]("v3 content plane: peer advert count mismatch")
    if !layout.fixedBytes32Equal(artifacts.root.topicCid, artifacts.topic.topicCid):
        return Err[bool]("v3 content plane: root topic mismatch")

    let summaryOk = dag.v3DagBlobSummaryValidate(artifacts.blobSummary)
    if IsErr(summaryOk):
        return Err[bool](Error(summaryOk))
    let certOk = dag.v3DagAvailabilityCertValidate(artifacts.availabilityCert,
                                                   artifacts.blobSummary,
                                                   artifacts.availabilityProofs)
    if IsErr(certOk):
        return Err[bool](Error(certOk))
    let advertOk = dag.v3DagPublishAdvertValidate(artifacts.publishAdvert,
                                                  artifacts.blobSummary,
                                                  artifacts.availabilityCert)
    if IsErr(advertOk):
        return Err[bool](Error(advertOk))
    if !layout.fixedBytes32Equal(artifacts.envelope.topicCid, artifacts.topic.topicCid):
        return Err[bool]("v3 content plane: envelope topic mismatch")
    if artifacts.envelope.payloadKind != pubsub.v3PubSubPayloadKindDagAdvert:
        return Err[bool]("v3 content plane: envelope payload kind mismatch")
    if !layout.fixedBytes32Equal(artifacts.envelope.payloadCid, artifacts.publishAdvert.advertCid):
        return Err[bool]("v3 content plane: envelope advert cid mismatch")
    if !layout.fixedBytes32Equal(artifacts.envelope.payloadSummaryCid, artifacts.blobSummary.summaryCid):
        return Err[bool]("v3 content plane: envelope summary cid mismatch")

    let pubsubPlanRes = pubsub.v3PubSubBuildPlan(artifacts.topic,
                                                 artifacts.envelope,
                                                 artifacts.subscriptions)
    if IsErr(pubsubPlanRes):
        return Err[bool](Error(pubsubPlanRes))
    let rebuiltPubsubPlan = Value(pubsubPlanRes)
    if !layout.fixedBytes32Equal(artifacts.pubsubPlan.planCid, rebuiltPubsubPlan.planCid):
        return Err[bool]("v3 content plane: pubsub plan cid mismatch")
    if artifacts.pubsubPlan.branchCount != rebuiltPubsubPlan.branchCount:
        return Err[bool]("v3 content plane: pubsub branch count mismatch")

    let plumtreePlanRes = plumtree.v3PlumtreeBuildPlan(artifacts.topic,
                                                       artifacts.root,
                                                       artifacts.pubsubPlan,
                                                       artifacts.subscriptions)
    if IsErr(plumtreePlanRes):
        return Err[bool](Error(plumtreePlanRes))
    let rebuiltPlumtreePlan = Value(plumtreePlanRes)
    if !layout.fixedBytes32Equal(artifacts.plumtreePlan.planCid, rebuiltPlumtreePlan.planCid):
        return Err[bool]("v3 content plane: plumtree plan cid mismatch")
    if artifacts.plumtreePlan.eagerEdgeCount != rebuiltPlumtreePlan.eagerEdgeCount:
        return Err[bool]("v3 content plane: plumtree eager edge count mismatch")
    if artifacts.plumtreePlan.lazyPeerCount != rebuiltPlumtreePlan.lazyPeerCount:
        return Err[bool]("v3 content plane: plumtree lazy peer count mismatch")

    let paramsRes = swarm.v3ErasureEncodingParamsValidate(artifacts.erasureParams)
    if IsErr(paramsRes):
        return Err[bool](Error(paramsRes))
    let manifestRes = swarm.v3ErasureManifestValidate(artifacts.erasureManifest,
                                                      artifacts.erasureParams)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    if !layout.fixedBytes32Equal(artifacts.erasureManifest.blobCid, artifacts.blobSummary.blobCid):
        return Err[bool]("v3 content plane: erasure manifest blob cid mismatch")
    if artifacts.erasureManifest.blobByteLen != artifacts.blobSummary.payloadLen:
        return Err[bool]("v3 content plane: erasure manifest payload length mismatch")
    let rebuiltRecoveryPlanRes = swarm.v3ErasureBuildRecoveryPlan(artifacts.erasureManifest,
                                                                  artifacts.erasureParams,
                                                                  artifacts.peerAdverts)
    if IsErr(rebuiltRecoveryPlanRes):
        return Err[bool](Error(rebuiltRecoveryPlanRes))
    let rebuiltRecoveryPlan = Value(rebuiltRecoveryPlanRes)
    let recoveryPlanOk = swarm.v3ErasureRecoveryPlanValidate(artifacts.recoveryPlan,
                                                             artifacts.erasureManifest,
                                                             artifacts.erasureParams)
    if IsErr(recoveryPlanOk):
        return Err[bool](Error(recoveryPlanOk))
    if !layout.fixedBytes32Equal(artifacts.recoveryPlan.planCid, rebuiltRecoveryPlan.planCid):
        return Err[bool]("v3 content plane: erasure recovery plan cid mismatch")
    if artifacts.recoveryPlan.requestCount != rebuiltRecoveryPlan.requestCount:
        return Err[bool]("v3 content plane: erasure recovery request count mismatch")
    if artifacts.recoveryPlan.minShardCount != swarm.v3ErasureRecoveryThreshold(artifacts.erasureParams):
        return Err[bool]("v3 content plane: erasure recovery threshold mismatch")

    let expectedBundleCid = v3ContentPublishArtifactsExpectedBundleCid(artifacts)
    if !layout.fixedBytes32Equal(artifacts.bundleCid, expectedBundleCid):
        return Err[bool]("v3 content plane: bundle cid mismatch")
    return Ok[bool](true)
