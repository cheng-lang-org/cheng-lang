import std/result
import std/rawbytes
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/codec_binary as codec
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/erasure_swarm as swarm
import cheng/v3/chain/content_plane as content

const
    v3ContentFetchMethodManifest: int32 = 1
    v3ContentFetchMethodPreview: int32 = 2
    v3ContentFetchMethodChunk: int32 = 3
    v3ContentFetchMethodRange: int32 = 4

    v3ContentFetchRequestMagic: str = "v3.content.fetch.request"
    v3ContentFetchResponseMagic: str = "v3.content.fetch.response"

type
    V3ContentFetchRequest =
        version: int32
        method: int32
        targetCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        shardIndex: int32
        rangeStart: int32
        rangeLen: int32
        requestCid: layout.FixedBytes32

    V3ContentFetchResponse =
        version: int32
        method: int32
        targetCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        shardIndex: int32
        rangeStart: int32
        rangeLen: int32
        payloadLen: int32
        payload: Bytes
        responseCid: layout.FixedBytes32

fn v3ContentFetchRequestZero(): V3ContentFetchRequest =
    return V3ContentFetchRequest(
        version: 1,
        method: 0,
        targetCid: layout.fixedBytes32Zero(),
        manifestCid: layout.fixedBytes32Zero(),
        shardIndex: 0,
        rangeStart: 0,
        rangeLen: 0,
        requestCid: layout.fixedBytes32Zero()
    )

fn v3ContentFetchResponseZero(): V3ContentFetchResponse =
    return V3ContentFetchResponse(
        version: 1,
        method: 0,
        targetCid: layout.fixedBytes32Zero(),
        manifestCid: layout.fixedBytes32Zero(),
        shardIndex: 0,
        rangeStart: 0,
        rangeLen: 0,
        payloadLen: 0,
        payload: emptyBytes(),
        responseCid: layout.fixedBytes32Zero()
    )

fn v3ContentFetchCidSet(value: layout.FixedBytes32): bool =
    return !layout.fixedBytes32Equal(value, layout.fixedBytes32Zero())

fn v3ContentFetchMethodValid(method: int32): bool =
    if method == v3ContentFetchMethodManifest:
        return true
    if method == v3ContentFetchMethodPreview:
        return true
    if method == v3ContentFetchMethodChunk:
        return true
    if method == v3ContentFetchMethodRange:
        return true
    return false

fn v3ContentFetchRequestCid(method: int32,
                            targetCid: layout.FixedBytes32,
                            manifestCid: layout.FixedBytes32,
                            shardIndex: int32,
                            rangeStart: int32,
                            rangeLen: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(192)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.content.fetch.request.cid"))
    lt.v3AppendU32BE(buf, 1)
    lt.v3AppendU32BE(buf, method)
    lt.v3AppendFixed32(buf, targetCid)
    lt.v3AppendFixed32(buf, manifestCid)
    lt.v3AppendU32BE(buf, shardIndex)
    lt.v3AppendU32BE(buf, rangeStart)
    lt.v3AppendU32BE(buf, rangeLen)
    return lt.v3FixedCidFromBuf(buf)

fn v3ContentFetchResponseCid(request: V3ContentFetchRequest,
                             payload: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256 + bytesLen(payload))
    layout.byteBufAppendBytes(buf, bytesFromString("v3.content.fetch.response.cid"))
    lt.v3AppendU32BE(buf, 1)
    lt.v3AppendU32BE(buf, request.method)
    lt.v3AppendFixed32(buf, request.targetCid)
    lt.v3AppendFixed32(buf, request.manifestCid)
    lt.v3AppendU32BE(buf, request.shardIndex)
    lt.v3AppendU32BE(buf, request.rangeStart)
    lt.v3AppendU32BE(buf, request.rangeLen)
    lt.v3AppendU32BE(buf, bytesLen(payload))
    layout.byteBufAppendBytes(buf, payload)
    return lt.v3FixedCidFromBuf(buf)

fn v3ContentFetchRequestValidate(request: V3ContentFetchRequest): Result[bool] =
    if request.version != 1:
        return Err[bool]("v3 content fetch: unsupported request version")
    if !v3ContentFetchMethodValid(request.method):
        return Err[bool]("v3 content fetch: invalid request method")
    if !v3ContentFetchCidSet(request.targetCid):
        return Err[bool]("v3 content fetch: missing request target cid")
    if request.method == v3ContentFetchMethodManifest:
        if !v3ContentFetchCidSet(request.manifestCid):
            return Err[bool]("v3 content fetch: missing manifest request cid")
        if !layout.fixedBytes32Equal(request.targetCid, request.manifestCid):
            return Err[bool]("v3 content fetch: manifest target mismatch")
        if request.shardIndex != 0 || request.rangeStart != 0 || request.rangeLen != 0:
            return Err[bool]("v3 content fetch: invalid manifest request selectors")
    elif request.method == v3ContentFetchMethodPreview:
        if v3ContentFetchCidSet(request.manifestCid):
            return Err[bool]("v3 content fetch: preview request must not carry manifest cid")
        if request.shardIndex != 0 || request.rangeStart != 0 || request.rangeLen != 0:
            return Err[bool]("v3 content fetch: invalid preview request selectors")
    elif request.method == v3ContentFetchMethodChunk:
        if !v3ContentFetchCidSet(request.manifestCid):
            return Err[bool]("v3 content fetch: missing chunk request manifest cid")
        if request.shardIndex < 0:
            return Err[bool]("v3 content fetch: invalid chunk request shard index")
        if request.rangeStart != 0 || request.rangeLen != 0:
            return Err[bool]("v3 content fetch: invalid chunk request range")
    else:
        if v3ContentFetchCidSet(request.manifestCid):
            return Err[bool]("v3 content fetch: range request must not carry manifest cid")
        if request.rangeStart < 0:
            return Err[bool]("v3 content fetch: invalid range request start")
        if request.rangeLen <= 0:
            return Err[bool]("v3 content fetch: invalid range request length")
        if request.shardIndex != 0:
            return Err[bool]("v3 content fetch: range request must not carry shard index")
    let expectedCid = v3ContentFetchRequestCid(request.method,
                                               request.targetCid,
                                               request.manifestCid,
                                               request.shardIndex,
                                               request.rangeStart,
                                               request.rangeLen)
    if !layout.fixedBytes32Equal(request.requestCid, expectedCid):
        return Err[bool]("v3 content fetch: request cid mismatch")
    return Ok[bool](true)

fn v3ContentFetchRequestMake(method: int32,
                             targetCid: layout.FixedBytes32,
                             manifestCid: layout.FixedBytes32,
                             shardIndex: int32,
                             rangeStart: int32,
                             rangeLen: int32): Result[V3ContentFetchRequest] =
    var out = v3ContentFetchRequestZero()
    out.version = 1
    out.method = method
    out.targetCid = targetCid
    out.manifestCid = manifestCid
    out.shardIndex = shardIndex
    out.rangeStart = rangeStart
    out.rangeLen = rangeLen
    out.requestCid = v3ContentFetchRequestCid(out.method,
                                              out.targetCid,
                                              out.manifestCid,
                                              out.shardIndex,
                                              out.rangeStart,
                                              out.rangeLen)
    let requestOk = v3ContentFetchRequestValidate(out)
    if IsErr(requestOk):
        return Err[V3ContentFetchRequest](Error(requestOk))
    return Ok[V3ContentFetchRequest](out)

fn v3ContentFetchRequestManifest(manifestCid: layout.FixedBytes32): Result[V3ContentFetchRequest] =
    return v3ContentFetchRequestMake(v3ContentFetchMethodManifest, manifestCid, manifestCid, 0, 0, 0)

fn v3ContentFetchRequestPreview(previewCid: layout.FixedBytes32): Result[V3ContentFetchRequest] =
    return v3ContentFetchRequestMake(v3ContentFetchMethodPreview,
                                     previewCid,
                                     layout.fixedBytes32Zero(),
                                     0,
                                     0,
                                     0)

fn v3ContentFetchRequestChunk(manifestCid: layout.FixedBytes32,
                              shardIndex: int32,
                              shardCid: layout.FixedBytes32): Result[V3ContentFetchRequest] =
    return v3ContentFetchRequestMake(v3ContentFetchMethodChunk, shardCid, manifestCid, shardIndex, 0, 0)

fn v3ContentFetchRequestRange(blobCid: layout.FixedBytes32,
                              rangeStart: int32,
                              rangeLen: int32): Result[V3ContentFetchRequest] =
    return v3ContentFetchRequestMake(v3ContentFetchMethodRange,
                                     blobCid,
                                     layout.fixedBytes32Zero(),
                                     0,
                                     rangeStart,
                                     rangeLen)

fn v3ContentFetchRequestFromShardPull(request: swarm.V3ErasureShardPullRequest): Result[V3ContentFetchRequest] =
    return v3ContentFetchRequestChunk(request.manifestCid, request.shardIndex, request.shardCid)

fn v3ContentFetchRequestToShardPull(request: V3ContentFetchRequest): Result[swarm.V3ErasureShardPullRequest] =
    let requestOk = v3ContentFetchRequestValidate(request)
    if IsErr(requestOk):
        return Err[swarm.V3ErasureShardPullRequest](Error(requestOk))
    if request.method != v3ContentFetchMethodChunk:
        return Err[swarm.V3ErasureShardPullRequest]("v3 content fetch: request is not chunk fetch")
    var out = swarm.v3ErasureShardPullRequestZero()
    out.manifestCid = request.manifestCid
    out.shardIndex = request.shardIndex
    out.shardCid = request.targetCid
    out.requestCid = swarm.v3ErasureShardPullRequestCid(out.manifestCid, out.shardIndex, out.shardCid)
    return Ok[swarm.V3ErasureShardPullRequest](out)

fn v3ContentPayloadHasMagic(payload: Bytes, magic: str): bool =
    let magicBytes = bytesFromString(magic)
    if bytesLen(payload) < bytesLen(magicBytes):
        return false
    for i in 0..<bytesLen(magicBytes):
        if bytesGet(payload, i) != bytesGet(magicBytes, i):
            return false
    return true

fn v3ContentFetchRequestEncode(request: V3ContentFetchRequest): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(192)
    layout.byteBufAppendBytes(buf, bytesFromString(v3ContentFetchRequestMagic))
    lt.v3AppendU32BE(buf, request.version)
    lt.v3AppendU32BE(buf, request.method)
    lt.v3AppendFixed32(buf, request.targetCid)
    lt.v3AppendFixed32(buf, request.manifestCid)
    lt.v3AppendU32BE(buf, request.shardIndex)
    lt.v3AppendU32BE(buf, request.rangeStart)
    lt.v3AppendU32BE(buf, request.rangeLen)
    lt.v3AppendFixed32(buf, request.requestCid)
    return layout.byteBufToBytes(buf)

fn v3ContentFetchRequestDecode(payload: Bytes): Result[V3ContentFetchRequest] =
    if !v3ContentPayloadHasMagic(payload, v3ContentFetchRequestMagic):
        return Err[V3ContentFetchRequest]("v3 content fetch: invalid request magic")
    let magicLen = bytesLen(bytesFromString(v3ContentFetchRequestMagic))
    let span = layout.byteSpanFromBytes(payload)
    let versionRes = codec.v3ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[V3ContentFetchRequest](Error(versionRes))
    let methodRes = codec.v3ReadU32BE(span, magicLen + 4)
    if IsErr(methodRes):
        return Err[V3ContentFetchRequest](Error(methodRes))
    let targetCidRes = codec.v3ReadFixed32(span, magicLen + 8)
    if IsErr(targetCidRes):
        return Err[V3ContentFetchRequest](Error(targetCidRes))
    let manifestCidRes = codec.v3ReadFixed32(span, magicLen + 40)
    if IsErr(manifestCidRes):
        return Err[V3ContentFetchRequest](Error(manifestCidRes))
    let shardIndexRes = codec.v3ReadU32BE(span, magicLen + 72)
    if IsErr(shardIndexRes):
        return Err[V3ContentFetchRequest](Error(shardIndexRes))
    let rangeStartRes = codec.v3ReadU32BE(span, magicLen + 76)
    if IsErr(rangeStartRes):
        return Err[V3ContentFetchRequest](Error(rangeStartRes))
    let rangeLenRes = codec.v3ReadU32BE(span, magicLen + 80)
    if IsErr(rangeLenRes):
        return Err[V3ContentFetchRequest](Error(rangeLenRes))
    let requestCidRes = codec.v3ReadFixed32(span, magicLen + 84)
    if IsErr(requestCidRes):
        return Err[V3ContentFetchRequest](Error(requestCidRes))
    var out = v3ContentFetchRequestZero()
    out.version = int32(Value(versionRes))
    out.method = int32(Value(methodRes))
    out.targetCid = Value(targetCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.shardIndex = int32(Value(shardIndexRes))
    out.rangeStart = int32(Value(rangeStartRes))
    out.rangeLen = int32(Value(rangeLenRes))
    out.requestCid = Value(requestCidRes)
    let requestOk = v3ContentFetchRequestValidate(out)
    if IsErr(requestOk):
        return Err[V3ContentFetchRequest](Error(requestOk))
    return Ok[V3ContentFetchRequest](out)

fn v3ContentFetchResponseValidate(response: V3ContentFetchResponse,
                                  request: V3ContentFetchRequest): Result[bool] =
    let requestOk = v3ContentFetchRequestValidate(request)
    if IsErr(requestOk):
        return Err[bool](Error(requestOk))
    if response.version != 1:
        return Err[bool]("v3 content fetch: unsupported response version")
    if response.method != request.method:
        return Err[bool]("v3 content fetch: response method mismatch")
    if !layout.fixedBytes32Equal(response.targetCid, request.targetCid):
        return Err[bool]("v3 content fetch: response target mismatch")
    if !layout.fixedBytes32Equal(response.manifestCid, request.manifestCid):
        return Err[bool]("v3 content fetch: response manifest mismatch")
    if response.shardIndex != request.shardIndex:
        return Err[bool]("v3 content fetch: response shard index mismatch")
    if response.rangeStart != request.rangeStart:
        return Err[bool]("v3 content fetch: response range start mismatch")
    if response.rangeLen != request.rangeLen:
        return Err[bool]("v3 content fetch: response range length mismatch")
    if response.payloadLen != bytesLen(response.payload):
        return Err[bool]("v3 content fetch: response payload length mismatch")
    let expectedCid = v3ContentFetchResponseCid(request, response.payload)
    if !layout.fixedBytes32Equal(response.responseCid, expectedCid):
        return Err[bool]("v3 content fetch: response cid mismatch")
    return Ok[bool](true)

fn v3ContentFetchResponseMake(request: V3ContentFetchRequest,
                              payload: Bytes): Result[V3ContentFetchResponse] =
    let requestOk = v3ContentFetchRequestValidate(request)
    if IsErr(requestOk):
        return Err[V3ContentFetchResponse](Error(requestOk))
    var out = v3ContentFetchResponseZero()
    out.version = request.version
    out.method = request.method
    out.targetCid = request.targetCid
    out.manifestCid = request.manifestCid
    out.shardIndex = request.shardIndex
    out.rangeStart = request.rangeStart
    out.rangeLen = request.rangeLen
    out.payloadLen = bytesLen(payload)
    out.payload = payload
    out.responseCid = v3ContentFetchResponseCid(request, payload)
    return Ok[V3ContentFetchResponse](out)

fn v3ContentFetchResponseEncode(response: V3ContentFetchResponse): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(256 + response.payloadLen)
    layout.byteBufAppendBytes(buf, bytesFromString(v3ContentFetchResponseMagic))
    lt.v3AppendU32BE(buf, response.version)
    lt.v3AppendU32BE(buf, response.method)
    lt.v3AppendFixed32(buf, response.targetCid)
    lt.v3AppendFixed32(buf, response.manifestCid)
    lt.v3AppendU32BE(buf, response.shardIndex)
    lt.v3AppendU32BE(buf, response.rangeStart)
    lt.v3AppendU32BE(buf, response.rangeLen)
    lt.v3AppendU32BE(buf, response.payloadLen)
    layout.byteBufAppendBytes(buf, response.payload)
    lt.v3AppendFixed32(buf, response.responseCid)
    return layout.byteBufToBytes(buf)

fn v3ContentFetchResponseDecode(payload: Bytes): Result[V3ContentFetchResponse] =
    if !v3ContentPayloadHasMagic(payload, v3ContentFetchResponseMagic):
        return Err[V3ContentFetchResponse]("v3 content fetch: invalid response magic")
    let magicLen = bytesLen(bytesFromString(v3ContentFetchResponseMagic))
    let span = layout.byteSpanFromBytes(payload)
    let versionRes = codec.v3ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[V3ContentFetchResponse](Error(versionRes))
    let methodRes = codec.v3ReadU32BE(span, magicLen + 4)
    if IsErr(methodRes):
        return Err[V3ContentFetchResponse](Error(methodRes))
    let targetCidRes = codec.v3ReadFixed32(span, magicLen + 8)
    if IsErr(targetCidRes):
        return Err[V3ContentFetchResponse](Error(targetCidRes))
    let manifestCidRes = codec.v3ReadFixed32(span, magicLen + 40)
    if IsErr(manifestCidRes):
        return Err[V3ContentFetchResponse](Error(manifestCidRes))
    let shardIndexRes = codec.v3ReadU32BE(span, magicLen + 72)
    if IsErr(shardIndexRes):
        return Err[V3ContentFetchResponse](Error(shardIndexRes))
    let rangeStartRes = codec.v3ReadU32BE(span, magicLen + 76)
    if IsErr(rangeStartRes):
        return Err[V3ContentFetchResponse](Error(rangeStartRes))
    let rangeLenRes = codec.v3ReadU32BE(span, magicLen + 80)
    if IsErr(rangeLenRes):
        return Err[V3ContentFetchResponse](Error(rangeLenRes))
    let payloadLenRes = codec.v3ReadU32BE(span, magicLen + 84)
    if IsErr(payloadLenRes):
        return Err[V3ContentFetchResponse](Error(payloadLenRes))
    let payloadLen = int32(Value(payloadLenRes))
    let payloadOffset = magicLen + 88
    if payloadLen < 0 || payloadOffset + payloadLen + 32 > bytesLen(payload):
        return Err[V3ContentFetchResponse]("v3 content fetch: truncated response payload")
    let responsePayload = bytesSlice(payload, payloadOffset, payloadLen)
    let responseCidRes = codec.v3ReadFixed32(span, payloadOffset + payloadLen)
    if IsErr(responseCidRes):
        return Err[V3ContentFetchResponse](Error(responseCidRes))
    var out = v3ContentFetchResponseZero()
    out.version = int32(Value(versionRes))
    out.method = int32(Value(methodRes))
    out.targetCid = Value(targetCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.shardIndex = int32(Value(shardIndexRes))
    out.rangeStart = int32(Value(rangeStartRes))
    out.rangeLen = int32(Value(rangeLenRes))
    out.payloadLen = payloadLen
    out.payload = responsePayload
    out.responseCid = Value(responseCidRes)
    let requestRes = v3ContentFetchRequestMake(out.method,
                                               out.targetCid,
                                               out.manifestCid,
                                               out.shardIndex,
                                               out.rangeStart,
                                               out.rangeLen)
    if IsErr(requestRes):
        return Err[V3ContentFetchResponse](Error(requestRes))
    let responseOk = v3ContentFetchResponseValidate(out, Value(requestRes))
    if IsErr(responseOk):
        return Err[V3ContentFetchResponse](Error(responseOk))
    return Ok[V3ContentFetchResponse](out)

fn v3ContentFetchResponseToManifestFill(out: var swarm.V3ErasureShardManifest,
                                        request: V3ContentFetchRequest,
                                        response: V3ContentFetchResponse): Result[bool] =
    let responseOk = v3ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[bool](Error(responseOk))
    if request.method != v3ContentFetchMethodManifest:
        return Err[bool]("v3 content fetch: request is not manifest fetch")
    let payloadOk = swarm.v3ErasureShardManifestValidatePayload(response.payload, request.manifestCid)
    if IsErr(payloadOk):
        return Err[bool](Error(payloadOk))
    let manifestRes = swarm.v3ErasureShardManifestDecode(response.payload)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    out = Value(manifestRes)
    return Ok[bool](true)

fn v3ContentFetchResponseToManifest(request: V3ContentFetchRequest,
                                    response: V3ContentFetchResponse): Result[swarm.V3ErasureShardManifest] =
    let responseOk = v3ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[swarm.V3ErasureShardManifest](Error(responseOk))
    if request.method != v3ContentFetchMethodManifest:
        return Err[swarm.V3ErasureShardManifest]("v3 content fetch: request is not manifest fetch")
    let payloadOk = swarm.v3ErasureShardManifestValidatePayload(response.payload, request.manifestCid)
    if IsErr(payloadOk):
        return Err[swarm.V3ErasureShardManifest](Error(payloadOk))
    let manifestRes = swarm.v3ErasureShardManifestDecode(response.payload)
    if IsErr(manifestRes):
        return Err[swarm.V3ErasureShardManifest](Error(manifestRes))
    return Ok[swarm.V3ErasureShardManifest](Value(manifestRes))

fn v3ContentFetchResponseToPreviewFill(out: var content.V3ContentStub,
                                       request: V3ContentFetchRequest,
                                       response: V3ContentFetchResponse): Result[bool] =
    let responseOk = v3ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[bool](Error(responseOk))
    if request.method != v3ContentFetchMethodPreview:
        return Err[bool]("v3 content fetch: request is not preview fetch")
    let stubRes = content.v3ContentStubDecode(response.payload)
    if IsErr(stubRes):
        return Err[bool](Error(stubRes))
    let stub = Value(stubRes)
    if !layout.fixedBytes32Equal(stub.blobSummaryCid, request.targetCid):
        return Err[bool]("v3 content fetch: preview target mismatch")
    out = stub
    return Ok[bool](true)

fn v3ContentFetchResponseToPreview(request: V3ContentFetchRequest,
                                   response: V3ContentFetchResponse): Result[content.V3ContentStub] =
    let responseOk = v3ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[content.V3ContentStub](Error(responseOk))
    if request.method != v3ContentFetchMethodPreview:
        return Err[content.V3ContentStub]("v3 content fetch: request is not preview fetch")
    let stubRes = content.v3ContentStubDecode(response.payload)
    if IsErr(stubRes):
        return Err[content.V3ContentStub](Error(stubRes))
    let stub = Value(stubRes)
    if !layout.fixedBytes32Equal(stub.blobSummaryCid, request.targetCid):
        return Err[content.V3ContentStub]("v3 content fetch: preview target mismatch")
    return Ok[content.V3ContentStub](stub)

fn v3ContentFetchResponseToShardPullFill(out: var swarm.V3ErasureShardPullResponse,
                                         request: V3ContentFetchRequest,
                                         response: V3ContentFetchResponse): Result[bool] =
    let responseOk = v3ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[bool](Error(responseOk))
    let shardRequestRes = v3ContentFetchRequestToShardPull(request)
    if IsErr(shardRequestRes):
        return Err[bool](Error(shardRequestRes))
    let shardRequest = Value(shardRequestRes)
    let shardResponseRes = swarm.v3ErasureShardPullResponseMake(shardRequest, response.payload)
    if IsErr(shardResponseRes):
        return Err[bool](Error(shardResponseRes))
    out = Value(shardResponseRes)
    return Ok[bool](true)

fn v3ContentFetchResponseToShardPull(request: V3ContentFetchRequest,
                                     response: V3ContentFetchResponse): Result[swarm.V3ErasureShardPullResponse] =
    let responseOk = v3ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[swarm.V3ErasureShardPullResponse](Error(responseOk))
    let shardRequestRes = v3ContentFetchRequestToShardPull(request)
    if IsErr(shardRequestRes):
        return Err[swarm.V3ErasureShardPullResponse](Error(shardRequestRes))
    let shardResponseRes = swarm.v3ErasureShardPullResponseMake(Value(shardRequestRes), response.payload)
    if IsErr(shardResponseRes):
        return Err[swarm.V3ErasureShardPullResponse](Error(shardResponseRes))
    return Ok[swarm.V3ErasureShardPullResponse](Value(shardResponseRes))
