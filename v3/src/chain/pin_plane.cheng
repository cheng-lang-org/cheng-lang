import std/result
import std/rawbytes
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/codec_binary as codec
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/dag_mempool as dag
import cheng/v3/chain/erasure_swarm as swarm
import cheng/v3/chain/content_plane as content

const
    v3PinSettlementStatusReward: int32 = 1
    v3PinSettlementStatusSlash: int32 = 2

    v3PinOfferMagic: str = "v3.pin.offer"
    v3PinAcceptMagic: str = "v3.pin.accept"
    v3PinChallengeMagic: str = "v3.pin.challenge"
    v3PinProofMagic: str = "v3.pin.proof"
    v3PinSettlementMagic: str = "v3.pin.settlement"

type
    V3PinOffer =
        version: int32
        bundleCid: layout.FixedBytes32
        blobSummaryCid: layout.FixedBytes32
        blobCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        minRetainedUntilEpoch: int32
        challengeShardCount: int32
        rewardUnits: int32
        slashUnits: int32
        offerCid: layout.FixedBytes32

    V3PinAccept =
        version: int32
        offerCid: layout.FixedBytes32
        providerPeerId: layout.FixedBytes32
        retainedUntilEpoch: int32
        rewardUnits: int32
        slashUnits: int32
        acceptCid: layout.FixedBytes32

    V3PinChallenge =
        version: int32
        offerCid: layout.FixedBytes32
        acceptCid: layout.FixedBytes32
        providerPeerId: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        challengeEpoch: int32
        shardCount: int32
        shardIndices: int32[]
        shardCids: layout.FixedBytes32[]
        challengeCid: layout.FixedBytes32

    V3PinProof =
        version: int32
        challengeCid: layout.FixedBytes32
        acceptCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        shardCount: int32
        shardIndices: int32[]
        shardPayloadLens: int32[]
        payloadConcatLen: int32
        payloadConcat: Bytes
        proofCid: layout.FixedBytes32

    V3PinSettlement =
        version: int32
        offerCid: layout.FixedBytes32
        acceptCid: layout.FixedBytes32
        challengeCid: layout.FixedBytes32
        proofCid: layout.FixedBytes32
        settledEpoch: int32
        status: int32
        rewardUnits: int32
        slashUnits: int32
        settlementCid: layout.FixedBytes32

fn v3PinOfferZero(): V3PinOffer =
    return V3PinOffer(
        version: 1,
        bundleCid: layout.fixedBytes32Zero(),
        blobSummaryCid: layout.fixedBytes32Zero(),
        blobCid: layout.fixedBytes32Zero(),
        manifestCid: layout.fixedBytes32Zero(),
        minRetainedUntilEpoch: 0,
        challengeShardCount: 0,
        rewardUnits: 0,
        slashUnits: 0,
        offerCid: layout.fixedBytes32Zero()
    )

fn v3PinAcceptZero(): V3PinAccept =
    return V3PinAccept(
        version: 1,
        offerCid: layout.fixedBytes32Zero(),
        providerPeerId: layout.fixedBytes32Zero(),
        retainedUntilEpoch: 0,
        rewardUnits: 0,
        slashUnits: 0,
        acceptCid: layout.fixedBytes32Zero()
    )

fn v3PinChallengeZero(): V3PinChallenge =
    return V3PinChallenge(
        version: 1,
        offerCid: layout.fixedBytes32Zero(),
        acceptCid: layout.fixedBytes32Zero(),
        providerPeerId: layout.fixedBytes32Zero(),
        manifestCid: layout.fixedBytes32Zero(),
        challengeEpoch: 0,
        shardCount: 0,
        shardIndices: [],
        shardCids: [],
        challengeCid: layout.fixedBytes32Zero()
    )

fn v3PinProofZero(): V3PinProof =
    return V3PinProof(
        version: 1,
        challengeCid: layout.fixedBytes32Zero(),
        acceptCid: layout.fixedBytes32Zero(),
        manifestCid: layout.fixedBytes32Zero(),
        shardCount: 0,
        shardIndices: [],
        shardPayloadLens: [],
        payloadConcatLen: 0,
        payloadConcat: emptyBytes(),
        proofCid: layout.fixedBytes32Zero()
    )

fn v3PinSettlementZero(): V3PinSettlement =
    return V3PinSettlement(
        version: 1,
        offerCid: layout.fixedBytes32Zero(),
        acceptCid: layout.fixedBytes32Zero(),
        challengeCid: layout.fixedBytes32Zero(),
        proofCid: layout.fixedBytes32Zero(),
        settledEpoch: 0,
        status: 0,
        rewardUnits: 0,
        slashUnits: 0,
        settlementCid: layout.fixedBytes32Zero()
    )

fn v3PinCidSet(value: layout.FixedBytes32): bool =
    return !layout.fixedBytes32Equal(value, layout.fixedBytes32Zero())

fn v3PinPayloadHasMagic(payload: Bytes, magic: str): bool =
    let magicBytes = bytesFromString(magic)
    if bytesLen(payload) < bytesLen(magicBytes):
        return false
    for i in 0..<bytesLen(magicBytes):
        if bytesGet(payload, i) != bytesGet(magicBytes, i):
            return false
    return true

fn v3PinSettlementStatusValid(status: int32): bool =
    if status == v3PinSettlementStatusReward:
        return true
    if status == v3PinSettlementStatusSlash:
        return true
    return false

fn v3PinIndexSetContains(values: int32[], value: int32): bool =
    for i in 0..<values.len:
        if values[i] == value:
            return true
    return false

fn v3PinManifestShardPos(manifest: swarm.V3ErasureShardManifest,
                         shardIndex: int32): int32 =
    for i in 0..<manifest.shardCount:
        if manifest.shardIndices[i] == shardIndex:
            return i
    return -1

fn v3PinChallengeResponsePos(responses: swarm.V3ErasureShardPullResponse[],
                             manifestCid: layout.FixedBytes32,
                             shardIndex: int32,
                             shardCid: layout.FixedBytes32): int32 =
    for i in 0..<responses.len:
        let response = responses[i]
        if !layout.fixedBytes32Equal(response.manifestCid, manifestCid):
            continue
        if response.shardIndex != shardIndex:
            continue
        if !layout.fixedBytes32Equal(response.shardCid, shardCid):
            continue
        return i
    return -1

fn v3PinOfferCid(bundleCid: layout.FixedBytes32,
                 blobSummaryCid: layout.FixedBytes32,
                 blobCid: layout.FixedBytes32,
                 manifestCid: layout.FixedBytes32,
                 minRetainedUntilEpoch: int32,
                 challengeShardCount: int32,
                 rewardUnits: int32,
                 slashUnits: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(192)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.pin.offer.cid"))
    lt.v3AppendU32BE(buf, 1)
    lt.v3AppendFixed32(buf, bundleCid)
    lt.v3AppendFixed32(buf, blobSummaryCid)
    lt.v3AppendFixed32(buf, blobCid)
    lt.v3AppendFixed32(buf, manifestCid)
    lt.v3AppendU32BE(buf, minRetainedUntilEpoch)
    lt.v3AppendU32BE(buf, challengeShardCount)
    lt.v3AppendU32BE(buf, rewardUnits)
    lt.v3AppendU32BE(buf, slashUnits)
    return lt.v3FixedCidFromBuf(buf)

fn v3PinAcceptCid(offerCid: layout.FixedBytes32,
                  providerPeerId: layout.FixedBytes32,
                  retainedUntilEpoch: int32,
                  rewardUnits: int32,
                  slashUnits: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(160)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.pin.accept.cid"))
    lt.v3AppendU32BE(buf, 1)
    lt.v3AppendFixed32(buf, offerCid)
    lt.v3AppendFixed32(buf, providerPeerId)
    lt.v3AppendU32BE(buf, retainedUntilEpoch)
    lt.v3AppendU32BE(buf, rewardUnits)
    lt.v3AppendU32BE(buf, slashUnits)
    return lt.v3FixedCidFromBuf(buf)

fn v3PinChallengeCid(offerCid: layout.FixedBytes32,
                     acceptCid: layout.FixedBytes32,
                     providerPeerId: layout.FixedBytes32,
                     manifestCid: layout.FixedBytes32,
                     challengeEpoch: int32,
                     shardIndices: int32[],
                     shardCids: layout.FixedBytes32[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256 + shardIndices.len * 40)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.pin.challenge.cid"))
    lt.v3AppendU32BE(buf, 1)
    lt.v3AppendFixed32(buf, offerCid)
    lt.v3AppendFixed32(buf, acceptCid)
    lt.v3AppendFixed32(buf, providerPeerId)
    lt.v3AppendFixed32(buf, manifestCid)
    lt.v3AppendU32BE(buf, challengeEpoch)
    lt.v3AppendU32BE(buf, shardIndices.len)
    for i in 0..<shardIndices.len:
        lt.v3AppendU32BE(buf, shardIndices[i])
        lt.v3AppendFixed32(buf, shardCids[i])
    return lt.v3FixedCidFromBuf(buf)

fn v3PinProofCid(challengeCid: layout.FixedBytes32,
                 acceptCid: layout.FixedBytes32,
                 manifestCid: layout.FixedBytes32,
                 shardIndices: int32[],
                 shardPayloadLens: int32[],
                 payloadConcat: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256 + bytesLen(payloadConcat))
    layout.byteBufAppendBytes(buf, bytesFromString("v3.pin.proof.cid"))
    lt.v3AppendU32BE(buf, 1)
    lt.v3AppendFixed32(buf, challengeCid)
    lt.v3AppendFixed32(buf, acceptCid)
    lt.v3AppendFixed32(buf, manifestCid)
    lt.v3AppendU32BE(buf, shardIndices.len)
    for i in 0..<shardIndices.len:
        lt.v3AppendU32BE(buf, shardIndices[i])
        lt.v3AppendU32BE(buf, shardPayloadLens[i])
    lt.v3AppendU32BE(buf, bytesLen(payloadConcat))
    layout.byteBufAppendBytes(buf, payloadConcat)
    return lt.v3FixedCidFromBuf(buf)

fn v3PinSettlementCid(offerCid: layout.FixedBytes32,
                      acceptCid: layout.FixedBytes32,
                      challengeCid: layout.FixedBytes32,
                      proofCid: layout.FixedBytes32,
                      settledEpoch: int32,
                      status: int32,
                      rewardUnits: int32,
                      slashUnits: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(192)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.pin.settlement.cid"))
    lt.v3AppendU32BE(buf, 1)
    lt.v3AppendFixed32(buf, offerCid)
    lt.v3AppendFixed32(buf, acceptCid)
    lt.v3AppendFixed32(buf, challengeCid)
    lt.v3AppendFixed32(buf, proofCid)
    lt.v3AppendU32BE(buf, settledEpoch)
    lt.v3AppendU32BE(buf, status)
    lt.v3AppendU32BE(buf, rewardUnits)
    lt.v3AppendU32BE(buf, slashUnits)
    return lt.v3FixedCidFromBuf(buf)

fn v3PinOfferValidate(offer: V3PinOffer): Result[bool] =
    if offer.version != 1:
        return Err[bool]("v3 pin: unsupported offer version")
    if !v3PinCidSet(offer.bundleCid):
        return Err[bool]("v3 pin: missing offer bundle cid")
    if !v3PinCidSet(offer.blobSummaryCid):
        return Err[bool]("v3 pin: missing offer blob summary cid")
    if !v3PinCidSet(offer.blobCid):
        return Err[bool]("v3 pin: missing offer blob cid")
    if !v3PinCidSet(offer.manifestCid):
        return Err[bool]("v3 pin: missing offer manifest cid")
    if offer.minRetainedUntilEpoch <= 0:
        return Err[bool]("v3 pin: invalid offer retained epoch")
    if offer.challengeShardCount <= 0:
        return Err[bool]("v3 pin: invalid offer challenge shard count")
    if offer.rewardUnits < 0:
        return Err[bool]("v3 pin: invalid offer reward")
    if offer.slashUnits < 0:
        return Err[bool]("v3 pin: invalid offer slash")
    if offer.rewardUnits == 0 && offer.slashUnits == 0:
        return Err[bool]("v3 pin: empty offer economics")
    let expectedCid = v3PinOfferCid(offer.bundleCid,
                                    offer.blobSummaryCid,
                                    offer.blobCid,
                                    offer.manifestCid,
                                    offer.minRetainedUntilEpoch,
                                    offer.challengeShardCount,
                                    offer.rewardUnits,
                                    offer.slashUnits)
    if !layout.fixedBytes32Equal(offer.offerCid, expectedCid):
        return Err[bool]("v3 pin: offer cid mismatch")
    return Ok[bool](true)

fn v3PinOfferValidateAgainstManifest(offer: V3PinOffer,
                                     manifest: swarm.V3ErasureShardManifest): Result[bool] =
    let offerOk = v3PinOfferValidate(offer)
    if IsErr(offerOk):
        return Err[bool](Error(offerOk))
    if !layout.fixedBytes32Equal(offer.blobCid, manifest.blobCid):
        return Err[bool]("v3 pin: offer blob cid mismatch")
    if !layout.fixedBytes32Equal(offer.manifestCid, manifest.manifestCid):
        return Err[bool]("v3 pin: offer manifest cid mismatch")
    if offer.challengeShardCount > manifest.shardCount:
        return Err[bool]("v3 pin: offer challenge shard count overflow")
    return Ok[bool](true)

fn v3PinOfferMake(bundleCid: layout.FixedBytes32,
                  blobSummaryCid: layout.FixedBytes32,
                  blobCid: layout.FixedBytes32,
                  manifestCid: layout.FixedBytes32,
                  minRetainedUntilEpoch: int32,
                  challengeShardCount: int32,
                  rewardUnits: int32,
                  slashUnits: int32): Result[V3PinOffer] =
    var out = v3PinOfferZero()
    out.bundleCid = bundleCid
    out.blobSummaryCid = blobSummaryCid
    out.blobCid = blobCid
    out.manifestCid = manifestCid
    out.minRetainedUntilEpoch = minRetainedUntilEpoch
    out.challengeShardCount = challengeShardCount
    out.rewardUnits = rewardUnits
    out.slashUnits = slashUnits
    out.offerCid = v3PinOfferCid(out.bundleCid,
                                 out.blobSummaryCid,
                                 out.blobCid,
                                 out.manifestCid,
                                 out.minRetainedUntilEpoch,
                                 out.challengeShardCount,
                                 out.rewardUnits,
                                 out.slashUnits)
    let offerOk = v3PinOfferValidate(out)
    if IsErr(offerOk):
        return Err[V3PinOffer](Error(offerOk))
    return Ok[V3PinOffer](out)

fn v3PinOfferFromArtifacts(artifacts: content.V3ContentPublishArtifacts,
                           minRetainedUntilEpoch: int32,
                           challengeShardCount: int32,
                           rewardUnits: int32,
                           slashUnits: int32): Result[V3PinOffer] =
    if !v3PinCidSet(artifacts.bundleCid):
        return Err[V3PinOffer]("v3 pin: artifacts missing bundle cid")
    let summaryOk = dag.v3DagBlobSummaryValidate(artifacts.blobSummary)
    if IsErr(summaryOk):
        return Err[V3PinOffer](Error(summaryOk))
    let manifestOk = swarm.v3ErasureManifestValidate(artifacts.erasureManifest, artifacts.erasureParams)
    if IsErr(manifestOk):
        return Err[V3PinOffer](Error(manifestOk))
    if !layout.fixedBytes32Equal(artifacts.erasureManifest.blobCid, artifacts.blobSummary.blobCid):
        return Err[V3PinOffer]("v3 pin: artifacts blob cid mismatch")
    return v3PinOfferMake(artifacts.bundleCid,
                          artifacts.blobSummary.summaryCid,
                          artifacts.blobSummary.blobCid,
                          artifacts.erasureManifest.manifestCid,
                          minRetainedUntilEpoch,
                          challengeShardCount,
                          rewardUnits,
                          slashUnits)

fn v3PinAcceptValidate(accept: V3PinAccept): Result[bool] =
    if accept.version != 1:
        return Err[bool]("v3 pin: unsupported accept version")
    if !v3PinCidSet(accept.offerCid):
        return Err[bool]("v3 pin: missing accept offer cid")
    if !v3PinCidSet(accept.providerPeerId):
        return Err[bool]("v3 pin: missing accept provider peer id")
    if accept.retainedUntilEpoch <= 0:
        return Err[bool]("v3 pin: invalid accept retained epoch")
    if accept.rewardUnits < 0:
        return Err[bool]("v3 pin: invalid accept reward")
    if accept.slashUnits < 0:
        return Err[bool]("v3 pin: invalid accept slash")
    if accept.rewardUnits == 0 && accept.slashUnits == 0:
        return Err[bool]("v3 pin: empty accept economics")
    let expectedCid = v3PinAcceptCid(accept.offerCid,
                                     accept.providerPeerId,
                                     accept.retainedUntilEpoch,
                                     accept.rewardUnits,
                                     accept.slashUnits)
    if !layout.fixedBytes32Equal(accept.acceptCid, expectedCid):
        return Err[bool]("v3 pin: accept cid mismatch")
    return Ok[bool](true)

fn v3PinAcceptValidateAgainstOffer(accept: V3PinAccept,
                                   offer: V3PinOffer): Result[bool] =
    let offerOk = v3PinOfferValidate(offer)
    if IsErr(offerOk):
        return Err[bool](Error(offerOk))
    let acceptOk = v3PinAcceptValidate(accept)
    if IsErr(acceptOk):
        return Err[bool](Error(acceptOk))
    if !layout.fixedBytes32Equal(accept.offerCid, offer.offerCid):
        return Err[bool]("v3 pin: accept offer cid mismatch")
    if accept.retainedUntilEpoch < offer.minRetainedUntilEpoch:
        return Err[bool]("v3 pin: accept retained epoch too short")
    if accept.rewardUnits != offer.rewardUnits:
        return Err[bool]("v3 pin: accept reward mismatch")
    if accept.slashUnits != offer.slashUnits:
        return Err[bool]("v3 pin: accept slash mismatch")
    return Ok[bool](true)

fn v3PinAcceptMake(offer: V3PinOffer,
                   providerPeerId: layout.FixedBytes32,
                   retainedUntilEpoch: int32): Result[V3PinAccept] =
    var out = v3PinAcceptZero()
    out.offerCid = offer.offerCid
    out.providerPeerId = providerPeerId
    out.retainedUntilEpoch = retainedUntilEpoch
    out.rewardUnits = offer.rewardUnits
    out.slashUnits = offer.slashUnits
    out.acceptCid = v3PinAcceptCid(out.offerCid,
                                   out.providerPeerId,
                                   out.retainedUntilEpoch,
                                   out.rewardUnits,
                                   out.slashUnits)
    let acceptOk = v3PinAcceptValidateAgainstOffer(out, offer)
    if IsErr(acceptOk):
        return Err[V3PinAccept](Error(acceptOk))
    return Ok[V3PinAccept](out)

fn v3PinChallengeValidate(challenge: V3PinChallenge): Result[bool] =
    if challenge.version != 1:
        return Err[bool]("v3 pin: unsupported challenge version")
    if !v3PinCidSet(challenge.offerCid):
        return Err[bool]("v3 pin: missing challenge offer cid")
    if !v3PinCidSet(challenge.acceptCid):
        return Err[bool]("v3 pin: missing challenge accept cid")
    if !v3PinCidSet(challenge.providerPeerId):
        return Err[bool]("v3 pin: missing challenge provider peer id")
    if !v3PinCidSet(challenge.manifestCid):
        return Err[bool]("v3 pin: missing challenge manifest cid")
    if challenge.challengeEpoch < 0:
        return Err[bool]("v3 pin: invalid challenge epoch")
    if challenge.shardCount <= 0:
        return Err[bool]("v3 pin: invalid challenge shard count")
    if challenge.shardCount != challenge.shardIndices.len:
        return Err[bool]("v3 pin: challenge shard index count mismatch")
    if challenge.shardCount != challenge.shardCids.len:
        return Err[bool]("v3 pin: challenge shard cid count mismatch")
    var seen: int32[]
    seen = []
    for i in 0..<challenge.shardCount:
        if challenge.shardIndices[i] < 0:
            return Err[bool]("v3 pin: invalid challenge shard index")
        if !v3PinCidSet(challenge.shardCids[i]):
            return Err[bool]("v3 pin: missing challenge shard cid")
        if v3PinIndexSetContains(seen, challenge.shardIndices[i]):
            return Err[bool]("v3 pin: duplicate challenge shard index")
        add(seen, challenge.shardIndices[i])
    let expectedCid = v3PinChallengeCid(challenge.offerCid,
                                        challenge.acceptCid,
                                        challenge.providerPeerId,
                                        challenge.manifestCid,
                                        challenge.challengeEpoch,
                                        challenge.shardIndices,
                                        challenge.shardCids)
    if !layout.fixedBytes32Equal(challenge.challengeCid, expectedCid):
        return Err[bool]("v3 pin: challenge cid mismatch")
    return Ok[bool](true)

fn v3PinChallengeValidateAgainstInputs(challenge: V3PinChallenge,
                                       offer: V3PinOffer,
                                       accept: V3PinAccept,
                                       manifest: swarm.V3ErasureShardManifest): Result[bool] =
    let offerOk = v3PinOfferValidateAgainstManifest(offer, manifest)
    if IsErr(offerOk):
        return Err[bool](Error(offerOk))
    let acceptOk = v3PinAcceptValidateAgainstOffer(accept, offer)
    if IsErr(acceptOk):
        return Err[bool](Error(acceptOk))
    let challengeOk = v3PinChallengeValidate(challenge)
    if IsErr(challengeOk):
        return Err[bool](Error(challengeOk))
    if !layout.fixedBytes32Equal(challenge.offerCid, offer.offerCid):
        return Err[bool]("v3 pin: challenge offer cid mismatch")
    if !layout.fixedBytes32Equal(challenge.acceptCid, accept.acceptCid):
        return Err[bool]("v3 pin: challenge accept cid mismatch")
    if !layout.fixedBytes32Equal(challenge.providerPeerId, accept.providerPeerId):
        return Err[bool]("v3 pin: challenge provider peer mismatch")
    if !layout.fixedBytes32Equal(challenge.manifestCid, manifest.manifestCid):
        return Err[bool]("v3 pin: challenge manifest cid mismatch")
    if challenge.challengeEpoch > accept.retainedUntilEpoch:
        return Err[bool]("v3 pin: challenge after retained epoch")
    if challenge.shardCount != offer.challengeShardCount:
        return Err[bool]("v3 pin: challenge shard count mismatch")
    if challenge.shardCount > manifest.shardCount:
        return Err[bool]("v3 pin: challenge shard count overflow")
    for i in 0..<challenge.shardCount:
        let pos = v3PinManifestShardPos(manifest, challenge.shardIndices[i])
        if pos < 0:
            return Err[bool]("v3 pin: challenge shard missing from manifest")
        if !layout.fixedBytes32Equal(challenge.shardCids[i], manifest.shardPayloadCids[pos]):
            return Err[bool]("v3 pin: challenge shard cid mismatch")
    return Ok[bool](true)

fn v3PinBuildChallenge(offer: V3PinOffer,
                       accept: V3PinAccept,
                       manifest: swarm.V3ErasureShardManifest,
                       challengeEpoch: int32): Result[V3PinChallenge] =
    let offerOk = v3PinOfferValidateAgainstManifest(offer, manifest)
    if IsErr(offerOk):
        return Err[V3PinChallenge](Error(offerOk))
    let acceptOk = v3PinAcceptValidateAgainstOffer(accept, offer)
    if IsErr(acceptOk):
        return Err[V3PinChallenge](Error(acceptOk))
    if challengeEpoch < 0:
        return Err[V3PinChallenge]("v3 pin: invalid challenge epoch")
    if challengeEpoch > accept.retainedUntilEpoch:
        return Err[V3PinChallenge]("v3 pin: challenge after retained epoch")
    var seedBuf: layout.ByteBuf = layout.byteBufInit(160)
    layout.byteBufAppendBytes(seedBuf, bytesFromString("v3.pin.challenge.seed"))
    lt.v3AppendFixed32(seedBuf, offer.offerCid)
    lt.v3AppendFixed32(seedBuf, accept.acceptCid)
    lt.v3AppendFixed32(seedBuf, manifest.manifestCid)
    lt.v3AppendU32BE(seedBuf, challengeEpoch)
    let seed = lt.v3FixedCidFromBuf(seedBuf)
    let start = (int32(seed.data[0]) * 256 + int32(seed.data[1])) % manifest.shardCount
    var indices: int32[]
    var cids: layout.FixedBytes32[]
    indices = []
    cids = []
    for i in 0..<offer.challengeShardCount:
        let pos = (start + i) % manifest.shardCount
        add(indices, manifest.shardIndices[pos])
        add(cids, manifest.shardPayloadCids[pos])
    var out = v3PinChallengeZero()
    out.offerCid = offer.offerCid
    out.acceptCid = accept.acceptCid
    out.providerPeerId = accept.providerPeerId
    out.manifestCid = manifest.manifestCid
    out.challengeEpoch = challengeEpoch
    out.shardCount = indices.len
    out.shardIndices = indices
    out.shardCids = cids
    out.challengeCid = v3PinChallengeCid(out.offerCid,
                                         out.acceptCid,
                                         out.providerPeerId,
                                         out.manifestCid,
                                         out.challengeEpoch,
                                         out.shardIndices,
                                         out.shardCids)
    let challengeOk = v3PinChallengeValidateAgainstInputs(out, offer, accept, manifest)
    if IsErr(challengeOk):
        return Err[V3PinChallenge](Error(challengeOk))
    return Ok[V3PinChallenge](out)

fn v3PinProofValidate(proof: V3PinProof): Result[bool] =
    if proof.version != 1:
        return Err[bool]("v3 pin: unsupported proof version")
    if !v3PinCidSet(proof.challengeCid):
        return Err[bool]("v3 pin: missing proof challenge cid")
    if !v3PinCidSet(proof.acceptCid):
        return Err[bool]("v3 pin: missing proof accept cid")
    if !v3PinCidSet(proof.manifestCid):
        return Err[bool]("v3 pin: missing proof manifest cid")
    if proof.shardCount <= 0:
        return Err[bool]("v3 pin: invalid proof shard count")
    if proof.shardCount != proof.shardIndices.len:
        return Err[bool]("v3 pin: proof shard index count mismatch")
    if proof.shardCount != proof.shardPayloadLens.len:
        return Err[bool]("v3 pin: proof shard payload count mismatch")
    if proof.payloadConcatLen < 0:
        return Err[bool]("v3 pin: invalid proof payload length")
    if proof.payloadConcatLen != bytesLen(proof.payloadConcat):
        return Err[bool]("v3 pin: proof payload length mismatch")
    var seen: int32[]
    seen = []
    var total = 0
    for i in 0..<proof.shardCount:
        if proof.shardIndices[i] < 0:
            return Err[bool]("v3 pin: invalid proof shard index")
        if proof.shardPayloadLens[i] < 0:
            return Err[bool]("v3 pin: invalid proof shard payload length")
        if v3PinIndexSetContains(seen, proof.shardIndices[i]):
            return Err[bool]("v3 pin: duplicate proof shard index")
        add(seen, proof.shardIndices[i])
        total = total + proof.shardPayloadLens[i]
    if total != proof.payloadConcatLen:
        return Err[bool]("v3 pin: proof payload concat mismatch")
    let expectedCid = v3PinProofCid(proof.challengeCid,
                                    proof.acceptCid,
                                    proof.manifestCid,
                                    proof.shardIndices,
                                    proof.shardPayloadLens,
                                    proof.payloadConcat)
    if !layout.fixedBytes32Equal(proof.proofCid, expectedCid):
        return Err[bool]("v3 pin: proof cid mismatch")
    return Ok[bool](true)

fn v3PinProofValidateAgainstInputs(proof: V3PinProof,
                                   challenge: V3PinChallenge,
                                   accept: V3PinAccept,
                                   manifest: swarm.V3ErasureShardManifest): Result[bool] =
    let challengeOk = v3PinChallengeValidate(challenge)
    if IsErr(challengeOk):
        return Err[bool](Error(challengeOk))
    let acceptOk = v3PinAcceptValidate(accept)
    if IsErr(acceptOk):
        return Err[bool](Error(acceptOk))
    let proofOk = v3PinProofValidate(proof)
    if IsErr(proofOk):
        return Err[bool](Error(proofOk))
    if !layout.fixedBytes32Equal(proof.challengeCid, challenge.challengeCid):
        return Err[bool]("v3 pin: proof challenge cid mismatch")
    if !layout.fixedBytes32Equal(proof.acceptCid, accept.acceptCid):
        return Err[bool]("v3 pin: proof accept cid mismatch")
    if !layout.fixedBytes32Equal(proof.manifestCid, manifest.manifestCid):
        return Err[bool]("v3 pin: proof manifest cid mismatch")
    if proof.shardCount != challenge.shardCount:
        return Err[bool]("v3 pin: proof shard count mismatch")
    var next = 0
    for i in 0..<proof.shardCount:
        if proof.shardIndices[i] != challenge.shardIndices[i]:
            return Err[bool]("v3 pin: proof shard index mismatch")
        let pos = v3PinManifestShardPos(manifest, challenge.shardIndices[i])
        if pos < 0:
            return Err[bool]("v3 pin: proof shard missing from manifest")
        let payloadLen = proof.shardPayloadLens[i]
        if next + payloadLen > proof.payloadConcatLen:
            return Err[bool]("v3 pin: truncated proof payload")
        let payload = bytesSlice(proof.payloadConcat, next, payloadLen)
        let payloadCid = swarm.v3ErasureShardPayloadCid(payload)
        if !layout.fixedBytes32Equal(payloadCid, challenge.shardCids[i]):
            return Err[bool]("v3 pin: proof challenged shard cid mismatch")
        if !layout.fixedBytes32Equal(payloadCid, manifest.shardPayloadCids[pos]):
            return Err[bool]("v3 pin: proof manifest shard cid mismatch")
        next = next + payloadLen
    if next != proof.payloadConcatLen:
        return Err[bool]("v3 pin: proof payload concat tail mismatch")
    return Ok[bool](true)

fn v3PinProofMake(challenge: V3PinChallenge,
                  manifest: swarm.V3ErasureShardManifest,
                  shardPayloads: Bytes[]): Result[V3PinProof] =
    let challengeOk = v3PinChallengeValidate(challenge)
    if IsErr(challengeOk):
        return Err[V3PinProof](Error(challengeOk))
    if !layout.fixedBytes32Equal(challenge.manifestCid, manifest.manifestCid):
        return Err[V3PinProof]("v3 pin: proof manifest cid mismatch")
    if shardPayloads.len != challenge.shardCount:
        return Err[V3PinProof]("v3 pin: proof payload count mismatch")
    var concat: layout.ByteBuf = layout.byteBufInit(256)
    var shardPayloadLens: int32[]
    shardPayloadLens = []
    for i in 0..<challenge.shardCount:
        let pos = v3PinManifestShardPos(manifest, challenge.shardIndices[i])
        if pos < 0:
            return Err[V3PinProof]("v3 pin: proof shard missing from manifest")
        let payloadCid = swarm.v3ErasureShardPayloadCid(shardPayloads[i])
        if !layout.fixedBytes32Equal(payloadCid, challenge.shardCids[i]):
            return Err[V3PinProof]("v3 pin: proof challenged shard cid mismatch")
        if !layout.fixedBytes32Equal(payloadCid, manifest.shardPayloadCids[pos]):
            return Err[V3PinProof]("v3 pin: proof manifest shard cid mismatch")
        add(shardPayloadLens, bytesLen(shardPayloads[i]))
        layout.byteBufAppendBytes(concat, shardPayloads[i])
    var out = v3PinProofZero()
    out.challengeCid = challenge.challengeCid
    out.acceptCid = challenge.acceptCid
    out.manifestCid = manifest.manifestCid
    out.shardCount = challenge.shardCount
    out.shardIndices = challenge.shardIndices
    out.shardPayloadLens = shardPayloadLens
    out.payloadConcat = layout.byteBufToBytes(concat)
    out.payloadConcatLen = bytesLen(out.payloadConcat)
    out.proofCid = v3PinProofCid(out.challengeCid,
                                 out.acceptCid,
                                 out.manifestCid,
                                 out.shardIndices,
                                 out.shardPayloadLens,
                                 out.payloadConcat)
    let proofOk = v3PinProofValidate(out)
    if IsErr(proofOk):
        return Err[V3PinProof](Error(proofOk))
    return Ok[V3PinProof](out)

fn v3PinProofFromResponses(challenge: V3PinChallenge,
                           manifest: swarm.V3ErasureShardManifest,
                           responses: swarm.V3ErasureShardPullResponse[]): Result[V3PinProof] =
    var payloads: Bytes[]
    payloads = []
    for i in 0..<challenge.shardCount:
        let pos = v3PinChallengeResponsePos(responses,
                                            manifest.manifestCid,
                                            challenge.shardIndices[i],
                                            challenge.shardCids[i])
        if pos < 0:
            return Err[V3PinProof]("v3 pin: proof response missing")
        let requestRes = swarm.v3ErasureShardPullRequestMake(manifest, challenge.shardIndices[i])
        if IsErr(requestRes):
            return Err[V3PinProof](Error(requestRes))
        let responseOk = swarm.v3ErasureShardPullResponseValidate(responses[pos], Value(requestRes))
        if IsErr(responseOk):
            return Err[V3PinProof](Error(responseOk))
        add(payloads, responses[pos].payload)
    return v3PinProofMake(challenge, manifest, payloads)

fn v3PinSettlementValidate(settlement: V3PinSettlement): Result[bool] =
    if settlement.version != 1:
        return Err[bool]("v3 pin: unsupported settlement version")
    if !v3PinCidSet(settlement.offerCid):
        return Err[bool]("v3 pin: missing settlement offer cid")
    if !v3PinCidSet(settlement.acceptCid):
        return Err[bool]("v3 pin: missing settlement accept cid")
    if !v3PinCidSet(settlement.challengeCid):
        return Err[bool]("v3 pin: missing settlement challenge cid")
    if !v3PinCidSet(settlement.proofCid):
        return Err[bool]("v3 pin: missing settlement proof cid")
    if settlement.settledEpoch < 0:
        return Err[bool]("v3 pin: invalid settled epoch")
    if !v3PinSettlementStatusValid(settlement.status):
        return Err[bool]("v3 pin: invalid settlement status")
    if settlement.rewardUnits < 0:
        return Err[bool]("v3 pin: invalid settlement reward")
    if settlement.slashUnits < 0:
        return Err[bool]("v3 pin: invalid settlement slash")
    let expectedCid = v3PinSettlementCid(settlement.offerCid,
                                         settlement.acceptCid,
                                         settlement.challengeCid,
                                         settlement.proofCid,
                                         settlement.settledEpoch,
                                         settlement.status,
                                         settlement.rewardUnits,
                                         settlement.slashUnits)
    if !layout.fixedBytes32Equal(settlement.settlementCid, expectedCid):
        return Err[bool]("v3 pin: settlement cid mismatch")
    return Ok[bool](true)

fn v3PinSettlementValidateAgainstInputs(settlement: V3PinSettlement,
                                        offer: V3PinOffer,
                                        accept: V3PinAccept,
                                        challenge: V3PinChallenge,
                                        manifest: swarm.V3ErasureShardManifest,
                                        proof: V3PinProof): Result[bool] =
    let settlementOk = v3PinSettlementValidate(settlement)
    if IsErr(settlementOk):
        return Err[bool](Error(settlementOk))
    let challengeOk = v3PinChallengeValidateAgainstInputs(challenge, offer, accept, manifest)
    if IsErr(challengeOk):
        return Err[bool](Error(challengeOk))
    if !layout.fixedBytes32Equal(settlement.offerCid, offer.offerCid):
        return Err[bool]("v3 pin: settlement offer cid mismatch")
    if !layout.fixedBytes32Equal(settlement.acceptCid, accept.acceptCid):
        return Err[bool]("v3 pin: settlement accept cid mismatch")
    if !layout.fixedBytes32Equal(settlement.challengeCid, challenge.challengeCid):
        return Err[bool]("v3 pin: settlement challenge cid mismatch")
    if !layout.fixedBytes32Equal(settlement.proofCid, proof.proofCid):
        return Err[bool]("v3 pin: settlement proof cid mismatch")
    if settlement.settledEpoch < challenge.challengeEpoch:
        return Err[bool]("v3 pin: settlement before challenge")
    let proofOk = v3PinProofValidateAgainstInputs(proof, challenge, accept, manifest)
    if IsErr(proofOk):
        if settlement.status != v3PinSettlementStatusSlash:
            return Err[bool]("v3 pin: settlement status mismatch")
        if settlement.rewardUnits != 0:
            return Err[bool]("v3 pin: invalid slashed reward")
        if settlement.slashUnits != accept.slashUnits:
            return Err[bool]("v3 pin: invalid slashed amount")
        return Ok[bool](true)
    if settlement.status != v3PinSettlementStatusReward:
        return Err[bool]("v3 pin: settlement reward status mismatch")
    if settlement.rewardUnits != offer.rewardUnits:
        return Err[bool]("v3 pin: settlement reward amount mismatch")
    if settlement.slashUnits != 0:
        return Err[bool]("v3 pin: settlement reward slash mismatch")
    return Ok[bool](true)

fn v3PinSettlementMake(offerCid: layout.FixedBytes32,
                       acceptCid: layout.FixedBytes32,
                       challengeCid: layout.FixedBytes32,
                       proofCid: layout.FixedBytes32,
                       settledEpoch: int32,
                       status: int32,
                       rewardUnits: int32,
                       slashUnits: int32): Result[V3PinSettlement] =
    var out = v3PinSettlementZero()
    out.offerCid = offerCid
    out.acceptCid = acceptCid
    out.challengeCid = challengeCid
    out.proofCid = proofCid
    out.settledEpoch = settledEpoch
    out.status = status
    out.rewardUnits = rewardUnits
    out.slashUnits = slashUnits
    out.settlementCid = v3PinSettlementCid(out.offerCid,
                                           out.acceptCid,
                                           out.challengeCid,
                                           out.proofCid,
                                           out.settledEpoch,
                                           out.status,
                                           out.rewardUnits,
                                           out.slashUnits)
    let settlementOk = v3PinSettlementValidate(out)
    if IsErr(settlementOk):
        return Err[V3PinSettlement](Error(settlementOk))
    return Ok[V3PinSettlement](out)

fn v3PinBuildSettlement(offer: V3PinOffer,
                        accept: V3PinAccept,
                        challenge: V3PinChallenge,
                        manifest: swarm.V3ErasureShardManifest,
                        proof: V3PinProof,
                        settledEpoch: int32): Result[V3PinSettlement] =
    let challengeOk = v3PinChallengeValidateAgainstInputs(challenge, offer, accept, manifest)
    if IsErr(challengeOk):
        return Err[V3PinSettlement](Error(challengeOk))
    let proofOk = v3PinProofValidateAgainstInputs(proof, challenge, accept, manifest)
    if IsErr(proofOk):
        let slashRes = v3PinSettlementMake(offer.offerCid,
                                           accept.acceptCid,
                                           challenge.challengeCid,
                                           proof.proofCid,
                                           settledEpoch,
                                           v3PinSettlementStatusSlash,
                                           0,
                                           accept.slashUnits)
        if IsErr(slashRes):
            return Err[V3PinSettlement](Error(slashRes))
        let settlementOk = v3PinSettlementValidateAgainstInputs(Value(slashRes),
                                                                offer,
                                                                accept,
                                                                challenge,
                                                                manifest,
                                                                proof)
        if IsErr(settlementOk):
            return Err[V3PinSettlement](Error(settlementOk))
        return slashRes
    let rewardRes = v3PinSettlementMake(offer.offerCid,
                                        accept.acceptCid,
                                        challenge.challengeCid,
                                        proof.proofCid,
                                        settledEpoch,
                                        v3PinSettlementStatusReward,
                                        offer.rewardUnits,
                                        0)
    if IsErr(rewardRes):
        return Err[V3PinSettlement](Error(rewardRes))
    let settlementOk = v3PinSettlementValidateAgainstInputs(Value(rewardRes),
                                                            offer,
                                                            accept,
                                                            challenge,
                                                            manifest,
                                                            proof)
    if IsErr(settlementOk):
        return Err[V3PinSettlement](Error(settlementOk))
    return rewardRes

fn v3PinOfferEncode(offer: V3PinOffer): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString(v3PinOfferMagic))
    lt.v3AppendU32BE(buf, offer.version)
    lt.v3AppendFixed32(buf, offer.bundleCid)
    lt.v3AppendFixed32(buf, offer.blobSummaryCid)
    lt.v3AppendFixed32(buf, offer.blobCid)
    lt.v3AppendFixed32(buf, offer.manifestCid)
    lt.v3AppendU32BE(buf, offer.minRetainedUntilEpoch)
    lt.v3AppendU32BE(buf, offer.challengeShardCount)
    lt.v3AppendU32BE(buf, offer.rewardUnits)
    lt.v3AppendU32BE(buf, offer.slashUnits)
    lt.v3AppendFixed32(buf, offer.offerCid)
    return layout.byteBufToBytes(buf)

fn v3PinOfferDecode(payload: Bytes): Result[V3PinOffer] =
    if !v3PinPayloadHasMagic(payload, v3PinOfferMagic):
        return Err[V3PinOffer]("v3 pin: invalid offer magic")
    let magicLen = bytesLen(bytesFromString(v3PinOfferMagic))
    let span = layout.byteSpanFromBytes(payload)
    let versionRes = codec.v3ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[V3PinOffer](Error(versionRes))
    let bundleCidRes = codec.v3ReadFixed32(span, magicLen + 4)
    if IsErr(bundleCidRes):
        return Err[V3PinOffer](Error(bundleCidRes))
    let blobSummaryCidRes = codec.v3ReadFixed32(span, magicLen + 36)
    if IsErr(blobSummaryCidRes):
        return Err[V3PinOffer](Error(blobSummaryCidRes))
    let blobCidRes = codec.v3ReadFixed32(span, magicLen + 68)
    if IsErr(blobCidRes):
        return Err[V3PinOffer](Error(blobCidRes))
    let manifestCidRes = codec.v3ReadFixed32(span, magicLen + 100)
    if IsErr(manifestCidRes):
        return Err[V3PinOffer](Error(manifestCidRes))
    let retainedRes = codec.v3ReadU32BE(span, magicLen + 132)
    if IsErr(retainedRes):
        return Err[V3PinOffer](Error(retainedRes))
    let challengeCountRes = codec.v3ReadU32BE(span, magicLen + 136)
    if IsErr(challengeCountRes):
        return Err[V3PinOffer](Error(challengeCountRes))
    let rewardRes = codec.v3ReadU32BE(span, magicLen + 140)
    if IsErr(rewardRes):
        return Err[V3PinOffer](Error(rewardRes))
    let slashRes = codec.v3ReadU32BE(span, magicLen + 144)
    if IsErr(slashRes):
        return Err[V3PinOffer](Error(slashRes))
    let offerCidRes = codec.v3ReadFixed32(span, magicLen + 148)
    if IsErr(offerCidRes):
        return Err[V3PinOffer](Error(offerCidRes))
    var out = v3PinOfferZero()
    out.version = int32(Value(versionRes))
    out.bundleCid = Value(bundleCidRes)
    out.blobSummaryCid = Value(blobSummaryCidRes)
    out.blobCid = Value(blobCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.minRetainedUntilEpoch = int32(Value(retainedRes))
    out.challengeShardCount = int32(Value(challengeCountRes))
    out.rewardUnits = int32(Value(rewardRes))
    out.slashUnits = int32(Value(slashRes))
    out.offerCid = Value(offerCidRes)
    let offerOk = v3PinOfferValidate(out)
    if IsErr(offerOk):
        return Err[V3PinOffer](Error(offerOk))
    return Ok[V3PinOffer](out)

fn v3PinOfferValidatePayload(payload: Bytes,
                             expectedCid: layout.FixedBytes32): Result[bool] =
    let offerRes = v3PinOfferDecode(payload)
    if IsErr(offerRes):
        return Err[bool](Error(offerRes))
    if !layout.fixedBytes32Equal(Value(offerRes).offerCid, expectedCid):
        return Err[bool]("v3 pin: offer payload cid mismatch")
    return Ok[bool](true)

fn v3PinAcceptEncode(accept: V3PinAccept): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(224)
    layout.byteBufAppendBytes(buf, bytesFromString(v3PinAcceptMagic))
    lt.v3AppendU32BE(buf, accept.version)
    lt.v3AppendFixed32(buf, accept.offerCid)
    lt.v3AppendFixed32(buf, accept.providerPeerId)
    lt.v3AppendU32BE(buf, accept.retainedUntilEpoch)
    lt.v3AppendU32BE(buf, accept.rewardUnits)
    lt.v3AppendU32BE(buf, accept.slashUnits)
    lt.v3AppendFixed32(buf, accept.acceptCid)
    return layout.byteBufToBytes(buf)

fn v3PinAcceptDecode(payload: Bytes): Result[V3PinAccept] =
    if !v3PinPayloadHasMagic(payload, v3PinAcceptMagic):
        return Err[V3PinAccept]("v3 pin: invalid accept magic")
    let magicLen = bytesLen(bytesFromString(v3PinAcceptMagic))
    let span = layout.byteSpanFromBytes(payload)
    let versionRes = codec.v3ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[V3PinAccept](Error(versionRes))
    let offerCidRes = codec.v3ReadFixed32(span, magicLen + 4)
    if IsErr(offerCidRes):
        return Err[V3PinAccept](Error(offerCidRes))
    let providerPeerIdRes = codec.v3ReadFixed32(span, magicLen + 36)
    if IsErr(providerPeerIdRes):
        return Err[V3PinAccept](Error(providerPeerIdRes))
    let retainedRes = codec.v3ReadU32BE(span, magicLen + 68)
    if IsErr(retainedRes):
        return Err[V3PinAccept](Error(retainedRes))
    let rewardRes = codec.v3ReadU32BE(span, magicLen + 72)
    if IsErr(rewardRes):
        return Err[V3PinAccept](Error(rewardRes))
    let slashRes = codec.v3ReadU32BE(span, magicLen + 76)
    if IsErr(slashRes):
        return Err[V3PinAccept](Error(slashRes))
    let acceptCidRes = codec.v3ReadFixed32(span, magicLen + 80)
    if IsErr(acceptCidRes):
        return Err[V3PinAccept](Error(acceptCidRes))
    var out = v3PinAcceptZero()
    out.version = int32(Value(versionRes))
    out.offerCid = Value(offerCidRes)
    out.providerPeerId = Value(providerPeerIdRes)
    out.retainedUntilEpoch = int32(Value(retainedRes))
    out.rewardUnits = int32(Value(rewardRes))
    out.slashUnits = int32(Value(slashRes))
    out.acceptCid = Value(acceptCidRes)
    let acceptOk = v3PinAcceptValidate(out)
    if IsErr(acceptOk):
        return Err[V3PinAccept](Error(acceptOk))
    return Ok[V3PinAccept](out)

fn v3PinAcceptValidatePayload(payload: Bytes,
                              expectedCid: layout.FixedBytes32): Result[bool] =
    let acceptRes = v3PinAcceptDecode(payload)
    if IsErr(acceptRes):
        return Err[bool](Error(acceptRes))
    if !layout.fixedBytes32Equal(Value(acceptRes).acceptCid, expectedCid):
        return Err[bool]("v3 pin: accept payload cid mismatch")
    return Ok[bool](true)

fn v3PinChallengeEncode(challenge: V3PinChallenge): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(256 + challenge.shardCount * 40)
    layout.byteBufAppendBytes(buf, bytesFromString(v3PinChallengeMagic))
    lt.v3AppendU32BE(buf, challenge.version)
    lt.v3AppendFixed32(buf, challenge.offerCid)
    lt.v3AppendFixed32(buf, challenge.acceptCid)
    lt.v3AppendFixed32(buf, challenge.providerPeerId)
    lt.v3AppendFixed32(buf, challenge.manifestCid)
    lt.v3AppendU32BE(buf, challenge.challengeEpoch)
    lt.v3AppendU32BE(buf, challenge.shardCount)
    for i in 0..<challenge.shardCount:
        lt.v3AppendU32BE(buf, challenge.shardIndices[i])
        lt.v3AppendFixed32(buf, challenge.shardCids[i])
    lt.v3AppendFixed32(buf, challenge.challengeCid)
    return layout.byteBufToBytes(buf)

fn v3PinChallengeDecode(payload: Bytes): Result[V3PinChallenge] =
    if !v3PinPayloadHasMagic(payload, v3PinChallengeMagic):
        return Err[V3PinChallenge]("v3 pin: invalid challenge magic")
    let magicLen = bytesLen(bytesFromString(v3PinChallengeMagic))
    let span = layout.byteSpanFromBytes(payload)
    let versionRes = codec.v3ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[V3PinChallenge](Error(versionRes))
    let offerCidRes = codec.v3ReadFixed32(span, magicLen + 4)
    if IsErr(offerCidRes):
        return Err[V3PinChallenge](Error(offerCidRes))
    let acceptCidRes = codec.v3ReadFixed32(span, magicLen + 36)
    if IsErr(acceptCidRes):
        return Err[V3PinChallenge](Error(acceptCidRes))
    let providerPeerIdRes = codec.v3ReadFixed32(span, magicLen + 68)
    if IsErr(providerPeerIdRes):
        return Err[V3PinChallenge](Error(providerPeerIdRes))
    let manifestCidRes = codec.v3ReadFixed32(span, magicLen + 100)
    if IsErr(manifestCidRes):
        return Err[V3PinChallenge](Error(manifestCidRes))
    let epochRes = codec.v3ReadU32BE(span, magicLen + 132)
    if IsErr(epochRes):
        return Err[V3PinChallenge](Error(epochRes))
    let shardCountRes = codec.v3ReadU32BE(span, magicLen + 136)
    if IsErr(shardCountRes):
        return Err[V3PinChallenge](Error(shardCountRes))
    let shardCount = int32(Value(shardCountRes))
    if shardCount <= 0:
        return Err[V3PinChallenge]("v3 pin: invalid decoded challenge shard count")
    var next = magicLen + 140
    var shardIndices: int32[]
    var shardCids: layout.FixedBytes32[]
    shardIndices = []
    shardCids = []
    for i in 0..<shardCount:
        let indexRes = codec.v3ReadU32BE(span, next)
        if IsErr(indexRes):
            return Err[V3PinChallenge](Error(indexRes))
        next = next + 4
        let shardCidRes = codec.v3ReadFixed32(span, next)
        if IsErr(shardCidRes):
            return Err[V3PinChallenge](Error(shardCidRes))
        next = next + 32
        add(shardIndices, int32(Value(indexRes)))
        add(shardCids, Value(shardCidRes))
    let challengeCidRes = codec.v3ReadFixed32(span, next)
    if IsErr(challengeCidRes):
        return Err[V3PinChallenge](Error(challengeCidRes))
    var out = v3PinChallengeZero()
    out.version = int32(Value(versionRes))
    out.offerCid = Value(offerCidRes)
    out.acceptCid = Value(acceptCidRes)
    out.providerPeerId = Value(providerPeerIdRes)
    out.manifestCid = Value(manifestCidRes)
    out.challengeEpoch = int32(Value(epochRes))
    out.shardCount = shardCount
    out.shardIndices = shardIndices
    out.shardCids = shardCids
    out.challengeCid = Value(challengeCidRes)
    let challengeOk = v3PinChallengeValidate(out)
    if IsErr(challengeOk):
        return Err[V3PinChallenge](Error(challengeOk))
    return Ok[V3PinChallenge](out)

fn v3PinChallengeValidatePayload(payload: Bytes,
                                 expectedCid: layout.FixedBytes32): Result[bool] =
    let challengeRes = v3PinChallengeDecode(payload)
    if IsErr(challengeRes):
        return Err[bool](Error(challengeRes))
    if !layout.fixedBytes32Equal(Value(challengeRes).challengeCid, expectedCid):
        return Err[bool]("v3 pin: challenge payload cid mismatch")
    return Ok[bool](true)

fn v3PinProofEncode(proof: V3PinProof): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(256 + proof.payloadConcatLen)
    layout.byteBufAppendBytes(buf, bytesFromString(v3PinProofMagic))
    lt.v3AppendU32BE(buf, proof.version)
    lt.v3AppendFixed32(buf, proof.challengeCid)
    lt.v3AppendFixed32(buf, proof.acceptCid)
    lt.v3AppendFixed32(buf, proof.manifestCid)
    lt.v3AppendU32BE(buf, proof.shardCount)
    for i in 0..<proof.shardCount:
        lt.v3AppendU32BE(buf, proof.shardIndices[i])
        lt.v3AppendU32BE(buf, proof.shardPayloadLens[i])
    lt.v3AppendU32BE(buf, proof.payloadConcatLen)
    layout.byteBufAppendBytes(buf, proof.payloadConcat)
    lt.v3AppendFixed32(buf, proof.proofCid)
    return layout.byteBufToBytes(buf)

fn v3PinProofDecode(payload: Bytes): Result[V3PinProof] =
    if !v3PinPayloadHasMagic(payload, v3PinProofMagic):
        return Err[V3PinProof]("v3 pin: invalid proof magic")
    let magicLen = bytesLen(bytesFromString(v3PinProofMagic))
    let span = layout.byteSpanFromBytes(payload)
    let versionRes = codec.v3ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[V3PinProof](Error(versionRes))
    let challengeCidRes = codec.v3ReadFixed32(span, magicLen + 4)
    if IsErr(challengeCidRes):
        return Err[V3PinProof](Error(challengeCidRes))
    let acceptCidRes = codec.v3ReadFixed32(span, magicLen + 36)
    if IsErr(acceptCidRes):
        return Err[V3PinProof](Error(acceptCidRes))
    let manifestCidRes = codec.v3ReadFixed32(span, magicLen + 68)
    if IsErr(manifestCidRes):
        return Err[V3PinProof](Error(manifestCidRes))
    let shardCountRes = codec.v3ReadU32BE(span, magicLen + 100)
    if IsErr(shardCountRes):
        return Err[V3PinProof](Error(shardCountRes))
    let shardCount = int32(Value(shardCountRes))
    if shardCount <= 0:
        return Err[V3PinProof]("v3 pin: invalid decoded proof shard count")
    var next = magicLen + 104
    var shardIndices: int32[]
    var shardPayloadLens: int32[]
    shardIndices = []
    shardPayloadLens = []
    for i in 0..<shardCount:
        let indexRes = codec.v3ReadU32BE(span, next)
        if IsErr(indexRes):
            return Err[V3PinProof](Error(indexRes))
        next = next + 4
        let payloadLenRes = codec.v3ReadU32BE(span, next)
        if IsErr(payloadLenRes):
            return Err[V3PinProof](Error(payloadLenRes))
        next = next + 4
        add(shardIndices, int32(Value(indexRes)))
        add(shardPayloadLens, int32(Value(payloadLenRes)))
    let concatLenRes = codec.v3ReadU32BE(span, next)
    if IsErr(concatLenRes):
        return Err[V3PinProof](Error(concatLenRes))
    next = next + 4
    let concatLen = int32(Value(concatLenRes))
    if concatLen < 0 || next + concatLen > bytesLen(payload):
        return Err[V3PinProof]("v3 pin: truncated proof payload")
    let payloadConcat = bytesSlice(payload, next, concatLen)
    next = next + concatLen
    let proofCidRes = codec.v3ReadFixed32(span, next)
    if IsErr(proofCidRes):
        return Err[V3PinProof](Error(proofCidRes))
    var out = v3PinProofZero()
    out.version = int32(Value(versionRes))
    out.challengeCid = Value(challengeCidRes)
    out.acceptCid = Value(acceptCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.shardCount = shardCount
    out.shardIndices = shardIndices
    out.shardPayloadLens = shardPayloadLens
    out.payloadConcatLen = concatLen
    out.payloadConcat = payloadConcat
    out.proofCid = Value(proofCidRes)
    let proofOk = v3PinProofValidate(out)
    if IsErr(proofOk):
        return Err[V3PinProof](Error(proofOk))
    return Ok[V3PinProof](out)

fn v3PinProofValidatePayload(payload: Bytes,
                             expectedCid: layout.FixedBytes32): Result[bool] =
    let proofRes = v3PinProofDecode(payload)
    if IsErr(proofRes):
        return Err[bool](Error(proofRes))
    if !layout.fixedBytes32Equal(Value(proofRes).proofCid, expectedCid):
        return Err[bool]("v3 pin: proof payload cid mismatch")
    return Ok[bool](true)

fn v3PinSettlementEncode(settlement: V3PinSettlement): Bytes =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString(v3PinSettlementMagic))
    lt.v3AppendU32BE(buf, settlement.version)
    lt.v3AppendFixed32(buf, settlement.offerCid)
    lt.v3AppendFixed32(buf, settlement.acceptCid)
    lt.v3AppendFixed32(buf, settlement.challengeCid)
    lt.v3AppendFixed32(buf, settlement.proofCid)
    lt.v3AppendU32BE(buf, settlement.settledEpoch)
    lt.v3AppendU32BE(buf, settlement.status)
    lt.v3AppendU32BE(buf, settlement.rewardUnits)
    lt.v3AppendU32BE(buf, settlement.slashUnits)
    lt.v3AppendFixed32(buf, settlement.settlementCid)
    return layout.byteBufToBytes(buf)

fn v3PinSettlementDecode(payload: Bytes): Result[V3PinSettlement] =
    if !v3PinPayloadHasMagic(payload, v3PinSettlementMagic):
        return Err[V3PinSettlement]("v3 pin: invalid settlement magic")
    let magicLen = bytesLen(bytesFromString(v3PinSettlementMagic))
    let span = layout.byteSpanFromBytes(payload)
    let versionRes = codec.v3ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[V3PinSettlement](Error(versionRes))
    let offerCidRes = codec.v3ReadFixed32(span, magicLen + 4)
    if IsErr(offerCidRes):
        return Err[V3PinSettlement](Error(offerCidRes))
    let acceptCidRes = codec.v3ReadFixed32(span, magicLen + 36)
    if IsErr(acceptCidRes):
        return Err[V3PinSettlement](Error(acceptCidRes))
    let challengeCidRes = codec.v3ReadFixed32(span, magicLen + 68)
    if IsErr(challengeCidRes):
        return Err[V3PinSettlement](Error(challengeCidRes))
    let proofCidRes = codec.v3ReadFixed32(span, magicLen + 100)
    if IsErr(proofCidRes):
        return Err[V3PinSettlement](Error(proofCidRes))
    let settledEpochRes = codec.v3ReadU32BE(span, magicLen + 132)
    if IsErr(settledEpochRes):
        return Err[V3PinSettlement](Error(settledEpochRes))
    let statusRes = codec.v3ReadU32BE(span, magicLen + 136)
    if IsErr(statusRes):
        return Err[V3PinSettlement](Error(statusRes))
    let rewardRes = codec.v3ReadU32BE(span, magicLen + 140)
    if IsErr(rewardRes):
        return Err[V3PinSettlement](Error(rewardRes))
    let slashRes = codec.v3ReadU32BE(span, magicLen + 144)
    if IsErr(slashRes):
        return Err[V3PinSettlement](Error(slashRes))
    let settlementCidRes = codec.v3ReadFixed32(span, magicLen + 148)
    if IsErr(settlementCidRes):
        return Err[V3PinSettlement](Error(settlementCidRes))
    var out = v3PinSettlementZero()
    out.version = int32(Value(versionRes))
    out.offerCid = Value(offerCidRes)
    out.acceptCid = Value(acceptCidRes)
    out.challengeCid = Value(challengeCidRes)
    out.proofCid = Value(proofCidRes)
    out.settledEpoch = int32(Value(settledEpochRes))
    out.status = int32(Value(statusRes))
    out.rewardUnits = int32(Value(rewardRes))
    out.slashUnits = int32(Value(slashRes))
    out.settlementCid = Value(settlementCidRes)
    let settlementOk = v3PinSettlementValidate(out)
    if IsErr(settlementOk):
        return Err[V3PinSettlement](Error(settlementOk))
    return Ok[V3PinSettlement](out)

fn v3PinSettlementValidatePayload(payload: Bytes,
                                  expectedCid: layout.FixedBytes32): Result[bool] =
    let settlementRes = v3PinSettlementDecode(payload)
    if IsErr(settlementRes):
        return Err[bool](Error(settlementRes))
    if !layout.fixedBytes32Equal(Value(settlementRes).settlementCid, expectedCid):
        return Err[bool]("v3 pin: settlement payload cid mismatch")
    return Ok[bool](true)
