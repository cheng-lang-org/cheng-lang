import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/binary_types as binary
import cheng/v3/chain/pubsub
import cheng/v3/chain/oracle_types as oracle_types
import cheng/v3/chain/oracle_plane as oracle_plane
import cheng/v3/overlay/contracts as overlay
import cheng/v3/overlay/libp2p_bridge as bridge
import cheng/v3/libp2p/core/types as core
import cheng/v3/libp2p/core/peerstore as ps
import cheng/v3/libp2p/host/host as host_base

type
    V3OracleFastRuntime =
        committee: oracle_types.V3OracleCommitteeConfig
        batches: oracle_plane.V3OracleSignedBatch[]

    V3OracleFastQuote =
        available: bool
        pairId: oracle_types.V3OraclePairId
        roundId: int64
        priceE8: int64
        reportCount: int32

fn v3OracleFastRuntimeInit(committee: oracle_types.V3OracleCommitteeConfig): V3OracleFastRuntime =
    var out: V3OracleFastRuntime
    out.committee = committee
    out.batches = []
    return out

fn v3OracleFastQuoteZero(): V3OracleFastQuote =
    var out: V3OracleFastQuote
    out.available = false
    out.pairId = 0
    out.roundId = int64(0)
    out.priceE8 = int64(0)
    out.reportCount = 0
    return out

fn v3OracleRuntimeSelectSyncRequest(localHost: var host_base.V3Libp2pHost,
                                    remoteHost: var host_base.V3Libp2pHost,
                                    remotePeerId: core.V3Libp2pPeerId,
                                    query: overlay.V3StoreQuery,
                                    out: var overlay.V3IngressEnvelope[]): Result[bool] =
    var endpoint = ps.v3Libp2pPeerEndpointZero()
    let endpointRes = host_base.v3Libp2pSelectPeerEndpoint(localHost, remotePeerId, endpoint)
    if IsErr(endpointRes):
        return Err[bool](Error(endpointRes))
    if endpoint.addr.transport == core.v3Libp2pTransportQuic:
        return Err[bool]("v3 oracle runtime host: quic sync requires pin_runtime_host_quic")
    return host_base.v3Libp2pSyncRequest(localHost, remoteHost, remotePeerId, query, out)

fn v3OracleRuntimeFindIngress(entries: overlay.V3IngressEnvelope[],
                              payloadCid: layout.FixedBytes32,
                              payloadKind: int32): Result[overlay.V3IngressEnvelope] =
    for i in 0..<entries.len:
        let ingress = entries[i]
        if !layout.fixedBytes32Equal(ingress.payloadCid, payloadCid):
            continue
        if ingress.payloadKind != payloadKind:
            continue
        return Ok[overlay.V3IngressEnvelope](ingress)
    return Err[overlay.V3IngressEnvelope]("v3 oracle runtime host: ingress missing")

fn v3OracleSortI64(values: var int64[]) =
    for i in 1..<values.len:
        let key = values[i]
        var j = i - 1
        while j >= 0 && values[j] > key:
            values[j + 1] = values[j]
            j = j - 1
        values[j + 1] = key

fn v3OracleFastRuntimeMaxRound(runtime: V3OracleFastRuntime): int64 =
    if runtime.batches.len <= 0:
        return int64(-1)
    var out = runtime.batches[0].roundId
    for i in 1..<runtime.batches.len:
        if runtime.batches[i].roundId > out:
            out = runtime.batches[i].roundId
    return out

fn v3OracleFastRuntimeReportCount(runtime: V3OracleFastRuntime, roundId: int64): int32 =
    var count = 0
    for i in 0..<runtime.batches.len:
        if runtime.batches[i].roundId == roundId:
            count = count + 1
    return count

fn v3OracleFastRuntimeFindQuorumRound(runtime: V3OracleFastRuntime): int64 =
    var best = int64(-1)
    for i in 0..<runtime.batches.len:
        let roundId = runtime.batches[i].roundId
        if roundId <= best:
            continue
        if v3OracleFastRuntimeReportCount(runtime, roundId) < runtime.committee.quorum:
            continue
        best = roundId
    return best

fn v3OracleFastRuntimeStoreBatch(runtime: var V3OracleFastRuntime,
                                 batch: var oracle_plane.V3OracleSignedBatch): Result[bool] =
    let verifyRes = oracle_plane.v3OracleSignedBatchVerifyAgainstCommittee(batch, runtime.committee)
    if IsErr(verifyRes):
        return Err[bool](Error(verifyRes))
    for i in 0..<runtime.batches.len:
        let prev = runtime.batches[i]
        if prev.roundId != batch.roundId:
            continue
        if prev.reporterSlot != batch.reporterSlot:
            continue
        if layout.fixedBytes32Equal(prev.batchCid, batch.batchCid):
            return Ok[bool](false)
        return Err[bool]("v3 oracle runtime host: conflicting reporter batch")
    add(runtime.batches, batch)
    let maxRound = v3OracleFastRuntimeMaxRound(runtime)
    let minRound = maxRound - int64(oracle_types.v3OraclePendingRoundMax - 1)
    var kept: oracle_plane.V3OracleSignedBatch[]
    kept = []
    for i in 0..<runtime.batches.len:
        if runtime.batches[i].roundId >= minRound:
            add(kept, runtime.batches[i])
    runtime.batches = kept
    return Ok[bool](true)

fn v3OracleFastRuntimeQueryFast(runtime: V3OracleFastRuntime,
                                pairId: oracle_types.V3OraclePairId): Result[V3OracleFastQuote] =
    if !oracle_types.v3OraclePairValid(pairId):
        return Err[V3OracleFastQuote]("v3 oracle runtime host: bad pair id")
    let roundId = v3OracleFastRuntimeFindQuorumRound(runtime)
    if roundId < 0:
        return Err[V3OracleFastQuote]("v3 oracle runtime host: fast quote unavailable")
    let pairIndex = oracle_types.v3OraclePairIndex(pairId)
    var values: int64[]
    values = []
    for i in 0..<runtime.batches.len:
        let batch = runtime.batches[i]
        if batch.roundId != roundId:
            continue
        add(values, batch.pricesE8[pairIndex])
    if values.len < runtime.committee.quorum:
        return Err[V3OracleFastQuote]("v3 oracle runtime host: fast quorum missing")
    v3OracleSortI64(values)
    var out = v3OracleFastQuoteZero()
    out.available = true
    out.pairId = pairId
    out.roundId = roundId
    out.priceE8 = values[values.len / 2]
    out.reportCount = values.len
    return Ok[V3OracleFastQuote](out)

fn v3OracleRuntimePublishBatch(hostState: var host_base.V3Libp2pHost,
                               scope: overlay.V3OverlayTopicScope,
                               address: binary.V3LsmrAddress,
                               batch: oracle_plane.V3OracleSignedBatch,
                               stampEpoch: int32,
                               stampGanzhi: int32): Result[bool] =
    let payload = oracle_plane.v3OracleSignedBatchEncode(batch)
    let payloadOk = oracle_plane.v3OracleSignedBatchValidatePayload(payload, batch.batchCid)
    if IsErr(payloadOk):
        return Err[bool](Error(payloadOk))
    let ingress = bridge.v3Libp2pIngressMake(hostState.selfPeerId,
                                             scope,
                                             address,
                                             pubsub.v3PubSubPayloadKindOracleBatch,
                                             batch.batchCid,
                                             payload,
                                             stampEpoch,
                                             stampGanzhi)
    bridge.v3Libp2pRelayPublish(hostState, ingress)
    host_base.v3Libp2pKadProvide(hostState, batch.batchCid)
    return Ok[bool](true)

fn v3OracleRuntimeFetchBatch(localHost: var host_base.V3Libp2pHost,
                             remoteHost: var host_base.V3Libp2pHost,
                             remotePeerId: core.V3Libp2pPeerId,
                             scope: overlay.V3OverlayTopicScope,
                             address: binary.V3LsmrAddress,
                             batchCid: layout.FixedBytes32): Result[oracle_plane.V3OracleSignedBatch] =
    var query = overlay.v3OverlayStoreQueryZero()
    query.topicScope = scope
    query.address = address
    query.wantEventCid = batchCid
    var entries: overlay.V3IngressEnvelope[]
    let entriesRes = v3OracleRuntimeSelectSyncRequest(localHost, remoteHost, remotePeerId, query, entries)
    if IsErr(entriesRes):
        return Err[oracle_plane.V3OracleSignedBatch](Error(entriesRes))
    let ingressRes = v3OracleRuntimeFindIngress(entries,
                                                batchCid,
                                                pubsub.v3PubSubPayloadKindOracleBatch)
    if IsErr(ingressRes):
        return Err[oracle_plane.V3OracleSignedBatch](Error(ingressRes))
    let ingress = Value(ingressRes)
    let payloadOk = oracle_plane.v3OracleSignedBatchValidatePayload(ingress.payload, batchCid)
    if IsErr(payloadOk):
        return Err[oracle_plane.V3OracleSignedBatch](Error(payloadOk))
    return oracle_plane.v3OracleSignedBatchDecode(ingress.payload)
