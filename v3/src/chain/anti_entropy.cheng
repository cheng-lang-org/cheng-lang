import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr as lsmr
import cheng/v3/chain/lsmr_types as lt

fn v3AntiEntropyStateLayerSummaryEqual(local: lt.V3StateLayerSummary,
                                       remote: lt.V3StateLayerSummary): bool =
    if local.layerId != remote.layerId:
        return false
    if !layout.fixedBytes32Equal(local.treeCid, remote.treeCid):
        return false
    if local.nodeCount != remote.nodeCount:
        return false
    if local.entryCount != remote.entryCount:
        return false
    return true

fn v3AntiEntropyRootSummaryPos(sig: lt.V3AntiEntropySignature, layerId: int32, baguaId: int32): int32 =
    for i in 0..<sig.rootCount:
        if sig.rootSummaries[i].layerId == layerId:
            if sig.rootSummaries[i].baguaId == baguaId:
                return i
    return -1

fn v3AntiEntropyLayerSummaryPos(sig: lt.V3AntiEntropySignature, layerId: int32): int32 =
    for i in 0..<sig.layerCount:
        if sig.layerSummaries[i].layerId == layerId:
            return i
    return -1

fn v3AntiEntropyLayerSummary(sig: lt.V3AntiEntropySignature, layerId: int32): Result[lt.V3StateLayerSummary] =
    let pos = v3AntiEntropyLayerSummaryPos(sig, layerId)
    if pos < 0:
        return Err[lt.V3StateLayerSummary]("v3 anti_entropy: missing layer summary")
    return Ok[lt.V3StateLayerSummary](sig.layerSummaries[pos])

fn v3AntiEntropyAppendTreeRoots(out: var lt.V3AntiEntropySignature,
                                layerId: int32,
                                tree: lt.V3BaguaPrefixTree) =
    for baguaStep in 0..<8:
        let baguaId = baguaStep + 1
        let rootRes = lsmr.v3BaguaRootSummaryFromTree(layerId, tree, baguaId)
        if rootRes.ok:
            if out.rootCount >= 24:
                panic("v3 anti_entropy: root summary overflow")
            out.rootSummaries[out.rootCount] = rootRes.value
            out.rootCount = out.rootCount + 1

fn v3AntiEntropySignatureFromForest(stampEpoch: int32,
                                    stampGanzhi: int32,
                                    eventCount: int32,
                                    accountCount: int32,
                                    forest: lt.V3StateLayerForest): lt.V3AntiEntropySignature =
    var out: lt.V3AntiEntropySignature
    lt.v3AntiEntropySignatureZeroInto(out)
    out.stampEpoch = stampEpoch
    out.stampGanzhi = stampGanzhi
    out.eventCount = eventCount
    out.accountCount = accountCount
    out.stateForestCid = forest.forestCid
    out.layerCount = 3
    out.layerSummaries[0] = lsmr.v3StateLayerSummaryFromForest(forest, lt.v3LayerGlobal)
    out.layerSummaries[1] = lsmr.v3StateLayerSummaryFromForest(forest, lt.v3LayerRegional)
    out.layerSummaries[2] = lsmr.v3StateLayerSummaryFromForest(forest, lt.v3LayerEdge)
    v3AntiEntropyAppendTreeRoots(out, lt.v3LayerGlobal, forest.globalTree)
    v3AntiEntropyAppendTreeRoots(out, lt.v3LayerRegional, forest.regionalTree)
    v3AntiEntropyAppendTreeRoots(out, lt.v3LayerEdge, forest.edgeTree)
    return out

fn v3AntiEntropySignatureCid(sig: lt.V3AntiEntropySignature): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(1024)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.anti_entropy.signature"))
    lt.v3AppendU32BE(buf, sig.stampEpoch)
    lt.v3AppendU32BE(buf, sig.stampGanzhi)
    lt.v3AppendU32BE(buf, sig.eventCount)
    lt.v3AppendU32BE(buf, sig.accountCount)
    lt.v3AppendFixed32(buf, sig.stateForestCid)
    lt.v3AppendU32BE(buf, sig.layerCount)
    for i in 0..<sig.layerCount:
        lt.v3AppendU32BE(buf, sig.layerSummaries[i].layerId)
        lt.v3AppendFixed32(buf, sig.layerSummaries[i].treeCid)
        lt.v3AppendU32BE(buf, sig.layerSummaries[i].nodeCount)
        lt.v3AppendU32BE(buf, sig.layerSummaries[i].entryCount)
    lt.v3AppendU32BE(buf, sig.rootCount)
    for i in 0..<sig.rootCount:
        lt.v3AppendU32BE(buf, sig.rootSummaries[i].layerId)
        lt.v3AppendU32BE(buf, sig.rootSummaries[i].baguaId)
        lt.v3AppendFixed32(buf, sig.rootSummaries[i].nodeCid)
        lt.v3AppendU32BE(buf, sig.rootSummaries[i].entryDescCount)
    return lt.v3FixedCidFromBuf(buf)

fn v3AntiEntropySignatureEqual(local: lt.V3AntiEntropySignature, remote: lt.V3AntiEntropySignature): bool =
    return layout.fixedBytes32Equal(v3AntiEntropySignatureCid(local), v3AntiEntropySignatureCid(remote))

fn v3PassiveAntiEntropySyncRequired(local: lt.V3AntiEntropySignature, remote: lt.V3AntiEntropySignature): bool =
    if v3AntiEntropySignatureEqual(local, remote):
        return false
    return true

fn v3AntiEntropyStampCompare(local: lt.V3AntiEntropySignature, remote: lt.V3AntiEntropySignature): int32 =
    if local.stampEpoch < remote.stampEpoch:
        return -1
    if local.stampEpoch > remote.stampEpoch:
        return 1
    if local.stampGanzhi < remote.stampGanzhi:
        return -1
    if local.stampGanzhi > remote.stampGanzhi:
        return 1
    return 0

fn v3AntiEntropyAppendRequest(plan: var lt.V3AntiEntropyPlan, request: lt.V3StateSubtreeRef) =
    for i in 0..<plan.requestCount:
        if plan.requests[i].layerId == request.layerId:
            if lt.v3PrefixRefEqual(plan.requests[i].prefix, request.prefix):
                return
    if plan.requestCount >= 24:
        panic("v3 anti_entropy: request overflow")
    plan.requests[plan.requestCount] = request
    plan.requestCount = plan.requestCount + 1

fn v3AntiEntropyWantLayer(remote: lt.V3AntiEntropySignature, compareLayer: int32): Result[int32] =
    if compareLayer == lt.v3LayerGlobal:
        let regionalRes = v3AntiEntropyLayerSummary(remote, lt.v3LayerRegional)
        if !regionalRes.ok:
            return Err[int32](regionalRes.err.msg)
        if regionalRes.value.entryCount > 0:
            return Ok[int32](lt.v3LayerRegional)
        return Ok[int32](lt.v3LayerGlobal)
    if compareLayer == lt.v3LayerRegional:
        let edgeRes = v3AntiEntropyLayerSummary(remote, lt.v3LayerEdge)
        if !edgeRes.ok:
            return Err[int32](edgeRes.err.msg)
        if edgeRes.value.entryCount > 0:
            return Ok[int32](lt.v3LayerEdge)
        return Ok[int32](lt.v3LayerRegional)
    return Ok[int32](lt.v3LayerEdge)

fn v3AntiEntropyAppendRootMismatchRequests(plan: var lt.V3AntiEntropyPlan,
                                           local: lt.V3AntiEntropySignature,
                                           remote: lt.V3AntiEntropySignature,
                                           compareLayer: int32,
                                           requestLayer: int32): Result[bool] =
    for i in 0..<remote.rootCount:
        let remoteRoot = remote.rootSummaries[i]
        if remoteRoot.layerId == compareLayer:
            let localPos = v3AntiEntropyRootSummaryPos(local, compareLayer, remoteRoot.baguaId)
            let localMissing = localPos < 0
            var cidMismatch = false
            var countMismatch = false
            if !localMissing:
                if !layout.fixedBytes32Equal(local.rootSummaries[localPos].nodeCid, remoteRoot.nodeCid):
                    cidMismatch = true
                if local.rootSummaries[localPos].entryDescCount != remoteRoot.entryDescCount:
                    countMismatch = true
            if localMissing:
                let prefixRes = lt.v3PrefixRefFromDigits(remoteRoot.baguaId, [])
                if !prefixRes.ok:
                    return Err[bool](prefixRes.err.msg)
                let request = lt.v3StateSubtreeRefMake(requestLayer, prefixRes.value, remoteRoot.nodeCid, remoteRoot.entryDescCount)
                v3AntiEntropyAppendRequest(plan, request)
            elif cidMismatch:
                let prefixRes = lt.v3PrefixRefFromDigits(remoteRoot.baguaId, [])
                if !prefixRes.ok:
                    return Err[bool](prefixRes.err.msg)
                let request = lt.v3StateSubtreeRefMake(requestLayer, prefixRes.value, remoteRoot.nodeCid, remoteRoot.entryDescCount)
                v3AntiEntropyAppendRequest(plan, request)
            elif countMismatch:
                let prefixRes = lt.v3PrefixRefFromDigits(remoteRoot.baguaId, [])
                if !prefixRes.ok:
                    return Err[bool](prefixRes.err.msg)
                let request = lt.v3StateSubtreeRefMake(requestLayer, prefixRes.value, remoteRoot.nodeCid, remoteRoot.entryDescCount)
                v3AntiEntropyAppendRequest(plan, request)
    return Ok[bool](true)

fn v3AntiEntropyPlan(local: lt.V3AntiEntropySignature,
                     remote: lt.V3AntiEntropySignature): Result[lt.V3AntiEntropyPlan] =
    let localGlobalRes = v3AntiEntropyLayerSummary(local, lt.v3LayerGlobal)
    if !localGlobalRes.ok:
        return Err[lt.V3AntiEntropyPlan](localGlobalRes.err.msg)
    let localRegionalRes = v3AntiEntropyLayerSummary(local, lt.v3LayerRegional)
    if !localRegionalRes.ok:
        return Err[lt.V3AntiEntropyPlan](localRegionalRes.err.msg)
    let localEdgeRes = v3AntiEntropyLayerSummary(local, lt.v3LayerEdge)
    if !localEdgeRes.ok:
        return Err[lt.V3AntiEntropyPlan](localEdgeRes.err.msg)
    let remoteGlobalRes = v3AntiEntropyLayerSummary(remote, lt.v3LayerGlobal)
    if !remoteGlobalRes.ok:
        return Err[lt.V3AntiEntropyPlan](remoteGlobalRes.err.msg)
    let remoteRegionalRes = v3AntiEntropyLayerSummary(remote, lt.v3LayerRegional)
    if !remoteRegionalRes.ok:
        return Err[lt.V3AntiEntropyPlan](remoteRegionalRes.err.msg)
    let remoteEdgeRes = v3AntiEntropyLayerSummary(remote, lt.v3LayerEdge)
    if !remoteEdgeRes.ok:
        return Err[lt.V3AntiEntropyPlan](remoteEdgeRes.err.msg)

    var out: lt.V3AntiEntropyPlan = lt.v3AntiEntropyPlanZero()
    if v3AntiEntropySignatureEqual(local, remote):
        return Ok[lt.V3AntiEntropyPlan](out)

    let stampCmp = v3AntiEntropyStampCompare(local, remote)
    out.remoteNewer = stampCmp < 0
    if stampCmp == 0:
        out.conflictCount = 1
    if !out.remoteNewer:
        if out.conflictCount == 0:
            return Ok[lt.V3AntiEntropyPlan](out)

    if !v3AntiEntropyStateLayerSummaryEqual(localGlobalRes.value, remoteGlobalRes.value):
        let wantLayerRes = v3AntiEntropyWantLayer(remote, lt.v3LayerGlobal)
        if !wantLayerRes.ok:
            return Err[lt.V3AntiEntropyPlan](wantLayerRes.err.msg)
        let appendRes = v3AntiEntropyAppendRootMismatchRequests(out,
                                                               local,
                                                               remote,
                                                               lt.v3LayerGlobal,
                                                               wantLayerRes.value)
        if !appendRes.ok:
            return Err[lt.V3AntiEntropyPlan](appendRes.err.msg)
        return Ok[lt.V3AntiEntropyPlan](out)
    if !v3AntiEntropyStateLayerSummaryEqual(localRegionalRes.value, remoteRegionalRes.value):
        let wantLayerRes = v3AntiEntropyWantLayer(remote, lt.v3LayerRegional)
        if !wantLayerRes.ok:
            return Err[lt.V3AntiEntropyPlan](wantLayerRes.err.msg)
        let appendRes = v3AntiEntropyAppendRootMismatchRequests(out,
                                                               local,
                                                               remote,
                                                               lt.v3LayerRegional,
                                                               wantLayerRes.value)
        if !appendRes.ok:
            return Err[lt.V3AntiEntropyPlan](appendRes.err.msg)
        return Ok[lt.V3AntiEntropyPlan](out)
    if !v3AntiEntropyStateLayerSummaryEqual(localEdgeRes.value, remoteEdgeRes.value):
        let appendRes = v3AntiEntropyAppendRootMismatchRequests(out,
                                                               local,
                                                               remote,
                                                               lt.v3LayerEdge,
                                                               lt.v3LayerEdge)
        if !appendRes.ok:
            return Err[lt.V3AntiEntropyPlan](appendRes.err.msg)
        return Ok[lt.V3AntiEntropyPlan](out)
    return Ok[lt.V3AntiEntropyPlan](out)
