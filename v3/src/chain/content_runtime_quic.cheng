import std/result
import cheng/v3/chain/content_runtime_host_quic as runtime_host_quic
import cheng/v3/chain/content_runtime as runtime
import cheng/v3/chain/erasure_swarm as swarm
import cheng/v3/libp2p/core/types as core
import cheng/v3/libp2p/host/host as host_base

fn v3ContentRuntimeRequestShardPullQuic(localHost: var host_base.V3Libp2pHost,
                                        remoteHost: var host_base.V3Libp2pHost,
                                        remotePeerId: core.V3Libp2pPeerId,
                                        remoteRuntime: var runtime.V3ContentRuntime,
                                        request: swarm.V3ErasureShardPullRequest): Result[swarm.V3ErasureShardPullResponse] =
    return runtime_host_quic.v3ContentRuntimeRequestShardPull(localHost,
                                                              remoteHost,
                                                              remotePeerId,
                                                              remoteRuntime,
                                                              request)
