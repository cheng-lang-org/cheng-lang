import cheng/v3/tooling/path as v3path

type
    V3ProgramSupportContract =
        version: str
        services: str[]
        providerNativeSources: str[]
        executionModel: str
        traceSymbol: str

importc fn cheng_ffi_handle_new_i32(value: int32): uint64
importc fn cheng_ffi_handle_get_i32(handle: uint64, outValue: var int32): int32
importc fn cheng_ffi_handle_add_i32(handle: uint64, delta: int32, outValue: var int32): int32
importc fn cheng_ffi_handle_release_i32(handle: uint64): int32

fn v3ProgramSupportProviderSourcePath(rootDir: str): str =
    return v3path.v3PathAbsolute(rootDir, "v3/src/runtime/program_support_backend_v3.cheng")

fn v3ProgramSupportContract(rootDir: str): V3ProgramSupportContract =
    return V3ProgramSupportContract(
        version: "v3.runtime.program_support.v1",
        services: ["ffi.handle.i32"],
        providerNativeSources: [
            v3ProgramSupportProviderSourcePath(rootDir)
        ],
        executionModel: "pure_cheng_runtime_provider",
        traceSymbol: "cheng_ffi_handle_register_ptr"
    )

fn v3ProgramSupportTargets(): str[] =
    return ["ffi.handle.i32"]

fn v3FfiHandleNewI32(value: int32): uint64 =
    return cheng_ffi_handle_new_i32(value)

fn v3FfiHandleGetI32(handle: uint64): int32 =
    var out: int32 = 0
    let rc: int32 = cheng_ffi_handle_get_i32(handle, out)
    if rc != 0:
        return rc
    return out

fn v3FfiHandleAddI32(handle: uint64, delta: int32): int32 =
    var out: int32 = 0
    let rc: int32 = cheng_ffi_handle_add_i32(handle, delta, out)
    if rc != 0:
        return rc
    return out

fn v3FfiHandleReleaseI32(handle: uint64): int32 =
    return cheng_ffi_handle_release_i32(handle)
