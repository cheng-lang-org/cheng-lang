@exportc("cheng_memcpy")
fn cheng_memcpy_export(dest: ptr, src: ptr, n: int64): ptr =
    if dest == nil || src == nil || n <= 0:
        return dest
    cheng_bytes_copy(dest, src, int32(n))
    return dest

@exportc("cheng_memset")
