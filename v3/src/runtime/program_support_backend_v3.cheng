    let value = int32(*(UInt8Ptr(cheng_ptr_plus(addr, index))))
    cheng_free_export(addr)
    return value

fn cheng_write_u32be(out: ptr, value: uint32) =
    if out == nil:
        return
    *(UInt8Ptr(out)) = uint8((value >> uint32(24)) & uint32(255))
    *(UInt8Ptr(cheng_ptr_plus(out, 1))) = uint8((value >> uint32(16)) & uint32(255))
    *(UInt8Ptr(cheng_ptr_plus(out, 2))) = uint8((value >> uint32(8)) & uint32(255))
    *(UInt8Ptr(cheng_ptr_plus(out, 3))) = uint8(value & uint32(255))

fn cheng_read_u32be(data: ptr): uint32 =
    if data == nil:
        return uint32(0)
    return (uint32(*(UInt8Ptr(data))) << uint32(24)) |
           (uint32(*(UInt8Ptr(cheng_ptr_plus(data, 1)))) << uint32(16)) |
           (uint32(*(UInt8Ptr(cheng_ptr_plus(data, 2)))) << uint32(8)) |
           uint32(*(UInt8Ptr(cheng_ptr_plus(data, 3))))

fn cheng_close_if_open(fd: int32) =
    if fd >= 0:
        libc_close(fd)

fn cheng_send_all(fd: int32, data: ptr, len0: int32): bool =
    if len0 <= 0:
        return true
    if fd < 0 || data == nil:
        return false
    var sent: int32 = 0
    while sent < len0:
        let wrote = libc_send(fd, cheng_ptr_plus(data, sent), len0 - sent, 0)
        if wrote <= 0:
            return false
        sent = sent + wrote
    return true

fn cheng_recv_exact(fd: int32, data: ptr, len0: int32): bool =
    if len0 <= 0:
        return true
    if fd < 0 || data == nil:
        return false
    var received: int32 = 0
    while received < len0:
        let got = libc_recv(fd, cheng_ptr_plus(data, received), len0 - received, cheng_msg_waitall())
        if got <= 0:
            return false
        received = received + got
    return true

fn cheng_write_u16le(out: ptr, value: int32) =
    if out == nil:
        return
    *(UInt8Ptr(out)) = uint8(value & 255)
    *(UInt8Ptr(cheng_ptr_plus(out, 1))) = uint8((value >> 8) & 255)

fn cheng_read_u16le(data: ptr): int32 =
    if data == nil:
        return 0
    return int32(*(UInt8Ptr(data))) | (int32(*(UInt8Ptr(cheng_ptr_plus(data, 1)))) << 8)

fn cheng_pollfd_write(out: ptr, fd: int32, events: int32) =
    if out == nil:
        return
    *(Int32Ptr(out)) = fd
    cheng_write_u16le(cheng_ptr_plus(out, 4), events)
    cheng_write_u16le(cheng_ptr_plus(out, 6), 0)

fn cheng_pollfd_revents(data: ptr): int32 =
    if data == nil:
        return 0
    return cheng_read_u16le(cheng_ptr_plus(data, 6))

fn cheng_tcp_wait_readable(fd: int32, timeoutMs: int32, errWire: var str): int32 =
    if fd < 0:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: invalid listener")
        return -1
    let pollFd = cheng_malloc_export(chengPollFdLen)
    if pollFd == nil:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
        return -1
    cheng_pollfd_write(pollFd, fd, chengPollIn)
    let rc = libc_poll(pollFd, 1, timeoutMs)
    let revents = cheng_pollfd_revents(pollFd)
    cheng_free_export(pollFd)
    if rc < 0:
        errWire = cheng_error_with_errno("v3 libp2p tcp: poll")
        return -1
    if rc == 0 || revents == 0:
        return 0
    return 1

fn cheng_bytes_hex_str(raw: ptr, n0: int32): str =
    var n = n0
    if n <= 0 || raw == nil:
        return cheng_str_empty()
    let out = driver_c_new_string_export(n * 2)
    if out == nil:
        return cheng_str_empty()
    for i in 0..<n:
        let value = int32(*(UInt8Ptr(cheng_ptr_plus(raw, i))))
        *(UInt8Ptr(cheng_ptr_plus(out, i * 2))) = cheng_sha256_hex_digit((value >> 4) & 15)
        *(UInt8Ptr(cheng_ptr_plus(out, i * 2 + 1))) = cheng_sha256_hex_digit(value & 15)
    return cheng_str_view_owned(out, n * 2)

fn cheng_hex_value(ch: uint8): int32 =
    if ch >= uint8(int32('0')) && ch <= uint8(int32('9')):
        return int32(ch) - int32(uint8(int32('0')))
    if ch >= uint8(int32('a')) && ch <= uint8(int32('f')):
        return 10 + int32(ch) - int32(uint8(int32('a')))
    if ch >= uint8(int32('A')) && ch <= uint8(int32('F')):
        return 10 + int32(ch) - int32(uint8(int32('A')))
    return -1

fn cheng_hex_decode_str(text: str, out: var str, errWire: var str): bool =
    out = cheng_str_empty()
    if (cheng_str_len(text) % 2) != 0:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: invalid capture hex length")
        return false
    let outRaw = driver_c_new_string_export(cheng_str_len(text) / 2)
    if outRaw == nil:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
        return false
    var i = 0
    while i < cheng_str_len(text):
        let hi = cheng_hex_value(*(UInt8Ptr(cheng_ptr_plus(cheng_str_data(text), i))))
        let lo = cheng_hex_value(*(UInt8Ptr(cheng_ptr_plus(cheng_str_data(text), i + 1))))
        if hi < 0 || lo < 0:
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: invalid capture hex")
            return false
        *(UInt8Ptr(cheng_ptr_plus(outRaw, i / 2))) = uint8((hi << 4) | lo)
        i = i + 2
    out = cheng_str_view_owned(outRaw, cheng_str_len(text) / 2)
    return true

fn cheng_hex_decode_alloc(text: str, outLen: var int32, errWire: var str): ptr =
    outLen = 0
    if (cheng_str_len(text) % 2) != 0:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: invalid capture hex length")
        return nil
    outLen = cheng_str_len(text) / 2
    if outLen <= 0:
        return nil
    let outRaw = cheng_malloc_export(outLen)
    if outRaw == nil:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
        return nil
    var i = 0
    while i < cheng_str_len(text):
        let hi = cheng_hex_value(*(UInt8Ptr(cheng_ptr_plus(cheng_str_data(text), i))))
        let lo = cheng_hex_value(*(UInt8Ptr(cheng_ptr_plus(cheng_str_data(text), i + 1))))
        if hi < 0 || lo < 0:
            cheng_free_export(outRaw)
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: invalid capture hex")
            return nil
        *(UInt8Ptr(cheng_ptr_plus(outRaw, i / 2))) = uint8((hi << 4) | lo)
        i = i + 2
    return outRaw

fn cheng_write_text_file(pathText: str, content: str): bool =
    let path = cheng_copy_cstring_from_str(pathText)
    if path == nil:
        return false
    let fp = cheng_fopen_write(path)
    cheng_free_export(path)
    if fp == nil:
        return false
    let wrote = libc_fwrite(cheng_str_data(content), 1, cheng_str_len(content), fp)
    let closeRc = libc_fclose(fp)
    return wrote == int64(cheng_str_len(content)) && closeRc == 0

fn cheng_write_ready_port(readyPath: str, boundPort: int32, errWire: var str): bool =
    if cheng_str_len(readyPath) <= 0:
        return true
    let path = cheng_copy_cstring_from_str(readyPath)
    let portText = driver_c_i32_to_str_export(boundPort)
    if path != nil && portText != nil:
        let fp = cheng_fopen_write(path)
        if fp != nil:
            let portLen = cheng_cstrlen_raw(portText)
            let wrote = libc_fwrite(portText, 1, portLen, fp)
            let closeRc = libc_fclose(fp)
            cheng_free_export(path)
            cheng_free_export(portText)
            if wrote == int64(portLen) && closeRc == 0:
                return true
            errWire = cheng_error_with_errno("v3 libp2p tcp: ready path")
            return false
    if path != nil:
        cheng_free_export(path)
    if portText != nil:
        cheng_free_export(portText)
    errWire = cheng_error_with_errno("v3 libp2p tcp: ready path")
    return false

fn cheng_sysctl_read_i64(nameText: str): int64 =
    nameText
    return 0

fn cheng_statvfs_query_root(totalBytesOut: Int64Ptr, availableBytesOut: Int64Ptr): bool =
    if totalBytesOut != nil:
        *totalBytesOut = native_cheng_v3_system_disk_total_bytes_value_runtime()
    if availableBytesOut != nil:
        *availableBytesOut = native_cheng_v3_system_disk_available_bytes_value_runtime()
    return true

fn cheng_sha256_u32(x: int64): int64 =
    return x & int64(0xffffffff)

fn cheng_sha256_rotr32(x: int64, n: int32): int64 =
    let v = cheng_sha256_u32(x)
    return cheng_sha256_u32((v >> n) | (v << (32 - n)))

fn cheng_sha256_ch(x: int64, y: int64, z: int64): int64 =
    let xu = cheng_sha256_u32(x)
    let yu = cheng_sha256_u32(y)
    let zu = cheng_sha256_u32(z)
    return cheng_sha256_u32((xu & yu) ^ ((xu ^ int64(0xffffffff)) & zu))

fn cheng_sha256_maj(x: int64, y: int64, z: int64): int64 =
    let xu = cheng_sha256_u32(x)
    let yu = cheng_sha256_u32(y)
    let zu = cheng_sha256_u32(z)
    return cheng_sha256_u32((xu & yu) ^ (xu & zu) ^ (yu & zu))

fn cheng_sha256_big_sigma0(x: int64): int64 =
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 2) ^ cheng_sha256_rotr32(x, 13) ^ cheng_sha256_rotr32(x, 22))

fn cheng_sha256_big_sigma1(x: int64): int64 =
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 6) ^ cheng_sha256_rotr32(x, 11) ^ cheng_sha256_rotr32(x, 25))

fn cheng_sha256_small_sigma0(x: int64): int64 =
    let xu = cheng_sha256_u32(x)
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 7) ^ cheng_sha256_rotr32(x, 18) ^ (xu >> 3))

fn cheng_sha256_small_sigma1(x: int64): int64 =
    let xu = cheng_sha256_u32(x)
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 17) ^ cheng_sha256_rotr32(x, 19) ^ (xu >> 10))

fn cheng_sha256_u32_from_bytes(b0: int32, b1: int32, b2: int32, b3: int32): int64 =
    return (int64(b0) << 24) | (int64(b1) << 16) | (int64(b2) << 8) | int64(b3)

fn cheng_sha256_k(i: int32): int64 =
    case i
    of 0: return cheng_sha256_u32_from_bytes(0x42, 0x8a, 0x2f, 0x98)
    of 1: return cheng_sha256_u32_from_bytes(0x71, 0x37, 0x44, 0x91)
    of 2: return cheng_sha256_u32_from_bytes(0xb5, 0xc0, 0xfb, 0xcf)
    of 3: return cheng_sha256_u32_from_bytes(0xe9, 0xb5, 0xdb, 0xa5)
    of 4: return cheng_sha256_u32_from_bytes(0x39, 0x56, 0xc2, 0x5b)
    of 5: return cheng_sha256_u32_from_bytes(0x59, 0xf1, 0x11, 0xf1)
    of 6: return cheng_sha256_u32_from_bytes(0x92, 0x3f, 0x82, 0xa4)
    of 7: return cheng_sha256_u32_from_bytes(0xab, 0x1c, 0x5e, 0xd5)
    of 8: return cheng_sha256_u32_from_bytes(0xd8, 0x07, 0xaa, 0x98)
    of 9: return cheng_sha256_u32_from_bytes(0x12, 0x83, 0x5b, 0x01)
    of 10: return cheng_sha256_u32_from_bytes(0x24, 0x31, 0x85, 0xbe)
    of 11: return cheng_sha256_u32_from_bytes(0x55, 0x0c, 0x7d, 0xc3)
    of 12: return cheng_sha256_u32_from_bytes(0x72, 0xbe, 0x5d, 0x74)
    of 13: return cheng_sha256_u32_from_bytes(0x80, 0xde, 0xb1, 0xfe)
    of 14: return cheng_sha256_u32_from_bytes(0x9b, 0xdc, 0x06, 0xa7)
    of 15: return cheng_sha256_u32_from_bytes(0xc1, 0x9b, 0xf1, 0x74)
    of 16: return cheng_sha256_u32_from_bytes(0xe4, 0x9b, 0x69, 0xc1)
    of 17: return cheng_sha256_u32_from_bytes(0xef, 0xbe, 0x47, 0x86)
    of 18: return cheng_sha256_u32_from_bytes(0x0f, 0xc1, 0x9d, 0xc6)
    of 19: return cheng_sha256_u32_from_bytes(0x24, 0x0c, 0xa1, 0xcc)
    of 20: return cheng_sha256_u32_from_bytes(0x2d, 0xe9, 0x2c, 0x6f)
    of 21: return cheng_sha256_u32_from_bytes(0x4a, 0x74, 0x84, 0xaa)
    of 22: return cheng_sha256_u32_from_bytes(0x5c, 0xb0, 0xa9, 0xdc)
    of 23: return cheng_sha256_u32_from_bytes(0x76, 0xf9, 0x88, 0xda)
    of 24: return cheng_sha256_u32_from_bytes(0x98, 0x3e, 0x51, 0x52)
    of 25: return cheng_sha256_u32_from_bytes(0xa8, 0x31, 0xc6, 0x6d)
    of 26: return cheng_sha256_u32_from_bytes(0xb0, 0x03, 0x27, 0xc8)
    of 27: return cheng_sha256_u32_from_bytes(0xbf, 0x59, 0x7f, 0xc7)
    of 28: return cheng_sha256_u32_from_bytes(0xc6, 0xe0, 0x0b, 0xf3)
    of 29: return cheng_sha256_u32_from_bytes(0xd5, 0xa7, 0x91, 0x47)
    of 30: return cheng_sha256_u32_from_bytes(0x06, 0xca, 0x63, 0x51)
    of 31: return cheng_sha256_u32_from_bytes(0x14, 0x29, 0x29, 0x67)
    of 32: return cheng_sha256_u32_from_bytes(0x27, 0xb7, 0x0a, 0x85)
    of 33: return cheng_sha256_u32_from_bytes(0x2e, 0x1b, 0x21, 0x38)
    of 34: return cheng_sha256_u32_from_bytes(0x4d, 0x2c, 0x6d, 0xfc)
    of 35: return cheng_sha256_u32_from_bytes(0x53, 0x38, 0x0d, 0x13)
    of 36: return cheng_sha256_u32_from_bytes(0x65, 0x0a, 0x73, 0x54)
    of 37: return cheng_sha256_u32_from_bytes(0x76, 0x6a, 0x0a, 0xbb)
    of 38: return cheng_sha256_u32_from_bytes(0x81, 0xc2, 0xc9, 0x2e)
    of 39: return cheng_sha256_u32_from_bytes(0x92, 0x72, 0x2c, 0x85)
    of 40: return cheng_sha256_u32_from_bytes(0xa2, 0xbf, 0xe8, 0xa1)
    of 41: return cheng_sha256_u32_from_bytes(0xa8, 0x1a, 0x66, 0x4b)
    of 42: return cheng_sha256_u32_from_bytes(0xc2, 0x4b, 0x8b, 0x70)
    of 43: return cheng_sha256_u32_from_bytes(0xc7, 0x6c, 0x51, 0xa3)
    of 44: return cheng_sha256_u32_from_bytes(0xd1, 0x92, 0xe8, 0x19)
    of 45: return cheng_sha256_u32_from_bytes(0xd6, 0x99, 0x06, 0x24)
    of 46: return cheng_sha256_u32_from_bytes(0xf4, 0x0e, 0x35, 0x85)
    of 47: return cheng_sha256_u32_from_bytes(0x10, 0x6a, 0xa0, 0x70)
    of 48: return cheng_sha256_u32_from_bytes(0x19, 0xa4, 0xc1, 0x16)
    of 49: return cheng_sha256_u32_from_bytes(0x1e, 0x37, 0x6c, 0x08)
    of 50: return cheng_sha256_u32_from_bytes(0x27, 0x48, 0x77, 0x4c)
    of 51: return cheng_sha256_u32_from_bytes(0x34, 0xb0, 0xbc, 0xb5)
    of 52: return cheng_sha256_u32_from_bytes(0x39, 0x1c, 0x0c, 0xb3)
    of 53: return cheng_sha256_u32_from_bytes(0x4e, 0xd8, 0xaa, 0x4a)
    of 54: return cheng_sha256_u32_from_bytes(0x5b, 0x9c, 0xca, 0x4f)
    of 55: return cheng_sha256_u32_from_bytes(0x68, 0x2e, 0x6f, 0xf3)
    of 56: return cheng_sha256_u32_from_bytes(0x74, 0x8f, 0x82, 0xee)
    of 57: return cheng_sha256_u32_from_bytes(0x78, 0xa5, 0x63, 0x6f)
    of 58: return cheng_sha256_u32_from_bytes(0x84, 0xc8, 0x78, 0x14)
    of 59: return cheng_sha256_u32_from_bytes(0x8c, 0xc7, 0x02, 0x08)
    of 60: return cheng_sha256_u32_from_bytes(0x90, 0xbe, 0xff, 0xfa)
    of 61: return cheng_sha256_u32_from_bytes(0xa4, 0x50, 0x6c, 0xeb)
    of 62: return cheng_sha256_u32_from_bytes(0xbe, 0xf9, 0xa3, 0xf7)
    of 63: return cheng_sha256_u32_from_bytes(0xc6, 0x71, 0x78, 0xf2)
    else: return 0

fn cheng_sha256_get_u32be(data: ptr, offset: int32): int64 =
    let b0 = int64(*(UInt8Ptr(cheng_ptr_plus(data, offset))))
    let b1 = int64(*(UInt8Ptr(cheng_ptr_plus(data, offset + 1))))
    let b2 = int64(*(UInt8Ptr(cheng_ptr_plus(data, offset + 2))))
    let b3 = int64(*(UInt8Ptr(cheng_ptr_plus(data, offset + 3))))
    return (b0 << 24) | (b1 << 16) | (b2 << 8) | b3

fn cheng_sha256_set_u32be(data: ptr, offset: int32, value: int64) =
    let v = cheng_sha256_u32(value)
    *(UInt8Ptr(cheng_ptr_plus(data, offset))) = uint8((v >> 24) & 255)
    *(UInt8Ptr(cheng_ptr_plus(data, offset + 1))) = uint8((v >> 16) & 255)
    *(UInt8Ptr(cheng_ptr_plus(data, offset + 2))) = uint8((v >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(data, offset + 3))) = uint8(v & 255)

fn cheng_sha256_digest_into(data: ptr, length: int32, out32: ptr): bool =
    if out32 == nil || length < 0:
        return false
    var h0 = cheng_sha256_u32_from_bytes(0x6a, 0x09, 0xe6, 0x67)
    var h1 = cheng_sha256_u32_from_bytes(0xbb, 0x67, 0xae, 0x85)
    var h2 = cheng_sha256_u32_from_bytes(0x3c, 0x6e, 0xf3, 0x72)
    var h3 = cheng_sha256_u32_from_bytes(0xa5, 0x4f, 0xf5, 0x3a)
    var h4 = cheng_sha256_u32_from_bytes(0x51, 0x0e, 0x52, 0x7f)
    var h5 = cheng_sha256_u32_from_bytes(0x9b, 0x05, 0x68, 0x8c)
    var h6 = cheng_sha256_u32_from_bytes(0x1f, 0x83, 0xd9, 0xab)
    var h7 = cheng_sha256_u32_from_bytes(0x5b, 0xe0, 0xcd, 0x19)
    var padZero: int32 = 0
    while ((length + 1 + padZero) % 64) != 56:
        padZero = padZero + 1
    let totalLen = length + 1 + padZero + 8
    let msg = cheng_malloc_export(totalLen)
    let wbuf = cheng_malloc_export(64 * 4)
    if msg == nil || wbuf == nil:
        if msg != nil:
            cheng_free_export(msg)
        if wbuf != nil:
            cheng_free_export(wbuf)
        return false
    cheng_bytes_set(msg, 0, totalLen)
    if data != nil && length > 0:
        cheng_bytes_copy(msg, data, length)
    *(UInt8Ptr(cheng_ptr_plus(msg, length))) = uint8(0x80)
    var bitLen = int64(length) * 8
    for i in 0..<8:
        *(UInt8Ptr(cheng_ptr_plus(msg, totalLen - 1 - i))) = uint8(bitLen & 255)
        bitLen = bitLen >> 8
    var offset: int32 = 0
    while offset < totalLen:
        for t in 0..<16:
            cheng_sha256_set_u32be(wbuf, t * 4, cheng_sha256_get_u32be(msg, offset + t * 4))
        for t in 16..<64:
            let w2 = cheng_sha256_get_u32be(wbuf, (t - 2) * 4)
            let w7 = cheng_sha256_get_u32be(wbuf, (t - 7) * 4)
            let w15 = cheng_sha256_get_u32be(wbuf, (t - 15) * 4)
            let w16 = cheng_sha256_get_u32be(wbuf, (t - 16) * 4)
            cheng_sha256_set_u32be(wbuf,
                                   t * 4,
                                   cheng_sha256_u32(w16 + cheng_sha256_small_sigma0(w15) +
                                                    w7 + cheng_sha256_small_sigma1(w2)))
        var a = h0
        var b = h1
        var c = h2
        var d = h3
        var e = h4
        var f = h5
        var g = h6
        var h = h7
        for t in 0..<64:
            let wt = cheng_sha256_get_u32be(wbuf, t * 4)
            let t1 = cheng_sha256_u32(h + cheng_sha256_big_sigma1(e) +
                                      cheng_sha256_ch(e, f, g) + cheng_sha256_k(t) + wt)
            let t2 = cheng_sha256_u32(cheng_sha256_big_sigma0(a) + cheng_sha256_maj(a, b, c))
            h = g
            g = f
            f = e
            e = cheng_sha256_u32(d + t1)
            d = c
            c = b
            b = a
            a = cheng_sha256_u32(t1 + t2)
        h0 = cheng_sha256_u32(h0 + a)
        h1 = cheng_sha256_u32(h1 + b)
        h2 = cheng_sha256_u32(h2 + c)
        h3 = cheng_sha256_u32(h3 + d)
        h4 = cheng_sha256_u32(h4 + e)
        h5 = cheng_sha256_u32(h5 + f)
        h6 = cheng_sha256_u32(h6 + g)
        h7 = cheng_sha256_u32(h7 + h)
        offset = offset + 64
    cheng_sha256_set_u32be(out32, 0, h0)
    cheng_sha256_set_u32be(out32, 4, h1)
    cheng_sha256_set_u32be(out32, 8, h2)
    cheng_sha256_set_u32be(out32, 12, h3)
    cheng_sha256_set_u32be(out32, 16, h4)
    cheng_sha256_set_u32be(out32, 20, h5)
    cheng_sha256_set_u32be(out32, 24, h6)
    cheng_sha256_set_u32be(out32, 28, h7)
    cheng_free_export(msg)
    cheng_free_export(wbuf)
    return true

fn cheng_sha256_hex_digit(value: int32): uint8 =
    if value < 10:
        return uint8(int32('0') + value)
    return uint8(int32('a') + (value - 10))

fn cheng_webrtc_unsupported(errWire: var str, text: ptr): int32 =
    errWire = cheng_str_copy_cstring(text)
    return 0

fn cheng_webrtc_error(errWire: var str, text: str): int32 =
    errWire = cheng_str_copy(cheng_str_data(text), cheng_str_len(text))
    return 0

fn cheng_webrtc_last_error_clear() =
    cheng_str_dispose(cheng_webrtc_bridge_last_error)

fn cheng_webrtc_last_error_set(text: str) =
    cheng_str_dispose(cheng_webrtc_bridge_last_error)
    cheng_webrtc_bridge_last_error = cheng_str_dup(text)

fn cheng_webrtc_last_error_set_ptr(text: ptr) =
    cheng_str_dispose(cheng_webrtc_bridge_last_error)
    cheng_webrtc_bridge_last_error = cheng_str_copy_cstring(text)

fn cheng_webrtc_last_error_alloc_failed() =
    cheng_webrtc_last_error_set_ptr("v3 libp2p webrtc: alloc failed")

fn cheng_webrtc_last_error_datachannel_bridge_failed() =
    cheng_webrtc_last_error_set_ptr("v3 libp2p webrtc: datachannel bridge failed")

fn cheng_webrtc_last_error_browser_session_open_failed() =
    cheng_webrtc_last_error_set_ptr("v3 libp2p webrtc browser: session open failed")

fn cheng_webrtc_last_error_browser_signal_alloc_failed() =
    cheng_webrtc_last_error_set_ptr("v3 libp2p webrtc browser: signal transcript alloc failed")

fn cheng_webrtc_last_error_browser_session_inactive() =
    cheng_webrtc_last_error_set_ptr("v3 libp2p webrtc browser: session inactive")

fn cheng_webrtc_last_error_browser_signal_missing() =
    cheng_webrtc_last_error_set_ptr("v3 libp2p webrtc browser: signal transcript missing")

fn cheng_webrtc_last_error_browser_session_exchange_failed() =
    cheng_webrtc_last_error_set_ptr("v3 libp2p webrtc browser: session exchange failed")

fn cheng_webrtc_last_error_browser_session_close_failed() =
    cheng_webrtc_last_error_set_ptr("v3 libp2p webrtc browser: session close failed")

fn cheng_fixed32_zero(): ChengFixedBytes32 =
    var out: ChengFixedBytes32
    for i in 0..<32:
        out.data[i] = uint8(0)
    return out

fn cheng_fixed32_equal(a: ChengFixedBytes32, b: ChengFixedBytes32): bool =
    for i in 0..<32:
        if a.data[i] != b.data[i]:
            return false
    return true

fn cheng_fixed32_from_ptr(raw: ptr): ChengFixedBytes32 =
    var out = cheng_fixed32_zero()
    if raw == nil:
        return out
    for i in 0..<32:
        out.data[i] = *(UInt8Ptr(cheng_ptr_plus(raw, i)))
    return out

fn cheng_fixed32_hex(value: ChengFixedBytes32): str =
    let raw = cheng_malloc_export(65)
    if raw == nil:
        return cheng_str_empty()
    cheng_bytes_set(raw, 0, 65)
    for i in 0..<32:
        let byteValue = int32(value.data[i]) & 255
        *(UInt8Ptr(cheng_ptr_plus(raw, i * 2))) = cheng_sha256_hex_digit(byteValue / 16)
        *(UInt8Ptr(cheng_ptr_plus(raw, i * 2 + 1))) = cheng_sha256_hex_digit(byteValue % 16)
    return cheng_str_view_owned(raw, 64)

fn cheng_binary_str_alloc(len0: int32): str =
    var len = len0
    if len < 0:
        len = 0
    let raw = cheng_malloc_export(len + 1)
    if raw == nil:
        return cheng_str_empty()
    cheng_bytes_set(raw, 0, len + 1)
    return cheng_str_view_owned(raw, len)

fn cheng_webrtc_signal_read_u32_at(raw: ptr,
                                   totalLen: int32,
                                   offset: int32,
                                   out: var int32): bool =
    out = 0
    if raw == nil || offset < 0 || offset + 4 > totalLen:
        return false
    out = int32(cheng_read_u32be(cheng_ptr_plus(raw, offset)))
    return true

fn cheng_webrtc_signal_skip_str(raw: ptr,
                                totalLen: int32,
                                offset: int32,
                                nextOffset: var int32): bool =
    nextOffset = offset
    var size = 0
    if !cheng_webrtc_signal_read_u32_at(raw, totalLen, offset, size):
        return false
    let next = offset + 4 + size
    if size < 0 || next < offset || next > totalLen:
        return false
    nextOffset = next
    return true

fn cheng_webrtc_signal_decode_header(messageText: str,
                                     kind: var int32,
                                     sessionId: var ChengFixedBytes32,
                                     relayOnly: var bool,
                                     errWire: var str): bool =
    kind = 0
    sessionId = cheng_fixed32_zero()
    relayOnly = false
    let data = cheng_str_data(messageText)
    let totalLen = cheng_str_len(messageText)
    if data == nil || totalLen < 36:
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: short signal payload")
        return false
    var kindValue = 0
    if !cheng_webrtc_signal_read_u32_at(data, totalLen, 0, kindValue):
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: short signal kind")
        return false
    kind = kindValue
    sessionId = cheng_fixed32_from_ptr(cheng_ptr_plus(data, 4))
    var offset = 36
    if !cheng_webrtc_signal_skip_str(data, totalLen, offset, offset):
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: short signal sdp")
        return false
    if !cheng_webrtc_signal_skip_str(data, totalLen, offset, offset):
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: short signal mid")
        return false
    if offset + 4 > totalLen:
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: short signal mline")
        return false
    offset = offset + 4
    if !cheng_webrtc_signal_skip_str(data, totalLen, offset, offset):
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: short signal candidate")
        return false
    var relayValue = 0
    if !cheng_webrtc_signal_read_u32_at(data, totalLen, offset, relayValue):
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: short signal relay flag")
        return false
    relayOnly = relayValue != 0
    return true

fn cheng_webrtc_signal_validate_transcript(signalWire: str,
                                           sessionId: var ChengFixedBytes32,
                                           relayOnly: var bool,
                                           errWire: var str): bool =
    sessionId = cheng_fixed32_zero()
    relayOnly = false
    errWire = cheng_str_empty()
    let data = cheng_str_data(signalWire)
    let totalLen = cheng_str_len(signalWire)
    if data == nil || totalLen < 4:
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: signal transcript missing")
        return false
    var count = 0
    if !cheng_webrtc_signal_read_u32_at(data, totalLen, 0, count):
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: signal transcript short count")
        return false
    var offset = 4
    var policyCount = 0
    var offerCount = 0
    var answerCount = 0
    var candidateCount = 0
    var sessionSeen = false
    for i in 0..<count:
        var size = 0
        if !cheng_webrtc_signal_read_u32_at(data, totalLen, offset, size):
            cheng_webrtc_error(errWire, "v3 libp2p webrtc: signal transcript short frame len")
            return false
        offset = offset + 4
        if size < 0 || offset + size > totalLen:
            cheng_webrtc_error(errWire, "v3 libp2p webrtc: signal transcript short frame")
            return false
        let messageText = cheng_str_view(cheng_ptr_plus(data, offset), size)
        var kind = 0
        var msgSessionId = cheng_fixed32_zero()
        var msgRelayOnly = false
        if !cheng_webrtc_signal_decode_header(messageText, kind, msgSessionId, msgRelayOnly, errWire):
            return false
        if cheng_fixed32_equal(msgSessionId, cheng_fixed32_zero()):
            cheng_webrtc_error(errWire, "v3 libp2p webrtc: signal transcript missing session id")
            return false
        if !sessionSeen:
            sessionSeen = true
            sessionId = msgSessionId
        elif !cheng_fixed32_equal(sessionId, msgSessionId):
            cheng_webrtc_error(errWire, "v3 libp2p webrtc: signal transcript session mismatch")
            return false
        if kind == 1:
            offerCount = offerCount + 1
        elif kind == 2:
            answerCount = answerCount + 1
        elif kind == 3:
            candidateCount = candidateCount + 1
        elif kind == 4:
            policyCount = policyCount + 1
            relayOnly = msgRelayOnly
        else:
            cheng_webrtc_error(errWire, "v3 libp2p webrtc: signal transcript kind mismatch")
            return false
        offset = offset + size
    if offset != totalLen:
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: signal transcript trailing bytes")
        return false
    if !sessionSeen || policyCount < 1 || offerCount < 1 || answerCount < 1 || candidateCount < 2:
        cheng_webrtc_error(errWire, "v3 libp2p webrtc: signal session not ready")
        return false
    return true

fn cheng_webrtc_signal_build_message(kind: int32,
                                     sessionId: ChengFixedBytes32,
                                     sdp: str,
                                     candidateMid: str,
                                     candidateMLineIndex: int32,
                                     candidateText: str,
                                     relayOnly: bool): str =
    let sdpLen = cheng_str_len(sdp)
    let midLen = cheng_str_len(candidateMid)
    let candidateLen = cheng_str_len(candidateText)
    let totalLen = 64 + sdpLen + midLen + candidateLen
    let out = cheng_binary_str_alloc(totalLen)
    let raw = cheng_str_data(out)
    if raw == nil && totalLen > 0:
        return cheng_str_empty()
    cheng_write_u32be(raw, uint32(kind))
    for i in 0..<32:
        *(UInt8Ptr(cheng_ptr_plus(raw, 4 + i))) = sessionId.data[i]
    var offset = 36
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(sdpLen))
    offset = offset + 4
    cheng_bytes_copy(cheng_ptr_plus(raw, offset), cheng_str_data(sdp), sdpLen)
    offset = offset + sdpLen
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(midLen))
    offset = offset + 4
    cheng_bytes_copy(cheng_ptr_plus(raw, offset), cheng_str_data(candidateMid), midLen)
    offset = offset + midLen
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(candidateMLineIndex))
    offset = offset + 4
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(candidateLen))
    offset = offset + 4
    cheng_bytes_copy(cheng_ptr_plus(raw, offset), cheng_str_data(candidateText), candidateLen)
    offset = offset + candidateLen
    cheng_write_u32be(cheng_ptr_plus(raw, offset), relayOnly ? uint32(1) : uint32(0))
    offset = offset + 4
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(0))
    offset = offset + 4
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(0))
    return out

fn cheng_webrtc_browser_offer_sdp(sessionId: ChengFixedBytes32, labelText: str): str =
    return "v=0\no=- 1 1 IN IP4 127.0.0.1\n" +
           "s=cheng-v3-browser-webrtc\n" +
           "t=0 0\n" +
           "m=application 9 UDP/DTLS/SCTP webrtc-datachannel\n" +
           "a=mid:0\n" +
           "a=setup:actpass\n" +
           "a=dcmap:0 label=" + labelText + "\n" +
           "a=x-session-id:" + cheng_fixed32_hex(sessionId)

fn cheng_webrtc_browser_answer_sdp(sessionId: ChengFixedBytes32, labelText: str): str =
    return "v=0\no=- 2 2 IN IP4 127.0.0.1\n" +
           "s=cheng-v3-browser-webrtc-answer\n" +
           "t=0 0\n" +
           "m=application 9 UDP/DTLS/SCTP webrtc-datachannel\n" +
           "a=mid:0\n" +
           "a=setup:active\n" +
           "a=dcmap:0 label=" + labelText + "\n" +
           "a=x-session-id:" + cheng_fixed32_hex(sessionId)

fn cheng_webrtc_browser_candidate_text(relayOnly: bool, side: str): str =
    if relayOnly:
        return "candidate:1 1 udp 2130706431 127.0.0.1 9 typ relay generation 0 ufrag " + side
    return "candidate:1 1 udp 2130706431 127.0.0.1 9 typ host generation 0 ufrag " + side

fn cheng_webrtc_browser_session_runtime_new(sessionId: ChengFixedBytes32,
                                            relayOnly: bool): ChengV3WebrtcBrowserSessionStatePtr =
    let mem = cheng_malloc_export(int32(sizeof ChengV3WebrtcBrowserSessionState))
    if mem == nil:
        return nil
    let runtime = ChengV3WebrtcBrowserSessionStatePtr(mem)
    runtime->active = true
    runtime->relayOnly = relayOnly
    runtime->sessionId = sessionId
    runtime->signalWire = cheng_str_empty()
    return runtime

fn cheng_webrtc_browser_session_runtime_dispose(runtime: ChengV3WebrtcBrowserSessionStatePtr) =
    if runtime == nil:
        return
    cheng_str_dispose(runtime->signalWire)
    cheng_free_export(ptr(runtime))

fn cheng_webrtc_browser_signal_transcript(policyText: str,
                                          labelText: str,
                                          signalResponseWire: var str,
                                          sessionId: var ChengFixedBytes32,
                                          relayOnly: var bool,
                                          errWire: var str): bool =
    signalResponseWire = cheng_str_empty()
    errWire = cheng_str_empty()
    sessionId = cheng_fixed32_zero()
    relayOnly = false
    var policyKind = 0
    if !cheng_webrtc_signal_decode_header(policyText, policyKind, sessionId, relayOnly, errWire):
        return false
    if policyKind != 4:
        cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: policy kind mismatch")
        return false
    if cheng_fixed32_equal(sessionId, cheng_fixed32_zero()):
        cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: policy session id missing")
        return false
    let offerWire = cheng_webrtc_signal_build_message(1,
                                                      sessionId,
                                                      cheng_webrtc_browser_offer_sdp(sessionId, labelText),
                                                      "",
                                                      0,
                                                      "",
                                                      false)
    let answerWire = cheng_webrtc_signal_build_message(2,
                                                       sessionId,
                                                       cheng_webrtc_browser_answer_sdp(sessionId, labelText),
                                                       "",
                                                       0,
                                                       "",
                                                       false)
    let clientCandidateWire = cheng_webrtc_signal_build_message(3,
                                                                sessionId,
                                                                "",
                                                                "0",
                                                                0,
                                                                cheng_webrtc_browser_candidate_text(relayOnly,
                                                                                                   "client"),
                                                                false)
    let serverCandidateWire = cheng_webrtc_signal_build_message(3,
                                                                sessionId,
                                                                "",
                                                                "0",
                                                                0,
                                                                cheng_webrtc_browser_candidate_text(relayOnly,
                                                                                                   "server"),
                                                                false)
    let totalLen = 24 +
                   cheng_str_len(policyText) +
                   cheng_str_len(offerWire) +
                   cheng_str_len(answerWire) +
                   cheng_str_len(clientCandidateWire) +
                   cheng_str_len(serverCandidateWire)
    signalResponseWire = cheng_binary_str_alloc(totalLen)
    let raw = cheng_str_data(signalResponseWire)
    if raw == nil && totalLen > 0:
        cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: alloc failed")
        signalResponseWire = cheng_str_empty()
        return false
    var offset = 0
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(5))
    offset = offset + 4
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(cheng_str_len(policyText)))
    offset = offset + 4
    cheng_bytes_copy(cheng_ptr_plus(raw, offset), cheng_str_data(policyText), cheng_str_len(policyText))
    offset = offset + cheng_str_len(policyText)
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(cheng_str_len(offerWire)))
    offset = offset + 4
    cheng_bytes_copy(cheng_ptr_plus(raw, offset), cheng_str_data(offerWire), cheng_str_len(offerWire))
    offset = offset + cheng_str_len(offerWire)
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(cheng_str_len(answerWire)))
    offset = offset + 4
    cheng_bytes_copy(cheng_ptr_plus(raw, offset), cheng_str_data(answerWire), cheng_str_len(answerWire))
    offset = offset + cheng_str_len(answerWire)
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(cheng_str_len(clientCandidateWire)))
    offset = offset + 4
    cheng_bytes_copy(cheng_ptr_plus(raw, offset),
                     cheng_str_data(clientCandidateWire),
                     cheng_str_len(clientCandidateWire))
    offset = offset + cheng_str_len(clientCandidateWire)
    cheng_write_u32be(cheng_ptr_plus(raw, offset), uint32(cheng_str_len(serverCandidateWire)))
    offset = offset + 4
    cheng_bytes_copy(cheng_ptr_plus(raw, offset),
                     cheng_str_data(serverCandidateWire),
                     cheng_str_len(serverCandidateWire))
    offset = offset + cheng_str_len(serverCandidateWire)
    if offset != totalLen:
        cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: transcript size mismatch")
        signalResponseWire = cheng_str_empty()
        return false
    var transcriptSessionId = cheng_fixed32_zero()
    var transcriptRelayOnly = false
    if !cheng_webrtc_signal_validate_transcript(signalResponseWire,
                                                transcriptSessionId,
                                                transcriptRelayOnly,
                                                errWire):
        signalResponseWire = cheng_str_empty()
        return false
    sessionId = transcriptSessionId
    relayOnly = transcriptRelayOnly
    return true

fn cheng_webrtc_browser_copy_response(responseWire: str,
                                      clientResponseWire: var str,
                                      errWire: var str): int32 =
    clientResponseWire = cheng_str_copy(cheng_str_data(responseWire), cheng_str_len(responseWire))
    errWire = cheng_str_empty()
    return 1

