    var errWire = cheng_str_empty()
    let handle = cheng_v3_webrtc_browser_session_open_bridge_export(policyText,
                                                                    labelText,
                                                                    signalResponseWire,
                                                                    errWire)
    if handle == uint64(0):
        if cheng_str_len(errWire) == 0:
            var openErr = v3WebrtcErrBrowserSessionOpenFailed
            cheng_webrtc_last_error_set(openErr)
        else:
