fn cheng_relay_provider_probe_payload(runtime: ChengV3RelayProviderRuntimePtr): str =
    if runtime == nil:
        return cheng_str_empty()
    let healthyText = runtime->healthy != 0 ? "1" : "0"
    var errorText = cheng_str_copy_cstring(runtime->lastError)
    let out = "ok=1\n" +
              "healthy=" + healthyText + "\n" +
              "successPermille=1000\n" +
              "loadPermille=0\n" +
              "capacityPermille=1000\n" +
              "error=" + errorText + "\n"
    cheng_str_dispose(errorText)
    return out

fn cheng_relay_provider_issue_lease_payload(runtime: ChengV3RelayProviderRuntimePtr,
                                            requesterPeerIdText: str,
                                            requestedRegionText: str,
                                            nonceHex: str): str =
    if runtime == nil:
        return cheng_str_empty()
    if runtime->healthy == 0:
        var errorText = cheng_str_copy_cstring(runtime->lastError)
        var out = "ok=0\nerror="
        out = out + errorText
        out = out + "\n"
        cheng_str_dispose(errorText)
        return out
    if runtime->requiresLease != 0 && cheng_str_len(requesterPeerIdText) <= 0:
        return "ok=0\nerror=relay provider: requester missing\n"
    var endpointText = cheng_str_copy_cstring(runtime->endpoint)
    var regionText = cheng_str_copy_cstring(runtime->region)
    if cheng_str_len(requestedRegionText) > 0:
        cheng_str_dispose(regionText)
        regionText = cheng_str_dup(requestedRegionText)
    var usernameText = cheng_str_empty()
    var credentialText = cheng_str_empty()
    if runtime->requiresLease != 0:
        var serviceText = cheng_str_copy_cstring(runtime->serviceKind)
        var scopeText = cheng_str_copy_cstring(runtime->authScope)
        usernameText = serviceText
        usernameText = usernameText + ":"
        usernameText = usernameText + requesterPeerIdText
        usernameText = usernameText + ":"
        usernameText = usernameText + nonceHex
        credentialText = "scope="
        credentialText = credentialText + scopeText
        credentialText = credentialText + "|peer="
        credentialText = credentialText + requesterPeerIdText
        credentialText = credentialText + "|nonce="
        credentialText = credentialText + nonceHex
        cheng_str_dispose(serviceText)
        cheng_str_dispose(scopeText)
    var out = "ok=1\n"
    out = out + "region="
    out = out + regionText
    out = out + "\n"
    out = out + "endpoint="
    out = out + endpointText
    out = out + "\n"
    out = out + "username="
    out = out + usernameText
    out = out + "\n"
    out = out + "credential="
    out = out + credentialText
    out = out + "\n"
    out = out + "error=\n"
    cheng_str_dispose(endpointText)
    cheng_str_dispose(regionText)
    cheng_str_dispose(usernameText)
    cheng_str_dispose(credentialText)
    return out

fn cheng_errno_code(): int32 =
    return native_cheng_v3_errno_code_runtime()

fn cheng_error_with_errno(prefix: ptr): str =
    let reason = libc_strerror(cheng_errno_code())
    let prefixText = cheng_str_copy_cstring(prefix)
    if reason == nil || cheng_cstrlen_raw(reason) <= 0:
        return prefixText
    return prefixText + ": " + cheng_str_copy_cstring(reason)

fn cheng_sockaddr_ipv4_make(port: int32, inaddr: int32): ptr =
    let addr = cheng_malloc_export(chengSockaddrInLen)
    if addr == nil:
        return nil
    cheng_bytes_set(addr, 0, chengSockaddrInLen)
    let family = cheng_af_inet()
    if cheng_sockaddr_use_len_field():
        *(UInt8Ptr(cheng_ptr_plus(addr, 0))) = uint8(chengSockaddrInLen)
        *(UInt8Ptr(cheng_ptr_plus(addr, 1))) = uint8(family & 255)
    else:
        *(UInt8Ptr(cheng_ptr_plus(addr, 0))) = uint8(family & 255)
        *(UInt8Ptr(cheng_ptr_plus(addr, 1))) = uint8((family >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 2))) = uint8((port >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 3))) = uint8(port & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 4))) = uint8((inaddr >> 24) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 5))) = uint8((inaddr >> 16) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 6))) = uint8((inaddr >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 7))) = uint8(inaddr & 255)
    return addr

fn cheng_sockaddr_loopback(port: int32): ptr =
    return cheng_sockaddr_ipv4_make(port, chengInaddrLoopback)

fn cheng_sockaddr_ipv6_make(port: int32, inaddr: ptr): ptr =
    let addr = cheng_malloc_export(chengSockaddrIn6Len)
    if addr == nil:
        return nil
    cheng_bytes_set(addr, 0, chengSockaddrIn6Len)
    let family = cheng_af_inet6()
    if cheng_sockaddr_use_len_field():
        *(UInt8Ptr(cheng_ptr_plus(addr, 0))) = uint8(chengSockaddrIn6Len)
        *(UInt8Ptr(cheng_ptr_plus(addr, 1))) = uint8(family & 255)
    else:
        *(UInt8Ptr(cheng_ptr_plus(addr, 0))) = uint8(family & 255)
        *(UInt8Ptr(cheng_ptr_plus(addr, 1))) = uint8((family >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 2))) = uint8((port >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 3))) = uint8(port & 255)
    if inaddr != nil:
        cheng_bytes_copy(cheng_ptr_plus(addr, 8), inaddr, 16)
    return addr

fn cheng_sockaddr_loopback_v6(port: int32): ptr =
    let octets = cheng_malloc_export(16)
    if octets == nil:
        return nil
    cheng_bytes_set(octets, 0, 16)
    *(UInt8Ptr(cheng_ptr_plus(octets, 15))) = uint8(1)
    let addr = cheng_sockaddr_ipv6_make(port, octets)
    cheng_free_export(octets)
    return addr

fn cheng_parse_ipv4_addr(text: str, outAddr: ptr): bool =
    if outAddr == nil:
        return false
    let data = cheng_str_data(text)
    let n = cheng_str_len(text)
    if data == nil || n <= 0:
        return false
    var partIndex: int32 = 0
    var value: int32 = 0
    var sawDigit = false
    cheng_bytes_set(outAddr, 0, 4)
    for i in 0..<n:
        let ch = int32(*(UInt8Ptr(cheng_ptr_plus(data, i))))
        if ch >= int32('0') && ch <= int32('9'):
            sawDigit = true
            value = value * 10 + (ch - int32('0'))
            if value > 255:
                return false
        elif ch == int32('.'):
            if !sawDigit || partIndex >= 3:
                return false
            *(UInt8Ptr(cheng_ptr_plus(outAddr, partIndex))) = uint8(value)
            partIndex = partIndex + 1
            value = 0
            sawDigit = false
        else:
            return false
    if !sawDigit || partIndex != 3:
        return false
    *(UInt8Ptr(cheng_ptr_plus(outAddr, partIndex))) = uint8(value)
    return true

fn cheng_sockaddr_ipv4_parse(hostText: str, port: int32): ptr =
    let octets = cheng_malloc_export(4)
    if octets == nil:
        return nil
    if !cheng_parse_ipv4_addr(hostText, octets):
        cheng_free_export(octets)
        return nil
    let inaddr = (int32(*(UInt8Ptr(cheng_ptr_plus(octets, 0)))) << 24) |
                 (int32(*(UInt8Ptr(cheng_ptr_plus(octets, 1)))) << 16) |
                 (int32(*(UInt8Ptr(cheng_ptr_plus(octets, 2)))) << 8) |
                 int32(*(UInt8Ptr(cheng_ptr_plus(octets, 3))))
    cheng_free_export(octets)
    return cheng_sockaddr_ipv4_make(port, inaddr)

fn cheng_sockaddr_port(addr: ptr): int32 =
    if addr == nil:
        return 0
    return (int32(*(UInt8Ptr(cheng_ptr_plus(addr, 2)))) << 8) |
           int32(*(UInt8Ptr(cheng_ptr_plus(addr, 3))))

type
    ChengUdpBindResult =
        rc: int32
        fd: int32
        port: int32
        family: int32
        useLenField: int32

fn cheng_udp_bind_host_port_impl(hostText: str, port: int32, isV6: bool): ChengUdpBindResult =
    var out: ChengUdpBindResult
    out.rc = 0
    out.fd = -1
    out.port = 0
    out.family = 0
    out.useLenField = 0
    if port < 0 || port > 65535:
        out.rc = 22
        return out

    let family: int32 = if isV6: cheng_af_inet6() else: cheng_af_inet()
    let fd: int32 = libc_socket(family, cheng_sock_dgram(), 0)
    if fd < 0:
        out.rc = cheng_errno_code()
        return out

    out.useLenField = cheng_sockaddr_use_len_field() ? 1 : 0
    var bindAddr: ptr = nil
    if isV6:
        if cheng_str_len(hostText) <= 0 || cheng_str_equals_cstring(hostText, "localhost"):
            bindAddr = cheng_sockaddr_loopback_v6(port)
        else:
            let hostRaw = cheng_copy_cstring_from_str(hostText)
            let octets = cheng_malloc_export(16)
            if hostRaw == nil || octets == nil:
                if hostRaw != nil:
                    cheng_free_export(hostRaw)
                if octets != nil:
                    cheng_free_export(octets)
                libc_close(fd)
                out.rc = 12
                return out
            cheng_bytes_set(octets, 0, 16)
            if libc_inet_pton_native(cheng_af_inet6(), hostRaw, octets) == 1:
                bindAddr = cheng_sockaddr_ipv6_make(port, octets)
            cheng_free_export(hostRaw)
            cheng_free_export(octets)
            if bindAddr == nil:
                libc_close(fd)
                out.rc = 22
                return out
        if bindAddr == nil:
            libc_close(fd)
            out.rc = 12
            return out
        if libc_bind(fd, bindAddr, chengSockaddrIn6Len) != 0:
            out.rc = cheng_errno_code()
            cheng_free_export(bindAddr)
            libc_close(fd)
            return out
        if port == 0:
            var rawLen: int32 = chengSockaddrIn6Len
            if libc_getsockname(fd, bindAddr, &rawLen) != 0:
                out.rc = cheng_errno_code()
                cheng_free_export(bindAddr)
                libc_close(fd)
                return out
        out.fd = fd
        out.port = cheng_sockaddr_port(bindAddr)
        out.family = cheng_af_inet6()
        cheng_free_export(bindAddr)
        return out
    if cheng_str_len(hostText) <= 0 || cheng_str_equals_cstring(hostText, "localhost"):
        bindAddr = cheng_sockaddr_loopback(port)
    else:
        bindAddr = cheng_sockaddr_ipv4_parse(hostText, port)
    if bindAddr == nil:
        libc_close(fd)
        out.rc = 22
        return out
    if libc_bind(fd, bindAddr, chengSockaddrInLen) != 0:
        out.rc = cheng_errno_code()
        cheng_free_export(bindAddr)
        libc_close(fd)
        return out
    if port == 0:
        var rawLen: int32 = chengSockaddrInLen
        if libc_getsockname(fd, bindAddr, &rawLen) != 0:
            out.rc = cheng_errno_code()
            cheng_free_export(bindAddr)
            libc_close(fd)
            return out
    out.fd = fd
    out.port = cheng_sockaddr_port(bindAddr)
    out.family = cheng_af_inet()
    cheng_free_export(bindAddr)
    return out

