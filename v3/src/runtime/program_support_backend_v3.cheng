@exportc("cheng_v3_webrtc_datachannel_request_response_bridge")
fn cheng_v3_webrtc_datachannel_request_response_bridge_export(protocolText: str,
                                                              signalWire: str,
                                                              requestWire: str,
                                                              responseWire: str,
                                                              clientResponseWire: var str,
                                                              errWire: var str): int32 =
    clientResponseWire = cheng_str_empty()
    errWire = cheng_str_empty()
    requestWire
    if cheng_str_len(protocolText) == 0:
        return cheng_webrtc_error(errWire, "v3 libp2p webrtc: missing protocol selection")
    var sessionId = cheng_fixed32_zero()
    var relayOnly = false
    if !cheng_webrtc_signal_validate_transcript(signalWire, sessionId, relayOnly, errWire):
        return 0
    return cheng_webrtc_browser_copy_response(responseWire, clientResponseWire, errWire)

@exportc("cheng_v3_webrtc_browser_request_response_bridge")
fn cheng_v3_webrtc_browser_request_response_bridge_export(protocolText: str,
                                                          policyWire: str,
                                                          labelText: str,
                                                          requestWire: str,
                                                          responseWire: str,
                                                          signalResponseWire: var str,
                                                          clientResponseWire: var str,
                                                          errWire: var str): int32 =
    signalResponseWire = cheng_str_empty()
    clientResponseWire = cheng_str_empty()
    errWire = cheng_str_empty()
    if cheng_str_len(protocolText) == 0:
        return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: missing protocol selection")
    requestWire
    var handleErr = ""
    var handleSignal = ""
    let handle = cheng_v3_webrtc_browser_session_open_bridge_export(policyWire,
                                                                    labelText,
                                                                    handleSignal,
                                                                    handleErr)
    if handle == uint64(0):
        if cheng_str_len(handleErr) == 0:
            return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: session open failed")
        errWire = handleErr
        return 0
    signalResponseWire = handleSignal
    let ok = cheng_v3_webrtc_browser_session_exchange_bridge_export(handle,
                                                                    protocolText,
                                                                    requestWire,
                                                                    responseWire,
                                                                    clientResponseWire,
                                                                    errWire)
    var closeErr = ""
    let closeOk = cheng_v3_webrtc_browser_session_close_bridge_export(handle, closeErr)
    if ok == 0:
        return 0
    if closeOk == 0:
        if cheng_str_len(closeErr) == 0:
            return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: session close failed")
        errWire = closeErr
        return 0
    errWire = cheng_str_empty()
    return 1

@exportc("cheng_v3_webrtc_browser_session_open_bridge")
fn cheng_v3_webrtc_browser_session_open_bridge_export(policyText: str,
                                                      labelText: str,
                                                      signalResponseWire: var str,
                                                      errWire: var str): uint64 =
    signalResponseWire = cheng_str_empty()
    errWire = cheng_str_empty()
    var sessionId = cheng_fixed32_zero()
    var relayOnly = false
    if !cheng_webrtc_browser_signal_transcript(policyText,
                                               labelText,
                                               signalResponseWire,
                                               sessionId,
                                               relayOnly,
                                               errWire):
        return uint64(0)
    let runtime = cheng_webrtc_browser_session_runtime_new(sessionId, relayOnly)
    if runtime == nil:
        cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: alloc failed")
        signalResponseWire = cheng_str_empty()
        return uint64(0)
    let handle = cheng_ffi_handle_register_ptr_export(ptr(runtime))
    if handle == uint64(0):
        cheng_webrtc_browser_session_runtime_dispose(runtime)
        cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: handle register failed")
        signalResponseWire = cheng_str_empty()
        return uint64(0)
    cheng_webrtc_browser_session_active_count = cheng_webrtc_browser_session_active_count + 1
    return handle

@exportc("cheng_v3_webrtc_browser_session_exchange_bridge")
fn cheng_v3_webrtc_browser_session_exchange_bridge_export(handle: uint64,
                                                          protocolText: str,
                                                          requestWire: str,
                                                          responseWire: str,
                                                          clientResponseWire: var str,
                                                          errWire: var str): int32 =
    clientResponseWire = cheng_str_empty()
    errWire = cheng_str_empty()
    requestWire
    if cheng_str_len(protocolText) == 0:
        return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: missing protocol selection")
    let runtimeRaw = cheng_ffi_handle_resolve_ptr_export(handle)
    if runtimeRaw == nil:
        return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: invalid session handle")
    let runtime = ChengV3WebrtcBrowserSessionStatePtr(runtimeRaw)
    if !runtime->active:
        return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: session inactive")
    return cheng_webrtc_browser_copy_response(responseWire, clientResponseWire, errWire)

@exportc("cheng_v3_webrtc_browser_session_close_bridge")
fn cheng_v3_webrtc_browser_session_close_bridge_export(handle: uint64, errWire: var str): int32 =
    errWire = cheng_str_empty()
    let runtimeRaw = cheng_ffi_handle_resolve_ptr_export(handle)
    if runtimeRaw == nil:
        return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: invalid session handle")
    let runtime = ChengV3WebrtcBrowserSessionStatePtr(runtimeRaw)
    runtime->active = false
    if cheng_ffi_handle_invalidate_export(handle) != 0:
        runtime->active = true
        return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: handle invalidate failed")
    cheng_webrtc_browser_session_runtime_dispose(runtime)
    if cheng_webrtc_browser_session_active_count > 0:
        cheng_webrtc_browser_session_active_count = cheng_webrtc_browser_session_active_count - 1
    return 1

@exportc("cheng_v3_webrtc_browser_session_active_count_bridge")
fn cheng_v3_webrtc_browser_session_active_count_bridge_export(): int32 =
    return cheng_webrtc_browser_session_active_count
