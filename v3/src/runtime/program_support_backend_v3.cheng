@exportc("cheng_bounds_check")
fn cheng_bounds_check_export(len: int32, idx: int32) =
    if idx < 0 || idx >= len:
        c_puts_runtime("cheng: bounds check failed")
        c_exit_runtime(1)

@exportc("cheng_seq_get")
fn cheng_seq_get_export(buffer: ptr, len: int32, idx: int32, elemSize: int32): ptr =
    cheng_bounds_check_export(len, idx)
    if buffer == nil || elemSize <= 0:
        return buffer
    return cheng_ptr_plus(buffer, idx * elemSize)

@exportc("cheng_seq_set")
fn cheng_seq_set_export(buffer: ptr, len: int32, idx: int32, elemSize: int32): ptr =
    return cheng_seq_get_export(buffer, len, idx, elemSize)

@exportc("cheng_seq_set_grow")
fn cheng_seq_set_grow_export(seqPtr: ptr, idx: int32, elemSize: int32): ptr =
    if seqPtr == nil || elemSize <= 0:
        return nil
    let seqHdr: ChengSeqHeaderPtr = ChengSeqHeaderPtr(seqPtr)
    if idx < 0:
        return cheng_seq_get_export(seqHdr->buffer, seqHdr->len, idx, elemSize)
    let needLen: int32 = idx + 1
    if needLen > seqHdr->cap || seqHdr->buffer == nil:
        var newCap: int32 = seqHdr->cap
        if newCap < 4:
            newCap = 4
        while newCap < needLen:
            let doubled: int32 = newCap * 2
            if doubled <= 0:
                newCap = needLen
                break
            newCap = doubled
        let oldCap: int32 = seqHdr->cap
        let bytes: int32 = newCap * elemSize
        let newBuf: ptr = cheng_realloc_export(seqHdr->buffer, bytes)
        if newBuf == nil:
            return nil
        if newCap > oldCap:
            cheng_bytes_set(cheng_ptr_plus(newBuf, oldCap * elemSize), 0, (newCap - oldCap) * elemSize)
        seqHdr->buffer = newBuf
        seqHdr->cap = newCap
    if needLen > seqHdr->len:
        seqHdr->len = needLen
    return cheng_seq_get_export(seqHdr->buffer, seqHdr->len, idx, elemSize)

