    if rightLen <= 0:
        return cheng_str_copy(leftData, leftLen)
    let leftLast: uint8 = *(UInt8Ptr(cheng_ptr_plus(leftData, leftLen - 1)))
    let rightFirst: uint8 = *(UInt8Ptr(rightData))
    let needSep: bool = leftLast != uint8(int32('/')) &&
                        leftLast != uint8(int32('\\')) &&
                        rightFirst != uint8(int32('/')) &&
                        rightFirst != uint8(int32('\\'))
    let total: int32 = leftLen + rightLen + (needSep ? 1 : 0)
    let out: ptr = driver_c_new_string_export(total)
    if out == nil:
        return cheng_str_empty()
    cheng_bytes_copy(out, leftData, leftLen)
    if needSep:
        *(UInt8Ptr(cheng_ptr_plus(out, leftLen))) = uint8(int32('/'))
    cheng_bytes_copy(cheng_ptr_plus(out, leftLen + (needSep ? 1 : 0)), rightData, rightLen)
    return cheng_str_view_owned(out, total)

