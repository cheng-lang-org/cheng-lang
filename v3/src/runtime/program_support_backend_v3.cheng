    cheng_saved_argv: ptr

fn cheng_mem_header(p: ptr): ChengMemHeaderPtr =
    if p == nil:
        return nil
    return ChengMemHeaderPtr(ptr(uint64(p) - uint64(sizeof ChengMemHeader)))

fn cheng_ptr_plus(base: ptr, off: int32): ptr =
    if base == nil:
        return nil
    return ptr(uint64(int64(uint64(base)) + int64(off)))

fn cheng_payload_ptr(raw: ptr): ptr =
    if raw == nil:
        return nil
    return cheng_ptr_plus(raw, int32(sizeof ChengMemHeader))

fn cheng_str_empty(): str =
    var out: str
    out.data = nil
    out.len = 0
    out.store_id = 0
    out.flags = 0
    return out

fn cheng_str_view_owned(data: ptr, len0: int32): str =
    var out: str
    let len: int32 = len0 < 0 ? 0 : len0
    if data == nil || len <= 0:
        return out
    out.data = data
    out.len = len
    out.store_id = 0
    out.flags = chengStrFlagOwned
    return out

fn cheng_probably_valid_str_bridge(s: str): bool =
    if s.len < 0 || s.len > 268435456:
        return false
    if s.flags != 0 && s.flags != chengStrFlagOwned:
        return false
    if s.data == nil:
        return s.len == 0
    return uint64(s.data) >= uint64(65536)

fn cheng_fallback_string_ptr(s: str): ptr =
    if s.data == nil:
        return nil
    if uint64(s.data) < uint64(65536):
        return nil
    return s.data

fn cheng_str_len(s: str): int32 =
    if cheng_probably_valid_str_bridge(s):
        if s.data == nil || s.len <= 0:
            return 0
        return s.len
    let compat: ptr = cheng_fallback_string_ptr(s)
    if compat == nil:
        return 0
    return cheng_cstrlen_raw(compat)

fn cheng_str_data(s: str): ptr =
    if cheng_probably_valid_str_bridge(s):
        if s.data == nil || s.len <= 0:
            return nil
        return s.data
    return cheng_fallback_string_ptr(s)

fn cheng_bytes_copy(dst: ptr, src: ptr, n0: int32) =
    if dst == nil || src == nil || n0 <= 0:
        return
    for i in 0..<n0:
        *(UInt8Ptr(cheng_ptr_plus(dst, i))) = *(UInt8Ptr(cheng_ptr_plus(src, i)))

fn cheng_bytes_set(dst: ptr, value: int32, n0: int32) =
    if dst == nil || n0 <= 0:
        return
    let byteValue: uint8 = uint8(value & 255)
    for i in 0..<n0:
        *(UInt8Ptr(cheng_ptr_plus(dst, i))) = byteValue

fn cheng_bytes_compare(a: ptr, b: ptr, n0: int32): int32 =
    if n0 <= 0:
        return 0
    if a == b:
        return 0
    if a == nil:
        return -1
    if b == nil:
        return 1
    for i in 0..<n0:
        let av: uint8 = *(UInt8Ptr(cheng_ptr_plus(a, i)))
        let bv: uint8 = *(UInt8Ptr(cheng_ptr_plus(b, i)))
        if av < bv:
            return -1
        if av > bv:
            return 1
    return 0

fn cheng_bytes_equal(a: ptr, b: ptr, n0: int32): bool =
    return cheng_bytes_compare(a, b, n0) == 0

fn cheng_cstrlen_raw(s: ptr): int32 =
    if s == nil:
        return 0
    var n: int32 = 0
    while *(UInt8Ptr(cheng_ptr_plus(s, n))) != uint8(0):
        n = n + 1
    return n

fn cheng_string_copy(raw: ptr, n0: int32): ptr =
    var n: int32 = n0
    if n < 0:
        n = 0
    let out: ptr = cheng_malloc_export(n + 1)
    if out == nil:
        return nil
    cheng_bytes_set(out, 0, n + 1)
    if raw != nil && n > 0:
        cheng_bytes_copy(out, raw, n)
    return out

fn cheng_str_copy(raw: ptr, n: int32): str =
    let outRaw: ptr = cheng_string_copy(raw, n)
    if outRaw == nil:
        return cheng_str_empty()
    return cheng_str_view_owned(outRaw, n)

fn cheng_fopen_write(path: ptr): ptr =
    if path == nil:
        return nil
    let mode = cheng_string_copy("wb", 2)
    if mode == nil:
        return nil
    let fp = libc_fopen(path, mode)
    cheng_free_export(mode)
    return fp

fn cheng_u64_to_string(value0: uint64): ptr =
    let scratch: ptr = cheng_malloc_export(64)
    if scratch == nil:
        return nil
    cheng_bytes_set(scratch, 0, 64)
    var value: uint64 = value0
    var idx: int32 = 63
    if value == uint64(0):
        idx = idx - 1
        *(UInt8Ptr(cheng_ptr_plus(scratch, idx))) = uint8(int32('0'))
    else:
        while value > uint64(0) && idx > 0:
            idx = idx - 1
            *(UInt8Ptr(cheng_ptr_plus(scratch, idx))) = uint8(int32('0') + int32(value % uint64(10)))
            value = value / uint64(10)
    let outLen: int32 = 63 - idx
    let out: ptr = cheng_string_copy(cheng_ptr_plus(scratch, idx), outLen)
    cheng_free_export(scratch)
    return out

fn probe_slot_at(idx: int32): ChengFfiHandleSlotPtr =
    return ChengFfiHandleSlotPtr(cheng_ptr_plus(ptr(probe_slots), idx * int32(sizeof ChengFfiHandleSlot)))

fn probe_ensure_capacity(minCap: int32): bool =
    if minCap <= probe_slots_cap:
        return true
    var newCap: int32 = probe_slots_cap
    if newCap < 16:
        newCap = 16
    while newCap < minCap:
        if newCap > 1073741823:
            return false
        newCap = newCap * 2
    let bytes: int64 = int64(newCap) * int64(sizeof ChengFfiHandleSlot)
    let mem: ptr = c_realloc(ptr(probe_slots), bytes)
    if mem == nil:
        return false
    probe_slots = ChengFfiHandleSlotPtr(mem)
    for i in probe_slots_cap..<newCap:
        let slot: ChengFfiHandleSlotPtr = probe_slot_at(i)
        slot->ptr = nil
        slot->generation = uint32(1)
    probe_slots_cap = newCap
    return true

@exportc("cheng_malloc")
fn cheng_malloc_export(size0: int32): ptr =
    var size: int32 = size0
    if size <= 0:
        size = 1
    let total: int64 = int64(sizeof ChengMemHeader) + int64(size)
    let raw: ptr = c_malloc(total)
    if raw == nil:
        return nil
    let header: ChengMemHeaderPtr = ChengMemHeaderPtr(raw)
    header->rc = 1
    header->size = size
    let payload: ptr = cheng_payload_ptr(raw)
    cheng_bytes_set(payload, 0, size)
    return payload

@exportc("cheng_free")
fn cheng_free_export(p: ptr) =
    let header: ChengMemHeaderPtr = cheng_mem_header(p)
    if header == nil:
        return
    c_free(ptr(header))

@exportc("cheng_realloc")
fn cheng_realloc_export(p: ptr, size0: int32): ptr =
    if p == nil:
        return cheng_malloc_export(size0)
    var size: int32 = size0
    if size <= 0:
        size = 1
    let header: ChengMemHeaderPtr = cheng_mem_header(p)
    if header == nil:
        return nil
    if header->rc > 1:
        let fresh: ptr = cheng_malloc_export(size)
        if fresh == nil:
            return nil
        var copyBytes: int32 = header->size
        if copyBytes > size:
            copyBytes = size
        if copyBytes > 0:
            cheng_bytes_copy(fresh, p, copyBytes)
        header->rc = header->rc - 1
        return fresh
    let total: int64 = int64(sizeof ChengMemHeader) + int64(size)
    let raw: ptr = c_realloc(ptr(header), total)
    if raw == nil:
        return nil
    let nextHeader: ChengMemHeaderPtr = ChengMemHeaderPtr(raw)
    if size > nextHeader->size:
        let payload: ptr = cheng_payload_ptr(raw)
        cheng_bytes_set(cheng_ptr_plus(payload, nextHeader->size), 0, size - nextHeader->size)
    nextHeader->size = size
    return cheng_payload_ptr(raw)

@exportc("cheng_mem_retain")
fn cheng_mem_retain_export(p: ptr) =
    let header: ChengMemHeaderPtr = cheng_mem_header(p)
    if header == nil:
        return
    header->rc = header->rc + 1

@exportc("cheng_mem_release")
fn cheng_mem_release_export(p: ptr) =
    let header: ChengMemHeaderPtr = cheng_mem_header(p)
    if header == nil:
        return
    if header->rc > 0:
        header->rc = header->rc - 1
    if header->rc <= 0:
        c_free(ptr(header))

@exportc("cheng_mem_scope_escape")
fn cheng_mem_scope_escape_export(p: ptr) =
    return

@exportc("cheng_mem_scope_escape_global")
fn cheng_mem_scope_escape_global_export(p: ptr) =
    return

@exportc("cheng_mem_refcount")
fn cheng_mem_refcount_export(p: ptr): int32 =
    let header: ChengMemHeaderPtr = cheng_mem_header(p)
    if header == nil:
        return 0
    return header->rc

@exportc("cheng_mem_retain_atomic")
fn cheng_mem_retain_atomic_export(p: ptr) =
