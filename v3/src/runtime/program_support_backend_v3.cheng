fn cheng_str_slice_copy(text: str, start0: int32, count0: int32): str =
    let textLen = cheng_str_len(text)
    let textData = cheng_str_data(text)
    var start = start0
    var count = count0
    if textData == nil || textLen <= 0:
        return cheng_str_empty()
    if start < 0:
        start = 0
    if start >= textLen || count <= 0:
        return cheng_str_empty()
    if start + count > textLen:
        count = textLen - start
    return cheng_str_copy(cheng_ptr_plus(textData, start), count)

fn cheng_read_text_file(path: str): str =
    let rawPath = cheng_copy_cstring_from_str(path)
    if rawPath == nil:
        return cheng_str_empty()
    let fp = cheng_fopen_read(rawPath)
    cheng_free_export(rawPath)
    if fp == nil:
        return cheng_str_empty()
    if libc_fseek(fp, int64(0), chengSeekEnd) != 0:
        libc_fclose(fp)
        return cheng_str_empty()
    let size64 = libc_ftell(fp)
    if size64 < int64(0) || size64 > int64(2147483647):
        libc_fclose(fp)
        return cheng_str_empty()
    if libc_fseek(fp, int64(0), chengSeekSet) != 0:
        libc_fclose(fp)
        return cheng_str_empty()
    let size = int32(size64)
    let out = driver_c_new_string_export(size)
    if out == nil:
        libc_fclose(fp)
        return cheng_str_empty()
    if size > 0 && libc_fread(out, int64(1), size64, fp) != size64:
        libc_fclose(fp)
        cheng_free_export(out)
        return cheng_str_empty()
    libc_fclose(fp)
    return cheng_str_view_owned(out, size)

fn cheng_tailnet_load_endpoint_payload(endpoint: str): str =
    var clean = cheng_v3_str_strip_bridge_export(endpoint)
    if cheng_str_len(clean) <= 0:
        return cheng_str_empty()
    var payload = cheng_str_empty()
    if cheng_str_has_prefix_cstring(clean, "file://"):
        var path = cheng_str_slice_copy(clean, 7, cheng_str_len(clean) - 7)
        payload = cheng_read_text_file(path)
        cheng_str_dispose(path)
    elif cheng_str_has_prefix_cstring(clean, "http://") ||
         cheng_str_has_prefix_cstring(clean, "https://"):
        payload = cheng_str_empty()
    else:
        payload = cheng_read_text_file(clean)
    cheng_str_dispose(clean)
    return payload

