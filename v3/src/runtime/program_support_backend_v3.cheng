fn cheng_cstrlen_export(s: ptr): int32 =
    return cheng_cstrlen_raw(s)

@exportc("cheng_strcmp")
fn cheng_strcmp_export(a: ptr, b: ptr): int32 =
    var i: int32 = 0
    while true:
        let av: uint8 = a == nil ? uint8(0) : *(UInt8Ptr(cheng_ptr_plus(a, i)))
        let bv: uint8 = b == nil ? uint8(0) : *(UInt8Ptr(cheng_ptr_plus(b, i)))
        if av < bv:
            return -1
        if av > bv:
            return 1
        if av == uint8(0):
            return 0
        i = i + 1

@exportc("driver_c_new_string")
fn driver_c_new_string_export(size0: int32): ptr =
    var size: int32 = size0
    if size < 0:
        size = 0
    let out: ptr = cheng_malloc_export(size + 1)
    if out == nil:
        return nil
    cheng_bytes_set(out, 0, size + 1)
    return out

@exportc("driver_c_new_string_copy_n")
fn driver_c_new_string_copy_n_export(raw: ptr, n: int32): ptr =
    return cheng_string_copy(raw, n)

@exportc("cheng_str_param_to_cstring_compat")
fn cheng_str_param_to_cstring_compat_export(s: str): ptr =
    if !cheng_probably_valid_str_bridge(s):
        let compat: ptr = cheng_fallback_string_ptr(s)
        return compat == nil ? "" : compat
    let data: ptr = cheng_str_data(s)
    let len: int32 = cheng_str_len(s)
    if data == nil || len <= 0:
        let empty: ptr = driver_c_new_string_export(0)
        return empty == nil ? "" : empty
    if s.flags == chengStrFlagOwned:
        return data
    let out: ptr = cheng_string_copy(data, len)
    if out == nil:
        return ""
    return out

@exportc("cheng_str_to_cstring_temp_bridge")
fn cheng_str_to_cstring_temp_bridge_export(s: str): ptr =
    return cheng_str_param_to_cstring_compat_export(s)

@exportc("driver_c_str_from_utf8_copy_bridge")
fn driver_c_str_from_utf8_copy_bridge_export(raw: ptr, n: int32): str =
    return cheng_str_copy(raw, n)

@exportc("driver_c_str_eq_bridge")
fn driver_c_str_eq_bridge_export(a: str, b: str): int32 =
    let lenA: int32 = cheng_str_len(a)
    let lenB: int32 = cheng_str_len(b)
    if lenA != lenB:
        return 0
    if lenA <= 0:
        return 1
    return cheng_bytes_equal(cheng_str_data(a), cheng_str_data(b), lenA) ? 1 : 0

fn cheng_runtime_param_count(): int32 =
    if cheng_saved_argc > 0 && cheng_saved_argv != nil:
        return cheng_saved_argc
    return 0

fn cheng_runtime_param_raw(i: int32): ptr =
    if i < 0 || i >= cheng_runtime_param_count() || cheng_saved_argv == nil:
        return nil
    let slot = VoidPtrPtr(cheng_ptr_plus(cheng_saved_argv, i * int32(sizeof ptr)))
    return *slot

fn cheng_runtime_param_str(i: int32): str =
    let raw = cheng_runtime_param_raw(i)
    if raw == nil:
        return cheng_str_empty()
    return cheng_str_copy_cstring(raw)

fn cheng_runtime_flag_key_matches(arg: str, key: str): bool =
    return driver_c_str_eq_bridge_export(arg, key) != 0

fn cheng_runtime_flag_inline_value(arg: str, key: str, outValue: var str): bool =
    outValue = cheng_str_empty()
    let keyLen = cheng_str_len(key)
    let argLen = cheng_str_len(arg)
    if keyLen <= 0 || argLen <= keyLen:
        return false
    if cheng_bytes_compare(cheng_str_data(arg), cheng_str_data(key), keyLen) != 0:
        return false
    let sep = *(UInt8Ptr(cheng_ptr_plus(cheng_str_data(arg), keyLen)))
    if sep != uint8(int32(':')) && sep != uint8(int32('=')):
        return false
    outValue = cheng_str_copy(cheng_ptr_plus(cheng_str_data(arg), keyLen + 1), argLen - keyLen - 1)
    return true

fn cheng_runtime_parse_int32(text: str, defaultValue: int32): int32 =
    let n = cheng_str_len(text)
    if n <= 0:
        return defaultValue
    let data = cheng_str_data(text)
    if data == nil:
        return defaultValue
    var sign: int64 = 1
    var i: int32 = 0
    if *(UInt8Ptr(data)) == uint8(int32('+')):
        i = 1
    elif *(UInt8Ptr(data)) == uint8(int32('-')):
        sign = -1
        i = 1
    if i >= n:
        return defaultValue
    var value: int64 = 0
    while i < n:
        let ch = *(UInt8Ptr(cheng_ptr_plus(data, i)))
        if ch < uint8(int32('0')) || ch > uint8(int32('9')):
            return defaultValue
        value = value * int64(10) + int64(int32(ch) - int32('0'))
        i = i + 1
    value = value * sign
    if value < int64(-2147483648) || value > int64(2147483647):
        return defaultValue
    return int32(value)

