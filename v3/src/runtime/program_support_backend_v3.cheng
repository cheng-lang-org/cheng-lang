    var i: int32 = 1
    while i < count:
        let arg = cheng_runtime_param_str(i)
        if cheng_runtime_flag_inline_value(arg, key, outValue):
            return true
        if cheng_runtime_flag_key_matches(arg, key):
            if i + 1 >= count:
                return false
            outValue = cheng_runtime_param_str(i + 1)
            return true
        i = i + 1
    return false

