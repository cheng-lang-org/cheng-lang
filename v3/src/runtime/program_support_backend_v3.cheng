    if ch == uint8(0) || ch == uint8(int32(',')) || ch == uint8(int32('}')):
        return true
    return cheng_ascii_space(ch)

fn cheng_tailnet_json_read_bool(payload: str, key: ptr, outValue: var bool): bool =
    let idx = cheng_tailnet_json_value_after_key(payload, key)
    let data = cheng_str_data(payload)
    let n = cheng_str_len(payload)
    if idx < 0 || data == nil:
        return false
    if idx + 4 <= n &&
       cheng_bytes_equal(cheng_ptr_plus(data, idx), "true", 4) &&
       (idx + 4 >= n || cheng_tailnet_json_bool_term(*(UInt8Ptr(cheng_ptr_plus(data, idx + 4))))):
        outValue = true
        return true
    if idx + 5 <= n &&
       cheng_bytes_equal(cheng_ptr_plus(data, idx), "false", 5) &&
       (idx + 5 >= n || cheng_tailnet_json_bool_term(*(UInt8Ptr(cheng_ptr_plus(data, idx + 5))))):
        outValue = false
        return true
    return false

fn cheng_tailnet_json_read_string(payload: str, key: ptr, outValue: var str): bool =
    outValue = cheng_str_empty()
    let idx = cheng_tailnet_json_value_after_key(payload, key)
    let data = cheng_str_data(payload)
    let n = cheng_str_len(payload)
    if idx < 0 || data == nil || idx >= n:
        return false
    if *(UInt8Ptr(cheng_ptr_plus(data, idx))) != uint8(int32('"')):
        return false
    let outRaw = driver_c_new_string_export(n - idx)
    if outRaw == nil:
        return false
    var used: int32 = 0
    var pos = idx + 1
    while pos < n:
        var ch = *(UInt8Ptr(cheng_ptr_plus(data, pos)))
        pos = pos + 1
        if ch == uint8(int32('"')):
            outValue = cheng_str_view_owned(outRaw, used)
            return true
        if ch == uint8(int32('\\')):
            if pos >= n:
                break
            ch = *(UInt8Ptr(cheng_ptr_plus(data, pos)))
            pos = pos + 1
        *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = ch
        used = used + 1
    cheng_free_export(outRaw)
    return false

fn cheng_tailnet_provider_runtime_new(): ChengV3TailnetProviderRuntimePtr =
    let mem = cheng_malloc_export(int32(sizeof ChengV3TailnetProviderRuntime))
    if mem == nil:
        return nil
    let runtime = ChengV3TailnetProviderRuntimePtr(mem)
    runtime->providerKind = cheng_str_empty()
    runtime->controlEndpoint = cheng_str_empty()
    runtime->relayEndpoint = cheng_str_empty()
    runtime->controlProbeEndpoint = cheng_str_empty()
    runtime->relayProbeEndpoint = cheng_str_empty()
    runtime->derpRegionCode = cheng_str_empty()
    runtime->derpHostname = cheng_str_empty()
    runtime->startupStage = cheng_str_copy_cstring("init")
    runtime->lastError = cheng_str_empty()
    runtime->providerReady = false
    runtime->proxyReady = false
    runtime->listenerNeedsRepair = false
    runtime->derpHealthy = false
    return runtime

fn cheng_tailnet_provider_runtime_dispose(runtime: ChengV3TailnetProviderRuntimePtr) =
    if runtime == nil:
        return
    cheng_str_dispose(runtime->providerKind)
    cheng_str_dispose(runtime->controlEndpoint)
    cheng_str_dispose(runtime->relayEndpoint)
    cheng_str_dispose(runtime->controlProbeEndpoint)
    cheng_str_dispose(runtime->relayProbeEndpoint)
    cheng_str_dispose(runtime->derpRegionCode)
    cheng_str_dispose(runtime->derpHostname)
    cheng_str_dispose(runtime->startupStage)
    cheng_str_dispose(runtime->lastError)
    cheng_free_export(ptr(runtime))

fn cheng_tailnet_provider_set_stage(runtime: ChengV3TailnetProviderRuntimePtr, stage: str) =
    if runtime == nil:
        return
    cheng_str_dispose(runtime->startupStage)
    runtime->startupStage = cheng_str_dup(stage)

fn cheng_tailnet_provider_set_stage_cstring(runtime: ChengV3TailnetProviderRuntimePtr, stage: ptr) =
    if runtime == nil:
        return
    cheng_str_dispose(runtime->startupStage)
    runtime->startupStage = cheng_str_copy_cstring(stage)

fn cheng_tailnet_provider_set_error_cstring(runtime: ChengV3TailnetProviderRuntimePtr, text: ptr) =
    if runtime == nil:
        return
    cheng_str_dispose(runtime->lastError)
    runtime->lastError = cheng_str_copy_cstring(text)

fn cheng_tailnet_provider_is_headscale(runtime: ChengV3TailnetProviderRuntimePtr): bool =
    if runtime == nil:
        return false
    return cheng_str_equals_cstring(runtime->providerKind, "headscale")

fn cheng_tailnet_provider_sync_control(runtime: ChengV3TailnetProviderRuntimePtr): bool =
    if runtime == nil:
        return false
    var payload = cheng_str_empty()
    if cheng_str_len(runtime->controlProbeEndpoint) > 0:
        payload = cheng_tailnet_load_endpoint_payload(runtime->controlProbeEndpoint)
    else:
        payload = cheng_tailnet_load_endpoint_payload(runtime->controlEndpoint)
    if cheng_str_len(payload) <= 0:
        cheng_tailnet_provider_set_error_cstring(runtime, "tailnet provider: control probe load failed")
        return false
    var providerReady = false
    var proxyReady = false
    var listenerNeedsRepair = false
    var startupStage = cheng_str_empty()
    let ok = cheng_tailnet_json_read_bool(payload, "providerReady", providerReady) &&
             cheng_tailnet_json_read_bool(payload, "proxyListenersReady", proxyReady) &&
             cheng_tailnet_json_read_bool(payload, "listenerNeedsRepair", listenerNeedsRepair) &&
             cheng_tailnet_json_read_string(payload, "startupStage", startupStage)
    cheng_str_dispose(payload)
    if !ok:
        cheng_str_dispose(startupStage)
        cheng_tailnet_provider_set_error_cstring(runtime, "tailnet provider: control probe parse failed")
        return false
    runtime->providerReady = providerReady
    runtime->proxyReady = proxyReady
    runtime->listenerNeedsRepair = listenerNeedsRepair
    cheng_tailnet_provider_set_stage(runtime, startupStage)
    cheng_str_dispose(startupStage)
    cheng_tailnet_provider_set_error_cstring(runtime, "")
    return true

fn cheng_tailnet_provider_sync_derp(runtime: ChengV3TailnetProviderRuntimePtr): bool =
    if runtime == nil:
        return false
    var payload = cheng_str_empty()
    if cheng_str_len(runtime->relayProbeEndpoint) > 0:
        payload = cheng_tailnet_load_endpoint_payload(runtime->relayProbeEndpoint)
    else:
        payload = cheng_tailnet_load_endpoint_payload(runtime->relayEndpoint)
    if cheng_str_len(payload) <= 0:
        cheng_tailnet_provider_set_error_cstring(runtime, "tailnet provider: derp probe load failed")
        return false
    var derpHealthy = false
    var startupStage = cheng_str_empty()
    let ok = cheng_tailnet_json_read_bool(payload, "derpHealthy", derpHealthy) &&
             cheng_tailnet_json_read_string(payload, "startupStage", startupStage)
    cheng_str_dispose(payload)
    if !ok:
        cheng_str_dispose(startupStage)
        cheng_tailnet_provider_set_error_cstring(runtime, "tailnet provider: derp probe parse failed")
        return false
    runtime->derpHealthy = derpHealthy
    cheng_tailnet_provider_set_stage(runtime, startupStage)
    cheng_str_dispose(startupStage)
    cheng_tailnet_provider_set_error_cstring(runtime, "")
    return true

fn cheng_errno_code(): int32 =
    let errnoPtr = libc_errno_ptr()
    if errnoPtr == nil:
        return 0
    return *(Int32Ptr(errnoPtr))

fn cheng_error_with_errno(prefix: ptr): str =
    let reason = libc_strerror(cheng_errno_code())
    let prefixText = cheng_str_copy_cstring(prefix)
    if reason == nil || cheng_cstrlen_raw(reason) <= 0:
        return prefixText
    return prefixText + ": " + cheng_str_copy_cstring(reason)

fn cheng_sockaddr_ipv4_make(port: int32, inaddr: int32): ptr =
    let addr = cheng_malloc_export(chengSockaddrInLen)
    if addr == nil:
        return nil
    cheng_bytes_set(addr, 0, chengSockaddrInLen)
    *(UInt8Ptr(addr)) = uint8(chengSockaddrInLen)
    *(UInt8Ptr(cheng_ptr_plus(addr, 1))) = uint8(chengAfInet)
    *(UInt8Ptr(cheng_ptr_plus(addr, 2))) = uint8((port >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 3))) = uint8(port & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 4))) = uint8((inaddr >> 24) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 5))) = uint8((inaddr >> 16) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 6))) = uint8((inaddr >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 7))) = uint8(inaddr & 255)
    return addr

fn cheng_sockaddr_loopback(port: int32): ptr =
    return cheng_sockaddr_ipv4_make(port, chengInaddrLoopback)

fn cheng_parse_ipv4_addr(text: str, outAddr: ptr): bool =
    if outAddr == nil:
        return false
    let data = cheng_str_data(text)
    let n = cheng_str_len(text)
    if data == nil || n <= 0:
        return false
    var partIndex: int32 = 0
    var value: int32 = 0
    var sawDigit = false
    cheng_bytes_set(outAddr, 0, 4)
    for i in 0..<n:
        let ch = int32(*(UInt8Ptr(cheng_ptr_plus(data, i))))
        if ch >= int32('0') && ch <= int32('9'):
            sawDigit = true
            value = value * 10 + (ch - int32('0'))
            if value > 255:
                return false
        elif ch == int32('.'):
            if !sawDigit || partIndex >= 3:
                return false
            *(UInt8Ptr(cheng_ptr_plus(outAddr, partIndex))) = uint8(value)
            partIndex = partIndex + 1
            value = 0
            sawDigit = false
        else:
            return false
    if !sawDigit || partIndex != 3:
        return false
    *(UInt8Ptr(cheng_ptr_plus(outAddr, partIndex))) = uint8(value)
    return true

fn cheng_sockaddr_ipv4_parse(hostText: str, port: int32): ptr =
    let octets = cheng_malloc_export(4)
    if octets == nil:
        return nil
    if !cheng_parse_ipv4_addr(hostText, octets):
        cheng_free_export(octets)
        return nil
    let inaddr = (int32(*(UInt8Ptr(octets))) << 24) |
                 (int32(*(UInt8Ptr(cheng_ptr_plus(octets, 1)))) << 16) |
                 (int32(*(UInt8Ptr(cheng_ptr_plus(octets, 2)))) << 8) |
                 int32(*(UInt8Ptr(cheng_ptr_plus(octets, 3))))
    cheng_free_export(octets)
    return cheng_sockaddr_ipv4_make(port, inaddr)

fn cheng_sockaddr_port(addr: ptr): int32 =
    if addr == nil:
        return 0
    return (int32(*(UInt8Ptr(cheng_ptr_plus(addr, 2)))) << 8) |
           int32(*(UInt8Ptr(cheng_ptr_plus(addr, 3))))

fn cheng_write_u32be(out: ptr, value: uint32) =
    if out == nil:
        return
    *(UInt8Ptr(out)) = uint8((value >> uint32(24)) & uint32(255))
    *(UInt8Ptr(cheng_ptr_plus(out, 1))) = uint8((value >> uint32(16)) & uint32(255))
    *(UInt8Ptr(cheng_ptr_plus(out, 2))) = uint8((value >> uint32(8)) & uint32(255))
    *(UInt8Ptr(cheng_ptr_plus(out, 3))) = uint8(value & uint32(255))

fn cheng_read_u32be(data: ptr): uint32 =
    if data == nil:
        return uint32(0)
    return (uint32(*(UInt8Ptr(data))) << uint32(24)) |
           (uint32(*(UInt8Ptr(cheng_ptr_plus(data, 1)))) << uint32(16)) |
           (uint32(*(UInt8Ptr(cheng_ptr_plus(data, 2)))) << uint32(8)) |
           uint32(*(UInt8Ptr(cheng_ptr_plus(data, 3))))

fn cheng_close_if_open(fd: int32) =
    if fd >= 0:
        libc_close(fd)

fn cheng_send_all(fd: int32, data: ptr, len0: int32): bool =
    if len0 <= 0:
        return true
    if fd < 0 || data == nil:
        return false
    var sent: int32 = 0
    while sent < len0:
        let wrote = libc_send(fd, cheng_ptr_plus(data, sent), len0 - sent, 0)
        if wrote <= 0:
            return false
        sent = sent + wrote
    return true

fn cheng_recv_exact(fd: int32, data: ptr, len0: int32): bool =
    if len0 <= 0:
        return true
    if fd < 0 || data == nil:
        return false
    var received: int32 = 0
    while received < len0:
        let got = libc_recv(fd, cheng_ptr_plus(data, received), len0 - received, chengMsgWaitAll)
        if got <= 0:
            return false
        received = received + got
    return true

fn cheng_write_text_file(pathText: str, content: str): bool =
    let path = cheng_copy_cstring_from_str(pathText)
    if path == nil:
        return false
    let fp = cheng_fopen_write(path)
    cheng_free_export(path)
    if fp == nil:
        return false
    let wrote = libc_fwrite(cheng_str_data(content), 1, cheng_str_len(content), fp)
    let closeRc = libc_fclose(fp)
    return wrote == int64(cheng_str_len(content)) && closeRc == 0

fn cheng_write_ready_port(readyPath: str, boundPort: int32, errWire: var str): bool =
    if cheng_str_len(readyPath) <= 0:
        return true
    let path = cheng_copy_cstring_from_str(readyPath)
    let portText = driver_c_i32_to_str_export(boundPort)
    if path != nil && portText != nil:
        let fp = cheng_fopen_write(path)
        if fp != nil:
            let portLen = cheng_cstrlen_raw(portText)
            let wrote = libc_fwrite(portText, 1, portLen, fp)
            let closeRc = libc_fclose(fp)
            cheng_free_export(path)
            cheng_free_export(portText)
            if wrote == int64(portLen) && closeRc == 0:
                return true
            errWire = cheng_error_with_errno("v3 libp2p tcp: ready path")
            return false
    if path != nil:
        cheng_free_export(path)
    if portText != nil:
        cheng_free_export(portText)
    errWire = cheng_error_with_errno("v3 libp2p tcp: ready path")
    return false

fn cheng_sysctl_read_i64(nameText: str): int64 =
    if cheng_str_len(nameText) <= 0:
        return 0
    let name = cheng_copy_cstring_from_str(nameText)
    if name == nil:
        return 0
    let valueBuf = cheng_malloc_export(int32(sizeof int64))
    let lenBuf = cheng_malloc_export(int32(sizeof int64))
    if valueBuf == nil || lenBuf == nil:
        cheng_free_export(name)
        if valueBuf != nil:
            cheng_free_export(valueBuf)
        if lenBuf != nil:
            cheng_free_export(lenBuf)
        return 0
    cheng_bytes_set(valueBuf, 0, int32(sizeof int64))
    *(Int64Ptr(lenBuf)) = int64(sizeof int64)
    let rc = libc_sysctlbyname(name, valueBuf, lenBuf, nil, 0)
    let value = rc == 0 ? *(Int64Ptr(valueBuf)) : int64(0)
    cheng_free_export(name)
    cheng_free_export(valueBuf)
    cheng_free_export(lenBuf)
    return value

fn cheng_statvfs_query_root(totalBytesOut: Int64Ptr, availableBytesOut: Int64Ptr): bool =
    if totalBytesOut != nil:
        *totalBytesOut = 0
    if availableBytesOut != nil:
        *availableBytesOut = 0
    let root = cheng_string_copy("/", 1)
    if root == nil:
        return false
    var fsInfo: DarwinStatvfs
    let rc = libc_statvfs(root, ptr(&fsInfo))
    cheng_free_export(root)
    if rc != 0:
        return false
    var blockSize: int64 = int64(fsInfo.f_frsize)
    if blockSize <= 0:
        blockSize = int64(fsInfo.f_bsize)
    if blockSize <= 0:
        return false
    let blocks = int64(fsInfo.f_blocks)
    let bavail = int64(fsInfo.f_bavail)
    if totalBytesOut != nil:
        *totalBytesOut = blocks * blockSize
    if availableBytesOut != nil:
        *availableBytesOut = bavail * blockSize
    return true

fn cheng_sha256_u32(x: int64): int64 =
    return x & int64(0xffffffff)

fn cheng_sha256_rotr32(x: int64, n: int32): int64 =
    let v = cheng_sha256_u32(x)
    return cheng_sha256_u32((v >> n) | (v << (32 - n)))

fn cheng_sha256_ch(x: int64, y: int64, z: int64): int64 =
    let xu = cheng_sha256_u32(x)
    let yu = cheng_sha256_u32(y)
    let zu = cheng_sha256_u32(z)
    return cheng_sha256_u32((xu & yu) ^ ((xu ^ int64(0xffffffff)) & zu))

fn cheng_sha256_maj(x: int64, y: int64, z: int64): int64 =
    let xu = cheng_sha256_u32(x)
    let yu = cheng_sha256_u32(y)
    let zu = cheng_sha256_u32(z)
    return cheng_sha256_u32((xu & yu) ^ (xu & zu) ^ (yu & zu))

fn cheng_sha256_big_sigma0(x: int64): int64 =
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 2) ^ cheng_sha256_rotr32(x, 13) ^ cheng_sha256_rotr32(x, 22))

fn cheng_sha256_big_sigma1(x: int64): int64 =
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 6) ^ cheng_sha256_rotr32(x, 11) ^ cheng_sha256_rotr32(x, 25))

fn cheng_sha256_small_sigma0(x: int64): int64 =
    let xu = cheng_sha256_u32(x)
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 7) ^ cheng_sha256_rotr32(x, 18) ^ (xu >> 3))

fn cheng_sha256_small_sigma1(x: int64): int64 =
    let xu = cheng_sha256_u32(x)
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 17) ^ cheng_sha256_rotr32(x, 19) ^ (xu >> 10))

fn cheng_sha256_u32_from_bytes(b0: int32, b1: int32, b2: int32, b3: int32): int64 =
    return (int64(b0) << 24) | (int64(b1) << 16) | (int64(b2) << 8) | int64(b3)

fn cheng_sha256_k(i: int32): int64 =
    case i
    of 0: return cheng_sha256_u32_from_bytes(0x42, 0x8a, 0x2f, 0x98)
    of 1: return cheng_sha256_u32_from_bytes(0x71, 0x37, 0x44, 0x91)
    of 2: return cheng_sha256_u32_from_bytes(0xb5, 0xc0, 0xfb, 0xcf)
