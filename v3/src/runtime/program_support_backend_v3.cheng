    let runtimeRaw = cheng_ffi_handle_resolve_ptr_export(handle)
    if runtimeRaw == nil:
        return uint64(0)
    let runtime = ChengV3RelayProviderRuntimePtr(runtimeRaw)
    var payload = cheng_relay_provider_probe_payload(runtime)
    let out = cheng_buffer_handle_new_from_str(payload)
    cheng_str_dispose(payload)
