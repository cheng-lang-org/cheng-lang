    probe_handle_slot_mod: uint64 = 4294967296
    probe_handle_err_invalid: int32 = -1
    probe_handle_max_generation: uint32 = uint32(4294967295)
    chengClockMonotonic: int32 = 6
    chengAfInet: int32 = 2
