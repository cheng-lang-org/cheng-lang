@exportc("cheng_ffi_handle_register_ptr")
fn cheng_ffi_handle_register_ptr_export(p: ptr): uint64 =
    if p == nil:
        return uint64(0)
    var idx: int32 = -1
    for i in 0..<probe_slots_len:
        let slot: ChengFfiHandleSlotPtr = probe_slot_at(i)
        if slot->ptr == nil:
            idx = i
            break
    if idx < 0:
        idx = probe_slots_len
        if !probe_ensure_capacity(idx + 1):
            return uint64(0)
        probe_slots_len = idx + 1
    let slot: ChengFfiHandleSlotPtr = probe_slot_at(idx)
    slot->ptr = p
    if slot->generation == uint32(0):
        slot->generation = uint32(1)
    return uint64(slot->generation) * probe_handle_slot_mod + uint64(idx + 1)

fn cheng_ffi_handle_decode_index(handle: uint64): int32 =
    if handle == uint64(0):
        return -1
    let low: uint64 = handle % probe_handle_slot_mod
    if low == uint64(0):
        return -1
    let idx: int32 = int32(low - uint64(1))
    if idx < 0 || idx >= probe_slots_len:
        return -1
    return idx

fn cheng_ffi_handle_decode_generation(handle: uint64): uint32 =
    return uint32(handle / probe_handle_slot_mod)

fn cheng_ffi_handle_abort_invalid(op: ptr, handle: uint64, detail: ptr) =
    let handleRaw = cheng_u64_to_string(handle)
    var line = "[cheng] ffi handle invalid: op="
    line = line + cheng_str_copy_cstring(op)
    line = line + " detail="
    line = line + cheng_str_copy_cstring(detail)
    line = line + " handle="
    line = line + cheng_str_copy_cstring(handleRaw)
    let rawLine = cheng_copy_cstring_from_str(line)
    if rawLine != nil:
        c_puts_runtime(rawLine)
        cheng_free_export(rawLine)
    if handleRaw != nil:
        cheng_free_export(handleRaw)
    native_cheng_v3_dump_backtrace_and_exit_runtime("ffi_handle", 86)

@exportc("cheng_ffi_handle_resolve_ptr")
fn cheng_ffi_handle_resolve_ptr_export(handle: uint64): ptr =
    let idx: int32 = cheng_ffi_handle_decode_index(handle)
    if idx < 0:
        cheng_ffi_handle_abort_invalid("resolve_ptr", handle, "decode")
        return nil
    let generation: uint32 = cheng_ffi_handle_decode_generation(handle)
    if generation == uint32(0):
        cheng_ffi_handle_abort_invalid("resolve_ptr", handle, "decode")
        return nil
    let slot: ChengFfiHandleSlotPtr = probe_slot_at(idx)
    if slot->ptr == nil:
        cheng_ffi_handle_abort_invalid("resolve_ptr", handle, "released")
        return nil
    if slot->generation != generation:
        cheng_ffi_handle_abort_invalid("resolve_ptr", handle, "stale")
        return nil
    return slot->ptr

@exportc("cheng_ffi_handle_invalidate")
fn cheng_ffi_handle_invalidate_export(handle: uint64): int32 =
    let idx: int32 = cheng_ffi_handle_decode_index(handle)
    if idx < 0:
        cheng_ffi_handle_abort_invalid("invalidate", handle, "decode")
        return probe_handle_err_invalid
    let generation: uint32 = cheng_ffi_handle_decode_generation(handle)
    if generation == uint32(0):
        cheng_ffi_handle_abort_invalid("invalidate", handle, "decode")
        return probe_handle_err_invalid
    let slot: ChengFfiHandleSlotPtr = probe_slot_at(idx)
    if slot->ptr == nil:
        cheng_ffi_handle_abort_invalid("invalidate", handle, "released")
        return probe_handle_err_invalid
    if slot->generation != generation:
        cheng_ffi_handle_abort_invalid("invalidate", handle, "stale")
        return probe_handle_err_invalid
    slot->ptr = nil
    slot->generation = slot->generation + uint32(1)
    if slot->generation == uint32(0):
        slot->generation = uint32(1)
    return 0

@exportc("cheng_ffi_handle_new_i32")
fn cheng_ffi_handle_new_i32_export(value: int32): uint64 =
    let mem: ptr = cheng_malloc_export(int32(sizeof int32))
    if mem == nil:
        return uint64(0)
    *(Int32Ptr(mem)) = value
    let handle: uint64 = cheng_ffi_handle_register_ptr_export(mem)
    if handle == uint64(0):
        cheng_free_export(mem)
    return handle

@exportc("cheng_ffi_handle_get_i32")
fn cheng_ffi_handle_get_i32_export(handle: uint64, outValue: ptr): int32 =
    if outValue == nil:
        cheng_ffi_handle_abort_invalid("get_i32", handle, "null-out")
        return probe_handle_err_invalid
    let cell: ptr = cheng_ffi_handle_resolve_ptr_export(handle)
    if cell == nil:
        return probe_handle_err_invalid
    *(Int32Ptr(outValue)) = *(Int32Ptr(cell))
    return 0

@exportc("cheng_ffi_handle_add_i32")
fn cheng_ffi_handle_add_i32_export(handle: uint64, delta: int32, outValue: ptr): int32 =
    if outValue == nil:
        cheng_ffi_handle_abort_invalid("add_i32", handle, "null-out")
        return probe_handle_err_invalid
    let cell: ptr = cheng_ffi_handle_resolve_ptr_export(handle)
    if cell == nil:
        return probe_handle_err_invalid
    let next: int32 = *(Int32Ptr(cell)) + delta
    *(Int32Ptr(cell)) = next
    *(Int32Ptr(outValue)) = next
    return 0

@exportc("cheng_ffi_handle_release_i32")
fn cheng_ffi_handle_release_i32_export(handle: uint64): int32 =
    let cell: ptr = cheng_ffi_handle_resolve_ptr_export(handle)
    if cell == nil:
        return probe_handle_err_invalid
    let rc: int32 = cheng_ffi_handle_invalidate_export(handle)
    if rc != 0:
        cheng_ffi_handle_abort_invalid("release_i32", handle, "invalidate")
        return rc
    cheng_free_export(cell)
    return 0

fn cheng_str_copy_cstring(text: ptr): str =
    if text == nil:
        return cheng_str_empty()
    return cheng_str_copy(text, cheng_cstrlen_raw(text))

fn cheng_str_dup(text: str): str =
    return cheng_str_copy(cheng_str_data(text), cheng_str_len(text))

fn cheng_str_dispose(s: var str) =
    if s.flags == chengStrFlagOwned && s.data != nil:
        cheng_free_export(s.data)
    s = cheng_str_empty()

fn cheng_copy_cstring_from_str(text: str): ptr =
    return cheng_string_copy(cheng_str_data(text), cheng_str_len(text))

fn cheng_fopen_read(path: ptr): ptr =
    if path == nil:
        return nil
    let mode = cheng_string_copy("rb", 2)
    if mode == nil:
        return nil
    let fp = libc_fopen(path, mode)
    cheng_free_export(mode)
    return fp

fn cheng_str_equals_cstring(text: str, raw: ptr): bool =
    let textLen = cheng_str_len(text)
    let rawLen = cheng_cstrlen_raw(raw)
    if textLen != rawLen:
        return false
    if textLen <= 0:
        return true
    return cheng_bytes_equal(cheng_str_data(text), raw, textLen)

fn cheng_str_has_prefix_cstring(text: str, prefix: ptr): bool =
    let textLen = cheng_str_len(text)
    let prefixLen = cheng_cstrlen_raw(prefix)
    if prefixLen <= 0:
        return true
    if textLen < prefixLen:
        return false
    return cheng_bytes_equal(cheng_str_data(text), prefix, prefixLen)

fn cheng_str_slice_copy(text: str, start0: int32, count0: int32): str =
    let textLen = cheng_str_len(text)
    let textData = cheng_str_data(text)
    var start = start0
    var count = count0
    if textData == nil || textLen <= 0:
        return cheng_str_empty()
    if start < 0:
        start = 0
    if start >= textLen || count <= 0:
        return cheng_str_empty()
    if start + count > textLen:
        count = textLen - start
    return cheng_str_copy(cheng_ptr_plus(textData, start), count)

fn cheng_cstring_equals_cstring(a: ptr, b: ptr): bool =
    let lenA = cheng_cstrlen_raw(a)
    let lenB = cheng_cstrlen_raw(b)
    if lenA != lenB:
        return false
    if lenA <= 0:
        return true
    return cheng_bytes_equal(a, b, lenA)

fn cheng_read_text_file(path: str): str =
    let rawPath = cheng_copy_cstring_from_str(path)
    if rawPath == nil:
        return cheng_str_empty()
    let fp = cheng_fopen_read(rawPath)
    cheng_free_export(rawPath)
    if fp == nil:
        return cheng_str_empty()
    var cap: int32 = 1024
    var out = driver_c_new_string_export(cap)
    if out == nil:
        libc_fclose(fp)
        return cheng_str_empty()
    var used: int32 = 0
    while true:
        let got = int32(libc_fread(cheng_ptr_plus(out, used), int64(1), int64(cap - used), fp))
        if got < 0:
            libc_fclose(fp)
            cheng_free_export(out)
            return cheng_str_empty()
        used = used + got
        *(UInt8Ptr(cheng_ptr_plus(out, used))) = uint8(0)
        if got == 0:
            break
        if used >= cap:
            let nextCap = cap * 2
            let next = cheng_realloc_export(out, nextCap + 1)
            if next == nil:
                libc_fclose(fp)
                cheng_free_export(out)
                return cheng_str_empty()
            out = next
            cap = nextCap
    libc_fclose(fp)
    return cheng_str_view_owned(out, used)

fn cheng_file_exists_raw(path: ptr): bool =
    if path == nil || *(UInt8Ptr(path)) == uint8(0):
        return false
    let fp = cheng_fopen_read(path)
    if fp == nil:
        return false
    libc_fclose(fp)
    return true

fn cheng_dir_exists_raw(path: ptr): bool =
    if path == nil || *(UInt8Ptr(path)) == uint8(0):
        return false
    let dir = libc_opendir(path)
    if dir == nil:
        return false
    libc_closedir(dir)
    return true

fn cheng_file_size_raw(path: ptr): int64 =
    if path == nil || *(UInt8Ptr(path)) == uint8(0):
        return 0
    let fp = cheng_fopen_read(path)
    if fp == nil:
        return 0
    if libc_fseek(fp, 0, chengSeekEnd) != 0:
        libc_fclose(fp)
        return 0
    let size = libc_ftell(fp)
    libc_fclose(fp)
    if size < 0:
        return 0
    return size

fn cheng_path_is_sep(ch: int32): bool =
    return ch == int32('/') || ch == int32('\\')

fn cheng_mkdir_if_needed(path: ptr) =
    if path == nil || *(UInt8Ptr(path)) == uint8(0):
        return
    if cheng_dir_exists_raw(path):
        return
    let rc = libc_mkdir(path, 493)
    rc

fn cheng_mkdir_all_raw(path: ptr, includeLeaf: bool) =
    if path == nil:
        return
    let n = cheng_cstrlen_raw(path)
    if n <= 0:
        return
    let scratch = cheng_string_copy(path, n)
    if scratch == nil:
        return
    for i in 0..<n:
        let ch = cheng_load_u8(scratch, i)
        if !cheng_path_is_sep(ch):
            continue
        if i == 0:
            continue
        if i == 2 && cheng_load_u8(scratch, 1) == int32(':'):
            continue
        *(UInt8Ptr(cheng_ptr_plus(scratch, i))) = uint8(0)
        cheng_mkdir_if_needed(scratch)
        *(UInt8Ptr(cheng_ptr_plus(scratch, i))) = uint8(ch)
    if includeLeaf:
        cheng_mkdir_if_needed(scratch)
    cheng_free_export(scratch)

fn cheng_sleep_ms(value: int32) =
    if value <= 0:
        return
    libc_usleep(uint32(value * 1000))

fn cheng_http_find_char(text: str, target: int32, start0: int32): int32 =
    let data = cheng_str_data(text)
    let n = cheng_str_len(text)
    if data == nil || n <= 0:
        return -1
    var start = start0
    if start < 0:
        start = 0
    var i = start
    while i < n:
        if cheng_load_u8(data, i) == target:
            return i
        i = i + 1
    return -1

fn cheng_http_response_status_ok(response: str): bool =
    let data = cheng_str_data(response)
    let n = cheng_str_len(response)
    if data == nil || n < 12:
        return false
    let space = cheng_http_find_char(response, 32, 0)
    if space < 0 || space + 4 > n:
        return false
    let d0 = cheng_load_u8(data, space + 1)
    let d1 = cheng_load_u8(data, space + 2)
    let d2 = cheng_load_u8(data, space + 3)
    if d0 < int32('0') || d0 > int32('9') ||
       d1 < int32('0') || d1 > int32('9') ||
       d2 < int32('0') || d2 > int32('9'):
        return false
    return d0 == int32('2')

fn cheng_http_response_body(response: str): str =
    let data = cheng_str_data(response)
    let n = cheng_str_len(response)
    if data == nil || n <= 0:
        return cheng_str_empty()
    var i: int32 = 0
    while i + 3 < n:
        if cheng_load_u8(data, i) == 13 &&
           cheng_load_u8(data, i + 1) == 10 &&
           cheng_load_u8(data, i + 2) == 13 &&
           cheng_load_u8(data, i + 3) == 10:
            return cheng_str_slice_copy(response, i + 4, n - i - 4)
        i = i + 1
    i = 0
    while i + 1 < n:
        if cheng_load_u8(data, i) == 10 &&
           cheng_load_u8(data, i + 1) == 10:
            return cheng_str_slice_copy(response, i + 2, n - i - 2)
        i = i + 1
    return cheng_str_empty()

fn cheng_http_parse_url(url: str,
                        outHost: var str,
                        outPort: var int32,
                        outPath: var str,
                        outHttps: var bool): bool =
    outHost = cheng_str_empty()
    outPort = 0
    outPath = cheng_str_empty()
    outHttps = false
    let n = cheng_str_len(url)
    if n <= 0:
        return false
    var start = 0
    if cheng_str_has_prefix_cstring(url, "http://"):
        start = 7
        outPort = 80
    elif cheng_str_has_prefix_cstring(url, "https://"):
        start = 8
        outPort = 443
        outHttps = true
    else:
        return false
    let slash = cheng_http_find_char(url, int32('/'), start)
    let authorityEnd = if slash >= 0: slash else: n
    if authorityEnd <= start:
        return false
    let authority = cheng_str_slice_copy(url, start, authorityEnd - start)
    let authorityLen = cheng_str_len(authority)
    if authorityLen <= 0:
        cheng_str_dispose(authority)
        return false
    let authorityData = cheng_str_data(authority)
    var colon = -1
    var i: int32 = 0
    while i < authorityLen:
        let ch = cheng_load_u8(authorityData, i)
        if ch == 91 || ch == 93 || ch == 64:
            cheng_str_dispose(authority)
            return false
        if ch == 58:
            if colon >= 0:
                cheng_str_dispose(authority)
                return false
            colon = i
        i = i + 1
    if colon >= 0:
        if colon <= 0 || colon + 1 >= authorityLen:
            cheng_str_dispose(authority)
            return false
        outHost = cheng_str_slice_copy(authority, 0, colon)
        let portText = cheng_str_slice_copy(authority, colon + 1, authorityLen - colon - 1)
        outPort = cheng_runtime_parse_int32(portText, -1)
        cheng_str_dispose(portText)
        if outPort <= 0 || outPort > 65535:
            cheng_str_dispose(authority)
            cheng_str_dispose(outHost)
            outHost = cheng_str_empty()
            return false
    else:
        outHost = authority
    if slash >= 0:
        outPath = cheng_str_slice_copy(url, slash, n - slash)
    else:
        outPath = cheng_str_copy_cstring("/")
    if cheng_str_len(outHost) <= 0 || cheng_str_len(outPath) <= 0:
        cheng_str_dispose(authority)
        cheng_str_dispose(outHost)
        cheng_str_dispose(outPath)
        outHost = cheng_str_empty()
        outPath = cheng_str_empty()
        return false
    if colon < 0:
        authority = cheng_str_empty()
    cheng_str_dispose(authority)
    return true

fn cheng_http_connect_ipv4(hostText: str, port: int32): int32 =
    if port <= 0 || port > 65535:
        return -1
    let fd = libc_socket(chengAfInet, chengSockStream, chengIpProtoIp)
    if fd < 0:
        return -1
    var connectAddr: ptr = nil
    if cheng_str_len(hostText) <= 0 || cheng_str_equals_cstring(hostText, "localhost"):
        connectAddr = cheng_sockaddr_loopback(port)
    else:
        connectAddr = cheng_sockaddr_ipv4_parse(hostText, port)
    if connectAddr == nil:
        cheng_close_if_open(fd)
        return -1
    if libc_connect(fd, connectAddr, chengSockaddrInLen) != 0:
        cheng_free_export(connectAddr)
        cheng_close_if_open(fd)
        return -1
    cheng_free_export(connectAddr)
    return fd

fn cheng_http_recv_all(fd: int32): str =
    if fd < 0:
        return cheng_str_empty()
    var cap: int32 = 2048
    var out = driver_c_new_string_export(cap)
    if out == nil:
        return cheng_str_empty()
    var used: int32 = 0
    while true:
        if used >= cap:
            let nextCap = cap * 2
            let next = cheng_realloc_export(out, nextCap + 1)
            if next == nil:
                cheng_free_export(out)
                return cheng_str_empty()
            out = next
            cap = nextCap
        let got = libc_recv(fd, cheng_ptr_plus(out, used), cap - used, 0)
        if got < 0:
            cheng_free_export(out)
            return cheng_str_empty()
        if got == 0:
            *(UInt8Ptr(cheng_ptr_plus(out, used))) = uint8(0)
            return cheng_str_view_owned(out, used)
        used = used + got
        *(UInt8Ptr(cheng_ptr_plus(out, used))) = uint8(0)
    return cheng_str_empty()

fn cheng_http_load_endpoint_payload_ex(endpoint: str, outErr: var str): str =
    outErr = cheng_str_empty()
    var host = cheng_str_empty()
    var path = cheng_str_empty()
    var port: int32 = 0
    var isHttps = false
    if !cheng_http_parse_url(endpoint, host, port, path, isHttps):
        outErr = cheng_str_copy_cstring("http probe: invalid url")
        return cheng_str_empty()
    if isHttps:
        outErr = cheng_str_copy_cstring("http probe: https unsupported")
        cheng_str_dispose(host)
        cheng_str_dispose(path)
        return cheng_str_empty()
    let fd = cheng_http_connect_ipv4(host, port)
    if fd < 0:
        outErr = cheng_str_copy_cstring("http probe: connect failed")
        cheng_str_dispose(host)
        cheng_str_dispose(path)
        return cheng_str_empty()
    var request = ""
    request = request + "GET "
    request = request + path
    request = request + " HTTP/1.0\r\n"
    request = request + "Host: "
    request = request + host
    request = request + "\r\n"
    request = request + "Connection: close\r\n"
    request = request + "Accept: application/json\r\n\r\n"
    let sentOk = cheng_send_all(fd, cheng_str_data(request), cheng_str_len(request))
    var response = cheng_str_empty()
    if sentOk:
        response = cheng_http_recv_all(fd)
    cheng_close_if_open(fd)
    cheng_str_dispose(host)
    cheng_str_dispose(path)
    if !sentOk:
        outErr = cheng_str_copy_cstring("http probe: send failed")
        cheng_str_dispose(response)
        return cheng_str_empty()
    if cheng_str_len(response) <= 0:
        outErr = cheng_str_copy_cstring("http probe: recv failed")
        cheng_str_dispose(response)
        return cheng_str_empty()
    if !cheng_http_response_status_ok(response):
        outErr = cheng_str_copy_cstring("http probe: bad status")
        cheng_str_dispose(response)
        return cheng_str_empty()
    let payload = cheng_http_response_body(response)
    cheng_str_dispose(response)
    if cheng_str_len(payload) <= 0:
        outErr = cheng_str_copy_cstring("http probe: missing body")
        return cheng_str_empty()
    outErr = cheng_str_empty()
    return payload

fn cheng_http_load_endpoint_payload(endpoint: str): str =
    var err = cheng_str_empty()
    let payload = cheng_http_load_endpoint_payload_ex(endpoint, err)
    cheng_str_dispose(err)
    return payload

fn cheng_tailnet_load_endpoint_payload(endpoint: str): str =
    var clean = cheng_v3_str_strip_bridge_export(endpoint)
    if cheng_str_len(clean) <= 0:
        return cheng_str_empty()
    var payload = cheng_str_empty()
    if cheng_str_has_prefix_cstring(clean, "file://"):
        var path = cheng_str_slice_copy(clean, 7, cheng_str_len(clean) - 7)
        payload = cheng_read_text_file(path)
        cheng_str_dispose(path)
    elif cheng_str_has_prefix_cstring(clean, "http://") ||
         cheng_str_has_prefix_cstring(clean, "https://"):
        payload = cheng_http_load_endpoint_payload(clean)
    else:
        payload = cheng_read_text_file(clean)
    cheng_str_dispose(clean)
    return payload

fn cheng_tailnet_load_endpoint_payload_cstring(endpoint: ptr): str =
    if endpoint == nil:
        return cheng_str_empty()
    var text = cheng_str_copy_cstring(endpoint)
    let payload = cheng_tailnet_load_endpoint_payload(text)
    cheng_str_dispose(text)
    return payload

fn cheng_tailnet_json_skip_ws(payload: str, idx0: int32): int32 =
    let data = cheng_str_data(payload)
    let n = cheng_str_len(payload)
    var idx = idx0
    while idx < n:
        let ch = cheng_load_u8(data, idx)
        if !cheng_ascii_space(uint8(ch)):
            return idx
        idx = idx + 1
    return idx

fn cheng_tailnet_json_value_after_key(payload: str, key: ptr): int32 =
    let payloadData = cheng_str_data(payload)
    let payloadLen = cheng_str_len(payload)
    let keyLen = cheng_cstrlen_raw(key)
    if payloadData == nil || payloadLen <= 0 || key == nil || keyLen <= 0:
        return -1
    let quote = 34
    let colon = 58
    let limit = payloadLen - keyLen - 2
    var i: int32 = 0
    while i <= limit:
        let ch0 = cheng_load_u8(payloadData, i)
        if ch0 == quote:
            let keyMatch = cheng_bytes_equal(cheng_ptr_plus(payloadData, i + 1), key, keyLen)
            if keyMatch:
                let ch1 = cheng_load_u8(payloadData, i + keyLen + 1)
                if ch1 == quote:
                    var idx = cheng_tailnet_json_skip_ws(payload, i + keyLen + 2)
                    if idx < payloadLen:
                        let sep = cheng_load_u8(payloadData, idx)
                        if sep == colon:
                            idx = cheng_tailnet_json_skip_ws(payload, idx + 1)
                            if idx < payloadLen:
                                return idx
        i = i + 1
    return -1

fn cheng_tailnet_json_bool_term(ch: int32): bool =
    if ch == 0:
        return true
    if ch == 44:
        return true
    if ch == 125:
        return true
    return cheng_ascii_space(uint8(ch))

fn cheng_tailnet_json_match_literal(data: ptr, idx: int32, totalLen: int32, text: ptr): bool =
    let textLen = cheng_cstrlen_raw(text)
    if data == nil || idx < 0 || totalLen < 0 || text == nil || textLen <= 0:
        return false
    if idx + textLen > totalLen:
        return false
    return cheng_bytes_equal(cheng_ptr_plus(data, idx), text, textLen)

fn cheng_tailnet_json_read_bool(payload: str, key: ptr, outValue: var bool): bool =
    let idx = cheng_tailnet_json_value_after_key(payload, key)
    let data = cheng_str_data(payload)
    let n = cheng_str_len(payload)
    outValue = false
    if idx < 0 || data == nil:
        return false
    if cheng_tailnet_json_match_literal(data, idx, n, "true"):
        let endIdx = idx + 4
        if endIdx >= n || cheng_tailnet_json_bool_term(cheng_load_u8(data, endIdx)):
            outValue = true
            return true
    if cheng_tailnet_json_match_literal(data, idx, n, "false"):
        let endIdx = idx + 5
        if endIdx >= n || cheng_tailnet_json_bool_term(cheng_load_u8(data, endIdx)):
            outValue = false
            return true
    return false

fn cheng_tailnet_json_read_string(payload: str, key: ptr, outValue: var str): bool =
    outValue = cheng_str_empty()
    let idx = cheng_tailnet_json_value_after_key(payload, key)
    let data = cheng_str_data(payload)
    let n = cheng_str_len(payload)
    if idx < 0 || data == nil || idx >= n:
        return false
    let quote = 34
    let slash = 92
    if cheng_load_u8(data, idx) != quote:
        return false
    let outRaw = driver_c_new_string_export(n - idx)
    if outRaw == nil:
        return false
    var used: int32 = 0
    var pos = idx + 1
    var ch: int32 = 0
    while pos < n:
        ch = cheng_load_u8(data, pos)
        pos = pos + 1
        if ch == quote:
            outValue = cheng_str_view_owned(outRaw, used)
            return true
        if ch == slash:
            if pos >= n:
                break
            ch = cheng_load_u8(data, pos)
            pos = pos + 1
        *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = uint8(ch)
        used = used + 1
    cheng_free_export(outRaw)
    return false

fn cheng_tailnet_provider_runtime_new(): ChengV3TailnetProviderRuntimePtr =
    let mem = cheng_malloc_export(int32(sizeof ChengV3TailnetProviderRuntime))
    if mem == nil:
        return nil
    let runtime = ChengV3TailnetProviderRuntimePtr(mem)
    runtime->providerKind = nil
    runtime->controlEndpoint = nil
    runtime->relayEndpoint = nil
    runtime->controlProbeEndpoint = nil
    runtime->relayProbeEndpoint = nil
    runtime->derpRegionCode = nil
    runtime->derpHostname = nil
    runtime->startupStage = cheng_string_copy("init", 4)
    runtime->lastError = nil
    runtime->providerReady = false
    runtime->proxyReady = false
    runtime->listenerNeedsRepair = false
    runtime->derpHealthy = false
    return runtime

fn cheng_tailnet_provider_runtime_dispose(runtime: ChengV3TailnetProviderRuntimePtr) =
    if runtime == nil:
        return
    cheng_free_export(runtime->providerKind)
    cheng_free_export(runtime->controlEndpoint)
    cheng_free_export(runtime->relayEndpoint)
    cheng_free_export(runtime->controlProbeEndpoint)
    cheng_free_export(runtime->relayProbeEndpoint)
    cheng_free_export(runtime->derpRegionCode)
    cheng_free_export(runtime->derpHostname)
    cheng_free_export(runtime->startupStage)
    cheng_free_export(runtime->lastError)
    cheng_free_export(ptr(runtime))

fn cheng_tailnet_provider_set_stage(runtime: ChengV3TailnetProviderRuntimePtr, stage: str) =
    if runtime == nil:
        return
    cheng_free_export(runtime->startupStage)
    runtime->startupStage = cheng_copy_cstring_from_str(stage)

fn cheng_tailnet_provider_set_stage_cstring(runtime: ChengV3TailnetProviderRuntimePtr, stage: ptr) =
    if runtime == nil:
        return
    cheng_free_export(runtime->startupStage)
    runtime->startupStage = cheng_string_copy(stage, cheng_cstrlen_raw(stage))

fn cheng_tailnet_provider_set_error_cstring(runtime: ChengV3TailnetProviderRuntimePtr, text: ptr) =
    if runtime == nil:
        return
    cheng_free_export(runtime->lastError)
    runtime->lastError = cheng_string_copy(text, cheng_cstrlen_raw(text))

fn cheng_tailnet_provider_set_error(runtime: ChengV3TailnetProviderRuntimePtr, text: str) =
    if runtime == nil:
        return
    cheng_free_export(runtime->lastError)
    runtime->lastError = cheng_copy_cstring_from_str(text)

fn cheng_tailnet_provider_is_headscale(runtime: ChengV3TailnetProviderRuntimePtr): bool =
    if runtime == nil:
        return false
    return cheng_cstring_equals_cstring(runtime->providerKind, "headscale")

fn cheng_tailnet_provider_sync_control(runtime: ChengV3TailnetProviderRuntimePtr): bool =
    if runtime == nil:
        return false
    var payload = cheng_str_empty()
    var loadErr = cheng_str_empty()
    if cheng_cstrlen_raw(runtime->controlProbeEndpoint) > 0:
        let endpoint = cheng_str_copy_cstring(runtime->controlProbeEndpoint)
        if cheng_str_has_prefix_cstring(endpoint, "http://") ||
           cheng_str_has_prefix_cstring(endpoint, "https://"):
            payload = cheng_http_load_endpoint_payload_ex(endpoint, loadErr)
        else:
            payload = cheng_tailnet_load_endpoint_payload(endpoint)
        cheng_str_dispose(endpoint)
    else:
        payload = cheng_tailnet_load_endpoint_payload_cstring(runtime->controlEndpoint)
    if cheng_str_len(payload) <= 0:
        if cheng_str_len(loadErr) > 0:
            let errText = "tailnet provider: " + loadErr
            cheng_tailnet_provider_set_error(runtime, errText)
            cheng_str_dispose(loadErr)
            return false
        cheng_tailnet_provider_set_error_cstring(runtime, "tailnet provider: control probe load failed")
        return false
    var providerReady = false
    var proxyReady = false
    var listenerNeedsRepair = false
    var startupStage = cheng_str_empty()
    let ok = cheng_tailnet_json_read_bool(payload, "providerReady", providerReady) &&
             cheng_tailnet_json_read_bool(payload, "proxyListenersReady", proxyReady) &&
             cheng_tailnet_json_read_bool(payload, "listenerNeedsRepair", listenerNeedsRepair) &&
             cheng_tailnet_json_read_string(payload, "startupStage", startupStage)
    cheng_str_dispose(payload)
    if !ok:
        cheng_str_dispose(startupStage)
        cheng_tailnet_provider_set_error_cstring(runtime, "tailnet provider: control probe parse failed")
        return false
    runtime->providerReady = providerReady
    runtime->proxyReady = proxyReady
    runtime->listenerNeedsRepair = listenerNeedsRepair
    cheng_tailnet_provider_set_stage(runtime, startupStage)
    cheng_str_dispose(startupStage)
    cheng_str_dispose(loadErr)
    cheng_tailnet_provider_set_error_cstring(runtime, "")
    return true

fn cheng_tailnet_provider_sync_derp(runtime: ChengV3TailnetProviderRuntimePtr): bool =
    if runtime == nil:
        return false
    var payload = cheng_str_empty()
    var loadErr = cheng_str_empty()
    if cheng_cstrlen_raw(runtime->relayProbeEndpoint) > 0:
        let endpoint = cheng_str_copy_cstring(runtime->relayProbeEndpoint)
        if cheng_str_has_prefix_cstring(endpoint, "http://") ||
           cheng_str_has_prefix_cstring(endpoint, "https://"):
            payload = cheng_http_load_endpoint_payload_ex(endpoint, loadErr)
        else:
            payload = cheng_tailnet_load_endpoint_payload(endpoint)
        cheng_str_dispose(endpoint)
    else:
        payload = cheng_tailnet_load_endpoint_payload_cstring(runtime->relayEndpoint)
    if cheng_str_len(payload) <= 0:
        if cheng_str_len(loadErr) > 0:
            let errText = "tailnet provider: " + loadErr
            cheng_tailnet_provider_set_error(runtime, errText)
            cheng_str_dispose(loadErr)
            return false
        cheng_tailnet_provider_set_error_cstring(runtime, "tailnet provider: derp probe load failed")
        return false
    var derpHealthy = false
    var startupStage = cheng_str_empty()
    let ok = cheng_tailnet_json_read_bool(payload, "derpHealthy", derpHealthy) &&
             cheng_tailnet_json_read_string(payload, "startupStage", startupStage)
    cheng_str_dispose(payload)
    if !ok:
        cheng_str_dispose(startupStage)
        cheng_tailnet_provider_set_error_cstring(runtime, "tailnet provider: derp probe parse failed")
        return false
    runtime->derpHealthy = derpHealthy
    cheng_tailnet_provider_set_stage(runtime, startupStage)
    cheng_str_dispose(startupStage)
    cheng_str_dispose(loadErr)
    cheng_tailnet_provider_set_error_cstring(runtime, "")
    return true

fn cheng_errno_code(): int32 =
    let errnoPtr = libc_errno_ptr()
    if errnoPtr == nil:
        return 0
    return *(Int32Ptr(errnoPtr))

fn cheng_error_with_errno(prefix: ptr): str =
    let reason = libc_strerror(cheng_errno_code())
    let prefixText = cheng_str_copy_cstring(prefix)
    if reason == nil || cheng_cstrlen_raw(reason) <= 0:
        return prefixText
    return prefixText + ": " + cheng_str_copy_cstring(reason)

fn cheng_sockaddr_ipv4_make(port: int32, inaddr: int32): ptr =
    let addr = cheng_malloc_export(chengSockaddrInLen)
    if addr == nil:
        return nil
    cheng_bytes_set(addr, 0, chengSockaddrInLen)
    *(UInt8Ptr(addr)) = uint8(chengSockaddrInLen)
    *(UInt8Ptr(cheng_ptr_plus(addr, 1))) = uint8(chengAfInet)
    *(UInt8Ptr(cheng_ptr_plus(addr, 2))) = uint8((port >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 3))) = uint8(port & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 4))) = uint8((inaddr >> 24) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 5))) = uint8((inaddr >> 16) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 6))) = uint8((inaddr >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 7))) = uint8(inaddr & 255)
    return addr

fn cheng_sockaddr_loopback(port: int32): ptr =
    return cheng_sockaddr_ipv4_make(port, chengInaddrLoopback)

fn cheng_sockaddr_ipv6_make(port: int32, inaddr: ptr): ptr =
    let addr = cheng_malloc_export(chengSockaddrIn6Len)
    if addr == nil:
        return nil
    cheng_bytes_set(addr, 0, chengSockaddrIn6Len)
    *(UInt8Ptr(addr)) = uint8(chengSockaddrIn6Len)
    *(UInt8Ptr(cheng_ptr_plus(addr, 1))) = uint8(chengAfInet6)
    *(UInt8Ptr(cheng_ptr_plus(addr, 2))) = uint8((port >> 8) & 255)
    *(UInt8Ptr(cheng_ptr_plus(addr, 3))) = uint8(port & 255)
    if inaddr != nil:
        cheng_bytes_copy(cheng_ptr_plus(addr, 8), inaddr, 16)
    return addr

fn cheng_sockaddr_loopback_v6(port: int32): ptr =
    let octets = cheng_malloc_export(16)
    if octets == nil:
        return nil
    cheng_bytes_set(octets, 0, 16)
    *(UInt8Ptr(cheng_ptr_plus(octets, 15))) = uint8(1)
    let addr = cheng_sockaddr_ipv6_make(port, octets)
    cheng_free_export(octets)
    return addr

fn cheng_parse_ipv4_addr(text: str, outAddr: ptr): bool =
    if outAddr == nil:
        return false
    let data = cheng_str_data(text)
    let n = cheng_str_len(text)
    if data == nil || n <= 0:
        return false
    var partIndex: int32 = 0
    var value: int32 = 0
    var sawDigit = false
    cheng_bytes_set(outAddr, 0, 4)
    for i in 0..<n:
        let ch = int32(*(UInt8Ptr(cheng_ptr_plus(data, i))))
        if ch >= int32('0') && ch <= int32('9'):
            sawDigit = true
            value = value * 10 + (ch - int32('0'))
            if value > 255:
                return false
        elif ch == int32('.'):
            if !sawDigit || partIndex >= 3:
                return false
            *(UInt8Ptr(cheng_ptr_plus(outAddr, partIndex))) = uint8(value)
            partIndex = partIndex + 1
            value = 0
            sawDigit = false
        else:
            return false
    if !sawDigit || partIndex != 3:
        return false
    *(UInt8Ptr(cheng_ptr_plus(outAddr, partIndex))) = uint8(value)
    return true

fn cheng_sockaddr_ipv4_parse(hostText: str, port: int32): ptr =
    let octets = cheng_malloc_export(4)
    if octets == nil:
        return nil
    if !cheng_parse_ipv4_addr(hostText, octets):
        cheng_free_export(octets)
        return nil
    let inaddr = (int32(*(UInt8Ptr(octets))) << 24) |
                 (int32(*(UInt8Ptr(cheng_ptr_plus(octets, 1)))) << 16) |
                 (int32(*(UInt8Ptr(cheng_ptr_plus(octets, 2)))) << 8) |
                 int32(*(UInt8Ptr(cheng_ptr_plus(octets, 3))))
    cheng_free_export(octets)
    return cheng_sockaddr_ipv4_make(port, inaddr)

fn cheng_sockaddr_port(addr: ptr): int32 =
    if addr == nil:
        return 0
    return (int32(*(UInt8Ptr(cheng_ptr_plus(addr, 2)))) << 8) |
           int32(*(UInt8Ptr(cheng_ptr_plus(addr, 3))))

fn cheng_udp_bind_host_port_impl(hostText: str, port: int32, isV6: bool, outFd: var int32, outPort: var int32, outFamily: var int32, outUseLenField: var int32): int32 =
    outFd = -1
    outPort = 0
    outFamily = 0
    outUseLenField = 0
    if port < 0 || port > 65535:
        return 22

    let family: int32 = if isV6: chengAfInet6 else: chengAfInet
    let fd: int32 = libc_socket(family, chengSockDgram, 0)
    if fd < 0:
        return cheng_errno_code()

    outUseLenField = 1
    var bindAddr: ptr = nil
    if isV6:
        if cheng_str_len(hostText) <= 0 || cheng_str_equals_cstring(hostText, "localhost"):
            bindAddr = cheng_sockaddr_loopback_v6(port)
        else:
            let hostRaw = cheng_copy_cstring_from_str(hostText)
            let octets = cheng_malloc_export(16)
            if hostRaw == nil || octets == nil:
                if hostRaw != nil:
                    cheng_free_export(hostRaw)
                if octets != nil:
                    cheng_free_export(octets)
                libc_close(fd)
                return 12
            cheng_bytes_set(octets, 0, 16)
            if libc_inet_pton_native(chengAfInet6, hostRaw, octets) == 1:
                bindAddr = cheng_sockaddr_ipv6_make(port, octets)
            cheng_free_export(hostRaw)
            cheng_free_export(octets)
            if bindAddr == nil:
                libc_close(fd)
                return 22
        if bindAddr == nil:
            libc_close(fd)
            return 12
        if libc_bind(fd, bindAddr, chengSockaddrIn6Len) != 0:
            let err = cheng_errno_code()
            cheng_free_export(bindAddr)
            libc_close(fd)
            return err
        if port == 0:
            var rawLen: int32 = chengSockaddrIn6Len
            if libc_getsockname(fd, bindAddr, &rawLen) != 0:
                let err = cheng_errno_code()
                cheng_free_export(bindAddr)
                libc_close(fd)
                return err
        outFd = fd
        outPort = cheng_sockaddr_port(bindAddr)
        outFamily = chengAfInet6
        cheng_free_export(bindAddr)
        return 0
    if cheng_str_len(hostText) <= 0 || cheng_str_equals_cstring(hostText, "localhost"):
        bindAddr = cheng_sockaddr_loopback(port)
    else:
        bindAddr = cheng_sockaddr_ipv4_parse(hostText, port)
    if bindAddr == nil:
        libc_close(fd)
        return 22
    if libc_bind(fd, bindAddr, chengSockaddrInLen) != 0:
        let err = cheng_errno_code()
        cheng_free_export(bindAddr)
        libc_close(fd)
        return err
    if port == 0:
        var rawLen: int32 = chengSockaddrInLen
        if libc_getsockname(fd, bindAddr, &rawLen) != 0:
            let err = cheng_errno_code()
            cheng_free_export(bindAddr)
            libc_close(fd)
            return err
    outFd = fd
    outPort = cheng_sockaddr_port(bindAddr)
    outFamily = chengAfInet
    cheng_free_export(bindAddr)
    return 0

@exportc("cheng_errno")
fn cheng_errno_export(): int32 =
    return cheng_errno_code()

@exportc("cheng_strerror")
fn cheng_strerror_export(err: int32): ptr =
    return libc_strerror(err)

@exportc("libc_socket")
fn libc_socket_export(domain: int32, typ: int32, protocol: int32): int32 =
    return libc_socket(domain, typ, protocol)

@exportc("libc_fcntl")
fn libc_fcntl_export(fd: int32, cmd: int32, arg: int32): int32 =
    return libc_fcntl_native(fd, cmd, arg)

@exportc("libc_bind")
fn libc_bind_export(fd: int32, addr: ptr, len: int32): int32 =
    return libc_bind(fd, addr, len)

@exportc("libc_sendto")
fn libc_sendto_export(fd: int32, buf: ptr, len: int32, flags: int32, addr: ptr, addrlen: int32): int32 =
    return libc_sendto_native(fd, buf, len, flags, addr, addrlen)

@exportc("libc_recvfrom")
fn libc_recvfrom_export(fd: int32, buf: ptr, len: int32, flags: int32, addr: ptr, addrlen: var int32): int32 =
    return libc_recvfrom_native(fd, buf, len, flags, addr, &addrlen)

@exportc("cheng_recvfrom_fd_ex")
fn cheng_recvfrom_fd_ex_export(fd: int32, buf: ptr, len: int32, flags: int32, addr: ptr, addrlen: ptr, outErr: var int32): int32 =
    outErr = 0
    let rc: int32 = libc_recvfrom_native(fd, buf, len, flags, addr, addrlen)
    if rc < 0:
        outErr = cheng_errno_code()
    return rc

@exportc("libc_setsockopt")
fn libc_setsockopt_export(fd: int32, level: int32, optname: int32, optval: ptr, optlen: int32): int32 =
    return libc_setsockopt(fd, level, optname, optval, optlen)

@exportc("libc_inet_pton")
fn libc_inet_pton_export(family: int32, src: ptr, dst: ptr): int32 =
    return libc_inet_pton_native(family, src, dst)

@exportc("libc_inet_ntop")
fn libc_inet_ntop_export(family: int32, src: ptr, dst: ptr, size: int32): ptr =
    return libc_inet_ntop_native(family, src, dst, size)

@exportc("libc_getsockname")
fn libc_getsockname_export(fd: int32, addr: ptr, addrlen: var int32): int32 =
    return libc_getsockname(fd, addr, &addrlen)

@exportc("libc_close")
fn libc_close_export(fd: int32): int32 =
    return libc_close(fd)

@exportc("cheng_v3_udp_bind_host_port_bridge")
fn cheng_v3_udp_bind_host_port_bridge_export(host: str, port: int32, isV6: int32, outFd: var int32, outPort: var int32, outFamily: var int32, outUseLenField: var int32): int32 =
    return cheng_udp_bind_host_port_impl(host, port, isV6 != 0, outFd, outPort, outFamily, outUseLenField)

@exportc("cheng_v3_udp_bind_fd_bridge")
fn cheng_v3_udp_bind_fd_bridge_export(host: str, port: int32, isV6: int32): int32 =
    var fd: int32 = -1
    var boundPort: int32 = 0
    var family: int32 = 0
    var useLenField: int32 = 0
    let rc: int32 = cheng_udp_bind_host_port_impl(host, port, isV6 != 0, fd, boundPort, family, useLenField)
    if rc != 0:
        return 0 - rc
    return fd

@exportc("cheng_v3_udp_bound_port_bridge")
fn cheng_v3_udp_bound_port_bridge_export(fd: int32, isV6: int32): int32 =
    if fd < 0:
        return -22
    let rawLenInit: int32 = if isV6 != 0: chengSockaddrIn6Len else: chengSockaddrInLen
    let rawAddr = cheng_malloc_export(rawLenInit)
    if rawAddr == nil:
        return -12
    cheng_bytes_set(rawAddr, 0, rawLenInit)
    var rawLen: int32 = rawLenInit
    if libc_getsockname(fd, rawAddr, &rawLen) != 0:
        let err = cheng_errno_code()
        cheng_free_export(rawAddr)
        return 0 - err
    let port: int32 = cheng_sockaddr_port(rawAddr)
    cheng_free_export(rawAddr)
    return port

@exportc("cheng_v3_udp_recvfrom_addr_bridge")
fn cheng_v3_udp_recvfrom_addr_bridge_export(fd: int32, buf: ptr, len: int32, flags: int32, addr: ptr, addrCap: int32, outAddrLen: var int32, outErr: var int32): int32 =
    outAddrLen = 0
    outErr = 0
    if fd < 0 || buf == nil || len <= 0 || addr == nil || addrCap <= 0:
        return -1
    var rawLen: int32 = addrCap
    let rc: int32 = libc_recvfrom_native(fd, buf, len, flags, addr, &rawLen)
    if rc < 0:
        outErr = cheng_errno_code()
        return rc
    outAddrLen = rawLen
    return rc

@exportc("cheng_v3_udp_platform_use_len_field_bridge")
fn cheng_v3_udp_platform_use_len_field_bridge_export(): int32 =
    return 1

fn cheng_write_u32be(out: ptr, value: uint32) =
    if out == nil:
        return
    *(UInt8Ptr(out)) = uint8((value >> uint32(24)) & uint32(255))
    *(UInt8Ptr(cheng_ptr_plus(out, 1))) = uint8((value >> uint32(16)) & uint32(255))
    *(UInt8Ptr(cheng_ptr_plus(out, 2))) = uint8((value >> uint32(8)) & uint32(255))
    *(UInt8Ptr(cheng_ptr_plus(out, 3))) = uint8(value & uint32(255))

fn cheng_read_u32be(data: ptr): uint32 =
    if data == nil:
        return uint32(0)
    return (uint32(*(UInt8Ptr(data))) << uint32(24)) |
           (uint32(*(UInt8Ptr(cheng_ptr_plus(data, 1)))) << uint32(16)) |
           (uint32(*(UInt8Ptr(cheng_ptr_plus(data, 2)))) << uint32(8)) |
           uint32(*(UInt8Ptr(cheng_ptr_plus(data, 3))))

fn cheng_close_if_open(fd: int32) =
    if fd >= 0:
        libc_close(fd)

fn cheng_send_all(fd: int32, data: ptr, len0: int32): bool =
    if len0 <= 0:
        return true
    if fd < 0 || data == nil:
        return false
    var sent: int32 = 0
    while sent < len0:
        let wrote = libc_send(fd, cheng_ptr_plus(data, sent), len0 - sent, 0)
        if wrote <= 0:
            return false
        sent = sent + wrote
    return true

fn cheng_recv_exact(fd: int32, data: ptr, len0: int32): bool =
    if len0 <= 0:
        return true
    if fd < 0 || data == nil:
        return false
    var received: int32 = 0
    while received < len0:
        let got = libc_recv(fd, cheng_ptr_plus(data, received), len0 - received, chengMsgWaitAll)
        if got <= 0:
            return false
        received = received + got
    return true

fn cheng_write_text_file(pathText: str, content: str): bool =
    let path = cheng_copy_cstring_from_str(pathText)
    if path == nil:
        return false
    let fp = cheng_fopen_write(path)
    cheng_free_export(path)
    if fp == nil:
        return false
    let wrote = libc_fwrite(cheng_str_data(content), 1, cheng_str_len(content), fp)
    let closeRc = libc_fclose(fp)
    return wrote == int64(cheng_str_len(content)) && closeRc == 0

fn cheng_write_ready_port(readyPath: str, boundPort: int32, errWire: var str): bool =
    if cheng_str_len(readyPath) <= 0:
        return true
    let path = cheng_copy_cstring_from_str(readyPath)
    let portText = driver_c_i32_to_str_export(boundPort)
    if path != nil && portText != nil:
        let fp = cheng_fopen_write(path)
        if fp != nil:
            let portLen = cheng_cstrlen_raw(portText)
            let wrote = libc_fwrite(portText, 1, portLen, fp)
            let closeRc = libc_fclose(fp)
            cheng_free_export(path)
            cheng_free_export(portText)
            if wrote == int64(portLen) && closeRc == 0:
                return true
            errWire = cheng_error_with_errno("v3 libp2p tcp: ready path")
            return false
    if path != nil:
        cheng_free_export(path)
    if portText != nil:
        cheng_free_export(portText)
    errWire = cheng_error_with_errno("v3 libp2p tcp: ready path")
    return false

fn cheng_sysctl_read_i64(nameText: str): int64 =
    if cheng_str_len(nameText) <= 0:
        return 0
    let name = cheng_copy_cstring_from_str(nameText)
    if name == nil:
        return 0
    let valueBuf = cheng_malloc_export(int32(sizeof int64))
    let lenBuf = cheng_malloc_export(int32(sizeof int64))
    if valueBuf == nil || lenBuf == nil:
        cheng_free_export(name)
        if valueBuf != nil:
            cheng_free_export(valueBuf)
        if lenBuf != nil:
            cheng_free_export(lenBuf)
        return 0
    cheng_bytes_set(valueBuf, 0, int32(sizeof int64))
    *(Int64Ptr(lenBuf)) = int64(sizeof int64)
    let rc = libc_sysctlbyname(name, valueBuf, lenBuf, nil, 0)
    let value = rc == 0 ? *(Int64Ptr(valueBuf)) : int64(0)
    cheng_free_export(name)
    cheng_free_export(valueBuf)
    cheng_free_export(lenBuf)
    return value

fn cheng_statvfs_query_root(totalBytesOut: Int64Ptr, availableBytesOut: Int64Ptr): bool =
    if totalBytesOut != nil:
        *totalBytesOut = 0
    if availableBytesOut != nil:
        *availableBytesOut = 0
    let root = cheng_string_copy("/", 1)
    if root == nil:
        return false
    var fsInfo: DarwinStatvfs
    let rc = libc_statvfs(root, ptr(&fsInfo))
    cheng_free_export(root)
    if rc != 0:
        return false
    var blockSize: int64 = int64(fsInfo.f_frsize)
    if blockSize <= 0:
        blockSize = int64(fsInfo.f_bsize)
    if blockSize <= 0:
        return false
    let blocks = int64(fsInfo.f_blocks)
    let bavail = int64(fsInfo.f_bavail)
    if totalBytesOut != nil:
        *totalBytesOut = blocks * blockSize
    if availableBytesOut != nil:
        *availableBytesOut = bavail * blockSize
    return true

fn cheng_sha256_u32(x: int64): int64 =
    return x & int64(0xffffffff)

fn cheng_sha256_rotr32(x: int64, n: int32): int64 =
    let v = cheng_sha256_u32(x)
    return cheng_sha256_u32((v >> n) | (v << (32 - n)))

fn cheng_sha256_ch(x: int64, y: int64, z: int64): int64 =
    let xu = cheng_sha256_u32(x)
    let yu = cheng_sha256_u32(y)
    let zu = cheng_sha256_u32(z)
    return cheng_sha256_u32((xu & yu) ^ ((xu ^ int64(0xffffffff)) & zu))

fn cheng_sha256_maj(x: int64, y: int64, z: int64): int64 =
    let xu = cheng_sha256_u32(x)
    let yu = cheng_sha256_u32(y)
    let zu = cheng_sha256_u32(z)
    return cheng_sha256_u32((xu & yu) ^ (xu & zu) ^ (yu & zu))

fn cheng_sha256_big_sigma0(x: int64): int64 =
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 2) ^ cheng_sha256_rotr32(x, 13) ^ cheng_sha256_rotr32(x, 22))

fn cheng_sha256_big_sigma1(x: int64): int64 =
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 6) ^ cheng_sha256_rotr32(x, 11) ^ cheng_sha256_rotr32(x, 25))

fn cheng_sha256_small_sigma0(x: int64): int64 =
    let xu = cheng_sha256_u32(x)
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 7) ^ cheng_sha256_rotr32(x, 18) ^ (xu >> 3))

fn cheng_sha256_small_sigma1(x: int64): int64 =
    let xu = cheng_sha256_u32(x)
    return cheng_sha256_u32(cheng_sha256_rotr32(x, 17) ^ cheng_sha256_rotr32(x, 19) ^ (xu >> 10))

fn cheng_sha256_u32_from_bytes(b0: int32, b1: int32, b2: int32, b3: int32): int64 =
    return (int64(b0) << 24) | (int64(b1) << 16) | (int64(b2) << 8) | int64(b3)

fn cheng_sha256_k(i: int32): int64 =
    case i
    of 0: return cheng_sha256_u32_from_bytes(0x42, 0x8a, 0x2f, 0x98)
    of 1: return cheng_sha256_u32_from_bytes(0x71, 0x37, 0x44, 0x91)
    of 2: return cheng_sha256_u32_from_bytes(0xb5, 0xc0, 0xfb, 0xcf)
