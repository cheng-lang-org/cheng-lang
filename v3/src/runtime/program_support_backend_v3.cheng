@exportc("cheng_v3_system_memory_available_bytes_bridge")
fn cheng_v3_system_memory_available_bytes_bridge_export(): int64 =
    let pageSize = cheng_sysctl_read_i64("vm.pagesize")
    let freeCount = cheng_sysctl_read_i64("vm.page_free_count")
    let inactiveCount = cheng_sysctl_read_i64("vm.page_inactive_count")
    let speculativeCount = cheng_sysctl_read_i64("vm.page_speculative_count")
    if pageSize <= 0:
        return 0
    return (freeCount + inactiveCount + speculativeCount) * pageSize

