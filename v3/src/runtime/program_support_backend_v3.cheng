@exportc("cheng_v3_sha256_word_bridge")
fn cheng_v3_sha256_word_bridge_export(text: str, wordIndex: int32): int64 =
    if wordIndex < 0 || wordIndex >= 4:
        return 0
    let digest = cheng_malloc_export(32)
    if digest == nil:
        return 0
    if !cheng_sha256_digest_into(cheng_str_data(text), cheng_str_len(text), digest):
        cheng_free_export(digest)
        return 0
    let base = wordIndex * 8
    var out: uint64 = uint64(0)
    for i in 0..<8:
        out = (out << uint64(8)) | uint64(*(UInt8Ptr(cheng_ptr_plus(digest, base + i))))
    cheng_free_export(digest)
    return int64(out)

@exportc("cheng_v3_sha256_hex_bridge")
fn cheng_v3_sha256_hex_bridge_export(text: str): str =
    let digest = cheng_malloc_export(32)
    if digest == nil:
        return cheng_str_empty()
    if !cheng_sha256_digest_into(cheng_str_data(text), cheng_str_len(text), digest):
        cheng_free_export(digest)
        return cheng_str_empty()
    let out = driver_c_new_string_export(64)
    if out == nil:
        cheng_free_export(digest)
        return cheng_str_empty()
    for i in 0..<32:
        let value = int32(*(UInt8Ptr(cheng_ptr_plus(digest, i))))
        *(UInt8Ptr(cheng_ptr_plus(out, i * 2))) = cheng_sha256_hex_digit((value >> 4) & 15)
        *(UInt8Ptr(cheng_ptr_plus(out, i * 2 + 1))) = cheng_sha256_hex_digit(value & 15)
    cheng_free_export(digest)
    return cheng_str_view_owned(out, 64)

fn cheng_v3_quote_json_text(text: str): str =
    let textLen = cheng_str_len(text)
    let outRaw = driver_c_new_string_export(textLen * 2 + 2)
    if outRaw == nil:
        return cheng_str_empty()
    var used: int32 = 0
    *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = uint8(34)
    used = used + 1
    for i in 0..<textLen:
        let ch = *(UInt8Ptr(cheng_ptr_plus(cheng_str_data(text), i)))
        if ch == uint8(92):
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = uint8(92)
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used + 1))) = uint8(92)
            used = used + 2
        elif ch == uint8(34):
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = uint8(92)
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used + 1))) = uint8(34)
            used = used + 2
        elif ch == uint8(10):
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = uint8(92)
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used + 1))) = uint8(110)
            used = used + 2
        elif ch == uint8(13):
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = uint8(92)
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used + 1))) = uint8(114)
            used = used + 2
        elif ch == uint8(9):
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = uint8(92)
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used + 1))) = uint8(116)
            used = used + 2
        else:
            *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = ch
            used = used + 1
    *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = uint8(34)
    used = used + 1
    return cheng_str_view_owned(outRaw, used)

