fn cheng_u64_to_string(value0: uint64): ptr =
    let scratch: ptr = cheng_malloc_export(64)
    if scratch == nil:
        return nil
    cheng_bytes_set(scratch, 0, 64)
    var value: uint64 = value0
    var idx: int32 = 63
    if value == uint64(0):
        idx = idx - 1
        *(UInt8Ptr(cheng_ptr_plus(scratch, idx))) = uint8(int32('0'))
    else:
        while value > uint64(0) && idx > 0:
            idx = idx - 1
            *(UInt8Ptr(cheng_ptr_plus(scratch, idx))) = uint8(int32('0') + int32(value % uint64(10)))
            value = value / uint64(10)
