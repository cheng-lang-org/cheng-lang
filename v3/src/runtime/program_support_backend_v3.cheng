@exportc("cheng_v3_relay_provider_open_bridge")
fn cheng_v3_relay_provider_open_bridge_export(serviceKindText: str,
                                              endpointText: str,
                                              regionText: str,
                                              authScopeText: str,
                                              requiresLease: int32): uint64 =
    if cheng_str_len(serviceKindText) <= 0 || cheng_str_len(endpointText) <= 0:
        return uint64(0)
    if cheng_str_equals_cstring(serviceKindText, "none"):
        return uint64(0)
    let runtime = cheng_relay_provider_runtime_new()
    if runtime == nil:
        return uint64(0)
    runtime->serviceKind = cheng_copy_cstring_from_str(serviceKindText)
    runtime->endpoint = cheng_copy_cstring_from_str(endpointText)
    runtime->region = cheng_copy_cstring_from_str(regionText)
    runtime->authScope = cheng_copy_cstring_from_str(authScopeText)
    runtime->requiresLease = requiresLease != 0 ? 1 : 0
    runtime->healthy = 1
    cheng_relay_provider_set_error_cstring(runtime, "")
    let handle = cheng_ffi_handle_register_ptr_export(ptr(runtime))
    if handle == uint64(0):
        cheng_relay_provider_runtime_dispose(runtime)
        return uint64(0)
    return handle

