        return -1
    var start = start0
    if start < 0:
        start = 0
    var i = start
    while i < n:
        if cheng_load_u8(data, i) == target:
            return i
        i = i + 1
    return -1

fn cheng_http_response_status_ok(response: str): bool =
    let data = cheng_str_data(response)
    let n = cheng_str_len(response)
    if data == nil || n < 12:
        return false
    let space = cheng_http_find_char(response, 32, 0)
    if space < 0 || space + 4 > n:
        return false
    let d0 = cheng_load_u8(data, space + 1)
    let d1 = cheng_load_u8(data, space + 2)
    let d2 = cheng_load_u8(data, space + 3)
    if d0 < int32('0') || d0 > int32('9') ||
       d1 < int32('0') || d1 > int32('9') ||
       d2 < int32('0') || d2 > int32('9'):
        return false
    return d0 == int32('2')

fn cheng_http_response_body(response: str): str =
    let data = cheng_str_data(response)
    let n = cheng_str_len(response)
    if data == nil || n <= 0:
        return cheng_str_empty()
    var i: int32 = 0
    while i + 3 < n:
        if cheng_load_u8(data, i) == 13 &&
           cheng_load_u8(data, i + 1) == 10 &&
           cheng_load_u8(data, i + 2) == 13 &&
           cheng_load_u8(data, i + 3) == 10:
            return cheng_str_slice_copy(response, i + 4, n - i - 4)
        i = i + 1
    i = 0
    while i + 1 < n:
        if cheng_load_u8(data, i) == 10 &&
           cheng_load_u8(data, i + 1) == 10:
            return cheng_str_slice_copy(response, i + 2, n - i - 2)
        i = i + 1
    return cheng_str_empty()

fn cheng_http_parse_url(url: str,
                        outHost: var str,
                        outPort: var int32,
                        outPath: var str,
                        outHttps: var bool): bool =
    outHost = cheng_str_empty()
    outPort = 0
    outPath = cheng_str_empty()
    outHttps = false
    let n = cheng_str_len(url)
    if n <= 0:
        return false
    var start = 0
    if cheng_str_has_prefix_cstring(url, "http://"):
        start = 7
        outPort = 80
    elif cheng_str_has_prefix_cstring(url, "https://"):
        start = 8
        outPort = 443
        outHttps = true
    else:
        return false
    let slash = cheng_http_find_char(url, int32('/'), start)
    let authorityEnd = if slash >= 0: slash else: n
    if authorityEnd <= start:
        return false
    let authority = cheng_str_slice_copy(url, start, authorityEnd - start)
    let authorityLen = cheng_str_len(authority)
    if authorityLen <= 0:
        cheng_str_dispose(authority)
        return false
    let authorityData = cheng_str_data(authority)
    var colon = -1
    var i: int32 = 0
    while i < authorityLen:
        let ch = cheng_load_u8(authorityData, i)
        if ch == 91 || ch == 93 || ch == 64:
            cheng_str_dispose(authority)
            return false
        if ch == 58:
            if colon >= 0:
                cheng_str_dispose(authority)
                return false
            colon = i
        i = i + 1
    if colon >= 0:
        if colon <= 0 || colon + 1 >= authorityLen:
            cheng_str_dispose(authority)
            return false
        outHost = cheng_str_slice_copy(authority, 0, colon)
        let portText = cheng_str_slice_copy(authority, colon + 1, authorityLen - colon - 1)
        outPort = cheng_runtime_parse_int32(portText, -1)
        cheng_str_dispose(portText)
        if outPort <= 0 || outPort > 65535:
            cheng_str_dispose(authority)
            cheng_str_dispose(outHost)
            outHost = cheng_str_empty()
            return false
    else:
        outHost = authority
    if slash >= 0:
        outPath = cheng_str_slice_copy(url, slash, n - slash)
    else:
        outPath = cheng_str_copy_cstring("/")
    if cheng_str_len(outHost) <= 0 || cheng_str_len(outPath) <= 0:
        cheng_str_dispose(authority)
        cheng_str_dispose(outHost)
        cheng_str_dispose(outPath)
        outHost = cheng_str_empty()
        outPath = cheng_str_empty()
        return false
    if colon < 0:
        authority = cheng_str_empty()
    cheng_str_dispose(authority)
    return true

fn cheng_http_connect_ipv4(hostText: str, port: int32): int32 =
    if port <= 0 || port > 65535:
        return -1
    let fd = libc_socket(chengTcpAfInet, chengTcpSockStream, chengTcpIpprotoIp)
    if fd < 0:
        return -1
    var connectAddr: ptr = nil
    if cheng_str_len(hostText) <= 0 || cheng_str_equals_cstring(hostText, "localhost"):
        connectAddr = cheng_sockaddr_loopback(port)
    else:
        connectAddr = cheng_sockaddr_ipv4_parse(hostText, port)
    if connectAddr == nil:
        cheng_close_if_open(fd)
        return -1
    if libc_connect(fd, connectAddr, chengSockaddrInLen) != 0:
        cheng_free_export(connectAddr)
        cheng_close_if_open(fd)
        return -1
    cheng_free_export(connectAddr)
    return fd

fn cheng_http_recv_all(fd: int32): str =
    if fd < 0:
        return cheng_str_empty()
    var cap: int32 = 2048
    var out = driver_c_new_string_export(cap)
    if out == nil:
        return cheng_str_empty()
    var used: int32 = 0
    while true:
        if used >= cap:
            let nextCap = cap * 2
            let next = cheng_realloc_export(out, nextCap + 1)
            if next == nil:
                cheng_free_export(out)
                return cheng_str_empty()
            out = next
            cap = nextCap
        let got = libc_recv(fd, cheng_ptr_plus(out, used), cap - used, 0)
        if got < 0:
            cheng_free_export(out)
            return cheng_str_empty()
        if got == 0:
            *(UInt8Ptr(cheng_ptr_plus(out, used))) = uint8(0)
            return cheng_str_view_owned(out, used)
        used = used + got
        *(UInt8Ptr(cheng_ptr_plus(out, used))) = uint8(0)
    return cheng_str_empty()

fn cheng_http_load_endpoint_payload_ex(endpoint: str, outErr: var str): str =
    outErr = cheng_str_empty()
    var host = cheng_str_empty()
    var path = cheng_str_empty()
    var port: int32 = 0
    var isHttps = false
    if !cheng_http_parse_url(endpoint, host, port, path, isHttps):
        outErr = cheng_str_copy_cstring("http probe: invalid url")
        return cheng_str_empty()
    if isHttps:
        outErr = cheng_str_copy_cstring("http probe: https unsupported")
        cheng_str_dispose(host)
        cheng_str_dispose(path)
        return cheng_str_empty()
    let fd = cheng_http_connect_ipv4(host, port)
    if fd < 0:
        outErr = cheng_str_copy_cstring("http probe: connect failed")
        cheng_str_dispose(host)
        cheng_str_dispose(path)
        return cheng_str_empty()
    var request = ""
    request = request + "GET "
    request = request + path
    request = request + " HTTP/1.0\r\n"
    request = request + "Host: "
    request = request + host
    request = request + "\r\n"
    request = request + "Connection: close\r\n"
    request = request + "Accept: application/json\r\n\r\n"
    let sentOk = cheng_send_all(fd, cheng_str_data(request), cheng_str_len(request))
    var response = cheng_str_empty()
    if sentOk:
        response = cheng_http_recv_all(fd)
    cheng_close_if_open(fd)
    cheng_str_dispose(host)
    cheng_str_dispose(path)
    if !sentOk:
        outErr = cheng_str_copy_cstring("http probe: send failed")
        cheng_str_dispose(response)
        return cheng_str_empty()
    if cheng_str_len(response) <= 0:
        outErr = cheng_str_copy_cstring("http probe: recv failed")
        cheng_str_dispose(response)
        return cheng_str_empty()
    if !cheng_http_response_status_ok(response):
        outErr = cheng_str_copy_cstring("http probe: bad status")
        cheng_str_dispose(response)
        return cheng_str_empty()
    let payload = cheng_http_response_body(response)
    cheng_str_dispose(response)
    if cheng_str_len(payload) <= 0:
        outErr = cheng_str_copy_cstring("http probe: missing body")
        return cheng_str_empty()
    outErr = cheng_str_empty()
    return payload

fn cheng_http_load_endpoint_payload(endpoint: str): str =
    var err = cheng_str_empty()
    let payload = cheng_http_load_endpoint_payload_ex(endpoint, err)
    cheng_str_dispose(err)
    return payload

fn cheng_tailnet_load_endpoint_payload(endpoint: str): str =
    var clean = cheng_v3_str_strip_bridge_export(endpoint)
    if cheng_str_len(clean) <= 0:
        return cheng_str_empty()
    var payload = cheng_str_empty()
    if cheng_str_has_prefix_cstring(clean, "file://"):
        var path = cheng_str_slice_copy(clean, 7, cheng_str_len(clean) - 7)
        payload = cheng_read_text_file(path)
        cheng_str_dispose(path)
    elif cheng_str_has_prefix_cstring(clean, "http://") ||
         cheng_str_has_prefix_cstring(clean, "https://"):
        payload = cheng_http_load_endpoint_payload(clean)
    else:
        payload = cheng_read_text_file(clean)
    cheng_str_dispose(clean)
    return payload

fn cheng_tailnet_load_endpoint_payload_cstring(endpoint: ptr): str =
    if endpoint == nil:
        return cheng_str_empty()
    var text = cheng_str_copy_cstring(endpoint)
    let payload = cheng_tailnet_load_endpoint_payload(text)
    cheng_str_dispose(text)
    return payload

fn cheng_tailnet_json_skip_ws(payload: str, idx0: int32): int32 =
    let data = cheng_str_data(payload)
    let n = cheng_str_len(payload)
    var idx = idx0
    while idx < n:
        let ch = cheng_load_u8(data, idx)
        if !cheng_ascii_space(uint8(ch)):
            return idx
        idx = idx + 1
    return idx

fn cheng_tailnet_json_value_after_key(payload: str, key: ptr): int32 =
    let payloadData = cheng_str_data(payload)
    let payloadLen = cheng_str_len(payload)
    let keyLen = cheng_cstrlen_raw(key)
    if payloadData == nil || payloadLen <= 0 || key == nil || keyLen <= 0:
        return -1
    let quote = 34
    let colon = 58
    let limit = payloadLen - keyLen - 2
    var i: int32 = 0
    while i <= limit:
        let ch0 = cheng_load_u8(payloadData, i)
        if ch0 == quote:
            let keyMatch = cheng_bytes_equal(cheng_ptr_plus(payloadData, i + 1), key, keyLen)
            if keyMatch:
                let ch1 = cheng_load_u8(payloadData, i + keyLen + 1)
                if ch1 == quote:
                    var idx = cheng_tailnet_json_skip_ws(payload, i + keyLen + 2)
                    if idx < payloadLen:
                        let sep = cheng_load_u8(payloadData, idx)
                        if sep == colon:
                            idx = cheng_tailnet_json_skip_ws(payload, idx + 1)
                            if idx < payloadLen:
                                return idx
        i = i + 1
    return -1

fn cheng_tailnet_json_bool_term(ch: int32): bool =
    if ch == 0:
        return true
    if ch == 44:
        return true
    if ch == 125:
        return true
    return cheng_ascii_space(uint8(ch))

fn cheng_tailnet_json_match_literal(data: ptr, idx: int32, totalLen: int32, text: ptr): bool =
    let textLen = cheng_cstrlen_raw(text)
    if data == nil || idx < 0 || totalLen < 0 || text == nil || textLen <= 0:
        return false
    if idx + textLen > totalLen:
        return false
    return cheng_bytes_equal(cheng_ptr_plus(data, idx), text, textLen)

fn cheng_tailnet_json_read_bool(payload: str, key: ptr, outValue: var bool): bool =
    let idx = cheng_tailnet_json_value_after_key(payload, key)
    let data = cheng_str_data(payload)
    let n = cheng_str_len(payload)
    outValue = false
    if idx < 0 || data == nil:
        return false
    if cheng_tailnet_json_match_literal(data, idx, n, "true"):
        let endIdx = idx + 4
        if endIdx >= n || cheng_tailnet_json_bool_term(cheng_load_u8(data, endIdx)):
            outValue = true
            return true
    if cheng_tailnet_json_match_literal(data, idx, n, "false"):
        let endIdx = idx + 5
        if endIdx >= n || cheng_tailnet_json_bool_term(cheng_load_u8(data, endIdx)):
            outValue = false
            return true
    return false

fn cheng_tailnet_json_read_string(payload: str, key: ptr, outValue: var str): bool =
    outValue = cheng_str_empty()
    let idx = cheng_tailnet_json_value_after_key(payload, key)
    let data = cheng_str_data(payload)
    let n = cheng_str_len(payload)
    if idx < 0 || data == nil || idx >= n:
        return false
    let quote = 34
    let slash = 92
    if cheng_load_u8(data, idx) != quote:
        return false
    let outRaw = driver_c_new_string_export(n - idx)
    if outRaw == nil:
        return false
    var used: int32 = 0
    var pos = idx + 1
    var ch: int32 = 0
    while pos < n:
        ch = cheng_load_u8(data, pos)
        pos = pos + 1
        if ch == quote:
            outValue = cheng_str_view_owned(outRaw, used)
            return true
        if ch == slash:
            if pos >= n:
                break
            ch = cheng_load_u8(data, pos)
            pos = pos + 1
        *(UInt8Ptr(cheng_ptr_plus(outRaw, used))) = uint8(ch)
        used = used + 1
    cheng_free_export(outRaw)
    return false

fn cheng_tailnet_provider_runtime_new(): ChengV3TailnetProviderRuntimePtr =
    let mem = cheng_malloc_export(int32(sizeof ChengV3TailnetProviderRuntime))
    if mem == nil:
        return nil
    let runtime = ChengV3TailnetProviderRuntimePtr(mem)
    runtime->providerKind = nil
    runtime->controlEndpoint = nil
    runtime->relayEndpoint = nil
    runtime->controlProbeEndpoint = nil
    runtime->relayProbeEndpoint = nil
    runtime->derpRegionCode = nil
    runtime->derpHostname = nil
    runtime->startupStage = cheng_string_copy("init", 4)
    runtime->lastError = nil
    runtime->providerReady = false
    runtime->proxyReady = false
    runtime->listenerNeedsRepair = false
    runtime->derpHealthy = false
    return runtime

fn cheng_tailnet_provider_runtime_dispose(runtime: ChengV3TailnetProviderRuntimePtr) =
    if runtime == nil:
        return
    cheng_free_export(runtime->providerKind)
    cheng_free_export(runtime->controlEndpoint)
    cheng_free_export(runtime->relayEndpoint)
    cheng_free_export(runtime->controlProbeEndpoint)
    cheng_free_export(runtime->relayProbeEndpoint)
    cheng_free_export(runtime->derpRegionCode)
    cheng_free_export(runtime->derpHostname)
    cheng_free_export(runtime->startupStage)
    cheng_free_export(runtime->lastError)
    cheng_free_export(ptr(runtime))

