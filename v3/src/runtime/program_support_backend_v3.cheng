fn cheng_runtime_flag_inline_value(arg: str, key: str, outValue: var str): bool =
    outValue = cheng_str_empty()
    let keyLen = cheng_str_len(key)
    let argLen = cheng_str_len(arg)
    if keyLen <= 0 || argLen <= keyLen:
        return false
    if cheng_bytes_compare(cheng_str_data(arg), cheng_str_data(key), keyLen) != 0:
        return false
    let sep = *(UInt8Ptr(cheng_ptr_plus(cheng_str_data(arg), keyLen)))
    if sep != uint8(int32(':')) && sep != uint8(int32('=')):
        return false
    outValue = cheng_str_copy(cheng_ptr_plus(cheng_str_data(arg), keyLen + 1), argLen - keyLen - 1)
    return true

fn cheng_runtime_parse_int32(text: str, defaultValue: int32): int32 =
    let n = cheng_str_len(text)
    if n <= 0:
        return defaultValue
    let data = cheng_str_data(text)
    if data == nil:
        return defaultValue
    var sign: int64 = 1
    var i: int32 = 0
    if *(UInt8Ptr(data)) == uint8(int32('+')):
        i = 1
    elif *(UInt8Ptr(data)) == uint8(int32('-')):
        sign = -1
        i = 1
    if i >= n:
        return defaultValue
    var value: int64 = 0
    while i < n:
        let ch = *(UInt8Ptr(cheng_ptr_plus(data, i)))
        if ch < uint8(int32('0')) || ch > uint8(int32('9')):
            return defaultValue
        value = value * int64(10) + int64(int32(ch) - int32('0'))
        i = i + 1
    value = value * sign
    if value < int64(-2147483648) || value > int64(2147483647):
        return defaultValue
    return int32(value)

