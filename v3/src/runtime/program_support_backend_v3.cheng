@exportc("cheng_seq_set_grow")
fn cheng_seq_set_grow_export(seqPtr: ptr, idx: int32, elemSize: int32): ptr =
    if seqPtr == nil || elemSize <= 0:
        return nil
    let seqHdr: ChengSeqHeaderPtr = ChengSeqHeaderPtr(seqPtr)
    if seqHdr->len < 0 || seqHdr->cap < 0 || seqHdr->cap < seqHdr->len:
        panic("cheng seq_set_grow: corrupt header")
    if idx < 0:
        return cheng_seq_get_export(seqHdr->buffer, seqHdr->len, idx, elemSize)
    let needLen: int32 = idx + 1
    if needLen > seqHdr->cap || seqHdr->buffer == nil:
        var newCap: int32 = seqHdr->cap
        if newCap < 4:
            newCap = 4
        while newCap < needLen:
            let doubled: int32 = newCap * 2
            if doubled <= 0:
                newCap = needLen
                break
            newCap = doubled
        let oldCap: int32 = seqHdr->cap
        let bytes64: int64 = int64(newCap) * int64(elemSize)
        if bytes64 <= 0 || bytes64 > int64(2147483647):
            panic("cheng seq_set_grow: bytes overflow")
        if bytes64 >= int64(67108864):
            if elemSize == 380:
                panic("cheng seq_set_grow: huge alloc statecell")
            if elemSize == 148:
                panic("cheng seq_set_grow: huge alloc chainevent")
            if elemSize == 136:
                panic("cheng seq_set_grow: huge alloc address")
            if elemSize == 32:
                panic("cheng seq_set_grow: huge alloc fixed32")
            if elemSize == 4:
                panic("cheng seq_set_grow: huge alloc i32")
            panic("cheng seq_set_grow: huge alloc")
        let bytes: int32 = int32(bytes64)
        let newBuf: ptr = cheng_realloc_export(seqHdr->buffer, bytes)
        if newBuf == nil:
            return nil
        if newCap > oldCap:
            cheng_bytes_set(cheng_ptr_plus(newBuf, oldCap * elemSize), 0, (newCap - oldCap) * elemSize)
        seqHdr->buffer = newBuf
        seqHdr->cap = newCap
    if needLen > seqHdr->len:
        seqHdr->len = needLen
    return cheng_seq_get_export(seqHdr->buffer, seqHdr->len, idx, elemSize)

