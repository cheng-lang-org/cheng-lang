@exportc("driver_c_read_flag_or_default_bridge")
fn driver_c_read_flag_or_default_bridge_export(key: str, defaultValue: str): str =
    let count = cheng_runtime_param_count()
    if count <= 1:
        return defaultValue
    var i: int32 = 1
    while i < count:
        let arg = cheng_runtime_param_str(i)
        var inlineValue: str
        if cheng_runtime_flag_inline_value(arg, key, inlineValue):
            return inlineValue
        if cheng_runtime_flag_key_matches(arg, key):
            if i + 1 >= count:
                return defaultValue
            return cheng_runtime_param_str(i + 1)
        i = i + 1
    return defaultValue

@exportc("driver_c_read_flag_value_bridge")
fn driver_c_read_flag_value_bridge_export(key: str, outValue: var str): bool =
    outValue = cheng_str_empty()
