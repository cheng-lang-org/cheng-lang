    return int32(got)

fn cheng_fwrite(buf: ptr, size: int64, n: int64, stream: ptr): int32 =
    let safe = cheng_safe_write_stream(stream)
    if buf == nil || safe == nil || size <= 0 || n <= 0:
        return 0
    let wrote = libc_fwrite(buf, size, n, safe)
    if wrote > 0:
        libc_fflush(safe)
    if wrote <= 0:
        return int32(wrote)
    if wrote > int64(2147483647):
