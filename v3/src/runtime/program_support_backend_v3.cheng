fn cheng_mkdir_all_raw(path: ptr, includeLeaf: bool) =
    if path == nil:
        return
    let n = cheng_cstrlen_raw(path)
    if n <= 0:
        return
    let scratch = cheng_string_copy(path, n)
    if scratch == nil:
        return
    var i: int32 = 0
    while i < n:
        let ch = cheng_load_u8(scratch, i)
        if cheng_path_is_sep(ch):
            if i > 0:
                var skip = false
                if i == 2:
                    if cheng_load_u8(scratch, 1) == 58:
                        skip = true
                if !skip:
                    *(UInt8Ptr(cheng_ptr_plus(scratch, i))) = uint8(0)
                    cheng_mkdir_if_needed(scratch)
                    *(UInt8Ptr(cheng_ptr_plus(scratch, i))) = uint8(ch)
        i = i + 1
    if includeLeaf:
        cheng_mkdir_if_needed(scratch)
    cheng_free_export(scratch)

