    let bindRes: ChengUdpBindResult = cheng_udp_bind_host_port_impl(host, port, isV6 != 0)
    if bindRes.rc != 0:
        return 0 - bindRes.rc
    return bindRes.fd

@exportc("cheng_v3_udp_bound_port_bridge")
fn cheng_v3_udp_bound_port_bridge_export(fd: int32, isV6: int32): int32 =
    if fd < 0:
        return -22
    let rawLenInit: int32 = if isV6 != 0: chengSockaddrIn6Len else: chengSockaddrInLen
    let rawAddr = cheng_malloc_export(rawLenInit)
    if rawAddr == nil:
        return -12
    cheng_bytes_set(rawAddr, 0, rawLenInit)
    var rawLen: int32 = rawLenInit
    if libc_getsockname(fd, rawAddr, &rawLen) != 0:
        let err = cheng_errno_code()
        cheng_free_export(rawAddr)
        return 0 - err
    let port: int32 = cheng_sockaddr_port(rawAddr)
    cheng_free_export(rawAddr)
    return port

@exportc("cheng_v3_udp_recvfrom_addr_bridge")
fn cheng_v3_udp_recvfrom_addr_bridge_export(fd: int32, buf: ptr, len: int32, flags: int32, addr: ptr, addrCap: int32, outAddrLen: var int32, outErr: var int32): int32 =
    outAddrLen = 0
    outErr = 0
    if fd < 0 || buf == nil || len <= 0 || addr == nil || addrCap <= 0:
        return -1
    var rawLen: int32 = addrCap
    let rc: int32 = libc_recvfrom_native(fd, buf, len, flags, addr, &rawLen)
    if rc < 0:
        outErr = cheng_errno_code()
        return rc
    outAddrLen = rawLen
    return rc

@exportc("cheng_v3_udp_platform_use_len_field_bridge")
fn cheng_v3_udp_platform_use_len_field_bridge_export(): int32 =
    return cheng_sockaddr_use_len_field() ? 1 : 0

@exportc("cheng_v3_udp_use_len_field_consistency_bridge")
fn cheng_v3_udp_use_len_field_consistency_bridge_export(): int32 =
    let raw = native_cheng_v3_sockaddr_use_len_field_runtime()
    let ternaryValue = cheng_sockaddr_use_len_field() ? 1 : 0
    var helperBranch = 0
    if cheng_sockaddr_use_len_field():
        helperBranch = 1
    var rawBranch = 0
    if native_cheng_v3_sockaddr_use_len_field_runtime() != 0:
        rawBranch = 1
    return raw + (ternaryValue * 10) + (helperBranch * 100) + (rawBranch * 1000)

@exportc("cheng_v3_udp_platform_msg_dontwait_bridge")
fn cheng_v3_udp_platform_msg_dontwait_bridge_export(): int32 =
    return cheng_sockaddr_use_len_field() ? 128 : 64

@exportc("cheng_v3_udp_ipv4_sockaddr_sanity_bridge")
fn cheng_v3_udp_ipv4_sockaddr_sanity_bridge_export(): int32 =
    let addr = cheng_sockaddr_ipv4_parse("127.0.0.1", 6210)
    if addr == nil:
        return 1
    let b0 = int32(*(UInt8Ptr(cheng_ptr_plus(addr, 0))))
    let b1 = int32(*(UInt8Ptr(cheng_ptr_plus(addr, 1))))
    let b2 = int32(*(UInt8Ptr(cheng_ptr_plus(addr, 2))))
    let b3 = int32(*(UInt8Ptr(cheng_ptr_plus(addr, 3))))
    let b4 = int32(*(UInt8Ptr(cheng_ptr_plus(addr, 4))))
    let b5 = int32(*(UInt8Ptr(cheng_ptr_plus(addr, 5))))
    let b6 = int32(*(UInt8Ptr(cheng_ptr_plus(addr, 6))))
    let b7 = int32(*(UInt8Ptr(cheng_ptr_plus(addr, 7))))
    cheng_free_export(addr)
    if b0 != 2:
        return 10 + b0
    if b1 != 0:
        return 20 + b1
    if b2 != ((6210 >> 8) & 255):
        return 30 + b2
    if b3 != (6210 & 255):
        return 40 + b3
    if b4 != 127:
        return 50 + b4
    if b5 != 0:
        return 60 + b5
    if b6 != 0:
        return 70 + b6
    if b7 != 1:
        return 80 + b7
    return 0

@exportc("cheng_v3_udp_ipv4_sockaddr_byte_bridge")
