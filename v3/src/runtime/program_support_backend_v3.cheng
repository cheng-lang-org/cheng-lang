        cheng_str_dispose(errWire)
        return uint64(0)
    let runtimeRaw = cheng_ffi_handle_resolve_ptr_export(handle)
    let runtime = ChengV3WebrtcBrowserSessionStatePtr(runtimeRaw)
    cheng_str_dispose(runtime->signalWire)
    runtime->signalWire = cheng_str_dup(signalResponseWire)
    if cheng_str_len(signalResponseWire) == 0 || cheng_str_len(runtime->signalWire) != cheng_str_len(signalResponseWire):
        var closeErr = cheng_str_empty()
        let closeOk = cheng_v3_webrtc_browser_session_close_bridge_export(handle, closeErr)
        closeOk
        if cheng_str_len(closeErr) > 0:
