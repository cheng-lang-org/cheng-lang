fn cheng_bounds_check_export(len: int32, idx: int32) =
    if idx < 0 || idx >= len:
        let msg: ptr = cheng_bounds_failure_message(len, idx)
        if msg != nil:
            cheng_stderr_write_line_cstr(msg)
