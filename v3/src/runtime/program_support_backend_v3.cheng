fn cheng_ascii_space(ch: uint8): bool =
    if ch == uint8(32):
        return true
    if ch == uint8(9):
        return true
    if ch == uint8(10):
        return true
    if ch == uint8(13):
        return true
    if ch == uint8(12):
        return true
    if ch == uint8(11):
        return true
    return false

@exportc("cheng_v3_str_strip_bridge")
fn cheng_v3_str_strip_bridge_export(s: str): str =
    let data: ptr = cheng_str_data(s)
    let n: int32 = cheng_str_len(s)
    if data == nil || n <= 0:
        return cheng_str_empty()
    var start: int32 = 0
    var stop: int32 = n
    while start < n && cheng_ascii_space(*(UInt8Ptr(cheng_ptr_plus(data, start)))):
        start = start + 1
    while stop > start && cheng_ascii_space(*(UInt8Ptr(cheng_ptr_plus(data, stop - 1)))):
        stop = stop - 1
    return cheng_str_copy(cheng_ptr_plus(data, start), stop - start)

@exportc("cheng_v3_os_is_absolute_bridge")
