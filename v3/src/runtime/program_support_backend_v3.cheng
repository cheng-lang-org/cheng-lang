        else:
            var signalAllocErr = v3WebrtcErrBrowserSignalAllocFailed
            cheng_webrtc_last_error_set(signalAllocErr)
        cheng_str_dispose(signalResponseWire)
        cheng_str_dispose(errWire)
        cheng_str_dispose(closeErr)
        return uint64(0)
    cheng_webrtc_last_error_clear()
    cheng_str_dispose(signalResponseWire)
    cheng_str_dispose(errWire)
    return handle

