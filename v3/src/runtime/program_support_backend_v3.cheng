@exportc("driver_c_i32_to_str")
fn driver_c_i32_to_str_export(value: int32): ptr =
    if value >= 0:
        return cheng_u64_to_string(uint64(value))
    let mag: uint64 = uint64(-(int64(value)))
    let digits: ptr = cheng_u64_to_string(mag)
    if digits == nil:
        return nil
    let lenDigits: int32 = cheng_cstrlen_raw(digits)
    let out: ptr = driver_c_new_string_export(lenDigits + 1)
    if out == nil:
        return nil
    *(UInt8Ptr(out)) = uint8(int32('-'))
    if lenDigits > 0:
