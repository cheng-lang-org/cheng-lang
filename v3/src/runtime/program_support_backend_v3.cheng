    clientResponseWire = cheng_str_empty()
    errWire = cheng_str_empty()
    if cheng_str_len(protocolText) == 0:
        return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: missing protocol selection")
    requestWire
    var handleErr = ""
    var handleSignal = ""
    let handle = cheng_v3_webrtc_browser_session_open_bridge_export(policyWire,
                                                                    labelText,
                                                                    handleSignal,
                                                                    handleErr)
    if handle == uint64(0):
        if cheng_str_len(handleErr) == 0:
            return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: session open failed")
        errWire = handleErr
        return 0
    signalResponseWire = handleSignal
    let ok = cheng_v3_webrtc_browser_session_exchange_bridge_export(handle,
                                                                    protocolText,
                                                                    requestWire,
                                                                    responseWire,
                                                                    clientResponseWire,
                                                                    errWire)
    var closeErr = ""
    let closeOk = cheng_v3_webrtc_browser_session_close_bridge_export(handle, closeErr)
    if ok == 0:
        return 0
    if closeOk == 0:
        if cheng_str_len(closeErr) == 0:
            return cheng_webrtc_error(errWire, "v3 libp2p webrtc browser: session close failed")
        errWire = closeErr
        return 0
    errWire = cheng_str_empty()
    return 1

