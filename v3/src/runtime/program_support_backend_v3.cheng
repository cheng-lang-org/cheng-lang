        signalResponseWire = cheng_str_empty()
        return uint64(0)
    cheng_webrtc_browser_session_active_count = cheng_webrtc_browser_session_active_count + 1
    return handle

@exportc("cheng_v3_webrtc_browser_session_open_handle_bridge")
fn cheng_v3_webrtc_browser_session_open_handle_bridge_export(policyText: str,
                                                             labelText: str): uint64 =
