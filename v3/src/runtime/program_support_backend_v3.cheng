    let payloadData = cheng_str_data(payload)
    let payloadLen = cheng_str_len(payload)
    let keyLen = cheng_cstrlen_raw(key)
    if payloadData == nil || payloadLen <= 0 || key == nil || keyLen <= 0:
        return -1
    var i: int32 = 0
    while i + keyLen + 2 <= payloadLen:
        if *(UInt8Ptr(cheng_ptr_plus(payloadData, i))) == uint8(int32('"')) &&
           cheng_bytes_equal(cheng_ptr_plus(payloadData, i + 1), key, keyLen) &&
           *(UInt8Ptr(cheng_ptr_plus(payloadData, i + keyLen + 1))) == uint8(int32('"')):
            var idx = cheng_tailnet_json_skip_ws(payload, i + keyLen + 2)
            if idx < payloadLen &&
               *(UInt8Ptr(cheng_ptr_plus(payloadData, idx))) == uint8(int32(':')):
                idx = cheng_tailnet_json_skip_ws(payload, idx + 1)
                if idx < payloadLen:
                    return idx
        i = i + 1
    return -1

