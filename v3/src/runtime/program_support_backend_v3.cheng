@exportc("cheng_v3_tcp_loopback_request_response_bridge")
fn cheng_v3_tcp_loopback_request_response_bridge_export(protocolText: str,
                                                        requestWire: str,
                                                        responseWire: str,
                                                        clientResponseWire: var str,
                                                        errWire: var str): int32 =
    clientResponseWire = cheng_str_empty()
    errWire = cheng_str_empty()
    var listenerFd: int32 = -1
    var clientFd: int32 = -1
    var serverFd: int32 = -1
    let listenerAddr = cheng_sockaddr_loopback(0)
    let clientAddr = cheng_sockaddr_loopback(0)
    let addrLenMem = cheng_malloc_export(int32(sizeof int32))
    let frameBuf = cheng_malloc_export(4)
    var protocolBuf: ptr = nil
    var protocolEcho: ptr = nil
    var requestBuf: ptr = nil
    var responseBuf: ptr = nil
    if listenerAddr == nil || clientAddr == nil || addrLenMem == nil || frameBuf == nil:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
    if cheng_str_len(errWire) == 0:
        listenerFd = libc_socket(chengAfInet, chengSockStream, chengIpProtoIp)
        if listenerFd < 0:
            errWire = cheng_error_with_errno("v3 libp2p tcp: socket")
    if cheng_str_len(errWire) == 0:
        let reuse: int32 = 1
        libc_setsockopt(listenerFd, chengSolSocket, chengSoReuseAddr, ptr(&reuse), int32(sizeof int32))
        if libc_bind(listenerFd, listenerAddr, chengSockaddrInLen) != 0:
            errWire = cheng_error_with_errno("v3 libp2p tcp: bind")
    if cheng_str_len(errWire) == 0 && libc_listen(listenerFd, 8) != 0:
        errWire = cheng_error_with_errno("v3 libp2p tcp: listen")
    if cheng_str_len(errWire) == 0:
        *(Int32Ptr(addrLenMem)) = chengSockaddrInLen
        if libc_getsockname(listenerFd, listenerAddr, addrLenMem) != 0:
            errWire = cheng_error_with_errno("v3 libp2p tcp: getsockname")
    if cheng_str_len(errWire) == 0:
        *(UInt8Ptr(cheng_ptr_plus(clientAddr, 2))) = *(UInt8Ptr(cheng_ptr_plus(listenerAddr, 2)))
        *(UInt8Ptr(cheng_ptr_plus(clientAddr, 3))) = *(UInt8Ptr(cheng_ptr_plus(listenerAddr, 3)))
        clientFd = libc_socket(chengAfInet, chengSockStream, chengIpProtoIp)
        if clientFd < 0:
            errWire = cheng_error_with_errno("v3 libp2p tcp: client socket")
    if cheng_str_len(errWire) == 0 && libc_connect(clientFd, clientAddr, chengSockaddrInLen) != 0:
        errWire = cheng_error_with_errno("v3 libp2p tcp: connect")
    if cheng_str_len(errWire) == 0:
        serverFd = libc_accept(listenerFd, nil, nil)
        if serverFd < 0:
            errWire = cheng_error_with_errno("v3 libp2p tcp: accept")
    if cheng_str_len(errWire) == 0 && cheng_str_len(protocolText) > 0:
        let protocolLen = cheng_str_len(protocolText)
        protocolBuf = cheng_malloc_export(protocolLen)
        protocolEcho = cheng_malloc_export(protocolLen)
        if protocolBuf == nil || protocolEcho == nil:
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
        elif !cheng_send_all(clientFd, cheng_str_data(protocolText), protocolLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: send request")
        elif !cheng_recv_exact(serverFd, protocolBuf, protocolLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: recv request")
        elif !cheng_bytes_equal(protocolBuf, cheng_str_data(protocolText), protocolLen):
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: multistream request mismatch")
        elif !cheng_send_all(serverFd, cheng_str_data(protocolText), protocolLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: send response")
        elif !cheng_recv_exact(clientFd, protocolEcho, protocolLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: recv response")
        elif !cheng_bytes_equal(protocolEcho, cheng_str_data(protocolText), protocolLen):
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: multistream response mismatch")
    if cheng_str_len(errWire) == 0:
        cheng_write_u32be(frameBuf, uint32(cheng_str_len(requestWire)))
        if !cheng_send_all(clientFd, frameBuf, 4):
            errWire = cheng_error_with_errno("v3 libp2p tcp: send request len")
        elif cheng_str_len(requestWire) > 0 &&
             !cheng_send_all(clientFd, cheng_str_data(requestWire), cheng_str_len(requestWire)):
            errWire = cheng_error_with_errno("v3 libp2p tcp: send request payload")
        elif !cheng_recv_exact(serverFd, frameBuf, 4):
            errWire = cheng_error_with_errno("v3 libp2p tcp: recv request len")
    let requestLen = int32(cheng_read_u32be(frameBuf))
    if cheng_str_len(errWire) == 0 && requestLen != cheng_str_len(requestWire):
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: request payload length mismatch")
    if cheng_str_len(errWire) == 0 && requestLen > 0:
        requestBuf = cheng_malloc_export(requestLen)
        if requestBuf == nil:
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
        elif !cheng_recv_exact(serverFd, requestBuf, requestLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: recv request payload")
        elif !cheng_bytes_equal(requestBuf, cheng_str_data(requestWire), requestLen):
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: request payload mismatch")
    if cheng_str_len(errWire) == 0:
        cheng_write_u32be(frameBuf, uint32(cheng_str_len(responseWire)))
        if !cheng_send_all(serverFd, frameBuf, 4):
            errWire = cheng_error_with_errno("v3 libp2p tcp: send response len")
        elif cheng_str_len(responseWire) > 0 &&
             !cheng_send_all(serverFd, cheng_str_data(responseWire), cheng_str_len(responseWire)):
            errWire = cheng_error_with_errno("v3 libp2p tcp: send response payload")
        elif !cheng_recv_exact(clientFd, frameBuf, 4):
            errWire = cheng_error_with_errno("v3 libp2p tcp: recv response len")
    let responseLen = int32(cheng_read_u32be(frameBuf))
    if cheng_str_len(errWire) == 0 && responseLen > 0:
        responseBuf = cheng_malloc_export(responseLen)
        if responseBuf == nil:
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
        elif !cheng_recv_exact(clientFd, responseBuf, responseLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: recv response payload")
    if cheng_str_len(errWire) == 0:
        clientResponseWire = cheng_str_copy(responseBuf, responseLen)
    if protocolBuf != nil:
        cheng_free_export(protocolBuf)
    if protocolEcho != nil:
        cheng_free_export(protocolEcho)
    if requestBuf != nil:
        cheng_free_export(requestBuf)
    if responseBuf != nil:
        cheng_free_export(responseBuf)
    if frameBuf != nil:
        cheng_free_export(frameBuf)
    if addrLenMem != nil:
        cheng_free_export(addrLenMem)
    if clientAddr != nil:
        cheng_free_export(clientAddr)
    if listenerAddr != nil:
        cheng_free_export(listenerAddr)
    cheng_close_if_open(serverFd)
    cheng_close_if_open(clientFd)
    cheng_close_if_open(listenerFd)
    return cheng_str_len(errWire) == 0 ? 1 : 0

@exportc("cheng_v3_tcp_loopback_payload_bridge")
fn cheng_v3_tcp_loopback_payload_bridge_export(protocolText: str,
                                               payloadWire: str,
                                               responseWire: var str,
                                               errWire: var str): int32 =
    return cheng_v3_tcp_loopback_request_response_bridge_export(protocolText,
                                                                payloadWire,
                                                                payloadWire,
                                                                responseWire,
                                                                errWire)

@exportc("cheng_v3_tcp_serve_payload_once_bridge")
fn cheng_v3_tcp_serve_payload_once_bridge_export(hostText: str,
                                                 port: int32,
                                                 protocolText: str,
                                                 payloadWire: str,
                                                 readyPath: str,
                                                 errWire: var str): int32 =
    errWire = cheng_str_empty()
    var listenerFd: int32 = -1
    var serverFd: int32 = -1
    let bindAddr = cheng_sockaddr_ipv4_parse(hostText, port)
    let addrLenMem = cheng_malloc_export(int32(sizeof int32))
    let frameBuf = cheng_malloc_export(4)
    var protocolBuf: ptr = nil
    if port < 0 || port > 65535:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: invalid port")
    if cheng_str_len(errWire) == 0 && bindAddr == nil:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: invalid host")
    if cheng_str_len(errWire) == 0 && (addrLenMem == nil || frameBuf == nil):
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
    if cheng_str_len(errWire) == 0:
        listenerFd = libc_socket(chengAfInet, chengSockStream, chengIpProtoIp)
        if listenerFd < 0:
            errWire = cheng_error_with_errno("v3 libp2p tcp: socket")
    if cheng_str_len(errWire) == 0:
        let reuse: int32 = 1
        libc_setsockopt(listenerFd, chengSolSocket, chengSoReuseAddr, ptr(&reuse), int32(sizeof int32))
        if libc_bind(listenerFd, bindAddr, chengSockaddrInLen) != 0:
            errWire = cheng_error_with_errno("v3 libp2p tcp: bind")
    if cheng_str_len(errWire) == 0 && libc_listen(listenerFd, 8) != 0:
        errWire = cheng_error_with_errno("v3 libp2p tcp: listen")
    if cheng_str_len(errWire) == 0:
        *(Int32Ptr(addrLenMem)) = chengSockaddrInLen
        if libc_getsockname(listenerFd, bindAddr, addrLenMem) != 0:
            errWire = cheng_error_with_errno("v3 libp2p tcp: getsockname")
    if cheng_str_len(errWire) == 0:
        let boundPort = cheng_sockaddr_port(bindAddr)
        let readyOk = cheng_write_ready_port(readyPath, boundPort, errWire)
        readyOk
    if cheng_str_len(errWire) == 0:
        serverFd = libc_accept(listenerFd, nil, nil)
        if serverFd < 0:
            errWire = cheng_error_with_errno("v3 libp2p tcp: accept")
    if cheng_str_len(errWire) == 0 && cheng_str_len(protocolText) > 0:
        let protocolLen = cheng_str_len(protocolText)
        protocolBuf = cheng_malloc_export(protocolLen)
        if protocolBuf == nil:
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
        elif !cheng_recv_exact(serverFd, protocolBuf, protocolLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: recv request")
        elif !cheng_bytes_equal(protocolBuf, cheng_str_data(protocolText), protocolLen):
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: multistream request mismatch")
        elif !cheng_send_all(serverFd, cheng_str_data(protocolText), protocolLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: send response")
    if cheng_str_len(errWire) == 0:
        cheng_write_u32be(frameBuf, uint32(cheng_str_len(payloadWire)))
        if !cheng_send_all(serverFd, frameBuf, 4):
            errWire = cheng_error_with_errno("v3 libp2p tcp: send frame len")
        elif cheng_str_len(payloadWire) > 0 &&
             !cheng_send_all(serverFd, cheng_str_data(payloadWire), cheng_str_len(payloadWire)):
            errWire = cheng_error_with_errno("v3 libp2p tcp: send payload")
    if protocolBuf != nil:
        cheng_free_export(protocolBuf)
    if frameBuf != nil:
        cheng_free_export(frameBuf)
    if addrLenMem != nil:
        cheng_free_export(addrLenMem)
    if bindAddr != nil:
        cheng_free_export(bindAddr)
    cheng_close_if_open(serverFd)
    cheng_close_if_open(listenerFd)
    return cheng_str_len(errWire) == 0 ? 1 : 0

@exportc("cheng_v3_tcp_recv_payload_once_bridge")
fn cheng_v3_tcp_recv_payload_once_bridge_export(hostText: str,
                                                port: int32,
                                                protocolText: str,
                                                responseWire: var str,
                                                errWire: var str): int32 =
    responseWire = cheng_str_empty()
    errWire = cheng_str_empty()
    var clientFd: int32 = -1
    let connectAddr = cheng_sockaddr_ipv4_parse(hostText, port)
    let frameBuf = cheng_malloc_export(4)
    var protocolBuf: ptr = nil
    var payloadBuf: ptr = nil
    if port < 0 || port > 65535:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: invalid port")
    if cheng_str_len(errWire) == 0 && connectAddr == nil:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: invalid host")
    if cheng_str_len(errWire) == 0 && frameBuf == nil:
        errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
    if cheng_str_len(errWire) == 0:
        clientFd = libc_socket(chengAfInet, chengSockStream, chengIpProtoIp)
        if clientFd < 0:
            errWire = cheng_error_with_errno("v3 libp2p tcp: client socket")
    if cheng_str_len(errWire) == 0 && libc_connect(clientFd, connectAddr, chengSockaddrInLen) != 0:
        errWire = cheng_error_with_errno("v3 libp2p tcp: connect")
    if cheng_str_len(errWire) == 0 && cheng_str_len(protocolText) > 0:
        let protocolLen = cheng_str_len(protocolText)
        protocolBuf = cheng_malloc_export(protocolLen)
        if protocolBuf == nil:
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
        elif !cheng_send_all(clientFd, cheng_str_data(protocolText), protocolLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: send request")
        elif !cheng_recv_exact(clientFd, protocolBuf, protocolLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: recv response")
        elif !cheng_bytes_equal(protocolBuf, cheng_str_data(protocolText), protocolLen):
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: multistream response mismatch")
    if cheng_str_len(errWire) == 0 && !cheng_recv_exact(clientFd, frameBuf, 4):
        errWire = cheng_error_with_errno("v3 libp2p tcp: recv frame len")
    let payloadLen = int32(cheng_read_u32be(frameBuf))
    if cheng_str_len(errWire) == 0 && payloadLen > 0:
        payloadBuf = cheng_malloc_export(payloadLen)
        if payloadBuf == nil:
            errWire = cheng_str_copy_cstring("v3 libp2p tcp: alloc failed")
        elif !cheng_recv_exact(clientFd, payloadBuf, payloadLen):
            errWire = cheng_error_with_errno("v3 libp2p tcp: recv payload")
    if cheng_str_len(errWire) == 0:
        responseWire = cheng_str_copy(payloadBuf, payloadLen)
    if payloadBuf != nil:
        cheng_free_export(payloadBuf)
    if protocolBuf != nil:
        cheng_free_export(protocolBuf)
    if frameBuf != nil:
        cheng_free_export(frameBuf)
    if connectAddr != nil:
        cheng_free_export(connectAddr)
    cheng_close_if_open(clientFd)
    return cheng_str_len(errWire) == 0 ? 1 : 0

@exportc("cheng_v3_tailnet_provider_open_bridge")
fn cheng_v3_tailnet_provider_open_bridge_export(providerKindText: str,
                                                controlEndpointText: str,
                                                relayEndpointText: str,
                                                controlProbeEndpointText: str,
                                                relayProbeEndpointText: str,
                                                derpRegionCodeText: str,
                                                derpHostnameText: str): uint64 =
    let runtime = cheng_tailnet_provider_runtime_new()
    if runtime == nil:
        return uint64(0)
    runtime->providerKind = cheng_str_dup(providerKindText)
    runtime->controlEndpoint = cheng_str_dup(controlEndpointText)
    runtime->relayEndpoint = cheng_str_dup(relayEndpointText)
    runtime->controlProbeEndpoint = cheng_str_dup(controlProbeEndpointText)
    runtime->relayProbeEndpoint = cheng_str_dup(relayProbeEndpointText)
    runtime->derpRegionCode = cheng_str_dup(derpRegionCodeText)
    runtime->derpHostname = cheng_str_dup(derpHostnameText)
    let handle = cheng_ffi_handle_register_ptr_export(ptr(runtime))
    if handle == uint64(0):
        cheng_tailnet_provider_runtime_dispose(runtime)
        return uint64(0)
    cheng_tailnet_provider_active_count = cheng_tailnet_provider_active_count + 1
    return handle

@exportc("cheng_v3_tailnet_provider_command_bridge")
fn cheng_v3_tailnet_provider_command_bridge_export(handle: uint64, commandText: str): int32 =
    let runtimeRaw = cheng_ffi_handle_resolve_ptr_export(handle)
    if runtimeRaw == nil:
        return -1
    let runtime = ChengV3TailnetProviderRuntimePtr(runtimeRaw)
    cheng_tailnet_provider_command_count = cheng_tailnet_provider_command_count + 1
    if cheng_str_equals_cstring(commandText, "provider-start"):
        if cheng_tailnet_provider_is_headscale(runtime):
            return cheng_tailnet_provider_sync_control(runtime) ? 0 : -1
        runtime->providerReady = true
        runtime->proxyReady = false
        runtime->listenerNeedsRepair = false
        cheng_tailnet_provider_set_stage_cstring(runtime, "provider-started")
        cheng_tailnet_provider_set_error_cstring(runtime, "")
        return 0
    if cheng_str_equals_cstring(commandText, "proxy-ready"):
        if cheng_tailnet_provider_is_headscale(runtime):
            return cheng_tailnet_provider_sync_control(runtime) ? 0 : -1
        runtime->providerReady = true
        runtime->proxyReady = true
        runtime->listenerNeedsRepair = false
        cheng_tailnet_provider_set_stage_cstring(runtime, "proxy-ready")
        cheng_tailnet_provider_set_error_cstring(runtime, "")
        return 0
    if cheng_str_equals_cstring(commandText, "repair-needed"):
        runtime->providerReady = true
        runtime->proxyReady = false
        runtime->listenerNeedsRepair = true
        cheng_tailnet_provider_set_stage_cstring(runtime, "repair-needed")
        cheng_tailnet_provider_set_error_cstring(runtime, "")
        return 0
    if cheng_str_equals_cstring(commandText, "repair-listeners"):
        if cheng_tailnet_provider_is_headscale(runtime):
            return cheng_tailnet_provider_sync_control(runtime) ? 0 : -1
        runtime->providerReady = true
        runtime->proxyReady = true
        runtime->listenerNeedsRepair = false
        cheng_tailnet_provider_set_stage_cstring(runtime, "repair-complete")
        cheng_tailnet_provider_set_error_cstring(runtime, "")
        return 0
    if cheng_str_equals_cstring(commandText, "derp-reconnect"):
        runtime->derpHealthy = false
        cheng_tailnet_provider_set_stage_cstring(runtime, "derp-reconnect")
        cheng_tailnet_provider_set_error_cstring(runtime, "")
        return 0
    if cheng_str_equals_cstring(commandText, "derp-ready"):
        if cheng_tailnet_provider_is_headscale(runtime):
            return cheng_tailnet_provider_sync_derp(runtime) ? 0 : -1
        runtime->derpHealthy = true
        cheng_tailnet_provider_set_stage_cstring(runtime, "derp-ready")
        cheng_tailnet_provider_set_error_cstring(runtime, "")
        return 0
    return -1

@exportc("cheng_v3_tailnet_provider_close_bridge")
fn cheng_v3_tailnet_provider_close_bridge_export(handle: uint64): int32 =
    let runtimeRaw = cheng_ffi_handle_resolve_ptr_export(handle)
    if runtimeRaw == nil:
        return -1
    let runtime = ChengV3TailnetProviderRuntimePtr(runtimeRaw)
    if cheng_ffi_handle_invalidate_export(handle) != 0:
        return -1
    cheng_tailnet_provider_runtime_dispose(runtime)
    if cheng_tailnet_provider_active_count > 0:
        cheng_tailnet_provider_active_count = cheng_tailnet_provider_active_count - 1
    return 0

@exportc("cheng_v3_tailnet_provider_active_count_bridge")
fn cheng_v3_tailnet_provider_active_count_bridge_export(): int32 =
    return cheng_tailnet_provider_active_count

@exportc("cheng_v3_tailnet_provider_command_count_bridge")
fn cheng_v3_tailnet_provider_command_count_bridge_export(): int32 =
    return cheng_tailnet_provider_command_count

