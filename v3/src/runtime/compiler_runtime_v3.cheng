import cheng/v3/tooling/path as v3path

type
    V3CompilerRuntimeTrack = enum
        v3CompilerRuntimeTrackProgram
        v3CompilerRuntimeTrackTooling

    V3CompilerRuntimeContract =
        version: str
        services: str[]
        providerNativeSources: str[]
        executionModel: str
        traceSymbol: str
        entryTrack: V3CompilerRuntimeTrack

fn v3CompilerRuntimeProgramArgvTarget(): str =
    return "runtime/compiler.program_argv_entry"

fn v3CompilerRuntimeToolingArgvTarget(): str =
    return "runtime/compiler.tooling_argv_entry"

fn v3CompilerRuntimeContract(rootDir: str, track: V3CompilerRuntimeTrack): V3CompilerRuntimeContract =
    if track == v3CompilerRuntimeTrackTooling:
        return V3CompilerRuntimeContract(
            version: "v3.runtime.compiler.v1",
            services: [v3CompilerRuntimeToolingArgvTarget()],
            providerNativeSources: [
                v3path.v3PathAbsolute(rootDir, "v3/runtime/native/v3_tooling_argv_native.c")
            ],
            executionModel: "native_tooling_argv_bridge",
            traceSymbol: "cheng_v3_tooling_argv_entry",
            entryTrack: v3CompilerRuntimeTrackTooling
        )
    return V3CompilerRuntimeContract(
        version: "v3.runtime.compiler.v1",
        services: [v3CompilerRuntimeProgramArgvTarget()],
        providerNativeSources: [
            v3path.v3PathAbsolute(rootDir, "v3/runtime/native/v3_program_argv_native.c")
        ],
        executionModel: "native_program_argv_bridge",
        traceSymbol: "cheng_v3_program_argv_entry",
        entryTrack: v3CompilerRuntimeTrackProgram
    )

fn v3CompilerRuntimeTargetsForTrack(rootDir: str, track: V3CompilerRuntimeTrack): str[] =
    return v3CompilerRuntimeContract(rootDir, track).services
