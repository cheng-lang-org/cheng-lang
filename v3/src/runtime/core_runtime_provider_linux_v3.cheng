@importc("cheng_host_statfs")
fn libc_statfs(path: ptr, out: ptr): int32

const
    chengStrFlagOwned: int32 = 1

type
    str =
        data: ptr
        len: int32
        store_id: int32
        flags: int32
    UInt8Ptr = uint8 *
    Int32Ptr = int32 *
    ChengLinuxSysinfo =
        uptime: int64
        load0: uint64
        load1: uint64
        load2: uint64
        totalram: uint64
        freeram: uint64
        sharedram: uint64
        bufferram: uint64
        totalswap: uint64
        freeswap: uint64
        procs: uint16
        pad: uint16
        totalhigh: uint64
        freehigh: uint64
        memUnit: uint32
    ChengLinuxStatfs =
        fType: int64
        fBsize: int64
        fBlocks: int64
        fBfree: int64
        fBavail: int64
        fFiles: int64
        fFfree: int64
        fFsid0: int32
        fFsid1: int32
        fNamelen: int64
        fFrsize: int64
        fFlags: int64
        fSpare0: int64
        fSpare1: int64
        fSpare2: int64
        fSpare3: int64

fn cheng_ptr_plus(base: ptr, off: int32): ptr =
    if base == nil:
        return nil
    return ptr(uint64(base) + uint64(off))

fn cheng_bytes_copy(dst: ptr, src: ptr, n0: int32) =
    if dst == nil || src == nil || n0 <= 0:
        return
    for i in 0..<n0:
        *(UInt8Ptr(cheng_ptr_plus(dst, i))) = *(UInt8Ptr(cheng_ptr_plus(src, i)))

fn cheng_bytes_set(dst: ptr, value: int32, n0: int32) =
    if dst == nil || n0 <= 0:
        return
    let v: uint8 = uint8(value & 255)
    for i in 0..<n0:
        *(UInt8Ptr(cheng_ptr_plus(dst, i))) = v

fn cheng_cstrlen_raw(s: ptr): int32 =
    if s == nil:
        return 0
    var n: int32 = 0
    while *(UInt8Ptr(cheng_ptr_plus(s, n))) != uint8(0):
        n = n + 1
    return n

fn cheng_string_copy(raw: ptr, n0: int32): ptr =
    var n: int32 = n0
    if n < 0:
        n = 0
    let out: ptr = cheng_runtime_malloc(n + 1)
    if out == nil:
        return nil
    cheng_bytes_set(out, 0, n + 1)
    if raw != nil && n > 0:
        cheng_bytes_copy(out, raw, n)
    return out

fn cheng_str_empty(): str =
    var out: str
    out.data = nil
    out.len = 0
    out.store_id = 0
    out.flags = 0
    return out

fn cheng_str_view_owned(data: ptr, len0: int32): str =
    var out: str
    if data == nil || len0 <= 0:
        return out
    out.data = data
    out.len = len0
    out.store_id = 0
    out.flags = chengStrFlagOwned
    return out

fn cheng_str_copy(raw: ptr, n: int32): str =
    let outRaw: ptr = cheng_string_copy(raw, n)
    if outRaw == nil:
        return cheng_str_empty()
    return cheng_str_view_owned(outRaw, n)

fn cheng_str_copy_cstring(raw: ptr): str =
    return cheng_str_copy(raw, cheng_cstrlen_raw(raw))

fn cheng_u64_mul_checked(a: uint64, b: uint64): int64 =
    if a == uint64(0) || b == uint64(0):
        return 0
    if a > uint64(9223372036854775807) / b:
        return 0
    return int64(a * b)

