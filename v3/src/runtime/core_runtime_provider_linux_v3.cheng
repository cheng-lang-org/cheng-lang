@exportc("cheng_v3_native_system_memory_total_bytes_value_bridge")
fn cheng_v3_native_system_memory_total_bytes_value_bridge_export(): int64 =
    var info: ChengLinuxSysinfo
    if libc_sysinfo(&info) != 0:
        return 0
    let unit: uint64 = info.memUnit <= uint32(0) ? uint64(1) : uint64(info.memUnit)
    return cheng_u64_mul_checked(info.totalram, unit)

