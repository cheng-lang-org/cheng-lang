type
    V3DebugRuntimeContract =
        version: str
        services: str[]
        providerNativeSources: str[]
        executionModel: str
        traceSymbol: str

fn v3DebugRuntimePath(rootDir: str, rel: str): str =
    if rootDir == "":
        return rel
    if rel == "":
        return rootDir
    if rootDir[rootDir.len - 1] == '/':
        return rootDir + rel
    return rootDir + "/" + rel

fn v3DebugRuntimeProviderSourcePath(rootDir: str): str =
    return v3DebugRuntimePath(rootDir, "v3/src/runtime/debug_runtime_stub_v3.cheng")

fn v3DebugRuntimeContract(rootDir: str): V3DebugRuntimeContract =
    return V3DebugRuntimeContract(
        version: "v3.runtime.debug.v1",
        services: [
            "runtime/debug.register_line_map",
            "runtime/debug.dump_backtrace",
            "runtime/debug.profile"
        ],
        providerNativeSources: [
            v3DebugRuntimeProviderSourcePath(rootDir)
        ],
        executionModel: "pure_cheng_debug_runtime_provider",
        traceSymbol: "cheng_v3_native_register_line_map_from_argv0"
    )

fn v3DebugRuntimeTargets(): str[] =
    return v3DebugRuntimeContract("").services
