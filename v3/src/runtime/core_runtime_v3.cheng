type
    V3RuntimeProviderSourceKind = enum
        v3RuntimeProviderNativeC

    V3RuntimeProviderCompileMode = enum
        v3RuntimeProviderExternalCcObject

    V3CoreRuntimeContract =
        version: str
        services: str[]
        providerSourceKind: V3RuntimeProviderSourceKind
        providerCompileMode: V3RuntimeProviderCompileMode
        providerNativeSources: str[]
        executionModel: str
        traceSymbol: str

fn v3CoreRuntimePath(rootDir: str, rel: str): str =
    if rootDir == "":
        return rel
    if rel == "":
        return rootDir
    if rootDir[rootDir.len - 1] == '/':
        return rootDir + rel
    return rootDir + "/" + rel

fn v3CoreRuntimeContract(rootDir: str): V3CoreRuntimeContract =
    return V3CoreRuntimeContract(
        version: "v3.runtime.core.v1",
        services: ["builtin.len"],
        providerSourceKind: v3RuntimeProviderNativeC,
        providerCompileMode: v3RuntimeProviderExternalCcObject,
        providerNativeSources: [
            v3CoreRuntimePath(rootDir, "v3/runtime/native/v3_core_runtime_stub.c")
        ],
        executionModel: "native_cc_stub",
        traceSymbol: "v3_core_runtime_stub_trace"
    )

fn v3CoreRuntimeTargets(): str[] =
    return ["builtin.len"]
