type
    VoidPtrPtr = ptr *

@importc("__cheng_setCmdLine")
fn cheng_set_cmdline_runtime(argc: int32, argv: ptr)

@importc("cheng_v3_register_line_map_from_argv0")
fn cheng_v3_register_line_map_from_argv0_runtime(argv0: ptr)
@importc("cheng_v3_debug_profile_flush_from_argv0")
fn cheng_v3_debug_profile_flush_from_argv0_runtime(argv0: ptr)

@importc("cheng_v3_program_argv_entry")
fn cheng_v3_program_argv_entry_runtime(argc: int32, argv: ptr): int32

fn cheng_runtime_argv0(argc: int32, argv: ptr): ptr =
    if argc <= 0 || argv == nil:
        return nil
    let slot: VoidPtrPtr = VoidPtrPtr(argv)
    return *slot

@exportc("main")
fn cheng_v3_program_runtime_main(argc: int32, argv: ptr): int32 =
    cheng_set_cmdline_runtime(argc, argv)
    let argv0: ptr = cheng_runtime_argv0(argc, argv)
    cheng_v3_register_line_map_from_argv0_runtime(argv0)
    let rc: int32 = cheng_v3_program_argv_entry_runtime(argc, argv)
    cheng_v3_debug_profile_flush_from_argv0_runtime(argv0)
    return rc
