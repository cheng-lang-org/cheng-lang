type
    R2cTruthRouteInput =
        routeId: str
        pathname: str
        search: str
        hash: str
        width: int32
        height: int32

    R2cTruthStorageEntry =
        key: str
        value: str

    R2cTruthEvent =
        category: str
        detail: str
        timestampMs: int64

    R2cTruthSnapshot =
        stateId: str
        route: R2cTruthRouteInput
        framehash: str
        rgbaPath: str
        domPath: str
        domHash: str
        runtimeStatePath: str
        semanticNodesHash: str
        semanticNodesCount: int32
        renderReady: bool
        storage: R2cTruthStorageEntry[]
        hostEvents: R2cTruthEvent[]
        timestampMs: int64

    R2cTruthTrace =
        format: str = "truth_trace_v2"
        traceId: str
        platform: str
        capturedAt: str
        sourceRoot: str
        states: str[]
        snapshots: R2cTruthSnapshot[]
        sideEffects: R2cTruthEvent[]

    R2cTruthRouteSource =
        path: str
        line: int32
        reason: str

    R2cTruthRoute =
        routeId: str
        firstSourcePath: str
        firstLine: int32
        reasons: str[]
        sources: R2cTruthRouteSource[]

    R2cTruthRouteCatalog =
        format: str = "truth_routes_v1"
        repoRoot: str
        sourceRoots: str[]
        typescriptVersion: str
        routes: R2cTruthRoute[]

    R2cTruthCaptureEntry =
        routeId: str
        framehash: str
        renderReady: bool
        semanticNodesLoaded: bool
        semanticNodesCount: int32
        rgbaPath: str
        domPath: str
        runtimeStatePath: str
        timestampMs: int64
        runtimeLogPath: str
        devServerLogPath: str

    R2cTruthCaptureIndex =
        format: str = "truth_capture_index_v1"
        ok: bool
        repoRoot: str
        baseUrl: str
        capturedAt: str
        truthTracePath: str
        routeCount: int32
        routes: str[]
        devServerLogPath: str
        entries: R2cTruthCaptureEntry[]
        outPath: str

    R2cAssetKind = enum
        r2cAssetModule
        r2cAssetImage
        r2cAssetFont
        r2cAssetWasm
        r2cAssetAudio
        r2cAssetVideo
        r2cAssetHtml
        r2cAssetCss
        r2cAssetJson
        r2cAssetOther

    R2cAssetEntry =
        path: str
        kind: R2cAssetKind
        sourceModule: str
        importMode: str
        contentHash: str

    R2cAssetManifest =
        format: str = "asset_manifest_v1"
        repoRoot: str
        entries: R2cAssetEntry[]

    R2cTailwindToken =
        token: str
        sources: str[]
        count: int32

    R2cTailwindStyleManifest =
        format: str = "tailwind_style_manifest_v1"
        repoRoot: str
        tokens: R2cTailwindToken[]

    R2cHostCapabilityGroup = enum
        r2cHostWindow
        r2cHostStorage
        r2cHostNet
        r2cHostRtc
        r2cHostMedia
        r2cHostPlatform
        r2cHostScene

    R2cHostMethod =
        group: R2cHostCapabilityGroup
        name: str
        signature: str
        required: bool

    R2cHostContract =
        format: str
        name: str
        methods: R2cHostMethod[]

    R2cCompileBlocker =
        code: str
        file: str
        line: int32
        column: int32
        snippet: str
        reason: str

    R2cCompileBlockerReport =
        format: str = "compile_blockers_v1"
        repoRoot: str
        sourceRoots: str[]
        blockers: R2cCompileBlocker[]

    R2cTsxImport =
        importType: str
        specifier: str
        line: int32

    R2cTsxHookCall =
        name: str
        line: int32
        column: int32

    R2cTsxElement =
        tag: str
        line: int32

    R2cTsxComponentTagRef =
        name: str
        count: int32

    R2cTsxReturnSurface =
        line: int32
        surfaceJsxCount: int32
        surfaceIntrinsicJsxCount: int32
        surfaceLiveJsxCount: int32
        surfaceLiveIntrinsicJsxCount: int32
        surfaceExpandedJsxCount: int32
        surfaceExpandedIntrinsicJsxCount: int32
        surfaceLiveExpandedJsxCount: int32
        surfaceLiveExpandedIntrinsicJsxCount: int32
        surfaceComponentTagCount: int32
        componentTagRefs: R2cTsxComponentTagRef[]
        liveComponentTagRefs: R2cTsxComponentTagRef[]
        expandedComponentTagRefs: R2cTsxComponentTagRef[]
        liveExpandedComponentTagRefs: R2cTsxComponentTagRef[]
        surfaceFragmentCount: int32

    R2cTsxComponent =
        name: str
        componentType: str
        line: int32
        exported: bool
        async: bool
        returnsJsx: bool
        errorBoundary: bool
        surfaceJsxCount: int32
        surfaceIntrinsicJsxCount: int32
        surfaceLiveJsxCount: int32
        surfaceLiveIntrinsicJsxCount: int32
        surfaceExpandedJsxCount: int32
        surfaceExpandedIntrinsicJsxCount: int32
        surfaceLiveExpandedJsxCount: int32
        surfaceLiveExpandedIntrinsicJsxCount: int32
        surfaceComponentTagCount: int32
        componentTagRefs: R2cTsxComponentTagRef[]
        liveComponentTagRefs: R2cTsxComponentTagRef[]
        expandedComponentTagRefs: R2cTsxComponentTagRef[]
        liveExpandedComponentTagRefs: R2cTsxComponentTagRef[]
        surfaceFragmentCount: int32
        returnSurfaces: R2cTsxReturnSurface[]

    R2cTsxAstModule =
        path: str
        hash: str
        ext: str
        runtimeRoot: str
        generated: bool
        jsxLike: bool
        staticImports: str[]
        dynamicImports: str[]
        assetRefs: str[]
        components: R2cTsxComponent[]
        blockers: R2cCompileBlocker[]
        imports: R2cTsxImport[]
        hookCalls: R2cTsxHookCall[]
        jsxElements: R2cTsxElement[]

    R2cTsxAstProject =
        format: str = "tsx_ast_v1"
        repoRoot: str
        sourceRoots: str[]
        typescriptVersion: str
        modules: R2cTsxAstModule[]

    R2cChengGeneratedModule =
        sourcePath: str
        moduleName: str
        importPath: str
        outputPath: str

    R2cChengGeneratedRouteCandidate =
        semanticNodesCount: int32
        reason: str

    R2cChengGeneratedRouteCatalogEntry =
        routeId: str
        supported: bool
        deterministic: bool
        reason: str
        candidateCount: int32
        candidates: R2cChengGeneratedRouteCandidate[]

    R2cChengGeneratedRouteCatalog =
        format: str
        runnerMode: str
        entryRouteState: str
        routeCount: int32
        supportedCount: int32
        unsupportedCount: int32
        routes: str[]
        entries: R2cChengGeneratedRouteCatalogEntry[]
        outPath: str

    R2cChengCodegenProject =
        format: str = "cheng_codegen_v1"
        workspaceRoot: str
        repoRoot: str
        packageRoot: str
        packageId: str
        modulePrefix: str
        packageImportPrefix: str
        runtimeModule: str
        uiHostModule: str
        react18CompatModule: str
        appRunnerModule: str
        execIoModule: str
        snapshotModule: str
        routeCatalogModule: str
        routeRuntimeModule: str
        routeRuntimeDataModule: str
        routeRuntimeRequestModule: str
        routeRuntimeMainModule: str
        routeMatrixModule: str
        routeMatrixMainModule: str
        truthCompareModule: str
        truthCompareMainModule: str
        truthCompareDataModule: str
        truthCompareMatrixModule: str
        truthCompareMatrixMainModule: str
        truthCompareMatrixDataModule: str
        execBundleModule: str
        routeCatalogPath: str
        projectModule: str
        entryProjectModule: str
        mainModule: str
        entryModule: str
        runnerMode: str
        routeCount: int32
        modules: R2cChengGeneratedModule[]

    R2cChengCodegenSmoke =
        format: str = "cheng_codegen_smoke_v1"
        ok: bool
        reason: str
        tool: str
        mainPath: str
        reportPath: str
        logPath: str
        returnCode: int32
        packageId: str
        sourceBundleCid: str
        canonicalGraphCid: str
        graphCid: str
        version: int32
        nodeCount: int32
        edgeCount: int32

    R2cChengCodegenExecSmoke =
        format: str = "cheng_codegen_exec_smoke_v1"
        ok: bool
        reason: str
        tool: str
        mainPath: str
        exePath: str
        compileReportPath: str
        compileLogPath: str
        runLogPath: str
        routeCatalogMainPath: str
        routeCatalogExePath: str
        routeCatalogCompileReportPath: str
        routeCatalogCompileLogPath: str
        routeCatalogRunLogPath: str
        snapshotPath: str
        target: str
        compileReturnCode: int32
        runReturnCode: int32
        routeCatalogCompileReturnCode: int32
        routeCatalogRunReturnCode: int32
        snapshotRouteState: str
        snapshotRenderReady: bool
        snapshotSemanticNodesLoaded: bool
        snapshotSemanticNodesCount: int32
        execRouteCatalogPath: str
        routeCatalogCount: int32
        routeCatalogSupportedCount: int32

    R2cChengCodegenExecSnapshot =
        format: str = "cheng_codegen_exec_snapshot_v1"
        routeState: str
        mountPhase: str
        commitPhase: str
        renderReady: bool
        semanticNodesLoaded: bool
        semanticNodesCount: int32
        moduleCount: int32
        componentCount: int32
        effectCount: int32
        stateSlotCount: int32
        passiveEffectsFlushed: bool
        passiveEffectFlushCount: int32
        hookSlotCount: int32
        effectSlotCount: int32
        componentInstanceCount: int32
        treeNodeCount: int32
        rootNodeCount: int32
        moduleNodeCount: int32
        componentNodeCount: int32
        elementNodeCount: int32
        hookNodeCount: int32
        effectNodeCount: int32

    R2cChengCodegenExecBundle =
        format: str = "cheng_codegen_exec_bundle_v1"
        snapshot: R2cChengCodegenExecSnapshot
        routeCatalog: R2cChengGeneratedRouteCatalog

    R2cChengCodegenExecRoute =
        routeId: str
        supported: bool
        reason: str
        snapshotPath: str
        snapshot: R2cChengCodegenExecSnapshot

    R2cChengCodegenExecRouteMatrix =
        format: str = "cheng_codegen_exec_route_matrix_v1"
        runnerMode: str
        entryRouteState: str
        routeCount: int32
        supportedCount: int32
        unsupportedCount: int32
        routes: str[]
        entries: R2cChengCodegenExecRoute[]
        outPath: str

    R2cTruthCompareMismatch =
        field: str
        execValue: str
        truthValue: str

    R2cTruthCompare =
        format: str = "truth_compare_v1"
        ok: bool
        reason: str
        truthTracePath: str
        truthTraceFormat: str
        truthState: str
        matchedSnapshotIndex: int32 = -1
        execSnapshotPath: str
        outPath: str
        execRouteState: str
        execRenderReady: bool
        execSemanticNodesLoaded: bool
        execSemanticNodesCount: int32
        truthRouteState: str
        truthRouteId: str
        truthRenderReady: bool
        truthSemanticNodesLoaded: bool
        truthSemanticNodesCount: int32
        missingTruthFields: str[]
        mismatches: R2cTruthCompareMismatch[]

    R2cTruthCompareMatrixEntry =
        routeId: str
        supported: bool
        ok: bool
        reason: str
        matchedSnapshotIndex: int32
        snapshotPath: str
        execRouteState: str
        truthRouteState: str
        execSemanticNodesCount: int32
        truthSemanticNodesCount: int32
        missingTruthFields: str[]
        mismatches: R2cTruthCompareMismatch[]

    R2cTruthCompareMatrix =
        format: str = "truth_compare_matrix_v1"
        ok: bool
        reason: str
        truthTracePath: str
        truthTraceFormat: str
        routeCount: int32
        okCount: int32
        unsupportedCount: int32
        mismatchCount: int32
        missingTruthStateCount: int32
        missingTruthFieldCount: int32
        entries: R2cTruthCompareMatrixEntry[]
        outPath: str

    R2cControllerReport =
        format: str = "controller_report_v1"
        controller: str
        command: str
        ok: bool
        reason: str
        workspaceRoot: str
        packageRoot: str
        repoRoot: str
        outDir: str
        nodeProgram: str
        pythonProgram: str
        helperScript: str
        helperSummaryPath: str
        helperLogPath: str
        primaryArtifactPath: str
        primaryArtifactFormat: str
        moduleCount: int32
        routeCount: int32
        semanticNodesCount: int32
        typescriptVersion: str
        legacyPrototypePath: str
        commands: str[]

    RsgNodeKind = enum
        rsgModule
        rsgImport
        rsgExport
        rsgComponentFunction
        rsgComponentClass
        rsgHookSlot
        rsgEffect
        rsgContext
        rsgSuspenseBoundary
        rsgLazyModule
        rsgEventHandler
        rsgStyleBlock
        rsgLayoutNode
        rsgHostCall
        rsgAsyncTask
        rsgErrorBoundary
        rsgJsClosure
        rsgJsPromise
        rsgJsCompletion

    RsgEdgeKind = enum
        rsgOwns
        rsgCalls
        rsgCaptures
        rsgReads
        rsgWrites
        rsgSchedules
        rsgResumes
        rsgDependsOn
        rsgHandles
        rsgStyles
        rsgLayouts
        rsgThrowsTo

    RsgNode =
        id: str
        kind: RsgNodeKind
        label: str
        capability: str
        sourcePath: str
        sourceSpan: str

    RsgEdge =
        fromId: str
        toId: str
        kind: RsgEdgeKind
        label: str

    RsgModule =
        format: str = "rsg_v1"
        repoRoot: str
        entryModule: str
        nodes: RsgNode[]
        edges: RsgEdge[]

fn r2cTruthTraceZero(): R2cTruthTrace =
    var out: R2cTruthTrace
    return out

fn r2cTruthRouteCatalogZero(): R2cTruthRouteCatalog =
    var out: R2cTruthRouteCatalog
    return out

fn r2cTruthCaptureIndexZero(): R2cTruthCaptureIndex =
    var out: R2cTruthCaptureIndex
    return out

fn r2cAssetManifestZero(): R2cAssetManifest =
    var out: R2cAssetManifest
    return out

fn r2cTailwindStyleManifestZero(): R2cTailwindStyleManifest =
    var out: R2cTailwindStyleManifest
    return out

fn rsgModuleZero(): RsgModule =
    var out: RsgModule
    return out

fn unimakerHostContractV1(): R2cHostContract =
    var out: R2cHostContract
    out.format = "unimaker_host_v1"
    out.name = "unimaker_host_v1"
    out.methods = []
    return out

fn r2cCompileBlockerReportZero(): R2cCompileBlockerReport =
    var out: R2cCompileBlockerReport
    return out

fn r2cTsxAstProjectZero(): R2cTsxAstProject =
    var out: R2cTsxAstProject
    return out

fn r2cChengCodegenProjectZero(): R2cChengCodegenProject =
    var out: R2cChengCodegenProject
    return out

fn r2cChengCodegenSmokeZero(): R2cChengCodegenSmoke =
    var out: R2cChengCodegenSmoke
    return out

fn r2cChengCodegenExecSmokeZero(): R2cChengCodegenExecSmoke =
    var out: R2cChengCodegenExecSmoke
    return out

fn r2cChengCodegenExecSnapshotZero(): R2cChengCodegenExecSnapshot =
    var out: R2cChengCodegenExecSnapshot
    return out

fn r2cChengCodegenExecBundleZero(): R2cChengCodegenExecBundle =
    var out: R2cChengCodegenExecBundle
    out.snapshot = r2cChengCodegenExecSnapshotZero()
    out.routeCatalog = r2cChengGeneratedRouteCatalogZero()
    return out

fn r2cChengCodegenExecRouteMatrixZero(): R2cChengCodegenExecRouteMatrix =
    var out: R2cChengCodegenExecRouteMatrix
    return out

fn r2cTruthCompareMismatchZero(): R2cTruthCompareMismatch =
    var out: R2cTruthCompareMismatch
    return out

fn r2cTruthCompareZero(): R2cTruthCompare =
    var out: R2cTruthCompare
    return out

fn r2cTruthCompareMatrixZero(): R2cTruthCompareMatrix =
    var out: R2cTruthCompareMatrix
    return out

fn r2cControllerReportZero(): R2cControllerReport =
    var out: R2cControllerReport
    return out
