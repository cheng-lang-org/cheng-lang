import std/os
import std/result
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/path as v3path
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/lang/parser as parser

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let packageRoot = v3path.V3PathJoin(workspaceRoot, "v3")
    let smokeLabel: str = os.GetEnvDefault("CHENG_V3_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathJoin(workspaceRoot, "artifacts/v3_program_selfhost/" + smokeLabel)
    assert(v3path.V3MkdirP(workspaceRoot, outDir), "v3 compiler pipeline: mkdir")
    let sourcePath = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = v3path.V3PathJoin(outDir, "program_selfhost_smoke")
    let packageId = parser.v3ParserPackageId(packageRoot)
    let contractsPath = parser.v3ParserModulePathToSourcePath(workspaceRoot, packageRoot, "cheng/v3/tooling/bootstrap_contracts")
    let expectedContractsPath = v3path.V3PathJoin(packageRoot, "src/tooling/bootstrap_contracts.cheng")
    assert(packageId == "cheng/v3", "v3 compiler pipeline: package id")
    assert(contractsPath == expectedContractsPath, "v3 compiler pipeline: contracts path")
    assert(parser.v3ParserSourceExists(contractsPath), "v3 compiler pipeline: contracts path exists")
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    var plan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(packageRoot, req, plan, err), "v3 compiler pipeline: build plan")
    assert(plan.moduleStem == "program_selfhost_smoke", "v3 compiler pipeline: module stem")
    assert(plan.workspaceRoot == workspaceRoot, "v3 compiler pipeline: workspace root")
    assert(plan.packageRoot == packageRoot, "v3 compiler pipeline: package root")
    assert(plan.linkMode == "system_link", "v3 compiler pipeline: link mode")
    assert(plan.buildEntryPath == v3path.V3PathJoin(workspaceRoot, "v3/src/tooling/compiler_main.cheng"),
           "v3 compiler pipeline: build entry")
    assert(plan.buildSourceUnitCount >= 11, "v3 compiler pipeline: source count")
    assert(plan.sourceClosurePaths.len >= 2, "v3 compiler pipeline: closure count")
    assert(plan.runtimeTargets.len == 1, "v3 compiler pipeline: runtime target count")
    assert(plan.runtimeTargets[0] == "runtime/compiler.program_argv_entry",
           "v3 compiler pipeline: program argv runtime target")
    assert(plan.providerModules.len == 5, "v3 compiler pipeline: provider module count")
    assert(plan.providerModules[0] == "runtime/compiler_runtime_v3",
           "v3 compiler pipeline: compiler provider")
    assert(plan.providerModules[1] == "runtime/core_runtime_v3",
           "v3 compiler pipeline: core provider")
    assert(plan.providerModules[2] == "runtime/debug_runtime_v3",
           "v3 compiler pipeline: debug provider")
    assert(plan.providerModules[3] == "runtime/program_support_v3",
           "v3 compiler pipeline: program support provider")
    assert(plan.providerModules[4] == "runtime/program_support_host_v3",
           "v3 compiler pipeline: host support provider")
    assert(plan.entrySymbol == "main", "v3 compiler pipeline: entry symbol")
    let report = slplan.v3SystemLinkPlanStubReport(plan)
    assert(plan.missingReasons.len == 0, "v3 compiler pipeline: missing reasons")
    assert(v3path.V3TextContains(report, "pipeline_stage=parser_to_system_link_plan"),
           "v3 compiler pipeline: report stage")
    assert(v3path.V3TextContains(report, "parser_syntax=v3_normalized_source_v3"),
           "v3 compiler pipeline: report parser syntax")
    assert(v3path.V3TextContains(report, "expr_surface_source_count="),
           "v3 compiler pipeline: expr surface count")
    assert(v3path.V3TextContains(report, "expr_surface_expr_count="),
           "v3 compiler pipeline: expr node count")
    assert(v3path.V3TextContains(report, "expr_surface_try_count="),
           "v3 compiler pipeline: try count")
    assert(v3path.V3TextContains(report, "expr_surface_question_residual_count=0"),
           "v3 compiler pipeline: question normalized")
    assert(v3path.V3TextContains(report, "runtime_targets=runtime/compiler.program_argv_entry"),
           "v3 compiler pipeline: report runtime target")
    assert(v3path.V3TextContains(report,
                            "provider_modules=runtime/compiler_runtime_v3,runtime/core_runtime_v3,runtime/debug_runtime_v3,runtime/program_support_v3,runtime/program_support_host_v3"),
           "v3 compiler pipeline: report providers")
    assert(v3path.V3TextContains(report, "missing_reasons=-"),
           "v3 compiler pipeline: report missing reasons cleared")
    echo("v3 compiler_pipeline_smoke ok")
    return 0
