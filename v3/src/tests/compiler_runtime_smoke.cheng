import cheng/v3/tooling/compiler_runtime as crun
import cheng/v3/tooling/support_matrix as smatrix
import cheng/v3/tooling/bootstrap_contracts as contracts
import cheng/v3/backend/build_plan as buildplan
import std/strings
import cheng/v3/runtime/core_runtime_v3 as corun
import cheng/v3/runtime/compiler_runtime_v3 as rtrun
import cheng/v3/runtime/debug_runtime_v3 as dbrun
import cheng/v3/runtime/program_support_v3 as psrun

fn main(): int32 =
    let contract = crun.v3CompilerRuntimeContract("/tmp/cheng-lang")
    assert(contract.version == "v3.compiler_runtime.v1", "v3 compiler runtime: version")
    assert(contract.executionModel == "argv_control_plane", "v3 compiler runtime: execution")
    assert(contract.compilerEntry == "/tmp/cheng-lang/v3/src/tooling/compiler_main.cheng",
           "v3 compiler runtime: entry")
    assert(contract.ordinaryCommand == "system-link-exec", "v3 compiler runtime: ordinary command")
    assert(contract.ordinaryPipelineState == "canonical_csg_verified_primary_object_codegen_missing",
           "v3 compiler runtime: ordinary state")
    assert(crun.v3CompilerProgramArgvRuntimeTarget() == "runtime/compiler.program_argv_entry",
           "v3 compiler runtime: program argv target")
    assert(crun.v3CompilerToolingArgvRuntimeTarget() == "runtime/compiler.tooling_argv_entry",
           "v3 compiler runtime: tooling argv target")
    assert(crun.v3CompilerRuntimeProviderModule() == "runtime/compiler_runtime_v3",
           "v3 compiler runtime: compiler provider")
    assert(crun.v3CoreRuntimeProviderModule() == "runtime/core_runtime_v3",
           "v3 compiler runtime: core provider")
    assert(crun.v3DebugRuntimeProviderModule() == "runtime/debug_runtime_v3",
           "v3 compiler runtime: debug provider")
    let programRuntimeContract = rtrun.v3CompilerRuntimeContract("/tmp/cheng-lang",
                                                                 rtrun.v3CompilerRuntimeTrackProgram)
    let toolingRuntimeContract = rtrun.v3CompilerRuntimeContract("/tmp/cheng-lang",
                                                                 rtrun.v3CompilerRuntimeTrackTooling)
    let coreDarwinContract = corun.v3CoreRuntimeContractForTarget("/tmp/cheng-lang",
                                                                  "arm64-apple-darwin")
    let coreLinuxContract = corun.v3CoreRuntimeContractForTarget("/tmp/cheng-lang",
                                                                 "x86_64-unknown-linux-gnu")
    let debugRuntimeContract = dbrun.v3DebugRuntimeContract("/tmp/cheng-lang")
    let programSupportContract = psrun.v3ProgramSupportContract("/tmp/cheng-lang")
    assert(programRuntimeContract.providerNativeSources[0] ==
               "/tmp/cheng-lang/v3/src/runtime/compiler_runtime_program_entry_provider_v3.cheng",
           "v3 compiler runtime: program argv provider source")
    assert(toolingRuntimeContract.providerNativeSources[0] ==
               "/tmp/cheng-lang/v3/src/runtime/compiler_runtime_tooling_entry_provider_v3.cheng",
           "v3 compiler runtime: tooling argv provider source")
    assert(coreDarwinContract.providerNativeSources[0] ==
               "/tmp/cheng-lang/v3/src/runtime/core_runtime_provider_darwin_v3.cheng",
           "v3 compiler runtime: darwin core provider source")
    assert(coreLinuxContract.providerNativeSources[0] ==
               "/tmp/cheng-lang/v3/src/runtime/core_runtime_provider_linux_v3.cheng",
           "v3 compiler runtime: linux core provider source")
    assert(debugRuntimeContract.providerNativeSources[0] ==
               "/tmp/cheng-lang/v3/src/runtime/debug_runtime_stub_v3.cheng",
           "v3 compiler runtime: debug provider source")
    assert(programSupportContract.providerNativeSources[0] ==
               "/tmp/cheng-lang/v3/src/runtime/program_support_backend_v3.cheng",
           "v3 compiler runtime: support provider source")
    assert(psrun.v3ProgramSupportHostProviderSourcePath("/tmp/cheng-lang") ==
               "/tmp/cheng-lang/v3/src/runtime/program_support_host_runtime_v3.cheng",
           "v3 compiler runtime: host support provider source")
    var providers: str[]
    crun.v3RuntimeProviderModulesForTrack(crun.v3CompilerTrackProgram, providers)
    assert(providers.len == 5, "v3 compiler runtime: provider count")
    assert(providers[0] == "runtime/compiler_runtime_v3",
           "v3 compiler runtime: provider compiler")
    assert(providers[1] == "runtime/core_runtime_v3",
           "v3 compiler runtime: provider core")
    assert(providers[2] == "runtime/debug_runtime_v3",
           "v3 compiler runtime: provider debug")
    assert(providers[3] == "runtime/program_support_v3",
           "v3 compiler runtime: provider program support")
    assert(providers[4] == "runtime/program_support_host_v3",
           "v3 compiler runtime: provider host support")

    let lines = crun.v3CompilerUsageLines("/tmp/cheng-lang")
    assert(lines.len >= 6, "v3 compiler runtime: usage lines")
    assert(lines[0] == "cheng_v3c", "v3 compiler runtime: usage header")
    var sawSystemLink = false
    var sawSupportMatrix = false
    var sawBootstrapBridge = false
    var sawPrintBootstrap = false
    var sawBuildBackendDriver = false
    var sawRunSmokes = false
    var sawScanHotpath = false
    var sawHostBridgeAudit = false
    var sawDebugReport = false
    var sawVerifyOrphanGuard = false
    var sawVerifyBackendDriverCommandSurface = false
    var sawVerifyR2cReactV3Surface = false
    var sawRunHostSmokes = false
    var sawRunChainNodeCliSmoke = false
    var sawBuildBftStateMachine = false
    var sawR2cReactEntry = false
    var sawVpnGuiEntry = false
    var sawVpnProxyEntry = false
    var sawMobileShellEntry = false
    var sawSliceGate = false
    var sawEmitCsg = false
    var sawMigrateCsg = false
    var sawVerifyWorld = false
    var sawWorldSync = false
    var sawProveEquivalence = false
    var sawProveMigration = false
    var sawPublishWorld = false
    var sawFreshNodeSelfhost = false
    var sawSelfhostBuild = false
    for i in 0..<lines.len:
        if lines[i] == "  support-matrix               print the current language/target support matrix":
            sawSupportMatrix = true
        if lines[i] == "  bootstrap-bridge             rebuild and install bootstrap stage0-stage3 via candidate artifacts":
            sawBootstrapBridge = true
        if lines[i] == "  print-bootstrap              print the current bootstrap snapshot":
            sawPrintBootstrap = true
        if lines[i] == "  build-backend-driver         rebuild and verify the ordinary backend driver":
            sawBuildBackendDriver = true
        if lines[i] == "  run-smokes                   self-check stage0/stage1/stage2/stage3 bootstrap compilers":
            sawRunSmokes = true
        if lines[i] == "  scan-hotpath                 scan v3/src for forbidden hotpath regressions":
            sawScanHotpath = true
        if lines[i] == "  host-bridge-audit            fail if legacy host-bridge surfaces leak back into the live path":
            sawHostBridgeAudit = true
        if lines[i] == "  debug-report                emit the stable ordinary pipeline debug report":
            sawDebugReport = true
        if lines[i] == "  verify-orphan-guard         fail on tooling residue or new Cheng U/UE after bootstrap/build":
            sawVerifyOrphanGuard = true
        if lines[i] == "  verify-backend-driver-command-surface verify live backend_driver zero-script command surface":
            sawVerifyBackendDriverCommandSurface = true
        if lines[i] == "  verify-r2c-react-v3-surface verify live r2c-react-v3 codegen/native-gui/fresh-clean surface":
            sawVerifyR2cReactV3Surface = true
        if lines[i] == "  run-host-smokes             run host ordinary/compiler/libp2p/chain smokes":
            sawRunHostSmokes = true
        if lines[i] == "  run-chain-node-cli-smoke    run the chain_node CLI smoke":
            sawRunChainNodeCliSmoke = true
        if lines[i] == "  build-bft-state-machine     build the BFT state machine daemon":
            sawBuildBftStateMachine = true
        if lines[i] == "  r2c-react-v3 <subcommand>    zero-script r2c controller entry":
            sawR2cReactEntry = true
        if lines[i] == "  vpn-gui [flags]              pure Cheng local Web GUI for vpn-proxy":
            sawVpnGuiEntry = true
        if lines[i] == "  vpn-proxy <subcommand>       QUIC+TLS dual-exit SOCKS5 proxy entry":
            sawVpnProxyEntry = true
        if lines[i] == "  mobile-shell <subcommand>    pure Cheng native shell generator for android/ios/harmony":
            sawMobileShellEntry = true
        if lines[i] == "  slice-gate                  run the full v3 gate through stage3 forwarding, incl. chain_node/bft/x86 mainline":
            sawSliceGate = true
        if lines[i] == "  system-link-exec             ordinary AOT compile entry (canonical CSG + provider object plan)":
            sawSystemLink = true
        if lines[i] == "  emit-csg                     emit the canonical compiler CSG report for a source closure":
            sawEmitCsg = true
        if lines[i] == "  migrate-csg                  migrate legacy source text into the current canonical CSG":
            sawMigrateCsg = true
        if lines[i] == "  verify-world                 verify world-head, lock, and export-surface compatibility":
            sawVerifyWorld = true
        if lines[i] == "  world-sync                   materialize a world bundle report set for sync/distribution":
            sawWorldSync = true
        if lines[i] == "  prove-equivalence            prove old world reports are canonically equivalent to the current CSG":
            sawProveEquivalence = true
        if lines[i] == "  prove-migration             prove legacy source migrates into a canonically equivalent CSG":
            sawProveMigration = true
        if lines[i] == "  publish-world                publish a world bundle with stable/edge gate enforcement":
            sawPublishWorld = true
        if lines[i] == "  fresh-node-selfhost          sync a published world into a fresh node and re-verify the receipt":
            sawFreshNodeSelfhost = true
        if lines[i] == "  selfhost-build               run the selfhost build gate pinned to a world head":
            sawSelfhostBuild = true
    assert(sawSupportMatrix, "v3 compiler runtime: usage support matrix")
    assert(sawBootstrapBridge, "v3 compiler runtime: usage bootstrap bridge")
    assert(sawPrintBootstrap, "v3 compiler runtime: usage print bootstrap")
    assert(sawBuildBackendDriver, "v3 compiler runtime: usage build backend driver")
    assert(sawRunSmokes, "v3 compiler runtime: usage run smokes")
    assert(sawScanHotpath, "v3 compiler runtime: usage scan hotpath")
    assert(sawHostBridgeAudit, "v3 compiler runtime: usage host bridge audit")
    assert(sawDebugReport, "v3 compiler runtime: usage debug report")
    assert(sawVerifyOrphanGuard, "v3 compiler runtime: usage orphan guard")
    assert(sawVerifyBackendDriverCommandSurface,
           "v3 compiler runtime: usage backend driver command surface")
    assert(sawVerifyR2cReactV3Surface, "v3 compiler runtime: usage r2c surface")
    assert(sawRunHostSmokes, "v3 compiler runtime: usage host smokes")
    assert(sawRunChainNodeCliSmoke, "v3 compiler runtime: usage chain node cli smoke")
    assert(sawBuildBftStateMachine, "v3 compiler runtime: usage build bft state machine")
    assert(sawR2cReactEntry, "v3 compiler runtime: usage r2c controller entry")
    assert(sawVpnGuiEntry, "v3 compiler runtime: usage vpn gui entry")
    assert(sawVpnProxyEntry, "v3 compiler runtime: usage vpn proxy entry")
    assert(sawMobileShellEntry, "v3 compiler runtime: usage mobile shell entry")
    assert(sawSliceGate, "v3 compiler runtime: usage slice gate")
    assert(sawSystemLink, "v3 compiler runtime: usage ordinary command")
    assert(sawEmitCsg, "v3 compiler runtime: usage emit csg")
    assert(sawMigrateCsg, "v3 compiler runtime: usage migrate csg")
    assert(sawVerifyWorld, "v3 compiler runtime: usage verify world")
    assert(sawWorldSync, "v3 compiler runtime: usage world sync")
    assert(sawProveEquivalence, "v3 compiler runtime: usage prove equivalence")
    assert(sawProveMigration, "v3 compiler runtime: usage prove migration")
    assert(sawPublishWorld, "v3 compiler runtime: usage publish world")
    assert(sawFreshNodeSelfhost, "v3 compiler runtime: usage fresh node")
    assert(sawSelfhostBuild, "v3 compiler runtime: usage selfhost build")

    let plan = buildplan.v3BackendBuildPlanDefault("/tmp/cheng-lang")
    assert(plan.entryPath == "/tmp/cheng-lang/v3/src/tooling/compiler_main.cheng",
           "v3 compiler runtime: build entry path")
    assert(plan.targetTriple == contracts.v3BootstrapDefaultTarget(),
           "v3 compiler runtime: build target")
    assert(plan.linker == buildplan.v3BackendLinkerSystemLink, "v3 compiler runtime: linker mode")
    assert(plan.sourceUnits.len >= 21, "v3 compiler runtime: build sources")
    let supportReport = smatrix.v3SupportMatrixReport("/tmp/cheng-lang")
    assert(strings.StrContains(supportReport, "format=v3_support_matrix_v1"),
           "v3 compiler runtime: support matrix format")
    assert(strings.StrContains(supportReport, "language_surface=line_normalized_parser_stub"),
           "v3 compiler runtime: support matrix language surface")
    assert(strings.StrContains(supportReport, "language_ast_authority=0"),
           "v3 compiler runtime: support matrix ast authority")
    assert(strings.StrContains(supportReport,
                               "ordinary_pipeline_state=canonical_csg_verified_primary_object_codegen_missing"),
           "v3 compiler runtime: support matrix pipeline")
    assert(strings.StrContains(supportReport, "target_count=7"),
           "v3 compiler runtime: support matrix target count")
    assert(strings.StrContains(supportReport, "target[0].triple=arm64-apple-darwin"),
           "v3 compiler runtime: support matrix host target")
    assert(strings.StrContains(supportReport, "target[2].linux_nolibc_runtime=1"),
           "v3 compiler runtime: support matrix linux nolibc")
    assert(strings.StrContains(supportReport, "compiler_build_source_unit_count=21"),
           "v3 compiler runtime: support matrix source count")

    echo("v3 compiler_runtime_smoke ok")
    return 0
