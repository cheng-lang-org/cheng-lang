import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus

type
    Outer =
        name: str
        epoch: int32
        tick: int64
        index: consensus.V3ChainIndex
        eventCids: layout.FixedBytes32[]
        marks: int32[]

fn outerZero(): Outer =
    var out: Outer
    out.name = "node-a"
    out.epoch = 1
    out.tick = int64(1)
    out.index = consensus.v3ChainIndexZero()
    out.eventCids = []
    out.marks = []
    return out

fn main(): int32 =
    var outer = outerZero()
    add(outer.eventCids, layout.fixedBytes32Zero())
    add(outer.marks, 11)
    assert(outer.eventCids.len == 1, "v3 offset chain index field assign preserves tail: pre cid len")
    assert(outer.marks.len == 1, "v3 offset chain index field assign preserves tail: pre marks len")

    var nextIndex = outer.index
    add(nextIndex.accountAssetIds, 7)
    add(nextIndex.accountIds, 1001)
    add(nextIndex.accountHeads, layout.fixedBytes32Zero())
    add(nextIndex.balances, int64(100))
    add(nextIndex.clockEpochs, 1)
    add(nextIndex.clockGanzhi, 1)
    add(nextIndex.diverged, false)
    outer.index = nextIndex

    assert(outer.index.accountIds.len == 1, "v3 offset chain index field assign preserves tail: index len")
    assert(outer.eventCids.len == 1, "v3 offset chain index field assign preserves tail: post cid len")
    assert(outer.marks.len == 1, "v3 offset chain index field assign preserves tail: post marks len")
    assert(outer.marks[0] == 11, "v3 offset chain index field assign preserves tail: mark item")
    echo("v3 offset_chain_index_field_assign_preserves_tail_smoke ok")
    return 0
