import std/system

type
    ProbeHolder =
        values: int64[2]

fn selectPos(seed: int32): int32 =
    return seed

fn main(): int32 =
    var holder: ProbeHolder
    holder.values[0] = int64(5)
    holder.values[1] = int64(7)
    assert(holder.values[selectPos(1)] == int64(7),
           "v3 member index call: nested member[index(call)]")
    echo("v3 member_index_call_smoke ok")
    return 0
