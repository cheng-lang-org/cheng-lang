import std/system
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/binary_types as types
import cheng/v3/chain/lsmr

fn main(): int32 =
    var digits: int32[]
    digits = []
    add(digits, 1)
    add(digits, 2)
    add(digits, 3)
    let addressRes = types.v3LsmrAddressFromDigits(digits)
    assert(IsOk(addressRes), "v3 lsmr locality smoke: address")
    let address = Value(addressRes)
    let zeroCid = layout.fixedBytes32Zero()
    let localityRes = lsmr.v3LsmrLocalityCidMake(7, address, 3, zeroCid, zeroCid)
    if IsErr(localityRes):
        panic(Error(localityRes))
    let locality = Value(localityRes)
    assert(locality.keyId == 7, "v3 lsmr locality smoke: key")
    assert(locality.resolutionLevel == 3, "v3 lsmr locality smoke: resolution")
    let stateCellRes = lsmr.v3LsmrStateCellMake(7, address, 3, zeroCid, zeroCid)
    if IsErr(stateCellRes):
        panic(Error(stateCellRes))
    let cell = Value(stateCellRes)
    assert(cell.keyId == 7, "v3 lsmr locality smoke: cell key")
    assert(cell.resolutionLevel == 3, "v3 lsmr locality smoke: cell resolution")
    echo("v3 lsmr_locality_statecell_smoke ok")
    return 0
