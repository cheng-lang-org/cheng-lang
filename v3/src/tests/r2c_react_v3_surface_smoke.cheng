import std/os
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let root = os.getCurrentDir()
    let outDir = v3path.v3PathAbsolute(root, "artifacts/v3_r2c_surface_smoke")
    assert(v3path.v3MkdirP(root, outDir), "v3 r2c surface smoke: mkdir")
    let driver = v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver/cheng")
    assert(v3path.v3FileExistsNonEmpty(root, driver), "v3 r2c surface smoke: backend_driver exists")
    let repoEnv = os.getEnv("R2C_REACT_V3_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.dirExists(repo), "v3 r2c surface smoke: React.js repo exists")

    let codegenOutDir = v3path.v3PathJoin(outDir, "codegen_surface")
    let codegenLog = v3path.v3PathJoin(outDir, "r2c_codegen_surface.log")
    if v3path.v3PathFileExists(codegenLog):
        os.removeFile(codegenLog)
    let codegenRun = hostops.v3RunFileLogged(root,
                                             "r2c_codegen_surface_smoke",
                                             driver,
                                             ["r2c-react-v3-codegen-surface-smoke",
                                              "--repo", repo,
                                              "--out-dir", codegenOutDir],
                                             [],
                                             root,
                                             0,
                                             codegenLog)
    assert(hostops.v3LoggedRunOk(codegenRun), "v3 r2c surface smoke: codegen surface rc")
    assert(v3path.v3PathFileExists(codegenLog), "v3 r2c surface smoke: codegen surface log")
    assert(v3path.v3TextContains(codegenRun.output, "r2c-react-v3 codegen surface smoke: ok"),
           "v3 r2c surface smoke: codegen surface ok")
    assert(v3path.v3FileExistsNonEmpty(root, os.joinPath(codegenOutDir, "codegen_surface_report_v1.json")),
           "v3 r2c surface smoke: codegen report")
    assert(v3path.v3FileExistsNonEmpty(root, os.joinPath(codegenOutDir, "codegen_surface.summary.env")),
           "v3 r2c surface smoke: codegen summary")

    let bundleOutDir = v3path.v3PathJoin(outDir, "native_gui_bundle_home_default")
    let bundleLog = v3path.v3PathJoin(outDir, "r2c_native_gui_bundle.log")
    if v3path.v3PathFileExists(bundleLog):
        os.removeFile(bundleLog)
    let bundleRun = hostops.v3RunFileLogged(root,
                                            "r2c_native_gui_bundle_smoke",
                                            driver,
                                            ["r2c-react-v3-native-gui-bundle-smoke",
                                             "--repo", repo,
                                             "--route-state", "home_default",
                                             "--out-dir", bundleOutDir],
                                            [],
                                            root,
                                            0,
                                            bundleLog)
    assert(hostops.v3LoggedRunOk(bundleRun), "v3 r2c surface smoke: native gui bundle rc")
    assert(v3path.v3PathFileExists(bundleLog), "v3 r2c surface smoke: native gui bundle log")
    assert(v3path.v3TextContains(bundleRun.output, "r2c-react-v3 native gui bundle smoke: ok"),
           "v3 r2c surface smoke: native gui bundle ok")
    assert(v3path.v3FileExistsNonEmpty(root, os.joinPath(bundleOutDir, "native_gui_bundle_report_v1.json")),
           "v3 r2c surface smoke: native gui report")
    assert(v3path.v3FileExistsNonEmpty(root, os.joinPath(bundleOutDir, "native_gui_bundle.summary.env")),
           "v3 r2c surface smoke: native gui summary")
    assert(v3path.v3FileExistsNonEmpty(root, os.joinPath(bundleOutDir, "native_gui_bundle_v1.json")),
           "v3 r2c surface smoke: native gui bundle json")

    let freshLog = v3path.v3PathJoin(outDir, "r2c_fresh_clean_gate.log")
    if v3path.v3PathFileExists(freshLog):
        os.removeFile(freshLog)
    let freshRun = hostops.v3RunFileLogged(root,
                                           "r2c_fresh_clean_gate",
                                           driver,
                                           ["r2c-react-v3-fresh-clean-gate",
                                            "--repo", repo],
                                           [],
                                           root,
                                           0,
                                           freshLog)
    assert(hostops.v3LoggedRunOk(freshRun), "v3 r2c surface smoke: fresh clean gate rc")
    assert(v3path.v3PathFileExists(freshLog), "v3 r2c surface smoke: fresh clean gate log")
    assert(v3path.v3TextContains(freshRun.output, "r2c-react-v3 fresh clean gate: ok"),
           "v3 r2c surface smoke: fresh clean gate ok")
    assert(v3path.v3FileExistsNonEmpty(root, "/tmp/r2c-status-fresh-clean-gate.json"),
           "v3 r2c surface smoke: fresh clean status")
    assert(v3path.v3FileExistsNonEmpty(root,
                                       "/tmp/r2c-native-gui-fresh-clean-gate-home_default/" +
                                           "native_gui_bundle_report_v1.json"),
           "v3 r2c surface smoke: fresh clean home report")
    assert(v3path.v3FileExistsNonEmpty(root,
                                       "/tmp/r2c-native-gui-fresh-clean-gate-content_detail/" +
                                           "native_gui_bundle_report_v1.json"),
           "v3 r2c surface smoke: fresh clean content report")
    assert(v3path.v3FileExistsNonEmpty(root,
                                       "/tmp/r2c-native-gui-fresh-clean-gate-publish_selector/" +
                                           "native_gui_bundle_report_v1.json"),
           "v3 r2c surface smoke: fresh clean publish report")

    echo("v3 r2c_react_v3_surface_smoke ok")
    return 0
