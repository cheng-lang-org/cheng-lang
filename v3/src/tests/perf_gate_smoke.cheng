import std/system
import cheng/v3/lang/intern as langintern
import cheng/v3/tooling/perf_gate as perfgate

fn main() =
    let pool: langintern.V3InternPool = langintern.v3InternPoolNew()
    let base: perfgate.V3BenchDataset = perfgate.v3BenchDatasetLoadText(
        pool,
        "sha256 ns_per_op=10.000\nx25519 ns_per_op=20.500\n")
    let candidate: perfgate.V3BenchDataset = perfgate.v3BenchDatasetLoadText(
        pool,
        "sha256 ns_per_op=10.100\nx25519 ns_per_op=20.500\n")
    let compare: perfgate.V3BenchCompare = perfgate.v3BenchCompare(base, candidate, int64(1010))
    assert(compare.ok, "v3 perf gate: within threshold")
    assert(compare.rows.len == 2, "v3 perf gate: rows")
    let report: str = perfgate.v3BenchCompareReport(pool, compare)
    assert(report != "", "v3 perf gate: report")
    echo("v3 perf_gate_smoke ok")
