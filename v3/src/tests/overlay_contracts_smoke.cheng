import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/binary_types as types
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/overlay/contracts as overlay

fn main(): int32 =
    assert(!overlay.v3OverlayRoleMayRoute(overlay.v3OverlayRoleLeafClient),
        "v3 overlay smoke: leaf cannot route")
    assert(overlay.v3OverlayRoleMayRoute(overlay.v3OverlayRoleEdgeRelayStore),
        "v3 overlay smoke: edge may route")
    assert(overlay.v3OverlayRoleMayRoute(overlay.v3OverlayRoleRegionalRouter),
        "v3 overlay smoke: regional may route")
    assert(overlay.v3OverlayRoleMayRoute(overlay.v3OverlayRoleGlobalAnchor),
        "v3 overlay smoke: global may route")
    assert(overlay.v3OverlayScopeText(overlay.v3OverlayScopeCell) == "cell",
        "v3 overlay smoke: cell scope text")
    assert(overlay.v3OverlayRoleText(overlay.v3OverlayRoleRegionalRouter) == "regional_router",
        "v3 overlay smoke: role text")

    let addrRes = types.v3LsmrAddressFromDigits([5, 1, 8])
    assert(addrRes.ok, "v3 overlay smoke: address")
    let prefixRes = lt.v3PrefixRefFromDigits(lt.v3BaguaLi, [5, 1])
    assert(prefixRes.ok, "v3 overlay smoke: prefix")

    var better = overlay.v3OverlayTrustScoreInputZero()
    better.lsmrDistance = 1
    better.rttEwmaMicros = 1000
    better.lossPermille = 2
    better.loadPermille = 3
    better.trustPermille = 900

    var worse = overlay.v3OverlayTrustScoreInputZero()
    worse.lsmrDistance = 1
    worse.rttEwmaMicros = 1000
    worse.lossPermille = 2
    worse.loadPermille = 3
    worse.trustPermille = 100

    assert(overlay.v3OverlayTrustScore(better) < overlay.v3OverlayTrustScore(worse),
        "v3 overlay smoke: trust score not pure lsmr distance")

    var candidate = overlay.v3OverlayNeighborCandidateZero()
    candidate.role = overlay.v3OverlayRoleRegionalRouter
    candidate.coordHint.address = addrRes.value
    candidate.coordHint.confidencePermille = 700
    candidate.scoreInput = better
    assert(overlay.v3OverlayNeighborEligible(candidate),
        "v3 overlay smoke: regional eligible")

    candidate.role = overlay.v3OverlayRoleLeafClient
    assert(!overlay.v3OverlayNeighborEligible(candidate),
        "v3 overlay smoke: leaf excluded from routing table")

    var witness = overlay.v3OverlayWitnessProofZero()
    witness.subjectPeerId = layout.fixedBytes32Zero()
    witness.witnessPeerId = layout.fixedBytes32Zero()
    witness.address = addrRes.value
    witness.confidencePermille = 600
    witness.stampEpoch = 3
    witness.stampGanzhi = 18
    assert(overlay.v3OverlayWitnessFreshEnough(witness),
        "v3 overlay smoke: witness fresh")

    var ingress = overlay.v3OverlayIngressEnvelopeZero()
    ingress.topicScope = overlay.v3OverlayScopeRegion
    ingress.address = addrRes.value
    ingress.payloadLen = 128
    assert(ingress.topicScope == overlay.v3OverlayScopeRegion,
        "v3 overlay smoke: ingress scope")

    var query = overlay.v3OverlayStoreQueryZero()
    query.address = addrRes.value
    query.prefix = prefixRes.value
    query.rangeLimit = 32
    assert(query.rangeLimit == 32, "v3 overlay smoke: store query range")

    var digest = overlay.v3OverlaySyncDigestZero()
    digest.topicScope = overlay.v3OverlayScopeGlobal
    digest.eventCount = 9
    digest.accountCount = 3
    assert(digest.topicScope == overlay.v3OverlayScopeGlobal,
        "v3 overlay smoke: sync scope")

    echo("v3 overlay_contracts_smoke ok")
    return 0
