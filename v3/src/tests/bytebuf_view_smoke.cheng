import std/system
import cheng/v3/std/bytes_layout as layout

fn main(): int32 =
    var buf = layout.byteBufInit(16)
    layout.byteBufAppendByte(buf, 0)
    layout.byteBufAppendByte(buf, 0)
    layout.byteBufAppendByte(buf, 0)
    layout.byteBufAppendByte(buf, 1)
    let span = layout.byteBufView(buf)
    assert(layout.byteSpanLen(span) == 4, "v3 bytebuf view: len")
    assert(layout.byteSpanAt(span, 3) == 1, "v3 bytebuf view: byte")
    echo("v3 bytebuf_view_smoke ok")
    return 0
