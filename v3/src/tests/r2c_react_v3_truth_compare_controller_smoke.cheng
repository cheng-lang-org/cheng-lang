import std/os
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let root = os.GetCurrentDir()
    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_r2c_truth_compare_controller_smoke")
    assert(v3path.V3MkdirP(root, outDir), "v3 r2c truth compare controller smoke: mkdir")
    let driver = v3path.V3PathAbsolute(root, "artifacts/v3_backend_driver/cheng")
    let packageRoot = v3path.V3PathAbsolute(root, "v3")
    let controllerSource = v3path.V3PathAbsolute(root, "v3/src/tooling/r2c_react_v3.cheng")
    assert(v3path.V3FileExistsNonEmpty(root, driver), "v3 r2c truth compare controller smoke: backend_driver exists")
    assert(v3path.V3FileExistsNonEmpty(root, controllerSource), "v3 r2c truth compare controller smoke: controller source exists")

    let controllerExe = os.JoinPath(outDir, "r2c_react_v3_truth_compare_smoke")
    let controllerCompileReport = controllerExe + ".report.txt"
    let controllerCompileLog = controllerExe + ".compile.log"
    if v3path.V3PathFileExists(controllerExe):
        os.RemoveFile(controllerExe)
    if v3path.V3PathFileExists(controllerCompileReport):
        os.RemoveFile(controllerCompileReport)
    let controllerCompileRun = hostops.v3RunFileLogged(root,
                                                       "r2c_truth_compare_controller_compile",
                                                       driver,
                                                       [
                                                           "system-link-exec",
                                                           "--root:" + packageRoot,
                                                           "--in:" + controllerSource,
                                                           "--emit:exe",
                                                           "--target:arm64-apple-darwin",
                                                           "--out:" + controllerExe,
                                                           "--report-out:" + controllerCompileReport
                                                       ],
                                                       ["CHENG_V3_BACKEND_DRIVER_READY=1"],
                                                       root,
                                                       0,
                                                       controllerCompileLog)
    assert(hostops.v3LoggedRunOk(controllerCompileRun), "v3 r2c truth compare controller smoke: controller compile rc")
    assert(v3path.V3FileExistsNonEmpty(root, controllerExe), "v3 r2c truth compare controller smoke: controller exe")

    let execSnapshotPath = os.JoinPath(outDir, "cheng_codegen_exec_snapshot_v1.json")
    let truthTracePath = os.JoinPath(outDir, "truth_trace_v2.json")
    let nativeGuiSummaryPath = os.JoinPath(outDir, "native_gui_run.summary.env")
    let truthComparePath = os.JoinPath(outDir, "truth_compare_v1.json")
    let truthCompareSummaryPath = os.JoinPath(outDir, "truth_compare.summary.env")
    let compareReportPath = os.JoinPath(outDir, "compare_truth_report_v1.json")
    let screenshotPath = os.JoinPath(outDir, "native_gui_session.png")
    assert(v3path.V3WriteTextFile("", execSnapshotPath,
                                  "{\n" +
                                  "  \"format\": \"cheng_codegen_exec_snapshot_v1\",\n" +
                                  "  \"route_state\": \"home_default\",\n" +
                                  "  \"render_ready\": true,\n" +
                                  "  \"semantic_nodes_loaded\": true,\n" +
                                  "  \"semantic_nodes_count\": 83\n" +
                                  "}\n"),
           "v3 r2c truth compare controller smoke: write exec snapshot")
    assert(v3path.V3WriteTextFile("", truthTracePath,
                                  "{\n" +
                                  "  \"format\": \"truth_trace_v2\",\n" +
                                  "  \"snapshots\": [\n" +
                                  "    {\n" +
                                  "      \"stateId\": \"home_default\",\n" +
                                  "      \"route\": {\n" +
                                  "        \"routeId\": \"home_default\"\n" +
                                  "      },\n" +
                                  "      \"semanticNodesCount\": 83,\n" +
                                  "      \"renderReady\": true\n" +
                                  "    }\n" +
                                  "  ]\n" +
                                  "}\n"),
           "v3 r2c truth compare controller smoke: write truth trace")
    assert(v3path.V3WriteTextFile("", screenshotPath, "png"),
           "v3 r2c truth compare controller smoke: write screenshot stub")
    assert(v3path.V3WriteTextFile("", nativeGuiSummaryPath,
                                  "native_gui_route_state=home_default\n" +
                                  "native_gui_screenshot_path=" + screenshotPath + "\n" +
                                  "native_gui_runtime_bundle_ready=true\n" +
                                  "native_gui_runtime_contract_ready=true\n" +
                                  "native_gui_runtime_bundle_route_state=home_default\n" +
                                  "native_gui_runtime_bundle_route_count=1\n" +
                                  "native_gui_runtime_bundle_supported_count=5\n" +
                                  "native_gui_runtime_bundle_semantic_nodes_count=83\n" +
                                  "native_gui_runtime_bundle_layout_item_count=31\n" +
                                  "native_gui_runtime_bundle_render_command_count=44\n" +
                                  "native_gui_runtime_contract_layout_item_count=31\n" +
                                  "native_gui_runtime_contract_viewport_item_count=18\n" +
                                  "native_gui_runtime_contract_interactive_item_count=7\n" +
                                  "native_gui_native_layout_plan_item_count=31\n" +
                                  "native_gui_render_plan_command_count=44\n"),
           "v3 r2c truth compare controller smoke: write native gui summary")

    let controllerLog = os.JoinPath(outDir, "compare_truth_controller.log")
    if v3path.V3PathFileExists(controllerLog):
        os.RemoveFile(controllerLog)
    let controllerRun = hostops.v3RunFileLogged(root,
                                                "r2c_truth_compare_controller_smoke",
                                                controllerExe,
                                                [
                                                    "compare-truth",
                                                    "--exec-snapshot", execSnapshotPath,
                                                    "--truth-trace", truthTracePath,
                                                    "--native-gui-summary", nativeGuiSummaryPath,
                                                    "--out", truthComparePath
                                                ],
                                                [],
                                                root,
                                                0,
                                                controllerLog)
    assert(hostops.v3LoggedRunOk(controllerRun), "v3 r2c truth compare controller smoke: controller rc")
    assert(v3path.V3FileExistsNonEmpty(root, truthComparePath), "v3 r2c truth compare controller smoke: truth compare json")
    assert(v3path.V3FileExistsNonEmpty(root, truthCompareSummaryPath), "v3 r2c truth compare controller smoke: truth compare summary")
    assert(v3path.V3FileExistsNonEmpty(root, compareReportPath), "v3 r2c truth compare controller smoke: compare report")

    let truthCompareText = v3path.V3ReadTextFile("", truthComparePath)
    let summaryText = v3path.V3ReadTextFile("", truthCompareSummaryPath)
    let reportText = v3path.V3ReadTextFile("", compareReportPath)
    assert(v3path.V3TextContains(truthCompareText, "\"ok\": true"),
           "v3 r2c truth compare controller smoke: compare ok")
    assert(v3path.V3TextContains(truthCompareText, "\"native_gui_summary_ready\": true"),
           "v3 r2c truth compare controller smoke: compare native gui summary ready")
    assert(v3path.V3TextContains(truthCompareText, "\"native_gui_runtime_bundle_ready\": true"),
           "v3 r2c truth compare controller smoke: compare runtime bundle ready")
    assert(v3path.V3TextContains(truthCompareText, "\"native_gui_runtime_contract_ready\": true"),
           "v3 r2c truth compare controller smoke: compare runtime contract ready")
    assert(v3path.V3TextContains(truthCompareText, "\"native_gui_runtime_bundle_route_state\": \"home_default\""),
           "v3 r2c truth compare controller smoke: compare runtime route state")
    assert(v3path.V3TextContains(truthCompareText, "\"native_gui_runtime_bundle_semantic_nodes_count\": 83"),
           "v3 r2c truth compare controller smoke: compare runtime semantic nodes")
    assert(v3path.V3TextContains(truthCompareText, "\"native_gui_runtime_bundle_layout_item_count\": 31"),
           "v3 r2c truth compare controller smoke: compare runtime layout count")
    assert(v3path.V3TextContains(truthCompareText, "\"native_gui_runtime_bundle_render_command_count\": 44"),
           "v3 r2c truth compare controller smoke: compare runtime render count")
    assert(v3path.V3TextContains(truthCompareText, "\"native_gui_native_layout_plan_item_count\": 31"),
           "v3 r2c truth compare controller smoke: compare native layout plan count")
    assert(v3path.V3TextContains(truthCompareText, "\"native_gui_render_plan_command_count\": 44"),
           "v3 r2c truth compare controller smoke: compare render plan count")

    assert(v3path.V3TextContains(summaryText, "native_gui_summary_ready=true"),
           "v3 r2c truth compare controller smoke: summary native gui ready")
    assert(v3path.V3TextContains(summaryText, "native_gui_runtime_bundle_route_state=home_default"),
           "v3 r2c truth compare controller smoke: summary runtime route state")
    assert(v3path.V3TextContains(summaryText, "native_gui_runtime_bundle_semantic_nodes_count=83"),
           "v3 r2c truth compare controller smoke: summary runtime semantic nodes")
    assert(v3path.V3TextContains(summaryText, "native_gui_runtime_contract_interactive_item_count=7"),
           "v3 r2c truth compare controller smoke: summary runtime interactive count")

    assert(v3path.V3TextContains(reportText, "\"native_gui_summary_ready\": true"),
           "v3 r2c truth compare controller smoke: report native gui ready")
    assert(v3path.V3TextContains(reportText, "\"native_gui_runtime_bundle_ready\": true"),
           "v3 r2c truth compare controller smoke: report runtime bundle ready")
    assert(v3path.V3TextContains(reportText, "\"native_gui_runtime_bundle_route_count\": 1"),
           "v3 r2c truth compare controller smoke: report runtime route count")
    assert(v3path.V3TextContains(reportText, "\"native_gui_runtime_bundle_supported_count\": 5"),
           "v3 r2c truth compare controller smoke: report runtime supported count")
    assert(v3path.V3TextContains(reportText, "\"native_gui_render_plan_command_count\": 44"),
           "v3 r2c truth compare controller smoke: report render plan count")

    echo("v3 r2c_react_v3_truth_compare_controller_smoke ok")
    return 0
