import std/result
import cheng/v3/quic/connection as qconn
import cheng/v3/quic/msquicruntime as qruntime
import cheng/v3/quic/msquictransport_native as qtransport
import cheng/v3/libp2p/transports/quic_transport
import cheng/v3/tooling/vpn_proxy_hysteria2_session as hy2sess

fn vpnHy2BytesEq(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    var settings = qruntime.initMsQuicSettings()
    settings.allowDatagram = true

    var listener = qtransport.initMsQuicTransport()
    assert(IsOk(qtransport.setMsQuicTransportSettings(listener, settings)),
        "v3 vpn proxy hysteria2 session: listener settings")
    assert(IsOk(quic_transport.v3Libp2pQuicConfigureTls(listener)),
        "v3 vpn proxy hysteria2 session: listener tls")
    let listenAddrRes = quic_transport.v3Libp2pQuicAddrFromHostPort("127.0.0.1", 0)
    assert(IsOk(listenAddrRes), "v3 vpn proxy hysteria2 session: listen addr")
    qtransport.start(listener, Value(listenAddrRes))

    var client = qtransport.initMsQuicTransport()
    assert(IsOk(qtransport.setMsQuicTransportSettings(client, settings)),
        "v3 vpn proxy hysteria2 session: client settings")
    assert(IsOk(quic_transport.v3Libp2pQuicConfigureTls(client)),
        "v3 vpn proxy hysteria2 session: client tls")
    let dialRes = qtransport.dial(client, listener.listenAddr)
    assert(IsOk(dialRes), "v3 vpn proxy hysteria2 session: dial")
    var clientConn = Value(dialRes)
    let acceptRes = qtransport.accept(listener)
    assert(IsOk(acceptRes), "v3 vpn proxy hysteria2 session: accept")
    var serverConn = Value(acceptRes)

    assert(IsOk(hy2sess.V3VpnProxyHy2ClientSendPreamble(clientConn)),
        "v3 vpn proxy hysteria2 session: client preamble send")
    assert(IsOk(hy2sess.V3VpnProxyHy2ServerSendPreamble(serverConn)),
        "v3 vpn proxy hysteria2 session: server preamble send")
    assert(IsOk(hy2sess.V3VpnProxyHy2ServerExpectClientPreamble(serverConn)),
        "v3 vpn proxy hysteria2 session: server preamble read")
    assert(IsOk(hy2sess.V3VpnProxyHy2ClientExpectServerPreamble(clientConn)),
        "v3 vpn proxy hysteria2 session: client preamble read")

    assert(IsOk(hy2sess.V3VpnProxyHy2ClientWriteAuth(clientConn,
                                                     "vpn-proxy.test",
                                                     "secret-token",
                                                     123456,
                                                     "pad-auth")),
        "v3 vpn proxy hysteria2 session: client auth write")
    let authReqRes = hy2sess.V3VpnProxyHy2ServerReadAuth(serverConn)
    assert(IsOk(authReqRes), "v3 vpn proxy hysteria2 session: server auth read")
    let authReq = Value(authReqRes)
    assert(authReq.authority == "vpn-proxy.test",
        "v3 vpn proxy hysteria2 session: auth authority")
    assert(authReq.auth == "secret-token",
        "v3 vpn proxy hysteria2 session: auth secret")
    assert(authReq.ccRx == 123456,
        "v3 vpn proxy hysteria2 session: auth cc-rx")
    assert(IsOk(hy2sess.V3VpnProxyHy2ServerWriteAuthResponse(serverConn,
                                                             233,
                                                             true,
                                                             "auto",
                                                             "pad-resp")),
        "v3 vpn proxy hysteria2 session: server auth write")
    let authRespRes = hy2sess.V3VpnProxyHy2ClientReadAuthResponse(clientConn)
    assert(IsOk(authRespRes), "v3 vpn proxy hysteria2 session: client auth read")
    let authResp = Value(authRespRes)
    assert(authResp.statusCode == 233,
        "v3 vpn proxy hysteria2 session: auth status")
    assert(authResp.udpEnabled,
        "v3 vpn proxy hysteria2 session: auth udp")
    assert(authResp.ccRxText == "auto",
        "v3 vpn proxy hysteria2 session: auth response cc-rx")

    assert(IsOk(hy2sess.V3VpnProxyHy2ClientWriteTcpRequest(clientConn,
                                                           8,
                                                           "example.com:443",
                                                           bytesFromString("req-pad"))),
        "v3 vpn proxy hysteria2 session: client tcp request write")
    let tcpReqRes = hy2sess.V3VpnProxyHy2ServerReadTcpRequest(serverConn, 8)
    assert(IsOk(tcpReqRes), "v3 vpn proxy hysteria2 session: server tcp request read")
    let tcpReq = Value(tcpReqRes)
    assert(tcpReq.req.address == "example.com:443",
        "v3 vpn proxy hysteria2 session: tcp request address")
    assert(vpnHy2BytesEq(tcpReq.req.padding, bytesFromString("req-pad")),
        "v3 vpn proxy hysteria2 session: tcp request padding")
    assert(IsOk(hy2sess.V3VpnProxyHy2ServerWriteTcpResponse(serverConn,
                                                            8,
                                                            true,
                                                            "",
                                                            bytesFromString("resp-pad"))),
        "v3 vpn proxy hysteria2 session: server tcp response write")
    let tcpRespRes = hy2sess.V3VpnProxyHy2ClientReadTcpResponse(clientConn, 8)
    assert(IsOk(tcpRespRes), "v3 vpn proxy hysteria2 session: client tcp response read")
    let tcpResp = Value(tcpRespRes)
    assert(tcpResp.resp.ok,
        "v3 vpn proxy hysteria2 session: tcp response ok")
    assert(vpnHy2BytesEq(tcpResp.resp.padding, bytesFromString("resp-pad")),
        "v3 vpn proxy hysteria2 session: tcp response padding")

    qconn.connClose(serverConn)
    qconn.connClose(clientConn)
    qtransport.stop(listener)
    echo("v3 vpn_proxy_hysteria2_session_smoke ok")
    return 0
