import std/system
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/transports/tailnet_transport as tsnet

fn main(): int32 =
    var cfg: tsnet.V3Libp2pTailnetTransportConfig
    cfg.controlEndpoint = "https://control.example"
    cfg.relayEndpoint = "https://derp.default.example:443"
    cfg.syntheticIPv4 = "100.64.7.11"
    cfg.syntheticIPv6 = "fd7a:115c:a1e0::711"
    cfg.localPeerId = "tailnet-relay-override"
    cfg.exactRouting = true

    var transport = tsnet.v3Libp2pTailnetTransportInit(cfg)
    tsnet.v3Libp2pTailnetProviderStart(transport)
    tsnet.v3Libp2pTailnetProviderMarkProxyReady(transport)
    tsnet.v3Libp2pTailnetProviderDerpReady(transport)

    var rawTcp: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(rawTcp, "127.0.0.1", 7401)
    let listenRes = tsnet.v3Libp2pTailnetListen(transport, rawTcp)
    assert(IsOk(listenRes), "v3 tailnet relay override: listen")
    let published = tsnet.v3Libp2pTailnetPublishedAddrs(transport)

    var relayOnlyPeer: tsnet.V3Libp2pTailnetPeerSession
    relayOnlyPeer.peerId = "peer-relay-only"
    relayOnlyPeer.remoteTailnetIp = "100.64.7.88"
    relayOnlyPeer.relayAllowed = true
    relayOnlyPeer.relayOnly = true
    relayOnlyPeer.derpRegionCode = "sfo"
    tsnet.v3Libp2pTailnetUpsertPeerSession(transport, relayOnlyPeer)

    let relayPlanBuild = tsnet.v3Libp2pTailnetDialPlanBuildWithRelay(transport,
                                                                     "peer-relay-only",
                                                                     published[0],
                                                                     true,
                                                                     false,
                                                                     "relay-peer-01",
                                                                     "https://derp.alt.example:443",
                                                                     "lax")
    assert(relayPlanBuild.ok, "v3 tailnet relay override: relay plan")
    let relayPlan = relayPlanBuild.plan
    assert(relayPlan.pathKind == tsnet.v3Libp2pTailnetPathDerp,
        "v3 tailnet relay override: derp path")
    assert(relayPlan.routeText == "https://derp.alt.example:443",
        "v3 tailnet relay override: override route")
    assert(relayPlan.selectedRelayPeerId == "relay-peer-01",
        "v3 tailnet relay override: selected relay peer")
    assert(relayPlan.selectedRelayRegion == "lax",
        "v3 tailnet relay override: selected relay region")

    var directPeer: tsnet.V3Libp2pTailnetPeerSession
    directPeer.peerId = "peer-direct"
    directPeer.remoteTailnetIp = "100.64.7.89"
    directPeer.directReachable = true
    directPeer.relayAllowed = true
    directPeer.boundAddrText = tsnet.v3Libp2pTailnetAddrText(rawTcp)
    tsnet.v3Libp2pTailnetUpsertPeerSession(transport, directPeer)

    let directPlanBuild = tsnet.v3Libp2pTailnetDialPlanBuildWithRelay(transport,
                                                                      "peer-direct",
                                                                      published[0],
                                                                      false,
                                                                      false,
                                                                      "relay-peer-01",
                                                                      "https://derp.alt.example:443",
                                                                      "lax")
    assert(directPlanBuild.ok, "v3 tailnet relay override: direct plan")
    let directPlan = directPlanBuild.plan
    assert(directPlan.pathKind == tsnet.v3Libp2pTailnetPathDirect,
        "v3 tailnet relay override: direct path wins")
    assert(directPlan.routeText == tsnet.v3Libp2pTailnetAddrText(rawTcp),
        "v3 tailnet relay override: direct route text")
    assert(directPlan.selectedRelayEndpoint == "",
        "v3 tailnet relay override: direct clears relay override")

    echo("v3 libp2p_tailnet_relay_override_smoke ok")
    return 0
