import std/system
import cheng/v3/std/bytes_layout as layout

fn main(): int32 =
    var xs: layout.FixedBytes32[]
    xs = []
    var a = layout.FixedBytes32()
    a.data[0] = 1
    a.data[31] = 7
    add(xs, a)
    let loaded = xs[0]
    assert(layout.fixedBytes32Equal(loaded, a), "v3 fixedbytes32 seq index: loaded equal")
    echo("v3 fixedbytes32_seq_index_smoke ok")
    return 0
