import cheng/v3/project/chain_node as node

fn main(): int32 =
    var state: node.V3ChainNode
    assert(IsOk(node.V3ChainNodeInitInto(state, "snapshot-boundary-node", "snapshot-boundary-seed")),
           "v3 chain_node snapshot boundary: init")
    var snapshot: node.V3ChainNodeServeSnapshot
    node.V3ChainNodeServeOnceInto(snapshot, state)
    echo("v3 chain_node_snapshot_return_boundary_smoke ok")
    return 0
