import std/cmdline as cmdline
import std/strutils as strutil

fn requestedTarget(): str =
    var targetTriple: str
    if cmdline.readFirstFlagValue("--target", targetTriple):
        let trimmed = strutil.strip(targetTriple)
        if len(trimmed) > 0:
            return trimmed
    return "fallback-target"

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let target = requestedTarget()
    assert(target == "x86_64-unknown-linux-gnu", "compiler requested target smoke")
    echo("v3 compiler_requested_target_smoke ok")
    return 0
