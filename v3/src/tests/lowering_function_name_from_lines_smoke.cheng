import cheng/v3/tooling/path as v3path
import cheng/v3/lang/parser
import cheng/v3/backend/lowering_plan as lower

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let packageRoot = v3path.V3PathJoin(workspaceRoot, "v3")
    let sourcePath = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let text = v3path.V3ReadTextFile("", sourcePath)
    let lines = parser.v3ParserSplitChar(text, '\n')
    var functionName = ""
    for i in 0..<lines.len:
        let current = lower.v3LoweringFunctionNameFromLine(lines[i])
        if current != "":
            functionName = current
    assert(functionName == "main", "v3 lowering function name from lines")
    let symbolText = lower.v3LoweringFunctionSymbolText("cheng/v3/tests/program_selfhost_smoke", functionName)
    assert(symbolText == "cheng/v3/tests/program_selfhost_smoke::main",
           "v3 lowering function name symbol text")
    echo("v3 lowering_function_name_from_lines_smoke ok")
    return 0
