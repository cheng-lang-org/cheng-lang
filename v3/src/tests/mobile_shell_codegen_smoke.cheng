import std/monotimes
import std/os
import std/strings
import cheng/v3/tooling/mobile_shell_codegen as mshell

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let stamp: str = int64ToStr(monotimes.MonoTimeNs(monotimes.GetMonoTime()))
    let outDir: str = "/tmp/v3_mobile_shell_codegen_smoke_" + stamp
    let args: str[] = [
        "export",
        "--platform", "all",
        "--out-dir", outDir,
        "--app-id", "org.cheng.smoke",
        "--app-name", "ChengSmoke",
        "--lib-name", "cheng_smoke_app"
    ]
    var outputText: str = ""
    var errorText: str = ""
    let rc: int32 = mshell.v3MobileShellRun(root, args, outputText, errorText)
    let errorPath: str = os.JoinPath(outDir, "mobile_shell_error.txt")
    if rc != 0:
        os.WriteFile(errorPath, errorText)
        echo("mobile shell smoke: export failed")
        return 1
    assert(len(errorText) == 0, "mobile shell smoke: export empty error")

    let manifest: str = os.JoinPath(outDir, "mobile_shell_manifest_v1.json")
    let androidGradleProperties: str = os.JoinPath(outDir, "android/gradle.properties")
    let androidHost: str = os.JoinPath(outDir, "android/app/src/main/cpp/cheng_generated_android_host.c")
    let androidActivity: str = os.JoinPath(outDir, "android/app/src/main/kotlin/org/cheng/smoke/ChengMainActivity.kt")
    let androidStrings: str = os.JoinPath(outDir, "android/app/src/main/res/values/strings.xml")
    let iosViewController: str = os.JoinPath(outDir, "ios/ChengGeneratedMetalViewController.m")
    let iosProject: str = os.JoinPath(outDir, "ios/ChengGeneratedApp.xcodeproj/project.pbxproj")
    let harmonyHvigorFile: str = os.JoinPath(outDir, "harmony/hvigorfile.ts")
    let harmonyHvigorConfig: str = os.JoinPath(outDir, "harmony/hvigor/hvigor-config.json5")
    let harmonyEntryHvigorFile: str = os.JoinPath(outDir, "harmony/entry/hvigorfile.ts")
    let harmonyEntryBuildProfile: str = os.JoinPath(outDir, "harmony/entry/build-profile.json5")
    let harmonyStringJson: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/base/element/string.json")
    let harmonyColorJson: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/base/element/color.json")
    let harmonyAppIcon: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/base/media/app_icon.svg")
    let harmonyHost: str = os.JoinPath(outDir, "harmony/entry/src/main/cpp/cheng_generated_harmony_host.cpp")
    let harmonyEntryAbility: str = os.JoinPath(outDir, "harmony/entry/src/main/ets/entryability/EntryAbility.ets")
    let harmonyMainPages: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/base/profile/main_pages.json")

    assert(os.FileExists(manifest), "mobile shell smoke: manifest exists")
    assert(os.FileExists(androidGradleProperties), "mobile shell smoke: android gradle properties exists")
    assert(os.FileExists(androidHost), "mobile shell smoke: android host exists")
    assert(os.FileExists(androidActivity), "mobile shell smoke: android activity exists")
    assert(os.FileExists(androidStrings), "mobile shell smoke: android strings exists")
    assert(os.FileExists(iosViewController), "mobile shell smoke: ios controller exists")
    assert(os.FileExists(iosProject), "mobile shell smoke: ios project exists")
    assert(os.FileExists(harmonyHvigorFile), "mobile shell smoke: harmony hvigor exists")
    assert(os.FileExists(harmonyHvigorConfig), "mobile shell smoke: harmony hvigor config exists")
    assert(os.FileExists(harmonyEntryHvigorFile), "mobile shell smoke: harmony entry hvigor exists")
    assert(os.FileExists(harmonyEntryBuildProfile), "mobile shell smoke: harmony entry build profile exists")
    assert(os.FileExists(harmonyStringJson), "mobile shell smoke: harmony string json exists")
    assert(os.FileExists(harmonyColorJson), "mobile shell smoke: harmony color json exists")
    assert(os.FileExists(harmonyAppIcon), "mobile shell smoke: harmony app icon exists")
    assert(os.FileExists(harmonyHost), "mobile shell smoke: harmony host exists")
    assert(os.FileExists(harmonyEntryAbility), "mobile shell smoke: harmony entry ability exists")
    assert(os.FileExists(harmonyMainPages), "mobile shell smoke: harmony main pages exists")

    let manifestText: str = os.ReadFile(manifest)
    let androidGradlePropertiesText: str = os.ReadFile(androidGradleProperties)
    let androidHostText: str = os.ReadFile(androidHost)
    let androidStringsText: str = os.ReadFile(androidStrings)
    let iosViewControllerText: str = os.ReadFile(iosViewController)
    let iosProjectText: str = os.ReadFile(iosProject)
    let harmonyHvigorFileText: str = os.ReadFile(harmonyHvigorFile)
    let harmonyHvigorConfigText: str = os.ReadFile(harmonyHvigorConfig)
    let harmonyEntryHvigorFileText: str = os.ReadFile(harmonyEntryHvigorFile)
    let harmonyEntryBuildProfileText: str = os.ReadFile(harmonyEntryBuildProfile)
    let harmonyStringJsonText: str = os.ReadFile(harmonyStringJson)
    let harmonyColorJsonText: str = os.ReadFile(harmonyColorJson)
    let harmonyAppIconText: str = os.ReadFile(harmonyAppIcon)
    let harmonyHostText: str = os.ReadFile(harmonyHost)
    let harmonyEntryAbilityText: str = os.ReadFile(harmonyEntryAbility)
    let harmonyMainPagesText: str = os.ReadFile(harmonyMainPages)

    assert(strings.StrContains(manifestText, "\"format\": \"mobile_shell_manifest_v1\""),
           "mobile shell smoke: manifest format")
    assert(strings.StrContains(manifestText, "\"app_id\": \"org.cheng.smoke\""),
           "mobile shell smoke: manifest app id")
    assert(strings.StrContains(androidGradlePropertiesText, "android.useAndroidX=true"),
           "mobile shell smoke: android gradle properties content")
    assert(strings.StrContains(androidHostText, "ANativeWindow_fromSurface"),
           "mobile shell smoke: android surface glue")
    assert(strings.StrContains(androidStringsText, "<string name=\"app_name\">ChengSmoke</string>"),
           "mobile shell smoke: android app name string")
    assert(strings.StrContains(iosViewControllerText, "CAMetalLayer"),
           "mobile shell smoke: ios metal glue")
    assert(strings.StrContains(iosProjectText, "PBXProject"),
           "mobile shell smoke: ios project syntax")
    assert(strings.StrContains(iosProjectText, "PRODUCT_BUNDLE_IDENTIFIER = \"org.cheng.smoke\";"),
           "mobile shell smoke: ios bundle id")
    assert(strings.StrContains(harmonyHvigorFileText, "appTasks"),
           "mobile shell smoke: harmony hvigor content")
    assert(strings.StrContains(harmonyHvigorConfigText, "\"modelVersion\": \"5.0.0\""),
           "mobile shell smoke: harmony hvigor config content")
    assert(strings.StrContains(harmonyEntryHvigorFileText, "hapTasks"),
           "mobile shell smoke: harmony entry hvigor content")
    assert(strings.StrContains(harmonyEntryBuildProfileText, "\"apiType\": \"stageMode\""),
           "mobile shell smoke: harmony entry build profile content")
    assert(strings.StrContains(harmonyStringJsonText, "\"name\": \"app_name\""),
           "mobile shell smoke: harmony string json content")
    assert(strings.StrContains(harmonyColorJsonText, "\"name\": \"start_window_background\""),
           "mobile shell smoke: harmony color json content")
    assert(strings.StrContains(harmonyAppIconText, "<svg"),
           "mobile shell smoke: harmony app icon svg content")
    assert(strings.StrContains(harmonyHostText, "OHNativeWindow"),
           "mobile shell smoke: harmony native window glue")
    assert(strings.StrContains(harmonyEntryAbilityText, "windowStage.loadContent('pages/Index'"),
           "mobile shell smoke: harmony entry ability content")
    assert(strings.StrContains(harmonyMainPagesText, "\"pages/Index\""),
           "mobile shell smoke: harmony pages manifest")
    echo("v3 mobile_shell_codegen_smoke ok")
    return 0
