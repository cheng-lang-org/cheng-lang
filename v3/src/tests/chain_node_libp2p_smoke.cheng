import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/anti_entropy as anti
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host
import cheng/v3/project/chain_node as node
import cheng/v3/project/chain_node_libp2p as net

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node libp2p: init server")
    var client: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(client, "node-b", "chain-node-a")),
           "v3 chain_node libp2p: init client")
    var serverHost = host.v3Libp2pHostInit("chain.server")
    var clientHost = host.v3Libp2pHostInit("chain.client")
    var serverAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(serverAddr, "127.0.0.1", 6201)
    let listenRes = host.v3Libp2pListen(serverHost, serverAddr)
    assert(listenRes.ok, "v3 chain_node libp2p: listen")
    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolGossipsub)
    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolStore)
    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolGossipsub)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolStore)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolSync)
    let dialRes = host.v3Libp2pDial(clientHost,
                                    serverHost.selfPeerId,
                                    serverAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 chain_node libp2p: dial")
    let mintRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintRes.ok, "v3 chain_node libp2p: mint")
    let transferRes = node.v3ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferRes.ok, "v3 chain_node libp2p: transfer")
    if layout.fixedBytes32Equal(Value(mintRes), Value(transferRes)):
        assert(false, "v3 chain_node libp2p: distinct cids")
    let serveRes = net.v3ChainNodeLibp2pServeOnce(server, serverHost)
    assert(serveRes.ok, "v3 chain_node libp2p: serve")
    assert(serveRes.value, "v3 chain_node libp2p: serve active")
    assert(serverHost.publishLog.len == 1, "v3 chain_node libp2p: advertise published")
    assert(serverHost.storeEntries.len == 2, "v3 chain_node libp2p: advertise plus snapshot stored")
    var query: overlay.V3StoreQuery
    net.v3ChainNodeLibp2pSnapshotQueryFill(query, server.address)
    var syncedEntries: overlay.V3IngressEnvelope[]
    let syncEntriesRes = host.v3Libp2pSyncRequest(clientHost, serverHost, serverHost.selfPeerId, query, syncedEntries)
    assert(syncEntriesRes.ok, "v3 chain_node libp2p: sync request")
    var syncedSnapshot: node.V3ChainNodeServeSnapshot
    let syncedDecodeRes = net.v3ChainNodeLibp2pDecodeLatestSnapshotFill(syncedEntries, server.address, syncedSnapshot)
    assert(syncedDecodeRes.ok, "v3 chain_node libp2p: synced decode")
    let syncRes = node.v3ChainNodeSyncOnce(client, syncedSnapshot)
    assert(syncRes.ok, "v3 chain_node libp2p: sync once")
    assert(syncRes.value, "v3 chain_node libp2p: sync changed")
    assert(clientHost.openStreamPeers.len == 1, "v3 chain_node libp2p: opened sync stream")
    assert(clientHost.syncRequestCount == 1, "v3 chain_node libp2p: sync request count")
    assert(serverHost.syncServeCount == 1, "v3 chain_node libp2p: sync serve count")
    let aliceRes = node.v3ChainNodeBalance(client, 7, 1001)
    assert(aliceRes.ok, "v3 chain_node libp2p: alice balance")
    assert(Value(aliceRes) == int64(60), "v3 chain_node libp2p: alice 60")
    let bobRes = node.v3ChainNodeBalance(client, 7, 2002)
    assert(bobRes.ok, "v3 chain_node libp2p: bob balance")
    assert(Value(bobRes) == int64(40), "v3 chain_node libp2p: bob 40")
    var serverSnapshot: node.V3ChainNodeServeSnapshot
    node.v3ChainNodeServeOnceInto(serverSnapshot, server)
    var clientSnapshot: node.V3ChainNodeServeSnapshot
    node.v3ChainNodeServeOnceInto(clientSnapshot, client)
    assert(layout.fixedBytes32Equal(serverSnapshot.tipEventCid, clientSnapshot.tipEventCid),
           "v3 chain_node libp2p: tip cid")
    assert(layout.fixedBytes32Equal(serverSnapshot.forest.forestCid, clientSnapshot.forest.forestCid),
           "v3 chain_node libp2p: forest cid")
    assert(anti.v3AntiEntropySignatureEqual(serverSnapshot.signature, clientSnapshot.signature),
           "v3 chain_node libp2p: signature")
    var syncedEntriesAgain: overlay.V3IngressEnvelope[]
    let syncEntriesAgainRes = host.v3Libp2pSyncRequest(clientHost, serverHost, serverHost.selfPeerId, query, syncedEntriesAgain)
    assert(syncEntriesAgainRes.ok, "v3 chain_node libp2p: second sync request")
    var syncedSnapshotAgain: node.V3ChainNodeServeSnapshot
    let syncedDecodeAgainRes = net.v3ChainNodeLibp2pDecodeLatestSnapshotFill(syncedEntriesAgain, server.address, syncedSnapshotAgain)
    assert(syncedDecodeAgainRes.ok, "v3 chain_node libp2p: second synced decode")
    let syncAgainRes = node.v3ChainNodeSyncOnce(client, syncedSnapshotAgain)
    assert(syncAgainRes.ok, "v3 chain_node libp2p: second sync")
    assert(!syncAgainRes.value, "v3 chain_node libp2p: second sync idle")
    assert(clientHost.syncRequestCount == 2, "v3 chain_node libp2p: second sync request count")
    assert(serverHost.syncServeCount == 2, "v3 chain_node libp2p: second sync serve count")
    echo("v3 chain_node_libp2p_smoke ok")
    return 0
