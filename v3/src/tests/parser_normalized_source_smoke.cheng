import std/os
import cheng/v3/lang/parser
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/backend/system_link_plan as slplan

fn ensureDir(path: str) =
    if !os.DirExists(path):
        os.CreateDir(path)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let fixturePath = v3path.V3PathJoin(root, "v3/src/tests/parser_normalized_decl_fixture.cheng")
    let text = os.ReadFile(fixturePath)
    var decls: parser.V3NormalizedFunctionDecl[] = []
    var err = ""
    assert(parser.v3ParserReadNormalizedFunctionDecls(text, decls, err),
           "v3 parser normalized source: read decls")
    assert(decls.len == 4, "v3 parser normalized source: decl count")
    assert(decls[0].name == "AlphaSeven", "v3 parser normalized source: alpha name")
    assert(!decls[0].importc, "v3 parser normalized source: alpha importc")
    assert(decls[0].explicitExportName == "alphaSeven", "v3 parser normalized source: alpha export name")
    assert(decls[1].name == "puts", "v3 parser normalized source: puts name")
    assert(decls[1].importc, "v3 parser normalized source: puts importc")
    assert(decls[1].explicitExportName == "", "v3 parser normalized source: puts export cleared")
    assert(decls[2].name == "hostNow", "v3 parser normalized source: inline importc name")
    assert(decls[2].importc, "v3 parser normalized source: inline importc")
    assert(decls[3].name == "BetaTwice", "v3 parser normalized source: beta name")
    assert(decls[3].explicitExportName == "betaTwice", "v3 parser normalized source: beta export name")
    assert(parser.v3ParserHasCompilerTopLevel(text), "v3 parser normalized source: compiler top level")
    assert(!parser.v3ParserMainFunctionPresent(text), "v3 parser normalized source: main absent")

    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_parser_normalized_source")
    let workspaceDir = v3path.V3PathJoin(outDir, "workspace")
    let pkgRoot = v3path.V3PathJoin(workspaceDir, "alias_pkg")
    let srcDir = v3path.V3PathJoin(pkgRoot, "src")
    ensureDir(outDir)
    ensureDir(workspaceDir)
    ensureDir(pkgRoot)
    ensureDir(srcDir)
    os.WriteFile(v3path.V3PathJoin(pkgRoot, "cheng-package.toml"),
                 "package_id = \"pkg://cheng/alias_pkg\"\nmodule_prefix = \"alias_pkg\"\n")
    let aliasSource = v3path.V3PathJoin(srcDir, "alias_main.cheng")
    let aliasText = "func main(): int32 =\n    return 0\n"
    os.WriteFile(aliasSource, aliasText)
    let outputPath = v3path.V3PathJoin(outDir, "alias_main")
    let req = creq.v3CompilerRequestNew(pkgRoot,
                                        aliasSource,
                                        outputPath,
                                        "arm64-apple-darwin",
                                        creq.v3EmitExe,
                                        "")
    var plan: slplan.V3SystemLinkPlanStub
    err = ""
    assert(!slplan.v3BuildSystemLinkPlanStub(root, req, plan, err),
           "v3 parser normalized source: reject func alias")
    assert(v3path.V3TextContains(err, "unsupported top-level function alias 'func'"),
           "v3 parser normalized source: reject func alias text")

    let nestedProcText = "fn main(): int32 =\n    proc = 1\n    return proc\n"
    var nestedDecls: parser.V3NormalizedFunctionDecl[] = []
    err = ""
    assert(parser.v3ParserReadNormalizedFunctionDecls(nestedProcText, nestedDecls, err),
           "v3 parser normalized source: ignore indented proc assignment")
    assert(nestedDecls.len == 1, "v3 parser normalized source: indented proc decl count")
    assert(nestedDecls[0].name == "main", "v3 parser normalized source: indented proc keep main")
    echo("v3 parser_normalized_source_smoke ok")
    return 0
