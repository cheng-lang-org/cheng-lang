import std/system
import std/rawbytes
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/dag_mempool as dag
import cheng/v3/chain/erasure_swarm as swarm
import cheng/v3/chain/content_fetch as fetch
import cheng/v3/chain/content_runtime as runtime
import cheng/v3/chain/content_runtime_host_quic as runtime_host_quic
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host

fn contentQuicSmokeBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    let shard = bytesFromString("quic-shard")
    let blob = shard
    let summaryRes = dag.v3DagBlobSummaryFromBytes(blob, bytesLen(shard))
    assert(IsOk(summaryRes), "v3 content quic smoke: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.v3ErasureEncodingParamsMake(swarm.v3ErasureLayoutRsSystematic, 1, 0, bytesLen(shard))
    assert(IsOk(paramsRes), "v3 content quic smoke: params")
    let params = Value(paramsRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    add(shardPayloadCids, swarm.v3ErasureShardPayloadCid(shard))
    let manifestRes = swarm.v3ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), "v3 content quic smoke: manifest")
    let manifest = Value(manifestRes)
    let requestRes = swarm.v3ErasureShardPullRequestMake(manifest, 0)
    assert(IsOk(requestRes), "v3 content quic smoke: request")
    let request = Value(requestRes)

    var serverRuntime = runtime.v3ContentRuntimeInit()
    let storeManifestRes = runtime.v3ContentRuntimeStoreManifest(serverRuntime, manifest)
    assert(IsOk(storeManifestRes), "v3 content quic smoke: store manifest")
    let storeBlobRes = runtime.v3ContentRuntimeStoreBlobPayload(serverRuntime, summary.blobCid, blob)
    assert(IsOk(storeBlobRes), "v3 content quic smoke: store blob")
    let seedResponseRes = swarm.v3ErasureShardPullResponseMake(request, shard)
    assert(IsOk(seedResponseRes), "v3 content quic smoke: seed response")
    let seedStoreRes = runtime.v3ContentRuntimeStoreShardResponse(serverRuntime, Value(seedResponseRes))
    assert(IsOk(seedStoreRes), "v3 content quic smoke: store server cache")

    var server = host.v3Libp2pHostInit("content.quic.server")
    var client = host.v3Libp2pHostInit("content.quic.client")
    var listenAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillQuic(listenAddr, "127.0.0.1", 0)
    let listenRes = host.v3Libp2pListen(server, listenAddr)
    assert(listenRes.ok, "v3 content quic smoke: listen")
    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolContent)
    host.v3Libp2pRegisterHandler(client, types.v3Libp2pProtocolContent)
    let dialRes = host.v3Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 content quic smoke: dial")

    let manifestFetchReqRes = fetch.v3ContentFetchRequestManifest(manifest.manifestCid)
    assert(IsOk(manifestFetchReqRes), "v3 content quic smoke: manifest fetch request")
    let manifestFetchRequest = Value(manifestFetchReqRes)
    let manifestFetchRes = runtime_host_quic.v3ContentRuntimeRequestFetch(client,
                                                                          server,
                                                                          server.selfPeerId,
                                                                          serverRuntime,
                                                                          manifestFetchRequest)
    assert(IsOk(manifestFetchRes), "v3 content quic smoke: manifest fetch")
    let manifestFetchResponse = Value(manifestFetchRes)
    var manifestPull = swarm.V3ErasureShardManifest()
    let manifestPullRes = fetch.v3ContentFetchResponseToManifestFill(manifestPull,
                                                                     manifestFetchRequest,
                                                                     manifestFetchResponse)
    assert(IsOk(manifestPullRes), "v3 content quic smoke: manifest pull")
    assert(layout.fixedBytes32Equal(manifestPull.manifestCid, manifest.manifestCid),
        "v3 content quic smoke: manifest cid")

    let pullRes = runtime_host_quic.v3ContentRuntimeRequestShardPull(client,
                                                                     server,
                                                                     server.selfPeerId,
                                                                     serverRuntime,
                                                                     request)
    assert(IsOk(pullRes), "v3 content quic smoke: pull")
    let response = Value(pullRes)
    assert(layout.fixedBytes32Equal(response.shardCid, request.shardCid),
        "v3 content quic smoke: shard cid")
    assert(response.payloadLen == bytesLen(shard), "v3 content quic smoke: payload len")
    assert(contentQuicSmokeBytesEqual(response.payload, shard),
        "v3 content quic smoke: payload bytes")

    let rebuildRes = runtime.v3ContentRuntimeRebuildBlob(manifest, params, [response])
    assert(IsOk(rebuildRes), "v3 content quic smoke: rebuild")
    assert(contentQuicSmokeBytesEqual(Value(rebuildRes), blob),
        "v3 content quic smoke: rebuild bytes")

    echo("v3 content_quic_smoke ok")
    return 0
