import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus

fn main(): int32 =
    var index = consensus.V3ChainIndex()
    let zeroCid = layout.FixedBytes32()
    let event = consensus.v3ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let eventCid = consensus.v3ChainEventCid(event)
    var decision = consensus.V3ConsensusDecision()
    decision.eventCid = eventCid
    consensus.v3ConsensusApplyMint(index, event, eventCid, 0, decision)
    assert(decision.accepted, "v3 consensus apply mint: accepted")
    assert(decision.applied, "v3 consensus apply mint: applied")
    assert(index.accountIds.len == 1, "v3 consensus apply mint: account len")
    assert(index.accountIds[0] == 1001, "v3 consensus apply mint: account")
    assert(index.balances[0] == int64(100), "v3 consensus apply mint: balance")
    echo("v3 consensus_apply_mint_smoke ok")
    return 0
