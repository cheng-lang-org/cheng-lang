import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/v3_os_walk_dir_rec_smoke_tmp"
    let childDir: str = os.JoinPath(tmpRoot, "nested")
    let childFile: str = os.JoinPath(tmpRoot, "top.txt")
    let deepFile: str = os.JoinPath(childDir, "deep.txt")

    if os.FileExists(deepFile):
        assert(os.RemoveFile(deepFile), "v3 ordinary os.WalkDirRec cleanup deep file")
    if os.FileExists(childFile):
        assert(os.RemoveFile(childFile), "v3 ordinary os.WalkDirRec cleanup top file")
    if os.DirExists(childDir):
        os.RemoveDir(childDir)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

    os.CreateDir(tmpRoot)
    os.CreateDir(childDir)
    os.WriteFile(childFile, "top")
    os.WriteFile(deepFile, "deep")

    let entries = os.WalkDirRec(tmpRoot)
    var sawTop: bool
    var sawDeep: bool
    for i in 0..<entries.len:
        let entry = entries[i]
        if entry == childFile:
            sawTop = true
        elif entry == deepFile:
            sawDeep = true

    assert(entries.len == 2, "v3 ordinary os.WalkDirRec count")
    assert(sawTop, "v3 ordinary os.WalkDirRec top file")
    assert(sawDeep, "v3 ordinary os.WalkDirRec nested file")

    assert(os.RemoveFile(deepFile), "v3 ordinary os.WalkDirRec remove deep file")
    assert(os.RemoveFile(childFile), "v3 ordinary os.WalkDirRec remove top file")
    os.RemoveDir(childDir)
    os.RemoveDir(tmpRoot)
    echo("v3 os_walk_dir_rec_smoke ok")
    return 0
