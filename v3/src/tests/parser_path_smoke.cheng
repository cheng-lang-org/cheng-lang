import cheng/v3/lang/parser
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let packageRoot = v3path.V3PathJoin(workspaceRoot, "v3")
    let contractsSourcePath = v3path.V3PathJoin(packageRoot, "src/tooling/bootstrap_contracts.cheng")
    let stdSourcePath = v3path.V3PathJoin(workspaceRoot, "src/std/strutils.cheng")
    let codexPackageRoot = v3path.V3PathJoin(packageRoot, "codex")
    let codexSourcePath = v3path.V3PathJoin(codexPackageRoot, "src/tests/session_exec_smoke.cheng")
    let codexEngineSourcePath = v3path.V3PathJoin(codexPackageRoot, "src/core/engine.cheng")
    let typedFixturePath = v3path.V3PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let typedHelperPath = v3path.V3PathJoin(packageRoot, "src/tests/typed_expr_fact_helper.cheng")
    let typedHelperPlainPath = v3path.V3PathJoin(packageRoot, "src/tests/typed_expr_fact_helper_plain.cheng")
    let typedImportcHelperPath = v3path.V3PathJoin(packageRoot, "src/tests/typed_expr_fact_importc_helper.cheng")
    assert(parser.v3ParserPackageId(packageRoot) == "cheng/v3", "v3 parser path: package id")
    assert(v3path.V3TextSlice("std/strutils", 4, 8) == "strutils",
           "v3 parser path: std slice helper literal")
    assert(parser.v3ParserModulePathToSourcePath(workspaceRoot,
                                                 packageRoot,
                                                 "cheng/v3/tooling/bootstrap_contracts") == contractsSourcePath,
           "v3 parser path: package import")
    assert(parser.v3ParserModulePathToSourcePath(workspaceRoot,
                                                 packageRoot,
                                                 "std/strutils") == stdSourcePath,
           "v3 parser path: std import")
    assert(parser.v3ParserSourcePathToModulePath(workspaceRoot,
                                                 packageRoot,
                                                 contractsSourcePath) == "cheng/v3/tooling/bootstrap_contracts",
           "v3 parser path: package source")
    assert(parser.v3ParserSourcePathToModulePath(workspaceRoot,
                                                 packageRoot,
                                                 stdSourcePath) == "std/strutils",
           "v3 parser path: std source")
    assert(creq.v3CompilerResolvePackageRoot(workspaceRoot,
                                             codexSourcePath,
                                             workspaceRoot) == codexPackageRoot,
           "v3 parser path: nested package root from workspace root")
    assert(creq.v3CompilerResolvePackageRoot(workspaceRoot,
                                             codexSourcePath,
                                             packageRoot) == codexPackageRoot,
           "v3 parser path: nested package root from v3 root")
    assert(parser.v3ParserWorkspaceRoot(codexPackageRoot) == workspaceRoot,
           "v3 parser path: nested package workspace root")
    assert(parser.v3ParserPackageId(codexPackageRoot) == "cheng/codex",
           "v3 parser path: nested package id")
    assert(parser.v3ParserModulePathToSourcePath(workspaceRoot,
                                                 codexPackageRoot,
                                                 "cheng/codex/core/engine") == codexEngineSourcePath,
           "v3 parser path: nested package import")
    assert(parser.v3ParserModulePathToSourcePath(workspaceRoot,
                                                 codexPackageRoot,
                                                 "cheng/v3/tooling/bootstrap_contracts") == contractsSourcePath,
           "v3 parser path: shared v3 import from nested package")
    assert(parser.v3ParserModulePathToSourcePath(workspaceRoot,
                                                 codexPackageRoot,
                                                 "std/strutils") == stdSourcePath,
           "v3 parser path: shared std import from nested package")
    assert(parser.v3ParserSourcePathToModulePath(workspaceRoot,
                                                 codexPackageRoot,
                                                 codexEngineSourcePath) == "cheng/codex/core/engine",
           "v3 parser path: nested package source")
    assert(parser.v3ParserSourcePathToModulePath(workspaceRoot,
                                                 codexPackageRoot,
                                                 contractsSourcePath) == "cheng/v3/tooling/bootstrap_contracts",
           "v3 parser path: shared v3 source from nested package")
    var parsed: parser.V3ParsedSourceStub
    var err = ""
    assert(parser.v3ParseOrdinarySourceStub(codexPackageRoot, codexSourcePath, parsed, err),
           "v3 parser path: nested package parse stub")
    assert(parsed.workspaceRoot == workspaceRoot, "v3 parser path: parsed nested workspace root")
    assert(parsed.packageRoot == codexPackageRoot, "v3 parser path: parsed nested package root")
    assert(parsed.ownerModulePaths.len >= 1 &&
           parser.v3ParserStringSeqContains(parsed.ownerModulePaths, "cheng/codex/tests/session_exec_smoke"),
           "v3 parser path: parsed nested owner module")
    assert(parsed.unresolvedImportCount == 0, "v3 parser path: parsed nested imports resolved")
    var typedParsed: parser.V3ParsedSourceStub
    err = ""
    assert(parser.v3ParseOrdinarySourceStub(packageRoot, typedFixturePath, typedParsed, err),
           "v3 parser path: typed fixture parse stub")
    var foundGroupedImport = false
    for i in 0..<typedParsed.importEdges.len:
        if typedParsed.importEdges[i].targetModulePath == "cheng/v3/tests/typed_expr_fact_helper_plain":
            foundGroupedImport = true
    assert(foundGroupedImport, "v3 parser path: grouped import edge")
    assert(parser.v3NormalizedExprLayerHasExpr(typedParsed.normalizedExprLayer,
                                               parser.v3NormalizedExprCall,
                                               "external_call",
                                               28),
           "v3 parser path: alias external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedParsed.normalizedExprLayer,
                                               parser.v3NormalizedExprCall,
                                               "external_call",
                                               29),
           "v3 parser path: module stem external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedParsed.normalizedExprLayer,
                                               parser.v3NormalizedExprCall,
                                               "external_call",
                                               30),
           "v3 parser path: nested qualified external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedParsed.normalizedExprLayer,
                                               parser.v3NormalizedExprCall,
                                               "external_call",
                                               32),
           "v3 parser path: alias importc external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedParsed.normalizedExprLayer,
                                               parser.v3NormalizedExprCall,
                                               "external_call",
                                               33),
           "v3 parser path: nested importc external call")
    var sawAliasExternalTarget = false
    var sawNestedExternalTarget = false
    var sawAliasImportcTarget = false
    var sawNestedImportcTarget = false
    for i in 0..<typedParsed.normalizedExprLayer.exprs.len:
        let expr = typedParsed.normalizedExprLayer.exprs[i]
        if expr.kind != parser.v3NormalizedExprCall:
            continue
        if !expr.callResolved:
            continue
        if expr.lineNumber == 28:
            assert(expr.callTargetSourcePath == typedHelperPath,
                   "v3 parser path: alias external target source")
            assert(!expr.callTargetImportc,
                   "v3 parser path: alias external target importc")
            sawAliasExternalTarget = true
        elif expr.lineNumber == 30:
            assert(expr.callTargetSourcePath == typedHelperPlainPath,
                   "v3 parser path: nested external target source")
            assert(!expr.callTargetImportc,
                   "v3 parser path: nested external target importc")
            sawNestedExternalTarget = true
        elif expr.lineNumber == 32:
            assert(expr.callTargetSourcePath == typedImportcHelperPath,
                   "v3 parser path: alias importc target source")
            assert(expr.callTargetImportc,
                   "v3 parser path: alias importc target importc")
            sawAliasImportcTarget = true
        elif expr.lineNumber == 33:
            assert(expr.callTargetSourcePath == typedImportcHelperPath,
                   "v3 parser path: nested importc target source")
            assert(expr.callTargetImportc,
                   "v3 parser path: nested importc target importc")
            sawNestedImportcTarget = true
    assert(sawAliasExternalTarget, "v3 parser path: saw alias external target")
    assert(sawNestedExternalTarget, "v3 parser path: saw nested external target")
    assert(sawAliasImportcTarget, "v3 parser path: saw alias importc target")
    assert(sawNestedImportcTarget, "v3 parser path: saw nested importc target")
    echo("v3 parser_path_smoke ok")
    return 0
