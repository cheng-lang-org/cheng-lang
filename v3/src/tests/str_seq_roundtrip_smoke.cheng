import std/system
import cheng/v3/tooling/path as v3path

fn splitLines(text: str): str[] =
    var out: str[] = []
    var start: int32 = 0
    for i in 0..<text.len:
        if text[i] == '\n':
            add(out, v3path.v3TextSlice(text, start, i - start))
            start = i + 1
    if start <= text.len:
        add(out, v3path.v3TextSlice(text, start, text.len - start))
    return out

fn main(): int32 =
    let nl = charToString('\n')
    let parts = splitLines(" alpha " + nl + " beta " + nl)
    var ordered: str[] = []
    add(ordered, parts[0])
    add(ordered, parts[1])
    let current = ordered[1]
    let trimmed = v3path.v3PathTrim(current)
    assert(ordered.len == 2, "v3 str_seq_roundtrip_smoke: len")
    assert(trimmed == "beta", "v3 str_seq_roundtrip_smoke: trim after seq index")
    echo("v3 str_seq_roundtrip_smoke ok")
    return 0
