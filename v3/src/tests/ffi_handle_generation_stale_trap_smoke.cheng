import std/system

const
    probeHandleSlotMod: uint64 = 4294967296

@importc("cheng_ffi_raw_new_i32")
fn cheng_ffi_raw_new_i32(value: int32): ptr

@importc("cheng_v3_tcp_buffer_handle_register_bridge")
fn cheng_v3_tcp_buffer_handle_register_bridge(raw: ptr): uint64

@importc("cheng_v3_tcp_buffer_handle_resolve_bridge")
fn cheng_v3_tcp_buffer_handle_resolve_bridge(handle: uint64): ptr

@importc("cheng_v3_tcp_buffer_handle_release_raw_bridge")
fn cheng_v3_tcp_buffer_handle_release_raw_bridge(handle: uint64): int32

fn handleSlot(handle: uint64): uint64 =
    return handle % probeHandleSlotMod

fn handleGeneration(handle: uint64): uint64 =
    return handle / probeHandleSlotMod

fn main(): int32 =
    let raw0: ptr = cheng_ffi_raw_new_i32(40)
    if raw0 == nil:
        return 1
    let handle0: uint64 = cheng_v3_tcp_buffer_handle_register_bridge(raw0)
    if handle0 == uint64(0):
        return 2
    let slot0: uint64 = handleSlot(handle0)
    let generation0: uint64 = handleGeneration(handle0)
    if cheng_v3_tcp_buffer_handle_release_raw_bridge(handle0) != 0:
        return 3

    let raw1: ptr = cheng_ffi_raw_new_i32(7)
    if raw1 == nil:
        return 4
    let handle1: uint64 = cheng_v3_tcp_buffer_handle_register_bridge(raw1)
    if handle1 == uint64(0):
        return 5
    let slot1: uint64 = handleSlot(handle1)
    let generation1: uint64 = handleGeneration(handle1)
    if slot1 != slot0:
        return 6
    if generation1 != generation0 + uint64(1):
        return 7

    let stale: ptr = cheng_v3_tcp_buffer_handle_resolve_bridge(handle0)
    if stale == nil:
        return 8
    return 9
