fn hot_mul(n: int32): int32 =
    var acc: int32 = 0
    var i: int32 = 0
    while i < n:
        acc = acc + ((i * 3) % 17)
        i = i + 1
    return acc

fn hot_mix(n: int32): int32 =
    var acc: int32 = 0
    var i: int32 = 0
    while i < n:
        acc = acc + ((i * 5) % 23)
        i = i + 1
    return acc

fn main(): int32 =
    var total: int32 = 0
    var round: int32 = 0
    while round < 512:
        total = total + hot_mul(160000)
        total = total + hot_mix(80000)
        round = round + 1
    if total == -1:
        return 1
    return 0
