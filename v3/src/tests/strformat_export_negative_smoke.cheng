import std/cmdline as cmdline
import std/os as os
import std/os_host_process as hostos
import std/strings as strings

fn ensureDir(path: str) =
    if !os.dirExists(path):
        os.createDir(path)

fn envDefault(key: str, defaultValue: str): str =
    let raw: str = os.getEnv(key)
    if len(raw) > 0:
        return raw
    return defaultValue

fn currentExecutablePath(root: str): str =
    let raw: str = cmdline.programName()
    if len(raw) <= 0:
        return ""
    if os.isAbsolute(raw):
        return raw
    return os.joinPath(root, raw)

fn compileFixture(compiler: str,
                  root: str,
                  packageRoot: str,
                  inputPath: str,
                  outputPath: str,
                  logPath: str): os.ExecCmdResult =
    let target: str = envDefault("CHENG_V3_BOOTSTRAP_TARGET", "arm64-apple-darwin")
    var argv: str[]
    add(argv, "system-link-exec")
    add(argv, "--root")
    add(argv, packageRoot)
    add(argv, "--in")
    add(argv, inputPath)
    add(argv, "--emit")
    add(argv, "exe")
    add(argv, "--target")
    add(argv, target)
    add(argv, "--out")
    add(argv, outputPath)
    var envv: str[]
    let res = hostos.execFileCapture(compiler, argv, envv, root, true, 60)
    let resOutput = os.execCmdResultOutput(res)
    os.writeFile(logPath, resOutput)
    return res

fn main(): int32 =
    let root: str = os.getCurrentDir()
    let exePath: str = currentExecutablePath(root)
    assert(len(exePath) > 0 && os.fileExists(exePath),
           "v3 strformat export negative: executable path")
    let exeParts = os.splitFile(exePath)
    let exeDir = exeParts.dir
    let exeName = exeParts.name
    let outDirName = exeName + ".workspace"
    let outDir = os.joinPath(exeDir, outDirName)
    ensureDir(outDir)

    let workspaceDir = os.joinPath(outDir, "workspace")
    let pkgRoot = os.joinPath(workspaceDir, "consumer_pkg")
    let srcDir = os.joinPath(pkgRoot, "src")
    ensureDir(workspaceDir)
    ensureDir(pkgRoot)
    ensureDir(srcDir)
    let pkgManifestPath = os.joinPath(pkgRoot, "cheng-package.toml")
    os.writeFile(pkgManifestPath,
                 "package_id = \"pkg://cheng/strformat_negative_pkg\"\nmodule_prefix = \"strformat_negative_pkg\"\n")

    let compilerEnv = os.getEnv("CHENG_V3_SMOKE_COMPILER")
    var compilerRaw = "artifacts/v3_bootstrap/cheng.stage3"
    if len(compilerEnv) > 0:
        compilerRaw = compilerEnv
    var compiler = compilerRaw
    if !os.isAbsolute(compilerRaw):
        compiler = os.joinPath(root, compilerRaw)
    assert(os.fileExists(compiler),
           "v3 strformat export negative: compiler exists")

    let fmtSrc = os.joinPath(srcDir, "fmt_private_main.cheng")
    os.writeFile(fmtSrc,
                 "import std/strformat as strfmt\n\nfn main(): int32 =\n    let text = strfmt.fmt\"bad\"\n    echo(text)\n    return 0\n")
    let fmtOutPath = os.joinPath(outDir, "fmt_private")
    let fmtLogPath = os.joinPath(outDir, "fmt_private.compile.log")
    let fmtRes = compileFixture(compiler,
                                root,
                                pkgRoot,
                                fmtSrc,
                                fmtOutPath,
                                fmtLogPath)
    let fmtOutput = os.execCmdResultOutput(fmtRes)
    assert(os.execCmdResultExitCode(fmtRes) != 0,
           "v3 strformat export negative: lowercase fmt rejected")
    assert(strings.StrContains(fmtOutput,
                               "imported private symbol 'fmt' is not exported"),
           "v3 strformat export negative: lowercase fmt diagnostic")

    let linesSrc = os.joinPath(srcDir, "lines_private_main.cheng")
    os.writeFile(linesSrc,
                 "import std/strformat as strfmt\n\nfn main(): int32 =\n    let text = strfmt.lines([\"a\", \"b\"])\n    echo(text)\n    return 0\n")
    let linesOutPath = os.joinPath(outDir, "lines_private")
    let linesLogPath = os.joinPath(outDir, "lines_private.compile.log")
    let linesRes = compileFixture(compiler,
                                  root,
                                  pkgRoot,
                                  linesSrc,
                                  linesOutPath,
                                  linesLogPath)
    let linesOutput = os.execCmdResultOutput(linesRes)
    assert(os.execCmdResultExitCode(linesRes) != 0,
           "v3 strformat export negative: lowercase lines rejected")
    assert(strings.StrContains(linesOutput,
                               "imported private symbol 'lines' is not exported"),
           "v3 strformat export negative: lowercase lines diagnostic")

    echo("v3 strformat_export_negative_smoke ok")
    return 0
