import std/system
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node: init")
    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node mint: mint")
    assert(server.index.accountIds.len == 1, "v3 chain_node mint: account len")
    assert(server.index.accountAssetIds[0] == 7, "v3 chain_node mint: asset id")
    assert(server.index.accountIds[0] == 1001, "v3 chain_node mint: account id")
    assert(server.index.balances.len == 1, "v3 chain_node mint: balance len")
    assert(server.index.balances[0] == int64(100), "v3 chain_node mint: raw balance slot")
    assert(node.v3ChainNodeBalanceValue(server.index, 7, 1001) == int64(100), "v3 chain_node mint: raw balance lookup")
    let balanceRes = node.v3ChainNodeBalance(server, 7, 1001)
    assert(balanceRes.ok, "v3 chain_node mint: balance")
    assert(balanceRes.value == int64(100), "v3 chain_node mint: amount")
    echo("v3 chain_node_mint_runtime_smoke ok")
    return 0
