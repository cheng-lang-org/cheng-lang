import std/system
import std/os

fn main(): int32 =
    let fd = os.udpBindFdBridge("127.0.0.1", 6210, 0)
    if fd == -22:
        panic("udp bind bridge: invalid argument")
    if fd == -47:
        panic("udp bind bridge: address family not supported")
    if fd == -48:
        panic("udp bind bridge: address in use")
    if fd == -49:
        panic("udp bind bridge: address not available")
    assert(fd >= 0, "udp bind bridge: bind failed")
    let closeRc = os.udpCloseFd(fd)
    assert(closeRc == 0, "udp bind bridge: close failed")
    echo("v3 udp_bind_bridge_smoke ok")
    return 0
