import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr as lsmr
import cheng/v3/chain/lsmr_types as lt

fn main(): int32 =
    let addrRes = lsmr.v3LsmrAddressFromSeed("forest-one-cell", 3)
    assert(addrRes.ok, "lsmr forest one cell: address")
    var cell: lt.V3StateCell
    lsmr.v3LsmrStateCellFill(
        cell,
        7001,
        addrRes.value,
        3,
        layout.FixedBytes32(),
        layout.FixedBytes32()
    )
    var forest = lt.V3StateLayerForest()
    lsmr.v3BuildStateLayerForestFill(forest, [cell])
    assert(forest.edgeTree.entryCount == 1, "lsmr forest one cell: edge entries")
    assert(forest.edgeTree.nodeCount > 0, "lsmr forest one cell: edge nodes")
    return 0
