import std/strutils as strutil

importc fn cheng_v3_exec_program_capture_bridge(programName: cstring, argvWire: str, workingDir: cstring, exitCode: var int64): cstring
importc fn cheng_v3_exec_program_capture_bridge_dispose(raw: cstring)

fn encodeArgvWire(argv: str[]): str =
    var out = ""
    let sep = charToStr('\0')
    for i in 0..<argv.len:
        out = out + argv[i]
        out = out + sep
    return out

fn main(): int32 =
    let argv: str[] = [
        "direct-seq-ok",
        "two.with.dot",
        "/tmp/cheng.next",
        "--out:/tmp/cheng.next"
    ]
    var exitCode: int64 = -1
    let argvWire = encodeArgvWire(argv)
    let rawOutput: cstring = cheng_v3_exec_program_capture_bridge(strToCStringTemp("/bin/echo"),
                                                                  argvWire,
                                                                  strToCStringTemp(""),
                                                                  exitCode)
    let output: str = strFromCStringCopy(rawOutput)
    cheng_v3_exec_program_capture_bridge_dispose(rawOutput)
    assert(int32(exitCode) == 0, "direct seq exit")
    assert(strutil.Strip(output) == "direct-seq-ok two.with.dot /tmp/cheng.next --out:/tmp/cheng.next",
           "direct seq output")
    echo("v3 host_process_exec_file_direct_seq_smoke ok")
    return 0
