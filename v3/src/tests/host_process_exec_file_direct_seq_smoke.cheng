import std/strutils as strutil

importc fn cheng_v3_exec_program_capture_bridge(programName: cstring, argvSeq: str[], workingDir: cstring, exitCode: var int64): cstring
importc fn cheng_v3_exec_program_capture_bridge_dispose(raw: cstring)

fn main(): int32 =
    let argv: str[] = ["direct-seq-ok"]
    var exitCode: int64 = -1
    let rawOutput: cstring = cheng_v3_exec_program_capture_bridge(strToCStringTemp("/bin/echo"),
                                                                  argv,
                                                                  strToCStringTemp(""),
                                                                  exitCode)
    let output: str = strFromCStringCopy(rawOutput)
    cheng_v3_exec_program_capture_bridge_dispose(rawOutput)
    assert(int32(exitCode) == 0, "direct seq exit")
    assert(strutil.strip(output) == "direct-seq-ok", "direct seq output")
    echo("v3 host_process_exec_file_direct_seq_smoke ok")
    return 0
