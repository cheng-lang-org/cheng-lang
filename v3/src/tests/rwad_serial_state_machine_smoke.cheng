import cheng/v3/std/bytes_layout as layout
import cheng/v3/project/rwad_serial_state_machine as rwad

fn main(): int32 =
    let alice = rwad.v3RwadOwnerIdFromText("alice")
    let bob = rwad.v3RwadOwnerIdFromText("bob")
    assert(!layout.fixedBytes32Equal(alice, bob), "v3 rwad serial smoke: owner ids")

    var machine = rwad.v3RwadStateMachineInit("rwad-serial-smoke")

    let preAlice = rwad.v3RwadStateMachineQueryOwner(machine, alice)
    assert(preAlice.code == rwad.v3RwadSerialCodeOk, "v3 rwad serial smoke: pre alice code")
    assert(preAlice.balance == int64(0), "v3 rwad serial smoke: pre alice balance")

    let mintTx = rwad.v3RwadMintTxMake(alice, int64(100))
    let mintCheck = rwad.v3RwadStateMachineCheckMint(machine, int64(1), mintTx)
    assert(mintCheck.code == rwad.v3RwadSerialCodeOk, "v3 rwad serial smoke: mint check code")
    assert(mintCheck.applied, "v3 rwad serial smoke: mint check applied")
    assert(machine.notes.len == 0, "v3 rwad serial smoke: mint check no mutate")

    let mintApply = rwad.v3RwadStateMachineApplyMint(machine, int64(1), mintTx)
    assert(mintApply.code == rwad.v3RwadSerialCodeOk, "v3 rwad serial smoke: mint apply code")
    assert(mintApply.applied, "v3 rwad serial smoke: mint apply")
    assert(mintApply.primaryNoteId == int64(1), "v3 rwad serial smoke: first note id")
    assert(machine.notes.len == 1, "v3 rwad serial smoke: note count after mint")
    assert(machine.notes[0].startSerial == int64(1), "v3 rwad serial smoke: mint start")
    assert(machine.notes[0].endSerial == int64(100), "v3 rwad serial smoke: mint end")
    assert(machine.notes[0].live, "v3 rwad serial smoke: mint live")

    let afterMintAlice = rwad.v3RwadStateMachineQueryOwner(machine, alice)
    assert(afterMintAlice.balance == int64(100), "v3 rwad serial smoke: alice after mint")
    assert(afterMintAlice.liveNoteCount == 1, "v3 rwad serial smoke: alice note count after mint")

    let transferTx = rwad.v3RwadTransferTxMake(int64(1), alice, bob, int64(21), int64(40))
    let transferCheck = rwad.v3RwadStateMachineCheckTransfer(machine, int64(2), transferTx)
    assert(transferCheck.code == rwad.v3RwadSerialCodeOk, "v3 rwad serial smoke: transfer check code")
    assert(machine.notes.len == 1, "v3 rwad serial smoke: transfer check no mutate")

    let transferApply = rwad.v3RwadStateMachineApplyTransfer(machine, int64(2), transferTx)
    assert(transferApply.code == rwad.v3RwadSerialCodeOk, "v3 rwad serial smoke: transfer apply code")
    assert(transferApply.applied, "v3 rwad serial smoke: transfer apply")
    assert(transferApply.primaryNoteId == int64(2), "v3 rwad serial smoke: left change note id")
    assert(transferApply.secondaryNoteId == int64(3), "v3 rwad serial smoke: payment note id")
    assert(transferApply.tertiaryNoteId == int64(4), "v3 rwad serial smoke: right change note id")
    assert(machine.notes.len == 4, "v3 rwad serial smoke: split note count")
    assert(!machine.notes[0].live, "v3 rwad serial smoke: input spent")
    assert(machine.notes[1].startSerial == int64(1), "v3 rwad serial smoke: left change start")
    assert(machine.notes[1].endSerial == int64(20), "v3 rwad serial smoke: left change end")
    assert(machine.notes[2].startSerial == int64(21), "v3 rwad serial smoke: payment start")
    assert(machine.notes[2].endSerial == int64(40), "v3 rwad serial smoke: payment end")
    assert(machine.notes[3].startSerial == int64(41), "v3 rwad serial smoke: right change start")
    assert(machine.notes[3].endSerial == int64(100), "v3 rwad serial smoke: right change end")
    assert(machine.nullifiers.len == 1, "v3 rwad serial smoke: nullifier count")
    assert(!layout.fixedBytes32Equal(transferApply.spentNullifier, layout.fixedBytes32Zero()),
           "v3 rwad serial smoke: nullifier nonzero")

    let afterTransferAlice = rwad.v3RwadStateMachineQueryOwner(machine, alice)
    let afterTransferBob = rwad.v3RwadStateMachineQueryOwner(machine, bob)
    assert(afterTransferAlice.balance == int64(80), "v3 rwad serial smoke: alice after transfer")
    assert(afterTransferAlice.liveNoteCount == 2, "v3 rwad serial smoke: alice note count after transfer")
    assert(afterTransferBob.balance == int64(20), "v3 rwad serial smoke: bob after transfer")
    assert(afterTransferBob.liveNoteCount == 1, "v3 rwad serial smoke: bob note count after transfer")
    assert(!layout.fixedBytes32Equal(afterTransferAlice.ownerRoot, afterTransferBob.ownerRoot),
           "v3 rwad serial smoke: owner roots differ")

    let doubleSpend = rwad.v3RwadStateMachineApplyTransfer(machine, int64(3), transferTx)
    assert(doubleSpend.code == rwad.v3RwadSerialCodeAlreadySpent, "v3 rwad serial smoke: double spend rejected")
    assert(machine.nullifiers.len == 1, "v3 rwad serial smoke: double spend no new nullifier")

    let commit = rwad.v3RwadStateMachineCommit(machine)
    assert(commit.height == int64(2), "v3 rwad serial smoke: commit height")
    assert(commit.nextSerial == int64(101), "v3 rwad serial smoke: next serial")
    assert(commit.nextNoteId == int64(5), "v3 rwad serial smoke: next note id")
    assert(commit.liveNoteCount == 3, "v3 rwad serial smoke: live note count")
    assert(commit.nullifierCount == 1, "v3 rwad serial smoke: commit nullifier count")
    assert(!layout.fixedBytes32Equal(commit.serialRoot, layout.fixedBytes32Zero()),
           "v3 rwad serial smoke: serial root")
    assert(!layout.fixedBytes32Equal(commit.nullifierRoot, layout.fixedBytes32Zero()),
           "v3 rwad serial smoke: nullifier root")
    assert(layout.fixedBytes32Equal(commit.appHash, rwad.v3RwadStateMachineQueryAppHash(machine)),
           "v3 rwad serial smoke: app hash")

    echo("v3 rwad_serial_state_machine_smoke ok")
    return 0
