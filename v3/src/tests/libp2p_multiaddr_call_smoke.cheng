import std/system
import std/rawbytes
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr

fn main(): int32 =
    let tcpText = bytesFromString("/ip4/127.0.0.1/tcp/4101")
    var tcp: types.V3Libp2pMultiaddr
    let tcpRes = multiaddr.v3Libp2pMultiaddrFillFromBytes(tcp, tcpText)
    assert(tcpRes.ok, "v3 libp2p multiaddr call: tcp parse")
    let quicText = bytesFromString("/ip4/127.0.0.1/udp/4201/quic-v1")
    var quic: types.V3Libp2pMultiaddr
    let quicRes = multiaddr.v3Libp2pMultiaddrFillFromBytes(quic, quicText)
    assert(quicRes.ok, "v3 libp2p multiaddr call: quic parse")
    echo("v3 libp2p_multiaddr_call_smoke ok")
    return 0
