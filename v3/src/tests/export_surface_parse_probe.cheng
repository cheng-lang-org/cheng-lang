import std/os
import std/result
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_csg as ccsg

fn main(): int32 =
    let literalText = "version=1\n" +
                      "package_id=cheng/v3\n" +
                      "exported_count=1\n" +
                      "surface_cid=24686d7dbf11d6fab7cc8c8a976ea819aba0449ff21ebefbf0c029131424660a\n" +
                      "export[0]=cheng/v3/tests/program_selfhost_smoke::main|5|2|2\n"
    var literalSurface: ccsg.V3CsgExportSurface
    let literalRes = ccsg.v3CompilerExportSurfaceFromReportText(literalText, literalSurface)
    if IsErr(literalRes):
        echo(Error(literalRes))
        assert(false, "export surface parse probe: literal parse")
    assert(literalSurface.exportedSymbolCount == 1, "export surface parse probe: literal count")
    let root = os.GetCurrentDir()
    let filePath = v3path.V3PathAbsolute(root, "artifacts/v3_fresh_node_gate/host/program_selfhost_smoke.sync.surface.txt")
    let fileText = v3path.V3ReadTextFile("", filePath)
    var fileSurface: ccsg.V3CsgExportSurface
    let fileRes = ccsg.v3CompilerExportSurfaceFromReportText(fileText, fileSurface)
    if IsErr(fileRes):
        echo(Error(fileRes))
        assert(false, "export surface parse probe: file parse")
    assert(fileSurface.exportedSymbolCount == 1, "export surface parse probe: file count")
    echo("v3 export_surface_parse_probe ok")
    return 0
