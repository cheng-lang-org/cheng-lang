import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/v3_os_list_dir_smoke_tmp"
    let childDir: str = os.JoinPath(tmpRoot, "nested")
    let childFile: str = os.JoinPath(tmpRoot, "top.txt")
    let deepFile: str = os.JoinPath(childDir, "deep.txt")

    if os.FileExists(deepFile):
        assert(os.RemoveFile(deepFile), "v3 ordinary os.ListDir cleanup deep file")
    if os.FileExists(childFile):
        assert(os.RemoveFile(childFile), "v3 ordinary os.ListDir cleanup top file")
    if os.DirExists(childDir):
        os.RemoveDir(childDir)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

    os.CreateDir(tmpRoot)
    os.CreateDir(childDir)
    os.WriteFile(childFile, "top")
    os.WriteFile(deepFile, "deep")

    let entries = os.ListDir(tmpRoot)
    var sawDir: bool = false
    var sawFile: bool = false
    var sawDeep: bool = false
    for i in 0..<entries.len:
        let entry = entries[i]
        if entry == "nested":
            sawDir = true
        elif entry == "top.txt":
            sawFile = true
        elif entry == "deep.txt":
            sawDeep = true

    assert(entries.len == 2, "v3 ordinary os.ListDir count")
    assert(sawDir, "v3 ordinary os.ListDir dir entry")
    assert(sawFile, "v3 ordinary os.ListDir file entry")
    assert(!sawDeep, "v3 ordinary os.ListDir excludes nested entry")

    assert(os.FileExists(deepFile), "v3 ordinary os.ListDir deep file still exists")
    assert(os.RemoveFile(deepFile), "v3 ordinary os.ListDir remove deep file")
    assert(os.RemoveFile(childFile), "v3 ordinary os.ListDir remove top file")
    os.RemoveDir(childDir)
    os.RemoveDir(tmpRoot)
    echo("v3 os_list_dir_smoke ok")
    return 0
