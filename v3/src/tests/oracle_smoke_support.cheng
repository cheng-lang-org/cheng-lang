import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/std/crypto/fixed256
import cheng/v3/chain/oracle_types as oracle_types
import cheng/v3/chain/oracle_plane as oracle_plane
import cheng/v3/project/oracle_fixture as fixture

fn oracleSmokePrivHex(slot: int32): str =
    return fixture.oracleSmokePrivHex(slot)

fn oracleSmokePrivateScalar(slot: int32): fixed256.Scalar256 =
    return fixture.oracleSmokePrivateScalar(slot)

fn oracleSmokePubKeyHex(slot: int32): str =
    return fixture.oracleSmokePubKeyHex(slot)

fn oracleSmokePubKey(slot: int32): layout.FixedBytes65 =
    return fixture.oracleSmokePubKey(slot)

fn oracleSmokeCommittee(): oracle_types.V3OracleCommitteeConfig =
    return fixture.oracleSmokeCommittee()

fn oracleSmokePrice(roundId: int64, pairIndex: int32, reporterSlot: int32): int64 =
    return fixture.oracleSmokePrice(roundId, pairIndex, reporterSlot)

fn oracleSmokePrices(roundId: int64, reporterSlot: int32): int64[] =
    return fixture.oracleSmokePrices(roundId, reporterSlot)

fn oracleSmokeSigHex(roundId: int64, reporterSlot: int32): str =
    return fixture.oracleSmokeSigHex(roundId, reporterSlot)

fn oracleSmokeSig(roundId: int64, reporterSlot: int32): layout.FixedBytes64 =
    return fixture.oracleSmokeSig(roundId, reporterSlot)

fn oracleSmokeBatch(roundId: int64, reporterSlot: int32): oracle_plane.V3OracleSignedBatch =
    return fixture.oracleSmokeBatch(roundId, reporterSlot)

fn oracleSmokePairId(assetId: int32, quoteId: int32): int32 =
    return fixture.oracleSmokePairId(assetId, quoteId)
