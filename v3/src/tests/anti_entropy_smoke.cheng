import std/system
import cheng/v3/chain/lsmr as lsmr
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/anti_entropy as anti

fn main(): int32 =
    let localAddrRes = lsmr.v3LsmrAddressFromSeed("local-qian", 1)
    assert(localAddrRes.ok, "v3 anti_entropy: local address")
    let remoteRegionalAddrRes = lsmr.v3LsmrAddressFromSeed("remote-regional", 2)
    assert(remoteRegionalAddrRes.ok, "v3 anti_entropy: remote regional address")

    let localCellRes = lsmr.v3LsmrStateCellFromText(
        1,
        localAddrRes.value,
        1,
        "local/global/content"
    )
    assert(localCellRes.ok, "v3 anti_entropy: local cell")
    let remoteGlobalCellRes = lsmr.v3LsmrStateCellFromText(
        1,
        localAddrRes.value,
        1,
        "remote/global/content"
    )
    assert(remoteGlobalCellRes.ok, "v3 anti_entropy: remote global cell")
    let remoteRegionalCellRes = lsmr.v3LsmrStateCellFromText(
        2,
        remoteRegionalAddrRes.value,
        2,
        "remote/regional/content"
    )
    assert(remoteRegionalCellRes.ok, "v3 anti_entropy: remote regional cell")

    var localCells: lt.V3StateCell[]
    localCells = []
    add(localCells, localCellRes.value)
    let localForest = lsmr.v3BuildStateLayerForest(localCells)

    var remoteCells: lt.V3StateCell[]
    remoteCells = []
    add(remoteCells, remoteGlobalCellRes.value)
    add(remoteCells, remoteRegionalCellRes.value)
    let remoteForest = lsmr.v3BuildStateLayerForest(remoteCells)

    let localSig = anti.v3AntiEntropySignatureFromForest(10, 12, 3, 1, localForest)
    let remoteSig = anti.v3AntiEntropySignatureFromForest(11, 1, 4, 1, remoteForest)

    assert(!anti.v3AntiEntropySignatureEqual(localSig, remoteSig), "v3 anti_entropy: signatures differ")
    assert(anti.v3PassiveAntiEntropySyncRequired(localSig, remoteSig), "v3 anti_entropy: sync required")

    let localPlanRes = anti.v3AntiEntropyPlan(localSig, localSig)
    assert(localPlanRes.ok, "v3 anti_entropy: identical plan")
    assert(localPlanRes.value.requestCount == 0, "v3 anti_entropy: identical plan empty")

    let planRes = anti.v3AntiEntropyPlan(localSig, remoteSig)
    assert(planRes.ok, "v3 anti_entropy: plan")
    let plan = planRes.value
    assert(plan.remoteNewer, "v3 anti_entropy: remote newer")
    assert(plan.requestCount == 1, "v3 anti_entropy: one subtree request")
    assert(plan.requests[0].layerId == lt.v3LayerRegional, "v3 anti_entropy: escalates to regional layer")
    assert(plan.requests[0].prefix.baguaId == remoteGlobalCellRes.value.baguaId, "v3 anti_entropy: request bagua")
    assert(plan.requests[0].prefix.prefixDepth == 0, "v3 anti_entropy: request root subtree")
    assert(plan.conflictCount == 0, "v3 anti_entropy: no equal-clock conflict")

    echo("v3 anti_entropy_smoke ok")
    return 0
