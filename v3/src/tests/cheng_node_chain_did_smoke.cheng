import std/result
import std/strings
import std/rawbytes
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus as consensus
import cheng/v3/project/chain_node as chain
import cheng/v3/project/cheng_node as node
import cheng/v3/project/cheng_node_state as state

const
    chengNodeChainDidSmokeDidBundleAssetId: int32 = 930001
    chengNodeChainDidSmokeDidOperatorAssetId: int32 = 930002
    chengNodeChainDidSmokeDidOperatorAccountId: int32 = 1

fn chengNodeChainDidSmokeChunkCount(payloadLen: int32): int32 =
    if payloadLen <= 28:
        return 1
    return 1 + ((payloadLen - 28 + 31) / 32)

fn chengNodeChainDidSmokeChunkCid(payload: Bytes,
                                  payloadLen: int32,
                                  chunkIndex: int32): layout.FixedBytes32 =
    var out: layout.FixedBytes32
    if chunkIndex == 0:
        out.data[0] = uint8((payloadLen >> 24) & 255)
        out.data[1] = uint8((payloadLen >> 16) & 255)
        out.data[2] = uint8((payloadLen >> 8) & 255)
        out.data[3] = uint8(payloadLen & 255)
        var payloadPos = 0
        var outPos = 4
        while outPos < 32 && payloadPos < payloadLen:
            out.data[outPos] = uint8(bytesGet(payload, payloadPos) & 255)
            outPos = outPos + 1
            payloadPos = payloadPos + 1
        return out
    let start = 28 + ((chunkIndex - 1) * 32)
    var outPos = 0
    var payloadPos = start
    while outPos < 32 && payloadPos < payloadLen:
        out.data[outPos] = uint8(bytesGet(payload, payloadPos) & 255)
        outPos = outPos + 1
        payloadPos = payloadPos + 1
    return out

fn chengNodeChainDidSmokeAppendChunkedText(node: var chain.V3ChainNode,
                                           assetId: int32,
                                           accountId: int32,
                                           seqId: int32,
                                           text: str) =
    let payload = bytesFromString(text)
    let payloadLen = len(text)
    let chunkCount = chengNodeChainDidSmokeChunkCount(payloadLen)
    var ordinal = 1
    while ordinal <= chunkCount:
        let parentCid = chain.V3ChainNodeAccountHead(node.index, assetId, accountId)
        var event = consensus.V3ChainEventMint(assetId,
                                               accountId,
                                               parentCid,
                                               int64(ordinal),
                                               node.nextEpoch,
                                               node.nextGanzhi,
                                               chain.V3ChainNodeSpaceSlot(accountId, accountId),
                                               node.nextTick)
        event.fromAccount = seqId
        event.fromParentCid = chengNodeChainDidSmokeChunkCid(payload, payloadLen, ordinal - 1)
        event.bodyCid = consensus.V3ChainEventBodyCid(event)
        let applyRes = chain.V3ChainNodeApplyEvent(node, event)
        assert(IsOk(applyRes), "cheng_node chain did smoke: append chunked text")
        ordinal = ordinal + 1

fn main(): int32 =
    var didText = ""
    didText = "did:cheng:alice"
    var operatorHex = ""
    operatorHex = "1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef"
    let operatorIdRes = layout.fixedBytes32FromHex(operatorHex)
    assert(IsOk(operatorIdRes), "cheng_node chain did smoke: operator hex")

    var legacyNode: chain.V3ChainNode
    assert(IsOk(chain.V3ChainNodeInitInto(legacyNode,
                                          "cheng.node.legacy",
                                          "cheng.node.legacy.addr")),
           "cheng_node chain did smoke: init legacy chain")
    let mintRes = chain.V3ChainNodeMint(legacyNode, 77, 100, int64(50))
    assert(IsOk(mintRes), "cheng_node chain did smoke: mint legacy balance")
    let transferRes = chain.V3ChainNodeTransfer(legacyNode, 77, 100, 200, int64(20))
    assert(IsOk(transferRes), "cheng_node chain did smoke: transfer legacy balance")

    var didBundleText = ""
    didBundleText = didBundleText + "version=1\n"
    didBundleText = didBundleText + "did=" + didText + "\n"
    didBundleText = didBundleText + "subject_account=3001\n"
    didBundleText = didBundleText + "bundle_seq=1\n"
    didBundleText = didBundleText + "bundle_kind=cheng_native_v1"
    chengNodeChainDidSmokeAppendChunkedText(legacyNode,
                                            chengNodeChainDidSmokeDidBundleAssetId,
                                            3001,
                                            1,
                                            didBundleText)
    var operatorAnchorText = ""
    operatorAnchorText = operatorAnchorText + "version=1\n"
    operatorAnchorText = operatorAnchorText + "operator_id=" + operatorHex + "\n"
    operatorAnchorText = operatorAnchorText + "did=" + didText + "\n"
    operatorAnchorText = operatorAnchorText + "bundle_seq=1\n"
    operatorAnchorText = operatorAnchorText + "bundle_kind=cheng_native_v1"
    chengNodeChainDidSmokeAppendChunkedText(legacyNode,
                                            chengNodeChainDidSmokeDidOperatorAssetId,
                                            chengNodeChainDidSmokeDidOperatorAccountId,
                                            1,
                                            operatorAnchorText)

    var snapshot: chain.V3ChainNodeServeSnapshot
    chain.V3ChainNodeServeOnceInto(snapshot, legacyNode)
    let legacyStatePath = "/tmp/cheng_node_chain_did_legacy.state"
    let writeLegacyRes = state.V3ChengNodeWriteLegacyChainState(legacyStatePath, snapshot)
    assert(IsOk(writeLegacyRes), "cheng_node chain did smoke: write legacy state")

    var legacySnapshot: chain.V3ChainNodeServeSnapshot
    let loadLegacyRes = state.V3ChengNodeLoadLegacyChainSnapshotInto(legacySnapshot, legacyStatePath)
    assert(IsOk(loadLegacyRes), "cheng_node chain did smoke: load legacy state")

    let coreRes = node.V3ChengNodeInit("cheng-node-chain-did-root")
    assert(IsOk(coreRes), "cheng_node chain did smoke: init cheng_node")
    var core = Value(coreRes)
    let importRes = node.V3ChengNodeImportChainSnapshot(core, legacySnapshot)
    assert(IsOk(importRes), "cheng_node chain did smoke: import legacy state")

    let balance100Res = node.V3ChengNodeBalanceQueryText(core, 77, 100, true)
    assert(IsOk(balance100Res), "cheng_node chain did smoke: query balance 100")
    let balance100Text = Value(balance100Res)
    assert(strings.StrContains(balance100Text, "balance=30"),
           "cheng_node chain did smoke: balance 100 text")
    assert(strings.StrContains(balance100Text, "delta_count=1"),
           "cheng_node chain did smoke: balance 100 delta")
    let balance200Res = node.V3ChengNodeBalanceQueryText(core, 77, 200, false)
    assert(IsOk(balance200Res), "cheng_node chain did smoke: query balance 200")
    assert(strings.StrContains(Value(balance200Res), "balance=20"),
           "cheng_node chain did smoke: balance 200 text")

    let didQueryRes = node.V3ChengNodeKeyedQueryText(core,
                                                     "did",
                                                     "subject",
                                                     didText,
                                                     false)
    assert(IsOk(didQueryRes), "cheng_node chain did smoke: query did")
    let didQueryText = Value(didQueryRes)
    assert(strings.StrContains(didQueryText, "found=1"),
           "cheng_node chain did smoke: did found")
    assert(strings.StrContains(didQueryText, "payload_present=1"),
           "cheng_node chain did smoke: did payload")

    let operatorQueryRes = node.V3ChengNodeKeyedQueryText(core,
                                                          "did_operator",
                                                          "operator",
                                                          operatorHex,
                                                          false)
    assert(IsOk(operatorQueryRes), "cheng_node chain did smoke: query operator")
    let operatorQueryText = Value(operatorQueryRes)
    assert(strings.StrContains(operatorQueryText, "found=1"),
           "cheng_node chain did smoke: operator found")
    assert(strings.StrContains(operatorQueryText, "payload_present=1"),
           "cheng_node chain did smoke: operator payload")

    let statePath = "/tmp/cheng_node_chain_did.state"
    let writeRes = state.V3ChengNodeWriteState(statePath, core)
    assert(IsOk(writeRes), "cheng_node chain did smoke: write node state")
    var loaded: node.V3ChengNode
    let loadRes = state.V3ChengNodeLoadStateInto(loaded,
                                                 statePath,
                                                 "cheng-node-chain-did-root")
    assert(IsOk(loadRes), "cheng_node chain did smoke: load node state")
    let loadedBalanceRes = node.V3ChengNodeBalanceQueryText(loaded, 77, 100, false)
    assert(IsOk(loadedBalanceRes), "cheng_node chain did smoke: loaded balance")
    assert(strings.StrContains(Value(loadedBalanceRes), "balance=30"),
           "cheng_node chain did smoke: loaded balance text")
    let loadedDidRes = node.V3ChengNodeKeyedQueryText(loaded,
                                                      "did",
                                                      "subject",
                                                      didText,
                                                      false)
    assert(IsOk(loadedDidRes), "cheng_node chain did smoke: loaded did")
    assert(strings.StrContains(Value(loadedDidRes), "found=1"),
           "cheng_node chain did smoke: loaded did found")
    let loadedOperatorRes = node.V3ChengNodeKeyedQueryText(loaded,
                                                           "did_operator",
                                                           "operator",
                                                           operatorHex,
                                                           false)
    assert(IsOk(loadedOperatorRes), "cheng_node chain did smoke: loaded operator")
    assert(strings.StrContains(Value(loadedOperatorRes), "found=1"),
           "cheng_node chain did smoke: loaded operator found")
    echo("v3 cheng_node_chain_did_smoke ok")
    return 0
