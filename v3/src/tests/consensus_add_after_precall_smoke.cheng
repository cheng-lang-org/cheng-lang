import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus

fn fixed32Same(a: layout.FixedBytes32, b: layout.FixedBytes32): bool =
    for i in 0..<32:
        if a.data[i] != b.data[i]:
            return false
    return true

fn localMutate(index: var consensus.V3ChainIndex, eventCid: layout.FixedBytes32): int32 =
    assert(fixed32Same(eventCid, eventCid), "v3 consensus add after precall: equal")
    add(index.accountIds, 1001)
    assert(index.accountIds.buffer != nil, "v3 consensus add after precall: buffer")
    assert(index.accountIds.len == 1, "v3 consensus add after precall: len")
    assert(index.accountIds.cap >= 1, "v3 consensus add after precall: cap")
    return 0

fn main(): int32 =
    var index = consensus.V3ChainIndex()
    let eventCid = layout.FixedBytes32()
    let rc = localMutate(index, eventCid)
    assert(rc == 0, "v3 consensus add after precall: rc")
    echo("v3 consensus_add_after_precall_smoke ok")
    return 0
