import std/system
import std/os
import std/result
import std/rawbytes
import std/strutils as strutil
import std/cmdline as cmdline
import cheng/v3/std/bytes_layout as layout
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/transports/quic_transport
import cheng/v3/quic/native_runtime as qnative
import cheng/v3/quic/tls/handshake13
import cheng/v3/project/bft_state_machine as bft
import cheng/v3/project/bft_validator_host as host
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn quicCloseOrderBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn quicCloseOrderMintWire(): Bytes =
    return bft.v3BftEncodeTx(bft.v3BftTxMint(9, 1001, int64(88)))

fn quicCloseOrderTransferWire(): Bytes =
    return bft.v3BftEncodeTx(bft.v3BftTxTransfer(9, 1001, 2002, int64(33)))

fn quicCloseOrderProposal(): host.V3BftProposal =
    var txs: Bytes[]
    txs = []
    add(txs, quicCloseOrderMintWire())
    add(txs, quicCloseOrderTransferWire())
    let proposalRes = host.v3BftValidatorProposalFromTxs("v3.bft.quic.close.order",
                                                         int64(1),
                                                         1,
                                                         txs)
    assert(IsOk(proposalRes), "v3 quic close order: build proposal")
    return Value(proposalRes)

fn quicCloseOrderStateMachine(): bft.V3BftStateMachine =
    var machine = bft.v3BftStateMachineInit("v3.bft.quic.close.order")
    var block: bft.V3BftTx[]
    block = []
    add(block, bft.v3BftTxMint(9, 1001, int64(88)))
    add(block, bft.v3BftTxTransfer(9, 1001, 2002, int64(33)))
    var summary = bft.v3BftBlockSummaryZero(int64(0))
    bft.v3BftStateMachineFinalizeBlockSummary(machine, int64(1), block, summary)
    return machine

fn quicCloseOrderReadyPath(root: str, mode: str): str =
    return v3path.v3PathAbsolute(root,
                                 "artifacts/v3_quic_close_order_smoke/" + mode + ".ready")

fn quicCloseOrderLogPath(root: str, mode: str): str =
    return v3path.v3PathAbsolute(root,
                                 "artifacts/v3_quic_close_order_smoke/" + mode + ".server.log")

fn quicCloseOrderParsePort(textRaw: str): Result[int32] =
    let text = strutil.strip(textRaw)
    if len(text) <= 0:
        return Err[int32]("v3 quic close order: empty port text")
    var value = int32(0)
    for i in 0..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int32]("v3 quic close order: invalid port text")
        value = value * 10 + (int32(ch) - int32('0'))
    if value <= 0:
        return Err[int32]("v3 quic close order: invalid ready port")
    return Ok[int32](value)

fn quicCloseOrderDebugEnabled(): bool =
    return cmdline.hasFlag("--debug-tls13")

fn quicCloseOrderDebugLog(text: str) =
    if quicCloseOrderDebugEnabled():
        os.writeLine(os.get_stderr(), text)

fn quicCloseOrderBoundPortForSecondPhase(port: int32, readyPath: str): Result[int32] =
    if port > 0:
        return Ok[int32](port)
    if len(readyPath) <= 0:
        return Err[int32]("v3 quic close order: missing ready path for rebound port")
    return quicCloseOrderParsePort(v3path.v3ReadTextFile("", readyPath))

fn quicCloseOrderWaitReadyPort(root: str,
                               readyPath: str,
                               proc: var hostops.V3SpawnedProcess,
                               portOut: var str): Result[bool] =
    portOut = ""
    for attempt in 0..<500:
        if v3path.v3FileExistsNonEmpty(root, readyPath):
            let text = strutil.strip(v3path.v3ReadTextFile("", readyPath))
            if len(text) > 0:
                portOut = text
                return Ok[bool](true)
        if !hostops.v3SpawnedProcessRunning(proc):
            return Err[bool]("v3 quic close order: server exited before ready: " + proc.output)
        if attempt + 1 < 500:
            os.sleepMs(10)
    return Err[bool]("v3 quic close order: ready timeout")

fn quicCloseOrderClientRequestResponse(port: int32): Result[bool] =
    let request = bytesFromString("quic.close.order.request")
    let response = bytesFromString("quic.close.order.response")
    let responseRes = quic_transport.v3Libp2pQuicRequestResponseNamed("127.0.0.1",
                                                                      port,
                                                                      "localhost",
                                                                      types.v3Libp2pProtocolSync,
                                                                      request)
    if IsErr(responseRes):
        return Err[bool](Error(responseRes))
    if !quicCloseOrderBytesEqual(Value(responseRes), response):
        return Err[bool]("v3 quic close order: request-response payload mismatch")
    return Ok[bool](true)

fn quicCloseOrderClientProposal(port: int32): Result[bool] =
    let proposalRes = host.v3BftValidatorRecvProposal("127.0.0.1", port)
    if IsErr(proposalRes):
        return Err[bool](Error(proposalRes))
    let proposal = Value(proposalRes)
    if proposal.height != int64(1):
        return Err[bool]("v3 quic close order: proposal height mismatch")
    if proposal.proposerSlot != 1:
        return Err[bool]("v3 quic close order: proposal slot mismatch")
    if proposal.txs.len != 2:
        return Err[bool]("v3 quic close order: proposal tx count mismatch")
    return Ok[bool](true)

fn quicCloseOrderClientStateSync(port: int32): Result[bool] =
    quicCloseOrderDebugLog("quic_close_order state_sync client begin")
    let machineRes = host.v3BftValidatorRecvStateMachine("127.0.0.1", port, int64(1))
    if IsErr(machineRes):
        return Err[bool](Error(machineRes))
    var machine = Value(machineRes)
    if machine.lastFinalizedHeight != int64(1):
        return Err[bool]("v3 quic close order: state sync height mismatch")
    let alice = bft.v3BftStateMachineQueryBalance(machine, 9, 1001)
    let bob = bft.v3BftStateMachineQueryBalance(machine, 9, 2002)
    if alice.code != bft.v3BftCodeOk || bob.code != bft.v3BftCodeOk:
        return Err[bool]("v3 quic close order: state sync balance query failed")
    if alice.balance != int64(55) || bob.balance != int64(33):
        return Err[bool]("v3 quic close order: state sync balances mismatch")
    return Ok[bool](true)

fn quicCloseOrderRunClientMode(mode: str, port: int32): Result[bool] =
    if mode == "request_response":
        return quicCloseOrderClientRequestResponse(port)
    if mode == "proposal":
        return quicCloseOrderClientProposal(port)
    if mode == "state_sync":
        return quicCloseOrderClientStateSync(port)
    return Err[bool]("v3 quic close order: unknown mode: " + mode)

fn quicCloseOrderRunCase(root: str, selfPath: str, mode: str): Result[bool] =
    let readyPath = quicCloseOrderReadyPath(root, mode)
    let logPath = quicCloseOrderLogPath(root, mode)
    if v3path.v3PathFileExists(readyPath):
        os.removeFile(readyPath)
    if v3path.v3PathFileExists(logPath):
        os.removeFile(logPath)
    let spawnRes = hostops.v3SpawnFile(root,
                                       "quic_close_order_server_" + mode,
                                       selfPath,
                                       ["--role:server",
                                        "--mode:" + mode,
                                        "--port:0",
                                        "--ready-path:" + readyPath],
                                       [],
                                       root)
    if IsErr(spawnRes):
        return Err[bool](Error(spawnRes))
    var serverProc = Value(spawnRes)
    var portText = ""
    let waitRes = quicCloseOrderWaitReadyPort(root, readyPath, serverProc, portText)
    if IsErr(waitRes):
        hostops.v3SpawnedProcessKill(serverProc)
        return Err[bool](Error(waitRes))
    let portRes = quicCloseOrderParsePort(portText)
    if IsErr(portRes):
        hostops.v3SpawnedProcessKill(serverProc)
        return Err[bool](Error(portRes))
    let clientRes = quicCloseOrderRunClientMode(mode, Value(portRes))
    if IsErr(clientRes):
        hostops.v3SpawnedProcessKill(serverProc)
        return Err[bool](Error(clientRes))
    let serverRun = hostops.v3SpawnedProcessWaitLogged(root, serverProc, 20, logPath)
    if !hostops.v3LoggedRunOk(serverRun):
        return Err[bool]("v3 quic close order: server failed " + mode + ": " + serverRun.output)
    return Ok[bool](true)

fn quicCloseOrderServeRequestResponse(port: int32, readyPath: str): int32 =
    let request = bytesFromString("quic.close.order.request")
    let response = bytesFromString("quic.close.order.response")
    let requestRes = quic_transport.v3Libp2pQuicServeRequestCaptureOnceNamed("127.0.0.1",
                                                                              port,
                                                                              "localhost",
                                                                              types.v3Libp2pProtocolSync,
                                                                              response,
                                                                              readyPath)
    assert(IsOk(requestRes), "v3 quic close order: serve request-response")
    assert(quicCloseOrderBytesEqual(Value(requestRes), request),
           "v3 quic close order: request-response request mismatch")
    return 0

fn quicCloseOrderServeProposal(port: int32, readyPath: str): int32 =
    let proposal = quicCloseOrderProposal()
    let serveRes = quic_transport.v3Libp2pQuicServePayloadOnceNamed("127.0.0.1",
                                                                    port,
                                                                    host.v3BftValidatorPublicTransportServerName(),
                                                                    host.v3BftValidatorProposalProtocol(),
                                                                    host.v3BftValidatorEncodeProposal(proposal),
                                                                    readyPath)
    assert(IsOk(serveRes), "v3 quic close order: serve proposal")
    return 0

fn quicCloseOrderServeStateSync(port: int32, readyPath: str): int32 =
    var machine = quicCloseOrderStateMachine()
    quicCloseOrderDebugLog("quic_close_order state_sync server ack-listen")
    let requestRes = quic_transport.v3Libp2pQuicServeRequestCaptureOnceNamed("127.0.0.1",
                                                                              port,
                                                                              host.v3BftValidatorPublicTransportServerName(),
                                                                              host.v3BftValidatorStateSyncProtocol(),
                                                                              bytesFromString("ok"),
                                                                              readyPath)
    assert(IsOk(requestRes), "v3 quic close order: serve state sync ack")
    quicCloseOrderDebugLog("quic_close_order state_sync server ack-done")
    let heightRes = host.v3BftValidatorDecodeStateSyncRequest(Value(requestRes))
    assert(IsOk(heightRes), "v3 quic close order: decode state sync request")
    assert(Value(heightRes) == int64(1), "v3 quic close order: state sync request height")
    let payload = host.v3BftValidatorEncodeStateSyncPayload(host.v3BftValidatorEncodeMachine(machine))
    let payloadPortRes = quicCloseOrderBoundPortForSecondPhase(port, readyPath)
    assert(IsOk(payloadPortRes), "v3 quic close order: resolve state sync payload port")
    quicCloseOrderDebugLog("quic_close_order state_sync server payload-listen")
    let serveRes = quic_transport.v3Libp2pQuicServePayloadOnceNamed("127.0.0.1",
                                                                    Value(payloadPortRes),
                                                                    host.v3BftValidatorPublicTransportServerName(),
                                                                    host.v3BftValidatorStateSyncProtocol(),
                                                                    payload,
                                                                    readyPath)
    assert(IsOk(serveRes), "v3 quic close order: serve state sync payload")
    quicCloseOrderDebugLog("quic_close_order state_sync server payload-done")
    return 0

fn quicCloseOrderRunServer(mode: str): int32 =
    let port = cmdline.readInt32FlagOrDefault("--port", 0)
    var readyPath = ""
    let hasReady = cmdline.readFirstFlagValue("--ready-path", readyPath)
    let readyPathValue = if hasReady: readyPath else: ""
    if mode == "request_response":
        return quicCloseOrderServeRequestResponse(port, readyPathValue)
    if mode == "proposal":
        return quicCloseOrderServeProposal(port, readyPathValue)
    if mode == "state_sync":
        return quicCloseOrderServeStateSync(port, readyPathValue)
    echo("v3 quic close order: unknown server mode")
    return 2

fn quicCloseOrderRunClientCommand(mode: str): int32 =
    let port = cmdline.readInt32FlagOrDefault("--port", -1)
    let clientRes = quicCloseOrderRunClientMode(mode, port)
    if IsErr(clientRes):
        os.writeLine(os.get_stderr(), Error(clientRes))
        return 1
    echo("v3 quic close order client ok")
    return 0

fn quicCloseOrderRunDefault(): int32 =
    let root = os.getCurrentDir()
    let selfPath = cmdline.programName()
    assert(len(selfPath) > 0, "v3 quic close order: self path")
    let rrRes = quicCloseOrderRunCase(root, selfPath, "request_response")
    if IsErr(rrRes):
        os.writeLine(os.get_stderr(), Error(rrRes))
        return 1
    let proposalRes = quicCloseOrderRunCase(root, selfPath, "proposal")
    if IsErr(proposalRes):
        os.writeLine(os.get_stderr(), Error(proposalRes))
        return 1
    let stateSyncRes = quicCloseOrderRunCase(root, selfPath, "state_sync")
    if IsErr(stateSyncRes):
        os.writeLine(os.get_stderr(), Error(stateSyncRes))
        return 1
    echo("v3 quic_close_order_smoke ok")
    return 0

fn main(): int32 =
    let debugTls13 = cmdline.hasFlag("--debug-tls13")
    qnative.msquicNativeSetDebugTls13(debugTls13)
    handshake13.msquicTls13SetDebug(debugTls13)
    let role = cmdline.readFlagOrDefault("--role", "")
    let mode = cmdline.readFlagOrDefault("--mode", "")
    if role == "server":
        return quicCloseOrderRunServer(mode)
    if role == "client":
        return quicCloseOrderRunClientCommand(mode)
    return quicCloseOrderRunDefault()
