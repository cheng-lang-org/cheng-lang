import std/os
import std/strutils as strutil
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/r2c_react_v3_surface_main as r2csurface

fn containsText(text: str, needle: str): bool =
    return strutil.Contains(text, needle)

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_V3_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_r2c_run_native_gui_controller_smoke")
    assert(v3path.V3MkdirP(root, outDir), "v3 r2c run-native-gui controller smoke: mkdir")
    let driver = v3path.V3PathAbsolute(root, "artifacts/v3_backend_driver/cheng")
    let stage3 = v3path.V3PathAbsolute(root, "artifacts/v3_bootstrap/cheng.stage3")
    let bundleScript = v3path.V3PathAbsolute(root, "v3/experimental/r2c-react-v3/r2c-react-v3-native-gui-bundle.mjs")
    assert(v3path.V3FileExistsNonEmpty(root, driver), "v3 r2c run-native-gui controller smoke: backend_driver exists")
    assert(v3path.V3FileExistsNonEmpty(root, stage3), "v3 r2c run-native-gui controller smoke: stage3 exists")
    assert(v3path.V3FileExistsNonEmpty(root, bundleScript), "v3 r2c run-native-gui controller smoke: bundle script exists")
    let packageRoot = v3path.V3PathAbsolute(root, "v3")
    let controllerSource = v3path.V3PathAbsolute(root, "v3/src/tooling/r2c_react_v3.cheng")
    let repoEnv = os.GetEnv("R2C_REACT_V3_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.DirExists(repo), "v3 r2c run-native-gui controller smoke: React.js repo exists")
    var readyEnv: str[]
    add(readyEnv, "CHENG_V3_BACKEND_DRIVER_READY=1")
    var controllerCompileEnv: str[]
    add(controllerCompileEnv, "BACKEND_INCREMENTAL=0")
    add(controllerCompileEnv, "BACKEND_MULTI_MODULE_CACHE=0")
    add(controllerCompileEnv, "CHENG_V3_DISABLE_PRIMARY_OBJECT_CACHE=1")
    add(controllerCompileEnv, "BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=0")
    add(controllerCompileEnv, "BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=0")
    let backendDriverRefreshLog = os.JoinPath(outDir, "backend_driver.refresh.log")
    if v3path.V3PathFileExists(backendDriverRefreshLog):
        os.RemoveFile(backendDriverRefreshLog)
    let backendDriverRefreshRun = hostops.v3RunFileLogged(root,
                                                          "r2c_run_native_gui_backend_driver_refresh",
                                                          stage3,
                                                          ["build-backend-driver"],
                                                          controllerCompileEnv,
                                                          root,
                                                          0,
                                                          backendDriverRefreshLog)
    assert(hostops.v3LoggedRunOk(backendDriverRefreshRun), "v3 r2c run-native-gui controller smoke: backend driver refresh rc")
    assert(v3path.V3FileExistsNonEmpty(root, driver), "v3 r2c run-native-gui controller smoke: refreshed backend_driver exists")
    var nativeEnv: str[]
    add(nativeEnv, "R2C_REACT_V3_TOOLING_BIN=" + stage3)
    add(nativeEnv, "CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1")

    let controllerExe = os.JoinPath(outDir, "r2c_react_v3_controller_smoke")
    let controllerCompileReport = controllerExe + ".report.txt"
    let controllerCompileLog = controllerExe + ".compile.log"
    if v3path.V3PathFileExists(controllerExe):
        os.RemoveFile(controllerExe)
    if v3path.V3PathFileExists(controllerCompileReport):
        os.RemoveFile(controllerCompileReport)
    var controllerCompileArgs: str[]
    add(controllerCompileArgs, "system-link-exec")
    add(controllerCompileArgs, "--root:" + packageRoot)
    add(controllerCompileArgs, "--in:" + controllerSource)
    add(controllerCompileArgs, "--emit:exe")
    add(controllerCompileArgs, "--target:arm64-apple-darwin")
    add(controllerCompileArgs, "--out:" + controllerExe)
    add(controllerCompileArgs, "--report-out:" + controllerCompileReport)
    let controllerCompileRun = hostops.v3RunFileLogged(root,
                                                       "r2c_run_native_gui_controller_compile",
                                                       driver,
                                                       controllerCompileArgs,
                                                       controllerCompileEnv,
                                                       root,
                                                       0,
                                                       controllerCompileLog)
    assert(hostops.v3LoggedRunOk(controllerCompileRun), "v3 r2c run-native-gui controller smoke: controller compile rc")
    assert(v3path.V3FileExistsNonEmpty(root, controllerExe), "v3 r2c run-native-gui controller smoke: controller exe")
    assert(v3path.V3FileExistsNonEmpty(root, controllerCompileReport), "v3 r2c run-native-gui controller smoke: controller compile report")
    let controllerCompileReportText = v3path.V3ReadTextFile("", controllerCompileReport)
    assert(containsText(controllerCompileReportText, "source_closure_paths=" + controllerSource),
           "v3 r2c run-native-gui controller smoke: controller compile source closure")
    assert(containsText(controllerCompileReportText, "/Users/lbcheng/cheng-lang/v3/src/tooling/r2c_react_v3_controller_main.cheng"),
           "v3 r2c run-native-gui controller smoke: controller compile controller main closure")
    assert(containsText(controllerCompileReportText, "primary_object_cache_hit_count=0"),
           "v3 r2c run-native-gui controller smoke: controller compile primary cache disabled")

    let codegenOutDir = v3path.V3PathJoin(outDir, "codegen_surface")
    let codegenLog = v3path.V3PathJoin(outDir, "r2c_codegen_surface.log")
    if v3path.V3PathFileExists(codegenLog):
        os.RemoveFile(codegenLog)
    var codegenArgs: str[]
    add(codegenArgs, "r2c-react-v3-codegen-surface-smoke")
    add(codegenArgs, "--repo")
    add(codegenArgs, repo)
    add(codegenArgs, "--out-dir")
    add(codegenArgs, codegenOutDir)
    let codegenRun = hostops.v3RunFileLogged(root,
                                             "r2c_codegen_surface_controller_smoke",
                                             driver,
                                             codegenArgs,
                                             readyEnv,
                                             root,
                                             0,
                                             codegenLog)
    assert(hostops.v3LoggedRunOk(codegenRun), "v3 r2c run-native-gui controller smoke: codegen rc")
    let codegenManifestPath = os.JoinPath(codegenOutDir, "cheng_codegen_v1.json")
    let codegenRouteCatalogPath = os.JoinPath(codegenOutDir, "cheng_codegen_route_catalog_v1.json")
    let codegenTsxAstPath = os.JoinPath(codegenOutDir, "tsx_ast_v1.json")
    assert(v3path.V3FileExistsNonEmpty(root, codegenManifestPath), "v3 r2c run-native-gui controller smoke: codegen manifest")
    assert(v3path.V3FileExistsNonEmpty(root, codegenRouteCatalogPath), "v3 r2c run-native-gui controller smoke: codegen route catalog")
    assert(v3path.V3FileExistsNonEmpty(root, codegenTsxAstPath), "v3 r2c run-native-gui controller smoke: codegen tsx ast")

    let staticSummaryPath = os.JoinPath(outDir, "static_surface.summary.env")
    let bundleHostContractPath = os.JoinPath(outDir, "unimaker_host_v1.json")
    let bundleAssetManifestPath = os.JoinPath(outDir, "asset_manifest_v1.json")
    let bundleTailwindManifestPath = os.JoinPath(outDir, "tailwind_style_manifest_v1.json")
    var staticAssetRoots: str[]
    var staticSurface: r2csurface.R2cStaticSurfaceRunResult
    assert(r2csurface.r2cRunStaticSurface(repo, outDir, codegenTsxAstPath, staticSummaryPath, staticAssetRoots, staticSurface),
           "v3 r2c run-native-gui controller smoke: static surface rc")
    assert(v3path.V3FileExistsNonEmpty(root, bundleHostContractPath),
           "v3 r2c run-native-gui controller smoke: host contract")
    assert(v3path.V3FileExistsNonEmpty(root, bundleAssetManifestPath),
           "v3 r2c run-native-gui controller smoke: asset manifest")
    assert(v3path.V3FileExistsNonEmpty(root, bundleTailwindManifestPath),
           "v3 r2c run-native-gui controller smoke: tailwind manifest")

    let bundlePath = os.JoinPath(outDir, "native_gui_bundle_v1.json")
    let sessionPath = os.JoinPath(outDir, "native_gui_session_v1.json")
    let bundleSummaryPath = os.JoinPath(outDir, "native_gui_bundle.summary.env")
    let bundleLog = os.JoinPath(outDir, "native_gui_bundle.log")
    if v3path.V3PathFileExists(bundleLog):
        os.RemoveFile(bundleLog)
    var bundleArgs: str[]
    add(bundleArgs, "native-gui-bundle")
    add(bundleArgs, "--repo")
    add(bundleArgs, repo)
    add(bundleArgs, "--route-state")
    add(bundleArgs, "home_default")
    add(bundleArgs, "--out-dir")
    add(bundleArgs, outDir)
    let bundleRun = hostops.v3RunFileLogged(root,
                                            "r2c_native_gui_bundle_controller_smoke",
                                            controllerExe,
                                            bundleArgs,
                                            nativeEnv,
                                            root,
                                            0,
                                            bundleLog)
    assert(hostops.v3LoggedRunOk(bundleRun), "v3 r2c run-native-gui controller smoke: bundle rc")
    assert(v3path.V3FileExistsNonEmpty(root, bundlePath), "v3 r2c run-native-gui controller smoke: bundle")
    assert(v3path.V3FileExistsNonEmpty(root, sessionPath), "v3 r2c run-native-gui controller smoke: session")
    let bundleReportPath = os.JoinPath(outDir, "native_gui_bundle_report_v1.json")
    let styleLayoutSurfacePath = os.JoinPath(outDir, "style_layout_surface_v1.json")
    let styleLayoutSurfaceControllerPath = os.JoinPath(outDir, "style_layout_surface_controller_v1.json")
    let styleLayoutSurfaceSourcePayloadPath = os.JoinPath(outDir, "style_layout_surface_source_payload_v1.json")
    let nativeLayoutPlanPath = os.JoinPath(outDir, "native_layout_plan_v1.json")
    let nativeLayoutPlanControllerPath = os.JoinPath(outDir, "native_layout_plan_controller_v1.json")
    let nativeLayoutPlanSourcePayloadPath = os.JoinPath(outDir, "native_layout_plan_source_payload_v1.json")
    let nativeLayoutItemCatalogPath = os.JoinPath(outDir, "native_layout_item_catalog_v1.json")
    let nativeRuntimeContractPath = os.JoinPath(outDir, "native_gui_runtime_contract_v1.json")
    assert(v3path.V3FileExistsNonEmpty(root, bundleReportPath), "v3 r2c run-native-gui controller smoke: bundle report")
    assert(v3path.V3FileExistsNonEmpty(root, styleLayoutSurfacePath),
           "v3 r2c run-native-gui controller smoke: style layout payload")
    assert(v3path.V3FileExistsNonEmpty(root, styleLayoutSurfaceControllerPath),
           "v3 r2c run-native-gui controller smoke: style layout controller")
    assert(v3path.V3FileExistsNonEmpty(root, styleLayoutSurfaceSourcePayloadPath),
           "v3 r2c run-native-gui controller smoke: style layout source payload")
    assert(v3path.V3FileExistsNonEmpty(root, nativeLayoutPlanPath),
           "v3 r2c run-native-gui controller smoke: native layout payload")
    assert(v3path.V3FileExistsNonEmpty(root, nativeLayoutPlanControllerPath),
           "v3 r2c run-native-gui controller smoke: native layout controller")
    assert(v3path.V3FileExistsNonEmpty(root, nativeLayoutPlanSourcePayloadPath),
           "v3 r2c run-native-gui controller smoke: native layout source payload")
    assert(v3path.V3FileExistsNonEmpty(root, nativeLayoutItemCatalogPath),
           "v3 r2c run-native-gui controller smoke: native layout item catalog")
    assert(v3path.V3FileExistsNonEmpty(root, nativeRuntimeContractPath),
           "v3 r2c run-native-gui controller smoke: native runtime contract")
    let bundleReportText = v3path.V3ReadTextFile("", bundleReportPath)
    let bundleSummaryText = v3path.V3ReadTextFile("", bundleSummaryPath)
    let bundleJsonText = v3path.V3ReadTextFile("", bundlePath)
    let styleLayoutSurfaceText = v3path.V3ReadTextFile("", styleLayoutSurfacePath)
    let styleLayoutControllerText = v3path.V3ReadTextFile("", styleLayoutSurfaceControllerPath)
    let styleLayoutSurfaceSourcePayloadText = v3path.V3ReadTextFile("", styleLayoutSurfaceSourcePayloadPath)
    let nativeLayoutPlanText = v3path.V3ReadTextFile("", nativeLayoutPlanPath)
    let nativeLayoutControllerText = v3path.V3ReadTextFile("", nativeLayoutPlanControllerPath)
    let nativeLayoutPlanSourcePayloadText = v3path.V3ReadTextFile("", nativeLayoutPlanSourcePayloadPath)
    let nativeLayoutItemCatalogText = v3path.V3ReadTextFile("", nativeLayoutItemCatalogPath)
    let nativeRuntimeContractText = v3path.V3ReadTextFile("", nativeRuntimeContractPath)
    assert(containsText(bundleReportText, "\"native_gui_bundle_finalizer\": \"cheng_controller_native_gui_bundle_finalizer_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle report finalizer")
    assert(containsText(bundleReportText, "\"native_gui_layout_payload_finalizer\": \"cheng_controller_layout_payload_finalizer_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle report layout finalizer")
    assert(containsText(bundleReportText, "\"native_gui_style_layout_surface_publish_mode\": \"cheng_controller_republished_payload_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle report style publish mode")
    assert(containsText(bundleReportText, "\"native_gui_style_layout_surface_source_payload_path\": "),
           "v3 r2c run-native-gui controller smoke: bundle report style source payload path")
    assert(containsText(bundleReportText, "\"native_gui_native_layout_plan_publish_mode\": \"cheng_controller_republished_payload_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle report native layout publish mode")
    assert(containsText(bundleReportText, "\"native_gui_native_layout_plan_source_payload_path\": "),
           "v3 r2c run-native-gui controller smoke: bundle report native layout source payload path")
    assert(containsText(bundleReportText, "\"native_gui_native_layout_plan_controller_items_ready\": true"),
           "v3 r2c run-native-gui controller smoke: bundle report layout controller items ready")
    assert(containsText(bundleReportText, "\"native_gui_native_layout_plan_controller_publish_mode\": \"cheng_controller_items_source_checked_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle report layout controller publish mode")
    assert(containsText(bundleReportText, "\"native_gui_native_layout_item_catalog_ready\": true"),
           "v3 r2c run-native-gui controller smoke: bundle report layout catalog ready")
    assert(containsText(bundleReportText, "\"native_gui_native_layout_item_catalog_publish_mode\": \"cheng_streamed_typed_layout_items_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle report layout catalog mode")
    assert(containsText(bundleReportText, "\"native_gui_native_layout_item_catalog_payload_profile\": \"cheng_runtime_layout_item_payload_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle report layout catalog payload profile")
    assert(containsText(bundleReportText, "\"native_gui_native_layout_item_catalog_text_payload_ready\": true"),
           "v3 r2c run-native-gui controller smoke: bundle report layout catalog text payload")
    assert(containsText(bundleReportText, "\"native_gui_native_layout_item_catalog_style_payload_ready\": true"),
           "v3 r2c run-native-gui controller smoke: bundle report layout catalog style payload")
    assert(containsText(bundleReportText, "\"native_gui_runtime_item_source_mode\": \"typed_item_catalog_contract_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle report runtime item source mode")
    assert(containsText(bundleReportText, "\"native_gui_runtime_typed_item_catalog_path\": "),
           "v3 r2c run-native-gui controller smoke: bundle report runtime catalog path")
    assert(containsText(bundleSummaryText, "native_gui_bundle_finalizer=cheng_controller_native_gui_bundle_finalizer_v1"),
           "v3 r2c run-native-gui controller smoke: bundle summary finalizer")
    assert(containsText(bundleSummaryText, "native_gui_layout_payload_finalizer=cheng_controller_layout_payload_finalizer_v1"),
           "v3 r2c run-native-gui controller smoke: bundle summary layout finalizer")
    let styleLayoutSurfaceControllerNeedle = "native_gui_style_layout_surface_controller_path=" + styleLayoutSurfaceControllerPath
    assert(containsText(bundleSummaryText, styleLayoutSurfaceControllerNeedle),
           "v3 r2c run-native-gui controller smoke: bundle summary style controller path")
    let styleLayoutSurfaceSourcePayloadNeedle = "native_gui_style_layout_surface_source_payload_path=" + styleLayoutSurfaceSourcePayloadPath
    assert(containsText(bundleSummaryText, "native_gui_style_layout_surface_publish_mode=cheng_controller_republished_payload_v1"),
           "v3 r2c run-native-gui controller smoke: bundle summary style publish mode")
    assert(containsText(bundleSummaryText, styleLayoutSurfaceSourcePayloadNeedle),
           "v3 r2c run-native-gui controller smoke: bundle summary style source payload path")
    let nativeLayoutPlanControllerNeedle = "native_gui_native_layout_plan_controller_path=" + nativeLayoutPlanControllerPath
    assert(containsText(bundleSummaryText, nativeLayoutPlanControllerNeedle),
           "v3 r2c run-native-gui controller smoke: bundle summary native layout controller path")
    let nativeLayoutPlanSourcePayloadNeedle = "native_gui_native_layout_plan_source_payload_path=" + nativeLayoutPlanSourcePayloadPath
    assert(containsText(bundleSummaryText, "native_gui_native_layout_plan_publish_mode=cheng_controller_republished_payload_v1"),
           "v3 r2c run-native-gui controller smoke: bundle summary native layout publish mode")
    assert(containsText(bundleSummaryText, nativeLayoutPlanSourcePayloadNeedle),
           "v3 r2c run-native-gui controller smoke: bundle summary native layout source payload path")
    assert(containsText(bundleSummaryText, "native_gui_native_layout_plan_controller_items_ready=true"),
           "v3 r2c run-native-gui controller smoke: bundle summary native layout items ready")
    assert(containsText(bundleSummaryText, "native_gui_native_layout_plan_controller_item_count="),
           "v3 r2c run-native-gui controller smoke: bundle summary native layout item count")
    let nativeLayoutItemCatalogNeedle = "native_gui_native_layout_item_catalog_path=" + nativeLayoutItemCatalogPath
    assert(containsText(bundleSummaryText, nativeLayoutItemCatalogNeedle),
           "v3 r2c run-native-gui controller smoke: bundle summary native layout catalog path")
    assert(containsText(bundleSummaryText, "native_gui_native_layout_item_catalog_ready=true"),
           "v3 r2c run-native-gui controller smoke: bundle summary native layout catalog ready")
    assert(containsText(bundleSummaryText, "native_gui_native_layout_item_catalog_payload_profile=cheng_runtime_layout_item_payload_v1"),
           "v3 r2c run-native-gui controller smoke: bundle summary native layout catalog payload profile")
    assert(containsText(bundleSummaryText, "native_gui_native_layout_item_catalog_text_payload_ready=true"),
           "v3 r2c run-native-gui controller smoke: bundle summary native layout catalog text payload")
    assert(containsText(bundleSummaryText, "native_gui_native_layout_item_catalog_style_payload_ready=true"),
           "v3 r2c run-native-gui controller smoke: bundle summary native layout catalog style payload")
    assert(containsText(bundleSummaryText, "native_gui_runtime_item_source_mode=typed_item_catalog_contract_v1"),
           "v3 r2c run-native-gui controller smoke: bundle summary runtime item source mode")
    let runtimeCatalogNeedle = "native_gui_runtime_typed_item_catalog_path=" + nativeLayoutItemCatalogPath
    assert(containsText(bundleSummaryText, runtimeCatalogNeedle),
           "v3 r2c run-native-gui controller smoke: bundle summary runtime catalog path")
    assert(containsText(bundleJsonText, "\"finalizer\": \"cheng_controller_native_gui_bundle_finalizer_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle json finalizer")
    assert(containsText(bundleJsonText, "\"layout_payload_finalizer\": \"cheng_controller_layout_payload_finalizer_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle json layout finalizer")
    assert(containsText(bundleJsonText, "\"publish_mode\": \"cheng_controller_republished_payload_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle json republish mode")
    assert(containsText(bundleJsonText, styleLayoutSurfaceSourcePayloadPath),
           "v3 r2c run-native-gui controller smoke: bundle json style source payload path")
    assert(containsText(bundleJsonText, nativeLayoutPlanSourcePayloadPath),
           "v3 r2c run-native-gui controller smoke: bundle json native layout source payload path")
    assert(containsText(bundleJsonText, "\"controller_publish_mode\": \"cheng_controller_items_source_checked_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle json native layout publish mode")
    assert(containsText(bundleJsonText, "\"controller_items_ready\": true"),
           "v3 r2c run-native-gui controller smoke: bundle json native layout items ready")
    assert(containsText(bundleJsonText, "\"typed_item_catalog_ready\": true"),
           "v3 r2c run-native-gui controller smoke: bundle json native layout catalog ready")
    assert(containsText(bundleJsonText, "\"typed_item_catalog_payload_profile\": \"cheng_runtime_layout_item_payload_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle json native layout catalog payload profile")
    assert(containsText(bundleJsonText, "\"typed_item_catalog_text_payload_ready\": true"),
           "v3 r2c run-native-gui controller smoke: bundle json native layout catalog text payload")
    assert(containsText(bundleJsonText, "\"typed_item_catalog_style_payload_ready\": true"),
           "v3 r2c run-native-gui controller smoke: bundle json native layout catalog style payload")
    assert(containsText(bundleJsonText, "\"item_source_mode\": \"typed_item_catalog_contract_v1\""),
           "v3 r2c run-native-gui controller smoke: bundle json runtime item source mode")
    assert(containsText(bundleJsonText, "\"typed_item_catalog_path\": "),
           "v3 r2c run-native-gui controller smoke: bundle json runtime catalog path")
    assert(containsText(styleLayoutSurfaceText, "\"controller\": \"cheng.live_controller\""),
           "v3 r2c run-native-gui controller smoke: style payload controller")
    assert(containsText(styleLayoutSurfaceText, "\"publish_mode\": \"cheng_controller_republished_payload_v1\""),
           "v3 r2c run-native-gui controller smoke: style payload publish mode")
    assert(containsText(styleLayoutSurfaceText, styleLayoutSurfaceSourcePayloadPath),
           "v3 r2c run-native-gui controller smoke: style payload source payload path")
    assert(containsText(styleLayoutControllerText, "\"finalizer\": \"cheng_controller_layout_payload_finalizer_v1\""),
           "v3 r2c run-native-gui controller smoke: style controller finalizer")
    assert(containsText(styleLayoutControllerText, "\"publish_mode\": \"cheng_controller_republished_payload_v1\""),
           "v3 r2c run-native-gui controller smoke: style controller publish mode")
    assert(containsText(styleLayoutControllerText, styleLayoutSurfaceSourcePayloadPath),
           "v3 r2c run-native-gui controller smoke: style controller source payload path")
    assert(containsText(styleLayoutSurfaceSourcePayloadText, "\"format\": \"style_layout_surface_v1\""),
           "v3 r2c run-native-gui controller smoke: style source payload format")
    assert(!containsText(styleLayoutSurfaceSourcePayloadText, "\"controller\": \"cheng.live_controller\""),
           "v3 r2c run-native-gui controller smoke: style source payload kept original")
    assert(containsText(nativeLayoutPlanText, "\"controller\": \"cheng.live_controller\""),
           "v3 r2c run-native-gui controller smoke: native layout payload controller")
    assert(containsText(nativeLayoutPlanText, "\"publish_mode\": \"cheng_controller_republished_payload_v1\""),
           "v3 r2c run-native-gui controller smoke: native layout payload publish mode")
    assert(containsText(nativeLayoutPlanText, nativeLayoutPlanSourcePayloadPath),
           "v3 r2c run-native-gui controller smoke: native layout payload source payload path")
    assert(containsText(nativeLayoutControllerText, "\"finalizer\": \"cheng_controller_layout_payload_finalizer_v1\""),
           "v3 r2c run-native-gui controller smoke: native layout controller finalizer")
    assert(containsText(nativeLayoutControllerText, "\"publish_mode\": \"cheng_controller_items_source_checked_v1\""),
           "v3 r2c run-native-gui controller smoke: native layout controller publish mode")
    assert(containsText(nativeLayoutControllerText, nativeLayoutPlanSourcePayloadPath),
           "v3 r2c run-native-gui controller smoke: native layout controller source payload path")
    assert(containsText(nativeLayoutPlanSourcePayloadText, "\"format\": \"native_layout_plan_v1\""),
           "v3 r2c run-native-gui controller smoke: native layout source payload format")
    assert(!containsText(nativeLayoutPlanSourcePayloadText, "\"controller\": \"cheng.live_controller\""),
           "v3 r2c run-native-gui controller smoke: native layout source payload kept original")
    assert(containsText(nativeLayoutControllerText, "\"published_item_count\": "),
           "v3 r2c run-native-gui controller smoke: native layout controller published item count")
    assert(containsText(nativeLayoutControllerText, "\"items_source_checked\": true"),
           "v3 r2c run-native-gui controller smoke: native layout controller items source checked")
    assert(containsText(nativeLayoutControllerText, "\"viewport_items_source_checked\": true"),
           "v3 r2c run-native-gui controller smoke: native layout controller viewport items source checked")
    assert(containsText(nativeLayoutControllerText, "\"items_publish_status\": \"source_checked\""),
           "v3 r2c run-native-gui controller smoke: native layout controller items status")
    assert(containsText(nativeLayoutControllerText, nativeLayoutItemCatalogPath),
           "v3 r2c run-native-gui controller smoke: native layout controller catalog path")
    assert(containsText(nativeLayoutControllerText, "\"typed_item_catalog_ready\": true"),
           "v3 r2c run-native-gui controller smoke: native layout controller catalog ready")
    assert(containsText(nativeLayoutControllerText, "\"typed_item_catalog_payload_profile\": \"cheng_runtime_layout_item_payload_v1\""),
           "v3 r2c run-native-gui controller smoke: native layout controller catalog payload profile")
    assert(containsText(nativeLayoutControllerText, "\"typed_item_catalog_text_payload_ready\": true"),
           "v3 r2c run-native-gui controller smoke: native layout controller catalog text payload")
    assert(containsText(nativeLayoutControllerText, "\"typed_item_catalog_style_payload_ready\": true"),
           "v3 r2c run-native-gui controller smoke: native layout controller catalog style payload")
    assert(containsText(nativeLayoutControllerText, "\"layout_policy\": {"),
           "v3 r2c run-native-gui controller smoke: native layout controller layout policy")
    assert(containsText(nativeLayoutItemCatalogText, "\"format\": \"native_layout_item_catalog_v1\""),
           "v3 r2c run-native-gui controller smoke: native layout item catalog format")
    assert(containsText(nativeLayoutItemCatalogText, "\"publish_mode\": \"cheng_streamed_typed_layout_items_v1\""),
