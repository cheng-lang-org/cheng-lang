    let hostRunLogPath = os.JoinPath(outDir, "native_gui_run.log")
    let hostRunFieldsPath = os.JoinPath(outDir, "native_gui_host_run.stdout.env")
    let hitInspectorPath = os.JoinPath(outDir, "native_gui_hit_inspector_v1.json")
    let inspectorStatePath = os.JoinPath(outDir, "native_gui_inspector_state_v1.json")
    let bundlePath = os.JoinPath(outDir, "native_gui_bundle_v1.json")
    let sessionPath = os.JoinPath(outDir, "native_gui_session_v1.json")
    assert(v3path.V3FileExistsNonEmpty(root, reportPath), "v3 r2c run-native-gui controller smoke: report")
    assert(v3path.V3FileExistsNonEmpty(root, summaryPath), "v3 r2c run-native-gui controller smoke: summary")
    assert(v3path.V3FileExistsNonEmpty(root, screenshotPath), "v3 r2c run-native-gui controller smoke: screenshot")
    assert(v3path.V3FileExistsNonEmpty(root, hostCompileLogPath), "v3 r2c run-native-gui controller smoke: host compile log")
    assert(v3path.V3FileExistsNonEmpty(root, hostRunLogPath), "v3 r2c run-native-gui controller smoke: host run log")
    assert(v3path.V3FileExistsNonEmpty(root, hostRunFieldsPath), "v3 r2c run-native-gui controller smoke: host run fields")
    assert(v3path.V3FileExistsNonEmpty(root, hitInspectorPath), "v3 r2c run-native-gui controller smoke: hit inspector")
    assert(v3path.V3FileExistsNonEmpty(root, inspectorStatePath), "v3 r2c run-native-gui controller smoke: inspector state")
    assert(v3path.V3FileExistsNonEmpty(root, bundlePath), "v3 r2c run-native-gui controller smoke: bundle")
    assert(v3path.V3FileExistsNonEmpty(root, sessionPath), "v3 r2c run-native-gui controller smoke: session")

    let reportText = v3path.V3ReadTextFile("", reportPath)
    let summaryText = v3path.V3ReadTextFile("", summaryPath)
