    let controllerLog = v3path.V3PathJoin(outDir, "run_native_gui_controller.log")
    if v3path.V3PathFileExists(controllerLog):
        os.RemoveFile(controllerLog)
    var controllerArgs: str[]
    add(controllerArgs, "run-native-gui")
    add(controllerArgs, "--repo")
    add(controllerArgs, repo)
    add(controllerArgs, "--out-dir")
    add(controllerArgs, outDir)
    add(controllerArgs, "--bundle-path")
    add(controllerArgs, bundlePath)
    add(controllerArgs, "--session-path")
    add(controllerArgs, sessionPath)
    add(controllerArgs, "--route-state")
    add(controllerArgs, "home_default")
    add(controllerArgs, "--auto-close-ms")
    add(controllerArgs, "600")
    var emptyEnv: str[]
    let controllerRun = hostops.v3RunFileLogged(root,
                                                "r2c_run_native_gui_controller_smoke",
                                                controllerExe,
                                                controllerArgs,
                                                emptyEnv,
                                                root,
                                                0,
                                                controllerLog)
    assert(hostops.v3LoggedRunOk(controllerRun), "v3 r2c run-native-gui controller smoke: controller rc")
    assert(v3path.V3PathFileExists(controllerLog), "v3 r2c run-native-gui controller smoke: controller log")

    let reportPath = os.JoinPath(outDir, "native_gui_run_report_v1.json")
    let summaryPath = os.JoinPath(outDir, "native_gui_run.summary.env")
