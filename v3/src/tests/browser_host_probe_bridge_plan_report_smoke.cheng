import cheng/v3/backend/system_link_exec as sexec
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/libp2p/browser/browser_host_probe_codegen as codegen
import cheng/v3/libp2p/browser/browser_host_probe_rule_schema as browserprobe

fn browserHostProbeBridgePlanReportContains(text: str, needle: str): bool =
    if len(needle) <= 0:
        return true
    if len(text) < len(needle):
        return false
    var i: int32
    while i + len(needle) <= len(text):
        var matched = true
        var j: int32
        while j < len(needle):
            if text[i + j] != needle[j]:
                matched = false
                break
            j = j + 1
        if matched:
            return true
        i = i + 1
    return false

fn main(): int32 =
    let workspaceRoot = "/Users/lbcheng/cheng-lang"
    let packageRoot = "/Users/lbcheng/cheng-lang/v3"
    let sourcePath = "/Users/lbcheng/cheng-lang/v3/src/libp2p/browser/browser_host_wasm_probe.cheng"
    var linkPlan: slplan.V3SystemLinkPlanStub
    linkPlan.workspaceRoot = workspaceRoot
    linkPlan.packageRoot = packageRoot
    linkPlan.entryPath = sourcePath
    linkPlan.outputPath = "/tmp/browser_host_probe_smoke"
    linkPlan.sourceClosurePaths = [sourcePath]
    var plan: sexec.V3SystemLinkExecPlan
    plan.compilerEntrySource = sourcePath
    plan.systemLinkPlan = linkPlan
    plan.compileReceipt.bootstrapStage = "stage3_local"
    plan.objectPlan.pipelineStage = "primary_object_plan_to_object_plan"
    plan.nativeLinkPlan.linkerProgram = "cc"
    plan.nativeLinkPlan.pipelineStage = "primary_object_plan_to_native_link_plan"
    let reportText = sexec.v3SystemLinkExecPlanReport(plan)
    let expectedEmitLine = codegen.v3BrowserHostProbeBridgeEmitLineForSourceRuleName(sourcePath,
                                                                                      browserprobe.v3BrowserHostProbeRuleDmWaitStartName())
    assert(browserHostProbeBridgePlanReportContains(reportText, "browser_bridge_plan_count=8"),
           "v3 browser_host_probe_bridge_plan_report: count")
    assert(browserHostProbeBridgePlanReportContains(reportText, "browser_bridge_plan_unique_key_count=4"),
           "v3 browser_host_probe_bridge_plan_report: unique key count")
    assert(browserHostProbeBridgePlanReportContains(reportText,
                                                    "browser_bridge_artifact_path=/tmp/browser_host_probe_smoke.browser_bridge_plan.txt"),
           "v3 browser_host_probe_bridge_plan_report: artifact path")
    assert(browserHostProbeBridgePlanReportContains(reportText, "browser_bridge_artifact_format=browser_abi_bridge_plan_v1"),
           "v3 browser_host_probe_bridge_plan_report: artifact format")
    assert(browserHostProbeBridgePlanReportContains(reportText, "browser_bridge_artifact_count=8"),
           "v3 browser_host_probe_bridge_plan_report: artifact count")
    assert(browserHostProbeBridgePlanReportContains(reportText, "browser_bridge_artifact_unique_key_count=4"),
           "v3 browser_host_probe_bridge_plan_report: artifact unique key count")
    assert(browserHostProbeBridgePlanReportContains(reportText,
                                                    "browser_bridge_source_path=/tmp/browser_host_probe_smoke.browser_bridge.generated.cheng"),
           "v3 browser_host_probe_bridge_plan_report: source path")
    assert(browserHostProbeBridgePlanReportContains(reportText, "browser_bridge_source_format=browser_abi_bridge_source_v1"),
           "v3 browser_host_probe_bridge_plan_report: source format")
    assert(browserHostProbeBridgePlanReportContains(reportText, "browser_bridge_source_count=8"),
           "v3 browser_host_probe_bridge_plan_report: source count")
    assert(browserHostProbeBridgePlanReportContains(reportText, "browser_bridge_plan[6]=" + expectedEmitLine),
           "v3 browser_host_probe_bridge_plan_report: dm wait emit line")
    echo("v3 browser_host_probe_bridge_plan_report_smoke ok")
    return 0
