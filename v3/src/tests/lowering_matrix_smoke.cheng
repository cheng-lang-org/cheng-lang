import std/os
import std/result
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_world as cworld
import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/backend/lowering_plan as lower

fn buildLinkPlan(workspaceRoot: str,
                 packageRoot: str,
                 sourcePath: str,
                 outputPath: str,
                 emitKind: int32): slplan.V3SystemLinkPlanStub =
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err),
           "v3 lowering matrix: link plan")
    return linkPlan

fn main(): int32 =
    let workspaceRoot: str = v3path.V3PathCurrentDir()
    let packageRoot: str = v3path.V3PathJoin(workspaceRoot, "v3")
    let smokeLabel: str = os.GetEnvDefault("CHENG_V3_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathJoin(workspaceRoot, "artifacts/v3_lowering_matrix/" + smokeLabel)
    assert(v3path.V3MkdirP(workspaceRoot, outDir), "v3 lowering matrix: mkdir")
    let fixturePath: str = v3path.V3PathJoin(packageRoot, "src/tests/lowering_matrix_fixture.cheng")
    let outputPath: str = v3path.V3PathJoin(outDir, "lowering_matrix_fixture")
    let linkPlan = buildLinkPlan(workspaceRoot,
                                 packageRoot,
                                 fixturePath,
                                 outputPath,
                                 creq.v3EmitShared)
    var err = ""
    var plan: lower.V3LoweringPlanStub
    assert(lower.v3BuildLoweringPlanStub(linkPlan, plan, err),
           "v3 lowering matrix: lowering plan")
    let sourceBundleCid = cworld.v3CompilerWorldSourceBundleCid(linkPlan.packageId, linkPlan.sourceClosurePaths)
    let csgRes = ccsg.v3BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(csgRes), "v3 lowering matrix: compiler csg")
    let csg = ccsg.v3CompilerCsgClone(Value(csgRes))
    let fixtureFacts = ccsg.v3TypedExprFactsForSource(csg.typedExprFacts, fixturePath)
    let fixtureRules = ccsg.v3TypedExprLoweringRulesFromFacts(fixtureFacts)
    let planRules = lower.v3LoweringPlanRulesForSource(plan, fixturePath)
    let csgReport = ccsg.v3CompilerCsgReport(csg)
    let planReport = lower.v3LoweringPlanStubReport(plan)
    assert(fixtureRules.len > 0, "v3 lowering matrix: fixture rules")
    assert(ccsg.v3TypedExprLoweringRulesEqual(fixtureRules, planRules),
           "v3 lowering matrix: compiler csg vs lowering plan")
    assert(v3path.V3TextContains(csgReport, "lowering_rule_arg_address_count="),
           "v3 lowering matrix: csg address arg key")
    assert(v3path.V3TextContains(planReport, "lowering_rule_arg_address_count="),
           "v3 lowering matrix: plan address arg key")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_arg_address_count=0\n"),
           "v3 lowering matrix: address arg rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_arg_call_result_address_count=0\n"),
           "v3 lowering matrix: call-result address arg rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_arg_value_count=0\n"),
           "v3 lowering matrix: value arg rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_result_reg_count=0\n"),
           "v3 lowering matrix: reg result rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_result_local_address_count=0\n"),
           "v3 lowering matrix: local-address result rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_result_sret_count=0\n"),
           "v3 lowering matrix: sret result rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_materialize_register_count=0\n"),
           "v3 lowering matrix: register materialize rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_materialize_local_slot_count=0\n"),
           "v3 lowering matrix: local-slot materialize rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_materialize_call_result_local_count=0\n"),
           "v3 lowering matrix: call-result local materialize rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_materialize_dest_address_count=0\n"),
           "v3 lowering matrix: dest-address materialize rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_copy_scalar_store_count=0\n"),
           "v3 lowering matrix: scalar-store copy rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_copy_region_copy_count=0\n"),
           "v3 lowering matrix: region-copy rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_import_builtin_address_slot_count=0\n"),
           "v3 lowering matrix: builtin address import rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_import_i32_value_slot_count=0\n"),
           "v3 lowering matrix: value-slot import rule")
    assert(!v3path.V3TextContains(planReport, "lowering_rule_import_i32_address_slot_count=0\n"),
           "v3 lowering matrix: address-slot import rule")
    echo("v3 lowering_matrix_smoke ok")
    return 0
