                            target: str,
                            requestAck: bool,
                            timeoutMs: int32): bool =
    let _ = target
    let payloadJson: str =
        "{" +
        "\"op\":" + toJsonStringValue(cstrToText(op)) + "," +
        "\"body\":" + toJsonStringValue(cstrToText(body)) +
        "}"
    return libp2p_send_direct_text(handle, peerId, messageId, payloadJson, "", requestAck, timeoutMs)

