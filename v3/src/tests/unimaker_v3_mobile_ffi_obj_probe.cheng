@exportc("libp2p_register_peer_hints")
fn libp2p_register_peer_hints(handle: int64, peerId: str, addressesJson: str, source: str): bool =
    clearLastError()
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        setLastError("register_peer_hints: invalid handle")
        return false
    var peerIdText: str = normalizePeerId(cstrToText(peerId))
    let addrs: str[] = parseQuotedValues(cstrToText(addressesJson))
    if len(peerIdText) <= 0 && len(addrs) > 0:
        peerIdText = normalizePeerId(addrs[0])
    if len(peerIdText) <= 0:
        return true
    let slot: int32 = ensurePeerSlot(idx, peerIdText)
    if slot < 0:
        setLastError("register_peer_hints: slot full")
        return false
    gNodes[idx].peers[slot].source = trimText(cstrToText(source))
    for i in 0..<len(addrs):
        mergePeerAddress(idx, slot, addrs[i])
    return true

@exportc("libp2p_add_external_address")
fn libp2p_add_external_address(handle: int64, multiaddr: str): bool =
    clearLastError()
