    if idx < 0:
        setLastError("add_external_address: invalid handle")
        return false
    let addrText: str = trimText(cstrToText(multiaddr))
    if len(addrText) <= 0:
        setLastError("add_external_address: empty multiaddr")
        return false
    gNodes[idx].listenAddr = addrText
    return true

@exportc("libp2p_connect_peer")
fn libp2p_connect_peer(handle: int64, peerId: str): int32 =
    clearLastError()
    let idx: int32 = findNodeByHandle(handle)
    let peerIdText: str = normalizePeerId(cstrToText(peerId))
    if idx < 0 || len(peerIdText) <= 0:
        setLastError("connect_peer: invalid args")
        return resultError
    if !connectPeerLocal(idx, peerIdText, "direct_dm"):
        setLastError("connect_peer: failed")
        return resultError
    return resultOk

@exportc("libp2p_connect_peer_timeout")
fn libp2p_connect_peer_timeout(handle: int64, peerId: str, timeoutMs: int32): int32 =
    let _ = timeoutMs
    return libp2p_connect_peer(handle, peerId)

@exportc("libp2p_connect_multiaddr")
fn libp2p_connect_multiaddr(handle: int64, multiaddr: str): int32 =
    clearLastError()
    let text: str = trimText(cstrToText(multiaddr))
    let pos: int32 = indexOf(text, "/p2p/", 0)
    if pos < 0:
        setLastError("connect_multiaddr: missing /p2p/")
        return resultError
    let peerText: str = sliceBytes(text, pos + 5, len(text) - pos - 5)
    return libp2p_connect_peer(handle, peerText)

@exportc("libp2p_connect_multiaddr_timeout")
fn libp2p_connect_multiaddr_timeout(handle: int64, multiaddr: str, timeoutMs: int32): int32 =
