@exportc("libp2p_send_direct_text")
fn libp2p_send_direct_text(handle: int64,
                           peerId: str,
                           messageId: str,
                           text: str,
                           replyTo: str,
                           requestAck: bool,
                           timeoutMs: int32): bool =
    let _ = replyTo
    let _ = requestAck
    let _ = timeoutMs
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        setLastError("send_direct_text: invalid handle or not started")
        return false
    let peerIdText: str = normalizePeerId(cstrToText(peerId))
    if len(peerIdText) <= 0:
        setLastError("send_direct_text: missing peer")
        return false
    if !hasConnectedPeer(idx, peerIdText):
        let _ = connectPeerLocal(idx, peerIdText, "direct_dm")
    let rawMessageId: str = trimText(cstrToText(messageId))
    var messageIdText: str = rawMessageId
    if len(messageIdText) <= 0:
        messageIdText = "msg-" + strings.int64ToStr(nowMs())
    let payloadJson: str = "{\"text\":" + toJsonStringValue(cstrToText(text)) + "}"
    appendMessage(idx, peerIdText, "", messageIdText, payloadJson, "out", "sent")
    let remoteIdx: int32 = findNodeByPeerId(peerIdText)
    if remoteIdx >= 0:
        appendMessage(remoteIdx, gNodes[idx].peerId, "", messageIdText, payloadJson, "in", "received")
        emitNodeEvent(remoteIdx, "dm_received", payloadJson)
    return true

@exportc("libp2p_send_dm_payload")
fn libp2p_send_dm_payload(handle: int64, peerId: str, payload: str, payloadLen: int64): bool =
    let payloadText: str = cstrToText(payload)
    var text: str = payloadText
    if payloadLen > 0:
        text = sliceBytes(payloadText, 0, int32(payloadLen))
    return libp2p_send_direct_text(handle, peerId, "", text, "", false, 0)

@exportc("libp2p_send_chat_control")
fn libp2p_send_chat_control(handle: int64,
                            peerId: str,
                            op: str,
