@exportc("social_moments_publish")
fn social_moments_publish(handle: int64, payloadJson: str): bool =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        return false
    let postIdText: str =
        "moment-" + strings.int64ToStr(nowMs()) + "-" + strings.int64ToStr(gNodes[idx].nextPostNonce)
    gNodes[idx].nextPostNonce = gNodes[idx].nextPostNonce + 1
    let payloadText: str = cstrToText(payloadJson)
    addMoment(idx, postIdText, payloadText)
    addFeedEntry(idx, payloadText)
    return true

@exportc("social_moments_delete")
fn social_moments_delete(handle: int64, postId: str): bool =
    let idx: int32 = findNodeByHandle(handle)
    let slot: int32 = findMomentSlot(idx, cstrToText(postId))
    if slot < 0:
        return false
    gNodes[idx].moments[slot] = initMomentState()
    return true

@exportc("social_moments_like")
fn social_moments_like(handle: int64, postId: str, like: bool): bool =
    let idx: int32 = findNodeByHandle(handle)
    let slot: int32 = findMomentSlot(idx, cstrToText(postId))
    if slot < 0:
        return false
    if like:
        gNodes[idx].moments[slot].likeCount = gNodes[idx].moments[slot].likeCount + 1
    elif gNodes[idx].moments[slot].likeCount > 0:
        gNodes[idx].moments[slot].likeCount = gNodes[idx].moments[slot].likeCount - 1
    return true

@exportc("social_moments_comment")
fn social_moments_comment(handle: int64, postId: str, commentJson: str): bool =
    let idx: int32 = findNodeByHandle(handle)
    let slot: int32 = findMomentSlot(idx, cstrToText(postId))
    if slot < 0:
        return false
    let commentSlot: int32 = gNodes[idx].moments[slot].commentCount
    if commentSlot < 16:
        gNodes[idx].moments[slot].comments[commentSlot] = cstrToText(commentJson)
        gNodes[idx].moments[slot].commentCount = gNodes[idx].moments[slot].commentCount + 1
    return true

@exportc("social_moments_timeline")
fn social_moments_timeline(handle: int64): str =
    return cStr(momentsTimelineJson(findNodeByHandle(handle)))

@exportc("social_notifications_list")
fn social_notifications_list(handle: int64): str =
    return cStr(notificationsListJson(findNodeByHandle(handle)))

@exportc("social_notifications_summary")
fn social_notifications_summary(handle: int64): str =
    return cStr(notificationsSummaryJson(findNodeByHandle(handle)))

@exportc("social_notifications_mark")
fn social_notifications_mark(handle: int64, notificationId: str, readState: str): bool =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return false
    let targetId: str = trimText(cstrToText(notificationId))
    let markRead: bool = strLowerAscii(trimText(cstrToText(readState))) != "unread"
    for i in 0..<gNodes[idx].notificationCount:
        if gNodes[idx].notifications[i].used && gNodes[idx].notifications[i].notificationId == targetId:
            gNodes[idx].notifications[i].read = markRead
            return true
    return false

@exportc("libp2p_update_host_network_status")
fn libp2p_update_host_network_status(handle: int64, payloadJson: str): bool =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return false
    gNodes[idx].hostNetworkStatusJson = cstrToText(payloadJson)
    return true

@exportc("libp2p_get_host_network_status_json")
fn libp2p_get_host_network_status_json(handle: int64): str =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return cStr("{}")
    return cStr(gNodes[idx].hostNetworkStatusJson)

@exportc("libp2p_get_local_system_profile_json")
fn libp2p_get_local_system_profile_json(handle: int64): str =
    let _ = handle
    return cStr("{\"cpuCores\":0,\"memoryBytes\":0,\"diskBytes\":0}")

@exportc("libp2p_get_network_resources_json")
fn libp2p_get_network_resources_json(handle: int64): str =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return cStr("{\"onlineNodes\":0}")
    return cStr("{\"onlineNodes\":" + strings.intToStr(gNodes[idx].peerCount) + "}")

@exportc("libp2p_refresh_node_resources")
fn libp2p_refresh_node_resources(handle: int64): bool =
    let _ = handle
    return true

@exportc("libp2p_measure_peer_bandwidth")
fn libp2p_measure_peer_bandwidth(handle: int64, peerId: str, durationMs: int32, chunkBytes: int32): str =
    let _ = durationMs
    let _ = chunkBytes
    return cStr("{\"peerId\":" + toJsonStringValue(cstrToText(peerId)) + ",\"bps\":0}")

@exportc("libp2p_measure_peer_latency")
fn libp2p_measure_peer_latency(handle: int64, peerId: str, probeCount: int32): str =
    let _ = handle
    let _ = probeCount
    return cStr("{\"peerId\":" + toJsonStringValue(cstrToText(peerId)) + ",\"rttMs\":0}")
