@exportc("libp2p_reconnect_bootstrap")
fn libp2p_reconnect_bootstrap(handle: int64): bool =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return false
    for i in 0..<gNodes[idx].peerCount:
        if gNodes[idx].peers[i].used:
            let _ = connectPeerLocal(idx, gNodes[idx].peers[i].peerId, "wan")
    return true

