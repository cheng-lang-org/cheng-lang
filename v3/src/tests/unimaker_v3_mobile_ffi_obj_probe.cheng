@exportc("libp2p_feed_publish_entry")
fn libp2p_feed_publish_entry(handle: int64, payloadJson: str): bool =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        return false
    let payloadText: str = cstrToText(payloadJson)
    addFeedEntry(idx, payloadText)
    emitNodeEvent(idx, "feed_publish", payloadText)
    for i in 0..<gNodes[idx].peerCount:
        if !gNodes[idx].peers[i].used || !gNodes[idx].peers[i].connected:
            continue
        let remoteIdx: int32 = findNodeByPeerId(gNodes[idx].peers[i].peerId)
        if remoteIdx >= 0:
            addFeedEntry(remoteIdx, payloadText)
            emitNodeEvent(remoteIdx, "feed_receive", payloadText)
    return true

