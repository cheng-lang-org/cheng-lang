@exportc("social_dm_send")
fn social_dm_send(handle: int64, peerId: str, conversationId: str, messageJson: str): bool =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        return false
    let peerIdText: str = normalizePeerId(cstrToText(peerId))
    let conversationIdText: str = trimText(cstrToText(conversationId))
    let payloadJson: str = cstrToText(messageJson)
    let messageIdText: str =
        "dm-" + strings.int64ToStr(nowMs()) + "-" + strings.int64ToStr(gNodes[idx].nextMessageNonce)
    gNodes[idx].nextMessageNonce = gNodes[idx].nextMessageNonce + 1
    appendMessage(idx, peerIdText, conversationIdText, messageIdText, payloadJson, "out", "sent")
    let remoteIdx: int32 = findNodeByPeerId(peerIdText)
    if remoteIdx >= 0:
        appendMessage(remoteIdx, gNodes[idx].peerId, conversationIdText, messageIdText, payloadJson, "in", "received")
        emitNodeEvent(remoteIdx, "social_dm_received", payloadJson)
    return true

