import std/system
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multistream

fn main(): int32 =
    let header = multistream.v3Libp2pMultistreamHeaderText()
    assert(header == "/multistream/1.0.0\n", "v3 libp2p multistream: header")
    let select = multistream.v3Libp2pMultistreamSelectBytes(types.v3Libp2pProtocolIdentify)
    assert(multistream.v3Libp2pMultistreamAccepts(select, types.v3Libp2pProtocolIdentify),
        "v3 libp2p multistream: accept")
    echo("v3 libp2p_multistream_smoke ok")
    return 0
