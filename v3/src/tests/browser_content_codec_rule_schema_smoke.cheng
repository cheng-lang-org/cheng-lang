import cheng/v3/lang/browser_abi_rule as barule
import cheng/v3/libp2p/browser/browser_content_codec_rule_schema as browsercodec

fn main(): int32 =
    let rules = browsercodec.v3BrowserContentCodecRules("/tmp/browser_content_codec_abi.cheng")
    assert(rules.len == 8, "v3 browser content codec rule schema: rule count")
    assert(barule.v3BrowserAbiRuleUniqueKeyCount(rules) == rules.len,
           "v3 browser content codec rule schema: unique key count")
    assert(barule.v3BrowserAbiRuleCountInputKind(rules, "bytes_required") == 1,
           "v3 browser content codec rule schema: bytes input")
    assert(barule.v3BrowserAbiRuleCountInputKind(rules, "text_required") == 1,
           "v3 browser content codec rule schema: text input")
    assert(barule.v3BrowserAbiRuleCountInputKind(rules, "text_optional") == 1,
           "v3 browser content codec rule schema: optional text input")
    assert(barule.v3BrowserAbiRuleCountErrorKind(rules, "moq_fountain_last_error") == 3,
           "v3 browser content codec rule schema: error channel")
    assert(barule.v3BrowserAbiRuleCountResultKind(rules, "status_i32") == 2,
           "v3 browser content codec rule schema: status result")
    assert(barule.v3BrowserAbiRuleCountOutBufferKind(rules, "raw_handle") == 2,
           "v3 browser content codec rule schema: raw handle out buffer")
    assert(barule.v3BrowserAbiRuleCountOutBufferKind(rules, "text_handle") == 3,
           "v3 browser content codec rule schema: text handle out buffer")
    assert(barule.v3BrowserAbiRuleHasRuleName(rules, browsercodec.v3BrowserContentCodecRuleExportMoqFountainBytesResultName()),
           "v3 browser content codec rule schema: moq bytes export rule")
    assert(barule.v3BrowserAbiRuleHasRuleName(rules, browsercodec.v3BrowserContentCodecRuleExportMoqFountainTextResultName()),
           "v3 browser content codec rule schema: moq text export rule")
    assert(barule.v3BrowserAbiRuleHasRuleName(rules, browsercodec.v3BrowserContentCodecRuleMoqFountainLastErrorHandleName()),
           "v3 browser content codec rule schema: moq error handle rule")
    let bytesRule = browsercodec.v3BrowserContentCodecRuleByName("/tmp/browser_content_codec_abi.cheng",
                                                                 browsercodec.v3BrowserContentCodecRuleInputBytesRequiredName())
    assert(bytesRule.ruleName == browsercodec.v3BrowserContentCodecRuleInputBytesRequiredName(),
           "v3 browser content codec rule schema: bytes rule by name")
    let exportTextRule = browsercodec.v3BrowserContentCodecRuleByName("/tmp/browser_content_codec_abi.cheng",
                                                                      browsercodec.v3BrowserContentCodecRuleExportMoqFountainTextResultName())
    let bridgeSpecs = barule.v3BrowserAbiBridgeSpecsFromRules(rules)
    assert(barule.v3BrowserAbiBridgeSpecCountStage(bridgeSpecs, "result_export") == 2,
           "v3 browser content codec rule schema: export bridge count")
    assert(barule.v3BrowserAbiBridgeSpecCountStage(bridgeSpecs, "error_handle_read") == 1,
           "v3 browser content codec rule schema: error handle bridge count")
    assert(exportTextRule.errorKindText == "moq_fountain_last_error",
           "v3 browser content codec rule schema: export text error kind")
    assert(barule.v3BrowserAbiBridgeHelperName(bridgeSpecs[0]) == "v3_browser_bridge_input_read_input_bytes_required",
           "v3 browser content codec rule schema: bytes helper name")
    echo("v3 browser_content_codec_rule_schema_smoke ok")
    return 0
