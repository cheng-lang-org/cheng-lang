import std/system
import std/result
import std/rawbytes
import cheng/v3/quic/tls/handshake13 as handshake13

fn main(): int32 =
    handshake13.msquicTls13ResetClientDefault(true)
    handshake13.msquicTls13ResetServerDefault(false)

    let genRes: Result[bool] = handshake13.msquicTls13ClientGenerateX25519()
    if IsErr(genRes):
        panic(ErrorText(genRes))

    let randomSeed: Bytes = bytesAlloc(32)
    for i in 0..<32:
        bytesSet(randomSeed, i, (i + 1) & 0xff)

    let helloRes: Result[Bytes] = handshake13.msquicTls13ClientBuildClientHello(
        randomSeed,
        "dm",
        "localhost",
        emptyBytes()
    )
    if IsErr(helloRes):
        panic(ErrorText(helloRes))

    let feedRes: Result[int32] = handshake13.msquicTls13SideFeed(1, Value(helloRes))
    if IsErr(feedRes):
        panic(ErrorText(feedRes))

    assert(Value(feedRes) == 1, "v3 tls client hello parse: one message")
    assert(
        handshake13.msquicTls13ServerClientKeyShareGroup() > 0,
        "v3 tls client hello parse: server parsed client key share"
    )
    echo("v3 tls_client_hello_parse_smoke ok")
    return 0
