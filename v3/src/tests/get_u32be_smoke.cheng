import std/system
import std/rawbytes
import std/crypto/sha256

fn main(): int32 =
    let data: Bytes = bytesAlloc(4)
    bytesSet(data, 0, 0x12)
    bytesSet(data, 1, 0x34)
    bytesSet(data, 2, 0x56)
    bytesSet(data, 3, 0x78)
    let word = sha256.getU32BE(data, 0)
    assert(word == int64(0x12345678), "v3 get_u32be: word")
    let out: Bytes = bytesAlloc(4)
    sha256.setU32BE(out, 0, word)
    assert(bytesGet(out, 0) == 0x12, "v3 get_u32be: out byte0")
    assert(bytesGet(out, 1) == 0x34, "v3 get_u32be: out byte1")
    assert(bytesGet(out, 2) == 0x56, "v3 get_u32be: out byte2")
    assert(bytesGet(out, 3) == 0x78, "v3 get_u32be: out byte3")
    bytesSet(data, 0, 0xba)
    bytesSet(data, 1, 0x78)
    bytesSet(data, 2, 0x16)
    bytesSet(data, 3, 0x80)
    let wordHigh = sha256.getU32BE(data, 0)
    assert(wordHigh == int64(0xba781680), "v3 get_u32be: high word")
    sha256.setU32BE(out, 0, wordHigh)
    assert(bytesGet(out, 0) == 0xba, "v3 get_u32be: high byte0")
    assert(bytesGet(out, 1) == 0x78, "v3 get_u32be: high byte1")
    assert(bytesGet(out, 2) == 0x16, "v3 get_u32be: high byte2")
    assert(bytesGet(out, 3) == 0x80, "v3 get_u32be: high byte3")
    echo("v3 get_u32be_smoke ok")
    return 0
