import cheng/v3/tooling/compiler_runtime as crun

fn main(): int32 =
    let root = "/tmp/cheng-lang"
    let sep = "/"
    let rel = "v3/src/tooling/compiler_main.cheng"
    assert(root + sep == "/tmp/cheng-lang/", "concat root slash")
    assert((root + sep) + rel ==
           "/tmp/cheng-lang/v3/src/tooling/compiler_main.cheng",
           "concat rel")
    assert(crun.v3CompilerRuntimePath(root, rel) ==
           "/tmp/cheng-lang/v3/src/tooling/compiler_main.cheng",
           "runtime path")
    echo("compiler_runtime_path_probe ok")
    return 0
