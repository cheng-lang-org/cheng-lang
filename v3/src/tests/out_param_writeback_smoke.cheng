fn fillSimple(outText: var str, outRc: var int32) =
    outText = "simple"
    outRc = 7

fn passthroughText(value: str): str =
    return value

fn passthroughRc(value: int32): int32 =
    return value

fn fillViaCalls(outText: var str, outRc: var int32) =
    let text = passthroughText("called")
    let rc = passthroughRc(9)
    outText = text
    outRc = rc

fn fillViaLoop(outText: var str, outRc: var int32) =
    var i: int32
    var total: int32
    while i < 3:
        total = total + 2
        i = i + 1
    outText = "loop"
    outRc = total

fn main(): int32 =
    var text: str
    var rc: int32 = -1

    fillSimple(text, rc)
    assert(text == "simple", "out param writeback simple text")
    assert(rc == 7, "out param writeback simple rc")

    text = ""
    rc = -1
    fillViaCalls(text, rc)
    assert(text == "called", "out param writeback call text")
    assert(rc == 9, "out param writeback call rc")

    text = ""
    rc = -1
    fillViaLoop(text, rc)
    assert(text == "loop", "out param writeback loop text")
    assert(rc == 6, "out param writeback loop rc")

    echo("v3 out_param_writeback_smoke ok")
    return 0
