import std/system
import std/rawbytes
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host
import cheng/v3/libp2p/protocols/store_sync
import cheng/v3/libp2p/transports/tcp_transport
import cheng/v3/project/chain_node as node
import cheng/v3/project/chain_node_libp2p as net

fn main(): int32 =
    let listenPort = 6211
    var server = node.v3ChainNodeInit("node-a", "chain-node-a")
    var clientA = node.v3ChainNodeInit("node-b", "chain-node-a")
    var clientB = node.v3ChainNodeInit("node-c", "chain-node-a")
    var serverHost = host.v3Libp2pHostInit("chain.roundtrip.server")
    var clientHost = host.v3Libp2pHostInit("chain.roundtrip.client")
    var serverAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(serverAddr, "127.0.0.1", listenPort)
    let listenRes = host.v3Libp2pListen(serverHost, serverAddr)
    assert(listenRes.ok, "v3 chain_node snapshot roundtrip: listen")

    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolGossipsub)
    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolStore)
    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolGossipsub)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolStore)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolSync)

    let dialRes = host.v3Libp2pDial(clientHost,
                                    serverHost.selfPeerId,
                                    serverAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 chain_node snapshot roundtrip: dial")

    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node snapshot roundtrip: mint")
    let transferCidRes = node.v3ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, "v3 chain_node snapshot roundtrip: transfer")
    let serveRes = net.v3ChainNodeLibp2pServeOnce(server, serverHost)
    assert(serveRes.ok, "v3 chain_node snapshot roundtrip: serve")
    assert(serveRes.value, "v3 chain_node snapshot roundtrip: serve active")

    let directIngressRes = net.v3ChainNodeLibp2pLatestSnapshot(serverHost, clientA.address)
    assert(directIngressRes.ok, "v3 chain_node snapshot roundtrip: direct latest")

    var query = overlay.v3OverlayStoreQueryZero()
    query.topicScope = overlay.v3OverlayScopeCell
    query.address = clientA.address
    let requestPayload = store_sync.v3Libp2pStoreQueryEncode(query)
    let servePayloadRes = host.v3Libp2pSyncServePayload(serverHost, requestPayload)
    assert(servePayloadRes.ok, "v3 chain_node snapshot roundtrip: serve payload")
    let servedEntriesRes = store_sync.v3Libp2pStoreEntriesDecode(servePayloadRes.value)
    assert(servedEntriesRes.ok, "v3 chain_node snapshot roundtrip: served decode")
    assert(servedEntriesRes.value.len == 2, "v3 chain_node snapshot roundtrip: served entry count")
    let servedSnapshotRes = net.v3ChainNodeLibp2pLatestSnapshotFromIngresses(servedEntriesRes.value, clientA.address)
    assert(servedSnapshotRes.ok, "v3 chain_node snapshot roundtrip: served latest")
    let loopbackPayloadRes = tcp_transport.v3Libp2pTcpLoopbackRequestResponse(types.v3Libp2pProtocolSync,
                                                                              requestPayload,
                                                                              servePayloadRes.value)
    assert(loopbackPayloadRes.ok, "v3 chain_node snapshot roundtrip: loopback")
    let loopbackEntriesRes = store_sync.v3Libp2pStoreEntriesDecode(loopbackPayloadRes.value)
    assert(loopbackEntriesRes.ok, "v3 chain_node snapshot roundtrip: loopback decode")
    assert(loopbackEntriesRes.value.len == 2, "v3 chain_node snapshot roundtrip: loopback entry count")
    let loopbackSnapshotRes = net.v3ChainNodeLibp2pLatestSnapshotFromIngresses(loopbackEntriesRes.value, clientA.address)
    assert(loopbackSnapshotRes.ok, "v3 chain_node snapshot roundtrip: loopback latest")
    var syncedEntries: overlay.V3IngressEnvelope[]
    let syncedEntriesRes = host.v3Libp2pSyncRequest(clientHost, serverHost, serverHost.selfPeerId, query, syncedEntries)
    assert(syncedEntriesRes.ok, "v3 chain_node snapshot roundtrip: sync request")
    assert(syncedEntries.len == 2, "v3 chain_node snapshot roundtrip: sync entry count")
    let syncedIngressRes = net.v3ChainNodeLibp2pLatestSnapshotFromIngresses(syncedEntries, clientA.address)
    assert(syncedIngressRes.ok, "v3 chain_node snapshot roundtrip: synced latest")

    let directIngress = directIngressRes.value
    let syncedIngress = syncedIngressRes.value
    assert(layout.fixedBytes32Equal(directIngress.payloadCid, syncedIngress.payloadCid),
        "v3 chain_node snapshot roundtrip: payload cid equal")
    assert(directIngress.payloadLen == syncedIngress.payloadLen,
        "v3 chain_node snapshot roundtrip: payload len equal")
    assert(bytesEqual(directIngress.payload, syncedIngress.payload),
        "v3 chain_node snapshot roundtrip: payload bytes equal")

    let directSnapshotRes = net.v3ChainNodeLibp2pDecodeSnapshot(directIngress.payload)
    assert(directSnapshotRes.ok, "v3 chain_node snapshot roundtrip: direct decode")
    let syncedSnapshotRes = net.v3ChainNodeLibp2pDecodeSnapshot(syncedIngress.payload)
    assert(syncedSnapshotRes.ok, "v3 chain_node snapshot roundtrip: synced decode")

    let directSnapshot = directSnapshotRes.value
    let syncedSnapshot = syncedSnapshotRes.value
    assert(directSnapshot.eventCids.len == syncedSnapshot.eventCids.len,
        "v3 chain_node snapshot roundtrip: event count equal")
    assert(directSnapshot.events.len == syncedSnapshot.events.len,
        "v3 chain_node snapshot roundtrip: event payload count equal")
    for i in 0..<directSnapshot.events.len:
        assert(layout.fixedBytes32Equal(directSnapshot.eventCids[i], syncedSnapshot.eventCids[i]),
            "v3 chain_node snapshot roundtrip: event cid equal")
        assert(layout.fixedBytes32Equal(directSnapshot.events[i].bodyCid, syncedSnapshot.events[i].bodyCid),
            "v3 chain_node snapshot roundtrip: body cid equal")
        assert(layout.fixedBytes32Equal(syncedSnapshot.events[i].bodyCid,
                                        consensus.v3ChainEventBodyCid(syncedSnapshot.events[i])),
            "v3 chain_node snapshot roundtrip: synced body cid valid")
        assert(layout.fixedBytes32Equal(syncedSnapshot.eventCids[i],
                                        consensus.v3ChainEventCid(syncedSnapshot.events[i])),
            "v3 chain_node snapshot roundtrip: synced event cid valid")

    let directSyncRes = node.v3ChainNodeSyncOnce(clientA, directSnapshot)
    assert(directSyncRes.ok, "v3 chain_node snapshot roundtrip: direct sync")
    assert(directSyncRes.value, "v3 chain_node snapshot roundtrip: direct sync changed")
    let syncedSyncRes = node.v3ChainNodeSyncOnce(clientB, syncedSnapshot)
    assert(syncedSyncRes.ok, "v3 chain_node snapshot roundtrip: synced sync")
    assert(syncedSyncRes.value, "v3 chain_node snapshot roundtrip: synced sync changed")

    echo("v3 chain_node_snapshot_sync_roundtrip_smoke ok")
    return 0
