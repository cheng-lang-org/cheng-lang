import std/cmdline as cmdline

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    var value: str
    let ok = cmdline.ReadFirstFlagValue("--needle", value)
    assert(ok, "cmdline readFirstFlagValue ok")
    assert(value == "needle-value", "cmdline readFirstFlagValue value")
    echo("v3 cmdline_read_first_flag_value_smoke ok")
    return 0
