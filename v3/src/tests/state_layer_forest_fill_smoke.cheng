import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/binary_types as types
import cheng/v3/chain/lsmr as lsmr
import cheng/v3/chain/lsmr_types as lt

fn mustAddress(digits: int32[]): types.V3LsmrAddress =
    let res = types.v3LsmrAddressFromDigits(digits)
    if IsErr(res):
        panic(Error(res))
    return Value(res)

fn makeCell(keyId: int32, digits: int32[], resolution: int32, salt: int32): lt.V3StateCell =
    let address = mustAddress(digits)
    let contentCid = lt.v3HashInts("v3.forest_fill.content", [keyId, salt, resolution])
    let localityHash = lt.v3HashInts("v3.forest_fill.locality", [keyId, salt, resolution])
    var cell: lt.V3StateCell
    lsmr.v3LsmrStateCellFill(cell, keyId, address, resolution, contentCid, localityHash)
    return cell

fn main(): int32 =
    var cells: lt.V3StateCell[]
    cells = []
    add(cells, makeCell(201, [6, 7, 9], 1, 1))
    add(cells, makeCell(202, [6, 7, 3], 2, 2))
    add(cells, makeCell(203, [6, 7, 4], 3, 3))
    var forest = lt.V3StateLayerForest()
    lsmr.v3BuildStateLayerForestFill(forest, cells)
    assert(forest.globalTree.entryCount == 1, "v3 state_layer_forest_fill_smoke: global count")
    assert(forest.regionalTree.entryCount == 1, "v3 state_layer_forest_fill_smoke: regional count")
    assert(forest.edgeTree.entryCount == 1, "v3 state_layer_forest_fill_smoke: edge count")
    assert(!layout.fixedBytes32Equal(forest.forestCid, layout.FixedBytes32()),
           "v3 state_layer_forest_fill_smoke: forest cid")
    echo("v3 state_layer_forest_fill_smoke ok")
    return 0
