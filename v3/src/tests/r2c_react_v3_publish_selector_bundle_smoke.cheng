import std/os
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/r2c_react_v3_surface_main as r2csurface

fn main(): int32 =
    let root = os.GetCurrentDir()
    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_r2c_publish_selector_smoke")
    assert(v3path.V3MkdirP(root, outDir), "v3 r2c publish selector smoke: mkdir")
    let driver = v3path.V3PathAbsolute(root, "artifacts/v3_backend_driver/cheng")
    let stage3 = v3path.V3PathAbsolute(root, "artifacts/v3_bootstrap/cheng.stage3")
    let bundleScript = v3path.V3PathAbsolute(root, "v3/experimental/r2c-react-v3/r2c-react-v3-native-gui-bundle.mjs")
    assert(v3path.V3FileExistsNonEmpty(root, driver), "v3 r2c publish selector smoke: backend_driver exists")
    assert(v3path.V3FileExistsNonEmpty(root, stage3), "v3 r2c publish selector smoke: stage3 exists")
    assert(v3path.V3FileExistsNonEmpty(root, bundleScript), "v3 r2c publish selector smoke: bundle script exists")
    let readyEnv = ["CHENG_V3_BACKEND_DRIVER_READY=1"]
    var nativeEnv: str[]
    add(nativeEnv, "R2C_REACT_V3_TOOLING_BIN=" + stage3)
    add(nativeEnv, "CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1")
    let repoEnv = os.GetEnv("R2C_REACT_V3_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.DirExists(repo), "v3 r2c publish selector smoke: React.js repo exists")

    let codegenOutDir = v3path.V3PathJoin(outDir, "codegen_surface")
    let codegenLog = v3path.V3PathJoin(outDir, "r2c_codegen_surface.log")
    if v3path.V3PathFileExists(codegenLog):
        os.RemoveFile(codegenLog)
    let codegenRun = hostops.v3RunFileLogged(root,
                                             "r2c_codegen_surface_publish_selector_smoke",
                                             driver,
                                             ["r2c-react-v3-codegen-surface-smoke",
                                              "--repo", repo,
                                              "--out-dir", codegenOutDir],
                                             readyEnv,
                                             root,
                                             0,
                                             codegenLog)
    assert(hostops.v3LoggedRunOk(codegenRun), "v3 r2c publish selector smoke: codegen surface rc")
    assert(v3path.V3PathFileExists(codegenLog), "v3 r2c publish selector smoke: codegen surface log")
    assert(v3path.V3TextContains(codegenRun.output, "r2c-react-v3 codegen surface smoke: ok"),
           "v3 r2c publish selector smoke: codegen surface ok")
    let codegenManifestPath = os.JoinPath(codegenOutDir, "cheng_codegen_v1.json")
    let codegenRouteCatalogPath = os.JoinPath(codegenOutDir, "cheng_codegen_route_catalog_v1.json")
    let codegenTsxAstPath = os.JoinPath(codegenOutDir, "tsx_ast_v1.json")
    assert(v3path.V3FileExistsNonEmpty(root, codegenManifestPath),
           "v3 r2c publish selector smoke: codegen manifest")
    assert(v3path.V3FileExistsNonEmpty(root, codegenRouteCatalogPath),
           "v3 r2c publish selector smoke: codegen route catalog")
    assert(v3path.V3FileExistsNonEmpty(root, codegenTsxAstPath),
           "v3 r2c publish selector smoke: codegen tsx ast")

    let bundleOutDir = v3path.V3PathJoin(outDir, "native_gui_bundle_publish_selector")
    let bundleLog = v3path.V3PathJoin(outDir, "r2c_native_gui_bundle_publish_selector.log")
    if v3path.V3PathFileExists(bundleLog):
        os.RemoveFile(bundleLog)
    assert(v3path.V3MkdirP(root, bundleOutDir), "v3 r2c publish selector smoke: bundle mkdir")
    let staticSummaryPath = os.JoinPath(bundleOutDir, "static_surface.summary.env")
    let bundleHostContractPath = os.JoinPath(bundleOutDir, "unimaker_host_v1.json")
    let bundleAssetManifestPath = os.JoinPath(bundleOutDir, "asset_manifest_v1.json")
    let bundleTailwindManifestPath = os.JoinPath(bundleOutDir, "tailwind_style_manifest_v1.json")
    var staticAssetRoots: str[]
    var staticSurface: r2csurface.R2cStaticSurfaceRunResult
    assert(r2csurface.r2cRunStaticSurface(repo, bundleOutDir, codegenTsxAstPath, staticSummaryPath, staticAssetRoots, staticSurface),
           "v3 r2c publish selector smoke: static surface rc")
    assert(v3path.V3FileExistsNonEmpty(root, staticSummaryPath),
           "v3 r2c publish selector smoke: static surface summary")
    assert(v3path.V3FileExistsNonEmpty(root, bundleHostContractPath),
           "v3 r2c publish selector smoke: bundle host contract")
    assert(v3path.V3FileExistsNonEmpty(root, bundleAssetManifestPath),
           "v3 r2c publish selector smoke: bundle asset manifest")
    assert(v3path.V3FileExistsNonEmpty(root, bundleTailwindManifestPath),
           "v3 r2c publish selector smoke: bundle tailwind manifest")

    let bundleSummaryPath = os.JoinPath(bundleOutDir, "native_gui_bundle.summary.env")
    let bundleRun = hostops.v3RunProgramLogged(root,
                                               "r2c_native_gui_bundle_publish_selector_smoke",
                                               "node",
                                               [bundleScript,
                                                "--repo", repo,
                                                "--route-state", "publish_selector",
                                                "--out-dir", bundleOutDir,
                                                "--codegen-manifest", codegenManifestPath,
                                                "--host-contract", bundleHostContractPath,
                                                "--asset-manifest", bundleAssetManifestPath,
                                                "--tailwind-manifest", bundleTailwindManifestPath,
                                                "--route-catalog", codegenRouteCatalogPath,
                                                "--tsx-ast", codegenTsxAstPath,
                                                "--summary-out", bundleSummaryPath],
                                               nativeEnv,
                                               root,
                                               0,
                                               bundleLog)
    assert(hostops.v3LoggedRunOk(bundleRun), "v3 r2c publish selector smoke: bundle rc")
    assert(v3path.V3PathFileExists(bundleLog), "v3 r2c publish selector smoke: bundle log")
    assert(v3path.V3TextContains(bundleRun.output, "\"ok\": true"),
           "v3 r2c publish selector smoke: bundle ok")
    let bundleReportPath = os.JoinPath(bundleOutDir, "native_gui_bundle_report_v1.json")
    let bundleJsonPath = os.JoinPath(bundleOutDir, "native_gui_bundle_v1.json")
    let bundleSessionPath = os.JoinPath(bundleOutDir, "native_gui_session_v1.json")
    assert(v3path.V3FileExistsNonEmpty(root, bundleReportPath),
           "v3 r2c publish selector smoke: bundle report")
    assert(v3path.V3FileExistsNonEmpty(root, bundleSummaryPath),
           "v3 r2c publish selector smoke: bundle summary")
    assert(v3path.V3FileExistsNonEmpty(root, bundleJsonPath),
           "v3 r2c publish selector smoke: bundle json")
    assert(v3path.V3FileExistsNonEmpty(root, bundleSessionPath),
           "v3 r2c publish selector smoke: session json")
    let bundleSummaryText = v3path.V3ReadTextFile("", bundleSummaryPath)
    assert(v3path.V3TextContains(bundleSummaryText, "native_gui_route_state=publish_selector"),
           "v3 r2c publish selector smoke: route state")
    assert(v3path.V3TextContains(bundleSummaryText, "native_gui_runtime_bundle_ready=true"),
           "v3 r2c publish selector smoke: runtime bundle ready")
    assert(v3path.V3TextContains(bundleSummaryText, "native_gui_runtime_contract_ready=true"),
           "v3 r2c publish selector smoke: runtime contract ready")
    assert(v3path.V3TextContains(bundleSummaryText, "native_gui_runtime_bundle_route_state=publish_selector"),
           "v3 r2c publish selector smoke: runtime bundle route state")
    assert(v3path.V3TextContains(bundleSummaryText, "native_gui_runtime_bundle_supported_count="),
           "v3 r2c publish selector smoke: runtime bundle supported count")

    echo("v3 r2c_react_v3_publish_selector_bundle_smoke ok")
    return 0
