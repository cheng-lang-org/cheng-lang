import std/system
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/binary_types as types
import cheng/v3/chain/lsmr
import cheng/v3/chain/lsmr_types as lt

fn makePayloadCid(keyId: int32,
                  baguaId: int32,
                  resolutionLevel: int32,
                  layerId: int32,
                  address: types.V3LsmrAddress,
                  prefix: lt.V3PrefixRef,
                  localityHash: layout.FixedBytes32,
                  contentCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.locality_cid"))
    lt.v3AppendU32BE(buf, keyId)
    lt.v3AppendU32BE(buf, baguaId)
    lt.v3AppendU32BE(buf, resolutionLevel)
    lt.v3AppendU32BE(buf, layerId)
    lt.v3AppendAddress(buf, address)
    lt.v3AppendPrefix(buf, prefix)
    lt.v3AppendFixed32(buf, localityHash)
    lt.v3AppendFixed32(buf, contentCid)
    return lt.v3FixedCidFromBuf(buf)

fn main(): int32 =
    var digits: int32[]
    digits = []
    add(digits, 1)
    add(digits, 2)
    add(digits, 3)
    let addressRes = types.v3LsmrAddressFromDigits(digits)
    assert(IsOk(addressRes), "v3 lsmr locality steps: address")
    let address = Value(addressRes)
    let keyText = intToStr(7)
    let baguaId = lsmr.v3LsmrAddressBagua(address, keyText)
    assert(lt.v3BaguaValid(baguaId), "v3 lsmr locality steps: bagua")
    let prefixRes = lt.v3PrefixRefFromDigits(baguaId, digits)
    assert(IsOk(prefixRes), "v3 lsmr locality steps: prefix")
    let prefix = Value(prefixRes)
    let zeroCid = layout.fixedBytes32Zero()
    let layerId = lsmr.v3LsmrStateLayerForResolution(3)
    let localityCid = makePayloadCid(7, baguaId, 3, layerId, address, prefix, zeroCid, zeroCid)
    var locality: lt.V3LocalityCid
    locality.keyId = 7
    locality.baguaId = baguaId
    locality.resolutionLevel = 3
    locality.layerId = layerId
    locality.address = address
    locality.prefix = prefix
    locality.localityHash = zeroCid
    locality.contentCid = zeroCid
    locality.cid = localityCid
    assert(locality.keyId == 7, "v3 lsmr locality steps: locality key")
    var cell: lt.V3StateCell
    cell.keyId = 7
    cell.baguaId = baguaId
    cell.resolutionLevel = 3
    cell.layerId = layerId
    cell.address = address
    cell.prefix = prefix
    cell.contentCid = zeroCid
    cell.localityHash = zeroCid
    cell.localityCid = localityCid
    assert(cell.keyId == 7, "v3 lsmr locality steps: cell key")
    echo("v3 lsmr_locality_steps_smoke ok")
    return 0
