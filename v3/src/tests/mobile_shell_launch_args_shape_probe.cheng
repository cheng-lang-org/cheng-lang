import std/monotimes
import std/os
import std/strings
import cheng/v3/tooling/mobile_shell_codegen as mshell
import cheng/v3/tooling/path as v3path

fn probeQuote(text: str): str =
    return "\"" + text + "\""

fn probeLaunchArgsKv(routeState: str,
                     runtimeMode: str,
                     runtimeManifestRel: str,
                     runtimeContractPayloadRel: str,
                     runtimeBundlePayloadRel: str): str =
    var text: str
    text = text + "gate_mode=android-semantic-visual-1to1"
    text = text + ";truth_mode=strict"
    text = text + ";route_state=" + routeState
    text = text + ";route_lock=1"
    text = text + ";runtime_mode=" + runtimeMode
    text = text + ";runtime_manifest=" + runtimeManifestRel
    text = text + ";runtime_contract_payload=" + runtimeContractPayloadRel
    text = text + ";runtime_bundle_payload=" + runtimeBundlePayloadRel
    return text

fn probeLaunchArgsJson(routeState: str,
                       runtimeMode: str,
                       runtimeManifestRel: str,
                       runtimeContractPayloadRel: str,
                       runtimeBundlePayloadRel: str): str =
    var text: str = "{\n"
    text = text + "  \"format\": \"mobile_shell_launch_args_v1\",\n"
    text = text + "  \"gate_mode\": \"android-semantic-visual-1to1\",\n"
    text = text + "  \"truth_mode\": \"strict\",\n"
    text = text + "  \"route_state\": \"" + routeState + "\",\n"
    text = text + "  \"route_lock\": true,\n"
    text = text + "  \"runtime_mode\": \"" + runtimeMode + "\",\n"
    text = text + "  \"runtime_manifest\": \"" + runtimeManifestRel + "\",\n"
    text = text + "  \"runtime_contract_payload\": \"" + runtimeContractPayloadRel + "\",\n"
    text = text + "  \"runtime_bundle_payload\": \"" + runtimeBundlePayloadRel + "\"\n"
    text = text + "}\n"
    return text

fn probeAndroidHostSourceOldShape(opts: var mshell.V3MobileShellOptions): str =
    let runtimeManifestRel: str = "mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "runtime/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "runtime/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKv: str = probeLaunchArgsKv(opts.routeState,
                                              opts.runtimeMode,
                                              runtimeManifestRel,
                                              runtimeContractPayloadRel,
                                              runtimeBundlePayloadRel)
    let launchArgsJson: str = probeLaunchArgsJson(opts.routeState,
                                                  opts.runtimeMode,
                                                  runtimeManifestRel,
                                                  runtimeContractPayloadRel,
                                                  runtimeBundlePayloadRel)
    var text: str = "#include <jni.h>\n"
    text = text + "#include <android/log.h>\n"
    text = text + "#include <android/native_window_jni.h>\n"
    text = text + "#include <dlfcn.h>\n"
    text = text + "#include <stdio.h>\n"
    text = text + "#include <stdint.h>\n"
    text = text + "#include <stdlib.h>\n"
    text = text + "#include <string.h>\n\n"
    text = text + "typedef uint64_t (*cheng_app_init_fn)(void);\n"
    text = text + "typedef void (*cheng_app_set_window_fn)(uint64_t, uint64_t, int, int, float);\n"
    text = text + "typedef void (*cheng_app_tick_fn)(uint64_t, float);\n"
    text = text + "typedef void (*cheng_app_on_touch_fn)(uint64_t, int, int, float, float);\n"
    text = text + "typedef void (*cheng_app_pause_fn)(uint64_t);\n"
    text = text + "typedef void (*cheng_app_resume_fn)(uint64_t);\n"
    text = text + "typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);\n\n"
    text = text + "static cheng_app_init_fn s_app_init = NULL;\n"
    text = text + "static cheng_app_set_window_fn s_app_set_window = NULL;\n"
    text = text + "static cheng_app_tick_fn s_app_tick = NULL;\n"
    text = text + "static cheng_app_on_touch_fn s_app_on_touch = NULL;\n"
    text = text + "static cheng_app_pause_fn s_app_pause = NULL;\n"
    text = text + "static cheng_app_resume_fn s_app_resume = NULL;\n\n"
    text = text + "static const char* kChengRuntimeManifest = \"" + runtimeManifestRel + "\";\n"
    text = text + "static const char* kChengLaunchArgsKv = " + probeQuote(launchArgsKv) + ";\n"
    text = text + "static const char* kChengLaunchArgsJson = " + probeQuote(launchArgsJson) + ";\n\n"
    text = text + "static int cheng_resolve_exports(void) {\n"
    text = text + "  void* s_app_handle = dlopen(\"libcheng_launch_args_probe.so\", RTLD_NOW | RTLD_GLOBAL);\n"
    text = text + "  if (s_app_handle == NULL) {\n"
    text = text + "    return 0;\n"
    text = text + "  }\n"
    text = text + "  s_app_init = (cheng_app_init_fn)dlsym(s_app_handle, \"cheng_app_init\");\n"
    text = text + "  s_app_set_window = (cheng_app_set_window_fn)dlsym(s_app_handle, \"cheng_app_set_window\");\n"
    text = text + "  s_app_tick = (cheng_app_tick_fn)dlsym(s_app_handle, \"cheng_app_tick\");\n"
    text = text + "  s_app_on_touch = (cheng_app_on_touch_fn)dlsym(s_app_handle, \"cheng_app_on_touch\");\n"
    text = text + "  s_app_pause = (cheng_app_pause_fn)dlsym(s_app_handle, \"cheng_app_pause\");\n"
    text = text + "  s_app_resume = (cheng_app_resume_fn)dlsym(s_app_handle, \"cheng_app_resume\");\n"
    text = text + "  cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(s_app_handle, \"cheng_mobile_host_runtime_set_launch_args\");\n"
    text = text + "  if (setLaunchArgs != NULL) {\n"
    text = text + "    setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);\n"
    text = text + "  }\n"
    text = text + "  return s_app_init && s_app_set_window && s_app_tick && s_app_on_touch && s_app_pause && s_app_resume;\n"
    text = text + "}\n"
    return text

fn probeIosHostSourceOldShape(opts: var mshell.V3MobileShellOptions): str =
    let runtimeManifestRel: str = "runtime/mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "runtime/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "runtime/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKv: str = probeLaunchArgsKv(opts.routeState,
                                              opts.runtimeMode,
                                              runtimeManifestRel,
                                              runtimeContractPayloadRel,
                                              runtimeBundlePayloadRel)
    let launchArgsJson: str = probeLaunchArgsJson(opts.routeState,
                                                  opts.runtimeMode,
                                                  runtimeManifestRel,
                                                  runtimeContractPayloadRel,
                                                  runtimeBundlePayloadRel)
    var text: str = "#import <UIKit/UIKit.h>\n"
    text = text + "#import <QuartzCore/CAMetalLayer.h>\n"
    text = text + "#import <Metal/Metal.h>\n"
    text = text + "#import <dlfcn.h>\n\n"
    text = text + "typedef unsigned long long (*cheng_app_init_fn)(void);\n"
    text = text + "typedef void (*cheng_app_set_window_fn)(unsigned long long, unsigned long long, int, int, float);\n"
    text = text + "typedef void (*cheng_app_tick_fn)(unsigned long long, float);\n"
    text = text + "typedef void (*cheng_app_on_touch_fn)(unsigned long long, int, int, float, float);\n"
    text = text + "typedef void (*cheng_app_pause_fn)(unsigned long long);\n"
    text = text + "typedef void (*cheng_app_resume_fn)(unsigned long long);\n"
    text = text + "typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);\n\n"
    text = text + "static const char* kChengRuntimeManifest = \"" + runtimeManifestRel + "\";\n"
    text = text + "static const char* kChengLaunchArgsKv = " + probeQuote(launchArgsKv) + ";\n"
    text = text + "static const char* kChengLaunchArgsJson = " + probeQuote(launchArgsJson) + ";\n\n"
    text = text + "@interface ChengGeneratedMetalView : UIView\n"
    text = text + "@property(nonatomic) unsigned long long appId;\n"
    text = text + "@end\n\n"
    text = text + "@implementation ChengGeneratedMetalView {\n"
    text = text + "    cheng_app_set_window_fn _setWindow;\n"
    text = text + "    cheng_app_tick_fn _tick;\n"
    text = text + "}\n\n"
    text = text + "- (instancetype)initWithFrame:(CGRect)frame {\n"
    text = text + "    self = [super initWithFrame:frame];\n"
    text = text + "    if (self == nil) {\n"
    text = text + "        return nil;\n"
    text = text + "    }\n"
    text = text + "    void* handle = dlopen(NULL, RTLD_NOW);\n"
    text = text + "    cheng_app_init_fn initFn = (cheng_app_init_fn)dlsym(handle, \"cheng_app_init\");\n"
    text = text + "    _setWindow = (cheng_app_set_window_fn)dlsym(handle, \"cheng_app_set_window\");\n"
    text = text + "    _tick = (cheng_app_tick_fn)dlsym(handle, \"cheng_app_tick\");\n"
    text = text + "    cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(handle, \"cheng_mobile_host_runtime_set_launch_args\");\n"
    text = text + "    if (setLaunchArgs != NULL) {\n"
    text = text + "        setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);\n"
    text = text + "    }\n"
    text = text + "    if (initFn != NULL) {\n"
    text = text + "        self.appId = initFn();\n"
    text = text + "    }\n"
    text = text + "    return self;\n"
    text = text + "}\n"
    return text

fn probeHarmonyHostSourceOldShape(opts: var mshell.V3MobileShellOptions): str =
    let runtimeManifestRel: str = "rawfile/mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "rawfile/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "rawfile/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKv: str = probeLaunchArgsKv(opts.routeState,
                                              opts.runtimeMode,
                                              runtimeManifestRel,
                                              runtimeContractPayloadRel,
                                              runtimeBundlePayloadRel)
    let launchArgsJson: str = probeLaunchArgsJson(opts.routeState,
                                                  opts.runtimeMode,
                                                  runtimeManifestRel,
                                                  runtimeContractPayloadRel,
                                                  runtimeBundlePayloadRel)
    var text: str = "#include <ace/xcomponent/native_interface_xcomponent.h>\n"
    text = text + "#include <hilog/log.h>\n"
    text = text + "#include <native_window/external_window.h>\n"
    text = text + "#include <dlfcn.h>\n"
    text = text + "#include <stdint.h>\n\n"
    text = text + "typedef uint64_t (*cheng_app_init_fn)(void);\n"
    text = text + "typedef void (*cheng_app_set_window_fn)(uint64_t, uint64_t, int, int, float);\n"
    text = text + "typedef void (*cheng_app_tick_fn)(uint64_t, float);\n"
    text = text + "typedef void (*cheng_app_on_touch_fn)(uint64_t, int, int, float, float);\n"
    text = text + "typedef void (*cheng_app_pause_fn)(uint64_t);\n"
    text = text + "typedef void (*cheng_app_resume_fn)(uint64_t);\n"
    text = text + "typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);\n\n"
    text = text + "static const char* kChengRuntimeManifest = \"" + runtimeManifestRel + "\";\n"
    text = text + "static const char* kChengLaunchArgsKv = " + probeQuote(launchArgsKv) + ";\n"
    text = text + "static const char* kChengLaunchArgsJson = " + probeQuote(launchArgsJson) + ";\n\n"
    text = text + "static int cheng_harmony_init_runtime(void) {\n"
    text = text + "  void* handle = dlopen(NULL, RTLD_NOW);\n"
    text = text + "  cheng_app_init_fn initFn = (cheng_app_init_fn)dlsym(handle, \"cheng_app_init\");\n"
    text = text + "  cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(handle, \"cheng_mobile_host_runtime_set_launch_args\");\n"
    text = text + "  if (setLaunchArgs != NULL) {\n"
    text = text + "    setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);\n"
    text = text + "  }\n"
    text = text + "  return initFn != NULL;\n"
    text = text + "}\n"
    return text

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let stamp: str = int64ToStr(monotimes.MonoTimeNs(monotimes.GetMonoTime()))
    let outDir: str = "/tmp/v3_mobile_shell_launch_args_shape_probe_" + stamp
    assert(v3path.V3MkdirP(root, outDir), "mobile shell launch args shape probe: mkdir")
    var opts: mshell.V3MobileShellOptions = mshell.v3MobileShellDefaultOptions(root)
    opts.outDir = outDir
    opts.runtimeMode = "r2c_native_gui_v1"
    opts.routeState = "home_default"
    let androidText: str = probeAndroidHostSourceOldShape(opts)
    let iosText: str = probeIosHostSourceOldShape(opts)
    let harmonyText: str = probeHarmonyHostSourceOldShape(opts)
    let kv: str = probeLaunchArgsKv(opts.routeState,
                                    opts.runtimeMode,
                                    "mobile_shell_runtime_contract_v1.json",
                                    "runtime/mobile_shell_runtime_contract_payload.json",
                                    "runtime/mobile_shell_runtime_bundle_payload.json")
    let json: str = probeLaunchArgsJson(opts.routeState,
                                        opts.runtimeMode,
                                        "mobile_shell_runtime_contract_v1.json",
                                        "runtime/mobile_shell_runtime_contract_payload.json",
                                        "runtime/mobile_shell_runtime_bundle_payload.json")
    assert(strings.StrContains(androidText, "kChengLaunchArgsKv"),
           "mobile shell launch args shape probe: kv symbol")
    assert(strings.StrContains(androidText, "route_state=home_default"),
           "mobile shell launch args shape probe: route text")
    assert(strings.StrContains(androidText, "setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);"),
           "mobile shell launch args shape probe: launch args call")
    assert(strings.StrContains(iosText, "setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);"),
           "mobile shell launch args shape probe: ios launch args call")
    assert(strings.StrContains(harmonyText, "setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);"),
           "mobile shell launch args shape probe: harmony launch args call")
    var files: str[]
    var errorText: str
    let kvPath: str = os.JoinPath(outDir, "launch_args.kv.txt")
    let jsonPath: str = os.JoinPath(outDir, "launch_args.json")
    let hostPath: str = os.JoinPath(outDir, "android_host_old_shape.c")
    let iosPath: str = os.JoinPath(outDir, "ios_host_old_shape.m")
    let harmonyPath: str = os.JoinPath(outDir, "harmony_host_old_shape.cpp")
    assert(mshell.v3MobileShellWriteFile(kvPath,
                                         kv,
                                         "launch_args.kv.txt",
                                         files,
                                         errorText),
           "mobile shell launch args shape probe: write kv")
    assert(mshell.v3MobileShellWriteFile(jsonPath,
                                         json,
                                         "launch_args.json",
                                         files,
                                         errorText),
           "mobile shell launch args shape probe: write json")
    assert(mshell.v3MobileShellWriteFile(hostPath,
                                         androidText,
                                         "android_host_old_shape.c",
                                         files,
                                         errorText),
           "mobile shell launch args shape probe: write host")
    assert(mshell.v3MobileShellWriteFile(iosPath,
                                         iosText,
                                         "ios_host_old_shape.m",
                                         files,
                                         errorText),
           "mobile shell launch args shape probe: write ios")
    assert(mshell.v3MobileShellWriteFile(harmonyPath,
                                         harmonyText,
                                         "harmony_host_old_shape.cpp",
                                         files,
                                         errorText),
           "mobile shell launch args shape probe: write harmony")
    assert(len(errorText) == 0, "mobile shell launch args shape probe: empty error")
    assert(files.len == 5, "mobile shell launch args shape probe: file count")
    echo("v3 mobile_shell_launch_args_shape_probe ok")
    return 0
