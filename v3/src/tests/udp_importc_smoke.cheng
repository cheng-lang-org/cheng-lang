import std/system
import std/result
import std/net/transports/udp_syscall as udp
import std/rawbytes
import std/os

fn main(): int32 =
    let listenerFd = os.udpBindFdBridge("127.0.0.1", 0, 0)
    assert(listenerFd >= 0, "v3 udp importc: listener bind")
    var listenerLocalAddr: udp.UdpSockAddr
    let listenerLocalAddrRes: Result[bool] = udp.udpGetSockName(listenerFd, listenerLocalAddr)
    assert(IsOk(listenerLocalAddrRes), "v3 udp importc: listener getsockname")
    assert(len(listenerLocalAddr.host) > 0, "v3 udp importc: listener local host")
    assert(listenerLocalAddr.port > 0, "v3 udp importc: listener local port")

    let senderFd = os.udpBindFdBridge("127.0.0.1", 0, 0)
    assert(senderFd >= 0, "v3 udp importc: sender bind")
    var senderLocalAddr: udp.UdpSockAddr
    let senderLocalAddrRes: Result[bool] = udp.udpGetSockName(senderFd, senderLocalAddr)
    assert(IsOk(senderLocalAddrRes), "v3 udp importc: sender getsockname")

    let payload: Bytes = bytesFromString("ping")
    var targetAddr: udp.UdpSockAddr
    let targetAddrRes: Result[bool] = udp.udpSockAddrFromHostPort(
        listenerLocalAddr.host,
        listenerLocalAddr.port,
        listenerLocalAddr.isV6,
        listenerLocalAddr.family,
        true,
        targetAddr
    )
    assert(IsOk(targetAddrRes), "v3 udp importc: target addr")
    let sendRes: Result[int32] = udp.udpSendTo(senderFd, payload, targetAddr)
    assert(IsOk(sendRes), "v3 udp importc: send")
    assert(Value(sendRes) == bytesLen(payload), "v3 udp importc: send size")

    var recv: udp.UdpRecvResult
    let recvRes: Result[bool] = udp.udpRecvFromBlocking(listenerFd, 64, recv)
    if IsErr(recvRes):
        panic(ErrorText(recvRes))
    assert(IsOk(recvRes), "v3 udp importc: recv")
    assert(bytesEqual(recv.data, payload), "v3 udp importc: recv payload")
    assert(recv.fromAddr.port == senderLocalAddr.port, "v3 udp importc: recv peer port")
    assert(len(recv.fromAddr.host) > 0, "v3 udp importc: recv peer host")

    let senderCloseRc = os.udpCloseFd(senderFd)
    assert(senderCloseRc == 0, "v3 udp importc: sender close")
    let listenerCloseRc = os.udpCloseFd(listenerFd)
    assert(listenerCloseRc == 0, "v3 udp importc: listener close")
    echo("v3 udp_importc_smoke ok")
    return 0
