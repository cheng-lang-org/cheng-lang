import std/system
import std/result
import std/net/transports/udp_syscall as udp

fn main(): int32 =
    let socketRes: Result[udp.UdpSocketHandle] = udp.udpSocketOpenDgram(false)
    assert(IsOk(socketRes), "v3 udp importc: open")
    let socket = Value(socketRes)

    let bindAddrRes: Result[udp.UdpSockAddr] = udp.udpSockAddrFromHostPort("127.0.0.1", 0, false, 0, false)
    assert(IsOk(bindAddrRes), "v3 udp importc: bind addr")
    let bindRes: Result[bool] = udp.udpBindAddr(socket.fd, Value(bindAddrRes))
    assert(IsOk(bindRes), "v3 udp importc: bind")

    let localAddrRes: Result[udp.UdpSockAddr] = udp.udpGetSockName(socket.fd)
    assert(IsOk(localAddrRes), "v3 udp importc: getsockname")
    let localAddr = Value(localAddrRes)
    assert(len(localAddr.host) > 0, "v3 udp importc: local host")
    assert(localAddr.port >= 0, "v3 udp importc: local port")

    udp.udpSocketClose(socket.fd)
    echo("v3 udp_importc_smoke ok")
    return 0
