import std/system
import cheng/v3/tooling/bootstrap_contracts as contracts
import cheng/v3/backend/build_plan as buildplan

fn main(): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault("/tmp/cheng-lang")
    assert(snapshot.targetTriple == "arm64-apple-darwin", "v3 bootstrap: target")
    assert(snapshot.stage1Source.path == "/tmp/cheng-lang/v3/bootstrap/stage1_bootstrap.cheng",
           "v3 bootstrap: stage1 source path")
    assert(contracts.v3BootstrapCompilerEntrySourcePath("/tmp/cheng-lang") == "/tmp/cheng-lang/v3/src/tooling/compiler_main.cheng",
           "v3 bootstrap: compiler entry source path")
    assert(contracts.v3BootstrapGateMainSourcePath("/tmp/cheng-lang") == "/tmp/cheng-lang/v3/src/tooling/gate_main.cheng",
           "v3 bootstrap: gate main source path")
    assert(snapshot.stage0Compiler.path == "/tmp/cheng-lang/artifacts/v3_bootstrap/cheng.stage0",
           "v3 bootstrap: stage0 path")
    assert(snapshot.stage2Compiler.path == "/tmp/cheng-lang/artifacts/v3_bootstrap/cheng.stage2",
           "v3 bootstrap: stage2 path")
    let plan: buildplan.V3BackendBuildPlan = buildplan.v3BackendBuildPlanDefault("/tmp/cheng-lang")
    assert(plan.sourceUnits.len >= 6, "v3 build plan: source list")
    assert(plan.entryPath == "/tmp/cheng-lang/v3/src/tooling/compiler_main.cheng", "v3 build plan: entry")
    assert(plan.stage2CompilerPath == "/tmp/cheng-lang/artifacts/v3_bootstrap/cheng.stage2",
           "v3 build plan: stage2 compiler")
    assert(plan.outputPath == "/tmp/cheng-lang/artifacts/v3_backend_driver/cheng", "v3 build plan: output")
    echo("v3 bootstrap_contracts_smoke ok")
    return 0
