import std/system

fn probeWriteBool(outValue: var bool): bool =
    outValue = true
    return true

fn probeWriteI32(outValue: var int32): bool =
    outValue = 7
    return true

fn main(): int32 =
    var flag = false
    var value: int32 = 0
    assert(probeWriteBool(flag), "v3 var out writeback probe: bool call")
    assert(flag, "v3 var out writeback probe: bool writeback")
    assert(probeWriteI32(value), "v3 var out writeback probe: i32 call")
    assert(value == 7, "v3 var out writeback probe: i32 writeback")
    echo("v3 var_out_param_writeback_probe ok")
    return 0
