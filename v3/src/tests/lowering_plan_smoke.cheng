import std/os
import std/result
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_world as cworld
import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/backend/lowering_plan as lower
import cheng/v3/lang/parser

fn reportFieldValue(report: str, key: str): str =
    let prefix = key + "="
    var lineStart: int32 = 0
    while lineStart < report.len:
        var lineEnd = lineStart
        while lineEnd < report.len && report[lineEnd] != '\n':
            lineEnd = lineEnd + 1
        let lineLen = lineEnd - lineStart
        if lineLen >= prefix.len &&
           v3path.V3TextSlice(report, lineStart, prefix.len) == prefix:
            return v3path.V3TextSlice(report, lineStart + prefix.len, lineLen - prefix.len)
        lineStart = lineEnd + 1
    return ""

fn reportFieldPositive(report: str, key: str): bool =
    let value = reportFieldValue(report, key)
    return value != "" && value != "0"

fn assertTypedCallFactsMatchLayer(facts: ccsg.V3TypedExprFact[],
                                  layer: parser.V3NormalizedExprLayer,
                                  label: str) =
    assert(ccsg.v3TypedExprFactCountCallResolved(facts) ==
           parser.v3NormalizedExprLayerCallResolvedCount(layer),
           label + " typed resolved call count")
    assert(ccsg.v3TypedExprFactCountCallUnresolved(facts) ==
           parser.v3NormalizedExprLayerCallUnresolvedCount(layer),
           label + " typed unresolved call count")
    assert(ccsg.v3TypedExprSurfaceCallLocalCount(facts) ==
           parser.v3NormalizedExprLayerCallKindCount(layer, "local_call"),
           label + " typed local call kind count")
    assert(ccsg.v3TypedExprSurfaceCallExternalCount(facts) ==
           parser.v3NormalizedExprLayerCallKindCount(layer, "external_call"),
           label + " typed external call kind count")
    assert(ccsg.v3TypedExprSurfaceCallImportcCount(facts) ==
           parser.v3NormalizedExprLayerCallKindCount(layer, "importc_call"),
           label + " typed importc call kind count")
    assert(ccsg.v3TypedExprSurfaceCallMemberCount(facts) ==
           parser.v3NormalizedExprLayerCallKindCount(layer, "member_call"),
           label + " typed member call kind count")
    assert(ccsg.v3TypedExprFactCountCallTargetImportc(facts) ==
           parser.v3NormalizedExprLayerCallTargetImportcCount(layer),
           label + " typed importc target count")
    assert(ccsg.v3TypedExprCallReasonUnknownQualifiedTargetCount(facts) ==
           parser.v3NormalizedExprLayerCallReasonCount(layer, "unknown_qualified_target"),
           label + " typed unknown qualified target count")
    assert(ccsg.v3TypedExprCallReasonShadowedQualifiedTargetCount(facts) ==
           parser.v3NormalizedExprLayerCallReasonCount(layer, "shadowed_qualified_target"),
           label + " typed shadowed qualified target count")
    assert(ccsg.v3TypedExprCallReasonAmbiguousExternalTargetCount(facts) ==
           parser.v3NormalizedExprLayerCallReasonCount(layer, "ambiguous_external_target"),
           label + " typed ambiguous external target count")
    assert(ccsg.v3TypedExprCallReasonAmbiguousQualifiedTargetCount(facts) ==
           parser.v3NormalizedExprLayerCallReasonCount(layer, "ambiguous_qualified_target"),
           label + " typed ambiguous qualified target count")

fn buildPlan(workspaceRoot: str,
             packageRoot: str,
             sourcePath: str,
             outputPath: str,
             emitKind: int32): lower.V3LoweringPlanStub =
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), "v3 lowering plan: build link plan")
    assert(linkPlan.missingReasons.len == 0, "v3 lowering plan: link plan ready")
    var plan: lower.V3LoweringPlanStub
    assert(lower.v3BuildLoweringPlanStub(linkPlan, plan, err), "v3 lowering plan: build lowering plan")
    return plan

fn main(): int32 =
    let workspaceRoot: str = v3path.V3PathCurrentDir()
    let packageRoot: str = v3path.V3PathJoin(workspaceRoot, "v3")
    let smokeLabel: str = os.GetEnvDefault("CHENG_V3_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathJoin(workspaceRoot, "artifacts/v3_program_selfhost/" + smokeLabel)
    assert(v3path.V3MkdirP(workspaceRoot, outDir), "v3 lowering plan: mkdir")
    let sourcePath: str = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath: str = v3path.V3PathJoin(outDir, "program_selfhost_smoke")
    var err = ""
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), "v3 lowering plan: build link plan")
    assert(linkPlan.missingReasons.len == 0, "v3 lowering plan: link plan ready")
    let plan = buildPlan(workspaceRoot, packageRoot, sourcePath, outputPath, creq.v3EmitExe)
    assert(plan.functionNames.len >= 1, "v3 lowering plan: function count")
    assert(plan.functionNameIds[0] >= 0, "v3 lowering plan: intern id")
    assert(plan.functionCallConvs[0] == lower.v3LoweringCallConvInternal(), "v3 lowering plan: callconv")
    assert(plan.typedExprFacts.len == parser.v3NormalizedExprLayerExprCount(plan.exprLayer),
           "v3 lowering plan: typed expr fact count")
    assert(plan.loweringRules.len == plan.typedExprFacts.len,
           "v3 lowering plan: lowering rule count")
    assert(plan.typedExprFacts[0].exprId != "", "v3 lowering plan: typed expr id")
    var sawMain = false
    for i in 0..<plan.functionNames.len:
        assert(!(plan.functionOwnerModulePaths[i] == "std/system" && plan.functionNames[i] == "mulCompat"),
               "v3 lowering plan: skip importc decl")
        if plan.functionEntryFlags[i] != 0:
            sawMain = true
            assert(plan.functionNames[i] == "main", "v3 lowering plan: entry name")
            assert(plan.functionResultLayoutKinds[i] == lower.v3LoweringLayoutKindI32(), "v3 lowering plan: entry layout")
    assert(sawMain, "v3 lowering plan: saw entry")
    assert(plan.exprLayer.sourceCount > 0, "v3 lowering plan: expr surface count")
    assert(parser.v3NormalizedExprLayerExprCount(plan.exprLayer) > 0, "v3 lowering plan: expr node count")
    assert(parser.v3NormalizedExprLayerTryCount(plan.exprLayer) >= 0, "v3 lowering plan: try count")
    assert(plan.exprLayer.questionResidualCount == 0, "v3 lowering plan: question normalized")
    assert(ccsg.v3TypedExprLowerLocalAddressCount(plan.typedExprFacts) > 0,
           "v3 lowering plan: typed lowering mode")
    assert(plan.missingReasons.len == 0, "v3 lowering plan: no lowering blockers")
    assert(lower.v3LoweringPlanPipelineStage(plan) == "canonical_csg_to_lowering_plan",
           "v3 lowering plan: report stage")

    let typedFixturePath: str = v3path.V3PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let typedOutputPath: str = v3path.V3PathJoin(outDir, "typed_expr_fact_fixture")
    let typedReq = creq.v3CompilerRequestNew(
        packageRoot,
        typedFixturePath,
        typedOutputPath,
        "arm64-apple-darwin",
        creq.v3EmitShared,
        ""
    )
    var typedLinkPlan: slplan.V3SystemLinkPlanStub
    err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, typedReq, typedLinkPlan, err),
           "v3 lowering plan: typed build link plan")
    let typedPlan = buildPlan(workspaceRoot, packageRoot, typedFixturePath, typedOutputPath, creq.v3EmitShared)
    let typedSourceBundleCid = cworld.v3CompilerWorldSourceBundleCid(typedLinkPlan.packageId, typedLinkPlan.sourceClosurePaths)
    let typedCsgRes = ccsg.v3BuildCompilerCsg(typedLinkPlan, typedSourceBundleCid)
    assert(IsOk(typedCsgRes), "v3 lowering plan: typed fixture csg")
    let typedCsg = ccsg.v3CompilerCsgClone(Value(typedCsgRes))
    assert(ccsg.v3TypedExprFactsEqual(typedCsg.typedExprFacts, typedPlan.typedExprFacts),
           "v3 lowering plan: typed facts match compiler csg")
    let typedCsgRules = ccsg.v3TypedExprLoweringRulesFromFacts(typedCsg.typedExprFacts)
    var loweringErr = ""
    assert(ccsg.v3TypedExprFactsValidateCallResolution(typedCsg.exprLayer, typedCsg.typedExprFacts, loweringErr),
           "v3 lowering plan: typed csg call resolution validate")
    assert(ccsg.v3TypedExprFactsValidateCallResolution(typedPlan.exprLayer, typedPlan.typedExprFacts, loweringErr),
           "v3 lowering plan: typed plan call resolution validate")
    assert(ccsg.v3TypedExprLoweringRulesValidate(typedCsgRules, loweringErr),
           "v3 lowering plan: typed csg lowering rules validate")
    assert(ccsg.v3TypedExprLoweringRulesValidate(typedPlan.loweringRules, loweringErr),
           "v3 lowering plan: typed plan lowering rules validate")
    assert(ccsg.v3TypedExprLoweringRulesEqual(typedCsgRules, typedPlan.loweringRules),
           "v3 lowering plan: lowering rules match compiler csg")
    let typedPlanReport = lower.v3LoweringPlanStubReport(typedPlan)
    let typedFixtureFacts = ccsg.v3TypedExprFactsForSource(typedPlan.typedExprFacts, typedFixturePath)
    assert(typedFixtureFacts.len > 0, "v3 lowering plan: typed fixture fact slice")
    assertTypedCallFactsMatchLayer(typedPlan.typedExprFacts, typedPlan.exprLayer, "v3 lowering plan: typed fixture")
    assert(plan.loweringRules.len == plan.typedExprFacts.len,
           "v3 lowering plan: typed lowering rule count")
    assert(ccsg.v3TypedExprLoweringRuleUniqueShapeCount(typedCsgRules) > 0,
           "v3 lowering plan: typed lowering rule shape count")
    assert(ccsg.v3TypedExprLoweringRuleUniqueShapeCount(typedCsgRules) ==
           ccsg.v3TypedExprLoweringRuleUniqueKeyCount(typedCsgRules),
           "v3 lowering plan: typed lowering rule key count")
    assert(ccsg.v3TypedExprAbiPolymorphicCount(typedFixtureFacts) == 0,
           "v3 lowering plan: typed fixture no abi polymorphic")
    assert(ccsg.v3TypedExprLowerDeferredCount(typedFixtureFacts) == 0,
           "v3 lowering plan: typed fixture no deferred lowering")
    assert(ccsg.v3TypedExprPlaceLocalCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture local place count")
    assert(ccsg.v3TypedExprLowerSretCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture sret count")
    assert(ccsg.v3TypedExprCallBuiltinCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture builtin call kind")
    assert(ccsg.v3TypedExprCallResultIntrinsicCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture result intrinsic call kind")
    assert(ccsg.v3TypedExprCallProjectionCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture projection call kind")
    assert(parser.v3NormalizedExprLayerHasExpr(typedPlan.exprLayer, parser.v3NormalizedExprCall, "external_call", 28),
           "v3 lowering plan: typed fixture alias external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedPlan.exprLayer, parser.v3NormalizedExprCall, "external_call", 29),
           "v3 lowering plan: typed fixture module stem external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedPlan.exprLayer, parser.v3NormalizedExprCall, "external_call", 30),
           "v3 lowering plan: typed fixture nested qualified external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedPlan.exprLayer, parser.v3NormalizedExprCall, "external_call", 32),
           "v3 lowering plan: typed fixture alias importc external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedPlan.exprLayer, parser.v3NormalizedExprCall, "external_call", 33),
           "v3 lowering plan: typed fixture nested importc external call")
    var sawAliasImportBuffer = false
    var sawNestedImportBuffer = false
    for i in 0..<typedFixtureFacts.len:
        if typedFixtureFacts[i].lineNumber == 32 &&
           ccsg.v3TypedExprLoweringModeText(typedFixtureFacts[i].loweringMode) == "import_buffer" &&
           ccsg.v3TypedExprReturnKindText(typedFixtureFacts[i].returnKind) == "import_buffer":
            sawAliasImportBuffer = true
        if typedFixtureFacts[i].lineNumber == 33 &&
           ccsg.v3TypedExprLoweringModeText(typedFixtureFacts[i].loweringMode) == "import_buffer" &&
           ccsg.v3TypedExprReturnKindText(typedFixtureFacts[i].returnKind) == "import_buffer":
            sawNestedImportBuffer = true
    assert(sawAliasImportBuffer, "v3 lowering plan: typed fixture alias importc uses import buffer")
    assert(sawNestedImportBuffer, "v3 lowering plan: typed fixture nested importc uses import buffer")
    assert(ccsg.v3TypedExprLowerImportBufferCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture import buffer lowering")
    assert(ccsg.v3TypedExprReturnRegCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture reg return kind")
    assert(ccsg.v3TypedExprReturnCompositeLocalCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture composite local return kind")
    assert(ccsg.v3TypedExprReturnSretCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture sret return kind")
    assert(ccsg.v3TypedExprReturnImportBufferCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture import buffer return kind")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_count") ==
           intToStr(parser.v3NormalizedExprLayerCallCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report call count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_resolved_count") ==
           intToStr(parser.v3NormalizedExprLayerCallResolvedCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report resolved call count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_unresolved_count") ==
           intToStr(parser.v3NormalizedExprLayerCallUnresolvedCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report unresolved call count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_local_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCount(typedPlan.exprLayer, "local_call")),
           "v3 lowering plan: typed report local call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_external_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCount(typedPlan.exprLayer, "external_call")),
           "v3 lowering plan: typed report external call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_importc_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCount(typedPlan.exprLayer, "importc_call")),
           "v3 lowering plan: typed report importc call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_member_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCount(typedPlan.exprLayer, "member_call")),
           "v3 lowering plan: typed report member call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_target_importc_count") ==
           intToStr(parser.v3NormalizedExprLayerCallTargetImportcCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report importc target count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_reason_unknown_qualified_target_count") ==
           intToStr(parser.v3NormalizedExprLayerCallReasonCount(typedPlan.exprLayer, "unknown_qualified_target")),
           "v3 lowering plan: typed report unknown qualified target count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_reason_shadowed_qualified_target_count") ==
           intToStr(parser.v3NormalizedExprLayerCallReasonCount(typedPlan.exprLayer, "shadowed_qualified_target")),
           "v3 lowering plan: typed report shadowed qualified target count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_reason_ambiguous_external_target_count") ==
           intToStr(parser.v3NormalizedExprLayerCallReasonCount(typedPlan.exprLayer, "ambiguous_external_target")),
           "v3 lowering plan: typed report ambiguous external target count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_reason_ambiguous_qualified_target_count") ==
           intToStr(parser.v3NormalizedExprLayerCallReasonCount(typedPlan.exprLayer, "ambiguous_qualified_target")),
           "v3 lowering plan: typed report ambiguous qualified target count")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_arg_address_count"),
           "v3 lowering plan: typed address arg rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_result_sret_count"),
           "v3 lowering plan: typed sret result rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_materialize_dest_address_count"),
           "v3 lowering plan: typed dest address materialize rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_copy_region_copy_count"),
           "v3 lowering plan: typed region copy rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_import_builtin_address_slot_count"),
           "v3 lowering plan: typed builtin address import rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_import_import_buffer_count"),
           "v3 lowering plan: typed import buffer import rule")
    assert(reportFieldValue(typedPlanReport, "lowering_rule_unique_key_count") ==
           reportFieldValue(typedPlanReport, "lowering_rule_unique_shape_count"),
           "v3 lowering plan: typed report unique key count")
    assert(reportFieldValue(typedPlanReport, "lowering_rule_entry[0]") != "",
           "v3 lowering plan: typed report rule entry")
    assert(v3path.V3TextContains(reportFieldValue(typedPlanReport, "lowering_rule_entry[0]"), "key=type="),
           "v3 lowering plan: typed report rule key text")

    echo("v3 lowering_plan_smoke ok")
    return 0
