import std/os
import std/result
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_world as cworld
import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/backend/lowering_plan as lower
import cheng/v3/lang/parser
import cheng/v3/lang/typed_expr as texpr

fn reportFieldValue(report: str, key: str): str =
    let taggedReport = "\n" + report
    let needle = "\n" + key + "="
    let fieldPos = parser.v3ParserFindText(taggedReport, needle)
    if fieldPos < 0:
        return ""
    let valueStart = fieldPos + needle.len
    let tail = v3path.V3TextSlice(taggedReport, valueStart, taggedReport.len - valueStart)
    let newlinePos = parser.v3ParserFindText(tail, "\n")
    if newlinePos < 0:
        return tail
    if newlinePos == 0:
        return ""
    return v3path.V3TextSlice(tail, 0, newlinePos)

fn reportFieldPositive(report: str, key: str): bool =
    let value = reportFieldValue(report, key)
    return value != "" && value != "0"

fn assertCallReasonReportField(report: str,
                               layer: parser.V3NormalizedExprLayer,
                               reason: parser.V3NormalizedExprCallReason,
                               label: str) =
    let reportKey = ccsg.v3CompilerCsgCallReasonReportKey(reason)
    assert(reportKey != "", label + " report key")
    assert(reportFieldValue(report, reportKey) ==
           intToStr(parser.v3NormalizedExprLayerCallReasonCountExact(layer, reason)),
           label)

fn assertTypedCallFactsMatchLayer(facts: ccsg.V3TypedExprFact[],
                                  layer: parser.V3NormalizedExprLayer,
                                  label: str) =
    assert(texpr.v3TypedExprTypeCallDefaultInitCount(facts) ==
           parser.v3NormalizedExprLayerDefaultInitCount(layer),
           label + " typed default init count")
    assert(texpr.v3TypedExprTypeCallConstructorCount(facts) ==
           parser.v3NormalizedExprLayerConstructorCount(layer),
           label + " typed constructor count")
    assert(texpr.v3TypedExprFactCountCallResolved(facts) ==
           parser.v3NormalizedExprLayerCallResolvedCount(layer),
           label + " typed resolved call count")
    assert(texpr.v3TypedExprFactCountCallUnresolved(facts) ==
           parser.v3NormalizedExprLayerCallUnresolvedCount(layer),
           label + " typed unresolved call count")
    assert(texpr.v3TypedExprFactCountSurfaceCallKindFromParser(facts, parser.v3NormalizedExprSurfaceCallLocal) ==
           parser.v3NormalizedExprLayerCallKindCountExact(layer, parser.v3NormalizedExprSurfaceCallLocal),
           label + " typed local call kind count")
    assert(texpr.v3TypedExprFactCountSurfaceCallKindFromParser(facts, parser.v3NormalizedExprSurfaceCallExternal) ==
           parser.v3NormalizedExprLayerCallKindCountExact(layer, parser.v3NormalizedExprSurfaceCallExternal),
           label + " typed external call kind count")
    assert(texpr.v3TypedExprFactCountSurfaceCallKindFromParser(facts, parser.v3NormalizedExprSurfaceCallImportc) ==
           parser.v3NormalizedExprLayerCallKindCountExact(layer, parser.v3NormalizedExprSurfaceCallImportc),
           label + " typed importc call kind count")
    assert(texpr.v3TypedExprFactCountSurfaceCallKindFromParser(facts, parser.v3NormalizedExprSurfaceCallMember) ==
           parser.v3NormalizedExprLayerCallKindCountExact(layer, parser.v3NormalizedExprSurfaceCallMember),
           label + " typed member call kind count")
    assert(texpr.v3TypedExprFactCountCallTargetImportc(facts) ==
           parser.v3NormalizedExprLayerCallTargetImportcCount(layer),
           label + " typed importc target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonUnknownQualifiedTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonUnknownQualifiedTarget),
           label + " typed unknown qualified target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonShadowedQualifiedTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonShadowedQualifiedTarget),
           label + " typed shadowed qualified target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonAmbiguousExternalTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonAmbiguousExternalTarget),
           label + " typed ambiguous external target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonAmbiguousQualifiedTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonAmbiguousQualifiedTarget),
           label + " typed ambiguous qualified target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonUnknownExternalTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonUnknownExternalTarget),
           label + " typed unknown external target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonUnknownCallTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonUnknownCallTarget),
           label + " typed unknown call target count")

fn buildPlan(workspaceRoot: str,
             packageRoot: str,
             sourcePath: str,
             outputPath: str,
             emitKind: int32): lower.V3LoweringPlanStub =
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), "v3 lowering plan: build link plan")
    assert(linkPlan.missingReasons.len == 0, "v3 lowering plan: link plan ready")
    var plan: lower.V3LoweringPlanStub
    assert(lower.v3BuildLoweringPlanStub(linkPlan, plan, err), "v3 lowering plan: build lowering plan err=" + err)
    return plan

fn findTypedFact(facts: ccsg.V3TypedExprFact[],
                 sourcePath: str,
                 lineNumber: int32): ccsg.V3TypedExprFact =
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath:
            continue
        if facts[i].lineNumber != lineNumber:
            continue
        return texpr.v3TypedExprFactClone(facts[i])
    var missing: ccsg.V3TypedExprFact
    return missing

fn main(): int32 =
    let workspaceRoot: str = v3path.V3PathCurrentDir()
    let packageRoot: str = v3path.V3PathJoin(workspaceRoot, "v3")
    let smokeLabel: str = os.GetEnvDefault("CHENG_V3_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathJoin(workspaceRoot, "artifacts/v3_program_selfhost/" + smokeLabel)
    assert(v3path.V3MkdirP(workspaceRoot, outDir), "v3 lowering plan: mkdir")
    let sourcePath: str = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath: str = v3path.V3PathJoin(outDir, "program_selfhost_smoke")
    var err = ""
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), "v3 lowering plan: build link plan")
    assert(linkPlan.missingReasons.len == 0, "v3 lowering plan: link plan ready")
    let plan = buildPlan(workspaceRoot, packageRoot, sourcePath, outputPath, creq.v3EmitExe)
    assert(plan.functionNames.len >= 1, "v3 lowering plan: function count")
    assert(plan.functionNameIds[0] >= 0, "v3 lowering plan: intern id")
    assert(plan.functionCallConvs[0] == lower.v3LoweringCallConvInternal(), "v3 lowering plan: callconv")
    assert(plan.typedExprFacts.len == parser.v3NormalizedExprLayerExprCount(plan.exprLayer),
           "v3 lowering plan: typed expr fact count")
    assert(plan.loweringRules.len == plan.typedExprFacts.len,
           "v3 lowering plan: lowering rule count")
    assert(plan.typedExprFacts[0].exprId != "", "v3 lowering plan: typed expr id")
    var sawMain = false
    for i in 0..<plan.functionNames.len:
        assert(!(plan.functionOwnerModulePaths[i] == "std/system" && plan.functionNames[i] == "mulCompat"),
               "v3 lowering plan: skip importc decl")
        if plan.functionEntryFlags[i] != 0:
            sawMain = true
            assert(plan.functionNames[i] == "main", "v3 lowering plan: entry name")
            assert(plan.functionResultLayoutKinds[i] == lower.v3LoweringLayoutKindI32(), "v3 lowering plan: entry layout")
    assert(sawMain, "v3 lowering plan: saw entry")
    assert(plan.exprLayer.sourceCount > 0, "v3 lowering plan: expr surface count")
    assert(parser.v3NormalizedExprLayerExprCount(plan.exprLayer) > 0, "v3 lowering plan: expr node count")
    assert(parser.v3NormalizedExprLayerTryCount(plan.exprLayer) >= 0, "v3 lowering plan: try count")
    assert(plan.exprLayer.questionResidualCount == 0, "v3 lowering plan: question normalized")
    assert(texpr.v3TypedExprLowerLocalAddressCount(plan.typedExprFacts) > 0,
           "v3 lowering plan: typed lowering mode")
    assert(plan.missingReasons.len == 0, "v3 lowering plan: no lowering blockers")
    assert(lower.v3LoweringPlanPipelineStage(plan) == "canonical_csg_to_lowering_plan",
           "v3 lowering plan: report stage")

    let typedFixturePath: str = v3path.V3PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let typedOutputPath: str = v3path.V3PathJoin(outDir, "typed_expr_fact_fixture")
    let typedReq = creq.v3CompilerRequestNew(
        packageRoot,
        typedFixturePath,
        typedOutputPath,
        "arm64-apple-darwin",
        creq.v3EmitShared,
        ""
    )
    var typedLinkPlan: slplan.V3SystemLinkPlanStub
    err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, typedReq, typedLinkPlan, err),
           "v3 lowering plan: typed build link plan")
    let typedPlan = buildPlan(workspaceRoot, packageRoot, typedFixturePath, typedOutputPath, creq.v3EmitShared)
    let typedSourceBundleCid = cworld.v3CompilerWorldSourceBundleCid(typedLinkPlan.packageId, typedLinkPlan.sourceClosurePaths)
    let typedCsgRes = ccsg.v3BuildCompilerCsg(typedLinkPlan, typedSourceBundleCid)
    assert(IsOk(typedCsgRes), "v3 lowering plan: typed fixture csg")
    let typedCsg = ccsg.v3CompilerCsgClone(Value(typedCsgRes))
    assert(texpr.v3TypedExprFactsEqual(typedCsg.typedExprFacts, typedPlan.typedExprFacts),
           "v3 lowering plan: typed facts match compiler csg")
    let typedCsgRules = texpr.v3TypedExprLoweringRulesFromFacts(typedCsg.typedExprFacts)
    var loweringErr = ""
    assert(texpr.v3TypedExprFactsValidateCallResolution(typedCsg.exprLayer, typedCsg.typedExprFacts, loweringErr),
           "v3 lowering plan: typed csg call resolution validate")
    assert(texpr.v3TypedExprFactsValidateCallResolution(typedPlan.exprLayer, typedPlan.typedExprFacts, loweringErr),
           "v3 lowering plan: typed plan call resolution validate")
    assert(texpr.v3TypedExprLoweringRulesValidate(typedCsgRules, loweringErr),
           "v3 lowering plan: typed csg lowering rules validate")
    assert(texpr.v3TypedExprLoweringRulesValidate(typedPlan.loweringRules, loweringErr),
           "v3 lowering plan: typed plan lowering rules validate")
    assert(texpr.v3TypedExprLoweringRulesEqual(typedCsgRules, typedPlan.loweringRules),
           "v3 lowering plan: lowering rules match compiler csg")
    let typedPlanReport = lower.v3LoweringPlanStubReport(typedPlan)
    let typedFixtureFacts = texpr.v3TypedExprFactsForSource(typedPlan.typedExprFacts, typedFixturePath)
    assert(typedFixtureFacts.len > 0, "v3 lowering plan: typed fixture fact slice")
    assertTypedCallFactsMatchLayer(typedPlan.typedExprFacts, typedPlan.exprLayer, "v3 lowering plan: typed fixture")
    assert(plan.loweringRules.len == plan.typedExprFacts.len,
           "v3 lowering plan: typed lowering rule count")
    assert(texpr.v3TypedExprLoweringRuleUniqueShapeCount(typedCsgRules) > 0,
           "v3 lowering plan: typed lowering rule shape count")
    assert(texpr.v3TypedExprLoweringRuleUniqueShapeCount(typedCsgRules) ==
           texpr.v3TypedExprLoweringRuleUniqueKeyCount(typedCsgRules),
           "v3 lowering plan: typed lowering rule key count")
    assert(texpr.v3TypedExprAbiPolymorphicCount(typedFixtureFacts) == 0,
           "v3 lowering plan: typed fixture no abi polymorphic")
    assert(texpr.v3TypedExprLowerDeferredCount(typedFixtureFacts) == 0,
           "v3 lowering plan: typed fixture no deferred lowering")
    assert(texpr.v3TypedExprPlaceLocalCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture local place count")
    assert(texpr.v3TypedExprLowerSretCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture sret count")
    assert(texpr.v3TypedExprCallBuiltinCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture builtin call kind")
    assert(texpr.v3TypedExprCallResultIntrinsicCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture result intrinsic call kind")
    assert(texpr.v3TypedExprCallProjectionCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture projection call kind")
    assert(parser.v3NormalizedExprLayerHasConstructorExpr(typedPlan.exprLayer, 60),
           "v3 lowering plan: typed fixture constructor expr")
    let constructorFact = findTypedFact(typedFixtureFacts, typedFixturePath, 60)
    assert(constructorFact.kind == parser.v3NormalizedExprConstructor,
           "v3 lowering plan: typed fixture constructor fact kind")
    assert(constructorFact.typeCallKind == texpr.v3TypedExprTypeCallConstructor,
           "v3 lowering plan: typed fixture constructor type call kind")
    assert(constructorFact.typeText == "TypedDefaultWrap",
           "v3 lowering plan: typed fixture constructor fact type")
    assert(!constructorFact.callPrefixStyle,
           "v3 lowering plan: typed fixture constructor call prefix")
    assert(constructorFact.callArgCount == 1,
           "v3 lowering plan: typed fixture constructor arg count")
    assert(constructorFact.callArgsText == "count: payload.len",
           "v3 lowering plan: typed fixture constructor args text")
    var sawConstructorRule = false
    for i in 0..<typedPlan.loweringRules.len:
        if typedPlan.loweringRules[i].sourcePath == typedFixturePath &&
           typedPlan.loweringRules[i].lineNumber == 60 &&
           typedPlan.loweringRules[i].typeCallKind == texpr.v3TypedExprTypeCallConstructor:
            assert(typedPlan.loweringRules[i].callArgCount == 1,
                   "v3 lowering plan: typed fixture constructor rule arg count")
            assert(typedPlan.loweringRules[i].callArgsText == "count: payload.len",
                   "v3 lowering plan: typed fixture constructor rule args text")
            sawConstructorRule = true
    assert(sawConstructorRule, "v3 lowering plan: typed fixture constructor lowering rule")
    assert(parser.v3NormalizedExprLayerHasCallExpr(typedPlan.exprLayer, parser.v3NormalizedExprSurfaceCallExternal, 28),
           "v3 lowering plan: typed fixture alias external call")
    assert(parser.v3NormalizedExprLayerHasCallExpr(typedPlan.exprLayer, parser.v3NormalizedExprSurfaceCallExternal, 29),
           "v3 lowering plan: typed fixture module stem external call")
    assert(parser.v3NormalizedExprLayerHasCallExpr(typedPlan.exprLayer, parser.v3NormalizedExprSurfaceCallExternal, 30),
           "v3 lowering plan: typed fixture nested qualified external call")
    assert(parser.v3NormalizedExprLayerHasCallExpr(typedPlan.exprLayer, parser.v3NormalizedExprSurfaceCallExternal, 32),
           "v3 lowering plan: typed fixture alias importc external call")
    assert(parser.v3NormalizedExprLayerHasCallExpr(typedPlan.exprLayer, parser.v3NormalizedExprSurfaceCallExternal, 33),
           "v3 lowering plan: typed fixture nested importc external call")
    var sawAliasImportBuffer = false
    var sawNestedImportBuffer = false
    var sawDefaultInitFact = false
    for i in 0..<typedFixtureFacts.len:
        if typedFixtureFacts[i].lineNumber == 32 &&
           texpr.v3TypedExprFactUsesImportBuffer(typedFixtureFacts[i]):
            sawAliasImportBuffer = true
        if typedFixtureFacts[i].lineNumber == 33 &&
           texpr.v3TypedExprFactUsesImportBuffer(typedFixtureFacts[i]):
            sawNestedImportBuffer = true
        if typedFixtureFacts[i].lineNumber == 56 &&
           typedFixtureFacts[i].kind == parser.v3NormalizedExprDefaultInit:
            assert(typedFixtureFacts[i].typeCallKind == texpr.v3TypedExprTypeCallDefaultInit,
                   "v3 lowering plan: typed fixture default init type call kind")
            assert(typedFixtureFacts[i].abiClass == texpr.v3TypedExprAbiComposite,
                   "v3 lowering plan: typed fixture default init abi")
            assert(typedFixtureFacts[i].placeKind != texpr.v3TypedExprPlaceCallResult,
                   "v3 lowering plan: typed fixture default init place")
            assert(typedFixtureFacts[i].loweringMode == texpr.v3TypedExprLowerLocalAddress,
                   "v3 lowering plan: typed fixture default init lowering")
            assert(typedFixtureFacts[i].returnKind == texpr.v3TypedExprReturnCompositeLocal,
                   "v3 lowering plan: typed fixture default init return")
            sawDefaultInitFact = true
    assert(sawAliasImportBuffer, "v3 lowering plan: typed fixture alias importc uses import buffer")
    assert(sawNestedImportBuffer, "v3 lowering plan: typed fixture nested importc uses import buffer")
    assert(sawDefaultInitFact, "v3 lowering plan: typed fixture saw default init fact")
    assert(texpr.v3TypedExprLowerImportBufferCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture import buffer lowering")
    assert(texpr.v3TypedExprReturnRegCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture reg return kind")
    assert(texpr.v3TypedExprReturnCompositeLocalCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture composite local return kind")
    assert(texpr.v3TypedExprReturnSretCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture sret return kind")
    assert(texpr.v3TypedExprReturnImportBufferCount(typedFixtureFacts) > 0,
           "v3 lowering plan: typed fixture import buffer return kind")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_count") ==
           intToStr(parser.v3NormalizedExprLayerCallCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report call count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_default_init_count") ==
           intToStr(parser.v3NormalizedExprLayerDefaultInitCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report default init count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_resolved_count") ==
           intToStr(parser.v3NormalizedExprLayerCallResolvedCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report resolved call count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_unresolved_count") ==
           intToStr(parser.v3NormalizedExprLayerCallUnresolvedCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report unresolved call count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_local_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCountExact(typedPlan.exprLayer, parser.v3NormalizedExprSurfaceCallLocal)),
           "v3 lowering plan: typed report local call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_external_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCountExact(typedPlan.exprLayer, parser.v3NormalizedExprSurfaceCallExternal)),
           "v3 lowering plan: typed report external call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_importc_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCountExact(typedPlan.exprLayer, parser.v3NormalizedExprSurfaceCallImportc)),
           "v3 lowering plan: typed report importc call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_member_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCountExact(typedPlan.exprLayer, parser.v3NormalizedExprSurfaceCallMember)),
           "v3 lowering plan: typed report member call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_target_importc_count") ==
           intToStr(parser.v3NormalizedExprLayerCallTargetImportcCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report importc target count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_constructor_count") ==
           intToStr(parser.v3NormalizedExprLayerConstructorCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report constructor count")
    assert(reportFieldValue(typedPlanReport, "typed_expr_type_call_default_init_count") ==
           intToStr(parser.v3NormalizedExprLayerDefaultInitCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report typed default init count")
    assert(reportFieldValue(typedPlanReport, "typed_expr_type_call_constructor_count") ==
           intToStr(parser.v3NormalizedExprLayerConstructorCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report typed constructor count")
    assert(reportFieldValue(typedPlanReport, "lowering_rule_type_call_default_init_count") ==
           intToStr(parser.v3NormalizedExprLayerDefaultInitCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report lowering default init count")
    assert(reportFieldValue(typedPlanReport, "lowering_rule_type_call_constructor_count") ==
           intToStr(parser.v3NormalizedExprLayerConstructorCount(typedPlan.exprLayer)),
           "v3 lowering plan: typed report lowering constructor count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.v3NormalizedExprCallReasonUnknownQualifiedTarget,
                                "v3 lowering plan: typed report unknown qualified target count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.v3NormalizedExprCallReasonShadowedQualifiedTarget,
                                "v3 lowering plan: typed report shadowed qualified target count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.v3NormalizedExprCallReasonAmbiguousExternalTarget,
                                "v3 lowering plan: typed report ambiguous external target count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.v3NormalizedExprCallReasonAmbiguousQualifiedTarget,
                                "v3 lowering plan: typed report ambiguous qualified target count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.v3NormalizedExprCallReasonUnknownExternalTarget,
                                "v3 lowering plan: typed report unknown external target count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.v3NormalizedExprCallReasonUnknownCallTarget,
                                "v3 lowering plan: typed report unknown call target count")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_arg_address_count"),
           "v3 lowering plan: typed address arg rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_result_sret_count"),
           "v3 lowering plan: typed sret result rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_materialize_dest_address_count"),
           "v3 lowering plan: typed dest address materialize rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_copy_region_copy_count"),
           "v3 lowering plan: typed region copy rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_import_builtin_address_slot_count"),
           "v3 lowering plan: typed builtin address import rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_import_import_buffer_count"),
           "v3 lowering plan: typed import buffer import rule")
    assert(reportFieldValue(typedPlanReport, "lowering_rule_unique_key_count") ==
           reportFieldValue(typedPlanReport, "lowering_rule_unique_shape_count"),
           "v3 lowering plan: typed report unique key count")
    assert(reportFieldValue(typedPlanReport, "lowering_rule_entry[0]") != "",
           "v3 lowering plan: typed report rule entry")
    assert(v3path.V3TextContains(reportFieldValue(typedPlanReport, "lowering_rule_entry[0]"), "key=type="),
           "v3 lowering plan: typed report rule key text")

    echo("v3 lowering_plan_smoke ok")
    return 0
