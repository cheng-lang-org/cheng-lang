import std/result
import cheng/v3/tooling/vpn_proxy_config as config
import cheng/v3/tooling/vpn_proxy_gui as gui

fn main(): int32 =
    var state = gui.V3VpnProxyGuiStateForTest("/tmp/cheng-vpn-gui-test",
                                              "/tmp/cheng-vpn-gui-test/runtime",
                                              "/tmp/cheng-vpn-gui-test/local.json")
    let buildRes: Result[str] = gui.V3VpnProxyGuiBuildConfigText(state)
    assert(IsOk(buildRes), "v3 vpn gui smoke: build config")
    let text: str = Value(buildRes)
    assert(len(text) > 0, "v3 vpn gui smoke: config text non-empty")
    let parseRes: Result[config.V3VpnProxyConfig] = config.V3VpnProxyParseConfigTextForTest(text)
    assert(IsOk(parseRes), "v3 vpn gui smoke: parse config")
    let cfg: config.V3VpnProxyConfig = Value(parseRes)
    assert(cfg.client.listen == "127.0.0.1:1086", "v3 vpn gui smoke: default listen")
    assert(cfg.exits.len == 1, "v3 vpn gui smoke: single exit")
    assert(cfg.exits[0].host == "64.176.84.12", "v3 vpn gui smoke: exit host")
    echo("v3 vpn_proxy_gui_smoke ok")
    return 0
