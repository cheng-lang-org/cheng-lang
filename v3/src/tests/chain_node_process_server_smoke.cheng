import std/system
import std/cmdline as cmdline
import cheng/v3/project/chain_node as node
import cheng/v3/project/chain_node_libp2p as net
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/transports/tcp_transport

fn main(): int32 =
    let port = cmdline.readInt32FlagOrDefault("--port", 0)
    var ready_path: str = ""
    let has_ready = cmdline.readFirstFlagValue("--ready-path", ready_path)
    let ready_path_value = if has_ready: ready_path else: ""

    var server = node.v3ChainNodeInit("process.server", "process.loopback")
    let mintRes = node.v3ChainNodeMint(server, 11, 1001, int64(88))
    assert(mintRes.ok, "v3 chain_node process server: mint")
    let transferRes = node.v3ChainNodeTransfer(server, 11, 1001, 2002, int64(33))
    assert(transferRes.ok, "v3 chain_node process server: transfer")

    let snapshot = node.v3ChainNodeServeOnce(server)
    let payload = net.v3ChainNodeLibp2pEncodeSnapshot(snapshot)
    let serveRes = tcp_transport.v3Libp2pTcpServePayloadOnce("127.0.0.1",
                                                             port,
                                                             types.v3Libp2pProtocolSync,
                                                             payload,
                                                             ready_path_value)
    assert(serveRes.ok, "v3 chain_node process server: serve once")
    echo("v3 chain_node_process_server_smoke ok")
    return 0
