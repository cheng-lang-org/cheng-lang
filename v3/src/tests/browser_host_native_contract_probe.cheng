import cheng/v3/tests/browser_wasm_probe_moq_build_min as moqbuildprobe
import cheng/v3/tests/browser_wasm_probe_moq_build_core_min as moqbuildcore
import cheng/v3/tests/browser_wasm_probe_moq_object_min as moqobjectprobe
import cheng/v3/tests/browser_wasm_probe_seq_arg_min as seqprobe
import std/strings

fn failProbe(label: str, got: int32, want: int32): int32 =
    echo("probe_fail " + label + " got=" + strings.IntToStr(got) + " want=" + strings.IntToStr(want))
    return 1

fn failProbePos(label: str, got: int32): int32 =
    echo("probe_fail_pos " + label + " got=" + strings.IntToStr(got))
    return 1

fn expectEq(label: str, got: int32, want: int32): int32 =
    echo("probe_begin " + label)
    if got != want:
        return failProbe(label, got, want)
    echo("probe_ok " + label)
    return 0

fn expectPos(label: str, got: int32): int32 =
    echo("probe_begin " + label)
    if got <= 0:
        return failProbePos(label, got)
    echo("probe_ok " + label)
    return 0

fn main(): int32 =
    var rc: int32 = 0
    rc = expectEq("moqLocalSeqBoxCount", moqbuildprobe.moqLocalSeqBoxCount(), 2)
    if rc != 0:
        return rc
    rc = expectEq("moqResultSeqBoxCount", moqbuildprobe.moqResultSeqBoxCount(), 2)
    if rc != 0:
        return rc
    rc = expectEq("moqBuildRemoteAckCount", moqbuildprobe.moqBuildRemoteAckCount(), 2)
    if rc != 0:
        return rc
    rc = expectEq("moqBuildRemoteAckFirstLen", moqbuildprobe.moqBuildRemoteAckFirstLen(), 6)
    if rc != 0:
        return rc
    rc = expectEq("moqBuildLongPeerRemoteAckCount", moqbuildprobe.moqBuildLongPeerRemoteAckCount(), 2)
    if rc != 0:
        return rc
    rc = expectEq("moqBuildLongPeerRemoteAckFirstLen", moqbuildprobe.moqBuildLongPeerRemoteAckFirstLen(), 52)
    if rc != 0:
        return rc
    rc = expectPos("moqBuildLongPeerWireLen", moqbuildprobe.moqBuildLongPeerWireLen())
    if rc != 0:
        return rc
    rc = expectEq("moqBuildObjectCount", moqbuildcore.moqBuildObjectCount(), 1)
    if rc != 0:
        return rc
    rc = expectEq("moqObjectSourceBlockCount", moqobjectprobe.moqObjectSourceBlockCount(), 1)
    if rc != 0:
        return rc
    echo("probe_begin moqObjectErrorText")
    if moqobjectprobe.moqObjectErrorText() != "ok":
        echo("probe_fail moqObjectErrorText")
        return 1
    echo("probe_ok moqObjectErrorText")
    rc = expectEq("moqBuildLongBlobObjectCount", moqbuildprobe.moqBuildLongBlobObjectCount(), 1)
    if rc != 0:
        return rc
    rc = expectPos("moqBuildLongBlobDropletCount", moqbuildprobe.moqBuildLongBlobDropletCount())
    if rc != 0:
        return rc
    rc = expectEq("moqBuildLongBlobComputedBundleCidLen", moqbuildprobe.moqBuildLongBlobComputedBundleCidLen(), 64)
    if rc != 0:
        return rc
    rc = expectEq("callSeqCount", seqprobe.callSeqCount(), 2)
    if rc != 0:
        return rc
    rc = expectEq("callDirectSeqCount", seqprobe.callDirectSeqCount(), 2)
    if rc != 0:
        return rc
    rc = expectEq("callSplitCount", seqprobe.callSplitCount(), 2)
    if rc != 0:
        return rc
    rc = expectEq("callFirstPartLen", seqprobe.callFirstPartLen(), 6)
    if rc != 0:
        return rc
    rc = expectEq("callFirstTrimmedLen", seqprobe.callFirstTrimmedLen(), 6)
    if rc != 0:
        return rc
    rc = expectEq("callDirectSliceLen", seqprobe.callDirectSliceLen(), 6)
    if rc != 0:
        return rc
    rc = expectEq("callDirectSliceEq", seqprobe.callDirectSliceEq(), 1)
    if rc != 0:
        return rc
    rc = expectEq("callLiteralLen", seqprobe.callLiteralLen(), 6)
    if rc != 0:
        return rc
    rc = expectEq("callLiteralEq", seqprobe.callLiteralEq(), 1)
    if rc != 0:
        return rc
    rc = expectEq("callSeqLiteralFirstLen", seqprobe.callSeqLiteralFirstLen(), 6)
    if rc != 0:
        return rc
    rc = expectEq("callSeqSliceFirstLen", seqprobe.callSeqSliceFirstLen(), 6)
    if rc != 0:
        return rc
    rc = expectEq("callRangeLoopSum", seqprobe.callRangeLoopSum(), 21)
    if rc != 0:
        return rc
    rc = expectPos("callJoinConcatLen", seqprobe.callJoinConcatLen())
    if rc != 0:
        return rc
    echo("probe_ok done")
    return 0
