import std/system
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus

fn main(): int32 =
    var index = consensus.v3ChainIndexZero()
    let zeroCid = layout.fixedBytes32Zero()
    let mint = consensus.v3ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let mintCid = consensus.v3ChainEventCid(mint)
    let applyRes = consensus.v3ConsensusApply(index, mint, mintCid, 0)
    assert(IsOk(applyRes), "v3 consensus single: mint apply")
    let decision = Value(applyRes)
    assert(decision.accepted, "v3 consensus single: accepted")
    assert(decision.applied, "v3 consensus single: applied")
    assert(index.accountIds.buffer != nil, "v3 consensus single: account buffer")
    assert(index.accountIds.len == 1, "v3 consensus single: account len")
    assert(index.accountIds.cap >= 1, "v3 consensus single: account cap")
    assert(index.accountAssetIds[0] == 7, "v3 consensus single: asset")
    assert(index.accountIds[0] == 1001, "v3 consensus single: account")
    assert(index.balances.len == 1, "v3 consensus single: balance len")
    assert(index.balances[0] == int64(100), "v3 consensus single: balance")
    echo("v3 consensus_single_apply_smoke ok")
    return 0
