import cheng/v3/backend/build_plan as buildplan
import std/strings

fn main(): int32 =
    let plan: buildplan.V3BackendBuildPlan = buildplan.v3BackendBuildPlanBackendDriverForTarget("/tmp/cheng-lang", "arm64-apple-darwin")
    let report: str = buildplan.v3BackendBuildPlanReport(plan)
    assert(strings.StrContains(report, "target=arm64-apple-darwin"),
           "build_plan_report_smoke: target")
    assert(strings.StrContains(report, "backend_driver_entry_source:/tmp/cheng-lang/v3/src/tooling/backend_driver_main.cheng"),
           "build_plan_report_smoke: backend driver entry")
    assert(strings.StrContains(report, "source[20]=tooling_source:/tmp/cheng-lang/v3/src/backend/build_plan.cheng"),
           "build_plan_report_smoke: build plan source")
    echo("build_plan_report_smoke ok")
    return 0
