import std/system

type
    Int32Box =
        limbs: int32[8]

fn main(argc: int32, argv: ptr): int32 =
    argc
    argv
    var box: Int32Box
    box.limbs[0] = 11
    box.limbs[1] = 22
    box.limbs[2] = 33
    box.limbs[7] = 88
    assert(box.limbs[0] == 11, "fixed_array_int32_probe: limb0")
    assert(box.limbs[1] == 22, "fixed_array_int32_probe: limb1")
    assert(box.limbs[2] == 33, "fixed_array_int32_probe: limb2")
    assert(box.limbs[7] == 88, "fixed_array_int32_probe: limb7")
    echo("v3 fixed_array_int32_probe ok")
    return 0
