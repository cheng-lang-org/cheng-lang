import std/os
import std/strutils as strutil
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let outDir = v3path.V3PathJoin(workspaceRoot, "artifacts/cheng_skill_consistency")
    assert(v3path.V3MkdirP(workspaceRoot, outDir), "v3 cheng skill consistency: mkdir")

    let specPath = v3path.V3PathJoin(workspaceRoot, "docs/cheng-formal-spec.md")
    let repoSkillPath = v3path.V3PathJoin(workspaceRoot, "docs/cheng-skill/SKILL.md")
    let repoGrammarPath = v3path.V3PathJoin(workspaceRoot, "docs/cheng-skill/references/grammar.md")
    let readmePath = v3path.V3PathJoin(workspaceRoot, "README.md")
    let toolingReadmePath = v3path.V3PathJoin(workspaceRoot, "v3/tooling/README.md")
    let fmtSmokePath = v3path.V3PathJoin(workspaceRoot, "v3/src/tests/strformat_fmt_smoke.cheng")
    let explicitDefaultPositiveSmokePath = v3path.V3PathJoin(workspaceRoot, "v3/src/tests/explicit_default_init_positive_smoke.cheng")
    let explicitDefaultNegativeSmokePath = v3path.V3PathJoin(workspaceRoot, "v3/src/tests/explicit_default_init_negative_smoke.cheng")
    let explicitDefaultGateSmokePath = v3path.V3PathJoin(workspaceRoot, "v3/src/tests/explicit_default_init_gate_smoke.cheng")
    let zeroHelperGateSmokePath = v3path.V3PathJoin(workspaceRoot, "v3/src/tests/composite_zero_helper_gate_smoke.cheng")
    let latestSnapshotSmokePath = v3path.V3PathJoin(workspaceRoot, "v3/src/tests/latest_snapshot_port_preserves_live_str_smoke.cheng")
    let listLiteralDepthSmokePath = v3path.V3PathJoin(workspaceRoot, "v3/src/tests/list_literal_nested_call_depth_smoke.cheng")
    let preQuicSnapshotSmokePath = v3path.V3PathJoin(workspaceRoot, "v3/src/tests/libp2p_quic_twoproc_server_pre_quic_smoke.cheng")

    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, specPath), "v3 cheng skill consistency: spec exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, repoSkillPath), "v3 cheng skill consistency: repo skill exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, repoGrammarPath), "v3 cheng skill consistency: repo grammar exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, readmePath), "v3 cheng skill consistency: readme exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, toolingReadmePath), "v3 cheng skill consistency: tooling readme exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, fmtSmokePath), "v3 cheng skill consistency: fmt smoke exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, explicitDefaultPositiveSmokePath), "v3 cheng skill consistency: explicit default positive smoke exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, explicitDefaultNegativeSmokePath), "v3 cheng skill consistency: explicit default negative smoke exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, explicitDefaultGateSmokePath), "v3 cheng skill consistency: explicit default gate smoke exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, zeroHelperGateSmokePath), "v3 cheng skill consistency: zero helper gate smoke exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, latestSnapshotSmokePath), "v3 cheng skill consistency: latest snapshot spill smoke exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, listLiteralDepthSmokePath), "v3 cheng skill consistency: list literal depth smoke exists")
    assert(v3path.V3FileExistsNonEmpty(workspaceRoot, preQuicSnapshotSmokePath), "v3 cheng skill consistency: pre quic snapshot smoke exists")

    let specText = v3path.V3ReadTextFile("", specPath)
    let repoSkillText = v3path.V3ReadTextFile("", repoSkillPath)
    let repoGrammarText = v3path.V3ReadTextFile("", repoGrammarPath)
    let readmeText = v3path.V3ReadTextFile("", readmePath)
    let toolingReadmeText = v3path.V3ReadTextFile("", toolingReadmePath)
    let fmtSmokeText = v3path.V3ReadTextFile("", fmtSmokePath)
    let explicitDefaultPositiveSmokeText = v3path.V3ReadTextFile("", explicitDefaultPositiveSmokePath)
    let explicitDefaultNegativeSmokeText = v3path.V3ReadTextFile("", explicitDefaultNegativeSmokePath)
    let explicitDefaultGateSmokeText = v3path.V3ReadTextFile("", explicitDefaultGateSmokePath)
    let zeroHelperGateSmokeText = v3path.V3ReadTextFile("", zeroHelperGateSmokePath)

    let fmtSurfaceText = "`Fmt / Lines` 是当前稳定公开表面：`Fmt\"label={expr}\"` 用于插值字符串，`Fmt(parts)` 用于无分隔拼接，`Lines(parts)` 用于按换行拼接。它们可以直接使用，也可以通过 `import std/strformat as sf` 调用 `sf.Fmt(...)` / `sf.Lines(...)`；`Fmt expr` / `Lines expr` 不再支持，小写 `fmt/lines` 不导出。"
    let fmtSurfaceSpecText = "`Fmt / Lines` 为当前稳定公开表面：`Fmt\"label={expr}\"` 用于插值字符串，`Fmt(parts)` 用于无分隔拼接，`Lines(parts)` 用于按换行拼接。它们可以直接使用，也可以通过 `import std/strformat as sf` 调用 `sf.Fmt(...)` / `sf.Lines(...)`；`Fmt expr` / `Lines expr` 不再支持，小写 `fmt/lines` 不导出。"
    let exportSurfaceSpecText = "Cheng 采用 Go 风格的“首字母大写导出”规则：标识符首字符为 ASCII 大写字母的符号视为导出。"
    let exportSurfaceSkillText = "- 导出采用 Go 风格：标识符首字符为 ASCII 大写字母即导出；小写字母或 `_` 开头保持模块私有。"
    let compositeOrderSpecText = "类型零值 -> 声明顺序应用字段/元素默认值 -> 显式构造实参覆盖。"
    let compositeHelperSpecText = "- 如果只是复合类型零值/默认值构造，不再维护 `FooZero()` 这类无参镜像 helper；直接使用 `var x: Foo`、`Foo()` 或 `new(Foo)`。"
    let tupleDefaultSpecText = "`tuple` 本轮仅支持 typed implicit init 与 `T()` 物化；"
    let compositeDefaultSkillText = "- `object/ref object/tuple` 字段或元素支持 `name: Type = expr` 默认值语法；初始化优先级固定为“显式实参 > 字段默认值 > 类型零值”。"
    let compositeDefaultGrammarText = "- 初始化优先级固定为：显式实参 > 字段默认值 > 类型零值。"
    let compositeSteadyGrammarText = "- 字段默认值只允许稳态表达式：字面量（含 `T[]/T[N]` 上下文下的 `[]` 与 `[a, b, ...]`）、复合类型 `T()`、`new(Type)`、纯类型构造与 `if/?:` 组合；禁止引用同对象其他字段与副作用调用。"
    let tupleGrammarText = "- tuple 这轮只支持 typed implicit init 与 `T()`；tuple 字面量/tuple 类型构造必须显式写全所有元素。"
    let implicitDefaultSkillText = "- 隐式默认值速记：`bool=false`，整数/枚举=0，浮点=0.0，`char='\\0'`，`str/cstring=\"\"`，指针/`ref`/`var`/`void*`=`nil`，复合类型先 zero-init，再应用字段默认值。"
    let implicitDefaultGrammarText = "- `bool=false`"
    let v3EntryText = "- `v3` 正式入口优先用 `artifacts/v3_bootstrap/cheng.stage3` 和 `artifacts/v3_backend_driver/cheng`；`v3/tooling/cheng_v3.sh` 只视为兼容壳，不再作为主入口。"
    let v3ProdRegressionText = "artifacts/v3_bootstrap/cheng.stage3 run-production-regression"
    let v3ProdRegressionSmokeText = "build_backend_driver_report_smoke perf_memory_gate_contract_smoke perf_memory_contract_smoke cheng_skill_consistency_smoke dev_hotpatch_100ms_scope_contract_smoke explicit_default_init_positive_smoke explicit_default_init_negative_smoke explicit_default_init_gate_smoke composite_zero_helper_gate_smoke latest_snapshot_port_preserves_live_str_smoke list_literal_nested_call_depth_smoke libp2p_quic_twoproc_server_pre_quic_smoke"
    let v3PerfText = "- 内建画像/门禁优先用 `artifacts/v3_bootstrap/cheng.stage3 profile-run/profile-report` 与 `artifacts/v3_backend_driver/cheng run-host-smokes perf_memory_contract_smoke`；不要再把外层脚本当默认路径。"
    let v3PerfDefaultCompilerText = "- `perf_memory_contract_smoke` 默认优先测 `artifacts/v3_backend_driver/cheng`；只有显式 `CHENG_V3_SMOKE_COMPILER` 才覆盖。"
    let v3PerfDarwinMemoryText = "- Darwin 正式内存比较值优先用 `peak memory footprint`；`maximum resident set size` 只保留原始观测，不作为稳定合同阈值。"
    let v3SkillCheckText = "artifacts/v3_backend_driver/cheng run-host-smokes cheng_skill_consistency_smoke"

    assert(v3path.V3TextContains(specText, fmtSurfaceSpecText),
           "v3 cheng skill consistency: formal spec fmt/lines public surface")
    assert(v3path.V3TextContains(specText, exportSurfaceSpecText),
           "v3 cheng skill consistency: formal spec export surface")
    assert(v3path.V3TextContains(specText, compositeOrderSpecText),
           "v3 cheng skill consistency: formal spec composite default order")
    assert(v3path.V3TextContains(specText, compositeHelperSpecText),
           "v3 cheng skill consistency: formal spec composite helper surface")
    assert(v3path.V3TextContains(specText, tupleDefaultSpecText),
           "v3 cheng skill consistency: formal spec tuple default surface")
    assert(v3path.V3TextContains(specText, v3SkillCheckText),
           "v3 cheng skill consistency: formal spec skill consistency command")
    assert(v3path.V3TextContains(specText, v3ProdRegressionText),
           "v3 cheng skill consistency: formal spec production regression command")
    assert(v3path.V3TextContains(specText, v3ProdRegressionSmokeText),
           "v3 cheng skill consistency: formal spec production regression smokes")
    assert(v3path.V3TextContains(specText, v3PerfDefaultCompilerText),
           "v3 cheng skill consistency: formal spec perf default compiler")
    assert(v3path.V3TextContains(specText, v3PerfDarwinMemoryText),
           "v3 cheng skill consistency: formal spec darwin perf memory")

    assert(v3path.V3TextContains(repoSkillText, fmtSurfaceText),
           "v3 cheng skill consistency: repo skill fmt/lines public surface")
    assert(v3path.V3TextContains(repoSkillText, exportSurfaceSkillText),
           "v3 cheng skill consistency: repo skill export surface")
    assert(v3path.V3TextContains(repoSkillText, compositeDefaultSkillText),
           "v3 cheng skill consistency: repo skill composite default surface")
    assert(v3path.V3TextContains(repoSkillText, implicitDefaultSkillText),
           "v3 cheng skill consistency: repo skill implicit default surface")
    assert(v3path.V3TextContains(repoSkillText, v3EntryText),
           "v3 cheng skill consistency: repo skill v3 entry surface")
    assert(v3path.V3TextContains(repoSkillText, v3ProdRegressionText),
           "v3 cheng skill consistency: repo skill production regression command")
    assert(v3path.V3TextContains(repoSkillText, v3PerfText),
           "v3 cheng skill consistency: repo skill v3 perf surface")
    assert(v3path.V3TextContains(repoSkillText, v3PerfDefaultCompilerText),
           "v3 cheng skill consistency: repo skill perf default compiler")
    assert(v3path.V3TextContains(repoSkillText, v3PerfDarwinMemoryText),
           "v3 cheng skill consistency: repo skill darwin perf memory")
    assert(v3path.V3TextContains(repoSkillText, v3SkillCheckText),
           "v3 cheng skill consistency: repo skill skill consistency command")

    assert(v3path.V3TextContains(repoGrammarText, exportSurfaceSkillText),
           "v3 cheng skill consistency: repo grammar export surface")
    assert(v3path.V3TextContains(repoGrammarText, compositeDefaultGrammarText),
           "v3 cheng skill consistency: repo grammar composite default surface")
    assert(v3path.V3TextContains(repoGrammarText, compositeSteadyGrammarText),
           "v3 cheng skill consistency: repo grammar steady default surface")
    assert(v3path.V3TextContains(repoGrammarText, tupleGrammarText),
           "v3 cheng skill consistency: repo grammar tuple default surface")
    assert(v3path.V3TextContains(repoGrammarText, implicitDefaultGrammarText),
           "v3 cheng skill consistency: repo grammar implicit default surface")
    assert(v3path.V3TextContains(repoGrammarText, "tags: str[]"),
           "v3 cheng skill consistency: repo grammar sample seq implicit default")
    assert(v3path.V3TextContains(repoGrammarText, "retries: int32[3] = [1, 2, 3]"),
           "v3 cheng skill consistency: repo grammar sample fixed literal default")
    assert(v3path.V3TextContains(repoGrammarText, "Fmt\"label={expr}\""),
           "v3 cheng skill consistency: repo grammar fmt surface")

    assert(v3path.V3TextContains(readmeText, "artifacts/v3_bootstrap/cheng.stage3"),
           "v3 cheng skill consistency: README stage3 entry")
    assert(v3path.V3TextContains(readmeText, "artifacts/v3_backend_driver/cheng"),
           "v3 cheng skill consistency: README backend driver entry")
    assert(v3path.V3TextContains(readmeText, v3ProdRegressionText),
           "v3 cheng skill consistency: README production regression command")
    assert(v3path.V3TextContains(readmeText, v3PerfDefaultCompilerText),
           "v3 cheng skill consistency: README perf default compiler")
    assert(v3path.V3TextContains(readmeText, v3PerfDarwinMemoryText),
           "v3 cheng skill consistency: README darwin perf memory")
    assert(v3path.V3TextContains(readmeText, "artifacts/v3_bootstrap/cheng.stage3 profile-run / profile-report"),
           "v3 cheng skill consistency: README profile commands")
    assert(v3path.V3TextContains(readmeText, "artifacts/v3_backend_driver/cheng run-host-smokes perf_memory_contract_smoke"),
           "v3 cheng skill consistency: README perf memory gate command")
    assert(v3path.V3TextContains(readmeText, "artifacts/v3_backend_driver/cheng run-host-smokes cheng_skill_consistency_smoke"),
           "v3 cheng skill consistency: README skill consistency command")

    assert(v3path.V3TextContains(toolingReadmeText,
                                 "artifacts/v3_bootstrap/cheng.stage3 run-production-regression"),
           "v3 cheng skill consistency: v3 tooling readme production regression command")
    assert(v3path.V3TextContains(toolingReadmeText, v3ProdRegressionSmokeText),
           "v3 cheng skill consistency: v3 tooling readme production regression smokes")
    assert(v3path.V3TextContains(toolingReadmeText, v3PerfDefaultCompilerText),
           "v3 cheng skill consistency: v3 tooling readme perf default compiler")
    assert(v3path.V3TextContains(toolingReadmeText, v3PerfDarwinMemoryText),
           "v3 cheng skill consistency: v3 tooling readme darwin perf memory")
    assert(v3path.V3TextContains(toolingReadmeText,
                                 "artifacts/v3_bootstrap/cheng.stage3 profile-run --in:/abs/path/file.cheng --target:arm64-apple-darwin --out:/tmp/app"),
           "v3 cheng skill consistency: v3 tooling readme profile-run command")
    assert(v3path.V3TextContains(toolingReadmeText,
                                 "artifacts/v3_bootstrap/cheng.stage3 profile-report --in:/tmp/app.v3.profile.raw.txt --out:/tmp/app.profile.txt"),
           "v3 cheng skill consistency: v3 tooling readme profile-report command")
    assert(v3path.V3TextContains(toolingReadmeText,
                                 "artifacts/v3_backend_driver/cheng run-host-smokes perf_memory_contract_smoke"),
           "v3 cheng skill consistency: v3 tooling readme perf memory gate command")
    assert(v3path.V3TextContains(toolingReadmeText,
                                 "artifacts/v3_backend_driver/cheng run-host-smokes cheng_skill_consistency_smoke"),
           "v3 cheng skill consistency: v3 tooling readme skill consistency command")
    assert(v3path.V3TextContains(toolingReadmeText, "explicit_default_init_gate_smoke"),
           "v3 cheng skill consistency: v3 tooling readme explicit default gate")

    assert(v3path.V3TextContains(fmtSmokeText, "let joined: str = Fmt(parts)"),
           "v3 cheng skill consistency: strformat fmt smoke direct Fmt join")
    assert(v3path.V3TextContains(fmtSmokeText, "let aliasedJoined: str = sf.Fmt(parts)"),
           "v3 cheng skill consistency: strformat fmt smoke aliased Fmt join")
    assert(v3path.V3TextContains(fmtSmokeText, "let lines: str = Lines(lineParts)"),
           "v3 cheng skill consistency: strformat fmt smoke direct Lines join")
    assert(v3path.V3TextContains(fmtSmokeText, "let aliasedLines: str = sf.Lines(lineParts)"),
           "v3 cheng skill consistency: strformat fmt smoke aliased Lines join")
    assert(v3path.V3TextContains(explicitDefaultPositiveSmokeText,
                                 "let xs: int32[] = [1, 2]"),
           "v3 cheng skill consistency: explicit default positive seq literal")
    assert(v3path.V3TextContains(explicitDefaultPositiveSmokeText,
                                 "let inferredFoo = PositiveFoo()"),
           "v3 cheng skill consistency: explicit default positive inferred object")
    assert(v3path.V3TextContains(explicitDefaultNegativeSmokeText,
                                 "redundant explicit default init; omit initializer"),
           "v3 cheng skill consistency: explicit default negative diagnostic")
    assert(v3path.V3TextContains(explicitDefaultGateSmokeText,
                                 "redundant explicit default init forbidden"),
           "v3 cheng skill consistency: explicit default gate diagnostic")
    assert(v3path.V3TextContains(zeroHelperGateSmokeText,
                                 "composite no-arg Zero helper forbidden; use implicit init, T(), or new(T)"),
           "v3 cheng skill consistency: zero helper gate diagnostic")

    var reportRows: str[]
    add(reportRows, "formal_spec=ok")
    add(reportRows, "repo_skill=ok")
    add(reportRows, "repo_grammar=ok")
    add(reportRows, "readme=ok")
    add(reportRows, "tooling_readme=ok")
    add(reportRows, "strformat_fmt_smoke=ok")
    add(reportRows, "explicit_default_init_positive_smoke=ok")
    add(reportRows, "explicit_default_init_negative_smoke=ok")
    add(reportRows, "explicit_default_init_gate_smoke=ok")
    add(reportRows, "composite_zero_helper_gate_smoke=ok")

    let homeDir = os.GetEnvDefault("HOME", "")
    if len(homeDir) > 0:
        let homeSkillPath = os.JoinPath(homeDir, ".codex/skills/cheng语言/SKILL.md")
        let homeGrammarPath = os.JoinPath(homeDir, ".codex/skills/cheng语言/references/grammar.md")
        if v3path.V3FileExistsNonEmpty(workspaceRoot, homeSkillPath):
            let homeSkillText = v3path.V3ReadTextFile("", homeSkillPath)
            assert(homeSkillText == repoSkillText, "v3 cheng skill consistency: home skill mirror drift")
            add(reportRows, "home_skill=ok")
        else:
            add(reportRows, "home_skill=missing")
        if v3path.V3FileExistsNonEmpty(workspaceRoot, homeGrammarPath):
            let homeGrammarText = v3path.V3ReadTextFile("", homeGrammarPath)
            assert(homeGrammarText == repoGrammarText, "v3 cheng skill consistency: home grammar mirror drift")
            add(reportRows, "home_grammar=ok")
        else:
            add(reportRows, "home_grammar=missing")
    else:
        add(reportRows, "home_skill=no_home_env")
        add(reportRows, "home_grammar=no_home_env")

    let reportPath = v3path.V3PathJoin(outDir, "v3_cheng_skill_consistency.report.txt")
    assert(v3path.V3WriteTextFile(workspaceRoot,
                                  reportPath,
                                  strutil.Join(reportRows, "\n") + "\n"),
           "v3 cheng skill consistency: write report")
    echo("v3 cheng_skill_consistency_smoke ok")
    return 0
