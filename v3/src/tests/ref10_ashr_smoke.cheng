import std/system
import std/crypto/ed25519/ref10

fn main(): int32 =
    assert(ref10.ashr64(int64(-1), 1) == int64(-1), "v3 ref10 ashr: i64 -1 >> 1")
    assert(ref10.ashr64(int64(-2), 1) == int64(-1), "v3 ref10 ashr: i64 -2 >> 1")
    assert(ref10.ashr64(int64(-3), 1) == int64(-2), "v3 ref10 ashr: i64 -3 >> 1")
    assert(ref10.ashr64(int64(-5), 2) == int64(-2), "v3 ref10 ashr: i64 -5 >> 2")
    assert(ref10.ashr32(-1, 1) == -1, "v3 ref10 ashr: i32 -1 >> 1")
    assert(ref10.ashr32(-2, 1) == -1, "v3 ref10 ashr: i32 -2 >> 1")
    assert(ref10.ashr32(-3, 1) == -2, "v3 ref10 ashr: i32 -3 >> 1")
    assert(ref10.ashr32(-5, 2) == -2, "v3 ref10 ashr: i32 -5 >> 2")
    echo("v3 ref10_ashr_smoke ok")
    return 0
