import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/anti_entropy as anti
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peer_id
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host
import cheng/v3/libp2p/transports/tailnet_transport as tsnet
import cheng/v3/project/chain_node as node
import cheng/v3/project/chain_node_libp2p as net

fn main(): int32 =
    var server = node.v3ChainNodeInit("tailnet.node.a", "tailnet-chain")
    var client = node.v3ChainNodeInit("tailnet.node.b", "tailnet-chain")
    var serverHost = host.v3Libp2pHostInit("tailnet.server")
    var clientHost = host.v3Libp2pHostInit("tailnet.client")
    host.v3Libp2pHostSetTrustedInfra(serverHost, true)
    host.v3Libp2pHostSetTrustedInfra(clientHost, true)

    var tailnetCfg = tsnet.v3Libp2pTailnetTransportConfigZero()
    tailnetCfg.controlEndpoint = "https://headscale.tailnet/control"
    tailnetCfg.relayEndpoint = "https://derp.tailnet:443"
    tailnetCfg.syntheticIPv4 = "100.64.0.21"
    tailnetCfg.exactRouting = true
    tailnetCfg.localPeerId = peer_id.v3Libp2pPeerIdText(serverHost.selfPeerId)
    var tailnet = tsnet.v3Libp2pTailnetTransportInit(tailnetCfg)
    tsnet.v3Libp2pTailnetSetProviderReady(tailnet, true, "control-ready")
    tsnet.v3Libp2pTailnetSetProxyListenersReady(tailnet, true, "proxy-ready")

    var rawListen = types.v3Libp2pMultiaddrZero()
    multiaddr.v3Libp2pMultiaddrFillTcp(rawListen, "127.0.0.1", 6211)
    let publishedRes = tsnet.v3Libp2pTailnetListen(tailnet, rawListen)
    assert(IsOk(publishedRes), "v3 chain_node tailnet: published listen")
    let tailnetAddr = Value(publishedRes)
    var serverSession = tsnet.v3Libp2pTailnetPeerSessionZero()
    serverSession.peerId = peer_id.v3Libp2pPeerIdText(serverHost.selfPeerId)
    serverSession.remoteTailnetIp = tailnetAddr.host
    serverSession.directReachable = true
    serverSession.relayAllowed = true
    serverSession.signedPreface = "preface-ok"
    serverSession.boundAddrText = tsnet.v3Libp2pTailnetAddrText(rawListen)
    tsnet.v3Libp2pTailnetUpsertPeerSession(tailnet, serverSession)
    var dialPlan = tsnet.v3Libp2pTailnetDialPlanZero()
    let dialPlanRes = tsnet.v3Libp2pTailnetDialPlanFill(dialPlan,
                                                        tailnet,
                                                        peer_id.v3Libp2pPeerIdText(serverHost.selfPeerId),
                                                        tailnetAddr,
                                                        false,
                                                        false)
    assert(IsOk(dialPlanRes), "v3 chain_node tailnet: dial plan")
    assert(dialPlan.pathKind == tsnet.v3Libp2pTailnetPathDirect,
        "v3 chain_node tailnet: direct path")
    assert(dialPlan.routeText == tsnet.v3Libp2pTailnetAddrText(rawListen),
        "v3 chain_node tailnet: exact route")

    let listenRes = host.v3Libp2pListen(serverHost, tailnetAddr)
    assert(listenRes.ok, "v3 chain_node tailnet: listen")

    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolGossipsub)
    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolStore)
    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolGossipsub)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolStore)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolSync)

    let dialRes = host.v3Libp2pDial(clientHost,
                                    serverHost.selfPeerId,
                                    tailnetAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 chain_node tailnet: dial")
    host.v3Libp2pSetPeerTrustedInfra(clientHost, serverHost.selfPeerId, true)

    let mintCidRes = node.v3ChainNodeMint(server, 9, 3001, int64(77))
    assert(mintCidRes.ok, "v3 chain_node tailnet: mint")
    let transferCidRes = node.v3ChainNodeTransfer(server, 9, 3001, 4002, int64(12))
    assert(transferCidRes.ok, "v3 chain_node tailnet: transfer")

    let serveRes = net.v3ChainNodeLibp2pServeOnce(server, serverHost)
    assert(serveRes.ok, "v3 chain_node tailnet: serve once")
    let syncRes = net.v3ChainNodeLibp2pSyncOnce(client, clientHost, serverHost, serverHost.selfPeerId)
    assert(syncRes.ok, "v3 chain_node tailnet: sync once")
    assert(syncRes.value, "v3 chain_node tailnet: sync changed")

    let exportedPublic = host.v3Libp2pVisibleListenAddrs(serverHost, false)
    assert(exportedPublic.len == 0, "v3 chain_node tailnet: no public export")
    let exportedTrusted = host.v3Libp2pIdentifyListenAddrsForPeer(serverHost, clientHost.selfPeerId)
    assert(exportedTrusted.len == 0, "v3 chain_node tailnet: no identify export without whitelist")
    let exportedPeerView = host.v3Libp2pPeerVisibleAddrs(clientHost, serverHost.selfPeerId, true)
    assert(exportedPeerView.len == 1, "v3 chain_node tailnet: client keeps tailnet endpoint")
    assert(exportedPeerView[0].networkDomain == types.v3Libp2pNetworkDomainTailnet,
        "v3 chain_node tailnet: selected domain")

    let aliceRes = node.v3ChainNodeBalance(client, 9, 3001)
    let bobRes = node.v3ChainNodeBalance(client, 9, 4002)
    assert(aliceRes.ok, "v3 chain_node tailnet: alice balance")
    assert(bobRes.ok, "v3 chain_node tailnet: bob balance")
    assert(aliceRes.value == int64(65), "v3 chain_node tailnet: alice 65")
    assert(bobRes.value == int64(12), "v3 chain_node tailnet: bob 12")

    let serverServed = node.v3ChainNodeServeOnce(server)
    let clientServed = node.v3ChainNodeServeOnce(client)
    assert(layout.fixedBytes32Equal(serverServed.forest.forestCid, clientServed.forest.forestCid),
        "v3 chain_node tailnet: forest cid")
    assert(anti.v3AntiEntropySignatureEqual(serverServed.signature, clientServed.signature),
        "v3 chain_node tailnet: signature")

    echo("v3 chain_node_tailnet_smoke ok")
    return 0
