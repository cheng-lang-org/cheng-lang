import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/binary_types as types
import cheng/v3/chain/lsmr as lsmr
import cheng/v3/chain/lsmr_types as lt

fn mustAddress(digits: int32[]): types.V3LsmrAddress =
    let res = types.v3LsmrAddressFromDigits(digits)
    if IsErr(res):
        panic(Error(res))
    return Value(res)

fn makeCell(keyId: int32, digits: int32[], resolution: int32, salt: int32): lt.V3StateCell =
    let address = mustAddress(digits)
    let contentCid = lt.v3HashInts("v3.bagua_fill.content", [keyId, salt, resolution])
    let localityHash = lt.v3HashInts("v3.bagua_fill.locality", [keyId, salt, resolution])
    var cell: lt.V3StateCell
    lsmr.v3LsmrStateCellFill(cell, keyId, address, resolution, contentCid, localityHash)
    return cell

fn main(): int32 =
    var cells: lt.V3StateCell[]
    cells = []
    add(cells, makeCell(101, [6, 7, 9], 3, 1))
    add(cells, makeCell(102, [6, 7, 3], 3, 2))
    var tree = lt.V3BaguaPrefixTree()
    lsmr.v3BuildBaguaPrefixTreeFill(tree, cells)
    assert(tree.entryCount == 2, "v3 bagua_prefix_tree_fill_smoke: entry count")
    assert(tree.nodeCount > 0, "v3 bagua_prefix_tree_fill_smoke: node count")
    assert(!layout.fixedBytes32Equal(tree.treeCid, layout.FixedBytes32()),
           "v3 bagua_prefix_tree_fill_smoke: tree cid")
    echo("v3 bagua_prefix_tree_fill_smoke ok")
    return 0
