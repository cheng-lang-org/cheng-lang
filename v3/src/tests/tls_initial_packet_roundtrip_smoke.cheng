import std/system
import std/result
import cheng/v3/quic/native_runtime as qnative
import cheng/v3/quic/tls/policy as qpolicy

fn smokeRoundtripPolicy(): qpolicy.MsQuicTlsPolicy =
    var out: qpolicy.MsQuicTlsPolicy
    out.serverName = "localhost"
    return out

fn main(): int32 =
    qnative.msquicNativeResetSession()
    let policy: qpolicy.MsQuicTlsPolicy = smokeRoundtripPolicy()
    qnative.msquicNativeSetClientPolicyCache(policy)
    let roundtripRes: Result[bool] = qnative.msquicNativeDebugRoundtripClientHelloInitial()
    if IsErr(roundtripRes):
        panic(ErrorText(roundtripRes))

    echo("v3 tls_initial_packet_roundtrip_smoke ok")
    return 0
