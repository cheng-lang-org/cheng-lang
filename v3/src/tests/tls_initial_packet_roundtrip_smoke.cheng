import std/system
import std/result
import std/rawbytes
import cheng/v3/quic/tls/handshake13 as handshake13
import cheng/v3/quic/core/frame_model
import cheng/v3/quic/core/packet_model
import cheng/v3/quic/core/packet_header_model

fn main(): int32 =
    handshake13.msquicTls13ResetClientDefault(true)
    handshake13.msquicTls13ResetServerDefault(false)

    let genRes: Result[bool] = handshake13.msquicTls13ClientGenerateX25519()
    if IsErr(genRes):
        panic(ErrorText(genRes))

    let randomSeed: Bytes = bytesAlloc(32)
    for i in 0..<32:
        bytesSet(randomSeed, i, (i + 1) & 0xff)

    let helloRes: Result[Bytes] = handshake13.msquicTls13ClientBuildClientHello(
        randomSeed,
        "dm",
        "localhost",
        emptyBytes()
    )
    if IsErr(helloRes):
        panic(ErrorText(helloRes))
    let hello: Bytes = Value(helloRes)

    var pkt: packet_model.MsQuicPacket = packet_model.initMsQuicPacket(1)
    let addRes: Result[bool] = packet_model.msquicPacketAddFrame(pkt, frame_model.msquicFrameCrypto(0, hello))
    if IsErr(addRes):
        panic(ErrorText(addRes))

    let payloadRes: Result[Bytes] = packet_model.msquicPacketPayloadEncode(pkt)
    if IsErr(payloadRes):
        panic(ErrorText(payloadRes))
    let payload: Bytes = Value(payloadRes)

    let cid: Bytes = bytesAlloc(8)
    for i in 0..<8:
        bytesSet(cid, i, (0x11 + i) & 0xff)

    var header: packet_header_model.QuicPacketHeader
    header.longHeader = true
    header.packetType = packet_header_model.QuicPacketInitial
    header.version = 1
    header.dcid = cid
    header.scid = cid
    header.token = emptyBytes()
    header.payloadLength = int64(bytesLen(payload) + 2)
    header.packetNumber = 1
    header.packetNumberLen = 2
    header.spinBit = false
    header.keyPhase = false

    let headerRes: Result[Bytes] = packet_header_model.quicPacketHeaderEncode(header)
    if IsErr(headerRes):
        panic(ErrorText(headerRes))
    let wire: Bytes = bytesConcat3(Value(headerRes), payload, emptyBytes())

    let decodeHeaderRes = packet_header_model.quicPacketHeaderDecode(wire, 8)
    if IsErr(decodeHeaderRes):
        panic(ErrorText(decodeHeaderRes))
    let decodedHeader: packet_header_model.QuicPacketHeaderDecoded = Value(decodeHeaderRes)
    let payloadOffset: int32 = decodedHeader.next
    let payloadLen: int32 = int32(decodedHeader.header.payloadLength) - decodedHeader.header.packetNumberLen
    let decodedPayload: Bytes = bytesSlice(wire, payloadOffset, payloadLen)

    var decodedPkt: packet_model.MsQuicPacket
    let decodePayloadRes = packet_model.msquicPacketPayloadDecodeInto(
        decodedPkt,
        decodedPayload,
        decodedHeader.header.packetNumber
    )
    if IsErr(decodePayloadRes):
        panic(ErrorText(decodePayloadRes))

    assert(decodedPkt.framesCount == 1, "v3 tls initial packet roundtrip: one frame")
    assert(decodedPkt.frames[0].kind == frame_model.FrameCrypto, "v3 tls initial packet roundtrip: crypto frame")
    assert(decodedPkt.frames[0].offset == 0, "v3 tls initial packet roundtrip: crypto offset")
    assert(bytesEqual(decodedPkt.frames[0].data, hello), "v3 tls initial packet roundtrip: crypto payload")

    let feedRes: Result[int32] = handshake13.msquicTls13SideFeed(1, decodedPkt.frames[0].data)
    if IsErr(feedRes):
        panic(ErrorText(feedRes))
    assert(Value(feedRes) == 1, "v3 tls initial packet roundtrip: one handshake message")
    assert(
        handshake13.msquicTls13ServerClientKeyShareGroup() > 0,
        "v3 tls initial packet roundtrip: server parsed client key share"
    )

    echo("v3 tls_initial_packet_roundtrip_smoke ok")
    return 0
