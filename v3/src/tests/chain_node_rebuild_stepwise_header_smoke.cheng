import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus as consensus
import cheng/v3/chain/lsmr as lsmr
import cheng/v3/chain/anti_entropy as anti
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server = node.v3ChainNodeInit("node-a", "chain-node-a")

    let parentCid = node.v3ChainNodeAccountHead(server.index, 7, 1001)
    var event = consensus.v3ChainEventMint(
        7,
        1001,
        parentCid,
        int64(100),
        server.nextEpoch,
        server.nextGanzhi,
        node.v3ChainNodeSpaceSlot(1001, 1001),
        server.nextTick
    )
    let eventCid = consensus.v3ChainEventCid(event)

    var nextIndex = server.index
    var decision = consensus.v3ConsensusDecisionZero()
    consensus.v3ConsensusApplyChecked(nextIndex, event, eventCid, server.eventCids.len, decision)
    assert(decision.accepted, "v3 chain_node rebuild stepwise: accepted")
    assert(decision.applied, "v3 chain_node rebuild stepwise: applied")

    server.index = nextIndex
    add(server.eventCids, eventCid)
    add(server.events, event)
    assert(server.eventCids.len == 1, "v3 chain_node rebuild stepwise: before cells")

    let cells = node.v3ChainNodeStateCells(server.index)
    assert(server.eventCids.len == 1, "v3 chain_node rebuild stepwise: after cells")

    lsmr.v3BuildStateLayerForestFill(server.forest, cells)
    assert(server.eventCids.len == 1, "v3 chain_node rebuild stepwise: after forest")

    let stamp = node.v3ChainNodeMaxStamp(server.index)
    assert(server.eventCids.len == 1, "v3 chain_node rebuild stepwise: after stamp")

    server.signature = anti.v3AntiEntropySignatureFromForest(
        stamp.epoch,
        stamp.ganzhi,
        server.eventCids.len,
        server.index.accountIds.len,
        server.forest
    )
    assert(server.eventCids.len == 1, "v3 chain_node rebuild stepwise: after signature")

    server.tipEventCid = server.eventCids.len > 0 ? server.eventCids[server.eventCids.len - 1] : layout.fixedBytes32Zero()
    assert(server.eventCids.len == 1, "v3 chain_node rebuild stepwise: after tip")
    server.nextEpoch = stamp.epoch
    assert(server.eventCids.len == 1, "v3 chain_node rebuild stepwise: after nextEpoch")
    server.nextGanzhi = stamp.ganzhi + 1
    assert(server.eventCids.len == 1, "v3 chain_node rebuild stepwise: after nextGanzhi")
    if server.nextGanzhi <= 0:
        server.nextGanzhi = 1
    assert(server.eventCids.len == 1, "v3 chain_node rebuild stepwise: after ganzhi guard")
    server.nextTick = int64(server.eventCids.len + 1)
    assert(server.eventCids.len == 1, "v3 chain_node rebuild stepwise: after tail")

    echo("v3 chain_node_rebuild_stepwise_header_smoke ok")
    return 0
