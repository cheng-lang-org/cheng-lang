import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/dag_mempool as dag

fn main(): int32 =
    let payload = bytesFromString("v3 dag payload body")
    let summaryRes = dag.v3DagBlobSummaryFromBytes(payload, 8)
    assert(IsOk(summaryRes), "v3 dag mempool smoke: summary")
    let summary = Value(summaryRes)
    let summaryOk = dag.v3DagBlobSummaryValidate(summary)
    assert(IsOk(summaryOk), "v3 dag mempool smoke: summary validate")
    assert(summary.chunkCount == 3, "v3 dag mempool smoke: chunk count")

    let providerA = lt.v3HashInts("v3.dag.provider", [1, 10])
    let providerB = lt.v3HashInts("v3.dag.provider", [2, 20])
    let proofARes = dag.v3DagAvailabilityProofMake(summary, providerA, 120)
    let proofBRes = dag.v3DagAvailabilityProofMake(summary, providerB, 90)
    assert(IsOk(proofARes), "v3 dag mempool smoke: proofA")
    assert(IsOk(proofBRes), "v3 dag mempool smoke: proofB")
    let proofA = Value(proofARes)
    let proofB = Value(proofBRes)
    let proofOk = dag.v3DagAvailabilityProofValidate(proofA, summary)
    assert(IsOk(proofOk), "v3 dag mempool smoke: proof validate")

    var proofs: dag.V3DagAvailabilityProof[]
    proofs = []
    add(proofs, proofB)
    add(proofs, proofA)
    let certRes = dag.v3DagAvailabilityCertMake(summary, proofs)
    assert(IsOk(certRes), "v3 dag mempool smoke: cert")
    let cert = Value(certRes)
    let certOk = dag.v3DagAvailabilityCertValidate(cert, summary, proofs)
    assert(IsOk(certOk), "v3 dag mempool smoke: cert validate")
    assert(cert.proofCount == 2, "v3 dag mempool smoke: cert proof count")
    assert(cert.minRetainedUntilEpoch == 90, "v3 dag mempool smoke: cert retained epoch")
    assert(layout.fixedBytes32Equal(cert.providerPeerIds[0], providerA),
        "v3 dag mempool smoke: provider sorted")

    let topicCid = lt.v3HashInts("v3.dag.topic", [7, 8, 9])
    let publisherPeerId = lt.v3HashInts("v3.dag.publisher", [3, 30])
    let advertRes = dag.v3DagPublishAdvertMake(topicCid,
                                               publisherPeerId,
                                               summary,
                                               cert,
                                               11,
                                               22)
    assert(IsOk(advertRes), "v3 dag mempool smoke: advert")
    let advert = Value(advertRes)
    let advertOk = dag.v3DagPublishAdvertValidate(advert, summary, cert)
    assert(IsOk(advertOk), "v3 dag mempool smoke: advert validate")

    var badAdvert = advert
    badAdvert.blobSummaryCid = layout.FixedBytes32()
    let badAdvertOk = dag.v3DagPublishAdvertValidate(badAdvert, summary, cert)
    assert(IsErr(badAdvertOk), "v3 dag mempool smoke: advert reject mismatch")

    echo("v3 dag_mempool_smoke ok")
    return 0
