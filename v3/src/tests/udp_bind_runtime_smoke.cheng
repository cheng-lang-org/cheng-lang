import std/system
import std/result
import std/strings
import cheng/v3/quic/platform/datapath_udp as qudp

fn main(): int32 =
    var bound: qudp.MsQuicUdpBound
    let bindRes = qudp.msquicUdpBindInto(bound, "/ip4/127.0.0.1/udp/0/quic-v1")
    assert(IsOk(bindRes), "udp runtime bind failed")
    assert(bound.fd >= 0, "udp runtime bind: invalid fd")
    assert(strings.hasPrefix(bound.addr, "udp://127.0.0.1:"), "udp runtime bind: canonical addr")
    qudp.msquicUdpUnbind(bound.fd)
    echo("v3 udp_bind_runtime_smoke ok")
    return 0
