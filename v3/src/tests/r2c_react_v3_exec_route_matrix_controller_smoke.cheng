import std/os
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_V3_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_r2c_exec_route_matrix_controller_smoke")
    assert(v3path.V3MkdirP(root, outDir), "v3 r2c exec route matrix smoke: mkdir")
    let driver = v3path.V3PathAbsolute(root, "artifacts/v3_backend_driver/cheng")
    let packageRoot = v3path.V3PathAbsolute(root, "v3")
    let controllerSource = v3path.V3PathAbsolute(root, "v3/src/tooling/r2c_react_v3.cheng")
    assert(v3path.V3FileExistsNonEmpty(root, driver), "v3 r2c exec route matrix smoke: backend_driver exists")
    assert(v3path.V3FileExistsNonEmpty(root, controllerSource), "v3 r2c exec route matrix smoke: controller source exists")

    let controllerExe = os.JoinPath(outDir, "r2c_react_v3_exec_route_matrix_controller_smoke")
    let controllerCompileReport = controllerExe + ".report.txt"
    let controllerCompileLog = controllerExe + ".compile.log"
    if v3path.V3PathFileExists(controllerExe):
        os.RemoveFile(controllerExe)
    if v3path.V3PathFileExists(controllerCompileReport):
        os.RemoveFile(controllerCompileReport)
    let controllerCompileRun = hostops.v3RunFileLogged(root,
                                                       "r2c_exec_route_matrix_controller_compile",
                                                       driver,
                                                       [
                                                           "system-link-exec",
                                                           "--root:" + packageRoot,
                                                           "--in:" + controllerSource,
                                                           "--emit:exe",
                                                           "--target:arm64-apple-darwin",
                                                           "--out:" + controllerExe,
                                                           "--report-out:" + controllerCompileReport
                                                       ],
                                                       ["CHENG_V3_BACKEND_DRIVER_READY=1"],
                                                       root,
                                                       0,
                                                       controllerCompileLog)
    assert(hostops.v3LoggedRunOk(controllerCompileRun), "v3 r2c exec route matrix smoke: controller compile rc")
    assert(v3path.V3FileExistsNonEmpty(root, controllerExe), "v3 r2c exec route matrix smoke: controller exe")

    let routeCatalogPath = os.JoinPath(outDir, "cheng_codegen_route_catalog_v1.json")
    let execSnapshotPath = os.JoinPath(outDir, "cheng_codegen_exec_snapshot_v1.json")
    let truthRoutesPath = os.JoinPath(outDir, "truth_routes_v1.json")
    let truthTracePath = os.JoinPath(outDir, "truth_trace_v2.json")
    let execRouteMatrixPath = os.JoinPath(outDir, "cheng_codegen_exec_route_matrix_v1.json")
    let execRouteMatrixSummaryPath = os.JoinPath(outDir, "exec_route_matrix.summary.env")
    let reportPath = os.JoinPath(outDir, "exec_route_matrix_report_v1.json")
    var routeCatalogText = "{\n"
    routeCatalogText = routeCatalogText + "  \"format\": \"cheng_codegen_route_catalog_v1\",\n"
    routeCatalogText = routeCatalogText + "  \"runnerMode\": \"react_surface_runner_v1\",\n"
    routeCatalogText = routeCatalogText + "  \"entryRouteState\": \"home_default\",\n"
    routeCatalogText = routeCatalogText + "  \"routeCount\": 2,\n"
    routeCatalogText = routeCatalogText + "  \"supportedCount\": 2,\n"
    routeCatalogText = routeCatalogText + "  \"unsupportedCount\": 0,\n"
    routeCatalogText = routeCatalogText + "  \"routes\": [\"home_default\", \"publish_selector\"],\n"
    routeCatalogText = routeCatalogText + "  \"entries\": [\n"
    routeCatalogText = routeCatalogText + "    {\n"
    routeCatalogText = routeCatalogText + "      \"routeId\": \"home_default\",\n"
    routeCatalogText = routeCatalogText + "      \"supported\": true,\n"
    routeCatalogText = routeCatalogText + "      \"deterministic\": true,\n"
    routeCatalogText = routeCatalogText + "      \"reason\": \"entry_surface\",\n"
    routeCatalogText = routeCatalogText + "      \"candidateCount\": 1,\n"
    routeCatalogText = routeCatalogText + "      \"candidates\": [\n"
    routeCatalogText = routeCatalogText + "        {\n"
    routeCatalogText = routeCatalogText + "          \"semanticNodesCount\": 83,\n"
    routeCatalogText = routeCatalogText + "          \"reason\": \"entry_surface\"\n"
    routeCatalogText = routeCatalogText + "        }\n"
    routeCatalogText = routeCatalogText + "      ]\n"
    routeCatalogText = routeCatalogText + "    },\n"
    routeCatalogText = routeCatalogText + "    {\n"
    routeCatalogText = routeCatalogText + "      \"routeId\": \"publish_selector\",\n"
    routeCatalogText = routeCatalogText + "      \"supported\": true,\n"
    routeCatalogText = routeCatalogText + "      \"deterministic\": true,\n"
    routeCatalogText = routeCatalogText + "      \"reason\": \"derived_candidate\",\n"
    routeCatalogText = routeCatalogText + "      \"candidateCount\": 1,\n"
    routeCatalogText = routeCatalogText + "      \"candidates\": [\n"
    routeCatalogText = routeCatalogText + "        {\n"
    routeCatalogText = routeCatalogText + "          \"semanticNodesCount\": 184,\n"
    routeCatalogText = routeCatalogText + "          \"reason\": \"derived_candidate\"\n"
    routeCatalogText = routeCatalogText + "        }\n"
    routeCatalogText = routeCatalogText + "      ]\n"
    routeCatalogText = routeCatalogText + "    }\n"
    routeCatalogText = routeCatalogText + "  ]\n"
    routeCatalogText = routeCatalogText + "}\n"
    assert(v3path.V3WriteTextFile("", routeCatalogPath, routeCatalogText),
           "v3 r2c exec route matrix smoke: write route catalog")
    var execSnapshotText = "{\n"
    execSnapshotText = execSnapshotText + "  \"format\": \"cheng_codegen_exec_snapshot_v1\",\n"
    execSnapshotText = execSnapshotText + "  \"route_state\": \"home_default\",\n"
    execSnapshotText = execSnapshotText + "  \"render_ready\": true,\n"
    execSnapshotText = execSnapshotText + "  \"semantic_nodes_loaded\": true,\n"
    execSnapshotText = execSnapshotText + "  \"semantic_nodes_count\": 83,\n"
    execSnapshotText = execSnapshotText + "  \"tree_node_count\": 83,\n"
    execSnapshotText = execSnapshotText + "  \"root_node_count\": 1,\n"
    execSnapshotText = execSnapshotText + "  \"element_node_count\": 83\n"
    execSnapshotText = execSnapshotText + "}\n"
    assert(v3path.V3WriteTextFile("", execSnapshotPath, execSnapshotText),
           "v3 r2c exec route matrix smoke: write exec snapshot")
    var truthRoutesText = "{\n"
    truthRoutesText = truthRoutesText + "  \"format\": \"truth_routes_v1\",\n"
    truthRoutesText = truthRoutesText + "  \"routes\": [\n"
    truthRoutesText = truthRoutesText + "    { \"routeId\": \"home_default\" },\n"
    truthRoutesText = truthRoutesText + "    { \"routeId\": \"publish_selector\" }\n"
    truthRoutesText = truthRoutesText + "  ]\n"
    truthRoutesText = truthRoutesText + "}\n"
    assert(v3path.V3WriteTextFile("", truthRoutesPath, truthRoutesText),
           "v3 r2c exec route matrix smoke: write truth routes")
    var truthTraceText = "{\n"
    truthTraceText = truthTraceText + "  \"format\": \"truth_trace_v2\",\n"
    truthTraceText = truthTraceText + "  \"snapshots\": [\n"
    truthTraceText = truthTraceText + "    {\n"
    truthTraceText = truthTraceText + "      \"stateId\": \"home_default\",\n"
    truthTraceText = truthTraceText + "      \"route\": {\n"
    truthTraceText = truthTraceText + "        \"routeId\": \"home_default\"\n"
    truthTraceText = truthTraceText + "      },\n"
    truthTraceText = truthTraceText + "      \"semanticNodesCount\": 83,\n"
    truthTraceText = truthTraceText + "      \"renderReady\": true\n"
    truthTraceText = truthTraceText + "    },\n"
    truthTraceText = truthTraceText + "    {\n"
    truthTraceText = truthTraceText + "      \"stateId\": \"publish_selector\",\n"
    truthTraceText = truthTraceText + "      \"route\": {\n"
    truthTraceText = truthTraceText + "        \"routeId\": \"publish_selector\"\n"
    truthTraceText = truthTraceText + "      },\n"
    truthTraceText = truthTraceText + "      \"semanticNodesCount\": 184,\n"
    truthTraceText = truthTraceText + "      \"renderReady\": true\n"
    truthTraceText = truthTraceText + "    }\n"
    truthTraceText = truthTraceText + "  ]\n"
    truthTraceText = truthTraceText + "}\n"
    assert(v3path.V3WriteTextFile("", truthTracePath, truthTraceText),
           "v3 r2c exec route matrix smoke: write truth trace")

    let controllerLog = os.JoinPath(outDir, "exec_route_matrix_controller.log")
    if v3path.V3PathFileExists(controllerLog):
        os.RemoveFile(controllerLog)
    let controllerRun = hostops.v3RunFileLogged(root,
                                                "r2c_exec_route_matrix_controller_smoke",
                                                controllerExe,
                                                [
                                                    "exec-route-matrix",
                                                    "--route-catalog", routeCatalogPath,
                                                    "--exec-snapshot", execSnapshotPath,
                                                    "--truth-routes-file", truthRoutesPath,
                                                    "--truth-trace", truthTracePath,
                                                    "--out", execRouteMatrixPath
                                                ],
                                                ["R2C_REACT_V3_TOOLING_BIN=" + driver],
                                                root,
                                                0,
                                                controllerLog)
    assert(hostops.v3LoggedRunOk(controllerRun), "v3 r2c exec route matrix smoke: controller rc")
    assert(v3path.V3FileExistsNonEmpty(root, execRouteMatrixPath), "v3 r2c exec route matrix smoke: route matrix json")
    assert(v3path.V3FileExistsNonEmpty(root, execRouteMatrixSummaryPath), "v3 r2c exec route matrix smoke: route matrix summary")
    assert(v3path.V3FileExistsNonEmpty(root, reportPath), "v3 r2c exec route matrix smoke: report")

    let execRouteMatrixText = v3path.V3ReadTextFile("", execRouteMatrixPath)
    let execRouteMatrixSummaryText = v3path.V3ReadTextFile("", execRouteMatrixSummaryPath)
    let reportText = v3path.V3ReadTextFile("", reportPath)
    assert(v3path.V3TextContains(execRouteMatrixText, "\"format\": \"cheng_codegen_exec_route_matrix_v1\""),
           "v3 r2c exec route matrix smoke: route matrix format")
    assert(v3path.V3TextContains(execRouteMatrixText, "\"routeId\": \"home_default\""),
           "v3 r2c exec route matrix smoke: route matrix home_default")
    assert(v3path.V3TextContains(execRouteMatrixText, "\"routeId\": \"publish_selector\""),
           "v3 r2c exec route matrix smoke: route matrix publish_selector")
    assert(v3path.V3TextContains(execRouteMatrixText, "\"supportedCount\": 2"),
           "v3 r2c exec route matrix smoke: route matrix supported count")
    assert(v3path.V3TextContains(execRouteMatrixText, "\"unsupportedCount\": 0"),
           "v3 r2c exec route matrix smoke: route matrix unsupported count")
    assert(v3path.V3TextContains(execRouteMatrixSummaryText, "route_matrix_ok=true"),
           "v3 r2c exec route matrix smoke: summary ok")
    assert(v3path.V3TextContains(execRouteMatrixSummaryText, "route_count=2"),
           "v3 r2c exec route matrix smoke: summary route count")
    assert(v3path.V3TextContains(execRouteMatrixSummaryText, "supported_count=2"),
           "v3 r2c exec route matrix smoke: summary supported count")
    assert(v3path.V3TextContains(execRouteMatrixSummaryText, "unsupported_count=0"),
           "v3 r2c exec route matrix smoke: summary unsupported count")
    assert(v3path.V3TextContains(reportText, "\"command\": \"exec-route-matrix\""),
           "v3 r2c exec route matrix smoke: report command")
    assert(v3path.V3TextContains(reportText, "\"primary_artifact_format\": \"cheng_codegen_exec_route_matrix_v1\""),
           "v3 r2c exec route matrix smoke: report artifact format")
    assert(v3path.V3TextContains(reportText, "\"route_count\": 2"),
           "v3 r2c exec route matrix smoke: report route count")

    echo("v3 r2c_react_v3_exec_route_matrix_controller_smoke ok")
    return 0
