import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/compiler_world as cworld
import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/tooling/compiler_equivalence as ceq
import cheng/v3/lang/parser
import cheng/v3/backend/system_link_plan as slplan

fn main(): int32 =
    let workspaceRoot = v3path.v3PathCurrentDir()
    let packageRoot = v3path.v3PathJoin(workspaceRoot, "v3")
    let currentSourcePath = v3path.v3PathJoin(packageRoot, "src/tests/compiler_migration_fixture.cheng")
    let legacySourcePath = v3path.v3PathJoin(packageRoot, "testdata/compiler_migration/compiler_migration_fixture_legacy.cheng")
    let outputPath = v3path.v3PathJoin(workspaceRoot, "artifacts/v3_compiler_migration/compiler_migration_publish_fixture")
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        currentSourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), "v3 compiler migration publish: link plan")
    let sourceBundleCid = cworld.v3CompilerWorldSourceBundleCid(linkPlan.packageId, linkPlan.sourceClosurePaths)
    let currentCsgRes = ccsg.v3BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(currentCsgRes), "v3 compiler migration publish: build current csg")
    let currentCsg = Value(currentCsgRes)
    let entryModulePath = parser.v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, currentSourcePath)
    let migrationRes = ccsg.v3BuildCompilerLegacyMigration(workspaceRoot,
                                                           packageRoot,
                                                           legacySourcePath,
                                                           linkPlan.packageId,
                                                           entryModulePath)
    assert(IsOk(migrationRes), "v3 compiler migration publish: build migration")
    let migration = Value(migrationRes)
    let providers = [
        "runtime/compiler_runtime_v3",
        "runtime/core_runtime_v3",
        "runtime/debug_runtime_v3",
        "runtime/program_support_v3"
    ]
    let worldHeadCid = layout.fixedBytes32Zero()
    let currentReceipt = ccsg.v3CompileReceiptMake(worldHeadCid,
                                                   currentCsg.graphCid,
                                                   currentCsg.canonicalGraphCid,
                                                   req.targetTriple,
                                                   ccsg.v3CompileOutputDigest(outputPath, req.targetTriple, providers, currentCsg.graphCid),
                                                   ccsg.v3CompileOutputDigest(outputPath, req.targetTriple, providers, currentCsg.canonicalGraphCid),
                                                   "stage3_local",
                                                   providers)
    let migrationReceipt = ccsg.v3CompileReceiptMake(worldHeadCid,
                                                     migration.compilerCsg.graphCid,
                                                     migration.compilerCsg.canonicalGraphCid,
                                                     req.targetTriple,
                                                     ccsg.v3CompileOutputDigest(outputPath, req.targetTriple, providers, migration.compilerCsg.graphCid),
                                                     ccsg.v3CompileOutputDigest(outputPath, req.targetTriple, providers, migration.compilerCsg.canonicalGraphCid),
                                                     "stage3_local",
                                                     providers)
    assert(ccsg.v3CompileReceiptEquivalent(currentReceipt, migrationReceipt),
           "v3 compiler migration publish: canonical receipt equivalent")
    let currentSurface = ccsg.v3CompilerExportSurfaceFromCsg(currentCsg)
    var proof: ceq.V3CompilerEquivalenceProof
    let proofRes = ceq.v3CompilerEquivalenceProofMake(linkPlan.packageId,
                                                      "stable",
                                                      currentCsg.canonicalGraphCid,
                                                      migration.compilerCsg.canonicalGraphCid,
                                                      currentSurface.surfaceCid,
                                                      migration.exportSurface.surfaceCid,
                                                      currentReceipt.receiptCid,
                                                      migrationReceipt.receiptCid,
                                                      req.targetTriple,
                                                      1,
                                                      1,
                                                      1,
                                                      proof)
    assert(IsOk(proofRes), "v3 compiler migration publish: proof make")
    assert(ceq.v3CompilerEquivalencePassed(proof), "v3 compiler migration publish: proof passed")
    var decision: ceq.V3CompilerPublishDecision
    let decisionRes = ceq.v3CompilerPublishDecisionMake("stable",
                                                        worldHeadCid,
                                                        true,
                                                        proof,
                                                        decision)
    assert(IsOk(decisionRes), "v3 compiler migration publish: decision")
    assert(decision.publishAllowed != 0, "v3 compiler migration publish: stable allowed")
    let proofReport = ceq.v3CompilerEquivalenceProofReport(proof)
    assert(v3path.v3TextContains(proofReport, "equivalence_kind=canonical_semantic_identity"),
           "v3 compiler migration publish: report kind")
    echo("v3 compiler_migration_publish_smoke ok")
    return 0
