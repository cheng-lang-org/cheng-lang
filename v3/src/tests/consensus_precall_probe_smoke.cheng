import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus

fn eventValid(event: consensus.V3ChainEvent, eventCid: layout.FixedBytes32): bool =
    if !layout.fixedBytes32Equal(eventCid, consensus.v3ChainEventCid(event)):
        return false
    if !layout.fixedBytes32Equal(event.bodyCid, consensus.v3ChainEventBodyCid(event)):
        return false
    return true

fn localProbe(index: var consensus.V3ChainIndex,
              event: consensus.V3ChainEvent,
              eventCid: layout.FixedBytes32): int32 =
    assert(index.accountIds.buffer == nil, "v3 consensus precall probe: pre buffer")
    assert(index.accountIds.cap == 0, "v3 consensus precall probe: pre cap")
    assert(index.accountIds.len == 0, "v3 consensus precall probe: pre len")
    assert(eventValid(event, eventCid), "v3 consensus precall probe: valid")
    assert(index.accountIds.buffer == nil, "v3 consensus precall probe: post buffer")
    assert(index.accountIds.cap == 0, "v3 consensus precall probe: post cap")
    assert(index.accountIds.len == 0, "v3 consensus precall probe: post len")
    return 0

fn main(): int32 =
    var index = consensus.v3ChainIndexZero()
    let zeroCid = layout.fixedBytes32Zero()
    let event = consensus.v3ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let eventCid = consensus.v3ChainEventCid(event)
    let rc = localProbe(index, event, eventCid)
    assert(rc == 0, "v3 consensus precall probe: rc")
    echo("v3 consensus_precall_probe_smoke ok")
    return 0
