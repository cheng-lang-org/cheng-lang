import std/system
import cheng/v3/chain/consensus

fn main(): int32 =
    var index = consensus.v3ChainIndexZero()
    let pos = consensus.v3ConsensusEnsureAccount(index, 7, 1001)
    assert(pos == 0, "v3 consensus ensure: pos")
    assert(index.accountAssetIds.len == 1, "v3 consensus ensure: asset len")
    assert(index.accountIds.len == 1, "v3 consensus ensure: account len")
    assert(index.accountHeads.len == 1, "v3 consensus ensure: heads len")
    assert(index.balances.len == 1, "v3 consensus ensure: balances len")
    assert(index.clockEpochs.len == 1, "v3 consensus ensure: epochs len")
    assert(index.clockGanzhi.len == 1, "v3 consensus ensure: ganzhi len")
    assert(index.diverged.len == 1, "v3 consensus ensure: diverged len")
    assert(index.accountAssetIds[0] == 7, "v3 consensus ensure: asset")
    assert(index.accountIds[0] == 1001, "v3 consensus ensure: account")
    assert(index.balances[0] == int64(0), "v3 consensus ensure: balance")
    assert(!index.diverged[0], "v3 consensus ensure: diverged")
    echo("v3 consensus_ensure_account_smoke ok")
    return 0
