import std/system
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus

fn localApply(index: var consensus.V3ChainIndex,
              event: consensus.V3ChainEvent,
              eventCid: layout.FixedBytes32,
              logOffset: int32): Result[consensus.V3ConsensusDecision] =
    var out = consensus.v3ConsensusDecisionZero()
    out.eventCid = eventCid
    assert(layout.fixedBytes32Equal(eventCid, consensus.v3ChainEventCid(event)),
           "v3 consensus event validate wrapper: cid")
    assert(layout.fixedBytes32Equal(event.bodyCid, consensus.v3ChainEventBodyCid(event)),
           "v3 consensus event validate wrapper: body")
    consensus.v3ConsensusApplyMint(index, event, eventCid, logOffset, out)
    assert(index.accountIds.buffer != nil, "v3 consensus event validate wrapper: inner account buffer")
    assert(index.accountIds.cap >= 1, "v3 consensus event validate wrapper: inner account cap")
    assert(index.accountIds.len == 1, "v3 consensus event validate wrapper: inner account len")
    return Ok[consensus.V3ConsensusDecision](out)

fn main(): int32 =
    var index = consensus.v3ChainIndexZero()
    let zeroCid = layout.fixedBytes32Zero()
    let event = consensus.v3ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let eventCid = consensus.v3ChainEventCid(event)
    let applyRes = localApply(index, event, eventCid, 0)
    assert(IsOk(applyRes), "v3 consensus event validate wrapper: ok")
    let decision = Value(applyRes)
    assert(decision.accepted, "v3 consensus event validate wrapper: accepted")
    assert(decision.applied, "v3 consensus event validate wrapper: applied")
    assert(index.accountIds.buffer != nil, "v3 consensus event validate wrapper: account buffer")
    assert(index.accountIds.cap >= 1, "v3 consensus event validate wrapper: account cap")
    assert(index.accountIds.len == 1, "v3 consensus event validate wrapper: account len")
    echo("v3 consensus_event_validate_wrapper_smoke ok")
    return 0
