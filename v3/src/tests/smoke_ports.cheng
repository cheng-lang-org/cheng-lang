import std/os

fn v3SmokeLabelPort(basePort: int32): int32 =
    let label: str = os.GetEnvDefault("CHENG_V3_SMOKE_LABEL", "host")
    let isHost = label.len == 4 &&
                 label[0] == 'h' &&
                 label[1] == 'o' &&
                 label[2] == 's' &&
                 label[3] == 't'
    if isHost:
        return basePort
    var first: int32 = 0
    var last: int32 = 0
    if label.len > 0:
        first = int32(label[0]) & 255
        last = int32(label[label.len - 1]) & 255
    let offset = ((label.len * 17) + (first % 19) + ((last % 23) * 3)) % 1000
    return basePort + offset
