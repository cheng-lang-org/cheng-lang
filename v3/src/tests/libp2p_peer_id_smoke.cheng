import std/system
import std/strings
import std/rawbytes
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peer_id

fn main(): int32 =
    let knownRaw = bytesAlloc(38)
    for i in 0..<38:
        bytesSet(knownRaw, i, 0)
    bytesSet(knownRaw, 1, 36)
    bytesSet(knownRaw, 2, 0x08)
    bytesSet(knownRaw, 3, 0x01)
    bytesSet(knownRaw, 4, 0x12)
    bytesSet(knownRaw, 5, 0x20)
    assert(peer_id.v3Libp2pEncodeBase58(knownRaw) ==
           "12D3KooW9pNAk8aiBuGVQtWRdbkLmo5qVL3e2h5UxbN2Nz9ttwiw",
           "v3 libp2p peer id: known raw text")
    let knownDecodeRes = peer_id.v3Libp2pDecodeBase58("12D3KooW9pNAk8aiBuGVQtWRdbkLmo5qVL3e2h5UxbN2Nz9ttwiw")
    assert(IsOk(knownDecodeRes), "v3 libp2p peer id: known decode")
    let knownDecoded = Value(knownDecodeRes)
    assert(bytesLen(knownDecoded) == 38, "v3 libp2p peer id: known decode size")
    assert(bytesGet(knownDecoded, 0) == 0 &&
           bytesGet(knownDecoded, 1) == 36 &&
           bytesGet(knownDecoded, 2) == 0x08 &&
           bytesGet(knownDecoded, 3) == 0x01 &&
           bytesGet(knownDecoded, 4) == 0x12 &&
           bytesGet(knownDecoded, 5) == 0x20,
           "v3 libp2p peer id: known decode header")
    var peerA: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(peerA, "alice")
    var peerB: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(peerB, "bob")
    assert(!types.v3Libp2pPeerIdEqual(peerA, peerB), "v3 libp2p peer id: distinct")
    assert(peer_id.v3Libp2pPeerIdDistance(peerA, peerB) > int64(0), "v3 libp2p peer id: distance")
    let peerABytes = peer_id.v3Libp2pPeerIdBytes(peerA.value)
    assert(bytesGet(peerABytes, 0) == 0, "v3 libp2p peer id: identity code")
    assert(bytesGet(peerABytes, 1) == 36, "v3 libp2p peer id: proto size")
    assert(bytesGet(peerABytes, 2) == 0x08 &&
           bytesGet(peerABytes, 3) == 0x01 &&
           bytesGet(peerABytes, 4) == 0x12 &&
           bytesGet(peerABytes, 5) == 0x20,
           "v3 libp2p peer id: protobuf header")
    let peerAText = peer_id.v3Libp2pPeerIdText(peerA)
    assert(strings.hasPrefix(peerAText, "12D3Koo"), "v3 libp2p peer id: standard text")
    let peerDecodeRes = peer_id.v3Libp2pDecodeBase58(peerAText)
    assert(IsOk(peerDecodeRes), "v3 libp2p peer id: peer decode")
    let peerDecoded = Value(peerDecodeRes)
    assert(bytesLen(peerDecoded) == 38, "v3 libp2p peer id: peer decode size")
    assert(bytesGet(peerDecoded, 0) == 0 &&
           bytesGet(peerDecoded, 1) == 36 &&
           bytesGet(peerDecoded, 2) == 0x08 &&
           bytesGet(peerDecoded, 3) == 0x01 &&
           bytesGet(peerDecoded, 4) == 0x12 &&
           bytesGet(peerDecoded, 5) == 0x20,
           "v3 libp2p peer id: peer decode header")
    let peerPubRes = peer_id.v3Libp2pPeerPublicKeyFromPeerIdBytes(peerDecoded)
    assert(IsOk(peerPubRes), "v3 libp2p peer id: peer decode pubkey")
    let roundtripRes = peer_id.v3Libp2pPeerIdFromText(peerAText)
    assert(IsOk(roundtripRes), "v3 libp2p peer id: parse text")
    assert(types.v3Libp2pPeerIdEqual(Value(roundtripRes), peerA), "v3 libp2p peer id: roundtrip")
    echo("v3 libp2p_peer_id_smoke ok")
    return 0
