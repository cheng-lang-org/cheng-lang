import std/os
import std/result
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/runtime_program_obj as runtimeobj

fn main(): int32 =
    let root = os.GetCurrentDir()
    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_runtime_program_combined_negative_smoke")
    assert(v3path.V3MkdirP(root, outDir), "v3 runtime program combined negative: mkdir")

    let runtimeObj = runtimeobj.v3RuntimeProgramCombinedPath(root, "")
    let runtimeBak = runtimeObj + ".runtime_program_combined_negative_smoke.bak"
    let splitObj = v3path.V3PathAbsolute(root,
                                         "chengcache/runtime_selflink/probe_split/system_helpers_program_runtime_bridge.o")
    let splitBak = splitObj + ".runtime_program_combined_negative_smoke.bak"
    let materializeLog = v3path.V3PathJoin(outDir, "materialize.log")
    assert(len(runtimeObj) > 0, "v3 runtime program combined negative: runtime path")
    assert(v3path.V3PathFileExists(splitObj),
           "v3 runtime program combined negative: split runtime exists")

    if v3path.V3PathFileExists(runtimeBak):
        assert(os.RemoveFile(runtimeBak), "v3 runtime program combined negative: stale runtime backup removed")
    if v3path.V3PathFileExists(splitBak):
        assert(os.RemoveFile(splitBak), "v3 runtime program combined negative: stale split backup removed")

    var hadRuntimeBackup: bool = false
    if v3path.V3PathFileExists(runtimeObj):
        assert(os.RenameFile(runtimeObj, runtimeBak), "v3 runtime program combined negative: runtime backup")
        hadRuntimeBackup = true
    assert(os.RenameFile(splitObj, splitBak), "v3 runtime program combined negative: split backup")

    let materializeRes = runtimeobj.v3RuntimeProgramMaterialize(root, "", materializeLog)
    var materializeErr = ""
    if IsErr(materializeRes):
        materializeErr = Error(materializeRes)

    assert(os.RenameFile(splitBak, splitObj), "v3 runtime program combined negative: restore split runtime")
    if hadRuntimeBackup:
        if v3path.V3PathFileExists(runtimeObj):
            assert(os.RemoveFile(runtimeObj), "v3 runtime program combined negative: remove generated runtime")
        assert(os.RenameFile(runtimeBak, runtimeObj), "v3 runtime program combined negative: restore runtime backup")
    else:
        if v3path.V3PathFileExists(runtimeObj):
            assert(os.RemoveFile(runtimeObj), "v3 runtime program combined negative: remove unexpected runtime")

    assert(IsErr(materializeRes),
           "v3 runtime program combined negative: missing split runtime rejected")
    assert(v3path.V3TextContains(materializeErr, splitObj),
           "v3 runtime program combined negative: missing split path diagnostic")
    echo("v3 runtime_program_combined_negative_smoke ok")
    return 0
