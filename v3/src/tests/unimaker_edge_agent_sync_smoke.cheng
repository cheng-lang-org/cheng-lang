import std/os as os
import std/strings as strings
import cheng/v3/tooling/path as v3path
import cheng/v3/std/bytes_layout as layout
import cheng/v3/project/unimaker_edge_types as types
import cheng/v3/project/unimaker_edge_agent as agent

fn unimakerSyncCleanup(tmpRoot: str) =
    let aStore = os.JoinPath(tmpRoot, "a.did")
    let bStore = os.JoinPath(tmpRoot, "b.did")
    let aLog = os.JoinPath(tmpRoot, "a.events.jsonl")
    let bLog = os.JoinPath(tmpRoot, "b.events.jsonl")
    let aLogTmp = aLog + ".tmp"
    let bLogTmp = bLog + ".tmp"
    if os.FileExists(aStore):
        let _ = os.RemoveFile(aStore)
    if os.FileExists(bStore):
        let _ = os.RemoveFile(bStore)
    if os.FileExists(aLog):
        let _ = os.RemoveFile(aLog)
    if os.FileExists(bLog):
        let _ = os.RemoveFile(bLog)
    if os.FileExists(aLogTmp):
        let _ = os.RemoveFile(aLogTmp)
    if os.FileExists(bLogTmp):
        let _ = os.RemoveFile(bLogTmp)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

fn main(): int32 =
    let tmpRoot = "artifacts/v3_unimaker_edge_agent_sync_smoke"
    unimakerSyncCleanup(tmpRoot)
    os.CreateDir(tmpRoot)

    var cfgA = types.V3UnimakerAgentConfig()
    cfgA.rootDir = v3path.V3PathCurrentDir()
    cfgA.eventLogPath = os.JoinPath(tmpRoot, "a.events.jsonl")
    cfgA.identityStorePath = os.JoinPath(tmpRoot, "a.did")
    cfgA.rootSeedHint = "sync.root.seed"
    cfgA.deviceSeedHint = "sync.phone.a"
    cfgA.deviceLabelHint = "phone-a"
    cfgA.epochSeconds = int64(1711000000)

    var cfgB = types.V3UnimakerAgentConfig()
    cfgB.rootDir = v3path.V3PathCurrentDir()
    cfgB.eventLogPath = os.JoinPath(tmpRoot, "b.events.jsonl")
    cfgB.identityStorePath = os.JoinPath(tmpRoot, "b.did")
    cfgB.rootSeedHint = "sync.root.seed"
    cfgB.deviceSeedHint = "sync.phone.b"
    cfgB.deviceLabelHint = "phone-b"
    cfgB.epochSeconds = int64(1711000000)

    var edgeA = agent.v3UnimakerAgentInit(cfgA)
    var edgeB = agent.v3UnimakerAgentInit(cfgB)

    var prevCid = layout.FixedBytes32()
    var i: int32
    while i < 100:
        var parents: layout.FixedBytes32[]
        if i > 0:
            add(parents, prevCid)
        let event = types.v3UnimakerEventMake(types.v3UnimakerEventUserInput,
                                              "task.sync",
                                              "sync observation " + strings.IntToStr(i),
                                              ["sync", "batch"],
                                              parents,
                                              types.v3UnimakerEdgeKindCausedBy,
                                              int64(1711000001 + i))
        let ingestRes = agent.v3UnimakerAgentIngest(edgeA, event)
        assert(IsOk(ingestRes), "v3 unimaker sync: ingest a")
        prevCid = Value(ingestRes).capsuleCid
        i = i + 1
    assert(agent.v3UnimakerAgentCapsuleCount(edgeA) == 100, "v3 unimaker sync: edgeA count")

    var peerAB = types.V3UnimakerSyncPeer()
    peerAB.peerIdText = edgeB.identity.peerIdText
    peerAB.transportKind = types.v3UnimakerTransportLibp2pReqResp
    peerAB.trusted = true

    var peerBA = types.V3UnimakerSyncPeer()
    peerBA.peerIdText = edgeA.identity.peerIdText
    peerBA.transportKind = types.v3UnimakerTransportLibp2pReqResp
    peerBA.trusted = true

    let pushABRes = agent.v3UnimakerAgentSyncPush(edgeA, peerAB)
    assert(IsOk(pushABRes), "v3 unimaker sync: push ab")
    assert(Value(pushABRes).pushedCount == 100, "v3 unimaker sync: push ab count")
    peerBA.inboundPushPayload = peerAB.outboundPushPayload
    let pullBARes = agent.v3UnimakerAgentSyncPull(edgeB, peerBA, types.V3SyncCursor())
    assert(IsOk(pullBARes), "v3 unimaker sync: pull ba")
    assert(Value(pullBARes).mergedCount == 100, "v3 unimaker sync: pull ba merged")
    assert(agent.v3UnimakerAgentCapsuleCount(edgeB) == 100, "v3 unimaker sync: edgeB count")

    let secondPushABRes = agent.v3UnimakerAgentSyncPush(edgeA, peerAB)
    assert(IsOk(secondPushABRes), "v3 unimaker sync: second push ab")
    assert(Value(secondPushABRes).pushedCount == 0, "v3 unimaker sync: second push no resend")

    let confirmEvent = types.v3UnimakerEventMake(types.v3UnimakerEventToolResult,
                                                 "task.sync",
                                                 "confirmed 100 synced observations",
                                                 ["sync", "confirmed"],
                                                 [prevCid],
                                                 types.v3UnimakerEdgeKindRefines,
                                                 int64(1711000500))
    let confirmRes = agent.v3UnimakerAgentIngest(edgeB, confirmEvent)
    assert(IsOk(confirmRes), "v3 unimaker sync: ingest b confirm")
    peerBA.remoteCursor = Value(pushABRes).cursor
    let pushBARes = agent.v3UnimakerAgentSyncPush(edgeB, peerBA)
    assert(IsOk(pushBARes), "v3 unimaker sync: push ba")
    assert(Value(pushBARes).pushedCount == 1, "v3 unimaker sync: push ba incremental")
    peerAB.inboundPushPayload = peerBA.outboundPushPayload
    let pullABRes = agent.v3UnimakerAgentSyncPull(edgeA, peerAB, Value(secondPushABRes).cursor)
    assert(IsOk(pullABRes), "v3 unimaker sync: pull ab")
    assert(Value(pullABRes).mergedCount == 1, "v3 unimaker sync: pull ab merged")

    assert(agent.v3UnimakerAgentCapsuleCount(edgeA) == 101, "v3 unimaker sync: edgeA final count")
    assert(agent.v3UnimakerAgentCapsuleCount(edgeB) == 101, "v3 unimaker sync: edgeB final count")
    assert(layout.fixedBytes32Equal(agent.v3UnimakerAgentHeadCid(edgeA),
                                    agent.v3UnimakerAgentHeadCid(edgeB)),
        "v3 unimaker sync: converged head")

    var query = types.V3MemoryQuery()
    query.keyword = "confirmed"
    query.limit = 8
    let recallRes = agent.v3UnimakerAgentRecall(edgeA, query)
    assert(IsOk(recallRes), "v3 unimaker sync: recall confirmed")
    assert(Value(recallRes).len == 1, "v3 unimaker sync: recall confirmed count")

    unimakerSyncCleanup(tmpRoot)
    echo("v3 unimaker_edge_agent_sync_smoke ok")
    return 0

