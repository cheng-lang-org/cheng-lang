import std/os
import std/result
import std/rawbytes
import std/crypto/rand
import std/strutils as strutil
import cheng/v3/std/bytes_layout as layout
import cheng/v3/project/chain_node as chain
import cheng/v3/project/chain_node_cli_core as cli
import cheng/v3/project/bio_did_chain_node as flow
import cheng/v3/mobile/hardware/biometric
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn chainNodeBioDidLookupCommandSmokeCompilerPath(root: str): str =
    let compilerEnv = os.getEnv("CHENG_V3_SMOKE_COMPILER")
    var compilerRaw = "artifacts/v3_bootstrap/cheng.stage3"
    if len(compilerEnv) > 0:
        compilerRaw = compilerEnv
    return v3path.v3PathAbsolute(root, compilerRaw)

fn chainNodeBioDidLookupCommandSmokeFeature(seed: int32): layout.FixedBytes32 =
    let raw: Bytes = bytesAlloc(32)
    for i in 0..<32:
        bytesSet(raw, i, ((seed * 31) + (i * 19) + 7) & 255)
    let res = layout.fixedBytes32FromBytes(raw)
    assert(IsOk(res), "chain node bio did lookup command smoke: feature build")
    return Value(res)

fn chainNodeBioDidLookupCommandSmokeAttestorPrivHex(): str =
    return "60d71049a0cafe01faa9948dc77ee5bc4bd5e05b8e328fdb9cc4c38237250a05"

fn chainNodeBioDidLookupCommandSmokeAttestorPubKeyHex(): str =
    return "04963c1356849b8478030a6eb572581063ccedf53fda0bc7241247eba977e3b0666e4bf0c12caa47487c2927f83b17d6f9f332481cd2ab0c4885f91fc2a6c547d5"

fn chainNodeBioDidLookupCommandSmokeCapture(feature: layout.FixedBytes32,
                                            bindingSeed: str,
                                            label: str,
                                            requestId: str,
                                            purpose: int32): flow.V3BioDidHardwareCapture =
    var out = flow.v3BioDidHardwareCaptureZero()
    out.verified = true
    out.feature32 = feature
    out.requestId = requestId
    out.sensorId = "sensor|" + bindingSeed
    out.deviceBindingSeed = bindingSeed
    out.deviceLabel = label
    var req = biometric.v3BiometricFingerprintAuthorizeReqZero()
    req.requestId = requestId
    req.purpose = purpose
    req.didText = ""
    req.promptTitle = "chain node bio did lookup command smoke"
    req.promptReason = "chain node bio did lookup command smoke"
    req.deviceBindingSeedHint = bindingSeed
    req.deviceLabelHint = label
    let attestationRes = biometric.v3BiometricFingerprintAttestationBuildSigned(req,
                                                                                feature,
                                                                                bindingSeed,
                                                                                label,
                                                                                out.sensorId,
                                                                                chainNodeBioDidLookupCommandSmokeAttestorPrivHex())
    assert(IsOk(attestationRes), "chain node bio did lookup command smoke: signed attestation")
    out.hardwareAttestation = Value(attestationRes)
    return out

fn chainNodeBioDidLookupCommandSmokeWriteState(statePath: str,
                                               operatorIdHex: var str): bool =
    assert(rand.setRandomSeed(bytesFromString("v3.chain_node.bio.did.lookup.command.seed")),
           "chain node bio did lookup command smoke: seed")
    let trustRes = flow.v3BioDidSetTrustedAttestorRootHex(chainNodeBioDidLookupCommandSmokeAttestorPubKeyHex(),
                                                          biometric.v3BiometricScriptedRootKeyId)
    assert(IsOk(trustRes), "chain node bio did lookup command smoke: trust attestor")
    let operatorIdRes = flow.v3BioDidOperatorIdFromRecoverySecretHex(
        "abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890"
    )
    assert(IsOk(operatorIdRes), "chain node bio did lookup command smoke: operator id")
    let operatorId = Value(operatorIdRes)
    operatorIdHex = layout.fixedBytes32Hex(operatorId)
    var node = chain.v3ChainNodeInit("bio.did.lookup.command.node", "bio.did.lookup.command.addr")
    let createRes = flow.v3BioDidCreateWithHardwareCapture(
        node,
        chainNodeBioDidLookupCommandSmokeCapture(chainNodeBioDidLookupCommandSmokeFeature(11),
                                                 "device.lookup.command.phone",
                                                 "lookup-command-phone",
                                                 "lookup-command-create-1",
                                                 biometric.v3BiometricPurposeDidCreate),
        int64(1000)
    )
    assert(IsOk(createRes), "chain node bio did lookup command smoke: create")
    let create = Value(createRes)
    let anchorRes = flow.v3BioDidChainAppendOperatorBundleAnchor(node,
                                                                 operatorId,
                                                                 create.bundle,
                                                                 "lookup-command-anchor-1")
    assert(IsOk(anchorRes), "chain node bio did lookup command smoke: anchor")
    var servedNode = node
    let snapshot = chain.v3ChainNodeServeOnce(servedNode)
    return cli.v3ChainNodeCliWriteState(statePath, snapshot)

fn main(): int32 =
    let root = os.getCurrentDir()
    let outDir = v3path.v3PathAbsolute(root, "artifacts/v3_chain_node_bio_did_lookup_command_smoke")
    assert(v3path.v3MkdirP(root, outDir), "chain node bio did lookup command smoke: mkdir")
    let compiler = chainNodeBioDidLookupCommandSmokeCompilerPath(root)
    assert(v3path.v3FileExistsNonEmpty(root, compiler),
           "chain node bio did lookup command smoke: compiler exists")
    let exePath = v3path.v3PathJoin(outDir, "chain_node_lookup_smoke_exe")
    let buildLogPath = v3path.v3PathJoin(outDir, "chain_node_lookup_smoke_build.log")
    let statePath = v3path.v3PathJoin(outDir, "chain_node_lookup_smoke.state")
    let hitLogPath = v3path.v3PathJoin(outDir, "chain_node_lookup_smoke_hit.log")
    let missLogPath = v3path.v3PathJoin(outDir, "chain_node_lookup_smoke_miss.log")
    let sourcePath = v3path.v3PathAbsolute(root, "v3/src/project/chain_node_main.cheng")
    let packageRoot = v3path.v3PathAbsolute(root, "v3")
    if v3path.v3PathFileExists(exePath):
        os.removeFile(exePath)
    if v3path.v3PathFileExists(buildLogPath):
        os.removeFile(buildLogPath)
    if v3path.v3PathFileExists(statePath):
        os.removeFile(statePath)
    if v3path.v3PathFileExists(hitLogPath):
        os.removeFile(hitLogPath)
    if v3path.v3PathFileExists(missLogPath):
        os.removeFile(missLogPath)
    var operatorIdHex = ""
    assert(chainNodeBioDidLookupCommandSmokeWriteState(statePath, operatorIdHex),
           "chain node bio did lookup command smoke: write state")
    let buildRun = hostops.v3RunFileLogged(root,
                                           "chain_node_lookup_build",
                                           compiler,
                                           [
                                               "system-link-exec",
                                               "--root",
                                               packageRoot,
                                               "--in",
                                               sourcePath,
                                               "--emit",
                                               "exe",
                                               "--target",
                                               "arm64-apple-darwin",
                                               "--out",
                                               exePath
                                           ],
                                           [],
                                           root,
                                           180,
                                           buildLogPath)
    assert(hostops.v3LoggedRunOk(buildRun),
           "chain node bio did lookup command smoke: build chain_node_main rc")
    let hitRun = hostops.v3RunFileLogged(root,
                                         "chain_node_lookup_hit",
                                         exePath,
                                         [
                                             "bio-did-operator-lookup",
                                             "--state",
                                             statePath,
                                             "--operator-id",
                                             operatorIdHex,
                                             "--preferred-kinds",
                                             flow.v3BioDidOperatorBundleKindAndroidBioV1
                                         ],
                                         [],
                                         root,
                                         30,
                                         hitLogPath)
    assert(hostops.v3LoggedRunOk(hitRun),
           "chain node bio did lookup command smoke: lookup hit rc")
    assert(strutil.contains(hitRun.output, "\"found\":true"),
           "chain node bio did lookup command smoke: lookup hit found")
    assert(strutil.contains(hitRun.output, "\"operatorId\":\"" + operatorIdHex + "\""),
           "chain node bio did lookup command smoke: lookup hit operator")
    assert(strutil.contains(hitRun.output, "\"bundleSeq\":1"),
           "chain node bio did lookup command smoke: lookup hit seq")
    assert(strutil.contains(hitRun.output, "\"bundleKind\":\"android_bio_v1\""),
           "chain node bio did lookup command smoke: lookup hit kind")
    let missRun = hostops.v3RunFileLogged(root,
                                          "chain_node_lookup_miss",
                                          exePath,
                                          [
                                              "bio-did-operator-lookup",
                                              "--state",
                                              statePath,
                                              "--operator-id",
                                              "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff"
                                          ],
                                          [],
                                          root,
                                          30,
                                          missLogPath)
    assert(hostops.v3LoggedRunOk(missRun),
           "chain node bio did lookup command smoke: lookup miss rc")
    assert(strutil.contains(missRun.output, "\"found\":false"),
           "chain node bio did lookup command smoke: lookup miss found")
    echo("v3 chain_node_bio_did_operator_lookup_command_smoke ok")
    return 0
