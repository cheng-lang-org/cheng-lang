import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus

fn localMutate(index: var consensus.V3ChainIndex, eventCid: layout.FixedBytes32): int32 =
    add(index.accountIds, 1001)
    assert(index.accountIds.buffer != nil, "v3 consensus add smoke: buffer")
    assert(index.accountIds.len == 1, "v3 consensus add smoke: len")
    assert(index.accountIds.cap >= 1, "v3 consensus add smoke: cap")
    return 0

fn main(): int32 =
    var index = consensus.V3ChainIndex()
    let eventCid = layout.FixedBytes32()
    let rc = localMutate(index, eventCid)
    assert(rc == 0, "v3 consensus add smoke: rc")
    echo("v3 consensus_add_smoke ok")
    return 0
