import std/system
import std/result
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/transports/quic_transport

fn main(): int32 =
    var listenAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillQuic(listenAddr, "127.0.0.1", 0)
    assert(quic_transport.v3Libp2pQuicTransportSupportsAddr(listenAddr),
        "v3 quic transport loopback: supports")
    var pair: quic_transport.V3Libp2pQuicLoopbackPair
    let openRes = quic_transport.v3Libp2pQuicLoopbackOpenInto(pair, listenAddr)
    if IsErr(openRes):
        let msg: str = ErrorText(openRes)
        panic(msg)
    quic_transport.v3Libp2pQuicLoopbackClose(pair)
    echo("v3 quic_transport_loopback_smoke ok")
    return 0
