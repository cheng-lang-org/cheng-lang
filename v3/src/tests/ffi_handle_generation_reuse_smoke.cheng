import std/system

const
    probeHandleSlotMod: uint64 = 4294967296

@importc("cheng_ffi_raw_new_i32")
fn cheng_ffi_raw_new_i32(value: int32): ptr

@importc("cheng_ffi_raw_get_i32")
fn cheng_ffi_raw_get_i32(p: ptr): int32

@importc("cheng_v3_tcp_buffer_handle_register_bridge")
fn cheng_v3_tcp_buffer_handle_register_bridge(raw: ptr): uint64

@importc("cheng_v3_tcp_buffer_handle_resolve_bridge")
fn cheng_v3_tcp_buffer_handle_resolve_bridge(handle: uint64): ptr

@importc("cheng_v3_tcp_buffer_handle_release_raw_bridge")
fn cheng_v3_tcp_buffer_handle_release_raw_bridge(handle: uint64): int32

fn handleSlot(handle: uint64): uint64 =
    return handle % probeHandleSlotMod

fn handleGeneration(handle: uint64): uint64 =
    return handle / probeHandleSlotMod

fn main(): int32 =
    let allocBefore: int64 = memAllocCount()
    let freeBefore: int64 = memFreeCount()
    let liveBefore: int64 = memLiveCount()

    let raw0: ptr = cheng_ffi_raw_new_i32(40)
    assert(raw0 != nil, "v3 ffi handle generation reuse: raw0 alloc")
    let handle0: uint64 = cheng_v3_tcp_buffer_handle_register_bridge(raw0)
    assert(handle0 != uint64(0), "v3 ffi handle generation reuse: handle0 create")
    let resolved0: ptr = cheng_v3_tcp_buffer_handle_resolve_bridge(handle0)
    assert(resolved0 == raw0, "v3 ffi handle generation reuse: handle0 resolve")
    assert(cheng_ffi_raw_get_i32(resolved0) == 40, "v3 ffi handle generation reuse: handle0 value")
    let slot0: uint64 = handleSlot(handle0)
    let generation0: uint64 = handleGeneration(handle0)
    assert(slot0 != uint64(0), "v3 ffi handle generation reuse: handle0 slot")
    assert(generation0 != uint64(0), "v3 ffi handle generation reuse: handle0 generation")

    assert(cheng_v3_tcp_buffer_handle_release_raw_bridge(handle0) == 0,
           "v3 ffi handle generation reuse: handle0 release")

    let raw1: ptr = cheng_ffi_raw_new_i32(7)
    assert(raw1 != nil, "v3 ffi handle generation reuse: raw1 alloc")
    let handle1: uint64 = cheng_v3_tcp_buffer_handle_register_bridge(raw1)
    assert(handle1 != uint64(0), "v3 ffi handle generation reuse: handle1 create")
    assert(handle1 != handle0, "v3 ffi handle generation reuse: handle changes after release")
    let resolved1: ptr = cheng_v3_tcp_buffer_handle_resolve_bridge(handle1)
    assert(resolved1 == raw1, "v3 ffi handle generation reuse: handle1 resolve")
    assert(cheng_ffi_raw_get_i32(resolved1) == 7, "v3 ffi handle generation reuse: handle1 value")
    let slot1: uint64 = handleSlot(handle1)
    let generation1: uint64 = handleGeneration(handle1)
    assert(slot1 == slot0, "v3 ffi handle generation reuse: slot reused")
    assert(generation1 == generation0 + uint64(1),
           "v3 ffi handle generation reuse: generation bumped")

    assert(cheng_v3_tcp_buffer_handle_release_raw_bridge(handle1) == 0,
           "v3 ffi handle generation reuse: handle1 release")

    let allocDelta: int64 = memAllocCount() - allocBefore
    let freeDelta: int64 = memFreeCount() - freeBefore
    let liveDelta: int64 = memLiveCount() - liveBefore
    assert(allocDelta == freeDelta, "v3 ffi handle generation reuse: alloc/free balanced")
    assert(liveDelta == 0, "v3 ffi handle generation reuse: live delta zero")

    echo("v3 ffi_handle_generation_reuse_smoke ok")
    return 0
