import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/backend/lowering_plan as lower
import cheng/v3/libp2p/browser/browser_content_codec_rule_schema as browsercodec

fn main(): int32 =
    let workspaceRoot = "/Users/lbcheng/cheng-lang"
    let packageRoot = "/Users/lbcheng/cheng-lang/v3"
    let browserCodecPath = "/Users/lbcheng/cheng-lang/v3/src/libp2p/browser/browser_content_codec_abi.cheng"
    let browserFixturePath = "/Users/lbcheng/cheng-lang/v3/src/tests/browser_host_native_min_smoke.cheng"
    var linkPlan: slplan.V3SystemLinkPlanStub
    linkPlan.workspaceRoot = workspaceRoot
    linkPlan.packageRoot = packageRoot
    linkPlan.sourceClosurePaths = [
        browserFixturePath,
        browserCodecPath
    ]
    let compilerRules = ccsg.v3CompilerBrowserAbiRulesForLinkPlan(linkPlan)
    let loweringRules = lower.v3LoweringPlanBrowserAbiRules(linkPlan)
    let compilerSourceRules = ccsg.v3BrowserAbiRulesForSource(compilerRules, browserCodecPath)
    let loweringSourceRules = lower.v3LoweringPlanBrowserAbiRulesForSource(linkPlan, browserCodecPath)
    let schemaRules = browsercodec.v3BrowserContentCodecRules(browserCodecPath)
    assert(compilerRules.len == 8, "v3 browser abi rule: compiler rule count")
    assert(ccsg.v3BrowserAbiRulesEqual(compilerRules, loweringRules),
           "v3 browser abi rule: compiler lowering equality")
    assert(ccsg.v3BrowserAbiRulesEqual(compilerSourceRules, loweringSourceRules),
           "v3 browser abi rule: source slice equality")
    assert(ccsg.v3BrowserAbiRulesEqual(compilerSourceRules, schemaRules),
           "v3 browser abi rule: source slice schema equality")
    assert(ccsg.v3BrowserAbiRuleUniqueKeyCount(compilerSourceRules) == compilerSourceRules.len,
           "v3 browser abi rule: unique key count")
    assert(ccsg.v3BrowserAbiRuleCountInputKind(compilerSourceRules, "bytes_required") == 1,
           "v3 browser abi rule: bytes input")
    assert(ccsg.v3BrowserAbiRuleCountInputKind(compilerSourceRules, "text_required") == 1,
           "v3 browser abi rule: text input")
    assert(ccsg.v3BrowserAbiRuleCountInputKind(compilerSourceRules, "text_optional") == 1,
           "v3 browser abi rule: optional text input")
    assert(ccsg.v3BrowserAbiRuleCountErrorKind(compilerSourceRules, "moq_fountain_last_error") == 3,
           "v3 browser abi rule: error channel")
    assert(ccsg.v3BrowserAbiRuleCountResultKind(compilerSourceRules, "status_i32") == 2,
           "v3 browser abi rule: status result")
    assert(ccsg.v3BrowserAbiRuleHasRuleName(compilerSourceRules, "export_moq_fountain_bytes_result"),
           "v3 browser abi rule: moq bytes export rule")
    assert(ccsg.v3BrowserAbiRuleHasRuleName(compilerSourceRules, "export_moq_fountain_text_result"),
           "v3 browser abi rule: moq text export rule")
    assert(ccsg.v3BrowserAbiRuleHasRuleName(compilerSourceRules, "moq_fountain_last_error_handle"),
           "v3 browser abi rule: moq error handle rule")
    assert(ccsg.v3BrowserAbiRuleCountOutBufferKind(compilerSourceRules, "raw_handle") == 2,
           "v3 browser abi rule: raw out buffer")
    assert(ccsg.v3BrowserAbiRuleCountOutBufferKind(compilerSourceRules, "text_handle") == 3,
           "v3 browser abi rule: text out buffer")
    echo("v3 browser_abi_rule_smoke ok")
    return 0
