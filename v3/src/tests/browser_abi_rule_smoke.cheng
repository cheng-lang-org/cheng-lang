import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/backend/lowering_plan as lower
import cheng/v3/libp2p/browser/browser_content_codec_codegen as codegen
import cheng/v3/libp2p/browser/browser_content_codec_rule_schema as browsercodec

fn main(): int32 =
    let workspaceRoot = "/Users/lbcheng/cheng-lang"
    let packageRoot = "/Users/lbcheng/cheng-lang/v3"
    let browserCodecPath = "/Users/lbcheng/cheng-lang/v3/src/libp2p/browser/browser_content_codec_abi.cheng"
    let browserFixturePath = "/Users/lbcheng/cheng-lang/v3/src/tests/browser_host_native_min_smoke.cheng"
    var linkPlan: slplan.V3SystemLinkPlanStub
    linkPlan.workspaceRoot = workspaceRoot
    linkPlan.packageRoot = packageRoot
    linkPlan.sourceClosurePaths = [
        browserFixturePath,
        browserCodecPath
    ]
    let compilerRules = ccsg.v3CompilerBrowserAbiRulesForLinkPlan(linkPlan)
    let loweringRules = lower.v3LoweringPlanBrowserAbiRules(linkPlan)
    let compilerSourceRules = ccsg.v3BrowserAbiRulesForSource(compilerRules, browserCodecPath)
    let loweringSourceRules = lower.v3LoweringPlanBrowserAbiRulesForSource(linkPlan, browserCodecPath)
    let schemaRules = browsercodec.v3BrowserContentCodecRules(browserCodecPath)
    let compilerBridgeSpecs = ccsg.v3CompilerBrowserAbiBridgeSpecsForLinkPlan(linkPlan)
    let loweringBridgeSpecs = lower.v3LoweringPlanBrowserAbiBridgeSpecs(linkPlan)
    let compilerSourceBridgeSpecs = ccsg.v3CompilerBrowserAbiBridgeSpecsForSource(linkPlan, browserCodecPath)
    let loweringSourceBridgeSpecs = lower.v3LoweringPlanBrowserAbiBridgeSpecsForSource(linkPlan, browserCodecPath)
    let schemaBridgeSpecs = ccsg.v3BrowserAbiBridgeSpecsFromRules(schemaRules)
    let compilerBridgePlans = ccsg.v3CompilerBrowserAbiBridgePlansForLinkPlan(linkPlan)
    let loweringBridgePlans = lower.v3LoweringPlanBrowserAbiBridgePlans(linkPlan)
    let compilerSourceBridgePlans = ccsg.v3CompilerBrowserAbiBridgePlansForSource(linkPlan, browserCodecPath)
    let loweringSourceBridgePlans = lower.v3LoweringPlanBrowserAbiBridgePlansForSource(linkPlan, browserCodecPath)
    let schemaBridgePlans = ccsg.v3BrowserAbiBridgePlansFromRules(schemaRules)
    let compilerArtifactManifest = ccsg.v3CompilerBrowserAbiBridgeArtifactManifest(linkPlan)
    let loweringArtifactManifest = lower.v3LoweringPlanBrowserAbiBridgeArtifactManifest(linkPlan)
    let schemaArtifactManifest = ccsg.v3BrowserAbiBridgePlanManifestText(schemaBridgePlans)
    let compilerSourceArtifact = ccsg.v3CompilerBrowserAbiBridgeSourceArtifact(linkPlan)
    let loweringSourceArtifact = lower.v3LoweringPlanBrowserAbiBridgeSourceArtifact(linkPlan)
    let schemaSourceArtifact = ccsg.v3BrowserAbiBridgeSourceText(schemaBridgePlans)
    assert(compilerRules.len == 8, "v3 browser abi rule: compiler rule count")
    assert(ccsg.v3BrowserAbiRulesEqual(compilerRules, loweringRules),
           "v3 browser abi rule: compiler lowering equality")
    assert(ccsg.v3BrowserAbiRulesEqual(compilerSourceRules, loweringSourceRules),
           "v3 browser abi rule: source slice equality")
    assert(ccsg.v3BrowserAbiRulesEqual(compilerSourceRules, schemaRules),
           "v3 browser abi rule: source slice schema equality")
    assert(ccsg.v3BrowserAbiRuleUniqueKeyCount(compilerSourceRules) == compilerSourceRules.len,
           "v3 browser abi rule: unique key count")
    assert(ccsg.v3BrowserAbiRuleCountInputKind(compilerSourceRules, "bytes_required") == 1,
           "v3 browser abi rule: bytes input")
    assert(ccsg.v3BrowserAbiRuleCountInputKind(compilerSourceRules, "text_required") == 1,
           "v3 browser abi rule: text input")
    assert(ccsg.v3BrowserAbiRuleCountInputKind(compilerSourceRules, "text_optional") == 1,
           "v3 browser abi rule: optional text input")
    assert(ccsg.v3BrowserAbiRuleCountErrorKind(compilerSourceRules, "moq_fountain_last_error") == 3,
           "v3 browser abi rule: error channel")
    assert(ccsg.v3BrowserAbiRuleCountResultKind(compilerSourceRules, "status_i32") == 2,
           "v3 browser abi rule: status result")
    assert(ccsg.v3BrowserAbiRuleHasRuleName(compilerSourceRules, browsercodec.v3BrowserContentCodecRuleExportMoqFountainBytesResultName()),
           "v3 browser abi rule: moq bytes export rule")
    assert(ccsg.v3BrowserAbiRuleHasRuleName(compilerSourceRules, browsercodec.v3BrowserContentCodecRuleExportMoqFountainTextResultName()),
           "v3 browser abi rule: moq text export rule")
    assert(ccsg.v3BrowserAbiRuleHasRuleName(compilerSourceRules, browsercodec.v3BrowserContentCodecRuleMoqFountainLastErrorHandleName()),
           "v3 browser abi rule: moq error handle rule")
    assert(ccsg.v3BrowserAbiRuleCountOutBufferKind(compilerSourceRules, "raw_handle") == 2,
           "v3 browser abi rule: raw out buffer")
    assert(ccsg.v3BrowserAbiRuleCountOutBufferKind(compilerSourceRules, "text_handle") == 3,
           "v3 browser abi rule: text out buffer")
    assert(ccsg.v3BrowserAbiBridgeSpecsEqual(compilerBridgeSpecs, loweringBridgeSpecs),
           "v3 browser abi bridge: compiler lowering equality")
    assert(ccsg.v3BrowserAbiBridgeSpecsEqual(compilerSourceBridgeSpecs, loweringSourceBridgeSpecs),
           "v3 browser abi bridge: source slice equality")
    assert(ccsg.v3BrowserAbiBridgeSpecsEqual(compilerSourceBridgeSpecs, schemaBridgeSpecs),
           "v3 browser abi bridge: source slice schema equality")
    assert(ccsg.v3BrowserAbiBridgeSpecUniqueKeyCount(compilerSourceBridgeSpecs) == compilerSourceBridgeSpecs.len,
           "v3 browser abi bridge: unique key count")
    assert(ccsg.v3BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, "input_read") == 3,
           "v3 browser abi bridge: input read count")
    assert(ccsg.v3BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, "output_write") == 2,
           "v3 browser abi bridge: output write count")
    assert(ccsg.v3BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, "result_export") == 2,
           "v3 browser abi bridge: export count")
    assert(ccsg.v3BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, "error_handle_read") == 1,
           "v3 browser abi bridge: error handle count")
    assert(ccsg.v3BrowserAbiBridgeSpecCountInputSchemaKind(compilerSourceBridgeSpecs, "bytes_required") == 1,
           "v3 browser abi bridge: bytes input schema")
    assert(ccsg.v3BrowserAbiBridgeSpecCountOutputSchemaKind(compilerSourceBridgeSpecs, "text_handle") == 3,
           "v3 browser abi bridge: text output schema")
    assert(ccsg.v3BrowserAbiBridgeSpecCountErrorSchemaKind(compilerSourceBridgeSpecs, "moq_fountain_last_error") == 3,
           "v3 browser abi bridge: moq error schema")
    assert(ccsg.v3BrowserAbiBridgeHelperName(compilerSourceBridgeSpecs[0]) == "v3_browser_bridge_input_read_input_bytes_required",
           "v3 browser abi bridge: bytes helper name")
    assert(ccsg.v3BrowserAbiBridgeHelperName(compilerSourceBridgeSpecs[6]) == "v3_browser_bridge_result_export_export_moq_fountain_text_result",
           "v3 browser abi bridge: export helper name")
    assert(ccsg.v3BrowserAbiBridgePlansEqual(compilerBridgePlans, loweringBridgePlans),
           "v3 browser abi plan: compiler lowering equality")
    assert(ccsg.v3BrowserAbiBridgePlansEqual(compilerSourceBridgePlans, loweringSourceBridgePlans),
           "v3 browser abi plan: source slice equality")
    assert(ccsg.v3BrowserAbiBridgePlansEqual(compilerSourceBridgePlans, schemaBridgePlans),
           "v3 browser abi plan: source slice schema equality")
    assert(compilerArtifactManifest == loweringArtifactManifest,
           "v3 browser abi artifact: compiler lowering equality")
    assert(compilerArtifactManifest == schemaArtifactManifest,
           "v3 browser abi artifact: schema equality")
    assert(compilerSourceArtifact == loweringSourceArtifact,
           "v3 browser abi source artifact: compiler lowering equality")
    assert(compilerSourceArtifact == schemaSourceArtifact,
           "v3 browser abi source artifact: schema equality")
    assert(ccsg.v3BrowserAbiBridgePlanUniqueKeyCount(compilerSourceBridgePlans) == compilerSourceBridgePlans.len,
           "v3 browser abi plan: unique key count")
    assert(ccsg.v3BrowserAbiBridgePlanCountStage(compilerSourceBridgePlans, "result_export") == 2,
           "v3 browser abi plan: export count")
    assert(ccsg.v3BrowserAbiBridgePlanCountInputSchemaKind(compilerSourceBridgePlans, "bytes_required") == 1,
           "v3 browser abi plan: bytes input schema")
    assert(ccsg.v3BrowserAbiBridgePlanCountOutputSchemaKind(compilerSourceBridgePlans, "text_handle") == 3,
           "v3 browser abi plan: text output schema")
    assert(ccsg.v3BrowserAbiBridgePlanCountErrorSchemaKind(compilerSourceBridgePlans, "moq_fountain_last_error") == 3,
           "v3 browser abi plan: moq error schema")
    assert(ccsg.v3BrowserAbiBridgePlanHelperName(compilerSourceBridgePlans[6]) == "v3_browser_bridge_result_export_export_moq_fountain_text_result",
           "v3 browser abi plan: export helper name")
    assert(codegen.v3BrowserCodecBridgeKeyForRuleName(browsercodec.v3BrowserContentCodecRuleExportMoqFountainTextResultName()) ==
           compilerSourceBridgeSpecs[6].bridgeKey,
           "v3 browser abi bridge: codegen bridge key equality")
    assert(codegen.v3BrowserCodecBridgeEmitLineForSourceRuleName(browserCodecPath,
                                                                 browsercodec.v3BrowserContentCodecRuleExportMoqFountainTextResultName()) ==
           ccsg.v3BrowserAbiBridgePlanEmitLine(compilerSourceBridgePlans[6]),
           "v3 browser abi plan: codegen bridge line equality")
    echo("v3 browser_abi_rule_smoke ok")
    return 0
