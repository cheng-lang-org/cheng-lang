import std/system
import std/times
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peer_id
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/core/peerstore as ps
import cheng/v3/libp2p/core/scheduler
import cheng/v3/libp2p/host/host
import cheng/v3/tests/smoke_ports

fn libp2pSchedulerPeerIdsContain(peerIds: types.V3Libp2pPeerId[],
                                 peerId: types.V3Libp2pPeerId): bool =
    for i in 0..<peerIds.len:
        if types.v3Libp2pPeerIdEqual(peerIds[i], peerId):
            return true
    return false

fn main(): int32 =
    let gib = int64(1024 * 1024 * 1024)
    let now = times.EpochTimeSeconds()
    let cacheCap = ps.v3Libp2pPeerCacheEntryCap

    var cacheRecord: ps.V3Libp2pPeerRecord
    var cacheKeys: str[]
    cacheKeys = []
    add(cacheKeys, "cid://cache.0")
    add(cacheKeys, "cid://cache.1")
    add(cacheKeys, "cid://cache.2")
    add(cacheKeys, "cid://cache.3")
    add(cacheKeys, "cid://cache.4")
    add(cacheKeys, "cid://cache.5")
    add(cacheKeys, "cid://cache.6")
    add(cacheKeys, "cid://cache.7")
    add(cacheKeys, "cid://cache.8")
    add(cacheKeys, "cid://cache.reject")
    assert(cacheCap < cacheKeys.len, "v3 libp2p scheduler: cache key fixture")
    for i in 0..<cacheCap:
        ps.v3Libp2pPeerRecordObserveCache(cacheRecord,
                                          cacheKeys[i],
                                          now - int64((cacheCap - i) * 10))
    assert(cacheRecord.cacheEntries.len == cacheCap, "v3 libp2p scheduler: cache cap fill")
    ps.v3Libp2pPeerRecordObserveCache(cacheRecord, cacheKeys[cacheCap], now)
    assert(cacheRecord.cacheEntries.len == cacheCap, "v3 libp2p scheduler: cache cap stable")
    assert(ps.v3Libp2pPeerRecordCacheEntryPos(cacheRecord, cacheKeys[0]) < 0,
        "v3 libp2p scheduler: cache oldest evicted")
    assert(ps.v3Libp2pPeerRecordCacheEntryPos(cacheRecord, cacheKeys[cacheCap]) >= 0,
        "v3 libp2p scheduler: cache candidate admitted")
    ps.v3Libp2pPeerRecordObserveCache(cacheRecord, cacheKeys[cacheCap - 1], now + 1)
    ps.v3Libp2pPeerRecordObserveCache(cacheRecord, cacheKeys[cacheKeys.len - 1], now - 100000)
    assert(ps.v3Libp2pPeerRecordCacheEntryPos(cacheRecord, cacheKeys[cacheKeys.len - 1]) < 0,
        "v3 libp2p scheduler: cache weak reject")
    assert(ps.v3Libp2pPeerRecordCacheEntryPos(cacheRecord, cacheKeys[cacheCap - 1]) >= 0,
        "v3 libp2p scheduler: cache retained hit")

    var trustedHost = host.v3Libp2pHostInit("scheduler.trusted")
    host.v3Libp2pHostSetTrustedInfra(trustedHost, true)

    var inferPeer: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(inferPeer, "scheduler.infer")
    var inferAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(inferAddr, "127.0.0.1", smoke_ports.v3SmokeLabelPort(6421))
    let inferDialRes = host.v3Libp2pDial(trustedHost,
                                         inferPeer,
                                         inferAddr,
                                         overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(inferDialRes), "v3 libp2p scheduler: infer dial")
    host.v3Libp2pSetPeerTrustedInfra(trustedHost, inferPeer, true)
    var inferSample: types.V3Libp2pNodeResource
    inferSample.sampledAtEpochSeconds = now - 10
    inferSample.cpuLogicalCores = 16
    inferSample.memoryAvailableBytes = 64 * gib
    inferSample.memoryTotalBytes = 64 * gib
    inferSample.diskAvailableBytes = 2 * 1024 * gib
    inferSample.diskTotalBytes = 2 * 1024 * gib
    inferSample.gpuDeviceCount = 1
    inferSample.gpuCoreCount = 256
    host.v3Libp2pObservePeerResources(trustedHost, inferPeer, inferSample)
    let inferPos = ps.v3Libp2pPeerstorePos(trustedHost.peers, inferPeer)
    assert(inferPos >= 0, "v3 libp2p scheduler: infer pos")
    trustedHost.peers.peers[inferPos].trustPermille = 850
    trustedHost.peers.peers[inferPos].loadPermille = 120
    trustedHost.peers.peers[inferPos].rttEwmaMicros = 800
    host.v3Libp2pSetPeerPlacementGroup(trustedHost, inferPeer, "az-a")

    var trainPeer: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(trainPeer, "scheduler.train")
    var trainAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(trainAddr, "127.0.0.1", smoke_ports.v3SmokeLabelPort(6422))
    let trainDialRes = host.v3Libp2pDial(trustedHost,
                                         trainPeer,
                                         trainAddr,
                                         overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(trainDialRes), "v3 libp2p scheduler: train dial")
    host.v3Libp2pSetPeerTrustedInfra(trustedHost, trainPeer, true)
    var trainSample: types.V3Libp2pNodeResource
    trainSample.sampledAtEpochSeconds = now - 10
    trainSample.cpuLogicalCores = 48
    trainSample.memoryAvailableBytes = 256 * gib
    trainSample.memoryTotalBytes = 256 * gib
    trainSample.diskAvailableBytes = 8 * 1024 * gib
    trainSample.diskTotalBytes = 8 * 1024 * gib
    trainSample.gpuDeviceCount = 4
    trainSample.gpuCoreCount = 2048
    trainSample.npuDeviceCount = 1
    trainSample.npuCoreCount = 1024
    host.v3Libp2pObservePeerResources(trustedHost, trainPeer, trainSample)
    let trainPos = ps.v3Libp2pPeerstorePos(trustedHost.peers, trainPeer)
    assert(trainPos >= 0, "v3 libp2p scheduler: train pos")
    trustedHost.peers.peers[trainPos].trustPermille = 920
    trustedHost.peers.peers[trainPos].loadPermille = 180
    trustedHost.peers.peers[trainPos].rttEwmaMicros = 1600
    host.v3Libp2pSetPeerPlacementGroup(trustedHost, trainPeer, "az-c")

    var cpuPeer: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(cpuPeer, "scheduler.cpu")
    var cpuAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(cpuAddr, "127.0.0.1", smoke_ports.v3SmokeLabelPort(6423))
    let cpuDialRes = host.v3Libp2pDial(trustedHost,
                                       cpuPeer,
                                       cpuAddr,
                                       overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(cpuDialRes), "v3 libp2p scheduler: cpu dial")
    host.v3Libp2pSetPeerTrustedInfra(trustedHost, cpuPeer, true)
    var cpuSample: types.V3Libp2pNodeResource
    cpuSample.sampledAtEpochSeconds = now - 10
    cpuSample.cpuLogicalCores = 12
    cpuSample.memoryAvailableBytes = 24 * gib
    cpuSample.memoryTotalBytes = 24 * gib
    cpuSample.diskAvailableBytes = 512 * gib
    cpuSample.diskTotalBytes = 512 * gib
    host.v3Libp2pObservePeerResources(trustedHost, cpuPeer, cpuSample)
    let cpuPos = ps.v3Libp2pPeerstorePos(trustedHost.peers, cpuPeer)
    assert(cpuPos >= 0, "v3 libp2p scheduler: cpu pos")
    trustedHost.peers.peers[cpuPos].trustPermille = 700
    trustedHost.peers.peers[cpuPos].loadPermille = 40
    trustedHost.peers.peers[cpuPos].rttEwmaMicros = 600
    host.v3Libp2pSetPeerPlacementGroup(trustedHost, cpuPeer, "az-cpu")

    var stalePeer: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(stalePeer, "scheduler.stale")
    var staleAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(staleAddr, "127.0.0.1", smoke_ports.v3SmokeLabelPort(6424))
    let staleDialRes = host.v3Libp2pDial(trustedHost,
                                         stalePeer,
                                         staleAddr,
                                         overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(staleDialRes), "v3 libp2p scheduler: stale dial")
    host.v3Libp2pSetPeerTrustedInfra(trustedHost, stalePeer, true)
    var staleSample: types.V3Libp2pNodeResource
    staleSample.sampledAtEpochSeconds = now - 7200
    staleSample.cpuLogicalCores = 64
    staleSample.memoryAvailableBytes = 512 * gib
    staleSample.memoryTotalBytes = 512 * gib
    staleSample.diskAvailableBytes = 16 * 1024 * gib
    staleSample.diskTotalBytes = 16 * 1024 * gib
    staleSample.gpuDeviceCount = 8
    staleSample.gpuCoreCount = 4096
    staleSample.npuDeviceCount = 2
    staleSample.npuCoreCount = 2048
    host.v3Libp2pObservePeerResources(trustedHost, stalePeer, staleSample)
    let stalePos = ps.v3Libp2pPeerstorePos(trustedHost.peers, stalePeer)
    assert(stalePos >= 0, "v3 libp2p scheduler: stale pos")
    trustedHost.peers.peers[stalePos].trustPermille = 990
    trustedHost.peers.peers[stalePos].loadPermille = 10
    trustedHost.peers.peers[stalePos].rttEwmaMicros = 300

    var hiddenPeer: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(hiddenPeer, "scheduler.hidden")
    var hiddenAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(hiddenAddr, "127.0.0.1", smoke_ports.v3SmokeLabelPort(6425))
    let hiddenDialRes = host.v3Libp2pDial(trustedHost,
                                          hiddenPeer,
                                          hiddenAddr,
                                          overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(hiddenDialRes), "v3 libp2p scheduler: hidden dial")
    host.v3Libp2pSetPeerTrustedInfra(trustedHost, hiddenPeer, false)
    var hiddenSample: types.V3Libp2pNodeResource
    hiddenSample.sampledAtEpochSeconds = now - 10
    hiddenSample.cpuLogicalCores = 128
    hiddenSample.memoryAvailableBytes = 1024 * gib
    hiddenSample.memoryTotalBytes = 1024 * gib
    hiddenSample.diskAvailableBytes = 32 * 1024 * gib
    hiddenSample.diskTotalBytes = 32 * 1024 * gib
    hiddenSample.gpuDeviceCount = 16
    hiddenSample.gpuCoreCount = 8192
    hiddenSample.npuDeviceCount = 4
    hiddenSample.npuCoreCount = 4096
    host.v3Libp2pObservePeerResources(trustedHost, hiddenPeer, hiddenSample)
    let hiddenPos = ps.v3Libp2pPeerstorePos(trustedHost.peers, hiddenPeer)
    assert(hiddenPos >= 0, "v3 libp2p scheduler: hidden pos")
    trustedHost.peers.peers[hiddenPos].trustPermille = 1000
    trustedHost.peers.peers[hiddenPos].loadPermille = 5
    trustedHost.peers.peers[hiddenPos].rttEwmaMicros = 100

    var inferReplicaPeer: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(inferReplicaPeer, "scheduler.infer.replica")
    var inferReplicaAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(inferReplicaAddr, "127.0.0.1", smoke_ports.v3SmokeLabelPort(6426))
    let inferReplicaDialRes = host.v3Libp2pDial(trustedHost,
                                                inferReplicaPeer,
                                                inferReplicaAddr,
                                                overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(inferReplicaDialRes), "v3 libp2p scheduler: infer replica dial")
    host.v3Libp2pSetPeerTrustedInfra(trustedHost, inferReplicaPeer, true)
    host.v3Libp2pObservePeerResources(trustedHost, inferReplicaPeer, inferSample)
    let inferReplicaPos = ps.v3Libp2pPeerstorePos(trustedHost.peers, inferReplicaPeer)
    assert(inferReplicaPos >= 0, "v3 libp2p scheduler: infer replica pos")
    trustedHost.peers.peers[inferReplicaPos].trustPermille = 830
    trustedHost.peers.peers[inferReplicaPos].loadPermille = 170
    trustedHost.peers.peers[inferReplicaPos].rttEwmaMicros = 900
    host.v3Libp2pSetPeerPlacementGroup(trustedHost, inferReplicaPeer, "az-a")

    var inferAffinityPeer: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(inferAffinityPeer, "scheduler.infer.affinity")
    var inferAffinityAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(inferAffinityAddr, "127.0.0.1", smoke_ports.v3SmokeLabelPort(6427))
    let inferAffinityDialRes = host.v3Libp2pDial(trustedHost,
                                                 inferAffinityPeer,
                                                 inferAffinityAddr,
                                                 overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(inferAffinityDialRes), "v3 libp2p scheduler: infer affinity dial")
    host.v3Libp2pSetPeerTrustedInfra(trustedHost, inferAffinityPeer, true)
    host.v3Libp2pObservePeerResources(trustedHost, inferAffinityPeer, inferSample)
    let inferAffinityPos = ps.v3Libp2pPeerstorePos(trustedHost.peers, inferAffinityPeer)
    assert(inferAffinityPos >= 0, "v3 libp2p scheduler: infer affinity pos")
    trustedHost.peers.peers[inferAffinityPos].trustPermille = 830
    trustedHost.peers.peers[inferAffinityPos].loadPermille = 170
    trustedHost.peers.peers[inferAffinityPos].rttEwmaMicros = 900
    host.v3Libp2pSetPeerPlacementGroup(trustedHost, inferAffinityPeer, "az-b")

    var cacheGovPeer: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(cacheGovPeer, "scheduler.cache.govern")
    var cacheGovAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(cacheGovAddr, "127.0.0.1", smoke_ports.v3SmokeLabelPort(6428))
    let cacheGovDialRes = host.v3Libp2pDial(trustedHost,
                                            cacheGovPeer,
                                            cacheGovAddr,
                                            overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(cacheGovDialRes), "v3 libp2p scheduler: cache govern dial")
    host.v3Libp2pSetPeerTrustedInfra(trustedHost, cacheGovPeer, true)
    host.v3Libp2pObservePeerResources(trustedHost, cacheGovPeer, inferSample)
    let cacheGovPos = ps.v3Libp2pPeerstorePos(trustedHost.peers, cacheGovPeer)
    assert(cacheGovPos >= 0, "v3 libp2p scheduler: cache govern pos")
    trustedHost.peers.peers[cacheGovPos].trustPermille = 600
    trustedHost.peers.peers[cacheGovPos].loadPermille = 400
    trustedHost.peers.peers[cacheGovPos].rttEwmaMicros = 950
    host.v3Libp2pSetPeerPlacementGroup(trustedHost, cacheGovPeer, "az-gov")

    var withdrawnPeer: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(withdrawnPeer, "scheduler.withdrawn")
    var withdrawnAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(withdrawnAddr, "127.0.0.1", smoke_ports.v3SmokeLabelPort(6429))
    let withdrawnDialRes = host.v3Libp2pDial(trustedHost,
                                             withdrawnPeer,
                                             withdrawnAddr,
                                             overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(withdrawnDialRes), "v3 libp2p scheduler: withdrawn dial")
    host.v3Libp2pSetPeerTrustedInfra(trustedHost, withdrawnPeer, true)
    host.v3Libp2pObservePeerResources(trustedHost, withdrawnPeer, inferSample)
    let withdrawnPos = ps.v3Libp2pPeerstorePos(trustedHost.peers, withdrawnPeer)
    assert(withdrawnPos >= 0, "v3 libp2p scheduler: withdrawn pos")
    trustedHost.peers.peers[withdrawnPos].trustPermille = 980
    trustedHost.peers.peers[withdrawnPos].loadPermille = 20
    trustedHost.peers.peers[withdrawnPos].rttEwmaMicros = 350
    host.v3Libp2pSetPeerPlacementGroup(trustedHost, withdrawnPeer, "az-d")
    host.v3Libp2pSetPeerReplicaWithdrawn(trustedHost, withdrawnPeer, true)
    host.v3Libp2pObservePeerCache(trustedHost, trainPeer, "cid://manifest.alpha", now - 30)
    host.v3Libp2pObservePeerCache(trustedHost, inferReplicaPeer, "cid://manifest.alpha", now - 5)
    host.v3Libp2pObservePeerCache(trustedHost, inferReplicaPeer, "cid://manifest.alpha", now - 3)
    host.v3Libp2pObservePeerCache(trustedHost, inferAffinityPeer, "cid://blob.hot.0", now - 20)

    var inferReq: scheduler.V3Libp2pWorkloadRequest
    inferReq.workloadKind = scheduler.v3Libp2pWorkloadInfer
    inferReq.minCpuLogicalCores = 4
    inferReq.minMemoryAvailableBytes = 8 * gib
    inferReq.minGpuDeviceCount = 1
    inferReq.minGpuCoreCount = 128
    inferReq.maxLoadPermille = 300
    inferReq.minTrustPermille = 800
    inferReq.maxSampleAgeSeconds = 300
    let inferTrustedView = host.v3Libp2pHostTrustedView(trustedHost, trustedHost.peers.peers[inferPos])
    assert(inferTrustedView, "v3 libp2p scheduler: infer trusted view")
    var inferScore: scheduler.V3Libp2pPlacementScore
    assert(scheduler.v3Libp2pPeerPlacementScoreFill(inferScore,
                                                    trustedHost.peers.peers[inferPos],
                                                    inferTrustedView,
                                                    inferReq),
        "v3 libp2p scheduler: infer eligible")
    var inferSelectedPeer: types.V3Libp2pPeerId
    var inferSelectedEndpoint: ps.V3Libp2pPeerEndpoint
    let inferRes = host.v3Libp2pSelectPeerForWorkload(trustedHost,
                                                      inferReq,
                                                      inferSelectedPeer,
                                                      inferSelectedEndpoint)
    assert(IsOk(inferRes), "v3 libp2p scheduler: infer select")
    assert(types.v3Libp2pPeerIdEqual(inferSelectedPeer, inferPeer),
        "v3 libp2p scheduler: infer peer")
    assert(!types.v3Libp2pPeerIdEqual(inferSelectedPeer, stalePeer),
        "v3 libp2p scheduler: infer not stale")
    assert(!types.v3Libp2pPeerIdEqual(inferSelectedPeer, hiddenPeer),
        "v3 libp2p scheduler: infer not hidden")
    assert(inferSelectedEndpoint.addr.port == 6421, "v3 libp2p scheduler: infer port")

    var trainReq: scheduler.V3Libp2pWorkloadRequest
    trainReq.workloadKind = scheduler.v3Libp2pWorkloadTrain
    trainReq.minCpuLogicalCores = 16
    trainReq.minMemoryAvailableBytes = 64 * gib
    trainReq.minDiskAvailableBytes = 1024 * gib
    trainReq.minGpuDeviceCount = 2
    trainReq.minGpuCoreCount = 1024
    trainReq.maxLoadPermille = 300
    trainReq.minTrustPermille = 800
    trainReq.maxSampleAgeSeconds = 300
    var trainSelectedPeer: types.V3Libp2pPeerId
    var trainSelectedEndpoint: ps.V3Libp2pPeerEndpoint
    let trainRes = host.v3Libp2pSelectPeerForWorkload(trustedHost,
                                                      trainReq,
                                                      trainSelectedPeer,
                                                      trainSelectedEndpoint)
    assert(IsOk(trainRes), "v3 libp2p scheduler: train select")
    assert(types.v3Libp2pPeerIdEqual(trainSelectedPeer, trainPeer),
        "v3 libp2p scheduler: train peer")
    assert(trainSelectedEndpoint.addr.port == 6422, "v3 libp2p scheduler: train port")

    var cpuReq: scheduler.V3Libp2pWorkloadRequest
    cpuReq.workloadKind = scheduler.v3Libp2pWorkloadOther
    cpuReq.minCpuLogicalCores = 8
    cpuReq.minMemoryAvailableBytes = 16 * gib
    cpuReq.maxLoadPermille = 100
    cpuReq.maxSampleAgeSeconds = 300
    var cpuSelectedPeer: types.V3Libp2pPeerId
    var cpuSelectedEndpoint: ps.V3Libp2pPeerEndpoint
    let cpuRes = host.v3Libp2pSelectPeerForWorkload(trustedHost,
                                                    cpuReq,
                                                    cpuSelectedPeer,
                                                    cpuSelectedEndpoint)
    assert(IsOk(cpuRes), "v3 libp2p scheduler: cpu select")
    assert(types.v3Libp2pPeerIdEqual(cpuSelectedPeer, cpuPeer),
        "v3 libp2p scheduler: cpu peer")
    assert(cpuSelectedEndpoint.addr.port == 6423, "v3 libp2p scheduler: cpu port")

    var staleReq: scheduler.V3Libp2pWorkloadRequest
    staleReq.workloadKind = scheduler.v3Libp2pWorkloadTrain
    staleReq.minGpuDeviceCount = 8
    staleReq.minGpuCoreCount = 4096
    staleReq.maxSampleAgeSeconds = 60
    var staleSelectedPeer: types.V3Libp2pPeerId
    var staleSelectedEndpoint: ps.V3Libp2pPeerEndpoint
    let staleRes = host.v3Libp2pSelectPeerForWorkload(trustedHost,
                                                      staleReq,
                                                      staleSelectedPeer,
                                                      staleSelectedEndpoint)
    assert(IsErr(staleRes), "v3 libp2p scheduler: stale denied")

    var publicHost = host.v3Libp2pHostInit("scheduler.public.viewer")
    var publicPeer: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(publicPeer, "scheduler.public.viewer.peer")
    var publicAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(publicAddr, "127.0.0.1", smoke_ports.v3SmokeLabelPort(6431))
    let publicDialRes = host.v3Libp2pDial(publicHost,
                                          publicPeer,
                                          publicAddr,
                                          overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(publicDialRes), "v3 libp2p scheduler: public dial")
    host.v3Libp2pSetPeerTrustedInfra(publicHost, publicPeer, true)
    host.v3Libp2pObservePeerResources(publicHost, publicPeer, inferSample)
    let publicPos = ps.v3Libp2pPeerstorePos(publicHost.peers, publicPeer)
    assert(publicPos >= 0, "v3 libp2p scheduler: public pos")
    publicHost.peers.peers[publicPos].trustPermille = 900
    publicHost.peers.peers[publicPos].loadPermille = 10
    publicHost.peers.peers[publicPos].rttEwmaMicros = 100
    var publicSelectedPeer: types.V3Libp2pPeerId
    var publicSelectedEndpoint: ps.V3Libp2pPeerEndpoint
    let publicRes = host.v3Libp2pSelectPeerForWorkload(publicHost,
                                                       inferReq,
                                                       publicSelectedPeer,
                                                       publicSelectedEndpoint)
    assert(IsErr(publicRes), "v3 libp2p scheduler: public hidden")
    assert(!types.v3Libp2pPeerIdEqual(publicSelectedPeer, publicPeer),
        "v3 libp2p scheduler: public no selection")

    var stickyReq = inferReq
    stickyReq.stickyKey = "model.alpha"
    var stickySelectedPeer: types.V3Libp2pPeerId
    var stickySelectedEndpoint: ps.V3Libp2pPeerEndpoint
    let stickyPrimeRes = host.v3Libp2pSelectPeerForWorkload(trustedHost,
                                                            stickyReq,
                                                            stickySelectedPeer,
                                                            stickySelectedEndpoint)
    assert(IsOk(stickyPrimeRes), "v3 libp2p scheduler: sticky prime")
    assert(types.v3Libp2pPeerIdEqual(stickySelectedPeer, inferPeer),
        "v3 libp2p scheduler: sticky first peer")

    trustedHost.peers.peers[inferPos].loadPermille = 290
    trustedHost.peers.peers[inferPos].rttEwmaMicros = 5000

    var plainAfterStickyPeer: types.V3Libp2pPeerId
    var plainAfterStickyEndpoint: ps.V3Libp2pPeerEndpoint
    let plainAfterStickyRes = host.v3Libp2pSelectPeerForWorkload(trustedHost,
                                                                 inferReq,
                                                                 plainAfterStickyPeer,
                                                                 plainAfterStickyEndpoint)
    assert(IsOk(plainAfterStickyRes), "v3 libp2p scheduler: plain after sticky")
    assert(!types.v3Libp2pPeerIdEqual(plainAfterStickyPeer, inferPeer),
        "v3 libp2p scheduler: sticky plain moved")

    var stickyReusedPeer: types.V3Libp2pPeerId
    var stickyReusedEndpoint: ps.V3Libp2pPeerEndpoint
    let stickyReuseRes = host.v3Libp2pSelectPeerForWorkload(trustedHost,
                                                            stickyReq,
                                                            stickyReusedPeer,
                                                            stickyReusedEndpoint)
    assert(IsOk(stickyReuseRes), "v3 libp2p scheduler: sticky reuse")
    assert(types.v3Libp2pPeerIdEqual(stickyReusedPeer, inferPeer),
        "v3 libp2p scheduler: sticky reused peer")
    assert(stickyReusedEndpoint.addr.port == 6421, "v3 libp2p scheduler: sticky reused port")

    var affinityReq = inferReq
    affinityReq.maxLoadPermille = 250
    affinityReq.affinityKey = "kv/session/42"
    var affinityTarget: types.V3Libp2pPeerId
    assert(scheduler.v3Libp2pWorkloadAffinityTargetFill(affinityTarget, affinityReq),
        "v3 libp2p scheduler: affinity target")
    let inferReplicaDist = peer_id.v3Libp2pPeerIdDistance(inferReplicaPeer, affinityTarget)
    let inferAffinityDist = peer_id.v3Libp2pPeerIdDistance(inferAffinityPeer, affinityTarget)
    assert(inferReplicaDist != inferAffinityDist, "v3 libp2p scheduler: affinity unequal distance")
    let expectedAffinityPeer = inferReplicaDist < inferAffinityDist ? inferReplicaPeer : inferAffinityPeer
    let expectedAffinityPort = inferReplicaDist < inferAffinityDist ? 6426 : 6427
    var affinitySelectedPeer: types.V3Libp2pPeerId
    var affinitySelectedEndpoint: ps.V3Libp2pPeerEndpoint
    let affinityRes = host.v3Libp2pSelectPeerForWorkload(trustedHost,
                                                         affinityReq,
                                                         affinitySelectedPeer,
                                                         affinitySelectedEndpoint)
    assert(IsOk(affinityRes), "v3 libp2p scheduler: affinity select")
    assert(types.v3Libp2pPeerIdEqual(affinitySelectedPeer, expectedAffinityPeer),
        "v3 libp2p scheduler: affinity peer")
    assert(affinitySelectedEndpoint.addr.port == expectedAffinityPort,
        "v3 libp2p scheduler: affinity port")

    var cacheReq = inferReq
    cacheReq.maxLoadPermille = 250
    cacheReq.cacheHintManifestCid = "cid://manifest.alpha"
    cacheReq.cacheHintBlobCid = "cid://blob.hot.0"
    var cacheReplicaScore: scheduler.V3Libp2pPlacementScore
    var cacheAffinityScore: scheduler.V3Libp2pPlacementScore
    var cacheTrainScore: scheduler.V3Libp2pPlacementScore
    assert(scheduler.v3Libp2pPeerPlacementScoreFill(cacheReplicaScore,
                                                    trustedHost.peers.peers[inferReplicaPos],
                                                    host.v3Libp2pHostTrustedView(trustedHost, trustedHost.peers.peers[inferReplicaPos]),
                                                    cacheReq),
        "v3 libp2p scheduler: cache replica eligible")
    assert(scheduler.v3Libp2pPeerPlacementScoreFill(cacheAffinityScore,
                                                    trustedHost.peers.peers[inferAffinityPos],
                                                    host.v3Libp2pHostTrustedView(trustedHost, trustedHost.peers.peers[inferAffinityPos]),
                                                    cacheReq),
        "v3 libp2p scheduler: cache affinity eligible")
    assert(scheduler.v3Libp2pPeerPlacementScoreFill(cacheTrainScore,
                                                    trustedHost.peers.peers[trainPos],
                                                    host.v3Libp2pHostTrustedView(trustedHost, trustedHost.peers.peers[trainPos]),
                                                    cacheReq),
        "v3 libp2p scheduler: cache train eligible")
    assert(cacheReplicaScore.cacheHit, "v3 libp2p scheduler: cache replica hit")
    assert(cacheAffinityScore.cacheHit, "v3 libp2p scheduler: cache affinity hit")
    assert(cacheTrainScore.cacheHit, "v3 libp2p scheduler: cache train hit")
    host.v3Libp2pObservePeerCache(trustedHost, withdrawnPeer, "cid://manifest.alpha", now - 2)
    host.v3Libp2pObservePeerCache(trustedHost, withdrawnPeer, "cid://blob.hot.0", now - 2)
    assert(scheduler.v3Libp2pPlacementScoreCompare(cacheReplicaScore,
                                                   cacheAffinityScore,
                                                   cacheReq,
                                                   inferReplicaPeer,
                                                   inferAffinityPeer) < 0,
        "v3 libp2p scheduler: cache replica beats affinity")
    assert(scheduler.v3Libp2pPlacementScoreCompare(cacheReplicaScore,
                                                   cacheTrainScore,
                                                   cacheReq,
                                                   inferReplicaPeer,
                                                   trainPeer) < 0,
        "v3 libp2p scheduler: cache replica beats train")
    var cacheSelectedPeer: types.V3Libp2pPeerId
    var cacheSelectedEndpoint: ps.V3Libp2pPeerEndpoint
    let cacheRes = host.v3Libp2pSelectPeerForWorkload(trustedHost,
                                                      cacheReq,
                                                      cacheSelectedPeer,
                                                      cacheSelectedEndpoint)
    assert(IsOk(cacheRes), "v3 libp2p scheduler: cache select")
    assert(!types.v3Libp2pPeerIdEqual(cacheSelectedPeer, withdrawnPeer),
        "v3 libp2p scheduler: withdrawn excluded")
    assert(types.v3Libp2pPeerIdEqual(cacheSelectedPeer, inferReplicaPeer),
        "v3 libp2p scheduler: cache preferred peer")
    assert(cacheSelectedEndpoint.addr.port == 6426, "v3 libp2p scheduler: cache preferred port")

    trustedHost.peers.peers[inferPos].loadPermille = 160
    trustedHost.peers.peers[inferPos].rttEwmaMicros = 700
    host.v3Libp2pObservePeerCache(trustedHost, inferPeer, "cid://manifest.alpha", now - 1)
    var cacheDupScore: scheduler.V3Libp2pPlacementScore
    assert(scheduler.v3Libp2pPeerPlacementScoreFill(cacheDupScore,
                                                    trustedHost.peers.peers[inferPos],
                                                    host.v3Libp2pHostTrustedView(trustedHost, trustedHost.peers.peers[inferPos]),
                                                    cacheReq),
        "v3 libp2p scheduler: cache duplicate eligible")
    assert(scheduler.v3Libp2pReplicaCandidateCompare(cacheAffinityScore,
                                                     cacheDupScore,
                                                     cacheReq,
                                                     true,
                                                     false,
                                                     inferAffinityPeer,
                                                     inferPeer) < 0,
        "v3 libp2p scheduler: blob replica beats duplicate manifest")

    var cacheReplicaReq = inferReq
    cacheReplicaReq.maxLoadPermille = 250
    cacheReplicaReq.cacheHintManifestCid = "cid://manifest.alpha"
    cacheReplicaReq.cacheHintBlobCid = "cid://blob.hot.0"
    cacheReplicaReq.preferPlacementGroupSpread = true
    var cacheReplicaPeers: types.V3Libp2pPeerId[]
    var cacheReplicaEndpoints: ps.V3Libp2pPeerEndpoint[]
    cacheReplicaPeers = []
    cacheReplicaEndpoints = []
    let cacheReplicaRes = host.v3Libp2pSelectPeersForWorkload(trustedHost,
                                                              cacheReplicaReq,
                                                              3,
                                                              cacheReplicaPeers,
                                                              cacheReplicaEndpoints)
    assert(IsOk(cacheReplicaRes), "v3 libp2p scheduler: cache replica select")
    assert(cacheReplicaPeers.len == 3, "v3 libp2p scheduler: cache replica count")
    assert(!libp2pSchedulerPeerIdsContain(cacheReplicaPeers, withdrawnPeer),
        "v3 libp2p scheduler: withdrawn replica excluded")
    assert(!(libp2pSchedulerPeerIdsContain(cacheReplicaPeers, inferPeer) &&
        libp2pSchedulerPeerIdsContain(cacheReplicaPeers, inferReplicaPeer)),
        "v3 libp2p scheduler: placement spread")
    assert(libp2pSchedulerPeerIdsContain(cacheReplicaPeers, inferAffinityPeer),
        "v3 libp2p scheduler: spread includes az-b")
    assert(libp2pSchedulerPeerIdsContain(cacheReplicaPeers, trainPeer),
        "v3 libp2p scheduler: spread includes az-c")

    var antiAffinityReq = inferReq
    antiAffinityReq.maxLoadPermille = 250
    antiAffinityReq.hasAntiAffinityPeer = true
    antiAffinityReq.antiAffinityPeerId = inferPeer
    var antiAffinitySelectedPeer: types.V3Libp2pPeerId
    var antiAffinitySelectedEndpoint: ps.V3Libp2pPeerEndpoint
    let antiAffinityRes = host.v3Libp2pSelectPeerForWorkload(trustedHost,
                                                             antiAffinityReq,
                                                             antiAffinitySelectedPeer,
                                                             antiAffinitySelectedEndpoint)
    assert(IsOk(antiAffinityRes), "v3 libp2p scheduler: anti affinity select")
    assert(types.v3Libp2pPeerIdEqual(antiAffinitySelectedPeer, inferAffinityPeer),
        "v3 libp2p scheduler: anti affinity peer")
    assert(antiAffinitySelectedEndpoint.addr.port == 6427,
        "v3 libp2p scheduler: anti affinity port")

    assert(host.v3Libp2pAdmitPeerCache(trustedHost,
                                       cacheGovPeer,
                                       "cid://cache.hot",
                                       now - 40,
                                       60,
                                       2,
                                       150),
        "v3 libp2p scheduler: cache govern hot admit")
    host.v3Libp2pObservePeerCache(trustedHost, cacheGovPeer, "cid://cache.hot", now - 20)
    assert(host.v3Libp2pAdmitPeerCache(trustedHost,
                                       cacheGovPeer,
                                       "cid://cache.cold",
                                       now - 30,
                                       70,
                                       2,
                                       150),
        "v3 libp2p scheduler: cache govern cold admit")
    assert(host.v3Libp2pEvictPeerCache(trustedHost, cacheGovPeer, "cid://cache.cold"),
        "v3 libp2p scheduler: cache govern cold evict")
    assert(host.v3Libp2pAdmitPeerCache(trustedHost,
                                       cacheGovPeer,
                                       "cid://cache.newhot",
                                       now - 10,
                                       80,
                                       2,
                                       150),
        "v3 libp2p scheduler: cache govern newhot admit")
    assert(!host.v3Libp2pAdmitPeerCache(trustedHost,
                                        cacheGovPeer,
                                        "cid://cache.oversized",
                                        now - 1,
                                        200,
                                        2,
                                        150),
        "v3 libp2p scheduler: cache govern oversized reject")
    assert(trustedHost.peers.peers[cacheGovPos].cacheEntries.len == 2,
        "v3 libp2p scheduler: cache govern final count")
    assert(ps.v3Libp2pPeerRecordCacheEntryPos(trustedHost.peers.peers[cacheGovPos],
                                              "cid://cache.hot") >= 0,
        "v3 libp2p scheduler: cache govern hot kept")
    let cacheGovHotPos = ps.v3Libp2pPeerRecordCacheEntryPos(trustedHost.peers.peers[cacheGovPos],
                                                            "cid://cache.hot")
    assert(cacheGovHotPos >= 0, "v3 libp2p scheduler: cache govern hot residency")
    assert(trustedHost.peers.peers[cacheGovPos].cacheEntries[cacheGovHotPos].residentBytes == 60,
        "v3 libp2p scheduler: cache govern hot bytes")
    assert(ps.v3Libp2pPeerRecordCacheEntryPos(trustedHost.peers.peers[cacheGovPos],
                                              "cid://cache.cold") < 0,
        "v3 libp2p scheduler: cache govern cold evicted")
    assert(ps.v3Libp2pPeerRecordCacheEntryPos(trustedHost.peers.peers[cacheGovPos],
                                              "cid://cache.newhot") >= 0,
        "v3 libp2p scheduler: cache govern newhot kept")

    assert(host.v3Libp2pAdmitPeerCache(trustedHost,
                                       inferReplicaPeer,
                                       "cid://blob.hot.0",
                                       now - 2,
                                       64,
                                       4,
                                       256),
        "v3 libp2p scheduler: cache replica admit")
    assert(host.v3Libp2pAdmitPeerCache(trustedHost,
                                       inferAffinityPeer,
                                       "cid://blob.hot.0",
                                       now - 20,
                                       64,
                                       4,
                                       256),
        "v3 libp2p scheduler: cache affinity admit")
    assert(host.v3Libp2pAdmitPeerCache(trustedHost,
                                       trainPeer,
                                       "cid://manifest.alpha",
                                       now - 30,
                                       64,
                                       4,
                                       256),
        "v3 libp2p scheduler: cache train admit")
    assert(host.v3Libp2pEvictPeerCache(trustedHost, inferAffinityPeer, "cid://blob.hot.0"),
        "v3 libp2p scheduler: cache affinity evict")
    var cacheReplicaPeersAfterEvict: types.V3Libp2pPeerId[]
    var cacheReplicaEndpointsAfterEvict: ps.V3Libp2pPeerEndpoint[]
    cacheReplicaPeersAfterEvict = []
    cacheReplicaEndpointsAfterEvict = []
    let cacheReplicaAfterEvictRes = host.v3Libp2pSelectPeersForWorkload(trustedHost,
                                                                        cacheReplicaReq,
                                                                        3,
                                                                        cacheReplicaPeersAfterEvict,
                                                                        cacheReplicaEndpointsAfterEvict)
    assert(IsOk(cacheReplicaAfterEvictRes), "v3 libp2p scheduler: cache replica reselect")
    assert(!libp2pSchedulerPeerIdsContain(cacheReplicaPeersAfterEvict, withdrawnPeer),
        "v3 libp2p scheduler: withdrawn after evict")
    assert(libp2pSchedulerPeerIdsContain(cacheReplicaPeersAfterEvict, trainPeer),
        "v3 libp2p scheduler: spread keeps az-c after evict")
    assert(!(libp2pSchedulerPeerIdsContain(cacheReplicaPeersAfterEvict, inferPeer) &&
        libp2pSchedulerPeerIdsContain(cacheReplicaPeersAfterEvict, inferReplicaPeer)),
        "v3 libp2p scheduler: spread still holds after evict")

    echo("v3 libp2p_scheduler_smoke ok")
    return 0
