import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus as consensus
import cheng/v3/project/chain_node as node

fn localApplyEvent(chain: var node.V3ChainNode, event: var consensus.V3ChainEvent): Result[layout.FixedBytes32] =
    let eventCid = consensus.v3ChainEventCid(event)
    var nextIndex = chain.index
    var decision = consensus.V3ConsensusDecision()
    consensus.v3ConsensusApplyChecked(nextIndex, event, eventCid, chain.eventCids.len, decision)
    chain.index = nextIndex
    if !decision.accepted:
        return Err[layout.FixedBytes32]("chain node local wrapper mint: apply rejected")
    if decision.applied:
        add(chain.eventCids, eventCid)
        add(chain.events, event)
        node.v3ChainNodeRebuildDerived(chain)
    return Ok[layout.FixedBytes32](eventCid)

fn localMint(chain: var node.V3ChainNode, assetId: int32, toAccount: int32, amount: int64): Result[layout.FixedBytes32] =
    let parentCid = node.v3ChainNodeAccountHead(chain.index, assetId, toAccount)
    var event = consensus.v3ChainEventMint(
        assetId,
        toAccount,
        parentCid,
        amount,
        chain.nextEpoch,
        chain.nextGanzhi,
        node.v3ChainNodeSpaceSlot(toAccount, toAccount),
        chain.nextTick
    )
    return localApplyEvent(chain, event)

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node: init")
    let mintCidRes = localMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "chain node local wrapper mint: mint")
    assert(server.eventCids.len == 1, "chain node local wrapper mint: cid len")
    assert(server.events.len == 1, "chain node local wrapper mint: event len")
    assert(layout.fixedBytes32Equal(server.eventCids[0], mintCidRes.value),
           "chain node local wrapper mint: first cid")
    assert(server.events[0].kind == consensus.v3ConsensusKindMint,
           "chain node local wrapper mint: first event kind")
    echo("v3 chain_node_local_wrapper_mint_smoke ok")
    return 0
