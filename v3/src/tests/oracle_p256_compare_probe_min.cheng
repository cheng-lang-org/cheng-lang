import std/system
import std/result
import std/crypto/ecnist
import std/crypto/bigint
import cheng/v3/std/bytes_layout as layout
import cheng/v3/std/crypto/fixed256
import cheng/v3/tests/oracle_smoke_support as support

fn main(): int32 =
    let priv = support.oracleSmokePrivateScalar(1)
    let privBytes = fixed256.scalar256ToBytes(priv)
    let bigRes = bigint.bigFromBytes(privBytes)
    assert(IsOk(bigRes), "probe: bigint")
    let combRes = ecnist.pointMulGeneratorFixed(Value(bigRes))
    assert(IsOk(combRes), "probe: comb")
    let wnafRes = ecnist.pointMulGeneratorWnaf(Value(bigRes))
    assert(IsOk(wnafRes), "probe: wnaf")
    let bigPointRes = ecnist.pointMulGenerator(Value(bigRes))
    assert(IsOk(bigPointRes), "probe: bigint")
    let combBytes = ecnist.ecdsaPublicPointFixedToBytes(Value(combRes))
    let wnafBytes = ecnist.ecdsaPublicPointFixedToBytes(Value(wnafRes))
    let bigBytes = ecnist.ecdsaPublicPointToBytes(Value(bigPointRes))
    let combFixedRes = layout.fixedBytes65FromBytes(combBytes)
    assert(IsOk(combFixedRes), "probe: comb fixed")
    let wnafFixedRes = layout.fixedBytes65FromBytes(wnafBytes)
    assert(IsOk(wnafFixedRes), "probe: wnaf fixed")
    let bigFixedRes = layout.fixedBytes65FromBytes(bigBytes)
    assert(IsOk(bigFixedRes), "probe: bigint fixed")
    if layout.fixedBytes65Equal(Value(combFixedRes), support.oracleSmokePubKey(1)):
        echo("probe: comb ok")
    else:
        echo("probe: comb bad")
    if layout.fixedBytes65Equal(Value(wnafFixedRes), support.oracleSmokePubKey(1)):
        echo("probe: wnaf ok")
    else:
        echo("probe: wnaf bad")
    if layout.fixedBytes65Equal(Value(combFixedRes), Value(wnafFixedRes)):
        echo("probe: equal")
    else:
        echo("probe: diff")
    if layout.fixedBytes65Equal(Value(bigFixedRes), support.oracleSmokePubKey(1)):
        echo("probe: bigint ok")
    else:
        echo("probe: bigint bad")
    return 0
