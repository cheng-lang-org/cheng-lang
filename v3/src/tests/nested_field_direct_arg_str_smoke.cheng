import std/strutils as strutil

type
    V3NestedFieldDirectArgInner =
        text: str

    V3NestedFieldDirectArgOuter =
        inner: V3NestedFieldDirectArgInner

    V3NestedFieldDirectArgWorldHead =
        universeId: str
        channel: str
        signature: str
        headEpoch: int32

    V3NestedFieldDirectArgLocalUniverse =
        compilerSnapshot: str
        stdSnapshot: str
        runtimeSnapshot: str
        worldHead: V3NestedFieldDirectArgWorldHead

    V3NestedFieldDirectArgSystemLinkPlan =
        packageId: str
        targetTriple: str
        outputPath: str

    V3NestedFieldDirectArgPlan =
        compilerEntrySource: str
        systemLinkPlan: V3NestedFieldDirectArgSystemLinkPlan
        localUniverse: V3NestedFieldDirectArgLocalUniverse
        compileReceipt: str
        note0: str
        note1: str
        note2: str

fn nestedFieldDirectArgNormalize(raw: str): str =
    return strutil.Strip(raw)

fn nestedFieldDirectArgFromParam(value: V3NestedFieldDirectArgOuter): str =
    return nestedFieldDirectArgNormalize(value.inner.text)

fn nestedFieldDirectArgFromPlan(plan: V3NestedFieldDirectArgPlan): str =
    return nestedFieldDirectArgNormalize(plan.localUniverse.worldHead.channel)

fn main(): int32 =
    let value = V3NestedFieldDirectArgOuter(
        inner: V3NestedFieldDirectArgInner(
            text: " stable "
        )
    )
    let direct = nestedFieldDirectArgNormalize(value.inner.text)
    assert(direct == "stable", "v3 nested field direct arg direct")
    let fromParam = nestedFieldDirectArgFromParam(value)
    assert(fromParam == "stable", "v3 nested field direct arg from param")
    let viaLocal = value.inner.text
    let local = nestedFieldDirectArgNormalize(viaLocal)
    assert(local == "stable", "v3 nested field direct arg local")
    let plan = V3NestedFieldDirectArgPlan(
        compilerEntrySource: "entry",
        systemLinkPlan: V3NestedFieldDirectArgSystemLinkPlan(
            packageId: "cheng/v3/tests/nested_field_direct_arg_str_smoke",
            targetTriple: "arm64-apple-darwin",
            outputPath: "/tmp/nested-field-direct"
        ),
        localUniverse: V3NestedFieldDirectArgLocalUniverse(
            compilerSnapshot: "compiler",
            stdSnapshot: "std",
            runtimeSnapshot: "runtime",
            worldHead: V3NestedFieldDirectArgWorldHead(
                universeId: "cheng/v3/compiler_universe",
                channel: " stable ",
                signature: "sig",
                headEpoch: 1
            )
        ),
        compileReceipt: "receipt",
        note0: "n0",
        note1: "n1",
        note2: "n2"
    )
    let fromPlan = nestedFieldDirectArgFromPlan(plan)
    assert(fromPlan == "stable", "v3 nested field direct arg from plan")
    echo("v3 nested_field_direct_arg_str_smoke ok")
    return 0
