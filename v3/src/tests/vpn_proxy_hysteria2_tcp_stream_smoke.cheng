import std/result
import cheng/v3/quic/connection as qconn
import cheng/v3/quic/msquicruntime as qruntime
import cheng/v3/quic/msquictransport_native as qtransport
import cheng/v3/libp2p/transports/quic_transport
import cheng/v3/tooling/vpn_proxy_hysteria2_session as hy2sess

fn vpnHy2TcpStreamBytesEq(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    var settings = qruntime.initMsQuicSettings()
    settings.allowDatagram = true

    var listener = qtransport.initMsQuicTransport()
    assert(IsOk(qtransport.setMsQuicTransportSettings(listener, settings)),
        "v3 vpn hy2 tcp stream: listener settings")
    assert(IsOk(quic_transport.v3Libp2pQuicConfigureTls(listener)),
        "v3 vpn hy2 tcp stream: listener tls")
    let listenAddrRes = quic_transport.v3Libp2pQuicAddrFromHostPort("127.0.0.1", 0)
    assert(IsOk(listenAddrRes), "v3 vpn hy2 tcp stream: listen addr")
    qtransport.start(listener, Value(listenAddrRes))

    var client = qtransport.initMsQuicTransport()
    assert(IsOk(qtransport.setMsQuicTransportSettings(client, settings)),
        "v3 vpn hy2 tcp stream: client settings")
    assert(IsOk(quic_transport.v3Libp2pQuicConfigureTls(client)),
        "v3 vpn hy2 tcp stream: client tls")
    let dialRes = qtransport.dial(client, listener.listenAddr)
    assert(IsOk(dialRes), "v3 vpn hy2 tcp stream: dial")
    var clientConn = Value(dialRes)
    let acceptRes = qtransport.accept(listener)
    assert(IsOk(acceptRes), "v3 vpn hy2 tcp stream: accept")
    var serverConn = Value(acceptRes)

    let clientStreamRes = hy2sess.V3VpnProxyHy2OpenTcpStream(clientConn, 8)
    assert(IsOk(clientStreamRes), "v3 vpn hy2 tcp stream: open client stream")
    var clientStream = Value(clientStreamRes)
    let serverStreamRes = hy2sess.V3VpnProxyHy2OpenTcpStream(serverConn, 8)
    assert(IsOk(serverStreamRes), "v3 vpn hy2 tcp stream: open server stream")
    var serverStream = Value(serverStreamRes)

    assert(IsOk(hy2sess.V3VpnProxyHy2TcpStreamWriteRequest(clientStream,
                                                           "example.com:443",
                                                           bytesFromString("req-pad"))),
        "v3 vpn hy2 tcp stream: client write request")
    assert(IsOk(hy2sess.V3VpnProxyHy2TcpStreamWrite(clientStream, bytesFromString("client-extra"))),
        "v3 vpn hy2 tcp stream: client write extra")
    let reqRes = hy2sess.V3VpnProxyHy2TcpStreamReadRequest(serverStream)
    assert(IsOk(reqRes), "v3 vpn hy2 tcp stream: server read request")
    let req = Value(reqRes)
    assert(req.address == "example.com:443",
        "v3 vpn hy2 tcp stream: request address")
    assert(vpnHy2TcpStreamBytesEq(req.padding, bytesFromString("req-pad")),
        "v3 vpn hy2 tcp stream: request padding")
    let reqExtraRes = hy2sess.V3VpnProxyHy2TcpStreamReadNonblocking(serverStream, 64)
    assert(IsOk(reqExtraRes), "v3 vpn hy2 tcp stream: server read extra")
    assert(vpnHy2TcpStreamBytesEq(Value(reqExtraRes), bytesFromString("client-extra")),
        "v3 vpn hy2 tcp stream: request extra")

    assert(IsOk(hy2sess.V3VpnProxyHy2TcpStreamWriteResponse(serverStream,
                                                            true,
                                                            "",
                                                            bytesFromString("resp-pad"))),
        "v3 vpn hy2 tcp stream: server write response")
    assert(IsOk(hy2sess.V3VpnProxyHy2TcpStreamWrite(serverStream, bytesFromString("server-extra"))),
        "v3 vpn hy2 tcp stream: server write extra")
    let respRes = hy2sess.V3VpnProxyHy2TcpStreamReadResponse(clientStream)
    assert(IsOk(respRes), "v3 vpn hy2 tcp stream: client read response")
    let resp = Value(respRes)
    assert(resp.ok, "v3 vpn hy2 tcp stream: response ok")
    assert(vpnHy2TcpStreamBytesEq(resp.padding, bytesFromString("resp-pad")),
        "v3 vpn hy2 tcp stream: response padding")
    let respExtraRes = hy2sess.V3VpnProxyHy2TcpStreamReadNonblocking(clientStream, 64)
    assert(IsOk(respExtraRes), "v3 vpn hy2 tcp stream: client read extra")
    assert(vpnHy2TcpStreamBytesEq(Value(respExtraRes), bytesFromString("server-extra")),
        "v3 vpn hy2 tcp stream: response extra")

    assert(IsOk(hy2sess.V3VpnProxyHy2TcpStreamShutdownWrite(clientStream)),
        "v3 vpn hy2 tcp stream: client shutdown write")
    let serverEofRes = hy2sess.V3VpnProxyHy2TcpStreamReadNonblocking(serverStream, 1)
    assert(IsErr(serverEofRes), "v3 vpn hy2 tcp stream: server eof err")
    assert(ErrorText(serverEofRes) == "msquic: stream closed",
        "v3 vpn hy2 tcp stream: server eof text")

    hy2sess.V3VpnProxyHy2TcpStreamClose(serverStream)
    hy2sess.V3VpnProxyHy2TcpStreamClose(clientStream)
    qconn.connClose(serverConn)
    qconn.connClose(clientConn)
    qtransport.stop(listener)
    echo("v3 vpn_proxy_hysteria2_tcp_stream_smoke ok")
    return 0
