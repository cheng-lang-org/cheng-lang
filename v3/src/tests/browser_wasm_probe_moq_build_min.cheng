@exportc("moqBuildLongBlobFirstDropletBlockIndexesLocalInlineCsvLen")
fn moqBuildLongBlobFirstDropletBlockIndexesLocalInlineCsvLen(): int32 =
    let builtRes = buildLongBlobLongPeerResult()
    if IsErr(builtRes):
        return -1
    let built = Value(builtRes)
    if built.droplets.len <= 0:
        return -2
    let droplet = built.droplets[0]
    let values = droplet.blockIndexes
    var rows: str[]
    rows = []
    var i: int32 = 0
    while i < values.len:
        add(rows, strings.IntToStr(values[i]))
        i = i + 1
    let text = strutils.Join(rows, ",")
    return text.len

