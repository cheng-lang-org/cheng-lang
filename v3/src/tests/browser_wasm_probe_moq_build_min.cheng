@exportc("moqBuildObjectRowsWireLen")
fn moqBuildObjectRowsWireLen(): int32 =
    let builtRes = buildResult()
    if IsErr(builtRes):
        return -1
    let built = Value(builtRes)
    if built.objects.len <= 0:
        return -2
    let item = built.objects[0]
    let prefix = fmt3("object.", intToStr(0), ".")
    var rows: str[]
    rows = []
    add(rows, fmt3(prefix, "object_index=", intToStr(item.objectIndex)))
    add(rows, fmt2(prefix + "group_id=", item.groupId))
    add(rows, fmt2(prefix + "object_id=", item.objectId))
    add(rows, fmt3(prefix, "priority=", intToStr(item.priority)))
    add(rows, fmt3(prefix, "byte_offset=", intToStr(item.byteOffset)))
    add(rows, fmt3(prefix, "byte_length=", intToStr(item.byteLength)))
    add(rows, fmt2(prefix + "object_cid=", item.objectCid))
    add(rows, fmt3(prefix, "source_block_bytes=", intToStr(item.sourceBlockBytes)))
    add(rows, fmt3(prefix, "source_block_count=", intToStr(item.sourceBlockCount)))
    add(rows, fmt3(prefix, "repair_droplet_count=", intToStr(item.repairDropletCount)))
    let text = Lines(rows)
    return text.len

@exportc("moqBuildDropletRowsWireLen")
fn moqBuildDropletRowsWireLen(): int32 =
    let builtRes = buildResult()
    if IsErr(builtRes):
        return -1
    let built = Value(builtRes)
    if built.droplets.len <= 0:
        return -2
    let droplet = built.droplets[0]
    let prefix = fmt3("droplet.", intToStr(0), ".")
    let kindText = if droplet.kindCode == 1: "source" else: "repair"
    var rows: str[]
    rows = []
    add(rows, fmt3(prefix, "object_index=", intToStr(droplet.objectIndex)))
    add(rows, fmt3(prefix, "droplet_index=", intToStr(droplet.dropletIndex)))
    add(rows, fmt2(prefix + "kind=", kindText))
    add(rows, fmt2(prefix + "key=", droplet.key))
    add(rows, fmt2(prefix + "peer_id=", droplet.peerId))
    add(rows, fmt2(prefix + "cid=", droplet.cid))
    add(rows, fmt3(prefix, "degree=", intToStr(droplet.degree)))
    add(rows, fmt2(prefix + "block_indexes=", joinIntCsv(droplet.blockIndexes)))
    add(rows, fmt2(prefix + "payload_hex=", bytesToHex(droplet.payload)))
    let text = Lines(rows)
    return text.len

fn moqBuildErrorText(): str =
    let result = buildResult()
    if IsErr(result):
        return Error(result)
    return "ok"

fn main(): int32 =
    return moqBuildWireLen()
