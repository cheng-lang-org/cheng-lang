fn buildLongBlobLongPeerWireText(): str =
    let builtRes = buildLongBlobLongPeerResult()
    if IsErr(builtRes):
        return ""
    let built = Value(builtRes)
    return moq.v3Libp2pMoqBuildToWire(bytesFromString("moq-fountain-smoke"),
                                      built.ownerPeerId,
                                      moqProbeRemotePeerCsv(),
                                      built.mimeType,
                                      1024,
                                      8,
                                      2)

fn buildLongBlobObjectOnly(): Result[moq.V3Libp2pMoqObject] =
    let peers = moq.v3Libp2pMoqNormalizePeerCsv("peer-a,peer-b")
    return moq.v3Libp2pMoqBuildObject(bytesFromString("moq-fountain-smoke"),
                                      0,
                                      0,
                                      peers,
                                      "bundle",
                                      8,
                                      2)

fn buildLongBlobLongPeerObjectOnly(): Result[moq.V3Libp2pMoqObject] =
    let blob = bytesFromString("moq-fountain-smoke")
    let peers = moq.v3Libp2pMoqNormalizePeerCsv(moqProbeRemotePeerCsv())
    let mimeType = "video/mp4"
    let blobCid = moq.v3Libp2pMoqSha256HexBytes(blob)
    var bundleSeed = "12D3KooWmxfnTuP2Gn5mhXTgeKiDHpKKQfVWKHeYruMuAVbkWmk8" + "|" + blobCid + "|" + mimeType + "|" + moq.v3Libp2pMoqJoinCsv(peers)
    bundleSeed = bundleSeed + "|" + intToStr(1024)
    bundleSeed = bundleSeed + "|" + intToStr(8)
    bundleSeed = bundleSeed + "|" + intToStr(2)
    let bundleCid = moq.v3Libp2pMoqSha256HexText(bundleSeed)
    return moq.v3Libp2pMoqBuildObject(blob,
                                      0,
                                      0,
                                      peers,
                                      bundleCid,
                                      8,
                                      2)

fn firstDropletBlockIndexesLen(droplets: moq.V3Libp2pMoqDroplet[]): int32 =
    if droplets.len <= 0:
        return -1
    return droplets[0].blockIndexes.len

fn firstDropletBlockIndex0Value(droplets: moq.V3Libp2pMoqDroplet[]): int32 =
    if droplets.len <= 0:
        return -1
    if droplets[0].blockIndexes.len <= 0:
        return -2
    return droplets[0].blockIndexes[0]

fn buildLongBlobManualResultObjectsOnly(): Result[moq.V3Libp2pMoqBuildResult] =
    let objectRes = buildLongBlobObjectOnly()
    if IsErr(objectRes):
        return Err[moq.V3Libp2pMoqBuildResult](Error(objectRes))
    let objectOut = Value(objectRes)
    var objects: moq.V3Libp2pMoqObject[]
    objects = []
    add(objects, objectOut)
    var droplets: moq.V3Libp2pMoqDroplet[]
    droplets = []
    let out = moq.V3Libp2pMoqBuildResult(
        ownerPeerId: "owner",
        mimeType: "video/mp4",
        bundleCid: "bundle",
        blobCid: "blob",
        catalogKey: "catalog",
        blobByteLen: len("moq-fountain-smoke"),
        objectTargetBytes: 1024,
        sourceBlockBytes: 8,
        objectCount: objects.len,
        remoteAckPeerIds: moq.v3Libp2pMoqNormalizePeerCsv("peer-a,peer-b"),
        objects: objects,
        droplets: droplets
    )
    return Ok[moq.V3Libp2pMoqBuildResult](out)

fn buildLongBlobManualResultFull(): Result[moq.V3Libp2pMoqBuildResult] =
    let objectRes = buildLongBlobObjectOnly()
    if IsErr(objectRes):
        return Err[moq.V3Libp2pMoqBuildResult](Error(objectRes))
    let objectOut = Value(objectRes)
    var objects: moq.V3Libp2pMoqObject[]
    objects = []
    add(objects, objectOut)
    var droplets: moq.V3Libp2pMoqDroplet[]
    droplets = []
    moq.v3Libp2pMoqAppendDroplets(droplets, objectOut.droplets)
    let out = moq.V3Libp2pMoqBuildResult(
        ownerPeerId: "owner",
        mimeType: "video/mp4",
        bundleCid: "bundle",
        blobCid: "blob",
        catalogKey: "catalog",
        blobByteLen: len("moq-fountain-smoke"),
        objectTargetBytes: 1024,
        sourceBlockBytes: 8,
        objectCount: objects.len,
        remoteAckPeerIds: moq.v3Libp2pMoqNormalizePeerCsv("peer-a,peer-b"),
        objects: objects,
        droplets: droplets
    )
    return Ok[moq.V3Libp2pMoqBuildResult](out)

fn buildLongBlobLoopCounts(): Result[int32[]] =
    let blob = bytesFromString("moq-fountain-smoke")
    let peers = moq.v3Libp2pMoqNormalizePeerCsv("peer-a,peer-b")
    let objectTargetBytes = 1024
    let sourceBlockBytes = 8
    let repairDropletCount = 2
    let mimeType = "video/mp4"
    let blobCid = moq.v3Libp2pMoqSha256HexBytes(blob)
    var bundleSeed = "owner" + "|" + blobCid + "|" + mimeType + "|" + moq.v3Libp2pMoqJoinCsv(peers)
    bundleSeed = bundleSeed + "|" + intToStr(objectTargetBytes)
    bundleSeed = bundleSeed + "|" + intToStr(sourceBlockBytes)
    bundleSeed = bundleSeed + "|" + intToStr(repairDropletCount)
    let bundleCid = moq.v3Libp2pMoqSha256HexText(bundleSeed)
    var objects: moq.V3Libp2pMoqObject[]
    objects = []
    var droplets: moq.V3Libp2pMoqDroplet[]
    droplets = []
    var byteOffset: int32 = 0
    var objectIndex: int32 = 0
    while byteOffset < bytesLen(blob):
        let objectByteLen = moq.v3Libp2pMoqMinInt32(objectTargetBytes, bytesLen(blob) - byteOffset)
        let objectBytes = bytesSlice(blob, byteOffset, objectByteLen)
        let objectRes = moq.v3Libp2pMoqBuildObject(objectBytes,
                                                   objectIndex,
                                                   byteOffset,
                                                   peers,
                                                   bundleCid,
                                                   sourceBlockBytes,
                                                   repairDropletCount)
        if IsErr(objectRes):
            return Err[int32[]](Error(objectRes))
        let objectOut = Value(objectRes)
        add(objects, objectOut)
        moq.v3Libp2pMoqAppendDroplets(droplets, objectOut.droplets)
        byteOffset = byteOffset + objectByteLen
        objectIndex = objectIndex + 1
    var counts: int32[]
    counts = []
    add(counts, objects.len)
    add(counts, droplets.len)
    return Ok[int32[]](counts)

fn buildLongBlobLoopObjectLenDirect(): Result[int32] =
    let countsRes = buildLongBlobLoopCounts()
    if IsErr(countsRes):
        return Err[int32](Error(countsRes))
    let counts = Value(countsRes)
    if counts.len <= 0:
        return Err[int32]("loop_counts_missing_object_len")
    return Ok[int32](counts[0])

fn buildLongBlobLoopDropletLenDirect(): Result[int32] =
    let countsRes = buildLongBlobLoopCounts()
    if IsErr(countsRes):
        return Err[int32](Error(countsRes))
    let counts = Value(countsRes)
    if counts.len <= 1:
        return Err[int32]("loop_counts_missing_droplet_len")
    return Ok[int32](counts[1])

