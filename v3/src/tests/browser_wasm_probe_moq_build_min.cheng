@exportc("moqBuildLongBlobLongPeerWireRemoteAckCsvLen")
fn moqBuildLongBlobLongPeerWireRemoteAckCsvLen(): int32 =
    let builtRes = buildLongBlobLongPeerResult()
    if IsErr(builtRes):
        return -1
    let built = Value(builtRes)
    let wire = moq.v3Libp2pMoqBuildToWire(bytesFromString("moq-fountain-smoke"),
                                          built.ownerPeerId,
                                          moqProbeRemotePeerCsv(),
                                          built.mimeType,
                                          1024,
                                          8,
                                          2)
    let csvRes = moq.v3Libp2pMoqWireFindValue(wire, "remote_ack_peer_ids")
    if IsErr(csvRes):
        return -2
    return Value(csvRes).len

