    )

fn buildNormalizedPrefixSeqBox(): PrefixSeqBox =
    let items = moq.v3Libp2pMoqNormalizePeerCsv("peer-a,peer-b")
    return PrefixSeqBox(
        ownerPeerId: "owner",
        mimeType: "video/mp4",
        bundleCid: "bundle",
        blobCid: "blob",
        catalogKey: "catalog",
        blobByteLen: 3,
        objectTargetBytes: 8,
        sourceBlockBytes: 4,
        objectCount: 1,
        remoteAckPeerIds: items
    )

fn buildLoopActualResult(): Result[moq.V3Libp2pMoqBuildResult] =
    let peers = moq.v3Libp2pMoqNormalizePeerCsv("peer-a,peer-b")
    let objectRes = moq.v3Libp2pMoqBuildObject(bytesFromString("abc"),
                                               0,
                                               0,
                                               peers,
                                               "bundle",
                                               4,
                                               1)
    if IsErr(objectRes):
        return Err[moq.V3Libp2pMoqBuildResult](Error(objectRes))
    let objectOut = Value(objectRes)
    var objects: moq.V3Libp2pMoqObject[]
    objects = []
    add(objects, objectOut)
    var allDroplets: moq.V3Libp2pMoqDroplet[]
    allDroplets = []
    moq.v3Libp2pMoqAppendDroplets(allDroplets, objectOut.droplets)
    let out = moq.V3Libp2pMoqBuildResult(
        ownerPeerId: "owner",
        mimeType: "video/mp4",
        bundleCid: "bundle",
        blobCid: "blob",
        catalogKey: "catalog",
        blobByteLen: 3,
        objectTargetBytes: 8,
        sourceBlockBytes: 4,
        objectCount: objects.len,
        remoteAckPeerIds: peers,
        objects: objects,
        droplets: allDroplets
    )
    return Ok[moq.V3Libp2pMoqBuildResult](out)

fn localNormalizeParts(parts: str[]): str[] =
    var out: str[]
    out = []
    var i: int32 = 0
    while i < parts.len:
        let candidate = moq.v3Libp2pMoqTrimAscii(parts[i])
        if len(candidate) <= 0:
            i = i + 1
            continue
        var exists = false
        var j: int32 = 0
        while j < out.len:
            if out[j] == candidate:
                exists = true
                break
            j = j + 1
        if !exists:
            add(out, candidate)
        i = i + 1
    return out

fn localMapTrimParts(parts: str[]): str[] =
    var out: str[]
    out = []
    var i: int32 = 0
    while i < parts.len:
        let candidate = moq.v3Libp2pMoqTrimAscii(parts[i])
        add(out, candidate)
        i = i + 1
    return out

