fn buildSeqBox(): SeqBox =
    var items: str[]
    items = []
    add(items, "peer-a")
    add(items, "peer-b")
    return SeqBox(items: items)

fn buildPrefixSeqBox(): PrefixSeqBox =
    var items: str[]
    items = []
    add(items, "peer-a")
    add(items, "peer-b")
    return PrefixSeqBox(
        ownerPeerId: "owner",
        mimeType: "video/mp4",
        bundleCid: "bundle",
        blobCid: "blob",
        catalogKey: "catalog",
        blobByteLen: 3,
        objectTargetBytes: 8,
        sourceBlockBytes: 4,
        objectCount: 1,
        remoteAckPeerIds: items
    )

fn buildTrailingSeqBox(): TrailingSeqBox =
    var peers: str[]
    peers = []
    add(peers, "peer-a")
    add(peers, "peer-b")
    var objects: str[]
    objects = []
    add(objects, "object-a")
    var droplets: str[]
    droplets = []
    add(droplets, "drop-a")
    return TrailingSeqBox(
        ownerPeerId: "owner",
        mimeType: "video/mp4",
        bundleCid: "bundle",
        blobCid: "blob",
        catalogKey: "catalog",
        blobByteLen: 3,
        objectTargetBytes: 8,
        sourceBlockBytes: 4,
        objectCount: 1,
        remoteAckPeerIds: peers,
        objects: objects,
        droplets: droplets
    )

fn buildManualActualResult(): moq.V3Libp2pMoqBuildResult =
    var peers: str[]
    peers = []
    add(peers, "peer-a")
    add(peers, "peer-b")
    var blockIndexes: int32[]
    blockIndexes = []
    add(blockIndexes, 0)
    let droplet = moq.V3Libp2pMoqDroplet(
        objectIndex: 0,
        dropletIndex: 0,
        kindCode: 1,
        key: "droplet-key",
        peerId: "peer-a",
        cid: "droplet-cid",
        degree: 1,
        blockIndexes: blockIndexes,
        payload: bytesFromString("abc")
    )
    var objectDroplets: moq.V3Libp2pMoqDroplet[]
    objectDroplets = []
    add(objectDroplets, droplet)
    let item = moq.V3Libp2pMoqObject(
        objectIndex: 0,
        groupId: "group-0",
        objectId: "object-0",
        priority: 1,
        byteOffset: 0,
        byteLength: 3,
        objectCid: "object-cid",
        sourceBlockBytes: 4,
        sourceBlockCount: 1,
        repairDropletCount: 1,
        droplets: objectDroplets
    )
    var objects: moq.V3Libp2pMoqObject[]
    objects = []
    add(objects, item)
    var allDroplets: moq.V3Libp2pMoqDroplet[]
    allDroplets = []
    add(allDroplets, droplet)
    return moq.V3Libp2pMoqBuildResult(
        ownerPeerId: "owner",
        mimeType: "video/mp4",
        bundleCid: "bundle",
        blobCid: "blob",
        catalogKey: "catalog",
        blobByteLen: 3,
        objectTargetBytes: 8,
        sourceBlockBytes: 4,
        objectCount: 1,
        remoteAckPeerIds: peers,
        objects: objects,
        droplets: allDroplets
    )

fn buildNormalizedActualResult(): moq.V3Libp2pMoqBuildResult =
    let peers = moq.v3Libp2pMoqNormalizePeerCsv("peer-a,peer-b")
    var objects: moq.V3Libp2pMoqObject[]
    objects = []
    var allDroplets: moq.V3Libp2pMoqDroplet[]
    allDroplets = []
    return moq.V3Libp2pMoqBuildResult(
