import std/rawbytes
import std/strformat
import std/strings as strings
import std/strutils
import cheng/v3/libp2p/content/moq_fountain as moq

type SeqBox = object
    items: str[]

type PrefixSeqBox = object
    ownerPeerId: str
    mimeType: str
    bundleCid: str
    blobCid: str
    catalogKey: str
    blobByteLen: int32
    objectTargetBytes: int32
    sourceBlockBytes: int32
    objectCount: int32
    remoteAckPeerIds: str[]

type TrailingSeqBox = object
    ownerPeerId: str
    mimeType: str
    bundleCid: str
    blobCid: str
    catalogKey: str
    blobByteLen: int32
    objectTargetBytes: int32
    sourceBlockBytes: int32
    objectCount: int32
    remoteAckPeerIds: str[]
    objects: str[]
    droplets: str[]

fn moqProbeRemotePeerCsv(): str =
    var parts: str[]
    parts = []
    add(parts, "12D3KooWiWLDFUvGDGRGfmTnfEEPzxuPw83ZnvNeSTWCNwQA4vy4")
    add(parts, ",")
    add(parts, "12D3KooW98NzVx7ZavtVbP9bT3hneTyz2j1kYaFZb54n8qbV5m9V")
    return Fmt(parts)

fn joinIntCsv(values: int32[]): str =
    var parts: str[]
    parts = []
    var idx: int32 = 0
    while idx < values.len:
        if idx > 0:
            add(parts, ",")
        add(parts, strings.IntToStr(values[idx]))
        idx = idx + 1
    return Fmt(parts)

fn fmt2(left: str, right: str): str =
    var parts: str[]
    parts = []
    add(parts, left)
    add(parts, right)
    return Fmt(parts)

fn fmt3(first: str, second: str, third: str): str =
    var parts: str[]
    parts = []
    add(parts, first)
    add(parts, second)
    add(parts, third)
    return Fmt(parts)

fn seqSingleStr(values: str[]): str =
    if values.len <= 0:
        return ""
    return values[0]

fn buildResult(): Result[moq.V3Libp2pMoqBuildResult] =
    let blob = bytesFromString("abc")
    return moq.v3Libp2pMoqBuild(blob,
                                "owner",
                                "peer-a,peer-b",
                                "video/mp4",
                                8,
                                4,
                                1)

fn buildLongPeerResult(): Result[moq.V3Libp2pMoqBuildResult] =
    let blob = bytesFromString("abc")
    let ownerPeerId = "12D3KooWmxfnTuP2Gn5mhXTgeKiDHpKKQfVWKHeYruMuAVbkWmk8"
    let remotePeerCsv = moqProbeRemotePeerCsv()
    return moq.v3Libp2pMoqBuild(blob,
                                ownerPeerId,
                                remotePeerCsv,
                                "video/mp4",
                                8,
                                4,
                                1)

fn buildCopiedLongPeerResult(): Result[moq.V3Libp2pMoqBuildResult] =
    let blob = bytesFromString("abc")
    let ownerPeerId = bytesToString(bytesFromString("12D3KooWmxfnTuP2Gn5mhXTgeKiDHpKKQfVWKHeYruMuAVbkWmk8"))
    let remotePeerCsv = bytesToString(bytesFromString(moqProbeRemotePeerCsv()))
    let mimeType = bytesToString(bytesFromString("video/mp4"))
    return moq.v3Libp2pMoqBuild(blob,
                                ownerPeerId,
                                remotePeerCsv,
                                mimeType,
                                8,
                                4,
                                1)

fn copyIntoOwnedBytes(text: str): Bytes =
    let src = bytesFromString(text)
    var out = bytesAlloc(src.len)
    var idx: int32 = 0
    while idx < src.len:
        bytesSet(out, idx, bytesGet(src, idx))
        idx = idx + 1
    return out

fn buildAllocCopiedLongPeerResult(): Result[moq.V3Libp2pMoqBuildResult] =
    let blob = copyIntoOwnedBytes("abc")
    let ownerPeerId = bytesToString(copyIntoOwnedBytes("12D3KooWmxfnTuP2Gn5mhXTgeKiDHpKKQfVWKHeYruMuAVbkWmk8"))
    let remotePeerCsv = bytesToString(copyIntoOwnedBytes(moqProbeRemotePeerCsv()))
    let mimeType = bytesToString(copyIntoOwnedBytes("video/mp4"))
    return moq.v3Libp2pMoqBuild(blob,
                                ownerPeerId,
                                remotePeerCsv,
                                mimeType,
                                8,
                                4,
                                1)

