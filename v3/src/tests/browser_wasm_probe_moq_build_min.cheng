@exportc("moqBuildLongBlobFirstDropletBlockIndexesEq")
fn moqBuildLongBlobFirstDropletBlockIndexesEq(): int32 =
    let builtRes = buildLongBlobLongPeerResult()
    if IsErr(builtRes):
        return -1
    let built = Value(builtRes)
    if built.droplets.len <= 0:
        return -2
    let droplet = built.droplets[0]
    if droplet.blockIndexes.len != 1:
        return 0
    if droplet.blockIndexes[0] == 0:
        return 1
    return 0

