    if indexes.len <= 0:
        return -1
    return indexes[indexes.len - 1]

@exportc("moqChooseUniqueBlockIndexesLongSeedCount")
fn moqChooseUniqueBlockIndexesLongSeedCount(): int32 =
    let seed = "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef|repair|0|1"
    let indexes = moq.v3Libp2pMoqChooseUniqueBlockIndexes(3, 3, seed)
    return indexes.len

@exportc("moqChooseUniqueBlockIndexesLongSeedLast")
