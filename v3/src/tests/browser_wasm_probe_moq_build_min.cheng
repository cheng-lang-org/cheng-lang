fn buildLongBlobDerivedResult(): Result[moq.V3Libp2pMoqBuildResult] =
    let blob = bytesFromString("moq-fountain-smoke")
    let peers = moq.v3Libp2pMoqNormalizePeerCsv("peer-a,peer-b")
    let objectTargetBytes = 1024
    let sourceBlockBytes = 8
    let repairDropletCount = 2
    let mimeType = "video/mp4"
    let blobCid = moq.v3Libp2pMoqSha256HexBytes(blob)
    var bundleSeed = "owner" + "|" + blobCid + "|" + mimeType + "|" + moq.v3Libp2pMoqJoinCsv(peers)
    bundleSeed = bundleSeed + "|" + intToStr(objectTargetBytes)
    bundleSeed = bundleSeed + "|" + intToStr(sourceBlockBytes)
    bundleSeed = bundleSeed + "|" + intToStr(repairDropletCount)
    let bundleCid = moq.v3Libp2pMoqSha256HexText(bundleSeed)
    let objectRes = moq.v3Libp2pMoqBuildObject(blob,
                                               0,
                                               0,
                                               peers,
                                               bundleCid,
                                               sourceBlockBytes,
                                               repairDropletCount)
    if IsErr(objectRes):
        return Err[moq.V3Libp2pMoqBuildResult](Error(objectRes))
    let objectOut = Value(objectRes)
    var objects: moq.V3Libp2pMoqObject[]
    objects = []
    add(objects, objectOut)
    var droplets: moq.V3Libp2pMoqDroplet[]
    droplets = []
    moq.v3Libp2pMoqAppendDroplets(droplets, objectOut.droplets)
    var out: moq.V3Libp2pMoqBuildResult
    moq.v3Libp2pMoqBuildResultFillFromParts(out,
                                            "owner",
                                            mimeType,
                                            bundleCid,
                                            blobCid,
                                            bytesLen(blob),
                                            objectTargetBytes,
                                            sourceBlockBytes,
                                            peers,
                                            objects,
                                            droplets)
    return Ok[moq.V3Libp2pMoqBuildResult](out)

