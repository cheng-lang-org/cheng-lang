import cheng/v3/lang/parser

fn main(): int32 =
    let sourcePath = "cheng/v3/tests/parser_surface_scan_fixture.cheng"
    let text = "fn sample(flag: bool, res: Result[int32]): int32 =\n" +
               "    let ignored = \"if ? Ok Err Value Error IsOk IsErr ErrorInfoOf\"\n" +
               "    let ignoredChar = '?'\n" +
               "    let verdict = IsOk(res)\n" +
               "    let info = ErrorInfoOf(res)\n" +
               "    return verdict ? 1 : 0\n"
    var layer = parser.V3NormalizedExprLayer()
    var err = ""
    assert(parser.v3ParserReadNormalizedExprLayerFromText(sourcePath, text, layer, err),
           "v3 parser surface scan: read layer")
    assert(parser.v3NormalizedExprLayerExprCount(layer) == 3,
           "v3 parser surface scan: expr count")
    assert(parser.v3NormalizedExprLayerIfCount(layer) == 1,
           "v3 parser surface scan: if count")
    assert(parser.v3NormalizedExprLayerTryCount(layer) == 0,
           "v3 parser surface scan: try count")
    assert(parser.v3NormalizedExprLayerResultIntrinsicCount(layer) == 2,
           "v3 parser surface scan: result intrinsic count")
    assert(parser.v3NormalizedExprLayerHasExprExact(layer,
                                                    parser.v3NormalizedExprResultIntrinsic,
                                                    parser.v3NormalizedExprDetailResultIsOk,
                                                    4),
           "v3 parser surface scan: IsOk line")
    assert(parser.v3NormalizedExprLayerHasExprExact(layer,
                                                    parser.v3NormalizedExprResultIntrinsic,
                                                    parser.v3NormalizedExprDetailResultErrorInfoOf,
                                                    5),
           "v3 parser surface scan: ErrorInfoOf line")
    assert(parser.v3NormalizedExprLayerHasExprExact(layer,
                                                    parser.v3NormalizedExprIf,
                                                    parser.v3NormalizedExprDetailIfTernary,
                                                    6),
           "v3 parser surface scan: ternary line")
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        assert(expr.lineNumber != 2, "v3 parser surface scan: ignore string literal tokens")
        assert(expr.lineNumber != 3, "v3 parser surface scan: ignore char literal tokens")
    echo("v3 parser_surface_scan_smoke ok")
    return 0
