import std/system
import std/rawbytes

type
    BytesBox =
        payload: Bytes

    PacketBox =
        payload: Bytes

fn releaseOwnedBytes(data: var Bytes) =
    if data.data != nil:
        memRelease(data.data)
    data = emptyBytes()

fn smokeBytesLocalOverwrite() =
    var payload: Bytes = bytesAlloc(32)
    let oldPtr = payload.data
    assert(memRefCount(oldPtr) == 1, "v3 bytes overwrite orc: local old rc before overwrite")
    payload = bytesAlloc(48)
    assert(memRefCount(oldPtr) == 0, "v3 bytes overwrite orc: local overwrite releases old payload")
    releaseOwnedBytes(payload)

fn smokeBytesFieldOverwrite() =
    var box: BytesBox
    box.payload = bytesAlloc(40)
    let oldPtr = box.payload.data
    assert(memRefCount(oldPtr) == 1, "v3 bytes overwrite orc: field old rc before overwrite")
    box.payload = bytesAlloc(56)
    assert(memRefCount(oldPtr) == 0, "v3 bytes overwrite orc: field overwrite releases old payload")
    if box.payload.data != nil:
        memRelease(box.payload.data)
    box.payload = emptyBytes()

fn smokeParentObjectCopy() =
    var slot: PacketBox
    slot.payload = bytesAlloc(24)
    let oldSlotPtr = slot.payload.data
    assert(memRefCount(oldSlotPtr) == 1, "v3 bytes overwrite orc: slot old rc before copy")

    var rhs: PacketBox
    rhs.payload = bytesAlloc(64)
    bytesSet(rhs.payload, 0, int32('z'))
    let rhsPtr = rhs.payload.data
    assert(memRefCount(rhsPtr) == 1, "v3 bytes overwrite orc: rhs rc before copy")

    slot = rhs
    assert(memRefCount(oldSlotPtr) == 0, "v3 bytes overwrite orc: parent copy releases old payload")
    assert(memRefCount(rhsPtr) == 2, "v3 bytes overwrite orc: parent copy retains new payload")

    if rhs.payload.data != nil:
        memRelease(rhs.payload.data)
    rhs.payload = emptyBytes()
    assert(memRefCount(rhsPtr) == 1, "v3 bytes overwrite orc: rhs release leaves slot owner")
    assert(bytesGet(slot.payload, 0) == int32('z'),
           "v3 bytes overwrite orc: slot payload survives rhs release")

    if slot.payload.data != nil:
        memRelease(slot.payload.data)
    slot.payload = emptyBytes()
    assert(memRefCount(rhsPtr) == 0, "v3 bytes overwrite orc: final slot release closes payload")

fn main(): int32 =
    smokeBytesLocalOverwrite()
    smokeBytesFieldOverwrite()
    smokeParentObjectCopy()
    echo("v3 bytes_overwrite_orc_smoke ok")
    return 0
