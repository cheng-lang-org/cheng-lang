import std/system
import std/cmdline as cmdline
import std/os
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/host/host
import cheng/v3/project/chain_node as node
import cheng/v3/project/chain_node_libp2p as net

fn main(): int32 =
    echo("debug latest snapshot writefile start")
    let keep = cmdline.ReadFlagOrDefault("--value", "")
    let keepStable = newStringCopy(strDataPtr(keep), strLenFast(keep))
    assert(len(keepStable) > 0, "latest snapshot writefile preserve: arg")
    os.WriteFile("/tmp/latest_snapshot_writefile_keep_main.txt", keep)
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "latest.snapshot.writefile", "quic.twoproc")),
           "latest snapshot writefile preserve: init")
    echo("debug latest snapshot writefile node init")
    var serverHost = host.v3Libp2pHostInit("latest.snapshot.writefile")
    assert(keep == keepStable, "latest snapshot writefile preserve: keep after host")
    os.WriteFile("/tmp/latest_snapshot_writefile_keep_after_host.txt", keep)
    let mintRes = node.v3ChainNodeMint(server, 9, 1001, int64(88))
    assert(keep == keepStable, "latest snapshot writefile preserve: keep after mint")
    os.WriteFile("/tmp/latest_snapshot_writefile_keep_after_mint.txt", keep)
    assert(mintRes.ok, "latest snapshot writefile preserve: mint")
    echo("debug latest snapshot writefile mint")
    let transferRes = node.v3ChainNodeTransfer(server, 9, 1001, 2002, int64(33))
    assert(keep == keepStable, "latest snapshot writefile preserve: keep after transfer")
    os.WriteFile("/tmp/latest_snapshot_writefile_keep_after_transfer.txt", keep)
    assert(transferRes.ok, "latest snapshot writefile preserve: transfer")
    echo("debug latest snapshot writefile transfer")
    let serveRes = net.v3ChainNodeLibp2pServeOnce(server, serverHost)
    assert(keep == keepStable, "latest snapshot writefile preserve: keep after serve")
    os.WriteFile("/tmp/latest_snapshot_writefile_keep_after_serve.txt", keep)
    assert(serveRes.ok, "latest snapshot writefile preserve: serve once")
    echo("debug latest snapshot writefile serve")
    var latest: overlay.V3IngressEnvelope
    let latestRes = net.v3ChainNodeLibp2pLatestSnapshotHostIndex(serverHost, server.address)
    assert(IsOk(latestRes), "latest snapshot writefile preserve: latest index")
    assert(keep == keepStable, "latest snapshot writefile preserve: keep after latest")
    os.WriteFile("/tmp/latest_snapshot_writefile_keep_after_latest.txt", keep)
    let latestIndex = latestRes.value
    assert(keep == keepStable, "latest snapshot writefile preserve: keep after latestIndex")
    let latestEntry = serverHost.storeEntries[latestIndex]
    assert(keep == keepStable, "latest snapshot writefile preserve: keep after latestEntry")
    net.v3ChainNodeLibp2pCopyIngress(latest, latestEntry.ingress)
    assert(keep == keepStable, "latest snapshot writefile preserve: keep after copy")
    echo("v3 latest_snapshot_writefile_preserves_live_str_smoke ok")
    return 0
