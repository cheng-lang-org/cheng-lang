type
    BuildPlanStructArrayTag = enum
        buildPlanStructArrayTagA
        buildPlanStructArrayTagB

    BuildPlanStructArrayItem =
        tag: BuildPlanStructArrayTag
        text: str

fn buildPlanStructArrayItems(): BuildPlanStructArrayItem[] =
    var out: BuildPlanStructArrayItem[]
    out = []
    add(out, BuildPlanStructArrayItem(tag: buildPlanStructArrayTagB, text: "abc"))
    return out

fn main(): int32 =
    let items: BuildPlanStructArrayItem[] = buildPlanStructArrayItems()
    assert(items.len == 1, "build_plan_struct_array_smoke: len")
    let item: BuildPlanStructArrayItem = items[0]
    assert(item.tag == buildPlanStructArrayTagB, "build_plan_struct_array_smoke: tag")
    assert(item.text == "abc", "build_plan_struct_array_smoke: text")
    echo("build_plan_struct_array_smoke ok")
    return 0
