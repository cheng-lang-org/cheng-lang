import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus as consensus
import cheng/v3/project/chain_node as node

fn localGuardedMintViaImportedApply(chain: var node.V3ChainNode,
                                    assetId: int32,
                                    toAccount: int32,
                                    amount: int64): Result[layout.FixedBytes32] =
    if assetId <= 0 || toAccount <= 0:
        return Err[layout.FixedBytes32]("v3 chain_node: invalid mint target")
    if amount <= int64(0):
        return Err[layout.FixedBytes32]("v3 chain_node: mint amount must be positive")
    let parentCid = node.v3ChainNodeAccountHead(chain.index, assetId, toAccount)
    var event = consensus.v3ChainEventMint(
        assetId,
        toAccount,
        parentCid,
        amount,
        chain.nextEpoch,
        chain.nextGanzhi,
        node.v3ChainNodeSpaceSlot(toAccount, toAccount),
        chain.nextTick
    )
    return node.v3ChainNodeApplyEvent(chain, event)

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node: init")
    let mintCidRes = localGuardedMintViaImportedApply(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "chain node local guarded wrapper imported apply: mint")
    assert(server.eventCids.len == 1, "chain node local guarded wrapper imported apply: cid len")
    assert(server.events.len == 1, "chain node local guarded wrapper imported apply: event len")
    assert(layout.fixedBytes32Equal(server.eventCids[0], mintCidRes.value),
           "chain node local guarded wrapper imported apply: first cid")
    assert(server.events[0].kind == consensus.v3ConsensusKindMint,
           "chain node local guarded wrapper imported apply: first event kind")
    echo("v3 chain_node_local_guarded_wrapper_imported_apply_smoke ok")
    return 0
