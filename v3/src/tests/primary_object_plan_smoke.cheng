import std/os
import std/system
import std/result
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/backend/lowering_plan as lower
import cheng/v3/backend/primary_object_plan as pobj

fn main(): int32 =
    let rootDir = os.getCurrentDir()
    let req = creq.v3CompilerRequestNew(
        os.joinPath(rootDir, "v3"),
        os.joinPath(rootDir, "v3/src/tests/program_selfhost_smoke.cheng"),
        os.joinPath(rootDir, "artifacts/v3_program_selfhost/program_selfhost_smoke"),
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    let linkPlanRes = slplan.v3BuildSystemLinkPlanStub(rootDir, req)
    assert(IsOk(linkPlanRes), "v3 primary object smoke: link plan")
    let loweringRes = lower.v3BuildLoweringPlanStub(Value(linkPlanRes))
    assert(IsOk(loweringRes), "v3 primary object smoke: lowering plan")
    let primaryRes = pobj.v3BuildPrimaryObjectPlan(Value(linkPlanRes), Value(loweringRes))
    assert(IsOk(primaryRes), "v3 primary object smoke: primary object plan")
    let primary = Value(primaryRes)
    assert(primary.itemIds.len > 0, "v3 primary object smoke: item ids")
    assert(primary.symbolNames.len == primary.itemIds.len, "v3 primary object smoke: symbol count")
    assert(primary.missingReasons.len > 0, "v3 primary object smoke: missing machine code is explicit")
    echo("v3 primary_object_plan_smoke ok")
    return 0
