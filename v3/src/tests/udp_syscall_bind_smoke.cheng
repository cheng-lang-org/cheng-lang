import std/result
import std/net/transports/udp_syscall as udp
import std/os

fn main(): int32 =
    let socketRes = udp.UdpSocketOpenDgram(false)
    if IsErr(socketRes):
        return 101
    let socket = Value(socketRes)
    var addr: udp.UdpSockAddr
    let addrRes = udp.UdpSockAddrFromHostPort("127.0.0.1", 6210, false, socket.family, false, addr)
    if IsErr(addrRes):
        let _ = os.UdpCloseFd(socket.fd)
        return 102
    let bindRc = os.UdpBindFd(socket.fd, addr.data, addr.len)
    if bindRc != 0:
        let err = os.UdpErrno()
        let _ = os.UdpCloseFd(socket.fd)
        return err
    let closeRc = os.UdpCloseFd(socket.fd)
    if closeRc != 0:
        return 104
    return 0
