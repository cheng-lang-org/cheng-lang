import std/json as json

fn main(): int32 =
    let countKey: str = "count"
    var root: json.JsonNode = json.NewJObject()
    root["name"] = "alpha"
    root[countKey] = int32(7)
    root["ok"] = true
    root["score"] = int64(9)

    var gotName: str
    var gotCount: int64 = -1
    var gotOk: bool = false
    var gotScore: int64 = -1

    assert(json.JsonNodeTryGetStr(root["name"], gotName), "json bracket assign name")
    assert(json.JsonTryGetInt64(root, countKey, gotCount), "json bracket assign count")
    assert(json.JsonTryGetBool(root, "ok", gotOk), "json bracket assign ok")
    assert(json.JsonTryGetInt64(root, "score", gotScore), "json bracket assign score")
    assert(gotName == "alpha", "json bracket assign name value")
    assert(gotCount == 7, "json bracket assign count value")
    assert(gotOk, "json bracket assign ok value")
    assert(gotScore == 9, "json bracket assign score value")

    root["name"] = "beta"
    assert(json.JsonNodeTryGetStr(root["name"], gotName), "json bracket overwrite")
    assert(gotName == "beta", "json bracket overwrite value")

    var child: json.JsonNode = json.NewJObject()
    child["label"] = "nested"
    root["child"] = child
    assert(json.JsonNodeTryGetStr(root["child"]["label"], gotName), "json bracket child")
    assert(gotName == "nested", "json bracket child value")

    echo("v3 json_bracket_assign_smoke ok")
    return 0
