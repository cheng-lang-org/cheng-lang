import std/system
import std/crypto/p256_fixed as pfix

type
    WordBox =
        limbs: int32[8]

fn main(argc: int32, argv: ptr): int32 =
    argc
    argv
    var box: WordBox
    box.limbs[0] = int32(uint32(0xfffffffe))
    box.limbs[1] = int32(uint32(0xffffffff))
    box.limbs[2] = int32(uint32(0xffffffff))
    assert(pfix.p256FixedWordToBitsU64(box.limbs[0]) == uint64(0xfffffffe), "fixed_array_word_bits_probe: limb0")
    assert(pfix.p256FixedWordToBitsU64(box.limbs[1]) == uint64(0xffffffff), "fixed_array_word_bits_probe: limb1")
    assert(pfix.p256FixedWordToBitsU64(box.limbs[2]) == uint64(0xffffffff), "fixed_array_word_bits_probe: limb2")
    echo("v3 fixed_array_word_bits_probe ok")
    return 0
