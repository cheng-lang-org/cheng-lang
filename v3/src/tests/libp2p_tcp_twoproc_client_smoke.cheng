import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/anti_entropy as anti
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/transports/tcp_transport
import cheng/v3/project/chain_node as node
import cheng/v3/project/chain_node_libp2p as net

importc fn driver_c_read_int32_flag_or_default_bridge(key: str, defaultValue: int32): int32

fn main(): int32 =
    let port = driver_c_read_int32_flag_or_default_bridge("--port", -1)
    assert(port > 0, "v3 libp2p tcp twoproc: client port")
    var client = node.v3ChainNodeInit("tcp.twoproc.client", "tcp.twoproc")
    let recvRes = tcp_transport.v3Libp2pTcpRecvPayloadOnce("127.0.0.1",
                                                           port,
                                                           types.v3Libp2pProtocolSync)
    assert(recvRes.ok, "v3 libp2p tcp twoproc: client recv")
    let snapshotRes = net.v3ChainNodeLibp2pDecodeSnapshot(recvRes.value)
    assert(snapshotRes.ok, "v3 libp2p tcp twoproc: client decode")
    let syncRes = node.v3ChainNodeSyncOnce(client, snapshotRes.value)
    assert(syncRes.ok, "v3 libp2p tcp twoproc: client sync")
    assert(syncRes.value, "v3 libp2p tcp twoproc: client changed")
    let aliceRes = node.v3ChainNodeBalance(client, 9, 1001)
    let bobRes = node.v3ChainNodeBalance(client, 9, 2002)
    assert(aliceRes.ok, "v3 libp2p tcp twoproc: client alice")
    assert(bobRes.ok, "v3 libp2p tcp twoproc: client bob")
    assert(aliceRes.value == int64(55), "v3 libp2p tcp twoproc: alice 55")
    assert(bobRes.value == int64(33), "v3 libp2p tcp twoproc: bob 33")
    let clientSnapshot = node.v3ChainNodeServeOnce(client)
    assert(layout.fixedBytes32Equal(clientSnapshot.tipEventCid, snapshotRes.value.tipEventCid),
        "v3 libp2p tcp twoproc: tip cid")
    assert(layout.fixedBytes32Equal(clientSnapshot.forest.forestCid, snapshotRes.value.forest.forestCid),
        "v3 libp2p tcp twoproc: forest cid")
    assert(anti.v3AntiEntropySignatureEqual(clientSnapshot.signature, snapshotRes.value.signature),
        "v3 libp2p tcp twoproc: signature")
    echo("v3 libp2p_tcp_twoproc_client ok")
    return 0
