import std/system
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/lsmr as lsmr
import cheng/v3/chain/binary_types as types

fn main(): int32 =
    let addrGlobalRes: Result[types.V3LsmrAddress] = lsmr.v3LsmrAddressFromSeed("global-a", 3)
    let addrRegionalRes: Result[types.V3LsmrAddress] = lsmr.v3LsmrAddressFromSeed("regional-b", 3)
    let addrEdgeRes: Result[types.V3LsmrAddress] = lsmr.v3LsmrAddressFromSeed("edge-c", 3)
    assert(IsOk(addrGlobalRes), "v3 lsmr tree: global address")
    assert(IsOk(addrRegionalRes), "v3 lsmr tree: regional address")
    assert(IsOk(addrEdgeRes), "v3 lsmr tree: edge address")

    let globalCellRes: Result[lt.V3StateCell] = lsmr.v3LsmrStateCellFromText(1, Value(addrGlobalRes), 1, "global-state")
    let regionalCellRes: Result[lt.V3StateCell] = lsmr.v3LsmrStateCellFromText(2, Value(addrRegionalRes), 2, "regional-state")
    let edgeCellRes: Result[lt.V3StateCell] = lsmr.v3LsmrStateCellFromText(3, Value(addrEdgeRes), 3, "edge-state")
    assert(IsOk(globalCellRes), "v3 lsmr tree: global cell")
    assert(IsOk(regionalCellRes), "v3 lsmr tree: regional cell")
    assert(IsOk(edgeCellRes), "v3 lsmr tree: edge cell")

    let forest: lt.V3StateLayerForest = lsmr.v3BuildStateLayerForest([
        Value(globalCellRes),
        Value(regionalCellRes),
        Value(edgeCellRes)
    ])
    assert(!layout.fixedBytes32Equal(forest.forestCid, layout.fixedBytes32Zero()), "v3 lsmr tree: forest cid")
    assert(forest.globalTree.entryCount == 1, "v3 lsmr tree: global entry count")
    assert(forest.regionalTree.entryCount == 1, "v3 lsmr tree: regional entry count")
    assert(forest.edgeTree.entryCount == 1, "v3 lsmr tree: edge entry count")

    let regionalSummary: lt.V3StateLayerSummary = lsmr.v3StateLayerSummaryFromForest(forest, lt.v3LayerRegional)
    assert(regionalSummary.entryCount == 1, "v3 lsmr tree: regional summary count")
    assert(regionalSummary.nodeCount >= 1, "v3 lsmr tree: regional summary nodes")

    let rootSummaryRes: Result[lt.V3BaguaRootSummary] = lsmr.v3BaguaRootSummaryFromTree(
        lt.v3LayerRegional,
        forest.regionalTree,
        Value(regionalCellRes).baguaId
    )
    assert(IsOk(rootSummaryRes), "v3 lsmr tree: bagua root summary")
    assert(Value(rootSummaryRes).entryDescCount >= 1, "v3 lsmr tree: root descendant count")

    echo("v3 lsmr_bagua_prefix_tree_smoke ok")
    return 0
