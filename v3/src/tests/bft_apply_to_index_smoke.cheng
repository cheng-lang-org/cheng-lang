import std/system
import cheng/v3/chain/consensus
import cheng/v3/project/bft_state_machine as bft

fn main(): int32 =
    var index = consensus.V3ChainIndex()
    let mint = bft.v3BftTxMint(7, 1001, int64(100))
    let exec = bft.v3BftApplyTxToIndex(index, mint, int64(1), 0)
    assert(exec.code == bft.v3BftCodeOk, "v3 bft apply to index: code")
    assert(exec.accepted, "v3 bft apply to index: accepted")
    assert(exec.applied, "v3 bft apply to index: applied")
    assert(index.eventCids.len == 1, "v3 bft apply to index: event cid len")
    assert(index.accountIds.len == 1, "v3 bft apply to index: account len")
    assert(index.balances[0] == int64(100), "v3 bft apply to index: balance")
    echo("v3 bft_apply_to_index_smoke ok")
    return 0
