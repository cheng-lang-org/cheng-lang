import std/system
import std/rawbytes
import std/tls/x509
import cheng/v3/quic/tls/test_pki as testpki

fn main(): int32 =
    assert("localhost" == "localhost", "v3 quic tls policy: server name")
    assert(len("localhost") > 0, "v3 quic tls policy: server name present")
    assert(!false, "v3 quic tls policy: insecure disabled")
    assert(bytesLen(testpki.msquicTestPkiHexDecode(testpki.msquicLocalhostCertDerHex)) > 0, "v3 quic tls policy: cert der")
    assert(bytesLen(testpki.msquicTestPkiHexDecode(testpki.msquicLocalhostCertDerHex)) > 0, "v3 quic tls policy: trust root")
    assert(bytesLen(testpki.msquicTestPkiHexDecode(testpki.msquicLocalhostKeyPkcs8DerHex)) > 0, "v3 quic tls policy: private key")
    assert(X509KeyRsa != X509KeyUnknown, "v3 quic tls policy: key kind")
    echo("v3 quic_tls_policy_smoke ok")
    return 0
