import std/os
import std/strings
import cheng/v3/tooling/r2c_react_v3_surface_main as surface

fn fail(message: str): int32 =
    os.writeLine(os.get_stderr(), message)
    return 1

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    let line: str = "app/App.tsx\t0\t1\t1"
    if surface.r2cSurfaceField(line, 0) != "app/App.tsx":
        return fail("field0")
    if surface.r2cSurfaceField(line, 1) != "0":
        return fail("field1")
    if surface.r2cSurfaceField(line, 2) != "1":
        return fail("field2")
    if surface.r2cSurfaceField(line, 3) != "1":
        return fail("field3")
    let parsed: int32 = surface.r2cSurfaceParseInt32(surface.r2cSurfaceField(line, 3))
    if parsed != 1:
        return fail("parse=" + strings.intToStr(parsed))
    os.writeLine(os.get_stdout(), "r2c-surface-field-smoke ok")
    return 0
