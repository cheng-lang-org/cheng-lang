import std/os
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/anti_entropy as anti
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server = node.v3ChainNodeInit("node-a", "chain-node-a")
    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node forest replay: mint")
    let transferCidRes = node.v3ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, "v3 chain_node forest replay: transfer")

    let served = node.v3ChainNodeServeOnce(server)
    let replayedRes = node.v3ChainNodeReplayFromSnapshot("node-b", served.address, served)
    if !replayedRes.ok:
        panic(Error(replayedRes))
    let replayed = replayedRes.value

    let serverForest = node.v3ChainNodeForestCid(server)
    let replayedForest = node.v3ChainNodeForestCid(replayed)
    if !layout.fixedBytes32Equal(serverForest, replayedForest):
        os.writeLine(os.get_stderr(), "server_forest=" + layout.fixedBytes32Hex(serverForest))
        os.writeLine(os.get_stderr(), "replayed_forest=" + layout.fixedBytes32Hex(replayedForest))
        os.writeLine(os.get_stderr(), "served_forest=" + layout.fixedBytes32Hex(served.forest.forestCid))
        os.writeLine(os.get_stderr(), "served_sig_forest=" + layout.fixedBytes32Hex(served.signature.stateForestCid))
        panic("v3 chain_node forest replay: forest mismatch")
    if !anti.v3AntiEntropySignatureEqual(server.signature, replayed.signature):
        panic("v3 chain_node forest replay: signature mismatch")
    echo("v3 chain_node_forest_replay_smoke ok")
    return 0
