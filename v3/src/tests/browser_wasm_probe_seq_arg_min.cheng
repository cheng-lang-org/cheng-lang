import cheng/v3/libp2p/content/moq_fountain as moq
import std/strings
import std/strutils

fn seqCount(peers: str[]): int32 =
    return peers.len

fn callSeqCount(): int32 =
    let peers = moq.v3Libp2pMoqNormalizePeerCsv("peer-a,peer-b")
    return seqCount(peers)

fn callDirectSeqCount(): int32 =
    let peers = moq.v3Libp2pMoqNormalizePeerCsv("peer-a,peer-b")
    return peers.len

fn callSplitCount(): int32 =
    let parts = moq.v3Libp2pMoqSplitCsv("peer-a,peer-b")
    return parts.len

fn callFirstPartLen(): int32 =
    let parts = moq.v3Libp2pMoqSplitCsv("peer-a,peer-b")
    if parts.len <= 0:
        return -1
    return parts[0].len

fn callFirstTrimmedLen(): int32 =
    let parts = moq.v3Libp2pMoqSplitCsv("peer-a,peer-b")
    if parts.len <= 0:
        return -1
    let candidate = moq.v3Libp2pMoqTrimAscii(parts[0])
    return candidate.len

fn callDirectSliceLen(): int32 =
    let part = strings.SliceBytes("peer-a,peer-b", 0, 6)
    return part.len

fn callDirectSliceEq(): int32 =
    let part = strings.SliceBytes("peer-a,peer-b", 0, 6)
    if part == "peer-a":
        return 1
    return 0

fn callLiteralLen(): int32 =
    let text = "peer-a"
    return text.len

fn callLiteralEq(): int32 =
    let text = "peer-a"
    if text == "peer-a":
        return 1
    return 0

fn callLocalSliceLen(): int32 =
    var item = ""
    item = strings.SliceBytes("peer-a,peer-b", 0, 6)
    return item.len

fn callSeqLiteralFirstLen(): int32 =
    var parts: str[]
    parts = []
    add(parts, "peer-a")
    if parts.len <= 0:
        return -1
    return parts[0].len

fn callSeqSliceFirstLen(): int32 =
    var parts: str[]
    parts = []
    add(parts, strings.SliceBytes("peer-a,peer-b", 0, 6))
    if parts.len <= 0:
        return -1
    return parts[0].len

fn callRangeLoopSum(): int32 =
    var total: int32 = 0
    for i in 0..<6:
        total = total + i + 1
    return total

fn callJoinConcatLen(): int32 =
    var rows: str[]
    rows = []
    add(rows, "owner=" + "peer-a")
    add(rows, "mime=" + "video/mp4")
    add(rows, "blob=" + "cid-1")
    let joined = strutils.Join(rows, "\n")
    return joined.len

fn main(): int32 =
    return 0
