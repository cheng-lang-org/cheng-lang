import std/strutils as strutil

fn main(): int32 =
    let line = "export[0]=cheng/v3/tests/program_selfhost_smoke::main|5|2|2"
    let eqParts = strutil.split(line, '=')
    assert(eqParts.len == 2, "strutils split probe: eq len")
    let pipeParts = strutil.split(eqParts[1], '|')
    assert(pipeParts.len == 4, "strutils split probe: pipe len")
    assert(pipeParts[0] == "cheng/v3/tests/program_selfhost_smoke::main",
           "strutils split probe: symbol")
    assert(pipeParts[1] == "5", "strutils split probe: layout")
    assert(pipeParts[2] == "2", "strutils split probe: effect")
    assert(pipeParts[3] == "2", "strutils split probe: capability")
    echo("v3 strutils_split_probe ok")
    return 0
