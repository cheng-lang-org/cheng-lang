import std/system
import std/result
import cheng/v3/libp2p/core/multiaddr

fn main(): int32 =
    let text = "/ip4/127.0.0.1/tcp/4101"
    let slice = multiaddr.v3Libp2pTextSlice(text, 1, 3)
    assert(slice == "ip4", "v3 libp2p multiaddr helpers: text slice")

    let segRes = multiaddr.v3Libp2pReadSegment(text, 1)
    assert(IsOk(segRes), "v3 libp2p multiaddr helpers: read segment ok")
    let seg = Value(segRes)
    assert(seg.seg == "ip4", "v3 libp2p multiaddr helpers: read segment text")
    assert(seg.next == 5, "v3 libp2p multiaddr helpers: read segment next")

    let portRes = multiaddr.v3Libp2pParsePositiveI32("4101")
    assert(IsOk(portRes), "v3 libp2p multiaddr helpers: parse port ok")
    assert(Value(portRes) == 4101, "v3 libp2p multiaddr helpers: parse port value")
    echo("v3 libp2p_multiaddr_helpers_smoke ok")
    return 0
