import std/system
import std/result
import std/rawbytes
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/dag_mempool as dag
import cheng/v3/chain/erasure_swarm as swarm
import cheng/v3/chain/content_plane as content
import cheng/v3/chain/pin_plane as pin

fn pinPlaneSmokeBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn pinPlaneSmokeBuildResponses(out: var swarm.V3ErasureShardPullResponse[],
                               challenge: pin.V3PinChallenge,
                               manifest: swarm.V3ErasureShardManifest,
                               shardPayloads: Bytes[]) =
    out = []
    var i = challenge.shardCount - 1
    while i >= 0:
        let requestRes = swarm.v3ErasureShardPullRequestMake(manifest, challenge.shardIndices[i])
        assert(IsOk(requestRes), "v3 pin plane smoke: request")
        let pos = pin.v3PinManifestShardPos(manifest, challenge.shardIndices[i])
        assert(pos >= 0, "v3 pin plane smoke: manifest shard pos")
        var response = swarm.v3ErasureShardPullResponseZero()
        let responseFillRes = swarm.v3ErasureShardPullResponseFill(response,
                                                                   Value(requestRes),
                                                                   shardPayloads[pos])
        assert(IsOk(responseFillRes), "v3 pin plane smoke: response")
        add(out, response)
        i = i - 1

fn pinPlaneSmokeAssertOfferFromArtifacts(bundleCid: layout.FixedBytes32,
                                         summary: dag.V3DagBlobSummary,
                                         params: swarm.V3ErasureEncodingParams,
                                         manifest: swarm.V3ErasureShardManifest,
                                         expected: pin.V3PinOffer) =
    var artifacts = content.v3ContentPublishArtifactsZero()
    artifacts.blobSummary = summary
    artifacts.erasureParams = params
    artifacts.erasureManifest = manifest
    artifacts.bundleCid = bundleCid
    let offerFromArtifactsRes = pin.v3PinOfferFromArtifacts(artifacts, 120, 3, 77, 33)
    assert(IsOk(offerFromArtifactsRes), "v3 pin plane smoke: artifacts offer")
    let offerFromArtifacts = Value(offerFromArtifactsRes)
    assert(layout.fixedBytes32Equal(offerFromArtifacts.offerCid, expected.offerCid),
        "v3 pin plane smoke: artifacts offer cid")
    assert(pinPlaneSmokeBytesEqual(pin.v3PinOfferEncode(offerFromArtifacts),
                                   pin.v3PinOfferEncode(expected)),
        "v3 pin plane smoke: artifacts offer payload")

fn main(): int32 =
    let blob = bytesFromString("v3 pin plane smoke blob")
    let bundleCid = lt.v3HashInts("v3.pin.bundle", [11, 22, 33])
    let paramsRes = swarm.v3ErasureEncodingParamsMake(swarm.v3ErasureLayoutRsSystematic, 3, 2, 8)
    assert(IsOk(paramsRes), "v3 pin plane smoke: params")
    let params = Value(paramsRes)
    let encodedRes = swarm.v3ErasureEncodeShardPayloads(blob, params)
    assert(IsOk(encodedRes), "v3 pin plane smoke: encode")
    let shardPayloads = Value(encodedRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    for i in 0..<shardPayloads.len:
        add(shardPayloadCids, swarm.v3ErasureShardPayloadCid(shardPayloads[i]))

    let summaryRes = dag.v3DagBlobSummaryFromBytes(blob, 8)
    assert(IsOk(summaryRes), "v3 pin plane smoke: summary")
    let summary = Value(summaryRes)
    let manifestRes = swarm.v3ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), "v3 pin plane smoke: manifest")
    let manifest = Value(manifestRes)

    let offerRes = pin.v3PinOfferMake(bundleCid,
                                      summary.summaryCid,
                                      summary.blobCid,
                                      manifest.manifestCid,
                                      120,
                                      3,
                                      77,
                                      33)
    assert(IsOk(offerRes), "v3 pin plane smoke: offer")
    let offer = Value(offerRes)
    let offerOk = pin.v3PinOfferValidateAgainstManifest(offer, manifest)
    assert(IsOk(offerOk), "v3 pin plane smoke: offer validate")
    pinPlaneSmokeAssertOfferFromArtifacts(bundleCid, summary, params, manifest, offer)
    let offerPayload = pin.v3PinOfferEncode(offer)
    let offerPayloadOk = pin.v3PinOfferValidatePayload(offerPayload, offer.offerCid)
    assert(IsOk(offerPayloadOk), "v3 pin plane smoke: offer payload")
    let offerDecodeRes = pin.v3PinOfferDecode(offerPayload)
    assert(IsOk(offerDecodeRes), "v3 pin plane smoke: offer decode")
    assert(layout.fixedBytes32Equal(Value(offerDecodeRes).offerCid, offer.offerCid),
        "v3 pin plane smoke: offer cid roundtrip")

    let providerPeerId = lt.v3HashInts("v3.pin.provider", [2])
    let acceptRes = pin.v3PinAcceptMake(offer, providerPeerId, 160)
    assert(IsOk(acceptRes), "v3 pin plane smoke: accept")
    let accept = Value(acceptRes)
    let acceptOk = pin.v3PinAcceptValidateAgainstOffer(accept, offer)
    assert(IsOk(acceptOk), "v3 pin plane smoke: accept validate")
    let acceptPayload = pin.v3PinAcceptEncode(accept)
    let acceptPayloadOk = pin.v3PinAcceptValidatePayload(acceptPayload, accept.acceptCid)
    assert(IsOk(acceptPayloadOk), "v3 pin plane smoke: accept payload")

    let challengeRes = pin.v3PinBuildChallenge(offer, accept, manifest, 100)
    assert(IsOk(challengeRes), "v3 pin plane smoke: challenge")
    let challenge = Value(challengeRes)
    let challengeOk = pin.v3PinChallengeValidateAgainstInputs(challenge,
                                                              offer,
                                                              accept,
                                                              manifest)
    assert(IsOk(challengeOk), "v3 pin plane smoke: challenge validate")
    let challengePayload = pin.v3PinChallengeEncode(challenge)
    let challengePayloadOk = pin.v3PinChallengeValidatePayload(challengePayload, challenge.challengeCid)
    assert(IsOk(challengePayloadOk), "v3 pin plane smoke: challenge payload")

    var responses: swarm.V3ErasureShardPullResponse[]
    pinPlaneSmokeBuildResponses(responses, challenge, manifest, shardPayloads)
    let proofRes = pin.v3PinProofFromResponses(challenge, manifest, responses)
    assert(IsOk(proofRes), "v3 pin plane smoke: proof")
    let proof = Value(proofRes)
    let proofOk = pin.v3PinProofValidateAgainstInputs(proof,
                                                      challenge,
                                                      accept,
                                                      manifest)
    assert(IsOk(proofOk), "v3 pin plane smoke: proof validate")
    let proofPayload = pin.v3PinProofEncode(proof)
    let proofPayloadOk = pin.v3PinProofValidatePayload(proofPayload, proof.proofCid)
    assert(IsOk(proofPayloadOk), "v3 pin plane smoke: proof payload")

    let settlementRes = pin.v3PinBuildSettlement(offer,
                                                 accept,
                                                 challenge,
                                                 manifest,
                                                 proof,
                                                 101)
    assert(IsOk(settlementRes), "v3 pin plane smoke: reward settlement")
    let settlement = Value(settlementRes)
    assert(settlement.status == pin.v3PinSettlementStatusReward,
        "v3 pin plane smoke: reward settlement status")
    assert(settlement.rewardUnits == offer.rewardUnits,
        "v3 pin plane smoke: reward settlement amount")
    let settlementPayload = pin.v3PinSettlementEncode(settlement)
    let settlementPayloadOk = pin.v3PinSettlementValidatePayload(settlementPayload, settlement.settlementCid)
    assert(IsOk(settlementPayloadOk), "v3 pin plane smoke: settlement payload")

    var badProof = proof
    let junk = bytesFromString("xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx")
    badProof.payloadConcat = bytesSlice(junk, 0, proof.payloadConcatLen)
    badProof.payloadConcatLen = bytesLen(badProof.payloadConcat)
    badProof.proofCid = pin.v3PinProofCid(badProof.challengeCid,
                                          badProof.acceptCid,
                                          badProof.manifestCid,
                                          badProof.shardIndices,
                                          badProof.shardPayloadLens,
                                          badProof.payloadConcat)
    let badProofGenericOk = pin.v3PinProofValidate(badProof)
    assert(IsOk(badProofGenericOk), "v3 pin plane smoke: bad proof generic validate")
    let badProofOk = pin.v3PinProofValidateAgainstInputs(badProof,
                                                         challenge,
                                                         accept,
                                                         manifest)
    assert(IsErr(badProofOk), "v3 pin plane smoke: bad proof reject")
    let slashSettlementRes = pin.v3PinBuildSettlement(offer,
                                                      accept,
                                                      challenge,
                                                      manifest,
                                                      badProof,
                                                      102)
    assert(IsOk(slashSettlementRes), "v3 pin plane smoke: slash settlement")
    let slashSettlement = Value(slashSettlementRes)
    assert(slashSettlement.status == pin.v3PinSettlementStatusSlash,
        "v3 pin plane smoke: slash settlement status")
    assert(slashSettlement.slashUnits == accept.slashUnits,
        "v3 pin plane smoke: slash settlement amount")
    let slashSettlementOk = pin.v3PinSettlementValidateAgainstInputs(slashSettlement,
                                                                     offer,
                                                                     accept,
                                                                     challenge,
                                                                     manifest,
                                                                     badProof)
    assert(IsOk(slashSettlementOk), "v3 pin plane smoke: slash settlement validate")
    assert(pinPlaneSmokeBytesEqual(offerPayload, pin.v3PinOfferEncode(Value(offerDecodeRes))),
        "v3 pin plane smoke: offer payload roundtrip")

    echo("v3 pin_plane_smoke ok")
    return 0
