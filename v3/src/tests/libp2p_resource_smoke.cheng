import std/system
import std/rawbytes
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/protocols/identify as identify
import cheng/v3/libp2p/transports/tcp_transport
import cheng/v3/libp2p/host/host

fn main(): int32 =
    var server = host.v3Libp2pHostInit("resource.server")
    var trustedClient = host.v3Libp2pHostInit("resource.trusted.client")
    var publicClient = host.v3Libp2pHostInit("resource.public.client")

    host.v3Libp2pHostSetTrustedInfra(server, true)
    host.v3Libp2pHostSetTrustedInfra(trustedClient, true)
    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolIdentify)
    host.v3Libp2pRegisterHandler(trustedClient, types.v3Libp2pProtocolIdentify)
    host.v3Libp2pRegisterHandler(publicClient, types.v3Libp2pProtocolIdentify)

    var serverAddr = types.v3Libp2pMultiaddrZero()
    multiaddr.v3Libp2pMultiaddrFillTcp(serverAddr, "127.0.0.1", 6321)
    let listenRes = host.v3Libp2pListen(server, serverAddr)
    assert(IsOk(listenRes), "v3 libp2p resource: server listen")

    var trustedAddr = types.v3Libp2pMultiaddrZero()
    multiaddr.v3Libp2pMultiaddrFillTcp(trustedAddr, "127.0.0.1", 6322)
    let trustedListenRes = host.v3Libp2pListen(trustedClient, trustedAddr)
    assert(IsOk(trustedListenRes), "v3 libp2p resource: trusted listen")

    let dialTrustedRes = host.v3Libp2pDial(trustedClient,
                                           server.selfPeerId,
                                           serverAddr,
                                           overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(dialTrustedRes), "v3 libp2p resource: trusted dial")
    let dialBackRes = host.v3Libp2pDial(server,
                                        trustedClient.selfPeerId,
                                        trustedAddr,
                                        overlay.v3OverlayRoleRegionalRouter)
    assert(IsOk(dialBackRes), "v3 libp2p resource: server dial back")
    host.v3Libp2pSetPeerTrustedInfra(server, trustedClient.selfPeerId, true)
    host.v3Libp2pSetPeerTrustedInfra(trustedClient, server.selfPeerId, true)
    let localTrustedRes = host.v3Libp2pIdentifyResourcesForPeer(server, trustedClient.selfPeerId)
    assert(IsOk(localTrustedRes), "v3 libp2p resource: local trusted visible")
    let identifyPayload = identify.v3Libp2pIdentifyRequestEncode()
    let localServeRes = host.v3Libp2pServePayloadFromPeer(server,
                                                          trustedClient.selfPeerId,
                                                          types.v3Libp2pProtocolIdentify,
                                                          identifyPayload)
    assert(IsOk(localServeRes), "v3 libp2p resource: local identify serve")
    var localServePayload: Bytes
    localServePayload = Value(localServeRes)
    var localDecoded = types.v3Libp2pNodeResourceZero()
    let localDecodeRes = identify.v3Libp2pIdentifyResponseDecodeFill(localDecoded,
                                                                     localServePayload)
    assert(IsOk(localDecodeRes), "v3 libp2p resource: local identify decode")
    let localTcpRes = tcp_transport.v3Libp2pTcpLoopbackRequestResponseRaw(types.v3Libp2pProtocolIdentify,
                                                                          identifyPayload.data,
                                                                          identifyPayload.len,
                                                                          localServePayload.data,
                                                                          localServePayload.len)
    assert(IsOk(localTcpRes), "v3 libp2p resource: local tcp rr")
    let localTcpPayload = Value(localTcpRes)
    assert(bytesLen(localTcpPayload) == bytesLen(localServePayload),
        "v3 libp2p resource: local tcp rr len")
    let responseMagic = bytesFromString("v3.identify.resource")
    for i in 0..<bytesLen(responseMagic):
        assert(bytesGet(localTcpPayload, i) == bytesGet(responseMagic, i),
            "v3 libp2p resource: local tcp rr magic")
    var localTcpDecoded = types.v3Libp2pNodeResourceZero()
    let localTcpDecodeRes = identify.v3Libp2pIdentifyResponseDecodeFill(localTcpDecoded,
                                                                        localTcpPayload)
    assert(IsOk(localTcpDecodeRes), "v3 libp2p resource: local tcp rr decode")

    var sample = types.v3Libp2pNodeResourceZero()
    let identifyRes = host.v3Libp2pIdentifyRequest(trustedClient,
                                                   server,
                                                   server.selfPeerId,
                                                   sample)
    assert(IsOk(identifyRes), "v3 libp2p resource: trusted identify")
    assert(sample.sampledAtEpochSeconds > 0, "v3 libp2p resource: sampled time")
    assert(sample.cpuLogicalCores > 0, "v3 libp2p resource: cpu cores")
    assert(sample.memoryTotalBytes > int64(0), "v3 libp2p resource: memory total")
    assert(sample.memoryAvailableBytes > int64(0), "v3 libp2p resource: memory available")
    assert(sample.memoryAvailableBytes <= sample.memoryTotalBytes,
        "v3 libp2p resource: memory range")
    assert(sample.diskTotalBytes > int64(0), "v3 libp2p resource: disk total")
    assert(sample.diskAvailableBytes > int64(0), "v3 libp2p resource: disk available")
    assert(sample.diskAvailableBytes <= sample.diskTotalBytes,
        "v3 libp2p resource: disk range")
    if sample.gpuDeviceCount > 0:
        assert(sample.gpuCoreCount > 0, "v3 libp2p resource: gpu cores")
    if sample.npuDeviceCount > 0:
        assert(sample.npuCoreCount > 0, "v3 libp2p resource: npu cores")

    var cached = types.v3Libp2pNodeResourceZero()
    assert(host.v3Libp2pPeerResourcesFill(cached, trustedClient, server.selfPeerId),
        "v3 libp2p resource: cached peer sample")
    assert(cached.cpuLogicalCores == sample.cpuLogicalCores,
        "v3 libp2p resource: cached cpu")
    assert(cached.memoryTotalBytes == sample.memoryTotalBytes,
        "v3 libp2p resource: cached memory")
    assert(cached.diskTotalBytes == sample.diskTotalBytes,
        "v3 libp2p resource: cached disk")
    assert(cached.gpuCoreCount == sample.gpuCoreCount,
        "v3 libp2p resource: cached gpu")
    assert(cached.npuCoreCount == sample.npuCoreCount,
        "v3 libp2p resource: cached npu")

    let publicDialRes = host.v3Libp2pDial(publicClient,
                                          server.selfPeerId,
                                          serverAddr,
                                          overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(publicDialRes), "v3 libp2p resource: public dial")
    var denied = types.v3Libp2pNodeResourceZero()
    let deniedRes = host.v3Libp2pIdentifyRequest(publicClient,
                                                 server,
                                                 server.selfPeerId,
                                                 denied)
    assert(IsErr(deniedRes), "v3 libp2p resource: public denied")

    echo("v3 libp2p_resource_smoke ok")
    return 0
