import std/system
import cheng/v3/chain/binary_types as types
import cheng/v3/project/chain_node as node

fn main(): int32 =
    let alice = node.v3ChainNodeAccountAddress(7, 1001)
    let aliceAgain = node.v3ChainNodeAccountAddress(7, 1001)
    let bob = node.v3ChainNodeAccountAddress(7, 2002)
    assert(alice.depth == 3, "v3 chain_node account address smoke: depth")
    assert(types.v3LsmrAddressEqual(alice, aliceAgain), "v3 chain_node account address smoke: deterministic")
    assert(!types.v3LsmrAddressEqual(alice, bob), "v3 chain_node account address smoke: distinct")
    echo("v3 chain_node_account_address_smoke ok")
    return 0
