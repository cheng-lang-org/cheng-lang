import cheng/v3/project/chain_node as node
import cheng/v3/project/chain_node_cli_core as cli

fn main(): int32 =
    var state: node.V3ChainNode
    assert(IsOk(node.V3ChainNodeInitInto(state, "snapshot-write-node", "snapshot-write-seed")),
           "v3 chain_node snapshot write boundary: init")
    var snapshot: node.V3ChainNodeServeSnapshot
    node.V3ChainNodeServeOnceInto(snapshot, state)
    let statePath = "/tmp/chain_node_snapshot_write_return_boundary_smoke.state"
    assert(cli.V3ChainNodeCliWriteState(statePath, snapshot),
           "v3 chain_node snapshot write boundary: write")
    echo("v3 chain_node_snapshot_write_return_boundary_smoke ok")
    return 0
