import std/result
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/path as v3path
import cheng/v3/backend/system_link_exec as sexec

fn main(): int32 =
    let workspaceRoot = v3path.v3PathCurrentDir()
    let packageRoot = v3path.v3PathJoin(workspaceRoot, "v3")
    let sourcePath = v3path.v3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = v3path.v3PathJoin(workspaceRoot, "artifacts/v3_compiler_world/program_selfhost_smoke")
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    let planRes = sexec.v3BuildSystemLinkExecPlan(workspaceRoot, req)
    assert(IsOk(planRes), "v3 compiler world: build plan")
    let plan = Value(planRes)
    assert(plan.compilerCsg.nodeCount > 0, "v3 compiler world: csg node count")
    assert(plan.exportSurface.exportedSymbolCount > 0, "v3 compiler world: export surface count")
    assert(plan.lockCheckEnabled == false, "v3 compiler world: lock disabled by default")
    assert(plan.baselineSurfaceChecked == false, "v3 compiler world: baseline disabled by default")
    assert(plan.compileReceipt.bootstrapStage == "stage3_local", "v3 compiler world: bootstrap stage")
    assert(len(plan.nativeLinkPlan.missingReasons) > 0, "v3 compiler world: native link still gated")
    echo("v3 compiler_world_smoke ok")
    return 0
