import std/result
import std/rawbytes
import std/crypto/rand

fn main(): int32 =
    let entropyRes: Result[Bytes] = rand.systemRandomBytes(16)
    assert(IsOk(entropyRes), "v3 system entropy smoke: result")
    let entropy: Bytes = Value(entropyRes)
    assert(bytesLen(entropy) == 16, "v3 system entropy smoke: len")
    echo("v3 system_entropy_smoke ok")
    return 0
