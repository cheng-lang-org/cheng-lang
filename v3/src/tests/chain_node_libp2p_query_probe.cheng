import std/system
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host
import cheng/v3/project/chain_node as node
import cheng/v3/project/chain_node_libp2p as net

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node libp2p query probe: init server")
    var client: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(client, "node-b", "chain-node-a")),
           "v3 chain_node libp2p query probe: init client")

    var serverHost = host.v3Libp2pHostInit("chain.server")
    var clientHost = host.v3Libp2pHostInit("chain.client")
    var serverAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(serverAddr, "127.0.0.1", 6201)
    let listenRes = host.v3Libp2pListen(serverHost, serverAddr)
    assert(listenRes.ok, "v3 chain_node libp2p query probe: listen")

    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolGossipsub)
    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolStore)
    host.v3Libp2pRegisterHandler(serverHost, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolGossipsub)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolStore)
    host.v3Libp2pRegisterHandler(clientHost, types.v3Libp2pProtocolSync)

    let dialRes = host.v3Libp2pDial(clientHost,
                                    serverHost.selfPeerId,
                                    serverAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 chain_node libp2p query probe: dial")

    let mintRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintRes.ok, "v3 chain_node libp2p query probe: mint")
    let transferRes = node.v3ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferRes.ok, "v3 chain_node libp2p query probe: transfer")

    let serveRes = net.v3ChainNodeLibp2pServeOnce(server, serverHost)
    assert(serveRes.ok, "v3 chain_node libp2p query probe: serve")

    var latest: overlay.V3IngressEnvelope
    let latestRes = net.v3ChainNodeLibp2pLatestSnapshotInto(serverHost, client.address, latest)
    assert(latestRes.ok, "v3 chain_node libp2p query probe: latest")

    var hostSnapshot: node.V3ChainNodeServeSnapshot
    let hostDecodeRes = net.v3ChainNodeLibp2pDecodeLatestSnapshotFromHostFill(serverHost,
                                                                              client.address,
                                                                              hostSnapshot)
    assert(hostDecodeRes.ok, "v3 chain_node libp2p query probe: host decode")
    assert(hostSnapshot.eventCids.len == 2, "v3 chain_node libp2p query probe: host decode len")

    var query: overlay.V3StoreQuery
    net.v3ChainNodeLibp2pSnapshotQueryFill(query, client.address)
    var entries: overlay.V3IngressEnvelope[]
    let entriesRes = host.v3Libp2pSyncRequest(clientHost, serverHost, serverHost.selfPeerId, query, entries)
    assert(entriesRes.ok, "v3 chain_node libp2p query probe: sync request")
    assert(entries.len == 2, "v3 chain_node libp2p query probe: entries len")

    var syncedSnapshot: node.V3ChainNodeServeSnapshot
    let syncedDecodeRes = net.v3ChainNodeLibp2pDecodeLatestSnapshotFill(entries,
                                                                        client.address,
                                                                        syncedSnapshot)
    assert(syncedDecodeRes.ok, "v3 chain_node libp2p query probe: synced decode")

    let syncRes = node.v3ChainNodeSyncOnce(client, syncedSnapshot)
    assert(syncRes.ok, "v3 chain_node libp2p query probe: sync")
    assert(syncRes.value, "v3 chain_node libp2p query probe: sync changed")

    echo("v3 chain_node_libp2p_query_probe ok")
    return 0
