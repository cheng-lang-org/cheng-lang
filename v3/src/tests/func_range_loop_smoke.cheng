import std/strformat
import std/strings

fn main(): int32
    var total: int32 = 0
    for i in 0..<4:
        total = total + i
    let summary: str = Fmt"sum={intToStr(total)}"
    if summary != "sum=6":
        return 1
    let line: str = Fmt"v3 func_range_loop_smoke {summary} ok"
    if line != "v3 func_range_loop_smoke sum=6 ok":
        return 1
    echo(Fmt"v3 func_range_loop_smoke {summary} ok")
    return 0
