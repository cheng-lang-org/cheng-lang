importc fn driver_c_str_from_utf8_copy_bridge(raw: ptr, n: int32): str
importc fn driver_c_str_concat_bridge(left: str, right: str): str

fn main(): int32 =
    assert(driver_c_str_from_utf8_copy_bridge("abc", 3) == "abc", "str from utf8 return")
    assert(driver_c_str_concat_bridge("abc", "def") == "abcdef", "str concat return")
    echo("str_return_bridge_probe ok")
    return 0
