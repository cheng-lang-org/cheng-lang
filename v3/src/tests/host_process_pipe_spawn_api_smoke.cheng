import std/os
import std/os_host_process as hostos
import std/strutils as strutil
import std/strings

type DrainResult = object
    output: str
    exitCode: int32

fn drainReadFdFill(readFd0: int32,
                   pid: int64,
                   out: var DrainResult) =
    var readFd: int32 = readFd0
    var output = ""
    var eof = false
    var spins: int32
    var exitCode: int32 = -1
    var waited = false
    while !eof && spins < 200:
        spins = spins + 1
        let readRes: os.TextReadResult = hostos.FdReadWait(readFd, 65536, 20)
        let text: str = readRes.text
        if strings.Len(text) > 0:
            output = output + text
        eof = readRes.eof
        if !eof:
            let waitRes: os.PtyWaitResult = hostos.PtyWait(pid)
            if waitRes.waitStatus < 0:
                assert(false, "api wait failed")
            if waitRes.waitStatus == 1:
                exitCode = waitRes.exitCode
                waited = true
                break
        os.SleepMs(10)
    hostos.PtyClose(readFd)
    if !waited:
        var waitSpins: int32
        while waitSpins < 200:
            waitSpins = waitSpins + 1
            let waitRes: os.PtyWaitResult = hostos.PtyWait(pid)
            if waitRes.waitStatus < 0:
                assert(false, "api wait final failed")
            if waitRes.waitStatus == 1:
                exitCode = waitRes.exitCode
                waited = true
                break
            os.SleepMs(10)
    assert(waited, "api wait timeout")
    out.output = output
    out.exitCode = exitCode

fn main(): int32 =
    let argv: str[] = ["api-ok"]
    var env: str[]
    let spawnRes: os.ExecFilePipeSpawnResult = hostos.ExecFilePipeSpawn("/bin/echo", argv, env, "")
    assert(spawnRes.ok, "execFilePipeSpawn ok")
    assert(spawnRes.readFd >= 0, "execFilePipeSpawn read fd")
    assert(spawnRes.writeFd >= 0, "execFilePipeSpawn write fd")
    assert(spawnRes.pid > 0, "execFilePipeSpawn pid")
    hostos.PtyClose(spawnRes.writeFd)
    var spawnDrain: DrainResult
    drainReadFdFill(spawnRes.readFd, spawnRes.pid, spawnDrain)
    assert(spawnDrain.exitCode == 0, "execFilePipeSpawn exit")
    assert(strutil.Strip(spawnDrain.output) == "api-ok", "execFilePipeSpawn output")

    let pipeRes: os.PipeSpawnResult = hostos.PipeSpawn("/bin/echo pipe-ok", "")
    assert(pipeRes.ok, "pipeSpawn ok")
    assert(pipeRes.readFd >= 0, "pipeSpawn read fd")
    assert(pipeRes.writeFd >= 0, "pipeSpawn write fd")
    assert(pipeRes.pid > 0, "pipeSpawn pid")
    hostos.PtyClose(pipeRes.writeFd)
    var pipeDrain: DrainResult
    drainReadFdFill(pipeRes.readFd, pipeRes.pid, pipeDrain)
    assert(pipeDrain.exitCode == 0, "pipeSpawn exit")
    assert(strutil.Strip(pipeDrain.output) == "pipe-ok", "pipeSpawn output")

    var stdinArgv: str[]
    let stdinRes: os.ExecFilePipeSpawnResult = hostos.ExecFilePipeSpawn("/bin/cat", stdinArgv, env, "")
    assert(stdinRes.ok, "execFilePipeSpawn stdin ok")
    assert(stdinRes.readFd >= 0, "execFilePipeSpawn stdin read fd")
    assert(stdinRes.writeFd >= 0, "execFilePipeSpawn stdin write fd")
    assert(stdinRes.pid > 0, "execFilePipeSpawn stdin pid")
    let stdinText = "pipe-stdin-ok\n"
    let wrote: int32 = hostos.PtyWrite(stdinRes.writeFd, stdinText)
    assert(wrote == len(stdinText), "execFilePipeSpawn stdin write")
    hostos.PtyClose(stdinRes.writeFd)
    var stdinDrain: DrainResult
    drainReadFdFill(stdinRes.readFd, stdinRes.pid, stdinDrain)
    assert(stdinDrain.exitCode == 0, "execFilePipeSpawn stdin exit")
    assert(stdinDrain.output == stdinText, "execFilePipeSpawn stdin output")

    let stderrArgv: str[] = ["-c", "printf stderr-ok >&2"]
    let stderrRes: os.ExecFilePipeSpawnResult = hostos.ExecFilePipeSpawn("/bin/sh", stderrArgv, env, "")
    assert(stderrRes.ok, "execFilePipeSpawn stderr ok")
    assert(stderrRes.readFd >= 0, "execFilePipeSpawn stderr read fd")
    assert(stderrRes.writeFd >= 0, "execFilePipeSpawn stderr write fd")
    assert(stderrRes.pid > 0, "execFilePipeSpawn stderr pid")
    hostos.PtyClose(stderrRes.writeFd)
    var stderrDrain: DrainResult
    drainReadFdFill(stderrRes.readFd, stderrRes.pid, stderrDrain)
    assert(stderrDrain.exitCode == 0, "execFilePipeSpawn stderr exit")
    assert(strutil.Strip(stderrDrain.output) == "stderr-ok", "execFilePipeSpawn stderr output")

    echo("v3 host_process_pipe_spawn_api_smoke ok")
    return 0
