import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/anti_entropy as anti
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server = node.v3ChainNodeInit("node-a", "chain-node-a")
    var client = node.v3ChainNodeInit("node-b", "chain-node-b")

    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node smoke: mint")

    let aliceAfterMintRes = node.v3ChainNodeBalance(server, 7, 1001)
    assert(aliceAfterMintRes.ok, "v3 chain_node smoke: balance after mint")
    assert(aliceAfterMintRes.value == int64(100), "v3 chain_node smoke: minted balance")

    let transferCidRes = node.v3ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, "v3 chain_node smoke: transfer")
    assert(!layout.fixedBytes32Equal(mintCidRes.value, transferCidRes.value), "v3 chain_node smoke: transfer cid differs")

    let aliceServerRes = node.v3ChainNodeBalance(server, 7, 1001)
    let bobServerRes = node.v3ChainNodeBalance(server, 7, 2002)
    assert(aliceServerRes.ok, "v3 chain_node smoke: server alice balance")
    assert(bobServerRes.ok, "v3 chain_node smoke: server bob balance")
    assert(aliceServerRes.value == int64(60), "v3 chain_node smoke: server alice 60")
    assert(bobServerRes.value == int64(40), "v3 chain_node smoke: server bob 40")

    let aliceClientPreRes = node.v3ChainNodeBalance(client, 7, 1001)
    let bobClientPreRes = node.v3ChainNodeBalance(client, 7, 2002)
    assert(aliceClientPreRes.ok, "v3 chain_node smoke: client pre balance")
    assert(bobClientPreRes.ok, "v3 chain_node smoke: client pre receiver balance")
    assert(aliceClientPreRes.value == int64(0), "v3 chain_node smoke: client pre alice zero")
    assert(bobClientPreRes.value == int64(0), "v3 chain_node smoke: client pre bob zero")

    let served = node.v3ChainNodeServeOnce(server)
    let syncRes = node.v3ChainNodeSyncOnce(client, served)
    assert(syncRes.ok, "v3 chain_node smoke: sync once")
    assert(syncRes.value, "v3 chain_node smoke: sync changed state")

    let aliceClientRes = node.v3ChainNodeBalance(client, 7, 1001)
    let bobClientRes = node.v3ChainNodeBalance(client, 7, 2002)
    assert(aliceClientRes.ok, "v3 chain_node smoke: client alice balance")
    assert(bobClientRes.ok, "v3 chain_node smoke: client bob balance")
    assert(aliceClientRes.value == int64(60), "v3 chain_node smoke: client alice 60")
    assert(bobClientRes.value == int64(40), "v3 chain_node smoke: client bob 40")

    let clientServed = node.v3ChainNodeServeOnce(client)
    assert(layout.fixedBytes32Equal(served.tipEventCid, clientServed.tipEventCid), "v3 chain_node smoke: tip cid一致")
    assert(layout.fixedBytes32Equal(node.v3ChainNodeForestCid(server), node.v3ChainNodeForestCid(client)), "v3 chain_node smoke: forest cid一致")
    assert(layout.fixedBytes32Equal(served.forest.forestCid, clientServed.forest.forestCid), "v3 chain_node smoke: served forest一致")
    assert(anti.v3AntiEntropySignatureEqual(served.signature, clientServed.signature), "v3 chain_node smoke: signature一致")
    let syncAgainRes = node.v3ChainNodeSyncOnce(client, served)
    assert(syncAgainRes.ok, "v3 chain_node smoke: sync again")
    assert(!syncAgainRes.value, "v3 chain_node smoke: second sync idle")

    echo("v3 chain_node_smoke ok")
    return 0
