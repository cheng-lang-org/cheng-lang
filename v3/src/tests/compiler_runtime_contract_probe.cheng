import cheng/v3/tooling/compiler_runtime as crun

fn main(): int32 =
    let direct = crun.v3CompilerRuntimePath("/tmp/cheng-lang", "v3/src/tooling/compiler_main.cheng")
    let contract = crun.v3CompilerRuntimeContract("/tmp/cheng-lang")
    assert(direct == "/tmp/cheng-lang/v3/src/tooling/compiler_main.cheng", "direct")
    assert(contract.compilerEntry == "/tmp/cheng-lang/v3/src/tooling/compiler_main.cheng", "contract")
    echo("compiler_runtime_contract_probe ok")
    return 0
