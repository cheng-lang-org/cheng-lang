import std/system
import cheng/v3/std/bytes_layout as layout

fn main(): int32 =
    var buf = layout.byteBufInit(16)
    assert(layout.byteBufLen(buf) == 0, "v3 bytebuf basic: init len")
    layout.byteBufAppendByte(buf, 1)
    assert(layout.byteBufLen(buf) == 1, "v3 bytebuf basic: append len")
    echo("v3 bytebuf_basic_smoke ok")
    return 0
