import std/os
import std/strings
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let driver: str = os.JoinPath(root, "artifacts/v3_backend_driver/cheng")
    assert(os.FileExists(driver), "v3 mobile_shell_build_probe_smoke: backend_driver exists")
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_mobile_shell_build_probe_smoke")
    assert(v3path.V3MkdirP(root, outDir), "v3 mobile_shell_build_probe_smoke: mkdir")
    let logPath: str = v3path.V3PathJoin(outDir, "verify_mobile_shell_build_probe.log")
    if v3path.V3PathFileExists(logPath):
        os.RemoveFile(logPath)
    let run = hostops.v3RunFileLogged(root,
                                      "mobile_shell_build_probe_smoke",
                                      driver,
                                      ["verify-mobile-shell-build-probe"],
                                      [],
                                      root,
                                      0,
                                      logPath)
    let output: str = run.output
    assert(run.exitCode == 0, "v3 mobile_shell_build_probe_smoke: verify rc")
    assert(strings.StrContains(output, "mobile-shell build-probe ok"),
           "v3 mobile_shell_build_probe_smoke: build probe output")
    assert(strings.StrContains(output, "verify-mobile-shell-build-probe: ok"),
           "v3 mobile_shell_build_probe_smoke: verify output")
    echo("v3 mobile_shell_build_probe_smoke ok")
    return 0
