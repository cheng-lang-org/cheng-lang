import std/system
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peer_id
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/core/peerstore as ps
import cheng/v3/libp2p/host/host
import cheng/v3/libp2p/transports/tailnet_transport as tsnet

fn main(): int32 =
    var cfg = tsnet.v3Libp2pTailnetTransportConfigZero()
    cfg.controlUrl = "https://headscale.example"
    cfg.controlEndpoint = "https://headscale.example/control"
    cfg.relayEndpoint = "https://derp.sfo.example:443"
    cfg.syntheticIPv4 = "100.64.1.9"
    cfg.syntheticIPv6 = "fd7a:115c:a1e0::109"
    cfg.localPeerId = "tailnet-derp-smoke"
    tsnet.v3Libp2pTailnetConfigSetHeadscale(cfg,
                                            "infra",
                                            "noise-pub-001",
                                            12,
                                            "sfo",
                                            "San Francisco",
                                            "derp.sfo.example",
                                            true)

    var transport = tsnet.v3Libp2pTailnetTransportInit(cfg)
    var peerA = tsnet.v3Libp2pTailnetPeerSessionZero()
    peerA.peerId = "peer-a"
    peerA.remoteTailnetIp = "100.64.1.21"
    peerA.directReachable = true
    peerA.relayAllowed = true
    peerA.derpRegionCode = "sfo"
    peerA.signedPreface = "preface-a"
    peerA.boundAddrText = "/ip4/10.0.0.21/udp/7202/quic-v1"
    tsnet.v3Libp2pTailnetUpsertPeerSession(transport, peerA)
    tsnet.v3Libp2pTailnetUpsertPeerSession(transport, peerA)
    var peerB = tsnet.v3Libp2pTailnetPeerSessionZero()
    peerB.peerId = "peer-b"
    peerB.remoteTailnetIp = "100.64.1.22"
    peerB.relayAllowed = true
    peerB.relayOnly = true
    peerB.derpRegionCode = "sfo"
    peerB.signedPreface = "preface-b"
    peerB.boundAddrText = "/ip4/10.0.0.22/udp/7203/quic-v1"
    tsnet.v3Libp2pTailnetUpsertPeerSession(transport, peerB)
    tsnet.v3Libp2pTailnetSetProviderReady(transport, true, "control-ready")
    tsnet.v3Libp2pTailnetSetProxyListenersReady(transport, true, "proxy-ready")
    tsnet.v3Libp2pTailnetSetDerpHealthy(transport, true, "derp-ready")

    var rawQuic = types.v3Libp2pMultiaddrZero()
    multiaddr.v3Libp2pMultiaddrFillQuic(rawQuic, "127.0.0.1", 7202)
    let listenRes = tsnet.v3Libp2pTailnetListen(transport, rawQuic)
    assert(IsOk(listenRes), "v3 libp2p tailnet derp: listen")

    var status: tsnet.V3Libp2pTailnetStatusSnapshot
    tsnet.v3Libp2pTailnetStatusFill(status, transport)
    assert(status.providerKind == "headscale", "v3 libp2p tailnet derp: provider")
    assert(status.controlPlane == "headscale", "v3 libp2p tailnet derp: control plane")
    assert(status.exactRouting, "v3 libp2p tailnet derp: exact routing")
    assert(status.relayHealthy, "v3 libp2p tailnet derp: relay healthy")
    assert(status.derpRegionCode == "sfo", "v3 libp2p tailnet derp: region code")
    assert(status.derpHostname == "derp.sfo.example", "v3 libp2p tailnet derp: hostname")
    assert(status.tailnetPath == "direct+derp", "v3 libp2p tailnet derp: path")
    assert(status.tailnetPeers.len == 2, "v3 libp2p tailnet derp: peer sessions")
    assert(status.proxyListenersReady, "v3 libp2p tailnet derp: proxy listeners ready")
    assert(status.publishedCount == 1, "v3 libp2p tailnet derp: published count")
    assert(status.tailnetDerpMapSummary == "headscale/infra@https://headscale.example/control#sfo/derp.sfo.example",
        "v3 libp2p tailnet derp: derp summary")
    assert(tsnet.v3Libp2pTailnetProviderUsesExactRouting(transport),
        "v3 libp2p tailnet derp: exact routing helper")
    assert(tsnet.v3Libp2pTailnetDerpAvailable(transport),
        "v3 libp2p tailnet derp: derp available helper")

    var published = tsnet.v3Libp2pTailnetPublishedAddrs(transport)
    var derpPlan = tsnet.v3Libp2pTailnetDialPlanZero()
    let derpPlanRes = tsnet.v3Libp2pTailnetDialPlanFill(derpPlan,
                                                        transport,
                                                        "peer-b",
                                                        published[0],
                                                        true,
                                                        false)
    assert(IsOk(derpPlanRes), "v3 libp2p tailnet derp: relay plan")
    assert(derpPlan.pathKind == tsnet.v3Libp2pTailnetPathDerp,
        "v3 libp2p tailnet derp: relay path")
    assert(derpPlan.reachability == types.v3Libp2pReachabilityRelayed,
        "v3 libp2p tailnet derp: relay reachability plan")
    assert(derpPlan.routeText == "https://derp.sfo.example:443",
        "v3 libp2p tailnet derp: relay route text")

    var trustedHost = host.v3Libp2pHostInit("tailnet.derp.trusted")
    host.v3Libp2pHostSetTrustedInfra(trustedHost, true)

    let mixedPeer = peer_id.v3Libp2pPeerIdFromSeed("tailnet.derp.mixed")
    var publicAddr = types.v3Libp2pMultiaddrZero()
    multiaddr.v3Libp2pMultiaddrFillQuic(publicAddr, "198.51.100.88", 7301)
    multiaddr.v3Libp2pMultiaddrSetRoutingMeta(publicAddr,
                                              types.v3Libp2pNetworkDomainPublic,
                                              types.v3Libp2pVisibilityPublic,
                                              100)
    var tailnetAddr = types.v3Libp2pMultiaddrZero()
    multiaddr.v3Libp2pMultiaddrFillTcp(tailnetAddr, "100.64.1.88", 7302)
    multiaddr.v3Libp2pMultiaddrSetRoutingMeta(tailnetAddr,
                                              types.v3Libp2pNetworkDomainTailnet,
                                              types.v3Libp2pVisibilityTrustedOnly,
                                              900)

    var mixedRecord = ps.v3Libp2pPeerRecordZero()
    mixedRecord.peerId = mixedPeer
    mixedRecord.trustedInfra = true
    ps.v3Libp2pPeerRecordPutEndpoint(mixedRecord,
                                     tailnetAddr,
                                     false,
                                     types.v3Libp2pReachabilityRelayed,
                                     tailnetAddr.priority)
    ps.v3Libp2pPeerRecordPutEndpoint(mixedRecord,
                                     publicAddr,
                                     false,
                                     types.v3Libp2pReachabilityDirect,
                                     publicAddr.priority)
    ps.v3Libp2pPeerstoreUpsert(trustedHost.peers, mixedRecord)

    var mixedEndpoint = ps.v3Libp2pPeerEndpointZero()
    let mixedRes = host.v3Libp2pSelectPeerEndpoint(trustedHost, mixedPeer, mixedEndpoint)
    assert(IsOk(mixedRes), "v3 libp2p tailnet derp: mixed select")
    assert(mixedEndpoint.addr.networkDomain == types.v3Libp2pNetworkDomainPublic,
        "v3 libp2p tailnet derp: relay stays behind public direct")
    assert(mixedEndpoint.reachability == types.v3Libp2pReachabilityDirect,
        "v3 libp2p tailnet derp: public stays direct")

    let relayPeer = peer_id.v3Libp2pPeerIdFromSeed("tailnet.derp.only")
    var relayRecord = ps.v3Libp2pPeerRecordZero()
    relayRecord.peerId = relayPeer
    relayRecord.trustedInfra = true
    ps.v3Libp2pPeerRecordPutEndpoint(relayRecord,
                                     tailnetAddr,
                                     false,
                                     types.v3Libp2pReachabilityRelayed,
                                     tailnetAddr.priority)
    ps.v3Libp2pPeerstoreUpsert(trustedHost.peers, relayRecord)

    var relayEndpoint = ps.v3Libp2pPeerEndpointZero()
    let relayRes = host.v3Libp2pSelectPeerEndpoint(trustedHost, relayPeer, relayEndpoint)
    assert(IsOk(relayRes), "v3 libp2p tailnet derp: relay select")
    assert(relayEndpoint.addr.networkDomain == types.v3Libp2pNetworkDomainTailnet,
        "v3 libp2p tailnet derp: relay path remains tailnet")
    assert(relayEndpoint.reachability == types.v3Libp2pReachabilityRelayed,
        "v3 libp2p tailnet derp: relay reachability")

    tsnet.v3Libp2pTailnetSetListenerNeedsRepair(transport, true, "repair-needed")
    var repairStatus: tsnet.V3Libp2pTailnetStatusSnapshot
    tsnet.v3Libp2pTailnetStatusFill(repairStatus, transport)
    assert(repairStatus.tailnetPath == "repair", "v3 libp2p tailnet derp: repair path")

    echo("v3 libp2p_tailnet_derp_smoke ok")
    return 0
