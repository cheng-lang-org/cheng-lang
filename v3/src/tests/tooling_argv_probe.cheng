import std/cmdline as cmdline
import std/os

fn argvProbeLine(text: str) =
    os.writeLine(os.get_stdout(), text)

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let count = cmdline.paramCount()
    argvProbeLine("count=" + intToStr(count))
    for i in 0..count:
        var line = "arg["
        line = line + intToStr(i)
        line = line + "]="
        line = line + cmdline.paramStr(i)
        argvProbeLine(line)
    argvProbeLine("flag_emit=" + cmdline.readFlagOrDefault("--emit", "<missing>"))
    argvProbeLine("flag_root=" + cmdline.readFlagOrDefault("--root", "<missing>"))
    argvProbeLine("flag_in=" + cmdline.readFlagOrDefault("--in", "<missing>"))
    argvProbeLine("flag_out=" + cmdline.readFlagOrDefault("--out", "<missing>"))
    return 0
