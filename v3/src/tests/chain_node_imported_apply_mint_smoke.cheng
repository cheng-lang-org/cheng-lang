import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus as consensus
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node: init")
    let parentCid = node.v3ChainNodeAccountHead(server.index, 7, 1001)
    var event = consensus.v3ChainEventMint(
        7,
        1001,
        parentCid,
        int64(100),
        server.nextEpoch,
        server.nextGanzhi,
        node.v3ChainNodeSpaceSlot(1001, 1001),
        server.nextTick
    )
    let applyRes = node.v3ChainNodeApplyEvent(server, event)
    assert(applyRes.ok, "chain node imported apply mint: apply")
    assert(server.eventCids.len == 1, "chain node imported apply mint: cid len")
    assert(server.events.len == 1, "chain node imported apply mint: event len")
    assert(layout.fixedBytes32Equal(server.eventCids[0], applyRes.value),
           "chain node imported apply mint: first cid")
    assert(server.events[0].kind == consensus.v3ConsensusKindMint,
           "chain node imported apply mint: first event kind")
    echo("v3 chain_node_imported_apply_mint_smoke ok")
    return 0
