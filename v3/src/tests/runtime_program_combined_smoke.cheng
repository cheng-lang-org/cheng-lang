import std/os
import std/result
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/runtime_program_obj as runtimeobj

fn main(): int32 =
    let root = os.GetCurrentDir()
    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_runtime_program_combined_smoke")
    assert(v3path.V3MkdirP(root, outDir), "v3 runtime program combined: mkdir")

    let runtimeObj = runtimeobj.v3RuntimeProgramCombinedPath(root, "")
    let runtimeBak = runtimeObj + ".runtime_program_combined_smoke.bak"
    let materializeLog = v3path.V3PathJoin(outDir, "materialize.log")
    assert(len(runtimeObj) > 0, "v3 runtime program combined: runtime path")

    if v3path.V3PathFileExists(runtimeBak):
        assert(os.RemoveFile(runtimeBak), "v3 runtime program combined: stale runtime backup removed")
    var hadRuntimeBackup: bool = false
    if v3path.V3PathFileExists(runtimeObj):
        assert(os.RenameFile(runtimeObj, runtimeBak), "v3 runtime program combined: runtime backup")
        hadRuntimeBackup = true

    let materializeRes = runtimeobj.v3RuntimeProgramMaterialize(root, "", materializeLog)
    let materializeOk = !IsErr(materializeRes)
    var materializedPath = ""
    if materializeOk:
        materializedPath = Value(materializeRes)
    let runtimeGenerated = v3path.V3FileExistsNonEmpty(root, materializedPath)

    if hadRuntimeBackup:
        if v3path.V3PathFileExists(runtimeObj):
            assert(os.RemoveFile(runtimeObj), "v3 runtime program combined: remove generated runtime")
        assert(os.RenameFile(runtimeBak, runtimeObj), "v3 runtime program combined: restore runtime backup")
    else:
        if v3path.V3PathFileExists(runtimeObj):
            assert(os.RemoveFile(runtimeObj), "v3 runtime program combined: remove generated runtime")

    assert(materializeOk, "v3 runtime program combined: materialize success")
    assert(runtimeGenerated, "v3 runtime program combined: output exists")
    echo("v3 runtime_program_combined_smoke ok")
    return 0
