import std/system
import std/result
import cheng/v3/chain/binary_types as types
import cheng/v3/chain/location_proof as lp

fn main(): int32 =
    let claimantRes = types.v3LsmrAddressFromDigits([5, 8, 1])
    assert(IsOk(claimantRes), "v3 location smoke: claimant address")
    let claimant = Value(claimantRes)

    var witnesses: lp.V3LocationWitness[]
    witnesses = []
    let w1Res = lp.v3LocationWitnessMake(100, claimant, 201, Value(types.v3LsmrAddressFromDigits([5, 1, 1])), 3)
    let w2Res = lp.v3LocationWitnessMake(100, claimant, 202, Value(types.v3LsmrAddressFromDigits([5, 6, 1])), 3)
    let w3Res = lp.v3LocationWitnessMake(100, claimant, 203, Value(types.v3LsmrAddressFromDigits([5, 3, 1])), 3)
    assert(IsOk(w1Res), "v3 location smoke: witness1")
    assert(IsOk(w2Res), "v3 location smoke: witness2")
    assert(IsOk(w3Res), "v3 location smoke: witness3")
    add(witnesses, Value(w1Res))
    add(witnesses, Value(w2Res))
    add(witnesses, Value(w3Res))

    let proofRes = lp.v3BuildLocationProof(100,
                                           claimant,
                                           42,
                                           lp.v3LocationNonceCid(42),
                                           witnesses)
    assert(IsOk(proofRes), "v3 location smoke: proof")
    let proof = Value(proofRes)
    let decision = lp.v3VerifyLocationProof(proof)
    assert(decision.accepted, "v3 location smoke: valid proof accepted")
    assert(decision.distinctWitnessCount == 3, "v3 location smoke: witness quorum")
    assert(decision.distinctSectorCount == 3, "v3 location smoke: sector coverage")

    var badProof = proof
    badProof.witnessRttBuckets[0] = 99
    let badDecision = lp.v3VerifyLocationProof(badProof)
    assert(!badDecision.accepted, "v3 location smoke: bad proof rejected")

    echo("v3 location_proof_smoke ok")
    return 0
