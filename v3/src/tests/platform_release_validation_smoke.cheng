import std/system
import std/result
import cheng/v3/quic/platform/common
import cheng/v3/quic/platform/platform_matrix
import cheng/v3/quic/platform/release_validation
import cheng/v3/quic/msquicruntime

fn main(): int32 =
    let matrix = platform_matrix.initMsQuicPlatformMatrix()
    assert(matrix.count > 0, "v3 platform release validation: matrix non-empty")
    assert(platform_matrix.msquicPlatformMatrixHas(matrix, common.MsQuicPlatformLinux),
        "v3 platform release validation: matrix has linux")
    let desc = platform_matrix.msquicPlatformMatrixDescribe(matrix, common.MsQuicPlatformLinux)
    assert(len(desc) > 0, "v3 platform release validation: matrix desc")
    let okRes = release_validation.msquicReleaseValidatePlatform(common.MsQuicPlatformLinux)
    if IsErr(okRes):
        panic(ErrorText(okRes))
    let badRes = release_validation.msquicReleaseValidatePlatform(common.MsQuicPlatformUnknown)
    assert(IsErr(badRes), "v3 platform release validation: reject unknown platform")
    let settings = msquicruntime.initMsQuicSettings()
    let setRes = release_validation.msquicReleaseValidateSettings(settings)
    if IsErr(setRes):
        panic(ErrorText(setRes))
    let summary = release_validation.msquicReleaseValidationSummary(common.MsQuicPlatformLinux, settings)
    assert(len(summary) > 0, "v3 platform release validation: summary")
    echo("v3 platform_release_validation_smoke ok")
    return 0
