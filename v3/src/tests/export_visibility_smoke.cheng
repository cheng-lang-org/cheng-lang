import cheng/v3/tests/export_visibility_helper as helper

fn main(): int32 =
    let publicValue: int32 = helper.PublicFn()
    if publicValue != 2:
        return 1
    let publicText: str = "2"
    let rendered: str = Fmt"export={publicText}"
    if rendered != "export=2":
        return 1
    let joinedParts: str[] = ["ok", "done"]
    let joined: str = Lines(joinedParts)
    if joined != "ok\ndone":
        return 1
    echo("v3 export_visibility_smoke ok")
    return 0
