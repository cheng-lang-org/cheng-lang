import std/system
import std/cmdline as cmdline

type
    PreserveProbeA = object
        words: int32[64]
    PreserveProbeB = object
        words: int32[33]

fn preserveProbeFind(a: PreserveProbeA, b: PreserveProbeB): Result[int32] =
    if a.words[0] == 7 && b.words[0] == 9:
        return Ok[int32](1)
    return Err[int32]("call result preserve probe: unexpected payload")

fn main(): int32 =
    let keep = cmdline.ReadFlagOrDefault("--value", "")
    var left: PreserveProbeA
    var right: PreserveProbeB
    left.words[0] = 7
    right.words[0] = 9
    let res = preserveProbeFind(left, right)
    assert(IsOk(res), "call result preserve probe: result ok")
    let idx = res.value
    assert(idx == 1, "call result preserve probe: value")
    assert(keep == "/tmp/call-result-preserve-live-str", "call result preserve probe: live str")
    echo("v3 call_result_preserves_live_str_smoke ok")
    return 0
