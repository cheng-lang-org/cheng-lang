import std/system
import cheng/v3/project/bft_state_machine as bft

fn main(): int32 =
    let appId = "bft-finalize-summary"
    var machine = bft.v3BftStateMachineInit(appId)
    let mint = bft.v3BftTxMint(7, 1001, int64(100))
    let badTransfer = bft.v3BftTxTransfer(7, 1001, 1001, int64(1))

    let mintCheck = bft.v3BftStateMachineCheckTx(machine, mint)
    assert(mintCheck.code == bft.v3BftCodeOk, "v3 bft finalize summary: mint check")
    assert(machine.index.eventCids.len == 0, "v3 bft finalize summary: checktx event log")
    assert(machine.index.accountIds.len == 0, "v3 bft finalize summary: checktx state")

    let badTransferCheck = bft.v3BftStateMachineCheckTx(machine, badTransfer)
    assert(badTransferCheck.code == bft.v3BftCodeBadTarget, "v3 bft finalize summary: bad transfer check")
    assert(machine.index.eventCids.len == 0, "v3 bft finalize summary: bad check event log")

    var batch = bft.v3BftTxBatchZero()
    bft.v3BftTxBatchAdd(batch, mint)
    bft.v3BftTxBatchAdd(batch, badTransfer)

    var summary = bft.v3BftBlockSummaryZero(int64(0))
    bft.v3BftStateMachineFinalizeBatchSummary(machine, int64(1), batch, summary)

    assert(summary.txCount == 2, "v3 bft finalize summary: tx count")
    assert(summary.appliedCount == 1, "v3 bft finalize summary: applied count")
    assert(summary.rejectedCount == 1, "v3 bft finalize summary: rejected count")
    assert(machine.index.eventCids.len == 1, "v3 bft finalize summary: event cid len")
    assert(machine.index.accountIds.len == 1, "v3 bft finalize summary: account len")
    assert(machine.lastFinalizedHeight == int64(1), "v3 bft finalize summary: finalized height")
    echo("v3 bft_finalize_summary_smoke ok")
    return 0
