import std/system
import std/result
import std/rawbytes
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/binary_types as binary
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/dag_mempool as dag
import cheng/v3/chain/erasure_swarm as swarm
import cheng/v3/chain/pubsub
import cheng/v3/chain/pin_plane as pin
import cheng/v3/chain/pin_runtime as runtime
import cheng/v3/chain/pin_runtime_host as runtime_host
import cheng/v3/chain/pin_runtime_host_quic as runtime_host_quic
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host

fn pinRuntimeQuicSmokeBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn pinRuntimeQuicSmokeBlob(parts: Bytes[]): Bytes =
    var total = 0
    for i in 0..<parts.len:
        total = total + bytesLen(parts[i])
    var buf: layout.ByteBuf = layout.byteBufInit(total)
    for i in 0..<parts.len:
        layout.byteBufAppendBytes(buf, parts[i])
    return layout.byteBufToBytes(buf)

fn pinRuntimeQuicSmokeBuildResponses(out: var swarm.V3ErasureShardPullResponse[],
                                     manifest: swarm.V3ErasureShardManifest,
                                     shardPayloads: Bytes[]) =
    out = []
    for i in 0..<manifest.shardCount:
        let requestRes = swarm.v3ErasureShardPullRequestMake(manifest, manifest.shardIndices[i])
        assert(IsOk(requestRes), "v3 pin runtime quic smoke: request")
        var response = swarm.v3ErasureShardPullResponseZero()
        let responseFillRes = swarm.v3ErasureShardPullResponseFill(response,
                                                                   Value(requestRes),
                                                                   shardPayloads[i])
        assert(IsOk(responseFillRes), "v3 pin runtime quic smoke: response")
        add(out, response)

fn main(): int32 =
    var authorHost = host.v3Libp2pHostInit("pin.runtime.quic.author")
    var providerHost = host.v3Libp2pHostInit("pin.runtime.quic.provider")
    var authorRuntime = runtime.v3PinRuntimeInit()
    var providerRuntime = runtime.v3PinRuntimeInit()

    var authorAddr: types.V3Libp2pMultiaddr
    var providerAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillQuic(authorAddr, "127.0.0.1", 0)
    multiaddr.v3Libp2pMultiaddrFillQuic(providerAddr, "127.0.0.1", 0)
    let authorListenRes = host.v3Libp2pListen(authorHost, authorAddr)
    assert(IsOk(authorListenRes), "v3 pin runtime quic smoke: author listen")
    let providerListenRes = host.v3Libp2pListen(providerHost, providerAddr)
    assert(IsOk(providerListenRes), "v3 pin runtime quic smoke: provider listen")
    host.v3Libp2pRegisterHandler(authorHost, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(providerHost, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(authorHost, types.v3Libp2pProtocolPin)
    host.v3Libp2pRegisterHandler(providerHost, types.v3Libp2pProtocolPin)
    let dialProviderToAuthorRes = host.v3Libp2pDial(providerHost,
                                                    authorHost.selfPeerId,
                                                    authorAddr,
                                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(dialProviderToAuthorRes), "v3 pin runtime quic smoke: provider->author dial")
    let dialAuthorToProviderRes = host.v3Libp2pDial(authorHost,
                                                    providerHost.selfPeerId,
                                                    providerAddr,
                                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(dialAuthorToProviderRes), "v3 pin runtime quic smoke: author->provider dial")

    var address = binary.v3LsmrAddressZero()
    let addressRes = binary.v3LsmrAddressFromDigits([6, 6, 6])
    assert(IsOk(addressRes), "v3 pin runtime quic smoke: address")
    address = Value(addressRes)
    let scope = overlay.v3OverlayScopeRegion

    let shard0 = bytesFromString("quic-a")
    let shard1 = bytesFromString("quic-b")
    let shard2 = bytesFromString("quic-c")
    var shardPayloads: Bytes[]
    shardPayloads = []
    add(shardPayloads, shard0)
    add(shardPayloads, shard1)
    add(shardPayloads, shard2)
    let blob = pinRuntimeQuicSmokeBlob(shardPayloads)
    let summaryRes = dag.v3DagBlobSummaryFromBytes(blob, 6)
    assert(IsOk(summaryRes), "v3 pin runtime quic smoke: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.v3ErasureEncodingParamsMake(swarm.v3ErasureLayoutRsSystematic, 3, 0, 6)
    assert(IsOk(paramsRes), "v3 pin runtime quic smoke: params")
    let params = Value(paramsRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    for i in 0..<shardPayloads.len:
        add(shardPayloadCids, swarm.v3ErasureShardPayloadCid(shardPayloads[i]))
    let manifestRes = swarm.v3ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), "v3 pin runtime quic smoke: manifest")
    let manifest = Value(manifestRes)

    let bundleCid = lt.v3HashInts("v3.pin.runtime.quic.bundle", [44, 55, 66])
    let offerRes = pin.v3PinOfferMake(bundleCid,
                                      summary.summaryCid,
                                      summary.blobCid,
                                      manifest.manifestCid,
                                      140,
                                      2,
                                      88,
                                      34)
    assert(IsOk(offerRes), "v3 pin runtime quic smoke: offer")
    let offer = Value(offerRes)
    let publishOfferRes = runtime_host.v3PinRuntimePublishOffer(authorHost, scope, address, offer, 21, 31)
    assert(IsOk(publishOfferRes), "v3 pin runtime quic smoke: publish offer")
    let fetchedOfferRes = runtime_host_quic.v3PinRuntimeFetchOffer(providerHost,
                                                                   authorHost,
                                                                   authorHost.selfPeerId,
                                                                   scope,
                                                                   address,
                                                                   offer.offerCid)
    assert(IsOk(fetchedOfferRes), "v3 pin runtime quic smoke: fetch offer")
    let fetchedOffer = Value(fetchedOfferRes)
    assert(pinRuntimeQuicSmokeBytesEqual(pin.v3PinOfferEncode(fetchedOffer), pin.v3PinOfferEncode(offer)),
        "v3 pin runtime quic smoke: fetched offer payload")

    let acceptRes = pin.v3PinAcceptMake(fetchedOffer, providerHost.selfPeerId.value, 180)
    assert(IsOk(acceptRes), "v3 pin runtime quic smoke: accept")
    let accept = Value(acceptRes)
    var responses: swarm.V3ErasureShardPullResponse[]
    pinRuntimeQuicSmokeBuildResponses(responses, manifest, shardPayloads)
    let acceptedStateRes = runtime.v3PinRuntimeStoreAcceptedState(providerRuntime,
                                                                  fetchedOffer,
                                                                  accept,
                                                                  manifest,
                                                                  params,
                                                                  responses)
    assert(IsOk(acceptedStateRes), "v3 pin runtime quic smoke: accepted state")
    let publishAcceptRes = runtime_host.v3PinRuntimePublishAccept(providerHost, scope, address, accept, 22, 32)
    assert(IsOk(publishAcceptRes), "v3 pin runtime quic smoke: publish accept")

    let fetchedAcceptRes = runtime_host_quic.v3PinRuntimeFetchAccept(authorHost,
                                                                     providerHost,
                                                                     providerHost.selfPeerId,
                                                                     scope,
                                                                     address,
                                                                     accept.acceptCid)
    assert(IsOk(fetchedAcceptRes), "v3 pin runtime quic smoke: fetch accept")
    let fetchedAccept = Value(fetchedAcceptRes)
    let schedulerStateRes = runtime.v3PinRuntimeStoreChallengerState(authorRuntime,
                                                                     fetchedOffer,
                                                                     fetchedAccept,
                                                                     manifest,
                                                                     params,
                                                                     111,
                                                                     2,
                                                                     1)
    assert(IsOk(schedulerStateRes), "v3 pin runtime quic smoke: scheduler state")
    assert(authorRuntime.schedules.len == 1, "v3 pin runtime quic smoke: author schedule ready")

    let retryOpenRes = runtime.v3PinRuntimeOpenChallenge(authorRuntime, fetchedAccept.acceptCid, 111)
    assert(IsOk(retryOpenRes), "v3 pin runtime quic smoke: retry open")
    let retryChallenge = Value(retryOpenRes)
    let retryOfferRes = runtime.v3PinRuntimeFindOffer(authorRuntime, retryChallenge.offerCid)
    assert(IsOk(retryOfferRes), "v3 pin runtime quic smoke: retry offer")
    let retryOffer = Value(retryOfferRes)
    let retryAcceptRes = runtime.v3PinRuntimeFindAccept(authorRuntime, fetchedAccept.acceptCid)
    assert(IsOk(retryAcceptRes), "v3 pin runtime quic smoke: retry accept")
    let retryAccept = Value(retryAcceptRes)
    let retryManifestRes = runtime.v3PinRuntimeFindManifest(authorRuntime, retryChallenge.manifestCid)
    assert(IsOk(retryManifestRes), "v3 pin runtime quic smoke: retry manifest")
    let retryManifest = Value(retryManifestRes)
    let retryProofRes = runtime_host_quic.v3PinRuntimeRequestProof(authorHost,
                                                                   providerHost,
                                                                   providerHost.selfPeerId,
                                                                   retryChallenge,
                                                                   retryOffer,
                                                                   retryAccept,
                                                                   retryManifest)
    assert(IsErr(retryProofRes), "v3 pin runtime quic smoke: retry proof missing")
    let retryStepRes = runtime.v3PinRuntimeNoteChallengeFailure(authorRuntime, fetchedAccept.acceptCid, 111)
    assert(IsOk(retryStepRes), "v3 pin runtime quic smoke: retry step")
    let retryStep = Value(retryStepRes)
    assert(retryStep.outcomeKind == runtime.v3PinRuntimeStepKindRetry,
        "v3 pin runtime quic smoke: retry outcome")
    assert(retryStep.retryCount == 1, "v3 pin runtime quic smoke: retry count")

    host.v3Libp2pAttachPinRuntime(providerHost, providerRuntime)
    let rewardOpen1Res = runtime.v3PinRuntimeOpenChallenge(authorRuntime, fetchedAccept.acceptCid, 112)
    assert(IsOk(rewardOpen1Res), "v3 pin runtime quic smoke: reward open1")
    let rewardChallenge1 = Value(rewardOpen1Res)
    let rewardOffer1Res = runtime.v3PinRuntimeFindOffer(authorRuntime, rewardChallenge1.offerCid)
    assert(IsOk(rewardOffer1Res), "v3 pin runtime quic smoke: reward offer1")
    let rewardOffer1 = Value(rewardOffer1Res)
    let rewardAccept1Res = runtime.v3PinRuntimeFindAccept(authorRuntime, fetchedAccept.acceptCid)
    assert(IsOk(rewardAccept1Res), "v3 pin runtime quic smoke: reward accept1")
    let rewardAccept1 = Value(rewardAccept1Res)
    let rewardManifest1Res = runtime.v3PinRuntimeFindManifest(authorRuntime, rewardChallenge1.manifestCid)
    assert(IsOk(rewardManifest1Res), "v3 pin runtime quic smoke: reward manifest1")
    let rewardManifest1 = Value(rewardManifest1Res)
    let rewardProof1Res = runtime_host_quic.v3PinRuntimeRequestProof(authorHost,
                                                                     providerHost,
                                                                     providerHost.selfPeerId,
                                                                     rewardChallenge1,
                                                                     rewardOffer1,
                                                                     rewardAccept1,
                                                                     rewardManifest1)
    assert(IsOk(rewardProof1Res), "v3 pin runtime quic smoke: reward proof1")
    let rewardStep1Res = runtime.v3PinRuntimeCompleteChallenge(authorRuntime,
                                                               fetchedAccept.acceptCid,
                                                               Value(rewardProof1Res),
                                                               112)
    assert(IsOk(rewardStep1Res), "v3 pin runtime quic smoke: reward step1")
    let rewardStep1 = Value(rewardStep1Res)
    let publishSettlement1Res = runtime.v3PinRuntimeFindSettlement(authorRuntime, rewardStep1.settlementCid)
    assert(IsOk(publishSettlement1Res), "v3 pin runtime quic smoke: local settlement1")
    let publishSettlement1IngressRes = runtime_host.v3PinRuntimePublishSettlement(authorHost,
                                                                                  scope,
                                                                                  address,
                                                                                  Value(publishSettlement1Res),
                                                                                  24,
                                                                                  34)
    assert(IsOk(publishSettlement1IngressRes), "v3 pin runtime quic smoke: publish settlement1")
    assert(rewardStep1.outcomeKind == runtime.v3PinRuntimeStepKindReward,
        "v3 pin runtime quic smoke: reward outcome1")
    let fetchedSettlement1Res = runtime_host_quic.v3PinRuntimeFetchSettlement(providerHost,
                                                                              authorHost,
                                                                              authorHost.selfPeerId,
                                                                              scope,
                                                                              address,
                                                                              rewardStep1.settlementCid)
    assert(IsOk(fetchedSettlement1Res), "v3 pin runtime quic smoke: fetch settlement1")
    let fetchedSettlement1 = Value(fetchedSettlement1Res)
    assert(fetchedSettlement1.status == pin.v3PinSettlementStatusReward,
        "v3 pin runtime quic smoke: reward status1")

    let rewardOpen2Res = runtime.v3PinRuntimeOpenChallenge(authorRuntime, fetchedAccept.acceptCid, 113)
    assert(IsOk(rewardOpen2Res), "v3 pin runtime quic smoke: reward open2")
    let rewardChallenge2 = Value(rewardOpen2Res)
    let rewardOffer2Res = runtime.v3PinRuntimeFindOffer(authorRuntime, rewardChallenge2.offerCid)
    assert(IsOk(rewardOffer2Res), "v3 pin runtime quic smoke: reward offer2")
    let rewardOffer2 = Value(rewardOffer2Res)
    let rewardAccept2Res = runtime.v3PinRuntimeFindAccept(authorRuntime, fetchedAccept.acceptCid)
    assert(IsOk(rewardAccept2Res), "v3 pin runtime quic smoke: reward accept2")
    let rewardAccept2 = Value(rewardAccept2Res)
    let rewardManifest2Res = runtime.v3PinRuntimeFindManifest(authorRuntime, rewardChallenge2.manifestCid)
    assert(IsOk(rewardManifest2Res), "v3 pin runtime quic smoke: reward manifest2")
    let rewardManifest2 = Value(rewardManifest2Res)
    let rewardProof2Res = runtime_host_quic.v3PinRuntimeRequestProof(authorHost,
                                                                     providerHost,
                                                                     providerHost.selfPeerId,
                                                                     rewardChallenge2,
                                                                     rewardOffer2,
                                                                     rewardAccept2,
                                                                     rewardManifest2)
    assert(IsOk(rewardProof2Res), "v3 pin runtime quic smoke: reward proof2")
    let rewardStep2Res = runtime.v3PinRuntimeCompleteChallenge(authorRuntime,
                                                               fetchedAccept.acceptCid,
                                                               Value(rewardProof2Res),
                                                               113)
    assert(IsOk(rewardStep2Res), "v3 pin runtime quic smoke: reward step2")
    let rewardStep2 = Value(rewardStep2Res)
    let publishSettlement2Res = runtime.v3PinRuntimeFindSettlement(authorRuntime, rewardStep2.settlementCid)
    assert(IsOk(publishSettlement2Res), "v3 pin runtime quic smoke: local settlement2")
    let publishSettlement2IngressRes = runtime_host.v3PinRuntimePublishSettlement(authorHost,
                                                                                  scope,
                                                                                  address,
                                                                                  Value(publishSettlement2Res),
                                                                                  25,
                                                                                  35)
    assert(IsOk(publishSettlement2IngressRes), "v3 pin runtime quic smoke: publish settlement2")
    assert(rewardStep2.outcomeKind == runtime.v3PinRuntimeStepKindReward,
        "v3 pin runtime quic smoke: reward outcome2")
    let fetchedSettlement2Res = runtime_host_quic.v3PinRuntimeFetchSettlement(providerHost,
                                                                              authorHost,
                                                                              authorHost.selfPeerId,
                                                                              scope,
                                                                              address,
                                                                              rewardStep2.settlementCid)
    assert(IsOk(fetchedSettlement2Res), "v3 pin runtime quic smoke: fetch settlement2")
    let fetchedSettlement2 = Value(fetchedSettlement2Res)
    assert(fetchedSettlement2.status == pin.v3PinSettlementStatusReward,
        "v3 pin runtime quic smoke: reward status2")

    let challengeCountRes = host.v3Libp2pPinRuntimeChallengeCount(providerHost)
    assert(IsOk(challengeCountRes), "v3 pin runtime quic smoke: challenge count")
    let proofCountRes = host.v3Libp2pPinRuntimeProofCount(providerHost)
    assert(IsOk(proofCountRes), "v3 pin runtime quic smoke: proof count")
    assert(Value(challengeCountRes) == 2, "v3 pin runtime quic smoke: challenge count value")
    assert(Value(proofCountRes) == 2, "v3 pin runtime quic smoke: proof count value")
    assert(authorRuntime.schedules.len == 1, "v3 pin runtime quic smoke: schedule count")
    assert(authorRuntime.schedules[0].nextChallengeEpoch == 114,
        "v3 pin runtime quic smoke: next epoch")
    assert(authorRuntime.schedules[0].retryCount == 0, "v3 pin runtime quic smoke: retry reset")
    assert(authorHost.publishLog.len == 3, "v3 pin runtime quic smoke: author publish log")
    assert(authorHost.storeEntries.len == 3, "v3 pin runtime quic smoke: author store")
    assert(providerHost.storeEntries.len == 1, "v3 pin runtime quic smoke: provider store")
    assert(authorHost.openStreamProtocols.len == 4, "v3 pin runtime quic smoke: author stream count")
    assert(providerHost.openStreamProtocols.len == 3, "v3 pin runtime quic smoke: provider stream count")
    assert(authorHost.syncRequestCount == 1, "v3 pin runtime quic smoke: author sync count")
    assert(providerHost.syncRequestCount == 3, "v3 pin runtime quic smoke: provider sync count")

    echo("v3 pin_runtime_quic_smoke ok")
    return 0
