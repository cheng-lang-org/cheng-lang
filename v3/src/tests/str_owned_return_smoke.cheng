import std/buffer
import std/rawbytes

fn makeJoined(prefix: str, value: str): str =
    var out: buffer.ByteBuffer
    out.data = rawbytes.emptyBytes()
    buffer.AppendBytes(out, prefix)
    buffer.AppendBytes(out, value)
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn main(): int32 =
    let first = makeJoined("left:", "alpha")
    let second = makeJoined("right:", "beta")
    assert(first == "left:alpha", "v3 str_owned_return_smoke: first")
    assert(second == "right:beta", "v3 str_owned_return_smoke: second")
    echo("v3 str_owned_return_smoke ok")
    return 0
