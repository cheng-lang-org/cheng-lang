import std/system
import std/crypto/sha256

fn main(): int32 =
    assert(sha256.u32Mask() == int64(4294967295), "v3 sha256 core: mask")
    assert(sha256.rotr32(int64(305419896), 4) == sha256.u32FromBytes(0x81, 0x23, 0x45, 0x67),
           "v3 sha256 core: rotr32")
    let a: int64 = sha256.u32FromBytes(0x6a, 0x09, 0xe6, 0x67)
    let b: int64 = sha256.u32FromBytes(0xbb, 0x67, 0xae, 0x85)
    let c: int64 = sha256.u32FromBytes(0x3c, 0x6e, 0xf3, 0x72)
    let e: int64 = sha256.u32FromBytes(0x51, 0x0e, 0x52, 0x7f)
    assert(sha256.ch(a, b, c) == sha256.u32FromBytes(0x3e, 0x67, 0xb7, 0x15),
           "v3 sha256 core: ch")
    assert(sha256.maj(a, b, c) == sha256.u32FromBytes(0x3a, 0x6f, 0xe6, 0x67),
           "v3 sha256 core: maj")
    assert(sha256.bigSigma0(a) == sha256.u32FromBytes(0xce, 0x20, 0xb4, 0x7e),
           "v3 sha256 core: bigSigma0")
    assert(sha256.bigSigma1(e) == sha256.u32FromBytes(0x35, 0x87, 0x27, 0x2b),
           "v3 sha256 core: bigSigma1")
    assert(sha256.smallSigma0(sha256.u32FromBytes(0x61, 0x62, 0x63, 0x80)) ==
           sha256.u32FromBytes(0x94, 0x0e, 0x90, 0xef),
           "v3 sha256 core: smallSigma0")
    assert(sha256.smallSigma1(sha256.u32FromBytes(0x61, 0x62, 0x63, 0x80)) ==
           sha256.u32FromBytes(0x7d, 0xa8, 0x64, 0x05),
           "v3 sha256 core: smallSigma1")
    assert(sha256.k256(0) == sha256.u32FromBytes(0x42, 0x8a, 0x2f, 0x98),
           "v3 sha256 core: k256[0]")
    assert(sha256.k256(15) == sha256.u32FromBytes(0xc1, 0x9b, 0xf1, 0x74),
           "v3 sha256 core: k256[15]")
    assert(sha256.k256(63) == sha256.u32FromBytes(0xc6, 0x71, 0x78, 0xf2),
           "v3 sha256 core: k256[63]")
    echo("v3 sha256_core_smoke ok")
    return 0
