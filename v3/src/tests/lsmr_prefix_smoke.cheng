import std/system
import std/result
import cheng/v3/chain/binary_types as types
import cheng/v3/chain/lsmr
import cheng/v3/chain/lsmr_types as lt

fn main(): int32 =
    var digits: int32[]
    digits = []
    add(digits, 1)
    add(digits, 2)
    add(digits, 3)
    let addressRes = types.v3LsmrAddressFromDigits(digits)
    assert(IsOk(addressRes), "v3 lsmr prefix smoke: address")
    let address = Value(addressRes)
    let keyText = intToStr(7)
    let baguaId = lsmr.v3LsmrAddressBagua(address, keyText)
    assert(lt.v3BaguaValid(baguaId), "v3 lsmr prefix smoke: bagua")
    var prefixDigits: int32[]
    prefixDigits = []
    for i in 0..<3:
        add(prefixDigits, address.digits[i])
    let prefixRes = lt.v3PrefixRefFromDigits(baguaId, prefixDigits)
    assert(IsOk(prefixRes), "v3 lsmr prefix smoke: prefix")
    let prefix = Value(prefixRes)
    assert(prefix.prefixDepth == 3, "v3 lsmr prefix smoke: depth")
    echo("v3 lsmr_prefix_smoke ok")
    return 0
