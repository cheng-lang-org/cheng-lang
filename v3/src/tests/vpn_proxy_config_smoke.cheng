import std/result
import cheng/v3/tooling/vpn_proxy_config as vpn

fn main(): int32 =
    var parseRes: Result[vpn.V3VpnProxyConfig]
    parseRes = vpn.V3VpnProxyParseConfigTextForTest(
        "{\"client\":{\"listen\":\"127.0.0.1:1080\",\"cert_der\":\"client.der\",\"key_pk8_der\":\"client.key\",\"trust_root_der\":\"root.der\",\"cert_chain_der\":[\"chain-a.der\",\"chain-b.der\"],\"trust_roots_der\":[\"root-b.der\"]},\"server\":{\"listen\":\"0.0.0.0:7443\"},\"exits\":[{\"name\":\"64\",\"host\":\"64.176.84.12\",\"port\":7443,\"server_name\":\"edge-64.internal\"},{\"name\":\"dmit\",\"host\":\"154.26.191.226\",\"port\":7443,\"server_name\":\"edge-dmit.internal\"}]}")
    assert(!IsErr(parseRes), "v3 vpn proxy config parse")

    var cfg: vpn.V3VpnProxyConfig
    cfg = Value(parseRes)
    assert(cfg.client.listen == "127.0.0.1:1080", "v3 vpn proxy config client listen")
    assert(cfg.client.certDer == "client.der", "v3 vpn proxy config client cert")
    assert(cfg.client.keyPk8Der == "client.key", "v3 vpn proxy config client key")
    assert(cfg.client.trustRootDer == "root.der", "v3 vpn proxy config client root")
    assert(cfg.client.certChainDer.len == 2, "v3 vpn proxy config client chain len")
    assert(cfg.client.trustRootsDer.len == 1, "v3 vpn proxy config client roots len")
    assert(cfg.server.listen == "0.0.0.0:7443", "v3 vpn proxy config server listen")
    assert(cfg.exits.len == 2, "v3 vpn proxy config exits len")
    assert(cfg.exits[0].name == "64", "v3 vpn proxy config first exit name")
    assert(cfg.exits[1].serverName == "edge-dmit.internal", "v3 vpn proxy config second exit server name")

    var serverOnlyRes: Result[vpn.V3VpnProxyConfig]
    serverOnlyRes = vpn.V3VpnProxyParseConfigTextForTest("{\"server\":{\"listen\":\"0.0.0.0:7443\"}}")
    assert(!IsErr(serverOnlyRes), "v3 vpn proxy config server-only parse")
    assert(Value(serverOnlyRes).client.listen == "", "v3 vpn proxy config server-only empty client")

    var badRes: Result[vpn.V3VpnProxyConfig]
    badRes = vpn.V3VpnProxyParseConfigTextForTest("{\"exits\":{\"name\":\"bad\"}}")
    assert(IsErr(badRes), "v3 vpn proxy config exits reject")
    assert(ErrorText(badRes) == "vpn proxy config: exits must be array", "v3 vpn proxy config exits reject text")

    echo("v3 vpn_proxy_config_smoke ok")
    return 0
