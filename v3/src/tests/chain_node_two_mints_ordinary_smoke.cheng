import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node: init")
    let mintA = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintA.ok, "chain node two mints: mint a")
    let mintB = node.v3ChainNodeMint(server, 7, 1002, int64(40))
    assert(mintB.ok, "chain node two mints: mint b")
    return 0
