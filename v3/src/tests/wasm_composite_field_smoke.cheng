import std/result
import std/rawbytes

fn bytesLen(value: Bytes): int32 =
    return value.len

fn textLen(value: str): int32 =
    return value.len

fn seqLen(values: int32[]): int32 =
    return values.len

fn resultOk(value: Result[int32]): bool =
    return value.ok

fn resultValue(value: Result[int32]): int32 =
    return value.value

fn echoBytes(value: Bytes): Bytes =
    return value

fn echoText(value: str): str =
    return value

fn echoSeq(values: int32[]): int32[] =
    return values

fn echoResult(value: Result[int32]): Result[int32] =
    return value
