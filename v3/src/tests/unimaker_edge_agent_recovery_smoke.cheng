import std/os as os
import cheng/v3/tooling/path as v3path
import cheng/v3/std/bytes_layout as layout
import cheng/v3/project/unimaker_edge_types as types
import cheng/v3/project/unimaker_edge_agent as agent

fn unimakerRecoveryCleanup(tmpRoot: str) =
    let storePath = os.JoinPath(tmpRoot, "agent.did")
    let eventLogPath = os.JoinPath(tmpRoot, "events.jsonl")
    let eventLogTmpPath = eventLogPath + ".tmp"
    if os.FileExists(storePath):
        let _ = os.RemoveFile(storePath)
    if os.FileExists(eventLogPath):
        let _ = os.RemoveFile(eventLogPath)
    if os.FileExists(eventLogTmpPath):
        let _ = os.RemoveFile(eventLogTmpPath)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

fn main(): int32 =
    let tmpRoot = "artifacts/v3_unimaker_edge_agent_recovery_smoke"
    unimakerRecoveryCleanup(tmpRoot)
    os.CreateDir(tmpRoot)

    var cfg = types.V3UnimakerAgentConfig()
    cfg.rootDir = v3path.V3PathCurrentDir()
    cfg.eventLogPath = os.JoinPath(tmpRoot, "events.jsonl")
    cfg.identityStorePath = os.JoinPath(tmpRoot, "agent.did")
    cfg.rootSeedHint = "recover.root.seed"
    cfg.deviceSeedHint = "recover.phone.seed"
    cfg.deviceLabelHint = "phone"
    cfg.epochSeconds = int64(1712000000)

    var original = agent.v3UnimakerAgentInit(cfg)
    let eventA = types.v3UnimakerEventMake(types.v3UnimakerEventSystemNotice,
                                           "task.recovery",
                                           "app moved to background",
                                           ["recovery", "background"],
                                           [],
                                           types.v3UnimakerEdgeKindCausedBy,
                                           int64(1712000001))
    let capsuleARes = agent.v3UnimakerAgentIngest(original, eventA)
    assert(IsOk(capsuleARes), "v3 unimaker recovery: ingest A")

    let capsuleA = Value(capsuleARes)
    let eventB = types.v3UnimakerEventMake(types.v3UnimakerEventNetworkMessage,
                                           "task.recovery",
                                           "remote sync acknowledged",
                                           ["recovery", "network"],
                                           [capsuleA.capsuleCid],
                                           types.v3UnimakerEdgeKindUsefulFor,
                                           int64(1712000002))
    let capsuleBRes = agent.v3UnimakerAgentIngest(original, eventB)
    assert(IsOk(capsuleBRes), "v3 unimaker recovery: ingest B")
    let originalHead = agent.v3UnimakerAgentHeadCid(original)
    let originalCount = agent.v3UnimakerAgentCapsuleCount(original)
    let originalEdges = agent.v3UnimakerAgentEdgeCount(original)

    var reloaded = agent.v3UnimakerAgentInit(cfg)
    assert(agent.v3UnimakerAgentCapsuleCount(reloaded) == originalCount,
        "v3 unimaker recovery: capsule count")
    assert(agent.v3UnimakerAgentEdgeCount(reloaded) == originalEdges,
        "v3 unimaker recovery: edge count")
    assert(layout.fixedBytes32Equal(agent.v3UnimakerAgentHeadCid(reloaded), originalHead),
        "v3 unimaker recovery: head cid")

    var query = types.V3MemoryQuery()
    query.taskId = "task.recovery"
    query.limit = 8
    let recallRes = agent.v3UnimakerAgentRecall(reloaded, query)
    assert(IsOk(recallRes), "v3 unimaker recovery: recall")
    let recallHits = Value(recallRes)
    assert(recallHits.len == 2, "v3 unimaker recovery: recall count")

    let capsuleB = Value(capsuleBRes)
    let followupEvent = types.v3UnimakerEventMake(types.v3UnimakerEventAppLifecycle,
                                                  "task.recovery",
                                                  "app returned to foreground",
                                                  ["recovery", "foreground"],
                                                  [capsuleB.capsuleCid],
                                                  types.v3UnimakerEdgeKindUsefulFor,
                                                  int64(1712000003))
    let followupRes = agent.v3UnimakerAgentIngest(reloaded, followupEvent)
    assert(IsOk(followupRes), "v3 unimaker recovery: ingest after reload")
    assert(agent.v3UnimakerAgentCapsuleCount(reloaded) == 3, "v3 unimaker recovery: final count")

    unimakerRecoveryCleanup(tmpRoot)
    echo("v3 unimaker_edge_agent_recovery_smoke ok")
    return 0
