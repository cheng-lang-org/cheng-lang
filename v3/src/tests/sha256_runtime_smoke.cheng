import std/system
import std/rawbytes
import std/crypto/sha256
import cheng/v3/std/bytes_layout as layout

fn main(): int32 =
    var input = bytesFromString("abc")
    var digest = sha256.sha256Digest(input)
    assert(bytesLen(digest) == 32, "v3 sha256 runtime: digest len")
    let fixedRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromBytes(digest)
    assert(IsOk(fixedRes), "v3 sha256 runtime: fixed32 conversion")
    return 0
