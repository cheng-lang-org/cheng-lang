import std/os
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server = node.v3ChainNodeInit("node-a", "chain-node-a")
    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node cell dump probe: mint")
    let transferCidRes = node.v3ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, "v3 chain_node cell dump probe: transfer")
    let served = node.v3ChainNodeServeOnce(server)
    var replayed = node.v3ChainNodeZero("node-b", served.address)
    for i in 0..<served.events.len:
        var event = served.events[i]
        event.stem = event.ganzhiIndex % 10
        event.branch = event.ganzhiIndex % 12
        event.bodyCid = consensus.v3ChainEventBodyCid(event)
        let applyRes = node.v3ChainNodeApplyEvent(replayed, event)
        assert(applyRes.ok, "v3 chain_node cell dump probe: replay apply")
    node.v3ChainNodeRebuildDerived(replayed)
    let serverCells = node.v3ChainNodeStateCells(server.index)
    let replayCells = node.v3ChainNodeStateCells(replayed.index)
    os.writeLine(os.get_stderr(), "server_cell0_content=" + layout.fixedBytes32Hex(serverCells[0].contentCid))
    os.writeLine(os.get_stderr(), "server_cell1_content=" + layout.fixedBytes32Hex(serverCells[1].contentCid))
    os.writeLine(os.get_stderr(), "server_cell0_locality=" + layout.fixedBytes32Hex(serverCells[0].localityCid))
    os.writeLine(os.get_stderr(), "server_cell1_locality=" + layout.fixedBytes32Hex(serverCells[1].localityCid))
    os.writeLine(os.get_stderr(), "replay_cell0_content=" + layout.fixedBytes32Hex(replayCells[0].contentCid))
    os.writeLine(os.get_stderr(), "replay_cell1_content=" + layout.fixedBytes32Hex(replayCells[1].contentCid))
    os.writeLine(os.get_stderr(), "replay_cell0_locality=" + layout.fixedBytes32Hex(replayCells[0].localityCid))
    os.writeLine(os.get_stderr(), "replay_cell1_locality=" + layout.fixedBytes32Hex(replayCells[1].localityCid))
    return 0
