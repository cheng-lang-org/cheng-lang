import std/result
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/compiler_world_libp2p as cwlp
import cheng/v3/backend/system_link_exec as sexec

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let packageRoot = v3path.V3PathJoin(workspaceRoot, "v3")
    let sourcePath = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = v3path.V3PathJoin(workspaceRoot, "artifacts/v3_compiler_world_fresh_node/program_selfhost_smoke")
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    let planRes = sexec.v3BuildSystemLinkExecPlan(workspaceRoot, req)
    assert(IsOk(planRes), "v3 compiler world fresh-node: build plan")
    let plan = Value(planRes)
    let reportRes = cwlp.v3CompilerWorldFreshNodeSelfhostReport(workspaceRoot, req, plan)
    assert(IsOk(reportRes), "v3 compiler world fresh-node: fresh report")
    let report = Value(reportRes)
    assert(v3path.V3TextContains(report, "manifest_root_cid="),
           "v3 compiler world fresh-node: manifest root")
    assert(v3path.V3TextContains(report, "manifest_entry_count=3"),
           "v3 compiler world fresh-node: manifest entry count")
    assert(v3path.V3TextContains(report, "receipt_equivalent=1"),
           "v3 compiler world fresh-node: receipt equivalence")
    assert(v3path.V3TextContains(report, "receipt_cid_match=1"),
           "v3 compiler world fresh-node: receipt cid match")
    echo("v3 compiler_world_fresh_node_selfhost_smoke ok")
    return 0
