import std/system
import std/result
import cheng/v3/chain/binary_types as binary
import cheng/v3/chain/pubsub
import cheng/v3/chain/oracle_runtime_host as oracle_host
import cheng/v3/chain/oracle_types as oracle_types
import cheng/v3/tests/oracle_smoke_support as support
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host

fn main(): int32 =
    let committee = support.oracleSmokeCommittee()
    var gossipRuntime = oracle_host.v3OracleFastRuntimeInit(committee)
    var syncRuntime = oracle_host.v3OracleFastRuntimeInit(committee)

    var authorHost = host.v3Libp2pHostInit("oracle.runtime.host.author")
    var readerHost = host.v3Libp2pHostInit("oracle.runtime.host.reader")

    var authorAddr: types.V3Libp2pMultiaddr
    var readerAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(authorAddr, "127.0.0.1", 6336)
    multiaddr.v3Libp2pMultiaddrFillTcp(readerAddr, "127.0.0.1", 6337)
    let authorListenRes = host.v3Libp2pListen(authorHost, authorAddr)
    assert(IsOk(authorListenRes), "oracle runtime host smoke: author listen")
    let readerListenRes = host.v3Libp2pListen(readerHost, readerAddr)
    assert(IsOk(readerListenRes), "oracle runtime host smoke: reader listen")
    host.v3Libp2pRegisterHandler(authorHost, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(readerHost, types.v3Libp2pProtocolSync)
    let dialReaderRes = host.v3Libp2pDial(readerHost,
                                          authorHost.selfPeerId,
                                          authorAddr,
                                          overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(dialReaderRes), "oracle runtime host smoke: reader dial")
    let dialAuthorRes = host.v3Libp2pDial(authorHost,
                                          readerHost.selfPeerId,
                                          readerAddr,
                                          overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(dialAuthorRes), "oracle runtime host smoke: author dial")

    let addressRes = binary.v3LsmrAddressFromDigits([2, 6, 6])
    assert(IsOk(addressRes), "oracle runtime host smoke: address")
    let address = Value(addressRes)
    let scope = overlay.v3OverlayScopeRegion
    let pairId = support.oracleSmokePairId(oracle_types.v3OracleAssetBtc, oracle_types.v3OracleQuoteUsd)
    let pairIndex = oracle_types.v3OraclePairIndex(pairId)

    for reporterSlot in 1..<6:
        var batch = support.oracleSmokeBatch(int64(12), reporterSlot)
        let storeGossipRes = oracle_host.v3OracleFastRuntimeStoreBatch(gossipRuntime, batch)
        assert(IsOk(storeGossipRes), "oracle runtime host smoke: store gossip")
        assert(Value(storeGossipRes), "oracle runtime host smoke: new gossip batch")

        let publishRes = oracle_host.v3OracleRuntimePublishBatch(authorHost,
                                                                 scope,
                                                                 address,
                                                                 batch,
                                                                 20 + reporterSlot,
                                                                 30 + reporterSlot)
        assert(IsOk(publishRes), "oracle runtime host smoke: publish")
        let fetchedRes = oracle_host.v3OracleRuntimeFetchBatch(readerHost,
                                                               authorHost,
                                                               authorHost.selfPeerId,
                                                               scope,
                                                               address,
                                                               batch.batchCid)
        assert(IsOk(fetchedRes), "oracle runtime host smoke: fetch")
        var fetched = Value(fetchedRes)
        let storeSyncRes = oracle_host.v3OracleFastRuntimeStoreBatch(syncRuntime, fetched)
        assert(IsOk(storeSyncRes), "oracle runtime host smoke: store sync")
        assert(Value(storeSyncRes), "oracle runtime host smoke: new sync batch")
    assert(authorHost.publishLog.len == 5, "oracle runtime host smoke: publish count")
    assert(authorHost.storeEntries.len == 5, "oracle runtime host smoke: store count")
    assert(authorHost.storeEntries[0].ingress.payloadKind == pubsub.v3PubSubPayloadKindOracleBatch,
        "oracle runtime host smoke: payload kind")

    var duplicateBatch = support.oracleSmokeBatch(int64(12), 1)
    let duplicateRes = oracle_host.v3OracleFastRuntimeStoreBatch(gossipRuntime, duplicateBatch)
    assert(IsOk(duplicateRes), "oracle runtime host smoke: duplicate store")
    assert(!Value(duplicateRes), "oracle runtime host smoke: duplicate no count")

    let fastGossipRes = oracle_host.v3OracleFastRuntimeQueryFast(gossipRuntime, pairId)
    assert(IsOk(fastGossipRes), "oracle runtime host smoke: fast gossip")
    let fastSyncRes = oracle_host.v3OracleFastRuntimeQueryFast(syncRuntime, pairId)
    assert(IsOk(fastSyncRes), "oracle runtime host smoke: fast sync")
    let fastGossip = Value(fastGossipRes)
    let fastSync = Value(fastSyncRes)
    let expectedMedian = support.oracleSmokePrice(int64(12), pairIndex, 3)
    assert(fastGossip.priceE8 == expectedMedian, "oracle runtime host smoke: gossip median")
    assert(fastSync.priceE8 == expectedMedian, "oracle runtime host smoke: sync median")
    assert(fastGossip.roundId == int64(12), "oracle runtime host smoke: gossip round")
    assert(fastSync.roundId == int64(12), "oracle runtime host smoke: sync round")

    echo("v3 oracle_runtime_host_smoke ok")
    return 0
