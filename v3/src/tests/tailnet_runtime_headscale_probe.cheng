import std/system
import cheng/v3/libp2p/transports/tailnet_transport as tsnet

fn main(): int32 =
    var cfg: tsnet.V3Libp2pTailnetTransportConfig
    cfg.controlUrl = "https://headscale.example"
    cfg.controlEndpoint = "https://headscale.example/control"
    cfg.relayEndpoint = "https://derp.sfo.example:443"
    cfg.controlProbeEndpoint = "v3/testdata/tailnet/headscale_control_ready.json"
    cfg.relayProbeEndpoint = "v3/testdata/tailnet/derp_ready.json"
    cfg.localPeerId = "tailnet-runtime-headscale-probe"
    tsnet.v3Libp2pTailnetConfigSetHeadscale(cfg,
                                            "infra",
                                            "noise-pub-probe",
                                            12,
                                            "sfo",
                                            "San Francisco",
                                            "derp.sfo.example",
                                            true)

    var transport = tsnet.v3Libp2pTailnetTransportInit(cfg)
    tsnet.v3Libp2pTailnetProviderStart(transport)
    assert(transport.runtimeHandle != uint64(0), "v3 tailnet runtime probe: handle")
    assert(tsnet.v3Libp2pTailnetProviderRuntimeActiveCountNow() == 1,
        "v3 tailnet runtime probe: active count")
    assert(tsnet.v3Libp2pTailnetProviderRuntimeReadyNow(transport),
        "v3 tailnet runtime probe: provider ready now")
    assert(transport.providerReady, "v3 tailnet runtime probe: provider ready field")

    tsnet.v3Libp2pTailnetProviderMarkProxyReady(transport)
    assert(transport.proxyListenersReady, "v3 tailnet runtime probe: proxy ready")

    tsnet.v3Libp2pTailnetProviderDerpReady(transport)
    assert(transport.derpHealthy, "v3 tailnet runtime probe: derp healthy")

    assert(tsnet.v3Libp2pTailnetProviderClose(transport),
        "v3 tailnet runtime probe: close")
    echo("v3 tailnet_runtime_headscale_probe ok")
    return 0
