import std/strings
import std/os
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let driver: str = os.JoinPath(root, "artifacts/v3_backend_driver/cheng")
    assert(os.FileExists(driver), "v3 backend_driver command surface: backend_driver exists")
    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_backend_driver_command_surface_smoke")
    assert(v3path.V3MkdirP(root, outDir), "v3 backend_driver command surface: mkdir")

    let helpLog = v3path.V3PathJoin(outDir, "help.log")
    if v3path.V3PathFileExists(helpLog):
        os.RemoveFile(helpLog)
    let helpRun = hostops.v3RunFileLogged(root,
                                          "backend_driver_surface_help",
                                          driver,
                                          ["help"],
                                          [],
                                          root,
                                          0,
                                          helpLog)
    let helpOutput: str = helpRun.output
    assert(helpRun.exitCode == 0, "v3 backend_driver command surface: help rc")
    assert(strings.StrContains(helpOutput, "  print-bootstrap"),
           "v3 backend_driver command surface: help print-bootstrap")
    assert(strings.StrContains(helpOutput, "  verify-export-visibility"),
           "v3 backend_driver command surface: help verify-export-visibility")
    assert(strings.StrContains(helpOutput, "  verify-export-visibility-parallel"),
           "v3 backend_driver command surface: help verify-export-visibility-parallel")
    assert(strings.StrContains(helpOutput, "  verify-mobile-shell-build-probe"),
           "v3 backend_driver command surface: help verify-mobile-shell-build-probe")
    assert(strings.StrContains(helpOutput, "  verify-chain-node-resilience"),
           "v3 backend_driver command surface: help verify-chain-node-resilience")
    assert(strings.StrContains(helpOutput, "  verify-oracle-resilience"),
           "v3 backend_driver command surface: help verify-oracle-resilience")
    assert(strings.StrContains(helpOutput, "  verify-oracle-bft-three-node"),
           "v3 backend_driver command surface: help verify-oracle-bft-three-node")
    assert(strings.StrContains(helpOutput, "  build-zero-exit"),
           "v3 backend_driver command surface: help build-zero-exit")
    assert(strings.StrContains(helpOutput, "  run-chain-node-resilience-smoke"),
           "v3 backend_driver command surface: help chain-node resilience")
    assert(strings.StrContains(helpOutput, "  run-oracle-resilience-smoke"),
           "v3 backend_driver command surface: help oracle resilience")
    assert(strings.StrContains(helpOutput, "  oracle-fixture-query"),
           "v3 backend_driver command surface: help oracle fixture query")
    assert(strings.StrContains(helpOutput, "  build-oracle-bft-state-machine"),
           "v3 backend_driver command surface: help build-oracle-bft-state-machine")
    assert(strings.StrContains(helpOutput, "  deploy-oracle-bft-three-node"),
           "v3 backend_driver command surface: help deploy-oracle-bft-three-node")
    assert(strings.StrContains(helpOutput, "  status-oracle-bft-three-node"),
           "v3 backend_driver command surface: help status-oracle-bft-three-node")
    assert(strings.StrContains(helpOutput, "  stop-oracle-bft-three-node"),
           "v3 backend_driver command surface: help stop-oracle-bft-three-node")
    assert(strings.StrContains(helpOutput, "  r2c-react-v3 <subcommand>"),
           "v3 backend_driver command surface: help r2c")
    assert(strings.StrContains(helpOutput, "  vpn-proxy <subcommand>"),
           "v3 backend_driver command surface: help vpn proxy")
    assert(strings.StrContains(helpOutput, "  mobile-shell <subcommand>"),
           "v3 backend_driver command surface: help mobile shell")

    let mobileHelpLog = v3path.V3PathJoin(outDir, "mobile_shell_help.log")
    if v3path.V3PathFileExists(mobileHelpLog):
        os.RemoveFile(mobileHelpLog)
    let mobileHelpRun = hostops.v3RunFileLogged(root,
                                                "backend_driver_surface_mobile_shell_help",
                                                driver,
                                                ["mobile-shell", "help"],
                                                [],
                                                root,
                                                0,
                                                mobileHelpLog)
    let mobileHelpOutput: str = mobileHelpRun.output
    assert(mobileHelpRun.exitCode == 0, "v3 backend_driver command surface: mobile-shell help rc")
    assert(strings.StrContains(mobileHelpOutput, "usage: cheng mobile-shell <subcommand> [args]"),
           "v3 backend_driver command surface: mobile-shell help output")
    assert(strings.StrContains(mobileHelpOutput, "subcommands: help, export, build-probe"),
           "v3 backend_driver command surface: mobile-shell build-probe help")

    let vpnHelpLog = v3path.V3PathJoin(outDir, "vpn_proxy_help.log")
    if v3path.V3PathFileExists(vpnHelpLog):
        os.RemoveFile(vpnHelpLog)
    let vpnHelpRun = hostops.v3RunFileLogged(root,
                                             "backend_driver_surface_vpn_proxy_help",
                                             driver,
                                             ["vpn-proxy", "help"],
                                             [],
                                             root,
                                             0,
                                             vpnHelpLog)
    let vpnHelpOutput: str = vpnHelpRun.output
    assert(vpnHelpRun.exitCode == 0, "v3 backend_driver command surface: vpn-proxy help rc")
    assert(strings.StrContains(vpnHelpOutput, "usage: cheng vpn-proxy <local|exit|status> --config:<path>"),
           "v3 backend_driver command surface: vpn-proxy help usage")
    assert(strings.StrContains(vpnHelpOutput, "status flags: --probe-timeout-ms:<n>"),
           "v3 backend_driver command surface: vpn-proxy help flags")

    let buildZeroExitLog = v3path.V3PathJoin(outDir, "build_zero_exit.log")
    if v3path.V3PathFileExists(buildZeroExitLog):
        os.RemoveFile(buildZeroExitLog)
    let buildZeroExitRun = hostops.v3RunFileLogged(root,
                                                   "backend_driver_surface_build_zero_exit",
                                                   driver,
                                                   ["build-zero-exit"],
                                                   [],
                                                   root,
                                                   0,
                                                   buildZeroExitLog)
    assert(buildZeroExitRun.exitCode == 0, "v3 backend_driver command surface: build-zero-exit rc")
    let buildZeroExitOut: str = os.JoinPath(root, "artifacts/v3_zero_exit/ordinary_zero_exit_fixture")
    assert(os.FileExists(buildZeroExitOut),
           "v3 backend_driver command surface: build-zero-exit output")

    let verifyExportLog = v3path.V3PathJoin(outDir, "verify_export_visibility.log")
    if v3path.V3PathFileExists(verifyExportLog):
        os.RemoveFile(verifyExportLog)
    let verifyExportRun = hostops.v3RunFileLogged(root,
                                                  "backend_driver_surface_verify_export_visibility",
                                                  driver,
                                                  ["verify-export-visibility"],
                                                  [],
                                                  root,
                                                  0,
                                                  verifyExportLog)
    let verifyExportOutput: str = verifyExportRun.output
    assert(verifyExportRun.exitCode == 0,
           "v3 backend_driver command surface: verify-export-visibility rc")
    assert(strings.StrContains(verifyExportOutput, "v3 host smokes: ok"),
           "v3 backend_driver command surface: verify-export-visibility output")

    let verifyExportParallelLog = v3path.V3PathJoin(outDir, "verify_export_visibility_parallel.log")
    if v3path.V3PathFileExists(verifyExportParallelLog):
        os.RemoveFile(verifyExportParallelLog)
    let verifyExportParallelRun = hostops.v3RunFileLogged(root,
                                                          "backend_driver_surface_verify_export_visibility_parallel",
                                                          driver,
                                                          ["verify-export-visibility-parallel"],
                                                          [],
                                                          root,
                                                          0,
                                                          verifyExportParallelLog)
    let verifyExportParallelOutput: str = verifyExportParallelRun.output
    assert(verifyExportParallelRun.exitCode == 0,
           "v3 backend_driver command surface: verify-export-visibility-parallel rc")
    assert(strings.StrContains(verifyExportParallelOutput, "v3 host smokes: ok"),
           "v3 backend_driver command surface: verify-export-visibility-parallel output")

    let oracleQueryLog = v3path.V3PathJoin(outDir, "oracle_fixture_query.log")
    if v3path.V3PathFileExists(oracleQueryLog):
        os.RemoveFile(oracleQueryLog)
    let oracleQueryRun = hostops.v3RunFileLogged(root,
                                                 "backend_driver_surface_oracle_fixture_query",
                                                 driver,
                                                 ["oracle-fixture-query", "--pair:BTC/USD", "--window-rounds:3"],
                                                 [],
                                                 root,
                                                 0,
                                                 oracleQueryLog)
    let oracleQueryOutput: str = oracleQueryRun.output
    assert(oracleQueryRun.exitCode == 0,
           "v3 backend_driver command surface: oracle-fixture-query rc")
    assert(strings.StrContains(oracleQueryOutput, "format=v3_oracle_fixture_query_v1"),
           "v3 backend_driver command surface: oracle-fixture-query format")
    assert(strings.StrContains(oracleQueryOutput, "pair=BTC/USD"),
           "v3 backend_driver command surface: oracle-fixture-query pair")
    assert(strings.StrContains(oracleQueryOutput, "latest_code=0"),
           "v3 backend_driver command surface: oracle-fixture-query latest")
    assert(strings.StrContains(oracleQueryOutput, "twap_code=0"),
           "v3 backend_driver command surface: oracle-fixture-query twap")
    assert(strings.StrContains(oracleQueryOutput, "stale_code=9"),
           "v3 backend_driver command surface: oracle-fixture-query stale")

    let oracleVerifyLog = v3path.V3PathJoin(outDir, "verify_oracle_resilience.log")
    if v3path.V3PathFileExists(oracleVerifyLog):
        os.RemoveFile(oracleVerifyLog)
    let oracleVerifyRun = hostops.v3RunFileLogged(root,
                                                  "backend_driver_surface_verify_oracle_resilience",
                                                  driver,
                                                  ["verify-oracle-resilience", "--label:backend_driver_surface_oracle"],
                                                  [],
                                                  root,
                                                  0,
                                                  oracleVerifyLog)
    let oracleVerifyOutput: str = oracleVerifyRun.output
    assert(oracleVerifyRun.exitCode == 0,
           "v3 backend_driver command surface: verify-oracle-resilience rc")
    assert(strings.StrContains(oracleVerifyOutput, "format=v3_oracle_resilience_smoke_v1"),
           "v3 backend_driver command surface: verify-oracle-resilience format")
    assert(strings.StrContains(oracleVerifyOutput, "verify-oracle-resilience: ok"),
           "v3 backend_driver command surface: verify-oracle-resilience output")
    echo("v3 backend_driver_command_surface_smoke ok")
    return 0
