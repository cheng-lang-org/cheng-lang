import std/os
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let root = os.getCurrentDir()
    let outDir = v3path.v3PathAbsolute(root, "artifacts/v3_command_surface_smoke")
    assert(v3path.v3MkdirP(root, outDir), "v3 backend_driver command surface: mkdir")
    let driver = v3path.v3PathAbsolute(root, "artifacts/v3_backend_driver/cheng")
    assert(v3path.v3FileExistsNonEmpty(root, driver),
           "v3 backend_driver command surface: backend_driver exists")

    let helpLog = v3path.v3PathJoin(outDir, "backend_driver.help.log")
    if v3path.v3PathFileExists(helpLog):
        os.removeFile(helpLog)
    let helpRun = hostops.v3RunFileLogged(root, "backend_driver_help", driver, ["help"], [], root, 20, helpLog)
    assert(hostops.v3LoggedRunOk(helpRun), "v3 backend_driver command surface: help rc")
    assert(v3path.v3FileExistsNonEmpty(root, helpLog), "v3 backend_driver command surface: help log")
    assert(v3path.v3TextContains(helpRun.output, "  print-bootstrap"),
           "v3 backend_driver command surface: help print-bootstrap")
    assert(v3path.v3TextContains(helpRun.output, "  build-zero-exit"),
           "v3 backend_driver command surface: help build-zero-exit")
    assert(v3path.v3TextContains(helpRun.output, "  r2c-react-v3 <subcommand>"),
           "v3 backend_driver command surface: help r2c")

    let printBootstrapLog = v3path.v3PathJoin(outDir, "backend_driver.print-bootstrap.log")
    if v3path.v3PathFileExists(printBootstrapLog):
        os.removeFile(printBootstrapLog)
    let printBootstrapRun = hostops.v3RunFileLogged(root,
                                                    "backend_driver_print_bootstrap",
                                                    driver,
                                                    ["print-bootstrap"],
                                                    [],
                                                    root,
                                                    20,
                                                    printBootstrapLog)
    assert(hostops.v3LoggedRunOk(printBootstrapRun), "v3 backend_driver command surface: print-bootstrap rc")
    assert(v3path.v3FileExistsNonEmpty(root, printBootstrapLog),
           "v3 backend_driver command surface: print-bootstrap log")
    assert(v3path.v3TextContains(printBootstrapRun.output, "stage3="),
           "v3 backend_driver command surface: print-bootstrap stage3")
    assert(v3path.v3TextContains(printBootstrapRun.output, "fixed_point="),
           "v3 backend_driver command surface: print-bootstrap fixed point")

    let r2cHelpLog = v3path.v3PathJoin(outDir, "backend_driver.r2c-help.log")
    if v3path.v3PathFileExists(r2cHelpLog):
        os.removeFile(r2cHelpLog)
    let r2cHelpRun = hostops.v3RunFileLogged(root,
                                             "backend_driver_r2c_help",
                                             driver,
                                             ["r2c-react-v3", "help"],
                                             [],
                                             root,
                                             20,
                                             r2cHelpLog)
    assert(hostops.v3LoggedRunOk(r2cHelpRun), "v3 backend_driver command surface: r2c help rc")
    assert(v3path.v3FileExistsNonEmpty(root, r2cHelpLog),
           "v3 backend_driver command surface: r2c help log")
    assert(v3path.v3TextContains(r2cHelpRun.output, "usage: cheng r2c-react-v3 <subcommand> [args]"),
           "v3 backend_driver command surface: r2c help usage")
    assert(v3path.v3TextContains(r2cHelpRun.output, "native-gui-bundle"),
           "v3 backend_driver command surface: r2c help native gui bundle")

    let zeroExitOut = v3path.v3PathAbsolute(root, "artifacts/v3_zero_exit/ordinary_zero_exit_fixture")
    if v3path.v3PathFileExists(zeroExitOut):
        os.removeFile(zeroExitOut)
    let buildZeroExitLog = v3path.v3PathJoin(outDir, "backend_driver.build-zero-exit.log")
    if v3path.v3PathFileExists(buildZeroExitLog):
        os.removeFile(buildZeroExitLog)
    let buildZeroExitRun = hostops.v3RunFileLogged(root,
                                                   "backend_driver_build_zero_exit",
                                                   driver,
                                                   ["build-zero-exit"],
                                                   [],
                                                   root,
                                                   120,
                                                   buildZeroExitLog)
    assert(hostops.v3LoggedRunOk(buildZeroExitRun), "v3 backend_driver command surface: build-zero-exit rc")
    assert(v3path.v3PathFileExists(buildZeroExitLog),
           "v3 backend_driver command surface: build-zero-exit log")
    assert(v3path.v3FileExistsNonEmpty(root, zeroExitOut),
           "v3 backend_driver command surface: zero-exit built")

    let zeroExitRunLog = v3path.v3PathJoin(outDir, "backend_driver.zero-exit.run.log")
    if v3path.v3PathFileExists(zeroExitRunLog):
        os.removeFile(zeroExitRunLog)
    let zeroExitRun = hostops.v3RunFileLogged(root,
                                              "backend_driver_zero_exit_fixture",
                                              zeroExitOut,
                                              [],
                                              [],
                                              root,
                                              10,
                                              zeroExitRunLog)
    assert(hostops.v3LoggedRunOk(zeroExitRun), "v3 backend_driver command surface: zero-exit run rc")
    assert(v3path.v3PathFileExists(zeroExitRunLog),
           "v3 backend_driver command surface: zero-exit run log")

    let worldSyncPrefixColon = v3path.v3PathAbsolute(root, "artifacts/v3_command_surface_smoke/program_selfhost_smoke.colon")
    let worldSyncLogColon = v3path.v3PathJoin(outDir, "backend_driver.world-sync-colon.log")
    if v3path.v3PathFileExists(worldSyncLogColon):
        os.removeFile(worldSyncLogColon)
    let worldSyncRunColon = hostops.v3RunFileLogged(root,
                                                    "backend_driver_world_sync_colon",
                                                    driver,
                                                    [
                                                        "world-sync",
                                                        "--root:" + v3path.v3PathAbsolute(root, "v3"),
                                                        "--in:" + v3path.v3PathAbsolute(root, "v3/src/tests/program_selfhost_smoke.cheng"),
                                                        "--target:arm64-apple-darwin",
                                                        "--channel:stable",
                                                        "--out:" + worldSyncPrefixColon
                                                    ],
                                                    [],
                                                    root,
                                                    120,
                                                    worldSyncLogColon)
    assert(hostops.v3LoggedRunOk(worldSyncRunColon), "v3 backend_driver command surface: world-sync colon rc")
    assert(v3path.v3FileExistsNonEmpty(root, worldSyncPrefixColon + ".world.txt"),
           "v3 backend_driver command surface: world-sync colon world")
    assert(v3path.v3FileExistsNonEmpty(root, worldSyncPrefixColon + ".receipt.txt"),
           "v3 backend_driver command surface: world-sync colon receipt")

    let worldSyncPrefixSplit = v3path.v3PathAbsolute(root, "artifacts/v3_command_surface_smoke/program_selfhost_smoke.split")
    let worldSyncLogSplit = v3path.v3PathJoin(outDir, "backend_driver.world-sync-split.log")
    if v3path.v3PathFileExists(worldSyncLogSplit):
        os.removeFile(worldSyncLogSplit)
    let worldSyncRunSplit = hostops.v3RunFileLogged(root,
                                                    "backend_driver_world_sync_split",
                                                    driver,
                                                    [
                                                        "world-sync",
                                                        "--root",
                                                        v3path.v3PathAbsolute(root, "v3"),
                                                        "--in",
                                                        v3path.v3PathAbsolute(root, "v3/src/tests/program_selfhost_smoke.cheng"),
                                                        "--target:arm64-apple-darwin",
                                                        "--channel:stable",
                                                        "--out:" + worldSyncPrefixSplit
                                                    ],
                                                    [],
                                                    root,
                                                    120,
                                                    worldSyncLogSplit)
    assert(hostops.v3LoggedRunOk(worldSyncRunSplit), "v3 backend_driver command surface: world-sync split rc")
    assert(v3path.v3FileExistsNonEmpty(root, worldSyncPrefixSplit + ".world.txt"),
           "v3 backend_driver command surface: world-sync split world")
    assert(v3path.v3FileExistsNonEmpty(root, worldSyncPrefixSplit + ".receipt.txt"),
           "v3 backend_driver command surface: world-sync split receipt")

    let proveEquivalenceLog = v3path.v3PathJoin(outDir, "backend_driver.prove-equivalence.log")
    if v3path.v3PathFileExists(proveEquivalenceLog):
        os.removeFile(proveEquivalenceLog)
    let proveEquivalenceRun = hostops.v3RunFileLogged(root,
                                                      "backend_driver_prove_equivalence",
                                                      driver,
                                                      [
                                                          "prove-equivalence",
                                                          "--root:" + v3path.v3PathAbsolute(root, "v3"),
                                                          "--in:" + v3path.v3PathAbsolute(root, "v3/src/tests/program_selfhost_smoke.cheng"),
                                                          "--target:arm64-apple-darwin",
                                                          "--channel:stable",
                                                          "--baseline-csg:" + worldSyncPrefixColon + ".csg.txt",
                                                          "--baseline-surface:" + worldSyncPrefixColon + ".surface.txt",
                                                          "--baseline-receipt:" + worldSyncPrefixColon + ".receipt.txt"
                                                      ],
                                                      [],
                                                      root,
                                                      120,
                                                      proveEquivalenceLog)
    assert(hostops.v3LoggedRunOk(proveEquivalenceRun),
           "v3 backend_driver command surface: prove-equivalence rc")
    assert(v3path.v3TextContains(proveEquivalenceRun.output, "graph_equivalent=1"),
           "v3 backend_driver command surface: prove-equivalence graph")
    assert(v3path.v3TextContains(proveEquivalenceRun.output, "compile_receipt_equivalent=1"),
           "v3 backend_driver command surface: prove-equivalence receipt")

    echo("v3 backend_driver_command_surface_smoke ok")
    return 0
