import std/system
import std/rawbytes
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/dag_mempool as dag
import cheng/v3/chain/erasure_swarm as swarm
import cheng/v3/chain/content_plane as content
import cheng/v3/chain/content_fetch as fetch

fn contentCodecBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    let shard0 = bytesFromString("codec-0")
    let shard1 = bytesFromString("codec-1")
    let blob = bytesFromString("codec-0codec-1")
    let summaryRes = dag.v3DagBlobSummaryFromBytes(blob, 7)
    assert(IsOk(summaryRes), "v3 content codec smoke: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.v3ErasureEncodingParamsMake(swarm.v3ErasureLayoutRsSystematic, 2, 0, 7)
    assert(IsOk(paramsRes), "v3 content codec smoke: params")
    let params = Value(paramsRes)

    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    add(shardPayloadCids, swarm.v3ErasureShardPayloadCid(shard0))
    add(shardPayloadCids, swarm.v3ErasureShardPayloadCid(shard1))
    let manifestRes = swarm.v3ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), "v3 content codec smoke: manifest")
    let manifest = Value(manifestRes)

    let pullReqRes = swarm.v3ErasureShardPullRequestMake(manifest, 0)
    assert(IsOk(pullReqRes), "v3 content codec smoke: pull request")
    let pullReq = Value(pullReqRes)
    let pullReqDecodedRes = swarm.v3ErasureShardPullRequestDecode(
        swarm.v3ErasureShardPullRequestEncode(pullReq)
    )
    assert(IsOk(pullReqDecodedRes), "v3 content codec smoke: pull request decode")
    let pullReqDecoded = Value(pullReqDecodedRes)
    assert(layout.fixedBytes32Equal(pullReqDecoded.requestCid, pullReq.requestCid),
        "v3 content codec smoke: pull request cid")

    let pullRespRes = swarm.v3ErasureShardPullResponseMake(pullReq, shard0)
    assert(IsOk(pullRespRes), "v3 content codec smoke: pull response")
    let pullResp = Value(pullRespRes)
    let pullRespDecodedRes = swarm.v3ErasureShardPullResponseDecode(
        swarm.v3ErasureShardPullResponseEncode(pullResp)
    )
    assert(IsOk(pullRespDecodedRes), "v3 content codec smoke: pull response decode")
    let pullRespDecoded = Value(pullRespDecodedRes)
    assert(layout.fixedBytes32Equal(pullRespDecoded.responseCid, pullResp.responseCid),
        "v3 content codec smoke: pull response cid")
    assert(pullRespDecoded.payloadLen == bytesLen(shard0), "v3 content codec smoke: pull payload len")

    let manifestFetchReqRes = fetch.v3ContentFetchRequestManifest(manifest.manifestCid)
    assert(IsOk(manifestFetchReqRes), "v3 content codec smoke: manifest fetch request")
    let manifestFetchReq = Value(manifestFetchReqRes)
    let manifestFetchRespRes = fetch.v3ContentFetchResponseMake(manifestFetchReq,
                                                                swarm.v3ErasureShardManifestEncode(manifest))
    assert(IsOk(manifestFetchRespRes), "v3 content codec smoke: manifest fetch response")
    var manifestBack = swarm.V3ErasureShardManifest()
    let manifestBackRes = fetch.v3ContentFetchResponseToManifestFill(manifestBack,
                                                                     manifestFetchReq,
                                                                     Value(manifestFetchRespRes))
    assert(IsOk(manifestBackRes), "v3 content codec smoke: manifest fetch roundtrip")
    assert(layout.fixedBytes32Equal(manifestBack.manifestCid, manifest.manifestCid),
        "v3 content codec smoke: manifest roundtrip cid")

    let chunkFetchReqRes = fetch.v3ContentFetchRequestFromShardPull(pullReq)
    assert(IsOk(chunkFetchReqRes), "v3 content codec smoke: chunk fetch request")
    let chunkFetchReq = Value(chunkFetchReqRes)
    let chunkFetchRespRes = fetch.v3ContentFetchResponseMake(chunkFetchReq, shard0)
    assert(IsOk(chunkFetchRespRes), "v3 content codec smoke: chunk fetch response")
    var pullRespBack = swarm.V3ErasureShardPullResponse()
    let pullRespBackRes = fetch.v3ContentFetchResponseToShardPullFill(pullRespBack,
                                                                      chunkFetchReq,
                                                                      Value(chunkFetchRespRes))
    assert(IsOk(pullRespBackRes), "v3 content codec smoke: chunk fetch roundtrip")
    assert(layout.fixedBytes32Equal(pullRespBack.shardCid, pullReq.shardCid),
        "v3 content codec smoke: chunk roundtrip shard cid")

    let stubRes = content.v3ContentStubMake(lt.v3HashInts("v3.content.codec.topic", [1]),
                                            lt.v3HashInts("v3.content.codec.bundle", [2]),
                                            summary.summaryCid,
                                            lt.v3HashInts("v3.content.codec.advert", [3]),
                                            manifest.manifestCid,
                                            lt.v3HashInts("v3.content.codec.plan", [4]),
                                            summary.payloadLen)
    assert(IsOk(stubRes), "v3 content codec smoke: stub")
    let stub = Value(stubRes)
    let stubDecodedRes = content.v3ContentStubDecode(content.v3ContentStubEncode(stub))
    assert(IsOk(stubDecodedRes), "v3 content codec smoke: stub decode")
    assert(layout.fixedBytes32Equal(Value(stubDecodedRes).stubCid, stub.stubCid),
        "v3 content codec smoke: stub cid")

    let rangeReqRes = fetch.v3ContentFetchRequestRange(summary.blobCid, 2, 4)
    assert(IsOk(rangeReqRes), "v3 content codec smoke: range request")
    let rangeReq = Value(rangeReqRes)
    let rangeRespRes = fetch.v3ContentFetchResponseMake(rangeReq, bytesSlice(blob, 2, 4))
    assert(IsOk(rangeRespRes), "v3 content codec smoke: range response")
    let rangeRespDecodedRes = fetch.v3ContentFetchResponseDecode(
        fetch.v3ContentFetchResponseEncode(Value(rangeRespRes))
    )
    assert(IsOk(rangeRespDecodedRes), "v3 content codec smoke: range response decode")
    let rangePayload = Value(rangeRespDecodedRes).payload
    assert(contentCodecBytesEqual(rangePayload, bytesSlice(blob, 2, 4)),
        "v3 content codec smoke: range payload")

    echo("v3 content_codec_smoke ok")
    return 0
