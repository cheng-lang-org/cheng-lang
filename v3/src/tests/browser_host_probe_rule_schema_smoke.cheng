import cheng/v3/lang/browser_abi_rule as barule
import cheng/v3/libp2p/browser/browser_host_probe_rule_schema as browserprobe

fn main(): int32 =
    let rules = browserprobe.v3BrowserHostProbeRules("/tmp/browser_host_wasm_probe.cheng")
    assert(rules.len == 8, "v3 browser_host_probe_rule_schema: rule count")
    assert(barule.v3BrowserAbiRuleCountInputKind(rules, "scalar_none") == 4,
           "v3 browser_host_probe_rule_schema: scalar none count")
    assert(barule.v3BrowserAbiRuleCountInputKind(rules, "scalar_i32_1") == 2,
           "v3 browser_host_probe_rule_schema: scalar i32_1 count")
    assert(barule.v3BrowserAbiRuleCountInputKind(rules, "scalar_i32_2") == 1,
           "v3 browser_host_probe_rule_schema: scalar i32_2 count")
    assert(barule.v3BrowserAbiRuleCountInputKind(rules, "scalar_i32_4") == 1,
           "v3 browser_host_probe_rule_schema: scalar i32_4 count")
    assert(barule.v3BrowserAbiRuleCountOutputKind(rules, "scalar_i32") == 8,
           "v3 browser_host_probe_rule_schema: scalar output count")
    let dmWait = browserprobe.v3BrowserHostProbeRuleByName("/tmp/browser_host_wasm_probe.cheng",
                                                           browserprobe.v3BrowserHostProbeRuleDmWaitStartName())
    assert(dmWait.ruleName == browserprobe.v3BrowserHostProbeRuleDmWaitStartName(),
           "v3 browser_host_probe_rule_schema: dm wait name")
    assert(dmWait.inputKindText == "scalar_i32_2",
           "v3 browser_host_probe_rule_schema: dm wait input")
    assert(dmWait.outputKindText == "scalar_i32",
           "v3 browser_host_probe_rule_schema: dm wait output")
    assert(dmWait.errorKindText == "inline_none",
           "v3 browser_host_probe_rule_schema: dm wait error")
    assert(barule.v3BrowserAbiBridgeEmitLine(barule.v3BrowserAbiBridgeSpecForRule(dmWait)) ==
           "source=/tmp/browser_host_wasm_probe.cheng|rule=dm_wait_start|stage=scalar_call|helper=v3_browser_bridge_scalar_call_dm_wait_start|input_schema=scalar_i32_2|output_schema=scalar_i32|error_schema=inline_none|result=scalar_i32|out_buffer=none",
           "v3 browser_host_probe_rule_schema: dm wait emit line")
    echo("v3 browser_host_probe_rule_schema_smoke ok")
    return 0
