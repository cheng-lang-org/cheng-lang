import std/system
import std/rawbytes
import cheng/v3/std/bytes_layout as layout
import cheng/v3/std/crypto/hash256
import cheng/v3/chain/binary_types as binary
import cheng/v3/overlay/contracts as overlay
import cheng/v3/overlay/libp2p_bridge as bridge
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/core/peer_id
import cheng/v3/libp2p/core/peerstore as ps
import cheng/v3/libp2p/discovery/kad
import cheng/v3/libp2p/host/host

fn smokeProtocolsAddress(): binary.V3LsmrAddress =
    var out: binary.V3LsmrAddress
    out.depth = 2
    out.digits[0] = 4
    out.digits[1] = 8
    return out

fn smokeProtocolsBytes(text: str): Bytes =
    var out: Bytes
    out.data = strDataPtr(text)
    out.len = len(text)
    return out

fn main(): int32 =
    var node = host.v3Libp2pHostInit("protocols.node")
    var requester = host.v3Libp2pHostInit("protocols.requester")
    let address = smokeProtocolsAddress()

    let expectedTopic = bridge.v3Libp2pTopicId(overlay.v3OverlayScopeRegion, address)
    host.v3Libp2pSubscribe(node, expectedTopic)
    assert(node.subscriptions.len == 1, "v3 libp2p protocols: subscription count")

    let sourcePeer = peer_id.v3Libp2pPeerIdFromSeed("protocols.source")
    let payload = smokeProtocolsBytes("v3.libp2p.payload")
    let payloadCid = hash256.sha256Fixed(layout.byteSpanFromBytes(payload))

    var ingress: overlay.V3IngressEnvelope
    ingress.sourcePeerId = sourcePeer.value
    ingress.topicScope = overlay.v3OverlayScopeRegion
    ingress.address = address
    ingress.payload = payload
    ingress.payloadCid = payloadCid
    ingress.payloadLen = bytesLen(payload)
    ingress.stampEpoch = 11
    ingress.stampGanzhi = 22

    bridge.v3Libp2pRelayPublish(node, ingress)

    assert(node.publishLog.len == 1, "v3 libp2p protocols: publish count")
    let published = node.publishLog[0]
    assert(types.v3Libp2pTopicIdEqual(published.topicId, expectedTopic),
        "v3 libp2p protocols: topic id")
    assert(layout.fixedBytes32Equal(published.payloadCid, payloadCid),
        "v3 libp2p protocols: publish payload cid")
    assert(published.payloadLen == bytesLen(payload),
        "v3 libp2p protocols: publish payload len")

    assert(node.storeEntries.len == 1, "v3 libp2p protocols: store count")
    let storedEntry = node.storeEntries[0]
    let storedIngress = storedEntry.ingress
    assert(layout.fixedBytes32Equal(storedIngress.payloadCid, payloadCid),
        "v3 libp2p protocols: store payload cid")
    assert(storedIngress.payloadLen == bytesLen(payload),
        "v3 libp2p protocols: store payload len")
    assert(bytesLen(storedIngress.payload) == bytesLen(payload),
        "v3 libp2p protocols: store raw payload len")
    assert(bytesGet(storedIngress.payload, 0) == int32('v'),
        "v3 libp2p protocols: store raw payload head")

    var listenAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(listenAddr, "127.0.0.1", 6207)
    let listenRes = host.v3Libp2pListen(node, listenAddr)
    assert(listenRes.ok, "v3 libp2p protocols: listen sync")
    host.v3Libp2pRegisterHandler(node, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(requester, types.v3Libp2pProtocolSync)
    let dialRes = host.v3Libp2pDial(requester,
                                    node.selfPeerId,
                                    listenAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 libp2p protocols: dial sync")

    var query = overlay.v3OverlayStoreQueryZero()
    query.topicScope = overlay.v3OverlayScopeRegion
    query.address = address
    query.rangeLimit = 4
    let syncRes = host.v3Libp2pSyncRequest(requester, node, node.selfPeerId, query)
    assert(syncRes.ok, "v3 libp2p protocols: sync request")
    assert(syncRes.value.len == 1, "v3 libp2p protocols: sync count")
    let synced = syncRes.value[0]
    assert(layout.fixedBytes32Equal(synced.payloadCid, payloadCid),
        "v3 libp2p protocols: sync payload cid")
    assert(synced.payloadLen == bytesLen(payload),
        "v3 libp2p protocols: sync payload len")
    assert(bytesLen(synced.payload) == bytesLen(payload),
        "v3 libp2p protocols: sync raw payload len")
    assert(bytesGet(synced.payload, 0) == int32('v'),
        "v3 libp2p protocols: sync raw payload head")
    assert(requester.syncRequestCount == 1, "v3 libp2p protocols: sync request count")
    assert(node.syncServeCount == 1, "v3 libp2p protocols: sync serve count")

    echo("v3 libp2p_protocols_smoke ok")
    return 0
