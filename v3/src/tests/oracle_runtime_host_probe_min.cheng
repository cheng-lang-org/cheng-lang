import std/system
import std/result
import std/crypto/ecnist
import cheng/v3/chain/binary_types as binary
import cheng/v3/chain/pubsub
import cheng/v3/chain/oracle_runtime_host as oracle_host
import cheng/v3/chain/oracle_plane as oracle_plane
import cheng/v3/chain/oracle_types as oracle_types
import cheng/v3/std/crypto/fixed256
import cheng/v3/std/bytes_layout as layout
import cheng/v3/tests/oracle_smoke_support as support
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host

fn main(): int32 =
    echo("probe: start")
    let committee = support.oracleSmokeCommittee()
    echo("probe: committee")
    var gossipRuntime = oracle_host.v3OracleFastRuntimeInit(committee)
    var syncRuntime = oracle_host.v3OracleFastRuntimeInit(committee)
    echo("probe: runtimes")

    var authorHost = host.v3Libp2pHostInit("oracle.runtime.host.author")
    var readerHost = host.v3Libp2pHostInit("oracle.runtime.host.reader")
    echo("probe: hosts")

    var authorAddr: types.V3Libp2pMultiaddr
    var readerAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(authorAddr, "127.0.0.1", 6336)
    multiaddr.v3Libp2pMultiaddrFillTcp(readerAddr, "127.0.0.1", 6337)
    echo("probe: addrs")

    let authorListenRes = host.v3Libp2pListen(authorHost, authorAddr)
    assert(IsOk(authorListenRes), "probe: author listen")
    let readerListenRes = host.v3Libp2pListen(readerHost, readerAddr)
    assert(IsOk(readerListenRes), "probe: reader listen")
    echo("probe: listen")

    host.v3Libp2pRegisterHandler(authorHost, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(readerHost, types.v3Libp2pProtocolSync)
    echo("probe: handlers")

    let dialReaderRes = host.v3Libp2pDial(readerHost,
                                          authorHost.selfPeerId,
                                          authorAddr,
                                          overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(dialReaderRes), "probe: reader dial")
    let dialAuthorRes = host.v3Libp2pDial(authorHost,
                                          readerHost.selfPeerId,
                                          readerAddr,
                                          overlay.v3OverlayRoleEdgeRelayStore)
    assert(IsOk(dialAuthorRes), "probe: author dial")
    echo("probe: dial")

    let addressRes = binary.v3LsmrAddressFromDigits([2, 6, 6])
    assert(IsOk(addressRes), "probe: address")
    let address = Value(addressRes)
    let scope = overlay.v3OverlayScopeRegion
    echo("probe: address done")

    let batch = support.oracleSmokeBatch(int64(12), 1)
    echo("probe: batch")
    let structuralRes = oracle_plane.v3OracleSignedBatchStructuralValidate(batch)
    assert(IsOk(structuralRes), "probe: structural")
    echo("probe: structural")
    let signableRes = oracle_plane.v3OracleSignedBatchSignableBytes(batch)
    assert(IsOk(signableRes), "probe: signable")
    echo("probe: signable")
    let pubKey = committee.reporterPubKeys[batch.reporterSlot - 1]
    echo("probe: pubkey")
    let pubBytes = layout.fixedBytes65ToBytes(pubKey)
    echo("probe: pub bytes")
    let sigBytes = layout.fixedBytes64ToBytes(batch.sig)
    echo("probe: sig bytes")
    let verifyTrusted = ecnist.ecdsaVerifyTrustedBytes(pubBytes, Value(signableRes), sigBytes)
    assert(verifyTrusted, "probe: verify trusted")
    echo("probe: verify trusted")
    let verifyDirectRes = fixed256.p256VerifyMessageFixed64(pubKey, Value(signableRes), batch.sig)
    assert(IsOk(verifyDirectRes), "probe: verify direct")
    echo("probe: verify direct")
    let verifyRes = oracle_plane.v3OracleSignedBatchVerifyAgainstCommittee(batch, committee)
    assert(IsOk(verifyRes), "probe: verify against committee")
    echo("probe: verify against committee")
    let storeGossipRes = oracle_host.v3OracleFastRuntimeStoreBatch(gossipRuntime, batch)
    assert(IsOk(storeGossipRes), "probe: store gossip")
    echo("probe: store gossip")

    let publishRes = oracle_host.v3OracleRuntimePublishBatch(authorHost,
                                                             scope,
                                                             address,
                                                             batch,
                                                             21,
                                                             31)
    assert(IsOk(publishRes), "probe: publish")
    echo("probe: publish")

    let fetchedRes = oracle_host.v3OracleRuntimeFetchBatch(readerHost,
                                                           authorHost,
                                                           authorHost.selfPeerId,
                                                           scope,
                                                           address,
                                                           batch.batchCid)
    assert(IsOk(fetchedRes), "probe: fetch")
    echo("probe: fetch")
    let fetched = Value(fetchedRes)
    let storeSyncRes = oracle_host.v3OracleFastRuntimeStoreBatch(syncRuntime, fetched)
    assert(IsOk(storeSyncRes), "probe: store sync")
    echo("probe: store sync")

    assert(authorHost.publishLog.len == 1, "probe: publish count")
    assert(authorHost.storeEntries.len == 1, "probe: store count")
    assert(authorHost.storeEntries[0].ingress.payloadKind == pubsub.v3PubSubPayloadKindOracleBatch,
        "probe: payload kind")
    echo("probe: done")
    return 0
