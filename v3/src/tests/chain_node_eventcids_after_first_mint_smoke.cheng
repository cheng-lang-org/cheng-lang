import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server = node.v3ChainNodeInit("node-a", "chain-node-a")
    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node eventcids after first mint: mint")
    add(server.eventCids, layout.fixedBytes32Zero())
    assert(server.eventCids.len == 2, "v3 chain_node eventcids after first mint: second add")
    echo("v3 chain_node_eventcids_after_first_mint_smoke ok")
    return 0
