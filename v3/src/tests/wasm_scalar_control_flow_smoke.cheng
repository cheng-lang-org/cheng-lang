fn normalizeMod(value: int32, modulus: int32): int32 =
    let rem = value % modulus
    if rem < 0: return rem + modulus
    return rem

fn accumulate(limit: int32): int32 =
    var total = 0
    var i = 0
    while i < limit:
        if i == 4:
            total = total + 7
        else:
            total = total + i
        i = i + 1
    return total

fn choose(flag: int32): int32 =
    return flag != 0 ? 11 : 22

fn main(): int32 =
    if normalizeMod(-1, 5) != 4:
        return 1
    if normalizeMod(14, 5) != 4:
        return 2
    if accumulate(5) != 13:
        return 3
    if choose(1) != 11:
        return 4
    if choose(0) != 22:
        return 5
    return 0
