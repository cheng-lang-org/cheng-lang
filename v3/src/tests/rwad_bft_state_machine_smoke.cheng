import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/project/rwad_serial_state_machine as serial
import cheng/v3/project/rwad_bft_state_machine as rwad

fn main(): int32 =
    let alice = serial.v3RwadOwnerIdFromText("alice")
    let bob = serial.v3RwadOwnerIdFromText("bob")
    var machine = rwad.v3RwadBftStateMachineInit("rwad-bft-smoke")

    let mint = rwad.v3RwadBftTxMint(alice, int64(100))
    let mintRaw = rwad.v3RwadBftEncodeTx(mint)
    let mintRoundtrip = rwad.v3RwadBftDecodeTx(layout.byteSpanFromBytes(mintRaw))
    assert(mintRoundtrip.ok, "v3 rwad bft smoke: mint roundtrip")
    let mintCheck = rwad.v3RwadBftStateMachineCheckTx(machine,
                                                      rwad.v3RwadBftBlockContextMake(int64(1), 0, int64(0), layout.fixedBytes32Zero()),
                                                      mint)
    assert(mintCheck.code == serial.v3RwadSerialCodeOk, "v3 rwad bft smoke: mint check")
    assert(machine.ledger.notes.len == 0, "v3 rwad bft smoke: mint check no mutate")

    var block1: rwad.V3RwadBftTx[]
    block1 = []
    add(block1, mint)
    var block1Summary = rwad.v3RwadBftBlockSummaryZero(int64(0))
    rwad.v3RwadBftStateMachineFinalizeBlockSummary(machine, int64(1), block1, block1Summary)
    assert(block1Summary.txCount == 1, "v3 rwad bft smoke: block1 tx count")
    assert(block1Summary.appliedCount == 1, "v3 rwad bft smoke: block1 applied")
    assert(machine.ledger.lastFinalizedHeight == int64(1), "v3 rwad bft smoke: block1 height")

    let transfer = rwad.v3RwadBftTxTransfer(int64(1), alice, bob, int64(21), int64(40))
    let transferRaw = rwad.v3RwadBftEncodeTx(transfer)
    let transferCheckBytes = rwad.v3RwadBftStateMachineCheckTxBytes(machine,
                                                                    rwad.v3RwadBftBlockContextMake(int64(2), 0, int64(0), layout.fixedBytes32Zero()),
                                                                    transferRaw)
    assert(transferCheckBytes.code == serial.v3RwadSerialCodeOk, "v3 rwad bft smoke: transfer check bytes")
    let transferCheck = rwad.v3RwadBftStateMachineCheckTx(machine,
                                                          rwad.v3RwadBftBlockContextMake(int64(2), 0, int64(0), layout.fixedBytes32Zero()),
                                                          transfer)
    assert(transferCheck.code == serial.v3RwadSerialCodeOk, "v3 rwad bft smoke: transfer check")

    var block2: rwad.V3RwadBftTx[]
    block2 = []
    add(block2, transfer)
    var block2Summary = rwad.v3RwadBftBlockSummaryZero(int64(0))
    rwad.v3RwadBftStateMachineFinalizeBlockSummary(machine, int64(2), block2, block2Summary)
    assert(block2Summary.appliedCount == 1, "v3 rwad bft smoke: block2 applied")
    assert(!layout.fixedBytes32Equal(block2Summary.serialRoot, layout.fixedBytes32Zero()),
           "v3 rwad bft smoke: block2 serial root")
    assert(!layout.fixedBytes32Equal(block2Summary.nullifierRoot, layout.fixedBytes32Zero()),
           "v3 rwad bft smoke: block2 nullifier root")

    let aliceQuery = rwad.v3RwadBftStateMachineQueryOwner(machine, alice)
    let bobQuery = rwad.v3RwadBftStateMachineQueryOwner(machine, bob)
    assert(aliceQuery.balance == int64(80), "v3 rwad bft smoke: alice balance")
    assert(aliceQuery.liveNoteCount == 2, "v3 rwad bft smoke: alice notes")
    assert(bobQuery.balance == int64(20), "v3 rwad bft smoke: bob balance")
    assert(bobQuery.liveNoteCount == 1, "v3 rwad bft smoke: bob notes")
    assert(layout.fixedBytes32Equal(block2Summary.appHash, rwad.v3RwadBftStateMachineQueryAppHash(machine)),
           "v3 rwad bft smoke: app hash")

    var bytesMachine = rwad.v3RwadBftStateMachineInit("rwad-bft-smoke-bytes")
    var rawBlock1: Bytes[]
    rawBlock1 = []
    add(rawBlock1, mintRaw)
    var rawBlock1Summary = rwad.v3RwadBftBlockSummaryZero(int64(0))
    rwad.v3RwadBftStateMachineFinalizeBlockBytesSummary(bytesMachine, int64(1), rawBlock1, rawBlock1Summary)
    assert(rawBlock1Summary.appliedCount == 1, "v3 rwad bft smoke: raw block1")
    var rawBlock2: Bytes[]
    rawBlock2 = []
    add(rawBlock2, transferRaw)
    var rawBlock2Summary = rwad.v3RwadBftBlockSummaryZero(int64(0))
    rwad.v3RwadBftStateMachineFinalizeBlockBytesSummary(bytesMachine, int64(2), rawBlock2, rawBlock2Summary)
    assert(rawBlock2Summary.appliedCount == 1, "v3 rwad bft smoke: raw block2")

    var staleBlock: rwad.V3RwadBftTx[]
    staleBlock = []
    add(staleBlock, transfer)
    var staleSummary = rwad.v3RwadBftBlockSummaryZero(int64(0))
    rwad.v3RwadBftStateMachineFinalizeBlockSummary(machine, int64(2), staleBlock, staleSummary)
    assert(staleSummary.appliedCount == 0, "v3 rwad bft smoke: stale applied")
    assert(staleSummary.rejectedCount == 1, "v3 rwad bft smoke: stale rejected")
    echo("v3 rwad_bft_state_machine_smoke ok")
    return 0
