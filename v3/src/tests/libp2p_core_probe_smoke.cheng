import std/system
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peer_id
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/core/multistream

fn main(): int32 =
    echo("probe:0")
    let peerA = peer_id.v3Libp2pPeerIdFromSeed("alice")
    echo("probe:1")
    let peerB = peer_id.v3Libp2pPeerIdFromSeed("bob")
    echo("probe:2")
    assert(!types.v3Libp2pPeerIdEqual(peerA, peerB), "probe: peer ids distinct")
    echo("probe:3")
    assert(peer_id.v3Libp2pPeerIdDistance(peerA, peerB) > int64(0), "probe: xor distance")
    echo("probe:4")

    let tcpAddrRes = multiaddr.v3Libp2pMultiaddrParse("/ip4/127.0.0.1/tcp/4101")
    echo("probe:5")
    assert(tcpAddrRes.ok, "probe: tcp parse")
    echo("probe:6")
    let tcpAddr = tcpAddrRes.value
    assert(tcpAddr.transport == types.v3Libp2pTransportTcp, "probe: tcp transport")
    echo("probe:7")
    assert(tcpAddr.secure == types.v3Libp2pSecureNoise, "probe: tcp noise")
    echo("probe:8")
    assert(tcpAddr.mux == types.v3Libp2pMuxYamux, "probe: tcp yamux")
    echo("probe:9")

    let quicAddrRes = multiaddr.v3Libp2pMultiaddrParse("/ip4/127.0.0.1/udp/4201/quic-v1")
    echo("probe:10")
    assert(quicAddrRes.ok, "probe: quic parse")
    echo("probe:11")
    let quicAddr = quicAddrRes.value
    assert(quicAddr.transport == types.v3Libp2pTransportQuic, "probe: quic transport")
    echo("probe:12")
    assert(quicAddr.secure == types.v3Libp2pSecureTls, "probe: quic tls")
    echo("probe:13")
    assert(quicAddr.mux == types.v3Libp2pMuxNone, "probe: quic mux")
    echo("probe:14")

    let header = multistream.v3Libp2pMultistreamHeaderText()
    echo("probe:15")
    assert(header == "/multistream/1.0.0\n", "probe: header")
    echo("probe:16")
    let select = multistream.v3Libp2pMultistreamSelectBytes(types.v3Libp2pProtocolIdentify)
    echo("probe:17")
    assert(multistream.v3Libp2pMultistreamAccepts(select, types.v3Libp2pProtocolIdentify),
        "probe: multistream accept")
    echo("probe:18")
    return 0
