fn directText(): str =
    return "direct-call"

fn directRc(): int32 =
    return 42

fn fillDirectCall(outText: var str, outRc: var int32) =
    outText = directText()
    outRc = directRc()

fn main(): int32 =
    var text: str
    var rc: int32 = -1
    fillDirectCall(text, rc)
    assert(text == "direct-call", "out param direct call text")
    assert(rc == 42, "out param direct call rc")
    echo("v3 out_param_direct_call_writeback_smoke ok")
    return 0
