import std/os
import std/strings
import std/strutils as strutil
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/host_ops as hostops

fn v3StrConcatLoweringFlag(prefix: str, value: str): str =
    var parts: str[]
    add(parts, prefix)
    add(parts, value)
    return Fmt(parts)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let compilerEnv = os.GetEnv("CHENG_V3_SMOKE_COMPILER")
    var compilerRaw = "artifacts/v3_bootstrap/cheng.stage3"
    if len(compilerEnv) > 0:
        compilerRaw = compilerEnv
    var driver = compilerRaw
    if !os.IsAbsolute(compilerRaw):
        driver = os.JoinPath(root, compilerRaw)
    let target = os.GetEnvDefault("CHENG_V3_RUNTIME_LINK_TARGET", "arm64-apple-darwin")
    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_str_concat_lowering_smoke")
    let sourcePath = os.JoinPath(root, "v3/src/tests/str_concat_lowering_fixture.cheng")
    let outBin = os.JoinPath(outDir, "str_concat_lowering_probe")
    let exeReportPath = os.JoinPath(outDir, "str_concat_lowering_probe.compile.report.txt")
    let exeCompileLog = os.JoinPath(outDir, "str_concat_lowering_probe.compile.log")
    let exeRunLog = os.JoinPath(outDir, "str_concat_lowering_probe.run.log")
    assert(v3path.V3MkdirP(root, outDir), "v3 str concat lowering: mkdir")
    assert(os.FileExists(driver), "v3 str concat lowering: compiler exists")
    if v3path.V3PathFileExists(outBin):
        os.RemoveFile(outBin)
    if v3path.V3PathFileExists(exeReportPath):
        os.RemoveFile(exeReportPath)
    if v3path.V3PathFileExists(exeCompileLog):
        os.RemoveFile(exeCompileLog)
    let compileRun = hostops.v3RunFileLogged(root,
                                             "str_concat_lowering_exe_build",
                                             driver,
                                             [
                                                 "system-link-exec",
                                                 v3StrConcatLoweringFlag("--root:", root),
                                                 v3StrConcatLoweringFlag("--in:", sourcePath),
                                                 "--emit:exe",
                                                 v3StrConcatLoweringFlag("--target:", target),
                                                 v3StrConcatLoweringFlag("--out:", outBin),
                                                 v3StrConcatLoweringFlag("--report-out:", exeReportPath)
                                             ],
                                             [],
                                             root,
                                             0,
                                             exeCompileLog)
    assert(compileRun.exitCode == 0, "v3 str concat lowering: exe compile rc")
    assert(v3path.V3PathFileExists(exeReportPath), "v3 str concat lowering: report exists")
    let reportText = os.ReadFile(exeReportPath)
    let reportPrefix = "native_primary_object="
    let reportLines = strutil.Split(reportText, '\n')
    var primaryObjectPath: str
    for i in 0..<reportLines.len:
        let line = strutil.Strip(reportLines[i])
        if strutil.StartsWith(line, reportPrefix):
            primaryObjectPath = v3path.V3TextSlice(line, len(reportPrefix), len(line) - len(reportPrefix))
    assert(len(primaryObjectPath) > 0, "v3 str concat lowering: primary object path")
    let nmCommand = v3StrConcatLoweringFlag("nm -u ", primaryObjectPath)
    let symbolsRun = os.ExecCmdEx(nmCommand, 0, root)
    assert(os.ExecCmdResultExitCode(symbolsRun) == 0, "v3 str concat lowering: nm rc")
    let symbolsText = os.ExecCmdResultOutput(symbolsRun)
    assert(strings.StrContains(symbolsText, "_cheng_v3_strformat_fmt_bridge"),
           "v3 str concat lowering: fmt bridge")
    assert(!strings.StrContains(symbolsText, "_driver_c_str_concat_bridge"),
           "v3 str concat lowering: no binary concat bridge")
    let run = hostops.v3RunFileLogged(root,
                                      "str_concat_lowering_run",
                                      outBin,
                                      [],
                                      [],
                                      root,
                                      0,
                                      exeRunLog)
    assert(run.exitCode == 0, "v3 str concat lowering: run rc")
    assert(strings.StrContains(run.output, "v3 str_concat_lowering_fixture ok"),
           "v3 str concat lowering: runtime output")
    echo("v3 str_concat_lowering_smoke ok")
    return 0
