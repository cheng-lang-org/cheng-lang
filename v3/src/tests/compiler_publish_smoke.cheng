import cheng/v3/tooling/compiler_equivalence as ceq
import cheng/v3/std/bytes_layout as layout

fn main(): int32 =
    var worldHeadCid = layout.fixedBytes32Zero()
    var passedProof: ceq.V3CompilerEquivalenceProof
    passedProof.packageId = "cheng/v3"
    passedProof.channel = "stable"
    passedProof.baselineGraphCid = worldHeadCid
    passedProof.migratedGraphCid = worldHeadCid
    passedProof.baselineSurfaceCid = worldHeadCid
    passedProof.migratedSurfaceCid = worldHeadCid
    passedProof.baselineReceiptCid = worldHeadCid
    passedProof.migratedReceiptCid = worldHeadCid
    passedProof.targetTriple = "arm64-apple-darwin"
    passedProof.graphEquivalent = 1
    passedProof.exportSurfaceCompatible = 1
    passedProof.compileReceiptEquivalent = 1
    passedProof.equivalenceLabel = ceq.v3CompilerEquivalenceKind(true, true, true)
    passedProof.proofCid = worldHeadCid
    var stableAllowed: ceq.V3CompilerPublishDecision
    let stableAllowedRes = ceq.v3CompilerPublishDecisionMake("stable",
                                                             worldHeadCid,
                                                             true,
                                                             passedProof,
                                                             stableAllowed)
    assert(IsOk(stableAllowedRes), "v3 compiler publish: stable allowed result")
    assert(stableAllowed.stableGateRequired != 0, "v3 compiler publish: stable gate")
    assert(stableAllowed.publishAllowed != 0, "v3 compiler publish: stable allowed")
    var failedProof: ceq.V3CompilerEquivalenceProof
    failedProof.packageId = "cheng/v3"
    failedProof.channel = "stable"
    failedProof.baselineGraphCid = worldHeadCid
    failedProof.migratedGraphCid = worldHeadCid
    failedProof.baselineSurfaceCid = worldHeadCid
    failedProof.migratedSurfaceCid = worldHeadCid
    failedProof.baselineReceiptCid = worldHeadCid
    failedProof.migratedReceiptCid = worldHeadCid
    failedProof.targetTriple = "arm64-apple-darwin"
    failedProof.graphEquivalent = 0
    failedProof.exportSurfaceCompatible = 1
    failedProof.compileReceiptEquivalent = 1
    failedProof.equivalenceLabel = ceq.v3CompilerEquivalenceKind(false, true, true)
    failedProof.proofCid = worldHeadCid
    var stableBlocked: ceq.V3CompilerPublishDecision
    let stableBlockedRes = ceq.v3CompilerPublishDecisionMake("stable",
                                                             worldHeadCid,
                                                             true,
                                                             failedProof,
                                                             stableBlocked)
    assert(IsOk(stableBlockedRes), "v3 compiler publish: stable blocked result")
    assert(stableBlocked.publishAllowed == 0, "v3 compiler publish: stable reject incompatible")
    var uncheckedProof: ceq.V3CompilerEquivalenceProof
    uncheckedProof.proofCid = layout.fixedBytes32Zero()
    var edgeDecision: ceq.V3CompilerPublishDecision
    let edgeDecisionRes = ceq.v3CompilerPublishDecisionMake("edge",
                                                            worldHeadCid,
                                                            false,
                                                            uncheckedProof,
                                                            edgeDecision)
    assert(IsOk(edgeDecisionRes), "v3 compiler publish: edge result")
    assert(edgeDecision.stableGateRequired == 0, "v3 compiler publish: edge gate off")
    assert(edgeDecision.publishAllowed != 0, "v3 compiler publish: edge allowed")
    echo("v3 compiler_publish_smoke ok")
    return 0
