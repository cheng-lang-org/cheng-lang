import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/libp2p/identity/did
import cheng/v3/project/astrology_peer_did_core as peer

fn main(): int32 =
    var peerId = "12D3KooWAstrologyPeer1111111111111111111111111111"
    let userRes = peer.v3AstrologyPeerDidUserMake("  " + peerId + "  ", "", int64(1713072000))
    assert(IsOk(userRes), "v3 astrology peer did: create user")
    let user = Value(userRes)
    assert(user.peerIdText == peerId, "v3 astrology peer did: trim peer id")
    assert(user.didText == did.v3DidFromRootSeed(peer.v3AstrologyPeerDidRootSeed(peerId)),
        "v3 astrology peer did: deterministic did")
    assert(peer.v3AstrologyPeerDidUserMatches(user, peerId),
        "v3 astrology peer did: peer match")
    assert(!layout.fixedBytes32Equal(user.bindingDigest, layout.fixedBytes32Zero()),
        "v3 astrology peer did: digest written")
    assert(user.displayName == "DID 用户 12D3KooW",
        "v3 astrology peer did: default display name")

    let sameRes = peer.v3AstrologyPeerDidUserMake(peerId, "自定义", int64(1713072000))
    assert(IsOk(sameRes), "v3 astrology peer did: create same peer")
    let sameUser = Value(sameRes)
    assert(sameUser.didText == user.didText,
        "v3 astrology peer did: same peer same did")

    let otherRes = peer.v3AstrologyPeerDidUserMake("12D3KooWAnotherPeer222222222222222222222222222", "", int64(1713072000))
    assert(IsOk(otherRes), "v3 astrology peer did: create other peer")
    let otherUser = Value(otherRes)
    assert(otherUser.didText != user.didText,
        "v3 astrology peer did: different peer different did")
    return 0
