import std/os
import std/strings
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/host_ops as hostops

fn main(): int32 =
    let root = os.GetCurrentDir()
    let driver = os.JoinPath(root, "artifacts/v3_backend_driver/cheng")
    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_runtime_zero_c_surface_smoke")
    let auditLog = os.JoinPath(outDir, "host_bridge_audit.log")
    assert(v3path.V3MkdirP(root, outDir), "v3 runtime zero c surface: mkdir")
    if v3path.V3PathFileExists(auditLog):
        os.RemoveFile(auditLog)
    let run = hostops.v3RunFileLogged(root,
                                      "runtime_zero_c_surface_audit",
                                      driver,
                                      ["host-bridge-audit"],
                                      [],
                                      root,
                                      0,
                                      auditLog)
    assert(run.exitCode == 0, "v3 runtime zero c surface: host bridge audit rc")
    let auditText = run.output
    assert(strings.StrContains(auditText, "pure_cheng_zero_c_ready=1"),
           "v3 runtime zero c surface: pure ready")
    assert(strings.StrContains(auditText, "remaining_non_pure_cheng_boundary=none"),
           "v3 runtime zero c surface: no remaining boundary")
    assert(strings.StrContains(auditText, "legacy_runtime_program_obj_command_present=0"),
           "v3 runtime zero c surface: no runtime obj command")
    assert(strings.StrContains(auditText, "legacy_runtime_program_obj_import_present=0"),
           "v3 runtime zero c surface: no runtime obj import")
    assert(strings.StrContains(auditText, "legacy_runtime_program_combined_smoke_present=0"),
           "v3 runtime zero c surface: no combined smoke")
    assert(strings.StrContains(auditText, "legacy_runtime_native_source_path_present=0"),
           "v3 runtime zero c surface: no native source path")
    assert(strings.StrContains(auditText, "legacy_runtime_combined_fallback_present=0"),
           "v3 runtime zero c surface: no combined fallback")
    echo("v3 runtime_zero_c_surface_smoke ok")
    return 0
