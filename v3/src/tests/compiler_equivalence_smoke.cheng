import cheng/v3/tooling/compiler_equivalence as ceq
import cheng/v3/std/bytes_layout as layout

fn main(): int32 =
    let csgText = "version=1\npackage_id=cheng/v3\ngraph_cid=1111111111111111111111111111111111111111111111111111111111111111"
    var cid = layout.FixedBytes32()
    let cidRes = ceq.v3CompilerEquivalenceGraphCidFromText(csgText, cid)
    assert(IsOk(cidRes), "v3 compiler equivalence: baseline graph cid")
    assert(!layout.fixedBytes32Equal(cid, layout.FixedBytes32()),
           "v3 compiler equivalence: parsed cid")
    assert(ceq.v3CompilerEquivalenceKind(true, true, true) == "canonical_semantic_identity",
           "v3 compiler equivalence: canonical kind")
    assert(ceq.v3CompilerEquivalenceKind(true, true, false) == "incompatible",
           "v3 compiler equivalence: incompatible kind")
    echo("v3 compiler_equivalence_smoke ok")
    return 0
