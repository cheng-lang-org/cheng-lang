import std/system
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/binary_types as types
import cheng/v3/chain/lsmr
import cheng/v3/chain/lsmr_types as lt

fn main(): int32 =
    var digits: int32[]
    digits = []
    add(digits, 1)
    add(digits, 2)
    add(digits, 3)
    let addressRes = types.v3LsmrAddressFromDigits(digits)
    assert(IsOk(addressRes), "v3 lsmr payload smoke: address")
    let address = Value(addressRes)
    let keyText = intToStr(7)
    let baguaId = lsmr.v3LsmrAddressBagua(address, keyText)
    assert(lt.v3BaguaValid(baguaId), "v3 lsmr payload smoke: bagua")
    var prefixDigits: int32[]
    prefixDigits = []
    for i in 0..<3:
        add(prefixDigits, address.digits[i])
    let prefixRes = lt.v3PrefixRefFromDigits(baguaId, prefixDigits)
    assert(IsOk(prefixRes), "v3 lsmr payload smoke: prefix")
    let prefix = Value(prefixRes)
    let zeroCid = layout.FixedBytes32()
    let layerId = lsmr.v3LsmrStateLayerForResolution(3)
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("v3.locality_cid"))
    lt.v3AppendU32BE(buf, 7)
    lt.v3AppendU32BE(buf, baguaId)
    lt.v3AppendU32BE(buf, 3)
    lt.v3AppendU32BE(buf, layerId)
    lt.v3AppendAddress(buf, address)
    lt.v3AppendPrefix(buf, prefix)
    lt.v3AppendFixed32(buf, zeroCid)
    lt.v3AppendFixed32(buf, zeroCid)
    let cid = lt.v3FixedCidFromBuf(buf)
    assert(cid.data[0] >= 0, "v3 lsmr payload smoke: cid")
    echo("v3 lsmr_payload_cid_smoke ok")
    return 0
