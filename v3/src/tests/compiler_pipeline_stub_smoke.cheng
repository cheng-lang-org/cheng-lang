import std/os
import std/system
import std/result
import std/strutils as strutil
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/lang/parser as parser

fn main(): int32 =
    let workspaceRoot = os.getCurrentDir()
    let packageRoot = os.joinPath(workspaceRoot, "v3")
    let sourcePath = os.joinPath(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = os.joinPath(workspaceRoot, "artifacts/v3_program_selfhost/program_selfhost_smoke")
    let packageId = parser.v3ParserPackageId(packageRoot)
    let contractsPath = parser.v3ParserModulePathToSourcePath(workspaceRoot, packageRoot, "cheng/v3/tooling/bootstrap_contracts")
    if contractsPath != os.joinPath(packageRoot, "src/tooling/bootstrap_contracts.cheng"):
        echo("packageId=" + packageId)
        echo("contractsPath=" + contractsPath)
        echo("expectedContractsPath=" + os.joinPath(packageRoot, "src/tooling/bootstrap_contracts.cheng"))
        return 1
    if !parser.v3ParserSourceExists(contractsPath):
        echo("contractsPathMissing=" + contractsPath)
        return 1
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    let planRes: Result[slplan.V3SystemLinkPlanStub] = slplan.v3BuildSystemLinkPlanStub(packageRoot, req)
    if IsErr(planRes):
        echo("v3 compiler pipeline stub err: " + Error(planRes))
        return 1
    let plan = Value(planRes)
    assert(plan.moduleStem == "program_selfhost_smoke", "v3 compiler pipeline stub: module stem")
    assert(plan.workspaceRoot == workspaceRoot, "v3 compiler pipeline stub: workspace root")
    assert(plan.packageRoot == packageRoot, "v3 compiler pipeline stub: package root")
    assert(plan.linkMode == "system_link", "v3 compiler pipeline stub: link mode")
    assert(plan.buildEntryPath == os.joinPath(workspaceRoot, "v3/src/tooling/compiler_main.cheng"),
           "v3 compiler pipeline stub: build entry")
    assert(plan.buildSourceUnitCount >= 11, "v3 compiler pipeline stub: source count")
    assert(plan.sourceClosurePaths.len >= 2, "v3 compiler pipeline stub: closure count")
    assert(plan.runtimeTargets.len == 1, "v3 compiler pipeline stub: runtime target count")
    assert(plan.runtimeTargets[0] == "runtime/compiler.program_argv_entry",
           "v3 compiler pipeline stub: program argv runtime target")
    assert(plan.providerModules.len == 3, "v3 compiler pipeline stub: provider module count")
    assert(plan.providerModules[0] == "runtime/compiler_runtime_v3",
           "v3 compiler pipeline stub: compiler provider")
    assert(plan.providerModules[1] == "runtime/core_runtime_v3",
           "v3 compiler pipeline stub: core provider")
    assert(plan.providerModules[2] == "runtime/program_support_v3",
           "v3 compiler pipeline stub: program support provider")
    assert(plan.entrySymbol == "main", "v3 compiler pipeline stub: entry symbol")
    let report = slplan.v3SystemLinkPlanStubReport(plan)
    if plan.missingReasons.len != 0:
        echo(report)
        return 1
    assert(strutil.contains(report, "pipeline_stage=parser_stub_to_system_link_plan_stub"),
           "v3 compiler pipeline stub: report stage")
    assert(strutil.contains(report, "parser_syntax=v3_source_stub_v1"),
           "v3 compiler pipeline stub: report parser syntax")
    assert(strutil.contains(report, "runtime_targets=runtime/compiler.program_argv_entry"),
           "v3 compiler pipeline stub: report runtime target")
    assert(strutil.contains(report,
                            "provider_modules=runtime/compiler_runtime_v3,runtime/core_runtime_v3,runtime/program_support_v3"),
           "v3 compiler pipeline stub: report providers")
    assert(strutil.contains(report, "missing_reasons=-"),
           "v3 compiler pipeline stub: report missing reasons cleared")
    echo("v3 compiler_pipeline_stub_smoke ok")
    return 0
