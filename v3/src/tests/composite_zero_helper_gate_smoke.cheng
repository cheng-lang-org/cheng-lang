import std/os
import std/strutils as strutil

fn main(): int32 =
    let command =
        "(rg -n 'fn\\s+[A-Za-z_][A-Za-z0-9_]*Zero\\s*\\(\\)\\s*:' src v3/src v3/DiLoCo v3/codex --glob '*.cheng' || true)" +
        " | grep -v '^v3/src/tests/composite_zero_helper_gate_smoke.cheng:'" +
        " | grep -v '^src/std/crypto/bigint.cheng:73:fn bigZero(): BigInt =$'" +
        " | grep -v '^v3/src/tests/call_hir_args_fixture.cheng:6:fn callZero(): str =$'" +
        " | grep -v '^v3/src/tests/wasm_importc_noarg_i32_smoke.cheng:2:fn chengTestZero(): int32$'" +
        " || true"
    let output = strutil.Strip(os.ExecCmdResultOutput(os.ExecCmdEx(command, uint64(1), "")))
    assert(output == "",
           "composite no-arg Zero helper forbidden; use implicit init, T(), or new(T)\n" + output)
    echo("v3 composite_zero_helper_gate_smoke ok")
    return 0
