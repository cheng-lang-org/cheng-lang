import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus

fn main(): int32 =
    var index = consensus.v3ChainIndexZero()
    let zeroCid = layout.fixedBytes32Zero()
    assert(index.accountIds.len == 0, "v3 consensus init: empty index")
    assert(layout.fixedBytes32Equal(zeroCid, layout.fixedBytes32Zero()), "v3 consensus init: zero cid")
    echo("v3 consensus_init_smoke ok")
    return 0
