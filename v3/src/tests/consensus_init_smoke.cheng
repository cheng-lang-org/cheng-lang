import std/system
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/consensus

fn main(): int32 =
    var index = consensus.V3ChainIndex()
    let zeroCid = layout.FixedBytes32()
    assert(index.accountIds.len == 0, "v3 consensus init: empty index")
    assert(layout.fixedBytes32Equal(zeroCid, layout.FixedBytes32()), "v3 consensus init: zero cid")
    echo("v3 consensus_init_smoke ok")
    return 0
