import cheng/v3/libp2p/browser/browser_host_probe_codegen as codegen
import cheng/v3/libp2p/browser/browser_host_probe_rule_schema as browserprobe

fn main(): int32 =
    let sourcePath = browserprobe.v3BrowserHostProbeModulePath()
    let dmWaitRule = browserprobe.v3BrowserHostProbeRuleDmWaitStartName()
    let dmSendRule = browserprobe.v3BrowserHostProbeRuleDmSendStartName()
    let dmWaitPlan = codegen.v3BrowserHostProbeBridgePlanForRuleName(dmWaitRule)
    assert(codegen.v3BrowserHostProbeInputSchemaKindFromBridgePlan(dmWaitPlan) == codegen.v3BrowserHostProbeInputScalarI32_2,
           "v3 browser_host_probe_codegen: dm wait input kind")
    assert(codegen.v3BrowserHostProbeOutputSchemaKindFromBridgePlan(dmWaitPlan) == codegen.v3BrowserHostProbeOutputScalarI32,
           "v3 browser_host_probe_codegen: dm wait output kind")
    assert(codegen.v3BrowserHostProbeBridgeKeyForRuleName(dmWaitRule) ==
           "stage=scalar_call|input_schema=scalar_i32_2|output_schema=scalar_i32|error_schema=inline_none|result=scalar_i32|out_buffer=none",
           "v3 browser_host_probe_codegen: dm wait bridge key")
    assert(codegen.v3BrowserHostProbeBridgeHelperNameForRuleName(dmSendRule) ==
           "v3_browser_bridge_scalar_call_dm_send_start",
           "v3 browser_host_probe_codegen: dm send helper name")
    assert(codegen.v3BrowserHostProbeBridgeEmitLineForSourceRuleName(sourcePath, dmSendRule) ==
           "source=cheng/v3/libp2p/browser/browser_host_wasm_probe|rule=dm_send_start|stage=scalar_call|helper=v3_browser_bridge_scalar_call_dm_send_start|input_schema=scalar_i32_4|output_schema=scalar_i32|error_schema=inline_none|result=scalar_i32|out_buffer=none",
           "v3 browser_host_probe_codegen: dm send emit line")
    echo("v3 browser_host_probe_codegen_smoke ok")
    return 0
