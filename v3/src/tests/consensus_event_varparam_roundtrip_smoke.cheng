import cheng/v3/chain/consensus
import cheng/v3/std/bytes_layout as layout

fn assertMintEvent(event: var consensus.V3ChainEvent) =
    if event.version != 1:
        panic("consensus event roundtrip: bad version")
    if event.kind != 1:
        panic("consensus event roundtrip: bad kind")
    if event.assetId != 7:
        panic("consensus event roundtrip: bad asset")
    if event.toAccount != 1001:
        panic("consensus event roundtrip: bad target")
    if event.amount != int64(100):
        panic("consensus event roundtrip: bad amount")
    if event.epoch != 1:
        panic("consensus event roundtrip: bad epoch")
    if event.ganzhiIndex != 13:
        panic("consensus event roundtrip: bad ganzhi")
    if event.spaceSlot != 1:
        panic("consensus event roundtrip: bad slot")
    if event.tick != int64(10):
        panic("consensus event roundtrip: bad tick")
    if event.stem != 3:
        panic("consensus event roundtrip: bad stem")
    if event.branch != 1:
        panic("consensus event roundtrip: bad branch")

fn main(): int32 =
    let zeroCid = layout.FixedBytes32()
    var event = consensus.v3ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    assertMintEvent(event)
    echo("v3 consensus_event_varparam_roundtrip_smoke ok")
    return 0
