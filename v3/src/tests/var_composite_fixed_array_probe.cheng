import std/system

type
    Int32BoxVar =
        limbs: int32[8]

fn fillBox(box: var Int32BoxVar) =
    box.limbs[0] = 11
    box.limbs[1] = 22
    box.limbs[2] = 33
    box.limbs[7] = 88

fn main(argc: int32, argv: ptr): int32 =
    argc
    argv
    var box: Int32BoxVar
    fillBox(box)
    assert(box.limbs[0] == 11, "var_composite_fixed_array_probe: limb0")
    assert(box.limbs[1] == 22, "var_composite_fixed_array_probe: limb1")
    assert(box.limbs[2] == 33, "var_composite_fixed_array_probe: limb2")
    assert(box.limbs[7] == 88, "var_composite_fixed_array_probe: limb7")
    echo("v3 var_composite_fixed_array_probe ok")
    return 0
