import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/backend/lowering_plan as lower
import cheng/v3/libp2p/browser/browser_host_probe_rule_schema as browserprobe

fn main(): int32 =
    let workspaceRoot = "/Users/lbcheng/cheng-lang"
    let packageRoot = "/Users/lbcheng/cheng-lang/v3"
    let probePath = "/Users/lbcheng/cheng-lang/v3/src/libp2p/browser/browser_host_wasm_probe.cheng"
    var linkPlan: slplan.V3SystemLinkPlanStub
    linkPlan.workspaceRoot = workspaceRoot
    linkPlan.packageRoot = packageRoot
    linkPlan.entryPath = probePath
    linkPlan.sourceClosurePaths = [probePath]
    let compilerRules = ccsg.v3CompilerBrowserAbiRulesForLinkPlan(linkPlan)
    let loweringRules = lower.v3LoweringPlanBrowserAbiRules(linkPlan)
    let compilerSourceRules = ccsg.v3BrowserAbiRulesForSource(compilerRules, probePath)
    let loweringSourceRules = lower.v3LoweringPlanBrowserAbiRulesForSource(linkPlan, probePath)
    let schemaRules = browserprobe.v3BrowserHostProbeRules(probePath)
    let compilerSourceBridgeSpecs = ccsg.v3CompilerBrowserAbiBridgeSpecsForSource(linkPlan, probePath)
    let loweringSourceBridgeSpecs = lower.v3LoweringPlanBrowserAbiBridgeSpecsForSource(linkPlan, probePath)
    let schemaBridgeSpecs = ccsg.v3BrowserAbiBridgeSpecsFromRules(schemaRules)
    let compilerSourceBridgePlans = ccsg.v3CompilerBrowserAbiBridgePlansForSource(linkPlan, probePath)
    let loweringSourceBridgePlans = lower.v3LoweringPlanBrowserAbiBridgePlansForSource(linkPlan, probePath)
    let schemaBridgePlans = ccsg.v3BrowserAbiBridgePlansFromRules(schemaRules)
    assert(compilerRules.len == 8, "v3 browser_host_probe_abi_rule: compiler rule count")
    assert(ccsg.v3BrowserAbiRulesEqual(compilerRules, loweringRules),
           "v3 browser_host_probe_abi_rule: compiler lowering equality")
    assert(ccsg.v3BrowserAbiRulesEqual(compilerSourceRules, loweringSourceRules),
           "v3 browser_host_probe_abi_rule: source slice equality")
    assert(ccsg.v3BrowserAbiRulesEqual(compilerSourceRules, schemaRules),
           "v3 browser_host_probe_abi_rule: source slice schema equality")
    assert(ccsg.v3BrowserAbiBridgeSpecsEqual(compilerSourceBridgeSpecs, loweringSourceBridgeSpecs),
           "v3 browser_host_probe_abi_rule: bridge spec equality")
    assert(ccsg.v3BrowserAbiBridgeSpecsEqual(compilerSourceBridgeSpecs, schemaBridgeSpecs),
           "v3 browser_host_probe_abi_rule: bridge spec schema equality")
    assert(ccsg.v3BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, "scalar_call") == 8,
           "v3 browser_host_probe_abi_rule: scalar call count")
    assert(ccsg.v3BrowserAbiBridgePlansEqual(compilerSourceBridgePlans, loweringSourceBridgePlans),
           "v3 browser_host_probe_abi_rule: bridge plan equality")
    assert(ccsg.v3BrowserAbiBridgePlansEqual(compilerSourceBridgePlans, schemaBridgePlans),
           "v3 browser_host_probe_abi_rule: bridge plan schema equality")
    assert(ccsg.v3BrowserAbiBridgePlanCountInputSchemaKind(compilerSourceBridgePlans, "scalar_i32_4") == 1,
           "v3 browser_host_probe_abi_rule: scalar i32_4 count")
    echo("v3 browser_host_probe_abi_rule_smoke ok")
    return 0
