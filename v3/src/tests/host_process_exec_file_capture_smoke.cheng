import std/os
import std/os_host_process as hostos
import std/strutils as strutil

fn main(): int32 =
    let capArgs: str[] = ["capture-ok"]
    var capEnv: str[]
    let capRes: os.ExecCmdResult = hostos.execFileCapture("/bin/echo", capArgs, capEnv, "", true, 5)
    let capRc: int32 = os.execCmdResultExitCode(capRes)
    if capRc == -11:
        assert(false, "v3 hostos execFileCapture rc -11")
    if capRc == -12:
        assert(false, "v3 hostos execFileCapture rc -12")
    if capRc == -13:
        assert(false, "v3 hostos execFileCapture rc -13")
    if capRc == 124:
        assert(false, "v3 hostos execFileCapture rc 124")
    if capRc == 1:
        assert(false, "v3 hostos execFileCapture rc 1")
    if capRc == 2:
        assert(false, "v3 hostos execFileCapture rc 2")
    if capRc == 126:
        assert(false, "v3 hostos execFileCapture rc 126")
    if capRc == 127:
        assert(false, "v3 hostos execFileCapture rc 127")
    if capRc == 128:
        assert(false, "v3 hostos execFileCapture rc 128")
    if capRc == 130:
        assert(false, "v3 hostos execFileCapture rc 130")
    if capRc == 141:
        assert(false, "v3 hostos execFileCapture rc 141")
    if capRc == 143:
        assert(false, "v3 hostos execFileCapture rc 143")
    if capRc == 255:
        assert(false, "v3 hostos execFileCapture rc 255")
    assert(os.execCmdResultExitCode(capRes) == 0, "v3 hostos execFileCapture rc")
    assert(strutil.strip(os.execCmdResultOutput(capRes)) == "capture-ok",
           "v3 hostos execFileCapture out")
    let splitArgs: str[] = ["BEGIN { print \"only-out\"; print \"only-err\" > \"/dev/stderr\" }"]
    let stdoutOnly: os.ExecCmdResult = hostos.execFileCapture("/usr/bin/awk", splitArgs, capEnv, "", false, 5)
    assert(os.execCmdResultExitCode(stdoutOnly) == 0, "v3 hostos execFileCapture stdout rc")
    assert(strutil.strip(os.execCmdResultOutput(stdoutOnly)) == "only-out",
           "v3 hostos execFileCapture stdout only")
    let statusRc: int32 = hostos.execFileStatus("/bin/echo", capArgs, capEnv, "", 5)
    assert(statusRc == 0, "v3 hostos execFileStatus rc")
    let timeoutArgs: str[] = ["-c", "sleep 2"]
    let timeoutRes: os.ExecCmdResult = hostos.execFileCapture("/bin/sh", timeoutArgs, capEnv, "", true, 1)
    assert(os.execCmdResultExitCode(timeoutRes) == 124, "v3 hostos execFileCapture timeout")
    echo("v3 host_process_exec_file_capture_smoke ok")
    return 0
