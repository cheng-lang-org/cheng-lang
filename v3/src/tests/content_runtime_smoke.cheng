import std/system
import std/rawbytes
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/chain/dag_mempool as dag
import cheng/v3/chain/erasure_swarm as swarm
import cheng/v3/chain/content_plane as content
import cheng/v3/chain/content_fetch as fetch
import cheng/v3/chain/content_runtime as runtime
import cheng/v3/chain/content_runtime_host as runtime_host
import cheng/v3/overlay/contracts as overlay
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/host/host

fn contentRuntimeSmokeBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn contentRuntimeSmokeBlob(shards: Bytes[]): Bytes =
    var total = 0
    for i in 0..<shards.len:
        total = total + bytesLen(shards[i])
    var buf: layout.ByteBuf = layout.byteBufInit(total)
    for i in 0..<shards.len:
        layout.byteBufAppendBytes(buf, shards[i])
    return layout.byteBufToBytes(buf)

fn main(): int32 =
    let shard0 = bytesFromString("delta-")
    let shard1 = bytesFromString("omega-")
    let shard2 = bytesFromString("sigma!")
    var shardPayloads: Bytes[]
    shardPayloads = []
    add(shardPayloads, shard0)
    add(shardPayloads, shard1)
    add(shardPayloads, shard2)
    let blob = contentRuntimeSmokeBlob(shardPayloads)

    let summaryRes = dag.v3DagBlobSummaryFromBytes(blob, 6)
    assert(IsOk(summaryRes), "v3 content runtime smoke: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.v3ErasureEncodingParamsMake(swarm.v3ErasureLayoutRsSystematic, 3, 0, 6)
    assert(IsOk(paramsRes), "v3 content runtime smoke: params")
    let params = Value(paramsRes)

    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    add(shardPayloadCids, swarm.v3ErasureShardPayloadCid(shard0))
    add(shardPayloadCids, swarm.v3ErasureShardPayloadCid(shard1))
    add(shardPayloadCids, swarm.v3ErasureShardPayloadCid(shard2))
    let manifestRes = swarm.v3ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), "v3 content runtime smoke: manifest")
    let manifest = Value(manifestRes)

    var server = host.v3Libp2pHostInit("content.runtime.server")
    let peerAdvertRes = swarm.v3ErasurePeerAdvertMake(server.selfPeerId.value,
                                                      manifest,
                                                      params,
                                                      [0, 1, 2],
                                                      900,
                                                      3)
    assert(IsOk(peerAdvertRes), "v3 content runtime smoke: peer advert")
    var adverts: swarm.V3ErasurePeerAdvert[]
    adverts = []
    add(adverts, Value(peerAdvertRes))
    let planRes = swarm.v3ErasureBuildRecoveryPlan(manifest, params, adverts)
    assert(IsOk(planRes), "v3 content runtime smoke: recovery plan")
    let plan = Value(planRes)
    let planOk = swarm.v3ErasureRecoveryPlanValidate(plan, manifest, params)
    assert(IsOk(planOk), "v3 content runtime smoke: plan validate")
    let targetsRes = runtime.v3ContentRuntimeBuildPullTargets(manifest, plan)
    assert(IsOk(targetsRes), "v3 content runtime smoke: pull targets")
    let targets = Value(targetsRes)
    assert(targets.len == 3, "v3 content runtime smoke: target count")
    assert(layout.fixedBytes32Equal(targets[0].peerId, server.selfPeerId.value),
        "v3 content runtime smoke: target peer")
    let requestsRes = runtime.v3ContentRuntimeBuildPullRequests(manifest, plan)
    assert(IsOk(requestsRes), "v3 content runtime smoke: pull requests")
    let requests = Value(requestsRes)
    assert(requests.len == 3, "v3 content runtime smoke: request count")
    assert(requests[0].shardIndex == 0, "v3 content runtime smoke: shard0 request")
    assert(requests[1].shardIndex == 1, "v3 content runtime smoke: shard1 request")
    assert(requests[2].shardIndex == 2, "v3 content runtime smoke: shard2 request")

    var serverRuntime = runtime.v3ContentRuntimeInit()
    let storeManifestRes = runtime.v3ContentRuntimeStoreManifest(serverRuntime, manifest)
    assert(IsOk(storeManifestRes), "v3 content runtime smoke: store manifest")
    let stubRes = content.v3ContentStubMake(lt.v3HashInts("v3.content.runtime.topic", [1]),
                                            lt.v3HashInts("v3.content.runtime.bundle", [2]),
                                            summary.summaryCid,
                                            lt.v3HashInts("v3.content.runtime.advert", [3]),
                                            manifest.manifestCid,
                                            lt.v3HashInts("v3.content.runtime.plan", [4]),
                                            summary.payloadLen)
    assert(IsOk(stubRes), "v3 content runtime smoke: stub")
    let stub = Value(stubRes)
    let storePreviewRes = runtime.v3ContentRuntimeStorePreview(serverRuntime, stub)
    assert(IsOk(storePreviewRes), "v3 content runtime smoke: store preview")
    let storeBlobRes = runtime.v3ContentRuntimeStoreBlobPayload(serverRuntime, summary.blobCid, blob)
    assert(IsOk(storeBlobRes), "v3 content runtime smoke: store blob")
    for i in 0..<requests.len:
        var response = swarm.v3ErasureShardPullResponseZero()
        let responseFillRes = swarm.v3ErasureShardPullResponseFill(response,
                                                                   requests[i],
                                                                   shardPayloads[requests[i].shardIndex])
        assert(IsOk(responseFillRes), "v3 content runtime smoke: seed response")
        let storeRes = runtime.v3ContentRuntimeStoreShardResponse(serverRuntime, response)
        assert(IsOk(storeRes), "v3 content runtime smoke: store server cache")
    assert(serverRuntime.shardCache.len == 3, "v3 content runtime smoke: server cache count")

    var client = host.v3Libp2pHostInit("content.runtime.client")
    var clientRuntime = runtime.v3ContentRuntimeInit()
    var listenAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(listenAddr, "127.0.0.1", 6308)
    let listenRes = host.v3Libp2pListen(server, listenAddr)
    assert(listenRes.ok, "v3 content runtime smoke: listen")
    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolContent)
    host.v3Libp2pRegisterHandler(client, types.v3Libp2pProtocolContent)
    let dialRes = host.v3Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 content runtime smoke: dial")

    let manifestFetchReqRes = fetch.v3ContentFetchRequestManifest(manifest.manifestCid)
    assert(IsOk(manifestFetchReqRes), "v3 content runtime smoke: manifest fetch request")
    let manifestFetchRequest = Value(manifestFetchReqRes)
    let manifestFetchRes = runtime_host.v3ContentRuntimeRequestFetch(client,
                                                                     server,
                                                                     server.selfPeerId,
                                                                     serverRuntime,
                                                                     manifestFetchRequest)
    assert(IsOk(manifestFetchRes), "v3 content runtime smoke: manifest fetch")
    let manifestFetchResponse = Value(manifestFetchRes)
    let manifestFetchResponseOk = fetch.v3ContentFetchResponseValidate(manifestFetchResponse,
                                                                       manifestFetchRequest)
    assert(IsOk(manifestFetchResponseOk), "v3 content runtime smoke: manifest response validate")
    let manifestPayloadOk = swarm.v3ErasureShardManifestValidatePayload(manifestFetchResponse.payload,
                                                                        manifest.manifestCid)
    assert(IsOk(manifestPayloadOk), "v3 content runtime smoke: manifest payload validate")
    let manifestPayloadDecodeRes = swarm.v3ErasureShardManifestDecode(manifestFetchResponse.payload)
    assert(IsOk(manifestPayloadDecodeRes), "v3 content runtime smoke: manifest payload decode")
    var manifestPull = swarm.v3ErasureShardManifestZero()
    let manifestPullRes = fetch.v3ContentFetchResponseToManifestFill(manifestPull,
                                                                     manifestFetchRequest,
                                                                     manifestFetchResponse)
    assert(IsOk(manifestPullRes), "v3 content runtime smoke: manifest pull")
    assert(layout.fixedBytes32Equal(manifestPull.manifestCid, manifest.manifestCid),
        "v3 content runtime smoke: manifest pull cid")

    let previewReqRes = fetch.v3ContentFetchRequestPreview(summary.summaryCid)
    assert(IsOk(previewReqRes), "v3 content runtime smoke: preview request")
    let previewRequest = Value(previewReqRes)
    let previewFetchRes = runtime_host.v3ContentRuntimeRequestFetch(client,
                                                                    server,
                                                                    server.selfPeerId,
                                                                    serverRuntime,
                                                                    previewRequest)
    assert(IsOk(previewFetchRes), "v3 content runtime smoke: preview fetch")
    var previewStub = content.v3ContentStubZero()
    let previewFillRes = fetch.v3ContentFetchResponseToPreviewFill(previewStub,
                                                                   previewRequest,
                                                                   Value(previewFetchRes))
    assert(IsOk(previewFillRes), "v3 content runtime smoke: preview decode")
    assert(layout.fixedBytes32Equal(previewStub.stubCid, stub.stubCid),
        "v3 content runtime smoke: preview stub cid")

    let rangeReqRes = fetch.v3ContentFetchRequestRange(summary.blobCid, 2, 5)
    assert(IsOk(rangeReqRes), "v3 content runtime smoke: range request")
    let rangeRequest = Value(rangeReqRes)
    let rangeFetchRes = runtime_host.v3ContentRuntimeRequestFetch(client,
                                                                  server,
                                                                  server.selfPeerId,
                                                                  serverRuntime,
                                                                  rangeRequest)
    assert(IsOk(rangeFetchRes), "v3 content runtime smoke: range fetch")
    let rangeFetch = Value(rangeFetchRes)
    let rangeOk = fetch.v3ContentFetchResponseValidate(rangeFetch, rangeRequest)
    assert(IsOk(rangeOk), "v3 content runtime smoke: range validate")
    assert(contentRuntimeSmokeBytesEqual(rangeFetch.payload, bytesSlice(blob, 2, 5)),
        "v3 content runtime smoke: range bytes")

    let directChunkReqRes = fetch.v3ContentFetchRequestChunk(manifest.manifestCid,
                                                             requests[0].shardIndex,
                                                             requests[0].shardCid)
    assert(IsOk(directChunkReqRes), "v3 content runtime smoke: direct chunk request")
    let directChunkReq = Value(directChunkReqRes)
    let directChunkFetchRes = runtime_host.v3ContentRuntimeRequestFetch(client,
                                                                        server,
                                                                        server.selfPeerId,
                                                                        serverRuntime,
                                                                        directChunkReq)
    assert(IsOk(directChunkFetchRes), "v3 content runtime smoke: direct chunk fetch")
    let directChunkFetch = Value(directChunkFetchRes)
    var directChunk = swarm.v3ErasureShardPullResponseZero()
    let directChunkFillRes = fetch.v3ContentFetchResponseToShardPullFill(directChunk,
                                                                         directChunkReq,
                                                                         directChunkFetch)
    assert(IsOk(directChunkFillRes), "v3 content runtime smoke: direct chunk decode")
    assert(directChunk.shardIndex == 0, "v3 content runtime smoke: direct chunk index")
    assert(layout.fixedBytes32Equal(directChunk.shardCid, requests[0].shardCid),
        "v3 content runtime smoke: direct chunk cid")
    assert(contentRuntimeSmokeBytesEqual(directChunk.payload, shard0),
        "v3 content runtime smoke: direct chunk bytes")

    var pulled: swarm.V3ErasureShardPullResponse[]
    pulled = []
    for i in 0..<requests.len:
        let pullRes = runtime_host.v3ContentRuntimeRequestShardPull(client,
                                                                    server,
                                                                    server.selfPeerId,
                                                                    serverRuntime,
                                                                    requests[i])
        assert(IsOk(pullRes), "v3 content runtime smoke: pull shard")
        let pulledResponse = Value(pullRes)
        let localStoreRes = runtime.v3ContentRuntimeStoreShardResponse(clientRuntime, pulledResponse)
        assert(IsOk(localStoreRes), "v3 content runtime smoke: store client cache")
        add(pulled, pulledResponse)
    assert(clientRuntime.shardCache.len == 3, "v3 content runtime smoke: client cache count")

    var cachedShard: Bytes
    assert(runtime.v3ContentRuntimeCachedShard(clientRuntime, requests[0], cachedShard),
        "v3 content runtime smoke: cached shard available")
    assert(contentRuntimeSmokeBytesEqual(cachedShard, shard0),
        "v3 content runtime smoke: cached shard bytes")

    let rebuildRes = runtime.v3ContentRuntimeRebuildBlob(manifest, params, pulled)
    assert(IsOk(rebuildRes), "v3 content runtime smoke: rebuild")
    assert(contentRuntimeSmokeBytesEqual(Value(rebuildRes), blob),
        "v3 content runtime smoke: rebuild bytes")
    assert(client.openStreamProtocols.len == 7, "v3 content runtime smoke: stream count")

    let parityBlob = bytesFromString("rs-data-with-parity")
    let parityParamsRes = swarm.v3ErasureEncodingParamsMake(swarm.v3ErasureLayoutRsSystematic, 3, 2, 7)
    assert(IsOk(parityParamsRes), "v3 content runtime smoke: parity params")
    let parityParams = Value(parityParamsRes)
    let parityShardPayloadsRes = swarm.v3ErasureEncodeShardPayloads(parityBlob, parityParams)
    assert(IsOk(parityShardPayloadsRes), "v3 content runtime smoke: parity shard payloads")
    let parityShardPayloads = Value(parityShardPayloadsRes)
    var parityShardPayloadCids: layout.FixedBytes32[]
    parityShardPayloadCids = []
    for i in 0..<parityShardPayloads.len:
        add(parityShardPayloadCids, swarm.v3ErasureShardPayloadCid(parityShardPayloads[i]))
    let paritySummaryRes = dag.v3DagBlobSummaryFromBytes(parityBlob, 7)
    assert(IsOk(paritySummaryRes), "v3 content runtime smoke: parity summary")
    let paritySummary = Value(paritySummaryRes)
    let parityManifestRes = swarm.v3ErasureShardManifestMake(paritySummary.blobCid,
                                                             paritySummary.payloadLen,
                                                             parityParams,
                                                             parityShardPayloadCids)
    assert(IsOk(parityManifestRes), "v3 content runtime smoke: parity manifest")
    let parityManifest = Value(parityManifestRes)
    let parityPeer0 = lt.v3HashInts("v3.content.runtime.parity.peer", [0])
    let parityPeer3 = lt.v3HashInts("v3.content.runtime.parity.peer", [3])
    let parityPeer4 = lt.v3HashInts("v3.content.runtime.parity.peer", [4])
    let parityAdvert0Res = swarm.v3ErasurePeerAdvertMake(parityPeer0, parityManifest, parityParams, [0], 900, 1)
    assert(IsOk(parityAdvert0Res), "v3 content runtime smoke: parity advert0")
    let parityAdvert3Res = swarm.v3ErasurePeerAdvertMake(parityPeer3, parityManifest, parityParams, [3], 900, 1)
    assert(IsOk(parityAdvert3Res), "v3 content runtime smoke: parity advert3")
    let parityAdvert4Res = swarm.v3ErasurePeerAdvertMake(parityPeer4, parityManifest, parityParams, [4], 900, 1)
    assert(IsOk(parityAdvert4Res), "v3 content runtime smoke: parity advert4")
    var parityAdverts: swarm.V3ErasurePeerAdvert[]
    parityAdverts = []
    add(parityAdverts, Value(parityAdvert0Res))
    add(parityAdverts, Value(parityAdvert3Res))
    add(parityAdverts, Value(parityAdvert4Res))
    let parityPlanRes = swarm.v3ErasureBuildRecoveryPlan(parityManifest, parityParams, parityAdverts)
    assert(IsOk(parityPlanRes), "v3 content runtime smoke: parity plan")
    let parityPlan = Value(parityPlanRes)
    let parityPlanOk = swarm.v3ErasureRecoveryPlanValidate(parityPlan, parityManifest, parityParams)
    assert(IsOk(parityPlanOk), "v3 content runtime smoke: parity plan validate")
    assert(parityPlan.requestCount == 3, "v3 content runtime smoke: parity request count")
    assert(parityPlan.requestShardIndices[0] == 0, "v3 content runtime smoke: parity shard0")
    assert(parityPlan.requestShardIndices[1] == 3, "v3 content runtime smoke: parity shard3")
    assert(parityPlan.requestShardIndices[2] == 4, "v3 content runtime smoke: parity shard4")
    let parityRequestsRes = runtime.v3ContentRuntimeBuildPullRequests(parityManifest, parityPlan)
    assert(IsOk(parityRequestsRes), "v3 content runtime smoke: parity requests")
    let parityRequests = Value(parityRequestsRes)
    var parityResponses: swarm.V3ErasureShardPullResponse[]
    parityResponses = []
    for i in 0..<parityRequests.len:
        var parityResponse = swarm.v3ErasureShardPullResponseZero()
        let parityFillRes = swarm.v3ErasureShardPullResponseFill(parityResponse,
                                                                 parityRequests[i],
                                                                 parityShardPayloads[parityRequests[i].shardIndex])
        assert(IsOk(parityFillRes), "v3 content runtime smoke: parity response")
        add(parityResponses, parityResponse)
    let parityRebuildRes = runtime.v3ContentRuntimeRebuildBlob(parityManifest, parityParams, parityResponses)
    assert(IsOk(parityRebuildRes), "v3 content runtime smoke: parity rebuild")
    assert(contentRuntimeSmokeBytesEqual(Value(parityRebuildRes), parityBlob),
        "v3 content runtime smoke: parity rebuild bytes")

    echo("v3 content_runtime_smoke ok")
    return 0
