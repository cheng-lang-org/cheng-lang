import std/system
import cheng/v3/project/bft_state_machine as bft

fn main(): int32 =
    var machine = bft.v3BftStateMachineInit("bft-apply-single")
    let mint = bft.v3BftTxMint(7, 1001, int64(100))
    let exec = bft.v3BftApplyTx(machine, mint, int64(1), 0)
    assert(exec.code == bft.v3BftCodeOk, "v3 bft apply single: code")
    assert(exec.accepted, "v3 bft apply single: accepted")
    assert(exec.applied, "v3 bft apply single: applied")
    assert(machine.index.eventCids.len == 1, "v3 bft apply single: event cid len")
    assert(machine.index.accountIds.len == 1, "v3 bft apply single: account len")
    assert(machine.index.balances.len == 1, "v3 bft apply single: balance len")
    assert(machine.index.balances[0] == int64(100), "v3 bft apply single: balance value")
    echo("v3 bft_apply_single_smoke ok")
    return 0
