type
    V3IfEnumSmoke = enum
        v3IfEnumSmokeNo
        v3IfEnumSmokeYes

fn v3IfEnumCompositeReturn(flag: V3IfEnumSmoke): str =
    if flag == v3IfEnumSmokeYes:
        return "yes"
    return "no"

fn main(): int32 =
    assert(v3IfEnumCompositeReturn(v3IfEnumSmokeYes) == "yes", "v3 if enum composite return: yes")
    assert(v3IfEnumCompositeReturn(v3IfEnumSmokeNo) == "no", "v3 if enum composite return: no")
    echo("v3 if_enum_composite_return_smoke ok")
    return 0
