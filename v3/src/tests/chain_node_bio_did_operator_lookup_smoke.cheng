import std/system
import std/result
import std/rawbytes
import std/crypto/rand
import std/strutils as strutil
import cheng/v3/std/bytes_layout as layout
import cheng/v3/project/chain_node as chain
import cheng/v3/project/chain_node_cli_core as cli
import cheng/v3/project/bio_did_chain_node as flow
import cheng/v3/mobile/hardware/biometric

fn chainNodeBioDidLookupSmokeFeature(seed: int32): layout.FixedBytes32 =
    let raw: Bytes = bytesAlloc(32)
    for i in 0..<32:
        bytesSet(raw, i, ((seed * 29) + (i * 17) + 11) & 255)
    let res = layout.fixedBytes32FromBytes(raw)
    assert(IsOk(res), "chain node bio did lookup smoke: feature build")
    return Value(res)

fn chainNodeBioDidLookupSmokeAttestorPrivHex(): str =
    return "60d71049a0cafe01faa9948dc77ee5bc4bd5e05b8e328fdb9cc4c38237250a05"

fn chainNodeBioDidLookupSmokeAttestorPubKeyHex(): str =
    return "04963c1356849b8478030a6eb572581063ccedf53fda0bc7241247eba977e3b0666e4bf0c12caa47487c2927f83b17d6f9f332481cd2ab0c4885f91fc2a6c547d5"

fn chainNodeBioDidLookupSmokeCapture(feature: layout.FixedBytes32,
                                     bindingSeed: str,
                                     label: str,
                                     requestId: str,
                                     purpose: int32): flow.V3BioDidHardwareCapture =
    var out = flow.v3BioDidHardwareCaptureZero()
    out.verified = true
    out.feature32 = feature
    out.requestId = requestId
    out.sensorId = "sensor|" + bindingSeed
    out.deviceBindingSeed = bindingSeed
    out.deviceLabel = label
    var req = biometric.v3BiometricFingerprintAuthorizeReqZero()
    req.requestId = requestId
    req.purpose = purpose
    req.didText = ""
    req.promptTitle = "chain node bio did lookup smoke"
    req.promptReason = "chain node bio did lookup smoke"
    req.deviceBindingSeedHint = bindingSeed
    req.deviceLabelHint = label
    let attestationRes = biometric.v3BiometricFingerprintAttestationBuildSigned(req,
                                                                                feature,
                                                                                bindingSeed,
                                                                                label,
                                                                                out.sensorId,
                                                                                chainNodeBioDidLookupSmokeAttestorPrivHex())
    assert(IsOk(attestationRes), "chain node bio did lookup smoke: signed attestation")
    out.hardwareAttestation = Value(attestationRes)
    return out

fn main(): int32 =
    assert(rand.setRandomSeed(bytesFromString("v3.chain_node.bio.did.lookup.seed")),
           "chain node bio did lookup smoke: seed")
    let trustRes = flow.v3BioDidSetTrustedAttestorRootHex(chainNodeBioDidLookupSmokeAttestorPubKeyHex(),
                                                          biometric.v3BiometricScriptedRootKeyId)
    assert(IsOk(trustRes), "chain node bio did lookup smoke: trust attestor")
    let operatorIdRes = flow.v3BioDidOperatorIdFromRecoverySecretHex(
        "1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef"
    )
    assert(IsOk(operatorIdRes), "chain node bio did lookup smoke: operator id")
    let operatorId = Value(operatorIdRes)
    var node: chain.V3ChainNode
    assert(IsOk(chain.v3ChainNodeInitInto(node, "bio.did.lookup.node", "bio.did.lookup.addr")),
           "chain node bio did lookup smoke: init node")
    let createRes = flow.v3BioDidCreateWithHardwareCapture(
        node,
        chainNodeBioDidLookupSmokeCapture(chainNodeBioDidLookupSmokeFeature(7),
                                          "device.lookup.phone",
                                          "lookup-phone",
                                          "lookup-create-1",
                                          biometric.v3BiometricPurposeDidCreate),
        int64(1000)
    )
    assert(IsOk(createRes), "chain node bio did lookup smoke: create")
    let create = Value(createRes)
    let anchorRes = flow.v3BioDidChainAppendOperatorBundleAnchor(node,
                                                                 operatorId,
                                                                 create.bundle,
                                                                 "lookup-anchor-1")
    assert(IsOk(anchorRes), "chain node bio did lookup smoke: anchor")
    var servedNode = node
    let snapshot = chain.v3ChainNodeServeOnce(servedNode)
    let statePath = "/tmp/chain_node_bio_did_operator_lookup_smoke.state"
    assert(cli.v3ChainNodeCliWriteState(statePath, snapshot),
           "chain node bio did lookup smoke: write state")
    let lookupJsonRes = cli.v3ChainNodeCliBioDidOperatorLookupJson(statePath,
                                                                   layout.fixedBytes32Hex(operatorId))
    assert(IsOk(lookupJsonRes), "chain node bio did lookup smoke: lookup hit")
    let lookupJson = Value(lookupJsonRes)
    assert(strutil.contains(lookupJson, "\"found\":true"),
           "chain node bio did lookup smoke: lookup hit found")
    assert(strutil.contains(lookupJson, "\"bundleSeq\":1"),
           "chain node bio did lookup smoke: lookup hit seq")
    assert(strutil.contains(lookupJson, "\"bundleKind\":\"android_bio_v1\""),
           "chain node bio did lookup smoke: lookup hit kind")
    let preferredLookupRes = cli.v3ChainNodeCliBioDidOperatorLookupJsonWithKinds(
        statePath,
        layout.fixedBytes32Hex(operatorId),
        [flow.v3BioDidOperatorBundleKindAndroidBioV1]
    )
    assert(IsOk(preferredLookupRes), "chain node bio did lookup smoke: preferred lookup hit")
    assert(strutil.contains(Value(preferredLookupRes), "\"found\":true"),
           "chain node bio did lookup smoke: preferred lookup found")
    let missJsonRes = cli.v3ChainNodeCliBioDidOperatorLookupJson(
        statePath,
        "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff"
    )
    assert(IsOk(missJsonRes), "chain node bio did lookup smoke: lookup miss")
    assert(strutil.contains(Value(missJsonRes), "\"found\":false"),
           "chain node bio did lookup smoke: lookup miss found false")
    echo("v3 chain_node_bio_did_operator_lookup_smoke ok")
    return 0
