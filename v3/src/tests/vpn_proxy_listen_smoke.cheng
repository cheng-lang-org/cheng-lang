import std/result
import cheng/v3/tooling/vpn_proxy_listen as listen

fn main(): int32 =
    let ipv4Res: Result[listen.V3VpnProxyListenAddress] = listen.V3VpnProxyParseListenAddress("127.0.0.1:1080")
    assert(!IsErr(ipv4Res), "v3 vpn proxy listen ipv4 ok")
    assert(Value(ipv4Res).host == "127.0.0.1", "v3 vpn proxy listen ipv4 host")
    assert(Value(ipv4Res).port == 1080, "v3 vpn proxy listen ipv4 port")

    let ipv6Res: Result[listen.V3VpnProxyListenAddress] = listen.V3VpnProxyParseListenAddress("[::1]:7443")
    assert(!IsErr(ipv6Res), "v3 vpn proxy listen ipv6 ok")
    assert(Value(ipv6Res).host == "::1", "v3 vpn proxy listen ipv6 host")
    assert(Value(ipv6Res).port == 7443, "v3 vpn proxy listen ipv6 port")

    let noColonRes: Result[listen.V3VpnProxyListenAddress] = listen.V3VpnProxyParseListenAddress("127.0.0.1")
    assert(IsErr(noColonRes), "v3 vpn proxy listen no colon reject")
    assert(ErrorText(noColonRes) == "vpn proxy: listen address must be host:port",
           "v3 vpn proxy listen no colon text")

    let badIpv6Res: Result[listen.V3VpnProxyListenAddress] = listen.V3VpnProxyParseListenAddress("[::1")
    assert(IsErr(badIpv6Res), "v3 vpn proxy listen bad ipv6 reject")
    assert(ErrorText(badIpv6Res) == "vpn proxy: invalid ipv6 listen address",
           "v3 vpn proxy listen bad ipv6 text")

    let badPortRes: Result[listen.V3VpnProxyListenAddress] = listen.V3VpnProxyParseListenAddress("127.0.0.1:99999")
    assert(IsErr(badPortRes), "v3 vpn proxy listen bad port reject")
    assert(ErrorText(badPortRes) == "vpn proxy: listen address must be host:port",
           "v3 vpn proxy listen bad port text")

    echo("v3 vpn_proxy_listen_smoke ok")
    return 0
