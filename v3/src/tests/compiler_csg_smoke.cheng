import std/os
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/lang/parser

fn reportFieldValue(report: str, key: str): str =
    let prefix = key + "="
    var lineStart: int32 = 0
    while lineStart < report.len:
        var lineEnd = lineStart
        while lineEnd < report.len && report[lineEnd] != '\n':
            lineEnd = lineEnd + 1
        let lineLen = lineEnd - lineStart
        if lineLen >= prefix.len &&
           v3path.V3TextSlice(report, lineStart, prefix.len) == prefix:
            return v3path.V3TextSlice(report, lineStart + prefix.len, lineLen - prefix.len)
        lineStart = lineEnd + 1
    return ""

fn reportFieldPositive(report: str, key: str): bool =
    let value = reportFieldValue(report, key)
    return value != "" && value != "0"

fn assertTypedCallFactsMatchLayer(facts: ccsg.V3TypedExprFact[],
                                  layer: parser.V3NormalizedExprLayer,
                                  label: str) =
    assert(ccsg.v3TypedExprFactCountCallResolved(facts) ==
           parser.v3NormalizedExprLayerCallResolvedCount(layer),
           label + " typed resolved call count")
    assert(ccsg.v3TypedExprFactCountCallUnresolved(facts) ==
           parser.v3NormalizedExprLayerCallUnresolvedCount(layer),
           label + " typed unresolved call count")
    assert(ccsg.v3TypedExprSurfaceCallLocalCount(facts) ==
           parser.v3NormalizedExprLayerCallKindCount(layer, "local_call"),
           label + " typed local call kind count")
    assert(ccsg.v3TypedExprSurfaceCallExternalCount(facts) ==
           parser.v3NormalizedExprLayerCallKindCount(layer, "external_call"),
           label + " typed external call kind count")
    assert(ccsg.v3TypedExprSurfaceCallImportcCount(facts) ==
           parser.v3NormalizedExprLayerCallKindCount(layer, "importc_call"),
           label + " typed importc call kind count")
    assert(ccsg.v3TypedExprSurfaceCallMemberCount(facts) ==
           parser.v3NormalizedExprLayerCallKindCount(layer, "member_call"),
           label + " typed member call kind count")
    assert(ccsg.v3TypedExprFactCountCallTargetImportc(facts) ==
           parser.v3NormalizedExprLayerCallTargetImportcCount(layer),
           label + " typed importc target count")
    assert(ccsg.v3TypedExprCallReasonUnknownQualifiedTargetCount(facts) ==
           parser.v3NormalizedExprLayerCallReasonCount(layer, "unknown_qualified_target"),
           label + " typed unknown qualified target count")
    assert(ccsg.v3TypedExprCallReasonShadowedQualifiedTargetCount(facts) ==
           parser.v3NormalizedExprLayerCallReasonCount(layer, "shadowed_qualified_target"),
           label + " typed shadowed qualified target count")
    assert(ccsg.v3TypedExprCallReasonAmbiguousExternalTargetCount(facts) ==
           parser.v3NormalizedExprLayerCallReasonCount(layer, "ambiguous_external_target"),
           label + " typed ambiguous external target count")
    assert(ccsg.v3TypedExprCallReasonAmbiguousQualifiedTargetCount(facts) ==
           parser.v3NormalizedExprLayerCallReasonCount(layer, "ambiguous_qualified_target"),
           label + " typed ambiguous qualified target count")

fn buildLinkPlan(workspaceRoot: str,
                 packageRoot: str,
                 sourcePath: str,
                 outputPath: str,
                 emitKind: int32): slplan.V3SystemLinkPlanStub =
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), "v3 compiler csg: link plan")
    return linkPlan

fn buildFullCsg(workspaceRoot: str,
                packageRoot: str,
                sourcePath: str,
                outputPath: str,
                emitKind: int32): ccsg.V3CompilerCsg =
    let linkPlan = buildLinkPlan(workspaceRoot, packageRoot, sourcePath, outputPath, emitKind)
    var sourceTexts: ccsg.V3TypedExprSourceText[] = []
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let currentSourcePath = linkPlan.sourceClosurePaths[i]
        let text = v3path.V3ReadTextFile("", currentSourcePath)
        add(sourceTexts, ccsg.v3CompilerCsgTypedSourceText(workspaceRoot,
                                                          packageRoot,
                                                          currentSourcePath,
                                                          text))
    var typedFacts: ccsg.V3TypedExprFact[] = []
    var err = ""
    assert(ccsg.v3CompilerCsgBuildTypedExprFacts(sourceTexts, linkPlan.exprLayer, typedFacts, err),
           "v3 compiler csg: build typed facts")
    var nodes: ccsg.V3CompilerCsgNode[] = []
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let currentSourcePath = linkPlan.sourceClosurePaths[i]
        let text = v3path.V3ReadTextFile("", currentSourcePath)
        let ownerModulePath = parser.v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, currentSourcePath)
        var decls: parser.V3NormalizedFunctionDecl[] = []
        err = ""
        assert(parser.v3ParserReadNormalizedFunctionDecls(text, decls, err),
               "v3 compiler csg: decls")
        var entryHasExplicitExports = false
        if currentSourcePath == linkPlan.entryPath &&
           (linkPlan.emitKind == creq.v3EmitShared || linkPlan.emitKind == creq.v3EmitObj):
            for declIndex in 0..<decls.len:
                if decls[declIndex].importc:
                    continue
                if decls[declIndex].explicitExportName != "":
                    entryHasExplicitExports = true
                    break
        for declIndex in 0..<decls.len:
            let decl = decls[declIndex]
            if decl.importc:
                continue
            let symbolText = ownerModulePath + "::" + decl.name
            var entryFlag = 0
            if currentSourcePath == linkPlan.entryPath && decl.name == linkPlan.entrySymbol:
                entryFlag = 1
            var resultLayoutKind = 0
            if decl.name == "main":
                resultLayoutKind = 5
            var effectKind = ccsg.v3CompilerCsgEffectPure
            if entryFlag != 0:
                effectKind = ccsg.v3CompilerCsgEffectProgramEntry
            var capabilityKind = ccsg.v3CompilerCsgCapabilityInternal
            if entryFlag != 0:
                capabilityKind = ccsg.v3CompilerCsgCapabilityEntrypoint
            var exportedFlag = 0
            if ccsg.v3CompilerCsgShouldExportSymbol(linkPlan.emitKind,
                                                    currentSourcePath == linkPlan.entryPath,
                                                    entryHasExplicitExports,
                                                    decl.explicitExportName,
                                                    decl.name,
                                                    entryFlag):
                exportedFlag = 1
            var node: ccsg.V3CompilerCsgNode
            node.nodeId = nodes.len + 1
            node.nodeKind = ccsg.v3CompilerCsgNodeKindSymbol
            node.ownerNodeId = 0
            node.modulePath = ownerModulePath
            node.symbolText = symbolText
            node.factText = decl.name
            node.resultLayoutKind = resultLayoutKind
            node.effectKind = effectKind
            node.capabilityKind = capabilityKind
            node.callConv = 1
            node.entryFlag = entryFlag
            node.exportedFlag = exportedFlag
            node.exportSymbolName = ""
            if exportedFlag != 0:
                node.exportSymbolName = ccsg.v3CompilerCsgTargetExportName(symbolText,
                                                                           decl.explicitExportName,
                                                                           decl.name)
            node.factCid = layout.fixedBytes32Zero()
            add(nodes, node)
    var edges: ccsg.V3CompilerCsgEdge[] = []
    if nodes.len > 0:
        var edge: ccsg.V3CompilerCsgEdge
        edge.edgeId = 1
        edge.fromNodeId = nodes[0].nodeId
        edge.toNodeId = nodes[0].nodeId
        edge.edgeKind = ccsg.v3CompilerCsgEdgeKindContains
        edge.edgeCid = layout.fixedBytes32Zero()
        add(edges, edge)
    var csg: ccsg.V3CompilerCsg
    csg.version = 1
    csg.packageId = linkPlan.packageId
    csg.sourceBundleCid = layout.fixedBytes32Zero()
    csg.exprLayer = parser.v3NormalizedExprLayerClone(linkPlan.exprLayer)
    csg.typedExprFacts = ccsg.v3CompilerCsgCloneTypedExprFacts(typedFacts)
    csg.nodeCount = nodes.len
    csg.edgeCount = edges.len
    csg.nodes = nodes
    csg.edges = edges
    csg.canonicalGraphCid = layout.fixedBytes32Zero()
    csg.graphCid = layout.fixedBytes32Zero()
    return csg

fn buildMinimalCsg(workspaceRoot: str,
                   packageRoot: str,
                   sourcePath: str,
                   outputPath: str,
                   emitKind: int32): ccsg.V3CompilerCsg =
    let linkPlan = buildLinkPlan(workspaceRoot, packageRoot, sourcePath, outputPath, emitKind)
    var sourceTexts: ccsg.V3TypedExprSourceText[] = []
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let currentSourcePath = linkPlan.sourceClosurePaths[i]
        let text = v3path.V3ReadTextFile("", currentSourcePath)
        add(sourceTexts, ccsg.v3CompilerCsgTypedSourceText(workspaceRoot,
                                                          packageRoot,
                                                          currentSourcePath,
                                                          text))
    var typedFacts: ccsg.V3TypedExprFact[] = []
    var err = ""
    assert(ccsg.v3CompilerCsgBuildTypedExprFacts(sourceTexts, linkPlan.exprLayer, typedFacts, err),
           "v3 compiler csg: build typed facts")
    var csg: ccsg.V3CompilerCsg
    csg.version = 1
    csg.packageId = linkPlan.packageId
    csg.sourceBundleCid = layout.fixedBytes32Zero()
    csg.exprLayer = parser.v3NormalizedExprLayerClone(linkPlan.exprLayer)
    csg.typedExprFacts = ccsg.v3CompilerCsgCloneTypedExprFacts(typedFacts)
    csg.nodeCount = 0
    csg.edgeCount = 0
    csg.nodes = []
    csg.edges = []
    csg.canonicalGraphCid = layout.fixedBytes32Zero()
    csg.graphCid = layout.fixedBytes32Zero()
    return csg

fn main(): int32 =
    let workspaceRoot: str = v3path.V3PathCurrentDir()
    let packageRoot: str = v3path.V3PathJoin(workspaceRoot, "v3")
    let smokeLabel: str = os.GetEnvDefault("CHENG_V3_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathJoin(workspaceRoot, "artifacts/v3_compiler_csg/" + smokeLabel)
    assert(v3path.V3MkdirP(workspaceRoot, outDir), "v3 compiler csg: mkdir")
    let sourcePath: str = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath: str = v3path.V3PathJoin(outDir, "program_selfhost_smoke")
    let csg = buildFullCsg(workspaceRoot,
                           packageRoot,
                           sourcePath,
                           outputPath,
                           creq.v3EmitExe)
    assert(csg.nodeCount > 0, "v3 compiler csg: node count")
    assert(csg.edgeCount > 0, "v3 compiler csg: edge count")
    assert(csg.typedExprFacts.len == parser.v3NormalizedExprLayerExprCount(csg.exprLayer),
           "v3 compiler csg: typed expr fact count")
    assert(csg.typedExprFacts[0].exprId != "", "v3 compiler csg: typed expr id")
    let surface = ccsg.v3CompilerExportSurfaceFromCsg(csg)
    assert(surface.exportedSymbolCount > 0, "v3 compiler csg: export count")
    assert(csg.exprLayer.sourceCount > 0, "v3 compiler csg: expr surface count")
    assert(parser.v3NormalizedExprLayerTryCount(csg.exprLayer) >= 0, "v3 compiler csg: try count")
    assert(csg.exprLayer.questionResidualCount == 0, "v3 compiler csg: question normalized")
    assert(ccsg.v3TypedExprLowerLocalAddressCount(csg.typedExprFacts) > 0,
           "v3 compiler csg: lowering mode count")

    let typedFixturePath: str = v3path.V3PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let typedOutputPath: str = v3path.V3PathJoin(outDir, "typed_expr_fact_fixture")
    let typedCsg = buildMinimalCsg(workspaceRoot,
                                   packageRoot,
                                   typedFixturePath,
                                   typedOutputPath,
                                   creq.v3EmitShared)
    let typedFixtureFacts = ccsg.v3TypedExprFactsForSource(typedCsg.typedExprFacts, typedFixturePath)
    let typedFixtureRules = ccsg.v3TypedExprLoweringRulesFromFacts(typedFixtureFacts)
    let typedReport = ccsg.v3CompilerCsgReport(typedCsg)
    var loweringErr = ""
    assert(typedFixtureFacts.len > 0, "v3 compiler csg: typed fixture fact slice")
    assertTypedCallFactsMatchLayer(typedCsg.typedExprFacts, typedCsg.exprLayer, "v3 compiler csg: typed fixture")
    assert(ccsg.v3TypedExprFactsValidateCallResolution(typedCsg.exprLayer, typedCsg.typedExprFacts, loweringErr),
           "v3 compiler csg: typed fixture call resolution validate")
    assert(ccsg.v3TypedExprLoweringRulesValidate(typedFixtureRules, loweringErr),
           "v3 compiler csg: typed fixture lowering rules validate")
    assert(typedFixtureRules.len == typedFixtureFacts.len,
           "v3 compiler csg: typed fixture lowering rule count")
    assert(ccsg.v3TypedExprLoweringRuleUniqueShapeCount(typedFixtureRules) > 0,
           "v3 compiler csg: typed fixture lowering rule shape count")
    assert(ccsg.v3TypedExprLoweringRuleUniqueShapeCount(typedFixtureRules) ==
           ccsg.v3TypedExprLoweringRuleUniqueKeyCount(typedFixtureRules),
           "v3 compiler csg: typed fixture lowering rule key count")
    assert(ccsg.v3TypedExprAbiPolymorphicCount(typedFixtureFacts) == 0,
           "v3 compiler csg: typed fixture no abi polymorphic")
    assert(ccsg.v3TypedExprLowerDeferredCount(typedFixtureFacts) == 0,
           "v3 compiler csg: typed fixture no deferred lowering")
    assert(ccsg.v3TypedExprPlaceLocalCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture local place count")
    assert(ccsg.v3TypedExprLowerSretCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture sret count")
    assert(ccsg.v3TypedExprCallBuiltinCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture builtin call kind")
    assert(ccsg.v3TypedExprCallResultIntrinsicCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture result intrinsic call kind")
    assert(ccsg.v3TypedExprCallProjectionCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture projection call kind")
    assert(parser.v3NormalizedExprLayerHasExpr(typedCsg.exprLayer, parser.v3NormalizedExprCall, "external_call", 28),
           "v3 compiler csg: typed fixture alias external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedCsg.exprLayer, parser.v3NormalizedExprCall, "external_call", 29),
           "v3 compiler csg: typed fixture module stem external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedCsg.exprLayer, parser.v3NormalizedExprCall, "external_call", 30),
           "v3 compiler csg: typed fixture nested qualified external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedCsg.exprLayer, parser.v3NormalizedExprCall, "external_call", 32),
           "v3 compiler csg: typed fixture alias importc external call")
    assert(parser.v3NormalizedExprLayerHasExpr(typedCsg.exprLayer, parser.v3NormalizedExprCall, "external_call", 33),
           "v3 compiler csg: typed fixture nested importc external call")
    var sawAliasImportBuffer = false
    var sawNestedImportBuffer = false
    for i in 0..<typedFixtureFacts.len:
        if typedFixtureFacts[i].lineNumber == 32 &&
           ccsg.v3TypedExprLoweringModeText(typedFixtureFacts[i].loweringMode) == "import_buffer" &&
           ccsg.v3TypedExprReturnKindText(typedFixtureFacts[i].returnKind) == "import_buffer":
            sawAliasImportBuffer = true
        if typedFixtureFacts[i].lineNumber == 33 &&
           ccsg.v3TypedExprLoweringModeText(typedFixtureFacts[i].loweringMode) == "import_buffer" &&
           ccsg.v3TypedExprReturnKindText(typedFixtureFacts[i].returnKind) == "import_buffer":
            sawNestedImportBuffer = true
    assert(sawAliasImportBuffer, "v3 compiler csg: typed fixture alias importc uses import buffer")
    assert(sawNestedImportBuffer, "v3 compiler csg: typed fixture nested importc uses import buffer")
    assert(ccsg.v3TypedExprLowerImportBufferCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture import buffer lowering")
    assert(ccsg.v3TypedExprReturnRegCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture reg return kind")
    assert(ccsg.v3TypedExprReturnCompositeLocalCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture composite local return kind")
    assert(ccsg.v3TypedExprReturnSretCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture sret return kind")
    assert(ccsg.v3TypedExprReturnImportBufferCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture import buffer return kind")
    assert(reportFieldValue(typedReport, "expr_surface_call_count") ==
           intToStr(parser.v3NormalizedExprLayerCallCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report call count")
    assert(reportFieldValue(typedReport, "expr_surface_call_resolved_count") ==
           intToStr(parser.v3NormalizedExprLayerCallResolvedCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report resolved call count")
    assert(reportFieldValue(typedReport, "expr_surface_call_unresolved_count") ==
           intToStr(parser.v3NormalizedExprLayerCallUnresolvedCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report unresolved call count")
    assert(reportFieldValue(typedReport, "expr_surface_call_local_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCount(typedCsg.exprLayer, "local_call")),
           "v3 compiler csg: typed fixture report local call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_external_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCount(typedCsg.exprLayer, "external_call")),
           "v3 compiler csg: typed fixture report external call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_importc_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCount(typedCsg.exprLayer, "importc_call")),
           "v3 compiler csg: typed fixture report importc call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_member_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCount(typedCsg.exprLayer, "member_call")),
           "v3 compiler csg: typed fixture report member call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_target_importc_count") ==
           intToStr(parser.v3NormalizedExprLayerCallTargetImportcCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report importc target count")
    assert(reportFieldValue(typedReport, "expr_surface_call_reason_unknown_qualified_target_count") ==
           intToStr(parser.v3NormalizedExprLayerCallReasonCount(typedCsg.exprLayer, "unknown_qualified_target")),
           "v3 compiler csg: typed fixture report unknown qualified target count")
    assert(reportFieldValue(typedReport, "expr_surface_call_reason_shadowed_qualified_target_count") ==
           intToStr(parser.v3NormalizedExprLayerCallReasonCount(typedCsg.exprLayer, "shadowed_qualified_target")),
           "v3 compiler csg: typed fixture report shadowed qualified target count")
    assert(reportFieldValue(typedReport, "expr_surface_call_reason_ambiguous_external_target_count") ==
           intToStr(parser.v3NormalizedExprLayerCallReasonCount(typedCsg.exprLayer, "ambiguous_external_target")),
           "v3 compiler csg: typed fixture report ambiguous external target count")
    assert(reportFieldValue(typedReport, "expr_surface_call_reason_ambiguous_qualified_target_count") ==
           intToStr(parser.v3NormalizedExprLayerCallReasonCount(typedCsg.exprLayer, "ambiguous_qualified_target")),
           "v3 compiler csg: typed fixture report ambiguous qualified target count")
    assert(reportFieldPositive(typedReport, "lowering_rule_arg_address_count"),
           "v3 compiler csg: typed fixture address arg rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_result_sret_count"),
           "v3 compiler csg: typed fixture sret result rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_materialize_dest_address_count"),
           "v3 compiler csg: typed fixture dest address materialize rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_copy_region_copy_count"),
           "v3 compiler csg: typed fixture region copy rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_import_builtin_address_slot_count"),
           "v3 compiler csg: typed fixture builtin address import rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_import_import_buffer_count"),
           "v3 compiler csg: typed fixture import buffer import rule")
    assert(reportFieldValue(typedReport, "lowering_rule_unique_key_count") ==
           reportFieldValue(typedReport, "lowering_rule_unique_shape_count"),
           "v3 compiler csg: typed fixture report unique key count")
    assert(reportFieldValue(typedReport, "lowering_rule_entry[0]") != "",
           "v3 compiler csg: typed fixture report rule entry")
    assert(v3path.V3TextContains(reportFieldValue(typedReport, "lowering_rule_entry[0]"), "key=type="),
           "v3 compiler csg: typed fixture report rule key text")

    echo("v3 compiler_csg_smoke ok")
    return 0
