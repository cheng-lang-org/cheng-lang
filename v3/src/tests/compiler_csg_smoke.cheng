import std/os
import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_world as cworld
import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/lang/parser
import cheng/v3/lang/typed_expr as texpr

fn reportFieldValue(report: str, key: str): str =
    let taggedReport = "\n" + report
    let needle = "\n" + key + "="
    let fieldPos = parser.v3ParserFindText(taggedReport, needle)
    if fieldPos < 0:
        return ""
    let valueStart = fieldPos + needle.len
    let tail = v3path.V3TextSlice(taggedReport, valueStart, taggedReport.len - valueStart)
    let newlinePos = parser.v3ParserFindText(tail, "\n")
    if newlinePos < 0:
        return tail
    return v3path.V3TextSlice(tail, 0, newlinePos)

fn reportFieldPositive(report: str, key: str): bool =
    let value = reportFieldValue(report, key)
    return value != "" && value != "0"

fn assertCallReasonReportField(report: str,
                               layer: parser.V3NormalizedExprLayer,
                               reason: parser.V3NormalizedExprCallReason,
                               label: str) =
    let reportKey = ccsg.v3CompilerCsgCallReasonReportKey(reason)
    assert(reportKey != "", label + " report key")
    assert(reportFieldValue(report, reportKey) ==
           intToStr(parser.v3NormalizedExprLayerCallReasonCountExact(layer, reason)),
           label)

fn assertTypedCallFactsMatchLayer(facts: ccsg.V3TypedExprFact[],
                                  layer: parser.V3NormalizedExprLayer,
                                  label: str) =
    assert(texpr.v3TypedExprTypeCallDefaultInitCount(facts) ==
           parser.v3NormalizedExprLayerDefaultInitCount(layer),
           label + " typed default init count")
    assert(texpr.v3TypedExprTypeCallConstructorCount(facts) ==
           parser.v3NormalizedExprLayerConstructorCount(layer),
           label + " typed constructor count")
    assert(texpr.v3TypedExprFactCountCallResolved(facts) ==
           parser.v3NormalizedExprLayerCallResolvedCount(layer),
           label + " typed resolved call count")
    assert(texpr.v3TypedExprFactCountCallUnresolved(facts) ==
           parser.v3NormalizedExprLayerCallUnresolvedCount(layer),
           label + " typed unresolved call count")
    assert(texpr.v3TypedExprFactCountSurfaceCallKindFromParser(facts, parser.v3NormalizedExprSurfaceCallLocal) ==
           parser.v3NormalizedExprLayerCallKindCountExact(layer, parser.v3NormalizedExprSurfaceCallLocal),
           label + " typed local call kind count")
    assert(texpr.v3TypedExprFactCountSurfaceCallKindFromParser(facts, parser.v3NormalizedExprSurfaceCallExternal) ==
           parser.v3NormalizedExprLayerCallKindCountExact(layer, parser.v3NormalizedExprSurfaceCallExternal),
           label + " typed external call kind count")
    assert(texpr.v3TypedExprFactCountSurfaceCallKindFromParser(facts, parser.v3NormalizedExprSurfaceCallImportc) ==
           parser.v3NormalizedExprLayerCallKindCountExact(layer, parser.v3NormalizedExprSurfaceCallImportc),
           label + " typed importc call kind count")
    assert(texpr.v3TypedExprFactCountSurfaceCallKindFromParser(facts, parser.v3NormalizedExprSurfaceCallMember) ==
           parser.v3NormalizedExprLayerCallKindCountExact(layer, parser.v3NormalizedExprSurfaceCallMember),
           label + " typed member call kind count")
    assert(texpr.v3TypedExprFactCountCallTargetImportc(facts) ==
           parser.v3NormalizedExprLayerCallTargetImportcCount(layer),
           label + " typed importc target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonUnknownQualifiedTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonUnknownQualifiedTarget),
           label + " typed unknown qualified target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonShadowedQualifiedTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonShadowedQualifiedTarget),
           label + " typed shadowed qualified target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonAmbiguousExternalTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonAmbiguousExternalTarget),
           label + " typed ambiguous external target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonAmbiguousQualifiedTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonAmbiguousQualifiedTarget),
           label + " typed ambiguous qualified target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonUnknownExternalTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonUnknownExternalTarget),
           label + " typed unknown external target count")
    assert(texpr.v3TypedExprFactCountCallReasonFromParser(facts, parser.v3NormalizedExprCallReasonUnknownCallTarget) ==
           parser.v3NormalizedExprLayerCallReasonCountExact(layer, parser.v3NormalizedExprCallReasonUnknownCallTarget),
           label + " typed unknown call target count")

fn buildLinkPlan(workspaceRoot: str,
                 packageRoot: str,
                 sourcePath: str,
                 outputPath: str,
                 emitKind: int32): slplan.V3SystemLinkPlanStub =
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), "v3 compiler csg: link plan")
    return linkPlan

fn buildFullCsg(workspaceRoot: str,
                packageRoot: str,
                sourcePath: str,
                outputPath: str,
                emitKind: int32): ccsg.V3CompilerCsg =
    let linkPlan = buildLinkPlan(workspaceRoot, packageRoot, sourcePath, outputPath, emitKind)
    var sourceTexts: ccsg.V3TypedExprSourceText[]
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let currentSourcePath = linkPlan.sourceClosurePaths[i]
        let text = v3path.V3ReadTextFile("", currentSourcePath)
        add(sourceTexts, texpr.v3TypedExprSourceTextNew(workspaceRoot,
                                                        packageRoot,
                                                        currentSourcePath,
                                                        text))
    var typedFacts: ccsg.V3TypedExprFact[]
    var err = ""
    assert(texpr.v3TypedExprBuildFacts(sourceTexts, linkPlan.exprLayer, typedFacts, err),
           "v3 compiler csg: build typed facts")
    var nodes: ccsg.V3CompilerCsgNode[]
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let currentSourcePath = linkPlan.sourceClosurePaths[i]
        let text = v3path.V3ReadTextFile("", currentSourcePath)
        let ownerModulePath = parser.v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, currentSourcePath)
        var decls: parser.V3NormalizedFunctionDecl[]
        err = ""
        assert(parser.v3ParserReadNormalizedFunctionDecls(text, decls, err),
               "v3 compiler csg: decls")
        var entryHasExplicitExports = false
        if currentSourcePath == linkPlan.entryPath &&
           (linkPlan.emitKind == creq.v3EmitShared || linkPlan.emitKind == creq.v3EmitObj):
            for declIndex in 0..<decls.len:
                if decls[declIndex].importc:
                    continue
                if decls[declIndex].explicitExportName != "":
                    entryHasExplicitExports = true
                    break
        for declIndex in 0..<decls.len:
            let decl = decls[declIndex]
            if decl.importc:
                continue
            let symbolText = ownerModulePath + "::" + decl.name
            var entryFlag = 0
            if currentSourcePath == linkPlan.entryPath && decl.name == linkPlan.entrySymbol:
                entryFlag = 1
            var resultLayoutKind = 0
            if decl.name == "main":
                resultLayoutKind = 5
            var effectKind = ccsg.v3CompilerCsgEffectPure
            if entryFlag != 0:
                effectKind = ccsg.v3CompilerCsgEffectProgramEntry
            var capabilityKind = ccsg.v3CompilerCsgCapabilityInternal
            if entryFlag != 0:
                capabilityKind = ccsg.v3CompilerCsgCapabilityEntrypoint
            var exportedFlag = 0
            if ccsg.v3CompilerCsgShouldExportSymbol(linkPlan.emitKind,
                                                    currentSourcePath == linkPlan.entryPath,
                                                    entryHasExplicitExports,
                                                    decl.explicitExportName,
                                                    decl.name,
                                                    entryFlag):
                exportedFlag = 1
            var node: ccsg.V3CompilerCsgNode
            node.nodeId = nodes.len + 1
            node.nodeKind = ccsg.v3CompilerCsgNodeKindSymbol
            node.ownerNodeId = 0
            node.modulePath = ownerModulePath
            node.symbolText = symbolText
            node.factText = decl.name
            node.resultLayoutKind = resultLayoutKind
            node.effectKind = effectKind
            node.capabilityKind = capabilityKind
            node.callConv = 1
            node.entryFlag = entryFlag
            node.exportedFlag = exportedFlag
            node.exportSymbolName = ""
            if exportedFlag != 0:
                node.exportSymbolName = ccsg.v3CompilerCsgTargetExportName(symbolText,
                                                                           decl.explicitExportName,
                                                                           decl.name)
            node.factCid = layout.FixedBytes32()
            add(nodes, node)
    var edges: ccsg.V3CompilerCsgEdge[]
    if nodes.len > 0:
        var edge: ccsg.V3CompilerCsgEdge
        edge.edgeId = 1
        edge.fromNodeId = nodes[0].nodeId
        edge.toNodeId = nodes[0].nodeId
        edge.edgeKind = ccsg.v3CompilerCsgEdgeKindContains
        edge.edgeCid = layout.FixedBytes32()
        add(edges, edge)
    var csg: ccsg.V3CompilerCsg
    csg.version = 1
    csg.packageId = linkPlan.packageId
    csg.sourceBundleCid = layout.FixedBytes32()
    csg.exprLayer = parser.v3NormalizedExprLayerClone(linkPlan.exprLayer)
    csg.typedExprFacts = texpr.v3TypedExprFactsClone(typedFacts)
    csg.nodeCount = nodes.len
    csg.edgeCount = edges.len
    csg.nodes = nodes
    csg.edges = edges
    csg.canonicalGraphCid = layout.FixedBytes32()
    csg.graphCid = layout.FixedBytes32()
    return csg

fn buildMinimalCsg(workspaceRoot: str,
                   packageRoot: str,
                   sourcePath: str,
                   outputPath: str,
                   emitKind: int32): ccsg.V3CompilerCsg =
    let linkPlan = buildLinkPlan(workspaceRoot, packageRoot, sourcePath, outputPath, emitKind)
    var sourceTexts: ccsg.V3TypedExprSourceText[]
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let currentSourcePath = linkPlan.sourceClosurePaths[i]
        let text = v3path.V3ReadTextFile("", currentSourcePath)
        add(sourceTexts, texpr.v3TypedExprSourceTextNew(workspaceRoot,
                                                        packageRoot,
                                                        currentSourcePath,
                                                        text))
    var typedFacts: ccsg.V3TypedExprFact[]
    var err = ""
    assert(texpr.v3TypedExprBuildFacts(sourceTexts, linkPlan.exprLayer, typedFacts, err),
           "v3 compiler csg: build typed facts")
    var csg: ccsg.V3CompilerCsg
    csg.version = 1
    csg.packageId = linkPlan.packageId
    csg.sourceBundleCid = layout.FixedBytes32()
    csg.exprLayer = parser.v3NormalizedExprLayerClone(linkPlan.exprLayer)
    csg.typedExprFacts = texpr.v3TypedExprFactsClone(typedFacts)
    csg.nodeCount = 0
    csg.edgeCount = 0
    csg.nodes = []
    csg.edges = []
    csg.canonicalGraphCid = layout.FixedBytes32()
    csg.graphCid = layout.FixedBytes32()
    return csg

fn byteBufBytesEqual(lhs: layout.ByteBuf,
                     rhs: layout.ByteBuf): bool =
    let lhsBytes = layout.byteBufToBytes(lhs)
    let rhsBytes = layout.byteBufToBytes(rhs)
    if len(lhsBytes) != len(rhsBytes):
        return false
    for i in 0..<len(lhsBytes):
        if lhsBytes[i] != rhsBytes[i]:
            return false
    return true

fn findCallExpr(layer: parser.V3NormalizedExprLayer,
                sourcePath: str,
                lineNumber: int32): parser.V3NormalizedExpr =
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].kind != parser.v3NormalizedExprCall:
            continue
        if layer.exprs[i].sourcePath != sourcePath:
            continue
        if layer.exprs[i].lineNumber != lineNumber:
            continue
        return parser.v3NormalizedExprClone(layer.exprs[i])
    var missing: parser.V3NormalizedExpr
    return missing

fn findTypedFact(facts: ccsg.V3TypedExprFact[],
                 sourcePath: str,
                 lineNumber: int32): ccsg.V3TypedExprFact =
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath:
            continue
        if facts[i].lineNumber != lineNumber:
            continue
        return texpr.v3TypedExprFactClone(facts[i])
    var missing: ccsg.V3TypedExprFact
    return missing

fn main(): int32 =
    let workspaceRoot: str = v3path.V3PathCurrentDir()
    let packageRoot: str = v3path.V3PathJoin(workspaceRoot, "v3")
    let smokeLabel: str = os.GetEnvDefault("CHENG_V3_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathJoin(workspaceRoot, "artifacts/v3_compiler_csg/" + smokeLabel)
    assert(v3path.V3MkdirP(workspaceRoot, outDir), "v3 compiler csg: mkdir")
    let sourcePath: str = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath: str = v3path.V3PathJoin(outDir, "program_selfhost_smoke")
    let csg = buildFullCsg(workspaceRoot,
                           packageRoot,
                           sourcePath,
                           outputPath,
                           creq.v3EmitExe)
    assert(csg.nodeCount > 0, "v3 compiler csg: node count")
    assert(csg.edgeCount > 0, "v3 compiler csg: edge count")
    assert(csg.typedExprFacts.len == parser.v3NormalizedExprLayerExprCount(csg.exprLayer),
           "v3 compiler csg: typed expr fact count")
    assert(csg.typedExprFacts[0].exprId != "", "v3 compiler csg: typed expr id")
    let surface = ccsg.v3CompilerExportSurfaceFromCsg(csg)
    assert(surface.exportedSymbolCount > 0, "v3 compiler csg: export count")
    assert(csg.exprLayer.sourceCount > 0, "v3 compiler csg: expr surface count")
    assert(parser.v3NormalizedExprLayerTryCount(csg.exprLayer) >= 0, "v3 compiler csg: try count")
    assert(csg.exprLayer.questionResidualCount == 0, "v3 compiler csg: question normalized")
    assert(texpr.v3TypedExprLowerLocalAddressCount(csg.typedExprFacts) > 0,
           "v3 compiler csg: lowering mode count")

    let typedFixturePath: str = v3path.V3PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let typedOutputPath: str = v3path.V3PathJoin(outDir, "typed_expr_fact_fixture")
    let typedCsg = buildMinimalCsg(workspaceRoot,
                                   packageRoot,
                                   typedFixturePath,
                                   typedOutputPath,
                                   creq.v3EmitShared)
    let typedFixtureFacts = texpr.v3TypedExprFactsForSource(typedCsg.typedExprFacts, typedFixturePath)
    let typedFixtureRules = texpr.v3TypedExprLoweringRulesFromFacts(typedFixtureFacts)
    let typedReport = ccsg.v3CompilerCsgReport(typedCsg)
    let aliasExternalExpr = findCallExpr(typedCsg.exprLayer, typedFixturePath, 28)
    var loweringErr = ""
    let actualTypedLinkPlan = buildLinkPlan(workspaceRoot,
                                            packageRoot,
                                            typedFixturePath,
                                            typedOutputPath,
                                            creq.v3EmitShared)
    let actualTypedBundleCid = cworld.v3CompilerWorldSourceBundleCid(actualTypedLinkPlan.packageId,
                                                                     actualTypedLinkPlan.sourceClosurePaths)
    let actualTypedCsgRes = ccsg.v3BuildCompilerCsg(actualTypedLinkPlan, actualTypedBundleCid)
    assert(IsOk(actualTypedCsgRes), "v3 compiler csg: actual typed fixture csg")
    let actualTypedCsg = ccsg.v3CompilerCsgClone(Value(actualTypedCsgRes))
    assert(texpr.v3TypedExprFactsValidateCallResolution(actualTypedCsg.exprLayer,
                                                        actualTypedCsg.typedExprFacts,
                                                        loweringErr),
           "v3 compiler csg: actual typed fixture call resolution validate")
    let actualTypedRules = texpr.v3TypedExprLoweringRulesFromFacts(actualTypedCsg.typedExprFacts)
    assert(texpr.v3TypedExprLoweringRulesValidate(actualTypedRules, loweringErr),
           "v3 compiler csg: actual typed fixture lowering rules validate")
    assert(typedFixtureFacts.len > 0, "v3 compiler csg: typed fixture fact slice")
    assert(aliasExternalExpr.exprId != "", "v3 compiler csg: typed fixture alias external expr")
    var legacyCompatBuf = layout.byteBufInit(128)
    var streamedCompatBuf = layout.byteBufInit(128)
    ccsg.v3CompilerCsgAppendText(legacyCompatBuf, ccsg.v3CompilerCsgExprCompatDetail(aliasExternalExpr))
    ccsg.v3CompilerCsgAppendExprCompatDetail(streamedCompatBuf, aliasExternalExpr)
    assert(byteBufBytesEqual(legacyCompatBuf, streamedCompatBuf),
           "v3 compiler csg: streamed compat detail bytes")
    assertTypedCallFactsMatchLayer(typedCsg.typedExprFacts, typedCsg.exprLayer, "v3 compiler csg: typed fixture")
    assert(texpr.v3TypedExprFactsValidateCallResolution(typedCsg.exprLayer, typedCsg.typedExprFacts, loweringErr),
           "v3 compiler csg: typed fixture call resolution validate")
    assert(texpr.v3TypedExprLoweringRulesValidate(typedFixtureRules, loweringErr),
           "v3 compiler csg: typed fixture lowering rules validate")
    assert(typedFixtureRules.len == typedFixtureFacts.len,
           "v3 compiler csg: typed fixture lowering rule count")
    assert(texpr.v3TypedExprLoweringRuleUniqueShapeCount(typedFixtureRules) > 0,
           "v3 compiler csg: typed fixture lowering rule shape count")
    assert(texpr.v3TypedExprLoweringRuleUniqueShapeCount(typedFixtureRules) ==
           texpr.v3TypedExprLoweringRuleUniqueKeyCount(typedFixtureRules),
           "v3 compiler csg: typed fixture lowering rule key count")
    assert(texpr.v3TypedExprAbiPolymorphicCount(typedFixtureFacts) == 0,
           "v3 compiler csg: typed fixture no abi polymorphic")
    assert(texpr.v3TypedExprLowerDeferredCount(typedFixtureFacts) == 0,
           "v3 compiler csg: typed fixture no deferred lowering")
    assert(texpr.v3TypedExprPlaceLocalCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture local place count")
    assert(texpr.v3TypedExprLowerSretCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture sret count")
    assert(texpr.v3TypedExprCallBuiltinCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture builtin call kind")
    assert(texpr.v3TypedExprCallResultIntrinsicCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture result intrinsic call kind")
    assert(texpr.v3TypedExprCallProjectionCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture projection call kind")
    assert(parser.v3NormalizedExprLayerHasConstructorExpr(typedCsg.exprLayer, 60),
           "v3 compiler csg: typed fixture constructor expr")
    let constructorFact = findTypedFact(typedFixtureFacts, typedFixturePath, 60)
    assert(constructorFact.kind == parser.v3NormalizedExprConstructor,
           "v3 compiler csg: typed fixture constructor fact kind")
    assert(constructorFact.typeCallKind == texpr.v3TypedExprTypeCallConstructor,
           "v3 compiler csg: typed fixture constructor type call kind")
    assert(constructorFact.typeText == "TypedDefaultWrap",
           "v3 compiler csg: typed fixture constructor fact type")
    assert(!constructorFact.callPrefixStyle,
           "v3 compiler csg: typed fixture constructor call prefix")
    assert(constructorFact.callArgCount == 1,
           "v3 compiler csg: typed fixture constructor arg count")
    assert(constructorFact.callArgsText == "count: payload.len",
           "v3 compiler csg: typed fixture constructor args text")
    let constructorRules = texpr.v3TypedExprLoweringRulesFromFacts(typedCsg.typedExprFacts)
    var sawConstructorRule = false
    for i in 0..<constructorRules.len:
        if constructorRules[i].sourcePath == typedFixturePath &&
           constructorRules[i].lineNumber == 60 &&
           constructorRules[i].typeCallKind == texpr.v3TypedExprTypeCallConstructor:
            assert(constructorRules[i].callArgCount == 1,
                   "v3 compiler csg: typed fixture constructor rule arg count")
            assert(constructorRules[i].callArgsText == "count: payload.len",
                   "v3 compiler csg: typed fixture constructor rule args text")
            sawConstructorRule = true
    assert(sawConstructorRule, "v3 compiler csg: typed fixture constructor lowering rule")
    var badTypeCallFacts = texpr.v3TypedExprFactsClone(typedCsg.typedExprFacts)
    var corruptedTypeCallFact = false
    for i in 0..<badTypeCallFacts.len:
        if badTypeCallFacts[i].sourcePath == typedFixturePath &&
           badTypeCallFacts[i].lineNumber == 60 &&
           badTypeCallFacts[i].kind == parser.v3NormalizedExprConstructor:
            badTypeCallFacts[i].abiClass = texpr.v3TypedExprAbiPolymorphic
            badTypeCallFacts[i].valueKind = texpr.v3TypedExprValuePolymorphic
            badTypeCallFacts[i].loweringMode = texpr.v3TypedExprLowerDeferred
            badTypeCallFacts[i].returnKind = texpr.v3TypedExprReturnDeferred
            corruptedTypeCallFact = true
    assert(corruptedTypeCallFact, "v3 compiler csg: corrupt constructor fact")
    loweringErr = ""
    assert(!texpr.v3TypedExprFactsValidateCallResolution(typedCsg.exprLayer, badTypeCallFacts, loweringErr),
           "v3 compiler csg: reject invalid constructor fact lowering")
    assert(v3path.V3TextContains(loweringErr, "type-call fact"),
           "v3 compiler csg: invalid constructor fact error")
    var badTypeCallRules = texpr.v3TypedExprLoweringRulesClone(constructorRules)
    var corruptedTypeCallRule = false
    for i in 0..<badTypeCallRules.len:
        if badTypeCallRules[i].sourcePath == typedFixturePath &&
           badTypeCallRules[i].lineNumber == 60 &&
           badTypeCallRules[i].typeCallKind == texpr.v3TypedExprTypeCallConstructor:
            badTypeCallRules[i].copyKind = texpr.v3TypedExprCopyScalarStore
            corruptedTypeCallRule = true
    assert(corruptedTypeCallRule, "v3 compiler csg: corrupt constructor rule")
    loweringErr = ""
    assert(!texpr.v3TypedExprLoweringRulesValidate(badTypeCallRules, loweringErr),
           "v3 compiler csg: reject invalid constructor lowering rule")
    assert(v3path.V3TextContains(loweringErr, "type-call rule"),
           "v3 compiler csg: invalid constructor rule error")
    assert(parser.v3NormalizedExprLayerHasCallExpr(typedCsg.exprLayer, parser.v3NormalizedExprSurfaceCallExternal, 28),
           "v3 compiler csg: typed fixture alias external call")
    assert(parser.v3NormalizedExprLayerHasCallExpr(typedCsg.exprLayer, parser.v3NormalizedExprSurfaceCallExternal, 29),
           "v3 compiler csg: typed fixture module stem external call")
    assert(parser.v3NormalizedExprLayerHasCallExpr(typedCsg.exprLayer, parser.v3NormalizedExprSurfaceCallExternal, 30),
           "v3 compiler csg: typed fixture nested qualified external call")
    assert(parser.v3NormalizedExprLayerHasCallExpr(typedCsg.exprLayer, parser.v3NormalizedExprSurfaceCallExternal, 32),
           "v3 compiler csg: typed fixture alias importc external call")
    assert(parser.v3NormalizedExprLayerHasCallExpr(typedCsg.exprLayer, parser.v3NormalizedExprSurfaceCallExternal, 33),
           "v3 compiler csg: typed fixture nested importc external call")
    var sawAliasImportBuffer = false
    var sawNestedImportBuffer = false
    var sawDefaultInitFact = false
    for i in 0..<typedFixtureFacts.len:
        if typedFixtureFacts[i].lineNumber == 32 &&
           texpr.v3TypedExprFactUsesImportBuffer(typedFixtureFacts[i]):
            sawAliasImportBuffer = true
        if typedFixtureFacts[i].lineNumber == 33 &&
           texpr.v3TypedExprFactUsesImportBuffer(typedFixtureFacts[i]):
            sawNestedImportBuffer = true
        if typedFixtureFacts[i].lineNumber == 56 &&
           typedFixtureFacts[i].kind == parser.v3NormalizedExprDefaultInit:
            assert(typedFixtureFacts[i].typeCallKind == texpr.v3TypedExprTypeCallDefaultInit,
                   "v3 compiler csg: typed fixture default init type call kind")
            assert(typedFixtureFacts[i].abiClass == texpr.v3TypedExprAbiComposite,
                   "v3 compiler csg: typed fixture default init abi")
            assert(typedFixtureFacts[i].placeKind != texpr.v3TypedExprPlaceCallResult,
                   "v3 compiler csg: typed fixture default init place")
            assert(typedFixtureFacts[i].loweringMode == texpr.v3TypedExprLowerLocalAddress,
                   "v3 compiler csg: typed fixture default init lowering")
            assert(typedFixtureFacts[i].returnKind == texpr.v3TypedExprReturnCompositeLocal,
                   "v3 compiler csg: typed fixture default init return")
            sawDefaultInitFact = true
    assert(sawAliasImportBuffer, "v3 compiler csg: typed fixture alias importc uses import buffer")
    assert(sawNestedImportBuffer, "v3 compiler csg: typed fixture nested importc uses import buffer")
    assert(sawDefaultInitFact, "v3 compiler csg: typed fixture saw default init fact")
    assert(texpr.v3TypedExprLowerImportBufferCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture import buffer lowering")
    assert(texpr.v3TypedExprReturnRegCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture reg return kind")
    assert(texpr.v3TypedExprReturnCompositeLocalCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture composite local return kind")
    assert(texpr.v3TypedExprReturnSretCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture sret return kind")
    assert(texpr.v3TypedExprReturnImportBufferCount(typedFixtureFacts) > 0,
           "v3 compiler csg: typed fixture import buffer return kind")
    assert(reportFieldValue(typedReport, "expr_surface_call_count") ==
           intToStr(parser.v3NormalizedExprLayerCallCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report call count")
    assert(reportFieldValue(typedReport, "expr_surface_default_init_count") ==
           intToStr(parser.v3NormalizedExprLayerDefaultInitCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report default init count")
    assert(reportFieldValue(typedReport, "expr_surface_call_resolved_count") ==
           intToStr(parser.v3NormalizedExprLayerCallResolvedCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report resolved call count")
    assert(reportFieldValue(typedReport, "expr_surface_call_unresolved_count") ==
           intToStr(parser.v3NormalizedExprLayerCallUnresolvedCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report unresolved call count")
    assert(reportFieldValue(typedReport, "expr_surface_call_local_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCountExact(typedCsg.exprLayer, parser.v3NormalizedExprSurfaceCallLocal)),
           "v3 compiler csg: typed fixture report local call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_external_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCountExact(typedCsg.exprLayer, parser.v3NormalizedExprSurfaceCallExternal)),
           "v3 compiler csg: typed fixture report external call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_importc_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCountExact(typedCsg.exprLayer, parser.v3NormalizedExprSurfaceCallImportc)),
           "v3 compiler csg: typed fixture report importc call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_member_kind_count") ==
           intToStr(parser.v3NormalizedExprLayerCallKindCountExact(typedCsg.exprLayer, parser.v3NormalizedExprSurfaceCallMember)),
           "v3 compiler csg: typed fixture report member call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_target_importc_count") ==
           intToStr(parser.v3NormalizedExprLayerCallTargetImportcCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report importc target count")
    assert(reportFieldValue(typedReport, "expr_surface_constructor_count") ==
           intToStr(parser.v3NormalizedExprLayerConstructorCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report constructor count")
    assert(reportFieldValue(typedReport, "typed_expr_type_call_default_init_count") ==
           intToStr(parser.v3NormalizedExprLayerDefaultInitCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report typed default init count")
    assert(reportFieldValue(typedReport, "typed_expr_type_call_constructor_count") ==
           intToStr(parser.v3NormalizedExprLayerConstructorCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report typed constructor count")
    assert(reportFieldValue(typedReport, "lowering_rule_type_call_default_init_count") ==
           intToStr(parser.v3NormalizedExprLayerDefaultInitCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report lowering default init count")
    assert(reportFieldValue(typedReport, "lowering_rule_type_call_constructor_count") ==
           intToStr(parser.v3NormalizedExprLayerConstructorCount(typedCsg.exprLayer)),
           "v3 compiler csg: typed fixture report lowering constructor count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.v3NormalizedExprCallReasonUnknownQualifiedTarget,
                                "v3 compiler csg: typed fixture report unknown qualified target count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.v3NormalizedExprCallReasonShadowedQualifiedTarget,
                                "v3 compiler csg: typed fixture report shadowed qualified target count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.v3NormalizedExprCallReasonAmbiguousExternalTarget,
                                "v3 compiler csg: typed fixture report ambiguous external target count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.v3NormalizedExprCallReasonAmbiguousQualifiedTarget,
                                "v3 compiler csg: typed fixture report ambiguous qualified target count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.v3NormalizedExprCallReasonUnknownExternalTarget,
                                "v3 compiler csg: typed fixture report unknown external target count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.v3NormalizedExprCallReasonUnknownCallTarget,
                                "v3 compiler csg: typed fixture report unknown call target count")
    assert(reportFieldPositive(typedReport, "lowering_rule_arg_address_count"),
           "v3 compiler csg: typed fixture address arg rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_result_sret_count"),
           "v3 compiler csg: typed fixture sret result rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_materialize_dest_address_count"),
           "v3 compiler csg: typed fixture dest address materialize rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_copy_region_copy_count"),
           "v3 compiler csg: typed fixture region copy rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_import_builtin_address_slot_count"),
           "v3 compiler csg: typed fixture builtin address import rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_import_import_buffer_count"),
           "v3 compiler csg: typed fixture import buffer import rule")
    assert(reportFieldValue(typedReport, "lowering_rule_unique_key_count") ==
           reportFieldValue(typedReport, "lowering_rule_unique_shape_count"),
           "v3 compiler csg: typed fixture report unique key count")
    assert(reportFieldValue(typedReport, "lowering_rule_entry[0]") != "",
           "v3 compiler csg: typed fixture report rule entry")
    assert(v3path.V3TextContains(reportFieldValue(typedReport, "lowering_rule_entry[0]"), "key=type="),
           "v3 compiler csg: typed fixture report rule key text")

    echo("v3 compiler_csg_smoke ok")
    return 0
