import std/system
import std/result
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr

fn main(): int32 =
    let okRes = multiaddr.v3Libp2pMultiaddrParse("/ip4/127.0.0.1/udp/4201/quic-v1")
    assert(IsOk(okRes), "v3 libp2p multiaddr boundary: quic parse ok")
    let okAddr = Value(okRes)
    assert(okAddr.transport == types.v3Libp2pTransportQuic, "v3 libp2p multiaddr boundary: quic transport")
    assert(okAddr.secure == types.v3Libp2pSecureTls, "v3 libp2p multiaddr boundary: quic secure")

    let emptyRes = multiaddr.v3Libp2pMultiaddrParse("")
    assert(IsErr(emptyRes), "v3 libp2p multiaddr boundary: empty rejected")
    assert(Error(emptyRes) == "v3 libp2p multiaddr: empty", "v3 libp2p multiaddr boundary: empty error")

    let missingQuicRes = multiaddr.v3Libp2pMultiaddrParse("/ip4/127.0.0.1/udp/4201")
    assert(IsErr(missingQuicRes), "v3 libp2p multiaddr boundary: missing quic rejected")
    assert(Error(missingQuicRes) == "v3 libp2p multiaddr: missing quic transport",
        "v3 libp2p multiaddr boundary: missing quic error")

    let badPortRes = multiaddr.v3Libp2pMultiaddrParse("/ip4/127.0.0.1/udp/abc/quic-v1")
    assert(IsErr(badPortRes), "v3 libp2p multiaddr boundary: invalid port rejected")
    assert(Error(badPortRes) == "v3 libp2p multiaddr: invalid number",
        "v3 libp2p multiaddr boundary: invalid port error")

    let trailingProtoRes = multiaddr.v3Libp2pMultiaddrParse("/ip4/127.0.0.1/tcp/4201/quic-v1")
    assert(IsErr(trailingProtoRes), "v3 libp2p multiaddr boundary: trailing protocol rejected")
    assert(Error(trailingProtoRes) == "v3 libp2p multiaddr: unsupported trailing protocol",
        "v3 libp2p multiaddr boundary: trailing protocol error")

    echo("v3 libp2p_multiaddr_parse_boundary_smoke ok")
    return 0
