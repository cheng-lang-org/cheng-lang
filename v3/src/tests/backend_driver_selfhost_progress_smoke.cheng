import std/os
import std/strings
import cheng/v3/tooling/bootstrap_contracts as contracts
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let packageRoot: str = os.JoinPath(root, "v3")
    let driver: str = os.JoinPath(root, "artifacts/v3_backend_driver/cheng")
    let source: str = os.JoinPath(root, "v3/src/tooling/compiler_main.cheng")
    let target: str = contracts.V3BootstrapDetectHostTarget()
    let outDir: str = v3path.V3PathAbsolute(root, "artifacts/v3_backend_driver_selfhost_progress_smoke")
    let outBin: str = os.JoinPath(outDir, "compiler_main.selfhost")
    let outMap: str = outBin + ".map"
    let compileLog: str = os.JoinPath(outDir, "compiler_main.compile.log")
    let progressLog: str = os.JoinPath(outDir, "compiler_main.progress.log")
    assert(os.FileExists(driver), "v3 backend driver selfhost progress: backend_driver exists")
    assert(len(target) > 0, "v3 backend driver selfhost progress: host target")
    assert(v3path.V3MkdirP(root, outDir), "v3 backend driver selfhost progress: mkdir")
    if v3path.V3PathFileExists(outBin):
        os.RemoveFile(outBin)
    if v3path.V3PathFileExists(outMap):
        os.RemoveFile(outMap)
    if v3path.V3PathFileExists(compileLog):
        os.RemoveFile(compileLog)
    if v3path.V3PathFileExists(progressLog):
        os.RemoveFile(progressLog)
    let compileRun = hostops.v3RunFileLogged(root,
                                             "backend_driver_selfhost_progress_compile",
                                             driver,
                                             [
                                                 "system-link-exec",
                                                 "--progress",
                                                 "--progress-out:" + progressLog,
                                                 "--root:" + packageRoot,
                                                 "--in:" + source,
                                                 "--emit:exe",
                                                 "--target:" + target,
                                                 "--out:" + outBin
                                             ],
                                             [
                                                 "CHENG_V3_ROOT=" + root,
                                                 "CHENG_V3_PROGRESS=1",
                                                 "CHENG_V3_PROGRESS_OUT=" + progressLog
                                             ],
                                             root,
                                             0,
                                             compileLog)
    assert(compileRun.exitCode == 0, "v3 backend driver selfhost progress: compile rc")
    assert(os.FileExists(outBin), "v3 backend driver selfhost progress: output exists")
    assert(os.FileExists(progressLog), "v3 backend driver selfhost progress: progress log exists")
    let compileText: str = os.ReadFile(compileLog)
    let progressText: str = os.ReadFile(progressLog)
    assert(strings.StrContains(progressText, "compile_progress phase=system_link_plan status=done"),
           "v3 backend driver selfhost progress: system_link_plan progress")
    assert(strings.StrContains(progressText, "compile_progress phase=source_bundle status=done"),
           "v3 backend driver selfhost progress: source_bundle progress")
    assert(strings.StrContains(progressText, "compile_progress phase=compiler_csg status=done"),
           "v3 backend driver selfhost progress: compiler_csg progress")
    assert(strings.StrContains(progressText, "compile_progress phase=world status=done"),
           "v3 backend driver selfhost progress: world progress")
    assert(strings.StrContains(progressText, "compile_progress phase=lowering_plan status=done"),
           "v3 backend driver selfhost progress: lowering_plan progress")
    assert(strings.StrContains(progressText, "compile_progress phase=primary_object_plan status=done"),
           "v3 backend driver selfhost progress: primary_object_plan progress")
    assert(strings.StrContains(progressText, "compile_progress phase=provider_sources status=done"),
           "v3 backend driver selfhost progress: provider_sources progress")
    assert(strings.StrContains(progressText, "compile_progress phase=object_plan status=done"),
           "v3 backend driver selfhost progress: object_plan progress")
    assert(strings.StrContains(progressText, "compile_progress phase=native_link_plan status=done"),
           "v3 backend driver selfhost progress: native_link_plan progress")
    assert(strings.StrContains(progressText, "compile_progress phase=compile_receipt status=done"),
           "v3 backend driver selfhost progress: compile_receipt progress")
    assert(strings.StrContains(progressText, "compile_progress phase=build status=done"),
           "v3 backend driver selfhost progress: build progress")
    assert(!strings.StrContains(compileText, "source_closure_count="),
           "v3 backend driver selfhost progress: no source_closure_count")
    assert(!strings.StrContains(compileText, "native_link_inputs="),
           "v3 backend driver selfhost progress: no native_link_inputs")
    assert(!strings.StrContains(compileText, "primary_object_symbols="),
           "v3 backend driver selfhost progress: no primary_object_symbols")
    assert(!strings.StrContains(compileText, "provider_object_count="),
           "v3 backend driver selfhost progress: no provider_object_count")
    echo("v3 backend_driver_selfhost_progress_smoke ok")
    return 0
