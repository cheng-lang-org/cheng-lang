import std/result
import std/rawbytes
import cheng/v3/tooling/vpn_proxy_socks as vpn

fn testBytes(values: int32[]): Bytes =
    var out: Bytes
    out = bytesAlloc(values.len)
    for i in 0..<values.len:
        bytesSet(out, i, values[i])
    return out

fn main(): int32 =
    var methodReplyRes: Result[Bytes]
    methodReplyRes = vpn.V3VpnProxySocksMethodReplyFor(testBytes([5, 1, 0]))
    assert(!IsErr(methodReplyRes), "v3 vpn proxy socks method ok")
    assert(bytesEqual(Value(methodReplyRes), testBytes([5, 0])),
           "v3 vpn proxy socks method reply")

    var methodRejectRes: Result[Bytes]
    methodRejectRes = vpn.V3VpnProxySocksMethodReplyFor(testBytes([5, 1, 2]))
    assert(IsErr(methodRejectRes), "v3 vpn proxy socks method reject")
    assert(ErrorText(methodRejectRes) == "vpn proxy socks5: no supported auth method",
           "v3 vpn proxy socks method reject text")

    var domainWire: Bytes
    domainWire = bytesConcat3(testBytes([5, 1, 0, 3, 11]),
                              bytesFromString("example.com"),
                              testBytes([1, 187]))
    var domainRes: Result[vpn.V3VpnProxyTarget]
    domainRes = vpn.V3VpnProxySocksParseTargetWire(domainWire)
    assert(!IsErr(domainRes), "v3 vpn proxy socks domain parse")
    var domainTarget: vpn.V3VpnProxyTarget
    domainTarget = Value(domainRes)
    assert(domainTarget.host == "example.com", "v3 vpn proxy socks domain host")
    assert(domainTarget.port == 443, "v3 vpn proxy socks domain port")

    var ipv4Res: Result[vpn.V3VpnProxyTarget]
    ipv4Res = vpn.V3VpnProxySocksParseTargetWire(testBytes([5, 1, 0, 1, 127, 0, 0, 1, 31, 144]))
    assert(!IsErr(ipv4Res), "v3 vpn proxy socks ipv4 parse")
    var ipv4Target: vpn.V3VpnProxyTarget
    ipv4Target = Value(ipv4Res)
    assert(ipv4Target.host == "127.0.0.1", "v3 vpn proxy socks ipv4 host")
    assert(ipv4Target.port == 8080, "v3 vpn proxy socks ipv4 port")

    var bindRes: Result[vpn.V3VpnProxyTarget]
    bindRes = vpn.V3VpnProxySocksParseTargetWire(testBytes([5, 2, 0, 1, 127, 0, 0, 1, 0, 80]))
    assert(IsErr(bindRes), "v3 vpn proxy socks bind reject")
    assert(ErrorText(bindRes) == "vpn proxy socks5: unsupported command",
           "v3 vpn proxy socks bind reject text")

    var atypRes: Result[vpn.V3VpnProxyTarget]
    atypRes = vpn.V3VpnProxySocksParseTargetWire(testBytes([5, 1, 0, 9]))
    assert(IsErr(atypRes), "v3 vpn proxy socks atyp reject")
    assert(ErrorText(atypRes) == "vpn proxy socks5: unsupported address type",
           "v3 vpn proxy socks atyp reject text")

    echo("v3 vpn_proxy_socks_smoke ok")
    return 0
