import std/system
import std/result
import std/rawbytes
import ../std/bytes_layout as layout
import ../std/crypto/fixed256 as fixed256

fn main() =
    let shaDigest: layout.FixedBytes32 = fixed256.sha256Fixed(layout.byteSpanFromBytes(bytesFromString("abc")))
    assert(
        layout.fixedBytes32Hex(shaDigest) ==
        "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad",
        "v3 fixed256: sha256"
    )

    let aliceRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex(
        "77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    assert(IsOk(aliceRes), "v3 fixed256: x25519 alice private")
    let bobRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex(
        "5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    assert(IsOk(bobRes), "v3 fixed256: x25519 bob private")
    let bobPubExpectRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "de9edb7d7b7dc1b4d35b61c2ece435373f8343c85b78674dadfc7e146f882b4f")
    assert(IsOk(bobPubExpectRes), "v3 fixed256: x25519 bob public vector")
    let sharedExpectRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "4a5d9d5ba4ce2de1728e3bf480350f25e07e21c947d19e3376f09b3c1e161742")
    assert(IsOk(sharedExpectRes), "v3 fixed256: x25519 shared vector")
    let alicePubRes: Result[layout.FixedBytes32] = fixed256.curve25519PublicKey(Value(aliceRes))
    assert(IsOk(alicePubRes), "v3 fixed256: x25519 alice public")
    let bobPubRes: Result[layout.FixedBytes32] = fixed256.curve25519PublicKey(Value(bobRes))
    assert(IsOk(bobPubRes), "v3 fixed256: x25519 bob public")
    assert(layout.fixedBytes32Equal(Value(bobPubRes), Value(bobPubExpectRes)), "v3 fixed256: x25519 bob public vector")
    let sharedRes: Result[layout.FixedBytes32] = fixed256.curve25519SharedKeyFixed(Value(aliceRes), Value(bobPubRes))
    assert(IsOk(sharedRes), "v3 fixed256: x25519 shared")
    assert(layout.fixedBytes32Equal(Value(sharedRes), Value(sharedExpectRes)), "v3 fixed256: x25519 shared vector")

    let p256PrivRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex(
        "000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f")
    assert(IsOk(p256PrivRes), "v3 fixed256: p256 private")
    let pubRes: Result[fixed256.PointAffine256] = fixed256.p256PublicKeyAffine(Value(p256PrivRes))
    assert(IsOk(pubRes), "v3 fixed256: p256 public")
    assert(!Value(pubRes).infinity, "v3 fixed256: p256 public infinity")
    let message: layout.ByteSpan = layout.byteSpanFromBytes(bytesFromString("v3 bootstrap keeps C-class hot paths"))
    let sigRes: Result[fixed256.P256Signature256] = fixed256.p256SignMessageFixed(Value(p256PrivRes), message)
    assert(IsOk(sigRes), "v3 fixed256: p256 sign")
    assert(fixed256.p256VerifyMessageFixed(Value(pubRes), message, Value(sigRes)), "v3 fixed256: p256 verify")

    echo("v3 fixed_surface_smoke ok")
