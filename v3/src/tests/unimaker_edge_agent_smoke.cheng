import std/os as os
import std/strutils as strutil
import cheng/v3/tooling/path as v3path
import cheng/v3/std/bytes_layout as layout
import cheng/v3/project/unimaker_edge_types as types
import cheng/v3/project/unimaker_evomap_protocol as proto
import cheng/v3/project/unimaker_edge_agent as agent

fn unimakerSmokeCleanup(tmpRoot: str) =
    let storePath = os.JoinPath(tmpRoot, "agent.did")
    let eventLogPath = os.JoinPath(tmpRoot, "events.jsonl")
    let eventLogTmpPath = eventLogPath + ".tmp"
    if os.FileExists(storePath):
        let _ = os.RemoveFile(storePath)
    if os.FileExists(eventLogPath):
        let _ = os.RemoveFile(eventLogPath)
    if os.FileExists(eventLogTmpPath):
        let _ = os.RemoveFile(eventLogTmpPath)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

fn main(): int32 =
    let tmpRoot = "artifacts/v3_unimaker_edge_agent_smoke"
    unimakerSmokeCleanup(tmpRoot)
    os.CreateDir(tmpRoot)

    var cfg = types.v3UnimakerConfigZero()
    cfg.rootDir = v3path.V3PathCurrentDir()
    cfg.eventLogPath = os.JoinPath(tmpRoot, "events.jsonl")
    cfg.identityStorePath = os.JoinPath(tmpRoot, "agent.did")
    cfg.rootSeedHint = "unimaker.root.seed"
    cfg.deviceSeedHint = "unimaker.phone.seed"
    cfg.deviceLabelHint = "phone"
    cfg.epochSeconds = int64(1710000000)

    var edge = agent.v3UnimakerAgentInit(cfg)
    assert(agent.v3UnimakerAgentCapsuleCount(edge) == 0, "v3 unimaker smoke: init capsule count")
    assert(agent.v3UnimakerAgentNodeCount(edge) == 0, "v3 unimaker smoke: init node count")
    assert(edge.identity.didText != "", "v3 unimaker smoke: did text")
    assert(edge.identity.peerIdText != "", "v3 unimaker smoke: peer text")

    let eventA = types.v3UnimakerEventMake(types.v3UnimakerEventUserInput,
                                           "task.alpha",
                                           "translate invoice title",
                                           ["invoice", "translate"],
                                           [],
                                           types.v3UnimakerEdgeKindCausedBy,
                                           int64(1710000001))
    let capsuleARes = agent.v3UnimakerAgentIngest(edge, eventA)
    assert(IsOk(capsuleARes), "v3 unimaker smoke: ingest A")
    let capsuleA = Value(capsuleARes)

    let eventB = types.v3UnimakerEventMake(types.v3UnimakerEventToolResult,
                                           "task.alpha",
                                           "translated invoice title to chinese",
                                           ["invoice", "translated"],
                                           [capsuleA.capsuleCid],
                                           types.v3UnimakerEdgeKindRefines,
                                           int64(1710000002))
    let capsuleBRes = agent.v3UnimakerAgentIngest(edge, eventB)
    assert(IsOk(capsuleBRes), "v3 unimaker smoke: ingest B")
    let capsuleB = Value(capsuleBRes)

    assert(agent.v3UnimakerAgentCapsuleCount(edge) == 2, "v3 unimaker smoke: capsule count")
    assert(agent.v3UnimakerAgentNodeCount(edge) == 2, "v3 unimaker smoke: node count")
    assert(agent.v3UnimakerAgentEdgeCount(edge) == 3, "v3 unimaker smoke: edge count")

    var queryTask = types.v3UnimakerMemoryQueryZero()
    queryTask.taskId = "task.alpha"
    queryTask.limit = 8
    let taskHitsRes = agent.v3UnimakerAgentRecall(edge, queryTask)
    assert(IsOk(taskHitsRes), "v3 unimaker smoke: recall task")
    assert(Value(taskHitsRes).len == 2, "v3 unimaker smoke: recall task count")

    var queryKeyword = types.v3UnimakerMemoryQueryZero()
    queryKeyword.keyword = "translated"
    queryKeyword.limit = 8
    let keywordHitsRes = agent.v3UnimakerAgentRecall(edge, queryKeyword)
    assert(IsOk(keywordHitsRes), "v3 unimaker smoke: recall keyword")
    let keywordHits = Value(keywordHitsRes)
    assert(keywordHits.len == 1, "v3 unimaker smoke: recall keyword count")
    let keywordCid = keywordHits[0].capsule.capsuleCid
    assert(layout.fixedBytes32Equal(keywordCid, capsuleB.capsuleCid),
        "v3 unimaker smoke: recall keyword cid")

    var queryParent = types.v3UnimakerMemoryQueryZero()
    queryParent.parentCid = capsuleA.capsuleCid
    queryParent.hasParent = true
    queryParent.limit = 8
    let parentHitsRes = agent.v3UnimakerAgentRecall(edge, queryParent)
    assert(IsOk(parentHitsRes), "v3 unimaker smoke: recall parent")
    let parentHits = Value(parentHitsRes)
    assert(parentHits.len == 1, "v3 unimaker smoke: recall parent count")
    let parentCid = parentHits[0].capsule.capsuleCid
    assert(layout.fixedBytes32Equal(parentCid, capsuleB.capsuleCid),
        "v3 unimaker smoke: recall parent cid")

    var task = types.v3UnimakerAgentTaskZero()
    task.taskId = "task.alpha"
    task.promptText = "continue translation"
    var taskKeywords: str[]
    add(taskKeywords, "invoice")
    add(taskKeywords, "translated")
    task.keywords = taskKeywords
    let planRes = agent.v3UnimakerAgentPlan(edge, task)
    assert(IsOk(planRes), "v3 unimaker smoke: plan")
    let plan = Value(planRes)
    assert(plan.actionKind == types.v3UnimakerPlanActionReuseMemory, "v3 unimaker smoke: plan action")
    assert(plan.memoryHitCount == 2, "v3 unimaker smoke: plan hit count")
    assert(plan.selectedCapsuleCids.len >= 1, "v3 unimaker smoke: plan selected")

    let helloPayload = agent.v3UnimakerAgentHelloPayload(edge)
    let helloRes = proto.v3UnimakerProtocolDecodeHello(helloPayload)
    assert(IsOk(helloRes), "v3 unimaker smoke: decode hello")
    assert(Value(helloRes).identity.didText == edge.identity.didText, "v3 unimaker smoke: hello did")
    assert(Value(helloRes).genes.len == edge.genes.len, "v3 unimaker smoke: hello genes")

    var taskWire = proto.v3UnimakerProtocolTaskZero()
    taskWire.requesterPeerIdText = edge.identity.peerIdText
    taskWire.task = task
    var contextCapsuleCids: layout.FixedBytes32[]
    add(contextCapsuleCids, capsuleA.capsuleCid)
    add(contextCapsuleCids, capsuleB.capsuleCid)
    taskWire.contextCapsuleCids = contextCapsuleCids
    let taskPayload = proto.v3UnimakerProtocolEncodeTask(taskWire)
    let taskDecodeRes = proto.v3UnimakerProtocolDecodeTask(taskPayload)
    assert(IsOk(taskDecodeRes), "v3 unimaker smoke: decode task")
    assert(Value(taskDecodeRes).task.taskId == task.taskId, "v3 unimaker smoke: task id")
    assert(Value(taskDecodeRes).contextCapsuleCids.len == 2, "v3 unimaker smoke: task context count")

    let resultPayload = agent.v3UnimakerAgentResultPayload(edge, plan)
    let resultRes = proto.v3UnimakerProtocolDecodeResult(resultPayload)
    assert(IsOk(resultRes), "v3 unimaker smoke: decode result")
    assert(Value(resultRes).taskId == task.taskId, "v3 unimaker smoke: result task id")
    assert(Value(resultRes).memoryHitCount == 2, "v3 unimaker smoke: result hit count")

    var peer = types.v3UnimakerSyncPeerZero()
    peer.peerIdText = "peer.remote"
    peer.transportKind = types.v3UnimakerTransportHttpJson
    peer.trusted = true
    let pushRes = agent.v3UnimakerAgentSyncPush(edge, peer)
    assert(IsOk(pushRes), "v3 unimaker smoke: sync push")
    assert(Value(pushRes).pushedCount == 2, "v3 unimaker smoke: sync push count")
    let pushDecodeRes = proto.v3UnimakerProtocolDecodePush(peer.outboundPushPayload)
    assert(IsOk(pushDecodeRes), "v3 unimaker smoke: decode push")
    assert(Value(pushDecodeRes).capsules.len == 2, "v3 unimaker smoke: push capsule count")

    let badHelloPayload = strutil.Replace(helloPayload, "\"version\":1", "\"version\":2")
    let badHelloRes = proto.v3UnimakerProtocolDecodeHello(badHelloPayload)
    assert(IsErr(badHelloRes), "v3 unimaker smoke: bad hello version")

    let badPushPayload = strutil.Replace(peer.outboundPushPayload,
                                         layout.fixedBytes32Hex(capsuleA.capsuleCid),
                                         layout.fixedBytes32Hex(layout.fixedBytes32Zero()))
    let badPushRes = proto.v3UnimakerProtocolDecodePush(badPushPayload)
    assert(IsErr(badPushRes), "v3 unimaker smoke: bad push cid")

    unimakerSmokeCleanup(tmpRoot)
    echo("v3 unimaker_edge_agent_smoke ok")
    return 0
