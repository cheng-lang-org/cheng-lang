import std/system
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server = node.v3ChainNodeInit("node-a", "chain-node-a")
    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node transfer copy index: mint")

    var nextIndex = server.index
    assert(nextIndex.accountIds.len == 1, "v3 chain_node transfer copy index: next account len")
    assert(nextIndex.balances.len == 1, "v3 chain_node transfer copy index: next balance len")
    assert(node.v3ChainNodeBalanceValue(server.index, 7, 1001) == int64(100),
           "v3 chain_node transfer copy index: server sender 100")
    assert(nextIndex.accountIds[0] == 1001, "v3 chain_node transfer copy index: account id")
    assert(nextIndex.balances[0] == int64(100), "v3 chain_node transfer copy index: balance")
    echo("v3 chain_node_transfer_copy_index_smoke ok")
    return 0
