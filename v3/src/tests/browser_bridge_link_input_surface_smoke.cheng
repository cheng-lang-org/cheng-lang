import std/os
import std/strutils as strutil
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path
import cheng/v3/backend/system_link_exec as sexec

fn containsText(text: str, needle: str): bool =
    return strutil.Contains(text, needle)

fn browserBridgeSmokeDriver(root: str): str =
    let envDriver = strutil.Strip(os.GetEnv("CHENG_V3_BROWSER_BRIDGE_DRIVER"))
    if len(envDriver) > 0:
        return v3path.V3PathAbsolute(root, envDriver)
    let freshDriver = v3path.V3PathAbsolute(root, "artifacts/v3_bootstrap/cheng.stage3.bridge_object")
    if v3path.V3FileExistsNonEmpty(root, freshDriver):
        return freshDriver
    let livefullDriver = v3path.V3PathAbsolute(root, "artifacts/v3_bootstrap/cheng.stage3.livefull")
    if v3path.V3FileExistsNonEmpty(root, livefullDriver):
        return livefullDriver
    let stage3Driver = v3path.V3PathAbsolute(root, "artifacts/v3_bootstrap/cheng.stage3")
    if v3path.V3FileExistsNonEmpty(root, stage3Driver):
        return stage3Driver
    return v3path.V3PathAbsolute(root, "artifacts/v3_backend_driver/cheng")

fn main(): int32 =
    let root = os.GetCurrentDir()
    let smokeLabel = os.GetEnvDefault("CHENG_V3_SMOKE_LABEL", "host")
    let driver = browserBridgeSmokeDriver(root)
    let packageRoot = v3path.V3PathAbsolute(root, "v3")
    let source = v3path.V3PathAbsolute(root, "v3/src/tests/browser_host_native_min_smoke.cheng")
    let manualBridgeFixtureSource = v3path.V3PathAbsolute(root,
                                                          "v3/src/tests/browser_bridge_manual_link_input_fixture.cheng")
    let outDir = v3path.V3PathAbsolute(root, "artifacts/v3_browser_bridge_link_input_surface/" + smokeLabel)
    let outBin = v3path.V3PathJoin(outDir, "browser_host_native_min_smoke")
    let reportPath = outBin + ".report.txt"
    let compileLog = outBin + ".compile.log"
    let bridgeArtifactPath = outBin + ".browser_bridge_plan.txt"
    let bridgeSourcePath = outBin + ".browser_bridge.generated.cheng"
    let bridgePlanObjectPath = outBin + ".browser_bridge.generated.o"
    let manualBridgeObjectPath = outBin + ".manual.browser_bridge.generated.o"
    let manualBridgeCompileLog = manualBridgeObjectPath + ".compile.log"
    let runLog = outBin + ".run.log"
    let req = creq.v3CompilerRequestNew(packageRoot,
                                        source,
                                        outBin,
                                        "arm64-apple-darwin",
                                        creq.v3EmitExe,
                                        reportPath)
    let planRes = sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(root,
                                                                     req,
                                                                     "",
                                                                     "",
                                                                     "",
                                                                     "stable")
    assert(IsOk(planRes), "v3 browser bridge link input: build plan")
    let plan = Value(planRes)
    let planReportText = sexec.v3SystemLinkExecPlanReport(plan)
    assert(v3path.V3MkdirP(root, outDir), "v3 browser bridge link input: mkdir")
    if v3path.V3PathFileExists(outBin):
        os.RemoveFile(outBin)
    if v3path.V3PathFileExists(reportPath):
        os.RemoveFile(reportPath)
    if v3path.V3PathFileExists(bridgeArtifactPath):
        os.RemoveFile(bridgeArtifactPath)
    if v3path.V3PathFileExists(bridgeSourcePath):
        os.RemoveFile(bridgeSourcePath)
    if v3path.V3PathFileExists(bridgePlanObjectPath):
        os.RemoveFile(bridgePlanObjectPath)
    if v3path.V3PathFileExists(manualBridgeObjectPath):
        os.RemoveFile(manualBridgeObjectPath)
    assert(containsText(planReportText, "browser_bridge_object_path=" + bridgePlanObjectPath),
           "v3 browser bridge link input: plan object path")
    assert(containsText(planReportText, "browser_bridge_object_count=1"),
           "v3 browser bridge link input: plan object count")
    assert(containsText(planReportText, "browser_bridge_plan_count=4"),
           "v3 browser bridge link input: plan bridge count")
    assert(sexec.v3SystemLinkExecWriteBrowserBridgeArtifact(root, plan),
           "v3 browser bridge link input: write artifact")
    assert(sexec.v3SystemLinkExecWriteBrowserBridgeSource(root, plan),
           "v3 browser bridge link input: write source")
    assert(v3path.V3FileExistsNonEmpty(root, bridgeArtifactPath),
           "v3 browser bridge link input: plan exists")
    assert(v3path.V3FileExistsNonEmpty(root, bridgeSourcePath),
           "v3 browser bridge link input: source exists")
    let bridgeArtifactText = v3path.V3ReadTextFile("", bridgeArtifactPath)
    assert(containsText(bridgeArtifactText, "bridge_count=4"),
           "v3 browser bridge link input: artifact bridge count")
    let bridgeCompileRun = hostops.v3RunFileLogged(root,
                                                   "browser_bridge_link_input_surface_bridge_object",
                                                   driver,
                                                   [
                                                       "system-link-exec",
                                                       "--root:" + packageRoot,
                                                       "--in:" + manualBridgeFixtureSource,
                                                       "--emit:obj",
                                                       "--target:arm64-apple-darwin",
                                                       "--symbol-visibility:" + creq.v3CompilerSymbolVisibilityInternal(),
                                                       "--out:" + manualBridgeObjectPath
                                                   ],
                                                   ["CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"],
                                                   root,
                                                   0,
                                                   manualBridgeCompileLog)
    assert(hostops.v3LoggedRunOk(bridgeCompileRun), "v3 browser bridge link input: bridge object rc")
    assert(v3path.V3FileExistsNonEmpty(root, manualBridgeObjectPath),
           "v3 browser bridge link input: manual object exists")
    let compileRun = hostops.v3RunFileLogged(root,
                                             "browser_bridge_link_input_surface_build",
                                             driver,
                                             [
                                                 "system-link-exec",
                                                 "--root:" + packageRoot,
                                                 "--in:" + source,
                                                 "--emit:exe",
                                                 "--target:arm64-apple-darwin",
                                                 "--out:" + outBin,
                                                 "--report-out:" + reportPath,
                                                 "--link-input:" + manualBridgeObjectPath
                                             ],
                                             ["CHENG_V3_NO_BACKEND_DRIVER_HANDOFF=1"],
                                             root,
                                             0,
                                             compileLog)
    assert(hostops.v3LoggedRunOk(compileRun), "v3 browser bridge link input: compile rc")
    assert(v3path.V3FileExistsNonEmpty(root, outBin), "v3 browser bridge link input: output exists")
    assert(v3path.V3FileExistsNonEmpty(root, reportPath), "v3 browser bridge link input: report exists")
    let reportText = v3path.V3ReadTextFile("", reportPath)
    assert(containsText(reportText, "extra_link_input=" + manualBridgeObjectPath),
           "v3 browser bridge link input: extra link input")
    assert(containsText(reportText, "browser_bridge_object=" + bridgePlanObjectPath),
           "v3 browser bridge link input: compiler-owned object field")
    assert(containsText(reportText, "object_link_inputs="), "v3 browser bridge link input: object inputs")
    assert(containsText(reportText, manualBridgeObjectPath), "v3 browser bridge link input: object listed")
    assert(containsText(reportText, bridgePlanObjectPath), "v3 browser bridge link input: internal object listed")
    assert(containsText(reportText, "native_link_inputs="), "v3 browser bridge link input: native inputs")
    let run = hostops.v3RunFileLogged(root,
                                      "browser_bridge_link_input_surface_run",
                                      outBin,
                                      [],
                                      [],
                                      root,
                                      0,
                                      runLog)
    assert(hostops.v3LoggedRunOk(run), "v3 browser bridge link input: run rc")
    assert(containsText(run.output, "v3 browser host wasm smoke: ok"),
           "v3 browser bridge link input: runtime output")
    echo("v3 browser_bridge_link_input_surface_smoke ok")
    return 0
