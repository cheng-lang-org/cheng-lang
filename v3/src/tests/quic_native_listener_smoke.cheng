import std/system
import std/rawbytes
import cheng/v3/quic/multiaddress as qaddr
import cheng/v3/quic/msquicruntime as qruntime
import cheng/v3/quic/native_runtime as qnative

fn main(): int32 =
    let addr = qaddr.makeInprocMultiAddress(qaddr.quicAddrKindMsQuic, 6210)
    let settings = qruntime.initMsQuicSettings()
    let certDer: Bytes = qnative.msquicNativeSeededBytes(17)
    let keyDer: Bytes = qnative.msquicNativeSeededBytes(29)
    let listenerId = qnative.msquicNativeStartListenerServerInputsCode(addr, settings, "localhost", certDer, keyDer)
    if listenerId == -1:
        panic("msquic tls policy: serverName missing")
    if listenerId == -2:
        panic("msquic tls policy: certificate missing")
    if listenerId == -3:
        panic("msquic tls policy: private key missing")
    if listenerId == -4:
        panic("msquic native: listener datapath add failed")
    if listenerId == -5:
        panic("msquic native: listener datapath start failed")
    if listenerId == -6:
        panic("msquic native: listener bind failed")
    assert(listenerId > 0, "msquic native: listener start failed")
    let _listenerId = listenerId
    let bound = qnative.msquicNativeListenerBoundAddr()
    assert(qaddr.quicMultiAddressKind(bound) == qaddr.quicAddrKindMsQuic, "v3 quic native listener: bound kind")
    assert(qaddr.quicMultiAddressPort(bound) == 6210, "v3 quic native listener: bound port")
    qnative.msquicNativeStopListener()

    echo("v3 quic_native_listener_smoke ok")
    return 0
