import std/system
import std/strings
import cheng/v3/libp2p/mobile/mobile_capi as capi
import cheng/v3/libp2p/mobile/android_bridge as mobile

fn main(): int32 =
    let selfPeer = capi.v3MobileCapiPeerIdFromSeed("mobile.bridge.self")
    assert(len(selfPeer) > 0, "v3 mobile bridge: self peer")
    assert(capi.v3MobileCapiMultiaddrNormalize("/ip4/127.0.0.1/tcp/9001") == "/ip4/127.0.0.1/tcp/9001",
        "v3 mobile bridge: normalize addr")
    assert(capi.v3MobileCapiMultiaddrNormalize("not-a-multiaddr") == "",
        "v3 mobile bridge: reject bad addr")
    let capiDialable = capi.v3MobileCapiDialableAddr("/ip4/127.0.0.1/tcp/9001", selfPeer)
    assert(strContains(capiDialable, "/ip4/127.0.0.1/tcp/9001"),
        "v3 mobile bridge: capi dialable base")
    assert(strContains(capiDialable, "/p2p/"),
        "v3 mobile bridge: capi dialable peer suffix")

    var host = mobile.v3MobileHostInit("mobile.bridge.self")
    assert(mobile.v3MobileHostPeerIdText(host) == selfPeer,
        "v3 mobile bridge: host peer id")
    assert(!mobile.v3MobileHostIsStarted(host),
        "v3 mobile bridge: init stopped")

    mobile.v3MobileHostStart(host)
    mobile.v3MobileHostSetMdnsEnabled(host, true)
    mobile.v3MobileHostSetMdnsInterval(host, 9)
    mobile.v3MobileHostSetTrustedInfra(host, true)
    assert(mobile.v3MobileHostIsStarted(host),
        "v3 mobile bridge: started")
    assert(mobile.v3MobileHostMdnsEnabled(host),
        "v3 mobile bridge: mdns enabled")
    assert(mobile.v3MobileHostMdnsInterval(host) == 9,
        "v3 mobile bridge: mdns interval")
    assert(mobile.v3MobileHostTrustedInfra(host),
        "v3 mobile bridge: trusted infra")

    let listenRes = mobile.v3MobileHostListenAddText(host, "/ip4/127.0.0.1/tcp/9001")
    assert(IsOk(listenRes), "v3 mobile bridge: listen add")
    assert(mobile.v3MobileHostListenAddrCount(host) == 1,
        "v3 mobile bridge: listen count")
    let listenDialable = mobile.v3MobileHostDialableAddrTextAt(host, 0)
    assert(strContains(listenDialable, "/ip4/127.0.0.1/tcp/9001"),
        "v3 mobile bridge: listen dialable base")
    assert(strContains(listenDialable, "/p2p/"),
        "v3 mobile bridge: listen dialable peer suffix")

    let bootstrapPeer = capi.v3MobileCapiPeerIdFromSeed("mobile.bridge.bootstrap")
    let bootstrapRes = mobile.v3MobileHostRegisterPeerHintText(host,
                                                               bootstrapPeer,
                                                               "/ip4/100.64.0.7/tcp/9101",
                                                               0,
                                                               true,
                                                               true)
    assert(IsOk(bootstrapRes), "v3 mobile bridge: bootstrap register")
    assert(mobile.v3MobileHostPeerCount(host) == 1,
        "v3 mobile bridge: peer count")
    assert(mobile.v3MobileHostBootstrapPeerCount(host) == 1,
        "v3 mobile bridge: bootstrap count")
    let bootstrapPeerText = mobile.v3MobileHostBootstrapPeerTextAt(host, 0)
    assert(len(bootstrapPeerText) > 0,
        "v3 mobile bridge: bootstrap text")
    assert(mobile.v3MobileHostPeerAddrCountText(host, bootstrapPeer) == 1,
        "v3 mobile bridge: peer addr count")
    assert(mobile.v3MobileHostPeerAddrTextAt(host, bootstrapPeer, 0) == "/ip4/100.64.0.7/tcp/9101",
        "v3 mobile bridge: peer addr text")
    let bootstrapDialable = mobile.v3MobileHostPeerDialableAddrTextAt(host, bootstrapPeer, 0)
    assert(strContains(bootstrapDialable, "/ip4/100.64.0.7/tcp/9101"),
        "v3 mobile bridge: peer dialable base")
    assert(strContains(bootstrapDialable, "/p2p/"),
        "v3 mobile bridge: peer dialable peer suffix")

    let connectRes = mobile.v3MobileHostConnectRegisteredText(host, bootstrapPeer)
    assert(IsOk(connectRes), "v3 mobile bridge: connect bootstrap")
    assert(mobile.v3MobileHostIsPeerConnectedText(host, bootstrapPeer),
        "v3 mobile bridge: connected")
    assert(mobile.v3MobileHostConnectedPeerCount(host) == 1,
        "v3 mobile bridge: connected count")
    let connectedPeerText = mobile.v3MobileHostConnectedPeerTextAt(host, 0)
    assert(len(connectedPeerText) > 0,
        "v3 mobile bridge: connected peer text")

    assert(mobile.v3MobileHostDisconnectText(host, bootstrapPeer),
        "v3 mobile bridge: disconnect")
    assert(!mobile.v3MobileHostIsPeerConnectedText(host, bootstrapPeer),
        "v3 mobile bridge: disconnected")
    assert(mobile.v3MobileHostReconnectBootstrap(host) == 1,
        "v3 mobile bridge: reconnect bootstrap")
    assert(mobile.v3MobileHostIsPeerConnectedText(host, bootstrapPeer),
        "v3 mobile bridge: reconnect restored")

    let adhocPeer = capi.v3MobileCapiPeerIdFromSeed("mobile.bridge.adhoc")
    let adhocRes = mobile.v3MobileHostConnectPreferredText(host,
                                                           adhocPeer,
                                                           "/ip4/127.0.0.1/tcp/9202")
    assert(IsOk(adhocRes), "v3 mobile bridge: adhoc connect")
    assert(mobile.v3MobileHostPeerCount(host) == 2,
        "v3 mobile bridge: adhoc peer count")
    let adhocDialable = mobile.v3MobileHostPeerDialableAddrTextAt(host, adhocPeer, 0)
    assert(strContains(adhocDialable, "/ip4/127.0.0.1/tcp/9202"),
        "v3 mobile bridge: adhoc dialable base")
    assert(strContains(adhocDialable, "/p2p/"),
        "v3 mobile bridge: adhoc dialable peer suffix")

    mobile.v3MobileHostStop(host)
    assert(!mobile.v3MobileHostIsStarted(host),
        "v3 mobile bridge: stopped")

    echo("v3 mobile_bridge_smoke ok")
    return 0
