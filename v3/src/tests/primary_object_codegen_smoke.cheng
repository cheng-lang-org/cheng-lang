import std/os
import std/system
import std/result
import std/strutils as strutil
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/backend/lowering_plan as lower
import cheng/v3/backend/primary_object_plan as pobj

fn main(): int32 =
    let rootDir = os.GetCurrentDir()
    let req = creq.v3CompilerRequestNew(
        os.JoinPath(rootDir, "v3"),
        os.JoinPath(rootDir, "v3/src/tests/ordinary_zero_exit_fixture.cheng"),
        os.JoinPath(rootDir, "artifacts/v3_zero_exit/ordinary_zero_exit_fixture"),
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(rootDir, req, linkPlan, err), "v3 primary object codegen smoke: link plan")
    var loweringPlan: lower.V3LoweringPlanStub
    assert(lower.v3BuildLoweringPlanStub(linkPlan, loweringPlan, err), "v3 primary object codegen smoke: lowering plan")
    let primaryRes = pobj.v3BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    assert(IsOk(primaryRes), "v3 primary object codegen smoke: primary object plan")
    let primary = Value(primaryRes)
    assert(primary.missingReasons.len == 0, "v3 primary object codegen smoke: missing reasons cleared")
    assert(primary.symbolNames.len == 2, "v3 primary object codegen smoke: symbol count")
    assert(strutil.Contains(primary.symbolNames[0], "main"),
           "v3 primary object codegen smoke: entry function symbol")
    assert(primary.symbolNames[1] == "_cheng_v3_program_argv_entry",
           "v3 primary object codegen smoke: argv bridge symbol")
    assert(primary.instructionWords.len == 3, "v3 primary object codegen smoke: three words")
    assert(primary.functionWordCounts[0] == 2, "v3 primary object codegen smoke: function word count")
    echo("v3 primary_object_codegen_smoke ok")
    return 0
