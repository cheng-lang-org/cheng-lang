import std/os
import cheng/v3/lang/parser
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let root = os.GetCurrentDir()
    let fixturePath = v3path.V3PathJoin(root, "v3/src/tests/parser_normalized_expr_fixture.cheng")
    var layer = parser.v3NormalizedExprLayerZero()
    var err = ""
    assert(parser.v3ParserReadNormalizedExprLayerFromPath(fixturePath, layer, err),
           "v3 parser normalized expr: read layer")
    assert(layer.sourceCount == 1, "v3 parser normalized expr: source count")
    assert(parser.v3NormalizedExprLayerExprCount(layer) == 17, "v3 parser normalized expr: expr count")
    assert(parser.v3NormalizedExprLayerIfCount(layer) == 4, "v3 parser normalized expr: if count")
    assert(parser.v3NormalizedExprLayerRangeCount(layer) == 2, "v3 parser normalized expr: range count")
    assert(parser.v3NormalizedExprLayerComprehensionCount(layer) == 1, "v3 parser normalized expr: comprehension count")
    assert(parser.v3NormalizedExprLayerStrFormatCount(layer) == 3, "v3 parser normalized expr: fmt count")
    assert(parser.v3NormalizedExprLayerResultIntrinsicCount(layer) == 3, "v3 parser normalized expr: result intrinsic count")
    assert(parser.v3NormalizedExprLayerCallCount(layer) == 3, "v3 parser normalized expr: call count")
    assert(parser.v3NormalizedExprLayerTryCount(layer) == 1, "v3 parser normalized expr: try count")
    assert(layer.questionResidualCount == 0, "v3 parser normalized expr: question normalized")
    assert(layer.exprs[0].exprId != "", "v3 parser normalized expr: expr id")
    assert(layer.exprs[0].endLineNumber == layer.exprs[0].lineNumber, "v3 parser normalized expr: same line span")
    assert(layer.exprs[0].endColumnNumber >= layer.exprs[0].columnNumber, "v3 parser normalized expr: end column")
    assert(parser.v3NormalizedExprLayerHasExpr(layer, parser.v3NormalizedExprIf, "ternary", 7),
           "v3 parser normalized expr: ternary normalized to if")
    assert(parser.v3NormalizedExprLayerHasExpr(layer, parser.v3NormalizedExprTry, "postfix_question", 10),
           "v3 parser normalized expr: postfix question normalized")
    assert(parser.v3NormalizedExprLayerHasExpr(layer, parser.v3NormalizedExprRange, "exclusive", 11),
           "v3 parser normalized expr: exclusive range")
    assert(parser.v3NormalizedExprLayerHasExpr(layer, parser.v3NormalizedExprComprehension, "list_comprehension", 14),
           "v3 parser normalized expr: comprehension")
    assert(parser.v3NormalizedExprLayerHasExpr(layer, parser.v3NormalizedExprResultIntrinsic, "err", 19),
           "v3 parser normalized expr: result intrinsic")
    assert(parser.v3NormalizedExprLayerHasExpr(layer, parser.v3NormalizedExprCall, "importc_call", 16),
           "v3 parser normalized expr: importc call")
    assert(parser.v3NormalizedExprLayerHasExpr(layer, parser.v3NormalizedExprCall, "local_call", 17),
           "v3 parser normalized expr: local call")
    assert(parser.v3NormalizedExprLayerHasExpr(layer, parser.v3NormalizedExprCall, "member_call", 18),
           "v3 parser normalized expr: member call")
    var sawMemberReason = false
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].kind != parser.v3NormalizedExprCall:
            continue
        if layer.exprs[i].lineNumber != 18:
            continue
        if parser.v3ParserCallExprDetailKind(layer.exprs[i].detail) != "member_call":
            continue
        assert(!parser.v3ParserCallExprDetailResolved(layer.exprs[i].detail),
               "v3 parser normalized expr: member call unresolved")
        assert(parser.v3ParserCallExprDetailReason(layer.exprs[i].detail) == "unknown_qualified_target",
               "v3 parser normalized expr: member call reason")
        sawMemberReason = true
    assert(sawMemberReason, "v3 parser normalized expr: saw member call reason")
    echo("v3 parser_normalized_expr_smoke ok")
    return 0
