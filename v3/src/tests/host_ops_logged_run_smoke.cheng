import std/os
import std/strutils as strutil
import cheng/v3/tooling/host_ops as hostops
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let root: str = os.getCurrentDir()
    let logPath: str = "/tmp/cheng_v3_host_ops_logged_run_smoke.log"
    if v3path.v3PathFileExists(logPath):
        os.removeFile(logPath)
    let run: hostops.V3LoggedRun = hostops.v3RunFileLogged(root,
                                                           "logged_probe",
                                                           "/bin/echo",
                                                           ["logged-ok"],
                                                           [],
                                                           root,
                                                           5,
                                                           logPath)
    assert(hostops.v3LoggedRunOk(run), "v3 host_ops logged run rc")
    assert(run.label == "logged_probe", "v3 host_ops logged run label")
    assert(run.filePath == "/bin/echo", "v3 host_ops logged run file")
    assert(run.logPath == logPath, "v3 host_ops logged run log")
    assert(run.exitCode == 0, "v3 host_ops logged run exitCode")
    assert(strutil.strip(run.output) == "logged-ok", "v3 host_ops logged run output")
    assert(v3path.v3FileExistsNonEmpty(root, logPath), "v3 host_ops logged run log exists")
    assert(strutil.strip(v3path.v3ReadTextFile("", logPath)) == "logged-ok",
           "v3 host_ops logged run log text")
    echo("v3 host_ops_logged_run_smoke ok")
    return 0
