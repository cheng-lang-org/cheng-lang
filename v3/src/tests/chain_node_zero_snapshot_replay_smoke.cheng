import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/anti_entropy as anti
import cheng/v3/project/chain_node as node
import cheng/v3/project/chain_node_libp2p as net

fn main(): int32 =
    var server = node.v3ChainNodeInit("node-a", "chain-node-a")
    let served = node.v3ChainNodeServeOnce(server)
    let payload = net.v3ChainNodeLibp2pEncodeSnapshot(served)
    let decodedRes = net.v3ChainNodeLibp2pDecodeSnapshot(payload)
    assert(decodedRes.ok, "v3 chain_node zero snapshot: decode")
    let replayRes = node.v3ChainNodeReplayFromSnapshot("node-a", served.address, decodedRes.value)
    assert(replayRes.ok, "v3 chain_node zero snapshot: replay")
    let replayed = replayRes.value
    let replayedSnapshot = node.v3ChainNodeServeOnce(replayed)
    assert(layout.fixedBytes32Equal(served.forest.forestCid, replayedSnapshot.forest.forestCid),
        "v3 chain_node zero snapshot: forest cid")
    assert(anti.v3AntiEntropySignatureEqual(served.signature, replayedSnapshot.signature),
        "v3 chain_node zero snapshot: signature")
    assert(replayedSnapshot.nodeId == "node-a", "v3 chain_node zero snapshot: node id")
    echo("v3 chain_node_zero_snapshot_replay_smoke ok")
    return 0
