import std/system
import std/cmdline as cmdline
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/anti_entropy as anti
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/transports/quic_transport
import cheng/v3/project/chain_node as node
import cheng/v3/project/chain_node_libp2p as net

fn main(): int32 =
    var port = cmdline.readInt32FlagOrDefault("--port", -1)
    assert(port > 0, "v3 libp2p quic twoproc: client port")
    var client = node.v3ChainNodeInit("quic.twoproc.client", "quic.twoproc")
    var recvRes = quic_transport.v3Libp2pQuicRecvPayloadOnce("127.0.0.1",
                                                             port,
                                                             types.v3Libp2pProtocolSync)
    assert(recvRes.ok, "v3 libp2p quic twoproc: client recv")
    var snapshotRes = net.v3ChainNodeLibp2pDecodeSnapshot(recvRes.value)
    assert(snapshotRes.ok, "v3 libp2p quic twoproc: client decode")
    var syncRes = node.v3ChainNodeSyncOnce(client, snapshotRes.value)
    assert(syncRes.ok, "v3 libp2p quic twoproc: client sync")
    assert(syncRes.value, "v3 libp2p quic twoproc: client changed")
    var aliceRes = node.v3ChainNodeBalance(client, 9, 1001)
    var bobRes = node.v3ChainNodeBalance(client, 9, 2002)
    assert(aliceRes.ok, "v3 libp2p quic twoproc: client alice")
    assert(bobRes.ok, "v3 libp2p quic twoproc: client bob")
    assert(aliceRes.value == int64(55), "v3 libp2p quic twoproc: alice 55")
    assert(bobRes.value == int64(33), "v3 libp2p quic twoproc: bob 33")
    var clientSnapshot = node.v3ChainNodeServeOnce(client)
    assert(layout.fixedBytes32Equal(clientSnapshot.tipEventCid, snapshotRes.value.tipEventCid),
        "v3 libp2p quic twoproc: tip cid")
    assert(layout.fixedBytes32Equal(clientSnapshot.forest.forestCid, snapshotRes.value.forest.forestCid),
        "v3 libp2p quic twoproc: forest cid")
    assert(anti.v3AntiEntropySignatureEqual(clientSnapshot.signature, snapshotRes.value.signature),
        "v3 libp2p quic twoproc: signature")
    echo("v3 libp2p_quic_twoproc_client ok")
    return 0
