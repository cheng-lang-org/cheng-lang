import std/system
import cheng/v3/chain/consensus as consensus
import cheng/v3/project/chain_node as node

fn main(): int32 =
    var server = node.v3ChainNodeInit("node-a", "chain-node-a")
    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node append event: mint")

    let fromParentCid = node.v3ChainNodeAccountHead(server.index, 7, 1001)
    let toParentCid = node.v3ChainNodeAccountHead(server.index, 7, 2002)
    var event: consensus.V3ChainEvent
    event.version = 1
    event.kind = consensus.v3ConsensusKindTransferCommit
    event.assetId = 7
    event.fromAccount = 1001
    event.toAccount = 2002
    event.fromParentCid = fromParentCid
    event.toParentCid = toParentCid
    event.amount = int64(40)
    event.epoch = server.nextEpoch
    event.ganzhiIndex = server.nextGanzhi
    event.spaceSlot = node.v3ChainNodeSpaceSlot(1001, 2002)
    event.tick = server.nextTick
    event.stem = event.ganzhiIndex % 10
    event.branch = event.ganzhiIndex % 12
    event.bodyCid = consensus.v3ChainEventBodyCid(event)

    let eventCid = consensus.v3ChainEventCid(event)
    var nextIndex = server.index
    var decision = consensus.v3ConsensusDecisionZero()
    consensus.v3ConsensusApplyChecked(nextIndex, event, eventCid, server.eventCids.len, decision)
    server.index = nextIndex
    add(server.eventCids, eventCid)
    add(server.events, event)
    assert(server.eventCids.len == 2, "v3 chain_node append event: cid len")
    assert(server.events.len == 2, "v3 chain_node append event: event len")
    assert(server.events[1].fromAccount == 1001, "v3 chain_node append event: sender")
    assert(server.events[1].toAccount == 2002, "v3 chain_node append event: receiver")
    echo("v3 chain_node_append_event_smoke ok")
    return 0
