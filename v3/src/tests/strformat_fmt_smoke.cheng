import std/strings

type
    Box = object
        title: str
        count: int32

fn main(): int32 =
    let name: str = "alpha"
    let count: int32 = 7
    let box = Box(title: "beta", count: 9)
    let fallback: str = "none"
    let summary: str = Fmt"box={name} count={intToStr(count)} rc={intToStr(count)}"
    assert(summary == "box=alpha count=7 rc=7", "v3 strformat fmt: multi placeholder")

    let escaped: str = Fmt"{{ok}} {name}"
    assert(escaped == "{ok} alpha", "v3 strformat fmt: escaped braces")

    let wrappedText: str = Fmt"{{{name}}}"
    assert(wrappedText == "{alpha}", "v3 strformat fmt: wrapped placeholder")

    let rightBraceText: str = Fmt"}}"
    assert(rightBraceText == "}", "v3 strformat fmt: right brace escape")

    let memberText: str = Fmt"{box.title}:{intToStr(box.count)}"
    assert(memberText == "beta:9", "v3 strformat fmt: member access")

    let condText: str = Fmt"selected={true ? box.title : fallback}"
    assert(condText == "selected=beta", "v3 strformat fmt: ternary placeholder")

    let ifExprText: str = Fmt"picked={if true: box.title else: fallback}"
    assert(ifExprText == "picked=beta", "v3 strformat fmt: if expr placeholder")

    var parts: str[]
    add(parts, Fmt"[{intToStr(count)}] {name}")
    assert(parts.len == 1, "v3 strformat fmt: nested add len")
    assert(parts[0] == "[7] alpha", "v3 strformat fmt: nested add value")

    let joined: str = Fmt(parts)
    assert(joined == "[7] alpha", "v3 strformat fmt: bare join")

    var lineParts: str[]
    add(lineParts, "left")
    add(lineParts, "right")
    let lines: str = Lines(lineParts)
    assert(lines == "left\nright", "v3 strformat fmt: bare lines")

    echo("v3 strformat_fmt_smoke ok")
    return 0
