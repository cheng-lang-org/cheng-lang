import cheng/v3/runtime/program_support_v3 as prosup

fn main(): int32 =
    let h0: uint64 = prosup.v3FfiHandleNewI32(40)
    if h0 == 0:
        return 1
    if prosup.v3FfiHandleGetI32(h0) != 40:
        return 2
    if prosup.v3FfiHandleAddI32(h0, 2) != 42:
        return 3
    if prosup.v3FfiHandleGetI32(h0) != 42:
        return 4
    if prosup.v3FfiHandleReleaseI32(h0) != 0:
        return 5
    let h1: uint64 = prosup.v3FfiHandleNewI32(7)
    if h1 == 0:
        return 6
    if h1 == h0:
        return 7
    if prosup.v3FfiHandleGetI32(h1) != 7:
        return 8
    if prosup.v3FfiHandleReleaseI32(h1) != 0:
        return 9
    echo("v3 ffi_handle_smoke ok")
    return 0
