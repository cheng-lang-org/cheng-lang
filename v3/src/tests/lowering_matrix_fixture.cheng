import std/result

@importc("cheng_matrix_import_text")
fn matrixImportText(handle: int32): str

fn matrixSret(flag: bool): str =
    let label: str = if flag: "yes" else: "no"
    return Fmt"flag={label}"

fn matrixRows(flag: bool): str[] =
    let imported: str = matrixImportText(7)
    let prefix: str = if flag: imported else: Fmt"fallback"
    let rows: str[] = [Fmt([prefix, intToStr(i)]) for i in 0..<2 if flag || i >= 0]
    return rows

fn matrixResult(flag: bool): Result[str] =
    let label: str = if flag: "yes" else: "no"
    let base: str = Fmt"flag={label}"
    let note: Result[str] = if flag: Ok[str](base) else: Err[str](base)
    let projected: str = note?
    let echoed: str = Value(note)
    let joined: str = Fmt([base, projected, echoed])
    let okFlag: bool = IsOk(note)
    if okFlag:
        return Ok[str](joined)
    return Err[str](Error(note))
