import std/os
import std/strutils as strutil
import std/os_host_process as hostos

fn main(): int32 =
    let res: os.ExecCmdResult = hostos.execFileCapture("/bin/echo", ["min-ok"], [], "", true, 5)
    assert(os.execCmdResultExitCode(res) == 0, "v3 hostos execFileCapture min rc")
    assert(strutil.strip(os.execCmdResultOutput(res)) == "min-ok", "v3 hostos execFileCapture min output")
    echo("v3 host_process_exec_file_capture_min_smoke ok")
    return 0
