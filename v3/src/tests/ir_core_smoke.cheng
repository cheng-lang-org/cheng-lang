import std/system
import std/result
import cheng/v3/lang/intern as langintern
import cheng/v3/ir/core_types as ir

fn main() =
    let pool: langintern.V3InternPool = langintern.v3InternPoolNew()
    let fnName0: langintern.V3InternId = langintern.v3Intern(pool, "chain.sync_once")
    let fnName1: langintern.V3InternId = langintern.v3Intern(pool, "chain.sync_once")
    assert(fnName0 == fnName1, "v3 ir: stable intern id")
    assert(langintern.v3InternPoolCount(pool) == 1, "v3 ir: no duplicate symbol")

    let textRes: Result[str] = langintern.v3LookupIntern(pool, fnName0)
    assert(IsOk(textRes), "v3 ir: lookup intern")
    assert(Value(textRes) == "chain.sync_once", "v3 ir: lookup text")

    let bytes32Layout: ir.V3TypeLayout = ir.v3TypeLayoutFixedBytes(32, 32)
    assert(bytes32Layout.kind == ir.v3LayoutFixedBytes, "v3 ir: fixed bytes layout")
    assert(bytes32Layout.abiClass == ir.v3AbiAggregate, "v3 ir: aggregate abi")

    let func: ir.V3MirFunction = ir.v3MirFunctionNew(fnName0)
    assert(func.nameId == fnName0, "v3 ir: mir function name")
    assert(func.values.len == 0, "v3 ir: empty values")

    let root: ir.V3Place = ir.v3PlaceRoot(7, 9)
    assert(root.baseValue == 7, "v3 ir: place base")
    assert(root.typeId == 9, "v3 ir: place type")
    assert(root.fieldOrdinal == -1, "v3 ir: root field ordinal")

    echo("v3 ir_core_smoke ok")
