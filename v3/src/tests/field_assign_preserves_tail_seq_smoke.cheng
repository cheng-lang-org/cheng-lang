import std/system

type
    Inner =
        xs: int32[]
        ys: int32[]

    Outer =
        inner: Inner
        tail: int32[]

fn innerZero(): Inner =
    var out: Inner
    out.xs = []
    out.ys = []
    return out

fn outerZero(): Outer =
    var out: Outer
    out.inner = innerZero()
    out.tail = []
    return out

fn main(): int32 =
    var outer = outerZero()
    add(outer.tail, 11)
    assert(outer.tail.len == 1, "v3 field assign preserves tail seq: pre len")
    assert(outer.tail[0] == 11, "v3 field assign preserves tail seq: pre item")

    var nextInner = outer.inner
    add(nextInner.xs, 7)
    add(nextInner.ys, 9)
    outer.inner = nextInner

    assert(outer.inner.xs.len == 1, "v3 field assign preserves tail seq: inner xs len")
    assert(outer.inner.ys.len == 1, "v3 field assign preserves tail seq: inner ys len")
    assert(outer.tail.len == 1, "v3 field assign preserves tail seq: post len")
    assert(outer.tail[0] == 11, "v3 field assign preserves tail seq: post item")
    echo("v3 field_assign_preserves_tail_seq_smoke ok")
    return 0
