import std/system
import std/result
import std/rawbytes
import cheng/v3/std/bytes_layout as layout
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/protocols/webrtc_signal as signal
import cheng/v3/libp2p/transports/webrtc_transport

fn main(): int32 =
    webrtc_transport.v3Libp2pWebrtcTransportResetStats()

    var addr: types.V3Libp2pMultiaddr
    addr.host = "203.0.113.142"
    addr.port = 9452
    addr.transport = types.v3Libp2pTransportWebrtc
    addr.networkDomain = types.v3Libp2pNetworkDomainBrowserWebrtc
    addr.visibility = types.v3Libp2pVisibilityPublic

    var cfg: webrtc_transport.V3Libp2pWebrtcTransportConfig
    cfg.dataChannelLabel = "cheng-browser-data"

    var browserSession: webrtc_transport.V3Libp2pWebrtcBrowserSession
    let openRes = webrtc_transport.v3Libp2pWebrtcBrowserSessionOpenInto(browserSession, cfg, addr)
    assert(IsOk(openRes), "v3 webrtc datachannel browser: session open")
    let request1 = bytesFromString("browser-datachannel-request-1")
    let response1 = bytesFromString("browser-datachannel-response-1")
    let request2 = bytesFromString("browser-datachannel-request-2")
    let response2 = bytesFromString("browser-datachannel-response-2")
    var clientResponse1: Bytes
    var clientResponse2: Bytes
    let exchange1 = webrtc_transport.v3Libp2pWebrtcBrowserSessionExchange(browserSession,
                                                                           types.v3Libp2pProtocolContent,
                                                                           request1,
                                                                           response1,
                                                                           clientResponse1)
    assert(IsOk(exchange1), "v3 webrtc datachannel browser: exchange1")
    let exchange2 = webrtc_transport.v3Libp2pWebrtcBrowserSessionExchange(browserSession,
                                                                           types.v3Libp2pProtocolSync,
                                                                           request2,
                                                                           response2,
                                                                           clientResponse2)
    assert(IsOk(exchange2), "v3 webrtc datachannel browser: exchange2")
    assert(bytesEqual(clientResponse1, response1), "v3 webrtc datachannel browser: payload1")
    assert(bytesEqual(clientResponse2, response2), "v3 webrtc datachannel browser: payload2")
    assert(webrtc_transport.v3Libp2pWebrtcBrowserDatachannelOpenCountNow() == 1,
        "v3 webrtc datachannel browser: open count")
    assert(webrtc_transport.v3Libp2pWebrtcBrowserDatachannelRequestCountNow() == 2,
        "v3 webrtc datachannel browser: request count")
    assert(webrtc_transport.v3Libp2pWebrtcNativeDatachannelOpenCountNow() == 0,
        "v3 webrtc datachannel browser: native open count")
    assert(webrtc_transport.v3Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        "v3 webrtc datachannel browser: loopback count")
    assert(webrtc_transport.v3Libp2pWebrtcLastProtocolNow() == types.v3Libp2pProtocolSync,
        "v3 webrtc datachannel browser: last protocol")
    assert(!webrtc_transport.v3Libp2pWebrtcLastRelayOnlyNow(),
        "v3 webrtc datachannel browser: relay only")
    assert(!layout.fixedBytes32Equal(webrtc_transport.v3Libp2pWebrtcLastSessionIdNow(),
                                     layout.FixedBytes32()),
        "v3 webrtc datachannel browser: last session")
    assert(webrtc_transport.v3Libp2pWebrtcBrowserSessionActiveCountNow() == 1,
        "v3 webrtc datachannel browser: active sessions")

    var signalSession: signal.V3Libp2pWebrtcSignalSession
    let applyRes = signal.v3Libp2pWebrtcSignalTranscriptApply(signalSession, browserSession.signalWire)
    assert(IsOk(applyRes), "v3 webrtc datachannel browser: signal apply")
    assert(signalSession.ready, "v3 webrtc datachannel browser: session ready")
    assert(signalSession.offerSeen, "v3 webrtc datachannel browser: offer")
    assert(signalSession.answerSeen, "v3 webrtc datachannel browser: answer")
    assert(signalSession.candidateTexts.len == 2, "v3 webrtc datachannel browser: candidate count")
    assert(layout.fixedBytes32Equal(signalSession.sessionId, webrtc_transport.v3Libp2pWebrtcLastSessionIdNow()),
        "v3 webrtc datachannel browser: session id")
    let closeRes = webrtc_transport.v3Libp2pWebrtcBrowserSessionClose(browserSession)
    assert(IsOk(closeRes), "v3 webrtc datachannel browser: close")
    assert(webrtc_transport.v3Libp2pWebrtcBrowserSessionActiveCountNow() == 0,
        "v3 webrtc datachannel browser: active sessions closed")

    echo("v3 webrtc_datachannel_browser_smoke ok")
    return 0
