import std/system
import cheng/v3/project/astrology_calendar_core as cal
import cheng/v3/project/astrology_daily_guide_core as guide

fn main(): int32 =
    assert(guide.v3AstrologyHexagramName(61) == "大有",
        "v3 astrology guide: fix fire-heaven")
    assert(guide.v3AstrologyHexagramName(62) == "姤",
        "v3 astrology guide: fix heaven-wind")

    var state = cal.V3AstrologyCalendarState()
    state.solar = cal.v3AstrologySolarDateMake(2024, 2, 10, 9, 0)
    state.dayGanzhiIndex = 40
    state.dayGanzhiText = "甲辰"
    state.hourBranchIndex = 5
    state.hourGanzhiIndex = 5
    state.hourGanzhiText = "己巳"

    var bazi = guide.V3AstrologyBaziGuideProfile()
    bazi.dayGanIndex = 0
    bazi.yearZhiIndex = 4
    bazi.dayMasterStrength = 2
    bazi.wuxingWood = 2
    bazi.wuxingFire = 2
    bazi.wuxingEarth = 1
    bazi.wuxingMetal = 0
    bazi.wuxingWater = 1

    var ziwei = guide.V3AstrologyZiweiGuideProfile()
    ziwei.mingGongIndex = 2
    ziwei.shenGongIndex = 8
    ziwei.relationScore = 1
    ziwei.careerScore = 2
    ziwei.wealthScore = 1
    ziwei.healthScore = 0
    ziwei.learningScore = 1
    ziwei.expressionScore = 2
    ziwei.siHuaScore = 1

    let today = guide.v3AstrologyDailyGuideCompute(state, bazi, ziwei)
    assert(today.hexagramIndex == 63,
        "v3 astrology guide: deterministic primary hexagram")
    assert(today.changedHexagramIndex == 31,
        "v3 astrology guide: deterministic changed hexagram")
    assert(today.movingLine == 6,
        "v3 astrology guide: deterministic moving line")
    assert(len(today.hexagramName) > 0, "v3 astrology guide: hexagram name")
    assert(len(today.changedHexagramName) > 0, "v3 astrology guide: changed hexagram name")
    assert(len(today.summary) > 0, "v3 astrology guide: summary")
    assert(today.actionCode == "外放推进", "v3 astrology guide: action code")
    return 0
