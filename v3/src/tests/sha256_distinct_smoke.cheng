import std/system
import std/rawbytes as raw
import std/crypto/sha256
import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr_types as lt

fn main(): int32 =
    assert(sha256.u32Mask() == int64(4294967295), "v3 sha256 distinct: mask")
    assert(sha256.rotr32(int64(305419896), 4) == sha256.u32FromBytes(0x81, 0x23, 0x45, 0x67),
           "v3 sha256 distinct: rotr32")
    var probeBufA = layout.byteBufInit(16)
    var probeBufB = layout.byteBufInit(16)
    lt.v3AppendU32BE(probeBufA, 1)
    lt.v3AppendU32BE(probeBufB, 2)
    let probeSpanA = layout.byteBufView(probeBufA)
    let probeSpanB = layout.byteBufView(probeBufB)
    assert(layout.byteSpanLen(probeSpanA) == 4, "v3 sha256 distinct: probe a len")
    assert(layout.byteSpanLen(probeSpanB) == 4, "v3 sha256 distinct: probe b len")
    assert(layout.byteSpanAt(probeSpanA, 3) == 1, "v3 sha256 distinct: probe a byte")
    assert(layout.byteSpanAt(probeSpanB, 3) == 2, "v3 sha256 distinct: probe b byte")
    assert(sha256.getU32BE(probeSpanA.data, 0) == 1, "v3 sha256 distinct: probe a word")
    assert(sha256.getU32BE(probeSpanB.data, 0) == 2, "v3 sha256 distinct: probe b word")
    let rawDigestA = sha256.sha256Digest(probeSpanA.data)
    let rawDigestB = sha256.sha256Digest(probeSpanB.data)
    assert(rawDigestA.len == 32, "v3 sha256 distinct: digest a len")
    assert(rawDigestB.len == 32, "v3 sha256 distinct: digest b len")
    var rawDigestLocalDistinct = false
    for i in 0..<32:
        if raw.ChengRawbytesGetAt(rawDigestA.data, i) != raw.ChengRawbytesGetAt(rawDigestB.data, i):
            rawDigestLocalDistinct = true
    assert(rawDigestLocalDistinct, "v3 sha256 distinct: local distinct")
    echo("v3 sha256_distinct_smoke ok")
    return 0
