import std/system
import std/times
import std/strings as strings
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/identity/did
import cheng/v3/libp2p/host/host
import cheng/v3/libp2p/mobile/android_bridge as mobile
import cheng/v3/libp2p/mobile/mobile_sdk as mobile_sdk
import cheng/v3/libp2p/browser/browser_sdk as browser
import cheng/v3/tooling/path as v3path

fn main(): int32 =
    let now = times.epochTimeSeconds()
    let storeRoot = "artifacts/v3_identity_store_smoke"
    let suffix = strings.int64ToStr(now)
    let phoneStorePath = storeRoot + "/phone_" + suffix + ".did"
    let laptopStorePath = storeRoot + "/laptop_" + suffix + ".did"
    let autoStorePath = storeRoot + "/auto_" + suffix + ".did"

    var phoneIdentity = did.v3DidIdentityZero()
    let phoneStoreRes = did.v3DidLoadOrCreateIdentityFill(phoneIdentity,
                                                          v3path.v3PathCurrentDir(),
                                                          phoneStorePath,
                                                          "alice.root.seed",
                                                          "alice.phone.device",
                                                          "phone",
                                                          now)
    assert(IsOk(phoneStoreRes), "v3 did identity: create phone store")

    var phoneIdentityAgain = did.v3DidIdentityZero()
    let phoneReloadRes = did.v3DidLoadOrCreateIdentityFill(phoneIdentityAgain,
                                                           v3path.v3PathCurrentDir(),
                                                           phoneStorePath,
                                                           "",
                                                           "",
                                                           "",
                                                           now + int64(1))
    assert(IsOk(phoneReloadRes), "v3 did identity: reload phone store")

    var laptopIdentity = did.v3DidIdentityZero()
    let laptopStoreRes = did.v3DidLoadOrCreateIdentityFill(laptopIdentity,
                                                           v3path.v3PathCurrentDir(),
                                                           laptopStorePath,
                                                           "alice.root.seed",
                                                           "alice.laptop.device",
                                                           "laptop",
                                                           now)
    assert(IsOk(laptopStoreRes), "v3 did identity: create laptop store")

    var autoIdentity = did.v3DidIdentityZero()
    let autoIdentityRes = did.v3DidLoadOrCreateIdentityFill(autoIdentity,
                                                            v3path.v3PathCurrentDir(),
                                                            autoStorePath,
                                                            "",
                                                            "",
                                                            "auto",
                                                            now)
    assert(IsOk(autoIdentityRes), "v3 did identity: create auto store")
    var autoReload = did.v3DidIdentityZero()
    let autoReloadRes = did.v3DidLoadOrCreateIdentityFill(autoReload,
                                                          v3path.v3PathCurrentDir(),
                                                          autoStorePath,
                                                          "",
                                                          "",
                                                          "",
                                                          now + int64(1))
    assert(IsOk(autoReloadRes), "v3 did identity: reload auto store")

    assert(did.v3DidIdentityDid(phoneIdentity) == did.v3DidFromRootSeed("alice.root.seed"),
        "v3 did identity: did text")
    assert(did.v3DidIdentityDid(phoneIdentity) == did.v3DidIdentityDid(laptopIdentity),
        "v3 did identity: same root same did")
    let phoneStoreTextRes = did.v3DidIdentityStoreText(phoneIdentity)
    assert(IsOk(phoneStoreTextRes), "v3 did identity: create store text")
    let phoneReloadStoreTextRes = did.v3DidIdentityStoreText(phoneIdentityAgain)
    assert(IsOk(phoneReloadStoreTextRes), "v3 did identity: reload store text")
    assert(Value(phoneStoreTextRes) == Value(phoneReloadStoreTextRes),
        "v3 did identity: reload device count")
    assert(types.v3Libp2pPeerIdEqual(phoneIdentity.selfDevice.devicePeerId,
                                     phoneIdentityAgain.selfDevice.devicePeerId),
        "v3 did identity: same device stable peer id")
    assert(!types.v3Libp2pPeerIdEqual(phoneIdentity.selfDevice.devicePeerId,
                                      laptopIdentity.selfDevice.devicePeerId),
        "v3 did identity: different device different peer id")
    assert(types.v3Libp2pPeerIdEqual(autoIdentity.selfDevice.devicePeerId,
                                     autoReload.selfDevice.devicePeerId),
        "v3 did identity: auto store stable peer id")
    assert(did.v3DidIdentityDid(autoIdentity) == did.v3DidIdentityDid(autoReload),
        "v3 did identity: auto store stable did")
    assert(v3path.v3FileExistsNonEmpty(v3path.v3PathCurrentDir(), phoneStorePath),
        "v3 did identity: phone store written")
    assert(v3path.v3FileExistsNonEmpty(v3path.v3PathCurrentDir(), autoStorePath),
        "v3 did identity: auto store written")

    let phoneDidText = did.v3DidFromRootSeed("alice.root.seed")
    let phoneRootPeerId = did.v3DidRootPeerIdFromSeed("alice.root.seed")
    let phoneRootSeedHash = did.v3DidRootSeedHash("alice.root.seed")
    let phoneGenesisCid = did.v3DidGenesisCid(phoneRootPeerId, phoneRootSeedHash)
    assert(strings.hasPrefix(phoneDidText, "did:cheng:g"),
        "v3 did identity: did genesis prefix")
    let phoneSelfDevice = did.v3DidDeviceMethodMake(phoneDidText,
                                                    phoneRootSeedHash,
                                                    "alice.phone.device",
                                                    "phone",
                                                    now)
    var document = did.v3DidDocumentZero()
    document.did = phoneDidText
    document.genesisCid = phoneGenesisCid
    document.rootPeerId = phoneRootPeerId
    document.rootSeedHash = phoneRootSeedHash
    document.version = did.v3DidWord64FromInt64(int64(1))
    document.updatedAtEpochSeconds = did.v3DidWord64FromInt64(now)
    var documentDevices: did.V3DidDeviceMethod[]
    add(documentDevices, phoneSelfDevice)
    document.devices = documentDevices
    let enrollRes = did.v3DidDocumentEnrollDevice(document,
                                                  "alice.root.seed",
                                                  "alice.laptop.device",
                                                  "laptop",
                                                  now + int64(20))
    assert(IsOk(enrollRes), "v3 did identity: enroll laptop")
    document = Value(enrollRes)
    let laptopPeerId = did.v3DidDevicePeerIdFromSeed("alice.laptop.device")
    let laptopPos = did.v3DidDocumentFindDevicePos(document, laptopPeerId)
    assert(laptopPos >= 0, "v3 did identity: enrolled laptop present")
    let laptopDevice = document.devices[laptopPos]
    assert(document.devices.len == 2, "v3 did identity: document device count")
    assert(did.v3DidWord64Value(document.version) == int64(2), "v3 did identity: enroll bumps version")
    assert(did.v3DidDocumentDeviceActive(document, laptopDevice.devicePeerId),
        "v3 did identity: laptop active")

    var persistedIdentity = did.v3DidIdentityClone(phoneIdentity)
    var appliedIdentity = did.v3DidIdentityZero()
    let applyEnrollRes = did.v3DidIdentityApplyDocumentFill(appliedIdentity,
                                                            persistedIdentity,
                                                            document)
    assert(IsOk(applyEnrollRes), "v3 did identity: apply enroll document")
    persistedIdentity = appliedIdentity
    let saveRes = did.v3DidSaveIdentity(v3path.v3PathCurrentDir(), phoneStorePath, persistedIdentity)
    assert(IsOk(saveRes), "v3 did identity: save enrolled document")
    var persistedReload = did.v3DidIdentityZero()
    let persistedReloadRes = did.v3DidIdentityLoadFill(persistedReload,
                                                       v3path.v3PathCurrentDir(),
                                                       phoneStorePath)
    assert(IsOk(persistedReloadRes), "v3 did identity: reload enrolled document")
    let persistedStoreTextRes = did.v3DidIdentityStoreText(persistedIdentity)
    assert(IsOk(persistedStoreTextRes), "v3 did identity: persisted store text")
    let persistedReloadStoreTextRes = did.v3DidIdentityStoreText(persistedReload)
    assert(IsOk(persistedReloadStoreTextRes), "v3 did identity: persisted reload store text")
    assert(Value(persistedStoreTextRes) == Value(persistedReloadStoreTextRes),
        "v3 did identity: persisted enrolled device count")

    let revokeRes = did.v3DidDocumentRevokeDevice(document,
                                                  "alice.root.seed",
                                                  laptopDevice.devicePeerId,
                                                  now + int64(30))
    assert(IsOk(revokeRes), "v3 did identity: revoke laptop")
    document = Value(revokeRes)
    assert(did.v3DidWord64Value(document.version) == int64(3), "v3 did identity: revoke bumps version")
    assert(!did.v3DidDocumentDeviceActive(document, laptopDevice.devicePeerId),
        "v3 did identity: laptop revoked")

    var libHost = host.v3Libp2pHostInitWithDid(phoneIdentity)
    assert(host.v3Libp2pHostHasDidIdentity(libHost),
        "v3 did identity: lib host attached")
    assert(host.v3Libp2pHostDidText(libHost) == did.v3DidIdentityDid(phoneIdentity),
        "v3 did identity: lib host did text")
    assert(types.v3Libp2pPeerIdEqual(libHost.selfPeerId, phoneIdentity.selfDevice.devicePeerId),
        "v3 did identity: lib host device peer")
    var libHostStored = host.v3Libp2pHostInit("")
    let libHostStoreRes = host.v3Libp2pHostInitWithDidStoreFill(libHostStored,
                                                                phoneStorePath,
                                                                "",
                                                                "",
                                                                "",
                                                                now + int64(2))
    assert(IsOk(libHostStoreRes), "v3 did identity: lib host store init")
    assert(host.v3Libp2pHostDidText(libHostStored) == did.v3DidIdentityDid(phoneIdentity),
        "v3 did identity: lib host store did text")

    var mobileHost = mobile.v3MobileHostInitWithDid(phoneIdentity)
    assert(mobile.v3MobileHostHasDidIdentity(mobileHost),
        "v3 did identity: mobile host attached")
    assert(mobile.v3MobileHostDidText(mobileHost) == did.v3DidIdentityDid(phoneIdentity),
        "v3 did identity: mobile host did text")
    assert(types.v3Libp2pPeerIdEqual(mobileHost.selfPeerId, phoneIdentity.selfDevice.devicePeerId),
        "v3 did identity: mobile host device peer")
    var mobileHostStored = mobile.v3MobileHostInit("")
    let mobileHostStoreRes = mobile.v3MobileHostInitWithDidStoreFill(mobileHostStored,
                                                                     phoneStorePath,
                                                                     "",
                                                                     "",
                                                                     "",
                                                                     now + int64(2))
    assert(IsOk(mobileHostStoreRes), "v3 did identity: mobile host store init")
    assert(mobile.v3MobileHostDidText(mobileHostStored) == did.v3DidIdentityDid(phoneIdentity),
        "v3 did identity: mobile host store did text")

    var sdk = mobile_sdk.v3MobileSdkInitWithDid(phoneIdentity)
    assert(mobile_sdk.v3MobileSdkDidText(sdk) == did.v3DidIdentityDid(phoneIdentity),
        "v3 did identity: mobile sdk did text")
    assert(mobile_sdk.v3MobileSdkSelfPeerText(sdk) != "",
        "v3 did identity: mobile sdk self peer")
    var sdkStored = mobile_sdk.v3MobileSdkInit("")
    let sdkStoreRes = mobile_sdk.v3MobileSdkInitWithDidStoreFill(sdkStored,
                                                                 phoneStorePath,
                                                                 "",
                                                                 "",
                                                                 "",
                                                                 now + int64(2))
    assert(IsOk(sdkStoreRes), "v3 did identity: mobile sdk store init")
    assert(mobile_sdk.v3MobileSdkDidText(sdkStored) == did.v3DidIdentityDid(phoneIdentity),
        "v3 did identity: mobile sdk store did text")
    let sdkSaveRes = mobile_sdk.v3MobileSdkSaveDidIdentity(phoneStorePath, sdkStored)
    assert(IsOk(sdkSaveRes), "v3 did identity: mobile sdk save did")

    var browserSdk = browser.v3BrowserSdkInitWithDid(phoneIdentity)
    assert(browser.v3BrowserSdkDidText(browserSdk) == did.v3DidIdentityDid(phoneIdentity),
        "v3 did identity: browser sdk did text")
    assert(browser.v3BrowserSdkPeerIdText(browserSdk) != "",
        "v3 did identity: browser sdk self peer")
    var browserStored = browser.v3BrowserSdkInit("")
    let browserStoreRes = browser.v3BrowserSdkInitWithDidStoreFill(browserStored,
                                                                   phoneStorePath,
                                                                   "",
                                                                   "",
                                                                   "",
                                                                   now + int64(2))
    assert(IsOk(browserStoreRes), "v3 did identity: browser sdk store init")
    assert(browser.v3BrowserSdkDidText(browserStored) == did.v3DidIdentityDid(phoneIdentity),
        "v3 did identity: browser sdk store did text")
    let browserSaveRes = browser.v3BrowserSdkSaveDidIdentity(phoneStorePath, browserStored)
    assert(IsOk(browserSaveRes), "v3 did identity: browser sdk save did")

    echo("v3 did_identity_smoke ok")
    return 0
