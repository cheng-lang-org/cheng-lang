import std/system
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peer_id
import cheng/v3/libp2p/core/multiaddr
import cheng/v3/libp2p/core/multistream

fn main(): int32 =
    var peerA: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(peerA, "alice")
    var peerB: types.V3Libp2pPeerId
    peer_id.v3Libp2pPeerIdFillFromSeed(peerB, "bob")
    assert(!types.v3Libp2pPeerIdEqual(peerA, peerB), "v3 libp2p core: peer ids distinct")
    assert(peer_id.v3Libp2pPeerIdDistance(peerA, peerB) > int64(0),
        "v3 libp2p core: xor distance")

    var tcpAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(tcpAddr, "127.0.0.1", 4101)
    assert(tcpAddr.transport == types.v3Libp2pTransportTcp, "v3 libp2p core: tcp transport")
    assert(tcpAddr.secure == types.v3Libp2pSecureNoise, "v3 libp2p core: tcp noise")
    assert(tcpAddr.mux == types.v3Libp2pMuxYamux, "v3 libp2p core: tcp yamux")

    var quicAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillQuic(quicAddr, "127.0.0.1", 4201)
    assert(quicAddr.transport == types.v3Libp2pTransportQuic, "v3 libp2p core: quic transport")
    assert(quicAddr.secure == types.v3Libp2pSecureTls, "v3 libp2p core: quic tls")
    assert(quicAddr.mux == types.v3Libp2pMuxNone, "v3 libp2p core: quic native streams")

    let header = multistream.v3Libp2pMultistreamHeaderText()
    assert(header == "/multistream/1.0.0\n", "v3 libp2p core: multistream header")
    let select = multistream.v3Libp2pMultistreamSelectBytes(types.v3Libp2pProtocolIdentify)
    assert(multistream.v3Libp2pMultistreamAccepts(select, types.v3Libp2pProtocolIdentify),
        "v3 libp2p core: multistream accept")

    echo("v3 libp2p_core_smoke ok")
    return 0
