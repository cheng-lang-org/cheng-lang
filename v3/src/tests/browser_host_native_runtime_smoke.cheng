import std/rawbytes
import std/rawmem_support
import std/result
import std/strings
import std/strutils as strutil
import cheng/v3/libp2p/browser/browser_host_wasm_probe as probe

var browserHostNativeBuffers: Bytes[] = []
var browserHostSetLenProbeBuffers: Bytes[] = []
var browserHostNativeLastError: str = ""

fn browserHostFail(label: str): int32 =
    echo("v3 browser host native smoke failed: " + label)
    return 1

fn browserHostBytesSeqSetLenProbe(): int32 =
    setLen(browserHostSetLenProbeBuffers, 2)
    return browserHostSetLenProbeBuffers.len

fn browserHostBufferHandleStore(payload: Bytes): int32 =
    add(browserHostNativeBuffers, bytesSlice(payload, 0, bytesLen(payload)))
    return browserHostNativeBuffers.len

fn browserHostInputHandleStore(payload: Bytes): int32 =
    return browserHostBufferHandleStore(payload)

fn browserHostBufferHandleLookup(handle: int32): Result[Bytes] =
    let idx = handle - 1
    if idx < 0 || idx >= browserHostNativeBuffers.len:
        return Err[Bytes]("browser_native_invalid_buffer_handle")
    return Ok[Bytes](browserHostNativeBuffers[idx])

fn browserHostInputHandleLookup(handle: int32): Result[Bytes] =
    let bytesRes = browserHostBufferHandleLookup(handle)
    if IsErr(bytesRes):
        return Err[Bytes]("browser_native_invalid_input_handle")
    return bytesRes

fn browserHostBufferHandleText(handle: int32): str =
    let bytesRes = browserHostBufferHandleLookup(handle)
    if IsErr(bytesRes):
        return ""
    return bytesToString(Value(bytesRes))

@exportc("cheng_v3_browser_now_ms_bridge")
fn cheng_v3_browser_now_ms_bridge_export(): int32 =
    return 24680

@exportc("cheng_v3_browser_echo_i32_bridge")
fn cheng_v3_browser_echo_i32_bridge_export(value: int32): int32 =
    return value

@exportc("cheng_v3_browser_peer_handle_bridge")
fn cheng_v3_browser_peer_handle_bridge_export(): int32 =
    return 41

@exportc("cheng_v3_browser_did_handle_bridge")
fn cheng_v3_browser_did_handle_bridge_export(): int32 =
    return 84

@exportc("cheng_v3_browser_dm_active_count_bridge")
fn cheng_v3_browser_dm_active_count_bridge_export(): int32 =
    return 7

@exportc("cheng_v3_browser_dm_connect_start_bridge")
fn cheng_v3_browser_dm_connect_start_bridge_export(peerHandle: int32): int32 =
    return peerHandle + 1000

@exportc("cheng_v3_browser_dm_wait_start_bridge")
fn cheng_v3_browser_dm_wait_start_bridge_export(peerHandle: int32, timeoutMs: int32): int32 =
    return peerHandle xor timeoutMs

@exportc("cheng_v3_browser_dm_send_start_bridge")
fn cheng_v3_browser_dm_send_start_bridge_export(peerHandle: int32,
                                                conversationHandle: int32,
                                                messageHandle: int32,
                                                timestampMs: int32): int32 =
    return peerHandle + conversationHandle + messageHandle + timestampMs

@exportc("cheng_v3_browser_distributed_video_build_bridge")
fn cheng_v3_browser_distributed_video_build_bridge_export(blobHandle: int32,
                                                          ownerPeerHandle: int32,
                                                          remotePeersHandle: int32,
                                                          dataShardCount: int32,
                                                          parityShardCount: int32,
                                                          shardPayloadBytes: int32): int32 =
    return blobHandle + ownerPeerHandle + remotePeersHandle + dataShardCount + parityShardCount + shardPayloadBytes

@exportc("cheng_v3_browser_distributed_video_rebuild_bridge")
fn cheng_v3_browser_distributed_video_rebuild_bridge_export(manifestPayloadHandle: int32,
                                                            shardSpecsHandle: int32,
                                                            dataShardCount: int32,
                                                            parityShardCount: int32,
                                                            shardPayloadBytes: int32): int32 =
    return manifestPayloadHandle xor shardSpecsHandle xor dataShardCount xor parityShardCount xor shardPayloadBytes

@exportc("cheng_v3_browser_distributed_video_last_error_handle_bridge")
fn cheng_v3_browser_distributed_video_last_error_handle_bridge_export(): int32 =
    return 501

@exportc("cheng_v3_browser_input_len_bridge")
fn cheng_v3_browser_input_len_bridge_export(handle: int32): int32 =
    let inputRes = browserHostInputHandleLookup(handle)
    if IsErr(inputRes):
        return -1
    return bytesLen(Value(inputRes))

@exportc("cheng_v3_browser_input_copy_bridge")
fn cheng_v3_browser_input_copy_bridge_export(handle: int32, data: ptr, n: int32): int32 =
    let inputRes = browserHostInputHandleLookup(handle)
    if IsErr(inputRes):
        return 0
    let payload = Value(inputRes)
    if n < 0 || n > bytesLen(payload):
        return 0
    if n > 0:
        rawmem_support.RawmemCopy(data, payload.data, n)
    return 1

@exportc("cheng_v3_buffer_handle_from_raw_bridge")
fn cheng_v3_buffer_handle_from_raw_bridge_export(data: ptr, n: int32): int32 =
    if data == nil || n <= 0:
        return 0
    let payload = bytesView(data, n)
    return browserHostBufferHandleStore(payload)

@exportc("cheng_v3_buffer_handle_from_text_bridge")
fn cheng_v3_buffer_handle_from_text_bridge_export(text: str): int32 =
    return browserHostBufferHandleStore(bytesFromString(text))

@exportc("cheng_v3_browser_buffer_handle_len_bridge")
fn cheng_v3_browser_buffer_handle_len_bridge_export(handle: int32): int32 =
    let bytesRes = browserHostBufferHandleLookup(handle)
    if IsErr(bytesRes):
        return -1
    return bytesLen(Value(bytesRes))

@exportc("cheng_v3_browser_buffer_handle_byte_bridge")
fn cheng_v3_browser_buffer_handle_byte_bridge_export(handle: int32, idx: int32): int32 =
    let bytesRes = browserHostBufferHandleLookup(handle)
    if IsErr(bytesRes):
        return -1
    return bytesGet(Value(bytesRes), idx)

@exportc("cheng_v3_browser_buffer_handle_release_bridge")
fn cheng_v3_browser_buffer_handle_release_bridge_export(handle: int32): int32 =
    let idx = handle - 1
    if idx < 0 || idx >= browserHostNativeBuffers.len:
        return 0
    browserHostNativeBuffers[idx] = emptyBytes()
    return 1

@exportc("cheng_v3_browser_moq_fountain_last_error_store_bridge")
fn cheng_v3_browser_moq_fountain_last_error_store_bridge_export(text: str): int32 =
    browserHostNativeLastError = text
    return 1

@exportc("cheng_v3_browser_moq_fountain_last_error_handle_bridge")
fn cheng_v3_browser_moq_fountain_last_error_handle_bridge_export(): int32 =
    if len(browserHostNativeLastError) <= 0:
        return 0
    return browserHostBufferHandleStore(bytesFromString(browserHostNativeLastError))

fn main(): int32 =
    if probe.main() != 0:
        return browserHostFail("main")
    if browserHostBytesSeqSetLenProbe() != 2:
        return browserHostFail("browserHostBytesSeqSetLenProbe")
    if probe.browserNowMs() != 24680:
        return browserHostFail("browserNowMs")
    if probe.browserEchoI32(31337) != 31337:
        return browserHostFail("browserEchoI32")
    if probe.browserPeerHandle() != 41:
        return browserHostFail("browserPeerHandle")
    if probe.browserDidHandle() != 84:
        return browserHostFail("browserDidHandle")
    if probe.browserDmActiveCount() != 7:
        return browserHostFail("browserDmActiveCount")
    if probe.browserDmConnectStart(9) != 1009:
        return browserHostFail("browserDmConnectStart")
    if probe.browserDmWaitStart(11, 22) != 29:
        return browserHostFail("browserDmWaitStart")
    if probe.browserDmSendStart(1, 2, 3, 4) != 10:
        return browserHostFail("browserDmSendStart")
    if probe.browserDistributedVideoBuild(1, 2, 3, 4, 5, 6) != 21:
        return browserHostFail("browserDistributedVideoBuild")
    if probe.browserDistributedVideoRebuild(10, 11, 12, 13, 14) != 14:
        return browserHostFail("browserDistributedVideoRebuild")
    if probe.browserDistributedVideoLastErrorHandle() != 501:
        return browserHostFail("browserDistributedVideoLastErrorHandle")
    if probe.browserStrformatFmtLenProbe() != 9:
        return browserHostFail("browserStrformatFmtLenProbe")
    if probe.browserStrformatLinesLenProbe() != 10:
        return browserHostFail("browserStrformatLinesLenProbe")
    if probe.browserMoqLocalSeqBoxCountProbe() != 2:
        return browserHostFail("browserMoqLocalSeqBoxCountProbe")
    if probe.browserMoqResultSeqBoxCountProbe() != 2:
        return browserHostFail("browserMoqResultSeqBoxCountProbe")
    if probe.browserMoqBuildRemoteAckCountProbe() != 2:
        return browserHostFail("browserMoqBuildRemoteAckCountProbe")
    if probe.browserMoqBuildRemoteAckFirstLenProbe() != 6:
        return browserHostFail("browserMoqBuildRemoteAckFirstLenProbe")
    if probe.browserMoqBuildLongPeerRemoteAckCountProbe() != 2:
        return browserHostFail("browserMoqBuildLongPeerRemoteAckCountProbe")
    if probe.browserMoqBuildLongPeerRemoteAckFirstLenProbe() != 52:
        return browserHostFail("browserMoqBuildLongPeerRemoteAckFirstLenProbe")
    if probe.browserMoqBuildLongPeerWireLenProbe() <= 0:
        return browserHostFail("browserMoqBuildLongPeerWireLenProbe")
    if probe.browserMoqBuildObjectCountProbe() != 1:
        return browserHostFail("browserMoqBuildObjectCountProbe")
    if probe.browserMoqObjectSourceBlockCountProbe() != 1:
        return browserHostFail("browserMoqObjectSourceBlockCountProbe")
    if probe.browserMoqBuildLongBlobObjectCountProbe() != 1:
        return browserHostFail("browserMoqBuildLongBlobObjectCountProbe")
    if probe.browserMoqBuildLongBlobDropletCountProbe() <= 0:
        return browserHostFail("browserMoqBuildLongBlobDropletCountProbe")
    if probe.browserMoqBuildLongBlobComputedBundleCidLenProbe() != 64:
        return browserHostFail("browserMoqBuildLongBlobComputedBundleCidLenProbe")
    if probe.browserMoqPeerCsvCountProbe() != 2:
        return browserHostFail("browserMoqPeerCsvCountProbe")
    if probe.browserMoqPeerCsvDirectCountProbe() != 2:
        return browserHostFail("browserMoqPeerCsvDirectCountProbe")
    if probe.browserMoqPeerCsvSplitCountProbe() != 2:
        return browserHostFail("browserMoqPeerCsvSplitCountProbe")
    if probe.browserMoqPeerCsvFirstPartLenProbe() != 6:
        return browserHostFail("browserMoqPeerCsvFirstPartLenProbe")
    if probe.browserMoqPeerCsvFirstTrimmedLenProbe() != 6:
        return browserHostFail("browserMoqPeerCsvFirstTrimmedLenProbe")
    if probe.browserMoqDirectSliceLenProbe() != 6:
        return browserHostFail("browserMoqDirectSliceLenProbe")
    if probe.browserMoqDirectSliceEqProbe() != 1:
        return browserHostFail("browserMoqDirectSliceEqProbe")
    if probe.browserMoqLiteralLenProbe() != 6:
        return browserHostFail("browserMoqLiteralLenProbe")
    if probe.browserMoqLiteralEqProbe() != 1:
        return browserHostFail("browserMoqLiteralEqProbe")
    if probe.browserMoqSeqLiteralFirstLenProbe() != 6:
        return browserHostFail("browserMoqSeqLiteralFirstLenProbe")
    if probe.browserMoqSeqSliceFirstLenProbe() != 6:
        return browserHostFail("browserMoqSeqSliceFirstLenProbe")
    if probe.browserRangeLoopSumProbe() != 21:
        return browserHostFail("browserRangeLoopSumProbe")
    let buildErrorHandle = probe.browserMoqBuildErrorHandleProbe()
    let objectErrorHandle = probe.browserMoqObjectErrorHandleProbe()
    if probe.browserBufferHandleLen(buildErrorHandle) != 2:
        return browserHostFail("browserMoqBuildErrorHandleProbe.len")
    if probe.browserBufferHandleLen(objectErrorHandle) != 2:
        return browserHostFail("browserMoqObjectErrorHandleProbe.len")
    if probe.browserBufferHandleByte(buildErrorHandle, 0) != int32('o'):
        return browserHostFail("browserMoqBuildErrorHandleProbe.byte0")
    if probe.browserBufferHandleByte(buildErrorHandle, 1) != int32('k'):
        return browserHostFail("browserMoqBuildErrorHandleProbe.byte1")
    if !strutil.Contains(browserHostBufferHandleText(buildErrorHandle), "ok"):
        return browserHostFail("browserMoqBuildErrorHandleProbe.text")
    if !strutil.Contains(browserHostBufferHandleText(objectErrorHandle), "ok"):
        return browserHostFail("browserMoqObjectErrorHandleProbe.text")
    if probe.browserBufferHandleRelease(buildErrorHandle) != 1:
        return browserHostFail("browserBufferHandleRelease")
    let blobHandle = browserHostInputHandleStore(bytesFromString("moq-fountain-smoke"))
    let ownerHandle = browserHostInputHandleStore(bytesFromString("12D3KooWmxfnTuP2Gn5mhXTgeKiDHpKKQfVWKHeYruMuAVbkWmk8"))
    let remoteHandle = browserHostInputHandleStore(bytesFromString("12D3KooWiWLDFUvGDGRGfmTnfEEPzxuPw83ZnvNeSTWCNwQA4vy4,12D3KooW98NzVx7ZavtVbP9bT3hneTyz2j1kYaFZb54n8qbV5m9V"))
    let mimeTypeHandle = browserHostInputHandleStore(bytesFromString("video/mp4"))
    if probe.browserInputTextRoundtripLen(remoteHandle) != 105:
        return browserHostFail("browserInputTextRoundtripLen")
    if probe.browserInputRemotePeerCount(remoteHandle) != 2:
        return browserHostFail("browserInputRemotePeerCount")
    if probe.browserMoqFountainInputRemotePeerCount(ownerHandle, remoteHandle, mimeTypeHandle) != 2:
        return browserHostFail("browserMoqFountainInputRemotePeerCount")
    if probe.browserMoqFountainBuildRemotePeerCount(blobHandle, ownerHandle, remoteHandle, mimeTypeHandle, 1024, 8, 2) != 2:
        return browserHostFail("browserMoqFountainBuildRemotePeerCount")
    if probe.browserMoqFountainBuildWireRemotePeerCsvLen(blobHandle, ownerHandle, remoteHandle, mimeTypeHandle, 1024, 8, 2) != 105:
        return browserHostFail("browserMoqFountainBuildWireRemotePeerCsvLen")
    let externalHandle = probe.browserMoqFountainBuild(blobHandle,
                                                       ownerHandle,
                                                       remoteHandle,
                                                       mimeTypeHandle,
                                                       1024,
                                                       8,
                                                       2)
    if externalHandle <= 0:
        return browserHostFail("browserMoqFountainBuild")
    let externalWire = browserHostBufferHandleText(externalHandle)
    if !strutil.Contains(externalWire,
                         "remote_ack_peer_ids=12D3KooWiWLDFUvGDGRGfmTnfEEPzxuPw83ZnvNeSTWCNwQA4vy4,12D3KooW98NzVx7ZavtVbP9bT3hneTyz2j1kYaFZb54n8qbV5m9V"):
        return browserHostFail("browserMoqFountainBuild.remoteAck")
    if !strutil.Contains(externalWire, "object.0.group_id="):
        return browserHostFail("browserMoqFountainBuild.group")
    if !strutil.Contains(externalWire, "object.0.object_id=object-0"):
        return browserHostFail("browserMoqFountainBuild.object")
    if !strutil.Contains(externalWire, "droplet.0.kind=source"):
        return browserHostFail("browserMoqFountainBuild.kind")
    if !strutil.Contains(externalWire, "droplet.0.block_indexes=0"):
        return browserHostFail("browserMoqFountainBuild.blockIndexes")
    if probe.browserMoqFountainBuild(0, ownerHandle, remoteHandle, mimeTypeHandle, 1024, 8, 2) != 0:
        return browserHostFail("browserMoqFountainBuild.missingBlob.rc")
    let missingBlobErrorHandle = probe.browserMoqFountainLastErrorHandle()
    if !strutil.Contains(browserHostBufferHandleText(missingBlobErrorHandle), "moq_fountain_missing_blob"):
        return browserHostFail("browserMoqFountainBuild.missingBlob.error")
    if probe.browserMoqFountainRebuild(0) != 0:
        return browserHostFail("browserMoqFountainRebuild.missingRequestWire.rc")
    let missingRequestWireErrorHandle = probe.browserMoqFountainLastErrorHandle()
    if !strutil.Contains(browserHostBufferHandleText(missingRequestWireErrorHandle), "moq_fountain_missing_request_wire"):
        return browserHostFail("browserMoqFountainRebuild.missingRequestWire.error")
    echo("v3 browser host wasm smoke: ok")
    return 0
