import std/system
import std/rawbytes
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/multiaddr

fn main(): int32 =
    let text = bytesFromString("/ip4/127.0.0.1/tcp/4101")
    var addr = types.v3Libp2pMultiaddrZero()
    let addrRes = multiaddr.v3Libp2pMultiaddrFillFromBytes(addr, text)
    assert(addrRes.ok, "v3 libp2p multiaddr tcp: parse")
    assert(addr.transport == types.v3Libp2pTransportTcp, "v3 libp2p multiaddr tcp: transport")
    assert(addr.secure == types.v3Libp2pSecureNoise, "v3 libp2p multiaddr tcp: secure")
    assert(addr.mux == types.v3Libp2pMuxYamux, "v3 libp2p multiaddr tcp: mux")
    echo("v3 libp2p_multiaddr_tcp_smoke ok")
    return 0
