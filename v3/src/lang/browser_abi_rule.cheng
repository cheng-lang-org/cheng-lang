fn v3BrowserAbiBridgeSourceFunctionText(plan: V3BrowserAbiBridgePlan): str =
    let helper = plan.helperName
    if plan.bridgeStageText == "input_read":
        if plan.inputSchemaKindText == "bytes_required":
            return v3BrowserAbiBridgeSourceInputBytesRequiredText(helper)
        if plan.inputSchemaKindText == "text_required":
            return v3BrowserAbiBridgeSourceInputTextRequiredText(helper)
        if plan.inputSchemaKindText == "text_optional":
            return v3BrowserAbiBridgeSourceInputTextOptionalText(helper)
    if plan.bridgeStageText == "output_write":
        if plan.outputSchemaKindText == "bytes_handle":
            return v3BrowserAbiBridgeSourceOutputBytesHandleText(helper)
        if plan.outputSchemaKindText == "text_handle":
            return v3BrowserAbiBridgeSourceOutputTextHandleText(helper)
    if plan.bridgeStageText == "result_export":
        if plan.outputSchemaKindText == "bytes_handle":
            return v3BrowserAbiBridgeSourceResultExportBytesText(helper)
        if plan.outputSchemaKindText == "text_handle":
            return v3BrowserAbiBridgeSourceResultExportTextText(helper)
    if plan.bridgeStageText == "error_handle_read":
        return v3BrowserAbiBridgeSourceErrorHandleText(helper)
    if plan.bridgeStageText == "scalar_call":
        let symbolName = "cheng_v3_browser_" + plan.ruleName + "_bridge"
        if plan.inputSchemaKindText == "scalar_none":
            return v3BrowserAbiBridgeSourceScalarCallNoneText(helper, symbolName)
        if plan.inputSchemaKindText == "scalar_i32_1":
            return v3BrowserAbiBridgeSourceScalarCall1Text(helper, symbolName)
        if plan.inputSchemaKindText == "scalar_i32_2":
            return v3BrowserAbiBridgeSourceScalarCall2Text(helper, symbolName)
        if plan.inputSchemaKindText == "scalar_i32_4":
            return v3BrowserAbiBridgeSourceScalarCall4Text(helper, symbolName)
    assert(false, "browser_abi_rule invalid bridge source plan")
    return ""

fn v3BrowserAbiBridgeSourceText(plans: V3BrowserAbiBridgePlan[]): str =
    var out = ""
    let sharedImports = v3BrowserAbiBridgeSourceSharedImportLines()
    for i in 0..<sharedImports.len:
        if len(out) > 0:
            out = out + "\n"
        out = out + sharedImports[i]
    var scalarImports: str[] = []
    for i in 0..<plans.len:
        if plans[i].bridgeStageText != "scalar_call":
            continue
        let importLine = v3BrowserAbiBridgeSourceScalarImportLine(plans[i])
        v3BrowserAbiBridgeSourceAppendUnique(scalarImports, importLine)
    for i in 0..<scalarImports.len:
        if len(out) > 0:
            out = out + "\n"
        out = out + scalarImports[i]
    out = out + "\n\n"
    out = out + "fn v3BrowserBridgeGeneratedSourceFormat(): str =\n"
    out = out + "    return \""
    out = out + v3BrowserAbiBridgeSourceFormat()
    out = out + "\""
    for i in 0..<plans.len:
        let fnText = v3BrowserAbiBridgeSourceFunctionText(plans[i])
        out = out + "\n\n"
        out = out + fnText
    return out

fn v3BrowserAbiBridgePlanManifestText(plans: V3BrowserAbiBridgePlan[]): str =
    var out = ""
    var header = ""
    header = header + "format="
    header = header + v3BrowserAbiBridgePlanManifestFormat()
    v3BrowserAbiBridgeManifestAppendLine(out, header)
    var countLine = ""
    countLine = countLine + "bridge_count="
    countLine = countLine + intToStr(plans.len)
    v3BrowserAbiBridgeManifestAppendLine(out, countLine)
    var uniqueLine = ""
    uniqueLine = uniqueLine + "bridge_unique_key_count="
    uniqueLine = uniqueLine + intToStr(v3BrowserAbiBridgePlanUniqueKeyCount(plans))
    v3BrowserAbiBridgeManifestAppendLine(out, uniqueLine)
    for i in 0..<plans.len:
        var line = ""
        line = line + "bridge["
        line = line + intToStr(i)
        line = line + "]="
        line = line + plans[i].emitLine
        v3BrowserAbiBridgeManifestAppendLine(out, line)
    return out

fn v3BrowserAbiBridgePlanManifestTextFromRules(rules: V3BrowserAbiRule[]): str =
    let plans = v3BrowserAbiBridgePlansFromRules(rules)
    return v3BrowserAbiBridgePlanManifestText(plans)
