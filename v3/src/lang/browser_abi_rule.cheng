    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(): int32 =\n"
    out = out + "    return cheng_v3_browser_moq_fountain_last_error_handle_bridge()"
    return out

fn v3BrowserAbiBridgeSourceScalarCallNoneText(helper: str,
                                              symbolName: str): str =
    var out = ""
    out = out + "fn "
    out = out + helper
    out = out + "(): int32 =\n"
    out = out + "    return "
    out = out + symbolName
    out = out + "()"
    return out

