    out = out + "    if len(text) <= 0:\n"
    out = out + "        cheng_v3_browser_moq_fountain_last_error_store_bridge(handleError)\n"
    out = out + "        return 0\n"
    out = out + "    let handle = cheng_v3_buffer_handle_from_text_bridge(text)\n"
    out = out + "    if handle <= 0:\n"
    out = out + "        cheng_v3_browser_moq_fountain_last_error_store_bridge(handleError)\n"
    out = out + "        return 0\n"
    out = out + "    return handle"
