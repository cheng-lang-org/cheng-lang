import std/result
import std/buffer
import std/rawbytes
import cheng/v3/tooling/path as v3path

type
    V3ParsedSourceKind = enum
        v3ParsedOrdinarySource

    V3ImportEdge =
        ownerModulePath: str
        targetModulePath: str
        targetSourcePath: str
        importAlias: str
        resolved: bool

    V3NormalizedExprKind = enum
        v3NormalizedExprIf
        v3NormalizedExprRange
        v3NormalizedExprComprehension
        v3NormalizedExprStrFormat
        v3NormalizedExprResultIntrinsic
        v3NormalizedExprCall
        v3NormalizedExprTry

    V3NormalizedExpr =
        exprId: str
        sourcePath: str
        lineNumber: int32
        columnNumber: int32
        endLineNumber: int32
        endColumnNumber: int32
        kind: V3NormalizedExprKind
        detail: str
        surfaceText: str

    V3NormalizedExprLayer =
        sourceCount: int32
        exprs: V3NormalizedExpr[]
        questionResidualCount: int32

    V3ParsedSourceStub =
        workspaceRoot: str
        packageRoot: str
        packageId: str
        entrySourcePath: str
        sourcePath: str
        moduleStem: str
        syntaxTag: str
        sourceKind: V3ParsedSourceKind
        ownerModulePaths: str[]
        importEdges: V3ImportEdge[]
        orderedClosureSourcePaths: str[]
        normalizedExprLayer: V3NormalizedExprLayer
        hasCompilerTopLevel: bool
        mainFunctionPresent: bool
        unresolvedImportCount: int32

    V3NormalizedFunctionDecl =
        name: str
        lineIndex: int32
        importc: bool
        explicitExportName: str
        surfaceKeyword: str

    V3NormalizedExprCallProfile =
        sourcePath: str
        ownerModulePath: str
        text: str
        decls: V3NormalizedFunctionDecl[]
        importcCallNames: str[]
        localCallNames: str[]
        importEdges: V3ImportEdge[]

fn v3ParsedSourceKindText(kind: V3ParsedSourceKind): str =
    if kind == v3ParsedOrdinarySource:
        return "ordinary_cheng_source"
    return "unknown"

fn v3ParsedSourceWorkspaceRoot(parsed: V3ParsedSourceStub): str =
    return parsed.workspaceRoot

fn v3NormalizedExprKindText(kind: V3NormalizedExprKind): str =
    if kind == v3NormalizedExprIf:
        return "IfExpr"
    if kind == v3NormalizedExprRange:
        return "RangeExpr"
    if kind == v3NormalizedExprComprehension:
        return "ComprehensionExpr"
    if kind == v3NormalizedExprStrFormat:
        return "StrFormatExpr"
    if kind == v3NormalizedExprResultIntrinsic:
        return "ResultIntrinsic"
    if kind == v3NormalizedExprCall:
        return "CallExpr"
    if kind == v3NormalizedExprTry:
        return "TryExpr"
    return "UnknownExpr"

fn v3NormalizedExprClone(expr: V3NormalizedExpr): V3NormalizedExpr =
    var out: V3NormalizedExpr
    out.exprId = expr.exprId
    out.sourcePath = expr.sourcePath
    out.lineNumber = expr.lineNumber
    out.columnNumber = expr.columnNumber
    out.endLineNumber = expr.endLineNumber
    out.endColumnNumber = expr.endColumnNumber
    out.kind = expr.kind
    out.detail = expr.detail
    out.surfaceText = expr.surfaceText
    return out

fn v3NormalizedExprEndColumn(columnNumber: int32,
                             surfaceText: str): int32 =
    if len(surfaceText) <= 0:
        return columnNumber
    return columnNumber + len(surfaceText) - 1

fn v3ParserConcat2(a: str, b: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserConcat3(a: str, b: str, c: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserConcat4(a: str, b: str, c: str, d: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    if d != "":
        buffer.AppendBytes(buf, d)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3NormalizedExprMakeId(sourcePath: str,
                          lineNumber: int32,
                          columnNumber: int32,
                          kind: V3NormalizedExprKind,
                          detail: str): str =
    var buf = buffer.NewByteBuffer()
    let hash: str = "#"
    let colon: str = ":"
    let lineText: str = intToStr(lineNumber)
    let columnText: str = intToStr(columnNumber)
    let kindText: str = v3NormalizedExprKindText(kind)
    buffer.AppendBytes(buf, sourcePath)
    buffer.AppendBytes(buf, hash)
    buffer.AppendBytes(buf, lineText)
    buffer.AppendBytes(buf, colon)
    buffer.AppendBytes(buf, columnText)
    buffer.AppendBytes(buf, colon)
    buffer.AppendBytes(buf, kindText)
    buffer.AppendBytes(buf, colon)
    buffer.AppendBytes(buf, detail)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3NormalizedExprLayerClone(layer: V3NormalizedExprLayer): V3NormalizedExprLayer =
    var out: V3NormalizedExprLayer
    out.sourceCount = 0
    out.exprs = []
    out.questionResidualCount = layer.questionResidualCount
    out.sourceCount = layer.sourceCount
    for i in 0..<layer.exprs.len:
        add(out.exprs, v3NormalizedExprClone(layer.exprs[i]))
    return out

fn v3NormalizedExprLayerZero(): V3NormalizedExprLayer =
    var out: V3NormalizedExprLayer
    out.sourceCount = 0
    out.exprs = []
    out.questionResidualCount = 0
    return out

fn v3NormalizedExprLayerAppend(layer: var V3NormalizedExprLayer,
                               sourcePath: str,
                               lineNumber: int32,
                               columnNumber: int32,
                               kind: V3NormalizedExprKind,
                               detail: str,
                               surfaceText: str) =
    var expr: V3NormalizedExpr
    expr.exprId = v3NormalizedExprMakeId(sourcePath, lineNumber, columnNumber, kind, detail)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = v3NormalizedExprEndColumn(columnNumber, surfaceText)
    expr.kind = kind
    expr.detail = detail
    expr.surfaceText = surfaceText
    add(layer.exprs, expr)

fn v3NormalizedExprLayerAdd(total: var V3NormalizedExprLayer,
                            delta: V3NormalizedExprLayer) =
    total.sourceCount = total.sourceCount + delta.sourceCount
    total.questionResidualCount = total.questionResidualCount + delta.questionResidualCount
    for i in 0..<delta.exprs.len:
        add(total.exprs, v3NormalizedExprClone(delta.exprs[i]))

fn v3NormalizedExprLayerExprCount(layer: V3NormalizedExprLayer): int32 =
    return layer.exprs.len

fn v3NormalizedExprLayerCountKind(layer: V3NormalizedExprLayer,
                                  kind: V3NormalizedExprKind): int32 =
    var count: int32 = 0
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].kind == kind:
            count = count + 1
    return count

fn v3NormalizedExprLayerIfCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprIf)

fn v3NormalizedExprLayerRangeCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprRange)

fn v3NormalizedExprLayerComprehensionCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprComprehension)

fn v3NormalizedExprLayerStrFormatCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprStrFormat)

fn v3NormalizedExprLayerResultIntrinsicCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprResultIntrinsic)

fn v3NormalizedExprLayerTryCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprTry)

fn v3NormalizedExprLayerCallCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprCall)

fn v3NormalizedExprLayerHasExpr(layer: V3NormalizedExprLayer,
                                kind: V3NormalizedExprKind,
                                detail: str,
                                lineNumber: int32): bool =
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != kind:
            continue
        if expr.detail != detail:
            continue
        if expr.lineNumber != lineNumber:
            continue
        return true
    return false

fn v3ParserNormalizePath(pathRaw: str): str =
    var path = v3path.V3PathTrim(pathRaw)
    while path.len > 1:
        let last = path[path.len - 1]
        if last != '/' && last != '\\':
            break
        path = v3path.V3TextSlice(path, 0, path.len - 1)
    return path

fn v3ParserBaseName(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    return v3path.V3PathBaseName(path)

fn v3ParserFileStem(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    var start: int32 = 0
    if lastSep >= 0:
        start = lastSep + 1
    var lastDot: int32 = -1
    for i in start..<path.len:
        if path[i] == '.':
            lastDot = i
    if lastDot <= start:
        return v3path.V3TextSlice(path, start, path.len - start)
    return v3path.V3TextSlice(path, start, lastDot - start)

fn v3ParserLastPathPiece(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep < 0:
        return path
    if lastSep + 1 >= path.len:
        return ""
    return v3path.V3TextSlice(path, lastSep + 1, path.len - lastSep - 1)

fn v3ParserDirPart(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep <= 0:
        return ""
    return v3path.V3TextSlice(path, 0, lastSep)

fn v3ParserPackageManifestExists(dirRaw: str): bool =
    let dir = v3ParserNormalizePath(dirRaw)
    if dir == "":
        return false
    let manifestPath = v3path.V3PathJoin(dir, "cheng-package.toml")
    return v3path.V3PathFileExists(manifestPath)

fn v3ParserSharedV3Root(packageRootRaw: str): str =
    var cursor = v3ParserNormalizePath(packageRootRaw)
    while cursor != "":
        let cursorBase = v3path.V3PathBaseName(cursor)
        let cursorIsV3 = cursorBase == "v3"
        if cursorIsV3 && v3ParserPackageManifestExists(cursor):
            return cursor
        let parent = v3path.V3PathParentDir(cursor)
        if parent == "" || parent == cursor:
            break
        cursor = parent
    return ""

fn v3ParserWorkspaceRoot(packageRootRaw: str): str =
    let packageRoot = v3ParserNormalizePath(packageRootRaw)
    let sharedV3Root = v3ParserSharedV3Root(packageRoot)
    if sharedV3Root != "":
        let parent = v3path.V3PathParentDir(sharedV3Root)
        if parent != "":
            return parent
        return sharedV3Root
    return packageRoot

fn v3ParserPackageId(packageRootRaw: str): str =
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    if packageRoot == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<packageRoot.len:
        if packageRoot[i] == '/' || packageRoot[i] == '\\':
            lastSep = i
    var name: str = packageRoot
    if lastSep >= 0:
        name = v3path.V3TextSlice(packageRoot, lastSep + 1, packageRoot.len - lastSep - 1)
    if name == "v3":
        return "cheng/v3"
    if name == "":
        return ""
    return v3ParserConcat2("cheng/", name)

fn v3ParserSourceExists(path: str): bool =
    if path == "":
        return false
    if !v3path.V3PathFileExists(path):
        return false
    let size: int64 = v3path.V3PathFileSize(path)
    return size > int64(0)

fn v3ParserExprIsResultIntrinsicName(name: str): bool =
    if name == "Ok" || name == "Err":
        return true
    if name == "Value" || name == "Error":
        return true
    if name == "IsOk" || name == "IsErr":
        return true
    if name == "ErrorInfoOf":
        return true
    return false

fn v3ParserResultIntrinsicDetail(name: str): str =
    if name == "Ok":
        return "ok"
    if name == "Err":
        return "err"
    if name == "Value":
        return "value"
    if name == "Error":
        return "error"
    if name == "IsOk":
        return "is_ok"
    if name == "IsErr":
        return "is_err"
    if name == "ErrorInfoOf":
        return "error_info_of"
    return name

fn v3ParserIsIdentChar(ch: char): bool =
    let digit = ch >= '0' && ch <= '9'
    let upper = ch >= 'A' && ch <= 'Z'
    let lower = ch >= 'a' && ch <= 'z'
    return digit || upper || lower || ch == '_'

fn v3ParserPreviousToken(lineRaw: str,
                         stopExclusive: int32): str =
    if stopExclusive <= 0:
        return ""
    var end = stopExclusive - 1
    while end >= 0:
        if !v3ParserIsInlineSpace(lineRaw[end]):
            break
        end = end - 1
    if end < 0:
        return ""
    var start = end
    while start >= 0:
        if !v3ParserIsIdentChar(lineRaw[start]):
            break
        start = start - 1
    return v3path.V3TextSlice(lineRaw, start + 1, end - start)

fn v3ParserNextNonSpaceChar(lineRaw: str,
                            start: int32): char =
    var cursor = start
    while cursor < lineRaw.len:
        if !v3ParserIsInlineSpace(lineRaw[cursor]):
            return lineRaw[cursor]
        cursor = cursor + 1
    return char(0)

fn v3ParserSkipInlineSpaces(lineRaw: str,
                            start: int32): int32 =
    var cursor = start
    var scanning = true
    while cursor < lineRaw.len && scanning:
        if v3ParserIsInlineSpace(lineRaw[cursor]):
            cursor = cursor + 1
        else:
            scanning = false
    return cursor

fn v3ParserStripLineComment(lineRaw: str): str =
    let hashPos = v3ParserFindText(lineRaw, "#")
    if hashPos < 0:
        return lineRaw
    return v3path.V3TextSlice(lineRaw, 0, hashPos)

fn v3ParserLineKeywordPositions(lineRaw: str,
                                keyword: str): int32[] =
    var out: int32[] = []
    if keyword == "":
        return out
    if lineRaw.len < keyword.len:
        return out
    for i in 0..<(lineRaw.len - keyword.len + 1):
        var matched = true
        for j in 0..<keyword.len:
            if lineRaw[i + j] != keyword[j]:
                matched = false
                break
        if !matched:
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + keyword.len
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        add(out, i)
    return out

fn v3ParserAppendIfExprsLine(sourcePath: str,
                             lineNumber: int32,
                             lineRaw: str,
                             layer: var V3NormalizedExprLayer) =
    let positions = v3ParserLineKeywordPositions(lineRaw, "if")
    for i in 0..<positions.len:
        v3NormalizedExprLayerAppend(layer,
                                    sourcePath,
                                    lineNumber,
                                    positions[i] + 1,
                                    v3NormalizedExprIf,
                                    "keyword_if",
                                    "if")

fn v3ParserAppendFmtExprsLine(sourcePath: str,
                              lineNumber: int32,
                              lineRaw: str,
                              layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 3:
        return
    for i in 0..<(lineRaw.len - 2):
        if lineRaw[i] != 'F' || lineRaw[i + 1] != 'm' || lineRaw[i + 2] != 't':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 3
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        let prevToken = v3ParserPreviousToken(lineRaw, i)
        if prevToken == "fn" || prevToken == "func" || prevToken == "proc" ||
           prevToken == "method" || prevToken == "converter":
            continue
        let nextChar = v3ParserNextNonSpaceChar(lineRaw, rightPos)
        if nextChar == '"' || nextChar == '(' || nextChar == '[' || v3ParserIsIdentChar(nextChar):
            var detail = "fmt_call"
            if nextChar == '"':
                detail = "fmt_literal"
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprStrFormat,
                                        detail,
                                        "Fmt")
    return

fn v3ParserAppendResultIntrinsicExprsLine(sourcePath: str,
                                          lineNumber: int32,
                                          lineRaw: str,
                                          layer: var V3NormalizedExprLayer) =
    v3ParserAppendResultIntrinsicOkExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicErrExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicValueExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicErrorExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicIsOkExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicIsErrExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicErrorInfoOfExprsLine(sourcePath, lineNumber, lineRaw, layer)

fn v3ParserAppendResultIntrinsicOkExprsLine(sourcePath: str,
                                            lineNumber: int32,
                                            lineRaw: str,
                                            layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 2:
        return
    for i in 0..<(lineRaw.len - 1):
        if lineRaw[i] != 'O':
            continue
        if lineRaw[i + 1] != 'k':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 2
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "ok", "Ok")
    return

fn v3ParserAppendResultIntrinsicErrExprsLine(sourcePath: str,
                                             lineNumber: int32,
                                             lineRaw: str,
                                             layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 3:
        return
    for i in 0..<(lineRaw.len - 2):
        if lineRaw[i] != 'E':
            continue
        if lineRaw[i + 1] != 'r':
            continue
        if lineRaw[i + 2] != 'r':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 3
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "err", "Err")
    return

fn v3ParserAppendResultIntrinsicValueExprsLine(sourcePath: str,
                                               lineNumber: int32,
                                               lineRaw: str,
                                               layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 5:
        return
    for i in 0..<(lineRaw.len - 4):
        if lineRaw[i] != 'V':
            continue
        if lineRaw[i + 1] != 'a':
            continue
        if lineRaw[i + 2] != 'l':
            continue
        if lineRaw[i + 3] != 'u':
            continue
        if lineRaw[i + 4] != 'e':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 5
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "value", "Value")
    return

fn v3ParserAppendResultIntrinsicErrorExprsLine(sourcePath: str,
                                               lineNumber: int32,
                                               lineRaw: str,
                                               layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 5:
        return
    for i in 0..<(lineRaw.len - 4):
        if lineRaw[i] != 'E':
            continue
        if lineRaw[i + 1] != 'r':
            continue
        if lineRaw[i + 2] != 'r':
            continue
        if lineRaw[i + 3] != 'o':
            continue
        if lineRaw[i + 4] != 'r':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 5
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "error", "Error")
    return

fn v3ParserAppendResultIntrinsicIsOkExprsLine(sourcePath: str,
                                              lineNumber: int32,
                                              lineRaw: str,
                                              layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 4:
        return
    for i in 0..<(lineRaw.len - 3):
        if lineRaw[i] != 'I':
            continue
        if lineRaw[i + 1] != 's':
            continue
        if lineRaw[i + 2] != 'O':
            continue
        if lineRaw[i + 3] != 'k':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 4
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "is_ok", "IsOk")
    return

fn v3ParserAppendResultIntrinsicIsErrExprsLine(sourcePath: str,
                                               lineNumber: int32,
                                               lineRaw: str,
                                               layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 5:
        return
    for i in 0..<(lineRaw.len - 4):
        if lineRaw[i] != 'I':
            continue
        if lineRaw[i + 1] != 's':
            continue
        if lineRaw[i + 2] != 'E':
            continue
        if lineRaw[i + 3] != 'r':
            continue
        if lineRaw[i + 4] != 'r':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 5
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "is_err", "IsErr")
    return

fn v3ParserAppendResultIntrinsicErrorInfoOfExprsLine(sourcePath: str,
                                                     lineNumber: int32,
                                                     lineRaw: str,
                                                     layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 11:
        return
    for i in 0..<(lineRaw.len - 10):
        if lineRaw[i] != 'E':
            continue
        if lineRaw[i + 1] != 'r':
            continue
        if lineRaw[i + 2] != 'r':
            continue
        if lineRaw[i + 3] != 'o':
            continue
        if lineRaw[i + 4] != 'r':
            continue
        if lineRaw[i + 5] != 'I':
            continue
        if lineRaw[i + 6] != 'n':
            continue
        if lineRaw[i + 7] != 'f':
            continue
        if lineRaw[i + 8] != 'o':
            continue
        if lineRaw[i + 9] != 'O':
            continue
        if lineRaw[i + 10] != 'f':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 11
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "error_info_of", "ErrorInfoOf")
    return

fn v3ParserAppendRangeExprsLine(sourcePath: str,
                                lineNumber: int32,
                                lineRaw: str,
                                layer: var V3NormalizedExprLayer) =
    var i: int32 = 0
    while i + 1 < lineRaw.len:
        if lineRaw[i] == '.':
            if lineRaw[i + 1] != '.':
                i = i + 1
                continue
            if i + 2 < lineRaw.len:
                if lineRaw[i + 2] == '<':
                    v3NormalizedExprLayerAppend(layer,
                                                sourcePath,
                                                lineNumber,
                                                i + 1,
                                                v3NormalizedExprRange,
                                                "exclusive",
                                                "..<")
                    i = i + 3
                    continue
            else:
                v3NormalizedExprLayerAppend(layer,
                                            sourcePath,
                                            lineNumber,
                                            i + 1,
                                            v3NormalizedExprRange,
                                            "inclusive",
                                            "..")
                i = i + 2
                continue
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprRange,
                                        "inclusive",
                                        "..")
            i = i + 2
            continue
        i = i + 1

fn v3ParserAppendQuestionExprsLine(sourcePath: str,
                                   lineNumber: int32,
                                   lineRaw: str,
                                   layer: var V3NormalizedExprLayer) =
    for i in 0..<lineRaw.len:
        if lineRaw[i] != '?':
            continue
        let nextChar = v3ParserNextNonSpaceChar(lineRaw, i + 1)
        if nextChar == char(0) || nextChar == ',' || nextChar == ';' ||
           nextChar == ':' || nextChar == ')' || nextChar == ']' || nextChar == '}':
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprTry,
                                        "postfix_question",
                                        "?")
        else:
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprIf,
                                        "ternary",
                                        "?")

fn v3ParserCallExprUsesDedicatedNormalization(callNameRaw: str): bool =
    let callName = callNameRaw
    if callName == "Fmt":
        return true
    if callName == "Ok":
        return true
    if callName == "Err":
        return true
    if callName == "Value":
        return true
    if callName == "Error":
        return true
    if callName == "IsOk":
        return true
    if callName == "IsErr":
        return true
    if callName == "ErrorInfoOf":
        return true
    return false

fn v3ParserAppendCallExprsLine(sourcePath: str,
                               lineNumber: int32,
                               lineRaw: str,
                               callNames: str[],
                               detail: str,
                               layer: var V3NormalizedExprLayer) =
    if callNames.len <= 0:
        return
    var i: int32 = 0
    while i < lineRaw.len:
        if !v3ParserIsIdentChar(lineRaw[i]):
            i = i + 1
            continue
        var middleOfIdent = false
        if i > 0:
            middleOfIdent = v3ParserIsIdentChar(lineRaw[i - 1])
        if middleOfIdent:
            i = i + 1
            continue
        var stop = i
        while stop < lineRaw.len:
            if !v3ParserIsIdentChar(lineRaw[stop]):
                break
            stop = stop + 1
        let callName = v3path.V3TextSlice(lineRaw, i, stop - i)
        var qualifiedCallName = callName
        if i > 1 && lineRaw[i - 1] == '.':
            var qualifierStop: int32 = i - 1
            var qualifierStart: int32 = qualifierStop - 1
            while qualifierStart >= 0:
                if !v3ParserIsIdentChar(lineRaw[qualifierStart]):
                    break
                qualifierStart = qualifierStart - 1
            qualifierStart = qualifierStart + 1
            if qualifierStart < qualifierStop:
                let qualifier = v3path.V3TextSlice(lineRaw, qualifierStart, qualifierStop - qualifierStart)
                qualifiedCallName = v3ParserConcat3(qualifier, ".", callName)
        let prevToken = v3ParserPreviousToken(lineRaw, i)
        if prevToken == "fn" || prevToken == "func" || prevToken == "proc" ||
           prevToken == "method" || prevToken == "converter" || prevToken == "importc":
            i = stop
            continue
        let nextPos = v3ParserSkipInlineSpaces(lineRaw, stop)
        var hasCallParen = false
        if nextPos < lineRaw.len:
            hasCallParen = v3path.V3TextSlice(lineRaw, nextPos, 1) == "("
        var matchedSurfaceText = ""
        if hasCallParen && !v3ParserCallExprUsesDedicatedNormalization(callName):
            if qualifiedCallName != callName && v3ParserStringSeqContainsExact(callNames, qualifiedCallName):
                matchedSurfaceText = qualifiedCallName
            elif v3ParserStringSeqContainsExact(callNames, callName):
                matchedSurfaceText = callName
        if matchedSurfaceText != "":
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprCall,
                                        detail,
                                        matchedSurfaceText)
        i = stop
    return

fn v3ParserAppendComprehensionExprsLine(sourcePath: str,
                                        lineNumber: int32,
                                        lineRaw: str,
                                        layer: var V3NormalizedExprLayer) =
    let openPos = v3ParserFindText(lineRaw, "[")
    if openPos < 0:
        return
    let forPositions = v3ParserLineKeywordPositions(lineRaw, "for")
    let inPositions = v3ParserLineKeywordPositions(lineRaw, "in")
    if forPositions.len <= 0 || inPositions.len <= 0:
        return
    v3NormalizedExprLayerAppend(layer,
                                sourcePath,
                                lineNumber,
                                openPos + 1,
                                v3NormalizedExprComprehension,
                                "list_comprehension",
                                "[for in]")

fn v3ParserImportcCallNamesFromDecls(decls: V3NormalizedFunctionDecl[],
                                     names: var str[]) =
    var out: str[] = []
    for i in 0..<decls.len:
        if !decls[i].importc:
            continue
        if decls[i].name == "":
            continue
        v3ParserAddUniqueText(out, decls[i].name)
    names = out

fn v3ParserLocalCallNamesFromDecls(decls: V3NormalizedFunctionDecl[],
                                   names: var str[]) =
    var out: str[] = []
    for i in 0..<decls.len:
        if decls[i].importc:
            continue
        if decls[i].name == "":
            continue
        v3ParserAddUniqueText(out, decls[i].name)
    names = out

fn v3ParserBuildExprCallProfile(workspaceRootRaw: str,
                                packageRootRaw: str,
                                sourcePathRaw: str,
                                text: str,
                                profile: var V3NormalizedExprCallProfile,
                                err: var str): bool =
    let workspaceRoot = v3ParserNormalizePath(workspaceRootRaw)
    let packageRoot = v3ParserNormalizePath(packageRootRaw)
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "missing source path"
        return false
    profile.sourcePath = sourcePath
    profile.ownerModulePath = v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)
    profile.text = text
    profile.decls = []
    profile.importcCallNames = []
    profile.localCallNames = []
    profile.importEdges = []
    if !v3ParserReadNormalizedFunctionDecls(text, profile.decls, err):
        return false
    if workspaceRoot != "" && packageRoot != "":
        if !v3ParserReadImportEdges(workspaceRoot,
                                    packageRoot,
                                    profile.ownerModulePath,
                                    text,
                                    profile.importEdges,
                                    err):
            return false
    v3ParserImportcCallNamesFromDecls(profile.decls, profile.importcCallNames)
    v3ParserLocalCallNamesFromDecls(profile.decls, profile.localCallNames)
    err = ""
    return true

fn v3ParserCallProfileIndexForSourcePath(profiles: V3NormalizedExprCallProfile[],
                                         sourcePathRaw: str): int32 =
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    for i in 0..<profiles.len:
        if profiles[i].sourcePath == sourcePath:
            return i
    return -1

fn v3ParserImportEdgeQualifier(edge: V3ImportEdge): str =
    let aliasText = v3ParserIdentPrefix(v3path.V3PathTrim(edge.importAlias))
    if aliasText != "":
        return aliasText
    let sourceStem = v3ParserFileStem(edge.targetSourcePath)
    if sourceStem != "":
        return sourceStem
    return v3ParserLastPathPiece(edge.targetModulePath)

fn v3ParserCollectExternalCallNames(profiles: V3NormalizedExprCallProfile[],
                                    profileIndex: int32,
                                    names: var str[]) =
    var out: str[] = []
    if profileIndex < 0 || profileIndex >= profiles.len:
        names = out
        return
    let current = profiles[profileIndex]
    for edgeIndex in 0..<current.importEdges.len:
        let edge = current.importEdges[edgeIndex]
        if !edge.resolved:
            continue
        let targetProfileIndex = v3ParserCallProfileIndexForSourcePath(profiles, edge.targetSourcePath)
        if targetProfileIndex < 0:
            continue
        let qualifier = v3ParserImportEdgeQualifier(edge)
        if qualifier == "":
            continue
        let targetProfile = profiles[targetProfileIndex]
        let targetLocalCallNames = targetProfile.localCallNames
        var callIndex: int32 = 0
        while callIndex < targetLocalCallNames.len:
            v3ParserAddUniqueText(out, v3ParserConcat3(qualifier, ".", targetLocalCallNames[callIndex]))
            callIndex = callIndex + 1
        callIndex = 0
        while callIndex < targetProfile.importcCallNames.len:
            v3ParserAddUniqueText(out, v3ParserConcat3(qualifier, ".", targetProfile.importcCallNames[callIndex]))
            callIndex = callIndex + 1
    names = out

fn v3ParserReadNormalizedExprLayerFromTextWithKnownCalls(sourcePathRaw: str,
                                                         text: str,
                                                         importcCallNames: str[],
                                                         localCallNames: str[],
                                                         externalCallNames: str[],
                                                         layer: var V3NormalizedExprLayer,
                                                         err: var str): bool =
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "missing source path"
        return false
    layer = v3NormalizedExprLayerZero()
    layer.sourceCount = 1
    let lines = v3ParserSplitChar(text, '\n')
    for i in 0..<lines.len:
        let line = v3ParserStripLineComment(lines[i])
        if v3path.V3PathTrim(line) == "":
            continue
        let lineNumber = i + 1
        v3ParserAppendIfExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendQuestionExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendRangeExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendComprehensionExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendFmtExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendResultIntrinsicExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendCallExprsLine(sourcePath, lineNumber, line, localCallNames, "local_call", layer)
        v3ParserAppendCallExprsLine(sourcePath, lineNumber, line, externalCallNames, "external_call", layer)
        v3ParserAppendCallExprsLine(sourcePath, lineNumber, line, importcCallNames, "importc_call", layer)
    layer.questionResidualCount = 0
    err = ""
    return true

fn v3ParserReadNormalizedExprLayerFromText(sourcePathRaw: str,
                                           text: str,
                                           layer: var V3NormalizedExprLayer,
                                           err: var str): bool =
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "missing source path"
        return false
    var decls: V3NormalizedFunctionDecl[] = []
    var declErr = ""
    if !v3ParserReadNormalizedFunctionDecls(text, decls, declErr):
        err = declErr
        return false
    var importcCallNames: str[] = []
    var localCallNames: str[] = []
    v3ParserImportcCallNamesFromDecls(decls, importcCallNames)
    v3ParserLocalCallNamesFromDecls(decls, localCallNames)
    return v3ParserReadNormalizedExprLayerFromTextWithKnownCalls(sourcePath,
                                                                 text,
                                                                 importcCallNames,
                                                                 localCallNames,
                                                                 [],
                                                                 layer,
                                                                 err)

fn v3ParserReadNormalizedExprLayerFromPath(sourcePathRaw: str,
                                           layer: var V3NormalizedExprLayer,
                                           err: var str): bool =
    let sourcePath: str = v3ParserNormalizePath(sourcePathRaw)
    if !v3ParserSourceExists(sourcePath):
        err = "source file missing"
        return false
    let text: str = v3path.V3ReadTextFile("", sourcePath)
    if text == "":
        err = "failed to read source"
        return false
    return v3ParserReadNormalizedExprLayerFromText(sourcePath, text, layer, err)

fn v3ParserStringSeqContains(items: str[], targetRaw: str): bool =
    let target = v3path.V3PathTrim(targetRaw)
    for i in 0..<items.len:
        if items[i] == target:
            return true
    return false

fn v3ParserStringSeqContainsExact(items: str[], target: str): bool =
    for i in 0..<items.len:
        if items[i] == target:
            return true
    return false

fn v3ParserIsInlineSpace(ch: char): bool =
    let code = int32(ch)
    if code == 32:
        return true
    if code == 9:
        return true
    return false

fn v3ParserFirstToken(textRaw: str): str =
    let text = v3path.V3PathTrim(textRaw)
    if text == "":
        return ""
    var start: int32 = 0
    while start < text.len:
        if !v3ParserIsInlineSpace(text[start]):
            break
        start = start + 1
    var stop: int32 = start
    while stop < text.len:
        if v3ParserIsInlineSpace(text[stop]):
            break
        stop = stop + 1
    if stop <= start:
        return ""
    return v3path.V3TextSlice(text, start, stop - start)

fn v3ParserIdentPrefix(text: str): str =
    var stop: int32 = 0
    for i in 0..<text.len:
        let ch = text[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower || ch == '_':
            stop = i + 1
        else:
            break
    if stop <= 0:
        return ""
    return v3path.V3TextSlice(text, 0, stop)
    
fn v3ParserSplitChar(textRaw: str, sep: char): str[] =
    let text = textRaw
    var out: str[] = []
    var start: int32 = 0
    for i in 0..<text.len:
        if text[i] == sep:
            add(out, v3path.V3TextSlice(text, start, i - start))
            start = i + 1
    if start <= text.len:
        add(out, v3path.V3TextSlice(text, start, text.len - start))
    return out

fn v3ParserJoinSlash(items: str[]): str =
    var out = buffer.NewByteBuffer()
    let slash: str = "/"
    var wrote = false
    for i in 0..<items.len:
        if items[i] == "":
            continue
        if wrote:
            buffer.AppendBytes(out, slash)
        buffer.AppendBytes(out, items[i])
        wrote = true
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn v3ParserStartsWith(textRaw: str, prefixRaw: str): bool =
    let text = v3path.V3PathTrim(textRaw)
    let prefix = v3path.V3PathTrim(prefixRaw)
    if prefix.len > text.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn v3ParserLineStartsWith(lineRaw: str, prefix: str): bool =
    return v3ParserStartsWith(lineRaw, prefix)

fn v3ParserFindText(text: str, needle: str): int32 =
    if needle.len <= 0:
        return 0
    if text.len < needle.len:
        return -1
    for i in 0..<(text.len - needle.len + 1):
        var matched = true
        for j in 0..<needle.len:
            if text[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn v3ParserCompilerTopLevelExportName(lineRaw: str): str =
    let line = v3path.V3PathTrim(lineRaw)
    if !v3ParserStartsWith(line, "@compiler_top_level("):
        return ""
    let exportPos = v3ParserFindText(line, "export_name")
    if exportPos < 0:
        return ""
    let quoteStart = v3ParserFindText(v3path.V3TextSlice(line, exportPos, line.len - exportPos), "\"")
    if quoteStart < 0:
        return ""
    let valueStart = exportPos + quoteStart + 1
    let tail = v3path.V3TextSlice(line, valueStart, line.len - valueStart)
    let quoteEnd = v3ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return v3path.V3TextSlice(line, valueStart, quoteEnd)

fn v3ParserExportcNameFromAnnotation(lineRaw: str): str =
    let line = v3path.V3PathTrim(lineRaw)
    if !v3ParserStartsWith(line, "@exportc("):
        return ""
    let quoteStart = v3ParserFindText(line, "\"")
    if quoteStart < 0:
        return ""
    let tail = v3path.V3TextSlice(line, quoteStart + 1, line.len - (quoteStart + 1))
    let quoteEnd = v3ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return v3path.V3TextSlice(line, quoteStart + 1, quoteEnd)

fn v3ParserIsImportcAnnotation(lineRaw: str): bool =
    return v3ParserStartsWith(lineRaw, "@importc(")

fn v3ParserHasLeadingIndent(lineRaw: str): bool =
    if len(lineRaw) <= 0:
        return false
    let head = int32(lineRaw[0])
    return head == 32 || head == 9

fn v3ParserTopLevelFunctionKeyword(lineRaw: str): str =
    if v3ParserHasLeadingIndent(lineRaw):
        return ""
    let line = v3path.V3PathTrim(lineRaw)
    if v3ParserStartsWith(line, "importc fn "):
        return "fn"
    if v3ParserStartsWith(line, "fn "):
        return "fn"
    if v3ParserStartsWith(line, "func "):
        return "func"
    if v3ParserStartsWith(line, "proc "):
        return "proc"
    if v3ParserStartsWith(line, "method "):
        return "method"
    if v3ParserStartsWith(line, "converter "):
        return "converter"
    return ""

fn v3ParserFunctionNameFromLine(lineRaw: str): str =
    if v3ParserHasLeadingIndent(lineRaw):
        return ""
    let line = v3path.V3PathTrim(lineRaw)
    var prefixLen: int32 = 0
    if v3ParserStartsWith(line, "importc fn "):
        prefixLen = len("importc fn ")
    elif v3ParserStartsWith(line, "fn "):
        prefixLen = len("fn ")
    elif v3ParserStartsWith(line, "func "):
        prefixLen = len("func ")
    elif v3ParserStartsWith(line, "proc "):
        prefixLen = len("proc ")
    elif v3ParserStartsWith(line, "method "):
        prefixLen = len("method ")
    elif v3ParserStartsWith(line, "converter "):
        prefixLen = len("converter ")
    if prefixLen <= 0:
        return ""
    if prefixLen >= line.len:
        return ""
    let tail = v3path.V3TextSlice(line, prefixLen, line.len - prefixLen)
    let firstToken = v3ParserFirstToken(tail)
    return v3ParserIdentPrefix(firstToken)

fn v3ParserReadNormalizedFunctionDecls(textRaw: str,
                                       decls: var V3NormalizedFunctionDecl[],
                                       err: var str): bool =
    var emptyDecls: V3NormalizedFunctionDecl[] = []
    decls = emptyDecls
    let lines: str[] = v3ParserSplitChar(textRaw, '\n')
    var pendingImportc = false
    var pendingExplicitExportName: str = ""
    for i in 0..<lines.len:
        let lineRaw = lines[i]
        let trimmed = v3path.V3PathTrim(lineRaw)
        if trimmed == "":
            continue
        if v3ParserHasLeadingIndent(lineRaw):
            continue
        let compilerExportName = v3ParserCompilerTopLevelExportName(trimmed)
        if compilerExportName != "":
            pendingExplicitExportName = compilerExportName
            continue
        let exportcName = v3ParserExportcNameFromAnnotation(trimmed)
        if exportcName != "":
            pendingExplicitExportName = exportcName
            continue
        if v3ParserIsImportcAnnotation(trimmed):
            pendingImportc = true
            pendingExplicitExportName = ""
            continue
        if v3ParserStartsWith(trimmed, "@"):
            continue
        let keyword = v3ParserTopLevelFunctionKeyword(lineRaw)
        if keyword == "":
            pendingImportc = false
            pendingExplicitExportName = ""
            continue
        if keyword != "fn":
            err = v3ParserConcat3("unsupported top-level function alias '", keyword, "'")
            return false
        let functionName = v3ParserFunctionNameFromLine(lineRaw)
        if functionName == "":
            pendingImportc = false
            pendingExplicitExportName = ""
            continue
        let inlineImportc = v3ParserStartsWith(trimmed, "importc fn ")
        var decl: V3NormalizedFunctionDecl
        decl.name = functionName
        decl.lineIndex = i + 1
        decl.importc = pendingImportc || inlineImportc
        decl.explicitExportName = decl.importc ? "" : pendingExplicitExportName
        decl.surfaceKeyword = inlineImportc ? "importc fn" : "fn"
        add(decls, decl)
        pendingImportc = false
        pendingExplicitExportName = ""
    err = ""
    return true

fn v3ParserContainsCompilerPrefix(lineRaw: str): bool =
    let line = v3path.V3PathTrim(lineRaw)
    if v3ParserStartsWith(line, "import "):
        return true
    if v3ParserStartsWith(line, "type"):
        return true
    if v3ParserTopLevelFunctionKeyword(line) != "":
        return true
    if v3ParserStartsWith(line, "iterator "):
        return true
    if v3ParserStartsWith(line, "const "):
        return true
    if v3ParserStartsWith(line, "let "):
        return true
    if v3ParserStartsWith(line, "var "):
        return true
    return false

fn v3ParserModulePathTail(modulePath: str, skipCount: int32): str =
    let modulePathTrim = v3path.V3PathTrim(modulePath)
    let parts = v3ParserSplitChar(modulePathTrim, '/')
    var out: str[] = []
    for i in skipCount..<parts.len:
        let rawPiece = parts[i]
        let piece = v3path.V3PathTrim(rawPiece)
        if piece != "":
            add(out, piece)
    return v3ParserJoinSlash(out)

fn v3ParserPathSlash(pathRaw: str): str =
    return v3ParserJoinSlash(v3ParserSplitChar(pathRaw, '\\'))

fn v3ParserRelWithoutExt(pathRaw: str): str =
    let path = v3ParserPathSlash(v3ParserNormalizePath(pathRaw))
    if path.len >= 6 && v3path.V3TextSlice(path, path.len - 6, 6) == ".cheng":
        return v3path.V3TextSlice(path, 0, path.len - 6)
    return path

fn v3ParserSharedV3PackageRoot(workspaceRootRaw: str): str =
    let workspaceRoot = v3ParserNormalizePath(workspaceRootRaw)
    if workspaceRoot == "":
        return ""
    let sharedV3Root = v3ParserNormalizePath(v3path.V3PathJoin(workspaceRoot, "v3"))
    if v3ParserPackageManifestExists(sharedV3Root):
        return sharedV3Root
    return ""

fn v3ParserModulePathToSourcePath(workspaceRootRaw: str, packageRootRaw: str, modulePathRaw: str): str =
    let workspaceRoot: str = v3ParserNormalizePath(workspaceRootRaw)
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    let modulePath: str = v3path.V3PathTrim(modulePathRaw)
    if modulePath == "":
        return ""
    if v3ParserStartsWith(modulePath, "std/") && modulePath.len > 4:
        let rel: str = v3ParserModulePathTail(modulePath, 1)
        return v3ParserConcat3(v3ParserConcat2(workspaceRoot, "/src/std/"), rel, ".cheng")
    let sharedV3PackageRoot: str = v3ParserSharedV3PackageRoot(workspaceRoot)
    if sharedV3PackageRoot != "" &&
       v3ParserStartsWith(modulePath, "cheng/v3/") &&
       modulePath.len > 9:
        let rel: str = v3ParserModulePathTail(modulePath, 2)
        return v3ParserConcat3(v3ParserConcat2(sharedV3PackageRoot, "/src/"), rel, ".cheng")
    let packageId: str = v3ParserPackageId(packageRoot)
    let packagePrefix: str = v3ParserConcat2(packageId, "/")
    if packageId != "" && modulePath.len > packageId.len && v3ParserStartsWith(modulePath, packagePrefix):
        let rel: str = v3ParserModulePathTail(modulePath, 2)
        return v3ParserConcat3(v3ParserConcat2(packageRoot, "/src/"), rel, ".cheng")
    return ""

fn v3ParserSourcePathToModulePath(workspaceRootRaw: str, packageRootRaw: str, sourcePathRaw: str): str =
    let workspaceRoot: str = v3ParserNormalizePath(workspaceRootRaw)
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    let sourcePath: str = v3ParserNormalizePath(sourcePathRaw)
    let packagePrefix: str = v3ParserConcat2(packageRoot, "/src/")
    if v3ParserStartsWith(sourcePath, packagePrefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                packagePrefix.len,
                                                                sourcePath.len - packagePrefix.len))
        let packageId: str = v3ParserPackageId(packageRoot)
        if rel == "":
            return packageId
        return v3ParserConcat3(packageId, "/", rel)
    let sharedV3PackageRoot: str = v3ParserSharedV3PackageRoot(workspaceRoot)
    let sharedV3Prefix: str = v3ParserConcat2(sharedV3PackageRoot, "/src/")
    if sharedV3PackageRoot != "" && v3ParserStartsWith(sourcePath, sharedV3Prefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                sharedV3Prefix.len,
                                                                sourcePath.len - sharedV3Prefix.len))
        if rel == "":
            return "cheng/v3"
        return v3ParserConcat2("cheng/v3/", rel)
    let stdPrefix: str = v3ParserConcat2(workspaceRoot, "/src/std/")
    if v3ParserStartsWith(sourcePath, stdPrefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                stdPrefix.len,
                                                                sourcePath.len - stdPrefix.len))
        if rel == "":
            return "std"
        return v3ParserConcat2("std/", rel)
    return v3ParserFileStem(sourcePath)

fn v3ParserHasCompilerTopLevel(textRaw: str): bool =
    var decls: V3NormalizedFunctionDecl[] = []
    var err = ""
    if v3ParserReadNormalizedFunctionDecls(textRaw, decls, err):
        if decls.len > 0:
            return true
    let lines = v3ParserSplitChar(textRaw, '\n')
    for i in 0..<lines.len:
        if v3ParserContainsCompilerPrefix(lines[i]):
            return true
    return false

fn v3ParserMainFunctionPresent(textRaw: str): bool =
    var decls: V3NormalizedFunctionDecl[] = []
    var err = ""
    if !v3ParserReadNormalizedFunctionDecls(textRaw, decls, err):
        return false
    for i in 0..<decls.len:
        if decls[i].importc:
            continue
        if decls[i].name == "main":
            return true
    return false

fn v3ParserReadImportEdges(workspaceRoot: str,
                           packageRoot: str,
                           ownerModulePath: str,
                           textRaw: str,
                           edges: var V3ImportEdge[],
                           err: var str): bool =
    let lines: str[] = v3ParserSplitChar(textRaw, '\n')
    edges = []
    for i in 0..<lines.len:
        let rawLine = lines[i]
        let line = v3path.V3PathTrim(rawLine)
        if !v3path.V3TextStartsWith(line, "import "):
            continue
        let importTail = v3path.V3TextSlice(line, 7, line.len - 7)
        let asMarker = " as "
        let asPos = v3ParserFindText(importTail, asMarker)
        var modulePath = ""
        var importAlias = ""
        if asPos >= 0:
            modulePath = v3ParserFirstToken(v3path.V3TextSlice(importTail, 0, asPos))
            let aliasTailStart = asPos + len(asMarker)
            if aliasTailStart < importTail.len:
                let aliasTail = v3path.V3TextSlice(importTail,
                                                   aliasTailStart,
                                                   importTail.len - aliasTailStart)
                importAlias = v3ParserIdentPrefix(v3ParserFirstToken(aliasTail))
        else:
            modulePath = v3ParserFirstToken(importTail)
        if modulePath == "":
            err = "v3 parser: malformed import"
            return false
        let sourcePath = v3ParserModulePathToSourcePath(workspaceRoot, packageRoot, modulePath)
        let resolved = v3ParserSourceExists(sourcePath)
        var edge: V3ImportEdge
        edge.ownerModulePath = ownerModulePath
        edge.targetModulePath = modulePath
        edge.targetSourcePath = sourcePath
        edge.importAlias = importAlias
        edge.resolved = resolved
        add(edges, edge)
    err = ""
    return true

fn v3ImportEdgeTargetSourcePath(edge: V3ImportEdge): str =
    return edge.targetSourcePath

fn v3ParserAddUniqueImportEdge(edges: var V3ImportEdge[],
                               edge: V3ImportEdge) =
    for i in 0..<edges.len:
        if edges[i].ownerModulePath != edge.ownerModulePath:
            continue
        if edges[i].targetModulePath != edge.targetModulePath:
            continue
        if edges[i].importAlias != edge.importAlias:
            continue
        return
    add(edges, edge)

fn v3ParserAddUniqueText(items: var str[],
                         text: str) =
    let value = v3path.V3PathTrim(text)
    if value == "":
        return
    for i in 0..<items.len:
        if items[i] == value:
            return
    add(items, value)

fn v3ParserCollectClosure(workspaceRoot: str,
                          packageRoot: str,
                          sourcePathRaw: str,
                          seen: var str[],
                          ordered: var str[],
                          importEdges: var V3ImportEdge[],
                          unresolved: var int32,
                          err: var str): bool =
    let sourcePath: str = v3path.V3PathTrim(sourcePathRaw)
    if sourcePath == "":
        err = "v3 parser: missing closure source path"
        return false
    if v3ParserStringSeqContains(seen, sourcePath):
        err = ""
        return true
    if !v3ParserSourceExists(sourcePath):
        err = "v3 parser: missing source"
        return false
    if !v3ParserStringSeqContains(seen, sourcePath):
        add(seen, sourcePath)
        add(ordered, sourcePath)
    var scanPos: int32 = 0
    while scanPos < ordered.len:
        let currentSourcePath = ordered[scanPos]
        scanPos = scanPos + 1
        let text = v3path.V3ReadTextFile("", currentSourcePath)
        var normalizedDecls: V3NormalizedFunctionDecl[] = []
        var normalizedErr = ""
        if !v3ParserReadNormalizedFunctionDecls(text, normalizedDecls, normalizedErr):
            err = normalizedErr
            return false
        let ownerModulePath = v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, currentSourcePath)
        var edges: V3ImportEdge[]
        if !v3ParserReadImportEdges(workspaceRoot, packageRoot, ownerModulePath, text, edges, err):
            return false
        for i in 0..<edges.len:
            v3ParserAddUniqueImportEdge(importEdges, edges[i])
            let childSourcePath = edges[i].targetSourcePath
            if !edges[i].resolved:
                unresolved = unresolved + 1
                continue
            if v3ParserStringSeqContains(seen, childSourcePath):
                continue
            add(seen, childSourcePath)
            add(ordered, childSourcePath)
    err = ""
    return true

fn v3ParseOrdinarySourceStub(packageRootRaw: str,
                             sourcePathRaw: str,
                             parsed: var V3ParsedSourceStub,
                             err: var str): bool =
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    let sourcePath: str = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "v3 parser: missing source path"
        return false
    if !v3ParserSourceExists(sourcePath):
        err = "v3 parser: source file missing"
        return false
    let workspaceRoot: str = v3ParserWorkspaceRoot(packageRoot)
    let packageId: str = v3ParserPackageId(packageRoot)
    let moduleStem: str = v3ParserFileStem(sourcePath)
    let rootText: str = v3path.V3ReadTextFile("", sourcePath)
    if rootText == "":
        err = "v3 parser: failed to read source"
        return false
    var rootDecls: V3NormalizedFunctionDecl[] = []
    if !v3ParserReadNormalizedFunctionDecls(rootText, rootDecls, err):
        return false
    var seen: str[] = []
    var ordered: str[] = []
    var importEdges: V3ImportEdge[] = []
    var exprLayer = v3NormalizedExprLayerZero()
    var unresolved: int32 = 0
    if !v3ParserCollectClosure(workspaceRoot, packageRoot, sourcePath, seen, ordered, importEdges, unresolved, err):
        return false
    var sourceProfiles: V3NormalizedExprCallProfile[] = []
    for i in 0..<ordered.len:
        let sourceText = v3path.V3ReadTextFile("", ordered[i])
        var profile: V3NormalizedExprCallProfile
        var profileErr = ""
        if !v3ParserBuildExprCallProfile(workspaceRoot, packageRoot, ordered[i], sourceText, profile, profileErr):
            err = profileErr
            return false
        add(sourceProfiles, profile)
    for i in 0..<sourceProfiles.len:
        var sourceExprLayer = v3NormalizedExprLayerZero()
        var sourceExternalCallNames: str[] = []
        v3ParserCollectExternalCallNames(sourceProfiles, i, sourceExternalCallNames)
        if !v3ParserReadNormalizedExprLayerFromTextWithKnownCalls(sourceProfiles[i].sourcePath,
                                                                  sourceProfiles[i].text,
                                                                  sourceProfiles[i].importcCallNames,
                                                                  sourceProfiles[i].localCallNames,
                                                                  sourceExternalCallNames,
                                                                  sourceExprLayer,
                                                                  err):
            err = v3ParserConcat4("v3 parser: ", sourceProfiles[i].sourcePath, ": ", err)
            return false
        v3NormalizedExprLayerAdd(exprLayer, sourceExprLayer)
    var ownerModulePaths: str[] = []
    for i in 0..<ordered.len:
        v3ParserAddUniqueText(ownerModulePaths,
                              v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, ordered[i]))
    parsed.workspaceRoot = workspaceRoot
    parsed.packageRoot = packageRoot
    parsed.packageId = packageId
    parsed.entrySourcePath = sourcePath
    parsed.sourcePath = sourcePath
    parsed.moduleStem = moduleStem
    parsed.syntaxTag = "v3_normalized_source_stub_v3"
    parsed.sourceKind = v3ParsedOrdinarySource
    parsed.ownerModulePaths = ownerModulePaths
    parsed.importEdges = importEdges
    parsed.orderedClosureSourcePaths = ordered
    parsed.normalizedExprLayer = exprLayer
    parsed.hasCompilerTopLevel = v3ParserHasCompilerTopLevel(rootText)
    parsed.mainFunctionPresent = false
    for i in 0..<rootDecls.len:
        if rootDecls[i].importc:
            continue
        if rootDecls[i].name == "main":
            parsed.mainFunctionPresent = true
    parsed.unresolvedImportCount = unresolved
    err = ""
    return true
