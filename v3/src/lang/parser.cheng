import std/result
import std/buffer
import std/rawbytes
import std/system
import cheng/v3/tooling/path as v3path

type
    V3ParsedSourceKind = enum
        v3ParsedOrdinarySource

    V3ImportEdge =
        ownerModulePath: str
        targetModulePath: str
        targetSourcePath: str
        importAlias: str
        resolved: bool

    V3NormalizedExprKind = enum
        v3NormalizedExprIf
        v3NormalizedExprRange
        v3NormalizedExprComprehension
        v3NormalizedExprStrFormat
        v3NormalizedExprResultIntrinsic
        v3NormalizedExprCall
        v3NormalizedExprTry

    V3NormalizedExpr =
        exprId: str
        sourcePath: str
        lineNumber: int32
        columnNumber: int32
        endLineNumber: int32
        endColumnNumber: int32
        kind: V3NormalizedExprKind
        detail: str
        surfaceText: str

    V3NormalizedExprLayer =
        sourceCount: int32
        exprs: V3NormalizedExpr[]
        questionResidualCount: int32

    V3ParsedSourceStub =
        workspaceRoot: str
        packageRoot: str
        packageId: str
        entrySourcePath: str
        sourcePath: str
        moduleStem: str
        syntaxTag: str
        sourceKind: V3ParsedSourceKind
        ownerModulePaths: str[]
        importEdges: V3ImportEdge[]
        orderedClosureSourcePaths: str[]
        normalizedExprLayer: V3NormalizedExprLayer
        hasCompilerTopLevel: bool
        mainFunctionPresent: bool
        unresolvedImportCount: int32

    V3NormalizedFunctionDecl =
        name: str
        lineIndex: int32
        importc: bool
        explicitExportName: str
        surfaceKeyword: str

    V3NormalizedExprCallProfile =
        sourcePath: str
        ownerModulePath: str
        text: str
        lines: str[]
        decls: V3NormalizedFunctionDecl[]
        importcCallNames: str[]
        localCallNames: str[]
        importEdges: V3ImportEdge[]
        maxQualifiedCallDepth: int32

    V3NormalizedExprResolvedCallTarget =
        sourcePath: str
        importc: bool
        reason: str

    V3ParserImportedTargetLookup =
        targetProfileIndex: int32
        reason: str

    V3ParserTextSeqCacheEntry =
        profileIndex: int32
        items: str[]

    V3ParserTextLookupBucket =
        keyLen: int32
        firstCode: int32
        lastCode: int32
        dotCount: int32
        items: str[]

    V3ParserTextLookup =
        slots: int32[]
        buckets: V3ParserTextLookupBucket[]
        totalCount: int32

fn v3ParsedSourceKindText(kind: V3ParsedSourceKind): str =
    if kind == v3ParsedOrdinarySource:
        return "ordinary_cheng_source"
    return "unknown"

fn v3ParsedSourceWorkspaceRoot(parsed: V3ParsedSourceStub): str =
    return parsed.workspaceRoot

fn v3NormalizedExprKindText(kind: V3NormalizedExprKind): str =
    if kind == v3NormalizedExprIf:
        return "IfExpr"
    if kind == v3NormalizedExprRange:
        return "RangeExpr"
    if kind == v3NormalizedExprComprehension:
        return "ComprehensionExpr"
    if kind == v3NormalizedExprStrFormat:
        return "StrFormatExpr"
    if kind == v3NormalizedExprResultIntrinsic:
        return "ResultIntrinsic"
    if kind == v3NormalizedExprCall:
        return "CallExpr"
    if kind == v3NormalizedExprTry:
        return "TryExpr"
    return "UnknownExpr"

fn v3NormalizedExprClone(expr: V3NormalizedExpr): V3NormalizedExpr =
    var out: V3NormalizedExpr
    out.exprId = expr.exprId
    out.sourcePath = expr.sourcePath
    out.lineNumber = expr.lineNumber
    out.columnNumber = expr.columnNumber
    out.endLineNumber = expr.endLineNumber
    out.endColumnNumber = expr.endColumnNumber
    out.kind = expr.kind
    out.detail = expr.detail
    out.surfaceText = expr.surfaceText
    return out

fn v3NormalizedExprEndColumn(columnNumber: int32,
                             surfaceText: str): int32 =
    if len(surfaceText) <= 0:
        return columnNumber
    return columnNumber + len(surfaceText) - 1

fn v3ParserConcat2(a: str, b: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserConcat3(a: str, b: str, c: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserConcat4(a: str, b: str, c: str, d: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    if d != "":
        buffer.AppendBytes(buf, d)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserOwnedText(text: str): str =
    return newStringCopy(strDataPtr(text), strLenFast(text))

fn v3NormalizedExprMakeId(sourcePath: str,
                          lineNumber: int32,
                          columnNumber: int32,
                          kind: V3NormalizedExprKind,
                          detail: str): str =
    var buf = buffer.NewByteBuffer()
    let hash: str = "#"
    let colon: str = ":"
    let lineText: str = intToStr(lineNumber)
    let columnText: str = intToStr(columnNumber)
    let kindText: str = v3NormalizedExprKindText(kind)
    buffer.AppendBytes(buf, sourcePath)
    buffer.AppendBytes(buf, hash)
    buffer.AppendBytes(buf, lineText)
    buffer.AppendBytes(buf, colon)
    buffer.AppendBytes(buf, columnText)
    buffer.AppendBytes(buf, colon)
    buffer.AppendBytes(buf, kindText)
    buffer.AppendBytes(buf, colon)
    buffer.AppendBytes(buf, detail)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3NormalizedExprLayerClone(layer: V3NormalizedExprLayer): V3NormalizedExprLayer =
    var out: V3NormalizedExprLayer
    out.sourceCount = 0
    out.exprs = []
    out.questionResidualCount = layer.questionResidualCount
    out.sourceCount = layer.sourceCount
    for i in 0..<layer.exprs.len:
        add(out.exprs, v3NormalizedExprClone(layer.exprs[i]))
    return out

fn v3NormalizedExprLayerZero(): V3NormalizedExprLayer =
    var out: V3NormalizedExprLayer
    out.sourceCount = 0
    out.exprs = []
    out.questionResidualCount = 0
    return out

fn v3NormalizedExprLayerAppend(layer: var V3NormalizedExprLayer,
                               sourcePath: str,
                               lineNumber: int32,
                               columnNumber: int32,
                               kind: V3NormalizedExprKind,
                               detail: str,
                               surfaceText: str) =
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].sourcePath != sourcePath:
            continue
        if layer.exprs[i].lineNumber != lineNumber:
            continue
        if layer.exprs[i].columnNumber != columnNumber:
            continue
        if layer.exprs[i].kind != kind:
            continue
        if layer.exprs[i].detail != detail:
            continue
        if layer.exprs[i].surfaceText != surfaceText:
            continue
        return
    var expr: V3NormalizedExpr
    expr.exprId = v3NormalizedExprMakeId(sourcePath, lineNumber, columnNumber, kind, detail)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = v3NormalizedExprEndColumn(columnNumber, surfaceText)
    expr.kind = kind
    expr.detail = detail
    expr.surfaceText = surfaceText
    add(layer.exprs, expr)

fn v3NormalizedExprLayerAdd(total: var V3NormalizedExprLayer,
                            delta: V3NormalizedExprLayer) =
    total.sourceCount = total.sourceCount + delta.sourceCount
    total.questionResidualCount = total.questionResidualCount + delta.questionResidualCount
    for i in 0..<delta.exprs.len:
        add(total.exprs, v3NormalizedExprClone(delta.exprs[i]))

fn v3NormalizedExprLayerExprCount(layer: V3NormalizedExprLayer): int32 =
    return layer.exprs.len

fn v3NormalizedExprLayerCountKind(layer: V3NormalizedExprLayer,
                                  kind: V3NormalizedExprKind): int32 =
    var count: int32 = 0
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].kind == kind:
            count = count + 1
    return count

fn v3NormalizedExprLayerIfCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprIf)

fn v3NormalizedExprLayerRangeCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprRange)

fn v3NormalizedExprLayerComprehensionCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprComprehension)

fn v3NormalizedExprLayerStrFormatCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprStrFormat)

fn v3NormalizedExprLayerResultIntrinsicCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprResultIntrinsic)

fn v3NormalizedExprLayerTryCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprTry)

fn v3NormalizedExprLayerCallCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprCall)

fn v3NormalizedExprLayerHasExpr(layer: V3NormalizedExprLayer,
                                kind: V3NormalizedExprKind,
                                detail: str,
                                lineNumber: int32): bool =
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != kind:
            continue
        if kind == v3NormalizedExprCall:
            if v3ParserCallExprDetailKind(expr.detail) != detail:
                continue
        elif expr.detail != detail:
            continue
        if expr.lineNumber != lineNumber:
            continue
        return true
    return false

fn v3ParserNormalizePath(pathRaw: str): str =
    var path = v3path.V3PathTrim(pathRaw)
    while path.len > 1:
        let last = path[path.len - 1]
        if last != '/' && last != '\\':
            break
        path = v3path.V3TextSlice(path, 0, path.len - 1)
    return path

fn v3ParserBaseName(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    return v3path.V3PathBaseName(path)

fn v3ParserFileStem(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    var start: int32 = 0
    if lastSep >= 0:
        start = lastSep + 1
    var lastDot: int32 = -1
    for i in start..<path.len:
        if path[i] == '.':
            lastDot = i
    if lastDot <= start:
        return v3path.V3TextSlice(path, start, path.len - start)
    return v3path.V3TextSlice(path, start, lastDot - start)

fn v3ParserLastPathPiece(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep < 0:
        return path
    if lastSep + 1 >= path.len:
        return ""
    return v3path.V3TextSlice(path, lastSep + 1, path.len - lastSep - 1)

fn v3ParserDirPart(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep <= 0:
        return ""
    return v3path.V3TextSlice(path, 0, lastSep)

fn v3ParserPackageManifestExists(dirRaw: str): bool =
    let dir = v3ParserNormalizePath(dirRaw)
    if dir == "":
        return false
    let manifestPath = v3path.V3PathJoin(dir, "cheng-package.toml")
    return v3path.V3PathFileExists(manifestPath)

fn v3ParserSharedV3Root(packageRootRaw: str): str =
    var cursor = v3ParserNormalizePath(packageRootRaw)
    while cursor != "":
        let cursorBase = v3path.V3PathBaseName(cursor)
        let cursorIsV3 = cursorBase == "v3"
        if cursorIsV3 && v3ParserPackageManifestExists(cursor):
            return cursor
        let parent = v3path.V3PathParentDir(cursor)
        if parent == "" || parent == cursor:
            break
        cursor = parent
    return ""

fn v3ParserWorkspaceRoot(packageRootRaw: str): str =
    let packageRoot = v3ParserNormalizePath(packageRootRaw)
    let sharedV3Root = v3ParserSharedV3Root(packageRoot)
    if sharedV3Root != "":
        let parent = v3path.V3PathParentDir(sharedV3Root)
        if parent != "":
            return parent
        return sharedV3Root
    return packageRoot

fn v3ParserPackageId(packageRootRaw: str): str =
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    if packageRoot == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<packageRoot.len:
        if packageRoot[i] == '/' || packageRoot[i] == '\\':
            lastSep = i
    var name: str = packageRoot
    if lastSep >= 0:
        name = v3path.V3TextSlice(packageRoot, lastSep + 1, packageRoot.len - lastSep - 1)
    if name == "v3":
        return "cheng/v3"
    if name == "":
        return ""
    return v3ParserConcat2("cheng/", name)

fn v3ParserSourceExists(path: str): bool =
    if path == "":
        return false
    if !v3path.V3PathFileExists(path):
        return false
    let size: int64 = v3path.V3PathFileSize(path)
    return size > int64(0)

fn v3ParserExprIsResultIntrinsicName(name: str): bool =
    if name == "Ok" || name == "Err":
        return true
    if name == "Value" || name == "Error":
        return true
    if name == "IsOk" || name == "IsErr":
        return true
    if name == "ErrorInfoOf":
        return true
    return false

fn v3ParserResultIntrinsicDetail(name: str): str =
    if name == "Ok":
        return "ok"
    if name == "Err":
        return "err"
    if name == "Value":
        return "value"
    if name == "Error":
        return "error"
    if name == "IsOk":
        return "is_ok"
    if name == "IsErr":
        return "is_err"
    if name == "ErrorInfoOf":
        return "error_info_of"
    return name

fn v3ParserIsIdentChar(ch: char): bool =
    let digit = ch >= '0' && ch <= '9'
    let upper = ch >= 'A' && ch <= 'Z'
    let lower = ch >= 'a' && ch <= 'z'
    return digit || upper || lower || ch == '_'

fn v3ParserPreviousToken(lineRaw: str,
                         stopExclusive: int32): str =
    if stopExclusive <= 0:
        return ""
    var cursor = stopExclusive
    while cursor > 0:
        let prevPos = cursor - 1
        if !v3ParserIsInlineSpace(lineRaw[prevPos]):
            break
        cursor = prevPos
    if cursor <= 0:
        return ""
    let end = cursor - 1
    if end < 0:
        return ""
    var start = end + 1
    while start > 0:
        let prevPos = start - 1
        if !v3ParserIsIdentChar(lineRaw[prevPos]):
            break
        start = prevPos
    if start > end:
        return ""
    return v3path.V3TextSlice(lineRaw, start, end - start + 1)

fn v3ParserDottedQualifierDepth(lineRaw: str,
                                identStart: int32): int32 =
    if identStart <= 1:
        return 0
    let qualifierStop = identStart - 1
    if lineRaw[qualifierStop] != '.':
        return 0
    var depth: int32 = 0
    var segmentStart: int32 = identStart
    var scanning = true
    while scanning && segmentStart > 1:
        let dotPos = segmentStart - 1
        if lineRaw[dotPos] != '.':
            break
        var identPos = dotPos
        while identPos > 0:
            let prevPos = identPos - 1
            if !v3ParserIsIdentChar(lineRaw[prevPos]):
                break
            identPos = prevPos
        if identPos >= dotPos:
            break
        depth = depth + 1
        segmentStart = identPos
        if segmentStart <= 1:
            break
        if lineRaw[segmentStart - 1] != '.':
            scanning = false
    return depth

fn v3ParserNextNonSpaceChar(lineRaw: str,
                            start: int32): char =
    var cursor = start
    while cursor < lineRaw.len:
        if !v3ParserIsInlineSpace(lineRaw[cursor]):
            return lineRaw[cursor]
        cursor = cursor + 1
    return char(0)

fn v3ParserSkipInlineSpaces(lineRaw: str,
                            start: int32): int32 =
    var cursor = start
    var scanning = true
    while cursor < lineRaw.len && scanning:
        if v3ParserIsInlineSpace(lineRaw[cursor]):
            cursor = cursor + 1
        else:
            scanning = false
    return cursor

fn v3ParserStripLineComment(lineRaw: str): str =
    let hashPos = v3ParserFindText(lineRaw, "#")
    if hashPos < 0:
        return lineRaw
    return v3path.V3TextSlice(lineRaw, 0, hashPos)

fn v3ParserLineKeywordPositions(lineRaw: str,
                                keyword: str): int32[] =
    var out: int32[] = []
    if keyword == "":
        return out
    if lineRaw.len < keyword.len:
        return out
    for i in 0..<(lineRaw.len - keyword.len + 1):
        var matched = true
        for j in 0..<keyword.len:
            if lineRaw[i + j] != keyword[j]:
                matched = false
                break
        if !matched:
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + keyword.len
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        add(out, i)
    return out

fn v3ParserAppendIfExprsLine(sourcePath: str,
                             lineNumber: int32,
                             lineRaw: str,
                             layer: var V3NormalizedExprLayer) =
    let positions = v3ParserLineKeywordPositions(lineRaw, "if")
    for i in 0..<positions.len:
        v3NormalizedExprLayerAppend(layer,
                                    sourcePath,
                                    lineNumber,
                                    positions[i] + 1,
                                    v3NormalizedExprIf,
                                    "keyword_if",
                                    "if")

fn v3ParserAppendFmtExprsLine(sourcePath: str,
                              lineNumber: int32,
                              lineRaw: str,
                              layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 3:
        return
    for i in 0..<(lineRaw.len - 2):
        if lineRaw[i] != 'F' || lineRaw[i + 1] != 'm' || lineRaw[i + 2] != 't':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 3
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        let prevToken = v3ParserPreviousToken(lineRaw, i)
        if prevToken == "fn" || prevToken == "func" || prevToken == "proc" ||
           prevToken == "method" || prevToken == "converter":
            continue
        let nextChar = v3ParserNextNonSpaceChar(lineRaw, rightPos)
        if nextChar == '"' || nextChar == '(' || nextChar == '[' || v3ParserIsIdentChar(nextChar):
            var detail = "fmt_call"
            if nextChar == '"':
                detail = "fmt_literal"
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprStrFormat,
                                        detail,
                                        "Fmt")
    return

fn v3ParserAppendResultIntrinsicExprsLine(sourcePath: str,
                                          lineNumber: int32,
                                          lineRaw: str,
                                          layer: var V3NormalizedExprLayer) =
    v3ParserAppendResultIntrinsicOkExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicErrExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicValueExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicErrorExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicIsOkExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicIsErrExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicErrorInfoOfExprsLine(sourcePath, lineNumber, lineRaw, layer)

fn v3ParserAppendResultIntrinsicOkExprsLine(sourcePath: str,
                                            lineNumber: int32,
                                            lineRaw: str,
                                            layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 2:
        return
    for i in 0..<(lineRaw.len - 1):
        if lineRaw[i] != 'O':
            continue
        if lineRaw[i + 1] != 'k':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 2
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "ok", "Ok")
    return

fn v3ParserAppendResultIntrinsicErrExprsLine(sourcePath: str,
                                             lineNumber: int32,
                                             lineRaw: str,
                                             layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 3:
        return
    for i in 0..<(lineRaw.len - 2):
        if lineRaw[i] != 'E':
            continue
        if lineRaw[i + 1] != 'r':
            continue
        if lineRaw[i + 2] != 'r':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 3
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "err", "Err")
    return

fn v3ParserAppendResultIntrinsicValueExprsLine(sourcePath: str,
                                               lineNumber: int32,
                                               lineRaw: str,
                                               layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 5:
        return
    for i in 0..<(lineRaw.len - 4):
        if lineRaw[i] != 'V':
            continue
        if lineRaw[i + 1] != 'a':
            continue
        if lineRaw[i + 2] != 'l':
            continue
        if lineRaw[i + 3] != 'u':
            continue
        if lineRaw[i + 4] != 'e':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 5
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "value", "Value")
    return

fn v3ParserAppendResultIntrinsicErrorExprsLine(sourcePath: str,
                                               lineNumber: int32,
                                               lineRaw: str,
                                               layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 5:
        return
    for i in 0..<(lineRaw.len - 4):
        if lineRaw[i] != 'E':
            continue
        if lineRaw[i + 1] != 'r':
            continue
        if lineRaw[i + 2] != 'r':
            continue
        if lineRaw[i + 3] != 'o':
            continue
        if lineRaw[i + 4] != 'r':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 5
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "error", "Error")
    return

fn v3ParserAppendResultIntrinsicIsOkExprsLine(sourcePath: str,
                                              lineNumber: int32,
                                              lineRaw: str,
                                              layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 4:
        return
    for i in 0..<(lineRaw.len - 3):
        if lineRaw[i] != 'I':
            continue
        if lineRaw[i + 1] != 's':
            continue
        if lineRaw[i + 2] != 'O':
            continue
        if lineRaw[i + 3] != 'k':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 4
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "is_ok", "IsOk")
    return

fn v3ParserAppendResultIntrinsicIsErrExprsLine(sourcePath: str,
                                               lineNumber: int32,
                                               lineRaw: str,
                                               layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 5:
        return
    for i in 0..<(lineRaw.len - 4):
        if lineRaw[i] != 'I':
            continue
        if lineRaw[i + 1] != 's':
            continue
        if lineRaw[i + 2] != 'E':
            continue
        if lineRaw[i + 3] != 'r':
            continue
        if lineRaw[i + 4] != 'r':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 5
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "is_err", "IsErr")
    return

fn v3ParserAppendResultIntrinsicErrorInfoOfExprsLine(sourcePath: str,
                                                     lineNumber: int32,
                                                     lineRaw: str,
                                                     layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 11:
        return
    for i in 0..<(lineRaw.len - 10):
        if lineRaw[i] != 'E':
            continue
        if lineRaw[i + 1] != 'r':
            continue
        if lineRaw[i + 2] != 'r':
            continue
        if lineRaw[i + 3] != 'o':
            continue
        if lineRaw[i + 4] != 'r':
            continue
        if lineRaw[i + 5] != 'I':
            continue
        if lineRaw[i + 6] != 'n':
            continue
        if lineRaw[i + 7] != 'f':
            continue
        if lineRaw[i + 8] != 'o':
            continue
        if lineRaw[i + 9] != 'O':
            continue
        if lineRaw[i + 10] != 'f':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 11
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "error_info_of", "ErrorInfoOf")
    return

fn v3ParserAppendRangeExprsLine(sourcePath: str,
                                lineNumber: int32,
                                lineRaw: str,
                                layer: var V3NormalizedExprLayer) =
    var i: int32 = 0
    while i + 1 < lineRaw.len:
        if lineRaw[i] == '.':
            if lineRaw[i + 1] != '.':
                i = i + 1
                continue
            if i + 2 < lineRaw.len:
                if lineRaw[i + 2] == '<':
                    v3NormalizedExprLayerAppend(layer,
                                                sourcePath,
                                                lineNumber,
                                                i + 1,
                                                v3NormalizedExprRange,
                                                "exclusive",
                                                "..<")
                    i = i + 3
                    continue
            else:
                v3NormalizedExprLayerAppend(layer,
                                            sourcePath,
                                            lineNumber,
                                            i + 1,
                                            v3NormalizedExprRange,
                                            "inclusive",
                                            "..")
                i = i + 2
                continue
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprRange,
                                        "inclusive",
                                        "..")
            i = i + 2
            continue
        i = i + 1

fn v3ParserAppendQuestionExprsLine(sourcePath: str,
                                   lineNumber: int32,
                                   lineRaw: str,
                                   layer: var V3NormalizedExprLayer) =
    for i in 0..<lineRaw.len:
        if lineRaw[i] != '?':
            continue
        let nextChar = v3ParserNextNonSpaceChar(lineRaw, i + 1)
        if nextChar == char(0) || nextChar == ',' || nextChar == ';' ||
           nextChar == ':' || nextChar == ')' || nextChar == ']' || nextChar == '}':
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprTry,
                                        "postfix_question",
                                        "?")
        else:
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprIf,
                                        "ternary",
                                        "?")

fn v3ParserCallExprUsesDedicatedNormalization(callNameRaw: str): bool =
    let callName = callNameRaw
    if callName == "Fmt":
        return true
    if callName == "Ok":
        return true
    if callName == "Err":
        return true
    if callName == "Value":
        return true
    if callName == "Error":
        return true
    if callName == "IsOk":
        return true
    if callName == "IsErr":
        return true
    if callName == "ErrorInfoOf":
        return true
    return false

fn v3ParserCallExprLastDot(textRaw: str): int32 =
    let text = v3path.V3PathTrim(textRaw)
    var dotPos: int32 = -1
    for i in 0..<text.len:
        if text[i] == '.':
            dotPos = i
    return dotPos

fn v3ParserFindMatchingParen(textRaw: str,
                             openPos: int32): int32 =
    if openPos < 0 || openPos >= textRaw.len:
        return -1
    if textRaw[openPos] != '(':
        return -1
    var depth: int32 = 0
    for i in openPos..<textRaw.len:
        if textRaw[i] == '(':
            depth = depth + 1
        elif textRaw[i] == ')':
            depth = depth - 1
            if depth == 0:
                return i
    return -1

fn v3ParserSplitTopLevelCsv(textRaw: str): str[] =
    var out: str[] = []
    var start: int32 = 0
    var bracketDepth: int32 = 0
    var parenDepth: int32 = 0
    var braceDepth: int32 = 0
    for i in 0..<textRaw.len:
        let piece = textRaw[i]
        if piece == '[':
            bracketDepth = bracketDepth + 1
        elif piece == ']':
            bracketDepth = bracketDepth - 1
        elif piece == '(':
            parenDepth = parenDepth + 1
        elif piece == ')':
            parenDepth = parenDepth - 1
        elif piece == '{':
            braceDepth = braceDepth + 1
        elif piece == '}':
            braceDepth = braceDepth - 1
        elif piece == ',' && bracketDepth == 0 && parenDepth == 0 && braceDepth == 0:
            add(out, v3path.V3PathTrim(v3path.V3TextSlice(textRaw, start, i - start)))
            start = i + 1
    add(out, v3path.V3PathTrim(v3path.V3TextSlice(textRaw, start, textRaw.len - start)))
    return out

fn v3ParserFunctionScopeDeclIndex(profile: V3NormalizedExprCallProfile,
                                  lineNumber: int32): int32 =
    var scopeIndex: int32 = -1
    for i in 0..<profile.decls.len:
        let decl = profile.decls[i]
        if decl.importc:
            continue
        if decl.lineIndex > lineNumber:
            break
        scopeIndex = i
    if scopeIndex < 0:
        return -1
    var endLine: int32 = 2147483647
    if scopeIndex + 1 < profile.decls.len:
        endLine = profile.decls[scopeIndex + 1].lineIndex - 1
    if lineNumber > endLine:
        return -1
    return scopeIndex

fn v3ParserAppendUniqueBindingName(out: var str[],
                                   nameRaw: str) =
    let name = v3ParserIdentPrefix(v3path.V3PathTrim(nameRaw))
    if name == "":
        return
    v3ParserAddUniqueText(out, name)

fn v3ParserAppendFunctionParamBindingNames(lineRaw: str,
                                           out: var str[]) =
    var openPos: int32 = -1
    openPos = v3ParserFindText(lineRaw, "(")
    if openPos < 0:
        return
    var closePos: int32 = -1
    closePos = v3ParserFindMatchingParen(lineRaw, openPos)
    if closePos <= openPos:
        return
    let paramsText = v3path.V3TextSlice(lineRaw, openPos + 1, closePos - openPos - 1)
    var params: str[] = []
    params = v3ParserSplitTopLevelCsv(paramsText)
    for i in 0..<params.len:
        var item = v3path.V3PathTrim(params[i])
        if v3ParserStartsWith(item, "var "):
            item = v3path.V3TextSlice(item, 4, item.len - 4)
        var colonPos: int32 = -1
        colonPos = v3ParserFindText(item, ":")
        if colonPos > 0:
            item = v3path.V3TextSlice(item, 0, colonPos)
        v3ParserAppendUniqueBindingName(out, item)

fn v3ParserBindingNameFromLine(lineRaw: str): str =
    let trimmed = v3path.V3PathTrim(lineRaw)
    var prefix = ""
    if v3ParserStartsWith(trimmed, "let "):
        prefix = "let "
    elif v3ParserStartsWith(trimmed, "var "):
        prefix = "var "
    elif v3ParserStartsWith(trimmed, "const "):
        prefix = "const "
    if prefix == "":
        return ""
    let tail = v3path.V3TextSlice(trimmed, prefix.len, trimmed.len - prefix.len)
    return v3ParserIdentPrefix(v3ParserFirstToken(tail))

fn v3ParserVisibleLocalBindingNames(profile: V3NormalizedExprCallProfile,
                                    lineNumber: int32): str[] =
    var out: str[] = []
    let scopeIndex = v3ParserFunctionScopeDeclIndex(profile, lineNumber)
    if scopeIndex < 0:
        return out
    let decl = profile.decls[scopeIndex]
    if decl.lineIndex > 0 && decl.lineIndex <= profile.lines.len:
        v3ParserAppendFunctionParamBindingNames(profile.lines[decl.lineIndex - 1], out)
    var scanLine = decl.lineIndex + 1
    while scanLine < lineNumber && scanLine <= profile.lines.len:
        let bindingName = v3ParserBindingNameFromLine(profile.lines[scanLine - 1])
        v3ParserAppendUniqueBindingName(out, bindingName)
        scanLine = scanLine + 1
    return out

fn v3ParserQualifierRoot(qualifierRaw: str): str =
    let qualifier = v3path.V3PathTrim(qualifierRaw)
    if qualifier == "":
        return ""
    let dotPos = v3ParserFindText(qualifier, ".")
    if dotPos < 0:
        return v3ParserIdentPrefix(qualifier)
    return v3ParserIdentPrefix(v3path.V3TextSlice(qualifier, 0, dotPos))

fn v3ParserQualifiedTargetShadowReason(currentProfile: V3NormalizedExprCallProfile,
                                       lineNumber: int32,
                                       targetRaw: str): str =
    let target = v3path.V3PathTrim(targetRaw)
    if target == "":
        return ""
    let dotPos = v3ParserFindText(target, ".")
    if dotPos <= 0:
        return ""
    let rootQualifier = v3ParserIdentPrefix(target)
    if rootQualifier == "":
        return ""
    let visibleBindings = v3ParserVisibleLocalBindingNames(currentProfile, lineNumber)
    if v3ParserStringSeqContainsExact(visibleBindings, rootQualifier):
        return "shadowed_qualified_target"
    return ""

fn v3ParserCallExprDetail(kindRaw: str,
                          calleeRaw: str,
                          qualifierRaw: str,
                          targetRaw: str,
                          resolved: bool,
                          reasonRaw: str,
                          targetSourcePathRaw: str,
                          targetImportc: bool): str =
    let kind = v3path.V3PathTrim(kindRaw)
    let callee = v3path.V3PathTrim(calleeRaw)
    let qualifier = v3path.V3PathTrim(qualifierRaw)
    let target = v3path.V3PathTrim(targetRaw)
    let reason = v3path.V3PathTrim(reasonRaw)
    let targetSourcePath = v3ParserNormalizePath(targetSourcePathRaw)
    var detail = v3ParserConcat3("kind=", kind, ";")
    detail = v3ParserConcat3(detail, "callee=", callee)
    detail = v3ParserConcat3(detail, ";qualifier=", qualifier)
    detail = v3ParserConcat3(detail, ";target=", target)
    if resolved:
        detail = detail + ";resolved=1"
    else:
        detail = detail + ";resolved=0"
    if reason != "":
        detail = v3ParserConcat3(detail, ";reason=", reason)
    if targetSourcePath != "":
        detail = v3ParserConcat3(detail, ";target_source_path=", targetSourcePath)
    if targetImportc:
        detail = detail + ";target_importc=1"
    else:
        detail = detail + ";target_importc=0"
    return detail

fn v3ParserCallExprDetailField(detailRaw: str,
                               keyRaw: str): str =
    let detail = v3path.V3PathTrim(detailRaw)
    let key = v3path.V3PathTrim(keyRaw)
    if detail == "" || key == "":
        return ""
    let prefix = v3ParserConcat2(key, "=")
    let parts = v3ParserSplitChar(detail, ';')
    for i in 0..<parts.len:
        let part = v3path.V3PathTrim(parts[i])
        if !v3ParserStartsWith(part, prefix):
            continue
        return v3path.V3PathTrim(v3path.V3TextSlice(part, prefix.len, part.len - prefix.len))
    return ""

fn v3ParserCallExprDetailKind(detailRaw: str): str =
    let kind = v3ParserCallExprDetailField(detailRaw, "kind")
    if kind != "":
        return kind
    let detail = v3path.V3PathTrim(detailRaw)
    if detail == "local_call" || detail == "external_call" || detail == "importc_call" || detail == "member_call":
        return detail
    return ""

fn v3ParserCallExprDetailCallee(detailRaw: str,
                                surfaceTextRaw: str): str =
    let callee = v3ParserCallExprDetailField(detailRaw, "callee")
    if callee != "":
        return callee
    return v3path.V3PathTrim(surfaceTextRaw)

fn v3ParserCallExprDetailQualifier(detailRaw: str,
                                   surfaceTextRaw: str): str =
    let qualifier = v3ParserCallExprDetailField(detailRaw, "qualifier")
    if qualifier != "":
        return qualifier
    let surfaceText = v3path.V3PathTrim(surfaceTextRaw)
    var dotPos: int32 = -1
    for i in 0..<surfaceText.len:
        if surfaceText[i] == '.':
            dotPos = i
    if dotPos <= 0:
        return ""
    return v3path.V3PathTrim(v3path.V3TextSlice(surfaceText, 0, dotPos))

fn v3ParserCallExprDetailTarget(detailRaw: str,
                                surfaceTextRaw: str): str =
    let target = v3ParserCallExprDetailField(detailRaw, "target")
    if target != "":
        return target
    return v3path.V3PathTrim(surfaceTextRaw)

fn v3ParserCallExprDetailResolved(detailRaw: str): bool =
    return v3ParserCallExprDetailField(detailRaw, "resolved") == "1"

fn v3ParserCallExprDetailReason(detailRaw: str): str =
    return v3ParserCallExprDetailField(detailRaw, "reason")

fn v3ParserCallExprDetailTargetSourcePath(detailRaw: str): str =
    return v3ParserNormalizePath(v3ParserCallExprDetailField(detailRaw, "target_source_path"))

fn v3ParserCallExprDetailTargetImportc(detailRaw: str): bool =
    return v3ParserCallExprDetailField(detailRaw, "target_importc") == "1"

fn v3ParserAppendCallExprsLine(sourcePath: str,
                               lineNumber: int32,
                               lineRaw: str,
                               callLookup: V3ParserTextLookup,
                               detailKind: str,
                               currentProfile: V3NormalizedExprCallProfile,
                               profiles: V3NormalizedExprCallProfile[],
                               layer: var V3NormalizedExprLayer) =
    if callLookup.totalCount <= 0:
        return
    var i: int32 = 0
    while i < lineRaw.len:
        if !v3ParserIsIdentChar(lineRaw[i]):
            i = i + 1
            continue
        var middleOfIdent = false
        if i > 0:
            middleOfIdent = v3ParserIsIdentChar(lineRaw[i - 1])
        if middleOfIdent:
            i = i + 1
            continue
        var stop = i
        while stop < lineRaw.len:
            if !v3ParserIsIdentChar(lineRaw[stop]):
                break
            stop = stop + 1
        let callName = v3path.V3TextSlice(lineRaw, i, stop - i)
        var qualifiedCallName = callName
        var dottedCallName = callName
        var qualifier = ""
        if i > 1:
            let qualifierStop: int32 = i - 1
            if lineRaw[qualifierStop] == '.':
                var qualifierStart: int32 = qualifierStop
                while qualifierStart > 0:
                    let prevPos = qualifierStart - 1
                    if !v3ParserIsIdentChar(lineRaw[prevPos]):
                        break
                    qualifierStart = prevPos
                if qualifierStart < qualifierStop:
                    qualifier = v3path.V3TextSlice(lineRaw, qualifierStart, qualifierStop - qualifierStart)
                    qualifiedCallName = v3ParserConcat3(qualifier, ".", callName)
                var dottedStart: int32 = qualifierStart
                var scanningQualifierChain = true
                while scanningQualifierChain && dottedStart > 1:
                    let prevDot = dottedStart - 1
                    if lineRaw[prevDot] != '.':
                        scanningQualifierChain = false
                    else:
                        var prevStart = prevDot
                        while prevStart > 0:
                            let prevPos = prevStart - 1
                            if !v3ParserIsIdentChar(lineRaw[prevPos]):
                                break
                            prevStart = prevPos
                        if prevStart < prevDot:
                            dottedStart = prevStart
                        else:
                            scanningQualifierChain = false
                if dottedStart < stop:
                    dottedCallName = v3path.V3TextSlice(lineRaw, dottedStart, stop - dottedStart)
        let prevToken = v3ParserPreviousToken(lineRaw, i)
        if prevToken == "fn" || prevToken == "func" || prevToken == "proc" ||
           prevToken == "method" || prevToken == "converter" || prevToken == "importc":
            i = stop
            continue
        let nextPos = v3ParserSkipInlineSpaces(lineRaw, stop)
        var hasCallParen = false
        if nextPos < lineRaw.len:
            hasCallParen = lineRaw[nextPos] == '('
        var matchedSurfaceText = ""
        if hasCallParen && !v3ParserCallExprUsesDedicatedNormalization(callName):
            matchedSurfaceText = v3ParserMatchKnownCallSurfaceText(callLookup,
                                                                  callName,
                                                                  qualifiedCallName,
                                                                  dottedCallName)
        if detailKind == "external_call" && matchedSurfaceText != "":
            let shadowReason = v3ParserQualifiedTargetShadowReason(currentProfile, lineNumber, matchedSurfaceText)
            if shadowReason != "":
                matchedSurfaceText = ""
        if matchedSurfaceText != "":
            let resolvedTarget = v3ParserResolveCallTarget(currentProfile,
                                                           profiles,
                                                           detailKind,
                                                           matchedSurfaceText,
                                                           callName)
            let resolved = resolvedTarget.sourcePath != ""
            let detail = v3ParserCallExprDetail(detailKind,
                                                callName,
                                                qualifier,
                                                matchedSurfaceText,
                                                resolved,
                                                resolvedTarget.reason,
                                                resolvedTarget.sourcePath,
                                                resolvedTarget.importc)
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprCall,
                                        detail,
                                        matchedSurfaceText)
        i = stop
    return

fn v3ParserAppendMemberCallExprsLine(sourcePath: str,
                                     lineNumber: int32,
                                     lineRaw: str,
                                     knownCallLookup: V3ParserTextLookup,
                                     currentProfile: V3NormalizedExprCallProfile,
                                     layer: var V3NormalizedExprLayer) =
    if knownCallLookup.totalCount <= 0:
        return
    var i: int32 = 0
    while i < lineRaw.len:
        if !v3ParserIsIdentChar(lineRaw[i]):
            i = i + 1
            continue
        let start = i
        var stop = i
        while stop < lineRaw.len:
            if !v3ParserIsIdentChar(lineRaw[stop]):
                break
            stop = stop + 1
        let callName = v3path.V3TextSlice(lineRaw, start, stop - start)
        var qualifiedCallName = callName
        var dottedCallName = callName
        if start > 1:
            let qualifierStop: int32 = start - 1
            if lineRaw[qualifierStop] == '.':
                var qualifierStart: int32 = qualifierStop
                while qualifierStart > 0:
                    let prevPos = qualifierStart - 1
                    if !v3ParserIsIdentChar(lineRaw[prevPos]):
                        break
                    qualifierStart = prevPos
                if qualifierStart < qualifierStop:
                    let qualifier = v3path.V3TextSlice(lineRaw, qualifierStart, qualifierStop - qualifierStart)
                    qualifiedCallName = v3ParserConcat3(qualifier, ".", callName)
                var dottedStart: int32 = qualifierStart
                var scanningQualifierChain = true
                while scanningQualifierChain && dottedStart > 1:
                    let prevDot = dottedStart - 1
                    if lineRaw[prevDot] != '.':
                        scanningQualifierChain = false
                    else:
                        var prevStart = prevDot
                        while prevStart > 0:
                            let prevPos = prevStart - 1
                            if !v3ParserIsIdentChar(lineRaw[prevPos]):
                                break
                            prevStart = prevPos
                        if prevStart < prevDot:
                            dottedStart = prevStart
                        else:
                            scanningQualifierChain = false
                if dottedStart < stop:
                    dottedCallName = v3path.V3TextSlice(lineRaw, dottedStart, stop - dottedStart)
        let prevToken = v3ParserPreviousToken(lineRaw, start)
        if prevToken == "fn" || prevToken == "func" || prevToken == "proc" ||
           prevToken == "method" || prevToken == "converter" || prevToken == "importc":
            i = stop
            continue
        let nextPos = v3ParserSkipInlineSpaces(lineRaw, stop)
        var hasCallParen = false
        if nextPos < lineRaw.len:
            hasCallParen = lineRaw[nextPos] == '('
        if hasCallParen && dottedCallName != callName && !v3ParserCallExprUsesDedicatedNormalization(callName):
            let shadowReason = v3ParserQualifiedTargetShadowReason(currentProfile, lineNumber, dottedCallName)
            let knownCall = v3ParserMatchKnownCallSurfaceText(knownCallLookup,
                                                              callName,
                                                              qualifiedCallName,
                                                              dottedCallName) != ""
            if shadowReason != "" || !knownCall:
                var qualifier = ""
                let dotPos = v3ParserCallExprLastDot(dottedCallName)
                if dotPos > 0:
                    qualifier = v3path.V3PathTrim(v3path.V3TextSlice(dottedCallName, 0, dotPos))
                var reasonText = "unknown_qualified_target"
                if shadowReason != "":
                    reasonText = shadowReason
                let detail = v3ParserCallExprDetail("member_call",
                                                    callName,
                                                    qualifier,
                                                    dottedCallName,
                                                    false,
                                                    reasonText,
                                                    "",
                                                    false)
                v3NormalizedExprLayerAppend(layer,
                                            sourcePath,
                                            lineNumber,
                                            start + 1,
                                            v3NormalizedExprCall,
                                            detail,
                                            dottedCallName)
        i = stop
    return

fn v3ParserMaxQualifiedCallDepthLines(lines: str[]): int32 =
    var maxDepth: int32 = 0
    for i in 0..<lines.len:
        let lineRaw = v3ParserStripLineComment(lines[i])
        if v3path.V3PathTrim(lineRaw) == "":
            continue
        var pos: int32 = 0
        while pos < lineRaw.len:
            if !v3ParserIsIdentChar(lineRaw[pos]):
                pos = pos + 1
                continue
            let start = pos
            var stop = pos
            while stop < lineRaw.len:
                if !v3ParserIsIdentChar(lineRaw[stop]):
                    break
                stop = stop + 1
            let prevToken = v3ParserPreviousToken(lineRaw, start)
            let nextPos = v3ParserSkipInlineSpaces(lineRaw, stop)
            var hasCallParen = false
            if nextPos < lineRaw.len:
                hasCallParen = v3path.V3TextSlice(lineRaw, nextPos, 1) == "("
            if hasCallParen &&
               prevToken != "fn" &&
               prevToken != "func" &&
               prevToken != "proc" &&
               prevToken != "method" &&
               prevToken != "converter" &&
               prevToken != "importc":
                let depth = v3ParserDottedQualifierDepth(lineRaw, start)
                if depth > maxDepth:
                    maxDepth = depth
            pos = stop
    return maxDepth

fn v3ParserMaxQualifiedCallDepth(text: str): int32 =
    let lines = v3ParserSplitChar(text, '\n')
    return v3ParserMaxQualifiedCallDepthLines(lines)

fn v3ParserAppendComprehensionExprsLine(sourcePath: str,
                                        lineNumber: int32,
                                        lineRaw: str,
                                        layer: var V3NormalizedExprLayer) =
    let openPos = v3ParserFindText(lineRaw, "[")
    if openPos < 0:
        return
    let forPositions = v3ParserLineKeywordPositions(lineRaw, "for")
    let inPositions = v3ParserLineKeywordPositions(lineRaw, "in")
    if forPositions.len <= 0 || inPositions.len <= 0:
        return
    v3NormalizedExprLayerAppend(layer,
                                sourcePath,
                                lineNumber,
                                openPos + 1,
                                v3NormalizedExprComprehension,
                                "list_comprehension",
                                "[for in]")

fn v3ParserImportcCallNamesFromDecls(decls: V3NormalizedFunctionDecl[],
                                     names: var str[]) =
    var out: str[] = []
    for i in 0..<decls.len:
        if !decls[i].importc:
            continue
        if decls[i].name == "":
            continue
        v3ParserAddUniqueText(out, decls[i].name)
    names = out

fn v3ParserLocalCallNamesFromDecls(decls: V3NormalizedFunctionDecl[],
                                   names: var str[]) =
    var out: str[] = []
    for i in 0..<decls.len:
        if decls[i].importc:
            continue
        if decls[i].name == "":
            continue
        v3ParserAddUniqueText(out, decls[i].name)
    names = out

fn v3ParserBuildExprCallProfile(workspaceRootRaw: str,
                                packageRootRaw: str,
                                sourcePathRaw: str,
                                text: str,
                                profile: var V3NormalizedExprCallProfile,
                                err: var str): bool =
    let workspaceRoot = v3ParserNormalizePath(workspaceRootRaw)
    let packageRoot = v3ParserNormalizePath(packageRootRaw)
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "missing source path"
        return false
    profile.sourcePath = sourcePath
    profile.ownerModulePath = v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)
    profile.text = text
    profile.lines = []
    profile.decls = []
    profile.importcCallNames = []
    profile.localCallNames = []
    profile.importEdges = []
    profile.maxQualifiedCallDepth = 0
    let lines = v3ParserSplitChar(text, '\n')
    profile.lines = lines
    if !v3ParserReadNormalizedFunctionDeclsLines(lines, profile.decls, err):
        return false
    if workspaceRoot != "" && packageRoot != "":
        if !v3ParserReadImportEdgesLines(workspaceRoot,
                                         packageRoot,
                                         profile.ownerModulePath,
                                         lines,
                                         profile.importEdges,
                                         err):
            return false
    v3ParserImportcCallNamesFromDecls(profile.decls, profile.importcCallNames)
    v3ParserLocalCallNamesFromDecls(profile.decls, profile.localCallNames)
    profile.maxQualifiedCallDepth = v3ParserMaxQualifiedCallDepthLines(lines)
    err = ""
    return true

fn v3ParserCallProfileIndexForSourcePath(profiles: V3NormalizedExprCallProfile[],
                                         sourcePathRaw: str): int32 =
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    for i in 0..<profiles.len:
        if profiles[i].sourcePath == sourcePath:
            return i
    return -1

fn v3ParserImportEdgeQualifier(edge: V3ImportEdge): str =
    let aliasText = v3ParserIdentPrefix(v3path.V3PathTrim(edge.importAlias))
    if aliasText != "":
        return aliasText
    let sourceStem = v3ParserFileStem(edge.targetSourcePath)
    if sourceStem != "":
        return sourceStem
    return v3ParserLastPathPiece(edge.targetModulePath)

fn v3ParserImportEdgeAllowsUnqualifiedCall(edge: V3ImportEdge): bool =
    return v3path.V3PathTrim(edge.importAlias) == ""

fn v3ParserQualifiedCallPrefix(prefixRaw: str,
                               qualifierRaw: str): str =
    let prefix = v3path.V3PathTrim(prefixRaw)
    let qualifier = v3path.V3PathTrim(qualifierRaw)
    if prefix == "":
        return qualifier
    if qualifier == "":
        return prefix
    return v3ParserConcat3(prefix, ".", qualifier)

fn v3ParserResolvedCallTargetNew(sourcePathRaw: str,
                                 importc: bool,
                                 reasonRaw: str): V3NormalizedExprResolvedCallTarget =
    var out: V3NormalizedExprResolvedCallTarget
    out.sourcePath = v3ParserNormalizePath(sourcePathRaw)
    out.importc = importc
    out.reason = v3path.V3PathTrim(reasonRaw)
    return out

fn v3ParserResolvedCallTargetResolved(sourcePathRaw: str,
                                      importc: bool): V3NormalizedExprResolvedCallTarget =
    return v3ParserResolvedCallTargetNew(sourcePathRaw, importc, "")

fn v3ParserResolvedCallTargetUnknown(reasonRaw: str): V3NormalizedExprResolvedCallTarget =
    return v3ParserResolvedCallTargetNew("", false, reasonRaw)

fn v3ParserResolvedCallTargetEmpty(): V3NormalizedExprResolvedCallTarget =
    return v3ParserResolvedCallTargetNew("", false, "")

fn v3ParserResolvedCallTargetSame(lhs: V3NormalizedExprResolvedCallTarget,
                                  rhs: V3NormalizedExprResolvedCallTarget): bool =
    return lhs.sourcePath == rhs.sourcePath &&
           lhs.importc == rhs.importc &&
           lhs.reason == rhs.reason

fn v3ParserAppendUniqueResolvedCallTarget(out: var V3NormalizedExprResolvedCallTarget[],
                                          target: V3NormalizedExprResolvedCallTarget) =
    if target.sourcePath == "" || target.reason != "":
        return
    for i in 0..<out.len:
        if v3ParserResolvedCallTargetSame(out[i], target):
            return
    add(out, target)

fn v3ParserImportedTargetLookupResolved(targetProfileIndex: int32): V3ParserImportedTargetLookup =
    var out: V3ParserImportedTargetLookup
    out.targetProfileIndex = targetProfileIndex
    out.reason = ""
    return out

fn v3ParserImportedTargetLookupUnknown(reasonRaw: str): V3ParserImportedTargetLookup =
    var out: V3ParserImportedTargetLookup
    out.targetProfileIndex = -1
    out.reason = v3path.V3PathTrim(reasonRaw)
    return out

fn v3ParserCallProfileHasImportcCall(profile: V3NormalizedExprCallProfile,
                                     nameRaw: str): bool =
    let name = v3ParserIdentPrefix(v3path.V3PathTrim(nameRaw))
    if name == "":
        return false
    return v3ParserStringSeqContainsExact(profile.importcCallNames, name)

fn v3ParserCallProfileHasLocalCall(profile: V3NormalizedExprCallProfile,
                                   nameRaw: str): bool =
    let name = v3ParserIdentPrefix(v3path.V3PathTrim(nameRaw))
    if name == "":
        return false
    return v3ParserStringSeqContainsExact(profile.localCallNames, name)

fn v3ParserImportedTargetProfileIndex(currentProfile: V3NormalizedExprCallProfile,
                                      profiles: V3NormalizedExprCallProfile[],
                                      qualifierChainRaw: str): V3ParserImportedTargetLookup =
    let qualifierChain = v3path.V3PathTrim(qualifierChainRaw)
    if qualifierChain == "":
        return v3ParserImportedTargetLookupUnknown("unknown_qualified_target")
    let qualifierParts = v3ParserSplitChar(qualifierChain, '.')
    var ctx = currentProfile
    var targetProfileIndex: int32 = -1
    for i in 0..<qualifierParts.len:
        let qualifier = v3ParserIdentPrefix(v3path.V3PathTrim(qualifierParts[i]))
        if qualifier == "":
            return v3ParserImportedTargetLookupUnknown("unknown_qualified_target")
        targetProfileIndex = -1
        for edgeIndex in 0..<ctx.importEdges.len:
            let edge = ctx.importEdges[edgeIndex]
            if !edge.resolved:
                continue
            if v3ParserImportEdgeQualifier(edge) != qualifier:
                continue
            let candidateIndex = v3ParserCallProfileIndexForSourcePath(profiles, edge.targetSourcePath)
            if candidateIndex < 0:
                continue
            if targetProfileIndex < 0:
                targetProfileIndex = candidateIndex
                continue
            if targetProfileIndex != candidateIndex:
                return v3ParserImportedTargetLookupUnknown("ambiguous_qualified_target")
        if targetProfileIndex < 0:
            return v3ParserImportedTargetLookupUnknown("unknown_qualified_target")
        if i + 1 >= qualifierParts.len:
            return v3ParserImportedTargetLookupResolved(targetProfileIndex)
        ctx = profiles[targetProfileIndex]
    return v3ParserImportedTargetLookupResolved(targetProfileIndex)

fn v3ParserResolveQualifiedCallTarget(currentProfile: V3NormalizedExprCallProfile,
                                      profiles: V3NormalizedExprCallProfile[],
                                      targetRaw: str,
                                      calleeRaw: str): V3NormalizedExprResolvedCallTarget =
    let qualifier = v3path.V3PathTrim(v3ParserCallExprDetailQualifier("", targetRaw))
    let callee = v3ParserIdentPrefix(v3path.V3PathTrim(calleeRaw))
    if qualifier == "" || callee == "":
        return v3ParserResolvedCallTargetUnknown("unknown_qualified_target")
    let targetLookup = v3ParserImportedTargetProfileIndex(currentProfile, profiles, qualifier)
    if targetLookup.targetProfileIndex < 0:
        return v3ParserResolvedCallTargetUnknown(targetLookup.reason)
    let targetProfile = profiles[targetLookup.targetProfileIndex]
    if v3ParserCallProfileHasImportcCall(targetProfile, callee):
        return v3ParserResolvedCallTargetResolved(targetProfile.sourcePath, true)
    if v3ParserCallProfileHasLocalCall(targetProfile, callee):
        return v3ParserResolvedCallTargetResolved(targetProfile.sourcePath, false)
    let visibleTarget = v3ParserResolveUnqualifiedExternalCallTarget(targetProfile, profiles, callee)
    if visibleTarget.sourcePath != "":
        return visibleTarget
    if visibleTarget.reason == "ambiguous_external_target":
        return v3ParserResolvedCallTargetUnknown("ambiguous_qualified_target")
    return v3ParserResolvedCallTargetUnknown("unknown_qualified_target")

fn v3ParserResolveUnqualifiedExternalCallTarget(currentProfile: V3NormalizedExprCallProfile,
                                                profiles: V3NormalizedExprCallProfile[],
                                                calleeRaw: str): V3NormalizedExprResolvedCallTarget =
    let callee = v3ParserIdentPrefix(v3path.V3PathTrim(calleeRaw))
    if callee == "":
        return v3ParserResolvedCallTargetUnknown("unknown_external_target")
    let currentProfileIndex = v3ParserCallProfileIndexForSourcePath(profiles, currentProfile.sourcePath)
    if currentProfileIndex < 0:
        return v3ParserResolvedCallTargetUnknown("unknown_external_target")
    var activeSourcePaths: str[] = []
    add(activeSourcePaths, currentProfile.sourcePath)
    var pending: int32[] = []
    add(pending, currentProfileIndex)
    var pendingIndex: int32 = 0
    var found: V3NormalizedExprResolvedCallTarget[] = []
    while pendingIndex < pending.len:
        let workingProfileIndex = pending[pendingIndex]
        pendingIndex = pendingIndex + 1
        let workingProfile = profiles[workingProfileIndex]
        for edgeIndex in 0..<workingProfile.importEdges.len:
            let edge = workingProfile.importEdges[edgeIndex]
            if !edge.resolved || !v3ParserImportEdgeAllowsUnqualifiedCall(edge):
                continue
            let targetProfileIndex = v3ParserCallProfileIndexForSourcePath(profiles, edge.targetSourcePath)
            if targetProfileIndex < 0:
                continue
            let targetProfile = profiles[targetProfileIndex]
            let hasImportc = v3ParserCallProfileHasImportcCall(targetProfile, callee)
            let hasLocal = v3ParserCallProfileHasLocalCall(targetProfile, callee)
            if hasImportc || hasLocal:
                v3ParserAppendUniqueResolvedCallTarget(found,
                                                       v3ParserResolvedCallTargetResolved(targetProfile.sourcePath,
                                                                                          hasImportc))
            if v3ParserStringSeqContainsExact(activeSourcePaths, targetProfile.sourcePath):
                continue
            add(activeSourcePaths, targetProfile.sourcePath)
            add(pending, targetProfileIndex)
    if found.len <= 0:
        return v3ParserResolvedCallTargetUnknown("unknown_external_target")
    if found.len > 1:
        return v3ParserResolvedCallTargetUnknown("ambiguous_external_target")
    return found[0]

fn v3ParserResolveCallTarget(currentProfile: V3NormalizedExprCallProfile,
                             profiles: V3NormalizedExprCallProfile[],
                             detailKindRaw: str,
                             targetRaw: str,
                             calleeRaw: str): V3NormalizedExprResolvedCallTarget =
    let detailKind = v3path.V3PathTrim(detailKindRaw)
    if detailKind == "local_call":
        return v3ParserResolvedCallTargetResolved(currentProfile.sourcePath, false)
    if detailKind == "importc_call":
        return v3ParserResolvedCallTargetResolved(currentProfile.sourcePath, true)
    if detailKind != "external_call":
        return v3ParserResolvedCallTargetUnknown("unknown_call_target")
    let target = v3path.V3PathTrim(targetRaw)
    if v3ParserCallExprLastDot(target) >= 0:
        return v3ParserResolveQualifiedCallTarget(currentProfile, profiles, target, calleeRaw)
    return v3ParserResolveUnqualifiedExternalCallTarget(currentProfile, profiles, calleeRaw)

fn v3ParserQualifiedCallDepth(prefixRaw: str): int32 =
    let prefix = v3path.V3PathTrim(prefixRaw)
    if prefix == "":
        return 0
    var depth: int32 = 1
    for i in 0..<prefix.len:
        if prefix[i] == '.':
            depth = depth + 1
    return depth

fn v3ParserAppendQualifiedCallNames(out: var str[],
                                    seen: var V3ParserTextLookup,
                                    prefixRaw: str,
                                    callNames: str[]) =
    let prefix = v3path.V3PathTrim(prefixRaw)
    if prefix == "":
        return
    for i in 0..<callNames.len:
        let callName = callNames[i]
        if callName == "":
            continue
        v3ParserAppendUniqueLookupText(out, seen, v3ParserConcat3(prefix, ".", callName))

fn v3ParserAppendDirectExternalCallNames(out: var str[],
                                         seen: var V3ParserTextLookup,
                                         callNames: str[]) =
    for i in 0..<callNames.len:
        let callName = callNames[i]
        if callName == "":
            continue
        v3ParserAppendUniqueLookupText(out, seen, callName)

fn v3ParserAppendVisibleDirectExternalCallNames(out: var str[],
                                                seen: var V3ParserTextLookup,
                                                callNames: str[],
                                                currentProfile: V3NormalizedExprCallProfile) =
    for i in 0..<callNames.len:
        let callName = v3path.V3PathTrim(callNames[i])
        if callName == "":
            continue
        if v3ParserStringSeqContainsExact(currentProfile.localCallNames, callName):
            continue
        if v3ParserStringSeqContainsExact(currentProfile.importcCallNames, callName):
            continue
        v3ParserAppendUniqueLookupText(out, seen, callName)

fn v3ParserCloneTextSeq(items: str[]): str[] =
    var out: str[] = []
    for i in 0..<items.len:
        add(out, items[i])
    return out

fn v3ParserCollectVisibleUnqualifiedExternalCallNamesRecursive(rootProfile: V3NormalizedExprCallProfile,
                                                               profiles: V3NormalizedExprCallProfile[],
                                                               profileIndex: int32,
                                                               activeSourcePaths: str[],
                                                               seen: var V3ParserTextLookup,
                                                               out: var str[]) =
    if profileIndex < 0 || profileIndex >= profiles.len:
        return
    var visited = v3ParserCloneTextSeq(activeSourcePaths)
    let rootSourcePath = profiles[profileIndex].sourcePath
    if !v3ParserStringSeqContainsExact(visited, rootSourcePath):
        add(visited, rootSourcePath)
    var pending: int32[] = []
    add(pending, profileIndex)
    var pendingIndex: int32 = 0
    while pendingIndex < pending.len:
        let currentIndex = pending[pendingIndex]
        pendingIndex = pendingIndex + 1
        let current = profiles[currentIndex]
        for edgeIndex in 0..<current.importEdges.len:
            let edge = current.importEdges[edgeIndex]
            if !edge.resolved || !v3ParserImportEdgeAllowsUnqualifiedCall(edge):
                continue
            let targetProfileIndex = v3ParserCallProfileIndexForSourcePath(profiles, edge.targetSourcePath)
            if targetProfileIndex < 0:
                continue
            let targetProfile = profiles[targetProfileIndex]
            v3ParserAppendVisibleDirectExternalCallNames(out, seen, targetProfile.localCallNames, rootProfile)
            v3ParserAppendVisibleDirectExternalCallNames(out, seen, targetProfile.importcCallNames, rootProfile)
            if v3ParserStringSeqContainsExact(visited, targetProfile.sourcePath):
                continue
            add(visited, targetProfile.sourcePath)
            add(pending, targetProfileIndex)

fn v3ParserCollectResolvedUnqualifiedExternalTargetsRecursive(profiles: V3NormalizedExprCallProfile[],
                                                              profileIndex: int32,
                                                              calleeRaw: str,
                                                              activeSourcePaths: str[],
                                                              out: var V3NormalizedExprResolvedCallTarget[]) =
    if profileIndex < 0 || profileIndex >= profiles.len:
        return
    let callee = v3ParserIdentPrefix(v3path.V3PathTrim(calleeRaw))
    if callee == "":
        return
    var visited = v3ParserCloneTextSeq(activeSourcePaths)
    let rootSourcePath = profiles[profileIndex].sourcePath
    if !v3ParserStringSeqContainsExact(visited, rootSourcePath):
        add(visited, rootSourcePath)
    var pending: int32[] = []
    add(pending, profileIndex)
    var pendingIndex: int32 = 0
    while pendingIndex < pending.len:
        let currentIndex = pending[pendingIndex]
        pendingIndex = pendingIndex + 1
        let current = profiles[currentIndex]
        for edgeIndex in 0..<current.importEdges.len:
            let edge = current.importEdges[edgeIndex]
            if !edge.resolved || !v3ParserImportEdgeAllowsUnqualifiedCall(edge):
                continue
            let targetProfileIndex = v3ParserCallProfileIndexForSourcePath(profiles, edge.targetSourcePath)
            if targetProfileIndex < 0:
                continue
            let targetProfile = profiles[targetProfileIndex]
            let hasImportc = v3ParserCallProfileHasImportcCall(targetProfile, callee)
            let hasLocal = v3ParserCallProfileHasLocalCall(targetProfile, callee)
            if hasImportc || hasLocal:
                v3ParserAppendUniqueResolvedCallTarget(out,
                                                       v3ParserResolvedCallTargetResolved(targetProfile.sourcePath,
                                                                                          hasImportc))
            if v3ParserStringSeqContainsExact(visited, targetProfile.sourcePath):
                continue
            add(visited, targetProfile.sourcePath)
            add(pending, targetProfileIndex)

fn v3ParserCachedVisibleUnqualifiedExternalCallNames(profiles: V3NormalizedExprCallProfile[],
                                                     profileIndex: int32,
                                                     cache: var V3ParserTextSeqCacheEntry[]): str[] =
    var i: int32 = 0
    while i < cache.len:
        if cache[i].profileIndex == profileIndex:
            return cache[i].items
        i = i + 1
    var out: str[] = []
    if profileIndex < 0 || profileIndex >= profiles.len:
        return out
    let rootProfile = profiles[profileIndex]
    var activeSourcePaths: str[] = []
    add(activeSourcePaths, rootProfile.sourcePath)
    var seen: V3ParserTextLookup
    seen.slots = []
    seen.buckets = []
    seen.totalCount = 0
    v3ParserCollectVisibleUnqualifiedExternalCallNamesRecursive(rootProfile,
                                                                profiles,
                                                                profileIndex,
                                                                activeSourcePaths,
                                                                seen,
                                                                out)
    var entry: V3ParserTextSeqCacheEntry
    entry.profileIndex = profileIndex
    entry.items = out
    add(cache, entry)
    return out

fn v3ParserCollectExternalCallNamesRecursive(profiles: V3NormalizedExprCallProfile[],
                                             profileIndex: int32,
                                             prefixRaw: str,
                                             maxQualifiedCallDepth: int32,
                                             activeSourcePaths: str[],
                                             visibleNameCache: var V3ParserTextSeqCacheEntry[],
                                             seen: var V3ParserTextLookup,
                                             out: var str[]) =
    if profileIndex < 0 || profileIndex >= profiles.len:
        return
    let current = profiles[profileIndex]
    let prefix = v3path.V3PathTrim(prefixRaw)
    for edgeIndex in 0..<current.importEdges.len:
        let edge = current.importEdges[edgeIndex]
        if !edge.resolved:
            continue
        let targetProfileIndex = v3ParserCallProfileIndexForSourcePath(profiles, edge.targetSourcePath)
        if targetProfileIndex < 0:
            continue
        let qualifier = v3ParserImportEdgeQualifier(edge)
        if qualifier == "":
            continue
        let targetProfile = profiles[targetProfileIndex]
        if prefix == "" && v3ParserImportEdgeAllowsUnqualifiedCall(edge):
            v3ParserAppendVisibleDirectExternalCallNames(out, seen, targetProfile.localCallNames, current)
            v3ParserAppendVisibleDirectExternalCallNames(out, seen, targetProfile.importcCallNames, current)
        let nextPrefix = v3ParserQualifiedCallPrefix(prefix, qualifier)
        let nextDepth = v3ParserQualifiedCallDepth(nextPrefix)
        if nextDepth > maxQualifiedCallDepth:
            continue
        v3ParserAppendQualifiedCallNames(out, seen, nextPrefix, targetProfile.localCallNames)
        v3ParserAppendQualifiedCallNames(out, seen, nextPrefix, targetProfile.importcCallNames)
        let visibleNames = v3ParserCachedVisibleUnqualifiedExternalCallNames(profiles,
                                                                             targetProfileIndex,
                                                                             visibleNameCache)
        v3ParserAppendQualifiedCallNames(out, seen, nextPrefix, visibleNames)
        if nextDepth >= maxQualifiedCallDepth:
            continue
        if v3ParserStringSeqContainsExact(activeSourcePaths, targetProfile.sourcePath):
            continue
        var nextActive = v3ParserCloneTextSeq(activeSourcePaths)
        add(nextActive, targetProfile.sourcePath)
        v3ParserCollectExternalCallNamesRecursive(profiles,
                                                  targetProfileIndex,
                                                  nextPrefix,
                                                  maxQualifiedCallDepth,
                                                  nextActive,
                                                  visibleNameCache,
                                                  seen,
                                                  out)

fn v3ParserCollectExternalCallNames(profiles: V3NormalizedExprCallProfile[],
                                    profileIndex: int32,
                                    names: var str[]) =
    var out: str[] = []
    if profileIndex < 0 || profileIndex >= profiles.len:
        names = out
        return
    let rootProfile = profiles[profileIndex]
    var activeSourcePaths: str[] = []
    add(activeSourcePaths, rootProfile.sourcePath)
    var seen: V3ParserTextLookup
    seen.slots = []
    seen.buckets = []
    seen.totalCount = 0
    var pending: int32[] = []
    add(pending, profileIndex)
    var pendingIndex: int32 = 0
    while pendingIndex < pending.len:
        let workingProfileIndex = pending[pendingIndex]
        pendingIndex = pendingIndex + 1
        let workingProfile = profiles[workingProfileIndex]
        for edgeIndex in 0..<workingProfile.importEdges.len:
            let edge = workingProfile.importEdges[edgeIndex]
            if !edge.resolved || !v3ParserImportEdgeAllowsUnqualifiedCall(edge):
                continue
            let targetProfileIndex = v3ParserCallProfileIndexForSourcePath(profiles, edge.targetSourcePath)
            if targetProfileIndex < 0:
                continue
            let targetProfile = profiles[targetProfileIndex]
            v3ParserAppendVisibleDirectExternalCallNames(out, seen, targetProfile.localCallNames, rootProfile)
            v3ParserAppendVisibleDirectExternalCallNames(out, seen, targetProfile.importcCallNames, rootProfile)
            if v3ParserStringSeqContainsExact(activeSourcePaths, targetProfile.sourcePath):
                continue
            add(activeSourcePaths, targetProfile.sourcePath)
            add(pending, targetProfileIndex)
    var visibleNameCache: V3ParserTextSeqCacheEntry[] = []
    v3ParserCollectExternalCallNamesRecursive(profiles,
                                              profileIndex,
                                              "",
                                              profiles[profileIndex].maxQualifiedCallDepth,
                                              activeSourcePaths,
                                              visibleNameCache,
                                              seen,
                                              out)
    names = out

fn v3ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfiles(sourcePathRaw: str,
                                                                    text: str,
                                                                    importcCallNames: str[],
                                                                    localCallNames: str[],
                                                                    externalCallNames: str[],
                                                                    currentProfile: V3NormalizedExprCallProfile,
                                                                    profiles: V3NormalizedExprCallProfile[],
                                                                    layer: var V3NormalizedExprLayer,
                                                                    err: var str): bool =
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "missing source path"
        return false
    layer = v3NormalizedExprLayerZero()
    layer.sourceCount = 1
    let localCallLookup = v3ParserTextLookupBuild(localCallNames)
    let externalCallLookup = v3ParserTextLookupBuild(externalCallNames)
    let importcCallLookup = v3ParserTextLookupBuild(importcCallNames)
    var knownCallLookup = v3ParserTextLookupInit(localCallNames.len +
                                                 externalCallNames.len +
                                                 importcCallNames.len + 8)
    v3ParserTextLookupAddAll(knownCallLookup, localCallNames)
    v3ParserTextLookupAddAll(knownCallLookup, externalCallNames)
    v3ParserTextLookupAddAll(knownCallLookup, importcCallNames)
    let lines = v3ParserSplitChar(text, '\n')
    for i in 0..<lines.len:
        let line = v3ParserStripLineComment(lines[i])
        if v3path.V3PathTrim(line) == "":
            continue
        let lineNumber = i + 1
        v3ParserAppendIfExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendQuestionExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendRangeExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendComprehensionExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendFmtExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendResultIntrinsicExprsLine(sourcePath, lineNumber, line, layer)
        v3ParserAppendCallExprsLine(sourcePath,
                                    lineNumber,
                                    line,
                                    localCallLookup,
                                    "local_call",
                                    currentProfile,
                                    profiles,
                                    layer)
        v3ParserAppendCallExprsLine(sourcePath,
                                    lineNumber,
                                    line,
                                    externalCallLookup,
                                    "external_call",
                                    currentProfile,
                                    profiles,
                                    layer)
        v3ParserAppendCallExprsLine(sourcePath,
                                    lineNumber,
                                    line,
                                    importcCallLookup,
                                    "importc_call",
                                    currentProfile,
                                    profiles,
                                    layer)
        v3ParserAppendMemberCallExprsLine(sourcePath,
                                          lineNumber,
                                          line,
                                          knownCallLookup,
                                          currentProfile,
                                          layer)
    layer.questionResidualCount = 0
    err = ""
    return true

fn v3ParserReadNormalizedExprLayerFromTextWithKnownCalls(sourcePathRaw: str,
                                                         text: str,
                                                         importcCallNames: str[],
                                                         localCallNames: str[],
                                                         externalCallNames: str[],
                                                         layer: var V3NormalizedExprLayer,
                                                         err: var str): bool =
    var currentProfile: V3NormalizedExprCallProfile
    currentProfile.sourcePath = v3ParserNormalizePath(sourcePathRaw)
    currentProfile.ownerModulePath = ""
    currentProfile.text = text
    currentProfile.lines = v3ParserSplitChar(text, '\n')
    currentProfile.decls = []
    currentProfile.importcCallNames = v3ParserCloneTextSeq(importcCallNames)
    currentProfile.localCallNames = v3ParserCloneTextSeq(localCallNames)
    currentProfile.importEdges = []
    currentProfile.maxQualifiedCallDepth = v3ParserMaxQualifiedCallDepthLines(currentProfile.lines)
    var profiles: V3NormalizedExprCallProfile[] = []
    return v3ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfiles(sourcePathRaw,
                                                                            text,
                                                                            importcCallNames,
                                                                            localCallNames,
                                                                            externalCallNames,
                                                                            currentProfile,
                                                                            profiles,
                                                                            layer,
                                                                            err)

fn v3ParserReadNormalizedExprLayerFromText(sourcePathRaw: str,
                                           text: str,
                                           layer: var V3NormalizedExprLayer,
                                           err: var str): bool =
    let sourcePath = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "missing source path"
        return false
    var decls: V3NormalizedFunctionDecl[] = []
    var declErr = ""
    if !v3ParserReadNormalizedFunctionDecls(text, decls, declErr):
        err = declErr
        return false
    var importcCallNames: str[] = []
    var localCallNames: str[] = []
    v3ParserImportcCallNamesFromDecls(decls, importcCallNames)
    v3ParserLocalCallNamesFromDecls(decls, localCallNames)
    return v3ParserReadNormalizedExprLayerFromTextWithKnownCalls(sourcePath,
                                                                 text,
                                                                 importcCallNames,
                                                                 localCallNames,
                                                                 [],
                                                                 layer,
                                                                 err)

fn v3ParserReadNormalizedExprLayerFromPath(sourcePathRaw: str,
                                           layer: var V3NormalizedExprLayer,
                                           err: var str): bool =
    let sourcePath: str = v3ParserNormalizePath(sourcePathRaw)
    if !v3ParserSourceExists(sourcePath):
        err = "source file missing"
        return false
    let text: str = v3path.V3ReadTextFile("", sourcePath)
    if text == "":
        err = "failed to read source"
        return false
    return v3ParserReadNormalizedExprLayerFromText(sourcePath, text, layer, err)

fn v3ParserStringSeqContains(items: str[], targetRaw: str): bool =
    let target = v3path.V3PathTrim(targetRaw)
    for i in 0..<items.len:
        if items[i] == target:
            return true
    return false

fn v3ParserTextLookupDotCount(text: str): int32 =
    var count: int32 = 0
    var i: int32 = 0
    while i < text.len:
        if text[i] == '.':
            count = count + 1
        i = i + 1
    return count

fn v3ParserTextLookupInit(minCap: int32): V3ParserTextLookup =
    var lookup: V3ParserTextLookup
    lookup.slots = []
    lookup.buckets = []
    lookup.totalCount = 0
    var cap: int32 = 32
    while cap < minCap:
        cap = cap * 2
    var i: int32 = 0
    while i < cap:
        add(lookup.slots, 0)
        i = i + 1
    return lookup

fn v3ParserTextLookupHash(keyLen: int32,
                          firstCode: int32,
                          lastCode: int32,
                          dotCount: int32): int64 =
    var h: int64 = int64(keyLen)
    h = h * 131 + int64(firstCode)
    h = h * 131 + int64(lastCode)
    h = h * 131 + int64(dotCount)
    if h < 0:
        h = -h
    return h

fn v3ParserTextLookupSlotForParts(lookup: V3ParserTextLookup,
                                  keyLen: int32,
                                  firstCode: int32,
                                  lastCode: int32,
                                  dotCount: int32): int32 =
    if lookup.slots.len <= 0:
        return -1
    let mask = lookup.slots.len - 1
    var probe: int32 = int32(v3ParserTextLookupHash(keyLen,
                                                    firstCode,
                                                    lastCode,
                                                    dotCount) & int64(mask))
    var scanned: int32 = 0
    while scanned <= mask:
        let bucketIndexPlus1 = lookup.slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        let bucket = lookup.buckets[bucketIndexPlus1 - 1]
        if bucket.keyLen == keyLen &&
           bucket.firstCode == firstCode &&
           bucket.lastCode == lastCode &&
           bucket.dotCount == dotCount:
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn v3ParserTextLookupRehash(lookup: var V3ParserTextLookup,
                            newCap: int32) =
    var slots: int32[] = []
    var i: int32 = 0
    while i < newCap:
        add(slots, 0)
        i = i + 1
    lookup.slots = slots
    var bucketIndex: int32 = 0
    while bucketIndex < lookup.buckets.len:
        let bucket = lookup.buckets[bucketIndex]
        let slot = v3ParserTextLookupSlotForParts(lookup,
                                                  bucket.keyLen,
                                                  bucket.firstCode,
                                                  bucket.lastCode,
                                                  bucket.dotCount)
        if slot >= 0:
            lookup.slots[slot] = bucketIndex + 1
        bucketIndex = bucketIndex + 1

fn v3ParserTextLookupGrow(lookup: var V3ParserTextLookup) =
    var nextCap: int32 = lookup.slots.len * 2
    if nextCap < 32:
        nextCap = 32
    v3ParserTextLookupRehash(lookup, nextCap)

fn v3ParserTextLookupBucketIndexExact(lookup: V3ParserTextLookup,
                                      text: str): int32 =
    if text == "":
        return -1
    let keyLen = text.len
    let firstCode = int32(text[0])
    let lastCode = int32(text[keyLen - 1])
    let dotCount = v3ParserTextLookupDotCount(text)
    let slot = v3ParserTextLookupSlotForParts(lookup, keyLen, firstCode, lastCode, dotCount)
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup.slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn v3ParserTextLookupEnsureBucket(lookup: var V3ParserTextLookup,
                                  text: str): int32 =
    if lookup.slots.len <= 0:
        lookup = v3ParserTextLookupInit(32)
    if (lookup.buckets.len + 1) * 10 >= lookup.slots.len * 7:
        v3ParserTextLookupGrow(lookup)
    let keyLen = text.len
    let firstCode = int32(text[0])
    let lastCode = int32(text[keyLen - 1])
    let dotCount = v3ParserTextLookupDotCount(text)
    let slot = v3ParserTextLookupSlotForParts(lookup, keyLen, firstCode, lastCode, dotCount)
    if slot < 0:
        return -1
    let existing = lookup.slots[slot]
    if existing > 0:
        return existing - 1
    var bucket: V3ParserTextLookupBucket
    bucket.keyLen = keyLen
    bucket.firstCode = firstCode
    bucket.lastCode = lastCode
    bucket.dotCount = dotCount
    bucket.items = []
    add(lookup.buckets, bucket)
    lookup.slots[slot] = lookup.buckets.len
    return lookup.buckets.len - 1

fn v3ParserTextLookupAddExact(lookup: var V3ParserTextLookup,
                              value: str) =
    if value == "":
        return
    let bucketIndex = v3ParserTextLookupEnsureBucket(lookup, value)
    var bucket = lookup.buckets[bucketIndex]
    for i in 0..<bucket.items.len:
        if bucket.items[i] == value:
            return
    add(bucket.items, value)
    lookup.buckets[bucketIndex] = bucket
    lookup.totalCount = lookup.totalCount + 1

fn v3ParserTextLookupAdd(lookup: var V3ParserTextLookup,
                         text: str) =
    let value = v3path.V3PathTrim(text)
    v3ParserTextLookupAddExact(lookup, value)

fn v3ParserTextLookupAddAll(lookup: var V3ParserTextLookup,
                            items: str[]) =
    for i in 0..<items.len:
        v3ParserTextLookupAdd(lookup, items[i])

fn v3ParserTextLookupBuild(items: str[]): V3ParserTextLookup =
    var lookup = v3ParserTextLookupInit(items.len * 2 + 8)
    v3ParserTextLookupAddAll(lookup, items)
    return lookup

fn v3ParserTextLookupContainsExact(lookup: V3ParserTextLookup,
                                   target: str): bool =
    if target == "":
        return false
    let bucketIndex = v3ParserTextLookupBucketIndexExact(lookup, target)
    if bucketIndex < 0:
        return false
    let bucket = lookup.buckets[bucketIndex]
    for i in 0..<bucket.items.len:
        if bucket.items[i] == target:
            return true
    return false

fn v3ParserAppendUniqueLookupText(out: var str[],
                                  seen: var V3ParserTextLookup,
                                  text: str) =
    let value = v3path.V3PathTrim(text)
    if value == "":
        return
    if v3ParserTextLookupContainsExact(seen, value):
        return
    add(out, value)
    v3ParserTextLookupAddExact(seen, value)

fn v3ParserMatchKnownCallSurfaceText(callLookup: V3ParserTextLookup,
                                     callName: str,
                                     qualifiedCallName: str,
                                     dottedCallName: str): str =
    if dottedCallName != callName && v3ParserTextLookupContainsExact(callLookup, dottedCallName):
        return dottedCallName
    if qualifiedCallName != callName && v3ParserTextLookupContainsExact(callLookup, qualifiedCallName):
        return qualifiedCallName
    if v3ParserTextLookupContainsExact(callLookup, callName):
        return callName
    return ""

fn v3ParserStringSeqContainsExact(items: str[], target: str): bool =
    for i in 0..<items.len:
        if items[i] == target:
            return true
    return false

fn v3ParserIsInlineSpace(ch: char): bool =
    let code = int32(ch)
    if code == 32:
        return true
    if code == 9:
        return true
    return false

fn v3ParserFirstToken(textRaw: str): str =
    let text = v3path.V3PathTrim(textRaw)
    if text == "":
        return ""
    var start: int32 = 0
    while start < text.len:
        if !v3ParserIsInlineSpace(text[start]):
            break
        start = start + 1
    var stop: int32 = start
    while stop < text.len:
        if v3ParserIsInlineSpace(text[stop]):
            break
        stop = stop + 1
    if stop <= start:
        return ""
    return v3path.V3TextSlice(text, start, stop - start)

fn v3ParserIdentPrefix(text: str): str =
    var stop: int32 = 0
    for i in 0..<text.len:
        let ch = text[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower || ch == '_':
            stop = i + 1
        else:
            break
    if stop <= 0:
        return ""
    return v3path.V3TextSlice(text, 0, stop)

fn v3ParserTextSliceFast(text: str,
                         startRaw: int32,
                         countRaw: int32): str =
    if countRaw <= 0:
        return ""
    let textLen = text.len
    if textLen <= 0:
        return ""
    var start = startRaw
    if start < 0:
        start = 0
    if start >= textLen:
        return ""
    var count = countRaw
    if start + count > textLen:
        count = textLen - start
    if count <= 0:
        return ""
    let data = strDataPtr(text)
    if data == nil:
        return ""
    return strViewWithFlags(system_ptr_add(data, start), count, text.store_id, 0)

fn v3ParserSplitChar(textRaw: str, sep: char): str[] =
    let text = textRaw
    var out: str[] = []
    var start: int32 = 0
    for i in 0..<text.len:
        if text[i] == sep:
            add(out, v3ParserTextSliceFast(text, start, i - start))
            start = i + 1
    if start <= text.len:
        add(out, v3ParserTextSliceFast(text, start, text.len - start))
    return out

fn v3ParserJoinSlash(items: str[]): str =
    var out = buffer.NewByteBuffer()
    let slash: str = "/"
    var wrote = false
    for i in 0..<items.len:
        if items[i] == "":
            continue
        if wrote:
            buffer.AppendBytes(out, slash)
        buffer.AppendBytes(out, items[i])
        wrote = true
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn v3ParserStartsWith(textRaw: str, prefixRaw: str): bool =
    let text = v3path.V3PathTrim(textRaw)
    let prefix = v3path.V3PathTrim(prefixRaw)
    if prefix.len > text.len:
        return false
    for i in 0..<prefix.len:
        if text[i] != prefix[i]:
            return false
    return true

fn v3ParserLineStartsWith(lineRaw: str, prefix: str): bool =
    return v3ParserStartsWith(lineRaw, prefix)

fn v3ParserFindText(text: str, needle: str): int32 =
    if needle.len <= 0:
        return 0
    if text.len < needle.len:
        return -1
    for i in 0..<(text.len - needle.len + 1):
        var matched = true
        for j in 0..<needle.len:
            if text[i + j] != needle[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn v3ParserCompilerTopLevelExportName(lineRaw: str): str =
    let line = v3path.V3PathTrim(lineRaw)
    if !v3ParserStartsWith(line, "@compiler_top_level("):
        return ""
    let exportPos = v3ParserFindText(line, "export_name")
    if exportPos < 0:
        return ""
    let quoteStart = v3ParserFindText(v3path.V3TextSlice(line, exportPos, line.len - exportPos), "\"")
    if quoteStart < 0:
        return ""
    let valueStart = exportPos + quoteStart + 1
    let tail = v3path.V3TextSlice(line, valueStart, line.len - valueStart)
    let quoteEnd = v3ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return v3path.V3TextSlice(line, valueStart, quoteEnd)

fn v3ParserExportcNameFromAnnotation(lineRaw: str): str =
    let line = v3path.V3PathTrim(lineRaw)
    if !v3ParserStartsWith(line, "@exportc("):
        return ""
    let quoteStart = v3ParserFindText(line, "\"")
    if quoteStart < 0:
        return ""
    let tail = v3path.V3TextSlice(line, quoteStart + 1, line.len - (quoteStart + 1))
    let quoteEnd = v3ParserFindText(tail, "\"")
    if quoteEnd <= 0:
        return ""
    return v3path.V3TextSlice(line, quoteStart + 1, quoteEnd)

fn v3ParserIsImportcAnnotation(lineRaw: str): bool =
    return v3ParserStartsWith(lineRaw, "@importc(")

fn v3ParserHasLeadingIndent(lineRaw: str): bool =
    if len(lineRaw) <= 0:
        return false
    let head = int32(lineRaw[0])
    return head == 32 || head == 9

fn v3ParserTopLevelFunctionKeyword(lineRaw: str): str =
    if v3ParserHasLeadingIndent(lineRaw):
        return ""
    let line = v3path.V3PathTrim(lineRaw)
    if v3ParserStartsWith(line, "importc fn "):
        return "fn"
    if v3ParserStartsWith(line, "fn "):
        return "fn"
    if v3ParserStartsWith(line, "func "):
        return "func"
    if v3ParserStartsWith(line, "proc "):
        return "proc"
    if v3ParserStartsWith(line, "method "):
        return "method"
    if v3ParserStartsWith(line, "converter "):
        return "converter"
    return ""

fn v3ParserFunctionNameFromLine(lineRaw: str): str =
    if v3ParserHasLeadingIndent(lineRaw):
        return ""
    let line = v3path.V3PathTrim(lineRaw)
    var prefixLen: int32 = 0
    if v3ParserStartsWith(line, "importc fn "):
        prefixLen = len("importc fn ")
    elif v3ParserStartsWith(line, "fn "):
        prefixLen = len("fn ")
    elif v3ParserStartsWith(line, "func "):
        prefixLen = len("func ")
    elif v3ParserStartsWith(line, "proc "):
        prefixLen = len("proc ")
    elif v3ParserStartsWith(line, "method "):
        prefixLen = len("method ")
    elif v3ParserStartsWith(line, "converter "):
        prefixLen = len("converter ")
    if prefixLen <= 0:
        return ""
    if prefixLen >= line.len:
        return ""
    let tail = v3path.V3TextSlice(line, prefixLen, line.len - prefixLen)
    let firstToken = v3ParserFirstToken(tail)
    return v3ParserIdentPrefix(firstToken)

fn v3ParserReadNormalizedFunctionDeclsLines(lines: str[],
                                            decls: var V3NormalizedFunctionDecl[],
                                            err: var str): bool =
    var emptyDecls: V3NormalizedFunctionDecl[] = []
    decls = emptyDecls
    var pendingImportc = false
    var pendingExplicitExportName: str = ""
    for i in 0..<lines.len:
        let lineRaw = lines[i]
        let trimmed = v3path.V3PathTrim(lineRaw)
        if trimmed == "":
            continue
        if v3ParserHasLeadingIndent(lineRaw):
            continue
        let compilerExportName = v3ParserCompilerTopLevelExportName(trimmed)
        if compilerExportName != "":
            pendingExplicitExportName = compilerExportName
            continue
        let exportcName = v3ParserExportcNameFromAnnotation(trimmed)
        if exportcName != "":
            pendingExplicitExportName = exportcName
            continue
        if v3ParserIsImportcAnnotation(trimmed):
            pendingImportc = true
            pendingExplicitExportName = ""
            continue
        if v3ParserStartsWith(trimmed, "@"):
            continue
        let keyword = v3ParserTopLevelFunctionKeyword(lineRaw)
        if keyword == "":
            pendingImportc = false
            pendingExplicitExportName = ""
            continue
        if keyword != "fn":
            err = v3ParserConcat3("unsupported top-level function alias '", keyword, "'")
            return false
        let functionName = v3ParserFunctionNameFromLine(lineRaw)
        if functionName == "":
            pendingImportc = false
            pendingExplicitExportName = ""
            continue
        let inlineImportc = v3ParserStartsWith(trimmed, "importc fn ")
        var decl: V3NormalizedFunctionDecl
        decl.name = functionName
        decl.lineIndex = i + 1
        decl.importc = pendingImportc || inlineImportc
        decl.explicitExportName = decl.importc ? "" : pendingExplicitExportName
        decl.surfaceKeyword = inlineImportc ? "importc fn" : "fn"
        add(decls, decl)
        pendingImportc = false
        pendingExplicitExportName = ""
    err = ""
    return true

fn v3ParserReadNormalizedFunctionDecls(textRaw: str,
                                       decls: var V3NormalizedFunctionDecl[],
                                       err: var str): bool =
    let lines = v3ParserSplitChar(textRaw, '\n')
    return v3ParserReadNormalizedFunctionDeclsLines(lines, decls, err)

fn v3ParserContainsCompilerPrefix(lineRaw: str): bool =
    let line = v3path.V3PathTrim(lineRaw)
    if v3ParserStartsWith(line, "import "):
        return true
    if v3ParserStartsWith(line, "type"):
        return true
    if v3ParserTopLevelFunctionKeyword(line) != "":
        return true
    if v3ParserStartsWith(line, "iterator "):
        return true
    if v3ParserStartsWith(line, "const "):
        return true
    if v3ParserStartsWith(line, "let "):
        return true
    if v3ParserStartsWith(line, "var "):
        return true
    return false

fn v3ParserModulePathTail(modulePath: str, skipCount: int32): str =
    let modulePathTrim = v3path.V3PathTrim(modulePath)
    let parts = v3ParserSplitChar(modulePathTrim, '/')
    var out: str[] = []
    for i in skipCount..<parts.len:
        let rawPiece = parts[i]
        let piece = v3path.V3PathTrim(rawPiece)
        if piece != "":
            add(out, piece)
    return v3ParserJoinSlash(out)

fn v3ParserPathSlash(pathRaw: str): str =
    return v3ParserJoinSlash(v3ParserSplitChar(pathRaw, '\\'))

fn v3ParserRelWithoutExt(pathRaw: str): str =
    let path = v3ParserPathSlash(v3ParserNormalizePath(pathRaw))
    if path.len >= 6 && v3path.V3TextSlice(path, path.len - 6, 6) == ".cheng":
        return v3path.V3TextSlice(path, 0, path.len - 6)
    return path

fn v3ParserSharedV3PackageRoot(workspaceRootRaw: str): str =
    let workspaceRoot = v3ParserNormalizePath(workspaceRootRaw)
    if workspaceRoot == "":
        return ""
    let sharedV3Root = v3ParserNormalizePath(v3path.V3PathJoin(workspaceRoot, "v3"))
    if v3ParserPackageManifestExists(sharedV3Root):
        return sharedV3Root
    return ""

fn v3ParserModulePathToSourcePath(workspaceRootRaw: str, packageRootRaw: str, modulePathRaw: str): str =
    let workspaceRoot: str = v3ParserNormalizePath(workspaceRootRaw)
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    let modulePath: str = v3path.V3PathTrim(modulePathRaw)
    if modulePath == "":
        return ""
    if v3ParserStartsWith(modulePath, "std/") && modulePath.len > 4:
        let rel: str = v3ParserModulePathTail(modulePath, 1)
        return v3ParserConcat3(v3ParserConcat2(workspaceRoot, "/src/std/"), rel, ".cheng")
    let sharedV3PackageRoot: str = v3ParserSharedV3PackageRoot(workspaceRoot)
    if sharedV3PackageRoot != "" &&
       v3ParserStartsWith(modulePath, "cheng/v3/") &&
       modulePath.len > 9:
        let rel: str = v3ParserModulePathTail(modulePath, 2)
        return v3ParserConcat3(v3ParserConcat2(sharedV3PackageRoot, "/src/"), rel, ".cheng")
    let packageId: str = v3ParserPackageId(packageRoot)
    let packagePrefix: str = v3ParserConcat2(packageId, "/")
    if packageId != "" && modulePath.len > packageId.len && v3ParserStartsWith(modulePath, packagePrefix):
        let rel: str = v3ParserModulePathTail(modulePath, 2)
        return v3ParserConcat3(v3ParserConcat2(packageRoot, "/src/"), rel, ".cheng")
    return ""

fn v3ParserSourcePathToModulePath(workspaceRootRaw: str, packageRootRaw: str, sourcePathRaw: str): str =
    let workspaceRoot: str = v3ParserNormalizePath(workspaceRootRaw)
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    let sourcePath: str = v3ParserNormalizePath(sourcePathRaw)
    let packagePrefix: str = v3ParserConcat2(packageRoot, "/src/")
    if v3ParserStartsWith(sourcePath, packagePrefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                packagePrefix.len,
                                                                sourcePath.len - packagePrefix.len))
        let packageId: str = v3ParserPackageId(packageRoot)
        if rel == "":
            return packageId
        return v3ParserConcat3(packageId, "/", rel)
    let sharedV3PackageRoot: str = v3ParserSharedV3PackageRoot(workspaceRoot)
    let sharedV3Prefix: str = v3ParserConcat2(sharedV3PackageRoot, "/src/")
    if sharedV3PackageRoot != "" && v3ParserStartsWith(sourcePath, sharedV3Prefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                sharedV3Prefix.len,
                                                                sourcePath.len - sharedV3Prefix.len))
        if rel == "":
            return "cheng/v3"
        return v3ParserConcat2("cheng/v3/", rel)
    let stdPrefix: str = v3ParserConcat2(workspaceRoot, "/src/std/")
    if v3ParserStartsWith(sourcePath, stdPrefix):
        let rel: str = v3ParserRelWithoutExt(v3path.V3TextSlice(sourcePath,
                                                                stdPrefix.len,
                                                                sourcePath.len - stdPrefix.len))
        if rel == "":
            return "std"
        return v3ParserConcat2("std/", rel)
    return v3ParserFileStem(sourcePath)

fn v3ParserHasCompilerTopLevel(textRaw: str): bool =
    let lines = v3ParserSplitChar(textRaw, '\n')
    var decls: V3NormalizedFunctionDecl[] = []
    var err = ""
    if v3ParserReadNormalizedFunctionDeclsLines(lines, decls, err):
        if decls.len > 0:
            return true
    for i in 0..<lines.len:
        if v3ParserContainsCompilerPrefix(lines[i]):
            return true
    return false

fn v3ParserMainFunctionPresent(textRaw: str): bool =
    let lines = v3ParserSplitChar(textRaw, '\n')
    var decls: V3NormalizedFunctionDecl[] = []
    var err = ""
    if !v3ParserReadNormalizedFunctionDeclsLines(lines, decls, err):
        return false
    for i in 0..<decls.len:
        if decls[i].importc:
            continue
        if decls[i].name == "main":
            return true
    return false

fn v3ParserAppendImportEdge(workspaceRoot: str,
                            packageRoot: str,
                            ownerModulePath: str,
                            modulePathRaw: str,
                            importAliasRaw: str,
                            edges: var V3ImportEdge[],
                            err: var str): bool =
    let modulePath = v3path.V3PathTrim(modulePathRaw)
    if modulePath == "":
        err = "v3 parser: malformed import"
        return false
    let sourcePath = v3ParserModulePathToSourcePath(workspaceRoot, packageRoot, modulePath)
    let resolved = v3ParserSourceExists(sourcePath)
    var edge: V3ImportEdge
    edge.ownerModulePath = ownerModulePath
    edge.targetModulePath = modulePath
    edge.targetSourcePath = sourcePath
    edge.importAlias = v3path.V3PathTrim(importAliasRaw)
    edge.resolved = resolved
    add(edges, edge)
    err = ""
    return true

fn v3ParserReadImportEdgesLines(workspaceRoot: str,
                                packageRoot: str,
                                ownerModulePath: str,
                                lines: str[],
                                edges: var V3ImportEdge[],
                                err: var str): bool =
    edges = []
    for i in 0..<lines.len:
        let rawLine = lines[i]
        let line = v3path.V3PathTrim(v3ParserStripLineComment(rawLine))
        if !v3path.V3TextStartsWith(line, "import "):
            continue
        let importTail = v3path.V3PathTrim(v3path.V3TextSlice(line, 7, line.len - 7))
        let asMarker = " as "
        let asPos = v3ParserFindText(importTail, asMarker)
        var importSpec = ""
        var importAlias = ""
        if asPos >= 0:
            importSpec = v3path.V3PathTrim(v3path.V3TextSlice(importTail, 0, asPos))
            let aliasTailStart = asPos + len(asMarker)
            if aliasTailStart < importTail.len:
                let aliasTail = v3path.V3TextSlice(importTail,
                                                   aliasTailStart,
                                                   importTail.len - aliasTailStart)
                importAlias = v3ParserIdentPrefix(v3ParserFirstToken(aliasTail))
        else:
            importSpec = v3path.V3PathTrim(importTail)
        let groupedOpenPos = v3ParserFindText(importSpec, "/[")
        if groupedOpenPos >= 0:
            if importAlias != "":
                err = "v3 parser: grouped import alias unsupported"
                return false
            let groupedClosePos = v3ParserFindText(importSpec, "]")
            if groupedClosePos < 0 || groupedClosePos != importSpec.len - 1:
                err = "v3 parser: malformed grouped import"
                return false
            let groupPrefix = v3path.V3PathTrim(v3path.V3TextSlice(importSpec, 0, groupedOpenPos))
            let groupItemsText = v3path.V3TextSlice(importSpec,
                                                    groupedOpenPos + 2,
                                                    groupedClosePos - (groupedOpenPos + 2))
            if groupPrefix == "" || groupItemsText == "":
                err = "v3 parser: malformed grouped import"
                return false
            var appended = false
            var start: int32 = 0
            var itemPos: int32 = 0
            while itemPos <= len(groupItemsText):
                let atEnd = itemPos >= len(groupItemsText)
                var stop = false
                if atEnd:
                    stop = true
                elif groupItemsText[itemPos] == ',':
                    stop = true
                if !stop:
                    itemPos = itemPos + 1
                    continue
                let itemRaw = v3path.V3TextSlice(groupItemsText, start, itemPos - start)
                let item = v3path.V3PathTrim(itemRaw)
                if len(item) > 0:
                    if !v3ParserAppendImportEdge(workspaceRoot,
                                                 packageRoot,
                                                 ownerModulePath,
                                                 v3ParserConcat3(groupPrefix, "/", item),
                                                 "",
                                                 edges,
                                                 err):
                        return false
                    appended = true
                start = itemPos + 1
                itemPos = itemPos + 1
            if !appended:
                err = "v3 parser: malformed grouped import"
                return false
            continue
        if !v3ParserAppendImportEdge(workspaceRoot,
                                     packageRoot,
                                     ownerModulePath,
                                     importSpec,
                                     importAlias,
                                     edges,
                                     err):
            return false
    err = ""
    return true

fn v3ParserReadImportEdges(workspaceRoot: str,
                           packageRoot: str,
                           ownerModulePath: str,
                           textRaw: str,
                           edges: var V3ImportEdge[],
                           err: var str): bool =
    let lines = v3ParserSplitChar(textRaw, '\n')
    return v3ParserReadImportEdgesLines(workspaceRoot, packageRoot, ownerModulePath, lines, edges, err)

fn v3ImportEdgeTargetSourcePath(edge: V3ImportEdge): str =
    return edge.targetSourcePath

fn v3ParserAddUniqueImportEdge(edges: var V3ImportEdge[],
                               edge: V3ImportEdge) =
    for i in 0..<edges.len:
        if edges[i].ownerModulePath != edge.ownerModulePath:
            continue
        if edges[i].targetModulePath != edge.targetModulePath:
            continue
        if edges[i].importAlias != edge.importAlias:
            continue
        return
    add(edges, edge)

fn v3ParserAddUniqueText(items: var str[],
                         text: str) =
    let value = v3path.V3PathTrim(text)
    v3ParserAddUniqueTextExact(items, value)

fn v3ParserAddUniqueTextExact(items: var str[],
                              value: str) =
    if value == "":
        return
    for i in 0..<items.len:
        if items[i] == value:
            return
    add(items, value)

fn v3ParserCollectClosure(workspaceRoot: str,
                          packageRoot: str,
                          sourcePathRaw: str,
                          seen: var str[],
                          ordered: var str[],
                          importEdges: var V3ImportEdge[],
                          unresolved: var int32,
                          err: var str): bool =
    let sourcePath: str = v3path.V3PathTrim(sourcePathRaw)
    if sourcePath == "":
        err = "v3 parser: missing closure source path"
        return false
    if v3ParserStringSeqContainsExact(seen, sourcePath):
        err = ""
        return true
    if !v3ParserSourceExists(sourcePath):
        err = "v3 parser: missing source"
        return false
    if !v3ParserStringSeqContainsExact(seen, sourcePath):
        add(seen, sourcePath)
        add(ordered, sourcePath)
    var scanPos: int32 = 0
    while scanPos < ordered.len:
        let currentSourcePath = ordered[scanPos]
        scanPos = scanPos + 1
        let text = v3ParserOwnedText(v3path.V3ReadTextFile("", currentSourcePath))
        let lines = v3ParserSplitChar(text, '\n')
        let ownerModulePath = v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, currentSourcePath)
        var edges: V3ImportEdge[]
        if !v3ParserReadImportEdgesLines(workspaceRoot, packageRoot, ownerModulePath, lines, edges, err):
            return false
        for i in 0..<edges.len:
            v3ParserAddUniqueImportEdge(importEdges, edges[i])
            let childSourcePath = edges[i].targetSourcePath
            if !edges[i].resolved:
                unresolved = unresolved + 1
                continue
            if v3ParserStringSeqContainsExact(seen, childSourcePath):
                continue
            add(seen, childSourcePath)
            add(ordered, childSourcePath)
    err = ""
    return true

fn v3ParseOrdinarySourceStub(packageRootRaw: str,
                             sourcePathRaw: str,
                             parsed: var V3ParsedSourceStub,
                             err: var str): bool =
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    let sourcePath: str = v3ParserNormalizePath(sourcePathRaw)
    if sourcePath == "":
        err = "v3 parser: missing source path"
        return false
    if !v3ParserSourceExists(sourcePath):
        err = "v3 parser: source file missing"
        return false
    let workspaceRoot: str = v3ParserWorkspaceRoot(packageRoot)
    let packageId: str = v3ParserPackageId(packageRoot)
    let moduleStem: str = v3ParserFileStem(sourcePath)
    let rootText: str = v3ParserOwnedText(v3path.V3ReadTextFile("", sourcePath))
    if rootText == "":
        err = "v3 parser: failed to read source"
        return false
    var rootDecls: V3NormalizedFunctionDecl[] = []
    if !v3ParserReadNormalizedFunctionDecls(rootText, rootDecls, err):
        return false
    var seen: str[] = []
    var ordered: str[] = []
    var importEdges: V3ImportEdge[] = []
    var exprLayer = v3NormalizedExprLayerZero()
    var unresolved: int32 = 0
    if !v3ParserCollectClosure(workspaceRoot, packageRoot, sourcePath, seen, ordered, importEdges, unresolved, err):
        return false
    var sourceProfiles: V3NormalizedExprCallProfile[] = []
    for i in 0..<ordered.len:
        let sourceText = v3ParserOwnedText(v3path.V3ReadTextFile("", ordered[i]))
        var profile: V3NormalizedExprCallProfile
        var profileErr = ""
        if !v3ParserBuildExprCallProfile(workspaceRoot, packageRoot, ordered[i], sourceText, profile, profileErr):
            err = profileErr
            return false
        add(sourceProfiles, profile)
    for i in 0..<sourceProfiles.len:
        var sourceExprLayer = v3NormalizedExprLayerZero()
        var sourceExternalCallNames: str[] = []
        v3ParserCollectExternalCallNames(sourceProfiles, i, sourceExternalCallNames)
        if !v3ParserReadNormalizedExprLayerFromTextWithKnownCallsAndProfiles(sourceProfiles[i].sourcePath,
                                                                             sourceProfiles[i].text,
                                                                             sourceProfiles[i].importcCallNames,
                                                                             sourceProfiles[i].localCallNames,
                                                                             sourceExternalCallNames,
                                                                             sourceProfiles[i],
                                                                             sourceProfiles,
                                                                             sourceExprLayer,
                                                                             err):
            err = v3ParserConcat4("v3 parser: ", sourceProfiles[i].sourcePath, ": ", err)
            return false
        v3NormalizedExprLayerAdd(exprLayer, sourceExprLayer)
    var ownerModulePaths: str[] = []
    for i in 0..<ordered.len:
        v3ParserAddUniqueText(ownerModulePaths,
                              v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, ordered[i]))
    parsed.workspaceRoot = workspaceRoot
    parsed.packageRoot = packageRoot
    parsed.packageId = packageId
    parsed.entrySourcePath = sourcePath
    parsed.sourcePath = sourcePath
    parsed.moduleStem = moduleStem
    parsed.syntaxTag = "v3_normalized_source_v3"
    parsed.sourceKind = v3ParsedOrdinarySource
    parsed.ownerModulePaths = ownerModulePaths
    parsed.importEdges = importEdges
    parsed.orderedClosureSourcePaths = ordered
    parsed.normalizedExprLayer = exprLayer
    parsed.hasCompilerTopLevel = v3ParserHasCompilerTopLevel(rootText)
    parsed.mainFunctionPresent = false
    for i in 0..<rootDecls.len:
        if rootDecls[i].importc:
            continue
        if rootDecls[i].name == "main":
            parsed.mainFunctionPresent = true
    parsed.unresolvedImportCount = unresolved
    err = ""
    return true
