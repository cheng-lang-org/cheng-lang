import std/result
import std/buffer
import std/rawbytes
import std/rawmem_support
import std/system
import cheng/v3/tooling/path as v3path

type
    V3ParsedSourceKind = enum
        v3ParsedOrdinarySource

    V3ImportEdge =
        ownerModulePath: str
        targetModulePath: str
        targetSourcePath: str
        targetSourcePathLen: int32
        targetSourcePathFirstCode: int32
        targetSourcePathLastCode: int32
        targetSourcePathDotCount: int32
        targetSourcePathHash: int32
        targetProfileIndex: int32
        importAlias: str
        qualifier: str
        allowsUnqualifiedCall: bool
        resolved: bool

    V3NormalizedExprKind = enum
        v3NormalizedExprIf
        v3NormalizedExprRange
        v3NormalizedExprComprehension
        v3NormalizedExprStrFormat
        v3NormalizedExprResultIntrinsic
        v3NormalizedExprCall
        v3NormalizedExprTry

    V3NormalizedExpr =
        exprId: str
        sourcePath: str
        lineNumber: int32
        columnNumber: int32
        endLineNumber: int32
        endColumnNumber: int32
        kind: V3NormalizedExprKind
        detail: str
        surfaceText: str
        callSurfaceKind: str
        callResolved: bool
        callReason: str
        callQualifier: str
        callCallee: str
        callTarget: str
        callTargetSourcePath: str
        callTargetImportc: bool
        callPrefixStyle: bool
        callArgCount: int32
        callArgsText: str

    V3NormalizedExprLookupBucket =
        sourcePathLen: int32
        sourcePathFirstCode: int32
        sourcePathLastCode: int32
        lineNumber: int32
        columnNumber: int32
        kindCode: int32
        detailLen: int32
        detailFirstCode: int32
        detailLastCode: int32
        surfaceLen: int32
        surfaceFirstCode: int32
        surfaceLastCode: int32
        items: int32[]

    V3NormalizedExprLookup =
        slots: int32[]
        buckets: V3NormalizedExprLookupBucket[]

    V3NormalizedExprLayer =
        sourceCount: int32
        exprs: V3NormalizedExpr[]
        questionResidualCount: int32
        exprLookup: V3NormalizedExprLookup

    V3ParsedSourceStub =
        workspaceRoot: str
        packageRoot: str
        packageId: str
        entrySourcePath: str
        sourcePath: str
        moduleStem: str
        syntaxTag: str
        sourceKind: V3ParsedSourceKind
        ownerModulePaths: str[]
        importEdges: V3ImportEdge[]
        orderedClosureSourcePaths: str[]
        normalizedExprLayer: V3NormalizedExprLayer
        hasCompilerTopLevel: bool
        mainFunctionPresent: bool
        unresolvedImportCount: int32

    V3NormalizedFunctionDecl =
        name: str
        lineIndex: int32
        importc: bool
        explicitExportName: str
        surfaceKeyword: str

    V3NormalizedExprCallProfile =
        sourcePath: str
        ownerModulePath: str
        text: str
        lines: str[]
        decls: V3NormalizedFunctionDecl[]
        importcCallNames: str[]
        localCallNames: str[]
        importEdges: V3ImportEdge[]
        maxQualifiedCallDepth: int32

    V3NormalizedExprResolvedCallTarget =
        sourcePath: str
        importc: bool
        reason: str

    V3ParserImportedTargetLookup =
        targetProfileIndex: int32
        reason: str

    V3ParserTextSeqCacheEntry =
        profileIndex: int32
        items: str[]

    V3ParserQualifiedTextSeqCacheEntry =
        profileIndex: int32
        prefix: str
        items: str[]

    V3ParserTextLookupKey =
        keyLen: int32
        firstCode: int32
        lastCode: int32
        dotCount: int32
        textHash: int32

    V3ParserTextLookupBucket =
        keyLen: int32
        firstCode: int32
        lastCode: int32
        dotCount: int32
        textHash: int32
        items: str[]

    V3ParserTextLookup =
        slots: int32[]
        buckets: V3ParserTextLookupBucket[]
        totalCount: int32

    V3ParserSourcePathIndexEntry =
        sourcePath: str
        profileIndex: int32

    V3ParserSourcePathIndexBucket =
        keyLen: int32
        firstCode: int32
        lastCode: int32
        dotCount: int32
        sourcePathHash: int32
        items: V3ParserSourcePathIndexEntry[]

    V3ParserSourcePathIndexLookup =
        slots: int32[]
        buckets: V3ParserSourcePathIndexBucket[]

type
    V3ParserProfileCallLookupCacheEntry =
        localLookup: V3ParserTextLookup
        importcLookup: V3ParserTextLookup

fn v3ParsedSourceKindText(kind: V3ParsedSourceKind): str =
    if kind == v3ParsedOrdinarySource:
        return "ordinary_cheng_source"
    return "unknown"

fn v3ParsedSourceWorkspaceRoot(parsed: V3ParsedSourceStub): str =
    return parsed.workspaceRoot

fn v3NormalizedExprKindText(kind: V3NormalizedExprKind): str =
    if kind == v3NormalizedExprIf:
        return "IfExpr"
    if kind == v3NormalizedExprRange:
        return "RangeExpr"
    if kind == v3NormalizedExprComprehension:
        return "ComprehensionExpr"
    if kind == v3NormalizedExprStrFormat:
        return "StrFormatExpr"
    if kind == v3NormalizedExprResultIntrinsic:
        return "ResultIntrinsic"
    if kind == v3NormalizedExprCall:
        return "CallExpr"
    if kind == v3NormalizedExprTry:
        return "TryExpr"
    return "UnknownExpr"

fn v3NormalizedExprClone(expr: V3NormalizedExpr): V3NormalizedExpr =
    var out: V3NormalizedExpr
    out.exprId = expr.exprId
    out.sourcePath = expr.sourcePath
    out.lineNumber = expr.lineNumber
    out.columnNumber = expr.columnNumber
    out.endLineNumber = expr.endLineNumber
    out.endColumnNumber = expr.endColumnNumber
    out.kind = expr.kind
    out.detail = expr.detail
    out.surfaceText = expr.surfaceText
    out.callSurfaceKind = expr.callSurfaceKind
    out.callResolved = expr.callResolved
    out.callReason = expr.callReason
    out.callQualifier = expr.callQualifier
    out.callCallee = expr.callCallee
    out.callTarget = expr.callTarget
    out.callTargetSourcePath = expr.callTargetSourcePath
    out.callTargetImportc = expr.callTargetImportc
    out.callPrefixStyle = expr.callPrefixStyle
    out.callArgCount = expr.callArgCount
    out.callArgsText = expr.callArgsText
    return out

fn v3NormalizedExprCompatDetail(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return expr.detail
    return v3ParserCallExprDetailExact(expr.callSurfaceKind,
                                       expr.callCallee,
                                       expr.callQualifier,
                                       expr.callTarget,
                                       expr.callResolved,
                                       expr.callReason,
                                       expr.callTargetSourcePath,
                                       expr.callTargetImportc)

fn v3NormalizedExprEndColumn(columnNumber: int32,
                             surfaceText: str): int32 =
    if len(surfaceText) <= 0:
        return columnNumber
    return columnNumber + len(surfaceText) - 1

fn v3NormalizedExprKindCode(kind: V3NormalizedExprKind): int32 =
    if kind == v3NormalizedExprIf:
        return 1
    if kind == v3NormalizedExprRange:
        return 2
    if kind == v3NormalizedExprComprehension:
        return 3
    if kind == v3NormalizedExprStrFormat:
        return 4
    if kind == v3NormalizedExprResultIntrinsic:
        return 5
    if kind == v3NormalizedExprCall:
        return 6
    if kind == v3NormalizedExprTry:
        return 7
    return 0

fn v3NormalizedExprLookupTextFirstCode(text: str): int32 =
    if text == "":
        return 0
    return int32(text[0])

fn v3NormalizedExprLookupTextLastCode(text: str): int32 =
    if text == "":
        return 0
    return int32(text[text.len - 1])

fn v3NormalizedExprLookupInit(minCap: int32): V3NormalizedExprLookup =
    var lookup: V3NormalizedExprLookup
    lookup.slots = []
    lookup.buckets = []
    var cap: int32 = 32
    while cap < minCap:
        cap = cap * 2
    var i: int32 = 0
    while i < cap:
        add(lookup.slots, 0)
        i = i + 1
    return lookup

fn v3NormalizedExprLookupHash(sourcePathLen: int32,
                              sourcePathFirstCode: int32,
                              sourcePathLastCode: int32,
                              lineNumber: int32,
                              columnNumber: int32,
                              kindCode: int32,
                              detailLen: int32,
                              detailFirstCode: int32,
                              detailLastCode: int32,
                              surfaceLen: int32,
                              surfaceFirstCode: int32,
                              surfaceLastCode: int32): int64 =
    var h: int64 = int64(sourcePathLen)
    h = h * 131 + int64(sourcePathFirstCode)
    h = h * 131 + int64(sourcePathLastCode)
    h = h * 131 + int64(lineNumber)
    h = h * 131 + int64(columnNumber)
    h = h * 131 + int64(kindCode)
    h = h * 131 + int64(detailLen)
    h = h * 131 + int64(detailFirstCode)
    h = h * 131 + int64(detailLastCode)
    h = h * 131 + int64(surfaceLen)
    h = h * 131 + int64(surfaceFirstCode)
    h = h * 131 + int64(surfaceLastCode)
    if h < 0:
        h = -h
    return h

fn v3NormalizedExprLookupSlotForParts(lookup: V3NormalizedExprLookup,
                                      sourcePathLen: int32,
                                      sourcePathFirstCode: int32,
                                      sourcePathLastCode: int32,
                                      lineNumber: int32,
                                      columnNumber: int32,
                                      kindCode: int32,
                                      detailLen: int32,
                                      detailFirstCode: int32,
                                      detailLastCode: int32,
                                      surfaceLen: int32,
                                      surfaceFirstCode: int32,
                                      surfaceLastCode: int32): int32 =
    if lookup.slots.len <= 0:
        return -1
    let mask = lookup.slots.len - 1
    var probe: int32 = int32(v3NormalizedExprLookupHash(sourcePathLen,
                                                        sourcePathFirstCode,
                                                        sourcePathLastCode,
                                                        lineNumber,
                                                        columnNumber,
                                                        kindCode,
                                                        detailLen,
                                                        detailFirstCode,
                                                        detailLastCode,
                                                        surfaceLen,
                                                        surfaceFirstCode,
                                                        surfaceLastCode) & int64(mask))
    var scanned: int32 = 0
    while scanned <= mask:
        let bucketIndexPlus1 = lookup.slots[probe]
        if bucketIndexPlus1 == 0:
            return probe
        let bucket = lookup.buckets[bucketIndexPlus1 - 1]
        if bucket.sourcePathLen == sourcePathLen &&
           bucket.sourcePathFirstCode == sourcePathFirstCode &&
           bucket.sourcePathLastCode == sourcePathLastCode &&
           bucket.lineNumber == lineNumber &&
           bucket.columnNumber == columnNumber &&
           bucket.kindCode == kindCode &&
           bucket.detailLen == detailLen &&
           bucket.detailFirstCode == detailFirstCode &&
           bucket.detailLastCode == detailLastCode &&
           bucket.surfaceLen == surfaceLen &&
           bucket.surfaceFirstCode == surfaceFirstCode &&
           bucket.surfaceLastCode == surfaceLastCode:
            return probe
        probe = (probe + 1) & mask
        scanned = scanned + 1
    return -1

fn v3NormalizedExprLookupRehash(lookup: var V3NormalizedExprLookup,
                                newCap: int32) =
    var slots: int32[] = []
    var i: int32 = 0
    while i < newCap:
        add(slots, 0)
        i = i + 1
    lookup.slots = slots
    var bucketIndex: int32 = 0
    while bucketIndex < lookup.buckets.len:
        let bucket = lookup.buckets[bucketIndex]
        let slot = v3NormalizedExprLookupSlotForParts(lookup,
                                                      bucket.sourcePathLen,
                                                      bucket.sourcePathFirstCode,
                                                      bucket.sourcePathLastCode,
                                                      bucket.lineNumber,
                                                      bucket.columnNumber,
                                                      bucket.kindCode,
                                                      bucket.detailLen,
                                                      bucket.detailFirstCode,
                                                      bucket.detailLastCode,
                                                      bucket.surfaceLen,
                                                      bucket.surfaceFirstCode,
                                                      bucket.surfaceLastCode)
        if slot >= 0:
            lookup.slots[slot] = bucketIndex + 1
        bucketIndex = bucketIndex + 1

fn v3NormalizedExprLookupGrow(lookup: var V3NormalizedExprLookup) =
    var nextCap: int32 = lookup.slots.len * 2
    if nextCap < 32:
        nextCap = 32
    v3NormalizedExprLookupRehash(lookup, nextCap)

fn v3NormalizedExprLookupEnsureBucket(lookup: var V3NormalizedExprLookup,
                                      sourcePath: str,
                                      lineNumber: int32,
                                      columnNumber: int32,
                                      kind: V3NormalizedExprKind,
                                      detail: str,
                                      surfaceText: str): int32 =
    if lookup.slots.len <= 0:
        lookup = v3NormalizedExprLookupInit(32)
    if (lookup.buckets.len + 1) * 10 >= lookup.slots.len * 7:
        v3NormalizedExprLookupGrow(lookup)
    let sourcePathLen = sourcePath.len
    let sourcePathFirstCode = v3NormalizedExprLookupTextFirstCode(sourcePath)
    let sourcePathLastCode = v3NormalizedExprLookupTextLastCode(sourcePath)
    let kindCode = v3NormalizedExprKindCode(kind)
    var lookupDetail = detail
    if kind == v3NormalizedExprCall:
        lookupDetail = ""
    let detailLen = lookupDetail.len
    let detailFirstCode = v3NormalizedExprLookupTextFirstCode(lookupDetail)
    let detailLastCode = v3NormalizedExprLookupTextLastCode(lookupDetail)
    let surfaceLen = surfaceText.len
    let surfaceFirstCode = v3NormalizedExprLookupTextFirstCode(surfaceText)
    let surfaceLastCode = v3NormalizedExprLookupTextLastCode(surfaceText)
    let slot = v3NormalizedExprLookupSlotForParts(lookup,
                                                  sourcePathLen,
                                                  sourcePathFirstCode,
                                                  sourcePathLastCode,
                                                  lineNumber,
                                                  columnNumber,
                                                  kindCode,
                                                  detailLen,
                                                  detailFirstCode,
                                                  detailLastCode,
                                                  surfaceLen,
                                                  surfaceFirstCode,
                                                  surfaceLastCode)
    if slot < 0:
        return -1
    let existing = lookup.slots[slot]
    if existing > 0:
        return existing - 1
    var bucket: V3NormalizedExprLookupBucket
    bucket.sourcePathLen = sourcePathLen
    bucket.sourcePathFirstCode = sourcePathFirstCode
    bucket.sourcePathLastCode = sourcePathLastCode
    bucket.lineNumber = lineNumber
    bucket.columnNumber = columnNumber
    bucket.kindCode = kindCode
    bucket.detailLen = detailLen
    bucket.detailFirstCode = detailFirstCode
    bucket.detailLastCode = detailLastCode
    bucket.surfaceLen = surfaceLen
    bucket.surfaceFirstCode = surfaceFirstCode
    bucket.surfaceLastCode = surfaceLastCode
    bucket.items = []
    add(lookup.buckets, bucket)
    lookup.slots[slot] = lookup.buckets.len
    return lookup.buckets.len - 1

fn v3NormalizedExprLookupBucketIndexExact(lookup: V3NormalizedExprLookup,
                                          sourcePath: str,
                                          lineNumber: int32,
                                          columnNumber: int32,
                                          kind: V3NormalizedExprKind,
                                          detail: str,
                                          surfaceText: str): int32 =
    if sourcePath == "":
        return -1
    var lookupDetail = detail
    if kind == v3NormalizedExprCall:
        lookupDetail = ""
    let slot = v3NormalizedExprLookupSlotForParts(lookup,
                                                  sourcePath.len,
                                                  v3NormalizedExprLookupTextFirstCode(sourcePath),
                                                  v3NormalizedExprLookupTextLastCode(sourcePath),
                                                  lineNumber,
                                                  columnNumber,
                                                  v3NormalizedExprKindCode(kind),
                                                  lookupDetail.len,
                                                  v3NormalizedExprLookupTextFirstCode(lookupDetail),
                                                  v3NormalizedExprLookupTextLastCode(lookupDetail),
                                                  surfaceText.len,
                                                  v3NormalizedExprLookupTextFirstCode(surfaceText),
                                                  v3NormalizedExprLookupTextLastCode(surfaceText))
    if slot < 0:
        return -1
    let bucketIndexPlus1 = lookup.slots[slot]
    if bucketIndexPlus1 > 0:
        return bucketIndexPlus1 - 1
    return -1

fn v3NormalizedExprMatchesKey(expr: V3NormalizedExpr,
                              sourcePath: str,
                              lineNumber: int32,
                              columnNumber: int32,
                              kind: V3NormalizedExprKind,
                              detail: str,
                              surfaceText: str,
                              callSurfaceKind: str,
                              callResolved: bool,
                              callReason: str,
                              callQualifier: str,
                              callCallee: str,
                              callTarget: str,
                              callTargetSourcePath: str,
                              callTargetImportc: bool,
                              callPrefixStyle: bool,
                              callArgCount: int32,
                              callArgsText: str): bool =
    if expr.sourcePath != sourcePath:
        return false
    if expr.lineNumber != lineNumber:
        return false
    if expr.columnNumber != columnNumber:
        return false
    if expr.kind != kind:
        return false
    if expr.surfaceText != surfaceText:
        return false
    if kind == v3NormalizedExprCall:
        if expr.callSurfaceKind != callSurfaceKind:
            return false
        if expr.callResolved != callResolved:
            return false
        if expr.callReason != callReason:
            return false
        if expr.callQualifier != callQualifier:
            return false
        if expr.callCallee != callCallee:
            return false
        if expr.callTarget != callTarget:
            return false
        if expr.callTargetSourcePath != callTargetSourcePath:
            return false
        if expr.callTargetImportc != callTargetImportc:
            return false
    elif expr.detail != detail:
        return false
    if expr.callPrefixStyle != callPrefixStyle:
        return false
    if expr.callArgCount != callArgCount:
        return false
    if expr.callArgsText != callArgsText:
        return false
    return true

fn v3NormalizedExprLayerContainsExact(layer: V3NormalizedExprLayer,
                                      sourcePath: str,
                                      lineNumber: int32,
                                      columnNumber: int32,
                                      kind: V3NormalizedExprKind,
                                      detail: str,
                                      surfaceText: str,
                                      callSurfaceKind: str,
                                      callResolved: bool,
                                      callReason: str,
                                      callQualifier: str,
                                      callCallee: str,
                                      callTarget: str,
                                      callTargetSourcePath: str,
                                      callTargetImportc: bool,
                                      callPrefixStyle: bool,
                                      callArgCount: int32,
                                      callArgsText: str): bool =
    let bucketIndex = v3NormalizedExprLookupBucketIndexExact(layer.exprLookup,
                                                             sourcePath,
                                                             lineNumber,
                                                             columnNumber,
                                                             kind,
                                                             detail,
                                                             surfaceText)
    if bucketIndex < 0 || bucketIndex >= layer.exprLookup.buckets.len:
        return false
    let bucket = layer.exprLookup.buckets[bucketIndex]
    for i in 0..<bucket.items.len:
        let exprIndex = bucket.items[i]
        if exprIndex < 0 || exprIndex >= layer.exprs.len:
            continue
        if v3NormalizedExprMatchesKey(layer.exprs[exprIndex],
                                      sourcePath,
                                      lineNumber,
                                      columnNumber,
                                      kind,
                                      detail,
                                      surfaceText,
                                      callSurfaceKind,
                                      callResolved,
                                      callReason,
                                      callQualifier,
                                      callCallee,
                                      callTarget,
                                      callTargetSourcePath,
                                      callTargetImportc,
                                      callPrefixStyle,
                                      callArgCount,
                                      callArgsText):
            return true
    return false

fn v3NormalizedExprLayerRememberExpr(layer: var V3NormalizedExprLayer,
                                     exprIndex: int32) =
    if exprIndex < 0 || exprIndex >= layer.exprs.len:
        return
    let expr = layer.exprs[exprIndex]
    let bucketIndex = v3NormalizedExprLookupEnsureBucket(layer.exprLookup,
                                                         expr.sourcePath,
                                                         expr.lineNumber,
                                                         expr.columnNumber,
                                                         expr.kind,
                                                         expr.detail,
                                                         expr.surfaceText)
    if bucketIndex < 0:
        return
    var bucket = layer.exprLookup.buckets[bucketIndex]
    for i in 0..<bucket.items.len:
        if bucket.items[i] == exprIndex:
            layer.exprLookup.buckets[bucketIndex] = bucket
            return
    add(bucket.items, exprIndex)
    layer.exprLookup.buckets[bucketIndex] = bucket

fn v3NormalizedExprLayerAppendExisting(layer: var V3NormalizedExprLayer,
                                       expr: V3NormalizedExpr) =
    if v3NormalizedExprLayerContainsExact(layer,
                                          expr.sourcePath,
                                          expr.lineNumber,
                                          expr.columnNumber,
                                          expr.kind,
                                          expr.detail,
                                          expr.surfaceText,
                                          expr.callSurfaceKind,
                                          expr.callResolved,
                                          expr.callReason,
                                          expr.callQualifier,
                                          expr.callCallee,
                                          expr.callTarget,
                                          expr.callTargetSourcePath,
                                          expr.callTargetImportc,
                                          expr.callPrefixStyle,
                                          expr.callArgCount,
                                          expr.callArgsText):
        return
    add(layer.exprs, expr)
    v3NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn v3ParserConcat2(a: str, b: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserConcat3(a: str, b: str, c: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserConcat4(a: str, b: str, c: str, d: str): str =
    var buf = buffer.NewByteBuffer()
    if a != "":
        buffer.AppendBytes(buf, a)
    if b != "":
        buffer.AppendBytes(buf, b)
    if c != "":
        buffer.AppendBytes(buf, c)
    if d != "":
        buffer.AppendBytes(buf, d)
    return rawbytes.bytesToString(buffer.ToBytes(buf))

fn v3ParserOwnedText(text: str): str =
    return newStringCopy(strDataPtr(text), strLenFast(text))

fn v3ParserWriteTextFast(outPtr: ptr,
                         writePos: var int32,
                         text: str) =
    let textLen = strLenFast(text)
    if textLen <= 0:
        return
    rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(outPtr, writePos),
                              rawmemAsVoid(text),
                              textLen)
    writePos = writePos + textLen

fn v3ParserWriteByteFast(out: var str,
                         writePos: var int32,
                         value: int32) =
    out[writePos] = char(value)
    writePos = writePos + 1

fn v3NormalizedExprMakeId(sourcePath: str,
                          lineNumber: int32,
                          columnNumber: int32,
                          kind: V3NormalizedExprKind,
                          detail: str): str =
    let lineText: str = intToStr(lineNumber)
    let columnText: str = intToStr(columnNumber)
    let kindText: str = intToStr(v3NormalizedExprKindCode(kind))
    let totalLen = sourcePath.len + lineText.len + columnText.len + kindText.len + detail.len + 4
    if totalLen <= 0:
        return ""
    let out = newStringAlloc(totalLen)
    let outPtr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    var writePos: int32 = 0
    v3ParserWriteTextFast(outPtr, writePos, sourcePath)
    v3ParserWriteByteFast(out, writePos, 35)
    v3ParserWriteTextFast(outPtr, writePos, lineText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, columnText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, kindText)
    v3ParserWriteByteFast(out, writePos, 58)
    v3ParserWriteTextFast(outPtr, writePos, detail)
    return out

fn v3NormalizedExprMakeCallId(sourcePath: str,
                              lineNumber: int32,
                              columnNumber: int32,
                              callSurfaceKind: str,
                              callResolved: bool,
                              callReason: str,
                              callQualifier: str,
                              callCallee: str,
                              callTarget: str,
                              callTargetSourcePath: str,
                              callTargetImportc: bool): str =
    let callDetail = v3ParserCallExprDetailExact(callSurfaceKind,
                                                 callCallee,
                                                 callQualifier,
                                                 callTarget,
                                                 callResolved,
                                                 callReason,
                                                 v3ParserNormalizePath(callTargetSourcePath),
                                                 callTargetImportc)
    return v3NormalizedExprMakeId(sourcePath,
                                  lineNumber,
                                  columnNumber,
                                  v3NormalizedExprCall,
                                  callDetail)

fn v3NormalizedExprLayerClone(layer: V3NormalizedExprLayer): V3NormalizedExprLayer =
    var out: V3NormalizedExprLayer
    out.sourceCount = 0
    out.exprs = []
    out.questionResidualCount = layer.questionResidualCount
    out.exprLookup = v3NormalizedExprLookupInit(layer.exprs.len * 2 + 8)
    out.sourceCount = layer.sourceCount
    for i in 0..<layer.exprs.len:
        v3NormalizedExprLayerAppendExisting(out, v3NormalizedExprClone(layer.exprs[i]))
    return out

fn v3NormalizedExprLayerZero(): V3NormalizedExprLayer =
    var out: V3NormalizedExprLayer
    out.sourceCount = 0
    out.exprs = []
    out.questionResidualCount = 0
    out.exprLookup = v3NormalizedExprLookupInit(32)
    return out

fn v3NormalizedExprLayerAppend(layer: var V3NormalizedExprLayer,
                               sourcePath: str,
                               lineNumber: int32,
                               columnNumber: int32,
                               kind: V3NormalizedExprKind,
                               detail: str,
                               surfaceText: str) =
    if v3NormalizedExprLayerContainsExact(layer,
                                          sourcePath,
                                          lineNumber,
                                          columnNumber,
                                          kind,
                                          detail,
                                          surfaceText,
                                          "",
                                          false,
                                          "",
                                          "",
                                          "",
                                          "",
                                          "",
                                          false,
                                          false,
                                          0,
                                          ""):
        return
    var expr: V3NormalizedExpr
    expr.exprId = v3NormalizedExprMakeId(sourcePath, lineNumber, columnNumber, kind, detail)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = v3NormalizedExprEndColumn(columnNumber, surfaceText)
    expr.kind = kind
    expr.detail = detail
    expr.surfaceText = surfaceText
    expr.callSurfaceKind = ""
    expr.callResolved = false
    expr.callReason = ""
    expr.callQualifier = ""
    expr.callCallee = ""
    expr.callTarget = ""
    expr.callTargetSourcePath = ""
    expr.callTargetImportc = false
    expr.callPrefixStyle = false
    expr.callArgCount = 0
    expr.callArgsText = ""
    add(layer.exprs, expr)
    v3NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn v3NormalizedExprLayerAppendCall(layer: var V3NormalizedExprLayer,
                                   sourcePath: str,
                                   lineNumber: int32,
                                   columnNumber: int32,
                                   detail: str,
                                   surfaceText: str,
                                   callSurfaceKind: str,
                                   callResolved: bool,
                                   callReason: str,
                                   callQualifier: str,
                                   callCallee: str,
                                   callTarget: str,
                                   callTargetSourcePath: str,
                                   callTargetImportc: bool,
                                   callArgsText: str,
                                   callArgCount: int32,
                                   callPrefixStyle: bool,
                                   endColumnNumberRaw: int32) =
    let normalizedTargetSourcePath = v3ParserNormalizePath(callTargetSourcePath)
    if v3NormalizedExprLayerContainsExact(layer,
                                          sourcePath,
                                          lineNumber,
                                          columnNumber,
                                          v3NormalizedExprCall,
                                          detail,
                                          surfaceText,
                                          callSurfaceKind,
                                          callResolved,
                                          callReason,
                                          callQualifier,
                                          callCallee,
                                          callTarget,
                                          normalizedTargetSourcePath,
                                          callTargetImportc,
                                          callPrefixStyle,
                                          callArgCount,
                                          callArgsText):
        return
    var expr: V3NormalizedExpr
    expr.exprId = v3NormalizedExprMakeCallId(sourcePath,
                                             lineNumber,
                                             columnNumber,
                                             callSurfaceKind,
                                             callResolved,
                                             callReason,
                                             callQualifier,
                                             callCallee,
                                             callTarget,
                                             normalizedTargetSourcePath,
                                             callTargetImportc)
    expr.sourcePath = sourcePath
    expr.lineNumber = lineNumber
    expr.columnNumber = columnNumber
    expr.endLineNumber = lineNumber
    expr.endColumnNumber = v3NormalizedExprEndColumn(columnNumber, surfaceText)
    if endColumnNumberRaw >= expr.endColumnNumber:
        expr.endColumnNumber = endColumnNumberRaw
    expr.kind = v3NormalizedExprCall
    expr.detail = detail
    expr.surfaceText = surfaceText
    expr.callSurfaceKind = callSurfaceKind
    expr.callResolved = callResolved
    expr.callReason = callReason
    expr.callQualifier = callQualifier
    expr.callCallee = callCallee
    expr.callTarget = callTarget
    expr.callTargetSourcePath = normalizedTargetSourcePath
    expr.callTargetImportc = callTargetImportc
    expr.callPrefixStyle = callPrefixStyle
    expr.callArgCount = callArgCount
    expr.callArgsText = callArgsText
    add(layer.exprs, expr)
    v3NormalizedExprLayerRememberExpr(layer, layer.exprs.len - 1)

fn v3NormalizedExprLayerAdd(total: var V3NormalizedExprLayer,
                            delta: V3NormalizedExprLayer) =
    total.sourceCount = total.sourceCount + delta.sourceCount
    total.questionResidualCount = total.questionResidualCount + delta.questionResidualCount
    for i in 0..<delta.exprs.len:
        v3NormalizedExprLayerAppendExisting(total, v3NormalizedExprClone(delta.exprs[i]))

fn v3NormalizedExprLayerExprCount(layer: V3NormalizedExprLayer): int32 =
    return layer.exprs.len

fn v3NormalizedExprLayerCountKind(layer: V3NormalizedExprLayer,
                                  kind: V3NormalizedExprKind): int32 =
    var count: int32 = 0
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].kind == kind:
            count = count + 1
    return count

fn v3NormalizedExprLayerIfCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprIf)

fn v3NormalizedExprLayerRangeCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprRange)

fn v3NormalizedExprLayerComprehensionCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprComprehension)

fn v3NormalizedExprLayerStrFormatCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprStrFormat)

fn v3NormalizedExprLayerResultIntrinsicCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprResultIntrinsic)

fn v3NormalizedExprLayerTryCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprTry)

fn v3NormalizedExprLayerCallCount(layer: V3NormalizedExprLayer): int32 =
    return v3NormalizedExprLayerCountKind(layer, v3NormalizedExprCall)

fn v3NormalizedExprCallKind(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return ""
    return expr.callSurfaceKind

fn v3NormalizedExprCallResolved(expr: V3NormalizedExpr): bool =
    if expr.kind != v3NormalizedExprCall:
        return false
    return expr.callResolved

fn v3NormalizedExprCallReason(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return ""
    return expr.callReason

fn v3NormalizedExprCallQualifier(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return ""
    return expr.callQualifier

fn v3NormalizedExprCallCallee(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return ""
    return expr.callCallee

fn v3NormalizedExprCallTarget(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return ""
    return expr.callTarget

fn v3NormalizedExprCallTargetSourcePath(expr: V3NormalizedExpr): str =
    if expr.kind != v3NormalizedExprCall:
        return ""
    return expr.callTargetSourcePath

fn v3NormalizedExprCallTargetImportc(expr: V3NormalizedExpr): bool =
    if expr.kind != v3NormalizedExprCall:
        return false
    return expr.callTargetImportc

fn v3NormalizedExprLayerCallResolvedCount(layer: V3NormalizedExprLayer): int32 =
    var count: int32 = 0
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if expr.callResolved:
            count = count + 1
    return count

fn v3NormalizedExprLayerCallUnresolvedCount(layer: V3NormalizedExprLayer): int32 =
    var count: int32 = 0
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if !expr.callResolved:
            count = count + 1
    return count

fn v3NormalizedExprLayerCallKindCount(layer: V3NormalizedExprLayer,
                                      detailKind: str): int32 =
    var count: int32 = 0
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if expr.callSurfaceKind == detailKind:
            count = count + 1
    return count

fn v3NormalizedExprLayerCallReasonCount(layer: V3NormalizedExprLayer,
                                        reason: str): int32 =
    var count: int32 = 0
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if expr.callReason == reason:
            count = count + 1
    return count

fn v3NormalizedExprLayerCallTargetImportcCount(layer: V3NormalizedExprLayer): int32 =
    var count: int32 = 0
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != v3NormalizedExprCall:
            continue
        if expr.callTargetImportc:
            count = count + 1
    return count

fn v3NormalizedExprLayerHasExpr(layer: V3NormalizedExprLayer,
                                kind: V3NormalizedExprKind,
                                detail: str,
                                lineNumber: int32): bool =
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != kind:
            continue
        if kind == v3NormalizedExprCall:
            if expr.callSurfaceKind != detail:
                continue
        elif expr.detail != detail:
            continue
        if expr.lineNumber != lineNumber:
            continue
        return true
    return false

fn v3ParserNormalizePath(pathRaw: str): str =
    var path = v3path.V3PathTrim(pathRaw)
    while path.len > 1:
        let last = path[path.len - 1]
        if last != '/' && last != '\\':
            break
        path = v3path.V3TextSlice(path, 0, path.len - 1)
    return path

fn v3ParserBaseName(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    return v3path.V3PathBaseName(path)

fn v3ParserFileStem(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    var start: int32 = 0
    if lastSep >= 0:
        start = lastSep + 1
    var lastDot: int32 = -1
    for i in start..<path.len:
        if path[i] == '.':
            lastDot = i
    if lastDot <= start:
        return v3path.V3TextSlice(path, start, path.len - start)
    return v3path.V3TextSlice(path, start, lastDot - start)

fn v3ParserLastPathPiece(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep < 0:
        return path
    if lastSep + 1 >= path.len:
        return ""
    return v3path.V3TextSlice(path, lastSep + 1, path.len - lastSep - 1)

fn v3ParserDirPart(pathRaw: str): str =
    let path = v3ParserNormalizePath(pathRaw)
    if path == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<path.len:
        if path[i] == '/' || path[i] == '\\':
            lastSep = i
    if lastSep <= 0:
        return ""
    return v3path.V3TextSlice(path, 0, lastSep)

fn v3ParserPackageManifestExists(dirRaw: str): bool =
    let dir = v3ParserNormalizePath(dirRaw)
    if dir == "":
        return false
    let manifestPath = v3path.V3PathJoin(dir, "cheng-package.toml")
    return v3path.V3PathFileExists(manifestPath)

fn v3ParserSharedV3Root(packageRootRaw: str): str =
    var cursor = v3ParserNormalizePath(packageRootRaw)
    while cursor != "":
        let cursorBase = v3path.V3PathBaseName(cursor)
        let cursorIsV3 = cursorBase == "v3"
        if cursorIsV3 && v3ParserPackageManifestExists(cursor):
            return cursor
        let parent = v3path.V3PathParentDir(cursor)
        if parent == "" || parent == cursor:
            break
        cursor = parent
    return ""

fn v3ParserWorkspaceRoot(packageRootRaw: str): str =
    let packageRoot = v3ParserNormalizePath(packageRootRaw)
    let sharedV3Root = v3ParserSharedV3Root(packageRoot)
    if sharedV3Root != "":
        let parent = v3path.V3PathParentDir(sharedV3Root)
        if parent != "":
            return parent
        return sharedV3Root
    return packageRoot

fn v3ParserPackageId(packageRootRaw: str): str =
    let packageRoot: str = v3ParserNormalizePath(packageRootRaw)
    if packageRoot == "":
        return ""
    var lastSep: int32 = -1
    for i in 0..<packageRoot.len:
        if packageRoot[i] == '/' || packageRoot[i] == '\\':
            lastSep = i
    var name: str = packageRoot
    if lastSep >= 0:
        name = v3path.V3TextSlice(packageRoot, lastSep + 1, packageRoot.len - lastSep - 1)
    if name == "v3":
        return "cheng/v3"
    if name == "":
        return ""
    return v3ParserConcat2("cheng/", name)

fn v3ParserSourceExists(path: str): bool =
    if path == "":
        return false
    return v3path.V3PathFileSize(path) > int64(0)

fn v3ParserExprIsResultIntrinsicName(name: str): bool =
    if name == "Ok" || name == "Err":
        return true
    if name == "Value" || name == "Error":
        return true
    if name == "IsOk" || name == "IsErr":
        return true
    if name == "ErrorInfoOf":
        return true
    return false

fn v3ParserResultIntrinsicDetail(name: str): str =
    if name == "Ok":
        return "ok"
    if name == "Err":
        return "err"
    if name == "Value":
        return "value"
    if name == "Error":
        return "error"
    if name == "IsOk":
        return "is_ok"
    if name == "IsErr":
        return "is_err"
    if name == "ErrorInfoOf":
        return "error_info_of"
    return name

fn v3ParserIsIdentChar(ch: char): bool =
    let digit = ch >= '0' && ch <= '9'
    let upper = ch >= 'A' && ch <= 'Z'
    let lower = ch >= 'a' && ch <= 'z'
    return digit || upper || lower || ch == '_'

fn v3ParserPreviousToken(lineRaw: str,
                         stopExclusive: int32): str =
    if stopExclusive <= 0:
        return ""
    var cursor = stopExclusive
    while cursor > 0:
        let prevPos = cursor - 1
        if !v3ParserIsInlineSpace(lineRaw[prevPos]):
            break
        cursor = prevPos
    if cursor <= 0:
        return ""
    let end = cursor - 1
    if end < 0:
        return ""
    var start = end + 1
    while start > 0:
        let prevPos = start - 1
        if !v3ParserIsIdentChar(lineRaw[prevPos]):
            break
        start = prevPos
    if start > end:
        return ""
    return v3ParserTextSliceFast(lineRaw, start, end - start + 1)

fn v3ParserPreviousTokenIsDeclKeyword(lineRaw: str,
                                      stopExclusive: int32): bool =
    if stopExclusive <= 0:
        return false
    var cursor = stopExclusive
    while cursor > 0:
        let prevPos = cursor - 1
        if !v3ParserIsInlineSpace(lineRaw[prevPos]):
            break
        cursor = prevPos
    if cursor <= 0:
        return false
    let end = cursor - 1
    if end < 0:
        return false
    var start = end + 1
    while start > 0:
        let prevPos = start - 1
        if !v3ParserIsIdentChar(lineRaw[prevPos]):
            break
        start = prevPos
    if start > end:
        return false
    let tokenLen = end - start + 1
    if tokenLen == 2 && v3ParserTextEqualsAt(lineRaw, start, "fn"):
        return true
    if tokenLen == 4 &&
       (v3ParserTextEqualsAt(lineRaw, start, "func") ||
        v3ParserTextEqualsAt(lineRaw, start, "proc")):
        return true
    if tokenLen == 6 && v3ParserTextEqualsAt(lineRaw, start, "method"):
        return true
    if tokenLen == 7 && v3ParserTextEqualsAt(lineRaw, start, "importc"):
        return true
    if tokenLen == 9 && v3ParserTextEqualsAt(lineRaw, start, "converter"):
        return true
    return false

fn v3ParserDottedQualifierDepth(lineRaw: str,
                                identStart: int32): int32 =
    if identStart <= 1:
        return 0
    let qualifierStop = identStart - 1
    if lineRaw[qualifierStop] != '.':
        return 0
    var depth: int32 = 0
    var segmentStart: int32 = identStart
    var scanning = true
    while scanning && segmentStart > 1:
        let dotPos = segmentStart - 1
        if lineRaw[dotPos] != '.':
            break
        var identPos = dotPos
        while identPos > 0:
            let prevPos = identPos - 1
            if !v3ParserIsIdentChar(lineRaw[prevPos]):
                break
            identPos = prevPos
        if identPos >= dotPos:
            break
        depth = depth + 1
        segmentStart = identPos
        if segmentStart <= 1:
            break
        if lineRaw[segmentStart - 1] != '.':
            scanning = false
    return depth

fn v3ParserNextNonSpaceChar(lineRaw: str,
                            start: int32): char =
    var cursor = start
    while cursor < lineRaw.len:
        if !v3ParserIsInlineSpace(lineRaw[cursor]):
            return lineRaw[cursor]
        cursor = cursor + 1
    return char(0)

fn v3ParserSkipInlineSpaces(lineRaw: str,
                            start: int32): int32 =
    var cursor = start
    var scanning = true
    while cursor < lineRaw.len && scanning:
        if v3ParserIsInlineSpace(lineRaw[cursor]):
            cursor = cursor + 1
        else:
            scanning = false
    return cursor

fn v3ParserIsTrimChar(ch: char): bool =
    if v3ParserIsInlineSpace(ch):
        return true
    let code = int32(ch)
    return code == 10 || code == 13

fn v3ParserTrimmedSliceRange(text: str,
                             startRaw: int32,
                             stopRaw: int32): str =
    var start = startRaw
    if start < 0:
        start = 0
    var stop = stopRaw
    if stop > text.len:
        stop = text.len
    if stop <= start:
        return ""
    while start < stop:
        if !v3ParserIsTrimChar(text[start]):
            break
        start = start + 1
    while stop > start:
        if !v3ParserIsTrimChar(text[stop - 1]):
            break
        stop = stop - 1
    if stop <= start:
        return ""
    return v3ParserTextSliceFast(text, start, stop - start)

fn v3ParserTrimmedLineWithoutComment(lineRaw: str): str =
    let hashPos = v3ParserFindText(lineRaw, "#")
    if hashPos < 0:
        return v3ParserTrimmedSliceRange(lineRaw, 0, lineRaw.len)
    return v3ParserTrimmedSliceRange(lineRaw, 0, hashPos)

fn v3ParserTrimmedLineRange(lineRaw: str,
                            startOut: var int32,
                            stopOut: var int32): bool =
    var start: int32 = 0
    var stop = lineRaw.len
    while start < stop:
        if !v3ParserIsTrimChar(lineRaw[start]):
            break
        start = start + 1
    while stop > start:
        if !v3ParserIsTrimChar(lineRaw[stop - 1]):
            break
        stop = stop - 1
    startOut = start
    stopOut = stop
    return stop > start

fn v3ParserTrimmedCommentRange(lineRaw: str,
                               startOut: var int32,
                               stopOut: var int32): bool =
    var stop = lineRaw.len
    let hashPos = v3ParserFindText(lineRaw, "#")
    if hashPos >= 0:
        stop = hashPos
    var start: int32 = 0
    while start < stop:
        if !v3ParserIsTrimChar(lineRaw[start]):
            break
        start = start + 1
    while stop > start:
        if !v3ParserIsTrimChar(lineRaw[stop - 1]):
            break
        stop = stop - 1
    startOut = start
    stopOut = stop
    return stop > start

fn v3ParserImportLineTailRange(lineRaw: str,
                               startOut: var int32,
                               stopOut: var int32): bool =
    startOut = -1
    stopOut = -1
    var lineStart: int32 = 0
    var lineStop: int32 = 0
    if !v3ParserTrimmedCommentRange(lineRaw, lineStart, lineStop):
        return false
    let importPrefix = "import "
    if lineStart + importPrefix.len > lineStop:
        return false
    if !v3ParserTextRangeEquals(lineRaw, lineStart, importPrefix.len, importPrefix):
        return false
    startOut = lineStart + importPrefix.len
    stopOut = lineStop
    return true

fn v3ParserHasNonTrimChar(lineRaw: str): bool =
    for i in 0..<lineRaw.len:
        if !v3ParserIsTrimChar(lineRaw[i]):
            return true
    return false

fn v3ParserStripLineComment(lineRaw: str): str =
    let hashPos = v3ParserFindText(lineRaw, "#")
    if hashPos < 0:
        return lineRaw
    return v3ParserTextSliceFast(lineRaw, 0, hashPos)

fn v3ParserLineKeywordPositions(lineRaw: str,
                                keyword: str): int32[] =
    var out: int32[] = []
    if keyword == "":
        return out
    if lineRaw.len < keyword.len:
        return out
    for i in 0..<(lineRaw.len - keyword.len + 1):
        var matched = true
        for j in 0..<keyword.len:
            if lineRaw[i + j] != keyword[j]:
                matched = false
                break
        if !matched:
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + keyword.len
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        add(out, i)
    return out

fn v3ParserAppendIfExprsLine(sourcePath: str,
                             lineNumber: int32,
                             lineRaw: str,
                             layer: var V3NormalizedExprLayer) =
    let positions = v3ParserLineKeywordPositions(lineRaw, "if")
    for i in 0..<positions.len:
        v3NormalizedExprLayerAppend(layer,
                                    sourcePath,
                                    lineNumber,
                                    positions[i] + 1,
                                    v3NormalizedExprIf,
                                    "keyword_if",
                                    "if")

fn v3ParserAppendFmtExprsLine(sourcePath: str,
                              lineNumber: int32,
                              lineRaw: str,
                              layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 3:
        return
    for i in 0..<(lineRaw.len - 2):
        if lineRaw[i] != 'F' || lineRaw[i + 1] != 'm' || lineRaw[i + 2] != 't':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 3
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        let prevToken = v3ParserPreviousToken(lineRaw, i)
        if prevToken == "fn" || prevToken == "func" || prevToken == "proc" ||
           prevToken == "method" || prevToken == "converter":
            continue
        let nextChar = v3ParserNextNonSpaceChar(lineRaw, rightPos)
        if nextChar == '"' || nextChar == '(' || nextChar == '[' || v3ParserIsIdentChar(nextChar):
            var detail = "fmt_call"
            if nextChar == '"':
                detail = "fmt_literal"
            v3NormalizedExprLayerAppend(layer,
                                        sourcePath,
                                        lineNumber,
                                        i + 1,
                                        v3NormalizedExprStrFormat,
                                        detail,
                                        "Fmt")
    return

fn v3ParserAppendResultIntrinsicExprsLine(sourcePath: str,
                                          lineNumber: int32,
                                          lineRaw: str,
                                          layer: var V3NormalizedExprLayer) =
    v3ParserAppendResultIntrinsicOkExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicErrExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicValueExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicErrorExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicIsOkExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicIsErrExprsLine(sourcePath, lineNumber, lineRaw, layer)
    v3ParserAppendResultIntrinsicErrorInfoOfExprsLine(sourcePath, lineNumber, lineRaw, layer)

fn v3ParserAppendResultIntrinsicOkExprsLine(sourcePath: str,
                                            lineNumber: int32,
                                            lineRaw: str,
                                            layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 2:
        return
    for i in 0..<(lineRaw.len - 1):
        if lineRaw[i] != 'O':
            continue
        if lineRaw[i + 1] != 'k':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 2
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "ok", "Ok")
    return

fn v3ParserAppendResultIntrinsicErrExprsLine(sourcePath: str,
                                             lineNumber: int32,
                                             lineRaw: str,
                                             layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 3:
        return
    for i in 0..<(lineRaw.len - 2):
        if lineRaw[i] != 'E':
            continue
        if lineRaw[i + 1] != 'r':
            continue
        if lineRaw[i + 2] != 'r':
            continue
        var leftOk = true
        if i > 0:
            leftOk = !v3ParserIsIdentChar(lineRaw[i - 1])
        let rightPos = i + 3
        var rightOk = true
        if rightPos < lineRaw.len:
            rightOk = !v3ParserIsIdentChar(lineRaw[rightPos])
        if !leftOk || !rightOk:
            continue
        v3NormalizedExprLayerAppend(layer, sourcePath, lineNumber, i + 1, v3NormalizedExprResultIntrinsic, "err", "Err")
    return

fn v3ParserAppendResultIntrinsicValueExprsLine(sourcePath: str,
                                               lineNumber: int32,
                                               lineRaw: str,
                                               layer: var V3NormalizedExprLayer) =
    if lineRaw.len < 5:
        return
    for i in 0..<(lineRaw.len - 4):
        if lineRaw[i] != 'V':
            continue
        if lineRaw[i + 1] != 'a':
            continue
        if lineRaw[i + 2] != 'l':
            continue
        if lineRaw[i + 3] != 'u':
            continue
        if lineRaw[i + 4] != 'e':
