import std/buffer
import std/rawbytes
import cheng/v3/tooling/bootstrap_contracts as contracts

type
    V3BackendTarget = enum
        v3BackendArm64AppleDarwin
        v3BackendX8664AppleDarwin
        v3BackendAarch64UnknownLinuxGnu
        v3BackendX8664UnknownLinuxGnu
        v3BackendAarch64PcWindowsMsvc
        v3BackendX8664PcWindowsMsvc
        v3BackendWasm32UnknownUnknown

    V3BackendLinker = enum
        v3BackendLinkerBootstrapMaterialize
        v3BackendLinkerSystemLink

    V3BackendSourceRole = enum
        v3BackendBootstrapContractSource
        v3BackendCompilerEntrySource
        v3BackendBackendDriverEntrySource
        v3BackendCompilerRuntimeSource
        v3BackendCompilerRequestSource
        v3BackendLangParserSource
        v3BackendSystemLinkPlanSource
        v3BackendLoweringPlanSource
        v3BackendPrimaryObjectPlanSource
        v3BackendObjectPlanSource
        v3BackendNativeLinkPlanSource
        v3BackendSystemLinkExecSource
        v3BackendRuntimeCoreSource
        v3BackendRuntimeCompilerSource
        v3BackendRuntimeDebugSource
        v3BackendToolingSource

    V3BackendSourceUnit =
        role: V3BackendSourceRole
        path: str

    V3BackendBuildPlan =
        target: V3BackendTarget
        targetTriple: str
        linker: V3BackendLinker
        entryPath: str
        outputPath: str
        stage2CompilerPath: str
        sourceUnits: V3BackendSourceUnit[]

fn v3BackendRootPath(rootDir: str, rel: str): str =
    if rootDir == "":
        return rel
    if rel == "":
        return rootDir
    if rootDir[rootDir.len - 1] == '/':
        var withSep = buffer.NewByteBuffer()
        buffer.AppendBytes(withSep, rootDir)
        buffer.AppendBytes(withSep, rel)
        return rawbytes.bytesToString(buffer.ToBytes(withSep))
    var out = buffer.NewByteBuffer()
    let slash: str = "/"
    buffer.AppendBytes(out, rootDir)
    buffer.AppendBytes(out, slash)
    buffer.AppendBytes(out, rel)
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn v3BackendBuildPlanJoinLines(rows: str[]): str =
    var out: str = ""
    for i in 0..<rows.len:
        out = out + rows[i] + "\n"
    return out

fn v3BackendBuildPlanDefaultEntryPath(rootDir: str): str =
    return v3BackendRootPath(rootDir, "v3/src/tooling/compiler_main.cheng")

fn v3BackendBuildPlanBackendDriverEntryPath(rootDir: str): str =
    return v3BackendRootPath(rootDir, "v3/src/tooling/backend_driver_main.cheng")

fn v3BackendBuildPlanDefaultSourceUnitCount(): int32 =
    return 20

fn v3BackendBuildPlanDefaultLinkMode(): str =
    return v3BackendLinkerText(v3BackendLinkerSystemLink)

fn v3BackendTargetFromTriple(targetTriple: str): V3BackendTarget =
    if targetTriple == "wasm32-unknown-unknown":
        return v3BackendWasm32UnknownUnknown
    if targetTriple == "x86_64-apple-darwin":
        return v3BackendX8664AppleDarwin
    if targetTriple == "aarch64-unknown-linux-gnu":
        return v3BackendAarch64UnknownLinuxGnu
    if targetTriple == "x86_64-unknown-linux-gnu":
        return v3BackendX8664UnknownLinuxGnu
    if targetTriple == "aarch64-pc-windows-msvc":
        return v3BackendAarch64PcWindowsMsvc
    if targetTriple == "x86_64-pc-windows-msvc":
        return v3BackendX8664PcWindowsMsvc
    return v3BackendArm64AppleDarwin

fn v3BackendBuildPlanDefaultForTarget(rootDir: str, targetTriple: str): V3BackendBuildPlan =
    var units: V3BackendSourceUnit[]
    units = []
    add(units, V3BackendSourceUnit(role: v3BackendBootstrapContractSource, path: v3BackendRootPath(rootDir, "v3/bootstrap/stage1_bootstrap.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendCompilerEntrySource, path: v3BackendRootPath(rootDir, "v3/src/tooling/compiler_main.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendCompilerRuntimeSource, path: v3BackendRootPath(rootDir, "v3/src/tooling/compiler_runtime.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendCompilerRequestSource, path: v3BackendRootPath(rootDir, "v3/src/tooling/compiler_request.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "v3/src/tooling/compiler_world.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "v3/src/tooling/compiler_csg.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "v3/src/tooling/compiler_world_libp2p.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "v3/src/tooling/compiler_equivalence.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendLangParserSource, path: v3BackendRootPath(rootDir, "v3/src/lang/parser.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendSystemLinkPlanSource, path: v3BackendRootPath(rootDir, "v3/src/backend/system_link_plan.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendLoweringPlanSource, path: v3BackendRootPath(rootDir, "v3/src/backend/lowering_plan.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendPrimaryObjectPlanSource, path: v3BackendRootPath(rootDir, "v3/src/backend/primary_object_plan.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendObjectPlanSource, path: v3BackendRootPath(rootDir, "v3/src/backend/object_plan.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendNativeLinkPlanSource, path: v3BackendRootPath(rootDir, "v3/src/backend/native_link_plan.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendSystemLinkExecSource, path: v3BackendRootPath(rootDir, "v3/src/backend/system_link_exec.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendRuntimeCoreSource, path: v3BackendRootPath(rootDir, "v3/src/runtime/core_runtime_v3.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendRuntimeCompilerSource, path: v3BackendRootPath(rootDir, "v3/src/runtime/compiler_runtime_v3.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendRuntimeDebugSource, path: v3BackendRootPath(rootDir, "v3/src/runtime/debug_runtime_v3.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "v3/src/tooling/bootstrap_contracts.cheng")))
    add(units, V3BackendSourceUnit(role: v3BackendToolingSource, path: v3BackendRootPath(rootDir, "v3/src/backend/build_plan.cheng")))
    return V3BackendBuildPlan(
        target: v3BackendTargetFromTriple(targetTriple),
        targetTriple: targetTriple,
        linker: v3BackendLinkerSystemLink,
        entryPath: v3BackendBuildPlanDefaultEntryPath(rootDir),
        outputPath: v3BackendRootPath(rootDir, "artifacts/v3_backend_driver/cheng"),
        stage2CompilerPath: v3BackendRootPath(rootDir, "artifacts/v3_bootstrap/cheng.stage2"),
        sourceUnits: units
    )

fn v3BackendBuildPlanDefault(rootDir: str): V3BackendBuildPlan =
    return v3BackendBuildPlanDefaultForTarget(rootDir, contracts.v3BootstrapDefaultTarget())

