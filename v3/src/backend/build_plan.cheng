import cheng/v3/tooling/bootstrap_contracts as contracts
import cheng/v3/tooling/path as v3path
import std/strutils as strutil

type
    V3BackendTarget = enum
        v3BackendArm64AppleDarwin

    V3BackendLinker = enum
        v3BackendLinkerBootstrapMaterialize
        v3BackendLinkerSystemLink

    V3BackendSourceRole = enum
        v3BackendBootstrapContractSource
        v3BackendSeedSource
        v3BackendCompilerEntrySource
        v3BackendCompilerRuntimeSource
        v3BackendCompilerRequestSource
        v3BackendLangParserSource
        v3BackendSystemLinkPlanSource
        v3BackendLoweringPlanSource
        v3BackendPrimaryObjectPlanSource
        v3BackendObjectPlanSource
        v3BackendNativeLinkPlanSource
        v3BackendSystemLinkExecSource
        v3BackendRuntimeCoreSource
        v3BackendRuntimeCompilerSource
        v3BackendToolingSource

    V3BackendSourceUnit =
        role: V3BackendSourceRole
        path: str

    V3BackendBuildPlan =
        target: V3BackendTarget
        targetTriple: str
        linker: V3BackendLinker
        entryPath: str
        outputPath: str
        stage2CompilerPath: str
        sourceUnits: V3BackendSourceUnit[]

fn v3BackendBuildPlanDefault(rootDir: str): V3BackendBuildPlan =
    let units: V3BackendSourceUnit[] = [
        V3BackendSourceUnit(role: v3BackendBootstrapContractSource, path: contracts.v3BootstrapStage1SourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendSeedSource, path: contracts.v3BootstrapSeedSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendCompilerEntrySource, path: contracts.v3BootstrapCompilerEntrySourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendCompilerRuntimeSource, path: contracts.v3BootstrapCompilerRuntimeSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendCompilerRequestSource, path: contracts.v3BootstrapCompilerRequestSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendLangParserSource, path: contracts.v3LangParserSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendSystemLinkPlanSource, path: contracts.v3BackendSystemLinkPlanSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendLoweringPlanSource, path: contracts.v3BackendLoweringPlanSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendPrimaryObjectPlanSource, path: contracts.v3BackendPrimaryObjectPlanSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendObjectPlanSource, path: contracts.v3BackendObjectPlanSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendNativeLinkPlanSource, path: contracts.v3BackendNativeLinkPlanSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendSystemLinkExecSource, path: contracts.v3BackendSystemLinkExecSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendRuntimeCoreSource, path: contracts.v3RuntimeCoreRuntimeSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendRuntimeCompilerSource, path: contracts.v3RuntimeCompilerRuntimeSourcePath(rootDir)),
        V3BackendSourceUnit(role: v3BackendToolingSource, path: v3path.v3PathAbsolute(rootDir, "v3/src/tooling/bootstrap_contracts.cheng")),
        V3BackendSourceUnit(role: v3BackendToolingSource, path: v3path.v3PathAbsolute(rootDir, "v3/src/backend/build_plan.cheng")),
        V3BackendSourceUnit(role: v3BackendToolingSource, path: v3path.v3PathAbsolute(rootDir, "v3/tooling/build_backend_driver_v3.sh"))
    ]
    return V3BackendBuildPlan(
        target: v3BackendArm64AppleDarwin,
        targetTriple: contracts.v3BootstrapDefaultTarget(),
        linker: v3BackendLinkerSystemLink,
        entryPath: contracts.v3BootstrapCompilerEntrySourcePath(rootDir),
        outputPath: contracts.v3BootstrapBackendDriverOutPath(rootDir),
        stage2CompilerPath: contracts.v3BootstrapStage2Path(rootDir),
        sourceUnits: units
    )

fn v3BackendSourceRoleText(role: V3BackendSourceRole): str =
    if role == v3BackendBootstrapContractSource:
        return "bootstrap_contract_source"
    if role == v3BackendSeedSource:
        return "seed_source"
    if role == v3BackendCompilerEntrySource:
        return "compiler_entry_source"
    if role == v3BackendCompilerRuntimeSource:
        return "compiler_runtime_source"
    if role == v3BackendCompilerRequestSource:
        return "compiler_request_source"
    if role == v3BackendLangParserSource:
        return "lang_parser_source"
    if role == v3BackendSystemLinkPlanSource:
        return "backend_system_link_plan_source"
    if role == v3BackendLoweringPlanSource:
        return "backend_lowering_plan_source"
    if role == v3BackendPrimaryObjectPlanSource:
        return "backend_primary_object_plan_source"
    if role == v3BackendObjectPlanSource:
        return "backend_object_plan_source"
    if role == v3BackendNativeLinkPlanSource:
        return "backend_native_link_plan_source"
    if role == v3BackendSystemLinkExecSource:
        return "backend_system_link_exec_source"
    if role == v3BackendRuntimeCoreSource:
        return "runtime_core_runtime_source"
    if role == v3BackendRuntimeCompilerSource:
        return "runtime_compiler_runtime_source"
    return "tooling_source"

fn v3BackendLinkerText(linker: V3BackendLinker): str =
    if linker == v3BackendLinkerBootstrapMaterialize:
        return "bootstrap_materialize"
    return "system_link"

fn v3BackendBuildPlanReport(plan: V3BackendBuildPlan): str =
    var rows: str[] = []
    add(rows, "target=" + plan.targetTriple)
    add(rows, "linker=" + v3BackendLinkerText(plan.linker))
    add(rows, "stage2_compiler=" + plan.stage2CompilerPath)
    add(rows, "entry=" + plan.entryPath)
    add(rows, "output=" + plan.outputPath)
    for i in 0..<plan.sourceUnits.len:
        let unit: V3BackendSourceUnit = plan.sourceUnits[i]
        add(rows, "source[" + intToStr(i) + "]=" + v3BackendSourceRoleText(unit.role) + ":" + unit.path)
    return strutil.join(rows, "\n") + "\n"
