import std/result
import std/strings
import std/os
import cheng/v3/std/bytes_layout as layout
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_world as cworld
import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/backend/system_link_plan as slplan
import cheng/v3/backend/lowering_plan as lower
import cheng/v3/backend/primary_object_plan as pobj
import cheng/v3/backend/object_plan as objplan
import cheng/v3/backend/native_link_plan as nplan
import cheng/v3/runtime/core_runtime_v3 as corun
import cheng/v3/runtime/compiler_runtime_v3 as comprun
import cheng/v3/runtime/debug_runtime_v3 as debrun
import cheng/v3/runtime/program_support_v3 as prun

type
    V3SystemLinkExecPlan =
        compilerEntrySource: str
        sourceBundleCid: layout.FixedBytes32
        systemLinkPlan: slplan.V3SystemLinkPlanStub
        compilerCsg: ccsg.V3CompilerCsg
        exportSurface: ccsg.V3CsgExportSurface
        localUniverse: cworld.V3CompilerLocalUniverse
        compileReceipt: ccsg.V3CompileReceipt
        worldHeadPinned: bool
        lockCheckEnabled: bool
        lockVerified: bool
        baselineSurfaceChecked: bool
        baselineSurfaceCompatible: bool
        lockPath: str
        baselineSurfacePath: str
        loweringPlan: lower.V3LoweringPlanStub
        primaryObjectPlan: pobj.V3PrimaryObjectPlan
        objectPlan: objplan.V3ObjectPlanStub
        nativeLinkPlan: nplan.V3NativeLinkPlanStub

fn v3SystemLinkExecBrowserBridgeArtifactBasePath(outputPath: str): str =
    if len(outputPath) <= 0:
        return ""
    return outputPath + ".browser_bridge_plan.txt"

fn v3SystemLinkExecBrowserBridgeSourceBasePath(outputPath: str): str =
    if len(outputPath) <= 0:
        return ""
    return outputPath + ".browser_bridge.generated.cheng"

fn v3SystemLinkExecBrowserBridgeObjectBasePath(outputPath: str): str =
    if len(outputPath) <= 0:
        return ""
    return outputPath + ".browser_bridge.generated.o"

fn v3SystemLinkExecBrowserBridgePlans(plan: V3SystemLinkExecPlan): ccsg.V3BrowserAbiBridgePlan[] =
    return ccsg.v3CompilerBrowserAbiBridgePlansForLinkPlan(plan.systemLinkPlan)

fn v3SystemLinkExecBrowserBridgeObjectPathForLinkPlan(linkPlan: slplan.V3SystemLinkPlanStub): str =
    let explicitPath = slplan.v3SystemLinkPlanBrowserBridgeObjectPath(linkPlan)
    if len(explicitPath) > 0:
        return explicitPath
    let bridgePlans = ccsg.v3CompilerBrowserAbiBridgePlansForLinkPlan(linkPlan)
    if bridgePlans.len <= 0:
        return ""
    return v3SystemLinkExecBrowserBridgeObjectBasePath(linkPlan.outputPath)

fn v3SystemLinkExecBrowserBridgeArtifactPath(plan: V3SystemLinkExecPlan): str =
    let plans = v3SystemLinkExecBrowserBridgePlans(plan)
    if plans.len <= 0:
        return ""
    return v3SystemLinkExecBrowserBridgeArtifactBasePath(plan.systemLinkPlan.outputPath)

fn v3SystemLinkExecBrowserBridgeArtifactText(plan: V3SystemLinkExecPlan): str =
    let plans = v3SystemLinkExecBrowserBridgePlans(plan)
    return ccsg.v3BrowserAbiBridgePlanManifestText(plans)

fn v3SystemLinkExecBrowserBridgeSourcePath(plan: V3SystemLinkExecPlan): str =
    let plans = v3SystemLinkExecBrowserBridgePlans(plan)
    if plans.len <= 0:
        return ""
    return v3SystemLinkExecBrowserBridgeSourceBasePath(plan.systemLinkPlan.outputPath)

fn v3SystemLinkExecBrowserBridgeObjectPath(plan: V3SystemLinkExecPlan): str =
    let plans = v3SystemLinkExecBrowserBridgePlans(plan)
    if plans.len <= 0:
        return ""
    return v3SystemLinkExecBrowserBridgeObjectBasePath(plan.systemLinkPlan.outputPath)

fn v3SystemLinkExecBrowserBridgeSourceText(plan: V3SystemLinkExecPlan): str =
    let plans = v3SystemLinkExecBrowserBridgePlans(plan)
    return ccsg.v3BrowserAbiBridgeSourceText(plans)

fn v3SystemLinkExecWriteBrowserBridgeArtifact(rootDir: str,
                                              plan: V3SystemLinkExecPlan): bool =
    let artifactBasePath = v3SystemLinkExecBrowserBridgeArtifactBasePath(plan.systemLinkPlan.outputPath)
    if len(artifactBasePath) <= 0:
        return true
    let artifactPath = v3SystemLinkExecBrowserBridgeArtifactPath(plan)
    if len(artifactPath) <= 0:
        if os.FileExists(artifactBasePath):
            let _ = os.RemoveFile(artifactBasePath)
        return true
    let artifactText = v3SystemLinkExecBrowserBridgeArtifactText(plan) + "\n"
    return v3path.V3WriteTextFile(rootDir, artifactPath, artifactText)

fn v3SystemLinkExecWriteBrowserBridgeSource(rootDir: str,
                                            plan: V3SystemLinkExecPlan): bool =
    let sourceBasePath = v3SystemLinkExecBrowserBridgeSourceBasePath(plan.systemLinkPlan.outputPath)
    if len(sourceBasePath) <= 0:
        return true
    let sourcePath = v3SystemLinkExecBrowserBridgeSourcePath(plan)
    if len(sourcePath) <= 0:
        if os.FileExists(sourceBasePath):
            let _ = os.RemoveFile(sourceBasePath)
        return true
    let sourceText = v3SystemLinkExecBrowserBridgeSourceText(plan) + "\n"
    return v3path.V3WriteTextFile(rootDir, sourcePath, sourceText)

fn v3ProviderSourcesForPlan(rootDir: str, linkPlan: slplan.V3SystemLinkPlanStub): Result[str[]] =
    var out: str[]
    out = []
    for i in 0..<linkPlan.providerModules.len:
        let modulePath = linkPlan.providerModules[i]
        if modulePath == "runtime/core_runtime_v3":
            var providerSource = ""
            providerSource = corun.v3CoreRuntimeProviderSourcePath(rootDir, linkPlan.targetTriple)
            add(out, providerSource)
        elif modulePath == "runtime/debug_runtime_v3":
            var providerSource = ""
            providerSource = debrun.v3DebugRuntimeProviderSourcePath(rootDir)
            add(out, providerSource)
        elif modulePath == "runtime/compiler_runtime_v3":
            var providerSource = ""
            if linkPlan.moduleKind == slplan.v3SystemCompilerControlPlane:
                providerSource = comprun.v3CompilerRuntimeProviderSourcePath(rootDir,
                                                                             comprun.v3CompilerRuntimeTrackTooling)
            else:
                providerSource = comprun.v3CompilerRuntimeProviderSourcePath(rootDir,
                                                                             comprun.v3CompilerRuntimeTrackProgram)
            add(out, providerSource)
        elif modulePath == "runtime/program_support_v3":
            var providerSource = ""
            providerSource = prun.v3ProgramSupportProviderSourcePath(rootDir)
            add(out, providerSource)
        elif modulePath == "runtime/program_support_host_v3":
            var providerSource = ""
            providerSource = prun.v3ProgramSupportHostProviderSourcePath(rootDir)
            add(out, providerSource)
        else:
            return Err[str[]]("v3 provider source: unsupported module " + modulePath)
    return Ok[str[]](out)

fn v3SystemLinkExecLinkerFlavor(targetTriple: str): str =
    if targetTriple == "arm64-apple-darwin":
        return "ld64"
    if slplan.v3SystemLinkPlanTargetUsesLinuxNolibcRuntime(targetTriple):
        return "elf_aarch64_nolibc_internal"
    if slplan.v3SystemLinkPlanTargetIsLinuxRiscv64(targetTriple):
        return "elf_riscv64_builtin"
    if slplan.v3SystemLinkPlanTargetIsWindows(targetTriple):
        return "coff_pe_builtin"
    return "system_linker"

fn v3SystemLinkExecLinkerProgram(targetTriple: str): str =
    if slplan.v3SystemLinkPlanTargetUsesLinuxNolibcRuntime(targetTriple):
        return "internal_elf_linker"
    if slplan.v3SystemLinkPlanTargetIsLinuxRiscv64(targetTriple):
        return "builtin_elf_linker_riscv64"
    if slplan.v3SystemLinkPlanTargetIsWindows(targetTriple):
        return "builtin_coff_linker"
    return "cc"

fn v3BuildSystemLinkExecPlanWithWorldAndChannel(rootDir: str,
                                                req: creq.V3CompilerRequest,
                                                requestedWorldHead: str,
                                                lockPath: str,
                                                baselineSurfacePath: str,
                                                channelRaw: str): Result[V3SystemLinkExecPlan] =
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    if !slplan.v3BuildSystemLinkPlanStub(rootDir, req, linkPlan, err):
        return Err[V3SystemLinkExecPlan](err)
    let sourceBundleCid = cworld.v3CompilerWorldSourceBundleCid(linkPlan.packageId,
                                                                linkPlan.sourceClosurePaths)
    let compilerCsgRes = ccsg.v3BuildCompilerCsg(linkPlan, sourceBundleCid)
    if IsErr(compilerCsgRes):
        return Err[V3SystemLinkExecPlan](Error(compilerCsgRes))
    let compilerCsg = ccsg.v3CompilerCsgClone(Value(compilerCsgRes))
    let exportSurface = ccsg.v3CompilerExportSurfaceFromCsg(compilerCsg)
    let universeRes = cworld.v3CompilerLocalUniverseBuildForChannel(channelRaw,
                                                                    sourceBundleCid,
                                                                    compilerCsg.graphCid,
                                                                    exportSurface.surfaceCid)
    if IsErr(universeRes):
        return Err[V3SystemLinkExecPlan](Error(universeRes))
    let localUniverse = Value(universeRes)
    let worldHeadPinned = len(requestedWorldHead) > 0
    if worldHeadPinned:
        let pinRes = cworld.v3CompilerWorldHeadMatchesHex(localUniverse.worldHead, requestedWorldHead)
        if IsErr(pinRes):
            return Err[V3SystemLinkExecPlan](Error(pinRes))
    let lockCheckEnabled = len(lockPath) > 0
    var lockVerified = false
    if lockCheckEnabled:
        let lockRes = cworld.v3CompilerLockSnapshotRead(rootDir, lockPath)
        if IsErr(lockRes):
            return Err[V3SystemLinkExecPlan](Error(lockRes))
        let verifyLockRes = cworld.v3CompilerWorldVerifyLock(localUniverse, Value(lockRes))
        if IsErr(verifyLockRes):
            return Err[V3SystemLinkExecPlan](Error(verifyLockRes))
        lockVerified = true
    let baselineSurfaceChecked = len(baselineSurfacePath) > 0
    var baselineSurfaceCompatible = false
    if baselineSurfaceChecked:
        let baselinePath = v3path.V3PathAbsolute(rootDir, baselineSurfacePath)
        if !v3path.V3PathFileExists(baselinePath):
            return Err[V3SystemLinkExecPlan]("v3 compiler world: missing baseline surface path: " + baselinePath)
        let baselineText = v3path.V3ReadTextFile("", baselinePath)
        var baselineSurface: ccsg.V3CsgExportSurface
        let baselineRes = ccsg.v3CompilerExportSurfaceFromReportText(baselineText, baselineSurface)
        if IsErr(baselineRes):
            return Err[V3SystemLinkExecPlan](Error(baselineRes))
        if !ccsg.v3CompilerExportSurfaceCompatible(baselineSurface, exportSurface):
            return Err[V3SystemLinkExecPlan]("v3 compiler world: baseline export surface incompatible")
        baselineSurfaceCompatible = true
    var loweringPlan: lower.V3LoweringPlanStub
    if !lower.v3BuildLoweringPlanStubFromCompilerCsg(linkPlan, compilerCsg, loweringPlan, err):
        return Err[V3SystemLinkExecPlan](err)
    let primaryRes = pobj.v3BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    if IsErr(primaryRes):
        return Err[V3SystemLinkExecPlan](Error(primaryRes))
    let providerSourcesRes = v3ProviderSourcesForPlan(rootDir, linkPlan)
    if IsErr(providerSourcesRes):
        return Err[V3SystemLinkExecPlan](Error(providerSourcesRes))
    var providerObjectPaths: str[]
    var linkInputs: str[]
    var objectMissing: str[]
    var nativeMissing: str[]
    var providerSourcePaths: str[]
    providerObjectPaths = []
    linkInputs = []
    objectMissing = []
    nativeMissing = []
    providerSourcePaths = []
    let primaryPlan = Value(primaryRes)
    providerSourcePaths = Value(providerSourcesRes)
    let primaryObjectPath = primaryPlan.outputPath
    let browserBridgeObjectPath = v3SystemLinkExecBrowserBridgeObjectPathForLinkPlan(linkPlan)
    if len(primaryObjectPath) > 0:
        add(linkInputs, primaryObjectPath)
    if len(browserBridgeObjectPath) > 0:
        add(linkInputs, browserBridgeObjectPath)
    var linuxNolibcSupportEnabled = false
    var linuxNolibcRuntimeSourcePath = ""
    var linuxNolibcRuntimeObjectPath = ""
    var linuxNolibcStartupSourcePath = ""
    var linuxNolibcStartupObjectPath = ""
    if linkPlan.emitKind == creq.v3EmitExe &&
       slplan.v3SystemLinkPlanTargetUsesLinuxNolibcRuntime(linkPlan.targetTriple):
        linuxNolibcSupportEnabled = true
        linuxNolibcRuntimeSourcePath = v3path.V3PathAbsolute(rootDir, "src/std/system_helpers_backend_nolibc_linux_aarch64.cheng")
        linuxNolibcRuntimeObjectPath = linkPlan.outputPath + ".runtime.system_helpers_backend_nolibc_linux_aarch64.o"
        linuxNolibcStartupSourcePath = v3path.V3PathAbsolute(rootDir, "v3/src/runtime/v3_linux_nolibc_aarch64_entry.S")
        linuxNolibcStartupObjectPath = linkPlan.outputPath + ".startup.v3_linux_nolibc_aarch64_entry.o"
        add(linkInputs, linuxNolibcStartupObjectPath)
        add(linkInputs, linuxNolibcRuntimeObjectPath)
    for i in 0..<linkPlan.providerModules.len:
        let providerModule = linkPlan.providerModules[i]
        var safe = ""
        for j in 0..<len(providerModule):
            let ch = providerModule[j]
            let digit = ch >= '0' && ch <= '9'
            let upper = ch >= 'A' && ch <= 'Z'
            let lower = ch >= 'a' && ch <= 'z'
            if digit || upper || lower:
                safe = safe + strings.SliceBytes(providerModule, j, 1)
            else:
                safe = safe + "_"
        let providerObjectPath = linkPlan.outputPath + ".provider." + safe + ".o"
        add(providerObjectPaths, providerObjectPath)
        add(linkInputs, providerObjectPath)
    if linkPlan.missingReasons.len > 0:
        add(objectMissing, "system_link_plan_not_ready_for_object_plan")
    if loweringPlan.missingReasons.len > 0:
        add(objectMissing, "lowering_plan_not_ready_for_object_plan")
    if primaryPlan.missingReasons.len > 0:
        add(objectMissing, "primary_object_not_ready_for_object_plan")
    if len(primaryObjectPath) <= 0:
        add(objectMissing, "primary_object_path_missing")
    if loweringPlan.functionSymbolTexts.len <= 0:
        add(objectMissing, "primary_object_functions_missing")
    if linkPlan.providerModules.len > 0 && providerObjectPaths.len != linkPlan.providerModules.len:
        add(objectMissing, "provider_object_paths_incomplete")
    if linkPlan.providerModules.len > 0 && providerSourcePaths.len != linkPlan.providerModules.len:
        add(objectMissing, "provider_source_paths_incomplete")
    if linuxNolibcSupportEnabled:
        if len(linuxNolibcRuntimeSourcePath) <= 0 || !v3path.V3PathFileExists(linuxNolibcRuntimeSourcePath):
            add(objectMissing, "linux_nolibc_runtime_source_missing")
        if len(linuxNolibcStartupSourcePath) <= 0 || !v3path.V3PathFileExists(linuxNolibcStartupSourcePath):
            add(objectMissing, "linux_nolibc_startup_source_missing")
        if len(linuxNolibcRuntimeObjectPath) <= 0:
            add(objectMissing, "linux_nolibc_runtime_object_path_missing")
        if len(linuxNolibcStartupObjectPath) <= 0:
            add(objectMissing, "linux_nolibc_startup_object_path_missing")
    var objectPlan: objplan.V3ObjectPlanStub
    objectPlan.workspaceRoot = linkPlan.workspaceRoot
    objectPlan.packageRoot = linkPlan.packageRoot
    objectPlan.packageId = linkPlan.packageId
    objectPlan.entryPath = linkPlan.entryPath
    objectPlan.outputPath = linkPlan.outputPath
    objectPlan.targetTriple = linkPlan.targetTriple
    objectPlan.primaryObjectPath = primaryObjectPath
    objectPlan.browserBridgeObjectPath = browserBridgeObjectPath
    objectPlan.linuxNolibcSupportEnabled = linuxNolibcSupportEnabled
    objectPlan.linuxNolibcRuntimeSourcePath = linuxNolibcRuntimeSourcePath
    objectPlan.linuxNolibcRuntimeObjectPath = linuxNolibcRuntimeObjectPath
    objectPlan.linuxNolibcStartupSourcePath = linuxNolibcStartupSourcePath
    objectPlan.linuxNolibcStartupObjectPath = linuxNolibcStartupObjectPath
    objectPlan.providerModules = linkPlan.providerModules
    objectPlan.providerSourcePaths = providerSourcePaths
    objectPlan.providerObjectPaths = providerObjectPaths
    objectPlan.linkInputPaths = linkInputs
    objectPlan.loweredFunctionSymbols = loweringPlan.functionSymbolTexts
    objectPlan.entrySymbol = linkPlan.entrySymbol
    objectPlan.missingReasons = objectMissing
    objectPlan.pipelineStage = "lowering_plan_to_object_plan"
    if linkPlan.missingReasons.len > 0:
        add(nativeMissing, "system_link_plan_not_ready_for_native_link")
    if objectPlan.missingReasons.len > 0:
        add(nativeMissing, "object_plan_not_ready_for_native_link")
    if objectPlan.linkInputPaths.len <= 0:
        add(nativeMissing, "native_link_inputs_missing")
    if len(linkPlan.outputPath) <= 0:
        add(nativeMissing, "native_link_output_missing")
    if linkPlan.emitKind == creq.v3EmitExe && len(linkPlan.entrySymbol) <= 0:
        add(nativeMissing, "native_link_entry_symbol_missing")
    let linkerFlavor = v3SystemLinkExecLinkerFlavor(linkPlan.targetTriple)
    let linkerProgram = v3SystemLinkExecLinkerProgram(linkPlan.targetTriple)
    var outputKind = nplan.v3NativeOutputArtifact
    if linkPlan.emitKind == creq.v3EmitExe:
        outputKind = nplan.v3NativeOutputExecutable
    var nativePlan: nplan.V3NativeLinkPlanStub
    nativePlan.targetTriple = linkPlan.targetTriple
    nativePlan.emitKind = linkPlan.emitKind
    nativePlan.outputPath = linkPlan.outputPath
    nativePlan.linkerProgram = linkerProgram
    nativePlan.linkerFlavor = linkerFlavor
    nativePlan.outputKind = outputKind
    nativePlan.entrySymbol = linkPlan.entrySymbol
    nativePlan.primaryObjectPath = objectPlan.primaryObjectPath
    nativePlan.browserBridgeObjectPath = objectPlan.browserBridgeObjectPath
    nativePlan.linkInputPaths = objectPlan.linkInputPaths
    nativePlan.missingReasons = nativeMissing
    nativePlan.pipelineStage = "object_plan_to_native_link_plan"
    let outputDigest = ccsg.v3CompileOutputDigest(linkPlan.outputPath,
                                                  linkPlan.targetTriple,
                                                  linkPlan.providerModules,
                                                  compilerCsg.graphCid)
    let canonicalOutputDigest = ccsg.v3CompileOutputDigest(linkPlan.outputPath,
                                                           linkPlan.targetTriple,
                                                           linkPlan.providerModules,
                                                           compilerCsg.canonicalGraphCid)
    let compileReceipt = ccsg.v3CompileReceiptMake(localUniverse.worldHead.headCid,
                                                   compilerCsg.graphCid,
                                                   compilerCsg.canonicalGraphCid,
                                                   linkPlan.targetTriple,
                                                   outputDigest,
                                                   canonicalOutputDigest,
                                                   "stage3_local",
                                                   linkPlan.providerModules)
    var execPlan: V3SystemLinkExecPlan
    execPlan.compilerEntrySource = linkPlan.buildEntryPath
    execPlan.sourceBundleCid = sourceBundleCid
    execPlan.systemLinkPlan = linkPlan
    execPlan.compilerCsg = compilerCsg
    execPlan.exportSurface = exportSurface
    execPlan.localUniverse = localUniverse
    execPlan.compileReceipt = compileReceipt
    execPlan.worldHeadPinned = worldHeadPinned
    execPlan.lockCheckEnabled = lockCheckEnabled
    execPlan.lockVerified = lockVerified
    execPlan.baselineSurfaceChecked = baselineSurfaceChecked
    execPlan.baselineSurfaceCompatible = baselineSurfaceCompatible
    execPlan.lockPath = lockPath
    execPlan.baselineSurfacePath = baselineSurfacePath
    execPlan.loweringPlan = loweringPlan
    execPlan.primaryObjectPlan = primaryPlan
    execPlan.objectPlan = objectPlan
    execPlan.nativeLinkPlan = nativePlan
    return Ok[V3SystemLinkExecPlan](execPlan)

fn v3BuildSystemLinkExecPlanWithWorld(rootDir: str,
                                      req: creq.V3CompilerRequest,
                                      requestedWorldHead: str,
                                      lockPath: str,
                                      baselineSurfacePath: str): Result[V3SystemLinkExecPlan] =
    return v3BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                        req,
                                                        requestedWorldHead,
                                                        lockPath,
                                                        baselineSurfacePath,
                                                        cworld.v3CompilerWorldDefaultChannel())

fn v3BuildSystemLinkExecPlan(rootDir: str,
                             req: creq.V3CompilerRequest): Result[V3SystemLinkExecPlan] =
    return v3BuildSystemLinkExecPlanWithWorld(rootDir,
                                              req,
                                              "",
                                              "",
                                              "")

fn v3BuildSystemLinkExecReportWithWorld(rootDir: str,
                                        req: creq.V3CompilerRequest,
                                        requestedWorldHead: str,
                                        lockPath: str,
                                        baselineSurfacePath: str): Result[str] =
    let planRes = v3BuildSystemLinkExecPlanWithWorld(rootDir,
                                                     req,
                                                     requestedWorldHead,
                                                     lockPath,
                                                     baselineSurfacePath)
    if IsErr(planRes):
        return Err[str](Error(planRes))
    return Ok[str](v3SystemLinkExecPlanReport(Value(planRes)))

fn v3BuildSystemLinkExecReport(rootDir: str,
                               req: creq.V3CompilerRequest): Result[str] =
    return v3BuildSystemLinkExecReportWithWorld(rootDir, req, "", "", "")

fn v3SystemLinkExecPlanReady(plan: V3SystemLinkExecPlan): bool =
    return plan.systemLinkPlan.missingReasons.len <= 0 &&
           plan.loweringPlan.missingReasons.len <= 0 &&
           plan.primaryObjectPlan.missingReasons.len <= 0 &&
           plan.objectPlan.missingReasons.len <= 0 &&
           plan.nativeLinkPlan.missingReasons.len <= 0

fn v3SystemLinkExecBrowserBridgeReport(plan: V3SystemLinkExecPlan): str =
    let bridgePlans = v3SystemLinkExecBrowserBridgePlans(plan)
    let bridgeArtifactPath = v3SystemLinkExecBrowserBridgeArtifactPath(plan)
    let bridgeSourcePath = v3SystemLinkExecBrowserBridgeSourcePath(plan)
    let bridgeObjectPath = v3SystemLinkExecBrowserBridgeObjectPath(plan)
    var bridgeArtifactPathText = "-"
    var bridgeSourcePathText = "-"
    var bridgeObjectPathText = "-"
    var bridgeObjectCount: int32 = 0
    if len(bridgeArtifactPath) > 0:
        bridgeArtifactPathText = bridgeArtifactPath
    if len(bridgeSourcePath) > 0:
        bridgeSourcePathText = bridgeSourcePath
    if len(bridgeObjectPath) > 0:
        bridgeObjectPathText = bridgeObjectPath
        bridgeObjectCount = 1
    var lines = ""
    for i in 0..<bridgePlans.len:
        lines = lines + "browser_bridge_plan["
        lines = lines + intToStr(i)
        lines = lines + "]="
        lines = lines + ccsg.v3BrowserAbiBridgePlanEmitLine(bridgePlans[i])
        lines = lines + "\n"
    var out = ""
    out = out + "browser_bridge_artifact_path=" + bridgeArtifactPathText + "\n"
    out = out + "browser_bridge_artifact_format=" + ccsg.v3BrowserAbiBridgePlanManifestFormat() + "\n"
    out = out + "browser_bridge_artifact_count=" + intToStr(bridgePlans.len) + "\n"
    out = out + "browser_bridge_artifact_unique_key_count=" + intToStr(ccsg.v3BrowserAbiBridgePlanUniqueKeyCount(bridgePlans)) + "\n"
    out = out + "browser_bridge_source_path=" + bridgeSourcePathText + "\n"
    out = out + "browser_bridge_source_format=" + ccsg.v3BrowserAbiBridgeSourceFormat() + "\n"
    out = out + "browser_bridge_source_count=" + intToStr(bridgePlans.len) + "\n"
    out = out + "browser_bridge_object_path=" + bridgeObjectPathText + "\n"
    out = out + "browser_bridge_object_count=" + intToStr(bridgeObjectCount) + "\n"
    out = out + "browser_bridge_plan_count=" + intToStr(bridgePlans.len) + "\n"
    out = out + "browser_bridge_plan_unique_key_count=" + intToStr(ccsg.v3BrowserAbiBridgePlanUniqueKeyCount(bridgePlans)) + "\n"
    out = out + lines
    return out

fn v3SystemLinkExecPlanReport(plan: V3SystemLinkExecPlan): str =
    var worldHeadPinned = "0"
    var lockCheckEnabled = "0"
    var lockVerified = "0"
    var baselineSurfaceChecked = "0"
    var baselineSurfaceCompatible = "0"
    var lockPath = "-"
    var baselineSurfacePath = "-"
    var primaryObjectPath = "-"
    var nativeOutputKind = "artifact"
    var nativePrimaryObject = "-"
    var browserBridgeObject = "-"
    var nativeEntrySymbol = "-"
    if plan.worldHeadPinned:
        worldHeadPinned = "1"
    if plan.lockCheckEnabled:
        lockCheckEnabled = "1"
    if plan.lockVerified:
        lockVerified = "1"
    if plan.baselineSurfaceChecked:
        baselineSurfaceChecked = "1"
    if plan.baselineSurfaceCompatible:
        baselineSurfaceCompatible = "1"
    if len(plan.lockPath) > 0:
        lockPath = plan.lockPath
    if len(plan.baselineSurfacePath) > 0:
        baselineSurfacePath = plan.baselineSurfacePath
    if len(plan.objectPlan.primaryObjectPath) > 0:
        primaryObjectPath = plan.objectPlan.primaryObjectPath
    if plan.nativeLinkPlan.outputKind == nplan.v3NativeOutputExecutable:
        nativeOutputKind = "executable"
    if len(plan.nativeLinkPlan.primaryObjectPath) > 0:
        nativePrimaryObject = plan.nativeLinkPlan.primaryObjectPath
    if len(plan.nativeLinkPlan.browserBridgeObjectPath) > 0:
        browserBridgeObject = plan.nativeLinkPlan.browserBridgeObjectPath
    if len(plan.nativeLinkPlan.entrySymbol) > 0:
        nativeEntrySymbol = plan.nativeLinkPlan.entrySymbol
    var linuxNolibcSupportEnabled = "0"
    var linuxNolibcRuntimeSource = "-"
    var linuxNolibcRuntimeObject = "-"
    var linuxNolibcStartupSource = "-"
    var linuxNolibcStartupObject = "-"
    if plan.objectPlan.linuxNolibcSupportEnabled:
        linuxNolibcSupportEnabled = "1"
    if len(plan.objectPlan.linuxNolibcRuntimeSourcePath) > 0:
        linuxNolibcRuntimeSource = plan.objectPlan.linuxNolibcRuntimeSourcePath
    if len(plan.objectPlan.linuxNolibcRuntimeObjectPath) > 0:
        linuxNolibcRuntimeObject = plan.objectPlan.linuxNolibcRuntimeObjectPath
    if len(plan.objectPlan.linuxNolibcStartupSourcePath) > 0:
        linuxNolibcStartupSource = plan.objectPlan.linuxNolibcStartupSourcePath
    if len(plan.objectPlan.linuxNolibcStartupObjectPath) > 0:
        linuxNolibcStartupObject = plan.objectPlan.linuxNolibcStartupObjectPath
    let browserBridgeReport = v3SystemLinkExecBrowserBridgeReport(plan)
    var out = ""
    out = out + "entry=" + plan.compilerEntrySource + "\n"
    out = out + "source_bundle_cid=" + layout.fixedBytes32Hex(plan.sourceBundleCid) + "\n"
    out = out + "canonical_compiler_csg_cid=" + layout.fixedBytes32Hex(plan.compilerCsg.canonicalGraphCid) + "\n"
    out = out + "compiler_csg_cid=" + layout.fixedBytes32Hex(plan.compilerCsg.graphCid) + "\n"
    out = out + "compiler_csg_node_count=" + intToStr(plan.compilerCsg.nodeCount) + "\n"
    out = out + "compiler_csg_edge_count=" + intToStr(plan.compilerCsg.edgeCount) + "\n"
    out = out + "export_surface_cid=" + layout.fixedBytes32Hex(plan.exportSurface.surfaceCid) + "\n"
    out = out + "export_surface_symbol_count=" + intToStr(plan.exportSurface.exportedSymbolCount) + "\n"
    out = out + "world_head_cid=" + layout.fixedBytes32Hex(plan.localUniverse.worldHead.headCid) + "\n"
    out = out + "compiler_pkg_cid=" + layout.fixedBytes32Hex(plan.localUniverse.compilerSnapshot.snapshotCid) + "\n"
    out = out + "std_pkg_cid=" + layout.fixedBytes32Hex(plan.localUniverse.stdSnapshot.snapshotCid) + "\n"
    out = out + "runtime_pkg_cid=" + layout.fixedBytes32Hex(plan.localUniverse.runtimeSnapshot.snapshotCid) + "\n"
    out = out + "world_head_pinned=" + worldHeadPinned + "\n"
    out = out + "lock_check_enabled=" + lockCheckEnabled + "\n"
    out = out + "lock_verified=" + lockVerified + "\n"
    out = out + "lock_path=" + lockPath + "\n"
    out = out + "baseline_surface_checked=" + baselineSurfaceChecked + "\n"
    out = out + "baseline_surface_compatible=" + baselineSurfaceCompatible + "\n"
    out = out + "baseline_surface_path=" + baselineSurfacePath + "\n"
    out = out + "compile_receipt_cid=" + layout.fixedBytes32Hex(plan.compileReceipt.receiptCid) + "\n"
    out = out + "compile_canonical_output_digest=" + layout.fixedBytes32Hex(plan.compileReceipt.canonicalOutputDigest) + "\n"
    out = out + "compile_output_digest=" + layout.fixedBytes32Hex(plan.compileReceipt.outputDigest) + "\n"
    out = out + "compile_bootstrap_stage=" + plan.compileReceipt.bootstrapStage + "\n"
    out = out + slplan.v3SystemLinkPlanStubReport(plan.systemLinkPlan) + "\n"
    out = out + lower.v3LoweringPlanStubReport(plan.loweringPlan) + "\n"
    out = out + browserBridgeReport
    out = out + pobj.v3PrimaryObjectPlanReport(plan.primaryObjectPlan) + "\n"
    out = out + "primary_object_path=" + primaryObjectPath + "\n"
    out = out + "provider_object_count=" + intToStr(plan.objectPlan.providerObjectPaths.len) + "\n"
    out = out + "provider_source_paths=" + slplan.v3SystemLinkPlanListText(plan.objectPlan.providerSourcePaths) + "\n"
    out = out + "provider_object_paths=" + slplan.v3SystemLinkPlanListText(plan.objectPlan.providerObjectPaths) + "\n"
    out = out + "linux_nolibc_support_enabled=" + linuxNolibcSupportEnabled + "\n"
    out = out + "linux_nolibc_runtime_source=" + linuxNolibcRuntimeSource + "\n"
    out = out + "linux_nolibc_runtime_object=" + linuxNolibcRuntimeObject + "\n"
    out = out + "linux_nolibc_startup_source=" + linuxNolibcStartupSource + "\n"
    out = out + "linux_nolibc_startup_object=" + linuxNolibcStartupObject + "\n"
    out = out + "browser_bridge_object=" + browserBridgeObject + "\n"
    out = out + "object_link_input_count=" + intToStr(plan.objectPlan.linkInputPaths.len) + "\n"
    out = out + "object_link_inputs=" + slplan.v3SystemLinkPlanListText(plan.objectPlan.linkInputPaths) + "\n"
    out = out + "object_missing_reasons=" + slplan.v3SystemLinkPlanListText(plan.objectPlan.missingReasons) + "\n"
    out = out + "object_pipeline_stage=" + plan.objectPlan.pipelineStage + "\n"
    out = out + "native_linker_program=" + plan.nativeLinkPlan.linkerProgram + "\n"
    out = out + "native_linker_flavor=" + plan.nativeLinkPlan.linkerFlavor + "\n"
    out = out + "native_output_kind=" + nativeOutputKind + "\n"
    out = out + "native_primary_object=" + nativePrimaryObject + "\n"
    out = out + "native_link_input_count=" + intToStr(plan.nativeLinkPlan.linkInputPaths.len) + "\n"
    out = out + "native_link_inputs=" + slplan.v3SystemLinkPlanListText(plan.nativeLinkPlan.linkInputPaths) + "\n"
    out = out + "native_link_entry_symbol=" + nativeEntrySymbol + "\n"
    out = out + "native_link_missing_reasons=" + slplan.v3SystemLinkPlanListText(plan.nativeLinkPlan.missingReasons) + "\n"
    out = out + "native_link_pipeline_stage=" + plan.nativeLinkPlan.pipelineStage + "\n"
    out = out + "exec_pipeline_stage=primary_object_plan_to_native_link_plan"
    return out
