import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_world as cworld
import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/lang/intern as langintern
import cheng/v3/lang/parser
import cheng/v3/lang/typed_expr as texpr
import cheng/v3/backend/system_link_plan as slplan

type
    V3LoweringPlanStub =
        workspaceRoot: str
        packageRoot: str
        packageId: str
        entryPath: str
        entrySymbol: str
        sourceBundleCid: layout.FixedBytes32
        compilerCsgCid: layout.FixedBytes32
        exprLayer: parser.V3NormalizedExprLayer
        typedExprFacts: ccsg.V3TypedExprFact[]
        loweringRules: texpr.V3TypedExprLoweringRule[]
        functionSourcePaths: str[]
        functionOwnerModulePaths: str[]
        functionNames: str[]
        functionSymbolTexts: str[]
        functionNameIds: langintern.V3InternId[]
        functionEntryFlags: int32[]
        functionCallConvs: int32[]
        functionResultLayoutKinds: int32[]
        missingReasons: str[]
        pipelineStage: str

fn v3LoweringCallConvInternal(): int32 =
    return 1

fn v3LoweringLayoutKindInvalid(): int32 =
    return 0

fn v3LoweringLayoutKindI32(): int32 =
    return 5

fn v3LoweringAppendLine(out: var str, key: str, value: str) =
    if len(out) > 0:
        out = out + "\n"
    out = out + key + "=" + value

fn v3LoweringListText(items: str[]): str =
    if items.len <= 0:
        return "-"
    var out = ""
    for i in 0..<items.len:
        if len(out) > 0:
            out = out + ","
        out = out + items[i]
    return out

fn v3LoweringFunctionNameFromLine(lineRaw: str): str =
    return parser.v3ParserFunctionNameFromLine(lineRaw)

fn v3LoweringFunctionSymbolText(ownerModulePath: str, functionName: str): str =
    return ownerModulePath + "::" + functionName

fn v3LoweringIsImportcAnnotation(lineRaw: str): bool =
    let line = v3path.V3PathTrim(lineRaw)
    if line == "":
        return false
    return v3path.V3TextStartsWith(line, "@importc")

fn v3LoweringFunctionResultLayoutKind(functionName: str): int32 =
    if functionName == "main":
        return v3LoweringLayoutKindI32()
    return v3LoweringLayoutKindInvalid()

fn v3LoweringInternIdForSymbol(functionSymbolTexts: str[], functionNameIds: langintern.V3InternId[], symbolText: str): langintern.V3InternId =
    for i in 0..<functionNameIds.len:
        if functionSymbolTexts[i] == symbolText:
            return functionNameIds[i]
    return functionSymbolTexts.len

fn v3LoweringCollectFunctionsFromSource(workspaceRoot: str,
                                        packageRoot: str,
                                        entryPath: str,
                                        entrySymbol: str,
                                        sourcePath: str,
                                        plan: var V3LoweringPlanStub): bool =
    if !parser.v3ParserSourceExists(sourcePath):
        return false
    let ownerModulePath = parser.v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)
    let text = v3path.V3ReadTextFile("", sourcePath)
    var decls: parser.V3NormalizedFunctionDecl[] = []
    var err = ""
    if !parser.v3ParserReadNormalizedFunctionDecls(text, decls, err):
        return false
    for i in 0..<decls.len:
        let decl = decls[i]
        let functionName = decl.name
        if decl.importc:
            continue
        let symbolText = v3LoweringFunctionSymbolText(ownerModulePath, functionName)
        var entryFlag: int32 = 0
        let callConv = v3LoweringCallConvInternal()
        let resultLayoutKind = v3LoweringFunctionResultLayoutKind(functionName)
        if sourcePath == entryPath && functionName == entrySymbol:
            entryFlag = 1
        add(plan.functionSourcePaths, sourcePath)
        add(plan.functionOwnerModulePaths, ownerModulePath)
        add(plan.functionNames, functionName)
        add(plan.functionSymbolTexts, symbolText)
        add(plan.functionEntryFlags, entryFlag)
        add(plan.functionCallConvs, callConv)
        add(plan.functionResultLayoutKinds, resultLayoutKind)
    return true

fn v3LoweringFunctionListText(functionSymbolTexts: str[]): str =
    return v3LoweringListText(functionSymbolTexts)

fn v3LoweringMissingReasons(functionNames: str[], functionEntryFlags: int32[], entrySymbol: str): str[] =
    var missing: str[] = []
    if functionNames.len <= 0:
        add(missing, "lowering_functions_missing")
        return missing
    if len(entrySymbol) > 0:
        var entryLowered = false
        for i in 0..<functionEntryFlags.len:
            if functionEntryFlags[i] != 0:
                entryLowered = true
        if !entryLowered:
            add(missing, "lowering_entry_function_missing")
    return missing

fn v3LoweringSequentialNameIds(count: int32): langintern.V3InternId[] =
    var out: langintern.V3InternId[]
    out = []
    for i in 0..<count:
        add(out, i)
    return out

fn v3BuildLoweringPlanStubFromCompilerCsg(linkPlan: slplan.V3SystemLinkPlanStub,
                                          compilerCsg: ccsg.V3CompilerCsg,
                                          plan: var V3LoweringPlanStub,
                                          err: var str): bool =
    plan.functionSourcePaths = []
    plan.functionOwnerModulePaths = []
    plan.functionNames = []
    plan.functionSymbolTexts = []
    plan.functionNameIds = []
    plan.functionEntryFlags = []
    plan.functionCallConvs = []
    plan.functionResultLayoutKinds = []
    plan.typedExprFacts = []
    plan.loweringRules = []
    let workspaceRoot = slplan.v3SystemLinkPlanWorkspaceRoot(linkPlan)
    let packageRoot = slplan.v3SystemLinkPlanPackageRoot(linkPlan)
    let packageId = slplan.v3SystemLinkPlanPackageId(linkPlan)
    let entryPath = slplan.v3SystemLinkPlanEntryPath(linkPlan)
    let entrySymbol = slplan.v3SystemLinkPlanEntrySymbol(linkPlan)
    for i in 0..<compilerCsg.nodes.len:
        let node = compilerCsg.nodes[i]
        if node.nodeKind != ccsg.v3CompilerCsgNodeKindSymbol:
            continue
        let sourcePath = parser.v3ParserModulePathToSourcePath(workspaceRoot,
                                                               packageRoot,
                                                               node.modulePath)
        add(plan.functionSourcePaths, sourcePath)
        add(plan.functionOwnerModulePaths, node.modulePath)
        add(plan.functionNames, node.factText)
        add(plan.functionSymbolTexts, node.symbolText)
        add(plan.functionEntryFlags, node.entryFlag)
        add(plan.functionCallConvs, node.callConv)
        add(plan.functionResultLayoutKinds, node.resultLayoutKind)
    let functionSymbolTexts = v3LoweringPlanFunctionSymbolTexts(plan)
    let functionNameIds = v3LoweringSequentialNameIds(functionSymbolTexts.len)
    plan.functionNameIds = functionNameIds
    let functionNames = v3LoweringPlanFunctionNamesField(plan)
    let functionEntryFlags = v3LoweringPlanFunctionEntryFlagsField(plan)
    let missingReasons = v3LoweringMissingReasons(functionNames, functionEntryFlags, entrySymbol)
    plan.workspaceRoot = workspaceRoot
    plan.packageRoot = packageRoot
    plan.packageId = packageId
    plan.entryPath = entryPath
    plan.entrySymbol = entrySymbol
    plan.sourceBundleCid = compilerCsg.sourceBundleCid
    plan.compilerCsgCid = compilerCsg.graphCid
    plan.exprLayer = parser.v3NormalizedExprLayerClone(compilerCsg.exprLayer)
    plan.typedExprFacts = ccsg.v3CompilerCsgCloneTypedExprFacts(compilerCsg.typedExprFacts)
    plan.loweringRules = texpr.v3TypedExprLoweringRulesFromFacts(plan.typedExprFacts)
    plan.missingReasons = missingReasons
    plan.pipelineStage = "canonical_csg_to_lowering_plan_stub"
    err = ""
    return true

fn v3LoweringPlanFunctionSymbolTexts(plan: V3LoweringPlanStub): str[] =
    return plan.functionSymbolTexts

fn v3LoweringPlanFunctionNameIds(plan: V3LoweringPlanStub): langintern.V3InternId[] =
    return plan.functionNameIds

fn v3LoweringPlanFunctionNamesField(plan: V3LoweringPlanStub): str[] =
    return plan.functionNames

fn v3LoweringPlanRulesForSource(plan: V3LoweringPlanStub,
                                sourcePathRaw: str): texpr.V3TypedExprLoweringRule[] =
    let sourcePath = parser.v3ParserNormalizePath(sourcePathRaw)
    var out: texpr.V3TypedExprLoweringRule[] = []
    for i in 0..<plan.loweringRules.len:
        if plan.loweringRules[i].sourcePath != sourcePath:
            continue
        add(out, texpr.v3TypedExprLoweringRuleClone(plan.loweringRules[i]))
    return out

fn v3LoweringPlanBrowserAbiRules(linkPlan: slplan.V3SystemLinkPlanStub): ccsg.V3BrowserAbiRule[] =
    return ccsg.v3CompilerBrowserAbiRulesForLinkPlan(linkPlan)

fn v3LoweringPlanBrowserAbiRulesForSource(linkPlan: slplan.V3SystemLinkPlanStub,
                                          sourcePathRaw: str): ccsg.V3BrowserAbiRule[] =
    let sourcePath = parser.v3ParserNormalizePath(sourcePathRaw)
    let rules = v3LoweringPlanBrowserAbiRules(linkPlan)
    return ccsg.v3BrowserAbiRulesForSource(rules, sourcePath)

fn v3LoweringPlanBrowserAbiBridgeSpecs(linkPlan: slplan.V3SystemLinkPlanStub): ccsg.V3BrowserAbiBridgeSpec[] =
    return ccsg.v3CompilerBrowserAbiBridgeSpecsForLinkPlan(linkPlan)

fn v3LoweringPlanBrowserAbiBridgeSpecsForSource(linkPlan: slplan.V3SystemLinkPlanStub,
                                                sourcePathRaw: str): ccsg.V3BrowserAbiBridgeSpec[] =
    let sourcePath = parser.v3ParserNormalizePath(sourcePathRaw)
    let specs = v3LoweringPlanBrowserAbiBridgeSpecs(linkPlan)
    return ccsg.v3BrowserAbiBridgeSpecsForSource(specs, sourcePath)

fn v3LoweringPlanBrowserAbiBridgeManifest(linkPlan: slplan.V3SystemLinkPlanStub): str =
    let specs = v3LoweringPlanBrowserAbiBridgeSpecs(linkPlan)
    return ccsg.v3BrowserAbiBridgeManifestText(specs)

fn v3LoweringPlanBrowserAbiBridgeManifestForSource(linkPlan: slplan.V3SystemLinkPlanStub,
                                                   sourcePathRaw: str): str =
    let sourcePath = parser.v3ParserNormalizePath(sourcePathRaw)
    let specs = v3LoweringPlanBrowserAbiBridgeSpecsForSource(linkPlan, sourcePath)
    return ccsg.v3BrowserAbiBridgeManifestText(specs)

fn v3LoweringPlanFunctionEntryFlagsField(plan: V3LoweringPlanStub): int32[] =
    return plan.functionEntryFlags

fn v3LoweringPlanMissingReasonsField(plan: V3LoweringPlanStub): str[] =
    return plan.missingReasons

fn v3LoweringPlanPipelineStage(plan: V3LoweringPlanStub): str =
    return plan.pipelineStage

fn v3BuildLoweringPlanStub(linkPlan: slplan.V3SystemLinkPlanStub,
                           plan: var V3LoweringPlanStub,
                           err: var str): bool =
    let sourceClosurePaths = slplan.v3SystemLinkPlanSourceClosurePaths(linkPlan)
    let sourceBundleCid = cworld.v3CompilerWorldSourceBundleCid(linkPlan.packageId, sourceClosurePaths)
    let csgRes = ccsg.v3BuildCompilerCsg(linkPlan, sourceBundleCid)
    if IsErr(csgRes):
        err = Error(csgRes)
        return false
    let csg = ccsg.v3CompilerCsgClone(Value(csgRes))
    return v3BuildLoweringPlanStubFromCompilerCsg(linkPlan, csg, plan, err)

fn v3LoweringPlanStubReport(plan: V3LoweringPlanStub): str =
    var out: str = ""
    var entryFunction = plan.entrySymbol
    let functionCount = intToStr(plan.functionNames.len)
    let functionTexts = v3LoweringPlanFunctionSymbolTexts(plan)
    let functionList = v3LoweringFunctionListText(functionTexts)
    let missingField = v3LoweringPlanMissingReasonsField(plan)
    let missingReasons = slplan.v3SystemLinkPlanListText(missingField)
    let pipelineStage = v3LoweringPlanPipelineStage(plan)
    let typedExprFacts = plan.typedExprFacts
    let loweringRules = plan.loweringRules
    if len(entryFunction) <= 0:
        entryFunction = "-"
    v3LoweringAppendLine(out, "lowering_function_count", functionCount)
    v3LoweringAppendLine(out, "lowering_functions", functionList)
    v3LoweringAppendLine(out, "lowering_entry_function", entryFunction)
    v3LoweringAppendLine(out, "expr_surface_source_count", intToStr(plan.exprLayer.sourceCount))
    v3LoweringAppendLine(out, "expr_surface_expr_count", intToStr(parser.v3NormalizedExprLayerExprCount(plan.exprLayer)))
    v3LoweringAppendLine(out, "expr_surface_if_count", intToStr(parser.v3NormalizedExprLayerIfCount(plan.exprLayer)))
    v3LoweringAppendLine(out, "expr_surface_range_count", intToStr(parser.v3NormalizedExprLayerRangeCount(plan.exprLayer)))
    v3LoweringAppendLine(out, "expr_surface_comprehension_count", intToStr(parser.v3NormalizedExprLayerComprehensionCount(plan.exprLayer)))
    v3LoweringAppendLine(out, "expr_surface_fmt_count", intToStr(parser.v3NormalizedExprLayerStrFormatCount(plan.exprLayer)))
    v3LoweringAppendLine(out, "expr_surface_result_intrinsic_count", intToStr(parser.v3NormalizedExprLayerResultIntrinsicCount(plan.exprLayer)))
    v3LoweringAppendLine(out, "expr_surface_try_count", intToStr(parser.v3NormalizedExprLayerTryCount(plan.exprLayer)))
    v3LoweringAppendLine(out, "expr_surface_question_residual_count", intToStr(plan.exprLayer.questionResidualCount))
    v3LoweringAppendLine(out, "typed_expr_fact_count", intToStr(typedExprFacts.len))
    v3LoweringAppendLine(out, "typed_expr_abi_scalar_count", intToStr(ccsg.v3TypedExprAbiScalarCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_abi_composite_count", intToStr(ccsg.v3TypedExprAbiCompositeCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_abi_pointer_like_count", intToStr(ccsg.v3TypedExprAbiPointerLikeCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_abi_polymorphic_count", intToStr(ccsg.v3TypedExprAbiPolymorphicCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_value_scalar_count", intToStr(ccsg.v3TypedExprValueScalarCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_value_composite_count", intToStr(ccsg.v3TypedExprValueCompositeCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_value_pointer_like_count", intToStr(ccsg.v3TypedExprValuePointerLikeCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_value_polymorphic_count", intToStr(ccsg.v3TypedExprValuePolymorphicCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_place_local_count", intToStr(ccsg.v3TypedExprPlaceLocalCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_place_global_count", intToStr(ccsg.v3TypedExprPlaceGlobalCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_place_field_count", intToStr(ccsg.v3TypedExprPlaceFieldCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_place_temporary_count", intToStr(ccsg.v3TypedExprPlaceTemporaryCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_place_call_result_count", intToStr(ccsg.v3TypedExprPlaceCallResultCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_lower_reg_count", intToStr(ccsg.v3TypedExprLowerRegCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_lower_local_address_count", intToStr(ccsg.v3TypedExprLowerLocalAddressCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_lower_sret_count", intToStr(ccsg.v3TypedExprLowerSretCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_lower_import_buffer_count", intToStr(ccsg.v3TypedExprLowerImportBufferCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_lower_deferred_count", intToStr(ccsg.v3TypedExprLowerDeferredCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_call_none_count", intToStr(ccsg.v3TypedExprCallNoneCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_call_builtin_count", intToStr(ccsg.v3TypedExprCallBuiltinCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_call_result_intrinsic_count", intToStr(ccsg.v3TypedExprCallResultIntrinsicCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_call_projection_count", intToStr(ccsg.v3TypedExprCallProjectionCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_return_reg_count", intToStr(ccsg.v3TypedExprReturnRegCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_return_composite_local_count", intToStr(ccsg.v3TypedExprReturnCompositeLocalCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_return_sret_count", intToStr(ccsg.v3TypedExprReturnSretCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_return_import_buffer_count", intToStr(ccsg.v3TypedExprReturnImportBufferCount(typedExprFacts)))
    v3LoweringAppendLine(out, "typed_expr_return_deferred_count", intToStr(ccsg.v3TypedExprReturnDeferredCount(typedExprFacts)))
    v3LoweringAppendLine(out, "lowering_rule_count", intToStr(loweringRules.len))
    v3LoweringAppendLine(out, "lowering_rule_unique_key_count", intToStr(texpr.v3TypedExprLoweringRuleUniqueKeyCount(loweringRules)))
    v3LoweringAppendLine(out, "lowering_rule_arg_value_count", intToStr(texpr.v3TypedExprLoweringRuleCountArgPassKind(loweringRules, "value")))
    v3LoweringAppendLine(out, "lowering_rule_arg_address_count", intToStr(texpr.v3TypedExprLoweringRuleCountArgPassKind(loweringRules, "address")))
    v3LoweringAppendLine(out, "lowering_rule_arg_call_result_address_count", intToStr(texpr.v3TypedExprLoweringRuleCountArgPassKind(loweringRules, "call_result_address")))
    v3LoweringAppendLine(out, "lowering_rule_result_reg_count", intToStr(texpr.v3TypedExprLoweringRuleCountResultPassKind(loweringRules, "reg")))
    v3LoweringAppendLine(out, "lowering_rule_result_local_address_count", intToStr(texpr.v3TypedExprLoweringRuleCountResultPassKind(loweringRules, "local_address")))
    v3LoweringAppendLine(out, "lowering_rule_result_sret_count", intToStr(texpr.v3TypedExprLoweringRuleCountResultPassKind(loweringRules, "sret")))
    v3LoweringAppendLine(out, "lowering_rule_materialize_register_count", intToStr(texpr.v3TypedExprLoweringRuleCountMaterializeKind(loweringRules, "register")))
    v3LoweringAppendLine(out, "lowering_rule_materialize_local_slot_count", intToStr(texpr.v3TypedExprLoweringRuleCountMaterializeKind(loweringRules, "local_slot")))
    v3LoweringAppendLine(out, "lowering_rule_materialize_call_result_local_count", intToStr(texpr.v3TypedExprLoweringRuleCountMaterializeKind(loweringRules, "call_result_local")))
    v3LoweringAppendLine(out, "lowering_rule_materialize_dest_address_count", intToStr(texpr.v3TypedExprLoweringRuleCountMaterializeKind(loweringRules, "dest_address")))
    v3LoweringAppendLine(out, "lowering_rule_copy_scalar_store_count", intToStr(texpr.v3TypedExprLoweringRuleCountCopyKind(loweringRules, "scalar_store")))
    v3LoweringAppendLine(out, "lowering_rule_copy_region_copy_count", intToStr(texpr.v3TypedExprLoweringRuleCountCopyKind(loweringRules, "region_copy")))
    v3LoweringAppendLine(out, "lowering_rule_import_builtin_address_slot_count", intToStr(texpr.v3TypedExprLoweringRuleCountImportKind(loweringRules, "builtin_address_slot")))
    v3LoweringAppendLine(out, "lowering_rule_import_i32_value_slot_count", intToStr(texpr.v3TypedExprLoweringRuleCountImportKind(loweringRules, "i32_value_slot")))
    v3LoweringAppendLine(out, "lowering_rule_import_i32_address_slot_count", intToStr(texpr.v3TypedExprLoweringRuleCountImportKind(loweringRules, "i32_address_slot")))
    v3LoweringAppendLine(out, "lowering_source_bundle_cid", layout.fixedBytes32Hex(plan.sourceBundleCid))
    v3LoweringAppendLine(out, "lowering_compiler_csg_cid", layout.fixedBytes32Hex(plan.compilerCsgCid))
    v3LoweringAppendLine(out, "lowering_missing_reasons", missingReasons)
    v3LoweringAppendLine(out, "exec_pipeline_stage", pipelineStage)
    return out
