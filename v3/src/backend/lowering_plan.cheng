import std/result
import cheng/v3/std/bytes_layout as layout
import cheng/v3/tooling/path as v3path
import cheng/v3/tooling/compiler_world as cworld
import cheng/v3/tooling/compiler_csg as ccsg
import cheng/v3/lang/intern as langintern
import cheng/v3/lang/parser
import cheng/v3/backend/system_link_plan as slplan

type
    V3LoweringPlanStub =
        workspaceRoot: str
        packageRoot: str
        packageId: str
        entryPath: str
        entrySymbol: str
        sourceBundleCid: layout.FixedBytes32
        compilerCsgCid: layout.FixedBytes32
        functionSourcePaths: str[]
        functionOwnerModulePaths: str[]
        functionNames: str[]
        functionSymbolTexts: str[]
        functionNameIds: langintern.V3InternId[]
        functionEntryFlags: int32[]
        functionCallConvs: int32[]
        functionResultLayoutKinds: int32[]
        missingReasons: str[]
        pipelineStage: str

fn v3LoweringCallConvInternal(): int32 =
    return 1

fn v3LoweringLayoutKindInvalid(): int32 =
    return 0

fn v3LoweringLayoutKindI32(): int32 =
    return 5

fn v3LoweringAppendLine(out: var str, key: str, value: str) =
    if len(out) > 0:
        out = out + "\n"
    out = out + key + "=" + value

fn v3LoweringListText(items: str[]): str =
    if items.len <= 0:
        return "-"
    var out = ""
    for i in 0..<items.len:
        if len(out) > 0:
            out = out + ","
        out = out + items[i]
    return out

fn v3LoweringIdentPrefix(text: str): str =
    var stop: int32 = 0
    for i in 0..<text.len:
        let ch = text[i]
        let digit = ch >= '0' && ch <= '9'
        let upper = ch >= 'A' && ch <= 'Z'
        let lower = ch >= 'a' && ch <= 'z'
        if digit || upper || lower || ch == '_':
            stop = i + 1
        else:
            break
    if stop <= 0:
        return ""
    return v3path.V3TextSlice(text, 0, stop)

fn v3LoweringFunctionNameFromLine(lineRaw: str): str =
    let line = v3path.V3PathTrim(lineRaw)
    if !v3path.V3TextStartsWith(line, "fn "):
        return ""
    let prefixLen = len("fn ")
    let tailCount = len(line) - prefixLen
    let tail = v3path.V3TextSlice(line, prefixLen, tailCount)
    let firstToken = parser.v3ParserFirstToken(tail)
    return v3LoweringIdentPrefix(firstToken)

fn v3LoweringFunctionSymbolText(ownerModulePath: str, functionName: str): str =
    return ownerModulePath + "::" + functionName

fn v3LoweringIsImportcAnnotation(lineRaw: str): bool =
    let line = v3path.V3PathTrim(lineRaw)
    if line == "":
        return false
    return v3path.V3TextStartsWith(line, "@importc")

fn v3LoweringFunctionResultLayoutKind(functionName: str): int32 =
    if functionName == "main":
        return v3LoweringLayoutKindI32()
    return v3LoweringLayoutKindInvalid()

fn v3LoweringInternIdForSymbol(functionSymbolTexts: str[], functionNameIds: langintern.V3InternId[], symbolText: str): langintern.V3InternId =
    for i in 0..<functionNameIds.len:
        if functionSymbolTexts[i] == symbolText:
            return functionNameIds[i]
    return functionSymbolTexts.len

fn v3LoweringCollectFunctionsFromSource(workspaceRoot: str,
                                        packageRoot: str,
                                        entryPath: str,
                                        entrySymbol: str,
                                        sourcePath: str,
                                        plan: var V3LoweringPlanStub): bool =
    if !parser.v3ParserSourceExists(sourcePath):
        return false
    let ownerModulePath = parser.v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)
    let text = v3path.V3ReadTextFile("", sourcePath)
    let lines = parser.v3ParserSplitChar(text, '\n')
    var pendingImportc = false
    for i in 0..<lines.len:
        let line = lines[i]
        let trimmed = v3path.V3PathTrim(line)
        if trimmed == "":
            continue
        if v3LoweringIsImportcAnnotation(trimmed):
            pendingImportc = true
            continue
        let functionName = v3LoweringFunctionNameFromLine(line)
        if len(functionName) <= 0:
            pendingImportc = false
            continue
        if pendingImportc:
            pendingImportc = false
            continue
        let symbolText = v3LoweringFunctionSymbolText(ownerModulePath, functionName)
        var entryFlag: int32 = 0
        let callConv = v3LoweringCallConvInternal()
        let resultLayoutKind = v3LoweringFunctionResultLayoutKind(functionName)
        if sourcePath == entryPath && functionName == entrySymbol:
            entryFlag = 1
        add(plan.functionSourcePaths, sourcePath)
        add(plan.functionOwnerModulePaths, ownerModulePath)
        add(plan.functionNames, functionName)
        add(plan.functionSymbolTexts, symbolText)
        add(plan.functionEntryFlags, entryFlag)
        add(plan.functionCallConvs, callConv)
        add(plan.functionResultLayoutKinds, resultLayoutKind)
    return true

fn v3LoweringFunctionListText(functionSymbolTexts: str[]): str =
    return v3LoweringListText(functionSymbolTexts)

fn v3LoweringMissingReasons(functionNames: str[], functionEntryFlags: int32[], entrySymbol: str): str[] =
    var missing: str[] = []
    if functionNames.len <= 0:
        add(missing, "lowering_functions_missing")
        return missing
    if len(entrySymbol) > 0:
        var entryLowered = false
        for i in 0..<functionEntryFlags.len:
            if functionEntryFlags[i] != 0:
                entryLowered = true
        if !entryLowered:
            add(missing, "lowering_entry_function_missing")
    return missing

fn v3LoweringSequentialNameIds(count: int32): langintern.V3InternId[] =
    var out: langintern.V3InternId[]
    out = []
    for i in 0..<count:
        add(out, i)
    return out

fn v3BuildLoweringPlanStubFromCompilerCsg(linkPlan: slplan.V3SystemLinkPlanStub,
                                          compilerCsg: ccsg.V3CompilerCsg,
                                          plan: var V3LoweringPlanStub,
                                          err: var str): bool =
    plan.functionSourcePaths = []
    plan.functionOwnerModulePaths = []
    plan.functionNames = []
    plan.functionSymbolTexts = []
    plan.functionNameIds = []
    plan.functionEntryFlags = []
    plan.functionCallConvs = []
    plan.functionResultLayoutKinds = []
    let workspaceRoot = slplan.v3SystemLinkPlanWorkspaceRoot(linkPlan)
    let packageRoot = slplan.v3SystemLinkPlanPackageRoot(linkPlan)
    let packageId = slplan.v3SystemLinkPlanPackageId(linkPlan)
    let entryPath = slplan.v3SystemLinkPlanEntryPath(linkPlan)
    let entrySymbol = slplan.v3SystemLinkPlanEntrySymbol(linkPlan)
    for i in 0..<compilerCsg.nodes.len:
        let node = compilerCsg.nodes[i]
        if node.nodeKind != ccsg.v3CompilerCsgNodeKindSymbol:
            continue
        let sourcePath = parser.v3ParserModulePathToSourcePath(workspaceRoot,
                                                               packageRoot,
                                                               node.modulePath)
        add(plan.functionSourcePaths, sourcePath)
        add(plan.functionOwnerModulePaths, node.modulePath)
        add(plan.functionNames, node.factText)
        add(plan.functionSymbolTexts, node.symbolText)
        add(plan.functionEntryFlags, node.entryFlag)
        add(plan.functionCallConvs, node.callConv)
        add(plan.functionResultLayoutKinds, node.resultLayoutKind)
    let functionSymbolTexts = v3LoweringPlanFunctionSymbolTexts(plan)
    let functionNameIds = v3LoweringSequentialNameIds(functionSymbolTexts.len)
    plan.functionNameIds = functionNameIds
    let functionNames = v3LoweringPlanFunctionNamesField(plan)
    let functionEntryFlags = v3LoweringPlanFunctionEntryFlagsField(plan)
    let missingReasons = v3LoweringMissingReasons(functionNames, functionEntryFlags, entrySymbol)
    plan.workspaceRoot = workspaceRoot
    plan.packageRoot = packageRoot
    plan.packageId = packageId
    plan.entryPath = entryPath
    plan.entrySymbol = entrySymbol
    plan.sourceBundleCid = compilerCsg.sourceBundleCid
    plan.compilerCsgCid = compilerCsg.graphCid
    plan.missingReasons = missingReasons
    plan.pipelineStage = "canonical_csg_to_lowering_plan_stub"
    err = ""
    return true

fn v3LoweringPlanFunctionSymbolTexts(plan: V3LoweringPlanStub): str[] =
    return plan.functionSymbolTexts

fn v3LoweringPlanFunctionNameIds(plan: V3LoweringPlanStub): langintern.V3InternId[] =
    return plan.functionNameIds

fn v3LoweringPlanFunctionNamesField(plan: V3LoweringPlanStub): str[] =
    return plan.functionNames

fn v3LoweringPlanFunctionEntryFlagsField(plan: V3LoweringPlanStub): int32[] =
    return plan.functionEntryFlags

fn v3LoweringPlanMissingReasonsField(plan: V3LoweringPlanStub): str[] =
    return plan.missingReasons

fn v3LoweringPlanPipelineStage(plan: V3LoweringPlanStub): str =
    return plan.pipelineStage

fn v3BuildLoweringPlanStub(linkPlan: slplan.V3SystemLinkPlanStub,
                           plan: var V3LoweringPlanStub,
                           err: var str): bool =
    let sourceClosurePaths = slplan.v3SystemLinkPlanSourceClosurePaths(linkPlan)
    let sourceBundleCid = cworld.v3CompilerWorldSourceBundleCid(linkPlan.packageId, sourceClosurePaths)
    let csgRes = ccsg.v3BuildCompilerCsg(linkPlan, sourceBundleCid)
    if IsErr(csgRes):
        err = Error(csgRes)
        return false
    return v3BuildLoweringPlanStubFromCompilerCsg(linkPlan, Value(csgRes), plan, err)

fn v3LoweringPlanStubReport(plan: V3LoweringPlanStub): str =
    var out: str = ""
    var entryFunction = plan.entrySymbol
    let functionCount = intToStr(plan.functionNames.len)
    let functionTexts = v3LoweringPlanFunctionSymbolTexts(plan)
    let functionList = v3LoweringFunctionListText(functionTexts)
    let missingField = v3LoweringPlanMissingReasonsField(plan)
    let missingReasons = slplan.v3SystemLinkPlanListText(missingField)
    let pipelineStage = v3LoweringPlanPipelineStage(plan)
    if len(entryFunction) <= 0:
        entryFunction = "-"
    v3LoweringAppendLine(out, "lowering_function_count", functionCount)
    v3LoweringAppendLine(out, "lowering_functions", functionList)
    v3LoweringAppendLine(out, "lowering_entry_function", entryFunction)
    v3LoweringAppendLine(out, "lowering_source_bundle_cid", layout.fixedBytes32Hex(plan.sourceBundleCid))
    v3LoweringAppendLine(out, "lowering_compiler_csg_cid", layout.fixedBytes32Hex(plan.compilerCsgCid))
    v3LoweringAppendLine(out, "lowering_missing_reasons", missingReasons)
    v3LoweringAppendLine(out, "exec_pipeline_stage", pipelineStage)
    return out
