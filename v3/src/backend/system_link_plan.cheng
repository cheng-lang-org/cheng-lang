import std/result
import std/strings
import std/strutils as strutil
import cheng/v3/tooling/compiler_request as creq
import cheng/v3/tooling/compiler_runtime as crun
import cheng/v3/lang/parser as parser
import cheng/v3/backend/build_plan as buildplan

type
    V3SystemModuleKind = enum
        v3SystemOrdinaryProgram
        v3SystemCompilerControlPlane

    V3SystemLinkPlanStub =
        entryPath: str
        outputPath: str
        targetTriple: str
        emitKind: creq.V3CompilerEmit
        packageRoot: str
        workspaceRoot: str
        packageId: str
        moduleStem: str
        moduleKind: V3SystemModuleKind
        sourceClosurePaths: str[]
        ownerModulePaths: str[]
        importEdgeCount: int32
        unresolvedImportCount: int32
        hasCompilerTopLevel: bool
        mainFunctionPresent: bool
        runtimeTargets: str[]
        providerModules: str[]
        entrySymbol: str
        missingReasons: str[]
        parserSyntaxTag: str
        parserSourceKind: int32
        buildEntryPath: str
        buildSourceUnitCount: int32
        linkMode: str
        pipelineStage: str

fn v3SystemModuleKindText(kind: V3SystemModuleKind): str =
    if kind == v3SystemCompilerControlPlane:
        return "compiler_control_plane"
    return "ordinary_program"

fn v3SystemLinkPlanListText(items: str[]): str =
    if items.len <= 0:
        return "-"
    var out = ""
    for i in 0..<items.len:
        if len(out) > 0:
            out = out + ","
        out = out + items[i]
    return out

fn v3SystemLinkPlanAppendLine(out: var str, key: str, value: str) =
    if len(out) > 0:
        out = out + "\n"
    out = out + key + "=" + value

fn v3SystemLinkPlanDeriveModuleKind(parsed: parser.V3ParsedSourceStub): V3SystemModuleKind =
    for i in 0..<parsed.ownerModulePaths.len:
        if parsed.ownerModulePaths[i] == "cheng/v3/tooling/compiler_main":
            return v3SystemCompilerControlPlane
    return v3SystemOrdinaryProgram

fn v3SystemLinkPlanDeriveEntrySymbol(parsed: parser.V3ParsedSourceStub, emitKind: creq.V3CompilerEmit): str =
    if emitKind == creq.v3EmitExe && parsed.mainFunctionPresent:
        return "main"
    return ""

fn v3SystemLinkPlanDeriveExecutionTrack(moduleKind: V3SystemModuleKind): crun.V3CompilerExecutionTrack =
    if moduleKind == v3SystemCompilerControlPlane:
        return crun.v3CompilerTrackTooling
    return crun.v3CompilerTrackProgram

fn v3SystemLinkPlanWorkspaceRoot(plan: V3SystemLinkPlanStub): str =
    return plan.workspaceRoot

fn v3SystemLinkPlanPackageRoot(plan: V3SystemLinkPlanStub): str =
    return plan.packageRoot

fn v3SystemLinkPlanPackageId(plan: V3SystemLinkPlanStub): str =
    return plan.packageId

fn v3SystemLinkPlanEntryPath(plan: V3SystemLinkPlanStub): str =
    return plan.entryPath

fn v3SystemLinkPlanOutputPath(plan: V3SystemLinkPlanStub): str =
    return plan.outputPath

fn v3SystemLinkPlanTargetTriple(plan: V3SystemLinkPlanStub): str =
    return plan.targetTriple

fn v3SystemLinkPlanEmitKind(plan: V3SystemLinkPlanStub): creq.V3CompilerEmit =
    return plan.emitKind

fn v3SystemLinkPlanModuleStem(plan: V3SystemLinkPlanStub): str =
    return plan.moduleStem

fn v3SystemLinkPlanModuleKind(plan: V3SystemLinkPlanStub): V3SystemModuleKind =
    return plan.moduleKind

fn v3SystemLinkPlanOwnerModulePaths(plan: V3SystemLinkPlanStub): str[] =
    return plan.ownerModulePaths

fn v3SystemLinkPlanImportEdgeCount(plan: V3SystemLinkPlanStub): int32 =
    return plan.importEdgeCount

fn v3SystemLinkPlanUnresolvedImportCount(plan: V3SystemLinkPlanStub): int32 =
    return plan.unresolvedImportCount

fn v3SystemLinkPlanHasCompilerTopLevel(plan: V3SystemLinkPlanStub): bool =
    return plan.hasCompilerTopLevel

fn v3SystemLinkPlanMainFunctionPresent(plan: V3SystemLinkPlanStub): bool =
    return plan.mainFunctionPresent

fn v3SystemLinkPlanRuntimeTargets(plan: V3SystemLinkPlanStub): str[] =
    return plan.runtimeTargets

fn v3SystemLinkPlanProviderModules(plan: V3SystemLinkPlanStub): str[] =
    return plan.providerModules

fn v3SystemLinkPlanEntrySymbol(plan: V3SystemLinkPlanStub): str =
    return plan.entrySymbol

fn v3SystemLinkPlanSourceClosurePaths(plan: V3SystemLinkPlanStub): str[] =
    return plan.sourceClosurePaths

fn v3SystemLinkPlanMissingReasonsField(plan: V3SystemLinkPlanStub): str[] =
    return plan.missingReasons

fn v3SystemLinkPlanParserSyntaxTag(plan: V3SystemLinkPlanStub): str =
    return plan.parserSyntaxTag

fn v3SystemLinkPlanParserSourceKind(plan: V3SystemLinkPlanStub): int32 =
    return plan.parserSourceKind

fn v3SystemLinkPlanBuildEntryPath(plan: V3SystemLinkPlanStub): str =
    return plan.buildEntryPath

fn v3SystemLinkPlanBuildSourceUnitCount(plan: V3SystemLinkPlanStub): int32 =
    return plan.buildSourceUnitCount

fn v3SystemLinkPlanLinkMode(plan: V3SystemLinkPlanStub): str =
    return plan.linkMode

fn v3SystemLinkPlanPipelineStage(plan: V3SystemLinkPlanStub): str =
    return plan.pipelineStage

fn v3SystemLinkPlanMissingReasons(parsed: parser.V3ParsedSourceStub,
                                  emitKind: creq.V3CompilerEmit,
                                  runtimeTargets: str[],
                                  providerModules: str[],
                                  entrySymbol: str): str[] =
    var missing: str[] = []
    if parsed.orderedClosureSourcePaths.len <= 0:
        add(missing, "source_closure_missing")
    if parsed.unresolvedImportCount > 0:
        add(missing, "source_closure_unresolved_imports")
    if !parsed.hasCompilerTopLevel:
        add(missing, "compiler_top_level_missing")
    if emitKind == creq.v3EmitExe && len(entrySymbol) <= 0:
        add(missing, "program_entry_symbol_missing")
    if emitKind == creq.v3EmitExe && runtimeTargets.len <= 0:
        add(missing, "runtime_targets_not_lowered")
    if emitKind == creq.v3EmitExe && providerModules.len <= 0:
        add(missing, "runtime_provider_modules_not_selected")
    return missing

fn v3BuildSystemLinkPlanStub(rootDir: str,
                             req: creq.V3CompilerRequest,
                             plan: var V3SystemLinkPlanStub,
                             err: var str): bool =
    let _ = rootDir
    let requestPackageRoot = creq.v3CompilerRequestRootDir(req)
    let requestSourcePath = creq.v3CompilerRequestSourcePath(req)
    let requestOutputPath = creq.v3CompilerRequestOutputPath(req)
    let requestTargetTriple = creq.v3CompilerRequestTargetTriple(req)
    let requestEmitKind = creq.v3CompilerRequestEmitKind(req)
    var parsed: parser.V3ParsedSourceStub
    if !parser.v3ParseOrdinarySourceStub(requestPackageRoot, requestSourcePath, parsed, err):
        return false
    var toolingTrack = false
    for i in 0..<parsed.ownerModulePaths.len:
        if parsed.ownerModulePaths[i] == "cheng/v3/tooling/compiler_main":
            toolingTrack = true
    var runtimeTargets: str[] = []
    var providerModules: str[] = []
    if toolingTrack:
        add(runtimeTargets, crun.v3CompilerToolingArgvRuntimeTarget())
    else:
        add(runtimeTargets, crun.v3CompilerProgramArgvRuntimeTarget())
    add(providerModules, crun.v3CompilerRuntimeProviderModule())
    add(providerModules, crun.v3CoreRuntimeProviderModule())
    add(providerModules, crun.v3ProgramSupportProviderModule())
    let entrySymbol = v3SystemLinkPlanDeriveEntrySymbol(parsed, requestEmitKind)
    let missing = v3SystemLinkPlanMissingReasons(parsed, requestEmitKind, runtimeTargets, providerModules, entrySymbol)
    let linkMode = buildplan.v3BackendBuildPlanDefaultLinkMode()
    let buildSourceUnitCount = buildplan.v3BackendBuildPlanDefaultSourceUnitCount()
    let parsedWorkspaceRoot = parser.v3ParsedSourceWorkspaceRoot(parsed)
    let buildEntryPath = buildplan.v3BackendBuildPlanDefaultEntryPath(parsedWorkspaceRoot)
    plan.entryPath = requestSourcePath
    plan.outputPath = requestOutputPath
    plan.targetTriple = requestTargetTriple
    plan.emitKind = requestEmitKind
    plan.packageRoot = parsed.packageRoot
    plan.workspaceRoot = parsed.workspaceRoot
    plan.packageId = parsed.packageId
    plan.moduleStem = parsed.moduleStem
    plan.moduleKind = v3SystemOrdinaryProgram
    if toolingTrack:
        plan.moduleKind = v3SystemCompilerControlPlane
    plan.sourceClosurePaths = parsed.orderedClosureSourcePaths
    plan.ownerModulePaths = parsed.ownerModulePaths
    plan.importEdgeCount = parsed.importEdges.len
    plan.unresolvedImportCount = parsed.unresolvedImportCount
    plan.hasCompilerTopLevel = parsed.hasCompilerTopLevel
    plan.mainFunctionPresent = parsed.mainFunctionPresent
    plan.runtimeTargets = runtimeTargets
    plan.providerModules = providerModules
    plan.entrySymbol = entrySymbol
    plan.missingReasons = missing
    plan.parserSyntaxTag = parsed.syntaxTag
    plan.parserSourceKind = int32(parsed.sourceKind)
    plan.buildEntryPath = buildEntryPath
    plan.buildSourceUnitCount = buildSourceUnitCount
    plan.linkMode = linkMode
    plan.pipelineStage = "parser_stub_to_system_link_plan_stub"
    err = ""
    return true

fn v3SystemLinkPlanStubReport(plan: V3SystemLinkPlanStub): str =
    var out: str = ""
    let entryPath = v3SystemLinkPlanEntryPath(plan)
    let outputPath = v3SystemLinkPlanOutputPath(plan)
    let targetTriple = v3SystemLinkPlanTargetTriple(plan)
    let emitKind = v3SystemLinkPlanEmitKind(plan)
    let emitText = creq.v3CompilerEmitText(emitKind)
    let workspaceRoot = v3SystemLinkPlanWorkspaceRoot(plan)
    let packageRoot = v3SystemLinkPlanPackageRoot(plan)
    let packageId = v3SystemLinkPlanPackageId(plan)
    let moduleStem = v3SystemLinkPlanModuleStem(plan)
    let moduleKind = v3SystemLinkPlanModuleKind(plan)
    let moduleKindText = v3SystemModuleKindText(moduleKind)
    let sourceClosurePaths = v3SystemLinkPlanSourceClosurePaths(plan)
    let sourceClosureCount = intToStr(sourceClosurePaths.len)
    let sourceClosureList = v3SystemLinkPlanListText(sourceClosurePaths)
    let ownerModulePaths = v3SystemLinkPlanOwnerModulePaths(plan)
    let ownerModuleList = v3SystemLinkPlanListText(ownerModulePaths)
    let importEdgeCount = intToStr(v3SystemLinkPlanImportEdgeCount(plan))
    let unresolvedImportCount = intToStr(v3SystemLinkPlanUnresolvedImportCount(plan))
    let hasCompilerTopLevel = v3SystemLinkPlanHasCompilerTopLevel(plan) ? "1" : "0"
    let mainFunctionPresent = v3SystemLinkPlanMainFunctionPresent(plan) ? "1" : "0"
    let runtimeTargets = v3SystemLinkPlanRuntimeTargets(plan)
    let runtimeTargetList = v3SystemLinkPlanListText(runtimeTargets)
    let providerModules = v3SystemLinkPlanProviderModules(plan)
    let providerModuleList = v3SystemLinkPlanListText(providerModules)
    var entrySymbol = v3SystemLinkPlanEntrySymbol(plan)
    let missingField = v3SystemLinkPlanMissingReasonsField(plan)
    let missingReasons = v3SystemLinkPlanListText(missingField)
    let parserSyntax = v3SystemLinkPlanParserSyntaxTag(plan)
    let parserSourceKind = v3SystemLinkPlanParserSourceKind(plan)
    let parserSourceKindText = v3SystemLinkPlanParserSourceKindText(parserSourceKind)
    let buildEntry = v3SystemLinkPlanBuildEntryPath(plan)
    let buildSourceUnitCount = intToStr(v3SystemLinkPlanBuildSourceUnitCount(plan))
    let linkMode = v3SystemLinkPlanLinkMode(plan)
    let pipelineStage = v3SystemLinkPlanPipelineStage(plan)
    if len(entrySymbol) <= 0:
        entrySymbol = "-"
    v3SystemLinkPlanAppendLine(out, "entry", entryPath)
    v3SystemLinkPlanAppendLine(out, "output", outputPath)
    v3SystemLinkPlanAppendLine(out, "target", targetTriple)
    v3SystemLinkPlanAppendLine(out, "emit", emitText)
    v3SystemLinkPlanAppendLine(out, "workspace_root", workspaceRoot)
    v3SystemLinkPlanAppendLine(out, "package_root", packageRoot)
    v3SystemLinkPlanAppendLine(out, "package_id", packageId)
    v3SystemLinkPlanAppendLine(out, "module_stem", moduleStem)
    v3SystemLinkPlanAppendLine(out, "module_kind", moduleKindText)
    v3SystemLinkPlanAppendLine(out, "source_closure_count", sourceClosureCount)
    v3SystemLinkPlanAppendLine(out, "source_closure_paths", sourceClosureList)
    v3SystemLinkPlanAppendLine(out, "owner_modules", ownerModuleList)
    v3SystemLinkPlanAppendLine(out, "import_edge_count", importEdgeCount)
    v3SystemLinkPlanAppendLine(out, "unresolved_import_count", unresolvedImportCount)
    v3SystemLinkPlanAppendLine(out, "has_compiler_top_level", hasCompilerTopLevel)
    v3SystemLinkPlanAppendLine(out, "main_function_present", mainFunctionPresent)
    v3SystemLinkPlanAppendLine(out, "runtime_targets", runtimeTargetList)
    v3SystemLinkPlanAppendLine(out, "provider_modules", providerModuleList)
    v3SystemLinkPlanAppendLine(out, "entry_symbol", entrySymbol)
    v3SystemLinkPlanAppendLine(out, "missing_reasons", missingReasons)
    v3SystemLinkPlanAppendLine(out, "parser_syntax", parserSyntax)
    v3SystemLinkPlanAppendLine(out, "parser_source_kind", parserSourceKindText)
    v3SystemLinkPlanAppendLine(out, "build_entry", buildEntry)
    v3SystemLinkPlanAppendLine(out, "build_source_unit_count", buildSourceUnitCount)
    v3SystemLinkPlanAppendLine(out, "link_mode", linkMode)
    v3SystemLinkPlanAppendLine(out, "pipeline_stage", pipelineStage)
    return out
fn v3SystemLinkPlanParserSourceKindText(kind: int32): str =
    if kind == int32(parser.v3ParsedOrdinarySource):
        return parser.v3ParsedSourceKindText(parser.v3ParsedOrdinarySource)
    return "unknown"
