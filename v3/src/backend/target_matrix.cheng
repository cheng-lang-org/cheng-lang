fn v3TargetIsDarwinArm64(targetTriple: str): bool =
    return targetTriple == "arm64-apple-darwin"

fn v3TargetIsWasm(targetTriple: str): bool =
    return targetTriple == "wasm32-unknown-unknown"

fn v3TargetIsLinuxX8664(targetTriple: str): bool =
    return targetTriple == "x86_64-unknown-linux-gnu"

fn v3TargetIsLinuxAarch64(targetTriple: str): bool =
    return targetTriple == "aarch64-unknown-linux-gnu" || targetTriple == "arm64-unknown-linux-gnu"

fn v3TargetIsLinuxRiscv64(targetTriple: str): bool =
    return targetTriple == "riscv64-unknown-linux-gnu"

fn v3TargetIsWindowsAarch64(targetTriple: str): bool =
    return targetTriple == "aarch64-pc-windows-msvc" || targetTriple == "arm64-pc-windows-msvc"

fn v3TargetIsWindowsX8664(targetTriple: str): bool =
    return targetTriple == "x86_64-pc-windows-msvc"

fn v3TargetIsWindows(targetTriple: str): bool =
    return v3TargetIsWindowsAarch64(targetTriple) ||
           v3TargetIsWindowsX8664(targetTriple)

fn v3TargetIsElfObject(targetTriple: str): bool =
    return v3TargetIsLinuxAarch64(targetTriple) ||
           v3TargetIsLinuxX8664(targetTriple) ||
           v3TargetIsLinuxRiscv64(targetTriple)

fn v3TargetIsCoffObject(targetTriple: str): bool =
    return v3TargetIsWindows(targetTriple)

fn v3TargetUsesLinuxNolibcRuntime(targetTriple: str): bool =
    return v3TargetIsLinuxAarch64(targetTriple)

fn v3TargetNeedsNativeProviders(targetTriple: str): bool =
    return !v3TargetIsWasm(targetTriple)

fn v3TargetRequiresNativeProviderModules(targetTriple: str): bool =
    return v3TargetNeedsNativeProviders(targetTriple) &&
           !v3TargetUsesLinuxNolibcRuntime(targetTriple)

fn v3TargetPrimaryObjectFormat(targetTriple: str): str =
    if v3TargetIsDarwinArm64(targetTriple):
        return "macho"
    if v3TargetIsWasm(targetTriple):
        return "wasm"
    if v3TargetIsCoffObject(targetTriple):
        return "coff"
    if v3TargetIsElfObject(targetTriple):
        return "elf"
    return "unknown"

fn v3TargetLinkerFlavor(targetTriple: str): str =
    if v3TargetIsDarwinArm64(targetTriple):
        return "ld64"
    if v3TargetUsesLinuxNolibcRuntime(targetTriple):
        return "elf_aarch64_nolibc_internal"
    if v3TargetIsLinuxRiscv64(targetTriple):
        return "elf_riscv64_builtin"
    if v3TargetIsWindows(targetTriple):
        return "coff_pe_builtin"
    return "system_linker"

fn v3TargetLinkerProgram(targetTriple: str): str =
    if v3TargetUsesLinuxNolibcRuntime(targetTriple):
        return "internal_elf_linker"
    if v3TargetIsLinuxRiscv64(targetTriple):
        return "builtin_elf_linker_riscv64"
    if v3TargetIsWindows(targetTriple):
        return "builtin_coff_linker"
    return "cc"

fn V3TargetIsWindows(targetTriple: str): bool =
    return v3TargetIsWindows(targetTriple)
