import ../lang/intern as langintern

type
    V3ModuleId = int32

    V3FuncId = int32

    V3BlockId = int32

    V3TypeId = int32

    V3ValueId = int32

    V3StackSlotId = int32

type
    V3AbiClass = enum
        v3AbiNone,
        v3AbiScalar,
        v3AbiPointer,
        v3AbiAggregate,
        v3AbiVector

type
    V3LayoutKind = enum
        v3LayoutInvalid,
        v3LayoutVoid,
        v3LayoutI1,
        v3LayoutI8,
        v3LayoutI16,
        v3LayoutI32,
        v3LayoutI64,
        v3LayoutFixedBytes,
        v3LayoutArray,
        v3LayoutRecord,
        v3LayoutPointer

type
    V3OwnershipKind = enum
        v3OwnInvalid,
        v3OwnPlain,
        v3OwnMove,
        v3OwnBorrowShared,
        v3OwnBorrowUnique

type
    V3AliasClass = enum
        v3AliasUnknown,
        v3AliasUnique,
        v3AliasNoAlias,
        v3AliasMayAlias

type
    V3EscapeKind = enum
        v3EscapeInvalid,
        v3EscapeNone,
        v3EscapeArg,
        v3EscapeReturn,
        v3EscapeGlobal

type
    V3ValueKind = enum
        v3ValueInvalid,
        v3ValueImmediate,
        v3ValueStack,
        v3ValueAddress,
        v3ValueBorrow,
        v3ValuePhi,
        v3ValueCallResult

type
    V3HirExprKind = enum
        v3HirInvalid,
        v3HirIntLiteral,
        v3HirBytesLiteral,
        v3HirNameRef,
        v3HirCall,
        v3HirField,
        v3HirIndex,
        v3HirBorrow,
        v3HirMove

type
    V3MirOpKind = enum
        v3MirInvalid,
        v3MirConst,
        v3MirMove,
        v3MirBorrow,
        v3MirLoad,
        v3MirStore,
        v3MirAddrOf,
        v3MirCall,
        v3MirPhi,
        v3MirRet,
        v3MirTrap

type
    V3CallConv = enum
        v3CallInvalid,
        v3CallInternal,
        v3CallC

type
    V3LirInsnKind = enum
        v3LirInvalid,
        v3LirMove,
        v3LirLoad,
        v3LirStore,
        v3LirCall,
        v3LirRet,
        v3LirTrap

type
    V3TypeLayout =
        kind: V3LayoutKind
        abiClass: V3AbiClass
        size: int32
        align: int32
        fixedCount: int32
        fieldCount: int32
        isTriviallyMoveable: bool
        isTriviallyDrop: bool

    V3Place =
        baseValue: V3ValueId
        typeId: V3TypeId
        offset: int32
        fieldOrdinal: int32
        ownership: V3OwnershipKind
        aliasClass: V3AliasClass
        escapeKind: V3EscapeKind

    V3BorrowFact =
        ownerValue: V3ValueId
        place: V3Place
        borrowKind: V3OwnershipKind
        aliasClass: V3AliasClass
        escapeKind: V3EscapeKind
        scopeDepth: int32

    V3MirValue =
        id: V3ValueId
        typeId: V3TypeId
        kind: V3ValueKind
        ownership: V3OwnershipKind
        aliasClass: V3AliasClass
        escapeKind: V3EscapeKind
        stackSlot: V3StackSlotId
        immLo: int64
        immHi: int64

    V3MirOp =
        kind: V3MirOpKind
        result: V3ValueId
        src0: V3ValueId
        src1: V3ValueId
        src2: V3ValueId
        place: V3Place
        callConv: V3CallConv
        calleeNameId: langintern.V3InternId
        trapTextId: langintern.V3InternId

    V3MirStackSlot =
        id: V3StackSlotId
        typeId: V3TypeId
        offset: int32
        size: int32
        align: int32
        noAlias: bool

    V3MirBlock =
        id: V3BlockId
        opStart: int32
        opCount: int32

    V3MirFunction = ref
        id: V3FuncId
        nameId: langintern.V3InternId
        paramCount: int32
        resultTypeId: V3TypeId
        stackSlots: V3MirStackSlot[]
        values: V3MirValue[]
        borrowFacts: V3BorrowFact[]
        ops: V3MirOp[]
        blocks: V3MirBlock[]

    V3LirInsn =
        kind: V3LirInsnKind
        dstReg: int32
        srcReg0: int32
        srcReg1: int32
        stackSlot: V3StackSlotId
        callConv: V3CallConv
        calleeNameId: langintern.V3InternId

    V3LirFunction = ref
        id: V3FuncId
        nameId: langintern.V3InternId
        stackSlots: V3MirStackSlot[]
        insns: V3LirInsn[]

fn v3InvalidTypeId(): V3TypeId =
    return -1

fn v3InvalidValueId(): V3ValueId =
    return -1

fn v3InvalidStackSlotId(): V3StackSlotId =
    return -1

fn v3TypeLayoutScalar(kind: V3LayoutKind, size: int32, align: int32): V3TypeLayout =
    return V3TypeLayout(
        kind: kind,
        abiClass: v3AbiScalar,
        size: size,
        align: align,
        fixedCount: 0,
        fieldCount: 0,
        isTriviallyMoveable: true,
        isTriviallyDrop: true
    )

fn v3TypeLayoutFixedBytes(size: int32, align: int32): V3TypeLayout =
    return V3TypeLayout(
        kind: v3LayoutFixedBytes,
        abiClass: v3AbiAggregate,
        size: size,
        align: align,
        fixedCount: size,
        fieldCount: 0,
        isTriviallyMoveable: true,
        isTriviallyDrop: true
    )

fn v3PlaceRoot(baseValue: V3ValueId, typeId: V3TypeId): V3Place =
    return V3Place(
        baseValue: baseValue,
        typeId: typeId,
        offset: 0,
        fieldOrdinal: -1,
        ownership: v3OwnPlain,
        aliasClass: v3AliasUnknown,
        escapeKind: v3EscapeInvalid
    )

fn v3MirFunctionNew(nameId: langintern.V3InternId): V3MirFunction =
    var out: V3MirFunction = new(V3MirFunction)
    out.id = -1
    out.nameId = nameId
    out.paramCount = 0
    out.resultTypeId = v3InvalidTypeId()
    out.stackSlots = []
    out.values = []
    out.borrowFacts = []
    out.ops = []
    out.blocks = []
    return out

fn v3LirFunctionNew(nameId: langintern.V3InternId): V3LirFunction =
    var out: V3LirFunction = new(V3LirFunction)
    out.id = -1
    out.nameId = nameId
    out.stackSlots = []
    out.insns = []
    return out
