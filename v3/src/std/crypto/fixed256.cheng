import std/result
import std/rawbytes
import std/system
import std/crypto/sha256
import std/crypto/curve25519
import std/crypto/ecnist
import ../bytes_layout as layout

const
    p256UncompressedSize: int32 = 65
    p256SignatureSize: int32 = 64

type
    Scalar256 =
        bytes: layout.FixedBytes32

    Field256 =
        bytes: layout.FixedBytes32

    PointAffine256 =
        x: layout.FixedBytes32
        y: layout.FixedBytes32
        infinity: bool

    PointJacobian256 =
        x: layout.FixedBytes32
        y: layout.FixedBytes32
        z: layout.FixedBytes32
        infinity: bool

    P256Signature256 =
        r: layout.FixedBytes32
        s: layout.FixedBytes32

fn scalar256FromBytes(data: Bytes): Result[Scalar256] =
    let fixedRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromBytes(data)
    if IsErr(fixedRes):
        return Err[Scalar256](Error(fixedRes))
    return Ok[Scalar256](Scalar256(bytes: Value(fixedRes)))

fn scalar256FromHex(text: str): Result[Scalar256] =
    let fixedRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(text)
    if IsErr(fixedRes):
        return Err[Scalar256](Error(fixedRes))
    return Ok[Scalar256](Scalar256(bytes: Value(fixedRes)))

fn scalar256ToBytes(value: Scalar256): Bytes =
    return layout.fixedBytes32ToBytes(value.bytes)

fn field256FromBytes(data: Bytes): Result[Field256] =
    let fixedRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromBytes(data)
    if IsErr(fixedRes):
        return Err[Field256](Error(fixedRes))
    return Ok[Field256](Field256(bytes: Value(fixedRes)))

fn field256ToBytes(value: Field256): Bytes =
    return layout.fixedBytes32ToBytes(value.bytes)

fn sha256Fixed(data: layout.ByteSpan): layout.FixedBytes32 =
    let digest: Bytes = sha256.sha256Digest(data.data)
    let digestRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromBytes(digest)
    if IsErr(digestRes):
        system.panicStr("v3 fixed256: sha256 digest width mismatch")
    return Value(digestRes)

fn curve25519PublicKey(priv: Scalar256): Result[layout.FixedBytes32] =
    let pubRes: Result[Bytes] = curve25519.curve25519PublicFromPrivate(scalar256ToBytes(priv))
    if IsErr(pubRes):
        return Err[layout.FixedBytes32](Error(pubRes))
    return layout.fixedBytes32FromBytes(Value(pubRes))

fn curve25519SharedKeyFixed(priv: Scalar256, peerPub: layout.FixedBytes32): Result[layout.FixedBytes32] =
    let sharedRes: Result[Bytes] = curve25519.curve25519SharedKey(scalar256ToBytes(priv), layout.fixedBytes32ToBytes(peerPub))
    if IsErr(sharedRes):
        return Err[layout.FixedBytes32](Error(sharedRes))
    return layout.fixedBytes32FromBytes(Value(sharedRes))

fn fixedBytes32One(): layout.FixedBytes32 =
    var out: layout.FixedBytes32 = layout.fixedBytes32Zero()
    out.data[31] = 1
    return out

fn pointJacobian256FromAffine(point: PointAffine256): PointJacobian256 =
    if point.infinity:
        return PointJacobian256(
            x: layout.fixedBytes32Zero(),
            y: layout.fixedBytes32Zero(),
            z: layout.fixedBytes32Zero(),
            infinity: true
        )
    return PointJacobian256(
        x: point.x,
        y: point.y,
        z: fixedBytes32One(),
        infinity: false
    )

fn pointAffine256FromUncompressedBytes(data: Bytes): Result[PointAffine256] =
    if bytesLen(data) != p256UncompressedSize:
        return Err[PointAffine256]("v3 fixed256: invalid P-256 public key size")
    if bytesGet(data, 0) != 0x04:
        return Err[PointAffine256]("v3 fixed256: invalid P-256 public key prefix")
    let xRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromBytes(bytesSliceView(data, 1, 32))
    if IsErr(xRes):
        return Err[PointAffine256](Error(xRes))
    let yRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromBytes(bytesSliceView(data, 33, 32))
    if IsErr(yRes):
        return Err[PointAffine256](Error(yRes))
    return Ok[PointAffine256](PointAffine256(x: Value(xRes), y: Value(yRes), infinity: false))

fn pointAffine256ToUncompressedBytes(point: PointAffine256): Bytes =
    let out: Bytes = bytesAlloc(p256UncompressedSize)
    bytesSet(out, 0, 0x04)
    let xBytes: Bytes = layout.fixedBytes32ToBytes(point.x)
    let yBytes: Bytes = layout.fixedBytes32ToBytes(point.y)
    for i in 0..<32:
        bytesSet(out, 1 + i, bytesGet(xBytes, i))
    for i in 0..<32:
        bytesSet(out, 33 + i, bytesGet(yBytes, i))
    return out

fn p256SignatureFromBytes(data: Bytes): Result[P256Signature256] =
    if bytesLen(data) != p256SignatureSize:
        return Err[P256Signature256]("v3 fixed256: invalid P-256 signature size")
    let rRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromBytes(bytesSliceView(data, 0, 32))
    if IsErr(rRes):
        return Err[P256Signature256](Error(rRes))
    let sRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromBytes(bytesSliceView(data, 32, 32))
    if IsErr(sRes):
        return Err[P256Signature256](Error(sRes))
    return Ok[P256Signature256](P256Signature256(r: Value(rRes), s: Value(sRes)))

fn p256SignatureToBytes(sig: P256Signature256): Bytes =
    let out: Bytes = bytesAlloc(p256SignatureSize)
    let rBytes: Bytes = layout.fixedBytes32ToBytes(sig.r)
    let sBytes: Bytes = layout.fixedBytes32ToBytes(sig.s)
    for i in 0..<32:
        bytesSet(out, i, bytesGet(rBytes, i))
    for i in 0..<32:
        bytesSet(out, 32 + i, bytesGet(sBytes, i))
    return out

fn p256PublicKeyAffine(priv: Scalar256): Result[PointAffine256] =
    let pubRes: Result[Bytes] = ecnist.ecdsaPublicKeyFromPrivateBytes(scalar256ToBytes(priv))
    if IsErr(pubRes):
        return Err[PointAffine256](Error(pubRes))
    return pointAffine256FromUncompressedBytes(Value(pubRes))

fn p256SignMessageFixed(priv: Scalar256, msg: layout.ByteSpan): Result[P256Signature256] =
    let sigRes: Result[Bytes] = ecnist.ecdsaSignBytes(scalar256ToBytes(priv), msg.data)
    if IsErr(sigRes):
        return Err[P256Signature256](Error(sigRes))
    return p256SignatureFromBytes(Value(sigRes))

fn p256VerifyMessageFixed(pub: PointAffine256, msg: layout.ByteSpan, sig: P256Signature256): bool =
    let pubBytes: Bytes = pointAffine256ToUncompressedBytes(pub)
    let sigBytes: Bytes = p256SignatureToBytes(sig)
    return ecnist.ecdsaVerifyBytes(pubBytes, msg.data, sigBytes)
