    let bodyRes = v3DiLoCoWireDecodeBodyText(payload, v3DiLoCoMessageFetchLineage, body)
    if IsErr(bodyRes):
        return Err[bool](Error(bodyRes))
    out = V3DiLoCoFetchLineageRequest()
    let jobBundleCidRes = v3DiLoCoWireRequireFixed32(body, "job_bundle_cid")
    if IsErr(jobBundleCidRes):
        return Err[bool](Error(jobBundleCidRes))
    out.jobBundleCid = Value(jobBundleCidRes)
    return Ok[bool](true)

fn v3DiLoCoFetchLineageResponseEncode(resp: V3DiLoCoFetchLineageResponse): Bytes =
    var body = ""
    body = v3DiLoCoWireAppendGlobalVersionArray(body, "versions", resp.versions)
    return v3DiLoCoWireEncodeBodyEnvelope(v3DiLoCoMessageFetchLineage, body)

fn V3DiLoCoFetchLineageResponseEncodeVersions(versions: core.V3DiLoCoGlobalVersion[]): Bytes =
    var body = ""
    body = v3DiLoCoWireAppendGlobalVersionArray(body, "versions", versions)
    return v3DiLoCoWireEncodeBodyEnvelope(v3DiLoCoMessageFetchLineage, body)

fn V3DiLoCoFetchLineageResponseEncodePair(head: core.V3DiLoCoGlobalVersion,
                                          tail: core.V3DiLoCoGlobalVersion): Bytes =
    var versions: core.V3DiLoCoGlobalVersion[]
    versions = []
    add(versions, head)
    add(versions, tail)
    return V3DiLoCoFetchLineageResponseEncodeVersions(versions)

fn v3DiLoCoFetchLineageResponseDecodeFill(out: var V3DiLoCoFetchLineageResponse,
                                          payload: Bytes): Result[bool] =
    var body = ""
    let bodyRes = v3DiLoCoWireDecodeBodyText(payload, v3DiLoCoMessageFetchLineage, body)
    if IsErr(bodyRes):
        return Err[bool](Error(bodyRes))
    out = V3DiLoCoFetchLineageResponse()
    return v3DiLoCoWireParseGlobalVersionArrayFill(out.versions, body, "versions")

fn V3DiLoCoFetchLineageResponseDecodeOkFill(out: var V3DiLoCoFetchLineageResponse,
                                            payload: Bytes): bool =
    let res = v3DiLoCoFetchLineageResponseDecodeFill(out, payload)
    return res.ok

