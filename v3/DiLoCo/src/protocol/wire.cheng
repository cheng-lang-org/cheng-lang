fn v3DiLoCoWireAppendOuterDelta(out: str,
                                prefix: str,
                                delta: core.V3DiLoCoOuterDelta): str =
    var next = out
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(delta.jobBundleCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "delta_cid"), layout.FixedBytes32Hex(delta.deltaCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "base_version_cid"), layout.FixedBytes32Hex(delta.baseVersionCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "outer_step"), intToStr(delta.outerStep))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "publisher_peer_id"), peer_id.V3Libp2pPeerIdText(delta.publisherPeerId))
    next = v3DiLoCoWireAppendArtifactRef(next, v3DiLoCoWireField(prefix, "model_delta_ref"), delta.modelDeltaRef)
    next = v3DiLoCoWireAppendArtifactRef(next, v3DiLoCoWireField(prefix, "optimizer_delta_ref"), delta.optimizerDeltaRef)
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "sample_count"), intToStr(delta.sampleCount))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "token_count"), intToStr(delta.tokenCount))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "inner_step_count"), intToStr(delta.innerStepCount))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "weight_numerator"), intToStr(delta.weightNumerator))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "weight_denominator"), intToStr(delta.weightDenominator))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "submitted_at_epoch_seconds"), intToStr(int32(delta.submittedAtEpochSeconds)))
    return next

