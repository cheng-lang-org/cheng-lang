fn v3DiLoCoWireAppendGlobalVersion(out: str,
                                   prefix: str,
                                   version: core.V3DiLoCoGlobalVersion): str =
    var next = out
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(version.jobBundleCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "version_cid"), layout.FixedBytes32Hex(version.versionCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "base_version_cid"), layout.FixedBytes32Hex(version.baseVersionCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "committed_outer_step"), intToStr(version.committedOuterStep))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "publisher_peer_id"), peer_id.V3Libp2pPeerIdText(version.publisherPeerId))
    next = v3DiLoCoWireAppendArtifactRef(next, v3DiLoCoWireField(prefix, "model_ref"), version.modelRef)
    next = v3DiLoCoWireAppendArtifactRef(next, v3DiLoCoWireField(prefix, "optimizer_ref"), version.optimizerRef)
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "accepted_count"), intToStr(version.acceptedCount))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "committed_at_epoch_seconds"), intToStr(int32(version.committedAtEpochSeconds)))
    return next

fn v3DiLoCoWireParseGlobalVersionFill(out: var core.V3DiLoCoGlobalVersion,
                                      wire: str,
                                      prefix: str): Result[bool] =
    out = core.V3DiLoCoGlobalVersion()
    let jobBundleCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "job_bundle_cid"))
    if IsErr(jobBundleCidRes):
        return Err[bool](Error(jobBundleCidRes))
    let versionCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "version_cid"))
    if IsErr(versionCidRes):
        return Err[bool](Error(versionCidRes))
    let baseVersionCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "base_version_cid"))
    if IsErr(baseVersionCidRes):
        return Err[bool](Error(baseVersionCidRes))
    let committedOuterStepRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "committed_outer_step"))
    if IsErr(committedOuterStepRes):
        return Err[bool](Error(committedOuterStepRes))
