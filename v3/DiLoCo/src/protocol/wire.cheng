    out = core.V3DiLoCoStepStatus()
    let jobBundleCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "job_bundle_cid"))
    if IsErr(jobBundleCidRes):
        return Err[bool](Error(jobBundleCidRes))
    let baseVersionCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "base_version_cid"))
    if IsErr(baseVersionCidRes):
        return Err[bool](Error(baseVersionCidRes))
    let outerStepRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "outer_step"))
    if IsErr(outerStepRes):
        return Err[bool](Error(outerStepRes))
    let barrierReadyRes = v3DiLoCoWireRequireBool(wire, v3DiLoCoWireField(prefix, "barrier_ready"))
    if IsErr(barrierReadyRes):
        return Err[bool](Error(barrierReadyRes))
    let barrierArrivedRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "barrier_arrived_count"))
    if IsErr(barrierArrivedRes):
        return Err[bool](Error(barrierArrivedRes))
    let expectedCountRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "expected_member_count"))
    if IsErr(expectedCountRes):
        return Err[bool](Error(expectedCountRes))
    let contributionCountRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "contribution_count"))
    if IsErr(contributionCountRes):
        return Err[bool](Error(contributionCountRes))
    let commitPublishedRes = v3DiLoCoWireRequireBool(wire, v3DiLoCoWireField(prefix, "commit_published"))
    if IsErr(commitPublishedRes):
        return Err[bool](Error(commitPublishedRes))
    let mergeCommitCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "merge_commit_cid"))
    if IsErr(mergeCommitCidRes):
        return Err[bool](Error(mergeCommitCidRes))
    out.jobBundleCid = Value(jobBundleCidRes)
    out.baseVersionCid = Value(baseVersionCidRes)
    out.outerStep = Value(outerStepRes)
    out.barrierReady = Value(barrierReadyRes)
    out.barrierArrivedCount = Value(barrierArrivedRes)
    out.expectedMemberCount = Value(expectedCountRes)
    out.contributionCount = Value(contributionCountRes)
    out.commitPublished = Value(commitPublishedRes)
    out.mergeCommitCid = Value(mergeCommitCidRes)
    return Ok[bool](true)

fn v3DiLoCoWireAppendGlobalVersionArray(out: str,
                                        prefix: str,
                                        versions: core.V3DiLoCoGlobalVersion[]): str =
    var next = did.V3DidStoreAppendLine(out, v3DiLoCoWireField(prefix, "count"), intToStr(versions.len))
    for i in 0..<versions.len:
        next = v3DiLoCoWireAppendGlobalVersion(next,
                                               v3DiLoCoWireField(prefix, intToStr(i)),
                                               versions[i])
    return next

fn v3DiLoCoWireParseGlobalVersionArrayFill(out: var core.V3DiLoCoGlobalVersion[],
                                           wire: str,
                                           prefix: str): Result[bool] =
    let countRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "count"))
    if IsErr(countRes):
        return Err[bool](Error(countRes))
    out = []
    for i in 0..<Value(countRes):
        add(out, core.V3DiLoCoGlobalVersion())
        let versionRes = v3DiLoCoWireParseGlobalVersionFill(out[out.len - 1],
                                                            wire,
                                                            v3DiLoCoWireField(prefix, intToStr(i)))
        if IsErr(versionRes):
            return Err[bool](Error(versionRes))
    return Ok[bool](true)

