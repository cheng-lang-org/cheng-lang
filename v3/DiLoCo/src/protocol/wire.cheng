    if IsErr(publisherPeerIdRes):
        return Err[bool](Error(publisherPeerIdRes))
    var modelRef = core.V3DiLoCoArtifactRef()
    let modelRefRes = v3DiLoCoWireParseArtifactRefFill(modelRef, wire, v3DiLoCoWireField(prefix, "model_ref"))
    if IsErr(modelRefRes):
        return Err[bool](Error(modelRefRes))
    var optimizerRef = core.V3DiLoCoArtifactRef()
    let optimizerRefRes = v3DiLoCoWireParseArtifactRefFill(optimizerRef, wire, v3DiLoCoWireField(prefix, "optimizer_ref"))
    if IsErr(optimizerRefRes):
        return Err[bool](Error(optimizerRefRes))
    let acceptedCountRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "accepted_count"))
    if IsErr(acceptedCountRes):
        return Err[bool](Error(acceptedCountRes))
    let committedAtRes = v3DiLoCoWireRequireI64(wire, v3DiLoCoWireField(prefix, "committed_at_epoch_seconds"))
    if IsErr(committedAtRes):
        return Err[bool](Error(committedAtRes))
    out.jobBundleCid = Value(jobBundleCidRes)
    out.versionCid = Value(versionCidRes)
    out.baseVersionCid = Value(baseVersionCidRes)
    out.committedOuterStep = Value(committedOuterStepRes)
    out.publisherPeerId.value = Value(publisherPeerIdRes).value
    out.modelRef.stubCid = modelRef.stubCid
    out.modelRef.blobSummaryCid = modelRef.blobSummaryCid
    out.modelRef.manifestCid = modelRef.manifestCid
    out.modelRef.blobCid = modelRef.blobCid
    out.modelRef.payloadLen = modelRef.payloadLen
    out.modelRef.paramsCid = modelRef.paramsCid
    out.modelRef.layoutKind = modelRef.layoutKind
    out.modelRef.dataShardCount = modelRef.dataShardCount
    out.modelRef.parityShardCount = modelRef.parityShardCount
    out.modelRef.shardPayloadBytes = modelRef.shardPayloadBytes
    out.optimizerRef.stubCid = optimizerRef.stubCid
    out.optimizerRef.blobSummaryCid = optimizerRef.blobSummaryCid
    out.optimizerRef.manifestCid = optimizerRef.manifestCid
    out.optimizerRef.blobCid = optimizerRef.blobCid
    out.optimizerRef.payloadLen = optimizerRef.payloadLen
    out.optimizerRef.paramsCid = optimizerRef.paramsCid
    out.optimizerRef.layoutKind = optimizerRef.layoutKind
    out.optimizerRef.dataShardCount = optimizerRef.dataShardCount
    out.optimizerRef.parityShardCount = optimizerRef.parityShardCount
    out.optimizerRef.shardPayloadBytes = optimizerRef.shardPayloadBytes
    out.acceptedCount = Value(acceptedCountRes)
    out.committedAtEpochSeconds = Value(committedAtRes)
    return Ok[bool](true)

