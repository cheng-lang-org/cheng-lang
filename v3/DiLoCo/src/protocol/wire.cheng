import std/result
import std/rawbytes
import std/strings
import cheng/v3/std/bytes_layout as layout
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peer_id
import cheng/v3/libp2p/identity/did
import cheng/v3/DiLoCo/core/diloco as core

const
    v3DiLoCoWireVersion: int32 = 1
    v3DiLoCoWireMagic: int32 = 0x444c4331

    v3DiLoCoMessageOpenJob: int32 = 1
    v3DiLoCoMessageJoinCohort: int32 = 2
    v3DiLoCoMessageFetchLease: int32 = 3
    v3DiLoCoMessageReportInnerStepDone: int32 = 4
    v3DiLoCoMessageSubmitOuterDelta: int32 = 5
    v3DiLoCoMessageFetchStepStatus: int32 = 6
    v3DiLoCoMessagePublishMergeCommit: int32 = 7
    v3DiLoCoMessageFetchGlobalVersion: int32 = 8
    v3DiLoCoMessageFetchLineage: int32 = 9

type
    V3DiLoCoEnvelope =
        version: int32 = 1
        kind: int32
        ok: bool = true
        errorText: str
        body: Bytes

    V3DiLoCoOpenJobRequest =
        jobBundleCid: layout.FixedBytes32
        requestedWorkerCount: int32
        innerStepBudget: int32
        outerStepTimeoutSeconds: int32
        initialModelRef: core.V3DiLoCoArtifactRef
        initialOptimizerRef: core.V3DiLoCoArtifactRef

    V3DiLoCoOpenJobResponse =
        job: core.V3DiLoCoJob
        version: core.V3DiLoCoGlobalVersion

    V3DiLoCoJoinCohortRequest =
        jobBundleCid: layout.FixedBytes32
        peerId: types.V3Libp2pPeerId

    V3DiLoCoJoinCohortResponse =
        cohort: core.V3DiLoCoCohort

    V3DiLoCoFetchLeaseRequest =
        jobBundleCid: layout.FixedBytes32
        peerId: types.V3Libp2pPeerId

    V3DiLoCoFetchLeaseResponse =
        lease: core.V3DiLoCoLease

    V3DiLoCoReportInnerStepDoneRequest =
        jobBundleCid: layout.FixedBytes32
        peerId: types.V3Libp2pPeerId

    V3DiLoCoReportInnerStepDoneResponse =
        barrier: core.V3DiLoCoBarrier

    V3DiLoCoSubmitOuterDeltaRequest =
        jobBundleCid: layout.FixedBytes32
        baseVersionCid: layout.FixedBytes32
        outerStep: int32
        publisherPeerId: types.V3Libp2pPeerId
        modelDeltaRef: core.V3DiLoCoArtifactRef
        optimizerDeltaRef: core.V3DiLoCoArtifactRef
        sampleCount: int32
        tokenCount: int32
        innerStepCount: int32
        weightNumerator: int32
        weightDenominator: int32

    V3DiLoCoSubmitOuterDeltaResponse =
        delta: core.V3DiLoCoOuterDelta

    V3DiLoCoFetchStepStatusRequest =
        jobBundleCid: layout.FixedBytes32

    V3DiLoCoFetchStepStatusResponse =
        status: core.V3DiLoCoStepStatus

    V3DiLoCoPublishMergeCommitRequest =
        jobBundleCid: layout.FixedBytes32
        publisherPeerId: types.V3Libp2pPeerId
        mergedModelRef: core.V3DiLoCoArtifactRef
        mergedOptimizerRef: core.V3DiLoCoArtifactRef

    V3DiLoCoPublishMergeCommitResponse =
        commit: core.V3DiLoCoMergeCommit
        version: core.V3DiLoCoGlobalVersion

    V3DiLoCoFetchGlobalVersionRequest =
        jobBundleCid: layout.FixedBytes32

    V3DiLoCoFetchGlobalVersionResponse =
        version: core.V3DiLoCoGlobalVersion

    V3DiLoCoFetchLineageRequest =
        jobBundleCid: layout.FixedBytes32

    V3DiLoCoFetchLineageResponse =
        versions: core.V3DiLoCoGlobalVersion[]

fn v3DiLoCoWireKnownKind(kind: int32): bool =
    return kind == v3DiLoCoMessageOpenJob ||
           kind == v3DiLoCoMessageJoinCohort ||
           kind == v3DiLoCoMessageFetchLease ||
           kind == v3DiLoCoMessageReportInnerStepDone ||
           kind == v3DiLoCoMessageSubmitOuterDelta ||
           kind == v3DiLoCoMessageFetchStepStatus ||
           kind == v3DiLoCoMessagePublishMergeCommit ||
           kind == v3DiLoCoMessageFetchGlobalVersion ||
           kind == v3DiLoCoMessageFetchLineage

fn v3DiLoCoWireAppendU32(buf: var layout.ByteBuf, value: int32) =
    layout.ByteBufAppendByte(buf, (value >> 24) & 255)
    layout.ByteBufAppendByte(buf, (value >> 16) & 255)
    layout.ByteBufAppendByte(buf, (value >> 8) & 255)
    layout.ByteBufAppendByte(buf, value & 255)

fn v3DiLoCoWireAppendI64(buf: var layout.ByteBuf, value: int64) =
    v3DiLoCoWireAppendU32(buf, int32((value >> 32) & int64(0xffffffff)))
    v3DiLoCoWireAppendU32(buf, int32(value & int64(0xffffffff)))

fn v3DiLoCoWireReadU32(span: layout.ByteSpan, offset: int32): Result[int32] =
    if offset < 0 || offset + 4 > layout.ByteSpanLen(span):
        return Err[int32]("v3 diloco wire: short u32")
    let b0 = layout.ByteSpanAt(span, offset)
    let b1 = layout.ByteSpanAt(span, offset + 1)
    let b2 = layout.ByteSpanAt(span, offset + 2)
    let b3 = layout.ByteSpanAt(span, offset + 3)
    return Ok[int32]((b0 << 24) | (b1 << 16) | (b2 << 8) | b3)

fn v3DiLoCoWireReadI64(span: layout.ByteSpan, offset: int32): Result[int64] =
    let hiRes = v3DiLoCoWireReadU32(span, offset)
    if IsErr(hiRes):
        return Err[int64](Error(hiRes))
    let loRes = v3DiLoCoWireReadU32(span, offset + 4)
    if IsErr(loRes):
        return Err[int64](Error(loRes))
    return Ok[int64]((int64(Value(hiRes)) << 32) | (int64(Value(loRes)) & int64(0xffffffff)))

fn v3DiLoCoWireField(prefix: str, name: str): str =
    if len(prefix) <= 0:
        return name
    return prefix + "_" + name

fn v3DiLoCoWireBoolText(value: bool): str =
    if value:
        return "1"
    return "0"

fn v3DiLoCoWireParseInt64(text: str): Result[int64] =
    if len(text) <= 0:
        return Err[int64]("v3 diloco wire: empty integer")
    var negative = false
    var start = 0
    if text[0] == '-':
        negative = true
        start = 1
    if start >= len(text):
        return Err[int64]("v3 diloco wire: invalid integer")
    var value: int64 = int64(0)
    for i in start..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int64]("v3 diloco wire: invalid integer")
        value = value * int64(10) + int64(ch - '0')
    if negative:
        value = -value
    return Ok[int64](value)

fn v3DiLoCoWireFindValue(wire: str, key: str): Result[str] =
    let prefix = key + "="
    var lineStart = 0
    while lineStart < len(wire):
        var lineEnd = lineStart
        while lineEnd < len(wire) && wire[lineEnd] != '\n':
            lineEnd = lineEnd + 1
        if lineEnd - lineStart >= len(prefix):
            var matched = true
            for i in 0..<len(prefix):
                if wire[lineStart + i] != prefix[i]:
                    matched = false
                    break
            if matched:
                return Ok[str](strings.SliceBytes(wire,
                                                  lineStart + len(prefix),
                                                  lineEnd - lineStart - len(prefix)))
        lineStart = lineEnd + 1
    return Err[str]("v3 diloco wire: missing key " + key)

fn v3DiLoCoWireRequireInt32(wire: str, key: str): Result[int32] =
    let valueRes = v3DiLoCoWireFindValue(wire, key)
    if IsErr(valueRes):
        return Err[int32](Error(valueRes))
    let parsedRes = v3DiLoCoWireParseInt64(Value(valueRes))
    if IsErr(parsedRes):
        return Err[int32](Error(parsedRes))
    return Ok[int32](int32(Value(parsedRes)))

fn v3DiLoCoWireRequireI64(wire: str, key: str): Result[int64] =
    let valueRes = v3DiLoCoWireFindValue(wire, key)
    if IsErr(valueRes):
        return Err[int64](Error(valueRes))
    return v3DiLoCoWireParseInt64(Value(valueRes))

fn v3DiLoCoWireRequireBool(wire: str, key: str): Result[bool] =
    let valueRes = v3DiLoCoWireFindValue(wire, key)
    if IsErr(valueRes):
        return Err[bool](Error(valueRes))
    if Value(valueRes) == "1":
        return Ok[bool](true)
    if Value(valueRes) == "0":
        return Ok[bool](false)
    return Err[bool]("v3 diloco wire: invalid bool")

fn v3DiLoCoWireRequireFixed32(wire: str, key: str): Result[layout.FixedBytes32] =
    let valueRes = v3DiLoCoWireFindValue(wire, key)
    if IsErr(valueRes):
        return Err[layout.FixedBytes32](Error(valueRes))
    return layout.FixedBytes32FromHex(Value(valueRes))

fn v3DiLoCoWireRequirePeerId(wire: str, key: str): Result[types.V3Libp2pPeerId] =
    let valueRes = v3DiLoCoWireFindValue(wire, key)
    if IsErr(valueRes):
        return Err[types.V3Libp2pPeerId](Error(valueRes))
    var out: types.V3Libp2pPeerId
    let fillRes = peer_id.V3Libp2pPeerIdFillFromText(out, Value(valueRes))
    if IsErr(fillRes):
        return Err[types.V3Libp2pPeerId](Error(fillRes))
    return Ok[types.V3Libp2pPeerId](out)

fn v3DiLoCoEnvelopeEncode(envelope: V3DiLoCoEnvelope): Bytes =
    let errorBytes = bytesFromString(envelope.errorText)
    let bodyBytes = envelope.body
    var buf = layout.ByteBufInit(32 + bytesLen(errorBytes) + bytesLen(bodyBytes))
    v3DiLoCoWireAppendU32(buf, v3DiLoCoWireMagic)
    v3DiLoCoWireAppendU32(buf, envelope.version)
    v3DiLoCoWireAppendU32(buf, envelope.kind)
    v3DiLoCoWireAppendU32(buf, int32(envelope.ok))
    v3DiLoCoWireAppendU32(buf, bytesLen(errorBytes))
    v3DiLoCoWireAppendU32(buf, bytesLen(bodyBytes))
    layout.ByteBufAppendBytes(buf, errorBytes)
    layout.ByteBufAppendBytes(buf, bodyBytes)
    return layout.ByteBufToBytes(buf)

fn v3DiLoCoEnvelopeDecodeFill(out: var V3DiLoCoEnvelope, payload: Bytes): Result[bool] =
    var span = layout.ByteSpanFromBytes(payload)
    let magicRes = v3DiLoCoWireReadU32(span, 0)
    if IsErr(magicRes):
        return Err[bool](Error(magicRes))
    if Value(magicRes) != v3DiLoCoWireMagic:
        return Err[bool]("v3 diloco wire: envelope magic")
    let versionRes = v3DiLoCoWireReadU32(span, 4)
    if IsErr(versionRes):
        return Err[bool](Error(versionRes))
    if Value(versionRes) != v3DiLoCoWireVersion:
        return Err[bool]("v3 diloco wire: envelope version")
    let kindRes = v3DiLoCoWireReadU32(span, 8)
    if IsErr(kindRes):
        return Err[bool](Error(kindRes))
    if !v3DiLoCoWireKnownKind(Value(kindRes)):
        return Err[bool]("v3 diloco wire: envelope kind")
    let okRes = v3DiLoCoWireReadU32(span, 12)
    if IsErr(okRes):
        return Err[bool](Error(okRes))
    let errorLenRes = v3DiLoCoWireReadU32(span, 16)
    if IsErr(errorLenRes):
        return Err[bool](Error(errorLenRes))
    let bodyLenRes = v3DiLoCoWireReadU32(span, 20)
    if IsErr(bodyLenRes):
        return Err[bool](Error(bodyLenRes))
    let errorLen = Value(errorLenRes)
    let bodyLen = Value(bodyLenRes)
    if errorLen < 0 || bodyLen < 0:
        return Err[bool]("v3 diloco wire: envelope lengths")
    let total = 24 + errorLen + bodyLen
    if total != bytesLen(payload):
        return Err[bool]("v3 diloco wire: envelope shape")
    out = V3DiLoCoEnvelope()
    out.version = Value(versionRes)
    out.kind = Value(kindRes)
    out.ok = Value(okRes) != 0
    out.errorText = bytesToString(layout.ByteSpanToBytes(layout.ByteSpanSlice(span, 24, errorLen)))
    out.body = layout.ByteSpanToBytes(layout.ByteSpanSlice(span, 24 + errorLen, bodyLen))
    return Ok[bool](true)

fn v3DiLoCoWireEncodeBodyEnvelope(kind: int32, bodyText: str): Bytes =
    var envelope = V3DiLoCoEnvelope()
    envelope.kind = kind
    envelope.ok = true
    envelope.body = bytesFromString(bodyText)
    return v3DiLoCoEnvelopeEncode(envelope)

fn v3DiLoCoWireEncodeErrorEnvelope(kind: int32, errorText: str): Bytes =
    var envelope = V3DiLoCoEnvelope()
    envelope.kind = kind
    envelope.ok = false
    envelope.errorText = errorText
    return v3DiLoCoEnvelopeEncode(envelope)

fn v3DiLoCoWireDecodeBodyText(payload: Bytes,
                              kind: int32,
                              out: var str): Result[bool] =
    var envelope = V3DiLoCoEnvelope()
    let decodeRes = v3DiLoCoEnvelopeDecodeFill(envelope, payload)
    if IsErr(decodeRes):
        return Err[bool](Error(decodeRes))
    if envelope.kind != kind:
        return Err[bool]("v3 diloco wire: unexpected kind")
    if !envelope.ok:
        return Err[bool](envelope.errorText)
    out = bytesToString(envelope.body)
    return Ok[bool](true)

fn v3DiLoCoWireAppendArtifactRef(out: str,
                                 prefix: str,
                                 ref: core.V3DiLoCoArtifactRef): str =
    var next = out
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "stub_cid"), layout.FixedBytes32Hex(ref.stubCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "blob_summary_cid"), layout.FixedBytes32Hex(ref.blobSummaryCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "manifest_cid"), layout.FixedBytes32Hex(ref.manifestCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "blob_cid"), layout.FixedBytes32Hex(ref.blobCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "payload_len"), intToStr(ref.payloadLen))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "params_cid"), layout.FixedBytes32Hex(ref.paramsCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "layout_kind"), intToStr(ref.layoutKind))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "data_shard_count"), intToStr(ref.dataShardCount))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "parity_shard_count"), intToStr(ref.parityShardCount))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "shard_payload_bytes"), intToStr(ref.shardPayloadBytes))
    return next

fn v3DiLoCoWireParseArtifactRefFill(out: var core.V3DiLoCoArtifactRef,
                                    wire: str,
                                    prefix: str): Result[bool] =
    out = core.V3DiLoCoArtifactRef()
    let stubCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "stub_cid"))
    if IsErr(stubCidRes):
        return Err[bool](Error(stubCidRes))
    let blobSummaryCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "blob_summary_cid"))
    if IsErr(blobSummaryCidRes):
        return Err[bool](Error(blobSummaryCidRes))
    let manifestCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "manifest_cid"))
    if IsErr(manifestCidRes):
        return Err[bool](Error(manifestCidRes))
    let blobCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "blob_cid"))
    if IsErr(blobCidRes):
        return Err[bool](Error(blobCidRes))
    let payloadLenRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "payload_len"))
    if IsErr(payloadLenRes):
        return Err[bool](Error(payloadLenRes))
    let paramsCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "params_cid"))
    if IsErr(paramsCidRes):
        return Err[bool](Error(paramsCidRes))
    let layoutKindRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "layout_kind"))
    if IsErr(layoutKindRes):
        return Err[bool](Error(layoutKindRes))
    let dataShardCountRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "data_shard_count"))
    if IsErr(dataShardCountRes):
        return Err[bool](Error(dataShardCountRes))
    let parityShardCountRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "parity_shard_count"))
    if IsErr(parityShardCountRes):
        return Err[bool](Error(parityShardCountRes))
    let shardPayloadBytesRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "shard_payload_bytes"))
    if IsErr(shardPayloadBytesRes):
        return Err[bool](Error(shardPayloadBytesRes))
    out.stubCid = Value(stubCidRes)
    out.blobSummaryCid = Value(blobSummaryCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.blobCid = Value(blobCidRes)
    out.payloadLen = Value(payloadLenRes)
    out.paramsCid = Value(paramsCidRes)
    out.layoutKind = Value(layoutKindRes)
    out.dataShardCount = Value(dataShardCountRes)
    out.parityShardCount = Value(parityShardCountRes)
    out.shardPayloadBytes = Value(shardPayloadBytesRes)
    return Ok[bool](true)

fn v3DiLoCoWireAppendPeerIdArray(out: str,
                                 prefix: str,
                                 peers: types.V3Libp2pPeerId[]): str =
    var next = did.V3DidStoreAppendLine(out, v3DiLoCoWireField(prefix, "count"), intToStr(peers.len))
    for i in 0..<peers.len:
        next = did.V3DidStoreAppendLine(next,
                                        v3DiLoCoWireField(prefix, intToStr(i)),
                                        peer_id.V3Libp2pPeerIdText(peers[i]))
    return next

fn v3DiLoCoWireParsePeerIdArrayFill(out: var types.V3Libp2pPeerId[],
                                    wire: str,
                                    prefix: str): Result[bool] =
    let countRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "count"))
    if IsErr(countRes):
        return Err[bool](Error(countRes))
    out = []
    for i in 0..<Value(countRes):
        let peerRes = v3DiLoCoWireRequirePeerId(wire, v3DiLoCoWireField(prefix, intToStr(i)))
        if IsErr(peerRes):
            return Err[bool](Error(peerRes))
        add(out, Value(peerRes))
    return Ok[bool](true)

fn v3DiLoCoWireAppendFixed32Array(out: str,
                                  prefix: str,
                                  items: layout.FixedBytes32[]): str =
    var next = did.V3DidStoreAppendLine(out, v3DiLoCoWireField(prefix, "count"), intToStr(items.len))
    for i in 0..<items.len:
        next = did.V3DidStoreAppendLine(next,
                                        v3DiLoCoWireField(prefix, intToStr(i)),
                                        layout.FixedBytes32Hex(items[i]))
    return next

fn v3DiLoCoWireParseFixed32ArrayFill(out: var layout.FixedBytes32[],
                                     wire: str,
                                     prefix: str): Result[bool] =
    let countRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "count"))
    if IsErr(countRes):
        return Err[bool](Error(countRes))
    out = []
    for i in 0..<Value(countRes):
        let valueRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, intToStr(i)))
        if IsErr(valueRes):
            return Err[bool](Error(valueRes))
        add(out, Value(valueRes))
    return Ok[bool](true)

fn v3DiLoCoWireAppendJob(out: str,
                         prefix: str,
                         job: core.V3DiLoCoJob): str =
    var next = out
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(job.jobBundleCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "requested_worker_count"), intToStr(job.requestedWorkerCount))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "inner_step_budget"), intToStr(job.innerStepBudget))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "outer_step_timeout_seconds"), intToStr(job.outerStepTimeoutSeconds))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "current_global_version_cid"), layout.FixedBytes32Hex(job.currentGlobalVersionCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "current_outer_step"), intToStr(job.currentOuterStep))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "sealed"), v3DiLoCoWireBoolText(job.sealed))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "cohort_cid"), layout.FixedBytes32Hex(job.cohortCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "opened_at_epoch_seconds"), intToStr(int32(job.openedAtEpochSeconds)))
    return next

fn v3DiLoCoWireParseJobFill(out: var core.V3DiLoCoJob,
                            wire: str,
                            prefix: str): Result[bool] =
    out = core.V3DiLoCoJob()
    let jobBundleCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "job_bundle_cid"))
    if IsErr(jobBundleCidRes):
        return Err[bool](Error(jobBundleCidRes))
    let requestedWorkerCountRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "requested_worker_count"))
    if IsErr(requestedWorkerCountRes):
        return Err[bool](Error(requestedWorkerCountRes))
    let innerStepBudgetRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "inner_step_budget"))
    if IsErr(innerStepBudgetRes):
        return Err[bool](Error(innerStepBudgetRes))
    let timeoutRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "outer_step_timeout_seconds"))
    if IsErr(timeoutRes):
        return Err[bool](Error(timeoutRes))
    let currentVersionRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "current_global_version_cid"))
    if IsErr(currentVersionRes):
        return Err[bool](Error(currentVersionRes))
    let currentStepRes = v3DiLoCoWireRequireInt32(wire, v3DiLoCoWireField(prefix, "current_outer_step"))
    if IsErr(currentStepRes):
        return Err[bool](Error(currentStepRes))
    let sealedRes = v3DiLoCoWireRequireBool(wire, v3DiLoCoWireField(prefix, "sealed"))
    if IsErr(sealedRes):
        return Err[bool](Error(sealedRes))
    let cohortCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "cohort_cid"))
    if IsErr(cohortCidRes):
        return Err[bool](Error(cohortCidRes))
    let openedAtRes = v3DiLoCoWireRequireI64(wire, v3DiLoCoWireField(prefix, "opened_at_epoch_seconds"))
    if IsErr(openedAtRes):
        return Err[bool](Error(openedAtRes))
    out.jobBundleCid = Value(jobBundleCidRes)
    out.requestedWorkerCount = Value(requestedWorkerCountRes)
    out.innerStepBudget = Value(innerStepBudgetRes)
    out.outerStepTimeoutSeconds = Value(timeoutRes)
    out.currentGlobalVersionCid = Value(currentVersionRes)
    out.currentOuterStep = Value(currentStepRes)
    out.sealed = Value(sealedRes)
    out.cohortCid = Value(cohortCidRes)
    out.openedAtEpochSeconds = Value(openedAtRes)
    return Ok[bool](true)

fn v3DiLoCoWireAppendCohort(out: str,
                            prefix: str,
                            cohort: core.V3DiLoCoCohort): str =
    var next = out
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "job_bundle_cid"), layout.FixedBytes32Hex(cohort.jobBundleCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "cohort_cid"), layout.FixedBytes32Hex(cohort.cohortCid))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "leader_peer_id"), peer_id.V3Libp2pPeerIdText(cohort.leaderPeerId))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "sealed_at_epoch_seconds"), intToStr(int32(cohort.sealedAtEpochSeconds)))
    next = did.V3DidStoreAppendLine(next, v3DiLoCoWireField(prefix, "fixed_member_count"), intToStr(cohort.fixedMemberCount))
    next = v3DiLoCoWireAppendPeerIdArray(next, v3DiLoCoWireField(prefix, "members"), cohort.members)
    return next

fn v3DiLoCoWireParseCohortFill(out: var core.V3DiLoCoCohort,
                               wire: str,
                               prefix: str): Result[bool] =
    out = core.V3DiLoCoCohort()
    let jobBundleCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "job_bundle_cid"))
    if IsErr(jobBundleCidRes):
        return Err[bool](Error(jobBundleCidRes))
    let cohortCidRes = v3DiLoCoWireRequireFixed32(wire, v3DiLoCoWireField(prefix, "cohort_cid"))
