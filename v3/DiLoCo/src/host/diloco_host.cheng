fn v3DiLoCoHostServePayload(out: var Bytes,
                            node: var V3DiLoCoHostNode,
                            payload: Bytes): Result[bool] =
    var envelope = wire.v3DiLoCoEnvelopeZero()
    let envelopeRes = wire.v3DiLoCoEnvelopeDecodeFill(envelope, payload)
    if IsErr(envelopeRes):
        return Err[bool](Error(envelopeRes))
    if !envelope.ok:
        return Err[bool]("v3 diloco host: request envelope not ok")
    if envelope.kind == wire.v3DiLoCoMessageOpenJob:
        return v3DiLoCoHostServeOpenJob(out, node, payload)
    elif envelope.kind == wire.v3DiLoCoMessageJoinCohort:
        return v3DiLoCoHostServeJoinCohort(out, node, payload)
    elif envelope.kind == wire.v3DiLoCoMessageFetchLease:
        return v3DiLoCoHostServeFetchLease(out, node, payload)
    elif envelope.kind == wire.v3DiLoCoMessageReportInnerStepDone:
        return v3DiLoCoHostServeReportInnerStepDone(out, node, payload)
    elif envelope.kind == wire.v3DiLoCoMessageSubmitOuterDelta:
        return v3DiLoCoHostServeSubmitOuterDelta(out, node, payload)
    elif envelope.kind == wire.v3DiLoCoMessageFetchStepStatus:
        return v3DiLoCoHostServeFetchStepStatus(out, node, payload)
    elif envelope.kind == wire.v3DiLoCoMessagePublishMergeCommit:
        return v3DiLoCoHostServePublishMergeCommit(out, node, payload)
    elif envelope.kind == wire.v3DiLoCoMessageFetchGlobalVersion:
        return v3DiLoCoHostServeFetchGlobalVersion(out, node, payload)
    elif envelope.kind == wire.v3DiLoCoMessageFetchLineage:
        return v3DiLoCoHostServeFetchLineage(out, node, payload)
    return Err[bool]("v3 diloco host: unsupported kind")

fn v3DiLoCoHostRequestResponseNamed(host: str,
                                    port: int32,
                                    serverName: str,
                                    payload: Bytes): Result[Bytes] =
    return quic_transport.v3Libp2pQuicRequestResponseNamed(host,
                                                           port,
                                                           serverName,
                                                           types.v3Libp2pProtocolDiLoCo,
                                                           payload)

fn v3DiLoCoHostServeWindowNamed(node: var V3DiLoCoHostNode,
                                host: str,
                                port: int32,
                                serverName: str,
                                readyPath: str,
                                maxServeCount: int32,
                                waitMs: int32): Result[bool] =
    var listener = qtransport.initMsQuicTransport()
    let startRes = quic_transport.v3Libp2pQuicStartListenerNamed(listener, host, port, serverName)
    if IsErr(startRes):
        return Err[bool](Error(startRes))
    if !quic_transport.v3Libp2pQuicWriteReadyPort(readyPath, Value(startRes)):
        qtransport.stop(listener)
        return Err[bool]("v3 diloco host: ready path write failed")
    var servedCount = 0
    while maxServeCount <= 0 || servedCount < maxServeCount:
        let acceptRes = qtransport.acceptTimed(listener, waitMs)
        if IsErr(acceptRes):
            if ErrorText(acceptRes) == "msquic: accept timeout":
                break
            os.writeLine(os.get_stderr(), "v3 diloco host accept error: " + ErrorText(acceptRes))
            qtransport.stop(listener)
            return Err[bool]("v3 diloco host: accept: " + ErrorText(acceptRes))
        var conn = Value(acceptRes)
        var dropConn = false
        let selectRes = quic_transport.v3Libp2pQuicServerSelectProtocol(listener,
                                                                        conn,
                                                                        types.v3Libp2pProtocolDiLoCo)
        var responsePayload = emptyBytes()
        if IsErr(selectRes):
            dropConn = true
        if !dropConn:
            let requestRes = quic_transport.v3Libp2pQuicReadFrame(listener, conn)
            if IsErr(requestRes):
                dropConn = true
            else:
                let serveRes = v3DiLoCoHostServePayload(responsePayload, node, Value(requestRes))
                if IsErr(serveRes):
                    dropConn = true
                else:
                    let autoLeaderRes = v3DiLoCoHostMaybeAdvanceAutoLeader(node)
                    if IsErr(autoLeaderRes):
                        qconn.connClose(conn)
                        qtransport.stop(listener)
                        return Err[bool]("v3 diloco host: auto leader: " + Error(autoLeaderRes))
        if !dropConn:
            let writeRes = quic_transport.v3Libp2pQuicWriteExact(listener,
                                                                 conn,
                                                                 quic_transport.v3Libp2pQuicEncodeFrame(responsePayload))
            if IsErr(writeRes):
                dropConn = true
        qconn.connClose(conn)
        if dropConn:
            continue
        servedCount = servedCount + 1
    qtransport.stop(listener)
    return Ok[bool](true)

fn v3DiLoCoOpenJobRequestNamed(host: str,
                               port: int32,
                               serverName: str,
                               req: wire.V3DiLoCoOpenJobRequest): Result[wire.V3DiLoCoOpenJobResponse] =
    let responseBytesRes = v3DiLoCoHostRequestResponseNamed(host,
                                                            port,
                                                            serverName,
                                                            wire.v3DiLoCoOpenJobRequestEncode(req))
    if IsErr(responseBytesRes):
        return Err[wire.V3DiLoCoOpenJobResponse](Error(responseBytesRes))
    var out = wire.v3DiLoCoOpenJobResponseZero()
    let decodeRes = wire.v3DiLoCoOpenJobResponseDecodeFill(out, Value(responseBytesRes))
    if IsErr(decodeRes):
        return Err[wire.V3DiLoCoOpenJobResponse](Error(decodeRes))
    return Ok[wire.V3DiLoCoOpenJobResponse](out)

