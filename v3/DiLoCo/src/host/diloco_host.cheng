fn v3DiLoCoFetchGlobalVersionRequestNamed(host: str,
                                          port: int32,
                                          serverName: str,
                                          req: wire.V3DiLoCoFetchGlobalVersionRequest): Result[wire.V3DiLoCoFetchGlobalVersionResponse] =
    let responseBytesRes = v3DiLoCoHostRequestResponseNamed(host,
                                                            port,
                                                            serverName,
                                                            wire.v3DiLoCoFetchGlobalVersionRequestEncode(req))
    if IsErr(responseBytesRes):
