import std/result
import std/os
import cheng/v3/std/bytes_layout as layout
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/host/host as host_base
import cheng/v3/libp2p/transports/quic_transport
import cheng/v3/quic/connection as qconn
import cheng/v3/quic/msquictransport_native as qtransport
import cheng/DiLoCo/core/diloco as core
import cheng/DiLoCo/protocol/wire

type
    V3DiLoCoHostNode =
        state: core.V3DiLoCoState
        autoLeaderEnabled: bool
        autoLeaderJobBundleCid: layout.FixedBytes32
        autoLeaderPeerId: types.V3Libp2pPeerId
        autoLeaderModelDeltaRef: core.V3DiLoCoArtifactRef
        autoLeaderOptimizerDeltaRef: core.V3DiLoCoArtifactRef
        autoLeaderSampleCount: int32
        autoLeaderTokenCount: int32
        autoLeaderInnerStepCount: int32
        autoLeaderWeightNumerator: int32
        autoLeaderWeightDenominator: int32

fn v3DiLoCoHostInit(label: str): V3DiLoCoHostNode =
    return V3DiLoCoHostNode(
        state: core.v3DiLoCoStateInit(label),
        autoLeaderEnabled: false,
        autoLeaderJobBundleCid: layout.fixedBytes32Zero(),
        autoLeaderPeerId: types.v3Libp2pPeerIdZero(),
        autoLeaderModelDeltaRef: core.v3DiLoCoArtifactRefZero(),
        autoLeaderOptimizerDeltaRef: core.v3DiLoCoArtifactRefZero(),
        autoLeaderSampleCount: 0,
        autoLeaderTokenCount: 0,
        autoLeaderInnerStepCount: 0,
        autoLeaderWeightNumerator: 0,
        autoLeaderWeightDenominator: 0
    )

fn v3DiLoCoHostRegister(host: var host_base.V3Libp2pHost) =
    host_base.v3Libp2pRegisterHandler(host, types.v3Libp2pProtocolDiLoCo)

fn v3DiLoCoHostEnableAutoLeader(node: var V3DiLoCoHostNode,
                                jobBundleCid: layout.FixedBytes32,
                                leaderPeerId: types.V3Libp2pPeerId,
                                modelDeltaRef: core.V3DiLoCoArtifactRef,
                                optimizerDeltaRef: core.V3DiLoCoArtifactRef,
                                sampleCount: int32,
                                tokenCount: int32,
                                innerStepCount: int32,
                                weightNumerator: int32,
                                weightDenominator: int32) =
    node.autoLeaderEnabled = true
    node.autoLeaderJobBundleCid = jobBundleCid
    node.autoLeaderPeerId = leaderPeerId
    node.autoLeaderModelDeltaRef = modelDeltaRef
    node.autoLeaderOptimizerDeltaRef = optimizerDeltaRef
    node.autoLeaderSampleCount = sampleCount
    node.autoLeaderTokenCount = tokenCount
    node.autoLeaderInnerStepCount = innerStepCount
    node.autoLeaderWeightNumerator = weightNumerator
    node.autoLeaderWeightDenominator = weightDenominator

fn v3DiLoCoHostMaybeAdvanceAutoLeader(node: var V3DiLoCoHostNode): Result[bool] =
    if !node.autoLeaderEnabled:
        return Ok[bool](false)
    let jobPos = core.v3DiLoCoJobPos(node.state, node.autoLeaderJobBundleCid)
    if jobPos < 0:
        return Err[bool]("v3 diloco host: auto leader job missing")
    let job = node.state.jobs[jobPos]
    if !job.sealed:
        return Ok[bool](false)
    var leaderLease = core.v3DiLoCoLeaseZero()
    let leaderLeaseRes = core.v3DiLoCoFetchLeaseFill(leaderLease,
                                                     node.state,
                                                     node.autoLeaderJobBundleCid,
                                                     node.autoLeaderPeerId)
    if IsErr(leaderLeaseRes):
        return Err[bool](Error(leaderLeaseRes))
    let barrierPos = core.v3DiLoCoBarrierPos(node.state,
                                             node.autoLeaderJobBundleCid,
                                             job.currentGlobalVersionCid,
                                             job.currentOuterStep)
    if barrierPos >= 0:
        let barrier = node.state.barriers[barrierPos]
        if barrier.completedPeerIds.len > 0 &&
           !core.v3DiLoCoBarrierHasPeer(barrier, node.autoLeaderPeerId):
            var barrierOut = core.v3DiLoCoBarrierZero()
            let barrierRes = core.v3DiLoCoReportInnerStepDoneFill(barrierOut,
                                                                  node.state,
                                                                  node.autoLeaderJobBundleCid,
                                                                  node.autoLeaderPeerId)
            if IsErr(barrierRes):
                return Err[bool](Error(barrierRes))
    let readyBarrierPos = core.v3DiLoCoBarrierPos(node.state,
                                                  node.autoLeaderJobBundleCid,
                                                  job.currentGlobalVersionCid,
                                                  job.currentOuterStep)
    if readyBarrierPos < 0:
        return Ok[bool](false)
    let readyBarrier = node.state.barriers[readyBarrierPos]
    if !readyBarrier.sealed:
        return Ok[bool](false)
    if core.v3DiLoCoDeltaPos(node.state,
                             node.autoLeaderJobBundleCid,
                             job.currentGlobalVersionCid,
                             job.currentOuterStep,
                             node.autoLeaderPeerId) >= 0:
        return Ok[bool](false)
    var leaderDelta = core.v3DiLoCoOuterDeltaZero()
    let leaderDeltaRes = core.v3DiLoCoSubmitOuterDeltaFill(leaderDelta,
                                                           node.state,
                                                           node.autoLeaderJobBundleCid,
                                                           job.currentGlobalVersionCid,
                                                           job.currentOuterStep,
                                                           node.autoLeaderPeerId,
                                                           node.autoLeaderModelDeltaRef,
                                                           node.autoLeaderOptimizerDeltaRef,
                                                           node.autoLeaderSampleCount,
                                                           node.autoLeaderTokenCount,
                                                           node.autoLeaderInnerStepCount,
                                                           node.autoLeaderWeightNumerator,
                                                           node.autoLeaderWeightDenominator)
    if IsErr(leaderDeltaRes):
        return Err[bool](Error(leaderDeltaRes))
    return Ok[bool](true)

fn v3DiLoCoHostServeOpenJob(out: var Bytes,
                            node: var V3DiLoCoHostNode,
                            payload: Bytes): Result[bool] =
    var req = wire.v3DiLoCoOpenJobRequestZero()
    let reqRes = wire.v3DiLoCoOpenJobRequestDecodeFill(req, payload)
    if IsErr(reqRes):
        return Err[bool](Error(reqRes))
    var job = core.v3DiLoCoJobZero()
    var version = core.v3DiLoCoGlobalVersionZero()
    let openRes = core.v3DiLoCoOpenJobFill(job,
                                           version,
                                           node.state,
                                           req.jobBundleCid,
                                           req.requestedWorkerCount,
                                           req.innerStepBudget,
                                           req.outerStepTimeoutSeconds,
                                           req.initialModelRef,
                                           req.initialOptimizerRef)
    if IsErr(openRes):
        out = wire.v3DiLoCoWireEncodeErrorEnvelope(wire.v3DiLoCoMessageOpenJob, Error(openRes))
        return Ok[bool](true)
    var resp = wire.v3DiLoCoOpenJobResponseZero()
    resp.job = job
    resp.version = version
    out = wire.v3DiLoCoOpenJobResponseEncode(resp)
    return Ok[bool](true)

