import cheng/v3/std/bytes_layout as layout
import cheng/v3/chain/lsmr_types as lt
import cheng/v3/libp2p/core/types
import cheng/v3/libp2p/core/peer_id
import cheng/DiLoCo/core/diloco as core

fn v3DiLoCoTestJobBundleCid(label: str): layout.FixedBytes32 =
    var buf = layout.ByteBufInit(96)
    layout.ByteBufAppendBytes(buf, bytesFromString("v3.diloco.test.job"))
    layout.ByteBufAppendBytes(buf, bytesFromString(label))
    return lt.V3FixedCidFromBuf(buf)

fn v3DiLoCoTestPeer(seed: str): types.V3Libp2pPeerId =
    return peer_id.V3Libp2pPeerIdFromSeed(seed)

fn v3DiLoCoTestArtifact(jobBundleCid: layout.FixedBytes32,
                        label: str): core.V3DiLoCoArtifactRef =
    var out = core.V3DiLoCoArtifactRef()
    let fillRes = core.v3DiLoCoArtifactRefFromBytesFill(out,
                                                        jobBundleCid,
                                                        bytesFromString("artifact:" + label),
                                                        64,
                                                        label)
    assert(fillRes.ok, "v3 diloco test artifact")
    return out
