import std/cmdline as cmdline
import cheng/DiLoCo/core/diloco as core
import cheng/DiLoCo/host/diloco_host
import cheng/DiLoCo/tests/support

fn main(): int32 =
    let port = cmdline.ReadInt32FlagOrDefault("--port", 0)
    var readyPathRaw: str = ""
    let hasReady = cmdline.ReadFirstFlagValue("--ready-path", readyPathRaw)
    let readyPath = if hasReady: readyPathRaw else: ""

    let jobBundleCid = support.v3DiLoCoTestJobBundleCid("quic-twoproc")
    let leaderPeerId = support.v3DiLoCoTestPeer("diloco.quic.leader")
    let workerPeerId = support.v3DiLoCoTestPeer("diloco.quic.worker")
    let initialModelRef = support.v3DiLoCoTestArtifact(jobBundleCid, "quic-initial-model")
    let initialOptimizerRef = support.v3DiLoCoTestArtifact(jobBundleCid, "quic-initial-optimizer")
    let leaderModelDeltaRef = support.v3DiLoCoTestArtifact(jobBundleCid, "quic-leader-model-delta")
    let leaderOptimizerDeltaRef = support.v3DiLoCoTestArtifact(jobBundleCid, "quic-leader-optimizer-delta")

    var node = diloco_host.v3DiLoCoHostInit("diloco.quic.server")
    var job = core.v3DiLoCoJobZero()
    var version = core.v3DiLoCoGlobalVersionZero()
    let openRes = core.v3DiLoCoOpenJobFill(job,
                                           version,
                                           node.state,
                                           jobBundleCid,
                                           2,
                                           5,
                                           60,
                                           initialModelRef,
                                           initialOptimizerRef)
    assert(openRes.ok, "v3 diloco quic status probe: open")
    var cohort = core.v3DiLoCoCohortZero()
    let joinLeaderRes = core.v3DiLoCoJoinCohortFill(cohort, node.state, jobBundleCid, leaderPeerId)
    assert(joinLeaderRes.ok, "v3 diloco quic status probe: join leader")
    diloco_host.v3DiLoCoHostEnableAutoLeader(node,
                                             jobBundleCid,
                                             leaderPeerId,
                                             leaderModelDeltaRef,
                                             leaderOptimizerDeltaRef,
                                             8,
                                             64,
                                             5,
                                             8,
                                             16)

    let serveRes = diloco_host.v3DiLoCoHostServeWindowNamed(node,
                                                            "127.0.0.1",
                                                            port,
                                                            "localhost",
                                                            readyPath,
                                                            5,
                                                            -1)
    assert(serveRes.ok, "v3 diloco quic status probe: serve")

    assert(node.state.jobs[0].currentOuterStep == 1, "v3 diloco quic status probe: current outer step")
    assert(node.state.deltas.len != 0, "v3 diloco quic status probe: delta len zero")
    assert(node.state.deltas.len != 1, "v3 diloco quic status probe: delta len one")
    assert(node.state.deltas.len != 3, "v3 diloco quic status probe: delta len three")
    assert(node.state.deltas.len == 2, "v3 diloco quic status probe: delta len")
    let leaderDeltaPos = core.v3DiLoCoDeltaPos(node.state,
                                               jobBundleCid,
                                               node.state.jobs[0].currentGlobalVersionCid,
                                               node.state.jobs[0].currentOuterStep,
                                               leaderPeerId)
    assert(leaderDeltaPos >= 0, "v3 diloco quic status probe: leader delta missing")
    let workerDeltaPos = core.v3DiLoCoDeltaPos(node.state,
                                               jobBundleCid,
                                               node.state.jobs[0].currentGlobalVersionCid,
                                               node.state.jobs[0].currentOuterStep,
                                               workerPeerId)
    assert(workerDeltaPos >= 0, "v3 diloco quic status probe: worker delta missing")
    var status = core.v3DiLoCoStepStatusZero()
    let statusRes = core.v3DiLoCoFetchStepStatusFill(status, node.state, jobBundleCid)
    assert(statusRes.ok, "v3 diloco quic status probe: fetch status")
    assert(status.contributionCount != 0, "v3 diloco quic status probe: contributions zero")
    assert(status.contributionCount != 1, "v3 diloco quic status probe: contributions one")
    assert(status.contributionCount == 2, "v3 diloco quic status probe: contributions")
    echo("v3 diloco_quic_status_server_probe ok")
    return 0
