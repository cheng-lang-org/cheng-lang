# v3 bootstrap subset source v1

syntax = v3-bootstrap-v1
bootstrap_name = cheng_v3_bootstrap
bootstrap_entry = bootstrap_main
compiler_class = bootstrap_subset
bootstrap_source_kind = bootstrap_subset_source
target = arm64-apple-darwin
compiler_parallel_model = two_pass,function_scheduler,thread_local_arena
program_parallel_model = deterministic_single_thread
ir_facts = move,borrow,noalias,escape,layout,abi
data_layout = dod,soa,fixed_layout
aot = required
forbidden = local_payload,exec_plan_payload,payloadText,BigInt,legacy_proof_surface,legacy_sidecar_mode
supported_commands = print-contract,self-check,compile-bootstrap,status,print-build-plan,system-link-exec
compiler_entry_source = v3/src/tooling/compiler_main.cheng
compiler_runtime_source = v3/src/tooling/compiler_runtime.cheng
compiler_request_source = v3/src/tooling/compiler_request.cheng
lang_parser_source = v3/src/lang/parser.cheng
backend_system_link_plan_source = v3/src/backend/system_link_plan.cheng
backend_lowering_plan_source = v3/src/backend/lowering_plan.cheng
backend_primary_object_plan_source = v3/src/backend/primary_object_plan.cheng
backend_object_plan_source = v3/src/backend/object_plan.cheng
backend_native_link_plan_source = v3/src/backend/native_link_plan.cheng
backend_system_link_exec_source = v3/src/backend/system_link_exec.cheng
runtime_core_runtime_source = v3/src/runtime/core_runtime_v3.cheng
runtime_compiler_runtime_source = v3/src/runtime/compiler_runtime_v3.cheng
tooling_bootstrap_contract_source = v3/src/tooling/bootstrap_contracts.cheng
backend_build_plan_source = v3/src/backend/build_plan.cheng
tooling_build_driver_script = v3/tooling/build_backend_driver_v3.sh
ordinary_command = system-link-exec
ordinary_pipeline_state = primary_object_codegen_missing
user_program_auto_parallel = off
bagua_bpi = sidecar_only
