module runtime_provider_autolink_constants

@importc("cheng_native_af_inet_bridge")
fn cheng_native_af_inet_bridge(): int32

@importc("cheng_native_af_inet6_bridge")
fn cheng_native_af_inet6_bridge(): int32

@importc("cheng_native_sock_stream_bridge")
fn cheng_native_sock_stream_bridge(): int32

@importc("cheng_native_sock_dgram_bridge")
fn cheng_native_sock_dgram_bridge(): int32

@importc("cheng_native_ipproto_ip_bridge")
fn cheng_native_ipproto_ip_bridge(): int32

@importc("cheng_native_sol_socket_bridge")
fn cheng_native_sol_socket_bridge(): int32

@importc("cheng_native_so_reuseaddr_bridge")
fn cheng_native_so_reuseaddr_bridge(): int32

@importc("cheng_native_so_broadcast_bridge")
fn cheng_native_so_broadcast_bridge(): int32

@importc("cheng_native_msg_waitall_bridge")
fn cheng_native_msg_waitall_bridge(): int32

@importc("cheng_native_sockaddr_use_len_field_bridge")
fn cheng_native_sockaddr_use_len_field_bridge(): int32

fn main(): int32 =
    let value: int32 =
        cheng_native_af_inet_bridge() +
        cheng_native_af_inet6_bridge() +
        cheng_native_sock_stream_bridge() +
        cheng_native_sock_dgram_bridge() +
        cheng_native_ipproto_ip_bridge() +
        cheng_native_sol_socket_bridge() +
        cheng_native_so_reuseaddr_bridge() +
        cheng_native_so_broadcast_bridge() +
        cheng_native_msg_waitall_bridge() +
        cheng_native_sockaddr_use_len_field_bridge()
    if value != 280:
        return 1
    return 0

main()
