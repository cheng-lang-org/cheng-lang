import cheng/rust-csg/core/parity

fn main(): int32 =
    let status = parity.RustCsgBlocked("tui")
    assert(!status.ported, "rust-csg parity: blocked status is not ported")
    assert(status.status == "explicitly_blocked", "rust-csg parity: status")
    assert(status.reason == parity.RustCsgBlockedReason, "rust-csg parity: reason")
    assert(parity.RustCsgBlockedExitCode != 0, "rust-csg parity: blocked exit non-zero")
    echo("rust_csg_parity_contract_smoke ok")
    return 0
