import cheng/rust-csg/core/module_map

fn main(): int32 =
    assert(module_map.RustCsgNormalizeSourceName("app-server-protocol") == "app_server_protocol",
           "dash normalization failed")
    assert(module_map.RustCsgNormalizeSourceName("utils/path-utils") == "utils_path_utils",
           "slash normalization failed")
    var unit = module_map.RustCsgCargoMemberUnit("app-server")
    var reason = ""
    assert(module_map.RustCsgMigrationUnitOk(unit, reason), reason)
    assert(unit.chengModule == "rust_csg/crates/app_server", "module path mismatch")
    assert(unit.status == "explicitly_blocked", "status mismatch")
    echo("rust_csg_module_map_smoke ok")
    return 0
