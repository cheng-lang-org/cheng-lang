fn main(): int32 =
    let cargoMembers = 106
    let rustFiles = 1738
    let typeScriptFiles = 528
    let tuiSnapshots = 454
    let tuiFrames = 360
    let productPackageJson = 5
    assert(cargoMembers == 106, "rust-csg inventory: cargo members")
    assert(rustFiles == 1738, "rust-csg inventory: rust files")
    assert(typeScriptFiles == 528, "rust-csg inventory: typescript files")
    assert(tuiSnapshots == 454, "rust-csg inventory: snapshots")
    assert(tuiFrames == 360, "rust-csg inventory: frames")
    assert(productPackageJson == 5, "rust-csg inventory: package json")
    echo("rust_csg_inventory_smoke ok")
    return 0
