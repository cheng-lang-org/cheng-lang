import std/strings
import std/strutils as strutil

fn RustCsgEndsWith(text: str, suffix: str): bool =
    let n = strings.Len(text)
    let m = strings.Len(suffix)
    if m == 0:
        return true
    if n < m:
        return false
    let start = n - m
    return strings.SliceBytes(text, start, m) == suffix

fn RustCsgContains(text: str, needle: str): bool =
    return strutil.Contains(text, needle)

fn RustCsgNormalizeModuleName(raw: str): str =
    let step1 = strutil.Replace(raw, "-", "_")
    return strutil.Replace(step1, "/", "_")

fn RustCsgBoolText(value: bool): str =
    return value ? "true" : "false"
