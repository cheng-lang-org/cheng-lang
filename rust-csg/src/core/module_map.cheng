import std/strutils as strutil
import cheng/rust-csg/protocol/types

const
    RustCsgCrateModulePrefix: str = "rust_csg/crates/"
    RustCsgExplicitlyBlocked: str = "explicitly_blocked"
    RustCsgBlockedUntilPorted: str = "source member is not ported to Cheng yet"

fn RustCsgNormalizeSourceName(sourceName: str): str =
    let slashFixed = strutil.Replace(sourceName, "/", "_")
    return strutil.Replace(slashFixed, "-", "_")

fn RustCsgCargoMemberModule(memberName: str): str =
    return strutil.Join([
        RustCsgCrateModulePrefix,
        RustCsgNormalizeSourceName(memberName)
    ], "")

fn RustCsgCargoMemberUnit(memberName: str): types.RustCsgMigrationUnit =
    var out: types.RustCsgMigrationUnit
    out.sourcePath = memberName
    out.chengModule = RustCsgCargoMemberModule(memberName)
    out.status = RustCsgExplicitlyBlocked
    out.reason = RustCsgBlockedUntilPorted
    return out

fn RustCsgMigrationUnitOk(unit: types.RustCsgMigrationUnit, outReason: var str): bool =
    outReason = ""
    if unit.sourcePath == "":
        outReason = "empty_source_path"
        return false
    if unit.chengModule == "":
        outReason = "empty_cheng_module"
        return false
    if unit.status != "ported" &&
       unit.status != "non-runtime asset" &&
       unit.status != RustCsgExplicitlyBlocked:
        outReason = strutil.Join(["invalid_status=", unit.status], "")
        return false
    if unit.status == RustCsgExplicitlyBlocked && unit.reason == "":
        outReason = "blocked_unit_missing_reason"
        return false
    return true
