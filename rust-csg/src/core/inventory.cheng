import std/os
import std/strings
import std/strutils as strutil
import cheng/rust-csg/core/text
import cheng/rust-csg/protocol/types

const
    RustCsgSourceRoot: str = "/Users/lbcheng/codex-lbcheng"
    RustCsgCodexRsRoot: str = "/Users/lbcheng/codex-lbcheng/codex-rs"
    RustCsgExpectedCargoMembers: int32 = 106
    RustCsgExpectedRustFiles: int32 = 1738
    RustCsgExpectedTypeScriptFiles: int32 = 528
    RustCsgExpectedTuiSnapshots: int32 = 454
    RustCsgExpectedTuiFrames: int32 = 360
    RustCsgExpectedProductPackageJson: int32 = 5

fn RustCsgPathUnder(path: str, prefix: str): bool =
    if path == prefix:
        return true
    return strutil.StartsWith(path, strutil.Join([prefix, "/"], ""))

fn RustCsgSkipVendoredPackageJson(path: str): bool =
    if text.RustCsgContains(path, "/node_modules/"):
        return true
    if text.RustCsgContains(path, "/target/"):
        return true
    if text.RustCsgContains(path, "/.cargo-home/"):
        return true
    if text.RustCsgContains(path, "/codex-rs/.cargo/"):
        return true
    return false

fn RustCsgCountCargoMembers(cargoTomlPath: str): int32 =
    let members = RustCsgCollectCargoMembers(cargoTomlPath)
    return int32(members.len)

fn RustCsgCargoMemberLineName(lineRaw: str): str =
    let line = strutil.Strip(lineRaw)
    if line.len < 2:
        return ""
    if line[0] != '"':
        return ""
    var stop = line.len - 1
    if line[stop] == ',':
        stop = stop - 1
    if stop <= 0 || line[stop] != '"':
        return ""
    return strutil.SliceStr(line, 1, stop - 1)

fn RustCsgCollectCargoMembers(cargoTomlPath: str): str[] =
    let body = os.ReadFile(cargoTomlPath)
    let lines = strutil.Split(body, '\n')
    var out: str[]
    var inside: bool
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        if line == "members = [":
            inside = true
            continue
        if inside && line == "]":
            break
        if inside:
            let name = RustCsgCargoMemberLineName(line)
            if name != "":
                add(out, name)
    return out

