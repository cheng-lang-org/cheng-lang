fn RustCsgStringSeqContainsExact(items: str[], needle: str): bool =
    for i in 0..<items.len:
        if items[i] == needle:
            return true
    return false

fn RustCsgCargoMembersOk(outReason: var str): bool =
    outReason = ""
    let expected = RustCsgExpectedCargoMembersList()
    let found = RustCsgCollectCargoMembers(os.JoinPath(RustCsgCodexRsRoot, "Cargo.toml"))
    if found.len != expected.len:
        outReason = strutil.Join([
            "cargo_member_name_count=",
            RustCsgInt32Text(int32(found.len)),
            " expected=",
            RustCsgInt32Text(int32(expected.len))
        ], "")
        return false
    for i in 0..<found.len:
        for j in i + 1..<found.len:
            if found[i] == found[j]:
                outReason = strutil.Join(["duplicate_cargo_member=", found[i]], "")
                return false
        if found[i] != expected[i]:
            outReason = strutil.Join([
                "cargo_member[",
                RustCsgInt32Text(int32(i)),
                "]=",
                found[i],
                " expected=",
                expected[i]
            ], "")
            return false
        if !RustCsgStringSeqContainsExact(expected, found[i]):
            outReason = strutil.Join(["unknown_cargo_member=", found[i]], "")
            return false
    return true

fn RustCsgCollectSourceStats(): types.RustCsgSourceStats =
    var out: types.RustCsgSourceStats
    out.cargoMemberCount = RustCsgCountCargoMembers(os.JoinPath(RustCsgCodexRsRoot, "Cargo.toml"))
    let codexRsFiles = os.WalkDirRec(RustCsgCodexRsRoot)
    for i in 0..<codexRsFiles.len:
        let path = codexRsFiles[i]
        if text.RustCsgContains(path, "/target/"):
            continue
        if text.RustCsgContains(path, "/node_modules/"):
            continue
        if text.RustCsgContains(path, "/.cargo/"):
            continue
        if text.RustCsgEndsWith(path, ".rs"):
            out.rustSourceFileCount = out.rustSourceFileCount + 1
        elif text.RustCsgEndsWith(path, ".ts"):
            out.typeScriptFileCount = out.typeScriptFileCount + 1
        elif text.RustCsgEndsWith(path, ".snap"):
            out.tuiSnapshotCount = out.tuiSnapshotCount + 1
        if RustCsgPathUnder(path, os.JoinPath(RustCsgCodexRsRoot, "tui/frames")) &&
           text.RustCsgEndsWith(path, ".txt"):
            out.tuiFrameCount = out.tuiFrameCount + 1
    let sourceFiles = os.WalkDirRec(RustCsgSourceRoot)
    for i in 0..<sourceFiles.len:
        let path = sourceFiles[i]
        if text.RustCsgEndsWith(path, "package.json") && !RustCsgSkipVendoredPackageJson(path):
            out.productPackageJsonCount = out.productPackageJsonCount + 1
    return out

fn RustCsgInventoryOk(stats: var types.RustCsgSourceStats, outReason: var str): bool =
    outReason = ""
    if stats.cargoMemberCount != RustCsgExpectedCargoMembers:
        outReason = strutil.Join(["cargo_member_count=", RustCsgInt32Text(stats.cargoMemberCount)], "")
        return false
    if stats.rustSourceFileCount != RustCsgExpectedRustFiles:
        outReason = strutil.Join(["rust_source_file_count=", RustCsgInt32Text(stats.rustSourceFileCount)], "")
        return false
    if stats.typeScriptFileCount != RustCsgExpectedTypeScriptFiles:
        outReason = strutil.Join(["typescript_file_count=", RustCsgInt32Text(stats.typeScriptFileCount)], "")
        return false
    if stats.tuiSnapshotCount != RustCsgExpectedTuiSnapshots:
        outReason = strutil.Join(["tui_snapshot_count=", RustCsgInt32Text(stats.tuiSnapshotCount)], "")
        return false
    if stats.tuiFrameCount != RustCsgExpectedTuiFrames:
        outReason = strutil.Join(["tui_frame_count=", RustCsgInt32Text(stats.tuiFrameCount)], "")
        return false
    if stats.productPackageJsonCount != RustCsgExpectedProductPackageJson:
        outReason = strutil.Join(["product_package_json_count=", RustCsgInt32Text(stats.productPackageJsonCount)], "")
        return false
    return true

fn RustCsgInt32Text(value: int32): str =
    return strings.Int64ToStr(int64(value))

fn RustCsgStatsText(stats: types.RustCsgSourceStats): str =
    return Lines([
        strutil.Join(["cargo_members=", RustCsgInt32Text(stats.cargoMemberCount)], ""),
        strutil.Join(["rust_files=", RustCsgInt32Text(stats.rustSourceFileCount)], ""),
        strutil.Join(["typescript_files=", RustCsgInt32Text(stats.typeScriptFileCount)], ""),
        strutil.Join(["tui_snapshots=", RustCsgInt32Text(stats.tuiSnapshotCount)], ""),
        strutil.Join(["tui_frames=", RustCsgInt32Text(stats.tuiFrameCount)], ""),
        strutil.Join(["product_package_json=", RustCsgInt32Text(stats.productPackageJsonCount)], "")
    ])
