import std/bytes as bytes
import std/os as os
import std/rawbytes as rawbytes

const
    wowExportClientLiteral = "/Volumes/NVMeSSD1T/World of Warcraft"
    wowExportBuildInfoLiteral = "/Volumes/NVMeSSD1T/World of Warcraft/.build.info"
    wowExportBuildInfoSuffix = "/.build.info"

fn pathExistsFromParam(clientPath: str): bool =
    let baseBytes: rawbytes.Bytes = rawbytes.BytesFromString(clientPath)
    let suffixBytes: rawbytes.Bytes = rawbytes.BytesFromString(wowExportBuildInfoSuffix)
    var pathBytes: rawbytes.Bytes = rawbytes.BytesConcat(baseBytes, suffixBytes)
    let path: str = rawbytes.BytesToString(pathBytes)
    rawbytes.BytesFree(pathBytes)
    return bytes.ReadFileBytes(path).len > 0

fn main(): int32 =
    let baseBytes: rawbytes.Bytes = rawbytes.BytesFromString(wowExportClientLiteral)
    let suffixBytes: rawbytes.Bytes = rawbytes.BytesFromString(wowExportBuildInfoSuffix)
    var manualBytes: rawbytes.Bytes = rawbytes.BytesConcat(baseBytes, suffixBytes)
    let manual: str = rawbytes.BytesToString(manualBytes)
    rawbytes.BytesFree(manualBytes)
    let buf: bytes.ByteBuffer = bytes.ReadFileBytes(manual)
    assert(os.FileExists(wowExportBuildInfoLiteral),
           "wow_export_build_info_probe literal exists")
    assert(manual == wowExportBuildInfoLiteral,
           "wow_export_build_info_probe manual text")
    assert(buf.len > 0,
           "wow_export_build_info_probe read bytes")
    assert(pathExistsFromParam(wowExportClientLiteral),
           "wow_export_build_info_probe param exists")
    echo("wow_export_build_info_probe ok")
    return 0
