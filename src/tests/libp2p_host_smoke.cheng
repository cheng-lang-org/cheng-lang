import std/system
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/host/host

fn main(): int32 =
    var node = host.Libp2pHostInit("host.alpha")
    var tcpAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(tcpAddr, "127.0.0.1", 5101)
    var quicAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(quicAddr, "127.0.0.1", 5102)
    let listenTcpRes = host.Libp2pListen(node, tcpAddr)
    assert(listenTcpRes.ok, " libp2p host: listen tcp")
    let listenQuicRes = host.Libp2pListen(node, quicAddr)
    assert(listenQuicRes.ok, " libp2p host: listen quic")

    host.Libp2pRegisterHandler(node, types.Libp2pProtocolIdentify)
    host.Libp2pRegisterHandler(node, types.Libp2pProtocolKad)
    host.Libp2pRegisterHandler(node, types.Libp2pProtocolGossipsub)
    host.Libp2pRegisterHandler(node, types.Libp2pProtocolStore)
    host.Libp2pRegisterHandler(node, types.Libp2pProtocolSync)

    var bootstrapPeer: types.Libp2pPeerId
    peer_id.Libp2pPeerIdFillFromSeed(bootstrapPeer, "bootstrap.one")
    var bootstrapRecord: ps.Libp2pPeerRecord
    bootstrapRecord.peerId = bootstrapPeer
    bootstrapRecord.routingRole = overlay.OverlayRoleRegionalRouter
    bootstrapRecord.connected = true
    bootstrapRecord.bootstrap = true
    bootstrapRecord.trustPermille = 900
    bootstrapRecord.rttEwmaMicros = 1200
    ps.Libp2pPeerRecordPutEndpoint(bootstrapRecord,
                                     tcpAddr,
                                     true,
                                     types.Libp2pReachabilityDirect,
                                     tcpAddr.priority)
    host.Libp2pAddBootstrapPeer(node, bootstrapRecord)

    var edgePeer: types.Libp2pPeerId
    peer_id.Libp2pPeerIdFillFromSeed(edgePeer, "edge.two")
    let dialRes = host.Libp2pDial(node, edgePeer, quicAddr, overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " libp2p host: dial peer")

    let streamRes = host.Libp2pOpenStream(node, bootstrapPeer, types.Libp2pProtocolIdentify)
    assert(streamRes.ok, " libp2p host: open identify stream")
    assert(streamRes.value == 1, " libp2p host: first stream id")

    let closest = host.Libp2pFindPeers(node, bootstrapPeer, 2)
    assert(closest.len >= 1, " libp2p host: kad closest")
    let closestPeer = closest[0].peerId
    assert(types.Libp2pPeerIdEqual(closestPeer, bootstrapPeer),
        " libp2p host: bootstrap closest")

    let snapshot = host.Libp2pPeerSnapshot(node)
    assert(snapshot.listenCount == 2, " libp2p host: listen count")
    assert(snapshot.peerCount == 2, " libp2p host: peer count")
    assert(snapshot.handlerCount == 5, " libp2p host: handler count")
    assert(snapshot.streamCount == 1, " libp2p host: stream count")
    assert(node.peers.peers[0].endpoints.len == 1, " libp2p host: bootstrap endpoint count")
    assert(node.peers.peers[1].endpoints.len == 1, " libp2p host: edge endpoint count")

    echo(" libp2p_host_smoke ok")
    return 0
