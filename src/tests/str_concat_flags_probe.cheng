fn main(): int32 =
    let path: str = "/tmp/no_model"
    let msg: str = "concat_param=" + path
    if msg.flags == 1:
        echo("flags-owned")
    elif msg.flags == 0:
        echo("flags-view")
    else:
        echo("flags-other")
    if msg.len == 26:
        echo("len-ok")
    else:
        echo("len-bad")
    if msg.data == nil:
        echo("data-nil")
    else:
        echo("data-ok")
    return 0
