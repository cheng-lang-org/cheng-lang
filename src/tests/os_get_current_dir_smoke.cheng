import std/os as os

fn main(): int32 =
    let cwd: str = os.GetCurrentDir()
    if cwd.len <= 0:
        assert(false, "v3 ordinary os.GetCurrentDir non-empty")
    assert(os.DirExists(cwd), "v3 ordinary os.GetCurrentDir existing dir")
    let repoV3Dir: str = os.JoinPath(cwd, "v3")
    assert(os.DirExists(repoV3Dir), "v3 ordinary os.GetCurrentDir repo root")
    echo("v3 os_get_current_dir_smoke ok")
    return 0
