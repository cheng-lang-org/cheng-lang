import std/os as os

fn main(): int32 =
    let cwd: str = os.GetCurrentDir()
    if cwd.len <= 0:
        assert(false, " ordinary os.GetCurrentDir non-empty")
    assert(os.DirExists(cwd), " ordinary os.GetCurrentDir existing dir")
    let repoRootDir: str = cwd
    assert(os.DirExists(repoRootDir), " ordinary os.GetCurrentDir repo root")
    echo(" os_get_current_dir_smoke ok")
    return 0
