import std/buffer
import std/rawbytes

fn makeJoined(prefix: str, value: str): str =
    var out: buffer.ByteBuffer
    out.data = rawbytes.emptyBytes()
    buffer.AppendBytes(out, prefix)
    buffer.AppendBytes(out, value)
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn main(): int32 =
    var items: str[]
    add(items, makeJoined("left:", "alpha"))
    add(items, makeJoined("right:", "beta"))
    assert(items.len == 2, "v3 str_array_add_owned_return_smoke: len")
    assert(items[0] == "left:alpha", "v3 str_array_add_owned_return_smoke: item0")
    assert(items[1] == "right:beta", "v3 str_array_add_owned_return_smoke: item1")
    echo("v3 str_array_add_owned_return_smoke ok")
    return 0
