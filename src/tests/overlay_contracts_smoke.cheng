import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt
import cheng/overlay/contracts as overlay

fn main(): int32 =
    assert(!overlay.OverlayRoleMayRoute(overlay.OverlayRoleLeafClient),
        " overlay smoke: leaf cannot route")
    assert(overlay.OverlayRoleMayRoute(overlay.OverlayRoleEdgeRelayStore),
        " overlay smoke: edge may route")
    assert(overlay.OverlayRoleMayRoute(overlay.OverlayRoleRegionalRouter),
        " overlay smoke: regional may route")
    assert(overlay.OverlayRoleMayRoute(overlay.OverlayRoleGlobalAnchor),
        " overlay smoke: global may route")
    assert(overlay.OverlayScopeText(overlay.OverlayScopeCell) == "cell",
        " overlay smoke: cell scope text")
    assert(overlay.OverlayRoleText(overlay.OverlayRoleRegionalRouter) == "regional_router",
        " overlay smoke: role text")

    let addrRes = types.LsmrAddressFromDigits([5, 1, 8])
    assert(addrRes.ok, " overlay smoke: address")
    let prefixRes = lt.PrefixRefFromDigits(lt.BaguaLi, [5, 1])
    assert(prefixRes.ok, " overlay smoke: prefix")

    var better = overlay.TrustScoreInput()
    better.lsmrDistance = 1
    better.rttEwmaMicros = 1000
    better.lossPermille = 2
    better.loadPermille = 3
    better.trustPermille = 900

    var worse = overlay.TrustScoreInput()
    worse.lsmrDistance = 1
    worse.rttEwmaMicros = 1000
    worse.lossPermille = 2
    worse.loadPermille = 3
    worse.trustPermille = 100

    assert(overlay.OverlayTrustScore(better) < overlay.OverlayTrustScore(worse),
        " overlay smoke: trust score not pure lsmr distance")

    var candidate = overlay.NeighborCandidate()
    candidate.role = overlay.OverlayRoleRegionalRouter
    candidate.coordHint.address = addrRes.value
    candidate.coordHint.confidencePermille = 700
    candidate.scoreInput = better
    assert(overlay.OverlayNeighborEligible(candidate),
        " overlay smoke: regional eligible")

    candidate.role = overlay.OverlayRoleLeafClient
    assert(!overlay.OverlayNeighborEligible(candidate),
        " overlay smoke: leaf excluded from routing table")

    var witness = overlay.WitnessProof()
    witness.subjectPeerId = layout.FixedBytes32()
    witness.witnessPeerId = layout.FixedBytes32()
    witness.address = addrRes.value
    witness.confidencePermille = 600
    witness.stampEpoch = 3
    witness.stampGanzhi = 18
    assert(overlay.OverlayWitnessFreshEnough(witness),
        " overlay smoke: witness fresh")

    var ingress = overlay.IngressEnvelope()
    ingress.topicScope = overlay.OverlayScopeRegion
    ingress.address = addrRes.value
    ingress.payloadLen = 128
    assert(ingress.topicScope == overlay.OverlayScopeRegion,
        " overlay smoke: ingress scope")

    var query = overlay.StoreQuery()
    query.address = addrRes.value
    query.prefix = prefixRes.value
    query.rangeLimit = 32
    assert(query.rangeLimit == 32, " overlay smoke: store query range")

    var digest = overlay.SyncDigest()
    digest.topicScope = overlay.OverlayScopeGlobal
    digest.eventCount = 9
    digest.accountCount = 3
    assert(digest.topicScope == overlay.OverlayScopeGlobal,
        " overlay smoke: sync scope")

    echo(" overlay_contracts_smoke ok")
    return 0
