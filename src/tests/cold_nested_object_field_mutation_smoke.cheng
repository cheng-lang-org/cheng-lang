type
    Bytes =
        data: ptr
        len: int32
    Buffer =
        data: Bytes

fn setBytes(buf: var Buffer, p: ptr, n: int32) =
    var out: Bytes
    out.data = p
    out.len = n
    buf.data = out

fn main() =
    var buf: Buffer
    let p: ptr = nil
    setBytes(buf, p, 9)
    assert(buf.data.len == 9, "cold nested object field mutation")
