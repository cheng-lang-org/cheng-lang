import cheng/core/lang/parser
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let contractsSourcePath = chengpath.PathJoin(packageRoot, "src/core/tooling/bootstrap_contracts.cheng")
    let stdSourcePath = chengpath.PathJoin(workspaceRoot, "src/std/strutils.cheng")
    let codexPackageRoot = chengpath.PathJoin(packageRoot, "codex")
    let codexSourcePath = chengpath.PathJoin(codexPackageRoot, "src/tests/session_exec_smoke.cheng")
    let codexEngineSourcePath = chengpath.PathJoin(codexPackageRoot, "src/core/engine.cheng")
    let typedFixturePath = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let typedHelperPath = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_helper.cheng")
    let typedHelperPlainPath = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_helper_plain.cheng")
    let typedImportcHelperPath = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_importc_helper.cheng")
    let oldDefaultPath = chengpath.PathJoin(packageRoot, "src/tests/composite_default_init_negative_old_default.cheng")
    let scalarTypeCallPath = chengpath.PathJoin(packageRoot, "src/tests/composite_default_init_negative_scalar_type_call.cheng")
    let refTypeCallPath = chengpath.PathJoin(packageRoot, "src/tests/composite_default_init_negative_ref_type_call.cheng")
    let refTypeCallUnusedPath = chengpath.PathJoin(packageRoot, "src/tests/composite_default_init_negative_ref_type_call_unused.cheng")
    let genericZeroArgCallPath = chengpath.PathJoin(packageRoot, "src/tests/composite_default_init_generic_zeroarg_call_ok.cheng")
    assert(parser.ParserPackageId(packageRoot) == "cheng", " parser path: package id")
    assert(chengpath.TextSlice("std/strutils", 4, 8) == "strutils",
           " parser path: std slice helper literal")
    assert(parser.ParserModulePathToSourcePath(workspaceRoot,
                                                 packageRoot,
                                                 "cheng/core/tooling/bootstrap_contracts") == contractsSourcePath,
           " parser path: package import")
    assert(parser.ParserModulePathToSourcePath(workspaceRoot,
                                                 packageRoot,
                                                 "std/strutils") == stdSourcePath,
           " parser path: std import")
    assert(parser.ParserSourcePathToModulePath(workspaceRoot,
                                                 packageRoot,
                                                 contractsSourcePath) == "cheng/core/tooling/bootstrap_contracts",
           " parser path: package source")
    assert(parser.ParserSourcePathToModulePath(workspaceRoot,
                                                 packageRoot,
                                                 stdSourcePath) == "std/strutils",
           " parser path: std source")
    assert(creq.CompilerResolvePackageRoot(workspaceRoot,
                                             codexSourcePath,
                                             workspaceRoot) == codexPackageRoot,
           " parser path: nested package root from workspace root")
    assert(creq.CompilerResolvePackageRoot(workspaceRoot,
                                             codexSourcePath,
                                             packageRoot) == codexPackageRoot,
           " parser path: nested package root from repo root")
    assert(parser.ParserWorkspaceRoot(codexPackageRoot) == workspaceRoot,
           " parser path: nested package workspace root")
    assert(parser.ParserPackageId(codexPackageRoot) == "cheng/codex",
           " parser path: nested package id")
    assert(parser.ParserModulePathToSourcePath(workspaceRoot,
                                                 codexPackageRoot,
                                                 "cheng/codex/core/engine") == codexEngineSourcePath,
           " parser path: nested package import")
    assert(parser.ParserModulePathToSourcePath(workspaceRoot,
                                                 codexPackageRoot,
                                                 "cheng/core/tooling/bootstrap_contracts") == contractsSourcePath,
           " parser path: shared  import from nested package")
    assert(parser.ParserModulePathToSourcePath(workspaceRoot,
                                                 codexPackageRoot,
                                                 "std/strutils") == stdSourcePath,
           " parser path: shared std import from nested package")
    assert(parser.ParserSourcePathToModulePath(workspaceRoot,
                                                 codexPackageRoot,
                                                 codexEngineSourcePath) == "cheng/codex/core/engine",
           " parser path: nested package source")
    assert(parser.ParserSourcePathToModulePath(workspaceRoot,
                                                 codexPackageRoot,
                                                 contractsSourcePath) == "cheng/core/tooling/bootstrap_contracts",
           " parser path: shared  source from nested package")
    var parsed: parser.ParsedSourceStub
    var err = ""
    assert(parser.ParseOrdinarySourceStub(codexPackageRoot, codexSourcePath, parsed, err),
           " parser path: nested package parse stub")
    assert(parsed.workspaceRoot == workspaceRoot, " parser path: parsed nested workspace root")
    assert(parsed.packageRoot == codexPackageRoot, " parser path: parsed nested package root")
    assert(parsed.ownerModulePaths.len >= 1 &&
           parser.ParserStringSeqContains(parsed.ownerModulePaths, "cheng/codex/tests/session_exec_smoke"),
           " parser path: parsed nested owner module")
    assert(parsed.unresolvedImportCount == 0, " parser path: parsed nested imports resolved")
    var typedParsed: parser.ParsedSourceStub
    err = ""
    assert(parser.ParseOrdinarySourceStub(packageRoot, typedFixturePath, typedParsed, err),
           " parser path: typed fixture parse stub")
    var foundGroupedImport = false
    for i in 0..<typedParsed.importEdges.len:
        if typedParsed.importEdges[i].targetModulePath == "cheng/tests/typed_expr_fact_helper_plain":
            foundGroupedImport = true
    assert(foundGroupedImport, " parser path: grouped import edge")
    assert(parser.NormalizedExprLayerHasCallExpr(typedParsed.normalizedExprLayer,
                                                   parser.NormalizedExprSurfaceCallExternal,
                                                   28),
           " parser path: alias external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedParsed.normalizedExprLayer,
                                                   parser.NormalizedExprSurfaceCallExternal,
                                                   29),
           " parser path: module stem external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedParsed.normalizedExprLayer,
                                                   parser.NormalizedExprSurfaceCallExternal,
                                                   30),
           " parser path: nested qualified external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedParsed.normalizedExprLayer,
                                                   parser.NormalizedExprSurfaceCallExternal,
                                                   32),
           " parser path: alias importc external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedParsed.normalizedExprLayer,
                                                   parser.NormalizedExprSurfaceCallExternal,
                                                   33),
           " parser path: nested importc external call")
    var sawAliasExternalTarget = false
    var sawNestedExternalTarget = false
    var sawAliasImportcTarget = false
    var sawNestedImportcTarget = false
    for i in 0..<typedParsed.normalizedExprLayer.exprs.len:
        let expr = typedParsed.normalizedExprLayer.exprs[i]
        if expr.kind != parser.NormalizedExprCall:
            continue
        if !expr.callResolved:
            continue
        if expr.lineNumber == 28:
            assert(expr.callTargetSourcePath == typedHelperPath,
                   " parser path: alias external target source")
            assert(!expr.callTargetImportc,
                   " parser path: alias external target importc")
            sawAliasExternalTarget = true
        elif expr.lineNumber == 30:
            assert(expr.callTargetSourcePath == typedHelperPlainPath,
                   " parser path: nested external target source")
            assert(!expr.callTargetImportc,
                   " parser path: nested external target importc")
            sawNestedExternalTarget = true
        elif expr.lineNumber == 32:
            assert(expr.callTargetSourcePath == typedImportcHelperPath,
                   " parser path: alias importc target source")
            assert(expr.callTargetImportc,
                   " parser path: alias importc target importc")
            sawAliasImportcTarget = true
        elif expr.lineNumber == 33:
            assert(expr.callTargetSourcePath == typedImportcHelperPath,
                   " parser path: nested importc target source")
            assert(expr.callTargetImportc,
                   " parser path: nested importc target importc")
            sawNestedImportcTarget = true
    assert(sawAliasExternalTarget, " parser path: saw alias external target")
    assert(sawNestedExternalTarget, " parser path: saw nested external target")
    assert(sawAliasImportcTarget, " parser path: saw alias importc target")
    assert(sawNestedImportcTarget, " parser path: saw nested importc target")
    var oldDefaultParsed: parser.ParsedSourceStub
    err = ""
    assert(!parser.ParseOrdinarySourceStub(packageRoot, oldDefaultPath, oldDefaultParsed, err),
           " parser path: old default syntax rejected in frontend")
    assert(chengpath.TextContains(err, "default[T] removed"),
           " parser path: old default syntax diagnostic")
    var scalarTypeCallParsed: parser.ParsedSourceStub
    err = ""
    assert(!parser.ParseOrdinarySourceStub(packageRoot, scalarTypeCallPath, scalarTypeCallParsed, err),
           " parser path: scalar type call rejected in frontend")
    assert(chengpath.TextContains(err, "simple type T() unsupported"),
           " parser path: scalar type call diagnostic")
    var refTypeCallParsed: parser.ParsedSourceStub
    err = ""
    assert(!parser.ParseOrdinarySourceStub(packageRoot, refTypeCallPath, refTypeCallParsed, err),
           " parser path: ref type call rejected in frontend")
    assert(chengpath.TextContains(err, "ref object T() unsupported"),
           " parser path: ref type call diagnostic")
    var refTypeCallUnusedParsed: parser.ParsedSourceStub
    err = ""
    assert(!parser.ParseOrdinarySourceStub(packageRoot, refTypeCallUnusedPath, refTypeCallUnusedParsed, err),
           " parser path: unused ref type call rejected in frontend")
    assert(chengpath.TextContains(err, "ref object T() unsupported"),
           " parser path: unused ref type call diagnostic")
    var genericZeroArgCallParsed: parser.ParsedSourceStub
    err = ""
    assert(parser.ParserTypeExprLooksLikeLowerGenericFunction("elemSize[int32]"),
           " parser path: lower generic helper detects elemSize")
    assert(!parser.ParserTypeExprLooksLikeLowerGenericFunction("SurfacePair"),
           " parser path: lower generic helper leaves type name")
    assert(!parser.ParserTypeExprLooksLikeLowerGenericFunction("int32[]"),
           " parser path: lower generic helper leaves seq type")
    assert(!parser.ParserTypeExprLooksLikeLowerGenericFunction("int32[2]"),
           " parser path: lower generic helper leaves fixed type")
    assert(parser.ParseOrdinarySourceStub(packageRoot, genericZeroArgCallPath, genericZeroArgCallParsed, err),
           " parser path: lower generic zeroarg call parses")
    var genericZeroArgMisclassified = false
    for i in 0..<genericZeroArgCallParsed.normalizedExprLayer.exprs.len:
        let expr = genericZeroArgCallParsed.normalizedExprLayer.exprs[i]
        if expr.sourcePath != genericZeroArgCallPath || expr.lineNumber != 4:
            continue
        if expr.kind == parser.NormalizedExprDefaultInit ||
           expr.kind == parser.NormalizedExprConstructor:
            genericZeroArgMisclassified = true
    assert(!genericZeroArgMisclassified,
           " parser path: lower generic zeroarg not type-call")
    echo(" parser_path_smoke ok")
    return 0
