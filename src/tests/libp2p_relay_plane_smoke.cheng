import std/system
import std/strings
import cheng/libp2p/core/types
import cheng/libp2p/host/host
import cheng/libp2p/core/multiaddr
import cheng/libp2p/transports/tailnet_transport as tsnet
import cheng/libp2p/transports/relay_provider
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/protocols/relay_plane
import std/strutils as strutil

fn main(): int32 =
    var server = host.Libp2pHostInit("relay.plane.server")
    var client = host.Libp2pHostInit("relay.plane.client")
    var stranger = host.Libp2pHostInit("relay.plane.stranger")
    var rogue = host.Libp2pHostInit("relay.plane.rogue")

    host.Libp2pRegisterHandler(server, types.Libp2pProtocolWebrtcSignal)
    host.Libp2pRegisterHandler(server, types.Libp2pProtocolRelayDescribe)
    host.Libp2pRegisterHandler(server, types.Libp2pProtocolRelayLease)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolRelayDescribe)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolRelayLease)
    host.Libp2pRegisterHandler(stranger, types.Libp2pProtocolRelayDescribe)
    host.Libp2pRegisterHandler(stranger, types.Libp2pProtocolRelayLease)
    host.Libp2pRegisterHandler(rogue, types.Libp2pProtocolWebrtcSignal)
    host.Libp2pRegisterHandler(rogue, types.Libp2pProtocolRelayDescribe)
    host.Libp2pRegisterHandler(rogue, types.Libp2pProtocolRelayLease)

    host.Libp2pHostSetTrustedInfra(server, true)

    var serverTcpAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(serverTcpAddr, "198.51.100.10", 43061)
    let serverListenRes = host.Libp2pListen(server, serverTcpAddr)
    assert(IsOk(serverListenRes), " libp2p relay plane: server tcp listen")

    var clientTcpAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(clientTcpAddr, "198.51.100.11", 43062)
    let clientListenRes = host.Libp2pListen(client, clientTcpAddr)
    assert(IsOk(clientListenRes), " libp2p relay plane: client tcp listen")

    var rogueTcpAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(rogueTcpAddr, "198.51.100.12", 43063)
    let rogueListenRes = host.Libp2pListen(rogue, rogueTcpAddr)
    assert(IsOk(rogueListenRes), " libp2p relay plane: rogue tcp listen")

    var publicWebrtcAddr: types.Libp2pMultiaddr
    publicWebrtcAddr.host = "203.0.113.77"
    publicWebrtcAddr.port = 3478
    publicWebrtcAddr.transport = types.Libp2pTransportWebrtc
    publicWebrtcAddr.networkDomain = types.Libp2pNetworkDomainPublic
    publicWebrtcAddr.visibility = types.Libp2pVisibilityPublic
    let webrtcListenRes = host.Libp2pListen(server, publicWebrtcAddr)
    assert(IsOk(webrtcListenRes), " libp2p relay plane: server webrtc listen")
    let rogueWebrtcListenRes = host.Libp2pListen(rogue, publicWebrtcAddr)
    assert(IsOk(rogueWebrtcListenRes), " libp2p relay plane: rogue webrtc listen")

    var healthyResources: types.Libp2pNodeResource
    healthyResources.sampledAtEpochSeconds = 1
    healthyResources.cpuLogicalCores = 8
    healthyResources.memoryAvailableBytes = int64(12) * int64(1024) * int64(1024) * int64(1024)
    healthyResources.memoryTotalBytes = int64(16) * int64(1024) * int64(1024) * int64(1024)
    healthyResources.diskAvailableBytes = int64(200) * int64(1024) * int64(1024) * int64(1024)
    healthyResources.diskTotalBytes = int64(256) * int64(1024) * int64(1024) * int64(1024)
    host.Libp2pHostObserveSelfResources(server, healthyResources)
    host.Libp2pHostObserveSelfResources(rogue, healthyResources)

    let dialClientToServerRes = host.Libp2pDial(client, server.selfPeerId, serverTcpAddr, 0)
    assert(IsOk(dialClientToServerRes), " libp2p relay plane: client dials server")
    let dialServerToClientRes = host.Libp2pDial(server, client.selfPeerId, clientTcpAddr, 0)
    assert(IsOk(dialServerToClientRes), " libp2p relay plane: server dials client")
    let dialStrangerToServerRes = host.Libp2pDial(stranger, server.selfPeerId, serverTcpAddr, 0)
    assert(IsOk(dialStrangerToServerRes), " libp2p relay plane: stranger dials server")

    var zeroTailnet = tsnet.Libp2pTailnetTransportInit(tsnet.Libp2pTailnetTransportConfig())
    let rogueRefreshRes = host.Libp2pHostRefreshRelayRole(rogue, zeroTailnet, "sfo", 60)
    assert(IsOk(rogueRefreshRes), " libp2p relay plane: rogue refresh")
    assert(rogue.relayDescriptors.len == 0, " libp2p relay plane: rogue no descriptors")
    assert(rogue.kadState.providers.len == 0, " libp2p relay plane: rogue no providers")

    var relayCfg: tsnet.Libp2pTailnetTransportConfig
    relayCfg.controlEndpoint = "https://control.example"
    relayCfg.relayEndpoint = "https://derp.sfo.example:443"
    relayCfg.derpRegionCode = "sfo"
    var relayTransport = tsnet.Libp2pTailnetTransportInit(relayCfg)
    tsnet.Libp2pTailnetProviderStart(relayTransport)
    tsnet.Libp2pTailnetProviderMarkProxyReady(relayTransport)
    tsnet.Libp2pTailnetProviderDerpReady(relayTransport)
    assert(relay_provider.Libp2pRelayProviderLineValue("ok=1\nhealthy=1\n", "healthy") == "1",
        " libp2p relay plane: relay line parser")
    assert(host.Libp2pRelayHealthAllowed(host.Libp2pHostSelfResources(server)),
        " libp2p relay plane: server resource health")
    assert(tsnet.Libp2pTailnetProviderFullyReady(relayTransport),
        " libp2p relay plane: tailnet provider ready")
    assert(tsnet.Libp2pTailnetDerpAvailable(relayTransport),
        " libp2p relay plane: tailnet derp ready")
    var turnProvider: relay_provider.Libp2pRelayProvider
    let turnProviderRes = relay_provider.Libp2pRelayProviderOpenFill(turnProvider,
                                                                       types.Libp2pRelayServiceTurn,
                                                                       "turn:203.0.113.77:3478",
                                                                       "sfo",
                                                                       "scope:test",
                                                                       true)
    assert(IsOk(turnProviderRes), " libp2p relay plane: turn provider open")
    var turnHealth: types.Libp2pRelayHealth
    let turnProbeRes = relay_provider.Libp2pRelayProviderProbeHealthFill(turnHealth,
                                                                           turnProvider,
                                                                           1)
    assert(IsOk(turnProbeRes), " libp2p relay plane: turn provider probe")
    assert(turnHealth.healthy, " libp2p relay plane: turn provider healthy")
    assert(relay_provider.Libp2pRelayProviderClose(turnProvider),
        " libp2p relay plane: turn provider close")
    var turnOnlyHost = host.Libp2pHostInit("relay.plane.turn.only")
    host.Libp2pHostObserveSelfResources(turnOnlyHost, healthyResources)
    let turnDirectAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(turnOnlyHost,
                                                                           types.Libp2pRelayServiceTurn,
                                                                           "turn:203.0.113.77:3478",
                                                                           "sfo",
                                                                           "scope:test",
                                                                           1,
                                                                           60)
    assert(IsOk(turnDirectAdvertiseRes), " libp2p relay plane: direct turn advertise")
    assert(Value(turnDirectAdvertiseRes), " libp2p relay plane: direct turn advertised")
    var pairHost = host.Libp2pHostInit("relay.plane.pair")
    host.Libp2pHostObserveSelfResources(pairHost, healthyResources)
    let stunPairAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(pairHost,
                                                                         types.Libp2pRelayServiceStun,
                                                                         "stun:203.0.113.77:3478",
                                                                         "sfo",
                                                                         "scope:test",
                                                                         1,
                                                                         60)
    assert(IsOk(stunPairAdvertiseRes), " libp2p relay plane: pair stun advertise")
    assert(Value(stunPairAdvertiseRes), " libp2p relay plane: pair stun advertised")
    let turnPairAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(pairHost,
                                                                         types.Libp2pRelayServiceTurn,
                                                                         "turn:203.0.113.77:3478",
                                                                         "sfo",
                                                                         "scope:test",
                                                                         1,
                                                                         60)
    assert(IsOk(turnPairAdvertiseRes), " libp2p relay plane: pair turn advertise")
    assert(Value(turnPairAdvertiseRes), " libp2p relay plane: pair turn advertised")
    var pairSawTurn = false
    for i in 0..<pairHost.relayDescriptors.len:
        if pairHost.relayDescriptors[i].serviceKind != types.Libp2pRelayServiceTurn:
            continue
        if pairHost.relayDescriptors[i].endpointText != "turn:203.0.113.77:3478":
            continue
        pairSawTurn = true
    assert(pairSawTurn, " libp2p relay plane: pair turn descriptor")
    host.Libp2pHostRelaySyncSelfRecord(pairHost)
    var pairSawTurnAfterSync = false
    for i in 0..<pairHost.relayDescriptors.len:
        if pairHost.relayDescriptors[i].serviceKind != types.Libp2pRelayServiceTurn:
            continue
        if pairHost.relayDescriptors[i].endpointText != "turn:203.0.113.77:3478":
            continue
        pairSawTurnAfterSync = true
    assert(pairSawTurnAfterSync, " libp2p relay plane: pair turn after sync")
    var tripleHost = host.Libp2pHostInit("relay.plane.triple")
    host.Libp2pHostObserveSelfResources(tripleHost, healthyResources)
    let stunTripleAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(tripleHost,
                                                                           types.Libp2pRelayServiceStun,
                                                                           "stun:203.0.113.77:3478",
                                                                           "sfo",
                                                                           "scope:test",
                                                                           1,
                                                                           60)
    assert(IsOk(stunTripleAdvertiseRes), " libp2p relay plane: triple stun advertise")
    assert(Value(stunTripleAdvertiseRes), " libp2p relay plane: triple stun advertised")
    let turnTripleAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(tripleHost,
                                                                           types.Libp2pRelayServiceTurn,
                                                                           "turn:203.0.113.77:3478",
                                                                           "sfo",
                                                                           "scope:test",
                                                                           1,
                                                                           60)
    assert(IsOk(turnTripleAdvertiseRes), " libp2p relay plane: triple turn advertise")
    assert(Value(turnTripleAdvertiseRes), " libp2p relay plane: triple turn advertised")
    let tsnetTripleAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(tripleHost,
                                                                            types.Libp2pRelayServiceTsnet,
                                                                            "https://derp.sfo.example:443",
                                                                            "sfo",
                                                                            "scope:test",
                                                                            1,
                                                                            60)
    assert(IsOk(tsnetTripleAdvertiseRes), " libp2p relay plane: triple tsnet advertise")
    assert(Value(tsnetTripleAdvertiseRes), " libp2p relay plane: triple tsnet advertised")
    var tripleSawTurn = false
    for i in 0..<tripleHost.relayDescriptors.len:
        if tripleHost.relayDescriptors[i].serviceKind != types.Libp2pRelayServiceTurn:
            continue
        if tripleHost.relayDescriptors[i].endpointText != "turn:203.0.113.77:3478":
            continue
        tripleSawTurn = true
    assert(tripleSawTurn, " libp2p relay plane: triple turn descriptor")
    host.Libp2pRegisterHandler(tripleHost, types.Libp2pProtocolRelayDescribe)
    host.Libp2pRegisterHandler(tripleHost, types.Libp2pProtocolRelayLease)
    var tripleSawTurnAfterRegister = false
    for i in 0..<tripleHost.relayDescriptors.len:
        if tripleHost.relayDescriptors[i].serviceKind != types.Libp2pRelayServiceTurn:
            continue
        if tripleHost.relayDescriptors[i].endpointText != "turn:203.0.113.77:3478":
            continue
        tripleSawTurnAfterRegister = true
    assert(tripleSawTurnAfterRegister, " libp2p relay plane: triple turn after handler register")
    let dynamicStunEndpoint = strutil.Join(["stun:", publicWebrtcAddr.host, ":", strings.IntToStr(publicWebrtcAddr.port)], "")
    let dynamicTurnEndpoint = strutil.Join(["turn:", publicWebrtcAddr.host, ":", strings.IntToStr(publicWebrtcAddr.port)], "")
    var dynamicTripleHost = host.Libp2pHostInit("relay.plane.dynamic.triple")
    host.Libp2pHostObserveSelfResources(dynamicTripleHost, healthyResources)
    let dynamicStunAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(dynamicTripleHost,
                                                                            types.Libp2pRelayServiceStun,
                                                                            dynamicStunEndpoint,
                                                                            "sfo",
                                                                            "scope:test",
                                                                            1,
                                                                            60)
    assert(IsOk(dynamicStunAdvertiseRes), " libp2p relay plane: dynamic stun advertise")
    assert(Value(dynamicStunAdvertiseRes), " libp2p relay plane: dynamic stun advertised")
    let dynamicTurnAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(dynamicTripleHost,
                                                                            types.Libp2pRelayServiceTurn,
                                                                            dynamicTurnEndpoint,
                                                                            "sfo",
                                                                            "scope:test",
                                                                            1,
                                                                            60)
    assert(IsOk(dynamicTurnAdvertiseRes), " libp2p relay plane: dynamic turn advertise")
    assert(Value(dynamicTurnAdvertiseRes), " libp2p relay plane: dynamic turn advertised")
    let dynamicTsnetAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(dynamicTripleHost,
                                                                             types.Libp2pRelayServiceTsnet,
                                                                             "https://derp.sfo.example:443",
                                                                             "sfo",
                                                                             "scope:test",
                                                                             1,
                                                                             60)
    assert(IsOk(dynamicTsnetAdvertiseRes), " libp2p relay plane: dynamic tsnet advertise")
    assert(Value(dynamicTsnetAdvertiseRes), " libp2p relay plane: dynamic tsnet advertised")
    var dynamicSawTurn = false
    for i in 0..<dynamicTripleHost.relayDescriptors.len:
        if dynamicTripleHost.relayDescriptors[i].serviceKind != types.Libp2pRelayServiceTurn:
            continue
        if dynamicTripleHost.relayDescriptors[i].endpointText != dynamicTurnEndpoint:
            continue
        dynamicSawTurn = true
    assert(dynamicSawTurn, " libp2p relay plane: dynamic triple turn descriptor")
    var clearThenManualHost = host.Libp2pHostInit("relay.plane.clear.then.manual")
    host.Libp2pHostObserveSelfResources(clearThenManualHost, healthyResources)
    host.Libp2pHostRelayClearLocalState(clearThenManualHost)
    let clearStunAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(clearThenManualHost,
                                                                          types.Libp2pRelayServiceStun,
                                                                          dynamicStunEndpoint,
                                                                          "sfo",
                                                                          "scope:test",
                                                                          1,
                                                                          60)
    assert(IsOk(clearStunAdvertiseRes), " libp2p relay plane: clear stun advertise")
    assert(Value(clearStunAdvertiseRes), " libp2p relay plane: clear stun advertised")
    let clearTurnAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(clearThenManualHost,
                                                                          types.Libp2pRelayServiceTurn,
                                                                          dynamicTurnEndpoint,
                                                                          "sfo",
                                                                          "scope:test",
                                                                          1,
                                                                          60)
    assert(IsOk(clearTurnAdvertiseRes), " libp2p relay plane: clear turn advertise")
    assert(Value(clearTurnAdvertiseRes), " libp2p relay plane: clear turn advertised")
    let clearTsnetAdvertiseRes = host.Libp2pHostRelayAdvertiseDescriptor(clearThenManualHost,
                                                                           types.Libp2pRelayServiceTsnet,
                                                                           "https://derp.sfo.example:443",
                                                                           "sfo",
                                                                           "scope:test",
                                                                           1,
                                                                           60)
    assert(IsOk(clearTsnetAdvertiseRes), " libp2p relay plane: clear tsnet advertise")
    assert(Value(clearTsnetAdvertiseRes), " libp2p relay plane: clear tsnet advertised")
    var clearSawTurn = false
    for i in 0..<clearThenManualHost.relayDescriptors.len:
        if clearThenManualHost.relayDescriptors[i].serviceKind != types.Libp2pRelayServiceTurn:
            continue
        if clearThenManualHost.relayDescriptors[i].endpointText != dynamicTurnEndpoint:
            continue
        clearSawTurn = true
    assert(clearSawTurn, " libp2p relay plane: clear then manual turn descriptor")
    var freshRefreshHost = host.Libp2pHostInit("relay.plane.fresh.refresh")
    host.Libp2pHostSetTrustedInfra(freshRefreshHost, true)
    host.Libp2pHostObserveSelfResources(freshRefreshHost, healthyResources)
    host.Libp2pRegisterHandler(freshRefreshHost, types.Libp2pProtocolWebrtcSignal)
    let freshTcpListenRes = host.Libp2pListen(freshRefreshHost, serverTcpAddr)
    assert(IsOk(freshTcpListenRes), " libp2p relay plane: fresh tcp listen")
    let freshWebrtcListenRes = host.Libp2pListen(freshRefreshHost, publicWebrtcAddr)
    assert(IsOk(freshWebrtcListenRes), " libp2p relay plane: fresh webrtc listen")
    let freshRefreshRes = host.Libp2pHostRefreshRelayRole(freshRefreshHost, relayTransport, "sfo", 60)
    assert(IsOk(freshRefreshRes), " libp2p relay plane: fresh refresh")
    assert(Value(freshRefreshRes), " libp2p relay plane: fresh refresh published")
    var freshSawTurn = false
    for i in 0..<freshRefreshHost.relayDescriptors.len:
        if freshRefreshHost.relayDescriptors[i].serviceKind != types.Libp2pRelayServiceTurn:
            continue
        if freshRefreshHost.relayDescriptors[i].endpointText != "turn:203.0.113.77:3478":
            continue
        freshSawTurn = true
    assert(freshSawTurn, " libp2p relay plane: fresh refresh turn descriptor")

    let refreshRes = host.Libp2pHostRefreshRelayRole(server, relayTransport, "sfo", 60)
    assert(IsOk(refreshRes), " libp2p relay plane: refresh")
    assert(Value(refreshRes), " libp2p relay plane: refresh published")
    var sawTurnDescriptor = false
    for i in 0..<server.relayDescriptors.len:
        if server.relayDescriptors[i].serviceKind != types.Libp2pRelayServiceTurn:
            continue
        if server.relayDescriptors[i].endpointText != "turn:203.0.113.77:3478":
            continue
        sawTurnDescriptor = true
    assert(host.Libp2pHostRelayProviderPos(server,
                                             types.Libp2pRelayServiceStun,
                                             "stun:203.0.113.77:3478") >= 0,
        " libp2p relay plane: stun advertised")
    assert(sawTurnDescriptor, " libp2p relay plane: turn descriptor advertised")
    assert(host.Libp2pHostRelayProviderPos(server,
                                             types.Libp2pRelayServiceTurn,
                                             "turn:203.0.113.77:3478") >= 0,
        " libp2p relay plane: turn advertised")
    assert(host.Libp2pHostRelayProviderPos(server,
                                             types.Libp2pRelayServiceTsnet,
                                             "https://derp.sfo.example:443") >= 0,
        " libp2p relay plane: tsnet advertised")
    assert(server.relayDescriptors.len == 3, " libp2p relay plane: stun+turn+tsnet descriptors")
    assert(server.kadState.providers.len == 6, " libp2p relay plane: region+global providers")

    client.kadState.providers = server.kadState.providers
    stranger.kadState.providers = server.kadState.providers

    var deniedDescriptors: types.Libp2pRelayDescriptor[]
    let deniedRes = host.Libp2pRelayDescribeRequest(stranger,
                                                      server,
                                                      server.selfPeerId,
                                                      types.Libp2pRelayServiceTurn,
                                                      "sfo",
                                                      deniedDescriptors)
    assert(IsErr(deniedRes), " libp2p relay plane: unauth requester denied")

    var turnDescriptors: types.Libp2pRelayDescriptor[]
    let turnDescribeRes = host.Libp2pRelayDescribeRequest(client,
                                                            server,
                                                            server.selfPeerId,
                                                            types.Libp2pRelayServiceTurn,
                                                            "sfo",
                                                            turnDescriptors)
    assert(IsOk(turnDescribeRes), " libp2p relay plane: describe turn")
    assert(turnDescriptors.len == 1, " libp2p relay plane: one turn descriptor")
    assert(turnDescriptors[0].endpointText == "turn:203.0.113.77:3478",
        " libp2p relay plane: turn endpoint")

    var stunDescriptors: types.Libp2pRelayDescriptor[]
    let stunDescribeRes = host.Libp2pRelayDescribeRequest(client,
                                                            server,
                                                            server.selfPeerId,
                                                            types.Libp2pRelayServiceStun,
                                                            "sfo",
                                                            stunDescriptors)
    assert(IsOk(stunDescribeRes), " libp2p relay plane: describe stun")
    assert(stunDescriptors.len == 1, " libp2p relay plane: one stun descriptor")

    var descriptorRoundtrip: types.Libp2pRelayDescriptor[]
    let descriptorRoundtripRes = relay_plane.Libp2pRelayDescriptorListDecodeFill(descriptorRoundtrip,
                                                                                    relay_plane.Libp2pRelayDescriptorListEncode(turnDescriptors))
    assert(IsOk(descriptorRoundtripRes), " libp2p relay plane: descriptor roundtrip")
    assert(descriptorRoundtrip.len == 1, " libp2p relay plane: descriptor roundtrip len")
    assert(descriptorRoundtrip[0].endpointText == turnDescriptors[0].endpointText,
        " libp2p relay plane: descriptor roundtrip endpoint")

    var candidates: host.Libp2pRelayCandidate[]
    let candidatesRes = host.Libp2pSelectRelayCandidates(client,
                                                           types.Libp2pRelayServiceTurn,
                                                           "sfo",
                                                           3,
                                                           candidates)
    assert(IsOk(candidatesRes), " libp2p relay plane: select candidates")
    assert(candidates.len == 1, " libp2p relay plane: one selected candidate")
    assert(candidates[0].descriptor.endpointText == "turn:203.0.113.77:3478",
        " libp2p relay plane: selected turn endpoint")

    let turnLeaseRes = host.Libp2pRelayLeaseRequestFetch(client,
                                                           server,
                                                           server.selfPeerId,
                                                           types.Libp2pRelayServiceTurn,
                                                           "sfo")
    assert(IsOk(turnLeaseRes), " libp2p relay plane: turn lease")
    let turnLease = Value(turnLeaseRes)
    assert(turnLease.username != "", " libp2p relay plane: turn username")
    assert(turnLease.credential != "", " libp2p relay plane: turn credential")

    let stunLeaseRes = host.Libp2pRelayLeaseRequestFetch(client,
                                                           server,
                                                           server.selfPeerId,
                                                           types.Libp2pRelayServiceStun,
                                                           "sfo")
    assert(IsOk(stunLeaseRes), " libp2p relay plane: stun lease")
    let stunLease = Value(stunLeaseRes)
    assert(stunLease.username == "", " libp2p relay plane: stun user empty")

    let tsnetLeaseRes = host.Libp2pRelayLeaseRequestFetch(client,
                                                            server,
                                                            server.selfPeerId,
                                                            types.Libp2pRelayServiceTsnet,
                                                            "sfo")
    assert(IsOk(tsnetLeaseRes), " libp2p relay plane: tsnet lease")
    let tsnetLease = Value(tsnetLeaseRes)
    assert(tsnetLease.endpointText == "https://derp.sfo.example:443",
        " libp2p relay plane: tsnet endpoint")
    assert(tsnetLease.username != "", " libp2p relay plane: tsnet credential user")

    let leaseRoundtripPayload = relay_plane.Libp2pRelayLeaseEncode(turnLease)
    var turnLeaseRoundtrip: types.Libp2pRelayLease
    let leaseRoundtripRes = relay_plane.Libp2pRelayLeaseDecodeFill(turnLeaseRoundtrip,
                                                                     leaseRoundtripPayload)
    assert(IsOk(leaseRoundtripRes), " libp2p relay plane: lease roundtrip")
    assert(turnLeaseRoundtrip.endpointText == turnLease.endpointText,
        " libp2p relay plane: lease roundtrip endpoint")

    var cfg: webrtc_transport.Libp2pWebrtcTransportConfig
    let applyTurnRes = webrtc_transport.Libp2pWebrtcTransportConfigApplyRelayLease(cfg, turnLease)
    assert(IsOk(applyTurnRes), " libp2p relay plane: apply turn lease")
    let applyStunRes = webrtc_transport.Libp2pWebrtcTransportConfigApplyRelayLease(cfg, stunLease)
    assert(IsOk(applyStunRes), " libp2p relay plane: apply stun lease")
    assert(cfg.relayOnly, " libp2p relay plane: relay only")
    assert(cfg.turnServers.len == 1, " libp2p relay plane: turn server count")
    assert(cfg.stunUrls.len == 1, " libp2p relay plane: stun url count")

    echo(" libp2p_relay_plane_smoke ok")
    return 0
