import std/result
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/apps/chain_node/chain_node as chain
import cheng/apps/chain_node/cheng_node as node
import cheng/apps/chain_node/cheng_node_ctl_main as ctl
import cheng/apps/chain_node/cheng_node_index as cindex
import cheng/apps/chain_node/cheng_node_object as cobject
import cheng/apps/chain_node/cheng_node_state as state
import cheng/apps/chain_node/cheng_node_domains as domains
import cheng/oracle/oracle_bft_state_host as oracle_host
import cheng/core/tooling/path as v3path
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg

fn main(): int32 =
    let rootSeed = "cheng-node-migration-root"
    let legacyChainPath = "/tmp/cheng_node_migration_legacy_chain.state"
    let legacyOraclePath = "/tmp/cheng_node_migration_legacy_oracle.state"
    let nodeStatePath = "/tmp/cheng_node_migration.state"
    let packageReportPath = "/tmp/cheng_node_migration_package.report"
    let worldReportPath = "/tmp/cheng_node_migration_world.report"
    let receiptReportPath = "/tmp/cheng_node_migration_receipt.report"

    var legacyNode: chain.V3ChainNode
    assert(IsOk(chain.V3ChainNodeInitInto(legacyNode,
                                          "cheng.node.migration.legacy",
                                          "cheng.node.migration.addr")),
           "cheng_node migration smoke: init legacy chain")
    assert(IsOk(chain.V3ChainNodeMint(legacyNode, 77, 1001, int64(90))),
           "cheng_node migration smoke: legacy mint")
    assert(IsOk(chain.V3ChainNodeTransfer(legacyNode, 77, 1001, 1002, int64(35))),
           "cheng_node migration smoke: legacy transfer")
    var legacySnapshot: chain.V3ChainNodeServeSnapshot
    chain.V3ChainNodeServeOnceInto(legacySnapshot, legacyNode)
    assert(IsOk(state.V3ChengNodeWriteLegacyChainState(legacyChainPath, legacySnapshot)),
           "cheng_node migration smoke: write legacy chain state")

    let importChainRes = ctl.v3ChengNodeCtlImportLegacyChainText(rootSeed,
                                                                 legacyChainPath,
                                                                 nodeStatePath)
    assert(IsOk(importChainRes), "cheng_node migration smoke: import legacy chain")

    var oracleDomain = domains.V3ChengNodeOracleDomainInit()
    let finalizeRes = domains.V3ChengNodeOracleFinalizeFixtureRound(oracleDomain, int64(22))
    assert(IsOk(finalizeRes), "cheng_node migration smoke: finalize oracle round")
    assert(IsOk(oracle_host.v3OracleBftWriteState(legacyOraclePath, oracleDomain.machine)),
           "cheng_node migration smoke: write legacy oracle state")

    let importOracleRes = ctl.v3ChengNodeCtlImportLegacyOracleText(rootSeed,
                                                                   nodeStatePath,
                                                                   legacyOraclePath)
    assert(IsOk(importOracleRes), "cheng_node migration smoke: import legacy oracle")

    let sourceCid = node.v3ChengNodeHashTextCid("compiler-source", "pkg://cheng/migration-demo")
    let csgCid = node.v3ChengNodeHashTextCid("compiler-csg", "migration-demo")
    let exportCid = node.v3ChengNodeHashTextCid("compiler-export", "migration-demo")
    let syntaxCid = node.v3ChengNodeHashTextCid("compiler-syntax", "migration-demo")
    let digestCid = node.v3ChengNodeHashTextCid("compiler-output", "migration-demo")
    let emptyDepsManifestCid = cworld.v3CompilerWorldEmptyManifestCid("stable")
    let pkg = cworld.v3CompilerPackageSnapshotMake("pkg://cheng/migration-demo",
                                                   "stable",
                                                   sourceCid,
                                                   csgCid,
                                                   exportCid,
                                                   syntaxCid,
                                                   layout.FixedBytes32(),
                                                   layout.FixedBytes32(),
                                                   layout.FixedBytes32(),
                                                   emptyDepsManifestCid,
                                                   layout.FixedBytes32(),
                                                   "stage3_local")
    let manifestRes = cworld.v3CompilerUniverseManifestMake("stable",
                                                            [cworld.v3CompilerUniverseManifestEntryMake(pkg.packageId,
                                                                                                       pkg.snapshotCid,
                                                                                                       pkg.syntaxSurfaceCid,
                                                                                                       pkg.migrationProofCid)])
    assert(IsOk(manifestRes), "cheng_node migration smoke: manifest make")
    let worldHead = cworld.v3CompilerWorldHeadMake("stable",
                                                   5,
                                                   layout.FixedBytes32(),
                                                   Value(manifestRes),
                                                   csgCid,
                                                   pkg.snapshotCid,
                                                   pkg.snapshotCid,
                                                   pkg.snapshotCid,
                                                   "stage3_local")
    let receipt = ccsg.v3CompileReceiptMake(worldHead.headCid,
                                            csgCid,
                                            csgCid,
                                            "arm64-apple-darwin",
                                            digestCid,
                                            digestCid,
                                            "stage3_local",
                                            ["runtime.contract"])
    assert(v3path.V3WriteTextFile(v3path.V3PathCurrentDir(),
                                  packageReportPath,
                                  cworld.v3CompilerPackageSnapshotReport(pkg)),
           "cheng_node migration smoke: write package report")
    assert(v3path.V3WriteTextFile(v3path.V3PathCurrentDir(),
                                  worldReportPath,
                                  cworld.v3CompilerWorldHeadReport(worldHead)),
           "cheng_node migration smoke: write world report")
    assert(v3path.V3WriteTextFile(v3path.V3PathCurrentDir(),
                                  receiptReportPath,
                                  ccsg.v3CompileReceiptReport(receipt)),
           "cheng_node migration smoke: write receipt report")

    assert(IsOk(ctl.v3ChengNodeCtlImportCompilerPackageText(rootSeed,
                                                            nodeStatePath,
                                                            packageReportPath)),
           "cheng_node migration smoke: import compiler package")
    assert(IsOk(ctl.v3ChengNodeCtlImportCompilerWorldText(rootSeed,
                                                          nodeStatePath,
                                                          worldReportPath)),
           "cheng_node migration smoke: import compiler world")
    assert(IsOk(ctl.v3ChengNodeCtlImportCompilerReceiptText(rootSeed,
                                                            nodeStatePath,
                                                            receiptReportPath,
                                                            "publish:migration-demo")),
           "cheng_node migration smoke: import compiler receipt")
    let usageText = ctl.v3ChengNodeCtlUsageText()
    assert(strutil.Contains(usageText, "migration import legacy-oracle"),
           "cheng_node migration smoke: usage legacy oracle")
    assert(strutil.Contains(usageText, "migration import compiler-package"),
           "cheng_node migration smoke: usage compiler package")
    assert(strutil.Contains(usageText, "migration import compiler-world"),
           "cheng_node migration smoke: usage compiler world")
    assert(strutil.Contains(usageText, "migration import compiler-receipt"),
           "cheng_node migration smoke: usage compiler receipt")
    assert(strutil.Contains(usageText, "migration verify legacy-chain"),
           "cheng_node migration smoke: usage verify legacy chain")
    assert(strutil.Contains(usageText, "migration verify legacy-oracle"),
           "cheng_node migration smoke: usage verify legacy oracle")
    assert(strutil.Contains(usageText, "migration verify compiler-package"),
           "cheng_node migration smoke: usage verify compiler package")
    assert(strutil.Contains(usageText, "migration verify compiler-world"),
           "cheng_node migration smoke: usage verify compiler world")
    assert(strutil.Contains(usageText, "migration verify compiler-receipt"),
           "cheng_node migration smoke: usage verify compiler receipt")
    assert(!strutil.Contains(usageText, "import-legacy-chain"),
           "cheng_node migration smoke: no old import legacy chain command")
    assert(!strutil.Contains(usageText, "verify-legacy-oracle"),
           "cheng_node migration smoke: no old verify legacy oracle command")

    var core: node.V3ChengNode
    assert(IsOk(state.V3ChengNodeLoadStateInto(core, nodeStatePath, rootSeed)),
           "cheng_node migration smoke: reload node state")

    let balanceQueryRes = node.V3ChengNodeBalanceQueryText(core, 77, 1001, false)
    assert(IsOk(balanceQueryRes), "cheng_node migration smoke: balance query")
    assert(strutil.Contains(Value(balanceQueryRes), "balance=55"),
           "cheng_node migration smoke: balance imported")

    let oracleQueryRes = node.V3ChengNodeOracleQueryText(core, "BTC/USD", false)
    assert(IsOk(oracleQueryRes), "cheng_node migration smoke: oracle query")
    let oracleQueryText = Value(oracleQueryRes)
    assert(strutil.Contains(oracleQueryText, "round_id=22"),
           "cheng_node migration smoke: oracle round imported")
    assert(strutil.Contains(oracleQueryText, "price_e8=22000001021"),
           "cheng_node migration smoke: oracle query summary from indexed payload")
    assert(strutil.Contains(oracleQueryText, "payload_present=1"),
           "cheng_node migration smoke: oracle proof payload")

    let packageQueryRes = node.V3ChengNodeKeyedQueryText(core,
                                                         "compiler",
                                                         "package",
                                                         pkg.packageId,
                                                         false)
    assert(IsOk(packageQueryRes), "cheng_node migration smoke: compiler package query")
    assert(strutil.Contains(Value(packageQueryRes), "payload_present=1"),
           "cheng_node migration smoke: compiler package payload")

    let worldQueryRes = node.V3ChengNodeKeyedQueryText(core,
                                                       "compiler",
                                                       "world_head",
                                                       layout.fixedBytes32Hex(worldHead.headCid),
                                                       false)
    assert(IsOk(worldQueryRes), "cheng_node migration smoke: compiler world query")
    assert(strutil.Contains(Value(worldQueryRes), "payload_present=1"),
           "cheng_node migration smoke: compiler world payload")

    let receiptEntryRes = cindex.V3ChengNodeIndexGet(core.indices,
                                                     "compiler",
                                                     "build_receipt",
                                                     "publish:migration-demo")
    assert(IsOk(receiptEntryRes), "cheng_node migration smoke: compiler receipt query")
    let receiptObjectRes = cobject.V3ChengNodeObjectStoreGet(core.objects,
                                                             Value(receiptEntryRes).valueCid)
    assert(IsOk(receiptObjectRes), "cheng_node migration smoke: compiler receipt object")
    assert(strutil.Contains(Value(receiptObjectRes).text, layout.fixedBytes32Hex(receipt.receiptCid)),
           "cheng_node migration smoke: compiler receipt cid")

    let targetEntryRes = cindex.V3ChengNodeIndexGet(core.indices,
                                                    "compiler",
                                                    "target",
                                                    receipt.targetTriple)
    assert(IsOk(targetEntryRes), "cheng_node migration smoke: compiler target query")
    let targetObjectRes = cobject.V3ChengNodeObjectStoreGet(core.objects,
                                                            Value(targetEntryRes).valueCid)
    assert(IsOk(targetObjectRes), "cheng_node migration smoke: compiler target object")
    assert(strutil.Contains(Value(targetObjectRes).text, "publish:migration-demo"),
           "cheng_node migration smoke: compiler target receipt key")

    echo("v3 cheng_node_migration_smoke ok")
    return 0
