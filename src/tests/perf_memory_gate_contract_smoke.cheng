import cheng/core/tooling/path as chengpath
import cheng/core/tooling/perf_memory_gate as perfgate

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let expectedCompiler = chengpath.PathJoin(workspaceRoot, "artifacts/backend_driver/cheng")
    let resolvedCompiler = perfgate.PerfMemoryResolveCompiler(workspaceRoot)
    assert(resolvedCompiler == expectedCompiler,
           " perf memory gate contract: default compiler prefers backend driver")

    let darwinOutput = "6.98 real 5.17 user 1.74 sys\n11737513984 maximum resident set size\n1638712 peak memory footprint\n"
    var elapsedMs: int64 = int64(-1)
    var maxRssBytes: int64 = int64(-1)
    var peakBytes: int64 = int64(-1)
    perfgate.PerfMemoryParseDarwinMetrics(darwinOutput, elapsedMs, maxRssBytes, peakBytes)
    assert(elapsedMs == int64(6980), " perf memory gate contract: darwin elapsed")
    assert(peakBytes == int64(1638712), " perf memory gate contract: peak footprint parsed")
    assert(maxRssBytes == peakBytes, " perf memory gate contract: peak footprint is contract rss")

    let phaseReport = """
    exec_phase_total_ms=100
    exec_phase_linux_nolibc_objects_ms=0
    exec_phase_provider_objects_ms=7
    exec_phase_provider_cache_lookup_ms=1
    exec_phase_provider_cache_copy_ms=2
    exec_phase_provider_cache_store_ms=3
    exec_phase_cheng_provider_compile_ms=4
    exec_phase_c_provider_compile_ms=0
    provider_object_cache_hit_count=5
    provider_object_cache_miss_count=6
    exec_phase_primary_object_cache_lookup_ms=8
    exec_phase_primary_object_cache_copy_ms=9
    exec_phase_primary_object_cache_store_ms=10
    primary_object_cache_hit_count=11
    primary_object_cache_miss_count=12
    exec_phase_primary_object_emit_ms=23
    exec_phase_primary_object_global_storage_ms=1
    exec_phase_primary_object_module_init_ms=2
    exec_phase_primary_object_function_emit_ms=13
    exec_phase_primary_object_entry_bridge_ms=1
    exec_phase_primary_object_line_map_embed_ms=2
    exec_phase_primary_object_symbol_trailer_ms=1
    exec_phase_primary_object_asm_write_ms=1
    exec_phase_primary_object_asm_compile_ms=2
    primary_object_asm_bytes=4096
    primary_object_line_map_asm_bytes=512
    exec_phase_materialize_total_ms=30
    exec_phase_native_link_ms=11
    exec_phase_line_map_ms=3
    exec_phase_backend_total_ms=144

    """
    let phases = perfgate.PerfMemoryExecPhaseSummaryFromOutput(phaseReport)
    assert(perfgate.PerfMemoryCompileGapBreakdownReady(phases),
           " perf memory gate contract: compile gap breakdown ready")
    assert(perfgate.PerfMemoryExecPhaseMaterializeMs(phases) == int64(30),
           " perf memory gate contract: materialize total")
    assert(perfgate.PerfMemoryExecPhaseAttributedMs(phases) == int64(144),
           " perf memory gate contract: backend attributed total")
    assert(phases.providerCacheLookupMs == int64(1),
           " perf memory gate contract: provider cache lookup")
    assert(phases.providerCacheCopyMs == int64(2),
           " perf memory gate contract: provider cache copy")
    assert(phases.providerCacheStoreMs == int64(3),
           " perf memory gate contract: provider cache store")
    assert(phases.chengProviderCompileMs == int64(4),
           " perf memory gate contract: cheng provider compile")
    assert(phases.cProviderCompileMs == int64(0),
           " perf memory gate contract: c provider compile")
    assert(phases.providerObjectCacheHitCount == int64(5),
           " perf memory gate contract: provider cache hit count")
    assert(phases.providerObjectCacheMissCount == int64(6),
           " perf memory gate contract: provider cache miss count")
    assert(phases.primaryObjectCacheLookupMs == int64(8),
           " perf memory gate contract: primary object cache lookup")
    assert(phases.primaryObjectCacheCopyMs == int64(9),
           " perf memory gate contract: primary object cache copy")
    assert(phases.primaryObjectCacheStoreMs == int64(10),
           " perf memory gate contract: primary object cache store")
    assert(phases.primaryObjectCacheHitCount == int64(11),
           " perf memory gate contract: primary object cache hit count")
    assert(phases.primaryObjectCacheMissCount == int64(12),
           " perf memory gate contract: primary object cache miss count")
    assert(phases.primaryObjectGlobalStorageMs == int64(1),
           " perf memory gate contract: primary object global storage")
    assert(phases.primaryObjectModuleInitMs == int64(2),
           " perf memory gate contract: primary object module init")
    assert(phases.primaryObjectFunctionEmitMs == int64(13),
           " perf memory gate contract: primary object function emit")
    assert(phases.primaryObjectEntryBridgeMs == int64(1),
           " perf memory gate contract: primary object entry bridge")
    assert(phases.primaryObjectLineMapEmbedMs == int64(2),
           " perf memory gate contract: primary object line map embed")
    assert(phases.primaryObjectSymbolTrailerMs == int64(1),
           " perf memory gate contract: primary object symbol trailer")
    assert(phases.primaryObjectAsmWriteMs == int64(1),
           " perf memory gate contract: primary object asm write")
    assert(phases.primaryObjectAsmCompileMs == int64(2),
           " perf memory gate contract: primary object asm compile")
    assert(phases.primaryObjectAsmBytes == int64(4096),
           " perf memory gate contract: primary object asm bytes")
    assert(phases.primaryObjectLineMapAsmBytes == int64(512),
           " perf memory gate contract: primary object line map asm bytes")

    echo(" perf_memory_gate_contract_smoke ok")
    return 0
