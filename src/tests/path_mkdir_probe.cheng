import std/os
import std/strings
import std/strformat as sf
import cheng/core/tooling/path as chengpath
import std/strutils as strutil

fn main(): int32 =
    let root = os.GetCurrentDir()
    let raw = "artifacts/path_mkdir_probe"
    let path = chengpath.PathAbsolute(root, raw)
    assert(strings.Len(root) > 0, " path probe: root")
    assert(strings.Len(path) > 0, " path probe: absolute path")
    echo(strutil.Join([" root=", root], ""))
    echo(strutil.Join([" path=", path], ""))
    let exists = os.DirExists(path)
    echo(strutil.Join([" exists=", exists ? "true" : "false"], ""))
    if !chengpath.MkdirP(root, raw):
        return 3
    echo(" path_mkdir_probe ok")
    return 0
