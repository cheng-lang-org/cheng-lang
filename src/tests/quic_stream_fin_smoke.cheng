import std/result
import cheng/quic/connection as qconn
import cheng/quic/msquicruntime as qruntime
import cheng/quic/msquictransport_native as qtransport
import cheng/libp2p/transports/quic_transport

fn quicStreamFinBytesEq(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    var settings = qruntime.initMsQuicSettings()
    settings.allowDatagram = true

    var listener = qtransport.InitMsQuicTransport()
    assert(IsOk(qtransport.setMsQuicTransportSettings(listener, settings)),
        " quic stream fin: listener settings")
    assert(IsOk(quic_transport.Libp2pQuicConfigureTls(listener)),
        " quic stream fin: listener tls")
    let listenAddrRes = quic_transport.Libp2pQuicAddrFromHostPort("127.0.0.1", 0)
    assert(IsOk(listenAddrRes), " quic stream fin: listen addr")
    qtransport.start(listener, Value(listenAddrRes))

    var client = qtransport.InitMsQuicTransport()
    assert(IsOk(qtransport.setMsQuicTransportSettings(client, settings)),
        " quic stream fin: client settings")
    assert(IsOk(quic_transport.Libp2pQuicConfigureTls(client)),
        " quic stream fin: client tls")
    let dialRes = qtransport.dial(client, listener.listenAddr)
    assert(IsOk(dialRes), " quic stream fin: dial")
    var clientLegacy = Value(dialRes)
    let acceptRes = qtransport.accept(listener)
    assert(IsOk(acceptRes), " quic stream fin: accept")
    var serverLegacy = Value(acceptRes)

    let streamPairRes = qconn.newNativeConnectionPairForStreams(clientLegacy.localAddr,
                                                                clientLegacy.remoteAddr,
                                                                serverLegacy.localAddr,
                                                                serverLegacy.remoteAddr,
                                                                4,
                                                                4,
                                                                4,
                                                                4)
    assert(IsOk(streamPairRes), " quic stream fin: stream pair")
    var clientStream = Value(streamPairRes).outbound
    var serverStream = Value(streamPairRes).inbound

    let clientPayload: Bytes = bytesFromString("client-half-close")
    assert(IsOk(qconn.connWrite(clientStream, clientPayload)),
        " quic stream fin: client write")
    assert(IsOk(qconn.connShutdownWrite(clientStream)),
        " quic stream fin: client shutdown write")
    let serverReadRes = qconn.connRead(serverStream, bytesLen(clientPayload))
    assert(IsOk(serverReadRes), " quic stream fin: server read")
    assert(quicStreamFinBytesEq(Value(serverReadRes), clientPayload),
        " quic stream fin: server payload")
    let serverEofRes = qconn.connReadNonblocking(serverStream, 1)
    assert(IsErr(serverEofRes), " quic stream fin: server eof err")
    assert(ErrorText(serverEofRes) == "msquic: stream closed",
        " quic stream fin: server eof text")

    let serverPayload: Bytes = bytesFromString("server-still-writes")
    assert(IsOk(qconn.connWrite(serverStream, serverPayload)),
        " quic stream fin: server write")
    assert(IsOk(qconn.connShutdownWrite(serverStream)),
        " quic stream fin: server shutdown write")
    let clientReadRes = qconn.connRead(clientStream, bytesLen(serverPayload))
    assert(IsOk(clientReadRes), " quic stream fin: client read")
    assert(quicStreamFinBytesEq(Value(clientReadRes), serverPayload),
        " quic stream fin: client payload")
    let clientEofRes = qconn.connReadNonblocking(clientStream, 1)
    assert(IsErr(clientEofRes), " quic stream fin: client eof err")
    assert(ErrorText(clientEofRes) == "msquic: stream closed",
        " quic stream fin: client eof text")

    qconn.ConnClose(serverStream)
    qconn.ConnClose(clientStream)
    qconn.ConnClose(serverLegacy)
    qconn.ConnClose(clientLegacy)
    qtransport.Stop(listener)
    echo(" quic_stream_fin_smoke ok")
    return 0
