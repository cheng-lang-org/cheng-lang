import std/system
import std/result
import cheng/quic/congestion/common
import cheng/quic/congestion/bbr_model
import cheng/quic/congestion/cubic_model
import cheng/quic/congestion/pacing_scheduler
import cheng/quic/congestion/validation_suite

fn validateBbrFlow(): Result[bool] =
    var model = bbr_model.bbrInit(common.quicInitialWindowPackets, 1200)
    if !bbr_model.bbrCanSend(model):
        return Err[bool]("congestion: bbr cannot send at init")
    let window = model.congestionWindow
    if window <= 0:
        return Err[bool]("congestion: invalid cwnd")
    let allowance0 = bbr_model.bbrSendAllowance(model)
    if allowance0 <= 0:
        return Err[bool]("congestion: invalid allowance")
    bbr_model.bbrOnPacketSent(model, 1200, false)
    let ack = validation_suite.initAckSnapshot(1000, 1, 1, 1200)
    let ackHeight = bbr_model.bbrOnDataAcked(model, ack)
    var pacing = pacing_scheduler.pacingInit(true)
    if ackHeight > 0:
        pacing_scheduler.pacingRecordAckHeight(pacing, ackHeight)
    let allowance1 = pacing_scheduler.pacingAllowance(pacing, model, 1000)
    if allowance1 < 0:
        return Err[bool]("congestion: negative allowance")
    if model.deliveryRateBps <= 0:
        return Err[bool]("congestion: invalid delivery rate")
    return Ok[bool](true)

fn validateCubicFlow(): Result[bool] =
    var model = cubic_model.cubicInit(common.quicInitialWindowPackets, 1200, 0)
    if !cubic_model.cubicCanSend(model):
        return Err[bool]("congestion: cubic cannot send at init")
    cubic_model.cubicOnPacketSent(model, 1200, true)
    let ack = validation_suite.initAckSnapshot(2000000, 1, 1, 1200)
    cubic_model.cubicOnDataAcked(model, ack)
    if model.congestionWindow <= 0:
        return Err[bool]("congestion: cubic window ! positive")
    let loss = validation_suite.initLossSnapshot(2, 600)
    cubic_model.cubicOnDataLost(model, loss)
    if model.congestionWindow <= 0:
        return Err[bool]("congestion: cubic window ! positive after loss")
    return Ok[bool](true)

fn main(): int32 =
    let bbrRes = validateBbrFlow()
    if IsErr(bbrRes):
        panic(ErrorText(bbrRes))
    let cubicRes = validateCubicFlow()
    if IsErr(cubicRes):
        panic(ErrorText(cubicRes))
    let suiteRes = validation_suite.runCongestionValidationSuite()
    if IsErr(suiteRes):
        panic(ErrorText(suiteRes))
    echo("v3 congestion_validation_smoke ok")
    return 0
