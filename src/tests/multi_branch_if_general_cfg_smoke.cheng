import std/os
import std/strings
import cheng/core/tooling/compiler_request as creq
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/backend/primary_object_plan as pobj
import cheng/core/ir/core_types as ir

fn main(): int32 =
    let rootDir = os.GetCurrentDir()
    let req = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/multi_branch_if_general_cfg_fixture.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/multi_branch_if_general_cfg_fixture.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err: str
    assert(slplan.BuildSystemLinkPlanStub(rootDir, req, linkPlan, err),
           " multi branch if cfg smoke: link plan")
    var loweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(linkPlan, loweringPlan, err),
           " multi branch if cfg smoke: lowering plan")
    let primary = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    assert(primary.missingReasons.len == 0,
           " multi branch if cfg smoke: primary missing reasons")
    assert(primary.functionBodyIRs.len >= 2,
           " multi branch if cfg smoke: function count")
    for fi in 0..<primary.functionBodyIRs.len:
        let bodyIR = primary.functionBodyIRs[fi]
        assert(pobj.PrimaryBodyIrGeneralCfgWordCount(bodyIR) > 0,
               Fmt" multi branch if cfg smoke: primary general cfg word count for function index {strings.IntToStr(fi)}")
        assert(primary.functionWordCounts[fi] == pobj.PrimaryBodyIrGeneralCfgWordCount(bodyIR),
               Fmt" multi branch if cfg smoke: plan word count for function index {strings.IntToStr(fi)}")
    echo(" multi_branch_if_general_cfg_smoke ok")
    return 0
