import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_list_dir_smoke_tmp"
    let childDir: str = os.JoinPath(tmpRoot, "nested")
    let childFile: str = os.JoinPath(tmpRoot, "top.txt")
    let deepFile: str = os.JoinPath(childDir, "deep.txt")

    if os.FileExists(deepFile):
        assert(os.RemoveFile(deepFile), " ordinary os.ListDir cleanup deep file")
    if os.FileExists(childFile):
        assert(os.RemoveFile(childFile), " ordinary os.ListDir cleanup top file")
    if os.DirExists(childDir):
        os.RemoveDir(childDir)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

    os.CreateDir(tmpRoot)
    os.CreateDir(childDir)
    os.WriteFile(childFile, "top")
    os.WriteFile(deepFile, "deep")

    let entries = os.ListDir(tmpRoot)
    var sawDir: bool
    var sawFile: bool
    var sawDeep: bool
    for i in 0..<entries.len:
        let entry = entries[i]
        if entry == "nested":
            sawDir = true
        elif entry == "top.txt":
            sawFile = true
        elif entry == "deep.txt":
            sawDeep = true

    assert(entries.len == 2, " ordinary os.ListDir count")
    assert(sawDir, " ordinary os.ListDir dir entry")
    assert(sawFile, " ordinary os.ListDir file entry")
    assert(!sawDeep, " ordinary os.ListDir excludes nested entry")

    assert(os.FileExists(deepFile), " ordinary os.ListDir deep file still exists")
    assert(os.RemoveFile(deepFile), " ordinary os.ListDir remove deep file")
    assert(os.RemoveFile(childFile), " ordinary os.ListDir remove top file")
    os.RemoveDir(childDir)
    os.RemoveDir(tmpRoot)
    echo(" os_list_dir_smoke ok")
    return 0
