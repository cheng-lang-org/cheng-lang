import std/os

fn main(): int32 =
    let quoted: str = os.QuoteShell("/bin/echo")
    assert(quoted == "'/bin/echo'", " string quoteShell")
    var manual: str = "'"
    manual = manual + "min-ok"
    manual = manual + "'"
    assert(manual == "'min-ok'", " string manual concat")
    echo(" string_concat_quote_shell_smoke ok")
    return 0
