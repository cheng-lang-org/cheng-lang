import std/system
import std/rawbytes
import std/strutils as strutil

fn releaseOwnedBytes(data: var Bytes) =
    if data.data != nil:
        memRelease(data.data)
    data = emptyBytes()

fn smokeBorrowedBytesViewNoop() =
    let view: Bytes = bytesFromString("join/path")
    assert(view.data != nil, " bytes view orc: borrowed view ptr")
    let borrowedRc0 = memRefCount(view.data)
    assert(borrowedRc0 == 0, strutil.Join([" bytes view orc: borrowed view starts outside registry actual=", intToStr(borrowedRc0)], ""))
    memDiagReset()
    memRetain(view.data)
    memRelease(view.data)
    let borrowedRc1 = memRefCount(view.data)
    assert(borrowedRc1 == 0, strutil.Join([" bytes view orc: borrowed view retain/release no-op actual=", intToStr(borrowedRc1)], ""))
    assert(memRetainCount() == 0, " bytes view orc: borrowed view retain count stays zero")
    assert(memReleaseCount() == 0, " bytes view orc: borrowed view release count stays zero")

fn smokeOwnedBytesRegistry() =
    var owned: Bytes = bytesAlloc(8)
    let raw = owned.data
    assert(raw != nil, " bytes view orc: owned ptr")
    let ownedRc0 = memRefCount(raw)
    assert(ownedRc0 > 0, strutil.Join([" bytes view orc: owned initial rc positive actual=", intToStr(ownedRc0)], ""))
    memDiagReset()
    memRetain(raw)
    memRelease(raw)
    assert(memRetainCount() == 1, " bytes view orc: owned retain counted")
    assert(memReleaseCount() == 1, " bytes view orc: owned release counted")
    let ownedRc1 = memRefCount(raw)
    assert(ownedRc1 == ownedRc0, strutil.Join([" bytes view orc: owned rc restored actual=", intToStr(ownedRc1)], ""))
    releaseOwnedBytes(owned)
    let ownedRc2 = memRefCount(raw)
    assert(ownedRc2 == 0, strutil.Join([" bytes view orc: owned final rc actual=", intToStr(ownedRc2)], ""))

fn main(): int32 =
    smokeBorrowedBytesViewNoop()
    smokeOwnedBytesRegistry()
    echo(" bytes_view_orc_registry_smoke ok")
    return 0
