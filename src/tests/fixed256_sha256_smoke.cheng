import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/std/crypto/fixed256 as fixed256

fn main(): int32 =
    let input: Bytes = bytesFromString("abc")
    let span: layout.ByteSpan = layout.ByteSpanFromBytes(input)
    let digest: layout.FixedBytes32 = fixed256.sha256Fixed(span)
    let expectRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(
        "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
    assert(IsOk(expectRes), " fixed256 sha256: expect")
    let expectFixed: layout.FixedBytes32 = Value(expectRes)
    let digestBytes: Bytes = layout.FixedBytes32ToBytes(digest)
    let expectBytes: Bytes = layout.FixedBytes32ToBytes(expectFixed)
    assert(bytesGet(expectBytes, 0) == 0xba, " fixed256 sha256: expect byte0")
    assert(bytesGet(expectBytes, 1) == 0x78, " fixed256 sha256: expect byte1")
    assert(bytesGet(expectBytes, 31) == 0xad, " fixed256 sha256: expect byte31")
    assert(bytesGet(digestBytes, 0) == 0xba, " fixed256 sha256: digest byte0")
    assert(bytesGet(digestBytes, 1) == 0x78, " fixed256 sha256: digest byte1")
    assert(bytesGet(digestBytes, 31) == 0xad, " fixed256 sha256: digest byte31")
    assert(layout.FixedBytes32Equal(digest, expectFixed), " fixed256 sha256: digest")
    echo(" fixed256_sha256_smoke ok")
    return 0
