import std/os
import std/strings
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root = os.GetCurrentDir()
    let dispatchPath = chengpath.PathJoin(root, "src/core/tooling/backend_driver_dispatch_min.cheng")
    let dispatchText = chengpath.ReadTextFile("", dispatchPath)
    assert(strings.StrContains(dispatchText, "DirectObjectEmitStandaloneExecutable(driverRoot, primaryPlan, linkPlan.outputPath)"),
           "direct_exe_dispatch_contract_smoke: standalone executable writer")
    assert(strings.StrContains(dispatchText, "tmat.TargetIsDarwinArm64(linkPlan.targetTriple)"),
           "direct_exe_dispatch_contract_smoke: darwin standalone gate")
    assert(strings.StrContains(dispatchText, "native_link_log=-"),
           "direct_exe_dispatch_contract_smoke: no native link log")
    assert(strings.StrContains(dispatchText, "direct_object_output_kind={object.outputKind}"),
           "direct_exe_dispatch_contract_smoke: executable output kind report")
    assert(strings.StrContains(dispatchText, "return BackendDriverDispatchMinRunSystemLinkExecEmitExeProviders(driverRoot, reportPath, linkPlan, loweringPlan, primaryPlan, phaseProfile)"),
           "direct_exe_dispatch_contract_smoke: provider-backed direct executable path")
    assert(strings.StrContains(dispatchText, "system_link_exec_runtime_standalone_no_runtime=0"),
           "direct_exe_dispatch_contract_smoke: provider-backed runtime report")
    assert(!strings.StrContains(dispatchText, "provider-backed direct executable is not closed in dispatch_min"),
           "direct_exe_dispatch_contract_smoke: provider-backed path no longer hard fails")
    assert(!strings.StrContains(dispatchText, "standalone path received provider modules"),
           "direct_exe_dispatch_contract_smoke: standalone direct ignores stale providers")
    echo("direct_exe_dispatch_contract_smoke ok")
    return 0
