import cheng/core/tooling/compiler_equivalence as ceq
import cheng/core/tooling/compiler_publish_gate as cpub
import cheng/std/bytes_layout as layout

fn main(): int32 =
    var worldHeadCid = layout.FixedBytes32()
    var passedProof: ceq.V3CompilerEquivalenceProof
    passedProof.packageId = "cheng"
    passedProof.channel = "stable"
    passedProof.baselineGraphCid = worldHeadCid
    passedProof.migratedGraphCid = worldHeadCid
    passedProof.baselineSurfaceCid = worldHeadCid
    passedProof.migratedSurfaceCid = worldHeadCid
    passedProof.baselineReceiptCid = worldHeadCid
    passedProof.migratedReceiptCid = worldHeadCid
    passedProof.targetTriple = "arm64-apple-darwin"
    passedProof.graphEquivalent = 1
    passedProof.exportSurfaceCompatible = 1
    passedProof.compileReceiptEquivalent = 1
    passedProof.equivalenceLabel = ceq.v3CompilerEquivalenceKind(true, true, true)
    passedProof.proofCid = worldHeadCid
    var stableAllowedChannel = ""
    var stableAllowedGate = 0
    var stableAllowedChecked = 0
    var stableAllowedPassed = 0
    var stableAllowedPublish = 0
    var stableAllowedProofCid = layout.FixedBytes32()
    let stableAllowedRes = cpub.v3CompilerPublishDecisionEvaluate("stable",
                                                                  worldHeadCid,
                                                                  true,
                                                                  passedProof,
                                                                  stableAllowedChannel,
                                                                  stableAllowedGate,
                                                                  stableAllowedChecked,
                                                                  stableAllowedPassed,
                                                                  stableAllowedPublish,
                                                                  stableAllowedProofCid)
    assert(IsOk(stableAllowedRes), "v3 compiler publish: stable allowed result")
    assert(stableAllowedGate != 0, "v3 compiler publish: stable gate")
    assert(stableAllowedPublish != 0, "v3 compiler publish: stable allowed")
    var failedProof: ceq.V3CompilerEquivalenceProof
    failedProof.packageId = "cheng"
    failedProof.channel = "stable"
    failedProof.baselineGraphCid = worldHeadCid
    failedProof.migratedGraphCid = worldHeadCid
    failedProof.baselineSurfaceCid = worldHeadCid
    failedProof.migratedSurfaceCid = worldHeadCid
    failedProof.baselineReceiptCid = worldHeadCid
    failedProof.migratedReceiptCid = worldHeadCid
    failedProof.targetTriple = "arm64-apple-darwin"
    failedProof.graphEquivalent = 0
    failedProof.exportSurfaceCompatible = 1
    failedProof.compileReceiptEquivalent = 1
    failedProof.equivalenceLabel = ceq.v3CompilerEquivalenceKind(false, true, true)
    failedProof.proofCid = worldHeadCid
    var stableBlockedChannel = ""
    var stableBlockedGate = 0
    var stableBlockedChecked = 0
    var stableBlockedPassed = 0
    var stableBlockedPublish = 0
    var stableBlockedProofCid = layout.FixedBytes32()
    let stableBlockedRes = cpub.v3CompilerPublishDecisionEvaluate("stable",
                                                                  worldHeadCid,
                                                                  true,
                                                                  failedProof,
                                                                  stableBlockedChannel,
                                                                  stableBlockedGate,
                                                                  stableBlockedChecked,
                                                                  stableBlockedPassed,
                                                                  stableBlockedPublish,
                                                                  stableBlockedProofCid)
    assert(IsOk(stableBlockedRes), "v3 compiler publish: stable blocked result")
    assert(stableBlockedPublish == 0, "v3 compiler publish: stable reject incompatible")
    var uncheckedProof: ceq.V3CompilerEquivalenceProof
    uncheckedProof.proofCid = layout.FixedBytes32()
    var edgeChannel = ""
    var edgeGate = 0
    var edgeChecked = 0
    var edgePassed = 0
    var edgePublish = 0
    var edgeProofCid = layout.FixedBytes32()
    let edgeDecisionRes = cpub.v3CompilerPublishDecisionEvaluate("edge",
                                                                 worldHeadCid,
                                                                 false,
                                                                 uncheckedProof,
                                                                 edgeChannel,
                                                                 edgeGate,
                                                                 edgeChecked,
                                                                 edgePassed,
                                                                 edgePublish,
                                                                 edgeProofCid)
    assert(IsOk(edgeDecisionRes), "v3 compiler publish: edge result")
    assert(edgeGate == 0, "v3 compiler publish: edge gate off")
    assert(edgePublish != 0, "v3 compiler publish: edge allowed")
    echo("v3 compiler_publish_smoke ok")
    return 0
