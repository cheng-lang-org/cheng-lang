import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_remove_dir_negative_smoke_tmp"
    let childFile: str = os.JoinPath(tmpRoot, "child.txt")
    if os.FileExists(childFile):
        assert(os.RemoveFile(childFile), " ordinary os.RemoveDir negative cleanup child")
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

    os.CreateDir(tmpRoot)
    os.WriteFile(childFile, "child")
    os.RemoveDir(tmpRoot)
    assert(os.DirExists(tmpRoot), " ordinary os.RemoveDir non-empty dir preserved")
    assert(os.RemoveFile(childFile), " ordinary os.RemoveDir negative remove child")
    os.RemoveDir(tmpRoot)
    assert(!os.DirExists(tmpRoot), " ordinary os.RemoveDir cleanup empty dir")
    echo(" os_remove_dir_negative_smoke ok")
    return 0
