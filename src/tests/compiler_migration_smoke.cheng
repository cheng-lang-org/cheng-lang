import std/os
import std/result
import cheng/std/bytes_layout as layout
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/lang/parser
import cheng/core/backend/system_link_plan as slplan
import std/strutils as strutil

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, strutil.Join(["artifacts/compiler_migration/", smokeLabel], ""))
    assert(chengpath.MkdirP(workspaceRoot, outDir), " compiler migration: mkdir")
    let currentSourcePath = chengpath.PathJoin(packageRoot, "src/tests/compiler_migration_fixture.cheng")
    let legacySourcePath = chengpath.PathJoin(packageRoot, "testdata/compiler_migration/compiler_migration_fixture_legacy.cheng")
    let outputPath = chengpath.PathJoin(outDir, "compiler_migration_fixture")
    let req = creq.CompilerRequestNew(
        packageRoot,
        currentSourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), " compiler migration: link plan")
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    assert(IsOk(sourceBundleRes), " compiler migration: source bundle")
    let sourceBundleCid = Value(sourceBundleRes)
    let currentCsgRes = ccsg.BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(currentCsgRes), " compiler migration: build current csg")
    let currentCsg = ccsg.CompilerCsgClone(Value(currentCsgRes))
    let entryModulePath = parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, currentSourcePath)
    let migrationRes = ccsg.BuildCompilerLegacyMigration(workspaceRoot,
                                                           packageRoot,
                                                           legacySourcePath,
                                                           linkPlan.packageId,
                                                           entryModulePath)
    assert(IsOk(migrationRes), " compiler migration: build legacy migration")
    let migration = ccsg.CompilerLegacyMigrationClone(Value(migrationRes))
    assert(migration.units.len == migration.unitCount, " compiler migration: unit count")
    assert(migration.unitCount > 0, " compiler migration: has migrated units")
    assert(migration.appliedRuleCount > 0, " compiler migration: applied rules")
    assert(migration.units[0].sourcePath == legacySourcePath, " compiler migration: first unit source path")
    assert(chengpath.TextContains(migration.units[0].migratedText, "fn ExportedAdd"),
           " compiler migration: migrated syntax")
    assert(!chengpath.TextContains(migration.units[0].migratedText, "proc ExportedAdd"),
           " compiler migration: legacy syntax removed")
    assert(layout.FixedBytes32Equal(currentCsg.canonicalGraphCid, migration.compilerCsg.canonicalGraphCid),
           " compiler migration: canonical graph match")
    let currentSurface = ccsg.CompilerExportSurfaceFromCsg(currentCsg)
    assert(ccsg.CompilerExportSurfaceCompatible(currentSurface, migration.exportSurface),
           " compiler migration: export surface compatible")
    let report = ccsg.CompilerLegacyMigrationReport(migration)
    assert(chengpath.TextContains(report, "migration_cid="), " compiler migration: report cid")
    assert(chengpath.TextContains(report, "applied_rule[0]="), " compiler migration: report rule")
    echo(" compiler_migration_smoke ok")
    return 0
