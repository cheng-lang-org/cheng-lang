import std/system
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/host/host

fn main(): int32 =
    var node: host.Libp2pHost
    node = host.Libp2pHostInit("tailnet.visibility.node")
    host.Libp2pHostSetTrustedInfra(node, true)

    var publicListen: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(publicListen, "203.0.113.8", 5501)
    var tailnetListen: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(tailnetListen, "100.64.0.8", 5502)
    multiaddr.Libp2pMultiaddrSetRoutingMeta(tailnetListen,
                                              types.Libp2pNetworkDomainTailnet,
                                              types.Libp2pVisibilityTrustedOnly,
                                              900)
    let publicListenRes = host.Libp2pListen(node, publicListen)
    assert(publicListenRes.ok, " libp2p tailnet visibility: public listen")
    let tailnetListenRes = host.Libp2pListen(node, tailnetListen)
    assert(tailnetListenRes.ok, " libp2p tailnet visibility: tailnet listen")

    let trustedViewer = peer_id.Libp2pPeerIdFromSeed("tailnet.visibility.trusted.viewer")
    var trustedViewerRecord: ps.Libp2pPeerRecord
    trustedViewerRecord.peerId = trustedViewer
    trustedViewerRecord.routingRole = overlay.OverlayRoleRegionalRouter
    trustedViewerRecord.trustedInfra = true
    ps.Libp2pPeerstoreUpsert(node.peers, trustedViewerRecord)

    let publicViewer = peer_id.Libp2pPeerIdFromSeed("tailnet.visibility.public.viewer")
    var publicViewerRecord: ps.Libp2pPeerRecord
    publicViewerRecord.peerId = publicViewer
    publicViewerRecord.routingRole = overlay.OverlayRoleEdgeRelayStore
    publicViewerRecord.trustedInfra = false
    ps.Libp2pPeerstoreUpsert(node.peers, publicViewerRecord)

    var publicListenView: types.Libp2pMultiaddr[]
    publicListenView = host.Libp2pIdentifyListenAddrsForPeer(node, publicViewer)
    assert(publicListenView.len == 1, " libp2p tailnet visibility: public listen export count")
    assert(publicListenView[0].networkDomain == types.Libp2pNetworkDomainPublic,
        " libp2p tailnet visibility: public listen export domain")

    var trustedListenView: types.Libp2pMultiaddr[]
    trustedListenView = host.Libp2pIdentifyListenAddrsForPeer(node, trustedViewer)
    assert(trustedListenView.len == 2, " libp2p tailnet visibility: trusted listen export count")

    let servicePeer = peer_id.Libp2pPeerIdFromSeed("tailnet.visibility.service")
    var serviceRecord: ps.Libp2pPeerRecord
    serviceRecord.peerId = servicePeer
    serviceRecord.routingRole = overlay.OverlayRoleRegionalRouter
    serviceRecord.trustedInfra = true
    ps.Libp2pPeerRecordPutEndpoint(serviceRecord,
                                     publicListen,
                                     false,
                                     types.Libp2pReachabilityDirect,
                                     publicListen.priority)
    ps.Libp2pPeerRecordPutEndpoint(serviceRecord,
                                     tailnetListen,
                                     false,
                                     types.Libp2pReachabilityDirect,
                                     tailnetListen.priority)
    ps.Libp2pPeerstoreUpsert(node.peers, serviceRecord)

    var publicPeerView: types.Libp2pMultiaddr[]
    publicPeerView = host.Libp2pPeerVisibleAddrs(node, servicePeer, false)
    assert(publicPeerView.len == 1, " libp2p tailnet visibility: public peer export count")
    assert(publicPeerView[0].networkDomain == types.Libp2pNetworkDomainPublic,
        " libp2p tailnet visibility: public peer export domain")

    var trustedPeerView: types.Libp2pMultiaddr[]
    trustedPeerView = host.Libp2pPeerVisibleAddrs(node, servicePeer, true)
    assert(trustedPeerView.len == 2, " libp2p tailnet visibility: trusted peer export count")

    echo(" libp2p_tailnet_visibility_smoke ok")
    return 0
