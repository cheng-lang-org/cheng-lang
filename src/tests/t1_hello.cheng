fn main(): int32 =
    var x: int32 = 10
    var y: int32 = 20
    var z: int32 = x + y
    assert(z == 30, "10 + 20 should equal 30")
    var a: int32 = z - x
    assert(a == 20, "30 - 10 should equal 20")
    var b: int32 = y * 2
    assert(b == 40, "20 * 2 should equal 40")
    echo("t1-hello-ok")
    return 0
