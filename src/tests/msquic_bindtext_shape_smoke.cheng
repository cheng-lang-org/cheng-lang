import std/system
import std/strings
import cheng/quic/platform/common
import std/strutils as strutil

fn main(): int32 =
    let portText = common.msquicPlatformIntToString(6210)
    assert(portText == "6210", "msquic bindtext shape: port text")
    let left = strutil.Join(["/ip4/127.0.0.1/udp/", portText], "")
    assert(strings.Len(left) == 23, "msquic bindtext shape: left len")
    assert(strings.HasPrefix(left, "/ip4/127.0.0.1/udp/"), "msquic bindtext shape: left prefix")
    assert(strings.HasSuffix(left, "6210"), "msquic bindtext shape: left suffix")
    let bindText = strutil.Join([left, "/quic-v1"], "")
    assert(strings.Len(bindText) == 31, "msquic bindtext shape: bind len")
    assert(strings.HasPrefix(bindText, "/ip4/127.0.0.1/udp/6210"), "msquic bindtext shape: bind prefix")
    assert(strings.HasSuffix(bindText, "/quic-v1"), "msquic bindtext shape: bind suffix")
    assert(bindText[22] == '0', "msquic bindtext shape: port last char")
    assert(bindText[23] == '/', "msquic bindtext shape: suffix slash")
    echo(" msquic_bindtext_shape_smoke ok")
    return 0
