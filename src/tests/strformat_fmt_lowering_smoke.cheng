import std/os
import std/strings
import std/strutils as strutil
import cheng/core/tooling/path as v3path
import cheng/core/tooling/host_ops as hostops

fn main(): int32 =
    let root = os.GetCurrentDir()
    let compilerEnv = os.GetEnv("CHENG_SMOKE_COMPILER")
    var compilerRaw = "artifacts/bootstrap/cheng.stage3"
    if len(compilerEnv) > 0:
        compilerRaw = compilerEnv
    var driver = compilerRaw
    if !os.IsAbsolute(compilerRaw):
        driver = os.JoinPath(root, compilerRaw)
    let target = os.GetEnvDefault("CHENG_RUNTIME_LINK_TARGET", "arm64-apple-darwin")
    let outDir = v3path.V3PathAbsolute(root, "artifacts/strformat_fmt_lowering_smoke")
    let sourcePath = os.JoinPath(root, "src/tests/strformat_fmt_smoke.cheng")
    let outBin = os.JoinPath(outDir, "strformat_fmt_smoke_probe")
    let exeReportPath = outBin + ".compile.report.txt"
    let exeCompileLog = outBin + ".compile.log"
    assert(v3path.V3MkdirP(root, outDir), "v3 strformat fmt lowering: mkdir")
    assert(os.FileExists(driver), "v3 strformat fmt lowering: compiler exists")
    if v3path.V3PathFileExists(outBin):
        os.RemoveFile(outBin)
    if v3path.V3PathFileExists(exeReportPath):
        os.RemoveFile(exeReportPath)
    if v3path.V3PathFileExists(exeCompileLog):
        os.RemoveFile(exeCompileLog)
    let compileRun = hostops.v3RunFileLogged(root,
                                             "strformat_fmt_lowering_exe_build",
                                             driver,
                                             [
                                                 "system-link-exec",
                                                 "--root:" + root,
                                                 "--in:" + sourcePath,
                                                 "--emit:exe",
                                                 "--target:" + target,
                                                 "--out:" + outBin,
                                                 "--report-out:" + exeReportPath
                                             ],
                                             [],
                                             root,
                                             0,
                                             exeCompileLog)
    assert(compileRun.exitCode == 0, "v3 strformat fmt lowering: exe compile rc")
    assert(v3path.V3PathFileExists(exeReportPath), "v3 strformat fmt lowering: report exists")
    let reportText = os.ReadFile(exeReportPath)
    let reportPrefix = "native_primary_object="
    let reportLines = strutil.Split(reportText, '\n')
    var primaryObjectPath: str
    for i in 0..<reportLines.len:
        let line = strutil.Strip(reportLines[i])
        if strutil.StartsWith(line, reportPrefix):
            primaryObjectPath = v3path.V3TextSlice(line, len(reportPrefix), len(line) - len(reportPrefix))
    assert(len(primaryObjectPath) > 0, "v3 strformat fmt lowering: primary object path")
    let symbolsRun = os.ExecCmdEx("nm -u " + primaryObjectPath, 0, root)
    assert(os.ExecCmdResultExitCode(symbolsRun) == 0, "v3 strformat fmt lowering: nm rc")
    let symbolsText = os.ExecCmdResultOutput(symbolsRun)
    assert(strings.StrContains(symbolsText, "_cheng_strformat_fmt_bridge"),
           "v3 strformat fmt lowering: fmt bridge")
    assert(strings.StrContains(symbolsText, "_cheng_strformat_lines_bridge"),
           "v3 strformat fmt lowering: lines bridge")
    assert(!strings.StrContains(symbolsText, "_driver_c_str_concat_bridge"),
           "v3 strformat fmt lowering: no binary concat bridge")
    let run = hostops.v3RunFileLogged(root,
                                      "strformat_fmt_lowering_run",
                                      outBin,
                                      [],
                                      [],
                                      root,
                                      0,
                                      outBin + ".run.log")
    assert(run.exitCode == 0, "v3 strformat fmt lowering: run rc")
    assert(strings.StrContains(run.output, "v3 strformat_fmt_smoke ok"),
           "v3 strformat fmt lowering: runtime output")
    echo("v3 strformat_fmt_lowering_smoke ok")
    return 0
