import cheng/core/lang/parser
import std/strings

fn main(): int32 =
    let source = "fn main(): int32 =\n    let name = \"cheng\"\n    let raw = \"\"\"\n        alpha\n          beta\n        \"\"\"\n    let fmt = Fmt\"\"\"\n        hi {name}\n        {{ok}}\n        \"\"\"\n    return len(raw) + len(fmt)\n"
    var rewritten = ""
    var err = ""
    assert(parser.ParserRewriteMultilineStringSourceText(source, rewritten, err),
           " multiline string parser: rewrite ok")
    assert(strings.StrContains(rewritten, "let raw = \"alpha\\n  beta\""),
           " multiline string parser: raw literal normalized")
    assert(strings.StrContains(rewritten, "let fmt = Fmt\"hi {name}\\n{{ok}}\""),
           " multiline string parser: fmt literal normalized")
    assert(parser.ParserSourceHasMultilineString(source),
           " multiline string parser: source has multiline")

    var layer = parser.NormalizedExprLayer()
    assert(parser.ParserReadNormalizedExprLayerFromText("src/tests/multiline_string_fixture.cheng",
                                                          source,
                                                          layer,
                                                          err),
           " multiline string parser: normalized expr read")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprStrFormat,
                                                    parser.NormalizedExprDetailStrFormatLiteral,
                                                    7),
           " multiline string parser: fmt line preserved")

    let bad = "fn bad(): int32 =\n    let raw = \"\"\"\n    shallow\n        \"\"\"\n    return 0\n"
    var badOut = ""
    var badErr = ""
    assert(!parser.ParserRewriteMultilineStringSourceText(bad, badOut, badErr),
           " multiline string parser: shallow indent rejected")
    assert(strings.StrContains(badErr, "indentation"),
           " multiline string parser: indent diagnostic")
    echo(" multiline_string_parser_smoke ok")
    return 0
