type
    BuildPlanStructArrayTag = enum
        buildPlanStructArrayTagA
        buildPlanStructArrayTagB

    BuildPlanStructArrayItem =
        tag: BuildPlanStructArrayTag
        text: str

    BuildPlanStructArrayOuter =
        title: str
        items: BuildPlanStructArrayItem[]

fn buildPlanStructArrayItems(): BuildPlanStructArrayItem[] =
    var out: BuildPlanStructArrayItem[]
    out = []
    add(out, BuildPlanStructArrayItem(tag: buildPlanStructArrayTagB, text: "abc"))
    return out

fn buildPlanStructArrayOuter(): BuildPlanStructArrayOuter =
    return BuildPlanStructArrayOuter(title: "top", items: buildPlanStructArrayItems())

fn main(): int32 =
    let items: BuildPlanStructArrayItem[] = buildPlanStructArrayItems()
    assert(items.len == 1, "build_plan_struct_array_smoke: len")
    let item: BuildPlanStructArrayItem = items[0]
    assert(item.tag == buildPlanStructArrayTagB, "build_plan_struct_array_smoke: tag")
    assert(item.text == "abc", "build_plan_struct_array_smoke: text")
    let outer: BuildPlanStructArrayOuter = buildPlanStructArrayOuter()
    assert(outer.title == "top", "build_plan_struct_array_smoke: outer title")
    assert(outer.items.len == 1, "build_plan_struct_array_smoke: outer len")
    let nested: BuildPlanStructArrayItem = outer.items[0]
    assert(nested.tag == buildPlanStructArrayTagB, "build_plan_struct_array_smoke: outer tag")
    assert(nested.text == "abc", "build_plan_struct_array_smoke: outer text")
    echo("build_plan_struct_array_smoke ok")
    return 0
