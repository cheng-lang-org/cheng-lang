import std/os
import cheng/core/tooling/perf_driver as perfdriver

fn main(): int32 =
    let root = os.Getcwd()
    let source = "src/tests/perf_fixture_min.cheng"
    if os.FileExists(source):
        let rc = perfdriver.PerfGateRunWitness(root, source)
        if rc != 0:
            echo("gate_perf_smoke: FAIL - perf gate returned error")
            return rc
        echo("gate_perf_smoke: PASS")
        return 0
    echo("gate_perf_smoke: SKIP - no fixture source")
    return 0
