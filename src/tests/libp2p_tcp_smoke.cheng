import std/system
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/transports/tcp_transport
import cheng/chain/anti_entropy as anti
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "tcp.server", "tcp.loopback")),
           "v3 chain_node: init")
    var client: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(client, "tcp.client", "tcp.loopback")),
           "v3 chain_node: init")
    let mintRes = node.v3ChainNodeMint(server, 9, 1001, int64(88))
    assert(mintRes.ok, "v3 libp2p tcp: mint")
    let transferRes = node.v3ChainNodeTransfer(server, 9, 1001, 2002, int64(33))
    assert(transferRes.ok, "v3 libp2p tcp: transfer")
    var snapshot: node.V3ChainNodeServeSnapshot
    node.v3ChainNodeServeOnceInto(snapshot, server)
    let payload = net.v3ChainNodeLibp2pEncodeSnapshot(snapshot)
    let roundtripRes = tcp_transport.v3Libp2pTcpLoopbackRoundtrip(types.v3Libp2pProtocolSync, payload)
    assert(roundtripRes.ok, "v3 libp2p tcp: loopback roundtrip")
    assert(bytesEqual(roundtripRes.value, payload), "v3 libp2p tcp: payload equal")
    var decoded: node.V3ChainNodeServeSnapshot
    let decodedRes = net.v3ChainNodeLibp2pDecodeSnapshotInto(roundtripRes.value, decoded)
    assert(decodedRes.ok, "v3 libp2p tcp: decode snapshot")
    let syncRes = node.v3ChainNodeSyncOnce(client, decoded)
    assert(syncRes.ok, "v3 libp2p tcp: sync once")
    assert(syncRes.value, "v3 libp2p tcp: sync changed")
    let aliceRes = node.v3ChainNodeBalance(client, 9, 1001)
    let bobRes = node.v3ChainNodeBalance(client, 9, 2002)
    assert(aliceRes.ok, "v3 libp2p tcp: alice balance")
    assert(bobRes.ok, "v3 libp2p tcp: bob balance")
    assert(aliceRes.value == int64(55), "v3 libp2p tcp: alice 55")
    assert(bobRes.value == int64(33), "v3 libp2p tcp: bob 33")
    var clientSnapshot: node.V3ChainNodeServeSnapshot
    node.v3ChainNodeServeOnceInto(clientSnapshot, client)
    assert(anti.v3AntiEntropySignatureEqual(snapshot.signature, clientSnapshot.signature),
        "v3 libp2p tcp: signature")
    echo("v3 libp2p_tcp_smoke ok")
    return 0
