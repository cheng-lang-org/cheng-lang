import std/system
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/transports/tcp_transport
import cheng/chain/anti_entropy as anti
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "tcp.server", "tcp.loopback")),
           " chain_node: init")
    var client: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(client, "tcp.client", "tcp.loopback")),
           " chain_node: init")
    let mintRes = node.ChainNodeMint(server, 9, 1001, int64(88))
    assert(mintRes.ok, " libp2p tcp: mint")
    let transferRes = node.ChainNodeTransfer(server, 9, 1001, 2002, int64(33))
    assert(transferRes.ok, " libp2p tcp: transfer")
    var snapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(snapshot, server)
    let payload = net.ChainNodeLibp2pEncodeSnapshot(snapshot)
    let roundtripRes = tcp_transport.Libp2pTcpLoopbackRoundtrip(types.Libp2pProtocolSync, payload)
    assert(roundtripRes.ok, " libp2p tcp: loopback roundtrip")
    assert(bytesEqual(roundtripRes.value, payload), " libp2p tcp: payload equal")
    var decoded: node.ChainNodeServeSnapshot
    let decodedRes = net.ChainNodeLibp2pDecodeSnapshotInto(roundtripRes.value, decoded)
    assert(decodedRes.ok, " libp2p tcp: decode snapshot")
    let syncRes = node.ChainNodeSyncOnce(client, decoded)
    assert(syncRes.ok, " libp2p tcp: sync once")
    assert(syncRes.value, " libp2p tcp: sync changed")
    let aliceRes = node.ChainNodeBalance(client, 9, 1001)
    let bobRes = node.ChainNodeBalance(client, 9, 2002)
    assert(aliceRes.ok, " libp2p tcp: alice balance")
    assert(bobRes.ok, " libp2p tcp: bob balance")
    assert(aliceRes.value == int64(55), " libp2p tcp: alice 55")
    assert(bobRes.value == int64(33), " libp2p tcp: bob 33")
    var clientSnapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(clientSnapshot, client)
    assert(anti.AntiEntropySignatureEqual(snapshot.signature, clientSnapshot.signature),
        " libp2p tcp: signature")
    echo(" libp2p_tcp_smoke ok")
    return 0
