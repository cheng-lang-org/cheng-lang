import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_smoke_support as r2csmoke
import std/strutils as strutil

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = chengpath.PathAbsolute(root, "artifacts/r2c_truth_compare_controller_smoke")
    assert(chengpath.MkdirP(root, outDir), " r2c truth compare controller smoke: mkdir")
    let driver = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    let packageRoot = root
    let controllerSource = chengpath.PathAbsolute(root, "src/r2c/r2c_react.cheng")
    assert(chengpath.FileExistsNonEmpty(root, driver), " r2c truth compare controller smoke: backend_driver exists")
    assert(chengpath.FileExistsNonEmpty(root, controllerSource), " r2c truth compare controller smoke: controller source exists")

    let controllerEnv = os.GetEnv("R2C_REACT_CONTROLLER_EXE")
    let allowControllerCompile = os.GetEnv("R2C_REACT_ALLOW_CONTROLLER_COMPILE") == "1"
    var controllerExe = ""
    if len(controllerEnv) > 0:
        controllerExe = chengpath.PathAbsolute(root, controllerEnv)
    elif allowControllerCompile:
        controllerExe = os.JoinPath(outDir, "r2c_react_truth_compare_smoke")
    else:
        assert(false,
               " r2c truth compare controller smoke: set R2C_REACT_CONTROLLER_EXE or R2C_REACT_ALLOW_CONTROLLER_COMPILE=1")
    if allowControllerCompile && len(controllerEnv) <= 0:
        let controllerCompileReport = strutil.Join([controllerExe, ".report.txt"], "")
        let controllerCompileLog = strutil.Join([controllerExe, ".compile.log"], "")
        if chengpath.PathFileExists(controllerExe):
            os.RemoveFile(controllerExe)
        if chengpath.PathFileExists(strutil.Join([controllerExe, ".map"], "")):
            os.RemoveFile(strutil.Join([controllerExe, ".map"], ""))
        if chengpath.PathFileExists(controllerCompileReport):
            os.RemoveFile(controllerCompileReport)
        if chengpath.PathFileExists(controllerCompileLog):
            os.RemoveFile(controllerCompileLog)
        let controllerCompileRun = hostops.RunFileLogged(root,
                                                           "r2c_truth_compare_controller_compile",
                                                           driver,
                                                           [
                                                               "system-link-exec",
                                                               strutil.Join(["--root:", packageRoot], ""),
                                                               strutil.Join(["--in:", controllerSource], ""),
                                                               "--emit:exe",
                                                               "--target:arm64-apple-darwin",
                                                               strutil.Join(["--out:", controllerExe], ""),
                                                               strutil.Join(["--report-out:", controllerCompileReport], "")
                                                           ],
                                                           r2csmoke.R2cReactSmokeControllerCompileEnv(),
                                                           root,
                                                           420,
                                                           controllerCompileLog)
        assert(hostops.LoggedRunOk(controllerCompileRun), " r2c truth compare controller smoke: controller compile rc")
        assert(chengpath.FileExistsNonEmpty(root, controllerCompileReport), " r2c truth compare controller smoke: controller compile report")
    assert(chengpath.FileExistsNonEmpty(root, controllerExe), " r2c truth compare controller smoke: controller exe")

    let execSnapshotPath = os.JoinPath(outDir, "cheng_codegen_exec_snapshot_v1.json")
    let truthTracePath = os.JoinPath(outDir, "truth_trace_v2.json")
    let nativeGuiSummaryPath = os.JoinPath(outDir, "native_gui_run.summary.env")
    let truthComparePath = os.JoinPath(outDir, "truth_compare_v1.json")
    let truthCompareSummaryPath = os.JoinPath(outDir, "truth_compare.summary.env")
    let compareReportPath = os.JoinPath(outDir, "compare_truth_report_v1.json")
    let screenshotPath = os.JoinPath(outDir, "native_gui_session.png")
    assert(chengpath.WriteTextFile("", execSnapshotPath,
                                  Fmt"""
                                  {{
                                    "format": "cheng_codegen_exec_snapshot_v1",
                                    "route_state": "home_default",
                                    "render_ready": true,
                                    "semantic_nodes_loaded": true,
                                    "semantic_nodes_count": 83
                                  }}

                                  """),
           " r2c truth compare controller smoke: write exec snapshot")
    assert(chengpath.WriteTextFile("", truthTracePath,
                                  Fmt"""
                                  {{
                                    "format": "truth_trace_v2",
                                    "snapshots": [
                                      {{
                                        "stateId": "home_default",
                                        "route": {{
                                          "routeId": "home_default"
                                        }},
                                        "semanticNodesCount": 83,
                                        "renderReady": true
                                      }}
                                    ]
                                  }}

                                  """),
           " r2c truth compare controller smoke: write truth trace")
    assert(chengpath.WriteTextFile("", screenshotPath, "png"),
           " r2c truth compare controller smoke: write screenshot stub")
    assert(chengpath.WriteTextFile("", nativeGuiSummaryPath,
                                  Fmt"""
                                  native_gui_route_state=home_default
                                  native_gui_screenshot_path={screenshotPath}
                                  native_gui_runtime_bundle_ready=true
                                  native_gui_runtime_contract_ready=true
                                  native_gui_runtime_bundle_route_state=home_default
                                  native_gui_runtime_bundle_route_count=1
                                  native_gui_runtime_bundle_supported_count=5
                                  native_gui_runtime_bundle_semantic_nodes_count=83
                                  native_gui_runtime_bundle_layout_item_count=31
                                  native_gui_runtime_bundle_render_command_count=44
                                  native_gui_runtime_contract_layout_item_count=31
                                  native_gui_runtime_contract_viewport_item_count=18
                                  native_gui_runtime_contract_interactive_item_count=7
                                  native_gui_native_layout_plan_item_count=31
                                  native_gui_render_plan_command_count=44

                                  """),
           " r2c truth compare controller smoke: write native gui summary")

    let controllerLog = os.JoinPath(outDir, "compare_truth_controller.log")
    if chengpath.PathFileExists(controllerLog):
        os.RemoveFile(controllerLog)
    let controllerRun = hostops.RunFileLogged(root,
                                                "r2c_truth_compare_controller_smoke",
                                                controllerExe,
                                                [
                                                    "compare-truth",
                                                    "--exec-snapshot", execSnapshotPath,
                                                    "--truth-trace", truthTracePath,
                                                    "--native-gui-summary", nativeGuiSummaryPath,
                                                    "--out", truthComparePath
                                                ],
                                                [],
                                                root,
                                                120,
                                                controllerLog)
    assert(hostops.LoggedRunOk(controllerRun), " r2c truth compare controller smoke: controller rc")
    assert(chengpath.FileExistsNonEmpty(root, truthComparePath), " r2c truth compare controller smoke: truth compare json")
    assert(chengpath.FileExistsNonEmpty(root, truthCompareSummaryPath), " r2c truth compare controller smoke: truth compare summary")
    assert(chengpath.FileExistsNonEmpty(root, compareReportPath), " r2c truth compare controller smoke: compare report")

    let truthCompareText = chengpath.ReadTextFile("", truthComparePath)
    let summaryText = chengpath.ReadTextFile("", truthCompareSummaryPath)
    let reportText = chengpath.ReadTextFile("", compareReportPath)
    assert(chengpath.TextContains(truthCompareText, "\"ok\": true"),
           " r2c truth compare controller smoke: compare ok")
    assert(chengpath.TextContains(truthCompareText, "\"native_gui_summary_ready\": true"),
           " r2c truth compare controller smoke: compare native gui summary ready")
    assert(chengpath.TextContains(truthCompareText, "\"native_gui_runtime_bundle_ready\": true"),
           " r2c truth compare controller smoke: compare runtime bundle ready")
    assert(chengpath.TextContains(truthCompareText, "\"native_gui_runtime_contract_ready\": true"),
           " r2c truth compare controller smoke: compare runtime contract ready")
    assert(chengpath.TextContains(truthCompareText, "\"native_gui_runtime_bundle_route_state\": \"home_default\""),
           " r2c truth compare controller smoke: compare runtime route state")
    assert(chengpath.TextContains(truthCompareText, "\"native_gui_runtime_bundle_semantic_nodes_count\": 83"),
           " r2c truth compare controller smoke: compare runtime semantic nodes")
    assert(chengpath.TextContains(truthCompareText, "\"native_gui_runtime_bundle_layout_item_count\": 31"),
           " r2c truth compare controller smoke: compare runtime layout count")
    assert(chengpath.TextContains(truthCompareText, "\"native_gui_runtime_bundle_render_command_count\": 44"),
           " r2c truth compare controller smoke: compare runtime render count")
    assert(chengpath.TextContains(truthCompareText, "\"native_gui_native_layout_plan_item_count\": 31"),
           " r2c truth compare controller smoke: compare native layout plan count")
    assert(chengpath.TextContains(truthCompareText, "\"native_gui_render_plan_command_count\": 44"),
           " r2c truth compare controller smoke: compare render plan count")

    assert(chengpath.TextContains(summaryText, "native_gui_summary_ready=true"),
           " r2c truth compare controller smoke: summary native gui ready")
    assert(chengpath.TextContains(summaryText, "native_gui_runtime_bundle_route_state=home_default"),
           " r2c truth compare controller smoke: summary runtime route state")
    assert(chengpath.TextContains(summaryText, "native_gui_runtime_bundle_semantic_nodes_count=83"),
           " r2c truth compare controller smoke: summary runtime semantic nodes")
    assert(chengpath.TextContains(summaryText, "native_gui_runtime_contract_interactive_item_count=7"),
           " r2c truth compare controller smoke: summary runtime interactive count")

    assert(chengpath.TextContains(reportText, "\"native_gui_summary_ready\": true"),
           " r2c truth compare controller smoke: report native gui ready")
    assert(chengpath.TextContains(reportText, "\"native_gui_runtime_bundle_ready\": true"),
           " r2c truth compare controller smoke: report runtime bundle ready")
    assert(chengpath.TextContains(reportText, "\"native_gui_runtime_bundle_route_count\": 1"),
           " r2c truth compare controller smoke: report runtime route count")
    assert(chengpath.TextContains(reportText, "\"native_gui_runtime_bundle_supported_count\": 5"),
           " r2c truth compare controller smoke: report runtime supported count")
    assert(chengpath.TextContains(reportText, "\"native_gui_render_plan_command_count\": 44"),
           " r2c truth compare controller smoke: report render plan count")

    echo(" r2c_react_truth_compare_controller_smoke ok")
    return 0
