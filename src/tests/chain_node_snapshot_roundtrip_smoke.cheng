import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/chain/consensus
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    var client: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(client, "node-b", "chain-node-b")),
           " chain_node: init")

    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node snapshot: mint")
    let transferCidRes = node.ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, " chain_node snapshot: transfer")

    var served: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(served, server)
    assert(served.eventCids.len == 2, " chain_node snapshot: event cid len")
    assert(served.events.len == 2, " chain_node snapshot: event len")
    assert(layout.fixedBytes32Equal(served.eventCids[0], mintCidRes.value), " chain_node snapshot: mint cid")
    assert(layout.fixedBytes32Equal(served.eventCids[1], transferCidRes.value), " chain_node snapshot: transfer cid")
    assert(served.signature.eventCount == 2, " chain_node snapshot: signature event count")
    assert(served.signature.accountCount == 2, " chain_node snapshot: signature account count")

    var replayed: node.ChainNode
    node.ChainNodeZeroInto(replayed, "node-b", client.address)
    for i in 0..<served.events.len:
        var event = served.events[i]
        event.stem = event.ganzhiIndex % 10
        event.branch = event.ganzhiIndex % 12
        event.bodyCid = consensus.ChainEventBodyCid(event)
        let applyRes = node.ChainNodeApplyEvent(replayed, event)
        assert(applyRes.ok, " chain_node snapshot: replay apply")
        assert(layout.fixedBytes32Equal(applyRes.value, served.eventCids[i]), " chain_node snapshot: replay cid")
    node.ChainNodeRebuildDerived(replayed)
    assert(layout.fixedBytes32Equal(node.ChainNodeForestCid(server), node.ChainNodeForestCid(replayed)), " chain_node snapshot: replay forest")
    assert(anti.AntiEntropySignatureEqual(served.signature, replayed.signature), " chain_node snapshot: replay signature")

    let syncRes = node.ChainNodeSyncOnce(client, served)
    assert(syncRes.ok, " chain_node snapshot: sync ok")
    assert(syncRes.value, " chain_node snapshot: sync changed")

    var clientServed: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(clientServed, client)
    assert(layout.fixedBytes32Equal(served.tipEventCid, clientServed.tipEventCid), " chain_node snapshot: tip cid")
    assert(layout.fixedBytes32Equal(served.forest.forestCid, clientServed.forest.forestCid), " chain_node snapshot: forest")
    assert(anti.AntiEntropySignatureEqual(served.signature, clientServed.signature), " chain_node snapshot: signature")

    echo(" chain_node_snapshot_roundtrip_smoke ok")
    return 0
