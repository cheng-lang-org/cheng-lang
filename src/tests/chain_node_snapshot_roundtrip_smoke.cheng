import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/chain/consensus
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node: init")
    var client: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(client, "node-b", "chain-node-b")),
           "v3 chain_node: init")

    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node snapshot: mint")
    let transferCidRes = node.v3ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, "v3 chain_node snapshot: transfer")

    var served: node.V3ChainNodeServeSnapshot
    node.v3ChainNodeServeOnceInto(served, server)
    assert(served.eventCids.len == 2, "v3 chain_node snapshot: event cid len")
    assert(served.events.len == 2, "v3 chain_node snapshot: event len")
    assert(layout.fixedBytes32Equal(served.eventCids[0], mintCidRes.value), "v3 chain_node snapshot: mint cid")
    assert(layout.fixedBytes32Equal(served.eventCids[1], transferCidRes.value), "v3 chain_node snapshot: transfer cid")
    assert(served.signature.eventCount == 2, "v3 chain_node snapshot: signature event count")
    assert(served.signature.accountCount == 2, "v3 chain_node snapshot: signature account count")

    var replayed: node.V3ChainNode
    node.v3ChainNodeZeroInto(replayed, "node-b", client.address)
    for i in 0..<served.events.len:
        var event = served.events[i]
        event.stem = event.ganzhiIndex % 10
        event.branch = event.ganzhiIndex % 12
        event.bodyCid = consensus.v3ChainEventBodyCid(event)
        let applyRes = node.v3ChainNodeApplyEvent(replayed, event)
        assert(applyRes.ok, "v3 chain_node snapshot: replay apply")
        assert(layout.fixedBytes32Equal(applyRes.value, served.eventCids[i]), "v3 chain_node snapshot: replay cid")
    node.v3ChainNodeRebuildDerived(replayed)
    assert(layout.fixedBytes32Equal(node.v3ChainNodeForestCid(server), node.v3ChainNodeForestCid(replayed)), "v3 chain_node snapshot: replay forest")
    assert(anti.v3AntiEntropySignatureEqual(served.signature, replayed.signature), "v3 chain_node snapshot: replay signature")

    let syncRes = node.v3ChainNodeSyncOnce(client, served)
    assert(syncRes.ok, "v3 chain_node snapshot: sync ok")
    assert(syncRes.value, "v3 chain_node snapshot: sync changed")

    var clientServed: node.V3ChainNodeServeSnapshot
    node.v3ChainNodeServeOnceInto(clientServed, client)
    assert(layout.fixedBytes32Equal(served.tipEventCid, clientServed.tipEventCid), "v3 chain_node snapshot: tip cid")
    assert(layout.fixedBytes32Equal(served.forest.forestCid, clientServed.forest.forestCid), "v3 chain_node snapshot: forest")
    assert(anti.v3AntiEntropySignatureEqual(served.signature, clientServed.signature), "v3 chain_node snapshot: signature")

    echo("v3 chain_node_snapshot_roundtrip_smoke ok")
    return 0
