import std/system
import std/strutils as strutil

@importc("statvfs")
fn libc_statvfs(path: ptr, out: ptr): int32
@importc("driver_c_new_string_copy_n")
fn driver_c_new_string_copy_n(raw: ptr, n: int32): ptr

type
    DarwinStatvfs =
        f_bsize: int64
        f_frsize: int64
        f_blocks: int64
        f_bfree: int64
        f_bavail: int64
        f_files: int64
        f_ffree: int64
        f_favail: int64

fn main(): int32 =
    let root = driver_c_new_string_copy_n("/", 1)
    var fs: DarwinStatvfs
    let rc = libc_statvfs(root, ptr(&fs))
    echo(strutil.Join(["rc=", intToStr(rc)], ""))
    echo(strutil.Join(["bsize=", intToStr(int32(fs.f_bsize))], ""))
    echo(strutil.Join(["frsize=", intToStr(int32(fs.f_frsize))], ""))
    echo(strutil.Join(["blocks=", intToStr(int32(fs.f_blocks))], ""))
    echo(strutil.Join(["bavail=", intToStr(int32(fs.f_bavail))], ""))
    return 0
