import std/buffer
import std/rawbytes
import std/strutils as strutil

fn main(): int32 =
    var buf: buffer.ByteBuffer = buffer.NewByteBuffer()
    var i: int32
    while i < 128:
        buffer.AppendBytes(buf, "abcdefghijabcdefghijabcdefghij\n")
        i = i + 1
    let text = rawbytes.bytesToString(buffer.ToBytes(buf))
    let lines = strutil.Split(text, '\n')
    assert(lines.len == 129, " split buffer many: len")
    assert(lines[0] == "abcdefghijabcdefghijabcdefghij", " split buffer many: first")
    assert(lines[127] == "abcdefghijabcdefghijabcdefghij", " split buffer many: body")
    assert(lines[128] == "", " split buffer many: trailing empty")
    echo(" strutils_split_buffer_many_probe ok")
    return 0
