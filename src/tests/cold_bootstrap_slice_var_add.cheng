type Buffer =
    items: int32[]

fn Push(xs: var int32[], value: int32): int32 =
    add(xs, value)
    return xs.len

fn main(): int32 =
    var xs: int32[]
    let n1 = Push(xs, 4)
    let n2 = Push(xs, 7)
    if n1 != 1:
        return 1
    if n2 != 2:
        return 2
    if xs.len != 2:
        return 3
    if xs[0] != 4:
        return 4
    if xs[1] != 7:
        return 5

    var b: Buffer
    add(b.items, 5)
    add(b.items, 6)
    if b.items.len != 2:
        return 6
    if b.items[0] != 5:
        return 7
    if b.items[1] != 6:
        return 8

    return xs[0] + xs[1] + xs.len + b.items[0] + b.items[1] + b.items.len
