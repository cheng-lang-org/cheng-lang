import std/system
import std/result
import std/rawbytes
import std/crypto/curve25519
import cheng/std/crypto/fixed256
import std/strutils as strutil

fn main(): int32 =
    let aliceScalarRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex(
        "77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    let bobScalarRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex(
        "5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    assert(IsOk(aliceScalarRes), "curve25519 runtime probe: alice scalar")
    assert(IsOk(bobScalarRes), "curve25519 runtime probe: bob scalar")
    let alice: Bytes = fixed256.scalar256ToBytes(Value(aliceScalarRes))
    let bob: Bytes = fixed256.scalar256ToBytes(Value(bobScalarRes))
    let alicePubRes: Result[Bytes] = curve25519.curve25519PublicFromPrivate(alice)
    let bobPubRes: Result[Bytes] = curve25519.curve25519PublicFromPrivate(bob)
    assert(IsOk(alicePubRes), "curve25519 runtime probe: alice public")
    assert(IsOk(bobPubRes), "curve25519 runtime probe: bob public")
    let sharedRes: Result[Bytes] = curve25519.curve25519SharedKey(alice, Value(bobPubRes))
    assert(IsOk(sharedRes), "curve25519 runtime probe: shared")
    echo(strutil.Join(["alice=", bytesToHex(Value(alicePubRes))], ""))
    echo(strutil.Join(["bob=", bytesToHex(Value(bobPubRes))], ""))
    echo(strutil.Join(["shared=", bytesToHex(Value(sharedRes))], ""))
    return 0
