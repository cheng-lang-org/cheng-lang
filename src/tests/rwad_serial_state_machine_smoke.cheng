import cheng/std/bytes_layout as layout
import cheng/apps/rwad/rwad_serial_state_machine as rwad

fn main(): int32 =
    let alice = rwad.RwadOwnerIdFromText("alice")
    let bob = rwad.RwadOwnerIdFromText("bob")
    assert(!layout.FixedBytes32Equal(alice, bob), " rwad serial smoke: owner ids")

    var machine = rwad.RwadStateMachineInit("rwad-serial-smoke")

    let preAlice = rwad.RwadStateMachineQueryOwner(machine, alice)
    assert(preAlice.code == rwad.RwadSerialCodeOk, " rwad serial smoke: pre alice code")
    assert(preAlice.balance == int64(0), " rwad serial smoke: pre alice balance")

    let mintTx = rwad.RwadMintTxMake(alice, int64(100))
    let mintCheck = rwad.RwadStateMachineCheckMint(machine, int64(1), mintTx)
    assert(mintCheck.code == rwad.RwadSerialCodeOk, " rwad serial smoke: mint check code")
    assert(mintCheck.applied, " rwad serial smoke: mint check applied")
    assert(machine.notes.len == 0, " rwad serial smoke: mint check no mutate")

    let mintApply = rwad.RwadStateMachineApplyMint(machine, int64(1), mintTx)
    assert(mintApply.code == rwad.RwadSerialCodeOk, " rwad serial smoke: mint apply code")
    assert(mintApply.applied, " rwad serial smoke: mint apply")
    assert(mintApply.primaryNoteId == int64(1), " rwad serial smoke: first note id")
    assert(machine.notes.len == 1, " rwad serial smoke: note count after mint")
    assert(machine.notes[0].startSerial == int64(1), " rwad serial smoke: mint start")
    assert(machine.notes[0].endSerial == int64(100), " rwad serial smoke: mint end")
    assert(machine.notes[0].live, " rwad serial smoke: mint live")

    let afterMintAlice = rwad.RwadStateMachineQueryOwner(machine, alice)
    assert(afterMintAlice.balance == int64(100), " rwad serial smoke: alice after mint")
    assert(afterMintAlice.liveNoteCount == 1, " rwad serial smoke: alice note count after mint")

    let transferTx = rwad.RwadTransferTxMake(int64(1), alice, bob, int64(21), int64(40))
    let transferCheck = rwad.RwadStateMachineCheckTransfer(machine, int64(2), transferTx)
    assert(transferCheck.code == rwad.RwadSerialCodeOk, " rwad serial smoke: transfer check code")
    assert(machine.notes.len == 1, " rwad serial smoke: transfer check no mutate")

    let transferApply = rwad.RwadStateMachineApplyTransfer(machine, int64(2), transferTx)
    assert(transferApply.code == rwad.RwadSerialCodeOk, " rwad serial smoke: transfer apply code")
    assert(transferApply.applied, " rwad serial smoke: transfer apply")
    assert(transferApply.primaryNoteId == int64(2), " rwad serial smoke: left change note id")
    assert(transferApply.secondaryNoteId == int64(3), " rwad serial smoke: payment note id")
    assert(transferApply.tertiaryNoteId == int64(4), " rwad serial smoke: right change note id")
    assert(machine.notes.len == 4, " rwad serial smoke: split note count")
    assert(!machine.notes[0].live, " rwad serial smoke: input spent")
    assert(machine.notes[1].startSerial == int64(1), " rwad serial smoke: left change start")
    assert(machine.notes[1].endSerial == int64(20), " rwad serial smoke: left change end")
    assert(machine.notes[2].startSerial == int64(21), " rwad serial smoke: payment start")
    assert(machine.notes[2].endSerial == int64(40), " rwad serial smoke: payment end")
    assert(machine.notes[3].startSerial == int64(41), " rwad serial smoke: right change start")
    assert(machine.notes[3].endSerial == int64(100), " rwad serial smoke: right change end")
    assert(machine.nullifiers.len == 1, " rwad serial smoke: nullifier count")
    assert(!layout.FixedBytes32Equal(transferApply.spentNullifier, layout.FixedBytes32()),
           " rwad serial smoke: nullifier nonzero")

    let afterTransferAlice = rwad.RwadStateMachineQueryOwner(machine, alice)
    let afterTransferBob = rwad.RwadStateMachineQueryOwner(machine, bob)
    assert(afterTransferAlice.balance == int64(80), " rwad serial smoke: alice after transfer")
    assert(afterTransferAlice.liveNoteCount == 2, " rwad serial smoke: alice note count after transfer")
    assert(afterTransferBob.balance == int64(20), " rwad serial smoke: bob after transfer")
    assert(afterTransferBob.liveNoteCount == 1, " rwad serial smoke: bob note count after transfer")
    assert(!layout.FixedBytes32Equal(afterTransferAlice.ownerRoot, afterTransferBob.ownerRoot),
           " rwad serial smoke: owner roots differ")

    let doubleSpend = rwad.RwadStateMachineApplyTransfer(machine, int64(3), transferTx)
    assert(doubleSpend.code == rwad.RwadSerialCodeAlreadySpent, " rwad serial smoke: double spend rejected")
    assert(machine.nullifiers.len == 1, " rwad serial smoke: double spend no new nullifier")

    let commit = rwad.RwadStateMachineCommit(machine)
    assert(commit.height == int64(2), " rwad serial smoke: commit height")
    assert(commit.nextSerial == int64(101), " rwad serial smoke: next serial")
    assert(commit.nextNoteId == int64(5), " rwad serial smoke: next note id")
    assert(commit.liveNoteCount == 3, " rwad serial smoke: live note count")
    assert(commit.nullifierCount == 1, " rwad serial smoke: commit nullifier count")
    assert(!layout.FixedBytes32Equal(commit.serialRoot, layout.FixedBytes32()),
           " rwad serial smoke: serial root")
    assert(!layout.FixedBytes32Equal(commit.nullifierRoot, layout.FixedBytes32()),
           " rwad serial smoke: nullifier root")
    assert(layout.FixedBytes32Equal(commit.appHash, rwad.RwadStateMachineQueryAppHash(machine)),
           " rwad serial smoke: app hash")

    echo(" rwad_serial_state_machine_smoke ok")
    return 0
