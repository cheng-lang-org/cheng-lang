import std/system
import std/strings
import std/os as os
import std/rawbytes

fn orcPerfEnvInt(name: str, defaultValue: int32): int32 =
    let raw: str = os.GetEnvDefault(name, "")
    if len(raw) <= 0:
        return defaultValue
    var value: int32
    var i: int32
    while i < len(raw):
        let ch: char = raw[i]
        if ch < '0' || ch > '9':
            return defaultValue
        value = value * 10 + (int32(ch) - int32('0'))
        i = i + 1
    return value

fn main(): int32 =
    let iterations: int32 = orcPerfEnvInt("CHENG_ORC_PERF_ITERS", 200000)
    assert(iterations > 0, " orc perf: iterations")

    let allocBefore: int64 = memAllocCount()
    let freeBefore: int64 = memFreeCount()
    let liveBefore: int64 = memLiveCount()

    var payload: Bytes = bytesAlloc(64)
    let raw = payload.data
    assert(raw != nil, " orc perf: payload ptr")
    assert(memAllocCount() == allocBefore + 1, " orc perf: alloc delta")
    assert(memLiveCount() == liveBefore + 1, " orc perf: live after alloc")
    assert(memRefCountAtomic(raw) == 1, " orc perf: initial rc")

    memDiagReset()
    var i: int32
    while i < iterations:
        memRetainAtomic(raw)
        memReleaseAtomic(raw)
        i = i + 1

    let retainCount: int64 = memRetainCount()
    let releaseCount: int64 = memReleaseCount()
    assert(retainCount == int64(iterations), " orc perf: retain count")
    assert(releaseCount == int64(iterations), " orc perf: release count")
    assert(memRefCountAtomic(raw) == 1, " orc perf: rc after loop")
    assert(memLiveCount() == liveBefore + 1, " orc perf: live before final release")

    memReleaseAtomic(raw)
    payload = emptyBytes()
    let allocDelta: int64 = memAllocCount() - allocBefore
    let freeDelta: int64 = memFreeCount() - freeBefore
    let liveDelta: int64 = memLiveCount() - liveBefore
    assert(allocDelta == int64(1), " orc perf: alloc delta after release")
    assert(freeDelta == int64(1), " orc perf: free delta after release")
    assert(liveDelta == int64(0), " orc perf: live delta after release")

    echo("orc_perf_iterations=" + intToStr(iterations))
    echo("orc_perf_retain_count=" + int64ToStr(retainCount))
    echo("orc_perf_release_count=" + int64ToStr(releaseCount))
    echo("orc_perf_alloc_delta=" + int64ToStr(allocDelta))
    echo("orc_perf_free_delta=" + int64ToStr(freeDelta))
    echo("orc_perf_live_delta=" + int64ToStr(liveDelta))
    echo(" orc_perf_contract_smoke ok")
    return 0
