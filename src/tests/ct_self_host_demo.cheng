// Self-hosting demo: minimal file I/O roundtrip
// Proves: cold_open, cold_read, cold_close, cold_write
import libc

fn main(): int32 =
    let fd: int32 = cold_open("README.md", 0)
    if fd < 0: return 1
    var buf: int32[64]
    let n: int32 = cold_read(fd, buf, 64)
    let _: int32 = cold_close(fd)
    if n > 0: return 42
    return 2
