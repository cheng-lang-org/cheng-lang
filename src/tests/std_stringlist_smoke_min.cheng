import std/system
import std/result
import std/stringlist

fn main() =
    var list: StringList = initStringList()
    let addRes: Result[bool] = stringListAdd(list, "a")
    assert(IsOk(addRes) && Value(addRes), "std/stringlist min add")
    let linesRes: Result[StringList] = stringListFromLines("x\ny\nx\n")
    assert(IsOk(linesRes), "std/stringlist min lines")
    let list2: StringList = Value(linesRes)
    assert(stringListCount(list2) == 2, "std/stringlist min dedupe")
