import std/cmdline as cmdline
import std/os
import std/rawbytes
import std/rawmem_support
import std/result
import std/strutils as strutil
import std/net/transports/tcp_syscall as tcp
import cheng/quic/tls/test_pki as testpki
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/apps/vpn_proxy/vpn_proxy_main as vpn

const
    vpnProxyE2eArtifactRel = "artifacts/vpn_proxy_end_to_end_smoke"
    vpnProxyE2eAuth = "shared-secret"
    vpnProxyE2eAuthority = "localhost"
    vpnProxyE2eTargetHost = "localhost"
    vpnProxyE2eTargetHostLen = 9
    vpnProxyE2eRequestText = "vpn-proxy-e2e-request"
    vpnProxyE2eResponseText = "vpn-proxy-e2e-response"

fn vpnProxyE2eBytesEq(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn vpnProxyE2eArtifactDir(root: str): str =
    return chengpath.PathAbsolute(root, vpnProxyE2eArtifactRel)

fn vpnProxyE2ePath(root: str, name: str): str =
    return chengpath.PathAbsolute(root, strutil.Join([vpnProxyE2eArtifactRel, "/", name], ""))

fn vpnProxyE2eReadyPath(root: str, name: str): str =
    return vpnProxyE2ePath(root, strutil.Join([name, ".ready"], ""))

fn vpnProxyE2eLogPath(root: str, name: str): str =
    return vpnProxyE2ePath(root, strutil.Join([name, ".log"], ""))

fn vpnProxyE2eParsePort(textRaw: str): Result[int32] =
    let text: str = strutil.Strip(textRaw)
    if len(text) <= 0:
        return Err[int32](" vpn proxy e2e: empty port text")
    var value: int32
    for i in 0..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int32](" vpn proxy e2e: invalid port text")
        value = value * 10 + (int32(ch) - int32('0'))
    if value <= 0:
        return Err[int32](" vpn proxy e2e: invalid port")
    return Ok[int32](value)

fn vpnProxyE2eRemoveFile(path: str) =
    if os.FileExists(path):
        let _ = os.RemoveFile(path)

fn vpnProxyE2eWriteBytes(path: str, data: Bytes): bool =
    let parent: str = os.ParentDir(path)
    if len(parent) > 0:
        if !chengpath.MkdirP("", parent):
            return false
    let file = os.Open(path, os.fmWrite)
    if file == nil:
        return false
    let total: int32 = bytesLen(data)
    if total <= 0:
        os.Close(file)
        return true
    let wrote: int32 = os.C_fwrite(data.data, 1, int64(total), file)
    os.Close(file)
    if wrote != total:
        return false
    return os.FileExists(path) && os.FileSize(path) == int64(total)

fn vpnProxyE2eWriteMaterials(root: str): Result[bool] =
    let artifactDir: str = vpnProxyE2eArtifactDir(root)
    if !chengpath.MkdirP(root, artifactDir):
        return Err[bool](" vpn proxy e2e: mkdir failed")
    let rootPath: str = vpnProxyE2ePath(root, "transport.root.der")
    let certPath: str = vpnProxyE2ePath(root, "transport.cert.der")
    let keyPath: str = vpnProxyE2ePath(root, "transport.key.pk8")
    var trustRoot: Bytes
    testpki.msquicLocalhostTransportTrustRootDerInto(trustRoot)
    if bytesLen(trustRoot) <= 0:
        return Err[bool](" vpn proxy e2e: trust root bytes empty")
    if !vpnProxyE2eWriteBytes(rootPath, trustRoot):
        return Err[bool](" vpn proxy e2e: write trust root failed")
    var certDer: Bytes
    testpki.msquicLocalhostTransportCertDerInto(certDer)
    if bytesLen(certDer) <= 0:
        return Err[bool](" vpn proxy e2e: cert bytes empty")
    if !vpnProxyE2eWriteBytes(certPath, certDer):
        return Err[bool](" vpn proxy e2e: write cert failed")
    var keyPk8: Bytes
    testpki.msquicLocalhostTransportKeyPkcs8DerInto(keyPk8)
    if bytesLen(keyPk8) <= 0:
        return Err[bool](" vpn proxy e2e: key bytes empty")
    if !vpnProxyE2eWriteBytes(keyPath, keyPk8):
        return Err[bool](" vpn proxy e2e: write key failed")
    return Ok[bool](true)

fn vpnProxyE2eExitConfigText(): str =
    var out = ""
    out = strutil.Join([out, "{\"server\":{"], "")
    out = strutil.Join([out, "\"listen\":\"127.0.0.1:0\","], "")
    out = strutil.Join([out, "\"cert_der\":\"transport.cert.der\","], "")
    out = strutil.Join([out, "\"key_pk8_der\":\"transport.key.pk8\","], "")
    out = strutil.Join([out, "\"trust_root_der\":\"transport.root.der\","], "")
    out = strutil.Join([out, "\"expected_auth\":\"", vpnProxyE2eAuth, "\","], "")
    out = strutil.Join([out, "\"expected_authority\":\"", vpnProxyE2eAuthority, "\","], "")
    out = strutil.Join([out, "\"cc_rx_text\":\"auto\""], "")
    out = strutil.Join([out, "}}"], "")
    return out

fn vpnProxyE2eLocalConfigText(exitPort: int32): str =
    var out = ""
    out = strutil.Join([out, "{\"client\":{"], "")
    out = strutil.Join([out, "\"listen\":\"127.0.0.1:0\","], "")
    out = strutil.Join([out, "\"cert_der\":\"transport.cert.der\","], "")
    out = strutil.Join([out, "\"key_pk8_der\":\"transport.key.pk8\","], "")
    out = strutil.Join([out, "\"trust_root_der\":\"transport.root.der\""], "")
    out = strutil.Join([out, "},\"exits\":[{"], "")
    out = strutil.Join([out, "\"name\":\"edge\","], "")
    out = strutil.Join([out, "\"host\":\"127.0.0.1\","], "")
    out = strutil.Join([out, "\"port\":", intToStr(exitPort), ","], "")
    out = strutil.Join([out, "\"server_name\":\"localhost\","], "")
    out = strutil.Join([out, "\"authority\":\"", vpnProxyE2eAuthority, "\","], "")
    out = strutil.Join([out, "\"auth\":\"", vpnProxyE2eAuth, "\","], "")
    out = strutil.Join([out, "\"cc_rx\":65535"], "")
    out = strutil.Join([out, "}]}"], "")
    return out

fn vpnProxyE2eWaitReadyPort(root: str,
                            readyPath: str,
                            proc: var hostops.SpawnedProcess,
                            portOut: var int32): Result[bool] =
    portOut = 0
    for attempt in 0..<500:
        if chengpath.FileExistsNonEmpty(root, readyPath):
            let textRaw: str = chengpath.ReadTextFile("", readyPath)
            let parseRes: Result[int32] = vpnProxyE2eParsePort(textRaw)
            if IsOk(parseRes):
                portOut = Value(parseRes)
                return Ok[bool](true)
        if !hostops.SpawnedProcessRunning(proc):
            return Err[bool](strutil.Join([" vpn proxy e2e: process exited before ready: ", proc.output], ""))
        if attempt + 1 < 500:
            os.SleepMs(10)
    return Err[bool](" vpn proxy e2e: ready timeout")

fn vpnProxyE2eTcpReadExact(conn: var tcp.TcpConnectionHandle, count: int32): Result[Bytes] =
    let out: Bytes = bytesAlloc(count)
    var filled: int32
    while filled < count:
        let dstPtr: ptr = rawmem_support.RawmemPtrAdd(out.data, filled)
        let readRes: Result[int32] = tcp.TcpRecvRaw(conn, dstPtr, count - filled)
        if IsErr(readRes):
            return Err[Bytes](ErrorText(readRes))
        let got: int32 = Value(readRes)
        if got <= 0:
            return Err[Bytes](" vpn proxy e2e: unexpected eof")
        filled = filled + got
    return Ok[Bytes](out)

fn vpnProxyE2eTcpWriteAll(conn: var tcp.TcpConnectionHandle, data: var Bytes): Result[int32] =
    return tcp.TcpSendRaw(conn, data.data, bytesLen(data))

fn vpnProxyE2eTargetRequest(): Bytes =
    return bytesFromString(vpnProxyE2eRequestText)

fn vpnProxyE2eTargetResponse(): Bytes =
    return bytesFromString(vpnProxyE2eResponseText)

fn vpnProxyE2eTargetConnectWireInto(out: var Bytes, port: int32) =
    out = bytesAlloc(16)
    bytesSet(out, 0, 5)
    bytesSet(out, 1, 1)
    bytesSet(out, 2, 0)
    bytesSet(out, 3, 3)
    bytesSet(out, 4, vpnProxyE2eTargetHostLen)
    bytesSet(out, 5, int32('l'))
    bytesSet(out, 6, int32('o'))
    bytesSet(out, 7, int32('c'))
    bytesSet(out, 8, int32('a'))
    bytesSet(out, 9, int32('l'))
    bytesSet(out, 10, int32('h'))
    bytesSet(out, 11, int32('o'))
    bytesSet(out, 12, int32('s'))
    bytesSet(out, 13, int32('t'))
    bytesSet(out, 5 + vpnProxyE2eTargetHostLen, (port >> 8) & 0xff)
    bytesSet(out, 6 + vpnProxyE2eTargetHostLen, port & 0xff)

fn vpnProxyE2eSocksMethodWireInto(out: var Bytes) =
    out = bytesAlloc(3)
    bytesSet(out, 0, 5)
    bytesSet(out, 1, 1)
    bytesSet(out, 2, 0)

fn vpnProxyE2eRunClient(localPort: int32, targetPort: int32): Result[bool] =
    let connectRes: Result[tcp.TcpConnectionHandle] = tcp.TcpConnect("127.0.0.1", localPort, false)
    if IsErr(connectRes):
        return Err[bool](ErrorText(connectRes))
    var conn = Value(connectRes)
    var methodWire: Bytes
    vpnProxyE2eSocksMethodWireInto(methodWire)
    let methodRes: Result[int32] = vpnProxyE2eTcpWriteAll(conn, methodWire)
    if IsErr(methodRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(methodRes))
    let methodReplyRes: Result[Bytes] = vpnProxyE2eTcpReadExact(conn, 2)
    if IsErr(methodReplyRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(methodReplyRes))
    let methodReply: Bytes = Value(methodReplyRes)
    if bytesGet(methodReply, 0) != 5 || bytesGet(methodReply, 1) != 0:
        tcp.TcpClose(conn)
        return Err[bool](" vpn proxy e2e: socks method rejected")
    var connectWire: Bytes
    vpnProxyE2eTargetConnectWireInto(connectWire, targetPort)
    let connectWriteRes: Result[int32] = vpnProxyE2eTcpWriteAll(conn, connectWire)
    if IsErr(connectWriteRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(connectWriteRes))
    let replyRes: Result[Bytes] = vpnProxyE2eTcpReadExact(conn, 10)
    if IsErr(replyRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(replyRes))
    let reply: Bytes = Value(replyRes)
    if bytesGet(reply, 0) != 5 || bytesGet(reply, 1) != 0:
        tcp.TcpClose(conn)
        return Err[bool](" vpn proxy e2e: socks connect rejected")
    var request: Bytes = vpnProxyE2eTargetRequest()
    let requestWriteRes: Result[int32] = vpnProxyE2eTcpWriteAll(conn, request)
    if IsErr(requestWriteRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(requestWriteRes))
    let responseRes: Result[Bytes] = vpnProxyE2eTcpReadExact(conn, bytesLen(vpnProxyE2eTargetResponse()))
    if IsErr(responseRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(responseRes))
    let response: Bytes = Value(responseRes)
    tcp.TcpClose(conn)
    if !vpnProxyE2eBytesEq(response, vpnProxyE2eTargetResponse()):
        return Err[bool](" vpn proxy e2e: response mismatch")
    return Ok[bool](true)

fn vpnProxyE2eWaitRunOk(root: str,
                        proc: var hostops.SpawnedProcess,
                        logPath: str,
                        label: str): Result[bool] =
    let run: hostops.LoggedRun = hostops.SpawnedProcessWaitLogged(root, proc, 20, logPath)
    if !hostops.LoggedRunOk(run):
        return Err[bool](strutil.Join([" vpn proxy e2e: ", label, " failed: ", run.output], ""))
    return Ok[bool](true)

fn vpnProxyE2eAppendLog(out: var str, root: str, logPath: str, label: str) =
    out = strutil.Join([out, "\n["], "")
    out = strutil.Join([out, label], "")
    out = strutil.Join([out, "]\n"], "")
    if chengpath.FileExistsNonEmpty(root, logPath):
        out = strutil.Join([out, chengpath.ReadTextFile("", logPath)], "")
        return
    out = strutil.Join([out, "<empty>"], "")

fn vpnProxyE2eWriteFailure(root: str,
                           message: str,
                           targetLog: str,
                           localLog: str,
                           exitLog: str) =
    var out: str = message
    vpnProxyE2eAppendLog(out, root, targetLog, "target")
    vpnProxyE2eAppendLog(out, root, localLog, "local")
    vpnProxyE2eAppendLog(out, root, exitLog, "exit")
    os.WriteLine(os.Get_stderr(), out)

fn vpnProxyE2eKillAndFinalize(root: str,
                              proc: var hostops.SpawnedProcess,
                              logPath: str) =
    hostops.SpawnedProcessKill(proc)
    let _ = hostops.SpawnedProcessFinalize(root, proc, logPath, 124)

fn vpnProxyE2eRunDefault(): int32 =
    let root: str = os.GetCurrentDir()
    let selfPath: str = cmdline.ProgramName()
    assert(len(selfPath) > 0, " vpn proxy e2e: self path")
    let materialRes: Result[bool] = vpnProxyE2eWriteMaterials(root)
    if IsErr(materialRes):
        os.WriteLine(os.Get_stderr(), ErrorText(materialRes))
        return 1

    let targetReady: str = vpnProxyE2eReadyPath(root, "target")
    let targetLog: str = vpnProxyE2eLogPath(root, "target")
    let exitReady: str = vpnProxyE2eReadyPath(root, "exit")
    let exitLog: str = vpnProxyE2eLogPath(root, "exit")
    let localReady: str = vpnProxyE2eReadyPath(root, "local")
    let localLog: str = vpnProxyE2eLogPath(root, "local")
    let exitConfigPath: str = vpnProxyE2ePath(root, "exit.config.json")
    let localConfigPath: str = vpnProxyE2ePath(root, "local.config.json")

    vpnProxyE2eRemoveFile(targetReady)
    vpnProxyE2eRemoveFile(targetLog)
    vpnProxyE2eRemoveFile(exitReady)
    vpnProxyE2eRemoveFile(exitLog)
    vpnProxyE2eRemoveFile(localReady)
    vpnProxyE2eRemoveFile(localLog)

    assert(chengpath.WriteTextFile("", exitConfigPath, vpnProxyE2eExitConfigText()),
           " vpn proxy e2e: write exit config")

    let targetSpawnRes = hostops.SpawnFile(root,
                                             "vpn_proxy_e2e_target",
                                             selfPath,
                                             ["--role:target", "--port:0", strutil.Join(["--ready-path:", targetReady], "")],
                                             [],
                                             root)
    if IsErr(targetSpawnRes):
        os.WriteLine(os.Get_stderr(), Error(targetSpawnRes))
        return 1
    var targetProc = Value(targetSpawnRes)

    var targetPort: int32
    let targetReadyRes = vpnProxyE2eWaitReadyPort(root, targetReady, targetProc, targetPort)
    if IsErr(targetReadyRes):
        hostops.SpawnedProcessKill(targetProc)
        os.WriteLine(os.Get_stderr(), ErrorText(targetReadyRes))
        return 1

    let exitSpawnRes = hostops.SpawnFile(root,
                                           "vpn_proxy_e2e_exit",
                                           selfPath,
                                           ["--role:proxy-exit",
                                            strutil.Join(["--config:", exitConfigPath], ""),
                                            strutil.Join(["--ready-path:", exitReady], ""),
                                            "--accept-count:2"],
                                           [],
                                           root)
    if IsErr(exitSpawnRes):
        hostops.SpawnedProcessKill(targetProc)
        os.WriteLine(os.Get_stderr(), Error(exitSpawnRes))
        return 1
    var exitProc = Value(exitSpawnRes)

    var exitPort: int32
    let exitReadyRes = vpnProxyE2eWaitReadyPort(root, exitReady, exitProc, exitPort)
    if IsErr(exitReadyRes):
        hostops.SpawnedProcessKill(exitProc)
        hostops.SpawnedProcessKill(targetProc)
        os.WriteLine(os.Get_stderr(), ErrorText(exitReadyRes))
        return 1
    assert(chengpath.WriteTextFile("", localConfigPath, vpnProxyE2eLocalConfigText(exitPort)),
           " vpn proxy e2e: write local config")

    let localSpawnRes = hostops.SpawnFile(root,
                                            "vpn_proxy_e2e_local",
                                            selfPath,
                                            ["--role:proxy-local",
                                             strutil.Join(["--config:", localConfigPath], ""),
                                             strutil.Join(["--ready-path:", localReady], ""),
                                             "--accept-count:1",
                                             "--probe-timeout-ms:500"],
                                            [],
                                            root)
    if IsErr(localSpawnRes):
        hostops.SpawnedProcessKill(exitProc)
        hostops.SpawnedProcessKill(targetProc)
        os.WriteLine(os.Get_stderr(), Error(localSpawnRes))
        return 1
    var localProc = Value(localSpawnRes)

    var localPort: int32
    let localReadyRes = vpnProxyE2eWaitReadyPort(root, localReady, localProc, localPort)
    if IsErr(localReadyRes):
        hostops.SpawnedProcessKill(localProc)
        hostops.SpawnedProcessKill(exitProc)
        hostops.SpawnedProcessKill(targetProc)
        os.WriteLine(os.Get_stderr(), ErrorText(localReadyRes))
        return 1

    let clientRes: Result[bool] = vpnProxyE2eRunClient(localPort, targetPort)
    if IsErr(clientRes):
        vpnProxyE2eKillAndFinalize(root, localProc, localLog)
        vpnProxyE2eKillAndFinalize(root, exitProc, exitLog)
        vpnProxyE2eKillAndFinalize(root, targetProc, targetLog)
        vpnProxyE2eWriteFailure(root, ErrorText(clientRes), targetLog, localLog, exitLog)
        return 1

    let targetWaitRes: Result[bool] = vpnProxyE2eWaitRunOk(root, targetProc, targetLog, "target")
    if IsErr(targetWaitRes):
        vpnProxyE2eKillAndFinalize(root, localProc, localLog)
        vpnProxyE2eKillAndFinalize(root, exitProc, exitLog)
        vpnProxyE2eWriteFailure(root, ErrorText(targetWaitRes), targetLog, localLog, exitLog)
        return 1
    let localWaitRes: Result[bool] = vpnProxyE2eWaitRunOk(root, localProc, localLog, "local")
    if IsErr(localWaitRes):
        vpnProxyE2eKillAndFinalize(root, exitProc, exitLog)
        vpnProxyE2eWriteFailure(root, ErrorText(localWaitRes), targetLog, localLog, exitLog)
        return 1
    let exitWaitRes: Result[bool] = vpnProxyE2eWaitRunOk(root, exitProc, exitLog, "exit")
    if IsErr(exitWaitRes):
        vpnProxyE2eWriteFailure(root, ErrorText(exitWaitRes), targetLog, localLog, exitLog)
        return 1

    echo(" vpn_proxy_end_to_end_smoke ok")
    return 0

fn vpnProxyE2eRunTarget(): int32 =
    let port: int32 = cmdline.ReadInt32FlagOrDefault("--port", 0)
    let readyPath: str = cmdline.ReadFlagOrDefault("--ready-path", "")
    let listenRes: Result[tcp.TcpListenerHandle] = tcp.TcpListen(vpnProxyE2eTargetHost, port, false)
    if IsErr(listenRes):
        os.WriteLine(os.Get_stderr(), ErrorText(listenRes))
        return 1
    var listener = Value(listenRes)
    if len(readyPath) > 0:
        if !chengpath.WriteTextFile("", readyPath, intToStr(listener.addr.port)):
            tcp.TcpListenerClose(listener)
            os.WriteLine(os.Get_stderr(), " vpn proxy e2e: write target ready failed")
            return 1
    let acceptRes: Result[tcp.TcpConnectionHandle] = tcp.TcpAccept(listener)
    if IsErr(acceptRes):
        tcp.TcpListenerClose(listener)
        os.WriteLine(os.Get_stderr(), ErrorText(acceptRes))
        return 1
    var conn = Value(acceptRes)
    let requestRes: Result[Bytes] = vpnProxyE2eTcpReadExact(conn, bytesLen(vpnProxyE2eTargetRequest()))
    if IsErr(requestRes):
        tcp.TcpClose(conn)
        tcp.TcpListenerClose(listener)
        os.WriteLine(os.Get_stderr(), ErrorText(requestRes))
        return 1
    if !vpnProxyE2eBytesEq(Value(requestRes), vpnProxyE2eTargetRequest()):
        tcp.TcpClose(conn)
        tcp.TcpListenerClose(listener)
        os.WriteLine(os.Get_stderr(), " vpn proxy e2e: target request mismatch")
        return 1
    var response: Bytes = vpnProxyE2eTargetResponse()
    let sendRes: Result[int32] = vpnProxyE2eTcpWriteAll(conn, response)
    if IsErr(sendRes):
        tcp.TcpClose(conn)
        tcp.TcpListenerClose(listener)
        os.WriteLine(os.Get_stderr(), ErrorText(sendRes))
        return 1
    tcp.TcpClose(conn)
    tcp.TcpListenerClose(listener)
    echo(" vpn_proxy_end_to_end_smoke target ok")
    return 0

fn vpnProxyE2eRunProxyRole(mode: str): int32 =
    let root: str = os.GetCurrentDir()
    let configPath: str = cmdline.ReadFlagOrDefault("--config", "")
    let readyPath: str = cmdline.ReadFlagOrDefault("--ready-path", "")
    let acceptCount: int32 = cmdline.ReadInt32FlagOrDefault("--accept-count", 0)
    let probeTimeoutMs: int32 = cmdline.ReadInt32FlagOrDefault("--probe-timeout-ms", 1000)
    var args: str[]
    args = [mode,
            strutil.Join(["--config:", configPath], ""),
            strutil.Join(["--ready-path:", readyPath], ""),
            strutil.Join(["--accept-count:", intToStr(acceptCount)], ""),
            strutil.Join(["--probe-timeout-ms:", intToStr(probeTimeoutMs)], "")]
    return vpn.VpnProxyMain(root, args)

fn vpnProxyE2eRunClientRole(): int32 =
    let localPort: int32 = cmdline.ReadInt32FlagOrDefault("--local-port", 0)
    let targetPort: int32 = cmdline.ReadInt32FlagOrDefault("--target-port", 0)
    let runRes: Result[bool] = vpnProxyE2eRunClient(localPort, targetPort)
    if IsErr(runRes):
        os.WriteLine(os.Get_stderr(), ErrorText(runRes))
        return 1
    echo(" vpn_proxy_end_to_end_smoke client ok")
    return 0

fn main(): int32 =
    let role: str = cmdline.ReadFlagOrDefault("--role", "")
    if role == "target":
        return vpnProxyE2eRunTarget()
    if role == "proxy-exit":
        return vpnProxyE2eRunProxyRole("exit")
    if role == "proxy-local":
        return vpnProxyE2eRunProxyRole("local")
    if role == "client":
        return vpnProxyE2eRunClientRole()
    return vpnProxyE2eRunDefault()
