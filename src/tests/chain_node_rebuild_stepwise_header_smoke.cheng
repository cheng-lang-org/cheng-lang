import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus as consensus
import cheng/chain/lsmr as lsmr
import cheng/chain/anti_entropy as anti
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")

    let parentCid = node.ChainNodeAccountHead(server.index, 7, 1001)
    var event = consensus.ChainEventMint(
        7,
        1001,
        parentCid,
        int64(100),
        server.nextEpoch,
        server.nextGanzhi,
        node.ChainNodeSpaceSlot(1001, 1001),
        server.nextTick
    )
    let eventCid = consensus.ChainEventCid(event)

    var nextIndex = server.index
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(nextIndex, event, eventCid, server.eventCids.len, decision)
    assert(decision.accepted, " chain_node rebuild stepwise: accepted")
    assert(decision.applied, " chain_node rebuild stepwise: applied")

    server.index = nextIndex
    add(server.eventCids, eventCid)
    add(server.events, event)
    assert(server.eventCids.len == 1, " chain_node rebuild stepwise: before cells")

    let cells = node.ChainNodeStateCells(server.index)
    assert(server.eventCids.len == 1, " chain_node rebuild stepwise: after cells")

    lsmr.BuildStateLayerForestFill(server.forest, cells)
    assert(server.eventCids.len == 1, " chain_node rebuild stepwise: after forest")

    let stamp = node.ChainNodeMaxStamp(server.index)
    assert(server.eventCids.len == 1, " chain_node rebuild stepwise: after stamp")

    server.signature = anti.AntiEntropySignatureFromForest(
        stamp.epoch,
        stamp.ganzhi,
        server.eventCids.len,
        server.index.accountIds.len,
        server.forest
    )
    assert(server.eventCids.len == 1, " chain_node rebuild stepwise: after signature")

    server.tipEventCid = server.eventCids.len > 0 ? server.eventCids[server.eventCids.len - 1] : layout.FixedBytes32()
    assert(server.eventCids.len == 1, " chain_node rebuild stepwise: after tip")
    server.nextEpoch = stamp.epoch
    assert(server.eventCids.len == 1, " chain_node rebuild stepwise: after nextEpoch")
    server.nextGanzhi = stamp.ganzhi + 1
    assert(server.eventCids.len == 1, " chain_node rebuild stepwise: after nextGanzhi")
    if server.nextGanzhi <= 0:
        server.nextGanzhi = 1
    assert(server.eventCids.len == 1, " chain_node rebuild stepwise: after ganzhi guard")
    server.nextTick = int64(server.eventCids.len + 1)
    assert(server.eventCids.len == 1, " chain_node rebuild stepwise: after tail")

    echo(" chain_node_rebuild_stepwise_header_smoke ok")
    return 0
