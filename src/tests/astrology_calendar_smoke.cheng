import std/system
import cheng/apps/astrology/astrology_calendar_core as cal

fn main(): int32 =
    let newYearSolar = cal.AstrologySolarDateMake(2024, 2, 10, 9, 30)
    let newYearLunarRes = cal.AstrologyLunarFromSolar(newYearSolar)
    assert(IsOk(newYearLunarRes), " astrology calendar: solar to lunar")
    let newYearLunar = Value(newYearLunarRes)
    assert(newYearLunar.year == 2024, " astrology calendar: lunar year")
    assert(newYearLunar.month == 1, " astrology calendar: lunar month")
    assert(newYearLunar.day == 1, " astrology calendar: lunar day")
    assert(!newYearLunar.leap, " astrology calendar: new year not leap")

    let solarBackRes = cal.AstrologySolarFromLunar(newYearLunar)
    assert(IsOk(solarBackRes), " astrology calendar: lunar to solar")
    let solarBack = Value(solarBackRes)
    assert(solarBack.year == 2024, " astrology calendar: roundtrip year")
    assert(solarBack.month == 2, " astrology calendar: roundtrip month")
    assert(solarBack.day == 10, " astrology calendar: roundtrip day")

    let leapLunar = cal.AstrologyLunarDateMake(1900, 8, 1, true)
    let leapSolarRes = cal.AstrologySolarFromLunar(leapLunar)
    assert(IsOk(leapSolarRes), " astrology calendar: leap lunar to solar")
    let leapSolar = Value(leapSolarRes)
    assert(leapSolar.year == 1900, " astrology calendar: leap year")
    assert(leapSolar.month == 9, " astrology calendar: leap month")
    assert(leapSolar.day == 24, " astrology calendar: leap day")

    let stateRes = cal.AstrologyCalendarStateFromSolar(
        cal.AstrologySolarDateMake(2024, 2, 10, 23, 30),
        true)
    assert(IsOk(stateRes), " astrology calendar: state from solar")
    let state = Value(stateRes)
    assert(state.hourBranchIndex == 0, " astrology calendar: late zi branch")
    assert(len(state.dayGanzhiText) > 0, " astrology calendar: day ganzhi text")
    assert(len(state.hourGanzhiText) > 0, " astrology calendar: hour ganzhi text")
    return 0
