import std/system
import cheng/apps/astrology/astrology_calendar_core as cal

fn main(): int32 =
    let newYearSolar = cal.v3AstrologySolarDateMake(2024, 2, 10, 9, 30)
    let newYearLunarRes = cal.v3AstrologyLunarFromSolar(newYearSolar)
    assert(IsOk(newYearLunarRes), "v3 astrology calendar: solar to lunar")
    let newYearLunar = Value(newYearLunarRes)
    assert(newYearLunar.year == 2024, "v3 astrology calendar: lunar year")
    assert(newYearLunar.month == 1, "v3 astrology calendar: lunar month")
    assert(newYearLunar.day == 1, "v3 astrology calendar: lunar day")
    assert(!newYearLunar.leap, "v3 astrology calendar: new year not leap")

    let solarBackRes = cal.v3AstrologySolarFromLunar(newYearLunar)
    assert(IsOk(solarBackRes), "v3 astrology calendar: lunar to solar")
    let solarBack = Value(solarBackRes)
    assert(solarBack.year == 2024, "v3 astrology calendar: roundtrip year")
    assert(solarBack.month == 2, "v3 astrology calendar: roundtrip month")
    assert(solarBack.day == 10, "v3 astrology calendar: roundtrip day")

    let leapLunar = cal.v3AstrologyLunarDateMake(1900, 8, 1, true)
    let leapSolarRes = cal.v3AstrologySolarFromLunar(leapLunar)
    assert(IsOk(leapSolarRes), "v3 astrology calendar: leap lunar to solar")
    let leapSolar = Value(leapSolarRes)
    assert(leapSolar.year == 1900, "v3 astrology calendar: leap year")
    assert(leapSolar.month == 9, "v3 astrology calendar: leap month")
    assert(leapSolar.day == 24, "v3 astrology calendar: leap day")

    let stateRes = cal.v3AstrologyCalendarStateFromSolar(
        cal.v3AstrologySolarDateMake(2024, 2, 10, 23, 30),
        true)
    assert(IsOk(stateRes), "v3 astrology calendar: state from solar")
    let state = Value(stateRes)
    assert(state.hourBranchIndex == 0, "v3 astrology calendar: late zi branch")
    assert(len(state.dayGanzhiText) > 0, "v3 astrology calendar: day ganzhi text")
    assert(len(state.hourGanzhiText) > 0, "v3 astrology calendar: hour ganzhi text")
    return 0
