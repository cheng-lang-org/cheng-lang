import std/system
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr

fn main(): int32 =
    let text = bytesFromString("/ip4/127.0.0.1/udp/4201/quic-v1")
    var addr: types.V3Libp2pMultiaddr
    let addrRes = multiaddr.v3Libp2pMultiaddrFillFromBytes(addr, text)
    assert(addrRes.ok, "v3 libp2p multiaddr quic: parse")
    assert(addr.transport == types.v3Libp2pTransportQuic, "v3 libp2p multiaddr quic: transport")
    assert(addr.secure == types.v3Libp2pSecureTls, "v3 libp2p multiaddr quic: secure")
    assert(addr.mux == types.v3Libp2pMuxNone, "v3 libp2p multiaddr quic: mux")
    echo("v3 libp2p_multiaddr_quic_smoke ok")
    return 0
