import std/system
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr

fn main(): int32 =
    let text = bytesFromString("/ip4/127.0.0.1/udp/4201/quic-v1")
    var addr: types.Libp2pMultiaddr
    let addrRes = multiaddr.Libp2pMultiaddrFillFromBytes(addr, text)
    assert(addrRes.ok, " libp2p multiaddr quic: parse")
    assert(addr.transport == types.Libp2pTransportQuic, " libp2p multiaddr quic: transport")
    assert(addr.secure == types.Libp2pSecureTls, " libp2p multiaddr quic: secure")
    assert(addr.mux == types.Libp2pMuxNone, " libp2p multiaddr quic: mux")
    echo(" libp2p_multiaddr_quic_smoke ok")
    return 0
