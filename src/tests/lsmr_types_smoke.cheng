import std/system
import std/result
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    let rootRes: Result[lt.V3PrefixRef] = lt.v3PrefixRefFromDigits(lt.v3BaguaQian, [6])
    assert(IsOk(rootRes), "v3 lsmr_types: root prefix")

    let childRes: Result[lt.V3PrefixRef] = lt.v3PrefixRefFromDigits(
        lt.v3BaguaQian,
        [6, 1, types.v3LsmrDigitCenter]
    )
    assert(IsOk(childRes), "v3 lsmr_types: child prefix")
    assert(lt.v3PrefixRefContains(Value(rootRes), Value(childRes)), "v3 lsmr_types: prefix contains")
    assert(!lt.v3PrefixRefEqual(Value(rootRes), Value(childRes)), "v3 lsmr_types: prefix equal distinguishes depth")
    let childText: str = lt.v3PrefixRefText(Value(childRes))
    assert(childText == "6/1/5", "v3 lsmr_types: prefix text")
    assert(lt.v3BaguaValid(lt.v3BaguaKun), "v3 lsmr_types: bagua valid")
    assert(lt.v3LayerValid(lt.v3LayerRegional), "v3 lsmr_types: layer valid")
    assert(lt.v3PubSubModeValid(lt.v3PubSubModeLi), "v3 lsmr_types: pubsub mode valid")

    echo("v3 lsmr_types_smoke ok")
    return 0
