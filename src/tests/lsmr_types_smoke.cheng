import std/system
import std/result
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    let rootRes: Result[lt.PrefixRef] = lt.PrefixRefFromDigits(lt.BaguaQian, [6])
    assert(IsOk(rootRes), " lsmr_types: root prefix")

    let childRes: Result[lt.PrefixRef] = lt.PrefixRefFromDigits(
        lt.BaguaQian,
        [6, 1, types.LsmrDigitCenter]
    )
    assert(IsOk(childRes), " lsmr_types: child prefix")
    assert(lt.PrefixRefContains(Value(rootRes), Value(childRes)), " lsmr_types: prefix contains")
    assert(!lt.PrefixRefEqual(Value(rootRes), Value(childRes)), " lsmr_types: prefix equal distinguishes depth")
    let childText: str = lt.PrefixRefText(Value(childRes))
    assert(childText == "6/1/5", " lsmr_types: prefix text")
    assert(lt.BaguaValid(lt.BaguaKun), " lsmr_types: bagua valid")
    assert(lt.LayerValid(lt.LayerRegional), " lsmr_types: layer valid")
    assert(lt.PubSubModeValid(lt.PubSubModeLi), " lsmr_types: pubsub mode valid")

    echo(" lsmr_types_smoke ok")
    return 0
