import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_smoke_support as r2csmoke
import std/strutils as strutil

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = chengpath.PathAbsolute(root, "artifacts/r2c_exec_route_matrix_controller_smoke")
    assert(chengpath.MkdirP(root, outDir), " r2c exec route matrix smoke: mkdir")
    let driver = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    let packageRoot = root
    let controllerSource = chengpath.PathAbsolute(root, "src/r2c/r2c_react.cheng")
    assert(chengpath.FileExistsNonEmpty(root, driver), " r2c exec route matrix smoke: backend_driver exists")
    assert(chengpath.FileExistsNonEmpty(root, controllerSource), " r2c exec route matrix smoke: controller source exists")

    let controllerEnv = os.GetEnv("R2C_REACT_CONTROLLER_EXE")
    let allowControllerCompile = os.GetEnv("R2C_REACT_ALLOW_CONTROLLER_COMPILE") == "1"
    var controllerExe = ""
    if len(controllerEnv) > 0:
        controllerExe = chengpath.PathAbsolute(root, controllerEnv)
    elif allowControllerCompile:
        controllerExe = os.JoinPath(outDir, "r2c_react_exec_route_matrix_controller_smoke")
    else:
        assert(false,
               " r2c exec route matrix smoke: set R2C_REACT_CONTROLLER_EXE or R2C_REACT_ALLOW_CONTROLLER_COMPILE=1")
    if allowControllerCompile && len(controllerEnv) <= 0:
        let controllerCompileReport = strutil.Join([controllerExe, ".report.txt"], "")
        let controllerCompileLog = strutil.Join([controllerExe, ".compile.log"], "")
        if chengpath.PathFileExists(controllerExe):
            os.RemoveFile(controllerExe)
        if chengpath.PathFileExists(strutil.Join([controllerExe, ".map"], "")):
            os.RemoveFile(strutil.Join([controllerExe, ".map"], ""))
        if chengpath.PathFileExists(controllerCompileReport):
            os.RemoveFile(controllerCompileReport)
        if chengpath.PathFileExists(controllerCompileLog):
            os.RemoveFile(controllerCompileLog)
        let controllerCompileRun = hostops.RunFileLogged(root,
                                                           "r2c_exec_route_matrix_controller_compile",
                                                           driver,
                                                           [
                                                               "system-link-exec",
                                                               strutil.Join(["--root:", packageRoot], ""),
                                                               strutil.Join(["--in:", controllerSource], ""),
                                                               "--emit:exe",
                                                               "--target:arm64-apple-darwin",
                                                               strutil.Join(["--out:", controllerExe], ""),
                                                               strutil.Join(["--report-out:", controllerCompileReport], "")
                                                           ],
                                                           r2csmoke.R2cReactSmokeControllerCompileEnv(),
                                                           root,
                                                           420,
                                                           controllerCompileLog)
        assert(hostops.LoggedRunOk(controllerCompileRun), " r2c exec route matrix smoke: controller compile rc")
        assert(chengpath.FileExistsNonEmpty(root, controllerCompileReport), " r2c exec route matrix smoke: controller compile report")
    assert(chengpath.FileExistsNonEmpty(root, controllerExe), " r2c exec route matrix smoke: controller exe")

    let routeCatalogPath = os.JoinPath(outDir, "cheng_codegen_route_catalog_v1.json")
    let execSnapshotPath = os.JoinPath(outDir, "cheng_codegen_exec_snapshot_v1.json")
    let truthRoutesPath = os.JoinPath(outDir, "truth_routes_v1.json")
    let truthTracePath = os.JoinPath(outDir, "truth_trace_v2.json")
    let execRouteMatrixPath = os.JoinPath(outDir, "cheng_codegen_exec_route_matrix_v1.json")
    let execRouteMatrixSummaryPath = os.JoinPath(outDir, "exec_route_matrix.summary.env")
    let reportPath = os.JoinPath(outDir, "exec_route_matrix_report_v1.json")
    let routeCatalogText = Fmt"""
    {{
      "format": "cheng_codegen_route_catalog_v1",
      "runnerMode": "react_surface_runner_v1",
      "entryRouteState": "home_default",
      "routeCount": 2,
      "supportedCount": 2,
      "unsupportedCount": 0,
      "routes": ["home_default", "publish_selector"],
      "entries": [
        {{
          "routeId": "home_default",
          "supported": true,
          "deterministic": true,
          "reason": "entry_surface",
          "candidateCount": 1,
          "candidates": [
            {{
              "semanticNodesCount": 83,
              "reason": "entry_surface"
            }}
          ]
        }},
        {{
          "routeId": "publish_selector",
          "supported": true,
          "deterministic": true,
          "reason": "derived_candidate",
          "candidateCount": 1,
          "candidates": [
            {{
              "semanticNodesCount": 184,
              "reason": "derived_candidate"
            }}
          ]
        }}
      ]
    }}

    """
    assert(chengpath.WriteTextFile("", routeCatalogPath, routeCatalogText),
           " r2c exec route matrix smoke: write route catalog")
    let execSnapshotText = Fmt"""
    {{
      "format": "cheng_codegen_exec_snapshot_v1",
      "route_state": "home_default",
      "render_ready": true,
      "semantic_nodes_loaded": true,
      "semantic_nodes_count": 83,
      "tree_node_count": 83,
      "root_node_count": 1,
      "element_node_count": 83
    }}

    """
    assert(chengpath.WriteTextFile("", execSnapshotPath, execSnapshotText),
           " r2c exec route matrix smoke: write exec snapshot")
    let truthRoutesText = Fmt"""
    {{
      "format": "truth_routes_v1",
      "routes": [
        {{ "routeId": "home_default" }},
        {{ "routeId": "publish_selector" }}
      ]
    }}

    """
    assert(chengpath.WriteTextFile("", truthRoutesPath, truthRoutesText),
           " r2c exec route matrix smoke: write truth routes")
    let truthTraceText = Fmt"""
    {{
      "format": "truth_trace_v2",
      "snapshots": [
        {{
          "stateId": "home_default",
          "route": {{
            "routeId": "home_default"
          }},
          "semanticNodesCount": 83,
          "renderReady": true
        }},
        {{
          "stateId": "publish_selector",
          "route": {{
            "routeId": "publish_selector"
          }},
          "semanticNodesCount": 184,
          "renderReady": true
        }}
      ]
    }}

    """
    assert(chengpath.WriteTextFile("", truthTracePath, truthTraceText),
           " r2c exec route matrix smoke: write truth trace")

    let controllerLog = os.JoinPath(outDir, "exec_route_matrix_controller.log")
    if chengpath.PathFileExists(controllerLog):
        os.RemoveFile(controllerLog)
    let controllerRun = hostops.RunFileLogged(root,
                                                "r2c_exec_route_matrix_controller_smoke",
                                                controllerExe,
                                                [
                                                    "exec-route-matrix",
                                                    "--route-catalog", routeCatalogPath,
                                                    "--exec-snapshot", execSnapshotPath,
                                                    "--truth-routes-file", truthRoutesPath,
                                                    "--truth-trace", truthTracePath,
                                                    "--out", execRouteMatrixPath
                                                ],
                                                [strutil.Join(["R2C_REACT_TOOLING_BIN=", driver], "")],
                                                root,
                                                120,
                                                controllerLog)
    assert(hostops.LoggedRunOk(controllerRun), " r2c exec route matrix smoke: controller rc")
    assert(chengpath.FileExistsNonEmpty(root, execRouteMatrixPath), " r2c exec route matrix smoke: route matrix json")
    assert(chengpath.FileExistsNonEmpty(root, execRouteMatrixSummaryPath), " r2c exec route matrix smoke: route matrix summary")
    assert(chengpath.FileExistsNonEmpty(root, reportPath), " r2c exec route matrix smoke: report")

    let execRouteMatrixText = chengpath.ReadTextFile("", execRouteMatrixPath)
    let execRouteMatrixSummaryText = chengpath.ReadTextFile("", execRouteMatrixSummaryPath)
    let reportText = chengpath.ReadTextFile("", reportPath)
    assert(chengpath.TextContains(execRouteMatrixText, "\"format\": \"cheng_codegen_exec_route_matrix_v1\""),
           " r2c exec route matrix smoke: route matrix format")
    assert(chengpath.TextContains(execRouteMatrixText, "\"routeId\": \"home_default\""),
           " r2c exec route matrix smoke: route matrix home_default")
    assert(chengpath.TextContains(execRouteMatrixText, "\"routeId\": \"publish_selector\""),
           " r2c exec route matrix smoke: route matrix publish_selector")
    assert(chengpath.TextContains(execRouteMatrixText, "\"supportedCount\": 2"),
           " r2c exec route matrix smoke: route matrix supported count")
    assert(chengpath.TextContains(execRouteMatrixText, "\"unsupportedCount\": 0"),
           " r2c exec route matrix smoke: route matrix unsupported count")
    assert(chengpath.TextContains(execRouteMatrixSummaryText, "route_matrix_ok=true"),
           " r2c exec route matrix smoke: summary ok")
    assert(chengpath.TextContains(execRouteMatrixSummaryText, "route_count=2"),
           " r2c exec route matrix smoke: summary route count")
    assert(chengpath.TextContains(execRouteMatrixSummaryText, "supported_count=2"),
           " r2c exec route matrix smoke: summary supported count")
    assert(chengpath.TextContains(execRouteMatrixSummaryText, "unsupported_count=0"),
           " r2c exec route matrix smoke: summary unsupported count")
    assert(chengpath.TextContains(reportText, "\"command\": \"exec-route-matrix\""),
           " r2c exec route matrix smoke: report command")
    assert(chengpath.TextContains(reportText, "\"primary_artifact_format\": \"cheng_codegen_exec_route_matrix_v1\""),
           " r2c exec route matrix smoke: report artifact format")
    assert(chengpath.TextContains(reportText, "\"route_count\": 2"),
           " r2c exec route matrix smoke: report route count")

    echo(" r2c_react_exec_route_matrix_controller_smoke ok")
    return 0
