import std/bytes as bytes
import std/result
import std/system
import cheng/apps/wow_export/blte as blte
import cheng/apps/wow_export/zlib_inflate as zlib_inflate

fn makeBuf(len: int32): bytes.ByteBuffer =
    var out: bytes.ByteBuffer
    out.len = len
    if len > 0:
        out.data = alloc(len)
    return out

fn put(buf: bytes.ByteBuffer, idx: int32, value: int32) =
    bytes.BufSetByte(buf, idx, value)

fn main(): int32 =
    let stored: bytes.ByteBuffer = makeBuf(14)
    put(stored, 0, 0x78)
    put(stored, 1, 0x01)
    put(stored, 2, 0x01)
    put(stored, 3, 0x03)
    put(stored, 4, 0x00)
    put(stored, 5, 0xfc)
    put(stored, 6, 0xff)
    put(stored, 7, int32('a'))
    put(stored, 8, int32('b'))
    put(stored, 9, int32('c'))
    put(stored, 10, 0x02)
    put(stored, 11, 0x4d)
    put(stored, 12, 0x01)
    put(stored, 13, 0x27)
    let storedRes: Result[bytes.ByteBuffer] = zlib_inflate.WowZlibInflate(stored, 0, stored.len, 3)
    assert(IsOk(storedRes), Error(storedRes))
    let storedOut: bytes.ByteBuffer = Value(storedRes)
    assert(bytes.BufByteAt(storedOut, 0) == int32('a'), "wow_export_zlib stored a")
    assert(bytes.BufByteAt(storedOut, 2) == int32('c'), "wow_export_zlib stored c")

    let fixed: bytes.ByteBuffer = makeBuf(13)
    put(fixed, 0, 0x78)
    put(fixed, 1, 0x9c)
    put(fixed, 2, 0xcb)
    put(fixed, 3, 0x48)
    put(fixed, 4, 0xcd)
    put(fixed, 5, 0xc9)
    put(fixed, 6, 0xc9)
    put(fixed, 7, 0x07)
    put(fixed, 8, 0x00)
    put(fixed, 9, 0x06)
    put(fixed, 10, 0x2c)
    put(fixed, 11, 0x02)
    put(fixed, 12, 0x15)
    let fixedRes: Result[bytes.ByteBuffer] = zlib_inflate.WowZlibInflate(fixed, 0, fixed.len, 5)
    assert(IsOk(fixedRes), Error(fixedRes))
    let fixedOut: bytes.ByteBuffer = Value(fixedRes)
    assert(bytes.BufByteAt(fixedOut, 0) == int32('h'), "wow_export_zlib fixed h")
    assert(bytes.BufByteAt(fixedOut, 4) == int32('o'), "wow_export_zlib fixed o")

    let blteBuf: bytes.ByteBuffer = makeBuf(50)
    put(blteBuf, 0, 0x42)
    put(blteBuf, 1, 0x4c)
    put(blteBuf, 2, 0x54)
    put(blteBuf, 3, 0x45)
    put(blteBuf, 4, 0)
    put(blteBuf, 5, 0)
    put(blteBuf, 6, 0)
    put(blteBuf, 7, 36)
    put(blteBuf, 8, 0x0f)
    put(blteBuf, 9, 0)
    put(blteBuf, 10, 0)
    put(blteBuf, 11, 1)
    put(blteBuf, 12, 0)
    put(blteBuf, 13, 0)
    put(blteBuf, 14, 0)
    put(blteBuf, 15, 14)
    put(blteBuf, 16, 0)
    put(blteBuf, 17, 0)
    put(blteBuf, 18, 0)
    put(blteBuf, 19, 5)
    put(blteBuf, 36, 0x5a)
    var i: int32
    for i in i..<fixed.len:
        put(blteBuf, 37 + i, bytes.BufByteAt(fixed, i))
    let blteRes: Result[bytes.ByteBuffer] = blte.DecodeNormalSingleBlock(blteBuf)
    assert(IsOk(blteRes), Error(blteRes))
    let blteOut: bytes.ByteBuffer = Value(blteRes)
    assert(blteOut.len == 5, "wow_export_zlib blte len")
    assert(bytes.BufByteAt(blteOut, 1) == int32('e'), "wow_export_zlib blte e")
    echo("wow_export_zlib_smoke ok")
    return 0
