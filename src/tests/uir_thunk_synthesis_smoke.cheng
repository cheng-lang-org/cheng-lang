import std/strings
import cheng/core/backend/uir_thunk_synthesis as uthunk

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn main(): int32 =
    var ctx = uthunk.UirThunkSynthesisCtxNew()
    let c1 = check(ctx.thunks.len == 0, 11)
    if c1 != 0: return c1

    let flushed = uthunk.UirThunkSynthesisCtxFlushThunks(ctx)
    let c2 = check(flushed.len == 0, 12)
    if c2 != 0: return c2
    let c3 = check(ctx.thunks.len == 0, 13)
    if c3 != 0: return c3

    let report = uthunk.UirThunkSynthesisReport(ctx)
    let c4 = check(strings.Len(report) > 0, 21)
    if c4 != 0: return c4

    let c5 = check(uthunk.InvalidThunkFuncId() == -1, 31)
    if c5 != 0: return c5

    let c6 = check(uthunk.ThunkSliceToPtrLenTag >= 0, 41)
    if c6 != 0: return c6
    let c7 = check(uthunk.ThunkPtrLenToSliceTag >= 0, 42)
    if c7 != 0: return c7
    let c8 = check(uthunk.ThunkOutPtrToTupleTag >= 0, 43)
    if c8 != 0: return c8
    let c9 = check(uthunk.ThunkHandleWrapTag >= 0, 44)
    if c9 != 0: return c9
    let c10 = check(uthunk.ThunkStructLowerTag >= 0, 45)
    if c10 != 0: return c10
    let c11 = check(uthunk.ThunkStructLiftTag >= 0, 46)
    if c11 != 0: return c11
    let c12 = check(uthunk.ThunkVarargsAdapterTag >= 0, 47)
    if c12 != 0: return c12

    let c13 = check(uthunk.ThunkNoneTag == 0, 51)
    if c13 != 0: return c13

    echo("uir_thunk_synthesis_smoke ok")
    return 0
