import std/strings
import std/strformat as sf
import std/strutils as strutil

type
    Box = object
        title: str
        count: int32

fn main(): int32 =
    let name: str = "alpha"
    let count: int32 = 7
    let box = Box(title: "beta", count: 9)
    let fallback: str = "none"
    let summary: str = Fmt"box={name} count={intToStr(count)} rc={intToStr(count)}"
    assert(summary == "box=alpha count=7 rc=7", " strformat fmt: multi placeholder")

    let escaped: str = Fmt"{{ok}} {name}"
    assert(escaped == "{ok} alpha", " strformat fmt: escaped braces")

    let wrappedText: str = Fmt"{{{name}}}"
    assert(wrappedText == "{alpha}", " strformat fmt: wrapped placeholder")

    let rightBraceText: str = Fmt"}}"
    assert(rightBraceText == "}", " strformat fmt: right brace escape")

    let memberText: str = Fmt"{box.title}:{intToStr(box.count)}"
    assert(memberText == "beta:9", " strformat fmt: member access")

    let condText: str = Fmt"selected={true ? box.title : fallback}"
    assert(condText == "selected=beta", " strformat fmt: ternary placeholder")

    let ifExprText: str = Fmt"picked={if true: box.title else: fallback}"
    assert(ifExprText == "picked=beta", " strformat fmt: if expr placeholder")

    var parts: str[]
    add(parts, Fmt"[{intToStr(count)}] {name}")
    assert(parts.len == 1, " strformat fmt: nested add len")
    assert(parts[0] == "[7] alpha", " strformat fmt: nested add value")

    let joined: str = Fmt(parts)
    assert(joined == "[7] alpha", " strformat fmt: bare join")
    let aliasedJoined: str = sf.Fmt(parts)
    assert(aliasedJoined == "[7] alpha", " strformat fmt: aliased join")

    var lineParts: str[]
    add(lineParts, "left")
    add(lineParts, "right")
    let lines: str = Lines(lineParts)
    assert(lines == "left\nright", " strformat fmt: bare lines")
    let aliasedLines: str = sf.Lines(lineParts)
    assert(aliasedLines == "left\nright", " strformat fmt: aliased lines")
    let joinedViaStrutils: str = strutil.Join(parts, "")
    assert(joinedViaStrutils == "[7] alpha", " strformat fmt: strutils empty join")
    let linesViaStrutils: str = strutil.Join(lineParts, "\n")
    assert(linesViaStrutils == "left\nright", " strformat fmt: strutils newline join")

    echo(" strformat_fmt_smoke ok")
    return 0
