import std/cmdline
import std/os
import cheng/core/tooling/mobile_shell_codegen as mshell

fn main(): int32 =
    var args: str[]
    let total: int32 = cmdline.paramCount()
    for i in 1..<total:
        add(args, cmdline.paramStr(i))
    var outText: str
    var errText: str
    let root: str = os.GetCurrentDir()
    return mshell.MobileShellRun(root, args, outText, errText)
