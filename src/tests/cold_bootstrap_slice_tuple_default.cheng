type
    SurfaceWrap = object
        count: int32

    SurfacePair = tuple[a: int32]

fn Defaults(): int32 =
    let localCount = 13
    let localPair = 17
    let wrap = SurfaceWrap()
    let pair = SurfacePair()
    let fixed: int32[2]
    let builtWrap = SurfaceWrap(count: localCount)
    let builtPair = SurfacePair(a: localPair)
    return wrap.count + pair.a + fixed[0] + builtWrap.count + builtPair.a

fn main(): int32 =
    return Defaults()
