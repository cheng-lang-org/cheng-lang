import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host
import cheng/libp2p/transports/tailnet_transport as tsnet
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net
import cheng/tests/smoke_ports

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "tailnet.node.a", "tailnet-chain")),
           " chain_node: init")
    var client: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(client, "tailnet.node.b", "tailnet-chain")),
           " chain_node: init")
    var serverHost = host.Libp2pHostInit("tailnet.server")
    var clientHost = host.Libp2pHostInit("tailnet.client")
    host.Libp2pHostSetTrustedInfra(serverHost, true)
    host.Libp2pHostSetTrustedInfra(clientHost, true)

    var tailnetCfg: tsnet.Libp2pTailnetTransportConfig
    tailnetCfg.controlEndpoint = "https://headscale.tailnet/control"
    tailnetCfg.relayEndpoint = "https://derp.tailnet:443"
    tailnetCfg.syntheticIPv4 = "100.64.0.21"
    tailnetCfg.exactRouting = true
    tailnetCfg.localPeerId = peer_id.Libp2pPeerIdText(serverHost.selfPeerId)
    var tailnet = tsnet.Libp2pTailnetTransportInit(tailnetCfg)
    tsnet.Libp2pTailnetSetProviderReady(tailnet, true, "control-ready")
    tsnet.Libp2pTailnetSetProxyListenersReady(tailnet, true, "proxy-ready")

    var rawListen: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(rawListen, "127.0.0.1", smoke_ports.SmokeLabelPort(6211))
    let publishedRes = tsnet.Libp2pTailnetListen(tailnet, rawListen)
    assert(IsOk(publishedRes), " chain_node tailnet: published listen")
    let tailnetAddr = Value(publishedRes)
    var serverSession: tsnet.Libp2pTailnetPeerSession
    serverSession.peerId = peer_id.Libp2pPeerIdText(serverHost.selfPeerId)
    serverSession.remoteTailnetIp = tailnetAddr.host
    serverSession.directReachable = true
    serverSession.relayAllowed = true
    serverSession.signedPreface = "preface-ok"
    serverSession.boundAddrText = tsnet.Libp2pTailnetAddrText(rawListen)
    tsnet.Libp2pTailnetUpsertPeerSession(tailnet, serverSession)
    let dialPlanBuild = tsnet.Libp2pTailnetDialPlanBuild(tailnet,
                                                           peer_id.Libp2pPeerIdText(serverHost.selfPeerId),
                                                           tailnetAddr,
                                                           false,
                                                           false)
    assert(dialPlanBuild.ok, " chain_node tailnet: dial plan")
    let dialPlan = dialPlanBuild.plan
    assert(dialPlan.pathKind == tsnet.Libp2pTailnetPathDirect,
        " chain_node tailnet: direct path")
    assert(dialPlan.routeText == tsnet.Libp2pTailnetAddrText(rawListen),
        " chain_node tailnet: exact route")

    let listenRes = host.Libp2pListen(serverHost, tailnetAddr)
    assert(listenRes.ok, " chain_node tailnet: listen")

    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolGossipsub)
    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolStore)
    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolGossipsub)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolStore)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolSync)

    let dialRes = host.Libp2pDial(clientHost,
                                    serverHost.selfPeerId,
                                    tailnetAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " chain_node tailnet: dial")
    host.Libp2pSetPeerTrustedInfra(clientHost, serverHost.selfPeerId, true)

    let mintCidRes = node.ChainNodeMint(server, 9, 3001, int64(77))
    assert(mintCidRes.ok, " chain_node tailnet: mint")
    let transferCidRes = node.ChainNodeTransfer(server, 9, 3001, 4002, int64(12))
    assert(transferCidRes.ok, " chain_node tailnet: transfer")

    let serveRes = net.ChainNodeLibp2pServeOnce(server, serverHost)
    assert(serveRes.ok, " chain_node tailnet: serve once")
    var query: overlay.StoreQuery
    net.ChainNodeLibp2pSnapshotQueryFill(query, server.address)
    var entries: overlay.IngressEnvelope[]
    let entriesRes = host.Libp2pSyncRequest(clientHost, serverHost, serverHost.selfPeerId, query, entries)
    assert(entriesRes.ok, " chain_node tailnet: sync request")
    var snapshot: node.ChainNodeServeSnapshot
    var snapshotIngress: overlay.IngressEnvelope
    let snapshotIndexRes = net.ChainNodeLibp2pLatestSnapshotIndexFromIngresses(entries, server.address)
    assert(IsOk(snapshotIndexRes), " chain_node tailnet: latest snapshot")
    let snapshotIndex = snapshotIndexRes.value
    net.ChainNodeLibp2pCopyIngress(snapshotIngress, entries[snapshotIndex])
    let decodeRes = net.ChainNodeLibp2pDecodeSnapshotFill(snapshotIngress.payload, snapshot)
    assert(decodeRes.ok, " chain_node tailnet: decode snapshot")
    let syncRes = node.ChainNodeSyncOnce(client, snapshot)
    assert(syncRes.ok, " chain_node tailnet: sync once")
    assert(syncRes.value, " chain_node tailnet: sync changed")

    let exportedPublic = host.Libp2pVisibleListenAddrs(serverHost, false)
    assert(exportedPublic.len == 0, " chain_node tailnet: no public export")
    let exportedTrusted = host.Libp2pIdentifyListenAddrsForPeer(serverHost, clientHost.selfPeerId)
    assert(exportedTrusted.len == 0, " chain_node tailnet: no identify export without whitelist")
    let exportedPeerView = host.Libp2pPeerVisibleAddrs(clientHost, serverHost.selfPeerId, true)
    assert(exportedPeerView.len == 1, " chain_node tailnet: client keeps tailnet endpoint")
    assert(exportedPeerView[0].networkDomain == types.Libp2pNetworkDomainTailnet,
        " chain_node tailnet: selected domain")

    let aliceRes = node.ChainNodeBalance(client, 9, 3001)
    let bobRes = node.ChainNodeBalance(client, 9, 4002)
    assert(aliceRes.ok, " chain_node tailnet: alice balance")
    assert(bobRes.ok, " chain_node tailnet: bob balance")
    assert(aliceRes.value == int64(65), " chain_node tailnet: alice 65")
    assert(bobRes.value == int64(12), " chain_node tailnet: bob 12")

    var serverServed: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(serverServed, server)
    var clientServed: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(clientServed, client)
    assert(layout.FixedBytes32Equal(serverServed.forest.forestCid, clientServed.forest.forestCid),
        " chain_node tailnet: forest cid")
    assert(anti.AntiEntropySignatureEqual(serverServed.signature, clientServed.signature),
        " chain_node tailnet: signature")

    echo(" chain_node_tailnet_smoke ok")
    return 0
