import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/codec_binary as codec

fn main(): int32 =
    let peerRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff")
    assert(IsOk(peerRes), " chain codec: peer id")
    let tipRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "1111111111111111111111111111111111111111111111111111111111111111")
    assert(IsOk(tipRes), " chain codec: tip cid")
    let forestRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "2222222222222222222222222222222222222222222222222222222222222222")
    assert(IsOk(forestRes), " chain codec: forest cid")
    let eventRootRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "3333333333333333333333333333333333333333333333333333333333333333")
    assert(IsOk(eventRootRes), " chain codec: event root cid")
    let accountRootRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "4444444444444444444444444444444444444444444444444444444444444444")
    assert(IsOk(accountRootRes), " chain codec: account root cid")
    let eventCidRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "5555555555555555555555555555555555555555555555555555555555555555")
    assert(IsOk(eventCidRes), " chain codec: event cid")

    let addrRes: Result[types.LsmrAddress] = types.LsmrAddressFromDigits([1, 3, 5, 7, 9, 2])
    assert(IsOk(addrRes), " chain codec: address")
    assert(Value(addrRes).digits[2] == types.LsmrDigitCenter, " chain codec: center digit")

    let badAddrRes: Result[types.LsmrAddress] = types.LsmrAddressFromDigits([0])
    assert(IsErr(badAddrRes), " chain codec: digit zero rejected")

    let summary = types.StateRootSummaryMake(
        Value(forestRes),
        Value(eventRootRes),
        Value(accountRootRes)
    )

    let helloPayload = types.HelloPayloadMake(
        Value(peerRes),
        Value(addrRes),
        Value(tipRes),
        summary
    )
    let helloFrameRes: Result[Bytes] = codec.EncodeHelloFrame(helloPayload, 7, 19)
    assert(IsOk(helloFrameRes), " chain codec: encode HELLO frame")
    let helloDecodedRes: Result[types.HelloPayload] = codec.DecodeHelloFrame(Value(helloFrameRes))
    assert(IsOk(helloDecodedRes), " chain codec: decode HELLO frame")
    assert(types.LsmrAddressEqual(Value(helloDecodedRes).address, Value(addrRes)), " chain codec: HELLO address")
    assert(layout.fixedBytes32Equal(Value(helloDecodedRes).summary.stateForestCid, summary.stateForestCid), " chain codec: HELLO summary")

    let advertisePayload = types.AdvertisePayloadMake(
        Value(peerRes),
        Value(forestRes),
        Value(eventCidRes),
        3,
        9,
        17,
        41
    )
    let advertiseFrameRes: Result[Bytes] = codec.EncodeAdvertiseFrame(advertisePayload, 17, 41)
    assert(IsOk(advertiseFrameRes), " chain codec: encode ADVERTISE frame")
    let advertiseDecodedRes: Result[types.AdvertisePayload] = codec.DecodeAdvertiseFrame(Value(advertiseFrameRes))
    assert(IsOk(advertiseDecodedRes), " chain codec: decode ADVERTISE frame")
    assert(Value(advertiseDecodedRes).eventCount == 9, " chain codec: ADVERTISE event count")
    assert(layout.fixedBytes32Equal(Value(advertiseDecodedRes).eventCid, Value(eventCidRes)), " chain codec: ADVERTISE event cid")

    let wantPayloadRes: Result[types.WantStatePayload] = types.WantStatePayloadFromDigits(
        Value(peerRes),
        Value(forestRes),
        5,
        [7, 1, 6, 5]
    )
    assert(IsOk(wantPayloadRes), " chain codec: want payload")
    let wantFrameRes: Result[Bytes] = codec.EncodeWantStateFrame(Value(wantPayloadRes), 23, 11)
    assert(IsOk(wantFrameRes), " chain codec: encode WANT_STATE frame")
    let wantDecodedRes: Result[types.WantStatePayload] = codec.DecodeWantStateFrame(Value(wantFrameRes))
    assert(IsOk(wantDecodedRes), " chain codec: decode WANT_STATE frame")
    assert(Value(wantDecodedRes).targetBaguaId == types.LsmrDigitCenter, " chain codec: WANT_STATE bagua digit")
    assert(Value(wantDecodedRes).prefixDepth == 4, " chain codec: WANT_STATE depth")
    assert(Value(wantDecodedRes).prefixDigits[2] == 6, " chain codec: WANT_STATE digits")
    assert(Value(wantDecodedRes).prefixDigits[3] == types.LsmrDigitCenter, " chain codec: WANT_STATE center digit")

    echo(" chain_codec_binary_smoke ok")
    return 0
