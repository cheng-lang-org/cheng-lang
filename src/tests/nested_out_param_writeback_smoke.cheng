import std/strutils as strutil

fn innerMultiFill(command: str,
                  workingDir: str,
                  outReadFd: var int32,
                  outWriteFd: var int32,
                  outPid: var int64,
                  outOk: var bool) =
    if command == "":
        outOk = false
        return
    outReadFd = 11
    outWriteFd = 12
    outPid = 13
    outOk = workingDir == "dir"

fn outerMultiFill(outText: var str, outRc: var int32) =
    var readFd: int32 = -1
    var writeFd: int32 = -1
    var pid: int64 = -1
    var ok = false
    innerMultiFill("cmd", "dir", readFd, writeFd, pid, ok)
    if !ok:
        outText = "bad"
        outRc = -11
        return
    outText = strutil.Join([IntToStr(readFd), ",", IntToStr(writeFd), ",", IntToStr(int32(pid))], "")
    outRc = 0

fn main(): int32 =
    var text: str
    var rc: int32 = -1
    outerMultiFill(text, rc)
    assert(rc == 0, "nested out param writeback rc")
    assert(strutil.Strip(text) == "11,12,13", "nested out param writeback text")
    echo(" nested_out_param_writeback_smoke ok")
    return 0
