import cheng/core/lang/browser_abi_rule as barule
import cheng/libp2p/browser/browser_content_codec_rule_schema as browsercodec

fn main(): int32 =
    let rules = browsercodec.BrowserContentCodecRules("/tmp/browser_content_codec_abi.cheng")
    assert(rules.len == 8, " browser content codec rule schema: rule count")
    assert(barule.BrowserAbiRuleUniqueKeyCount(rules) == rules.len,
           " browser content codec rule schema: unique key count")
    assert(barule.BrowserAbiRuleCountInputKind(rules, barule.BrowserAbiInputBytesRequired) == 1,
           " browser content codec rule schema: bytes input")
    assert(barule.BrowserAbiRuleCountInputKind(rules, barule.BrowserAbiInputTextRequired) == 1,
           " browser content codec rule schema: text input")
    assert(barule.BrowserAbiRuleCountInputKind(rules, barule.BrowserAbiInputTextOptional) == 1,
           " browser content codec rule schema: optional text input")
    assert(barule.BrowserAbiRuleCountErrorKind(rules, barule.BrowserAbiErrorMoqFountainLastError) == 3,
           " browser content codec rule schema: error channel")
    assert(barule.BrowserAbiRuleCountResultKind(rules, barule.BrowserAbiResultStatusI32) == 2,
           " browser content codec rule schema: status result")
    assert(barule.BrowserAbiRuleCountOutBufferKind(rules, barule.BrowserAbiOutBufferRawHandle) == 2,
           " browser content codec rule schema: raw handle out buffer")
    assert(barule.BrowserAbiRuleCountOutBufferKind(rules, barule.BrowserAbiOutBufferTextHandle) == 3,
           " browser content codec rule schema: text handle out buffer")
    assert(barule.BrowserAbiRuleHasRuleName(rules, browsercodec.BrowserContentCodecRuleExportMoqFountainBytesResultName()),
           " browser content codec rule schema: moq bytes export rule")
    assert(barule.BrowserAbiRuleHasRuleName(rules, browsercodec.BrowserContentCodecRuleExportMoqFountainTextResultName()),
           " browser content codec rule schema: moq text export rule")
    assert(barule.BrowserAbiRuleHasRuleName(rules, browsercodec.BrowserContentCodecRuleMoqFountainLastErrorHandleName()),
           " browser content codec rule schema: moq error handle rule")
    let bytesRule = browsercodec.BrowserContentCodecRuleByName("/tmp/browser_content_codec_abi.cheng",
                                                                 browsercodec.BrowserContentCodecRuleInputBytesRequiredName())
    assert(bytesRule.ruleName == browsercodec.BrowserContentCodecRuleInputBytesRequiredName(),
           " browser content codec rule schema: bytes rule by name")
    let exportTextRule = browsercodec.BrowserContentCodecRuleByName("/tmp/browser_content_codec_abi.cheng",
                                                                      browsercodec.BrowserContentCodecRuleExportMoqFountainTextResultName())
    let bridgeSpecs = barule.BrowserAbiBridgeSpecsFromRules(rules)
    let bridgePlans = barule.BrowserAbiBridgePlansFromRules(rules)
    assert(barule.BrowserAbiBridgeSpecCountStage(bridgeSpecs, barule.BrowserAbiBridgeStageResultExport) == 2,
           " browser content codec rule schema: export bridge count")
    assert(barule.BrowserAbiBridgeSpecCountStage(bridgeSpecs, barule.BrowserAbiBridgeStageErrorHandleRead) == 1,
           " browser content codec rule schema: error handle bridge count")
    assert(barule.BrowserAbiBridgePlansEqual(bridgePlans, barule.BrowserAbiBridgePlansFromSpecs(bridgeSpecs)),
           " browser content codec rule schema: bridge plan equality")
    assert(exportTextRule.errorKind == barule.BrowserAbiErrorMoqFountainLastError,
           " browser content codec rule schema: export text error kind")
    assert(barule.BrowserAbiBridgeHelperName(bridgeSpecs[0]) == "cheng_browser_bridge_input_read_input_bytes_required",
           " browser content codec rule schema: bytes helper name")
    assert(barule.BrowserAbiBridgePlanEmitLine(bridgePlans[6]) ==
           "source=/tmp/browser_content_codec_abi.cheng|rule=export_moq_fountain_text_result|stage=result_export|helper=cheng_browser_bridge_result_export_export_moq_fountain_text_result|input_schema=none|output_schema=text_handle|error_schema=moq_fountain_last_error|result=status_i32|out_buffer=text_handle",
           " browser content codec rule schema: export text emit line")
    echo(" browser_content_codec_rule_schema_smoke ok")
    return 0
