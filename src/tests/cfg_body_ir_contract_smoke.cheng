import cheng/core/ir/core_types as ir
import cheng/core/ir/body_ir_noalias as noalias

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn addI32Slot(bodyIR: var ir.BodyIR,
              name: str): int32 =
    var slot: ir.LocalSlot
    slot.id = bodyIR.localSlots.len
    slot.name = name
    slot.typeKind = ir.LocalI32Tag
    slot.stackOffset = 16 + slot.id * 8
    slot.sizeBytes = 4
    slot.alignBytes = 4
    slot.noAlias = true
    add(bodyIR.localSlots, slot)
    return slot.id

fn main(): int32 =
    var bodyIR = ir.BodyIRNew()

    # Add 2 locals: int32 x at slot 0, float64 y at slot 1
    var local0: ir.LocalSlot
    local0.id = 0
    local0.name = "x"
    local0.typeKind = ir.LocalI32Tag
    local0.stackOffset = 16
    local0.sizeBytes = 4
    local0.alignBytes = 4
    local0.noAlias = true
    add(bodyIR.localSlots, local0)

    var local1: ir.LocalSlot
    local1.id = 1
    local1.name = "y"
    local1.typeKind = ir.LocalF64Tag
    local1.stackOffset = 32
    local1.sizeBytes = 8
    local1.alignBytes = 8
    local1.noAlias = true
    add(bodyIR.localSlots, local1)

    # Add 1 call op (BodyOpCall = tag 2)
    var callOp: ir.BodyOp
    callOp.kind = ir.BodyOpCallTag
    callOp.target = 0
    add(callOp.operands, 0)
    add(callOp.operands, 1)
    add(bodyIR.ops, callOp)

    # Add a return op (BodyOpReturn = tag 6)
    var retOp: ir.BodyOp
    retOp.kind = ir.BodyOpReturnTag
    retOp.target = -1
    add(retOp.operands, 0)
    add(bodyIR.ops, retOp)

    # Add a call sequence entry
    var callSeq: ir.CallOp
    callSeq.targetSymbol = "GetValue"
    callSeq.resultSlot = 0
    callSeq.relocWordOffset = 2
    add(callSeq.argSlots, 0)
    add(bodyIR.callSequence, callSeq)

    # Add a return term (BodyTermReturn = tag 1)
    var term: ir.BodyTerm
    term.kind = ir.BodyTermReturnTag
    term.resultSlot = 0
    let termIndex = ir.BodyIRAppendTerm(bodyIR, term)

    # Add a block referencing the term (opStart=0, opCount=2)
    let blockId = ir.BodyIRAppendBlock(bodyIR, 0, 2, termIndex)

    # ---------- Verify field access ----------
    # Locals
    let c1 = check(bodyIR.localSlots.len == 2, 11)
    if c1 != 0: return c1
    let c2 = check(bodyIR.localSlots[0].name == "x", 12)
    if c2 != 0: return c2
    let c3 = check(bodyIR.localSlots[0].typeKind == ir.LocalI32Tag, 13)
    if c3 != 0: return c3
    let c4 = check(bodyIR.localSlots[1].name == "y", 14)
    if c4 != 0: return c4
    let c5 = check(bodyIR.localSlots[1].typeKind == ir.LocalF64Tag, 15)
    if c5 != 0: return c5

    # Ops
    let c6 = check(bodyIR.ops.len == 2, 16)
    if c6 != 0: return c6
    let c7 = check(bodyIR.ops[0].kind == ir.BodyOpCallTag, 17)
    if c7 != 0: return c7
    let c8 = check(bodyIR.ops[1].kind == ir.BodyOpReturnTag, 18)
    if c8 != 0: return c8

    # Call sequence
    let c9 = check(bodyIR.callSequence.len == 1, 19)
    if c9 != 0: return c9
    let c10 = check(bodyIR.callSequence[0].targetSymbol == "GetValue", 20)
    if c10 != 0: return c10
    let c11 = check(bodyIR.callSequence[0].resultSlot == 0, 21)
    if c11 != 0: return c11

    # Blocks
    let c12 = check(bodyIR.blocks.len == 1, 22)
    if c12 != 0: return c12
    let c13 = check(bodyIR.blocks[0].id == 0, 23)
    if c13 != 0: return c13
    let c14 = check(bodyIR.blocks[0].opStart == 0, 24)
    if c14 != 0: return c14
    let c15 = check(bodyIR.blocks[0].opCount == 2, 25)
    if c15 != 0: return c15

    # Terms
    let c16 = check(bodyIR.terms.len == 1, 26)
    if c16 != 0: return c16
    let c17 = check(bodyIR.terms[0].kind == ir.BodyTermReturnTag, 27)
    if c17 != 0: return c17

    # Cbr term construction (conditional branch)
    var cbrTerm: ir.BodyTerm
    cbrTerm.kind = ir.BodyTermCbrTag
    cbrTerm.conditionKind = ir.BodyCondI32LeTag
    cbrTerm.lhsSlot = 0
    cbrTerm.rhsSlot = -1
    cbrTerm.trueBlock = 1
    cbrTerm.falseBlock = 2
    let cbrTermIndex = ir.BodyIRAppendTerm(bodyIR, cbrTerm)

    let c18 = check(bodyIR.terms.len == 2, 28)
    if c18 != 0: return c18
    let c19 = check(bodyIR.terms[1].kind == ir.BodyTermCbrTag, 29)
    if c19 != 0: return c19
    let c20 = check(bodyIR.terms[1].conditionKind == ir.BodyCondI32LeTag, 30)
    if c20 != 0: return c20
    let c21 = check(bodyIR.terms[1].trueBlock == 1, 31)
    if c21 != 0: return c21
    let c22 = check(bodyIR.terms[1].falseBlock == 2, 32)
    if c22 != 0: return c22

    # Br term (unconditional branch)
    var brTerm: ir.BodyTerm
    brTerm.kind = ir.BodyTermBrTag
    brTerm.trueBlock = 0
    let brTermIndex = ir.BodyIRAppendTerm(bodyIR, brTerm)

    let c23 = check(bodyIR.terms.len == 3, 33)
    if c23 != 0: return c23
    let c24 = check(bodyIR.terms[2].kind == ir.BodyTermBrTag, 34)
    if c24 != 0: return c24
    let c25 = check(bodyIR.terms[2].trueBlock == 0, 35)
    if c25 != 0: return c25

    # Local slot noAlias and id tracking
    let c26 = check(bodyIR.localSlots[0].noAlias, 36)
    if c26 != 0: return c26
    let c27 = check(bodyIR.localSlots[1].id == 1, 37)
    if c27 != 0: return c27

    var noAliasBody = ir.BodyIRNew()
    let a = addI32Slot(noAliasBody, "a")
    let b = addI32Slot(noAliasBody, "b")
    let c = addI32Slot(noAliasBody, "c")

    var loadB: ir.BodyOp
    loadB.kind = ir.BodyOpLoadLocalTag
    loadB.target = b
    add(loadB.operands, a)
    add(noAliasBody.ops, loadB)

    var copyC: ir.BodyOp
    copyC.kind = ir.BodyOpCopyLocalTag
    copyC.target = c
    add(copyC.operands, b)
    add(noAliasBody.ops, copyC)

    var noAliasTerm: ir.BodyTerm
    noAliasTerm.kind = ir.BodyTermReturnTag
    noAliasTerm.resultSlot = c
    let noAliasTermIndex = ir.BodyIRAppendTerm(noAliasBody, noAliasTerm)
    let _ = ir.BodyIRAppendBlock(noAliasBody, 0, 2, noAliasTermIndex)

    var analyzedNoAliasBody = noAliasBody
    noalias.BodyIrAnalyzeOwnership(analyzedNoAliasBody)
    let forwardedNoAliasBody = noalias.BodyIrNoAliasForwardLocals(analyzedNoAliasBody)
    let noAliasRewriteCount = noalias.BodyIrNoAliasRewriteCount(analyzedNoAliasBody,
                                                                forwardedNoAliasBody)
    let noAliasContract = ir.BodyIRDodSoAContractCheck(forwardedNoAliasBody)

    let c28 = check(noAliasRewriteCount >= 2, 38)
    if c28 != 0: return c28
    let c29 = check(forwardedNoAliasBody.ops[1].operands[0] == a, 39)
    if c29 != 0: return c29
    let c30 = check(forwardedNoAliasBody.terms[0].resultSlot == a, 40)
    if c30 != 0: return c30
    let c31 = check(noalias.BodyIrNoAliasLocalCount(forwardedNoAliasBody) >= 2, 41)
    if c31 != 0: return c31
    let c32 = check(noAliasContract.ok, 42)
    if c32 != 0: return c32

    echo(" cfg_body_ir_contract_smoke ok")
    return 0
