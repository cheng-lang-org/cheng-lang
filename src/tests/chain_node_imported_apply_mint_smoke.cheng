import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus as consensus
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    let parentCid = node.ChainNodeAccountHead(server.index, 7, 1001)
    var event = consensus.ChainEventMint(
        7,
        1001,
        parentCid,
        int64(100),
        server.nextEpoch,
        server.nextGanzhi,
        node.ChainNodeSpaceSlot(1001, 1001),
        server.nextTick
    )
    let applyRes = node.ChainNodeApplyEvent(server, event)
    assert(applyRes.ok, "chain node imported apply mint: apply")
    assert(server.eventCids.len == 1, "chain node imported apply mint: cid len")
    assert(server.events.len == 1, "chain node imported apply mint: event len")
    assert(layout.FixedBytes32Equal(server.eventCids[0], applyRes.value),
           "chain node imported apply mint: first cid")
    assert(server.events[0].kind == consensus.ConsensusKindMint,
           "chain node imported apply mint: first event kind")
    echo(" chain_node_imported_apply_mint_smoke ok")
    return 0
