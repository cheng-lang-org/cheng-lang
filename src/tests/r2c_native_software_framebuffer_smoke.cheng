import std/os
import std/strings
import std/strutils as strutil
import cheng/r2c/native_gui_software_framebuffer as nativefb

fn main(): int32 =
    let outPath: str = "/tmp/r2c_native_software_framebuffer_smoke.png"
    let rgbaPath: str = "/tmp/r2c_native_software_framebuffer_smoke.rgba"
    let manifestPath: str = "/tmp/r2c_native_software_framebuffer_manifest_smoke.json"
    if os.FileExists(outPath):
        os.RemoveFile(outPath)
    if os.FileExists(rgbaPath):
        os.RemoveFile(rgbaPath)
    if os.FileExists(manifestPath):
        os.RemoveFile(manifestPath)
    var plan = "{"
    plan = strutil.Join([plan, "\"format\":\"native_render_plan_v1\","], "")
    plan = strutil.Join([plan, "\"window_width\":64,"], "")
    plan = strutil.Join([plan, "\"window_height\":48,"], "")
    plan = strutil.Join([plan, "\"commands\":["], "")
    plan = strutil.Join([plan, "{\"type\":\"background_gradient\",\"x\":0,\"y\":0,\"width\":64,\"height\":48,\"color_top\":\"#f2f7fd\",\"color_bottom\":\"#e6eefb\",\"z_index\":0},"], "")
    plan = strutil.Join([plan, "{\"type\":\"rounded_panel\",\"x\":6,\"y\":6,\"width\":52,\"height\":36,\"corner_radius\":8,\"background_color\":\"#ffffff\",\"shadow_color\":\"#cddaf0\",\"border_color\":\"#d5e2f0\",\"z_index\":1}"], "")
    plan = strutil.Join([plan, "],\"command_count\":2}"], "")
    assert(nativefb.WriteNativeRenderPlanPng(plan, outPath), "r2c native software framebuffer smoke: write png")
    assert(os.FileExists(outPath), "r2c native software framebuffer smoke: png exists")
    assert(os.FileSize(outPath) > int64(1000), "r2c native software framebuffer smoke: png size")
    let pngText = os.ReadFile(outPath)
    assert(strings.Len(pngText) > 33, "r2c native software framebuffer smoke: png readable")
    assert(pngText[0] == char(137), "r2c native software framebuffer smoke: png signature byte 0")
    assert(pngText[1] == char(80), "r2c native software framebuffer smoke: png signature byte 1")
    assert(pngText[2] == char(78), "r2c native software framebuffer smoke: png signature byte 2")
    assert(pngText[3] == char(71), "r2c native software framebuffer smoke: png signature byte 3")
    assert(pngText[12] == char(73), "r2c native software framebuffer smoke: ihdr byte 0")
    assert(pngText[13] == char(72), "r2c native software framebuffer smoke: ihdr byte 1")
    assert(pngText[14] == char(68), "r2c native software framebuffer smoke: ihdr byte 2")
    assert(pngText[15] == char(82), "r2c native software framebuffer smoke: ihdr byte 3")
    assert(nativefb.WriteNativeRenderPlanSurfaceArtifacts(plan, rgbaPath, manifestPath),
           "r2c native software framebuffer smoke: write surface artifacts")
    assert(os.FileExists(rgbaPath), "r2c native software framebuffer smoke: rgba exists")
    assert(os.FileSize(rgbaPath) == int64(64 * 48 * 4), "r2c native software framebuffer smoke: rgba size")
    assert(os.FileExists(manifestPath), "r2c native software framebuffer smoke: manifest exists")
    let manifestText = os.ReadFile(manifestPath)
    assert(strutil.Contains(manifestText, "\"format\": \"native_surface_frame_manifest_v1\""),
           "r2c native software framebuffer smoke: manifest format")
    assert(strutil.Contains(manifestText, "\"android_surface_binding\": \"ANativeWindow_rgba_blit_v1\""),
           "r2c native software framebuffer smoke: android binding")
    assert(strutil.Contains(manifestText, "\"ios_surface_binding\": \"CAMetalLayer_rgba_blit_v1\""),
           "r2c native software framebuffer smoke: ios binding")
    assert(strutil.Contains(manifestText, "\"ohos_surface_binding\": \"OHNativeWindow_rgba_blit_v1\""),
           "r2c native software framebuffer smoke: ohos binding")
    echo("r2c_native_software_framebuffer_smoke ok")
    return 0
