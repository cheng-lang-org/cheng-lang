import std/system
import std/crypto/p256_fixed as pfix

fn main(argc: int32, argv: ptr): int32 =
    argc
    argv
    var modulus: pfix.P256Fixed = pfix.P256FieldModulus()
    var zero: pfix.P256Fixed
    var one: pfix.P256Fixed = pfix.P256FixedOne()

    var rawOut: pfix.P256Fixed
    var rawBorrow: uint64 = uint64(0)
    pfix.P256FixedSubRawInto(rawOut, rawBorrow, modulus, one)
    var expect: pfix.P256Fixed = modulus
    expect.limbs[0] = int32(uint32(0xfffffffe))
    assert(rawOut.limbs[0] == expect.limbs[0], "p256_fixed_sub_probe: limb0")
    assert(rawOut.limbs[1] == expect.limbs[1], "p256_fixed_sub_probe: limb1")
    assert(rawOut.limbs[2] == expect.limbs[2], "p256_fixed_sub_probe: limb2")
    assert(rawOut.limbs[3] == expect.limbs[3], "p256_fixed_sub_probe: limb3")
    assert(rawOut.limbs[4] == expect.limbs[4], "p256_fixed_sub_probe: limb4")
    assert(rawOut.limbs[5] == expect.limbs[5], "p256_fixed_sub_probe: limb5")
    assert(rawOut.limbs[6] == expect.limbs[6], "p256_fixed_sub_probe: limb6")
    assert(rawOut.limbs[7] == expect.limbs[7], "p256_fixed_sub_probe: limb7")
    assert(rawBorrow == uint64(0), "p256_fixed_sub_probe: modulus minus one borrow")

    var modOut: pfix.P256Fixed
    pfix.P256FixedModSubTrustedInto(modOut, zero, one, modulus)
    assert(pfix.P256FixedCmp(modOut, modulus) < 0, "p256_fixed_sub_probe: modsub normalized")

    var checkOut: pfix.P256Fixed
    var checkBorrow: uint64 = uint64(0)
    pfix.P256FixedSubRawInto(checkOut, checkBorrow, modulus, modOut)
    assert(checkBorrow == uint64(0), "p256_fixed_sub_probe: modulus minus modOut borrow")

    echo("v3 p256_fixed_sub_probe ok")
    return 0
