import std/result
import std/strings as strings
import cheng/apps/wow_export/build_info as build_info
import cheng/apps/wow_export/tact_index as tact_index

const
    wowExportLooseIndexName = "303b4155efa35ae393a48c869f1d1899.index"
    wowExportEncodingEKey = "00f6dcef63eafe6254ab5408ea8baa09"
    wowExportVfsRootEKey = "2aece4e2ec64a8c89753c53f4d0207ca"

fn main(): int32 =
    let encodingLookupRes: Result[tact_index.TactIndexLookup] =
        tact_index.LoadTactIndexLookupFromClientIndices(build_info.DefaultClientPath, wowExportEncodingEKey)
    assert(IsOk(encodingLookupRes), Error(encodingLookupRes))
    let encodingLookup: tact_index.TactIndexLookup = Value(encodingLookupRes)
    assert(encodingLookup.indexName == wowExportLooseIndexName,
           "wow_export_tact_index_lookup_smoke encoding index name")
    assert(encodingLookup.entryIndex == 86,
           "wow_export_tact_index_lookup_smoke encoding entry index")
    assert(encodingLookup.entry.size == 183655454,
           "wow_export_tact_index_lookup_smoke encoding size")
    assert(encodingLookup.entry.offset == 0,
           "wow_export_tact_index_lookup_smoke encoding offset")
    assert(encodingLookup.block.blockIndex == 0,
           "wow_export_tact_index_lookup_smoke encoding block index")
    assert(encodingLookup.block.keyWord0 == 35225254,
           "wow_export_tact_index_lookup_smoke encoding block key0")
    assert(encodingLookup.block.keyWord1 == 806379788,
           "wow_export_tact_index_lookup_smoke encoding block key1")
    assert(encodingLookup.block.keyWord2 == 649032849,
           "wow_export_tact_index_lookup_smoke encoding block key2")
    assert(encodingLookup.block.keyWord3 == -470605326,
           "wow_export_tact_index_lookup_smoke encoding block key3")
    assert(encodingLookup.block.hashWord0 == 72326346,
           "wow_export_tact_index_lookup_smoke encoding block hash0")
    assert(encodingLookup.block.hashWord1 == 1586709962,
           "wow_export_tact_index_lookup_smoke encoding block hash1")
    assert(encodingLookup.footer.blockCount == 122,
           "wow_export_tact_index_lookup_smoke encoding block count")
    assert(encodingLookup.footer.tocStart == 499712,
           "wow_export_tact_index_lookup_smoke encoding toc start")

    let vfsRootLookupRes: Result[tact_index.TactIndexLookup] =
        tact_index.LoadTactIndexLookupFromClientIndices(build_info.DefaultClientPath, wowExportVfsRootEKey)
    assert(IsOk(vfsRootLookupRes), Error(vfsRootLookupRes))
    let vfsRootLookup: tact_index.TactIndexLookup = Value(vfsRootLookupRes)
    assert(vfsRootLookup.indexName == wowExportLooseIndexName,
           "wow_export_tact_index_lookup_smoke vfs-root index name")
    assert(vfsRootLookup.entryIndex == 4120,
           "wow_export_tact_index_lookup_smoke vfs-root entry index")
    assert(vfsRootLookup.entry.size == 34973,
           "wow_export_tact_index_lookup_smoke vfs-root size")
    assert(vfsRootLookup.entry.offset == 0,
           "wow_export_tact_index_lookup_smoke vfs-root offset")
    assert(vfsRootLookup.block.blockIndex == 20,
           "wow_export_tact_index_lookup_smoke vfs-root block index")
    assert(vfsRootLookup.block.keyWord0 == 1100362046,
           "wow_export_tact_index_lookup_smoke vfs-root block key0")
    assert(vfsRootLookup.block.keyWord1 == -1788095457,
           "wow_export_tact_index_lookup_smoke vfs-root block key1")
    assert(vfsRootLookup.block.keyWord2 == -1692129848,
           "wow_export_tact_index_lookup_smoke vfs-root block key2")
    assert(vfsRootLookup.block.keyWord3 == -512643261,
           "wow_export_tact_index_lookup_smoke vfs-root block key3")
    assert(vfsRootLookup.block.hashWord0 == 1139137491,
           "wow_export_tact_index_lookup_smoke vfs-root block hash0")
    assert(vfsRootLookup.block.hashWord1 == -300344855,
           "wow_export_tact_index_lookup_smoke vfs-root block hash1")

    let vfsChainRes: Result[tact_index.TactIndexFollowChain] =
        tact_index.LoadTactIndexFollowChainFromPath(vfsRootLookup.indexPath, wowExportVfsRootEKey, 8)
    assert(IsOk(vfsChainRes), Error(vfsChainRes))
    let vfsChain: tact_index.TactIndexFollowChain = Value(vfsChainRes)
    assert(vfsChain.stepCount == 3, "wow_export_tact_index_lookup_smoke vfs chain len")
    assert(vfsChain.steps[0].hit.block.keyWord0 == 1100362046,
           "wow_export_tact_index_lookup_smoke vfs chain block0 key0")
    assert(vfsChain.steps[0].hit.block.keyWord1 == -1788095457,
           "wow_export_tact_index_lookup_smoke vfs chain block0 key1")
    assert(vfsChain.steps[0].hit.block.keyWord2 == -1692129848,
           "wow_export_tact_index_lookup_smoke vfs chain block0 key2")
    assert(vfsChain.steps[0].hit.block.keyWord3 == -512643261,
           "wow_export_tact_index_lookup_smoke vfs chain block0 key3")
    assert(vfsChain.steps[1].hit.entry.size == 5219259,
           "wow_export_tact_index_lookup_smoke vfs chain size1")
    assert(vfsChain.steps[1].hit.block.keyWord0 == 1632719390,
           "wow_export_tact_index_lookup_smoke vfs chain block1 key0")
    assert(vfsChain.steps[1].hit.block.keyWord1 == 688049356,
           "wow_export_tact_index_lookup_smoke vfs chain block1 key1")
    assert(vfsChain.steps[1].hit.block.keyWord2 == 283624663,
           "wow_export_tact_index_lookup_smoke vfs chain block1 key2")
    assert(vfsChain.steps[1].hit.block.keyWord3 == 2142303383,
           "wow_export_tact_index_lookup_smoke vfs chain block1 key3")
    assert(vfsChain.steps[2].hit.entry.size == 5055097,
           "wow_export_tact_index_lookup_smoke vfs chain size2")
    assert(vfsChain.steps[2].hit.block.keyWord0 == -1948258463,
           "wow_export_tact_index_lookup_smoke vfs chain block2 key0")
    assert(vfsChain.steps[2].hit.block.keyWord1 == 1396221789,
           "wow_export_tact_index_lookup_smoke vfs chain block2 key1")
    assert(vfsChain.steps[2].hit.block.keyWord2 == -1852187302,
           "wow_export_tact_index_lookup_smoke vfs chain block2 key2")
    assert(vfsChain.steps[2].hit.block.keyWord3 == 1955675412,
           "wow_export_tact_index_lookup_smoke vfs chain block2 key3")
    assert(vfsChain.stopReason == "wowExport tact-index: key not found",
           "wow_export_tact_index_lookup_smoke vfs chain stop reason")

    let encodingChainRes: Result[tact_index.TactIndexFollowChain] =
        tact_index.LoadTactIndexFollowChainFromPath(encodingLookup.indexPath, wowExportEncodingEKey, 4)
    assert(IsOk(encodingChainRes), Error(encodingChainRes))
    let encodingChain: tact_index.TactIndexFollowChain = Value(encodingChainRes)
    assert(encodingChain.stepCount == 2,
           "wow_export_tact_index_lookup_smoke encoding chain len")
    assert(encodingChain.steps[1].hit.entry.size == 38005,
           "wow_export_tact_index_lookup_smoke encoding chain size1")
    assert(encodingChain.steps[1].hit.block.keyWord0 == 35225254,
           "wow_export_tact_index_lookup_smoke encoding chain block key0")
    assert(encodingChain.steps[1].hit.block.keyWord1 == 806379788,
           "wow_export_tact_index_lookup_smoke encoding chain block key1")
    assert(encodingChain.steps[1].hit.block.keyWord2 == 649032849,
           "wow_export_tact_index_lookup_smoke encoding chain block key2")
    assert(encodingChain.steps[1].hit.block.keyWord3 == -470605326,
           "wow_export_tact_index_lookup_smoke encoding chain block key3")
    assert(encodingChain.stopReason == "wowExport tact-index: block key cycle",
           "wow_export_tact_index_lookup_smoke encoding chain stop reason")

    echo("wow_export_tact_index_lookup_smoke ok")
    return 0
