import std/result
import cheng/apps/vpn_proxy/vpn_proxy_listen as listen

fn main(): int32 =
    let ipv4Res: Result[listen.VpnProxyListenAddress] = listen.VpnProxyParseListenAddress("127.0.0.1:1080")
    assert(!IsErr(ipv4Res), " vpn proxy listen ipv4 ok")
    assert(Value(ipv4Res).host == "127.0.0.1", " vpn proxy listen ipv4 host")
    assert(Value(ipv4Res).port == 1080, " vpn proxy listen ipv4 port")

    let zeroPortRes: Result[listen.VpnProxyListenAddress] = listen.VpnProxyParseListenAddress("127.0.0.1:0")
    assert(!IsErr(zeroPortRes), " vpn proxy listen zero port ok")
    assert(Value(zeroPortRes).port == 0, " vpn proxy listen zero port value")

    let ipv6Res: Result[listen.VpnProxyListenAddress] = listen.VpnProxyParseListenAddress("[::1]:7443")
    assert(!IsErr(ipv6Res), " vpn proxy listen ipv6 ok")
    assert(Value(ipv6Res).host == "::1", " vpn proxy listen ipv6 host")
    assert(Value(ipv6Res).port == 7443, " vpn proxy listen ipv6 port")

    let noColonRes: Result[listen.VpnProxyListenAddress] = listen.VpnProxyParseListenAddress("127.0.0.1")
    assert(IsErr(noColonRes), " vpn proxy listen no colon reject")
    assert(ErrorText(noColonRes) == "vpn proxy: listen address must be host:port",
           " vpn proxy listen no colon text")

    let badIpv6Res: Result[listen.VpnProxyListenAddress] = listen.VpnProxyParseListenAddress("[::1")
    assert(IsErr(badIpv6Res), " vpn proxy listen bad ipv6 reject")
    assert(ErrorText(badIpv6Res) == "vpn proxy: invalid ipv6 listen address",
           " vpn proxy listen bad ipv6 text")

    let badPortRes: Result[listen.VpnProxyListenAddress] = listen.VpnProxyParseListenAddress("127.0.0.1:99999")
    assert(IsErr(badPortRes), " vpn proxy listen bad port reject")
    assert(ErrorText(badPortRes) == "vpn proxy: listen address must be host:port",
           " vpn proxy listen bad port text")

    echo(" vpn_proxy_listen_smoke ok")
    return 0
