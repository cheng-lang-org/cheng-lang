# Extended WASM control flow test (runtime bridge-free)
# Tests: nested loops, nested if/else, recursion, break/continue, while, early returns

fn fibonacci(n: int32): int32 =
    if n <= 0: return 0
    if n == 1: return 1
    var a = 0
    var b = 1
    var i = 2
    while i <= n:
        let next = a + b
        a = b
        b = next
        i = i + 1
    return b

fn test_fibonacci(): int32 =
    if fibonacci(0) != 0: return 1
    if fibonacci(1) != 1: return 2
    if fibonacci(2) != 1: return 3
    if fibonacci(3) != 2: return 4
    if fibonacci(4) != 3: return 5
    if fibonacci(5) != 5: return 6
    if fibonacci(6) != 8: return 7
    if fibonacci(7) != 13: return 8
    if fibonacci(10) != 55: return 9
    return 0

fn factorial(n: int32): int32 =
    if n <= 0: return 1
    var result = 1
    var i = 1
    while i <= n:
        result = result * i
        i = i + 1
    return result

fn test_factorial(): int32 =
    if factorial(0) != 1: return 1
    if factorial(1) != 1: return 2
    if factorial(5) != 120: return 3
    if factorial(7) != 5040: return 4
    return 0

fn gcd(a: int32, b: int32): int32 =
    var x = a
    var y = b
    while y != 0:
        let tmp = y
        y = x % y
        x = tmp
    return x

fn test_gcd(): int32 =
    if gcd(12, 8) != 4: return 1
    if gcd(17, 5) != 1: return 2
    if gcd(100, 25) != 25: return 3
    if gcd(0, 5) != 5: return 4
    if gcd(7, 0) != 7: return 5
    return 0

fn collatz_steps(n: int32): int32 =
    var x = n
    var steps: int32
    while x > 1:
        if x % 2 == 0:
            x = x / 2
        else:
            x = 3 * x + 1
        steps = steps + 1
    return steps

fn test_collatz(): int32 =
    if collatz_steps(1) != 0: return 1
    if collatz_steps(2) != 1: return 2
    if collatz_steps(3) != 7: return 3
    if collatz_steps(4) != 2: return 4
    if collatz_steps(6) != 8: return 5
    return 0

fn nested_loop_sum(limit: int32): int32 =
    var total: int32
    var i: int32
    while i < limit:
        var j: int32
        while j < limit:
            total = total + (i * j)
            j = j + 1
        i = i + 1
    return total

fn test_nested_loop(): int32 =
    if nested_loop_sum(4) != 36: return 1
    if nested_loop_sum(0) != 0: return 2
    if nested_loop_sum(1) != 0: return 3
    return 0

fn multiple_early_returns(x: int32): int32 =
    if x < 0: return -1
    if x == 0: return 0
    if x > 100: return 100
    return x

fn test_early_returns(): int32 =
    if multiple_early_returns(-5) != -1: return 1
    if multiple_early_returns(0) != 0: return 2
    if multiple_early_returns(50) != 50: return 3
    if multiple_early_returns(200) != 100: return 4
    return 0

fn deep_nested_if_else(a: int32, b: int32, c: int32): int32 =
    if a > 0:
        if b > 0:
            if c > 0:
                return 1
            else:
                return 0
        else:
            if c > 0:
                return 2
            else:
                return -1
    else:
        if b > 0:
            if c > 0:
                return 3
            else:
                return -2
        else:
            if c > 0:
                return 4
            else:
                return -3

fn test_deep_nested_if(): int32 =
    if deep_nested_if_else(1, 1, 1) != 1: return 1
    if deep_nested_if_else(1, 1, 0) != 0: return 2
    if deep_nested_if_else(1, 0, 1) != 2: return 3
    if deep_nested_if_else(1, 0, 0) != -1: return 4
    if deep_nested_if_else(0, 1, 1) != 3: return 5
    if deep_nested_if_else(0, 1, 0) != -2: return 6
    if deep_nested_if_else(0, 0, 1) != 4: return 7
    if deep_nested_if_else(0, 0, 0) != -3: return 8
    return 0

fn is_prime(n: int32): bool =
    if n < 2: return false
    if n == 2: return true
    if n % 2 == 0: return false
    var i = 3
    while i * i <= n:
        if n % i == 0:
            return false
        i = i + 2
    return true

fn test_is_prime(): int32 =
    if is_prime(0) != false: return 1
    if is_prime(1) != false: return 2
    if is_prime(2) != true: return 3
    if is_prime(3) != true: return 4
    if is_prime(4) != false: return 5
    if is_prime(17) != true: return 6
    if is_prime(18) != false: return 7
    if is_prime(97) != true: return 8
    return 0

fn sum_to_n(n: int32): int32 =
    var total: int32
    var i: int32
    while i < n:
        i = i + 1
        total = total + i
    return total

fn test_sum_to_n(): int32 =
    if sum_to_n(1) != 1: return 1
    if sum_to_n(5) != 15: return 2
    if sum_to_n(10) != 55: return 3
    if sum_to_n(0) != 0: return 4
    return 0

fn main(): int32 =
    if test_fibonacci() != 0: return 1
    if test_factorial() != 0: return 2
    if test_gcd() != 0: return 3
    if test_collatz() != 0: return 4
    if test_nested_loop() != 0: return 5
    if test_early_returns() != 0: return 6
    if test_deep_nested_if() != 0: return 7
    if test_is_prime() != 0: return 8
    if test_sum_to_n() != 0: return 9
    return 0
