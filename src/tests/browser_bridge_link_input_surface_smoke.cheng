import std/os
import std/strutils as strutil
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/core/backend/system_link_exec as sexec

fn containsText(text: str, needle: str): bool =
    return strutil.Contains(text, needle)

fn browserBridgeSmokeDriver(root: str): str =
    let envDriver = strutil.Strip(os.GetEnv("CHENG_BROWSER_BRIDGE_DRIVER"))
    if len(envDriver) > 0:
        return chengpath.PathAbsolute(root, envDriver)
    let freshDriver = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3.bridge_object")
    if chengpath.FileExistsNonEmpty(root, freshDriver):
        return freshDriver
    let livefullDriver = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3.livefull")
    if chengpath.FileExistsNonEmpty(root, livefullDriver):
        return livefullDriver
    let stage3Driver = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3")
    if chengpath.FileExistsNonEmpty(root, stage3Driver):
        return stage3Driver
    return chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")

fn main(): int32 =
    let root = os.GetCurrentDir()
    let smokeLabel = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let driver = browserBridgeSmokeDriver(root)
    let packageRoot = root
    let source = chengpath.PathAbsolute(root, "src/tests/browser_host_native_min_smoke.cheng")
    let manualBridgeFixtureSource = chengpath.PathAbsolute(root,
                                                          "src/tests/browser_bridge_manual_link_input_fixture.cheng")
    let outDir = chengpath.PathAbsolute(root, "artifacts/browser_bridge_link_input_surface/" + smokeLabel)
    let outBin = chengpath.PathJoin(outDir, "browser_host_native_min_smoke")
    let reportPath = outBin + ".report.txt"
    let compileLog = outBin + ".compile.log"
    let bridgeArtifactPath = outBin + ".browser_bridge_plan.txt"
    let bridgeSourcePath = outBin + ".browser_bridge.generated.cheng"
    let bridgePlanObjectPath = outBin + ".browser_bridge.generated.o"
    let manualBridgeObjectPath = outBin + ".manual.browser_bridge.generated.o"
    let manualBridgeCompileLog = manualBridgeObjectPath + ".compile.log"
    let runLog = outBin + ".run.log"
    let req = creq.CompilerRequestNew(packageRoot,
                                        source,
                                        outBin,
                                        "arm64-apple-darwin",
                                        creq.EmitExe,
                                        reportPath)
    let planRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(root,
                                                                     req,
                                                                     "",
                                                                     "",
                                                                     "",
                                                                     "stable")
    assert(IsOk(planRes), " browser bridge link input: build plan")
    let plan = Value(planRes)
    let planReportText = sexec.SystemLinkExecPlanReport(plan)
    assert(chengpath.MkdirP(root, outDir), " browser bridge link input: mkdir")
    if chengpath.PathFileExists(outBin):
        os.RemoveFile(outBin)
    if chengpath.PathFileExists(reportPath):
        os.RemoveFile(reportPath)
    if chengpath.PathFileExists(bridgeArtifactPath):
        os.RemoveFile(bridgeArtifactPath)
    if chengpath.PathFileExists(bridgeSourcePath):
        os.RemoveFile(bridgeSourcePath)
    if chengpath.PathFileExists(bridgePlanObjectPath):
        os.RemoveFile(bridgePlanObjectPath)
    if chengpath.PathFileExists(manualBridgeObjectPath):
        os.RemoveFile(manualBridgeObjectPath)
    assert(containsText(planReportText, "browser_bridge_object_path=" + bridgePlanObjectPath),
           " browser bridge link input: plan object path")
    assert(containsText(planReportText, "browser_bridge_object_count=1"),
           " browser bridge link input: plan object count")
    assert(containsText(planReportText, "browser_bridge_plan_count=4"),
           " browser bridge link input: plan bridge count")
    assert(sexec.SystemLinkExecWriteBrowserBridgeArtifact(root, plan),
           " browser bridge link input: write artifact")
    assert(sexec.SystemLinkExecWriteBrowserBridgeSource(root, plan),
           " browser bridge link input: write source")
    assert(chengpath.FileExistsNonEmpty(root, bridgeArtifactPath),
           " browser bridge link input: plan exists")
    assert(chengpath.FileExistsNonEmpty(root, bridgeSourcePath),
           " browser bridge link input: source exists")
    let bridgeArtifactText = chengpath.ReadTextFile("", bridgeArtifactPath)
    assert(containsText(bridgeArtifactText, "bridge_count=4"),
           " browser bridge link input: artifact bridge count")
    let bridgeCompileRun = hostops.RunFileLogged(root,
                                                   "browser_bridge_link_input_surface_bridge_object",
                                                   driver,
                                                   [
                                                       "system-link-exec",
                                                       "--root:" + packageRoot,
                                                       "--in:" + manualBridgeFixtureSource,
                                                       "--emit:obj",
                                                       "--target:arm64-apple-darwin",
                                                       "--symbol-visibility:" + creq.CompilerSymbolVisibilityInternal(),
                                                       "--out:" + manualBridgeObjectPath
                                                   ],
                                                   ["CHENG_NO_BACKEND_DRIVER_HANDOFF=1"],
                                                   root,
                                                   0,
                                                   manualBridgeCompileLog)
    assert(hostops.LoggedRunOk(bridgeCompileRun), " browser bridge link input: bridge object rc")
    assert(chengpath.FileExistsNonEmpty(root, manualBridgeObjectPath),
           " browser bridge link input: manual object exists")
    let compileRun = hostops.RunFileLogged(root,
                                             "browser_bridge_link_input_surface_build",
                                             driver,
                                             [
                                                 "system-link-exec",
                                                 "--root:" + packageRoot,
                                                 "--in:" + source,
                                                 "--emit:exe",
                                                 "--target:arm64-apple-darwin",
                                                 "--out:" + outBin,
                                                 "--report-out:" + reportPath,
                                                 "--link-input:" + manualBridgeObjectPath
                                             ],
                                             ["CHENG_NO_BACKEND_DRIVER_HANDOFF=1"],
                                             root,
                                             0,
                                             compileLog)
    assert(hostops.LoggedRunOk(compileRun), " browser bridge link input: compile rc")
    assert(chengpath.FileExistsNonEmpty(root, outBin), " browser bridge link input: output exists")
    assert(chengpath.FileExistsNonEmpty(root, reportPath), " browser bridge link input: report exists")
    let reportText = chengpath.ReadTextFile("", reportPath)
    assert(containsText(reportText, "extra_link_input=" + manualBridgeObjectPath),
           " browser bridge link input: extra link input")
    assert(containsText(reportText, "browser_bridge_object=" + bridgePlanObjectPath),
           " browser bridge link input: compiler-owned object field")
    assert(containsText(reportText, "object_link_inputs="), " browser bridge link input: object inputs")
    assert(containsText(reportText, manualBridgeObjectPath), " browser bridge link input: object listed")
    assert(containsText(reportText, bridgePlanObjectPath), " browser bridge link input: internal object listed")
    assert(containsText(reportText, "native_link_inputs="), " browser bridge link input: native inputs")
    let run = hostops.RunFileLogged(root,
                                      "browser_bridge_link_input_surface_run",
                                      outBin,
                                      [],
                                      [],
                                      root,
                                      0,
                                      runLog)
    assert(hostops.LoggedRunOk(run), " browser bridge link input: run rc")
    assert(containsText(run.output, " browser host wasm smoke: ok"),
           " browser bridge link input: runtime output")
    echo(" browser_bridge_link_input_surface_smoke ok")
    return 0
