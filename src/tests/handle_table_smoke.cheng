import cheng/core/runtime/handle_table as htable

fn main(): int32 =
    let h0: uint64 = htable.handle_table_new_i32(40)
    if h0 == 0:
        echo("handle_table_smoke: FAIL - new returned 0")
        return 1
    var out: int32
    if htable.handle_table_get_i32(h0, out) != 0:
        echo("handle_table_smoke: FAIL - get returned error")
        return 2
    if out != 40:
        echo("handle_table_smoke: FAIL - get returned wrong value")
        return 3
    if htable.handle_table_add_i32(h0, 2, out) != 0:
        echo("handle_table_smoke: FAIL - add returned error")
        return 4
    if out != 42:
        echo("handle_table_smoke: FAIL - add returned wrong value")
        return 5
    if htable.handle_table_get_i32(h0, out) != 0:
        echo("handle_table_smoke: FAIL - get after add returned error")
        return 6
    if out != 42:
        echo("handle_table_smoke: FAIL - get after add returned wrong value")
        return 7
    if htable.handle_table_release_i32(h0) != 0:
        echo("handle_table_smoke: FAIL - release returned error")
        return 8
    if htable.handle_table_get_i32(h0, out) == 0:
        echo("handle_table_smoke: FAIL - get after release should fail")
        return 9
    let h1: uint64 = htable.handle_table_new_i32(7)
    if h1 == 0:
        echo("handle_table_smoke: FAIL - second new returned 0")
        return 10
    if h1 == h0:
        echo("handle_table_smoke: FAIL - reused handle same as released")
        return 11
    if htable.handle_table_get_i32(h1, out) != 0:
        echo("handle_table_smoke: FAIL - get on second handle error")
        return 12
    if out != 7:
        echo("handle_table_smoke: FAIL - get on second handle wrong value")
        return 13
    if htable.handle_table_release_i32(h1) != 0:
        echo("handle_table_smoke: FAIL - release second handle error")
        return 14
    echo(" handle_table_smoke ok")
    return 0
