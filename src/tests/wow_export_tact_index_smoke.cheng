import std/result
import std/strings as strings
import cheng/apps/wow_export/build_info as build_info
import cheng/apps/wow_export/tact_index as tact_index

fn main(): int32 =
    let indexPath: str =
        build_info.StableConcat(build_info.DefaultClientPath,
                                "/Data/indices/bd643d2dac9bfdc365890dafbbea83d6.index")
    let summaryRes: Result[tact_index.TactIndexSummary] =
        tact_index.LoadTactIndexSummaryFromPath(indexPath)
    assert(IsOk(summaryRes), Error(summaryRes))
    let summary: tact_index.TactIndexSummary = Value(summaryRes)
    assert(summary.footer.formatRevision == 1, "wow_export_tact_index_smoke format revision")
    assert(summary.footer.blockSizeKB == 4, "wow_export_tact_index_smoke block size")
    assert(summary.footer.offsetBytes == 4, "wow_export_tact_index_smoke offset bytes")
    assert(summary.footer.sizeBytes == 4, "wow_export_tact_index_smoke size bytes")
    assert(summary.footer.keyBytes == 16, "wow_export_tact_index_smoke key bytes")
    assert(summary.footer.hashBytes == 8, "wow_export_tact_index_smoke hash bytes")
    assert(summary.footer.entryCount > 0, "wow_export_tact_index_smoke entry count")
    assert(strings.Len(summary.first.archiveKey) == 0, "wow_export_tact_index_smoke archive key omitted")
    assert(summary.first.keyWord0 == 16814, "wow_export_tact_index_smoke key word0")
    assert(summary.first.keyWord1 == -1014276727, "wow_export_tact_index_smoke key word1")
    assert(summary.first.keyWord2 == -87747191, "wow_export_tact_index_smoke key word2")
    assert(summary.first.keyWord3 == 1208825288, "wow_export_tact_index_smoke key word3")
    assert(summary.first.size == 269512, "wow_export_tact_index_smoke first size")
    assert(summary.first.offset == 241735217, "wow_export_tact_index_smoke first offset")
    assert(summary.first.archiveIndex == -1, "wow_export_tact_index_smoke first archive index")

    let lookupRes: Result[tact_index.TactIndexEntry] =
        tact_index.LoadTactIndexEntryAtPathIndex(indexPath, 0)
    assert(IsOk(lookupRes), Error(lookupRes))
    let entry: tact_index.TactIndexEntry = Value(lookupRes)
    assert(strings.Len(entry.archiveKey) == 0, "wow_export_tact_index_smoke archive key roundtrip")
    assert(entry.keyWord0 == summary.first.keyWord0, "wow_export_tact_index_smoke key word0 roundtrip")
    assert(entry.keyWord1 == summary.first.keyWord1, "wow_export_tact_index_smoke key word1 roundtrip")
    assert(entry.keyWord2 == summary.first.keyWord2, "wow_export_tact_index_smoke key word2 roundtrip")
    assert(entry.keyWord3 == summary.first.keyWord3, "wow_export_tact_index_smoke key word3 roundtrip")
    assert(entry.size == summary.first.size, "wow_export_tact_index_smoke size roundtrip")
    assert(entry.offset == summary.first.offset, "wow_export_tact_index_smoke offset roundtrip")
    assert(entry.archiveIndex == summary.first.archiveIndex, "wow_export_tact_index_smoke archive index roundtrip")
    echo("wow_export_tact_index_smoke ok")
    return 0
