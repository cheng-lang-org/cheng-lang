import std/system

type
    SeqPair =
        left: int32[]
        right: int32[]

fn main(): int32 =
    var pair: SeqPair
    pair.left = []
    pair.right = []
    add(pair.right, 7)
    add(pair.left, pair.right[0])
    assert(pair.left.len == 1, " seq_add_member_index_rhs_smoke: left len")
    assert(pair.left[0] == 7, " seq_add_member_index_rhs_smoke: left value")
    echo(" seq_add_member_index_rhs_smoke ok")
    return 0
