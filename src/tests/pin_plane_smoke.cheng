import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content
import cheng/chain/pin_plane as pin

fn pinPlaneSmokeBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn pinPlaneSmokeBuildResponses(out: var swarm.ErasureShardPullResponse[],
                               challenge: pin.PinChallenge,
                               manifest: swarm.ErasureShardManifest,
                               shardPayloads: Bytes[]) =
    out = []
    var i = challenge.shardCount - 1
    while i >= 0:
        let requestRes = swarm.ErasureShardPullRequestMake(manifest, challenge.shardIndices[i])
        assert(IsOk(requestRes), " pin plane smoke: request")
        let pos = pin.PinManifestShardPos(manifest, challenge.shardIndices[i])
        assert(pos >= 0, " pin plane smoke: manifest shard pos")
        var response = swarm.ErasureShardPullResponse()
        let responseFillRes = swarm.ErasureShardPullResponseFill(response,
                                                                   Value(requestRes),
                                                                   shardPayloads[pos])
        assert(IsOk(responseFillRes), " pin plane smoke: response")
        add(out, response)
        i = i - 1

fn pinPlaneSmokeAssertOfferFromArtifacts(bundleCid: layout.FixedBytes32,
                                         summary: dag.DagBlobSummary,
                                         params: swarm.ErasureEncodingParams,
                                         manifest: swarm.ErasureShardManifest,
                                         expected: pin.PinOffer) =
    var artifacts = content.ContentPublishArtifacts()
    artifacts.blobSummary = summary
    artifacts.erasureParams = params
    artifacts.erasureManifest = manifest
    artifacts.bundleCid = bundleCid
    let offerFromArtifactsRes = pin.PinOfferFromArtifacts(artifacts, 120, 3, 77, 33)
    assert(IsOk(offerFromArtifactsRes), " pin plane smoke: artifacts offer")
    let offerFromArtifacts = Value(offerFromArtifactsRes)
    assert(layout.fixedBytes32Equal(offerFromArtifacts.offerCid, expected.offerCid),
        " pin plane smoke: artifacts offer cid")
    assert(pinPlaneSmokeBytesEqual(pin.PinOfferEncode(offerFromArtifacts),
                                   pin.PinOfferEncode(expected)),
        " pin plane smoke: artifacts offer payload")

fn main(): int32 =
    let blob = bytesFromString(" pin plane smoke blob")
    let bundleCid = lt.HashInts("cheng.pin.bundle", [11, 22, 33])
    let paramsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic, 3, 2, 8)
    assert(IsOk(paramsRes), " pin plane smoke: params")
    let params = Value(paramsRes)
    let encodedRes = swarm.ErasureEncodeShardPayloads(blob, params)
    assert(IsOk(encodedRes), " pin plane smoke: encode")
    let shardPayloads = Value(encodedRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    for i in 0..<shardPayloads.len:
        add(shardPayloadCids, swarm.ErasureShardPayloadCid(shardPayloads[i]))

    let summaryRes = dag.DagBlobSummaryFromBytes(blob, 8)
    assert(IsOk(summaryRes), " pin plane smoke: summary")
    let summary = Value(summaryRes)
    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), " pin plane smoke: manifest")
    let manifest = Value(manifestRes)

    let offerRes = pin.PinOfferMake(bundleCid,
                                      summary.summaryCid,
                                      summary.blobCid,
                                      manifest.manifestCid,
                                      120,
                                      3,
                                      77,
                                      33)
    assert(IsOk(offerRes), " pin plane smoke: offer")
    let offer = Value(offerRes)
    let offerOk = pin.PinOfferValidateAgainstManifest(offer, manifest)
    assert(IsOk(offerOk), " pin plane smoke: offer validate")
    pinPlaneSmokeAssertOfferFromArtifacts(bundleCid, summary, params, manifest, offer)
    let offerPayload = pin.PinOfferEncode(offer)
    let offerPayloadOk = pin.PinOfferValidatePayload(offerPayload, offer.offerCid)
    assert(IsOk(offerPayloadOk), " pin plane smoke: offer payload")
    let offerDecodeRes = pin.PinOfferDecode(offerPayload)
    assert(IsOk(offerDecodeRes), " pin plane smoke: offer decode")
    assert(layout.fixedBytes32Equal(Value(offerDecodeRes).offerCid, offer.offerCid),
        " pin plane smoke: offer cid roundtrip")

    let providerPeerId = lt.HashInts("cheng.pin.provider", [2])
    let acceptRes = pin.PinAcceptMake(offer, providerPeerId, 160)
    assert(IsOk(acceptRes), " pin plane smoke: accept")
    let accept = Value(acceptRes)
    let acceptOk = pin.PinAcceptValidateAgainstOffer(accept, offer)
    assert(IsOk(acceptOk), " pin plane smoke: accept validate")
    let acceptPayload = pin.PinAcceptEncode(accept)
    let acceptPayloadOk = pin.PinAcceptValidatePayload(acceptPayload, accept.acceptCid)
    assert(IsOk(acceptPayloadOk), " pin plane smoke: accept payload")

    let challengeRes = pin.PinBuildChallenge(offer, accept, manifest, 100)
    assert(IsOk(challengeRes), " pin plane smoke: challenge")
    let challenge = Value(challengeRes)
    let challengeOk = pin.PinChallengeValidateAgainstInputs(challenge,
                                                              offer,
                                                              accept,
                                                              manifest)
    assert(IsOk(challengeOk), " pin plane smoke: challenge validate")
    let challengePayload = pin.PinChallengeEncode(challenge)
    let challengePayloadOk = pin.PinChallengeValidatePayload(challengePayload, challenge.challengeCid)
    assert(IsOk(challengePayloadOk), " pin plane smoke: challenge payload")

    var responses: swarm.ErasureShardPullResponse[]
    pinPlaneSmokeBuildResponses(responses, challenge, manifest, shardPayloads)
    let proofRes = pin.PinProofFromResponses(challenge, manifest, responses)
    assert(IsOk(proofRes), " pin plane smoke: proof")
    let proof = Value(proofRes)
    let proofOk = pin.PinProofValidateAgainstInputs(proof,
                                                      challenge,
                                                      accept,
                                                      manifest)
    assert(IsOk(proofOk), " pin plane smoke: proof validate")
    let proofPayload = pin.PinProofEncode(proof)
    let proofPayloadOk = pin.PinProofValidatePayload(proofPayload, proof.proofCid)
    assert(IsOk(proofPayloadOk), " pin plane smoke: proof payload")

    let settlementRes = pin.PinBuildSettlement(offer,
                                                 accept,
                                                 challenge,
                                                 manifest,
                                                 proof,
                                                 101)
    assert(IsOk(settlementRes), " pin plane smoke: reward settlement")
    let settlement = Value(settlementRes)
    assert(settlement.status == pin.PinSettlementStatusReward,
        " pin plane smoke: reward settlement status")
    assert(settlement.rewardUnits == offer.rewardUnits,
        " pin plane smoke: reward settlement amount")
    let settlementPayload = pin.PinSettlementEncode(settlement)
    let settlementPayloadOk = pin.PinSettlementValidatePayload(settlementPayload, settlement.settlementCid)
    assert(IsOk(settlementPayloadOk), " pin plane smoke: settlement payload")

    var badProof = proof
    let junk = bytesFromString("xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx")
    badProof.payloadConcat = bytesSlice(junk, 0, proof.payloadConcatLen)
    badProof.payloadConcatLen = bytesLen(badProof.payloadConcat)
    badProof.proofCid = pin.PinProofCid(badProof.challengeCid,
                                          badProof.acceptCid,
                                          badProof.manifestCid,
                                          badProof.shardIndices,
                                          badProof.shardPayloadLens,
                                          badProof.payloadConcat)
    let badProofGenericOk = pin.PinProofValidate(badProof)
    assert(IsOk(badProofGenericOk), " pin plane smoke: bad proof generic validate")
    let badProofOk = pin.PinProofValidateAgainstInputs(badProof,
                                                         challenge,
                                                         accept,
                                                         manifest)
    assert(IsErr(badProofOk), " pin plane smoke: bad proof reject")
    let slashSettlementRes = pin.PinBuildSettlement(offer,
                                                      accept,
                                                      challenge,
                                                      manifest,
                                                      badProof,
                                                      102)
    assert(IsOk(slashSettlementRes), " pin plane smoke: slash settlement")
    let slashSettlement = Value(slashSettlementRes)
    assert(slashSettlement.status == pin.PinSettlementStatusSlash,
        " pin plane smoke: slash settlement status")
    assert(slashSettlement.slashUnits == accept.slashUnits,
        " pin plane smoke: slash settlement amount")
    let slashSettlementOk = pin.PinSettlementValidateAgainstInputs(slashSettlement,
                                                                     offer,
                                                                     accept,
                                                                     challenge,
                                                                     manifest,
                                                                     badProof)
    assert(IsOk(slashSettlementOk), " pin plane smoke: slash settlement validate")
    assert(pinPlaneSmokeBytesEqual(offerPayload, pin.PinOfferEncode(Value(offerDecodeRes))),
        " pin plane smoke: offer payload roundtrip")

    echo(" pin_plane_smoke ok")
    return 0
