import std/system
import cheng/core/tooling/bootstrap_contracts as contracts
import cheng/core/backend/build_plan as buildplan

fn main(): int32 =
    let snapshot: contracts.BootstrapSnapshot = contracts.BootstrapSnapshotDefault("/tmp/cheng-lang")
    let expectedTarget = contracts.BootstrapDefaultTarget()
    assert(snapshot.targetTriple == expectedTarget, " bootstrap: target")
    assert(snapshot.bootstrapMode == "selfhost", " bootstrap: mode")
    assert(snapshot.stage1Source.path == "/tmp/cheng-lang/bootstrap/stage1_bootstrap.cheng",
           " bootstrap: stage1 source path")
    assert(contracts.BootstrapCompilerEntrySourcePath("/tmp/cheng-lang") == "/tmp/cheng-lang/src/core/tooling/compiler_main.cheng",
           " bootstrap: compiler entry source path")
    assert(contracts.BootstrapGateMainSourcePath("/tmp/cheng-lang") == "/tmp/cheng-lang/src/core/tooling/gate_main.cheng",
           " bootstrap: gate main source path")
    assert(snapshot.stage0Compiler.path == "/tmp/cheng-lang/artifacts/bootstrap/cheng.stage0",
           " bootstrap: stage0 path")
    assert(snapshot.stage2Compiler.path == "/tmp/cheng-lang/artifacts/bootstrap/cheng.stage2",
           " bootstrap: stage2 path")
    let plan: buildplan.BackendBuildPlan = buildplan.BackendBuildPlanDefault("/tmp/cheng-lang")
    assert(plan.sourceUnits.len >= 6, " build plan: source list")
    assert(plan.entryPath == "/tmp/cheng-lang/src/core/tooling/compiler_main.cheng", " build plan: entry")
    assert(plan.stage2CompilerPath == "/tmp/cheng-lang/artifacts/bootstrap/cheng.stage2",
           " build plan: stage2 compiler")
    assert(plan.targetTriple == expectedTarget, " build plan: target")
    assert(plan.outputPath == "/tmp/cheng-lang/artifacts/backend_driver/cheng", " build plan: output")
    echo(" bootstrap_contracts_smoke ok")
    return 0
