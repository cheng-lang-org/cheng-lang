import cheng/libp2p/browser/browser_host_probe_codegen as codegen
import cheng/libp2p/browser/browser_host_probe_rule_schema as browserprobe

fn main(): int32 =
    let sourcePath = browserprobe.BrowserHostProbeModulePath()
    let dmWaitRule = browserprobe.BrowserHostProbeRuleDmWaitStartName()
    let dmSendRule = browserprobe.BrowserHostProbeRuleDmSendStartName()
    let dmWaitPlan = codegen.BrowserHostProbeBridgePlanForRuleName(dmWaitRule)
    assert(codegen.BrowserHostProbeInputSchemaKindFromBridgePlan(dmWaitPlan) == codegen.BrowserHostProbeInputScalarI32_2,
           " browser_host_probe_codegen: dm wait input kind")
    assert(codegen.BrowserHostProbeOutputSchemaKindFromBridgePlan(dmWaitPlan) == codegen.BrowserHostProbeOutputScalarI32,
           " browser_host_probe_codegen: dm wait output kind")
    assert(codegen.BrowserHostProbeBridgeKeyForRuleName(dmWaitRule) ==
           "stage=scalar_call|input_schema=scalar_i32_2|output_schema=scalar_i32|error_schema=inline_none|result=scalar_i32|out_buffer=none",
           " browser_host_probe_codegen: dm wait bridge key")
    assert(codegen.BrowserHostProbeBridgeHelperNameForRuleName(dmSendRule) ==
           "cheng_browser_bridge_scalar_call_dm_send_start",
           " browser_host_probe_codegen: dm send helper name")
    assert(codegen.BrowserHostProbeBridgeEmitLineForSourceRuleName(sourcePath, dmSendRule) ==
           "source=cheng/libp2p/browser/browser_host_wasm_probe|rule=dm_send_start|stage=scalar_call|helper=cheng_browser_bridge_scalar_call_dm_send_start|input_schema=scalar_i32_4|output_schema=scalar_i32|error_schema=inline_none|result=scalar_i32|out_buffer=none",
           " browser_host_probe_codegen: dm send emit line")
    echo(" browser_host_probe_codegen_smoke ok")
    return 0
