import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node: init")
    assert(server.eventCids.len == 0, "v3 chain node inline mint heads: init cid len")
    assert(server.events.len == 0, "v3 chain node inline mint heads: init event len")

    let parentCid = node.v3ChainNodeAccountHead(server.index, 7, 1001)
    var event = consensus.v3ChainEventMint(
        7,
        1001,
        parentCid,
        int64(100),
        server.nextEpoch,
        server.nextGanzhi,
        node.v3ChainNodeSpaceSlot(1001, 1001),
        server.nextTick
    )
    let eventCid = consensus.v3ChainEventCid(event)
    var nextIndex = server.index
    var decision = consensus.V3ConsensusDecision()
    consensus.v3ConsensusApplyChecked(nextIndex, event, eventCid, server.eventCids.len, decision)
    server.index = nextIndex
    assert(decision.accepted, "v3 chain node inline mint heads: accepted")
    assert(decision.applied, "v3 chain node inline mint heads: applied")
    add(server.eventCids, eventCid)
    add(server.events, event)
    assert(server.eventCids.len == 1, "v3 chain node inline mint heads: cid len")
    assert(server.events.len == 1, "v3 chain node inline mint heads: event len")
    assert(layout.fixedBytes32Equal(server.eventCids[0], eventCid),
           "v3 chain node inline mint heads: cid item")
    assert(server.events[0].kind == consensus.v3ConsensusKindMint,
           "v3 chain node inline mint heads: event item")
    echo("v3 chain_node_inline_mint_event_heads_smoke ok")
    return 0
