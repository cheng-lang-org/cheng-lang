import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    assert(server.eventCids.len == 0, " chain node inline mint heads: init cid len")
    assert(server.events.len == 0, " chain node inline mint heads: init event len")

    let parentCid = node.ChainNodeAccountHead(server.index, 7, 1001)
    var event = consensus.ChainEventMint(
        7,
        1001,
        parentCid,
        int64(100),
        server.nextEpoch,
        server.nextGanzhi,
        node.ChainNodeSpaceSlot(1001, 1001),
        server.nextTick
    )
    let eventCid = consensus.ChainEventCid(event)
    var nextIndex = server.index
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(nextIndex, event, eventCid, server.eventCids.len, decision)
    server.index = nextIndex
    assert(decision.accepted, " chain node inline mint heads: accepted")
    assert(decision.applied, " chain node inline mint heads: applied")
    add(server.eventCids, eventCid)
    add(server.events, event)
    assert(server.eventCids.len == 1, " chain node inline mint heads: cid len")
    assert(server.events.len == 1, " chain node inline mint heads: event len")
    assert(layout.FixedBytes32Equal(server.eventCids[0], eventCid),
           " chain node inline mint heads: cid item")
    assert(server.events[0].kind == consensus.ConsensusKindMint,
           " chain node inline mint heads: event item")
    echo(" chain_node_inline_mint_event_heads_smoke ok")
    return 0
