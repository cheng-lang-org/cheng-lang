import cheng/apps/vpn_proxy/vpn_proxy_config as config
import cheng/apps/vpn_proxy/vpn_proxy_routing as routing

fn exitCfg(name: str, host: str, port: int32, serverName: str): config.VpnProxyExitConfig =
    var out: config.VpnProxyExitConfig
    out.name = name
    out.host = host
    out.port = port
    out.serverName = serverName
    return out

fn main(): int32 =
    var states: routing.VpnProxyExitState[]
    states = routing.VpnProxyInitExitStates([
        exitCfg("64", "64.176.84.12", 7443, "edge-64.internal"),
        exitCfg("dmit", "154.26.191.226", 7443, "edge-dmit.internal")
    ])
    assert(states.len == 2, " vpn proxy routing init len")
    assert(states[0].healthy, " vpn proxy routing init healthy")
    assert(states[0].ewmaMs == 0, " vpn proxy routing init ewma")

    routing.VpnProxyMarkSuccess(states[0], 1000, 100)
    assert(states[0].healthy, " vpn proxy routing first success healthy")
    assert(states[0].ewmaMs == 100, " vpn proxy routing first success ewma")

    routing.VpnProxyMarkSuccess(states[0], 2000, 50)
    assert(states[0].ewmaMs == 90, " vpn proxy routing ewma update")

    routing.VpnProxyMarkProbeFailure(states[0], 3000, "timeout-1")
    routing.VpnProxyMarkProbeFailure(states[0], 4000, "timeout-2")
    assert(states[0].healthy, " vpn proxy routing two probe failures still healthy")
    routing.VpnProxyMarkProbeFailure(states[0], 5000, "timeout-3")
    assert(!states[0].healthy, " vpn proxy routing three probe failures unhealthy")

    routing.VpnProxyMarkSuccess(states[0], 6000, 70)
    assert(!states[0].healthy, " vpn proxy routing one recovery success not enough")
    routing.VpnProxyMarkSuccess(states[0], 7000, 60)
    assert(states[0].healthy, " vpn proxy routing two recovery successes healthy")

    routing.VpnProxyRecordOpenFailure(states[1], 10000, "dial-1")
    assert(states[1].healthy, " vpn proxy routing one open failure still healthy")
    routing.VpnProxyRecordOpenFailure(states[1], 20000, "dial-2")
    assert(!states[1].healthy, " vpn proxy routing two recent open failures unhealthy")

    routing.VpnProxyMarkSuccess(states[1], 21000, 40)
    routing.VpnProxyMarkSuccess(states[1], 22000, 30)
    assert(states[1].healthy, " vpn proxy routing recover after open failure")
    assert(states[1].ewmaMs == 38, " vpn proxy routing second ewma")

    assert(routing.VpnProxyBestHealthyExit(states, -1) == 1, " vpn proxy routing pick lower ewma")
    assert(routing.VpnProxyBestHealthyExit(states, 1) == 0, " vpn proxy routing exclude first choice")

    echo(" vpn_proxy_routing_smoke ok")
    return 0
