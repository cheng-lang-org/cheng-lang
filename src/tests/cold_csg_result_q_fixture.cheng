type IntResult = Ok(value: int32) | Err(code: int32)

fn Need(flag: int32): IntResult =
    if flag == 1:
        return Ok(40)
    return Err(7)

fn Use(flag: int32): IntResult =
    let value = Need(flag)?
    return Ok(value + 2)

fn main(): int32 =
    let good = Use(1)
    match good:
        Ok(value) =>
            let bad = Use(0)
            match bad:
                Ok(other) =>
                    return other
                Err(code) =>
                    return value + code
        Err(code) =>
            return code
