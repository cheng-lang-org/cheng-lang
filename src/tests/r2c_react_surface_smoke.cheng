import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_smoke_support as smoke

fn main(): int32 =
    let ctx = smoke.R2cReactSmokeSetup("artifacts/r2c_surface_smoke",
                                         "r2c_surface_controller_compile",
                                         " r2c surface smoke")
    let codegen = smoke.R2cReactSmokeRunCodegen(ctx,
                                                 "r2c_codegen_surface_smoke",
                                                 " r2c surface smoke")
    let bundle = smoke.R2cReactSmokeRunBundle(ctx,
                                               codegen,
                                               "home_default",
                                               "native_gui_bundle_home_default",
                                               "r2c_native_gui_bundle.log",
                                               "r2c_native_gui_bundle_smoke",
                                               " r2c surface smoke")
    let runSummaryText = smoke.R2cReactSmokeRunNativeGui(ctx,
                                                          bundle,
                                                          "home_default",
                                                          "native_gui_run_home_default",
                                                          " r2c surface smoke")
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_bundle_ready=true"),
           " r2c surface smoke: runtime bundle ready")
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_contract_ready=true"),
           " r2c surface smoke: runtime contract ready")
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_bundle_route_state=home_default"),
           " r2c surface smoke: runtime bundle route state")
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_contract_layout_item_count="),
           " r2c surface smoke: runtime contract layout count")
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_bundle_render_command_count="),
           " r2c surface smoke: runtime bundle render count")

    let contentBundle = smoke.R2cReactSmokeRunBundle(ctx,
                                                      codegen,
                                                      "content_detail",
                                                      "native_gui_bundle_content_detail",
                                                      "r2c_native_gui_bundle_content_detail.log",
                                                      "r2c_native_gui_bundle_content_detail",
                                                      " r2c surface smoke: content")
    let contentBundleSummaryText = chengpath.ReadTextFile("", contentBundle.summaryPath)
    assert(chengpath.TextContains(contentBundleSummaryText, "native_gui_route_state=content_detail"),
           " r2c surface smoke: content route state")
    assert(chengpath.TextContains(contentBundleSummaryText, "native_gui_runtime_bundle_ready=true"),
           " r2c surface smoke: content runtime bundle ready")

    echo(" r2c_react_surface_smoke ok")
    return 0
