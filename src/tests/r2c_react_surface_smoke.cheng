import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_surface_main as r2csurface

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = chengpath.PathAbsolute(root, "artifacts/r2c_surface_smoke")
    assert(chengpath.MkdirP(root, outDir), " r2c surface smoke: mkdir")
    let driver = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    let stage3 = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3")
    let bundleScript = chengpath.PathAbsolute(root, "tools/r2c/experimental/r2c-react-native-gui-bundle.mjs")
    let runScript = chengpath.PathAbsolute(root, "tools/r2c/experimental/r2c-react-native-gui-run.mjs")
    assert(chengpath.FileExistsNonEmpty(root, driver), " r2c surface smoke: backend_driver exists")
    assert(chengpath.FileExistsNonEmpty(root, stage3), " r2c surface smoke: stage3 exists")
    assert(chengpath.FileExistsNonEmpty(root, bundleScript), " r2c surface smoke: bundle script exists")
    assert(chengpath.FileExistsNonEmpty(root, runScript), " r2c surface smoke: run script exists")
    let readyEnv = ["CHENG_BACKEND_DRIVER_READY=1"]
    var nativeEnv: str[]
    add(nativeEnv, "R2C_REACT_TOOLING_BIN=" + stage3)
    add(nativeEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    let repoEnv = os.GetEnv("R2C_REACT_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.DirExists(repo), " r2c surface smoke: React.js repo exists")

    let codegenOutDir = chengpath.PathJoin(outDir, "codegen_surface")
    let codegenLog = chengpath.PathJoin(outDir, "r2c_codegen_surface.log")
    if chengpath.PathFileExists(codegenLog):
        os.RemoveFile(codegenLog)
    let codegenRun = hostops.RunFileLogged(root,
                                             "r2c_codegen_surface_smoke",
                                             driver,
                                             ["r2c-react-codegen-surface-smoke",
                                              "--repo", repo,
                                              "--out-dir", codegenOutDir],
                                             readyEnv,
                                             root,
                                             0,
                                             codegenLog)
    let codegenOutputRaw = codegenRun.output
    let codegenOutput = codegenOutputRaw
    assert(hostops.LoggedRunOk(codegenRun), " r2c surface smoke: codegen surface rc")
    assert(chengpath.PathFileExists(codegenLog), " r2c surface smoke: codegen surface log")
    assert(chengpath.TextContains(codegenOutput, "r2c-react codegen surface smoke: ok"),
           " r2c surface smoke: codegen surface ok")
    let codegenReportPath = os.JoinPath(codegenOutDir, "codegen_surface_report_v1.json")
    let codegenSummaryPath = os.JoinPath(codegenOutDir, "codegen_surface.summary.env")
    let codegenManifestPath = os.JoinPath(codegenOutDir, "cheng_codegen_v1.json")
    let codegenRouteCatalogPath = os.JoinPath(codegenOutDir, "cheng_codegen_route_catalog_v1.json")
    let codegenTsxAstPath = os.JoinPath(codegenOutDir, "tsx_ast_v1.json")
    assert(chengpath.FileExistsNonEmpty(root, codegenReportPath),
           " r2c surface smoke: codegen report")
    assert(chengpath.FileExistsNonEmpty(root, codegenSummaryPath),
           " r2c surface smoke: codegen summary")
    assert(chengpath.FileExistsNonEmpty(root, codegenManifestPath),
           " r2c surface smoke: codegen manifest")
    assert(chengpath.FileExistsNonEmpty(root, codegenRouteCatalogPath),
           " r2c surface smoke: codegen route catalog")
    assert(chengpath.FileExistsNonEmpty(root, codegenTsxAstPath),
           " r2c surface smoke: codegen tsx ast")

    let bundleOutDir = chengpath.PathJoin(outDir, "native_gui_bundle_home_default")
    let bundleLog = chengpath.PathJoin(outDir, "r2c_native_gui_bundle.log")
    if chengpath.PathFileExists(bundleLog):
        os.RemoveFile(bundleLog)
    assert(chengpath.MkdirP(root, bundleOutDir), " r2c surface smoke: bundle mkdir")
    let staticSummaryPath = os.JoinPath(bundleOutDir, "static_surface.summary.env")
    let bundleHostContractPath = os.JoinPath(bundleOutDir, "unimaker_host_v1.json")
    let bundleAssetManifestPath = os.JoinPath(bundleOutDir, "asset_manifest_v1.json")
    let bundleTailwindManifestPath = os.JoinPath(bundleOutDir, "tailwind_style_manifest_v1.json")
    var staticAssetRoots: str[]
    var staticSurface: r2csurface.R2cStaticSurfaceRunResult
    assert(r2csurface.r2cRunStaticSurface(repo, bundleOutDir, codegenTsxAstPath, staticSummaryPath, staticAssetRoots, staticSurface),
           " r2c surface smoke: static surface rc")
    assert(chengpath.FileExistsNonEmpty(root, staticSummaryPath),
           " r2c surface smoke: static surface summary")
    assert(chengpath.FileExistsNonEmpty(root, bundleHostContractPath),
           " r2c surface smoke: bundle host contract")
    assert(chengpath.FileExistsNonEmpty(root, bundleAssetManifestPath),
           " r2c surface smoke: bundle asset manifest")
    assert(chengpath.FileExistsNonEmpty(root, bundleTailwindManifestPath),
           " r2c surface smoke: bundle tailwind manifest")
    let bundleRun = hostops.RunProgramLogged(root,
                                               "r2c_native_gui_bundle_smoke",
                                               "node",
                                               [bundleScript,
                                                "--repo", repo,
                                                "--route-state", "home_default",
                                                "--out-dir", bundleOutDir,
                                                "--codegen-manifest", codegenManifestPath,
                                                "--host-contract", bundleHostContractPath,
                                                "--asset-manifest", bundleAssetManifestPath,
                                                "--tailwind-manifest", bundleTailwindManifestPath,
                                                "--route-catalog", codegenRouteCatalogPath,
                                                "--tsx-ast", codegenTsxAstPath,
                                                "--summary-out", os.JoinPath(bundleOutDir, "native_gui_bundle.summary.env")],
                                               nativeEnv,
                                               root,
                                               0,
                                               bundleLog)
    let bundleOutputRaw = bundleRun.output
    let bundleOutput = bundleOutputRaw
    assert(hostops.LoggedRunOk(bundleRun), " r2c surface smoke: native gui bundle rc")
    assert(chengpath.PathFileExists(bundleLog), " r2c surface smoke: native gui bundle log")
    let bundleReportPath = os.JoinPath(bundleOutDir, "native_gui_bundle_report_v1.json")
    let bundleSummaryPath = os.JoinPath(bundleOutDir, "native_gui_bundle.summary.env")
    let bundleJsonPath = os.JoinPath(bundleOutDir, "native_gui_bundle_v1.json")
    let bundleSessionPath = os.JoinPath(bundleOutDir, "native_gui_session_v1.json")
    assert(chengpath.FileExistsNonEmpty(root, bundleReportPath),
           " r2c surface smoke: native gui report")
    assert(chengpath.FileExistsNonEmpty(root, bundleSummaryPath),
           " r2c surface smoke: native gui summary")
    assert(chengpath.FileExistsNonEmpty(root, bundleJsonPath),
           " r2c surface smoke: native gui bundle json")
    assert(chengpath.FileExistsNonEmpty(root, bundleSessionPath),
           " r2c surface smoke: native gui session json")
    assert(chengpath.TextContains(bundleOutput, "\"ok\": true"),
           " r2c surface smoke: native gui bundle ok")
    let bundleSummaryText = chengpath.ReadTextFile("", bundleSummaryPath)
    assert(chengpath.TextContains(bundleSummaryText, "native_gui_runtime_bundle_ready=true"),
           " r2c surface smoke: bundle runtime bundle ready")
    assert(chengpath.TextContains(bundleSummaryText, "native_gui_runtime_contract_ready=true"),
           " r2c surface smoke: bundle runtime contract ready")

    let runOutDir = chengpath.PathJoin(outDir, "native_gui_run_home_default")
    let runLog = chengpath.PathJoin(outDir, "r2c_native_gui_run.log")
    if chengpath.PathFileExists(runLog):
        os.RemoveFile(runLog)
    let runReportPath = os.JoinPath(runOutDir, "native_gui_run_report_v1.json")
    let runSummaryPath = os.JoinPath(runOutDir, "native_gui_run.summary.env")
    let runScreenshotPath = os.JoinPath(runOutDir, "native_gui_session.png")
    assert(chengpath.MkdirP(root, runOutDir), " r2c surface smoke: run mkdir")
    let runRun = hostops.RunProgramLogged(root,
                                            "r2c_native_gui_run_smoke",
                                            "node",
                                            [runScript,
                                             "--repo", repo,
                                             "--out-dir", runOutDir,
                                             "--bundle-path", bundleJsonPath,
                                             "--session-path", bundleSessionPath,
                                             "--route-state", "home_default",
                                             "--auto-close-ms", "600",
                                             "--summary-out", runSummaryPath],
                                            [],
                                            root,
                                            0,
                                            runLog)
    let runOutputRaw = runRun.output
    let runOutput = runOutputRaw
    assert(hostops.LoggedRunOk(runRun), " r2c surface smoke: native gui run rc")
    assert(chengpath.PathFileExists(runLog), " r2c surface smoke: native gui run log")
    assert(chengpath.FileExistsNonEmpty(root, runReportPath),
           " r2c surface smoke: native gui run report")
    assert(chengpath.FileExistsNonEmpty(root, runSummaryPath),
           " r2c surface smoke: native gui run summary")
    assert(chengpath.FileExistsNonEmpty(root, runScreenshotPath),
           " r2c surface smoke: native gui run screenshot")
    assert(chengpath.TextContains(runOutput, "\"ok\": true"),
           " r2c surface smoke: native gui run output path")
    let runSummaryText = chengpath.ReadTextFile("", runSummaryPath)
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_bundle_ready=true"),
           " r2c surface smoke: runtime bundle ready")
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_contract_ready=true"),
           " r2c surface smoke: runtime contract ready")
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_bundle_route_state=home_default"),
           " r2c surface smoke: runtime bundle route state")
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_contract_layout_item_count="),
           " r2c surface smoke: runtime contract layout count")
    assert(chengpath.TextContains(runSummaryText, "native_gui_runtime_bundle_render_command_count="),
           " r2c surface smoke: runtime bundle render count")

    let contentBundleOutDir = chengpath.PathJoin(outDir, "native_gui_bundle_content_detail")
    let contentBundleLog = chengpath.PathJoin(outDir, "r2c_native_gui_bundle_content_detail.log")
    if chengpath.PathFileExists(contentBundleLog):
        os.RemoveFile(contentBundleLog)
    assert(chengpath.MkdirP(root, contentBundleOutDir), " r2c surface smoke: content bundle mkdir")
    let contentStaticSummaryPath = os.JoinPath(contentBundleOutDir, "static_surface.summary.env")
    let contentHostContractPath = os.JoinPath(contentBundleOutDir, "unimaker_host_v1.json")
    let contentAssetManifestPath = os.JoinPath(contentBundleOutDir, "asset_manifest_v1.json")
    let contentTailwindManifestPath = os.JoinPath(contentBundleOutDir, "tailwind_style_manifest_v1.json")
    var contentAssetRoots: str[]
    var contentStaticSurface: r2csurface.R2cStaticSurfaceRunResult
    assert(r2csurface.r2cRunStaticSurface(repo, contentBundleOutDir, codegenTsxAstPath, contentStaticSummaryPath, contentAssetRoots, contentStaticSurface),
           " r2c surface smoke: content static surface rc")
    assert(chengpath.FileExistsNonEmpty(root, contentHostContractPath),
           " r2c surface smoke: content host contract")
    assert(chengpath.FileExistsNonEmpty(root, contentAssetManifestPath),
           " r2c surface smoke: content asset manifest")
    assert(chengpath.FileExistsNonEmpty(root, contentTailwindManifestPath),
           " r2c surface smoke: content tailwind manifest")
    let contentBundleSummaryPath = os.JoinPath(contentBundleOutDir, "native_gui_bundle.summary.env")
    let contentBundleRun = hostops.RunProgramLogged(root,
                                                      "r2c_native_gui_bundle_content_detail",
                                                      "node",
                                                      [bundleScript,
                                                       "--repo", repo,
                                                       "--route-state", "content_detail",
                                                       "--out-dir", contentBundleOutDir,
                                                       "--codegen-manifest", codegenManifestPath,
                                                       "--host-contract", contentHostContractPath,
                                                       "--asset-manifest", contentAssetManifestPath,
                                                       "--tailwind-manifest", contentTailwindManifestPath,
                                                       "--route-catalog", codegenRouteCatalogPath,
                                                       "--tsx-ast", codegenTsxAstPath,
                                                       "--summary-out", contentBundleSummaryPath],
                                                      nativeEnv,
                                                      root,
                                                      0,
                                                      contentBundleLog)
    assert(hostops.LoggedRunOk(contentBundleRun), " r2c surface smoke: content bundle rc")
    assert(chengpath.PathFileExists(contentBundleLog), " r2c surface smoke: content bundle log")
    assert(chengpath.FileExistsNonEmpty(root, os.JoinPath(contentBundleOutDir, "native_gui_bundle_report_v1.json")),
           " r2c surface smoke: content bundle report")
    assert(chengpath.FileExistsNonEmpty(root, contentBundleSummaryPath),
           " r2c surface smoke: content bundle summary")
    assert(chengpath.FileExistsNonEmpty(root, os.JoinPath(contentBundleOutDir, "native_gui_bundle_v1.json")),
           " r2c surface smoke: content bundle json")
    let contentBundleSummaryText = chengpath.ReadTextFile("", contentBundleSummaryPath)
    assert(chengpath.TextContains(contentBundleSummaryText, "native_gui_route_state=content_detail"),
           " r2c surface smoke: content route state")
    assert(chengpath.TextContains(contentBundleSummaryText, "native_gui_runtime_bundle_ready=true"),
           " r2c surface smoke: content runtime bundle ready")

    echo(" r2c_react_surface_smoke ok")
    return 0
