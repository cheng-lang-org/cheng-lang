import std/system
import std/result
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/transports/quic_transport

fn main(): int32 =
    var listenAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(listenAddr, "127.0.0.1", 0)
    assert(quic_transport.Libp2pQuicTransportSupportsAddr(listenAddr),
        " quic transport loopback: supports")
    var pair: quic_transport.Libp2pQuicLoopbackPair
    let openRes = quic_transport.Libp2pQuicLoopbackOpenInto(pair, listenAddr)
    if IsErr(openRes):
        let msg: str = ErrorText(openRes)
        panic(msg)
    quic_transport.Libp2pQuicLoopbackClose(pair)
    echo(" quic_transport_loopback_smoke ok")
    return 0
