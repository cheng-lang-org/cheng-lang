import std/system
import cheng/std/bytes_layout as layout

fn main(): int32 =
    var buf = layout.byteBufInit(16)
    layout.byteBufAppendByte(buf, 0)
    layout.byteBufAppendByte(buf, 0)
    layout.byteBufAppendByte(buf, 0)
    layout.byteBufAppendByte(buf, 1)
    let span = layout.byteBufView(buf)
    assert(layout.byteSpanLen(span) == 4, " bytebuf view: len")
    assert(layout.byteSpanAt(span, 3) == 1, " bytebuf view: byte")
    echo(" bytebuf_view_smoke ok")
    return 0
