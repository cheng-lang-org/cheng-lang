import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_remove_dir_smoke_tmp"
    let childPath: str = os.JoinPath(tmpRoot, "child.txt")

    if os.FileExists(childPath):
        assert(os.RemoveFile(childPath), " ordinary os.RemoveDir cleanup child file")
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

    os.CreateDir(tmpRoot)
    assert(os.DirExists(tmpRoot), " ordinary os.RemoveDir created dir")
    os.RemoveDir(tmpRoot)
    let removedEmptyDir: bool = os.DirExists(tmpRoot)
    if removedEmptyDir:
        assert(false, " ordinary os.RemoveDir removes empty dir")

    os.CreateDir(tmpRoot)
    os.WriteFile(childPath, "x")
    os.RemoveDir(tmpRoot)
    assert(os.DirExists(tmpRoot), " ordinary os.RemoveDir keeps non-empty dir")
    assert(os.FileExists(childPath), " ordinary os.RemoveDir keeps child file")

    assert(os.RemoveFile(childPath), " ordinary os.RemoveDir remove child file")
    os.RemoveDir(tmpRoot)
    let removedAfterCleanup: bool = os.DirExists(tmpRoot)
    if removedAfterCleanup:
        assert(false, " ordinary os.RemoveDir removes dir after cleanup")
    echo(" os_remove_dir_smoke ok")
    return 0
