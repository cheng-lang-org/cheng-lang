import std/system
import std/result
import std/rawbytes
import std/varint

fn main() =
    let encoded: Bytes = encodeUVarint(300)
    let decodedRes: Result[VarintDecoded] = decodeUVarint(encoded, 0)
    assert(IsOk(decodedRes), "std/varint min decode")
    let decoded: VarintDecoded = Value(decodedRes)
    assert(decoded.value == 300, "std/varint min value")
    assert(decoded.next == bytesLen(encoded), "std/varint min next")

