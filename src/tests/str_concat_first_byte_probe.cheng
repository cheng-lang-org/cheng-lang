import std/system
fn main(): int32 =
    let path: str = "/tmp/no_model"
    let msg: str = "concat_param=" + path
    let data: ptr = strDataPtr(msg)
    if data == nil:
        echo("nil")
        return 1
    if *(UInt8Ptr(data)) == uint8(99):
        echo("byte-ok")
    else:
        echo("byte-bad")
    return 0
