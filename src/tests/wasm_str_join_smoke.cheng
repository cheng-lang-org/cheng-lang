import std/strutils as strutils

fn test_join_two_strings(): int32 =
    let parts: str[] = ["hello", "world"]
    let result = strutils.Join(parts, " ")
    if result != "hello world": return 1
    return 0

fn test_join_single(): int32 =
    let parts: str[] = ["only"]
    let result = strutils.Join(parts, ",")
    if result != "only": return 1
    return 0

fn test_join_empty_list(): int32 =
    let parts: str[] = []
    let result = strutils.Join(parts, ",")
    if result != "": return 1
    return 0

fn test_join_three_with_empty_sep(): int32 =
    let parts: str[] = ["a", "b", "c"]
    let result = strutils.Join(parts, "")
    if result != "abc": return 1
    return 0

fn test_join_with_numbers(): int32 =
    let parts: str[] = ["1", "2", "3"]
    let result = strutils.Join(parts, " + ")
    if result != "1 + 2 + 3": return 1
    return 0

fn main(): int32 =
    if test_join_two_strings() != 0: return 1
    if test_join_single() != 0: return 2
    if test_join_empty_list() != 0: return 3
    if test_join_three_with_empty_sep() != 0: return 4
    if test_join_with_numbers() != 0: return 5
    return 0
