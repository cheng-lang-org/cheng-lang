import std/result
import cheng/apps/vpn_proxy/vpn_proxy_cli as cli

fn main(): int32 =
    var options: cli.VpnProxyCliOptions
    options = cli.VpnProxyOptions([
        "--config:/tmp/vpn.json",
        "--ready-path=/tmp/vpn.ready",
        "--accept-count", "7",
        "--probe-interval-ms:-3",
        "--probe-timeout-ms=0"
    ])
    assert(options.configPath == "/tmp/vpn.json", " vpn proxy cli config")
    assert(options.readyPath == "/tmp/vpn.ready", " vpn proxy cli ready path")
    assert(options.acceptCount == 7, " vpn proxy cli accept count")
    assert(options.probeIntervalMs == 0, " vpn proxy cli interval clamp")
    assert(options.probeTimeoutMs == 1000, " vpn proxy cli timeout clamp")

    var defaultOptions: cli.VpnProxyCliOptions
    defaultOptions = cli.VpnProxyOptions([])
    assert(defaultOptions.acceptCount == 0, " vpn proxy cli default accept count")
    assert(defaultOptions.probeIntervalMs == 3000, " vpn proxy cli default interval")
    assert(defaultOptions.probeTimeoutMs == 1000, " vpn proxy cli default timeout")

    let parseOk: Result[int32] = cli.VpnProxyParseInt32(" 42 ")
    assert(!IsErr(parseOk), " vpn proxy cli parse int ok")
    assert(Value(parseOk) == 42, " vpn proxy cli parse int value")

    let parseBad: Result[int32] = cli.VpnProxyParseInt32("x")
    assert(IsErr(parseBad), " vpn proxy cli parse int reject")
    assert(ErrorText(parseBad) == "vpn proxy: invalid integer", " vpn proxy cli parse int reject text")

    let rest: str[] = cli.VpnProxyCollectArgsFrom(["vpn-proxy", "local", "--config:a"], 1)
    assert(rest.len == 2, " vpn proxy cli collect len")
    assert(rest[0] == "local", " vpn proxy cli collect first")
    assert(rest[1] == "--config:a", " vpn proxy cli collect second")

    echo(" vpn_proxy_cli_smoke ok")
    return 0
