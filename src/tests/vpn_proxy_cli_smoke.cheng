import std/result
import cheng/apps/vpn_proxy/vpn_proxy_cli as cli

fn main(): int32 =
    var options: cli.V3VpnProxyCliOptions
    options = cli.V3VpnProxyOptions([
        "--config:/tmp/vpn.json",
        "--ready-path=/tmp/vpn.ready",
        "--accept-count", "7",
        "--probe-interval-ms:-3",
        "--probe-timeout-ms=0"
    ])
    assert(options.configPath == "/tmp/vpn.json", "v3 vpn proxy cli config")
    assert(options.readyPath == "/tmp/vpn.ready", "v3 vpn proxy cli ready path")
    assert(options.acceptCount == 7, "v3 vpn proxy cli accept count")
    assert(options.probeIntervalMs == 0, "v3 vpn proxy cli interval clamp")
    assert(options.probeTimeoutMs == 1000, "v3 vpn proxy cli timeout clamp")

    var defaultOptions: cli.V3VpnProxyCliOptions
    defaultOptions = cli.V3VpnProxyOptions([])
    assert(defaultOptions.acceptCount == 0, "v3 vpn proxy cli default accept count")
    assert(defaultOptions.probeIntervalMs == 3000, "v3 vpn proxy cli default interval")
    assert(defaultOptions.probeTimeoutMs == 1000, "v3 vpn proxy cli default timeout")

    let parseOk: Result[int32] = cli.V3VpnProxyParseInt32(" 42 ")
    assert(!IsErr(parseOk), "v3 vpn proxy cli parse int ok")
    assert(Value(parseOk) == 42, "v3 vpn proxy cli parse int value")

    let parseBad: Result[int32] = cli.V3VpnProxyParseInt32("x")
    assert(IsErr(parseBad), "v3 vpn proxy cli parse int reject")
    assert(ErrorText(parseBad) == "vpn proxy: invalid integer", "v3 vpn proxy cli parse int reject text")

    let rest: str[] = cli.V3VpnProxyCollectArgsFrom(["vpn-proxy", "local", "--config:a"], 1)
    assert(rest.len == 2, "v3 vpn proxy cli collect len")
    assert(rest[0] == "local", "v3 vpn proxy cli collect first")
    assert(rest[1] == "--config:a", "v3 vpn proxy cli collect second")

    echo("v3 vpn_proxy_cli_smoke ok")
    return 0
