type Header =
    size: int32
    align: int32 = 4
    words: int32[2]

fn MakeHeader(size: int32): Header =
    return Header(size: size, align: 8, words: [3, 5])

fn main(): int32 =
    let h = MakeHeader(9)
    if h.size != 9:
        return 1
    if h.align != 8:
        return 2
    if h.words[0] != 3:
        return 3
    if h.words[1] != 5:
        return 4
    return h.size + h.align + h.words[0] + h.words[1]
