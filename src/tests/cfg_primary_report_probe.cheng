import std/os
import cheng/core/backend/lowering_plan as lower
import cheng/core/backend/primary_object_plan as pobj
import cheng/core/backend/system_link_plan as slplan
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root = os.GetEnvDefault("CHENG_SMOKE_ROOT", ".")
    let sourcePath = chengpath.PathJoin(root, "src/tests/cfg_final_return_call_sequence_fixture.cheng")
    let outputPath = chengpath.PathJoin(root, "artifacts/probe/cfg_final_return_call_sequence_fixture.o")
    let req = creq.CompilerRequestNew(root,
                                      sourcePath,
                                      outputPath,
                                      "arm64-apple-darwin",
                                      creq.EmitObj,
                                      "")
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    if !slplan.BuildSystemLinkPlanStub(root, req, linkPlan, err):
        echo(err)
        return 2
    var loweringPlan: lower.LoweringPlanStub
    if !lower.BuildLoweringPlanStub(linkPlan, loweringPlan, err):
        echo(err)
        return 3
    let primary = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    echo(pobj.PrimaryObjectPlanReport(primary))
    return 0
