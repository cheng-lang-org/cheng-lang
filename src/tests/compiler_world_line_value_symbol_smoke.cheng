import std/os
import std/strings

fn countSubstr(text: str, needle: str): int32 =
    if len(needle) <= 0:
        return 0
    var count: int32
    var i: int32
    while i + len(needle) <= len(text):
        var matched = true
        for j in 0..<len(needle):
            if text[i + j] != needle[j]:
                matched = false
                break
        if matched:
            count = count + 1
            i = i + len(needle)
        else:
            i = i + 1
    return count

fn main(): int32 =
    let worldPath = "src/core/tooling/compiler_world.cheng"
    let csgPath = "src/core/tooling/compiler_csg.cheng"
    let libp2pPath = "src/core/tooling/compiler_world_libp2p.cheng"
    assert(os.FileExists(worldPath), " compiler world symbol: world source exists")
    assert(os.FileExists(csgPath), " compiler world symbol: csg source exists")
    assert(os.FileExists(libp2pPath), " compiler world symbol: libp2p source exists")
    let worldText: str = os.ReadFile(worldPath)
    let csgText: str = os.ReadFile(csgPath)
    let libp2pText: str = os.ReadFile(libp2pPath)
    assert(countSubstr(worldText, "fn CompilerWorldLineValue") == 1,
           " compiler world symbol: one public parser helper")
    assert(!strings.StrContains(csgText, "fn CompilerWorldLineValue"),
           " compiler world symbol: csg helper private")
    assert(strings.StrContains(csgText, "fn compilerCsgLineValue"),
           " compiler world symbol: csg helper renamed")
    assert(!strings.StrContains(libp2pText, "fn CompilerWorldLineValue"),
           " compiler world symbol: libp2p helper private")
    assert(strings.StrContains(libp2pText, "fn compilerWorldLibp2pLineValue"),
           " compiler world symbol: libp2p helper renamed")
    echo(" compiler_world_line_value_symbol_smoke ok")
    return 0
