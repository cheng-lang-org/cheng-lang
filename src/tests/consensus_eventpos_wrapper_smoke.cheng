import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

fn localApply(index: var consensus.ChainIndex,
              event: consensus.ChainEvent,
              eventCid: layout.FixedBytes32,
              logOffset: int32): Result[consensus.ConsensusDecision] =
    var out = consensus.ConsensusDecision()
    out.eventCid = eventCid
    let duplicatePos = consensus.ConsensusEventPos(index, eventCid)
    assert(duplicatePos == -1, " consensus eventpos wrapper: duplicate pos")
    consensus.ConsensusApplyMint(index, event, eventCid, logOffset, out)
    assert(index.accountIds.buffer != nil, " consensus eventpos wrapper: inner account buffer")
    assert(index.accountIds.cap >= 1, " consensus eventpos wrapper: inner account cap")
    assert(index.accountIds.len == 1, " consensus eventpos wrapper: inner account len")
    return Ok[consensus.ConsensusDecision](out)

fn main(): int32 =
    var index = consensus.ChainIndex()
    let zeroCid = layout.FixedBytes32()
    let event = consensus.ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let eventCid = consensus.ChainEventCid(event)
    let applyRes = localApply(index, event, eventCid, 0)
    assert(IsOk(applyRes), " consensus eventpos wrapper: ok")
    let decision = Value(applyRes)
    assert(decision.accepted, " consensus eventpos wrapper: accepted")
    assert(decision.applied, " consensus eventpos wrapper: applied")
    assert(index.accountIds.buffer != nil, " consensus eventpos wrapper: account buffer")
    assert(index.accountIds.cap >= 1, " consensus eventpos wrapper: account cap")
    assert(index.accountIds.len == 1, " consensus eventpos wrapper: account len")
    echo(" consensus_eventpos_wrapper_smoke ok")
    return 0
