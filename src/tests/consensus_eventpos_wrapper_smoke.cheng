import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

fn localApply(index: var consensus.V3ChainIndex,
              event: consensus.V3ChainEvent,
              eventCid: layout.FixedBytes32,
              logOffset: int32): Result[consensus.V3ConsensusDecision] =
    var out = consensus.V3ConsensusDecision()
    out.eventCid = eventCid
    let duplicatePos = consensus.v3ConsensusEventPos(index, eventCid)
    assert(duplicatePos == -1, "v3 consensus eventpos wrapper: duplicate pos")
    consensus.v3ConsensusApplyMint(index, event, eventCid, logOffset, out)
    assert(index.accountIds.buffer != nil, "v3 consensus eventpos wrapper: inner account buffer")
    assert(index.accountIds.cap >= 1, "v3 consensus eventpos wrapper: inner account cap")
    assert(index.accountIds.len == 1, "v3 consensus eventpos wrapper: inner account len")
    return Ok[consensus.V3ConsensusDecision](out)

fn main(): int32 =
    var index = consensus.V3ChainIndex()
    let zeroCid = layout.FixedBytes32()
    let event = consensus.v3ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let eventCid = consensus.v3ChainEventCid(event)
    let applyRes = localApply(index, event, eventCid, 0)
    assert(IsOk(applyRes), "v3 consensus eventpos wrapper: ok")
    let decision = Value(applyRes)
    assert(decision.accepted, "v3 consensus eventpos wrapper: accepted")
    assert(decision.applied, "v3 consensus eventpos wrapper: applied")
    assert(index.accountIds.buffer != nil, "v3 consensus eventpos wrapper: account buffer")
    assert(index.accountIds.cap >= 1, "v3 consensus eventpos wrapper: account cap")
    assert(index.accountIds.len == 1, "v3 consensus eventpos wrapper: account len")
    echo("v3 consensus_eventpos_wrapper_smoke ok")
    return 0
