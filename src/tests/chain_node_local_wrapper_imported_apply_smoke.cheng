import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus as consensus
import cheng/apps/chain_node/chain_node as node

fn localMintViaImportedApply(chain: var node.ChainNode,
                             assetId: int32,
                             toAccount: int32,
                             amount: int64): Result[layout.FixedBytes32] =
    let parentCid = node.ChainNodeAccountHead(chain.index, assetId, toAccount)
    var event = consensus.ChainEventMint(
        assetId,
        toAccount,
        parentCid,
        amount,
        chain.nextEpoch,
        chain.nextGanzhi,
        node.ChainNodeSpaceSlot(toAccount, toAccount),
        chain.nextTick
    )
    return node.ChainNodeApplyEvent(chain, event)

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    let mintCidRes = localMintViaImportedApply(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "chain node local wrapper imported apply: mint")
    assert(server.eventCids.len == 1, "chain node local wrapper imported apply: cid len")
    assert(server.events.len == 1, "chain node local wrapper imported apply: event len")
    assert(layout.FixedBytes32Equal(server.eventCids[0], mintCidRes.value),
           "chain node local wrapper imported apply: first cid")
    assert(server.events[0].kind == consensus.ConsensusKindMint,
           "chain node local wrapper imported apply: first event kind")
    echo(" chain_node_local_wrapper_imported_apply_smoke ok")
    return 0
