import std/system
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/transports/tailnet_transport as tsnet
import cheng/tests/smoke_ports

fn main(): int32 =
    var cfg: tsnet.Libp2pTailnetTransportConfig
    cfg.controlEndpoint = "https://control.example"
    cfg.relayEndpoint = "derp-sfo"
    cfg.syntheticIPv4 = "100.64.0.44"
    cfg.syntheticIPv6 = "fd7a:115c:a1e0::44"
    cfg.localPeerId = "tailnet-transport-smoke"
    cfg.exactRouting = true

    var transport = tsnet.Libp2pTailnetTransportInit(cfg)
    tsnet.Libp2pTailnetProviderStart(transport)

    var rawTcp: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(rawTcp, "127.0.0.1", smoke_ports.SmokeLabelPort(7101))
    var rawQuic: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(rawQuic, "127.0.0.1", smoke_ports.SmokeLabelPort(7102))

    let tcpRes = tsnet.Libp2pTailnetListen(transport, rawTcp)
    assert(IsOk(tcpRes), " libp2p tailnet transport: tcp listen")
    let quicRes = tsnet.Libp2pTailnetListen(transport, rawQuic)
    assert(IsOk(quicRes), " libp2p tailnet transport: quic listen")

    let published = tsnet.Libp2pTailnetPublishedAddrs(transport)
    assert(published.len == 2, " libp2p tailnet transport: published count")
    assert(published[0].networkDomain == types.Libp2pNetworkDomainTailnet,
        " libp2p tailnet transport: published domain")
    assert(published[0].visibility == types.Libp2pVisibilityTrustedOnly,
        " libp2p tailnet transport: published visibility")
    assert(published[0].host == "100.64.0.44",
        " libp2p tailnet transport: synthetic host")
    assert(published[1].transport == types.Libp2pTransportQuic,
        " libp2p tailnet transport: quic preserved")

    var rawLookup: types.Libp2pMultiaddr
    assert(tsnet.Libp2pTailnetResolvePublishedToRaw(transport, published[0], rawLookup),
        " libp2p tailnet transport: published to raw")
    assert(rawLookup.host == "127.0.0.1", " libp2p tailnet transport: raw host lookup")
    var publishedLookup: types.Libp2pMultiaddr
    assert(tsnet.Libp2pTailnetResolveRawToPublished(transport, rawQuic, publishedLookup),
        " libp2p tailnet transport: raw to published")
    assert(publishedLookup.host == "100.64.0.44", " libp2p tailnet transport: published host lookup")

    var pendingStatus: tsnet.Libp2pTailnetStatusSnapshot
    tsnet.Libp2pTailnetStatusFill(pendingStatus, transport)
    assert(pendingStatus.tailnetPath == "direct-pending",
        " libp2p tailnet transport: pending path")
    assert(pendingStatus.startupStage == "provider-started",
        " libp2p tailnet transport: provider start stage")
    assert(tsnet.Libp2pTailnetProviderRuntimeActiveCountNow() == 1,
        " libp2p tailnet transport: runtime active")

    tsnet.Libp2pTailnetProviderMarkProxyReady(transport)

    var directSession: tsnet.Libp2pTailnetPeerSession
    directSession.peerId = "peer-direct"
    directSession.remoteTailnetIp = "100.64.0.88"
    directSession.directReachable = true
    directSession.relayAllowed = true
    directSession.derpRegionCode = "sfo"
    directSession.signedPreface = "preface-ok"
    directSession.boundAddrText = tsnet.Libp2pTailnetAddrText(rawTcp)
    tsnet.Libp2pTailnetUpsertPeerSession(transport, directSession)
    var preStatus: tsnet.Libp2pTailnetStatusSnapshot
    tsnet.Libp2pTailnetStatusFill(preStatus, transport)
    assert(preStatus.sessionCount == 1, " libp2p tailnet transport: session count")
    let directPlanBuild = tsnet.Libp2pTailnetDialPlanBuild(transport,
                                                             "peer-direct",
                                                             published[0],
                                                             false,
                                                             false)
    assert(directPlanBuild.ok, " libp2p tailnet transport: direct plan")
    let directPlan = directPlanBuild.plan
    assert(directPlan.pathKind == tsnet.Libp2pTailnetPathDirect,
        " libp2p tailnet transport: direct path")
    assert(directPlan.reachability == types.Libp2pReachabilityDirect,
        " libp2p tailnet transport: direct reachability")
    assert(directPlan.routeText == tsnet.Libp2pTailnetAddrText(rawTcp),
        " libp2p tailnet transport: exact route text")

    tsnet.Libp2pTailnetProviderMarkListenerRepairNeeded(transport)
    let repairPlanBuild = tsnet.Libp2pTailnetDialPlanBuild(transport,
                                                             "peer-direct",
                                                             published[0],
                                                             false,
                                                             true)
    assert(!repairPlanBuild.ok, " libp2p tailnet transport: repair blocks direct")
    let repairPlan = repairPlanBuild.plan
    assert(repairPlan.pathKind == tsnet.Libp2pTailnetPathRepair,
        " libp2p tailnet transport: repair path")
    tsnet.Libp2pTailnetProviderRepairListeners(transport)

    let directPlanAfterRepairBuild = tsnet.Libp2pTailnetDialPlanBuild(transport,
                                                                        "peer-direct",
                                                                        published[0],
                                                                        false,
                                                                        false)
    assert(directPlanAfterRepairBuild.ok, " libp2p tailnet transport: repair restores direct")
    let directPlanAfterRepair = directPlanAfterRepairBuild.plan
    assert(directPlanAfterRepair.pathKind == tsnet.Libp2pTailnetPathDirect,
        " libp2p tailnet transport: repair direct path")

    var status: tsnet.Libp2pTailnetStatusSnapshot
    tsnet.Libp2pTailnetStatusFill(status, transport)
    assert(status.providerLabel == "synthetic", " libp2p tailnet transport: provider")
    assert(status.controlPlane == "synthetic", " libp2p tailnet transport: control plane")
    assert(status.providerReady, " libp2p tailnet transport: provider ready")
    assert(status.proxyListenersReady, " libp2p tailnet transport: proxy ready")
    assert(status.exactRouting, " libp2p tailnet transport: exact routing")
    assert(status.tailnetPath == "direct", " libp2p tailnet transport: status path")
    assert(status.tailnetIPs.len == 2, " libp2p tailnet transport: status ips")
    assert(status.publishedCount == 2, " libp2p tailnet transport: published count status")
    assert(status.sessionCount == 1, " libp2p tailnet transport: session count status")
    assert(status.tailnetRelay == "derp-sfo", " libp2p tailnet transport: relay")
    assert(status.tailnetDerpMapSummary == "https://control.example",
        " libp2p tailnet transport: control")
    assert(status.startupStage == "repair-complete", " libp2p tailnet transport: startup stage")
    assert(tsnet.Libp2pTailnetProviderRuntimeCommandCountNow() == 4,
        " libp2p tailnet transport: runtime commands")

    echo(" libp2p_tailnet_transport_smoke ok")
    return 0
