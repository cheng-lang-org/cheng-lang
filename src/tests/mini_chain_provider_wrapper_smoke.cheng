import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus
import cheng/tests/mini_chain_provider_support as support

fn main(): int32 =
    var node = support.MiniNode()
    let mintRes = support.miniMint(node, 7, 1001, int64(100))
    assert(mintRes.ok, "mini chain provider wrapper: mint")
    assert(node.eventCids.len == 1, "mini chain provider wrapper: cid len")
    assert(node.events.len == 1, "mini chain provider wrapper: event len")
    assert(node.index.accountIds.len == 1, "mini chain provider wrapper: account len")
    assert(node.index.balances.len == 1, "mini chain provider wrapper: balance len")
    assert(layout.fixedBytes32Equal(node.eventCids[0], mintRes.value),
           "mini chain provider wrapper: first cid")
    assert(node.events[0].kind == consensus.v3ConsensusKindMint,
           "mini chain provider wrapper: first event kind")
    assert(layout.fixedBytes32Equal(node.tipEventCid, mintRes.value),
           "mini chain provider wrapper: tip cid")
    assert(node.nextTick == int64(2), "mini chain provider wrapper: next tick")
    echo("v3 mini_chain_provider_wrapper_smoke ok")
    return 0
