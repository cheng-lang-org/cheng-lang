import std/cmdline
import std/os
import std/strings

fn main(): int32 =
    if cmdline.ParamCount() < 1:
        return 0
    let command: str = cmdline.ParamStr(1)
    if command == "train-diloco-libp2p-server":
        let bindHost: str = cmdline.ReadFlagOrDefault("--bind", "127.0.0.1")
        let portText: str = cmdline.ReadFlagOrDefault("--port", "")
        let serverName: str = cmdline.ReadFlagOrDefault("--server-name", "localhost")
        let readyPath: str = cmdline.ReadFlagOrDefault("--ready-path", "")
        let jobCidHex: str = cmdline.ReadFlagOrDefault("--job-cid", "")
        let stateLabel: str = cmdline.ReadFlagOrDefault("--state-label", "gapup-libp2p")
        let requestedWorkersText: str = cmdline.ReadFlagOrDefault("--requested-workers", "")
        let innerStepBudgetText: str = cmdline.ReadFlagOrDefault("--inner-step-budget", "")
        let timeoutSecText: str = cmdline.ReadFlagOrDefault("--timeout-sec", "")
        let initialModelPath: str = cmdline.ReadFlagOrDefault("--initial-model-path", "")
        let initialOptimizerPath: str = cmdline.ReadFlagOrDefault("--initial-optimizer-path", "")
        let maxServeCountText: str = cmdline.ReadFlagOrDefault("--max-serve-count", "")
        let waitMsText: str = cmdline.ReadFlagOrDefault("--wait-ms", "")
        echo(bindHost)
        echo(portText)
        echo(serverName)
        echo(readyPath)
        echo(jobCidHex)
        echo(stateLabel)
        echo(requestedWorkersText)
        echo(innerStepBudgetText)
        echo(timeoutSecText)
        echo(initialModelPath)
        echo(initialOptimizerPath)
        echo(maxServeCountText)
        echo(waitMsText)
        echo("server-ok")
        return 0
    if command == "train-distributed":
        let inputCsv: str = cmdline.ReadFlagOrDefault("--input-csv", "")
        var outputModel: str = cmdline.ReadFlagOrDefault("--output-model", "")
        if len(outputModel) == 0:
            outputModel = os.JoinPath(os.GetCurrentDir(), "gapup_model.kv")
        var outputReport: str = cmdline.ReadFlagOrDefault("--output-report", "")
        if len(outputReport) == 0:
            outputReport = os.JoinPath(os.GetCurrentDir(), "gapup_train.report.json")
        let workersText: str = cmdline.ReadFlagOrDefault("--workers", "")
        let epochsText: str = cmdline.ReadFlagOrDefault("--epochs", "")
        let learningRateText: str = cmdline.ReadFlagOrDefault("--learning-rate", "")
        let splitRatioText: str = cmdline.ReadFlagOrDefault("--split-ratio", "")
        let labelTarget: str = cmdline.ReadFlagOrDefault("--label-target", "gap_up")
        let coordination: str = cmdline.ReadFlagOrDefault("--coordination", "libp2p-diloco")
        var runDir: str = cmdline.ReadFlagOrDefault("--run-dir", "")
        if len(runDir) == 0:
            runDir = os.JoinPath(os.GetCurrentDir(), ".gapup_train")
        var selfExe: str = cmdline.ReadFlagOrDefault("--self-exe", "")
        if len(selfExe) == 0:
            selfExe = cmdline.ProgramName()
        let bindHost: str = cmdline.ReadFlagOrDefault("--diloco-bind", "127.0.0.1")
        let coordinatorHost: str = cmdline.ReadFlagOrDefault("--diloco-host", "127.0.0.1")
        let serverName: str = cmdline.ReadFlagOrDefault("--diloco-server-name", "localhost")
        echo(inputCsv)
        echo(outputModel)
        echo(outputReport)
        echo(workersText)
        echo(epochsText)
        echo(learningRateText)
        echo(splitRatioText)
        echo(labelTarget)
        echo(coordination)
        echo(runDir)
        echo(selfExe)
        echo(bindHost)
        echo(coordinatorHost)
        echo(serverName)
        echo("train-ok")
        return 0
    echo(strings.IntToStr(cmdline.ParamCount()))
    return 0
