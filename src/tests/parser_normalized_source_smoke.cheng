import std/os
import cheng/core/lang/parser
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_request as creq
import cheng/core/backend/system_link_plan as slplan

fn ensureDir(path: str) =
    if !os.DirExists(path):
        os.CreateDir(path)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let fixturePath = chengpath.PathJoin(root, "src/tests/parser_normalized_decl_fixture.cheng")
    let text = os.ReadFile(fixturePath)
    var decls: parser.NormalizedFunctionDecl[]
    var err = ""
    assert(parser.ParserReadNormalizedFunctionDecls(text, decls, err),
           " parser normalized source: read decls")
    assert(decls.len == 4, " parser normalized source: decl count")
    assert(decls[0].name == "AlphaSeven", " parser normalized source: alpha name")
    assert(!decls[0].importc, " parser normalized source: alpha importc")
    assert(decls[0].explicitExportName == "alphaSeven", " parser normalized source: alpha export name")
    assert(decls[1].name == "puts", " parser normalized source: puts name")
    assert(decls[1].importc, " parser normalized source: puts importc")
    assert(decls[1].explicitExportName == "", " parser normalized source: puts export cleared")
    assert(decls[2].name == "hostNow", " parser normalized source: inline importc name")
    assert(decls[2].importc, " parser normalized source: inline importc")
    assert(decls[3].name == "BetaTwice", " parser normalized source: beta name")
    assert(decls[3].explicitExportName == "betaTwice", " parser normalized source: beta export name")
    assert(parser.ParserHasCompilerTopLevel(text), " parser normalized source: compiler top level")
    assert(!parser.ParserMainFunctionPresent(text), " parser normalized source: main absent")

    let outDir = chengpath.PathAbsolute(root, "artifacts/parser_normalized_source")
    let workspaceDir = chengpath.PathJoin(outDir, "workspace")
    let pkgRoot = chengpath.PathJoin(workspaceDir, "alias_pkg")
    let srcDir = chengpath.PathJoin(pkgRoot, "src")
    ensureDir(outDir)
    ensureDir(workspaceDir)
    ensureDir(pkgRoot)
    ensureDir(srcDir)
    os.WriteFile(chengpath.PathJoin(pkgRoot, "cheng-package.toml"),
                 "package_id = \"pkg://cheng/alias_pkg\"\nmodule_prefix = \"alias_pkg\"\n")
    let aliasSource = chengpath.PathJoin(srcDir, "alias_main.cheng")
    let aliasText = "func main(): int32 =\n    return 0\n"
    os.WriteFile(aliasSource, aliasText)
    let outputPath = chengpath.PathJoin(outDir, "alias_main")
    let req = creq.CompilerRequestNew(pkgRoot,
                                        aliasSource,
                                        outputPath,
                                        "arm64-apple-darwin",
                                        creq.EmitExe,
                                        "")
    var plan: slplan.SystemLinkPlanStub
    err = ""
    assert(!slplan.BuildSystemLinkPlanStub(root, req, plan, err),
           " parser normalized source: reject func alias")
    assert(chengpath.TextContains(err, "unsupported top-level function alias 'func'"),
           " parser normalized source: reject func alias text")

    let nestedProcText = "fn main(): int32 =\n    proc = 1\n    return proc\n"
    var nestedDecls: parser.NormalizedFunctionDecl[]
    err = ""
    assert(parser.ParserReadNormalizedFunctionDecls(nestedProcText, nestedDecls, err),
           " parser normalized source: ignore indented proc assignment")
    assert(nestedDecls.len == 1, " parser normalized source: indented proc decl count")
    assert(nestedDecls[0].name == "main", " parser normalized source: indented proc keep main")

    echo(" parser_normalized_source_smoke ok")
    return 0
