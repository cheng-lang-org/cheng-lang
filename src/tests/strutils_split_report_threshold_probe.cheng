import std/os
import std/strutils as strutil
import cheng/core/tooling/path as chengpath

fn splitNonEmpty(text: str): bool =
    let lines = strutil.Split(text, '\n')
    return lines.len > 0

fn main(): int32 =
    let root = os.GetCurrentDir()
    let reportPath = os.JoinPath(root, "artifacts/str_concat_lowering_smoke/str_concat_lowering_probe.compile.report.txt")
    assert(chengpath.PathFileExists(reportPath), " split threshold: report exists")
    let reportText = os.ReadFile(reportPath)
    assert(splitNonEmpty(chengpath.TextSlice(reportText, 0, 200)), " split threshold: 200")
    echo(" split threshold 200 ok")
    assert(splitNonEmpty(chengpath.TextSlice(reportText, 0, 500)), " split threshold: 500")
    echo(" split threshold 500 ok")
    assert(splitNonEmpty(chengpath.TextSlice(reportText, 0, 1000)), " split threshold: 1000")
    echo(" split threshold 1000 ok")
    assert(splitNonEmpty(chengpath.TextSlice(reportText, 0, 2000)), " split threshold: 2000")
    echo(" split threshold 2000 ok")
    assert(splitNonEmpty(chengpath.TextSlice(reportText, 0, 4000)), " split threshold: 4000")
    echo(" split threshold 4000 ok")
    assert(splitNonEmpty(chengpath.TextSlice(reportText, 0, 8000)), " split threshold: 8000")
    echo(" split threshold 8000 ok")
    return 0
