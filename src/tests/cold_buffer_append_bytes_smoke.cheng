import std/rawbytes
import std/buffer

fn main() =
    var buf = buffer.NewByteBuffer()
    let a = rawbytes.BytesFromString("abc")
    let b = rawbytes.BytesFromString("def")
    buffer.AppendBytes(buf, a)
    assert(rawbytes.BytesLen(buffer.ToBytes(buf)) == 3, "cold buffer append bytes first len")
    buffer.AppendBytes(buf, b)
    assert(rawbytes.BytesLen(buffer.ToBytes(buf)) == 6, "cold buffer append bytes second len")
    let out = rawbytes.BytesToString(buffer.ToBytes(buf))
    assert(out == "abcdef", "cold buffer append bytes")
