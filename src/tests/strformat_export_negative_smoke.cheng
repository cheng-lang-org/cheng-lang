import std/cmdline as cmdline
import std/os as os
import std/os_host_process as hostos
import std/strings as strings

fn ensureDir(path: str) =
    if !os.dirExists(path):
        os.createDir(path)

fn envDefault(key: str, defaultValue: str): str =
    let raw: str = os.getEnv(key)
    if len(raw) > 0:
        return raw
    return defaultValue

fn currentExecutablePath(root: str): str =
    let raw: str = cmdline.programName()
    if len(raw) <= 0:
        return ""
    if os.isAbsolute(raw):
        return raw
    return os.joinPath(root, raw)

fn joinPieces(parts: str[]): str =
    var total: int32
    for i in 0..<parts.len:
        total = total + len(parts[i])
    if total <= 0:
        return ""
    let out = newStringAlloc(total)
    var writePos: int32
    for i in 0..<parts.len:
        let part = parts[i]
        for j in 0..<len(part):
            out[writePos] = part[j]
            writePos = writePos + 1
    return out

fn charText(ch: char): str =
    let out = newStringAlloc(1)
    out[0] = ch
    return out

fn ownedText(text: str): str =
    if len(text) <= 0:
        return ""
    return newStringCopy(strDataPtr(text), len(text))

fn quoteShellStable(value: str): str =
    if len(value) == 0:
        return "''"
    var parts: str[]
    add(parts, "'")
    for i in 0..<len(value):
        let ch = value[i]
        if ch == '\'':
            add(parts, "'\"'\"'")
        else:
            add(parts, charText(ch))
    add(parts, "'")
    return joinPieces(parts)

fn compileCommandText(filePath: str, argv: str[], envOverrides: str[], logPath: str): str =
    var parts: str[]
    if envOverrides.len > 0:
        add(parts, "env")
        for i in 0..<envOverrides.len:
            let envText = envOverrides[i]
            if len(envText) > 0:
                add(parts, " ")
                add(parts, quoteShellStable(envText))
        add(parts, " ")
    add(parts, quoteShellStable(filePath))
    for i in 0..<argv.len:
        add(parts, " ")
        add(parts, quoteShellStable(argv[i]))
    add(parts, " > ")
    add(parts, quoteShellStable(logPath))
    add(parts, " 2>&1")
    return joinPieces(parts)

fn compileFixture(compiler: str,
                  root: str,
                  packageRoot: str,
                  inputPath: str,
                  outputPath: str,
                  logPath: str,
                  outOutput: var str): int32 =
    let target: str = envDefault("CHENG_BOOTSTRAP_TARGET", "arm64-apple-darwin")
    var argv: str[]
    add(argv, "system-link-exec")
    add(argv, "--root")
    add(argv, ownedText(packageRoot))
    add(argv, "--in")
    add(argv, ownedText(inputPath))
    add(argv, "--emit")
    add(argv, "exe")
    add(argv, "--target")
    add(argv, ownedText(target))
    add(argv, "--out")
    add(argv, ownedText(outputPath))
    var envv: str[]
    let command = compileCommandText(compiler, argv, envv, logPath)
    outOutput = ""
    var shellArgv: str[]
    add(shellArgv, "-lc")
    add(shellArgv, ownedText(command))
    let exitCode: int32 = hostos.ExecFileStatus("/bin/sh",
                                                shellArgv,
                                                [],
                                                root,
                                                60)
    outOutput = os.ReadFile(logPath)
    return exitCode

fn main(): int32 =
    let root: str = os.getCurrentDir()
    let exePath: str = currentExecutablePath(root)
    assert(len(exePath) > 0 && os.fileExists(exePath),
           " strformat export negative: executable path")
    let exeDir = os.ParentDir(exePath)
    let exeName = os.ExtractFilename(exePath)
    let outDirName = exeName + ".workspace"
    let outDir = os.joinPath(exeDir, outDirName)
    ensureDir(outDir)

    let workspaceDir = os.joinPath(outDir, "workspace")
    let pkgRoot = os.joinPath(workspaceDir, "consumer_pkg")
    let srcDir = os.joinPath(pkgRoot, "src")
    ensureDir(workspaceDir)
    ensureDir(pkgRoot)
    ensureDir(srcDir)
    let pkgManifestPath = os.joinPath(pkgRoot, "cheng-package.toml")
    os.writeFile(pkgManifestPath,
                 "package_id = \"pkg://cheng/strformat_negative_pkg\"\nmodule_prefix = \"strformat_negative_pkg\"\n")

    let compilerEnv = os.getEnv("CHENG_SMOKE_COMPILER")
    var compilerRaw = "artifacts/bootstrap/cheng.stage3"
    if len(compilerEnv) > 0:
        compilerRaw = compilerEnv
    var compiler = compilerRaw
    if !os.isAbsolute(compilerRaw):
        compiler = os.joinPath(root, compilerRaw)
    compiler = ownedText(compiler)
    assert(os.fileExists(compiler),
           " strformat export negative: compiler exists")

    let fmtSrc = os.joinPath(srcDir, "fmt_private_main.cheng")
    os.writeFile(fmtSrc,
                 "import std/strformat as strfmt\n\nfn main(): int32 =\n    let text = strfmt.fmt(\"bad\")\n    echo(text)\n    return 0\n")
    let fmtOutPath = os.joinPath(outDir, "fmt_private")
    let fmtLogPath = os.joinPath(outDir, "fmt_private.compile.log")
    var fmtOutput = ""
    let fmtExitCode = compileFixture(compiler,
                                     root,
                                     pkgRoot,
                                     fmtSrc,
                                     fmtOutPath,
                                     fmtLogPath,
                                     fmtOutput)
    assert(fmtExitCode != 0,
           " strformat export negative: lowercase fmt rejected")
    assert(strings.StrContains(fmtOutput,
                               "imported private symbol 'fmt' is not exported"),
           " strformat export negative: lowercase fmt diagnostic")

    let linesSrc = os.joinPath(srcDir, "lines_private_main.cheng")
    os.writeFile(linesSrc,
                 "import std/strformat as strfmt\n\nfn main(): int32 =\n    let text = strfmt.lines([\"a\", \"b\"])\n    echo(text)\n    return 0\n")
    let linesOutPath = os.joinPath(outDir, "lines_private")
    let linesLogPath = os.joinPath(outDir, "lines_private.compile.log")
    var linesOutput = ""
    let linesExitCode = compileFixture(compiler,
                                       root,
                                       pkgRoot,
                                       linesSrc,
                                       linesOutPath,
                                       linesLogPath,
                                       linesOutput)
    assert(linesExitCode != 0,
           " strformat export negative: lowercase lines rejected")
    assert(strings.StrContains(linesOutput,
                               "imported private symbol 'lines' is not exported"),
           " strformat export negative: lowercase lines diagnostic")

    echo(" strformat_export_negative_smoke ok")
    return 0
