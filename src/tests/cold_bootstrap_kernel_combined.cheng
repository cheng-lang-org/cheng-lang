type Result[T] = Ok(value: T) | Err(error: str)

type ScanState =
    pos: int32
    limit: int32
    ok: bool
    label: str
    values: int32[2]

type OutlineState =
    source: str
    pos: int32
    errors: int32

type StatementScan =
    source: str
    pos: int32
    lineStart: int32
    lineEnd: int32
    indent: int32
    tokenStart: int32
    payloadStart: int32
    payloadLen: int32
    kindCode: int32
    exprTokenCount: int32
    error: int32

type ExprTokenStore =
    tokenMeta: int32[96]
    tokenSpan: int32[96]
    count: int32
    error: int32

type FactSink =
    bytes: int32[]
    error: int32

type FactReader =
    bytes: int32[]
    pos: int32
    value: int32
    error: int32

type FactRecordView =
    fieldCount: int32
    kindCode: int32
    fieldHexStart: int32[8]
    fieldLen: int32[8]
    fieldInt: int32[8]
    fieldIsDecimal: int32[8]
    error: int32

type LayoutTable =
    fieldMeta: int32[96]
    fieldSpan: int32[96]
    objectCount: int32
    fieldCount: int32
    error: int32

type LayoutObjectCursor =
    index: int32
    fieldStart: int32
    fieldCount: int32
    size: int32
    align: int32

type WorkDeque =
    taskFn: int32[4]
    taskRange: int32[4]
    head: int32
    tail: int32
    error: int32

type PhaseArena =
    pageSize: int32
    used: int32
    pageCount: int32
    highWater: int32
    error: int32

fn FrontendIsIdentStart(ch: uint8): bool =
    return (ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z') || ch == '_'

fn FrontendIsIdentCont(ch: uint8): bool =
    return FrontendIsIdentStart(ch) || (ch >= '0' && ch <= '9')

fn FrontendIsSpace(ch: uint8): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn FrontendLineIndentWidth(line: str): int32 =
    var indent: int32 = 0
    for i in 0..<len(line):
        let ch: uint8 = line[i]
        if ch == ' ':
            indent = indent + 1
        elif ch == '\t':
            indent = indent + 4
        else:
            return indent
    return indent

fn FrontendTextIsFactSafe(text: str): bool =
    for i in 0..<len(text):
        let ch: uint8 = text[i]
        if ch == '\t' || ch == '\n' || ch == '\r':
            return false
    return true

fn FrontendIdentPrefixLen(text: str, start: int32): int32 =
    var pos: int32 = start
    if pos >= len(text):
        return 0
    if !FrontendIsIdentStart(text[pos]):
        return 0
    pos = pos + 1
    while pos < len(text) && FrontendIsIdentCont(text[pos]):
        pos = pos + 1
    return pos - start

fn FrontendFunctionNameLenFromLine(line: str): int32 =
    if len(line) < 3:
        return 0
    if line[0] != 'f' || line[1] != 'n' || line[2] != ' ':
        return 0
    var pos: int32 = 3
    while pos < len(line) && line[pos] == ' ':
        pos = pos + 1
    return FrontendIdentPrefixLen(line, pos)

fn FrontendSkipWhitespaceAndLineComments(source: str, start: int32): int32 =
    var pos: int32 = start
    while pos < len(source):
        let ch: uint8 = source[pos]
        if FrontendIsSpace(ch):
            pos = pos + 1
        elif ch == '/' && pos + 1 < len(source) && source[pos + 1] == '/':
            pos = pos + 2
            while pos < len(source) && source[pos] != '\n':
                pos = pos + 1
        else:
            return pos
    return pos

fn FrontendAdvance(state: var ScanState, amount: int32): int32 =
    state.pos = state.pos + amount
    state.ok = state.pos < state.limit && state.label[0] == 'c'
    state.label = "ok\n"
    state.values = [7, 8]
    if !state.ok:
        return 31
    return state.pos + state.values[1]

fn FrontendStateCheck(): int32 =
    var state: ScanState
    state.pos = 5
    state.limit = 10
    state.ok = false
    state.label = "cold"
    state.values = [1, 2]
    let score = FrontendAdvance(state, 4)
    if score != 17:
        return score
    if !state.ok:
        return 32
    if state.values[0] != 7:
        return 33
    if state.label[2] != '\n':
        return 34
    return 0

fn OutlineSkipLineComment(p: var OutlineState): int32 =
    while p.pos < len(p.source):
        let ch: uint8 = p.source[p.pos]
        p.pos = p.pos + 1
        if ch == '\n':
            return 0
    return 0

fn OutlineSkipBlockComment(p: var OutlineState): bool =
    if p.pos + 1 >= len(p.source) || p.source[p.pos] != '/' || p.source[p.pos + 1] != '*':
        return false
    p.pos = p.pos + 2
    while p.pos + 1 < len(p.source):
        if p.source[p.pos] == '*' && p.source[p.pos + 1] == '/':
            p.pos = p.pos + 2
            return true
        p.pos = p.pos + 1
    p.errors = p.errors + 1
    return false

fn OutlineSkipString(p: var OutlineState): bool =
    if p.pos >= len(p.source) || p.source[p.pos] != '"':
        return false
    p.pos = p.pos + 1
    while p.pos < len(p.source):
        let ch: uint8 = p.source[p.pos]
        if ch == '\\':
            p.pos = p.pos + 2
        elif ch == '"':
            p.pos = p.pos + 1
            return true
        else:
            p.pos = p.pos + 1
    p.errors = p.errors + 1
    return false

fn OutlineSkipCharLiteral(p: var OutlineState): bool =
    if p.pos >= len(p.source) || p.source[p.pos] != '\'':
        return false
    p.pos = p.pos + 1
    while p.pos < len(p.source):
        let ch: uint8 = p.source[p.pos]
        if ch == '\\':
            p.pos = p.pos + 2
        elif ch == '\'':
            p.pos = p.pos + 1
            return true
        else:
            p.pos = p.pos + 1
    p.errors = p.errors + 1
    return false

fn OutlineSkipToMatchingBrace(p: var OutlineState): bool =
    var depth: int32 = 1
    while p.pos < len(p.source) && depth > 0:
        let ch: uint8 = p.source[p.pos]
        if ch == '"':
            if OutlineSkipString(p) == false:
                return false
        elif ch == '\'':
            if OutlineSkipCharLiteral(p) == false:
                return false
        elif ch == '/' && p.pos + 1 < len(p.source):
            if p.source[p.pos + 1] == '/':
                OutlineSkipLineComment(p)
            elif p.source[p.pos + 1] == '*':
                if OutlineSkipBlockComment(p) == false:
                    return false
            else:
                p.pos = p.pos + 1
        elif ch == '{':
            depth = depth + 1
            p.pos = p.pos + 1
        elif ch == '}':
            depth = depth - 1
            p.pos = p.pos + 1
            if depth == 0:
                return true
        else:
            p.pos = p.pos + 1
    p.errors = p.errors + 1
    return false

fn OutlineSkipBalanced(p: var OutlineState, openCh: uint8, closeCh: uint8): bool =
    if p.pos >= len(p.source) || p.source[p.pos] != openCh:
        return false
    var depth: int32 = 1
    p.pos = p.pos + 1
    while p.pos < len(p.source) && depth > 0:
        let ch: uint8 = p.source[p.pos]
        if ch == '"':
            if OutlineSkipString(p) == false:
                return false
        elif ch == '\'':
            if OutlineSkipCharLiteral(p) == false:
                return false
        elif ch == '/' && p.pos + 1 < len(p.source):
            if p.source[p.pos + 1] == '/':
                OutlineSkipLineComment(p)
            elif p.source[p.pos + 1] == '*':
                if OutlineSkipBlockComment(p) == false:
                    return false
            else:
                p.pos = p.pos + 1
        elif ch == openCh:
            depth = depth + 1
            p.pos = p.pos + 1
        elif ch == closeCh:
            depth = depth - 1
            p.pos = p.pos + 1
            if depth == 0:
                return true
        else:
            p.pos = p.pos + 1
    p.errors = p.errors + 1
    return false

fn OutlineSkipToEquals(p: var OutlineState): bool =
    var depth: int32 = 0
    while p.pos < len(p.source):
        let ch: uint8 = p.source[p.pos]
        if ch == '"':
            if OutlineSkipString(p) == false:
                return false
        elif ch == '\'':
            if OutlineSkipCharLiteral(p) == false:
                return false
        elif ch == '/' && p.pos + 1 < len(p.source):
            if p.source[p.pos + 1] == '/':
                OutlineSkipLineComment(p)
            elif p.source[p.pos + 1] == '*':
                if OutlineSkipBlockComment(p) == false:
                    return false
            else:
                p.pos = p.pos + 1
        elif ch == '(' || ch == '[' || ch == '{':
            depth = depth + 1
            p.pos = p.pos + 1
        elif ch == ')' || ch == ']' || ch == '}':
            if depth > 0:
                depth = depth - 1
            p.pos = p.pos + 1
        elif ch == '=' && depth == 0:
            return true
        else:
            p.pos = p.pos + 1
    return false

fn OutlineCheck(): int32 =
    var brace: OutlineState
    brace.source = "{ let text = \"}\" /* ignore } */ { let c = '\\'' } } tail"
    brace.pos = 1
    if OutlineSkipToMatchingBrace(brace) == false:
        return 41
    if brace.pos != 50:
        return brace.pos
    if brace.errors != 0:
        return 42

    var balanced: OutlineState
    balanced.source = "[A[B] /* [ ] */ \"[\" ']'] rest"
    balanced.pos = 0
    if OutlineSkipBalanced(balanced, '[', ']') == false:
        return 43
    if balanced.pos != 24:
        return balanced.pos + 40

    var equals: OutlineState
    equals.source = "fn Foo(x: Result[int32]) /* skip = */: int32 = body"
    equals.pos = 0
    if OutlineSkipToEquals(equals) == false:
        return 44
    if equals.pos != 45:
        return equals.pos + 50

    /* source->CSG must erase this block comment before statement parsing */
    if 1 + 2 != 3:
        return 45
    return 0

fn StatementLineEnd(source: str, start: int32): int32 =
    var pos: int32 = start
    while pos < len(source) && source[pos] != '\n':
        pos = pos + 1
    return pos

fn StatementTrimRight(source: str, start: int32, endPos: int32): int32 =
    var end: int32 = endPos
    while end > start:
        let ch: uint8 = source[end - 1]
        if ch == ' ' || ch == '\t' || ch == '\r':
            end = end - 1
        else:
            return end
    return end

fn StatementSkipInlineSpace(source: str, start: int32, endPos: int32): int32 =
    var pos: int32 = start
    while pos < endPos && (source[pos] == ' ' || source[pos] == '\t'):
        pos = pos + 1
    return pos

fn StatementKeywordAt(source: str, start: int32, endPos: int32, word: str): bool =
    if start + len(word) > endPos:
        return false
    for i in 0..<len(word):
        if source[start + i] != word[i]:
            return false
    let after: int32 = start + len(word)
    if after >= endPos:
        return true
    return !FrontendIsIdentCont(source[after])

fn StatementContainsArrow(source: str, start: int32, endPos: int32): bool =
    var pos: int32 = start
    while pos + 1 < endPos:
        if source[pos] == '=' && source[pos + 1] == '>':
            return true
        pos = pos + 1
    return false

fn StatementSetPayload(scan: var StatementScan, start: int32, endPos: int32): int32 =
    scan.payloadStart = StatementSkipInlineSpace(scan.source, start, endPos)
    scan.payloadLen = endPos - scan.payloadStart
    return scan.payloadLen

fn StatementClassifyLine(scan: var StatementScan): bool =
    if scan.pos > len(scan.source):
        scan.error = 151
        return false
    scan.lineStart = scan.pos
    scan.lineEnd = StatementLineEnd(scan.source, scan.pos)
    scan.indent = 0
    scan.kindCode = 0
    scan.payloadStart = scan.lineEnd
    scan.payloadLen = 0
    scan.exprTokenCount = 0

    var start: int32 = scan.lineStart
    while start < scan.lineEnd && (scan.source[start] == ' ' || scan.source[start] == '\t'):
        if scan.source[start] == '\t':
            scan.indent = scan.indent + 4
        else:
            scan.indent = scan.indent + 1
        start = start + 1
    scan.tokenStart = start
    let endPos: int32 = StatementTrimRight(scan.source, start, scan.lineEnd)
    if start >= endPos:
        return true
    if start + 1 < endPos && scan.source[start] == '/' && scan.source[start + 1] == '/':
        return true

    if StatementKeywordAt(scan.source, start, endPos, "let"):
        scan.kindCode = 1
        StatementSetPayload(scan, start + 3, endPos)
        scan.exprTokenCount = StatementScanExprTokens(scan.source,
                                                       scan.payloadStart,
                                                       scan.payloadStart + scan.payloadLen)
    elif StatementKeywordAt(scan.source, start, endPos, "return"):
        scan.kindCode = 2
        StatementSetPayload(scan, start + 6, endPos)
    elif StatementKeywordAt(scan.source, start, endPos, "if"):
        scan.kindCode = 3
        StatementSetPayload(scan, start + 2, endPos)
    elif StatementKeywordAt(scan.source, start, endPos, "elif"):
        scan.kindCode = 4
        StatementSetPayload(scan, start + 4, endPos)
    elif StatementKeywordAt(scan.source, start, endPos, "else"):
        scan.kindCode = 5
        scan.payloadStart = endPos
        scan.payloadLen = 0
    elif StatementKeywordAt(scan.source, start, endPos, "match"):
        scan.kindCode = 6
        StatementSetPayload(scan, start + 5, endPos)
    elif StatementKeywordAt(scan.source, start, endPos, "case"):
        scan.kindCode = 7
        StatementSetPayload(scan, start + 4, endPos)
    elif StatementContainsArrow(scan.source, start, endPos):
        scan.kindCode = 7
        scan.payloadStart = start
        scan.payloadLen = endPos - start
    elif StatementKeywordAt(scan.source, start, endPos, "var"):
        scan.kindCode = 8
        StatementSetPayload(scan, start + 3, endPos)
    else:
        scan.kindCode = 9
        scan.payloadStart = start
        scan.payloadLen = endPos - start
    if scan.payloadLen > 0 && scan.kindCode != 5:
        scan.exprTokenCount = StatementScanExprTokens(scan.source,
                                                       scan.payloadStart,
                                                       scan.payloadStart + scan.payloadLen)
    return true

fn StatementScanExprTokens(source: str, start: int32, endPos: int32): int32 =
    if start >= endPos:
        return 0
    let count: int32 = ExprScanSpanCountOnly(source, start, endPos)
    if count < 0:
        return count
    return count

fn StatementAdvance(scan: var StatementScan): int32 =
    scan.pos = scan.lineEnd
    if scan.pos < len(scan.source) && scan.source[scan.pos] == '\n':
        scan.pos = scan.pos + 1
    return scan.pos

fn StatementScanChecksum(source: str): int32 =
    var scan: StatementScan
    scan.source = source
    var statementCount: int32 = 0
    var checksum: int32 = 0
    while scan.pos < len(source):
        if StatementClassifyLine(scan) == false:
            return 0 - scan.error
        if scan.kindCode != 0:
            statementCount = statementCount + 1
            let kindScore: int32 = scan.kindCode * 17
            let lineScore: int32 = kindScore + scan.indent + scan.payloadLen
            checksum = checksum + lineScore
        StatementAdvance(scan)
    let countScore: int32 = statementCount * 1000
    return countScore + checksum

fn StatementCheck(): int32 =
    let observed: int32 = StatementScanChecksum("    let value = FactReadByte(reader)\n    if value != expected:\n        return 13\n    elif value == 7:\n        return 14\n    else:\n        return 15\n    match result:\n        case Ok(value): return value\n    var next = value\n")
    if observed < 10000 || observed > 20000:
        return 152

    var line: StatementScan
    line.source = "        case Ok(value): return value\n"
    if StatementClassifyLine(line) == false:
        return 153
    if line.kindCode != 7:
        return 154
    if line.indent != 8:
        return 155
    if line.payloadStart != 13:
        return 156
    if line.payloadLen != 23:
        return 157
    if line.exprTokenCount <= 0:
        return 160

    var blank: StatementScan
    blank.source = "    \n"
    if StatementClassifyLine(blank) == false:
        return 158
    if blank.kindCode != 0:
        return 159
    if blank.exprTokenCount != 0:
        return 161
    return 0

fn StatementExprCheck(): int32 =
    var scan: StatementScan
    scan.source = "    let x = a + b\n    return x\n    if x > 7:\n        return 1\n"
    scan.pos = 0
    if StatementClassifyLine(scan) == false:
        return 171
    if scan.kindCode != 1:
        return 172
    if scan.exprTokenCount <= 0:
        return 173
    StatementAdvance(scan)
    if StatementClassifyLine(scan) == false:
        return 174
    if scan.kindCode != 2:
        return 175
    StatementAdvance(scan)
    if StatementClassifyLine(scan) == false:
        return 177
    if scan.kindCode != 3:
        return 178
    StatementAdvance(scan)
    if StatementClassifyLine(scan) == false:
        return 181
    if scan.kindCode != 2:
        return 182
    return 0

fn ExprIsDigit(ch: uint8): bool =
    return ch >= '0' && ch <= '9'

fn ExprIsSpace(ch: uint8): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn ExprIsTwoCharOp(source: str, pos: int32): bool =
    if pos + 1 >= len(source):
        return false
    let a: uint8 = source[pos]
    let b: uint8 = source[pos + 1]
    if a == '=' && b == '=':
        return true
    if a == '!' && b == '=':
        return true
    if a == '<' && b == '=':
        return true
    if a == '>' && b == '=':
        return true
    if a == '&' && b == '&':
        return true
    if a == '|' && b == '|':
        return true
    if a == '<' && b == '<':
        return true
    if a == '>' && b == '>':
        return true
    return false

fn ExprSkipStringLiteral(source: str, start: int32): int32 =
    var pos: int32 = start + 1
    while pos < len(source):
        let ch: uint8 = source[pos]
        if ch == '\\':
            pos = pos + 2
        elif ch == '"':
            return pos + 1
        else:
            pos = pos + 1
    return len(source)

fn ExprSkipCharLiteral(source: str, start: int32): int32 =
    var pos: int32 = start + 1
    while pos < len(source):
        let ch: uint8 = source[pos]
        if ch == '\\':
            pos = pos + 2
        elif ch == '\'':
            return pos + 1
        else:
            pos = pos + 1
    return len(source)

fn ExprSkipIdent(source: str, start: int32): int32 =
    var pos: int32 = start
    if pos < len(source) && FrontendIsIdentStart(source[pos]):
        pos = pos + 1
    while pos < len(source) && FrontendIsIdentCont(source[pos]):
        pos = pos + 1
    return pos

fn ExprSkipNumber(source: str, start: int32): int32 =
    var pos: int32 = start
    while pos < len(source) && ExprIsDigit(source[pos]):
        pos = pos + 1
    return pos

fn ExprTokenKindAt(store: var ExprTokenStore, index: int32): int32 =
    return store.tokenMeta[index] / 100

fn ExprTokenDepthAt(store: var ExprTokenStore, index: int32): int32 =
    return store.tokenMeta[index] % 100

fn ExprTokenStartAt(store: var ExprTokenStore, index: int32): int32 =
    return store.tokenSpan[index] / 128

fn ExprTokenLenAt(store: var ExprTokenStore, index: int32): int32 =
    return store.tokenSpan[index] % 128

fn ExprTokenAdd(store: var ExprTokenStore, kind: int32,
                start: int32, tokenLen: int32, depth: int32): int32 =
    if store.count >= store.tokenMeta.len:
        store.error = 201
        return store.error
    if tokenLen < 0 || tokenLen >= 128:
        store.error = 204
        return store.error
    let index: int32 = store.count
    store.tokenMeta[index] = kind * 100 + depth
    store.tokenSpan[index] = start * 128 + tokenLen
    store.count = store.count + 1
    return 0

fn ExprScanIntoStore(source: str, store: var ExprTokenStore): int32 =
    var pos: int32 = 0
    var depth: int32 = 0
    while pos < len(source):
        let ch: uint8 = source[pos]
        if ExprIsSpace(ch):
            pos = pos + 1
        elif FrontendIsIdentStart(ch):
            let endPos: int32 = ExprSkipIdent(source, pos)
            let addResult: int32 = ExprTokenAdd(store, 1, pos, endPos - pos, depth)
            if addResult != 0:
                return addResult
            pos = endPos
        elif ExprIsDigit(ch):
            let endPos: int32 = ExprSkipNumber(source, pos)
            let addResult: int32 = ExprTokenAdd(store, 2, pos, endPos - pos, depth)
            if addResult != 0:
                return addResult
            pos = endPos
        elif ch == '"':
            let endPos: int32 = ExprSkipStringLiteral(source, pos)
            let addResult: int32 = ExprTokenAdd(store, 3, pos, endPos - pos, depth)
            if addResult != 0:
                return addResult
            pos = endPos
        elif ch == '\'':
            let endPos: int32 = ExprSkipCharLiteral(source, pos)
            let addResult: int32 = ExprTokenAdd(store, 4, pos, endPos - pos, depth)
            if addResult != 0:
                return addResult
            pos = endPos
        elif ch == '(' || ch == '[':
            let nextDepth: int32 = depth + 1
            let addResult: int32 = ExprTokenAdd(store, 5, pos, 1, nextDepth)
            if addResult != 0:
                return addResult
            depth = nextDepth
            pos = pos + 1
        elif ch == ')' || ch == ']':
            if depth <= 0:
                store.error = 202
                return store.error
            let addResult: int32 = ExprTokenAdd(store, 6, pos, 1, depth)
            if addResult != 0:
                return addResult
            depth = depth - 1
            pos = pos + 1
        elif ExprIsTwoCharOp(source, pos):
            let addResult: int32 = ExprTokenAdd(store, 7, pos, 2, depth)
            if addResult != 0:
                return addResult
            pos = pos + 2
        else:
            let addResult: int32 = ExprTokenAdd(store, 7, pos, 1, depth)
            if addResult != 0:
                return addResult
            pos = pos + 1
    if depth != 0:
        store.error = 203
        return store.error
    return 0

fn ExprScanSpanIntoStore(source: str, start: int32, endPos: int32,
                          store: var ExprTokenStore): int32 =
    if start < 0 || endPos > len(source) || start >= endPos:
        return 0
    var pos: int32 = start
    var depth: int32 = 0
    while pos < endPos:
        let ch: uint8 = source[pos]
        if ExprIsSpace(ch):
            pos = pos + 1
        elif FrontendIsIdentStart(ch):
            let idEnd: int32 = ExprSkipIdent(source, pos)
            if idEnd > endPos:
                return 221
            let addResult: int32 = ExprTokenAdd(store, 1, pos, idEnd - pos, depth)
            if addResult != 0:
                return addResult
            pos = idEnd
        elif ExprIsDigit(ch):
            let numEnd: int32 = ExprSkipNumber(source, pos)
            if numEnd > endPos:
                return 222
            let addResult: int32 = ExprTokenAdd(store, 2, pos, numEnd - pos, depth)
            if addResult != 0:
                return addResult
            pos = numEnd
        elif ch == '(' || ch == '[':
            let nextDepth: int32 = depth + 1
            let addResult: int32 = ExprTokenAdd(store, 5, pos, 1, nextDepth)
            if addResult != 0:
                return addResult
            depth = nextDepth
            pos = pos + 1
        elif ch == ')' || ch == ']':
            if depth <= 0:
                return 202
            let addResult: int32 = ExprTokenAdd(store, 6, pos, 1, depth)
            if addResult != 0:
                return addResult
            depth = depth - 1
            pos = pos + 1
        elif ExprIsTwoCharOp(source, pos):
            let addResult: int32 = ExprTokenAdd(store, 7, pos, 2, depth)
            if addResult != 0:
                return addResult
            pos = pos + 2
        else:
            let addResult: int32 = ExprTokenAdd(store, 7, pos, 1, depth)
            if addResult != 0:
                return addResult
            pos = pos + 1
    if depth != 0:
        return 203
    return 0

fn ExprScanSpanCountOnly(source: str, start: int32, endPos: int32): int32 =
    if start < 0 || endPos > len(source) || start >= endPos:
        return 0
    var pos: int32 = start
    var depth: int32 = 0
    var count: int32 = 0
    while pos < endPos:
        let ch: uint8 = source[pos]
        if ExprIsSpace(ch):
            pos = pos + 1
        elif FrontendIsIdentStart(ch):
            let idEnd: int32 = ExprSkipIdent(source, pos)
            if idEnd > endPos:
                return 0 - 221
            count = count + 1
            pos = idEnd
        elif ExprIsDigit(ch):
            let numEnd: int32 = ExprSkipNumber(source, pos)
            if numEnd > endPos:
                return 0 - 222
            count = count + 1
            pos = numEnd
        elif ch == '(' || ch == '[':
            depth = depth + 1
            count = count + 1
            pos = pos + 1
        elif ch == ')' || ch == ']':
            if depth <= 0:
                return 0 - 202
            count = count + 1
            depth = depth - 1
            pos = pos + 1
        elif ExprIsTwoCharOp(source, pos):
            count = count + 1
            pos = pos + 2
        else:
            count = count + 1
            pos = pos + 1
    if depth != 0:
        return 0 - 203
    return count

fn ExprStoreChecksum(store: var ExprTokenStore): int32 =
    var checksum: int32 = 0
    for i in 0..<store.count:
        let kindScore: int32 = ExprTokenKindAt(store, i) * 19
        let spanScore: int32 = ExprTokenStartAt(store, i) + ExprTokenLenAt(store, i)
        let lineScore: int32 = kindScore + spanScore + ExprTokenDepthAt(store, i)
        checksum = checksum + lineScore
    return store.count * 1000 + checksum

fn ExprCheck(): int32 =
    var store: ExprTokenStore
    let scanResult: int32 = ExprScanIntoStore("value + Call(7, items[2]) * len(text) - flag", store)
    if scanResult != 0:
        return 210 + scanResult
    if store.count != 18:
        return 211
    if ExprTokenKindAt(store, 0) != 1 || ExprTokenLenAt(store, 0) != 5:
        return 212
    if ExprTokenKindAt(store, 3) != 5 || ExprTokenDepthAt(store, 3) != 1:
        return 213
    if ExprTokenKindAt(store, 7) != 5 || ExprTokenDepthAt(store, 7) != 2:
        return 214
    if ExprTokenKindAt(store, 9) != 6 || ExprTokenDepthAt(store, 9) != 2:
        return 215
    if ExprStoreChecksum(store) != 19790:
        return 216

    var literalStore: ExprTokenStore
    let literalResult: int32 = ExprScanIntoStore("text[0] != '\\n' && len(name) >= 3", literalStore)
    if literalResult != 0:
        return 220 + literalResult
    if literalStore.count != 13:
        return 217
    if ExprTokenKindAt(literalStore, 5) != 4:
        return 218
    if ExprTokenKindAt(literalStore, 6) != 7 || ExprTokenLenAt(literalStore, 6) != 2:
        return 219
    return 0

fn LayoutAlignUp(value: int32, align: int32): int32 =
    if align <= 1:
        return value
    let adjusted: int32 = value + align - 1
    return (adjusted / align) * align

fn LayoutKindSize(kind: int32): int32 =
    if kind == 1:
        return 4
    if kind == 2:
        return 4
    if kind == 3:
        return 16
    if kind == 4:
        return 16
    if kind == 5:
        return 16
    if kind == 6:
        return 24
    return -1

fn LayoutKindAlign(kind: int32): int32 =
    let size: int32 = LayoutKindSize(kind)
    if size < 0:
        return -1
    if size >= 8:
        return 8
    return 4

fn LayoutFieldOwner(table: var LayoutTable, fieldIndex: int32): int32 =
    return table.fieldMeta[fieldIndex] / 16

fn LayoutFieldKind(table: var LayoutTable, fieldIndex: int32): int32 =
    let owner: int32 = table.fieldMeta[fieldIndex] / 16
    return table.fieldMeta[fieldIndex] - owner * 16

fn LayoutBeginObject(table: var LayoutTable, object: var LayoutObjectCursor): int32 =
    let index: int32 = table.objectCount
    object.index = index
    object.fieldStart = table.fieldCount
    object.fieldCount = 0
    object.size = 0
    object.align = 1
    table.objectCount = table.objectCount + 1
    return index

fn LayoutAddField(table: var LayoutTable, object: var LayoutObjectCursor, kind: int32): int32 =
    if object.index < 0 || object.index >= table.objectCount:
        table.error = 302
        return -1
    if table.fieldCount >= table.fieldMeta.len:
        table.error = 303
        return -1
    let size: int32 = LayoutKindSize(kind)
    let align: int32 = LayoutKindAlign(kind)
    if size <= 0 || align <= 0:
        table.error = 304
        return -1
    let offset: int32 = LayoutAlignUp(object.size, align)
    let fieldIndex: int32 = table.fieldCount
    table.fieldMeta[fieldIndex] = object.index * 16 + kind
    table.fieldSpan[fieldIndex] = offset
    table.fieldCount = table.fieldCount + 1
    object.fieldCount = object.fieldCount + 1
    object.size = offset + size
    if align > object.align:
        object.align = align
    return fieldIndex

fn LayoutFinalizeObject(table: var LayoutTable, object: var LayoutObjectCursor): int32 =
    if object.index < 0 || object.index >= table.objectCount:
        table.error = 305
        return -1
    object.size = LayoutAlignUp(object.size, object.align)
    return object.size

fn LayoutFieldOffset(table: var LayoutTable, fieldIndex: int32): int32 =
    if fieldIndex < 0 || fieldIndex >= table.fieldCount:
        return -1
    return table.fieldSpan[fieldIndex]

fn LayoutFieldSize(table: var LayoutTable, fieldIndex: int32): int32 =
    if fieldIndex < 0 || fieldIndex >= table.fieldCount:
        return -1
    return LayoutKindSize(LayoutFieldKind(table, fieldIndex))

fn LayoutChecksum(table: var LayoutTable, a: var LayoutObjectCursor,
                  b: var LayoutObjectCursor): int32 =
    var checksum: int32 = 0
    checksum = checksum + a.size + a.align * 7 + a.fieldCount * 11
    checksum = checksum + b.size + b.align * 7 + b.fieldCount * 11
    for i in 0..<table.fieldCount:
        let indexScore: int32 = i * 17
        checksum = checksum + indexScore + LayoutFieldOffset(table, i)
    return table.objectCount * 1000 + table.fieldCount * 100 + checksum

fn LayoutCheck(): int32 =
    var table: LayoutTable
    var objectAState: LayoutObjectCursor
    let objectA: int32 = LayoutBeginObject(table, objectAState)
    if objectA != 0:
        return 320
    let a0: int32 = LayoutAddField(table, objectAState, 1)
    let a1: int32 = LayoutAddField(table, objectAState, 3)
    let a2: int32 = LayoutAddField(table, objectAState, 4)
    let a3: int32 = LayoutAddField(table, objectAState, 5)
    if a0 != 0 || a1 != 1 || a2 != 2 || a3 != 3:
        return 321
    let sizeA: int32 = LayoutFinalizeObject(table, objectAState)
    if sizeA != 56:
        return 322
    if LayoutFieldOffset(table, a0) != 0:
        return 323
    if LayoutFieldOffset(table, a1) != 8:
        return 324
    if LayoutFieldOffset(table, a2) != 24:
        return 325
    if LayoutFieldOffset(table, a3) != 40:
        return 326

    var objectBState: LayoutObjectCursor
    let objectB: int32 = LayoutBeginObject(table, objectBState)
    if objectB != 1:
        return 327
    let b0: int32 = LayoutAddField(table, objectBState, 2)
    let b1: int32 = LayoutAddField(table, objectBState, 1)
    if b0 != 4 || b1 != 5:
        return 328
    if LayoutFinalizeObject(table, objectBState) != 8:
        return 329
    if LayoutFieldOffset(table, b0) != 0:
        return 330
    if LayoutFieldOffset(table, b1) != 4:
        return 331
    if table.fieldCount != 6:
        return 334
    return 0

fn WorkDequeReset(queue: var WorkDeque): int32 =
    queue.head = 0
    queue.tail = 0
    queue.error = 0
    for i in 0..<4:
        queue.taskFn[i] = 0
        queue.taskRange[i] = 0
    return 0

fn WorkDequeLen(queue: var WorkDeque): int32 =
    return queue.tail - queue.head

fn WorkDequeCapacity(): int32 =
    return 4

fn WorkDequeSetSlot(queue: var WorkDeque, slot: int32,
                    fnIndex: int32, range: int32): int32 =
    if slot < 0 || slot >= WorkDequeCapacity():
        queue.error = 403
        return queue.error
    queue.taskFn[slot] = fnIndex
    queue.taskRange[slot] = range
    return 0

fn WorkDequeSlotFn(queue: var WorkDeque, slot: int32): int32 =
    if slot < 0 || slot >= WorkDequeCapacity():
        return -1
    return queue.taskFn[slot]

fn WorkDequeSlotRange(queue: var WorkDeque, slot: int32): int32 =
    if slot < 0 || slot >= WorkDequeCapacity():
        return -1
    return queue.taskRange[slot]

fn WorkDequeTaskChecksum(queue: var WorkDeque, slot: int32): int32 =
    let range: int32 = WorkDequeSlotRange(queue, slot)
    let start: int32 = range / 100
    let endPos: int32 = range - start * 100
    let fnIndex: int32 = WorkDequeSlotFn(queue, slot)
    return fnIndex + start + endPos

fn WorkDequePush(queue: var WorkDeque, fnIndex: int32, start: int32, endPos: int32): int32 =
    if WorkDequeLen(queue) >= WorkDequeCapacity():
        queue.error = 401
        return queue.error
    let slot: int32 = queue.tail % WorkDequeCapacity()
    let setResult: int32 = WorkDequeSetSlot(queue, slot, fnIndex, start * 100 + endPos)
    if setResult != 0:
        return setResult
    queue.tail = queue.tail + 1
    return 0

fn WorkDequeCasHead(queue: var WorkDeque, expected: int32, desired: int32): bool =
    if queue.head != expected:
        return false
    queue.head = desired
    return true

fn WorkDequePopLocal(queue: var WorkDeque): int32 =
    if queue.tail <= queue.head:
        return -1
    queue.tail = queue.tail - 1
    let slot: int32 = queue.tail % WorkDequeCapacity()
    return WorkDequeTaskChecksum(queue, slot)

fn WorkDequeSteal(queue: var WorkDeque): int32 =
    let observedHead: int32 = queue.head
    if observedHead >= queue.tail:
        return -1
    let slot: int32 = observedHead % WorkDequeCapacity()
    let checksum: int32 = WorkDequeTaskChecksum(queue, slot)
    if WorkDequeCasHead(queue, observedHead, observedHead + 1) == false:
        queue.error = 402
        return -1
    return checksum

fn WorkDequeDrainChecksum(queue: var WorkDeque): int32 =
    var checksum: int32 = 0
    var stealCount: int32 = 0
    while WorkDequeLen(queue) > 1:
        let stolen: int32 = WorkDequeSteal(queue)
        if stolen < 0:
            return -1
        checksum = checksum + stolen * 3
        stealCount = stealCount + 1
    while WorkDequeLen(queue) > 0:
        let local: int32 = WorkDequePopLocal(queue)
        if local < 0:
            return -2
        checksum = checksum + local * 5
    return checksum + stealCount * 1000

fn WorkDequeCheck(): int32 =
    var queue: WorkDeque
    if WorkDequeReset(queue) != 0:
        return 409
    if WorkDequePush(queue, 1, 0, 4) != 0:
        return 410
    if WorkDequePush(queue, 2, 4, 8) != 0:
        return 411
    if WorkDequePush(queue, 3, 8, 12) != 0:
        return 412
    if WorkDequePush(queue, 4, 12, 20) != 0:
        return 413
    if WorkDequeLen(queue) != 4:
        return 414
    if queue.head != 0:
        return 442
    if queue.tail != 4:
        return 443
    if WorkDequeSlotFn(queue, 0) != 1:
        return 440
    if WorkDequeSlotRange(queue, 0) != 4:
        return 441
    if WorkDequeTaskChecksum(queue, 0) != 5:
        return 444
    if WorkDequeSlotFn(queue, 2) != 3:
        return 415
    if WorkDequeSlotRange(queue, 3) != 1220:
        return 416
    let stolen0: int32 = WorkDequeSteal(queue)
    if stolen0 != 5:
        return 430
    let stolen1: int32 = WorkDequeSteal(queue)
    if stolen1 != 14:
        return 431
    let stolen2: int32 = WorkDequeSteal(queue)
    if stolen2 != 23:
        return 432
    let local0: int32 = WorkDequePopLocal(queue)
    if local0 != 36:
        return 433
    if queue.head != 3:
        return 417
    if queue.tail != 3:
        return 418
    if queue.error != 0:
        return 419
    let overflow: int32 = WorkDequePush(queue, 9, 0, 1)
    if overflow != 0:
        return 420
    if WorkDequePush(queue, 10, 1, 2) != 0:
        return 421
    if WorkDequeLen(queue) != 2:
        return 422
    let local: int32 = WorkDequePopLocal(queue)
    if local != 13:
        return 423
    let stolen: int32 = WorkDequeSteal(queue)
    if stolen != 10:
        return 424
    if WorkDequeLen(queue) != 0:
        return 425
    return 0

fn PhaseArenaAlignUp(value: int32, align: int32): int32 =
    if align <= 1:
        return value
    let adjusted: int32 = value + align - 1
    return (adjusted / align) * align

fn PhaseArenaInit(arena: var PhaseArena, pageSize: int32): int32 =
    if pageSize <= 0:
        arena.error = 501
        return arena.error
    arena.pageSize = pageSize
    arena.used = 0
    arena.pageCount = 1
    arena.highWater = 0
    arena.error = 0
    return 0

fn PhaseArenaAlloc(arena: var PhaseArena, size: int32, align: int32): int32 =
    if size <= 0 || align <= 0:
        arena.error = 502
        return -1
    let offset: int32 = PhaseArenaAlignUp(arena.used, align)
    let endPos: int32 = offset + size
    if endPos > arena.pageSize:
        arena.pageCount = arena.pageCount + 1
        arena.used = size
        if arena.used > arena.highWater:
            arena.highWater = arena.used
        return 0
    arena.used = endPos
    if arena.used > arena.highWater:
        arena.highWater = arena.used
    return offset

fn PhaseArenaReset(arena: var PhaseArena): int32 =
    arena.used = 0
    arena.pageCount = 0
    return 0

fn PhaseArenaCheck(): int32 =
    var arena: PhaseArena
    if PhaseArenaInit(arena, 32) != 0:
        return 520
    if PhaseArenaAlloc(arena, 7, 4) != 0:
        return 521
    if PhaseArenaAlloc(arena, 9, 8) != 8:
        return 522
    if PhaseArenaAlloc(arena, 20, 8) != 0:
        return 523
    if arena.pageCount != 2:
        return 524
    if arena.highWater != 20:
        return 525
    PhaseArenaReset(arena)
    if arena.used != 0 || arena.pageCount != 0:
        return 526
    return 0

fn FactAddByte(sink: var FactSink, value: int32): int32 =
    if value < 0 || value > 255:
        sink.error = 1
        return 1
    add(sink.bytes, value)
    return 0

fn FactAddText(sink: var FactSink, text: str): int32 =
    for i in 0..<len(text):
        if FactAddByte(sink, text[i]) != 0:
            return sink.error
    return 0

fn FactHexDigit(value: int32): int32 =
    if value < 0 || value > 15:
        return -1
    if value < 10:
        return '0' + value
    return 'a' + value - 10

fn FactHexValue(ch: int32): int32 =
    if ch >= '0' && ch <= '9':
        return ch - '0'
    if ch >= 'a' && ch <= 'f':
        return ch - 'a' + 10
    if ch >= 'A' && ch <= 'F':
        return ch - 'A' + 10
    return -1

fn FactAddDecimal(sink: var FactSink, value: int32): int32 =
    if value < 0:
        sink.error = 2
        return sink.error
    var digits: int32[10]
    var count: int32 = 0
    var n: int32 = value
    if n == 0:
        return FactAddByte(sink, '0')
    while n > 0:
        if count >= digits.len:
            sink.error = 3
            return sink.error
        digits[count] = n % 10
        count = count + 1
        n = n / 10
    for i in 0..<count:
        let index: int32 = count - 1 - i
        if FactAddByte(sink, '0' + digits[index]) != 0:
            return sink.error
    return 0

fn FactAddHexField(sink: var FactSink, text: str): int32 =
    if FactAddDecimal(sink, len(text)) != 0:
        return sink.error
    if FactAddByte(sink, ':') != 0:
        return sink.error
    for i in 0..<len(text):
        if FactAddHexByte(sink, text[i]) != 0:
            return sink.error
    return 0

fn FactAddHexByte(sink: var FactSink, byte: int32): int32 =
    let hi: int32 = FactHexDigit((byte >> 4) & 15)
    let lo: int32 = FactHexDigit(byte & 15)
    if hi < 0 || lo < 0:
        sink.error = 4
        return sink.error
    if FactAddByte(sink, hi) != 0:
        return sink.error
    if FactAddByte(sink, lo) != 0:
        return sink.error
    return 0

fn FactWriteVersion2(sink: var FactSink): int32 =
    return FactAddText(sink, "cold_csg_version=2\n")

fn FactWriteRecordBegin(sink: var FactSink, fieldCount: int32): int32 =
    if fieldCount <= 0 || fieldCount > 8:
        sink.error = 5
        return sink.error
    if FactAddText(sink, "cold_csg_record") != 0:
        return sink.error
    if FactAddByte(sink, '\t') != 0:
        return sink.error
    if FactAddDecimal(sink, fieldCount) != 0:
        return sink.error
    return 0

fn FactWriteRecordField(sink: var FactSink, text: str): int32 =
    if FactAddByte(sink, '\t') != 0:
        return sink.error
    return FactAddHexField(sink, text)

fn FactDecimalDigitCount(value: int32): int32 =
    if value < 0:
        return -1
    if value == 0:
        return 1
    var n: int32 = value
    var count: int32 = 0
    while n > 0:
        count = count + 1
        n = n / 10
    return count

fn FactWriteIntField(sink: var FactSink, value: int32): int32 =
    if value < 0:
        sink.error = 30
        return sink.error
    let digitCount: int32 = FactDecimalDigitCount(value)
    if digitCount <= 0:
        sink.error = 31
        return sink.error
    if FactAddByte(sink, '\t') != 0:
        return sink.error
    if FactAddDecimal(sink, digitCount) != 0:
        return sink.error
    if FactAddByte(sink, ':') != 0:
        return sink.error
    if value == 0:
        return FactAddHexByte(sink, '0')

    var digits: int32[10]
    var count: int32 = 0
    var n: int32 = value
    while n > 0:
        if count >= digits.len:
            sink.error = 32
            return sink.error
        digits[count] = n % 10
        count = count + 1
        n = n / 10
    for i in 0..<count:
        let index: int32 = count - 1 - i
        if FactAddHexByte(sink, '0' + digits[index]) != 0:
            return sink.error
    return 0

fn FactWriteRecordEnd(sink: var FactSink): int32 =
    return FactAddByte(sink, '\n')

fn FactArgLen(text: str): int32 =
    return len(text)

fn FactWriteRecord2(sink: var FactSink, a: str, b: str): int32 =
    if FactWriteRecordBegin(sink, 2) != 0:
        return sink.error
    if FactWriteRecordField(sink, a) != 0:
        return sink.error
    if FactWriteRecordField(sink, b) != 0:
        return sink.error
    return FactWriteRecordEnd(sink)

fn FactWriteRecord3(sink: var FactSink, a: str, b: str, c: str): int32 =
    if FactWriteRecordBegin(sink, 3) != 0:
        return sink.error
    if FactWriteRecordField(sink, a) != 0:
        return sink.error
    if FactWriteRecordField(sink, b) != 0:
        return sink.error
    if FactWriteRecordField(sink, c) != 0:
        return sink.error
    return FactWriteRecordEnd(sink)

fn FactWriteStatementRecord(sink: var FactSink, fnName: str, kindCode: int32,
                            indent: int32, payloadStart: int32, payloadLen: int32): int32 =
    if FactWriteRecordBegin(sink, 6) != 0:
        return sink.error
    if FactWriteRecordField(sink, "cold_csg_stmt") != 0:
        return sink.error
    if FactWriteRecordField(sink, fnName) != 0:
        return sink.error
    if FactWriteIntField(sink, kindCode) != 0:
        return sink.error
    if FactWriteIntField(sink, indent) != 0:
        return sink.error
    if FactWriteIntField(sink, payloadStart) != 0:
        return sink.error
    if FactWriteIntField(sink, payloadLen) != 0:
        return sink.error
    return FactWriteRecordEnd(sink)

fn StatementWriteFacts(sink: var FactSink, fnName: str, source: str): int32 =
    var scan: StatementScan
    scan.source = source
    while scan.pos < len(source):
        if StatementClassifyLine(scan) == false:
            sink.error = 33
            return sink.error
        if scan.kindCode != 0:
            let writeResult: int32 = FactWriteStatementRecord(sink, fnName, scan.kindCode, scan.indent, scan.payloadStart, scan.payloadLen)
            if writeResult != 0:
                return sink.error
        StatementAdvance(scan)
    return 0

fn FactWriteExprTokenRecord(sink: var FactSink, fnName: str, exprId: int32,
                            tokenKind: int32, tokenStart: int32,
                            tokenLen: int32, tokenDepth: int32): int32 =
    if FactWriteRecordBegin(sink, 7) != 0:
        return sink.error
    if FactWriteRecordField(sink, "cold_csg_expr_token") != 0:
        return sink.error
    if FactWriteRecordField(sink, fnName) != 0:
        return sink.error
    if FactWriteIntField(sink, exprId) != 0:
        return sink.error
    if FactWriteIntField(sink, tokenKind) != 0:
        return sink.error
    if FactWriteIntField(sink, tokenStart) != 0:
        return sink.error
    if FactWriteIntField(sink, tokenLen) != 0:
        return sink.error
    if FactWriteIntField(sink, tokenDepth) != 0:
        return sink.error
    return FactWriteRecordEnd(sink)

fn ExprWriteTokenFacts(sink: var FactSink, fnName: str, exprId: int32, source: str): int32 =
    var store: ExprTokenStore
    let scanResult: int32 = ExprScanIntoStore(source, store)
    if scanResult != 0:
        sink.error = scanResult
        return sink.error
    for i in 0..<store.count:
        let writeResult: int32 = FactWriteExprTokenRecord(sink, fnName, exprId,
                                                          ExprTokenKindAt(store, i),
                                                          ExprTokenStartAt(store, i),
                                                          ExprTokenLenAt(store, i),
                                                          ExprTokenDepthAt(store, i))
        if writeResult != 0:
            return sink.error
    return 0

fn FactReadByte(reader: var FactReader): int32 =
    if reader.pos >= reader.bytes.len:
        reader.error = 11
        return -1
    let value: int32 = reader.bytes[reader.pos]
    reader.pos = reader.pos + 1
    return value

fn FactReadDecimal(reader: var FactReader): bool =
    var value: int32 = 0
    var count: int32 = 0
    while reader.pos < reader.bytes.len:
        let ch: int32 = reader.bytes[reader.pos]
        if ch < '0' || ch > '9':
            break
        value = value * 10 + ch - '0'
        reader.pos = reader.pos + 1
        count = count + 1
    if count == 0:
        reader.error = 12
        return false
    reader.value = value
    return true

fn FactExpectByte(reader: var FactReader, expected: int32): bool =
    let value: int32 = FactReadByte(reader)
    if value != expected:
        reader.error = 13
        return false
    return true

fn FactExpectText(reader: var FactReader, text: str): bool =
    for i in 0..<len(text):
        if FactExpectByte(reader, text[i]) == false:
            return false
    return true

fn FactReadHexField(reader: var FactReader, expected: str): bool =
    if FactReadDecimal(reader) == false:
        return false
    let fieldLen: int32 = reader.value
    if fieldLen != len(expected):
        reader.error = 14
        return false
    if FactExpectByte(reader, ':') == false:
        return false
    for i in 0..<fieldLen:
        let hi: int32 = FactHexValue(FactReadByte(reader))
        let lo: int32 = FactHexValue(FactReadByte(reader))
        if hi < 0 || lo < 0:
            reader.error = 15
            return false
        let byte: int32 = (hi << 4) | lo
        if byte != expected[i]:
            reader.error = 16
            return false
    return true

fn FactRecordSetField(record: var FactRecordView, index: int32,
                      hexStart: int32, byteLen: int32): bool =
    if index < 0 || index >= 8:
        return false
    record.fieldHexStart[index] = hexStart
    record.fieldLen[index] = byteLen
    return true

fn FactRecordFieldLen(record: var FactRecordView, index: int32): int32 =
    if index < 0 || index >= 8:
        return -1
    return record.fieldLen[index]

fn FactRecordFieldHexStart(record: var FactRecordView, index: int32): int32 =
    if index < 0 || index >= 8:
        return -1
    return record.fieldHexStart[index]

fn FactRecordSetInt(record: var FactRecordView, index: int32,
                    value: int32, isDecimal: int32): bool =
    if index < 0 || index >= 8:
        return false
    record.fieldInt[index] = value
    record.fieldIsDecimal[index] = isDecimal
    return true

fn FactRecordFieldInt(record: var FactRecordView, index: int32): int32 =
    if index < 0 || index >= 8:
        return -1
    return record.fieldInt[index]

fn FactRecordFieldIsDecimal(record: var FactRecordView, index: int32): int32 =
    if index < 0 || index >= 8:
        return 0
    return record.fieldIsDecimal[index]

fn FactRecordIntChecksum(record: var FactRecordView): int32 =
    var checksum: int32 = 0
    for i in 0..<record.fieldCount:
        checksum = checksum + record.fieldInt[i] * (i + 1)
        checksum = checksum + record.fieldIsDecimal[i] * 17
    return checksum

fn FactRecordSpanChecksum(record: var FactRecordView): int32 =
    var checksum: int32 = 0
    for i in 0..<record.fieldCount:
        checksum = checksum + record.fieldHexStart[i] + record.fieldLen[i] * 3
    return checksum

fn FactRecordCheck(): int32 =
    var record: FactRecordView
    record.fieldCount = 4
    if FactRecordSetField(record, 0, 10, 3) == false:
        return 170
    if FactRecordSetField(record, 1, 20, 4) == false:
        return 171
    if FactRecordSetField(record, 2, 40, 5) == false:
        return 172
    if FactRecordSetField(record, 3, 80, 6) == false:
        return 173
    if FactRecordSetInt(record, 0, 7, 1) == false:
        return 174
    if FactRecordSetInt(record, 1, 11, 0) == false:
        return 175
    if FactRecordSetInt(record, 2, 13, 1) == false:
        return 176
    if FactRecordSetInt(record, 3, 17, 0) == false:
        return 177
    if FactRecordFieldHexStart(record, 2) != 40:
        return 178
    if FactRecordFieldLen(record, 3) != 6:
        return 179
    if FactRecordFieldInt(record, 1) != 11:
        return 180
    if FactRecordFieldIsDecimal(record, 2) != 1:
        return 181
    if FactRecordIntChecksum(record) != 170:
        return 182
    if FactRecordSpanChecksum(record) != 204:
        return 183
    return 0

fn FactReadHexFieldView(reader: var FactReader, record: var FactRecordView, index: int32): bool =
    if index < 0 || index >= 8:
        reader.error = 17
        return false
    if FactReadDecimal(reader) == false:
        return false
    let fieldLen: int32 = reader.value
    if fieldLen < 0:
        reader.error = 18
        return false
    if FactExpectByte(reader, ':') == false:
        return false
    let hexStart: int32 = reader.pos
    var isEntry: bool = index == 0 && fieldLen == len("cold_csg_entry")
    var isFunction: bool = index == 0 && fieldLen == len("cold_csg_function")
    var isStmt: bool = index == 0 && fieldLen == len("cold_csg_stmt")
    var isExprToken: bool = index == 0 && fieldLen == len("cold_csg_expr_token")
    var isDecimal: bool = fieldLen > 0
    var decimalValue: int32 = 0
    for i in 0..<fieldLen:
        let hi: int32 = FactHexValue(FactReadByte(reader))
        let lo: int32 = FactHexValue(FactReadByte(reader))
        if hi < 0 || lo < 0:
            reader.error = 19
            return false
        let byte: int32 = (hi << 4) | lo
        if isEntry && byte != "cold_csg_entry"[i]:
            isEntry = false
        if isFunction && byte != "cold_csg_function"[i]:
            isFunction = false
        if isStmt && byte != "cold_csg_stmt"[i]:
            isStmt = false
        if isExprToken && byte != "cold_csg_expr_token"[i]:
            isExprToken = false
        if byte >= '0' && byte <= '9' && isDecimal:
            decimalValue = decimalValue * 10 + byte - '0'
        else:
            isDecimal = false
    if FactRecordSetField(record, index, hexStart, fieldLen) == false:
        reader.error = 21
        return false
    if FactRecordFieldLen(record, index) != fieldLen:
        reader.error = 22
        return false
    if index == 0:
        if isEntry:
            record.kindCode = 1
        elif isFunction:
            record.kindCode = 2
        elif isStmt:
            record.kindCode = 3
        elif isExprToken:
            record.kindCode = 4
        else:
            record.kindCode = 0
    if isDecimal:
        FactRecordSetInt(record, index, decimalValue, 1)
    return true

fn FactReadRecordView(reader: var FactReader, record: var FactRecordView): bool =
    record.fieldCount = 0
    record.kindCode = 0
    record.error = 0
    if FactExpectText(reader, "cold_csg_record") == false:
        return false
    if FactExpectByte(reader, '\t') == false:
        return false
    if FactReadDecimal(reader) == false:
        return false
    record.fieldCount = reader.value
    if record.fieldCount <= 0 || record.fieldCount > 8:
        reader.error = 20
        record.error = reader.error
        return false
    for i in 0..<record.fieldCount:
        if FactExpectByte(reader, '\t') == false:
            return false
        if FactReadHexFieldView(reader, record, i) == false:
            record.error = reader.error
            return false
    if FactExpectByte(reader, '\n') == false:
        return false
    return true

fn FactReadRecordBeginExpected(reader: var FactReader, record: var FactRecordView, fieldCount: int32): bool =
    record.fieldCount = 0
    record.kindCode = 0
    record.error = 0
    if FactExpectText(reader, "cold_csg_record") == false:
        return false
    if FactExpectByte(reader, '\t') == false:
        return false
    if FactReadDecimal(reader) == false:
        return false
    if reader.value != fieldCount:
        reader.error = 23
        return false
    record.fieldCount = fieldCount
    return true

fn FactReadHexFieldViewExpected(reader: var FactReader, record: var FactRecordView, index: int32, expected: str): bool =
    if index < 0 || index >= 8:
        reader.error = 24
        return false
    if FactExpectByte(reader, '\t') == false:
        return false
    if FactReadDecimal(reader) == false:
        return false
    let fieldLen: int32 = reader.value
    if fieldLen != len(expected):
        reader.error = 25
        return false
    if FactExpectByte(reader, ':') == false:
        return false
    let start: int32 = reader.pos
    if start <= 0:
        reader.error = 30
        return false
    for i in 0..<fieldLen:
        let hi: int32 = FactHexValue(FactReadByte(reader))
        let lo: int32 = FactHexValue(FactReadByte(reader))
        if hi < 0 || lo < 0:
            reader.error = 26
            return false
        let byte: int32 = (hi << 4) | lo
        if byte != expected[i]:
            reader.error = 27
            return false
    if FactRecordSetField(record, index, start, fieldLen) == false:
        reader.error = 28
        return false
    if FactRecordFieldHexStart(record, index) != start:
        reader.error = 31
        return false
    if FactRecordFieldLen(record, index) != fieldLen:
        reader.error = 29
        return false
    return true

fn FactStatementScanChecksum(reader: var FactReader): int32 =
    if FactExpectText(reader, "cold_csg_version=2\n") == false:
        return 0 - reader.error
    var recordCount: int32 = 0
    var checksum: int32 = 0
    var lastPayloadStart: int32 = 0
    while reader.pos < reader.bytes.len:
        var record: FactRecordView
        if FactReadRecordView(reader, record) == false:
            return 0 - reader.error
        if record.kindCode != 3:
            return 170
        if record.fieldCount != 6:
            return 171
        if FactRecordFieldLen(record, 0) != len("cold_csg_stmt"):
            return 172
        if FactRecordFieldLen(record, 1) != len("StatementCheck"):
            return 173
        if FactRecordFieldIsDecimal(record, 2) != 1:
            return 174
        if FactRecordFieldIsDecimal(record, 3) != 1:
            return 175
        if FactRecordFieldIsDecimal(record, 4) != 1:
            return 176
        if FactRecordFieldIsDecimal(record, 5) != 1:
            return 177

        let kindCode: int32 = FactRecordFieldInt(record, 2)
        let indent: int32 = FactRecordFieldInt(record, 3)
        let payloadStart: int32 = FactRecordFieldInt(record, 4)
        let payloadLen: int32 = FactRecordFieldInt(record, 5)
        if recordCount > 0 && payloadStart <= lastPayloadStart:
            return 178
        lastPayloadStart = payloadStart
        recordCount = recordCount + 1
        let kindScore: int32 = kindCode * 17
        let lineScore: int32 = kindScore + indent + payloadLen
        checksum = checksum + lineScore
    let countScore: int32 = recordCount * 1000
    return countScore + checksum

fn StatementFactCheck(): int32 =
    var sink: FactSink
    if FactWriteVersion2(sink) != 0:
        return 180 + sink.error
    if StatementWriteFacts(sink, "StatementCheck", "    let value = FactReadByte(reader)\n    if value != expected:\n        return 13\n    elif value == 7:\n        return 14\n    else:\n        return 15\n    match result:\n        case Ok(value): return value\n    var next = value\n") != 0:
        return 180 + sink.error

    var reader: FactReader
    reader.bytes = sink.bytes
    let observed: int32 = FactStatementScanChecksum(reader)
    let expected: int32 = StatementScanChecksum("    let value = FactReadByte(reader)\n    if value != expected:\n        return 13\n    elif value == 7:\n        return 14\n    else:\n        return 15\n    match result:\n        case Ok(value): return value\n    var next = value\n")
    if observed != expected:
        return 181
    if observed != 10841:
        return 182
    if reader.pos != reader.bytes.len:
        return 183
    return 0

fn FactExprTokenScanChecksum(reader: var FactReader): int32 =
    if FactExpectText(reader, "cold_csg_version=2\n") == false:
        return 0 - reader.error
    var recordCount: int32 = 0
    var checksum: int32 = 0
    var lastStart: int32 = 0
    while reader.pos < reader.bytes.len:
        var record: FactRecordView
        if FactReadRecordView(reader, record) == false:
            return 0 - reader.error
        if record.kindCode != 4:
            return 230
        if record.fieldCount != 7:
            return 231
        if FactRecordFieldLen(record, 0) != len("cold_csg_expr_token"):
            return 232
        if FactRecordFieldLen(record, 1) != len("ExprCheck"):
            return 233
        for field in 2..<7:
            if FactRecordFieldIsDecimal(record, field) != 1:
                return 234
        let exprId: int32 = FactRecordFieldInt(record, 2)
        if exprId != 1:
            return 235
        let tokenKind: int32 = FactRecordFieldInt(record, 3)
        let tokenStart: int32 = FactRecordFieldInt(record, 4)
        let tokenLen: int32 = FactRecordFieldInt(record, 5)
        let tokenDepth: int32 = FactRecordFieldInt(record, 6)
        if recordCount > 0 && tokenStart <= lastStart:
            return 236
        lastStart = tokenStart
        recordCount = recordCount + 1
        let kindScore: int32 = tokenKind * 19
        let spanScore: int32 = tokenStart + tokenLen
        let lineScore: int32 = kindScore + spanScore + tokenDepth
        checksum = checksum + lineScore
    return recordCount * 1000 + checksum

fn ExprFactCheck(): int32 =
    var sink: FactSink
    if FactWriteVersion2(sink) != 0:
        return 240 + sink.error
    let writeResult: int32 = ExprWriteTokenFacts(sink, "ExprCheck", 1, "value + Call(7, items[2]) * len(text) - flag")
    if writeResult != 0:
        return 240 + sink.error

    var reader: FactReader
    reader.bytes = sink.bytes
    let observed: int32 = FactExprTokenScanChecksum(reader)
    var store: ExprTokenStore
    let scanResult: int32 = ExprScanIntoStore("value + Call(7, items[2]) * len(text) - flag", store)
    if scanResult != 0:
        return 241
    let expected: int32 = ExprStoreChecksum(store)
    if observed != expected:
        return 242
    if observed != 19790:
        return 243
    if reader.pos != reader.bytes.len:
        return 244
    return 0

fn FactCheck(): int32 =
    var sink: FactSink
    if FactArgLen("") != 0:
        return 125
    if FactWriteVersion2(sink) != 0:
        return 50 + sink.error
    if FactWriteRecord2(sink, "cold_csg_entry", "main") != 0:
        return 50 + sink.error
    if FactWriteRecordBegin(sink, 5) != 0:
        return 50 + sink.error
    if FactWriteRecordField(sink, "cold_csg_function") != 0:
        return 50 + sink.error
    if FactWriteRecordField(sink, "0") != 0:
        return 50 + sink.error
    if FactWriteRecordField(sink, "FactCheck") != 0:
        return 50 + sink.error
    if FactWriteRecordField(sink, "") != 0:
        return 50 + sink.error
    if FactWriteRecordField(sink, "int32") != 0:
        return 50 + sink.error
    if FactWriteRecordEnd(sink) != 0:
        return 50 + sink.error
    if FactWriteRecord3(sink, "cold_csg_stmt", "main", "a\tb") != 0:
        return 50 + sink.error
    var reader: FactReader
    reader.bytes = sink.bytes
    if FactExpectText(reader, "cold_csg_version=2\n") == false:
        return 60 + reader.error
    var record: FactRecordView
    if FactReadRecordBeginExpected(reader, record, 2) == false:
        return 60 + reader.error
    if FactReadHexFieldViewExpected(reader, record, 0, "cold_csg_entry") == false:
        return 60 + reader.error
    if FactReadHexFieldViewExpected(reader, record, 1, "main") == false:
        return 60 + reader.error
    if FactExpectByte(reader, '\n') == false:
        return 60 + reader.error
    if record.fieldCount != 2:
        return 70 + record.fieldCount
    if FactRecordFieldLen(record, 0) != len("cold_csg_entry"):
        return 71
    if FactRecordFieldHexStart(record, 0) <= 0:
        return 72
    if FactReadRecordBeginExpected(reader, record, 5) == false:
        return 60 + reader.error
    if FactReadHexFieldViewExpected(reader, record, 0, "cold_csg_function") == false:
        return 60 + reader.error
    if FactReadHexFieldViewExpected(reader, record, 1, "0") == false:
        return 60 + reader.error
    if FactReadHexFieldViewExpected(reader, record, 2, "FactCheck") == false:
        return 60 + reader.error
    if FactReadHexFieldViewExpected(reader, record, 3, "") == false:
        return 60 + reader.error
    if FactReadHexFieldViewExpected(reader, record, 4, "int32") == false:
        return 60 + reader.error
    if FactExpectByte(reader, '\n') == false:
        return 60 + reader.error
    if record.fieldCount != 5:
        return 73 + record.fieldCount
    if FactRecordFieldLen(record, 4) != len("int32"):
        return 81
    if FactReadRecordBeginExpected(reader, record, 3) == false:
        return 60 + reader.error
    if FactReadHexFieldViewExpected(reader, record, 0, "cold_csg_stmt") == false:
        return 60 + reader.error
    if FactReadHexFieldViewExpected(reader, record, 1, "main") == false:
        return 60 + reader.error
    if FactReadHexFieldViewExpected(reader, record, 2, "a\tb") == false:
        return 60 + reader.error
    if FactExpectByte(reader, '\n') == false:
        return 60 + reader.error
    if record.fieldCount != 3:
        return 82 + record.fieldCount
    if FactRecordFieldLen(record, 2) != 3:
        return 87
    if reader.pos != reader.bytes.len:
        return 88

    var viewReader: FactReader
    viewReader.bytes = sink.bytes
    if FactExpectText(viewReader, "cold_csg_version=2\n") == false:
        return 126
    var view: FactRecordView
    if FactReadRecordView(viewReader, view) == false:
        return 127
    if FactRecordFieldLen(view, 0) != 14:
        return 130
    if FactRecordFieldLen(view, 1) != 4:
        return 131
    if FactReadRecordView(viewReader, view) == false:
        return 132
    if FactRecordFieldLen(view, 0) != 17:
        return 133
    if FactRecordFieldLen(view, 1) != 1:
        return 134
    if FactRecordFieldLen(view, 2) != 9:
        return 135
    if FactRecordFieldLen(view, 3) != 0:
        return 136
    if FactRecordFieldLen(view, 4) != 5:
        return 137
    if FactReadRecordView(viewReader, view) == false:
        return 138
    if FactRecordFieldLen(view, 0) != 13:
        return 139
    if FactRecordFieldLen(view, 1) != 4:
        return 140
    if FactRecordFieldLen(view, 2) != 3:
        return 141

    var scan: FactReader
    scan.bytes = sink.bytes
    if FactExpectText(scan, "cold_csg_version=2\n") == false:
        return 90 + scan.error
    var entryCount: int32 = 0
    var functionCount: int32 = 0
    var stmtCount: int32 = 0
    var recordCount: int32 = 0
    var totalFields: int32 = 0
    var totalBytes: int32 = 0
    while scan.pos < scan.bytes.len:
        var scanRecord: FactRecordView
        if FactReadRecordView(scan, scanRecord) == false:
            return 90 + scan.error
        recordCount = recordCount + 1
        totalFields = totalFields + scanRecord.fieldCount
        for i in 0..<scanRecord.fieldCount:
            let fieldLen: int32 = FactRecordFieldLen(scanRecord, i)
            totalBytes = totalBytes + fieldLen
        if scanRecord.kindCode == 1:
            entryCount = entryCount + 1
        elif scanRecord.kindCode == 2:
            functionCount = functionCount + 1
        elif scanRecord.kindCode == 3:
            stmtCount = stmtCount + 1
        else:
            return 143
    if recordCount != 3:
        return 100 + recordCount
    if totalBytes != 70:
        return 142
    if totalFields != 10:
        return 144
    if entryCount != 1:
        return 145
    if functionCount != 1:
        return 146
    if stmtCount != 1:
        return 147
    if len("") != 0:
        return 124
    if len("cold_csg_entry") != 14:
        return len("cold_csg_entry")
    if len("cold_csg_function") != 17:
        return len("cold_csg_function")
    if len("0") != 1:
        return len("0")
    if len("FactCheck") != 9:
        return len("FactCheck")
    if len("int32") != 5:
        return len("int32")
    if len("cold_csg_stmt") != 13:
        return len("cold_csg_stmt")
    if len("main") != 4:
        return len("main")
    if len("a\tb") != 3:
        return len("a\tb")
    if scan.pos != scan.bytes.len:
        return 123
    return 0

fn FrontendCheck(): int32 =
    let starts: bool = FrontendIsIdentStart('A') && !FrontendIsIdentStart('9')
    if !starts:
        return 11
    if !FrontendIsIdentStart('A'):
        return 1
    if FrontendIsIdentStart('9'):
        return 2
    if !FrontendIsIdentCont('9'):
        return 3
    if !FrontendIsSpace('\n'):
        return 4
    if FrontendLineIndentWidth("       body") != 7:
        return 5
    if !FrontendTextIsFactSafe("cold_fact"):
        return 7
    if FrontendIdentPrefixLen("Token42 rest", 0) != 7:
        return 8
    if FrontendFunctionNameLenFromLine("fn ParserToken(source: str)") != 11:
        return 9
    if FrontendSkipWhitespaceAndLineComments("  // skip me", 0) != 12:
        return 10
    if len("a\n") != 2:
        return 12
    if "a\n"[1] != '\n':
        return 13
    let state = FrontendStateCheck()
    if state != 0:
        return state
    let outline = OutlineCheck()
    if outline != 0:
        return outline
    let statements = StatementCheck()
    if statements != 0:
        return statements
    let expr = ExprCheck()
    if expr != 0:
        return expr
    let layout = LayoutCheck()
    if layout != 0:
        return layout
    let work = WorkDequeCheck()
    if work != 0:
        return work
    let arena = PhaseArenaCheck()
    if arena != 0:
        return arena
    let factRecord = FactRecordCheck()
    if factRecord != 0:
        return factRecord
    let facts = FactCheck()
    if facts != 0:
        return facts
    let statementFacts = StatementFactCheck()
    if statementFacts != 0:
        return statementFacts
    let exprFacts = ExprFactCheck()
    if exprFacts != 0:
        return exprFacts
    return 0

fn a64RegField(reg: int32, shift: int32): uint32 =
    return uint32(reg) << uint32(shift)

fn a64ImmField(value: int32, mask: int32, shift: int32): uint32 =
    return uint32(value & mask) << uint32(shift)

fn A64EncRet(): int32 =
    return int32(uint32(0xD65F03C0))

fn A64EncNop(): int32 =
    return int32(uint32(0xD503201F))

fn A64EncBlPlaceholder(): int32 =
    return int32(uint32(0x94000000))

fn A64EncBPlaceholder(): int32 =
    return int32(uint32(0x14000000))

fn A64EncMovz32(rd: int32, imm16: int32, hw: int32): int32 =
    return int32(uint32(0x52800000) |
                 a64ImmField(hw, 3, 21) |
                 a64ImmField(imm16, 0xffff, 5) |
                 a64RegField(rd, 0))

fn A64EncAddReg(is64: bool, rd: int32, rn: int32, rm: int32): int32 =
    if is64:
        return int32(uint32(0x8B000000) |
                     a64RegField(rm, 16) |
                     a64RegField(rn, 5) |
                     a64RegField(rd, 0))
    return int32(uint32(0x0B000000) |
                 a64RegField(rm, 16) |
                 a64RegField(rn, 5) |
                 a64RegField(rd, 0))

fn A64EncAndReg(is64: bool, rd: int32, rn: int32, rm: int32): int32 =
    if is64:
        return int32(uint32(0x8A000000) |
                     a64RegField(rm, 16) |
                     a64RegField(rn, 5) |
                     a64RegField(rd, 0))
    return int32(uint32(0x0A000000) |
                 a64RegField(rm, 16) |
                 a64RegField(rn, 5) |
                 a64RegField(rd, 0))

fn A64EncBImm(deltaWords: int64): Result[int32] =
    if deltaWords < -33554432 || deltaWords > 33554431:
        return Err(" aarch64 encode: b offset out of range")
    let imm26: uint32 = uint32(uint64(deltaWords) & uint64(0x03ffffff))
    return Ok(int32(uint32(0x14000000) | imm26))

fn A64EncBCond(deltaWords: int64, cond: int32): Result[int32] =
    if cond < 0 || cond > 15:
        return Err(" aarch64 encode: condition out of range")
    if deltaWords < -262144 || deltaWords > 262143:
        return Err(" aarch64 encode: b.cond offset out of range")
    let imm19: uint32 = uint32(uint64(deltaWords) & uint64(0x7ffff))
    return Ok(int32(uint32(0x54000000) |
                    (imm19 << uint32(5)) |
                    uint32(cond)))

fn A64CodeWordCount(byteCount: int32): int32 =
    return (byteCount + 3) / 4

fn A64RelocPageRemainder(byteOffset: int32): int32 =
    return byteOffset % 4096

fn A64SignedDivModRoundTrip(value: int32, unit: int32): int32 =
    return (value / unit) * unit + (value % unit)

fn A64Check(): int32 =
    if A64EncRet() != int32(uint32(0xD65F03C0)):
        return 21
    if A64EncNop() != int32(uint32(0xD503201F)):
        return 22
    if A64EncBlPlaceholder() != int32(uint32(0x94000000)):
        return 23
    if A64EncBPlaceholder() != int32(uint32(0x14000000)):
        return 24
    if A64EncMovz32(0, 42, 0) != int32(uint32(0x52800540)):
        return 25
    if A64EncAddReg(false, 0, 1, 2) != int32(uint32(0x0B020020)):
        return 26
    if A64EncAndReg(false, 0, 1, 2) != int32(uint32(0x0A020020)):
        return 27

    let branch = A64EncBImm(2)
    match branch:
        Ok(word) =>
            if word != int32(uint32(0x14000002)):
                return 28
        Err(error) =>
            return len(error)

    let condBranch = A64EncBCond(3, 1)
    match condBranch:
        Ok(word) =>
            if word != int32(uint32(0x54000061)):
                return 29
        Err(error) =>
            return len(error)

    if A64CodeWordCount(17) != 5:
        return 30
    if A64RelocPageRemainder(4101) != 5:
        return 31
    if A64SignedDivModRoundTrip(-17, 4) != -17:
        return 32

    return 0

fn StmtExprWriteFacts(sink: var FactSink, fnName: str, source: str): int32 =
    var scan: StatementScan
    scan.source = source
    var exprId: int32 = 0
    while scan.pos < len(source):
        if StatementClassifyLine(scan) == false:
            sink.error = 51
            return sink.error
        if scan.kindCode != 0 && scan.kindCode != 5:
            let writeResult: int32 = FactWriteStatementRecord(sink, fnName, scan.kindCode, scan.indent, scan.payloadStart, scan.payloadLen)
            if writeResult != 0:
                return sink.error
            if scan.payloadLen > 0:
                var store: ExprTokenStore
                let scanResult: int32 = ExprScanIntoStore(source, store)
                if scanResult != 0:
                    sink.error = scanResult
                    return sink.error
                for i in 0..<store.count:
                    let tr: int32 = FactWriteExprTokenRecord(sink, fnName, exprId,
                                                             ExprTokenKindAt(store, i),
                                                             ExprTokenStartAt(store, i),
                                                             ExprTokenLenAt(store, i),
                                                             ExprTokenDepthAt(store, i))
                    if tr != 0:
                        return sink.error
                exprId = exprId + 1
        StatementAdvance(scan)
    return 0

fn StmtExprReadVerify(reader: var FactReader, source: str): int32 =
    if FactExpectText(reader, "cold_csg_version=2\n") == false:
        return 0 - reader.error
    var stmtCount: int32 = 0
    while reader.pos < reader.bytes.len:
        var record: FactRecordView
        if FactReadRecordView(reader, record) == false:
            return 0 - reader.error
        if record.kindCode == 3:
            stmtCount = stmtCount + 1
        elif record.kindCode != 4:
            return 250 + record.kindCode
    if stmtCount <= 0:
        return 251
    return stmtCount

fn StmtExprRoundTripCheck(): int32 =
    var sink: FactSink
    if FactWriteVersion2(sink) != 0:
        return 260 + sink.error
    let testSource: str = "    let x = a + b\n    return x\n    if x > 7:\n        return 1\n"
    if StmtExprWriteFacts(sink, "RoundTrip", testSource) != 0:
        return 261 + sink.error
    var reader: FactReader
    reader.bytes = sink.bytes
    let stmtCount: int32 = StmtExprReadVerify(reader, testSource)
    if stmtCount <= 0:
        return stmtCount
    if stmtCount != 4:
        return 262
    return 0

fn main(): int32 =
    let frontend = FrontendCheck()
    if frontend != 0:
        return frontend
    let stmt = StatementCheck()
    if stmt != 0:
        return stmt
    let stmtExpr = StatementExprCheck()
    if stmtExpr != 0:
        return stmtExpr
    let expr = ExprCheck()
    if expr != 0:
        return expr
    let facts = FactCheck()
    if facts != 0:
        return facts
    let stmtFact = StatementFactCheck()
    if stmtFact != 0:
        return stmtFact
    let exprFact = ExprFactCheck()
    if exprFact != 0:
        return exprFact
    let rt = StmtExprRoundTripCheck()
    if rt != 0:
        return rt
    let a64 = A64Check()
    if a64 != 0:
        return a64
    return 42
