import std/system
import std/strings

fn stringsIntToStrCheck() =
    let int32Min: int32 = int32(-2147483647) - int32(1)
    let int64Min: int64 = int64(-9223372036854775807) - int64(1)
    let uint64Max: uint64 = uint64(9223372036854775807) * uint64(2) + uint64(1)

    assert(IntToStr(0) == "0", " strings intToStr zero")
    assert(IntToStr(12345) == "12345", " strings intToStr positive")
    assert(IntToStr(int32Min) == "-2147483648", " strings intToStr int32 min")
    assert(int64ToStr(int64Min) == "-9223372036854775808", " strings int64ToStr min")
    assert(uint64ToStr(uint64Max) == "18446744073709551615", " strings uint64ToStr max")

fn main(): int32 =
    let liveBefore: int64 = memLiveCount()
    stringsIntToStrCheck()
    let liveAfter: int64 = memLiveCount()
    assert(liveAfter == liveBefore, " strings intToStr: live delta zero")
    echo(" strings_int_to_str_smoke ok")
    return 0
