import std/system
import std/rawbytes

type
    PacketBox =
        payload: Bytes

fn clearBytes(data: var Bytes) =
    data = emptyBytes()

fn main(): int32 =
    var box: PacketBox
    box.payload = bytesAlloc(24)
    let raw = box.payload.data
    if raw == nil:
        return 101
    clearBytes(box.payload)
    return memRefCount(raw)
