import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/std/crypto/fixed256
import cheng/oracle/oracle_types
import cheng/oracle/oracle_plane
import cheng/tests/oracle_smoke_support as support
import std/crypto/ecnist

fn printPub(slot: int32): void =
    let priv = support.oracleSmokePrivateScalar(slot)
    let pubRes = ecnist.ecdsaPublicKeyFromPrivateBytes(fixed256.scalar256ToBytes(priv))
    assert(IsOk(pubRes), "oracle fixture regen: pub")
    let fixedRes = layout.fixedBytes65FromBytes(Value(pubRes))
    assert(IsOk(fixedRes), "oracle fixture regen: pub fixed")
    echo("pub[" + IntToStr(slot) + "]=" + layout.fixedBytes65Hex(Value(fixedRes)))

fn printSig(roundId: int64, reporterSlot: int32): void =
    let observedAtMs = oracle_types.v3OracleRoundStartMs(roundId) + int64(reporterSlot)
    var batch = oracle_plane.V3OracleSignedBatch()
    batch.version = oracle_types.v3OracleVersion
    batch.committeeSetId = 1
    batch.reporterSlot = reporterSlot
    batch.roundId = oracle_types.v3OracleRoundIdFromObservedAtMs(observedAtMs)
    batch.observedAtMs = observedAtMs
    batch.pricesE8 = support.oracleSmokePrices(roundId, reporterSlot)
    let signableRes = oracle_plane.v3OracleSignedBatchSignableBytes(batch)
    if IsErr(signableRes):
        panic("oracle fixture regen signable: " + Error(signableRes))
    let sigRes = fixed256.p256SignMessageFixed64(support.oracleSmokePrivateScalar(reporterSlot),
                                                 Value(signableRes))
    if IsErr(sigRes):
        panic("oracle fixture regen sign: " + Error(sigRes))
    batch.sig = Value(sigRes)
    echo("sig[" + IntToStr(int32(roundId)) + "][" + IntToStr(reporterSlot) + "]=" + layout.fixedBytes64Hex(batch.sig))

fn main(): int32 =
    for slot in 1..<8:
        printPub(slot)
    let rounds: int64[] = [int64(10), int64(12), int64(20), int64(21), int64(22), int64(25), int64(30), int64(40)]
    for roundIndex in 0..<rounds.len:
        for reporterSlot in 1..<8:
            printSig(rounds[roundIndex], reporterSlot)
    return 0
