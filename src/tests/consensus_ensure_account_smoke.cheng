import std/system
import cheng/chain/consensus

fn main(): int32 =
    var index = consensus.ChainIndex()
    let pos = consensus.ConsensusEnsureAccount(index, 7, 1001)
    assert(pos == 0, " consensus ensure: pos")
    assert(index.accountAssetIds.len == 1, " consensus ensure: asset len")
    assert(index.accountIds.len == 1, " consensus ensure: account len")
    assert(index.accountHeads.len == 1, " consensus ensure: heads len")
    assert(index.balances.len == 1, " consensus ensure: balances len")
    assert(index.clockEpochs.len == 1, " consensus ensure: epochs len")
    assert(index.clockGanzhi.len == 1, " consensus ensure: ganzhi len")
    assert(index.diverged.len == 1, " consensus ensure: diverged len")
    assert(index.accountAssetIds[0] == 7, " consensus ensure: asset")
    assert(index.accountIds[0] == 1001, " consensus ensure: account")
    assert(index.balances[0] == int64(0), " consensus ensure: balance")
    assert(!index.diverged[0], " consensus ensure: diverged")
    echo(" consensus_ensure_account_smoke ok")
    return 0
