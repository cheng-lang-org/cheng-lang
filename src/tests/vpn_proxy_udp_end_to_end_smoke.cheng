import std/cmdline as cmdline
import std/os
import std/rawbytes
import std/rawmem_support
import std/result
import std/strutils as strutil
import std/net/transports/tcp_syscall as tcp
import std/net/transports/udp_syscall as udp
import cheng/quic/tls/test_pki as testpki
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/apps/vpn_proxy/vpn_proxy_main as vpn
import cheng/apps/vpn_proxy/vpn_proxy_socks as socks

const
    vpnProxyUdpE2eArtifactRel = "artifacts/vpn_proxy_udp_end_to_end_smoke"
    vpnProxyUdpE2eAuth = "shared-secret"
    vpnProxyUdpE2eAuthority = "localhost"
    vpnProxyUdpE2eTargetHost = "127.0.0.1"
    vpnProxyUdpE2eRequestText = "vpn-proxy-udp-e2e-request"
    vpnProxyUdpE2eResponseText = "vpn-proxy-udp-e2e-response"

fn vpnProxyUdpE2eUseLenField(): bool =
    return os.udpPlatformUseLenFieldBridge() != 0

fn vpnProxyUdpE2eBindSocket(host: str,
                            port: int32,
                            isV6: bool,
                            outSocket: var udp.UdpSocketHandle,
                            outSockName: var udp.UdpSockAddr): Result[bool] =
    var isV6Flag: int32
    if isV6:
        isV6Flag = 1
    let fd: int32 = os.udpBindFdBridge(host, port, isV6Flag)
    if fd < 0:
        return Err[bool]("udp syscall: bind failed")
    let sockNameRes: Result[bool] = udp.UdpGetSockName(fd, outSockName)
    if IsErr(sockNameRes):
        udp.UdpSocketClose(fd)
        return Err[bool](ErrorText(sockNameRes))
    outSocket = udp.UdpSocketHandle(fd: fd,
                                    family: outSockName.family,
                                    isV6: outSockName.isV6)
    return Ok[bool](true)

fn vpnProxyUdpE2eBytesEq(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn vpnProxyUdpE2eArtifactDir(root: str): str =
    return chengpath.PathAbsolute(root, vpnProxyUdpE2eArtifactRel)

fn vpnProxyUdpE2ePath(root: str, name: str): str =
    return chengpath.PathAbsolute(root, strutil.Join([vpnProxyUdpE2eArtifactRel, "/", name], ""))

fn vpnProxyUdpE2eReadyPath(root: str, name: str): str =
    return vpnProxyUdpE2ePath(root, strutil.Join([name, ".ready"], ""))

fn vpnProxyUdpE2eLogPath(root: str, name: str): str =
    return vpnProxyUdpE2ePath(root, strutil.Join([name, ".log"], ""))

fn vpnProxyUdpE2eParsePort(textRaw: str): Result[int32] =
    let text: str = strutil.Strip(textRaw)
    if len(text) <= 0:
        return Err[int32](" vpn proxy udp e2e: empty port text")
    var value: int32
    for i in 0..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int32](" vpn proxy udp e2e: invalid port text")
        value = value * 10 + (int32(ch) - int32('0'))
    if value <= 0:
        return Err[int32](" vpn proxy udp e2e: invalid port")
    return Ok[int32](value)

fn vpnProxyUdpE2eRemoveFile(path: str) =
    if os.FileExists(path):
        let _ = os.RemoveFile(path)

fn vpnProxyUdpE2eWriteBytes(path: str, data: Bytes): bool =
    let parent: str = os.ParentDir(path)
    if len(parent) > 0:
        if !chengpath.MkdirP("", parent):
            return false
    let file = os.Open(path, os.fmWrite)
    if file == nil:
        return false
    let total: int32 = bytesLen(data)
    if total <= 0:
        os.Close(file)
        return true
    let wrote: int32 = os.C_fwrite(data.data, 1, int64(total), file)
    os.Close(file)
    if wrote != total:
        return false
    return os.FileExists(path) && os.FileSize(path) == int64(total)

fn vpnProxyUdpE2eWriteMaterials(root: str): Result[bool] =
    let artifactDir: str = vpnProxyUdpE2eArtifactDir(root)
    if !chengpath.MkdirP(root, artifactDir):
        return Err[bool](" vpn proxy udp e2e: mkdir failed")
    let rootPath: str = vpnProxyUdpE2ePath(root, "transport.root.der")
    let certPath: str = vpnProxyUdpE2ePath(root, "transport.cert.der")
    let keyPath: str = vpnProxyUdpE2ePath(root, "transport.key.pk8")
    var trustRoot: Bytes
    testpki.msquicLocalhostTransportTrustRootDerInto(trustRoot)
    if bytesLen(trustRoot) <= 0:
        return Err[bool](" vpn proxy udp e2e: trust root bytes empty")
    if !vpnProxyUdpE2eWriteBytes(rootPath, trustRoot):
        return Err[bool](" vpn proxy udp e2e: write trust root failed")
    var certDer: Bytes
    testpki.msquicLocalhostTransportCertDerInto(certDer)
    if bytesLen(certDer) <= 0:
        return Err[bool](" vpn proxy udp e2e: cert bytes empty")
    if !vpnProxyUdpE2eWriteBytes(certPath, certDer):
        return Err[bool](" vpn proxy udp e2e: write cert failed")
    var keyPk8: Bytes
    testpki.msquicLocalhostTransportKeyPkcs8DerInto(keyPk8)
    if bytesLen(keyPk8) <= 0:
        return Err[bool](" vpn proxy udp e2e: key bytes empty")
    if !vpnProxyUdpE2eWriteBytes(keyPath, keyPk8):
        return Err[bool](" vpn proxy udp e2e: write key failed")
    return Ok[bool](true)

fn vpnProxyUdpE2eExitConfigText(): str =
    var out = ""
    out = strutil.Join([out, "{\"server\":{"], "")
    out = strutil.Join([out, "\"listen\":\"127.0.0.1:0\","], "")
    out = strutil.Join([out, "\"cert_der\":\"transport.cert.der\","], "")
    out = strutil.Join([out, "\"key_pk8_der\":\"transport.key.pk8\","], "")
    out = strutil.Join([out, "\"trust_root_der\":\"transport.root.der\","], "")
    out = strutil.Join([out, "\"expected_auth\":\"", vpnProxyUdpE2eAuth, "\","], "")
    out = strutil.Join([out, "\"expected_authority\":\"", vpnProxyUdpE2eAuthority, "\","], "")
    out = strutil.Join([out, "\"cc_rx_text\":\"auto\""], "")
    out = strutil.Join([out, "}}"], "")
    return out

fn vpnProxyUdpE2eLocalConfigText(exitPort: int32): str =
    var out = ""
    out = strutil.Join([out, "{\"client\":{"], "")
    out = strutil.Join([out, "\"listen\":\"127.0.0.1:0\","], "")
    out = strutil.Join([out, "\"cert_der\":\"transport.cert.der\","], "")
    out = strutil.Join([out, "\"key_pk8_der\":\"transport.key.pk8\","], "")
    out = strutil.Join([out, "\"trust_root_der\":\"transport.root.der\""], "")
    out = strutil.Join([out, "},\"exits\":[{"], "")
    out = strutil.Join([out, "\"name\":\"edge\","], "")
    out = strutil.Join([out, "\"host\":\"127.0.0.1\","], "")
    out = strutil.Join([out, "\"port\":", intToStr(exitPort), ","], "")
    out = strutil.Join([out, "\"server_name\":\"localhost\","], "")
    out = strutil.Join([out, "\"authority\":\"", vpnProxyUdpE2eAuthority, "\","], "")
    out = strutil.Join([out, "\"auth\":\"", vpnProxyUdpE2eAuth, "\","], "")
    out = strutil.Join([out, "\"cc_rx\":65535"], "")
    out = strutil.Join([out, "}]}"], "")
    return out

fn vpnProxyUdpE2eWaitReadyPort(root: str,
                               readyPath: str,
                               proc: var hostops.SpawnedProcess,
                               portOut: var int32): Result[bool] =
    portOut = 0
    for attempt in 0..<500:
        if chengpath.FileExistsNonEmpty(root, readyPath):
            let textRaw: str = chengpath.ReadTextFile("", readyPath)
            let parseRes: Result[int32] = vpnProxyUdpE2eParsePort(textRaw)
            if IsOk(parseRes):
                portOut = Value(parseRes)
                return Ok[bool](true)
        if !hostops.SpawnedProcessRunning(proc):
            return Err[bool](strutil.Join([" vpn proxy udp e2e: process exited before ready: ", proc.output], ""))
        if attempt + 1 < 500:
            os.SleepMs(10)
    return Err[bool](" vpn proxy udp e2e: ready timeout")

fn vpnProxyUdpE2eTcpReadExact(conn: var tcp.TcpConnectionHandle, count: int32): Result[Bytes] =
    let out: Bytes = bytesAlloc(count)
    var filled: int32
    while filled < count:
        let dstPtr: ptr = rawmem_support.RawmemPtrAdd(out.data, filled)
        let readRes: Result[int32] = tcp.TcpRecvRaw(conn, dstPtr, count - filled)
        if IsErr(readRes):
            return Err[Bytes](ErrorText(readRes))
        let got: int32 = Value(readRes)
        if got <= 0:
            return Err[Bytes](" vpn proxy udp e2e: unexpected eof")
        filled = filled + got
    return Ok[Bytes](out)

fn vpnProxyUdpE2eTcpWriteAll(conn: var tcp.TcpConnectionHandle, data: var Bytes): Result[int32] =
    return tcp.TcpSendRaw(conn, data.data, bytesLen(data))

fn vpnProxyUdpE2eTargetRequest(): Bytes =
    return bytesFromString(vpnProxyUdpE2eRequestText)

fn vpnProxyUdpE2eTargetResponse(): Bytes =
    return bytesFromString(vpnProxyUdpE2eResponseText)

fn vpnProxyUdpE2eSocksMethodWireInto(out: var Bytes) =
    out = bytesAlloc(3)
    bytesSet(out, 0, 5)
    bytesSet(out, 1, 1)
    bytesSet(out, 2, 0)

fn vpnProxyUdpE2eSocksUdpAssocWireInto(out: var Bytes) =
    out = bytesAlloc(10)
    bytesSet(out, 0, 5)
    bytesSet(out, 1, 3)
    bytesSet(out, 2, 0)
    bytesSet(out, 3, 1)
    bytesSet(out, 4, 0)
    bytesSet(out, 5, 0)
    bytesSet(out, 6, 0)
    bytesSet(out, 7, 0)
    bytesSet(out, 8, 0)
    bytesSet(out, 9, 0)

fn vpnProxyUdpE2eParseAssocReply(reply: Bytes): Result[socks.VpnProxyTarget] =
    if bytesLen(reply) != 10:
        return Err[socks.VpnProxyTarget](" vpn proxy udp e2e: invalid associate reply size")
    if bytesGet(reply, 0) != 5 || bytesGet(reply, 1) != 0:
        return Err[socks.VpnProxyTarget](strutil.Join([" vpn proxy udp e2e: associate reply invalid ver=", intToStr(bytesGet(reply, 0)), " code=", intToStr(bytesGet(reply, 1)), " atyp=", intToStr(bytesGet(reply, 3))], ""))
    let pseudo: Bytes = bytesConcat(testBytes([5, 1, 0]), bytesSlice(reply, 3, bytesLen(reply) - 3))
    let reqRes: Result[socks.VpnProxySocksRequest] = socks.VpnProxySocksParseRequestWire(pseudo)
    if IsErr(reqRes):
        return Err[socks.VpnProxyTarget](ErrorText(reqRes))
    return Ok[socks.VpnProxyTarget](Value(reqRes).target)

fn testBytes(values: int32[]): Bytes =
    var out: Bytes = bytesAlloc(values.len)
    for i in 0..<values.len:
        bytesSet(out, i, values[i])
    return out

fn vpnProxyUdpE2eRunClient(localPort: int32, targetPort: int32): Result[bool] =
    let connectRes: Result[tcp.TcpConnectionHandle] = tcp.TcpConnect("127.0.0.1", localPort, false)
    if IsErr(connectRes):
        return Err[bool](ErrorText(connectRes))
    var conn = Value(connectRes)
    var methodWire: Bytes
    vpnProxyUdpE2eSocksMethodWireInto(methodWire)
    let methodWriteRes: Result[int32] = vpnProxyUdpE2eTcpWriteAll(conn, methodWire)
    if IsErr(methodWriteRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(methodWriteRes))
    let methodReplyRes: Result[Bytes] = vpnProxyUdpE2eTcpReadExact(conn, 2)
    if IsErr(methodReplyRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(methodReplyRes))
    if !vpnProxyUdpE2eBytesEq(Value(methodReplyRes), testBytes([5, 0])):
        tcp.TcpClose(conn)
        return Err[bool](" vpn proxy udp e2e: method reply invalid")
    var assocWire: Bytes
    vpnProxyUdpE2eSocksUdpAssocWireInto(assocWire)
    let assocWriteRes: Result[int32] = vpnProxyUdpE2eTcpWriteAll(conn, assocWire)
    if IsErr(assocWriteRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(assocWriteRes))
    let assocReplyRes: Result[Bytes] = vpnProxyUdpE2eTcpReadExact(conn, 10)
    if IsErr(assocReplyRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(assocReplyRes))
    let assocReply: Bytes = Value(assocReplyRes)
    let relayTargetRes: Result[socks.VpnProxyTarget] = vpnProxyUdpE2eParseAssocReply(assocReply)
    if IsErr(relayTargetRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(relayTargetRes))
    let relayTarget: socks.VpnProxyTarget = Value(relayTargetRes)
    var udpSock: udp.UdpSocketHandle
    var udpSockName: udp.UdpSockAddr
    let bindRes: Result[bool] = vpnProxyUdpE2eBindSocket("127.0.0.1", 0, false, udpSock, udpSockName)
    if IsErr(bindRes):
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(bindRes))
    var relayAddr: udp.UdpSockAddr
    let relayAddrRes: Result[bool] = udp.UdpSockAddrFromHostPort(relayTarget.host,
                                                                 relayTarget.port,
                                                                 false,
                                                                 udpSock.family,
                                                                 vpnProxyUdpE2eUseLenField(),
                                                                 relayAddr)
    if IsErr(relayAddrRes):
        udp.UdpSocketClose(udpSock.fd)
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(relayAddrRes))
    var target: socks.VpnProxyTarget
    target.host = "127.0.0.1"
    target.port = targetPort
    var requestDatagram: socks.VpnProxySocksUdpDatagram
    requestDatagram.fragmentId = 0
    requestDatagram.target = target
    requestDatagram.payload = vpnProxyUdpE2eTargetRequest()
    let udpWireRes: Result[Bytes] = socks.VpnProxySocksEncodeUdpDatagram(requestDatagram)
    if IsErr(udpWireRes):
        udp.UdpSocketClose(udpSock.fd)
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(udpWireRes))
    let sendRes: Result[int32] = udp.UdpSendTo(udpSock.fd, Value(udpWireRes), relayAddr)
    if IsErr(sendRes):
        udp.UdpSocketClose(udpSock.fd)
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(sendRes))
    var recv: udp.UdpRecvResult
    let recvRes: Result[bool] = udp.UdpRecvFromBlocking(udpSock.fd, 65535, recv)
    if IsErr(recvRes):
        udp.UdpSocketClose(udpSock.fd)
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(recvRes))
    let responseDatagramRes: Result[socks.VpnProxySocksUdpDatagram] = socks.VpnProxySocksDecodeUdpDatagram(recv.data)
    if IsErr(responseDatagramRes):
        udp.UdpSocketClose(udpSock.fd)
        tcp.TcpClose(conn)
        return Err[bool](ErrorText(responseDatagramRes))
    let responseDatagram: socks.VpnProxySocksUdpDatagram = Value(responseDatagramRes)
    udp.UdpSocketClose(udpSock.fd)
    tcp.TcpClose(conn)
    if responseDatagram.target.host != "127.0.0.1" || responseDatagram.target.port != targetPort:
        return Err[bool](" vpn proxy udp e2e: response source mismatch")
    if !vpnProxyUdpE2eBytesEq(responseDatagram.payload, vpnProxyUdpE2eTargetResponse()):
        return Err[bool](" vpn proxy udp e2e: response payload mismatch")
    return Ok[bool](true)

fn vpnProxyUdpE2eWaitRunOk(root: str,
                           proc: var hostops.SpawnedProcess,
                           logPath: str,
                           label: str): Result[bool] =
    let run: hostops.LoggedRun = hostops.SpawnedProcessWaitLogged(root, proc, 20, logPath)
    if !hostops.LoggedRunOk(run):
        return Err[bool](strutil.Join([" vpn proxy udp e2e: ", label, " failed: ", run.output], ""))
    return Ok[bool](true)

fn vpnProxyUdpE2eAppendLog(out: var str, root: str, logPath: str, label: str) =
    out = strutil.Join([out, "\n["], "")
    out = strutil.Join([out, label], "")
    out = strutil.Join([out, "]\n"], "")
    if chengpath.FileExistsNonEmpty(root, logPath):
        out = strutil.Join([out, chengpath.ReadTextFile("", logPath)], "")
        return
    out = strutil.Join([out, "<empty>"], "")

fn vpnProxyUdpE2eWriteFailure(root: str,
                              message: str,
                              targetLog: str,
                              localLog: str,
                              exitLog: str) =
    var out: str = message
    vpnProxyUdpE2eAppendLog(out, root, targetLog, "target")
    vpnProxyUdpE2eAppendLog(out, root, localLog, "local")
    vpnProxyUdpE2eAppendLog(out, root, exitLog, "exit")
    os.WriteLine(os.Get_stderr(), out)

fn vpnProxyUdpE2eKillAndFinalize(root: str,
                                 proc: var hostops.SpawnedProcess,
                                 logPath: str) =
    hostops.SpawnedProcessKill(proc)
    let _ = hostops.SpawnedProcessFinalize(root, proc, logPath, 124)

fn vpnProxyUdpE2eRunDefault(): int32 =
    let root: str = os.GetCurrentDir()
    let selfPath: str = cmdline.ProgramName()
    assert(len(selfPath) > 0, " vpn proxy udp e2e: self path")
    let materialRes: Result[bool] = vpnProxyUdpE2eWriteMaterials(root)
    if IsErr(materialRes):
        os.WriteLine(os.Get_stderr(), ErrorText(materialRes))
        return 1

    let targetReady: str = vpnProxyUdpE2eReadyPath(root, "target")
    let targetLog: str = vpnProxyUdpE2eLogPath(root, "target")
    let exitReady: str = vpnProxyUdpE2eReadyPath(root, "exit")
    let exitLog: str = vpnProxyUdpE2eLogPath(root, "exit")
    let localReady: str = vpnProxyUdpE2eReadyPath(root, "local")
    let localLog: str = vpnProxyUdpE2eLogPath(root, "local")
    let exitConfigPath: str = vpnProxyUdpE2ePath(root, "exit.config.json")
    let localConfigPath: str = vpnProxyUdpE2ePath(root, "local.config.json")

    vpnProxyUdpE2eRemoveFile(targetReady)
    vpnProxyUdpE2eRemoveFile(targetLog)
    vpnProxyUdpE2eRemoveFile(exitReady)
    vpnProxyUdpE2eRemoveFile(exitLog)
    vpnProxyUdpE2eRemoveFile(localReady)
    vpnProxyUdpE2eRemoveFile(localLog)

    assert(chengpath.WriteTextFile("", exitConfigPath, vpnProxyUdpE2eExitConfigText()),
           " vpn proxy udp e2e: write exit config")

    let targetSpawnRes = hostops.SpawnFile(root,
                                             "vpn_proxy_udp_e2e_target",
                                             selfPath,
                                             ["--role:target", "--port:0", strutil.Join(["--ready-path:", targetReady], "")],
                                             [],
                                             root)
    if IsErr(targetSpawnRes):
        os.WriteLine(os.Get_stderr(), Error(targetSpawnRes))
        return 1
    var targetProc = Value(targetSpawnRes)

    var targetPort: int32
    let targetReadyRes = vpnProxyUdpE2eWaitReadyPort(root, targetReady, targetProc, targetPort)
    if IsErr(targetReadyRes):
        hostops.SpawnedProcessKill(targetProc)
        os.WriteLine(os.Get_stderr(), ErrorText(targetReadyRes))
        return 1

    let exitSpawnRes = hostops.SpawnFile(root,
                                           "vpn_proxy_udp_e2e_exit",
                                           selfPath,
                                           ["--role:proxy-exit",
                                            strutil.Join(["--config:", exitConfigPath], ""),
                                            strutil.Join(["--ready-path:", exitReady], ""),
                                            "--accept-count:2"],
                                           [],
                                           root)
    if IsErr(exitSpawnRes):
        hostops.SpawnedProcessKill(targetProc)
        os.WriteLine(os.Get_stderr(), Error(exitSpawnRes))
        return 1
    var exitProc = Value(exitSpawnRes)

    var exitPort: int32
    let exitReadyRes = vpnProxyUdpE2eWaitReadyPort(root, exitReady, exitProc, exitPort)
    if IsErr(exitReadyRes):
        hostops.SpawnedProcessKill(exitProc)
        hostops.SpawnedProcessKill(targetProc)
        os.WriteLine(os.Get_stderr(), ErrorText(exitReadyRes))
        return 1
    assert(chengpath.WriteTextFile("", localConfigPath, vpnProxyUdpE2eLocalConfigText(exitPort)),
           " vpn proxy udp e2e: write local config")

    let localSpawnRes = hostops.SpawnFile(root,
                                            "vpn_proxy_udp_e2e_local",
                                            selfPath,
                                            ["--role:proxy-local",
                                             strutil.Join(["--config:", localConfigPath], ""),
                                             strutil.Join(["--ready-path:", localReady], ""),
                                             "--accept-count:1",
                                             "--probe-timeout-ms:500"],
                                            [],
                                            root)
    if IsErr(localSpawnRes):
        hostops.SpawnedProcessKill(exitProc)
        hostops.SpawnedProcessKill(targetProc)
        os.WriteLine(os.Get_stderr(), Error(localSpawnRes))
        return 1
    var localProc = Value(localSpawnRes)

    var localPort: int32
    let localReadyRes = vpnProxyUdpE2eWaitReadyPort(root, localReady, localProc, localPort)
    if IsErr(localReadyRes):
        hostops.SpawnedProcessKill(localProc)
        hostops.SpawnedProcessKill(exitProc)
        hostops.SpawnedProcessKill(targetProc)
        os.WriteLine(os.Get_stderr(), ErrorText(localReadyRes))
        return 1

    let clientRes: Result[bool] = vpnProxyUdpE2eRunClient(localPort, targetPort)
    if IsErr(clientRes):
        vpnProxyUdpE2eKillAndFinalize(root, localProc, localLog)
        vpnProxyUdpE2eKillAndFinalize(root, exitProc, exitLog)
        vpnProxyUdpE2eKillAndFinalize(root, targetProc, targetLog)
        vpnProxyUdpE2eWriteFailure(root, ErrorText(clientRes), targetLog, localLog, exitLog)
        return 1

    let targetWaitRes: Result[bool] = vpnProxyUdpE2eWaitRunOk(root, targetProc, targetLog, "target")
    if IsErr(targetWaitRes):
        vpnProxyUdpE2eKillAndFinalize(root, localProc, localLog)
        vpnProxyUdpE2eKillAndFinalize(root, exitProc, exitLog)
        vpnProxyUdpE2eWriteFailure(root, ErrorText(targetWaitRes), targetLog, localLog, exitLog)
        return 1
    let localWaitRes: Result[bool] = vpnProxyUdpE2eWaitRunOk(root, localProc, localLog, "local")
    if IsErr(localWaitRes):
        vpnProxyUdpE2eKillAndFinalize(root, exitProc, exitLog)
        vpnProxyUdpE2eWriteFailure(root, ErrorText(localWaitRes), targetLog, localLog, exitLog)
        return 1
    let exitWaitRes: Result[bool] = vpnProxyUdpE2eWaitRunOk(root, exitProc, exitLog, "exit")
    if IsErr(exitWaitRes):
        vpnProxyUdpE2eWriteFailure(root, ErrorText(exitWaitRes), targetLog, localLog, exitLog)
        return 1

    echo(" vpn_proxy_udp_end_to_end_smoke ok")
    return 0

fn vpnProxyUdpE2eRunTarget(): int32 =
    let port: int32 = cmdline.ReadInt32FlagOrDefault("--port", 0)
    let readyPath: str = cmdline.ReadFlagOrDefault("--ready-path", "")
    var socket: udp.UdpSocketHandle
    var sockName: udp.UdpSockAddr
    let bindRes: Result[bool] = vpnProxyUdpE2eBindSocket(vpnProxyUdpE2eTargetHost, port, false, socket, sockName)
    if IsErr(bindRes):
        os.WriteLine(os.Get_stderr(), ErrorText(bindRes))
        return 1
    if len(readyPath) > 0:
        if !chengpath.WriteTextFile("", readyPath, intToStr(sockName.port)):
            udp.UdpSocketClose(socket.fd)
            os.WriteLine(os.Get_stderr(), " vpn proxy udp e2e: write target ready failed")
            return 1
    var recv: udp.UdpRecvResult
    let recvRes: Result[bool] = udp.UdpRecvFromBlocking(socket.fd, 65535, recv)
    if IsErr(recvRes):
        udp.UdpSocketClose(socket.fd)
        os.WriteLine(os.Get_stderr(), ErrorText(recvRes))
        return 1
    if !vpnProxyUdpE2eBytesEq(recv.data, vpnProxyUdpE2eTargetRequest()):
        udp.UdpSocketClose(socket.fd)
        os.WriteLine(os.Get_stderr(), " vpn proxy udp e2e: target request mismatch")
        return 1
    let sendRes: Result[int32] = udp.UdpSendTo(socket.fd, vpnProxyUdpE2eTargetResponse(), recv.fromAddr)
    if IsErr(sendRes):
        udp.UdpSocketClose(socket.fd)
        os.WriteLine(os.Get_stderr(), ErrorText(sendRes))
        return 1
    udp.UdpSocketClose(socket.fd)
    echo(" vpn_proxy_udp_end_to_end_smoke target ok")
    return 0

fn vpnProxyUdpE2eRunProxyRole(mode: str): int32 =
    let root: str = os.GetCurrentDir()
    let configPath: str = cmdline.ReadFlagOrDefault("--config", "")
    let readyPath: str = cmdline.ReadFlagOrDefault("--ready-path", "")
    let acceptCount: int32 = cmdline.ReadInt32FlagOrDefault("--accept-count", 0)
    let probeTimeoutMs: int32 = cmdline.ReadInt32FlagOrDefault("--probe-timeout-ms", 1000)
    var args: str[]
    args = [mode,
            strutil.Join(["--config:", configPath], ""),
            strutil.Join(["--ready-path:", readyPath], ""),
            strutil.Join(["--accept-count:", intToStr(acceptCount)], ""),
            strutil.Join(["--probe-timeout-ms:", intToStr(probeTimeoutMs)], "")]
    return vpn.VpnProxyMain(root, args)

fn main(): int32 =
    let role: str = cmdline.ReadFlagOrDefault("--role", "")
    if role == "target":
        return vpnProxyUdpE2eRunTarget()
    if role == "proxy-exit":
        return vpnProxyUdpE2eRunProxyRole("exit")
    if role == "proxy-local":
        return vpnProxyUdpE2eRunProxyRole("local")
    return vpnProxyUdpE2eRunDefault()
