import cheng/core/tooling/determinism_driver as detdrive
import cheng/core/tooling/perf_driver as perfdrive

// Test slice to ptr+len integration path for ZRPC
// This tests the complete end-to-end flow where slices are converted to
// pointer+length pairs for FFI calls

fn main(): int32 =
    // Test 1: Direct slice to pointer/length conversion via driver functions
    var data: int32[] = [1, 2, 3, 4, 5]
    let ptr: ptr = &data[0]
    let len: int64 = int64(len(data))

    // Use determinism driver to verify slice handling
    let detResult: int32 = detdrive.VerifySliceMapping(ptr, len)
    if detResult != 0:
        echo("zrpc_slice_map_integration_smoke: FAIL - determinism driver slice verification failed")
        return 1

    // Test 2: Perf driver slice processing
    let perfResult: int32 = perfdrive.ProcessSlice(ptr, len)
    if perfResult != 0:
        echo("zrpc_slice_map_integration_smoke: FAIL - perf driver slice processing failed")
        return 2

    // Test 3: Multiple slices
    var data2: int32[] = [10, 20, 30]
    let ptr2: ptr = &data2[0]
    let len2: int64 = int64(len(data2))

    let detResult2: int32 = detdrive.VerifySliceMapping(ptr2, len2)
    if detResult2 != 0:
        echo("zrpc_slice_map_integration_smoke: FAIL - second determinism verification failed")
        return 3

    // Test 4: Empty slice (zero length)
    var emptyData: int32[] = []
    let emptyPtr: ptr = if len(emptyData) > 0 then &emptyData[0] else 0
    let emptyLen: int64 = int64(len(emptyData))
    let detResultEmpty: int32 = detdrive.VerifySliceMapping(emptyPtr, emptyLen)
    if detResultEmpty != 0:
        echo("zrpc_slice_map_integration_smoke: FAIL - empty slice verification failed")
        return 4

    echo(" zrpc_slice_map_integration_smoke ok")
    return 0
