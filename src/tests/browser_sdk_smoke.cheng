import std/system
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/binary_types as binary
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_fetch as fetch
import cheng/chain/content_runtime as runtime
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/browser/browser_sdk as sdk

fn browserSdkAddress(): binary.LsmrAddress =
    var out: binary.LsmrAddress
    out.depth = 2
    out.digits[0] = 6
    out.digits[1] = 4
    return out

fn browserSdkBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    sdk.BrowserSdkResetTransportStats()
    var server = sdk.BrowserSdkInit("browser.sdk.server")
    var client = sdk.BrowserSdkInit("browser.sdk.client")
    sdk.BrowserSdkEnableLightNode(server)
    sdk.BrowserSdkEnableLightNode(client)

    var listenAddr: types.Libp2pMultiaddr
    let listenRes = sdk.BrowserSdkListenPublic(listenAddr, server, "203.0.113.146", 9456)
    assert(IsOk(listenRes), " browser sdk: listen")
    let dialRes = sdk.BrowserSdkDialRemote(client, server, listenAddr)
    assert(IsOk(dialRes), " browser sdk: dial")

    let address = browserSdkAddress()
    let syncPayload = bytesFromString("browser-sdk-sync")
    let syncCid = hash256.Sha256Fixed(layout.ByteSpanFromBytes(syncPayload))
    var syncIngress = overlay.IngressEnvelope()
    syncIngress.sourcePeerId = server.host.selfPeerId.value
    syncIngress.topicScope = overlay.OverlayScopeRegion
    syncIngress.address = address
    syncIngress.payloadKind = 0
    syncIngress.payload = syncPayload
    syncIngress.payloadCid = syncCid
    syncIngress.payloadLen = bytesLen(syncPayload)
    syncIngress.stampEpoch = 21
    syncIngress.stampGanzhi = 42
    sdk.BrowserSdkStorePut(server, syncIngress)

    var query = overlay.StoreQuery()
    query.topicScope = overlay.OverlayScopeRegion
    query.address = address
    query.rangeLimit = 4
    var syncEntries: overlay.IngressEnvelope[]
    let syncRes = sdk.BrowserSdkSync(client, server, query, syncEntries)
    assert(IsOk(syncRes), " browser sdk: sync")
    assert(syncEntries.len == 1, " browser sdk: sync count")
    assert(layout.FixedBytes32Equal(syncEntries[0].payloadCid, syncCid),
        " browser sdk: sync cid")

    let pushPayload = bytesFromString("browser-sdk-pubsub")
    let pushCid = hash256.Sha256Fixed(layout.ByteSpanFromBytes(pushPayload))
    var pushIngress = overlay.IngressEnvelope()
    pushIngress.sourcePeerId = client.host.selfPeerId.value
    pushIngress.topicScope = overlay.OverlayScopeRegion
    pushIngress.address = address
    pushIngress.payloadKind = 0
    pushIngress.payload = pushPayload
    pushIngress.payloadCid = pushCid
    pushIngress.payloadLen = bytesLen(pushPayload)
    pushIngress.stampEpoch = 22
    pushIngress.stampGanzhi = 44
    var pushed: overlay.IngressEnvelope[]
    pushed = []
    add(pushed, pushIngress)
    let pushRes = sdk.BrowserSdkIngressPush(client, server, pushed)
    assert(IsOk(pushRes), " browser sdk: push")

    let shard = bytesFromString("browser-sdk-shard")
    let blob = shard
    let summaryRes = dag.DagBlobSummaryFromBytes(blob, bytesLen(shard))
    assert(IsOk(summaryRes), " browser sdk: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic, 1, 0, bytesLen(shard))
    assert(IsOk(paramsRes), " browser sdk: params")
    let params = Value(paramsRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard))
    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), " browser sdk: manifest")
    let manifest = Value(manifestRes)
    let requestRes = swarm.ErasureShardPullRequestMake(manifest, 0)
    assert(IsOk(requestRes), " browser sdk: request")
    let request = Value(requestRes)

    var serverRuntime = runtime.ContentRuntimeInit()
    assert(IsOk(runtime.ContentRuntimeStoreManifest(serverRuntime, manifest)),
        " browser sdk: store manifest")
    assert(IsOk(runtime.ContentRuntimeStoreBlobPayload(serverRuntime, summary.blobCid, blob)),
        " browser sdk: store blob")
    let seedResponseRes = swarm.ErasureShardPullResponseMake(request, shard)
    assert(IsOk(seedResponseRes), " browser sdk: seed response")
    assert(IsOk(runtime.ContentRuntimeStoreShardResponse(serverRuntime, Value(seedResponseRes))),
        " browser sdk: store shard")

    let manifestReqRes = fetch.ContentFetchRequestManifest(manifest.manifestCid)
    assert(IsOk(manifestReqRes), " browser sdk: manifest request")
    var manifestResp = fetch.ContentFetchResponse()
    let manifestFetchRes = sdk.BrowserSdkContentFetch(manifestResp,
                                                        client,
                                                        server,
                                                        serverRuntime,
                                                        Value(manifestReqRes))
    assert(IsOk(manifestFetchRes), " browser sdk: manifest fetch")
    var pulledManifest = swarm.ErasureShardManifest()
    assert(IsOk(fetch.ContentFetchResponseToManifestFill(pulledManifest,
                                                           Value(manifestReqRes),
                                                           manifestResp)),
        " browser sdk: manifest decode")
    assert(layout.FixedBytes32Equal(pulledManifest.manifestCid, manifest.manifestCid),
        " browser sdk: manifest cid")

    var shardResp = swarm.ErasureShardPullResponse()
    let shardPullRes = sdk.BrowserSdkShardPull(shardResp,
                                                 client,
                                                 server,
                                                 serverRuntime,
                                                 request)
    assert(IsOk(shardPullRes), " browser sdk: shard pull")
    assert(browserSdkBytesEqual(shardResp.payload, shard),
        " browser sdk: shard payload")

    assert(sdk.BrowserSdkStreamCount(client) == 5,
        " browser sdk: stream count")
    assert(sdk.BrowserSdkSignalEgressCount(client) == 5,
        " browser sdk: signal egress")
    assert(sdk.BrowserSdkSignalIngressCount(server) == 5,
        " browser sdk: signal ingress")
    assert(sdk.BrowserSdkStoreEntryCount(server) == 2,
        " browser sdk: store count")
    assert(sdk.BrowserSdkPublishCount(server) == 1,
        " browser sdk: publish count")
    assert(sdk.BrowserSdkBrowserOpenCountNow() == 1,
        " browser sdk: browser open")
    assert(sdk.BrowserSdkBrowserRequestCountNow() == 4,
        " browser sdk: browser request count")
    assert(sdk.BrowserSdkBrowserActiveSessionCountNow() == 1,
        " browser sdk: browser active session")

    echo(" browser_sdk_smoke ok")
    return 0
