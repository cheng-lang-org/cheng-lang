import std/system
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr

fn main(): int32 =
    let tcpText = bytesFromString("/ip4/127.0.0.1/tcp/4101")
    var tcp: types.Libp2pMultiaddr
    let tcpRes = multiaddr.Libp2pMultiaddrFillFromBytes(tcp, tcpText)
    assert(tcpRes.ok, " libp2p multiaddr call: tcp parse")
    let quicText = bytesFromString("/ip4/127.0.0.1/udp/4201/quic-v1")
    var quic: types.Libp2pMultiaddr
    let quicRes = multiaddr.Libp2pMultiaddrFillFromBytes(quic, quicText)
    assert(quicRes.ok, " libp2p multiaddr call: quic parse")
    echo(" libp2p_multiaddr_call_smoke ok")
    return 0
