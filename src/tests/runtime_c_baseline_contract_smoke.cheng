import std/strutils as strutil
import cheng/core/tooling/runtime_c_baseline_contract as baseline

fn main(): int32 =
    let orcThreshold = baseline.RuntimeCBaselineOrcRetainReleaseThreshold()
    let exactOrc = baseline.RuntimeCBaselineSampleNew("orc_retain_release",
                                                      int64(100),
                                                      int64(200))
    assert(exactOrc.ratioX1000 == int64(2000),
           " runtime c baseline: exact ratio")
    assert(baseline.RuntimeCBaselineSampleOk(exactOrc, orcThreshold),
           " runtime c baseline: exact threshold ok")

    let tooSlowOrc = baseline.RuntimeCBaselineSampleNew("orc_retain_release",
                                                        int64(100),
                                                        int64(201))
    assert(tooSlowOrc.ratioX1000 == int64(2010),
           " runtime c baseline: ceil ratio")
    assert(!baseline.RuntimeCBaselineSampleOk(tooSlowOrc, orcThreshold),
           " runtime c baseline: threshold fails")

    let wrongCase = baseline.RuntimeCBaselineSampleNew("atomic_i32_add",
                                                       int64(100),
                                                       int64(120))
    assert(!baseline.RuntimeCBaselineSampleOk(wrongCase, orcThreshold),
           " runtime c baseline: case mismatch fails")

    let invalidC = baseline.RuntimeCBaselineSampleNew("orc_retain_release",
                                                      int64(0),
                                                      int64(1))
    assert(invalidC.ratioX1000 == int64(-1),
           " runtime c baseline: invalid c baseline")
    assert(!baseline.RuntimeCBaselineSampleOk(invalidC, orcThreshold),
           " runtime c baseline: invalid sample fails")

    let atomicThreshold = baseline.RuntimeCBaselineAtomicI32AddThreshold()
    let atomicSample = baseline.RuntimeCBaselineSampleNew("atomic_i32_add",
                                                          int64(80),
                                                          int64(120))
    assert(baseline.RuntimeCBaselineSampleOk(atomicSample, atomicThreshold),
           " runtime c baseline: atomic threshold ok")

    assert(baseline.RuntimeCBaselineThreadSpawnJoinThreshold().maxRatioX1000 == int64(3000),
           " runtime c baseline: thread threshold")
    assert(baseline.RuntimeCBaselineSliceBoundsLoopThreshold().maxRatioX1000 == int64(1200),
           " runtime c baseline: bounds threshold")
    assert(baseline.RuntimeCBaselineHashLookupThreshold().maxRatioX1000 == int64(1500),
           " runtime c baseline: hash threshold")
    assert(baseline.RuntimeCBaselineSyscallWriteThreshold().maxRatioX1000 == int64(1100),
           " runtime c baseline: syscall threshold")

    let row = baseline.RuntimeCBaselineReportRow(exactOrc, orcThreshold)
    assert(strutil.Contains(row, "runtime_baseline=c"),
           " runtime c baseline: row baseline")
    assert(strutil.Contains(row, "runtime_case=cheng"),
           " runtime c baseline: row case")
    assert(strutil.Contains(row, "runtime_case_name=orc_retain_release"),
           " runtime c baseline: row case name")
    assert(strutil.Contains(row, "runtime_perf_ratio_x1000=2000"),
           " runtime c baseline: row ratio")
    assert(strutil.Contains(row, "limit_runtime_perf_ratio_x1000=2000"),
           " runtime c baseline: row limit")

    let unavailable = baseline.RuntimeCBaselineUnavailableReport("orc_retain_release",
                                                                 "missing_real_c_measurement")
    assert(strutil.Contains(unavailable, "runtime_c_baseline_status=unavailable"),
           " runtime c baseline: unavailable status")
    assert(strutil.Contains(unavailable, "runtime_c_baseline_hard_fail=1"),
           " runtime c baseline: unavailable hard fail")
    assert(strutil.Contains(unavailable, "runtime_c_baseline_reason=missing_real_c_measurement"),
           " runtime c baseline: unavailable reason")

    echo(" runtime_c_baseline_contract_smoke ok")
    return 0
