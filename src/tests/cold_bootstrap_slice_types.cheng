type TypeKind = Int32Kind | StrKind | BoolKind

type TypeInfo =
    Named(name: str, kind: TypeKind)
    | Ptr(innerName: str)
    | Empty

fn MakeInt32(): TypeInfo =
    return Named("int32", Int32Kind)

fn MakeStr(): TypeInfo =
    return Named("str", StrKind)

fn TypeSize(info: TypeInfo): int32 =
    match info:
        Named(n, k) =>
            match k:
                Int32Kind =>
                    return 4
                StrKind =>
                    return 16
                BoolKind =>
                    return 1
        Ptr(inner) =>
            return 8
        Empty =>
            return 0

fn main(): int32 =
    let t = MakeInt32()
    return TypeSize(t)
