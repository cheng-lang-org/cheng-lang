import std/os as os
import std/strings as strings

fn main(): int32 =
    let hostPath = "src/libp2p/host/host.cheng"
    let kadPath = "src/libp2p/discovery/kad.cheng"
    let storeSyncPath = "src/libp2p/protocols/store_sync.cheng"
    let hostQuicPath = "src/libp2p/host/host_quic.cheng"
    assert(os.FileExists(hostPath), " libp2p register handler symbol: host source exists")
    assert(os.FileExists(kadPath), " libp2p register handler symbol: kad source exists")
    assert(os.FileExists(storeSyncPath), " libp2p register handler symbol: store sync source exists")
    assert(os.FileExists(hostQuicPath), " libp2p register handler symbol: host quic source exists")
    let hostText = os.ReadFile(hostPath)
    let kadText = os.ReadFile(kadPath)
    let storeSyncText = os.ReadFile(storeSyncPath)
    let hostQuicText = os.ReadFile(hostQuicPath)
    assert(strings.StrContains(hostText, "fn Libp2pRegisterHandler("),
           " libp2p register handler symbol: definition exists")
    assert(!strings.StrContains(hostText,
                                "fn Libp2pRegisterHandler(host: var Libp2pHost,\n                           protocol: types.Libp2pProtocolId) =\n    Libp2pRegisterHandler(host, protocol)"),
           " libp2p register handler symbol: no recursive wrapper")
    assert(strings.StrContains(hostText, "fn Libp2pKadProvide("),
           " libp2p symbol: host kad wrapper exists")
    assert(!strings.StrContains(kadText, "fn Libp2pKadProvide("),
           " libp2p symbol: kad implementation uses unique name")
    assert(strings.StrContains(kadText, "fn Libp2pKadStateProvide("),
           " libp2p symbol: kad implementation exists")
    assert(strings.StrContains(hostText, "fn Libp2pStorePut("),
           " libp2p symbol: host store wrapper exists")
    assert(!strings.StrContains(storeSyncText, "fn Libp2pStorePut("),
           " libp2p symbol: store implementation uses unique name")
    assert(strings.StrContains(storeSyncText, "fn Libp2pStoreEntriesPut("),
           " libp2p symbol: store implementation exists")
    assert(strings.StrContains(hostText, "fn Libp2pSyncServePayload("),
           " libp2p symbol: host sync wrapper exists")
    assert(!strings.StrContains(storeSyncText, "fn Libp2pSyncServePayload("),
           " libp2p symbol: sync implementation uses unique name")
    assert(strings.StrContains(storeSyncText, "fn Libp2pStoreSyncServePayload("),
           " libp2p symbol: sync implementation exists")
    assert(!strings.StrContains(storeSyncText, "fn Libp2pStoreQueryCount("),
           " libp2p symbol: store query count implementation uses unique name")
    assert(!strings.StrContains(storeSyncText, "fn Libp2pStoreQueryFirst("),
           " libp2p symbol: store query first implementation uses unique name")
    assert(!strings.StrContains(storeSyncText, "fn Libp2pStoreQuery("),
           " libp2p symbol: store query implementation uses unique name")
    assert(!strings.StrContains(storeSyncText, "fn Libp2pStoreQueryFill("),
           " libp2p symbol: store query fill implementation uses unique name")
    assert(strings.StrContains(storeSyncText, "fn Libp2pStoreEntriesQueryCount("),
           " libp2p symbol: store query count implementation exists")
    assert(strings.StrContains(storeSyncText, "fn Libp2pStoreEntriesQueryFirst("),
           " libp2p symbol: store query first implementation exists")
    assert(strings.StrContains(storeSyncText, "fn Libp2pStoreEntriesQuery("),
           " libp2p symbol: store query implementation exists")
    assert(strings.StrContains(storeSyncText, "fn Libp2pStoreEntriesQueryFill("),
           " libp2p symbol: store query fill implementation exists")
    assert(!strings.StrContains(hostQuicText, "fn Libp2pRequestResponse("),
           " libp2p symbol: quic request response uses unique name")
    assert(!strings.StrContains(hostQuicText, "fn Libp2pSyncRequest("),
           " libp2p symbol: quic sync request uses unique name")
    assert(!strings.StrContains(hostQuicText, "fn Libp2pQuicRequestResponse("),
           " libp2p symbol: host quic request response avoids transport name")
    assert(strings.StrContains(hostQuicText, "fn Libp2pHostQuicRequestResponse("),
           " libp2p symbol: quic request response implementation exists")
    assert(strings.StrContains(hostQuicText, "fn Libp2pQuicSyncRequest("),
           " libp2p symbol: quic sync request implementation exists")
    echo(" libp2p_register_handler_symbol_smoke ok")
    return 0
