    return c_time(nil) * 1000

@exportc("um_sys_disk_total_bytes")
fn UmSysDiskTotalBytesCompat(path: cstring): int64 =
    var fs: DarwinStatvfs
    let target: cstring = if ptr(path) == nil || system.c_strlen(path) <= 0: dupText("/") else: path
    if c_statvfs(target, ptr(&fs)) != 0:
        return 0
    return fs.f_blocks * fs.f_frsize

@exportc("um_sys_disk_available_bytes")
fn UmSysDiskAvailableBytesCompat(path: cstring): int64 =
    var fs: DarwinStatvfs
    let target: cstring = if ptr(path) == nil || system.c_strlen(path) <= 0: dupText("/") else: path
    if c_statvfs(target, ptr(&fs)) != 0:
        return 0
    return fs.f_bavail * fs.f_frsize

@exportc("um_vrf_generate_keypair_json")
fn UmVrfGenerateKeypairJsonCompat(): cstring =
    let seed: ChengBytes = fillRandom(32)
    if seed.len < 32:
        return jsonError("rng_unavailable")
    let pub: ChengBytes = derivePublicKey(seed)
    let priv: ChengBytes = bytesFromStd(rawbytes.bytesConcat(bytesToStd(seed), bytesToStd(pub)))
    return dupText(
        "{\"ok\":true,\"publicKeyHex\":\"" + hexEncode(pub) +
        "\",\"privateKeyHex\":\"" + hexEncode(priv) + "\"}"
    )

@exportc("um_vrf_sign_json")
fn UmVrfSignJsonCompat(privateKeyHex: cstring, inputHex: cstring): cstring =
    if ptr(privateKeyHex) == nil || ptr(inputHex) == nil:
        return jsonError("missing_input")
    let msg: ChengBytes = hexDecode(borrowText(inputHex))
    if msg.len <= 0:
        return jsonError("invalid_input_hex")
    let privateKey: ChengBytes = hexDecode(borrowText(privateKeyHex))
    if privateKey.len != 32 && privateKey.len != 64:
        return jsonError("invalid_private_key")
    var pub: ChengBytes = emptyBytesCompat()
    if privateKey.len == 64:
        pub = bytesFromStd(rawbytes.bytesSlice(bytesToStd(privateKey), 32, 32))
    else:
        pub = derivePublicKey(privateKey)
    if pub.len != 32:
        return jsonError("invalid_private_key")
    let sig: ChengBytes = makeSignature(pub, msg)
    return jsonOkSignature(hexEncode(sig))

@exportc("um_vrf_verify_json")
fn UmVrfVerifyJsonCompat(publicKeyHex: cstring, inputHex: cstring, signatureHex: cstring): cstring =
    if ptr(publicKeyHex) == nil || ptr(inputHex) == nil || ptr(signatureHex) == nil:
        return jsonError("missing_input")
    let pub: ChengBytes = hexDecode(borrowText(publicKeyHex))
    if pub.len != 32:
        return jsonError("invalid_public_key")
    let msg: ChengBytes = hexDecode(borrowText(inputHex))
    if msg.len <= 0:
        return jsonError("invalid_input_hex")
    let sig: ChengBytes = hexDecode(borrowText(signatureHex))
    if sig.len != 64:
        return jsonError("invalid_signature")
    let expected: ChengBytes = makeSignature(pub, msg)
    return jsonOkVerify(rawbytes.bytesEqual(bytesToStd(sig), bytesToStd(expected)))

