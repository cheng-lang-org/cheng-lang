@exportc("cheng_ftell")
fn ChengFtellCompat(stream: int64): int64 =
    return c_ftell(ptr(uint64(stream)))

@exportc("cheng_read_file")
fn ChengReadFileCompat(path: cstring): cstring =
    if ptr(path) == nil:
        return emptyCString()
    let stream: ptr = c_fopen(path, dupText("rb"))
    if stream == nil:
        return emptyCString()
    if c_fseek(stream, 0, seekEnd) != 0:
        let _ = c_fclose(stream)
        return emptyCString()
    let fileSize: int64 = c_ftell(stream)
    if fileSize < 0 || c_fseek(stream, 0, seekSet) != 0:
        let _ = c_fclose(stream)
        return emptyCString()
    if fileSize == 0:
        let _ = c_fclose(stream)
        return emptyCString()
    let raw: ptr = system.alloc(int32(fileSize) + 1)
    if raw == nil:
        let _ = c_fclose(stream)
        return emptyCString()
    let readCount: int64 = c_fread(raw, 1, fileSize, stream)
    let _ = c_fclose(stream)
    rawmem_support.RawmemWriteI8(raw, int32(readCount), int8(0))
    return dupText(system.strFromCStringBorrow(cstring(raw)))

@exportc("cheng_write_file")
fn ChengWriteFileCompat(path: cstring, content: cstring): int32 =
    if ptr(path) == nil:
        return 0
    let stream: ptr = c_fopen(path, dupText("wb"))
    if stream == nil:
        return 0
    let text: str = borrowText(content)
    let writeLen: int32 = len(text)
    var wrote: int64
    if writeLen > 0:
        wrote = c_fwrite(system.strDataPtr(text), 1, writeLen, stream)
    let _ = c_fclose(stream)
    if int32(wrote) == writeLen:
        return 1
    return 0

