@importc("statvfs")
fn c_statvfs(path: cstring, out: ptr): int32

const
    seqElemBytes = 8
    seekSet = 0
    seekEnd = 2
    maxHostSlots = 8
    hexDigits = "0123456789abcdef"

type
    DarwinStatvfs =
        f_bsize: int64
        f_frsize: int64
        f_blocks: int64
        f_bfree: int64
        f_bavail: int64
        f_files: int64
        f_ffree: int64
        f_favail: int64

    ChengBytes =
        data: ptr
        len: int32

    ChengResultAny =
        ok: uint8
        pad0: uint8
        pad1: uint8
        pad2: uint8
        pad3: uint8
        pad4: uint8
        pad5: uint8
        pad6: uint8
        value: uint64
        code: int32
        pad7: int32
        msg: cstring

var
    gNodePtrs: ptr[maxHostSlots]
    gSwitchPtrs: ptr[maxHostSlots]

fn trimText(text: str): str =
    let n: int32 = len(text)
    if n <= 0:
        return ""
    var left: int32
    while left < n:
        let ch: char = text[left]
        if ch != ' ' && ch != '\t' && ch != '\r' && ch != '\n':
            break
        left = left + 1
    if left >= n:
        return ""
    var right: int32 = n
    while right > left:
        let ch: char = text[right - 1]
        if ch != ' ' && ch != '\t' && ch != '\r' && ch != '\n':
            break
        right = right - 1
    return strings.sliceBytes(text, left, right - left)

fn borrowText(raw: cstring): str =
    if ptr(raw) == nil:
        return ""
    return system.strFromCStringBorrow(raw)

fn dupText(text: str): cstring =
    let n: int32 = system.strLenFast(text)
    if n <= 0:
        return system.driver_c_new_string(0)
    return system.driver_c_new_string_copy_n(system.strDataPtr(text), n)

fn dupRaw(raw: cstring): cstring =
    return dupText(borrowText(raw))

fn emptyCString(): cstring =
    return system.driver_c_new_string(0)

fn boolToI32(value: bool): int32 =
    if value:
        return 1
    return 0

fn emptyBytesCompat(): ChengBytes =
    var out: ChengBytes
    out.data = nil
    out.len = 0
    return out

fn bytesViewCompat(data: ptr, length: int32): ChengBytes =
    var out: ChengBytes
    out.data = data
    if length <= 0:
        out.len = 0
    else:
        out.len = length
    return out

fn bytesToStd(value: ChengBytes): rawbytes.Bytes =
    var out: rawbytes.Bytes
    out.data = value.data
    out.len = value.len
    return out

fn bytesFromStd(value: rawbytes.Bytes): ChengBytes =
    var out: ChengBytes
    out.data = value.data
    out.len = value.len
    return out

fn writeResult(out: ptr, ok: bool, value: uint64, code: int32, msg: cstring) =
    if out == nil:
        return
    var resultValue: ChengResultAny
    if ok:
        resultValue.ok = uint8(1)
    else:
        resultValue.ok = uint8(0)
    resultValue.pad0 = uint8(0)
    resultValue.pad1 = uint8(0)
    resultValue.pad2 = uint8(0)
    resultValue.pad3 = uint8(0)
    resultValue.pad4 = uint8(0)
    resultValue.pad5 = uint8(0)
    resultValue.pad6 = uint8(0)
    resultValue.value = value
    resultValue.code = code
    resultValue.pad7 = 0
    resultValue.msg = msg
    system.memCopyCompat(out, &resultValue, int32(sizeof(ChengResultAny)))

fn resultOk(out: ptr, value: uint64) =
    writeResult(out, true, value, 0, emptyCString())

fn resultErr(out: ptr, msg: str) =
    writeResult(out, false, uint64(0), 1, dupText(msg))

fn seqSlotPtr(buffer: ptr, idx: int32, elemBytes: int32): ptr =
    return system.system_ptr_add(buffer, idx * elemBytes)

fn seqEnsureCapacity(seqPtr: ptr, needLen: int32, elemBytes: int32): bool =
    if seqPtr == nil:
        return false
    let oldCap: int32 = system.chengSeqHdrCapGet(seqPtr)
    let oldBuf: ptr = system.chengSeqHdrBufferGet(seqPtr)
    if needLen <= oldCap && (needLen <= 0 || oldBuf != nil):
        return true
    var newCap: int32 = oldCap
    if newCap < 4:
        newCap = 4
    while newCap < needLen:
        newCap = newCap * 2
    let totalBytes: int32 = newCap * elemBytes
    var newBuf: ptr = nil
    if oldBuf == nil:
        newBuf = system.heapNewCompat(totalBytes)
        if newBuf == nil:
            return false
        rawmem_support.RawmemSet(newBuf, 0, totalBytes)
    else:
        newBuf = system.heapResizeCompat(oldBuf, totalBytes)
        if newBuf == nil:
            return false
        if newCap > oldCap:
            rawmem_support.RawmemSet(
                rawmem_support.RawmemPtrAdd(newBuf, oldCap * elemBytes),
                0,
                (newCap - oldCap) * elemBytes
            )
    system.chengSeqHdrBufferSet(seqPtr, newBuf)
    system.chengSeqHdrCapSet(seqPtr, newCap)
    return true

fn hexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return system.ord(ch) - system.ord('0')
    if ch >= 'a' && ch <= 'f':
        return system.ord(ch) - system.ord('a') + 10
    if ch >= 'A' && ch <= 'F':
        return system.ord(ch) - system.ord('A') + 10
    return -1

fn hexSpan(text: str): str =
    var out: str = trimText(text)
    if len(out) >= 2 && out[0] == '0' && (out[1] == 'x' || out[1] == 'X'):
        out = strings.sliceBytes(out, 2, len(out) - 2)
    return out

fn hexDecode(text: str): ChengBytes =
    let normalized: str = hexSpan(text)
    let n: int32 = len(normalized)
    if n <= 0 || (n % 2) != 0:
        return emptyBytesCompat()
    var out: ChengBytes = bytesFromStd(rawbytes.bytesAlloc(n / 2))
    var i: int32
    while i < out.len:
        let hi: int32 = hexValue(normalized[i * 2])
        let lo: int32 = hexValue(normalized[i * 2 + 1])
        if hi < 0 || lo < 0:
            return emptyBytesCompat()
        var outBytes: rawbytes.Bytes = bytesToStd(out)
        rawbytes.bytesSet(outBytes, i, (hi << 4) | lo)
        i = i + 1
    return out

fn hexEncode(value: ChengBytes): str =
    return rawbytes.bytesToHex(bytesToStd(value))

fn mix64(x: uint64): uint64 =
    var v: uint64 = x
    v = v ^ (v >> uint64(33))
    v = v * uint64(0xff51afd7ed558ccd)
    v = v ^ (v >> uint64(33))
    v = v * uint64(0xc4ceb9fe1a85ec53)
    v = v ^ (v >> uint64(33))
    return v

fn fillRandom(lenValue: int32): ChengBytes =
    if lenValue <= 0:
        return emptyBytesCompat()
    var out: ChengBytes = bytesFromStd(rawbytes.bytesAlloc(lenValue))
    if c_getentropy(out.data, lenValue) == 0:
        return out
    var seed: uint64 = mix64(uint64(c_time(nil)) ^ uint64(lenValue) ^ system.ptrToU64(out.data))
    var i: int32
    while i < out.len:
        seed = mix64(seed + uint64(i) * uint64(0x9e3779b97f4a7c15) + uint64(0xa0761d6478bd642f))
        var outBytes: rawbytes.Bytes = bytesToStd(out)
        rawbytes.bytesSet(outBytes, i, int32(seed & uint64(0xff)))
        i = i + 1
    return out

fn derivePublicKey(seed: ChengBytes): ChengBytes =
    if seed.len < 32:
        return emptyBytesCompat()
    var out: ChengBytes = bytesFromStd(rawbytes.bytesAlloc(32))
    var state: uint64 = uint64(0x6a09e667f3bcc909)
    var i: int32
    while i < 32:
        state = mix64(state ^ (uint64(rawbytes.bytesGet(bytesToStd(seed), i)) + uint64(i + 1) * uint64(0x9e3779b97f4a7c15)))
        i = i + 1
    i = 0
    while i < 32:
        state = mix64(state + uint64(i + 1) * uint64(0xbf58476d1ce4e5b9) + uint64(rawbytes.bytesGet(bytesToStd(seed), i)))
        var outBytes: rawbytes.Bytes = bytesToStd(out)
        rawbytes.bytesSet(outBytes, i, int32(state & uint64(0xff)))
        i = i + 1
    return out

fn makeSignature(pub: ChengBytes, msg: ChengBytes): ChengBytes =
    if pub.len < 32:
        return emptyBytesCompat()
    var out: ChengBytes = bytesFromStd(rawbytes.bytesAlloc(64))
    var state: uint64 = uint64(0x243f6a8885a308d3)
    var i: int32
    while i < 32:
        state = mix64(state ^ (uint64(rawbytes.bytesGet(bytesToStd(pub), i)) + uint64(i + 3) * uint64(0x94d049bb133111eb)))
        i = i + 1
    i = 0
    while i < msg.len:
        state = mix64(state ^ (uint64(rawbytes.bytesGet(bytesToStd(msg), i)) + uint64(i + 5) * uint64(0x9e3779b97f4a7c15)))
        i = i + 1
    i = 0
    while i < 64:
        var m: int32
        if msg.len > 0:
            m = rawbytes.bytesGet(bytesToStd(msg), i % msg.len)
        else:
            m = rawbytes.bytesGet(bytesToStd(pub), (i * 7) % 32)
        state = mix64(
            state +
            (uint64(m) << uint64((i % 8) * 8)) +
            uint64(rawbytes.bytesGet(bytesToStd(pub), (i * 13) % 32)) +
            uint64(i + 1) * uint64(0xd6e8feb86659fd93)
        )
        var outBytes: rawbytes.Bytes = bytesToStd(out)
        rawbytes.bytesSet(outBytes, i, int32(state & uint64(0xff)))
        i = i + 1
    return out

fn jsonError(code: str): cstring =
    return dupText("{\"ok\":false,\"error\":\"" + code + "\"}")

fn jsonOkSignature(signatureHex: str): cstring =
    return dupText("{\"ok\":true,\"signatureHex\":\"" + signatureHex + "\"}")

fn jsonOkVerify(valid: bool): cstring =
    if valid:
        return dupText("{\"ok\":true,\"valid\":true}")
    return dupText("{\"ok\":true,\"valid\":false}")

@exportc("ChengMain")
fn ChengMainCompat() =
    return

@exportc("cheng_thread_attach")
fn ChengThreadAttachCompat() =
    return

@exportc("cheng_thread_detach")
fn ChengThreadDetachCompat() =
    return

@exportc("DmEnvelope")
fn DmEnvelopeCompat(): uint64 =
    return uint64(0)

@exportc("IsOk")
fn IsOkCompat(res: ptr): int32 =
    if res == nil:
        return 0
    var resultValue: ChengResultAny
    system.memCopyCompat(&resultValue, res, int32(sizeof(ChengResultAny)))
    return boolToI32(resultValue.ok != uint8(0))

@exportc("IsErr")
fn IsErrCompat(res: ptr): int32 =
    if res == nil:
        return 1
    var resultValue: ChengResultAny
    system.memCopyCompat(&resultValue, res, int32(sizeof(ChengResultAny)))
    if resultValue.ok != uint8(0):
        return 0
    return 1

@exportc("Error")
fn ErrorCompat(res: ptr): cstring =
    if res == nil:
        return dupText("error")
    var resultValue: ChengResultAny
    system.memCopyCompat(&resultValue, res, int32(sizeof(ChengResultAny)))
    let msg: cstring = resultValue.msg
    if ptr(msg) != nil:
        return msg
    if resultValue.ok != uint8(0):
        return emptyCString()
    return dupText("error")

@exportc("value")
fn ValueCompat(res: ptr): uint64 =
    if res == nil:
        return uint64(0)
    var resultValue: ChengResultAny
    system.memCopyCompat(&resultValue, res, int32(sizeof(ChengResultAny)))
    return resultValue.value

@exportc("bytesAlloc")
fn BytesAllocCompat(length: int32): ChengBytes =
    return bytesFromStd(rawbytes.bytesAlloc(length))

@exportc("bytesFromString")
fn BytesFromStringCompat(text: cstring): ChengBytes =
    return bytesFromStd(rawbytes.bytesFromString(borrowText(text)))

@exportc("bytesLen")
fn BytesLenCompat(value: ChengBytes): int32 =
    return value.len

@exportc("bytesSet")
fn BytesSetCompat(value: ptr, idx: int32, data: int32) =
    if value == nil:
        return
    var bytesValue: ChengBytes
    system.memCopyCompat(&bytesValue, value, int32(sizeof(ChengBytes)))
    if bytesValue.data == nil || bytesValue.len <= 0:
        return
    var stdBytes: rawbytes.Bytes = bytesToStd(bytesValue)
    rawbytes.bytesSet(stdBytes, idx, data)

@exportc("bytesGet")
fn BytesGetCompat(value: ChengBytes, idx: int32): int32 =
    return rawbytes.bytesGet(bytesToStd(value), idx)

@exportc("bytesSlice")
fn BytesSliceCompat(value: ChengBytes, start: int32, count: int32): ChengBytes =
    return bytesFromStd(rawbytes.bytesSlice(bytesToStd(value), start, count))

@exportc("cheng_seq_get")
fn ChengSeqGetCompat(buffer: ptr, lenValue: int32, idx: int32, elemSize: int32): ptr =
    if buffer == nil || idx < 0 || idx >= lenValue || elemSize <= 0:
        return nil
    return seqSlotPtr(buffer, idx, elemSize)

@exportc("cheng_seq_set")
fn ChengSeqSetCompat(buffer: ptr, lenValue: int32, idx: int32, elemSize: int32): ptr =
    if buffer == nil || idx < 0 || idx >= lenValue || elemSize <= 0:
        return nil
    return seqSlotPtr(buffer, idx, elemSize)

@exportc("cheng_seq_ptr_get_compat")
fn ChengSeqGetPtrCompat(seqPtr: ptr, idx: int32): ptr =
    if seqPtr == nil || idx < 0:
        return nil
    let seqLen: int32 = system.chengSeqHdrLenGet(seqPtr)
    if idx >= seqLen:
        return nil
    let buffer: ptr = system.chengSeqHdrBufferGet(seqPtr)
    if buffer == nil:
        return nil
    let slot: ptr = seqSlotPtr(buffer, idx, seqElemBytes)
    return system.ptrLoadCompat(slot)

@exportc("cheng_seq_ptr_set_compat")
fn ChengSeqSetPtrCompat(seqPtr: ptr, idx: int32, value: ptr) =
    if seqPtr == nil || idx < 0:
        return
    if !seqEnsureCapacity(seqPtr, idx + 1, seqElemBytes):
        return
    let buffer: ptr = system.chengSeqHdrBufferGet(seqPtr)
    if buffer == nil:
        return
    let slot: ptr = seqSlotPtr(buffer, idx, seqElemBytes)
    system.ptrStoreCompat(slot, value)
    if idx + 1 > system.chengSeqHdrLenGet(seqPtr):
        system.chengSeqHdrLenSet(seqPtr, idx + 1)

@exportc("add")
fn ChengSeqAddPtrCompat(seqPtr: ptr, value: ptr) =
    if seqPtr == nil:
        return
    let writeAt: int32 = system.chengSeqHdrLenGet(seqPtr)
    ChengSeqSetPtrCompat(seqPtr, writeAt, value)

@exportc("len")
fn ChengSeqLenCompat(seqPtr: ptr): int32 =
    if seqPtr == nil:
        return 0
    return system.chengSeqHdrLenGet(seqPtr)

@exportc("cheng_i64_to_cstring_compat")
fn ChengDollarI64Compat(value: int64): cstring =
