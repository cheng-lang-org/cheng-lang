@exportc("cheng_file_exists")
fn ChengFileExistsCompat(path: cstring): int32 =
    let stream: ptr = c_fopen(path, dupText("rb"))
    if stream == nil:
        return 0
    let _ = c_fclose(stream)
    return 1

