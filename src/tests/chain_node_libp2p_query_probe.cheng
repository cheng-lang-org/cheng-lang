import std/system
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node libp2p query probe: init server")
    var client: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(client, "node-b", "chain-node-a")),
           " chain_node libp2p query probe: init client")

    var serverHost = host.Libp2pHostInit("chain.server")
    var clientHost = host.Libp2pHostInit("chain.client")
    var serverAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(serverAddr, "127.0.0.1", 6201)
    let listenRes = host.Libp2pListen(serverHost, serverAddr)
    assert(listenRes.ok, " chain_node libp2p query probe: listen")

    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolGossipsub)
    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolStore)
    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolGossipsub)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolStore)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolSync)

    let dialRes = host.Libp2pDial(clientHost,
                                    serverHost.selfPeerId,
                                    serverAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " chain_node libp2p query probe: dial")

    let mintRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintRes.ok, " chain_node libp2p query probe: mint")
    let transferRes = node.ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferRes.ok, " chain_node libp2p query probe: transfer")

    let serveRes = net.ChainNodeLibp2pServeOnce(server, serverHost)
    assert(serveRes.ok, " chain_node libp2p query probe: serve")

    var latest: overlay.IngressEnvelope
    let latestRes = net.ChainNodeLibp2pLatestSnapshotHostIndex(serverHost, client.address)
    assert(IsOk(latestRes), " chain_node libp2p query probe: latest")
    let latestIndex = latestRes.value
    let latestEntry = serverHost.storeEntries[latestIndex]
    net.ChainNodeLibp2pCopyIngress(latest, latestEntry.ingress)

    var hostSnapshot: node.ChainNodeServeSnapshot
    var hostIngress: overlay.IngressEnvelope
    let hostIndexRes = net.ChainNodeLibp2pLatestSnapshotHostIndex(serverHost, client.address)
    assert(IsOk(hostIndexRes), " chain_node libp2p query probe: host latest")
    let hostIndex = hostIndexRes.value
    let hostEntry = serverHost.storeEntries[hostIndex]
    net.ChainNodeLibp2pCopyIngress(hostIngress, hostEntry.ingress)
    let hostDecodeRes = net.ChainNodeLibp2pDecodeSnapshotFill(hostIngress.payload,
                                                                hostSnapshot)
    assert(hostDecodeRes.ok, " chain_node libp2p query probe: host decode")
    assert(hostSnapshot.eventCids.len == 2, " chain_node libp2p query probe: host decode len")

    var query: overlay.StoreQuery
    net.ChainNodeLibp2pSnapshotQueryFill(query, client.address)
    var entries: overlay.IngressEnvelope[]
    let entriesRes = host.Libp2pSyncRequest(clientHost, serverHost, serverHost.selfPeerId, query, entries)
    assert(entriesRes.ok, " chain_node libp2p query probe: sync request")
    assert(entries.len == 2, " chain_node libp2p query probe: entries len")

    var syncedSnapshot: node.ChainNodeServeSnapshot
    var syncedIngress: overlay.IngressEnvelope
    let syncedIndexRes = net.ChainNodeLibp2pLatestSnapshotIndexFromIngresses(entries, client.address)
    assert(IsOk(syncedIndexRes), " chain_node libp2p query probe: synced latest")
    let syncedIndex = syncedIndexRes.value
    net.ChainNodeLibp2pCopyIngress(syncedIngress, entries[syncedIndex])
    let syncedDecodeRes = net.ChainNodeLibp2pDecodeSnapshotFill(syncedIngress.payload,
                                                                  syncedSnapshot)
    assert(syncedDecodeRes.ok, " chain_node libp2p query probe: synced decode")

    let syncRes = node.ChainNodeSyncOnce(client, syncedSnapshot)
    assert(syncRes.ok, " chain_node libp2p query probe: sync")
    assert(syncRes.value, " chain_node libp2p query probe: sync changed")

    echo(" chain_node_libp2p_query_probe ok")
    return 0
