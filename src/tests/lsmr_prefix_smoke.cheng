import std/system
import std/result
import cheng/chain/binary_types as types
import cheng/chain/lsmr
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    var digits: int32[]
    digits = []
    add(digits, 1)
    add(digits, 2)
    add(digits, 3)
    let addressRes = types.LsmrAddressFromDigits(digits)
    assert(IsOk(addressRes), " lsmr prefix smoke: address")
    let address = Value(addressRes)
    let keyText = intToStr(7)
    let baguaId = lsmr.LsmrAddressBagua(address, keyText)
    assert(lt.BaguaValid(baguaId), " lsmr prefix smoke: bagua")
    var prefixDigits: int32[]
    prefixDigits = []
    for i in 0..<3:
        add(prefixDigits, address.digits[i])
    let prefixRes = lt.PrefixRefFromDigits(baguaId, prefixDigits)
    assert(IsOk(prefixRes), " lsmr prefix smoke: prefix")
    let prefix = Value(prefixRes)
    assert(prefix.prefixDepth == 3, " lsmr prefix smoke: depth")
    echo(" lsmr_prefix_smoke ok")
    return 0
