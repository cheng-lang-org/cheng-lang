import std/os
import std/result
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world_libp2p as cwlp
import cheng/core/tooling/compiler_world as cworld
import cheng/core/backend/system_link_exec as sexec
import cheng/std/bytes_layout as layout
import cheng/chain/pubsub
import cheng/libp2p/core/types as core
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host

fn compilerWorldSmokePortBase(label: str): int32 =
    var acc: int32
    for i in 0..<label.len:
        acc = (acc + (int32(label[i]) & 255)) % 200
    return 6461 + (acc * 2)

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, "artifacts/compiler_world_libp2p/" + smokeLabel)
    let portBase: int32 = compilerWorldSmokePortBase(smokeLabel)
    assert(chengpath.MkdirP(workspaceRoot, outDir), " compiler world libp2p: mkdir")
    let sourcePath = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = chengpath.PathJoin(outDir, "program_selfhost_smoke")
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    let planRes = sexec.BuildSystemLinkExecPlan(workspaceRoot, req)
    assert(IsOk(planRes), " compiler world libp2p: build plan")
    let plan = Value(planRes)
    var seedHost = host.Libp2pHostInit("compiler-world-seed")
    var syncHost = host.Libp2pHostInit("compiler-world-sync")
    cwlp.CompilerWorldRegister(seedHost)
    cwlp.CompilerWorldRegister(syncHost)
    var seedAddr: core.Libp2pMultiaddr
    var syncAddr: core.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(seedAddr, "127.0.0.1", portBase)
    multiaddr.Libp2pMultiaddrFillTcp(syncAddr, "127.0.0.1", portBase + 1)
    let seedListenRes = host.Libp2pListen(seedHost, seedAddr)
    assert(IsOk(seedListenRes), " compiler world libp2p: seed listen")
    let syncListenRes = host.Libp2pListen(syncHost, syncAddr)
    assert(IsOk(syncListenRes), " compiler world libp2p: sync listen")
    let dialSeedRes = host.Libp2pDial(syncHost, seedHost.selfPeerId, seedAddr, 1)
    assert(IsOk(dialSeedRes), " compiler world libp2p: dial seed")
    let dialSyncRes = host.Libp2pDial(seedHost, syncHost.selfPeerId, syncAddr, 1)
    assert(IsOk(dialSyncRes), " compiler world libp2p: dial sync")
    cwlp.CompilerWorldPublishUniverse(seedHost,
                                        plan.localUniverse,
                                        plan.compilerCsg,
                                        plan.exportSurface,
                                        plan.compileReceipt)
    let syncRes = cwlp.CompilerWorldSync(syncHost, seedHost, seedHost.selfPeerId)
    assert(IsOk(syncRes), " compiler world libp2p: sync")
    assert(cwlp.CompilerWorldStoredEntryCount(seedHost) == 8, " compiler world libp2p: seed count")
    assert(cwlp.CompilerWorldStoredEntryCount(syncHost) == 8, " compiler world libp2p: sync count")
    assert(cwlp.CompilerWorldPublishedHeadCount(seedHost) == 1, " compiler world libp2p: published head")
    assert(Value(syncRes) == 8, " compiler world libp2p: synced entries")
    var worldText = ""
    assert(cwlp.CompilerWorldFirstPayloadTextByKind(syncHost,
                                                      pubsub.PubSubPayloadKindCompilerWorldHead,
                                                      worldText),
           " compiler world libp2p: synced head text")
    var manifestText = ""
    assert(cwlp.CompilerWorldFirstPayloadTextByKind(syncHost,
                                                      pubsub.PubSubPayloadKindCompilerUniverseManifest,
                                                      manifestText),
           " compiler world libp2p: synced manifest text")
    var parsedManifest: cworld.CompilerUniverseManifest
    let parseManifestRes = cworld.CompilerUniverseManifestFromReportText(manifestText, parsedManifest)
    assert(IsOk(parseManifestRes), " compiler world libp2p: parse manifest")
    assert(chengpath.TextContains(worldText, "head_cid="), " compiler world libp2p: head field")
    assert(chengpath.TextContains(worldText, layout.fixedBytes32Hex(plan.localUniverse.worldHead.headCid)),
           " compiler world libp2p: synced head cid")
    assert(layout.fixedBytes32Equal(parsedManifest.manifestCid, plan.localUniverse.manifest.manifestCid),
           " compiler world libp2p: synced manifest cid")
    echo(" compiler_world_libp2p_smoke ok")
    return 0
