import cheng/core/lang/outline_parser as op
import std/strings

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn main(): int32 =
    let source = """
module test_app

import cheng/core/tooling/path

fn add(a: int32, b: int32): int32 =
    return a + b

type Point =
    x: int32
    y: int32

var globalCounter: int32

const MaxItems: int32 = 100
"""

    let parser = op.OutlineParseSource(source, "test_app")
    let c1 = check(!op.OutlineParserHasErrors(parser), 11)
    if c1 != 0: return c1

    let c2 = check(op.OutlineParserFunctionCount(parser) == 1, 12)
    if c2 != 0: return c2

    let names = op.OutlineParserDeclarationNames(parser)
    let c3 = check(names.len >= 4, 21)
    if c3 != 0: return c3

    var hasAdd: bool
    var hasPoint: bool
    var hasCounter: bool
    var hasMax: bool
    for i in 0..<names.len:
        if names[i] == "add": hasAdd = true
        if names[i] == "Point": hasPoint = true
        if names[i] == "globalCounter": hasCounter = true
        if names[i] == "MaxItems": hasMax = true
    let c4 = check(hasAdd, 22)
    if c4 != 0: return c4
    let c5 = check(hasPoint, 23)
    if c5 != 0: return c5
    let c6 = check(hasCounter, 24)
    if c6 != 0: return c6
    let c7 = check(hasMax, 25)
    if c7 != 0: return c7

    let table = op.OutlineParserBuildSymbolTable(parser)
    let c8 = check(table.names.len == names.len, 31)
    if c8 != 0: return c8
    let c9 = check(table.kinds.len == names.len, 32)
    if c9 != 0: return c9
    let c10 = check(table.sourceStarts.len == names.len, 33)
    if c10 != 0: return c10
    let c11 = check(table.sourceEnds.len == names.len, 34)
    if c11 != 0: return c11
    let c12 = check(table.modulePaths.len == names.len, 35)
    if c12 != 0: return c12

    let emptyParser = op.OutlineParseSource("", "")
    let c13 = check(op.OutlineParserFunctionCount(emptyParser) == 0, 41)
    if c13 != 0: return c13
    let c14 = check(!op.OutlineParserHasErrors(emptyParser), 42)
    if c14 != 0: return c14

    echo("outline_parser_smoke ok")
    return 0
