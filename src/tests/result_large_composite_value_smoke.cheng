import std/result
import std/strutils as strutil

type
    V3ResultLargeWorldHead =
        universeId: str
        channel: str
        signature: str
        headEpoch: int32

    V3ResultLargeLocalUniverse =
        compilerSnapshot: str
        stdSnapshot: str
        runtimeSnapshot: str
        worldHead: V3ResultLargeWorldHead

    V3ResultLargeSystemLinkPlan =
        entryPath: str
        outputPath: str
        targetTriple: str
        packageRoot: str
        workspaceRoot: str
        packageId: str
        moduleStem: str

    V3ResultLargePlan =
        compilerEntrySource: str
        sourceBundleCidText: str
        systemLinkPlan: V3ResultLargeSystemLinkPlan
        compilerCsgCidText: str
        exportSurfaceCidText: str
        localUniverse: V3ResultLargeLocalUniverse
        compileReceiptCidText: str
        note0: str
        note1: str
        note2: str

fn resultLargePlanMake(): Result[V3ResultLargePlan] =
    let plan = V3ResultLargePlan(
        compilerEntrySource: "compiler_main",
        sourceBundleCidText: "bundle",
        systemLinkPlan: V3ResultLargeSystemLinkPlan(
            entryPath: "/tmp/in.cheng",
            outputPath: "/tmp/out.bin",
            targetTriple: "arm64-apple-darwin",
            packageRoot: "/tmp/pkg",
            workspaceRoot: "/tmp",
            packageId: "cheng/tests/result_large_composite_value_smoke",
            moduleStem: "result_large_composite_value_smoke"
        ),
        compilerCsgCidText: "csg",
        exportSurfaceCidText: "surface",
        localUniverse: V3ResultLargeLocalUniverse(
            compilerSnapshot: "compiler",
            stdSnapshot: "std",
            runtimeSnapshot: "runtime",
            worldHead: V3ResultLargeWorldHead(
                universeId: "cheng/compiler_universe",
                channel: " stable ",
                signature: "local:world_head",
                headEpoch: 1
            )
        ),
        compileReceiptCidText: "receipt",
        note0: "n0",
        note1: "n1",
        note2: "n2"
    )
    return Ok[V3ResultLargePlan](plan)

fn resultLargePlanChannel(plan: V3ResultLargePlan): str =
    return strutil.Strip(plan.localUniverse.worldHead.channel)

fn main(): int32 =
    let planRes = resultLargePlanMake()
    assert(planRes.ok, "v3 result large composite: make ok")
    let direct = strutil.Strip(Value(planRes).localUniverse.worldHead.channel)
    assert(direct == "stable", "v3 result large composite: direct")
    let plan = Value(planRes)
    let local = strutil.Strip(plan.localUniverse.worldHead.channel)
    assert(local == "stable", "v3 result large composite: local")
    let forwarded = resultLargePlanChannel(plan)
    assert(forwarded == "stable", "v3 result large composite: forwarded")
    echo("v3 result_large_composite_value_smoke ok")
    return 0
