import std/os
import std/system
import std/result
import std/strutils as strutil
import cheng/core/tooling/compiler_request as creq
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/backend/primary_object_plan as pobj

fn main(): int32 =
    let rootDir = os.GetCurrentDir()
    let req = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/ordinary_zero_exit_fixture.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/ordinary_zero_exit_fixture"),
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(rootDir, req, linkPlan, err), " primary object codegen smoke: link plan")
    var loweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(linkPlan, loweringPlan, err), " primary object codegen smoke: lowering plan")
    let primaryRes = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    assert(IsOk(primaryRes), " primary object codegen smoke: primary object plan")
    let primary = Value(primaryRes)
    assert(primary.missingReasons.len == 0, " primary object codegen smoke: missing reasons cleared")
    assert(primary.reachableFunctionCount == 1, " primary object codegen smoke: reachable function count")
    assert(primary.firstMissingFunction == "", " primary object codegen smoke: first missing function")
    assert(primary.firstMissingBodyKind == "", " primary object codegen smoke: first missing body kind")
    assert(primary.symbolNames.len == 2, " primary object codegen smoke: symbol count")
    assert(strutil.Contains(primary.symbolNames[0], "main"),
           " primary object codegen smoke: entry function symbol")
    assert(primary.symbolNames[1] == "_cheng_program_argv_entry",
           " primary object codegen smoke: argv bridge symbol")
    assert(primary.instructionWords.len == 19, " primary object codegen smoke: instruction words")
    assert(primary.functionWordCounts[0] == 2, " primary object codegen smoke: function word count")
    let objReq = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/float64_mul_direct_object_smoke.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/float64_mul_direct_object_smoke.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var objLinkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(rootDir, objReq, objLinkPlan, err), " primary object codegen smoke: obj link plan")
    var objLoweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(objLinkPlan, objLoweringPlan, err), " primary object codegen smoke: obj lowering plan")
    let objPrimaryRes = pobj.BuildPrimaryObjectPlan(objLinkPlan, objLoweringPlan)
    assert(IsOk(objPrimaryRes), " primary object codegen smoke: obj primary object plan")
    let objPrimary = Value(objPrimaryRes)
    assert(objPrimary.missingReasons.len == 0, " primary object codegen smoke: obj missing reasons cleared")
    assert(objPrimary.reachableFunctionCount == 1, " primary object codegen smoke: obj reachable function count")
    assert(objPrimary.symbolNames.len == 1, " primary object codegen smoke: obj symbol count")
    assert(objPrimary.functionBodyKinds[0] == "return_f64_mul_args", " primary object codegen smoke: obj body kind")
    let call3Req = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/return_call_three_args_fixture.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/return_call_three_args_fixture.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var call3LinkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(rootDir, call3Req, call3LinkPlan, err), " primary object codegen smoke: call3 link plan")
    var call3LoweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(call3LinkPlan, call3LoweringPlan, err), " primary object codegen smoke: call3 lowering plan")
    let call3PrimaryRes = pobj.BuildPrimaryObjectPlan(call3LinkPlan, call3LoweringPlan)
    assert(IsOk(call3PrimaryRes), " primary object codegen smoke: call3 primary object plan")
    let call3Primary = Value(call3PrimaryRes)
    assert(call3Primary.missingReasons.len == 0, " primary object codegen smoke: call3 missing reasons cleared")
    assert(call3Primary.reachableFunctionCount == 2, " primary object codegen smoke: call3 reachable function count")
    assert(strutil.Contains(strutil.Join(call3Primary.functionBodyKinds, ","), "return_call_arg0_arg1_arg2_i32"),
           " primary object codegen smoke: call3 body kind")
    let letCallReq = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/non_return_call_not_primary_fixture.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/non_return_call_not_primary_fixture.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var letCallLinkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(rootDir, letCallReq, letCallLinkPlan, err),
           " primary object codegen smoke: let-call link plan")
    var letCallLoweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(letCallLinkPlan, letCallLoweringPlan, err),
           " primary object codegen smoke: let-call lowering plan")
    let letCallPrimaryRes = pobj.BuildPrimaryObjectPlan(letCallLinkPlan, letCallLoweringPlan)
    assert(IsOk(letCallPrimaryRes), " primary object codegen smoke: let-call primary object plan")
    let letCallPrimary = Value(letCallPrimaryRes)
    assert(letCallPrimary.missingReasons.len == 0,
           " primary object codegen smoke: let-call missing reasons cleared")
    assert(letCallPrimary.firstMissingFunction == "",
           " primary object codegen smoke: let-call first missing function cleared")
    assert(letCallPrimary.firstMissingBodyKind == "",
           " primary object codegen smoke: let-call first missing body kind cleared")
    assert(strutil.Contains(strutil.Join(letCallPrimary.functionBodyKinds, ","), "statement_sequence"),
           " primary object codegen smoke: let-call statement sequence body kind")
    assert(strutil.Contains(pobj.PrimaryObjectPlanReport(letCallPrimary), "primary_object_statement_return_modes=1"),
           " primary object codegen smoke: let-call statement return mode")
    assert(letCallPrimary.relocSourceItemIds.len == 1,
           " primary object codegen smoke: let-call reloc count")
    assert(!strutil.Contains(strutil.Join(letCallPrimary.functionBodyKinds, ","), "return_call_noarg_i32"),
           " primary object codegen smoke: let-call no false return call")
    echo(" primary_object_codegen_smoke ok")
    return 0
