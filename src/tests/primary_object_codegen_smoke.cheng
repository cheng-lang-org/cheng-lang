import std/os
import std/system
import std/result
import std/strutils as strutil
import cheng/core/tooling/compiler_request as creq
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/backend/primary_object_plan as pobj

fn main(): int32 =
    let rootDir = os.GetCurrentDir()
    let req = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/ordinary_zero_exit_fixture.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/ordinary_zero_exit_fixture"),
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(rootDir, req, linkPlan, err), " primary object codegen smoke: link plan")
    var loweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(linkPlan, loweringPlan, err), " primary object codegen smoke: lowering plan")
    let primaryRes = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    assert(IsOk(primaryRes), " primary object codegen smoke: primary object plan")
    let primary = Value(primaryRes)
    assert(primary.missingReasons.len == 0, " primary object codegen smoke: missing reasons cleared")
    assert(primary.symbolNames.len == 2, " primary object codegen smoke: symbol count")
    assert(strutil.Contains(primary.symbolNames[0], "main"),
           " primary object codegen smoke: entry function symbol")
    assert(primary.symbolNames[1] == "_cheng_program_argv_entry",
           " primary object codegen smoke: argv bridge symbol")
    assert(primary.instructionWords.len == 3, " primary object codegen smoke: three words")
    assert(primary.functionWordCounts[0] == 2, " primary object codegen smoke: function word count")
    echo(" primary_object_codegen_smoke ok")
    return 0
