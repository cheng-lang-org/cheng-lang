import std/os
import std/system
import std/result
import std/strutils as strutil
import cheng/core/tooling/compiler_request as creq
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/backend/primary_object_plan as pobj
import cheng/core/backend/primary_object_emit as pemit
import cheng/core/ir/core_types as ir

fn main(): int32 =
    let rootDir = os.GetCurrentDir()
    let req = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/ordinary_zero_exit_fixture.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/ordinary_zero_exit_fixture"),
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(rootDir, req, linkPlan, err), " primary object codegen smoke: link plan")
    var loweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(linkPlan, loweringPlan, err), " primary object codegen smoke: lowering plan")
    let primary = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    assert(primary.missingReasons.len == 0, " primary object codegen smoke: missing reasons cleared")
    assert(primary.reachableFunctionCount == 1, " primary object codegen smoke: reachable function count")
    assert(primary.error.functionName == "", " primary object codegen smoke: first missing function")
    assert(primary.error.bodyKind == "", " primary object codegen smoke: first missing body kind")
    assert(primary.symbolNames.len == 2, " primary object codegen smoke: symbol count")
    assert(strutil.Contains(primary.symbolNames[0], "main"),
           " primary object codegen smoke: entry function symbol")
    assert(primary.symbolNames[1] == "_cheng_program_argv_entry",
           " primary object codegen smoke: argv bridge symbol")
    assert(primary.instructionWords.len == 19, " primary object codegen smoke: instruction words")
    assert(primary.functionWordCounts[0] == 2, " primary object codegen smoke: function word count")
    assert(primary.functionBodyIRs[0].ops.len == 2,
           " primary object codegen smoke: zero return body ir op count")
    assert(primary.functionBodyIRs[0].ops[0].kind == ir.BodyOpLoadConstTag,
           " primary object codegen smoke: zero return body ir const op")
    assert(primary.functionBodyIRs[0].ops[1].kind == ir.BodyOpReturnTag,
           " primary object codegen smoke: zero return body ir return op")
    let objReq = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/float64_mul_direct_object_smoke.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/float64_mul_direct_object_smoke.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var objLinkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(rootDir, objReq, objLinkPlan, err), " primary object codegen smoke: obj link plan")
    var objLoweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(objLinkPlan, objLoweringPlan, err), " primary object codegen smoke: obj lowering plan")
    let objPrimary = pobj.BuildPrimaryObjectPlan(objLinkPlan, objLoweringPlan)
    assert(objPrimary.missingReasons.len == 0, " primary object codegen smoke: obj missing reasons cleared")
    assert(objPrimary.reachableFunctionCount == 1, " primary object codegen smoke: obj reachable function count")
    assert(objPrimary.symbolNames.len == 1, " primary object codegen smoke: obj symbol count")
    assert(objPrimary.functionBodyKinds[0] == "return_f64_mul_args", " primary object codegen smoke: obj body kind")
    assert(objPrimary.functionBodyIRs[0].ops.len == 2,
           " primary object codegen smoke: f64 body ir op count")
    assert(objPrimary.functionBodyIRs[0].ops[0].kind == ir.BodyOpBinOpTag,
           " primary object codegen smoke: f64 body ir bin op")
    assert(objPrimary.functionBodyIRs[0].ops[1].kind == ir.BodyOpReturnTag,
           " primary object codegen smoke: f64 body ir return op")
    let call3Req = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/return_call_three_args_fixture.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/return_call_three_args_fixture.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var call3LinkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(rootDir, call3Req, call3LinkPlan, err), " primary object codegen smoke: call3 link plan")
    var call3LoweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(call3LinkPlan, call3LoweringPlan, err), " primary object codegen smoke: call3 lowering plan")
    let call3Primary = pobj.BuildPrimaryObjectPlan(call3LinkPlan, call3LoweringPlan)
    assert(call3Primary.missingReasons.len == 0, " primary object codegen smoke: call3 missing reasons cleared")
    assert(call3Primary.reachableFunctionCount == 2, " primary object codegen smoke: call3 reachable function count")
    assert(strutil.Contains(strutil.Join(call3Primary.functionBodyKinds, ","), "return_call_arg0_arg1_arg2_i32"),
           " primary object codegen smoke: call3 body kind")
    var call3IrIndex = -1
    for irIndex in 0..<call3LoweringPlan.primaryObjectIr.functions.len:
        if call3LoweringPlan.primaryObjectIr.functions[irIndex].functionName == "Forward3":
            call3IrIndex = irIndex
    assert(call3IrIndex >= 0, " primary object codegen smoke: call3 ir function")
    let call3IrFunction = call3LoweringPlan.primaryObjectIr.functions[call3IrIndex]
    assert(call3IrFunction.callSequence.len == 1, " primary object codegen smoke: call3 call sequence count")
    assert(call3IrFunction.callSequence[0].targetSymbol == "Leaf3",
           " primary object codegen smoke: call3 call sequence target")
    assert(call3IrFunction.callSequence[0].argCount == 3,
           " primary object codegen smoke: call3 call sequence arg count")
    assert(call3IrFunction.callSequence[0].argSlots.len == 3,
           " primary object codegen smoke: call3 call sequence arg slots")
    assert(call3IrFunction.callSequence[0].argSlots[0] == -1,
           " primary object codegen smoke: call3 param arg slot marker")
    assert(call3IrFunction.bodyIR.callSequence.len == 1,
           " primary object codegen smoke: call3 body ir call count")
    assert(call3IrFunction.bodyIR.ops.len == 2,
           " primary object codegen smoke: call3 body ir op count")
    assert(call3IrFunction.bodyIR.ops[1].kind == ir.BodyOpReturnTag,
           " primary object codegen smoke: call3 body ir return op")
    assert(call3IrFunction.bodyIR.ops[1].target == -1,
           " primary object codegen smoke: call3 body ir return target")
    assert(call3IrFunction.bodyIR.localSlots.len == 0,
           " primary object codegen smoke: call3 body ir local count")
    let letCallReq = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/non_return_call_not_primary_fixture.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/non_return_call_not_primary_fixture.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var letCallLinkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(rootDir, letCallReq, letCallLinkPlan, err),
           " primary object codegen smoke: let-call link plan")
    var letCallLoweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(letCallLinkPlan, letCallLoweringPlan, err),
           " primary object codegen smoke: let-call lowering plan")
    let letCallLoweringReport = lower.LoweringPlanStubReport(letCallLoweringPlan)
    let letCallPrimary = pobj.BuildPrimaryObjectPlan(letCallLinkPlan, letCallLoweringPlan)
    assert(letCallPrimary.missingReasons.len == 0,
           " primary object codegen smoke: let-call missing reasons cleared")
    assert(letCallPrimary.error.functionName == "",
           " primary object codegen smoke: let-call first missing function cleared")
    assert(letCallPrimary.error.bodyKind == "",
           " primary object codegen smoke: let-call first missing body kind cleared")
    assert(strutil.Contains(strutil.Join(letCallPrimary.functionBodyKinds, ","), "statement_sequence"),
           " primary object codegen smoke: let-call statement sequence body kind")
    let letCallPrimaryReport = pobj.PrimaryObjectPlanReport(letCallPrimary)
    assert(strutil.Contains(letCallPrimaryReport, "primary_object_statement_return_modes=1"),
           " primary object codegen smoke: let-call statement return mode")
    assert(strutil.Contains(letCallPrimaryReport, "primary_object_reloc_word_offsets="),
           " primary object codegen smoke: let-call reloc word offsets report")
    assert(strutil.Contains(letCallLoweringReport, "primary_object_ir_body_ir_return_counts="),
           " primary object codegen smoke: let-call body ir return count report")
    assert(strutil.Contains(letCallLoweringReport, "primary_object_ir_body_ir_op_kinds="),
           " primary object codegen smoke: let-call body ir op kinds report")
    assert(letCallPrimary.relocSourceItemIds.len == 1,
           " primary object codegen smoke: let-call reloc count")
    assert(strutil.Contains(letCallPrimaryReport, "primary_object_local_slot_counts=0,1"),
           " primary object codegen smoke: let-call local slot report")
    assert(strutil.Contains(letCallPrimaryReport, "primary_object_local_stack_byte_counts=0,32"),
           " primary object codegen smoke: let-call local stack report")
    assert(strutil.Contains(letCallPrimaryReport, "primary_object_body_ir_op_counts=2,2"),
           " primary object codegen smoke: let-call plan body ir op report")
    assert(strutil.Contains(letCallPrimaryReport, "primary_object_body_ir_return_counts=1,1"),
           " primary object codegen smoke: let-call plan body ir return report")
    var letCallPlanIrIndex = -1
    for functionIndex in 0..<letCallPrimary.functionBodyIRs.len:
        if functionIndex < letCallPrimary.functionLocalSlotCounts.len &&
           letCallPrimary.functionLocalSlotCounts[functionIndex] == 1:
            letCallPlanIrIndex = functionIndex
    assert(letCallPlanIrIndex >= 0, " primary object codegen smoke: let-call plan body ir index")
    assert(letCallPrimary.functionBodyIRs[letCallPlanIrIndex].ops.len == 2,
           " primary object codegen smoke: let-call plan body ir op count")
    let letCallBodyIR = letCallPrimary.functionBodyIRs[letCallPlanIrIndex]
    assert(pobj.PrimaryBodyIrStatementReturnMode(letCallBodyIR) == pobj.PrimaryStatementReturnModeI32Const(),
           " primary object codegen smoke: let-call body ir statement mode")
    assert(pobj.PrimaryBodyIrWordCount(letCallBodyIR) == letCallPrimary.functionWordCounts[letCallPlanIrIndex],
           " primary object codegen smoke: let-call body ir word count")
    assert(pobj.PrimaryBodyIrRequiresCallSequence(letCallBodyIR),
           " primary object codegen smoke: let-call body ir call sequence required")
    assert(letCallPrimary.functionBodyIRs[letCallPlanIrIndex].ops[1].kind == ir.BodyOpReturnTag,
           " primary object codegen smoke: let-call plan body ir return op")
    assert(letCallPrimary.functionBodyIRs[letCallPlanIrIndex].callSequence.len == 1,
           " primary object codegen smoke: let-call plan body ir call sequence")
    assert(letCallPrimary.relocWordOffsets[0] ==
           letCallPrimary.functionWordOffsets[letCallPlanIrIndex] + 2,
           " primary object codegen smoke: let-call plan reloc offset")
    var letCallIrIndex = -1
    for irIndex in 0..<letCallLoweringPlan.primaryObjectIr.functions.len:
        if letCallLoweringPlan.primaryObjectIr.functions[irIndex].functionName == "main":
            letCallIrIndex = irIndex
    assert(letCallIrIndex >= 0, " primary object codegen smoke: let-call ir function")
    let letCallIrFunction = letCallLoweringPlan.primaryObjectIr.functions[letCallIrIndex]
    assert(letCallIrFunction.callSequence.len == 1,
           " primary object codegen smoke: let-call sequence count")
    assert(letCallIrFunction.callSequence[0].targetSymbol == "Helper",
           " primary object codegen smoke: let-call sequence target")
    assert(letCallIrFunction.callSequence[0].argCount == 0,
           " primary object codegen smoke: let-call sequence arg count")
    assert(letCallIrFunction.callSequence[0].resultType == "int32",
           " primary object codegen smoke: let-call sequence result type")
    assert(letCallIrFunction.callSequence[0].argSlots.len == 0,
           " primary object codegen smoke: let-call sequence arg slots")
    assert(letCallIrFunction.bodyIR.callSequence.len == 1,
           " primary object codegen smoke: let-call body ir call count")
    assert(letCallIrFunction.bodyIR.ops.len == 2,
           " primary object codegen smoke: let-call body ir op count")
    assert(letCallIrFunction.bodyIR.ops[0].kind == ir.BodyOpCallTag,
           " primary object codegen smoke: let-call body ir op kind")
    assert(letCallIrFunction.bodyIR.ops[1].kind == ir.BodyOpReturnTag,
           " primary object codegen smoke: let-call body ir return op")
    assert(letCallIrFunction.bodyIR.ops[1].target == -1,
           " primary object codegen smoke: let-call body ir return target")
    assert(letCallIrFunction.bodyIR.ops[1].operands.len == 2,
           " primary object codegen smoke: let-call body ir return operands")
    assert(letCallIrFunction.bodyIR.localSlots.len == 1,
           " primary object codegen smoke: let-call body ir local count")
    assert(letCallIrFunction.bodyIR.localSlots[0].name == "value",
           " primary object codegen smoke: let-call body ir local name")
    assert(letCallIrFunction.bodyIR.localSlots[0].typeKind == ir.LocalI32Tag,
           " primary object codegen smoke: let-call body ir local type")
    assert(letCallIrFunction.bodyIR.localSlots[0].noAlias,
           " primary object codegen smoke: let-call body ir local no alias")
    assert(letCallIrFunction.callSequence[0].resultSlot == letCallIrFunction.bodyIR.localSlots[0].id,
           " primary object codegen smoke: let-call call result local")
    assert(!strutil.Contains(strutil.Join(letCallPrimary.functionBodyKinds, ","), "return_call_noarg_i32"),
           " primary object codegen smoke: let-call no false return call")
    let cfgReq = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/cfg_guard_return_direct_object_smoke.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/cfg_guard_return_direct_object_smoke.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var cfgLinkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(rootDir, cfgReq, cfgLinkPlan, err),
           " primary object codegen smoke: cfg link plan")
    var cfgLoweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(cfgLinkPlan, cfgLoweringPlan, err),
           " primary object codegen smoke: cfg lowering plan")
    let cfgPrimary = pobj.BuildPrimaryObjectPlan(cfgLinkPlan, cfgLoweringPlan)
    assert(cfgPrimary.missingReasons.len == 0,
           " primary object codegen smoke: cfg missing reasons")
    var cfgIndex = -1
    for functionIndex in 0..<cfgPrimary.functionBodyIRs.len:
        if pobj.PrimaryBodyIrIsCallCfgReturnInt32(cfgPrimary.functionBodyIRs[functionIndex]):
            cfgIndex = functionIndex
    assert(cfgIndex >= 0,
           " primary object codegen smoke: cfg function index")
    let cfgBodyIR = cfgPrimary.functionBodyIRs[cfgIndex]
    assert(cfgBodyIR.blocks.len == 3,
           " primary object codegen smoke: cfg block count")
    assert(cfgBodyIR.terms.len == 3,
           " primary object codegen smoke: cfg term count")
    assert(cfgBodyIR.blocks[0].opCount == 1,
           " primary object codegen smoke: cfg entry op count")
    assert(cfgBodyIR.terms[cfgBodyIR.blocks[0].termIndex].kind == ir.BodyTermCbrTag,
           " primary object codegen smoke: cfg entry cbr")
    assert(cfgBodyIR.terms[cfgBodyIR.blocks[1].termIndex].kind == ir.BodyTermReturnTag,
           " primary object codegen smoke: cfg true return")
    assert(cfgBodyIR.terms[cfgBodyIR.blocks[2].termIndex].kind == ir.BodyTermReturnTag,
           " primary object codegen smoke: cfg false return")
    assert(cfgBodyIR.localSlots.len == 1,
           " primary object codegen smoke: cfg local count")
    assert(cfgBodyIR.localSlots[0].noAlias,
           " primary object codegen smoke: cfg local no alias")
    assert(pobj.PrimaryBodyIrWordCount(cfgBodyIR) == cfgPrimary.functionWordCounts[cfgIndex],
           " primary object codegen smoke: cfg word count")
    assert(cfgPrimary.relocWordOffsets.len == 1,
           " primary object codegen smoke: cfg reloc count")
    assert(cfgPrimary.relocWordOffsets[0] == cfgPrimary.functionWordOffsets[cfgIndex] + 2,
           " primary object codegen smoke: cfg reloc offset")
    let cfgAsmRes = pemit.PrimaryObjectEmitObjectAsmText(cfgPrimary)
    assert(IsOk(cfgAsmRes), " primary object codegen smoke: cfg asm fallback")
    let cfgAsm = Value(cfgAsmRes)
    assert(strutil.Contains(cfgAsm, "L_cheng_body_ir_cfg_"),
           " primary object codegen smoke: cfg asm label")
    assert(strutil.Contains(cfgAsm, "mov w0, #7"),
           " primary object codegen smoke: cfg asm true return")
    assert(strutil.Contains(cfgAsm, "mov w0, #3"),
           " primary object codegen smoke: cfg asm false return")
    let multiStmtReq = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/multi_stmt_i32_guard_direct_object_smoke.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/multi_stmt_i32_guard_direct_object_smoke.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var multiStmtLinkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(rootDir, multiStmtReq, multiStmtLinkPlan, err),
           " primary object codegen smoke: multi stmt link plan")
    var multiStmtLoweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(multiStmtLinkPlan, multiStmtLoweringPlan, err),
           " primary object codegen smoke: multi stmt lowering plan")
    let multiStmtPrimary = pobj.BuildPrimaryObjectPlan(multiStmtLinkPlan, multiStmtLoweringPlan)
    assert(multiStmtPrimary.missingReasons.len == 0,
           " primary object codegen smoke: multi stmt missing reasons")
    var multiStmtIndex = -1
    for functionIndex in 0..<multiStmtPrimary.functionBodyIRs.len:
        if functionIndex < multiStmtPrimary.functionStatementCallCounts.len &&
           multiStmtPrimary.functionStatementCallCounts[functionIndex] == 2:
            multiStmtIndex = functionIndex
    assert(multiStmtIndex >= 0,
           " primary object codegen smoke: multi stmt plan body ir index")
    let multiStmtBodyIR = multiStmtPrimary.functionBodyIRs[multiStmtIndex]
    assert(multiStmtBodyIR.ops.len == 4,
           " primary object codegen smoke: multi stmt body ir op count")
    assert(multiStmtBodyIR.ops[0].kind == ir.BodyOpCallTag,
           " primary object codegen smoke: multi stmt first call op")
    assert(multiStmtBodyIR.ops[1].kind == ir.BodyOpCallTag,
           " primary object codegen smoke: multi stmt second call op")
    assert(multiStmtBodyIR.ops[2].kind == ir.BodyOpBranchTag,
           " primary object codegen smoke: multi stmt branch op")
    assert(multiStmtBodyIR.ops[3].kind == ir.BodyOpReturnTag,
           " primary object codegen smoke: multi stmt return op")
    assert(pobj.PrimaryBodyIrIsI32TwoCallGuardFirstReturn(multiStmtBodyIR),
           " primary object codegen smoke: multi stmt shape")
    assert(pobj.PrimaryBodyIrWordCount(multiStmtBodyIR) == 13,
           " primary object codegen smoke: multi stmt word count")
    assert(multiStmtPrimary.functionWordCounts[multiStmtIndex] == 13,
           " primary object codegen smoke: multi stmt plan word count")
    assert(multiStmtPrimary.relocWordOffsets.len == 2,
           " primary object codegen smoke: multi stmt reloc count")
    assert(multiStmtPrimary.relocWordOffsets[0] == multiStmtPrimary.functionWordOffsets[multiStmtIndex] + 2,
           " primary object codegen smoke: multi stmt first reloc offset")
    assert(multiStmtPrimary.relocWordOffsets[1] == multiStmtPrimary.functionWordOffsets[multiStmtIndex] + 4,
           " primary object codegen smoke: multi stmt second reloc offset")
    let multiStmtAsmRes = pemit.PrimaryObjectEmitObjectAsmText(multiStmtPrimary)
    assert(IsOk(multiStmtAsmRes), " primary object codegen smoke: multi stmt asm fallback")
    let multiStmtAsm = Value(multiStmtAsmRes)
    assert(strutil.Contains(multiStmtAsm, "str w0, [sp, #16]"),
           " primary object codegen smoke: multi stmt asm saves first result")
    assert(strutil.Contains(multiStmtAsm, "ldr w0, [sp, #16]"),
           " primary object codegen smoke: multi stmt asm returns first result")
    let generalMultiReq = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/multi_stmt_general_direct_object_smoke.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/multi_stmt_general_direct_object_smoke.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var generalMultiLinkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(rootDir, generalMultiReq, generalMultiLinkPlan, err),
           " primary object codegen smoke: general multi stmt link plan")
    var generalMultiLoweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(generalMultiLinkPlan, generalMultiLoweringPlan, err),
           " primary object codegen smoke: general multi stmt lowering plan")
    let generalMultiPrimary = pobj.BuildPrimaryObjectPlan(generalMultiLinkPlan, generalMultiLoweringPlan)
    assert(generalMultiPrimary.missingReasons.len == 0,
           " primary object codegen smoke: general multi stmt missing reasons")
    var generalMultiIndex = -1
    for functionIndex in 0..<generalMultiPrimary.functionBodyIRs.len:
        if functionIndex < generalMultiPrimary.functionStatementCallCounts.len &&
           generalMultiPrimary.functionStatementCallCounts[functionIndex] == 3:
            generalMultiIndex = functionIndex
    assert(generalMultiIndex >= 0,
           " primary object codegen smoke: general multi stmt body ir index")
    let generalMultiBodyIR = generalMultiPrimary.functionBodyIRs[generalMultiIndex]
    assert(generalMultiBodyIR.ops.len == 4,
           " primary object codegen smoke: general multi stmt body ir op count")
    assert(generalMultiBodyIR.ops[0].kind == ir.BodyOpCallTag,
           " primary object codegen smoke: general multi stmt first call op")
    assert(generalMultiBodyIR.ops[1].kind == ir.BodyOpCallTag,
           " primary object codegen smoke: general multi stmt second call op")
    assert(generalMultiBodyIR.ops[2].kind == ir.BodyOpCallTag,
           " primary object codegen smoke: general multi stmt third call op")
    assert(generalMultiBodyIR.ops[3].kind == ir.BodyOpReturnTag,
           " primary object codegen smoke: general multi stmt return op")
    assert(pobj.PrimaryBodyIrIsCallSequenceReturnInt32(generalMultiBodyIR),
           " primary object codegen smoke: general multi stmt call sequence return i32")
    assert(pobj.PrimaryBodyIrWordCount(generalMultiBodyIR) > 0,
           " primary object codegen smoke: general multi stmt word count")
    assert(generalMultiPrimary.functionWordCounts[generalMultiIndex] > 0,
           " primary object codegen smoke: general multi stmt plan word count")
    assert(generalMultiPrimary.relocWordOffsets.len == 3,
           " primary object codegen smoke: general multi stmt reloc count")
    let generalMultiAsmRes = pemit.PrimaryObjectEmitObjectAsmText(generalMultiPrimary)
    assert(IsOk(generalMultiAsmRes), " primary object codegen smoke: general multi stmt asm fallback")
    let generalMultiAsm = Value(generalMultiAsmRes)
    assert(strutil.Contains(generalMultiAsm, "bl "),
           " primary object codegen smoke: general multi stmt asm has branches")
    assert(strutil.Contains(generalMultiAsm, "stp x29, x30"),
           " primary object codegen smoke: general multi stmt asm has prologue")
    let guardThenReq = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/i32_guard_then_command_direct_object_smoke.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/i32_guard_then_command_direct_object_smoke.o"),
        "arm64-apple-darwin",
        creq.EmitObj,
        ""
    )
    var guardThenLinkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(rootDir, guardThenReq, guardThenLinkPlan, err),
           " primary object codegen smoke: guard command link plan")
    var guardThenLoweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(guardThenLinkPlan, guardThenLoweringPlan, err),
           " primary object codegen smoke: guard command lowering plan")
    let guardThenPrimary = pobj.BuildPrimaryObjectPlan(guardThenLinkPlan, guardThenLoweringPlan)
    assert(guardThenPrimary.missingReasons.len == 0,
           " primary object codegen smoke: guard command missing reasons")
    var guardThenIndex = -1
    for functionIndex in 0..<guardThenPrimary.functionBodyIRs.len:
        if functionIndex < guardThenPrimary.functionStatementCallCounts.len &&
           guardThenPrimary.functionStatementCallCounts[functionIndex] == 2:
            guardThenIndex = functionIndex
    assert(guardThenIndex >= 0,
           " primary object codegen smoke: guard command plan body ir index")
    let guardThenBodyIR = guardThenPrimary.functionBodyIRs[guardThenIndex]
    assert(pobj.PrimaryBodyIrIsI32GuardThenCommandReturn(guardThenBodyIR),
           " primary object codegen smoke: guard command body ir shape")
    assert(pobj.PrimaryBodyIrWordCount(guardThenBodyIR) == 11,
           " primary object codegen smoke: guard command word count")
    assert(guardThenPrimary.relocWordOffsets.len == 2,
           " primary object codegen smoke: guard command reloc count")
    assert(guardThenPrimary.relocWordOffsets[0] == guardThenPrimary.functionWordOffsets[guardThenIndex] + 2,
           " primary object codegen smoke: guard command first reloc offset")
    assert(guardThenPrimary.relocWordOffsets[1] == guardThenPrimary.functionWordOffsets[guardThenIndex] + 8,
           " primary object codegen smoke: guard command second reloc offset")
    let guardThenAsmRes = pemit.PrimaryObjectEmitObjectAsmText(guardThenPrimary)
    assert(IsOk(guardThenAsmRes), " primary object codegen smoke: guard command asm fallback")
    let guardThenAsm = Value(guardThenAsmRes)
    assert(strutil.Contains(guardThenAsm, "L_cheng_body_ir_i32_guard_command_"),
           " primary object codegen smoke: guard command asm label")
    assert(strutil.Contains(guardThenAsm, "mov w0, #0"),
           " primary object codegen smoke: guard command zero return")
