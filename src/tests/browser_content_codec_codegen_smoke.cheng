import cheng/libp2p/browser/browser_content_codec_codegen as codegen
import cheng/libp2p/browser/browser_content_codec_rule_schema as browsercodec

fn main(): int32 =
    let sourcePath = browsercodec.v3BrowserContentCodecModulePath()
    let bytesInput = codegen.v3BrowserCodecInputSchemaForRuleName(browsercodec.v3BrowserContentCodecRuleInputBytesRequiredName(),
                                                                  "missing_bytes",
                                                                  "copy_bytes_failed")
    assert(bytesInput.kind == codegen.v3BrowserCodecInputBytesRequired,
           "v3 browser content codec codegen: bytes input kind")
    assert(bytesInput.missingError == "missing_bytes",
           "v3 browser content codec codegen: bytes input missing error")
    assert(bytesInput.copyError == "copy_bytes_failed",
           "v3 browser content codec codegen: bytes input copy error")

    let optionalTextInput = codegen.v3BrowserCodecInputSchemaForRuleName(browsercodec.v3BrowserContentCodecRuleInputTextOptionalName(),
                                                                         "",
                                                                         "copy_optional_text_failed")
    assert(optionalTextInput.kind == codegen.v3BrowserCodecInputTextOptional,
           "v3 browser content codec codegen: optional text input kind")
    assert(optionalTextInput.copyError == "copy_optional_text_failed",
           "v3 browser content codec codegen: optional text input copy error")

    let textExport = codegen.v3BrowserCodecExportSchemaForRuleName(browsercodec.v3BrowserContentCodecRuleExportMoqFountainTextResultName(),
                                                                   "text_handle_failed")
    assert(textExport.output.kind == codegen.v3BrowserCodecOutputTextHandle,
           "v3 browser content codec codegen: text export output kind")
    assert(textExport.output.handleError == "text_handle_failed",
           "v3 browser content codec codegen: text export handle error")
    assert(textExport.error.kind == codegen.v3BrowserCodecErrorMoqFountainLastError,
           "v3 browser content codec codegen: text export error kind")

    let bytesExport = codegen.v3BrowserCodecExportSchemaForRuleName(browsercodec.v3BrowserContentCodecRuleExportMoqFountainBytesResultName(),
                                                                    "raw_handle_failed")
    assert(bytesExport.output.kind == codegen.v3BrowserCodecOutputBytesHandle,
           "v3 browser content codec codegen: bytes export output kind")
    assert(bytesExport.output.handleError == "raw_handle_failed",
           "v3 browser content codec codegen: bytes export handle error")
    assert(bytesExport.error.kind == codegen.v3BrowserCodecErrorMoqFountainLastError,
           "v3 browser content codec codegen: bytes export error kind")

    let errorSchema = codegen.v3BrowserCodecErrorSchemaForRuleName(browsercodec.v3BrowserContentCodecRuleMoqFountainLastErrorHandleName())
    assert(errorSchema.kind == codegen.v3BrowserCodecErrorMoqFountainLastError,
           "v3 browser content codec codegen: error schema kind")

    let exportTextRule = browsercodec.v3BrowserContentCodecRuleExportMoqFountainTextResultName()
    assert(codegen.v3BrowserCodecBridgeKeyForRuleName(exportTextRule) ==
           "stage=result_export|input_schema=none|output_schema=text_handle|error_schema=moq_fountain_last_error|result=status_i32|out_buffer=text_handle",
           "v3 browser content codec codegen: text export bridge key")
    assert(codegen.v3BrowserCodecBridgeHelperNameForRuleName(exportTextRule) ==
           "v3_browser_bridge_result_export_export_moq_fountain_text_result",
           "v3 browser content codec codegen: text export helper name")
    assert(codegen.v3BrowserCodecBridgeEmitLineForRuleName(exportTextRule) ==
           "source=cheng/libp2p/browser/browser_content_codec_abi|rule=export_moq_fountain_text_result|stage=result_export|helper=v3_browser_bridge_result_export_export_moq_fountain_text_result|input_schema=none|output_schema=text_handle|error_schema=moq_fountain_last_error|result=status_i32|out_buffer=text_handle",
           "v3 browser content codec codegen: text export bridge line")
    assert(codegen.v3BrowserCodecBridgeKeyForSourceRuleName(sourcePath, exportTextRule) ==
           codegen.v3BrowserCodecBridgeKeyForRuleName(exportTextRule),
           "v3 browser content codec codegen: source bridge key")
    assert(codegen.v3BrowserCodecBridgeHelperNameForSourceRuleName(sourcePath, exportTextRule) ==
           codegen.v3BrowserCodecBridgeHelperNameForRuleName(exportTextRule),
           "v3 browser content codec codegen: source helper name")
    assert(codegen.v3BrowserCodecBridgeEmitLineForSourceRuleName(sourcePath, exportTextRule) ==
           codegen.v3BrowserCodecBridgeEmitLineForRuleName(exportTextRule),
           "v3 browser content codec codegen: source bridge line")

    echo("v3 browser_content_codec_codegen_smoke ok")
    return 0
