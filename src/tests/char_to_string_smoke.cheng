import std/system
import std/rawbytes

fn main(): int32 =
    let text: str = charToString('x')
    let bytes: Bytes = bytesFromString(text)
    assert(len(text) == 1, " char_to_string_smoke: len")
    assert(bytesLen(bytes) == 1, " char_to_string_smoke: byte len")
    assert(bytesGet(bytes, 0) == int32('x'), " char_to_string_smoke: content")
    echo(" char_to_string_smoke ok")
    return 0
