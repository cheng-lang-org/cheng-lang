import std/result
import cheng/hysteria2/hysteria2_protocol as hy2

fn bytesEq(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    let authReq = hy2.Hysteria2MakeAuthRequest("hysteria",
                                                 "top-secret",
                                                 123456,
                                                 "pad")
    let authReqWireRes: Result[Bytes] = hy2.Hysteria2EncodeAuthRequestFrame(authReq)
    assert(IsOk(authReqWireRes), " hysteria2 protocol: auth request encode")
    let authReqDecRes: Result[hy2.Hysteria2AuthRequest] = hy2.Hysteria2DecodeAuthRequestFrame(Value(authReqWireRes))
    assert(IsOk(authReqDecRes), " hysteria2 protocol: auth request decode")
    let authReqDec: hy2.Hysteria2AuthRequest = Value(authReqDecRes)
    assert(authReqDec.authority == "hysteria", " hysteria2 protocol: auth authority")
    assert(authReqDec.auth == "top-secret", " hysteria2 protocol: auth secret")
    assert(authReqDec.ccRx == 123456, " hysteria2 protocol: auth cc-rx")

    let authResp = hy2.Hysteria2MakeAuthResponse(233,
                                                   true,
                                                   "auto",
                                                   "resp")
    let authRespWireRes: Result[Bytes] = hy2.Hysteria2EncodeAuthResponseFrame(authResp)
    assert(IsOk(authRespWireRes), " hysteria2 protocol: auth response encode")
    let authRespDecRes: Result[hy2.Hysteria2AuthResponse] = hy2.Hysteria2DecodeAuthResponseFrame(Value(authRespWireRes))
    assert(IsOk(authRespDecRes), " hysteria2 protocol: auth response decode")
    let authRespDec: hy2.Hysteria2AuthResponse = Value(authRespDecRes)
    assert(authRespDec.statusCode == 233, " hysteria2 protocol: auth response status")
    assert(authRespDec.udpEnabled, " hysteria2 protocol: auth response udp")
    assert(authRespDec.ccRxText == "auto", " hysteria2 protocol: auth response cc-rx")

    let tcpReq = hy2.Hysteria2MakeTcpRequest("example.com:443", bytesFromString("pad"))
    let tcpReqWireRes: Result[Bytes] = hy2.Hysteria2EncodeTcpRequest(tcpReq)
    assert(IsOk(tcpReqWireRes), " hysteria2 protocol: tcp request encode")
    let tcpReqDecRes: Result[hy2.Hysteria2TcpRequest] = hy2.Hysteria2DecodeTcpRequest(Value(tcpReqWireRes))
    assert(IsOk(tcpReqDecRes), " hysteria2 protocol: tcp request decode")
    assert(Value(tcpReqDecRes).address == "example.com:443", " hysteria2 protocol: tcp request address")

    let tcpResp = hy2.Hysteria2MakeTcpResponse(true, "", bytesFromString("ok"))
    let tcpRespWireRes: Result[Bytes] = hy2.Hysteria2EncodeTcpResponse(tcpResp)
    assert(IsOk(tcpRespWireRes), " hysteria2 protocol: tcp response encode")
    let tcpRespDecRes: Result[hy2.Hysteria2TcpResponse] = hy2.Hysteria2DecodeTcpResponse(Value(tcpRespWireRes))
    assert(IsOk(tcpRespDecRes), " hysteria2 protocol: tcp response decode")
    assert(Value(tcpRespDecRes).ok, " hysteria2 protocol: tcp response ok")

    let udpMsg = hy2.Hysteria2MakeUdpMessage(7,
                                               9,
                                               0,
                                               1,
                                               "1.1.1.1:53",
                                               bytesFromString("hello-udp-world"))
    let udpWireRes: Result[Bytes] = hy2.Hysteria2EncodeUdpMessage(udpMsg)
    assert(IsOk(udpWireRes), " hysteria2 protocol: udp encode")
    let udpDecRes: Result[hy2.Hysteria2UdpMessage] = hy2.Hysteria2DecodeUdpMessage(Value(udpWireRes))
    assert(IsOk(udpDecRes), " hysteria2 protocol: udp decode")
    let udpDec: hy2.Hysteria2UdpMessage = Value(udpDecRes)
    assert(udpDec.sessionId == 7, " hysteria2 protocol: udp session")
    assert(udpDec.address == "1.1.1.1:53", " hysteria2 protocol: udp address")
    assert(bytesEq(udpDec.payload, bytesFromString("hello-udp-world")), " hysteria2 protocol: udp payload")

    let fragmentsRes: Result[hy2.Hysteria2UdpMessage[]] = hy2.Hysteria2FragmentUdpMessage(udpMsg, 5)
    assert(IsOk(fragmentsRes), " hysteria2 protocol: udp fragment")
    let fragments: hy2.Hysteria2UdpMessage[] = Value(fragmentsRes)
    assert(fragments.len == 3, " hysteria2 protocol: udp fragment count")
    var reassembledFill: hy2.Hysteria2UdpMessage
    let reassembleFillRes: Result[bool] = hy2.Hysteria2ReassembleUdpMessagesFill(fragments, reassembledFill)
    assert(IsOk(reassembleFillRes), " hysteria2 protocol: udp reassemble fill")
    assert(bytesEq(reassembledFill.payload, udpMsg.payload), " hysteria2 protocol: udp reassemble fill payload")
    let reassembleRes: Result[hy2.Hysteria2UdpMessage] = hy2.Hysteria2ReassembleUdpMessages(fragments)
    assert(IsOk(reassembleRes), " hysteria2 protocol: udp reassemble")
    let reassembled: hy2.Hysteria2UdpMessage = Value(reassembleRes)
    assert(bytesEq(reassembled.payload, udpMsg.payload), " hysteria2 protocol: udp reassemble payload")

    echo(" hysteria2_protocol_smoke ok")
    return 0
