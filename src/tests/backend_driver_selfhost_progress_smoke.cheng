import std/os
import std/strings
import cheng/core/tooling/bootstrap_contracts as contracts
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import std/strutils as strutil

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let packageRoot: str = root
    let driver: str = os.JoinPath(root, "artifacts/backend_driver/cheng")
    let source: str = os.JoinPath(root, "src/core/tooling/compiler_main.cheng")
    let target: str = contracts.BootstrapDetectHostTarget()
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/backend_driver_selfhost_progress_smoke")
    let outBin: str = os.JoinPath(outDir, "compiler_main.selfhost")
    let outMap: str = strutil.Join([outBin, ".map"], "")
    let compileLog: str = os.JoinPath(outDir, "compiler_main.compile.log")
    let progressLog: str = os.JoinPath(outDir, "compiler_main.progress.log")
    assert(os.FileExists(driver), " backend driver selfhost progress: backend_driver exists")
    assert(len(target) > 0, " backend driver selfhost progress: host target")
    assert(chengpath.MkdirP(root, outDir), " backend driver selfhost progress: mkdir")
    if chengpath.PathFileExists(outBin):
        os.RemoveFile(outBin)
    if chengpath.PathFileExists(outMap):
        os.RemoveFile(outMap)
    if chengpath.PathFileExists(compileLog):
        os.RemoveFile(compileLog)
    if chengpath.PathFileExists(progressLog):
        os.RemoveFile(progressLog)
    let compileRun = hostops.RunFileLogged(root,
                                             "backend_driver_selfhost_progress_compile",
                                             driver,
                                             [
                                                 "system-link-exec",
                                                 "--progress",
                                                 strutil.Join(["--progress-out:", progressLog], ""),
                                                 strutil.Join(["--root:", packageRoot], ""),
                                                 strutil.Join(["--in:", source], ""),
                                                 "--emit:exe",
                                                 strutil.Join(["--target:", target], ""),
                                                 strutil.Join(["--out:", outBin], "")
                                             ],
                                             [
                                                 strutil.Join(["CHENG_ROOT=", root], ""),
                                                 "CHENG_PROGRESS=1",
                                                 strutil.Join(["CHENG_PROGRESS_OUT=", progressLog], "")
                                             ],
                                             root,
                                             0,
                                             compileLog)
    assert(compileRun.exitCode == 0, " backend driver selfhost progress: compile rc")
    assert(os.FileExists(outBin), " backend driver selfhost progress: output exists")
    assert(os.FileExists(progressLog), " backend driver selfhost progress: progress log exists")
    let compileText: str = os.ReadFile(compileLog)
    let progressText: str = os.ReadFile(progressLog)
    assert(strings.StrContains(progressText, "compile_progress phase=system_link_plan status=done"),
           " backend driver selfhost progress: system_link_plan progress")
    assert(strings.StrContains(progressText, "compile_progress phase=source_bundle status=done"),
           " backend driver selfhost progress: source_bundle progress")
    assert(strings.StrContains(progressText, "compile_progress phase=compiler_csg status=done"),
           " backend driver selfhost progress: compiler_csg progress")
    assert(strings.StrContains(progressText, "compile_progress phase=world status=done"),
           " backend driver selfhost progress: world progress")
    assert(strings.StrContains(progressText, "compile_progress phase=lowering_plan status=done"),
           " backend driver selfhost progress: lowering_plan progress")
    assert(strings.StrContains(progressText, "compile_progress phase=primary_object_plan status=done"),
           " backend driver selfhost progress: primary_object_plan progress")
    assert(strings.StrContains(progressText, "compile_progress phase=provider_sources status=done"),
           " backend driver selfhost progress: provider_sources progress")
    assert(strings.StrContains(progressText, "compile_progress phase=provider_objects status=done"),
           " backend driver selfhost progress: provider_objects progress")
    assert(strings.StrContains(progressText, "compile_progress phase=object_plan status=done"),
           " backend driver selfhost progress: object_plan progress")
    assert(strings.StrContains(progressText, "compile_progress phase=primary_object_emit status=done"),
           " backend driver selfhost progress: primary_object_emit progress")
    assert(strings.StrContains(progressText, "compile_progress phase=native_link_plan status=done"),
           " backend driver selfhost progress: native_link_plan progress")
    assert(strings.StrContains(progressText, "compile_progress phase=native_link status=done"),
           " backend driver selfhost progress: native_link progress")
    assert(strings.StrContains(progressText, "compile_progress phase=line_map status=done"),
           " backend driver selfhost progress: line_map progress")
    assert(strings.StrContains(progressText, "compile_progress phase=compile_receipt status=done"),
           " backend driver selfhost progress: compile_receipt progress")
    assert(strings.StrContains(progressText, "compile_progress phase=build status=done"),
           " backend driver selfhost progress: build progress")
    assert(strings.StrContains(progressText, "compile_progress phase=bridge_compile status=done"),
           " backend driver selfhost progress: bridge_compile progress")
    assert(strings.StrContains(progressText, "compile_progress phase=browser_bridge_restore status=done"),
           " backend driver selfhost progress: browser_bridge_restore progress")
    assert(strings.StrContains(progressText, "compile_progress phase=execute status=done"),
           " backend driver selfhost progress: execute progress")
    assert(!strings.StrContains(compileText, "source_closure_count="),
           " backend driver selfhost progress: no source_closure_count")
    assert(!strings.StrContains(compileText, "native_link_inputs="),
           " backend driver selfhost progress: no native_link_inputs")
    assert(!strings.StrContains(compileText, "primary_object_symbols="),
           " backend driver selfhost progress: no primary_object_symbols")
    assert(!strings.StrContains(compileText, "provider_object_count="),
           " backend driver selfhost progress: no provider_object_count")
    echo(" backend_driver_selfhost_progress_smoke ok")
    return 0
