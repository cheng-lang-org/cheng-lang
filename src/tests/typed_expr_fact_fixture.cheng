import std/result
import cheng/tests/typed_expr_fact_helper as typedhelper
import cheng/tests/[typed_expr_fact_helper_plain]
import cheng/tests/typed_expr_fact_helper_nested as typednested
import cheng/tests/typed_expr_fact_importc_helper as typedimporthelper
import cheng/tests/typed_expr_fact_importc_nested as typedimportnested
import std/strutils as strutil

importc fn typedImportEcho(payload: str): str
importc fn typedImportLen(payload: str): int32

fn typedLocalEcho(payload: str): str =
    return payload

fn typedSurface(flag: bool): Result[int32] =
    let picked: int32 = flag ? 7 : 9
    let direct: int32 = if flag: picked else: 11
    let okRes: Result[int32] = Ok[int32](direct)
    let viaValue: int32 = Value(okRes)
    let viaTry: int32 = okRes?
    let openRange = 0..<4
    let closedRange = 1..5
    let rendered: str = Fmt"picked={IntToStr(viaTry)}"
    let rows: str[] = [Fmt"picked={IntToStr(viaValue)}", strutil.Join(["span", IntToStr(picked)], "")]
    let filtered: str[] = [row for row in rows if row != ""]
    let joined: str = strutil.Join(filtered, "")
    let importedText: str = typedImportEcho(joined)
    let localText: str = typedLocalEcho(importedText)
    let externalText: str = typedhelper.TypedExternalEcho(localText)
    let externalLen: int32 = typed_expr_fact_helper_plain.TypedExternalLen(externalText)
    let nestedLen: int32 = typednested.plainhelper.TypedExternalLen(externalText)
    let importedLen: int32 = typedImportLen(externalText)
    let importedExternalText: str = typedimporthelper.TypedImportedBufferEcho(externalText)
    let nestedImportedText: str = typedimportnested.importcbuffer.TypedImportedBufferEcho(externalText)
    let errRes: Result[int32] = Err[int32](joined)
    let errText: str = Error(errRes)
    let errInfo: ErrorInfo = ErrorInfoOf(errRes)
    let okFlag: bool = IsOk(okRes)
    let errFlag: bool = IsErr(errRes)
    if okFlag &&
       !errFlag &&
       importedLen > 0 &&
       externalLen >= importedLen &&
       nestedLen == externalLen &&
       importedExternalText == nestedImportedText:
        return Ok[int32](nestedLen)
    let _ = openRange
    let _ = closedRange
    let _ = errInfo
    return Err[int32](strutil.Join([externalText, errText], ""))

type
    TypedDefaultWrap = object
        count: int32

fn typedDefaultSurface(): int32 =
    let wrap = TypedDefaultWrap()
    return wrap.count

fn typedConstructors(payload: str): TypedDefaultWrap =
    let built = TypedDefaultWrap(count: payload.len)
    return built

fn `$`(wrap: TypedDefaultWrap): str =
    return IntToStr(wrap.count)

fn typedStringify(payload: str): str =
    let built = TypedDefaultWrap(count: payload.len)
    let direct: str = $built
    let paren: str = $(built)
    return strutil.Join([direct, paren], "")
