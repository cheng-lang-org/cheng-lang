import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/std/crypto/fixed256 as fixed256
import std/strutils as strutil

fn main(): int32 =
    let aliceRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex("77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    assert(IsOk(aliceRes), "probe: alice private")
    let bobRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex("5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    assert(IsOk(bobRes), "probe: bob private")
    let alicePubRes: Result[layout.FixedBytes32] = fixed256.curve25519PublicKey(Value(aliceRes))
    assert(IsOk(alicePubRes), "probe: alice public")
    let bobPubRes: Result[layout.FixedBytes32] = fixed256.curve25519PublicKey(Value(bobRes))
    assert(IsOk(bobPubRes), "probe: bob public")
    let sharedRes: Result[layout.FixedBytes32] =
        fixed256.curve25519SharedKeyFixed(Value(aliceRes), Value(bobPubRes))
    assert(IsOk(sharedRes), "probe: shared")
    echo(strutil.Join(["alice=", layout.FixedBytes32Hex(Value(alicePubRes))], ""))
    echo(strutil.Join(["bob=", layout.FixedBytes32Hex(Value(bobPubRes))], ""))
    echo(strutil.Join(["shared=", layout.FixedBytes32Hex(Value(sharedRes))], ""))
    return 0
