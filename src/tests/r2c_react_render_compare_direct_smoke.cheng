import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_smoke_support as r2csmoke
import std/strutils as strutil

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = chengpath.PathAbsolute(root, "artifacts/r2c_render_compare_direct_smoke")
    assert(chengpath.MkdirP(root, outDir), " r2c render compare direct smoke: mkdir")
    let stage3 = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3")
    assert(chengpath.FileExistsNonEmpty(root, stage3), " r2c render compare direct smoke: stage3 exists")
    let controllerEnv = os.GetEnv("R2C_REACT_CONTROLLER_EXE")
    assert(len(controllerEnv) > 0,
           " r2c render compare direct smoke: set R2C_REACT_CONTROLLER_EXE; direct smoke never recompiles controller")
    let controllerExe = chengpath.PathAbsolute(root, controllerEnv)
    assert(chengpath.FileExistsNonEmpty(root, controllerExe), " r2c render compare direct smoke: controller exe")

    let repoEnv = os.GetEnv("R2C_REACT_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.DirExists(repo), " r2c render compare direct smoke: React.js repo exists")

    let nativePngPath = os.JoinPath(outDir, "native_gui_session.png")
    let truthPngPath = os.JoinPath(outDir, "truth_session.png")
    let nativeSummaryPath = os.JoinPath(outDir, "native_gui_run.summary.env")
    let truthSummaryPath = os.JoinPath(outDir, "truth.summary.env")
    let truthTracePath = os.JoinPath(outDir, "truth_trace_v2.json")
    let truthRuntimeStatePath = os.JoinPath(outDir, "truth_runtime_state_v1.json")
    let truthDomPath = os.JoinPath(outDir, "truth_dom_v1.json")
    let truthSemanticNodesPath = os.JoinPath(outDir, "truth_semantic_nodes_v1.json")
    let truthRuntimeMetaPath = os.JoinPath(outDir, "truth_runtime_meta_v1.json")
    let renderComparePath = os.JoinPath(outDir, "render_compare_report_v1.json")
    let renderCompareSummaryPath = os.JoinPath(outDir, "render_compare.summary.env")

    r2csmoke.R2cReactSmokeWriteTinyPng(nativePngPath)
    r2csmoke.R2cReactSmokeWriteTinyPng(truthPngPath)
    assert(chengpath.FileExistsNonEmpty(root, nativePngPath), " r2c render compare direct smoke: native png")
    assert(chengpath.FileExistsNonEmpty(root, truthPngPath), " r2c render compare direct smoke: truth png")

    assert(chengpath.WriteTextFile("", truthTracePath,
                                  strutil.Join(["{\n", "  \"format\": \"truth_trace_v2\",\n", "  \"snapshots\": [\n", "    {\n", "      \"stateId\": \"home_default\",\n", "      \"route\": {\n", "        \"routeId\": \"home_default\"\n", "      },\n", "      \"semanticNodesCount\": 83,\n", "      \"renderReady\": true\n", "    }\n", "  ]\n", "}\n"], "")),
           " r2c render compare direct smoke: write truth trace")
    assert(chengpath.WriteTextFile("", truthRuntimeStatePath,
                                  strutil.Join(["{\n", "  \"format\": \"truth_runtime_state_v1\",\n", "  \"route_state\": \"home_default\"\n", "}\n"], "")),
           " r2c render compare direct smoke: write truth runtime state")
    assert(chengpath.WriteTextFile("", truthDomPath,
                                  strutil.Join(["{\n", "  \"format\": \"truth_dom_v1\",\n", "  \"route_state\": \"home_default\"\n", "}\n"], "")),
           " r2c render compare direct smoke: write truth dom")
    assert(chengpath.WriteTextFile("", truthSemanticNodesPath,
                                  strutil.Join(["{\n", "  \"format\": \"truth_semantic_nodes_v1\",\n", "  \"count\": 83\n", "}\n"], "")),
           " r2c render compare direct smoke: write truth semantic nodes")
    assert(chengpath.WriteTextFile("", truthRuntimeMetaPath,
                                  strutil.Join(["{\n", "  \"format\": \"truth_runtime_meta_v1\",\n", "  \"browser_width\": 1,\n", "  \"browser_height\": 1\n", "}\n"], "")),
           " r2c render compare direct smoke: write truth runtime meta")

    assert(chengpath.WriteTextFile("", nativeSummaryPath,
                                  strutil.Join(["native_gui_route_state=home_default\n", "native_gui_screenshot_path=", nativePngPath, "\n", "native_gui_window_width=1\n", "native_gui_window_height=1\n", "native_gui_layout_item_count=31\n", "native_gui_runtime_manifest_ready=true\n", "native_gui_runtime_contract_payload_ready=true\n", "native_gui_runtime_bundle_payload_ready=true\n", "native_gui_runtime_bundle_ready=true\n", "native_gui_runtime_contract_ready=true\n", "native_gui_runtime_bundle_route_state=home_default\n", "native_gui_runtime_bundle_route_count=1\n", "native_gui_runtime_bundle_supported_count=6\n", "native_gui_runtime_bundle_semantic_nodes_count=83\n", "native_gui_runtime_bundle_layout_item_count=31\n", "native_gui_runtime_bundle_render_command_count=44\n", "native_gui_runtime_contract_layout_item_count=31\n", "native_gui_runtime_contract_viewport_item_count=18\n", "native_gui_runtime_contract_interactive_item_count=7\n", "native_gui_native_layout_plan_item_count=31\n", "native_gui_render_plan_command_count=44\n", "native_gui_storage_host_ready=true\n", "native_gui_fetch_host_ready=true\n", "native_gui_custom_event_host_ready=true\n", "native_gui_resize_observer_host_ready=true\n"], "")),
           " r2c render compare direct smoke: write native summary")
    assert(chengpath.WriteTextFile("", truthSummaryPath,
                                  strutil.Join(["truth_trace_path=", truthTracePath, "\n", "truth_trace_format=truth_trace_v2\n", "runtime_state_path=", truthRuntimeStatePath, "\n", "dom_path=", truthDomPath, "\n", "semantic_nodes_path=", truthSemanticNodesPath, "\n", "runtime_meta_path=", truthRuntimeMetaPath, "\n", "screenshot_path=", truthPngPath, "\n", "semantic_nodes_count=83\n", "document_nodes_count=21\n", "dom_hash=truth_dom_hash_1\n", "screenshot_sha256=truth_screenshot_sha256_1\n", "pathname=/\n", "search=?route=home_default\n", "hash=#top\n"], "")),
           " r2c render compare direct smoke: write truth summary")

    let renderCompareLog = os.JoinPath(outDir, "render_compare.log")
    if chengpath.PathFileExists(renderCompareLog):
        os.RemoveFile(renderCompareLog)
    let renderCompareRun = hostops.RunFileLogged(root,
                                                   "r2c_render_compare_direct_smoke",
                                                   controllerExe,
                                                   [
                                                       "render-compare",
                                                       "--repo", repo,
                                                       "--route", "home_default",
                                                       "--out-dir", outDir,
                                                       "--native-summary", nativeSummaryPath,
                                                       "--truth-summary", truthSummaryPath,
                                                       "--native-screenshot", nativePngPath,
                                                       "--truth-screenshot", truthPngPath
                                                   ],
                                                   r2csmoke.R2cReactSmokeNativeEnv(stage3),
                                                   root,
                                                   120,
                                                   renderCompareLog)
    assert(hostops.LoggedRunOk(renderCompareRun), " r2c render compare direct smoke: render compare rc")
    assert(chengpath.FileExistsNonEmpty(root, renderComparePath), " r2c render compare direct smoke: report")
    assert(chengpath.FileExistsNonEmpty(root, renderCompareSummaryPath), " r2c render compare direct smoke: summary")

    let reportText = chengpath.ReadTextFile("", renderComparePath)
    let summaryText = chengpath.ReadTextFile("", renderCompareSummaryPath)
    assert(chengpath.TextContains(reportText, "\"ok\": true"),
           " r2c render compare direct smoke: report ok")
    assert(chengpath.TextContains(reportText, "\"direct_mode\": true"),
           " r2c render compare direct smoke: report direct mode")
    assert(chengpath.TextContains(reportText, "\"native_gui_summary_ready\": true"),
           " r2c render compare direct smoke: report native summary ready")
    assert(chengpath.TextContains(reportText, "\"native_gui_runtime_bundle_ready\": true"),
           " r2c render compare direct smoke: report runtime bundle ready")
    assert(chengpath.TextContains(reportText, "\"native_gui_runtime_contract_ready\": true"),
           " r2c render compare direct smoke: report runtime contract ready")
    assert(chengpath.TextContains(reportText, "\"truth_trace_format\": \"truth_trace_v2\""),
           " r2c render compare direct smoke: report truth trace format")
    assert(chengpath.TextContains(reportText, "\"route_state_match\": true"),
           " r2c render compare direct smoke: report route state match")
    assert(chengpath.TextContains(reportText, "\"semantic_nodes_count_delta\": 0"),
           " r2c render compare direct smoke: report semantic nodes delta")
    assert(chengpath.TextContains(reportText, "\"diff_pixel_count\": 0"),
           " r2c render compare direct smoke: report diff pixel count")

    assert(chengpath.TextContains(summaryText, "ok=true"),
           " r2c render compare direct smoke: summary ok")
    assert(chengpath.TextContains(summaryText, "direct_mode=true"),
           " r2c render compare direct smoke: summary direct mode")
    assert(chengpath.TextContains(summaryText, "route_state_match=true"),
           " r2c render compare direct smoke: summary route state match")
    assert(chengpath.TextContains(summaryText, "native_gui_runtime_bundle_ready=true"),
           " r2c render compare direct smoke: summary runtime bundle ready")
    assert(chengpath.TextContains(summaryText, "native_gui_runtime_contract_ready=true"),
           " r2c render compare direct smoke: summary runtime contract ready")
    assert(chengpath.TextContains(summaryText, "truth_trace_format=truth_trace_v2"),
           " r2c render compare direct smoke: summary truth trace format")
    assert(chengpath.TextContains(summaryText, "semantic_nodes_count_delta=0"),
           " r2c render compare direct smoke: summary semantic nodes delta")
    assert(chengpath.TextContains(summaryText, "diff_pixel_count=0"),
           " r2c render compare direct smoke: summary diff pixel count")

    echo(" r2c_react_render_compare_direct_smoke ok")
    return 0
