import std/system
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node mint: mint")
    assert(server.index.accountIds.len == 1, " chain_node mint: account len")
    assert(server.index.accountAssetIds[0] == 7, " chain_node mint: asset id")
    assert(server.index.accountIds[0] == 1001, " chain_node mint: account id")
    assert(server.index.balances.len == 1, " chain_node mint: balance len")
    assert(server.index.balances[0] == int64(100), " chain_node mint: raw balance slot")
    assert(node.ChainNodeBalanceValue(server.index, 7, 1001) == int64(100), " chain_node mint: raw balance lookup")
    let balanceRes = node.ChainNodeBalance(server, 7, 1001)
    assert(balanceRes.ok, " chain_node mint: balance")
    assert(balanceRes.value == int64(100), " chain_node mint: amount")
    echo(" chain_node_mint_runtime_smoke ok")
    return 0
