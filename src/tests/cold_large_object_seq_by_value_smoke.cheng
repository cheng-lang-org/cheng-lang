type
    LargePlan =
        f0: str
        f1: str
        f2: str
        f3: str
        f4: str
        f5: str
        f6: str
        f7: str
        f8: str
        f9: str
        f10: str
        f11: str
        f12: str
        f13: str
        f14: str
        f15: str
        f16: str
        f17: str
        f18: str
        f19: str
        f20: str
        f21: str
        f22: str
        f23: str
        f24: str
        f25: str
        f26: str
        f27: str
        f28: str
        f29: str
        f30: str
        f31: str
        f32: str
        f33: str
        f34: str
        f35: str
        f36: str
        f37: str
        f38: str
        f39: str
        paths: str[]

fn pathCount(plan: LargePlan): int32 =
    return plan.paths.len

fn main() =
    var plan: LargePlan
    var paths: str[]
    add(paths, "alpha")
    plan.paths = paths
    assert(plan.paths.len == 1, "cold large object seq direct len")
    assert(pathCount(plan) == 1, "cold large object seq by value len")
