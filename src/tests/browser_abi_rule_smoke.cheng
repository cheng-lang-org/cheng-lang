import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/lang/browser_abi_rule as barule
import cheng/libp2p/browser/browser_content_codec_codegen as codegen
import cheng/libp2p/browser/browser_content_codec_rule_schema as browsercodec

fn main(): int32 =
    let workspaceRoot = "/Users/lbcheng/cheng-lang"
    let packageRoot = "/Users/lbcheng/cheng-lang"
    let browserCodecPath = "/Users/lbcheng/cheng-lang/src/libp2p/browser/browser_content_codec_abi.cheng"
    let browserFixturePath = "/Users/lbcheng/cheng-lang/src/tests/browser_host_native_min_smoke.cheng"
    var linkPlan: slplan.V3SystemLinkPlanStub
    linkPlan.workspaceRoot = workspaceRoot
    linkPlan.packageRoot = packageRoot
    linkPlan.entryPath = browserCodecPath
    linkPlan.sourceClosurePaths = [
        browserFixturePath,
        browserCodecPath
    ]
    let compilerRules = ccsg.v3CompilerBrowserAbiRulesForLinkPlan(linkPlan)
    let compilerSourceRules = barule.v3BrowserAbiRulesForSource(compilerRules, browserCodecPath)
    let schemaRules = browsercodec.v3BrowserContentCodecRules(browserCodecPath)
    let compilerBridgeSpecs = ccsg.v3CompilerBrowserAbiBridgeSpecsForLinkPlan(linkPlan)
    let compilerSourceBridgeSpecs = ccsg.v3CompilerBrowserAbiBridgeSpecsForSource(linkPlan, browserCodecPath)
    let sourceBridgeSpecs = barule.v3BrowserAbiBridgeSpecsForSource(compilerBridgeSpecs, browserCodecPath)
    let schemaBridgeSpecs = barule.v3BrowserAbiBridgeSpecsFromRules(schemaRules)
    let compilerBridgePlans = ccsg.v3CompilerBrowserAbiBridgePlansForLinkPlan(linkPlan)
    let compilerSourceBridgePlans = ccsg.v3CompilerBrowserAbiBridgePlansForSource(linkPlan, browserCodecPath)
    let sourceBridgePlans = barule.v3BrowserAbiBridgePlansForSource(compilerBridgePlans, browserCodecPath)
    let schemaBridgePlans = barule.v3BrowserAbiBridgePlansFromRules(schemaRules)
    let compilerArtifactManifest = barule.v3BrowserAbiBridgePlanManifestText(compilerBridgePlans)
    let schemaArtifactManifest = barule.v3BrowserAbiBridgePlanManifestText(schemaBridgePlans)
    let compilerSourceArtifact = barule.v3BrowserAbiBridgeSourceText(compilerBridgePlans)
    let schemaSourceArtifact = barule.v3BrowserAbiBridgeSourceText(schemaBridgePlans)
    assert(compilerRules.len == 8, "v3 browser abi rule: compiler rule count")
    assert(barule.v3BrowserAbiRulesEqual(compilerSourceRules, schemaRules),
           "v3 browser abi rule: source slice schema equality")
    assert(barule.v3BrowserAbiRuleUniqueKeyCount(compilerSourceRules) == compilerSourceRules.len,
           "v3 browser abi rule: unique key count")
    assert(barule.v3BrowserAbiRuleCountInputKind(compilerSourceRules, barule.v3BrowserAbiInputBytesRequired) == 1,
           "v3 browser abi rule: bytes input")
    assert(barule.v3BrowserAbiRuleCountInputKind(compilerSourceRules, barule.v3BrowserAbiInputTextRequired) == 1,
           "v3 browser abi rule: text input")
    assert(barule.v3BrowserAbiRuleCountInputKind(compilerSourceRules, barule.v3BrowserAbiInputTextOptional) == 1,
           "v3 browser abi rule: optional text input")
    assert(barule.v3BrowserAbiRuleCountErrorKind(compilerSourceRules, barule.v3BrowserAbiErrorMoqFountainLastError) == 3,
           "v3 browser abi rule: error channel")
    assert(barule.v3BrowserAbiRuleCountResultKind(compilerSourceRules, barule.v3BrowserAbiResultStatusI32) == 2,
           "v3 browser abi rule: status result")
    assert(barule.v3BrowserAbiRuleHasRuleName(compilerSourceRules, browsercodec.v3BrowserContentCodecRuleExportMoqFountainBytesResultName()),
           "v3 browser abi rule: moq bytes export rule")
    assert(barule.v3BrowserAbiRuleHasRuleName(compilerSourceRules, browsercodec.v3BrowserContentCodecRuleExportMoqFountainTextResultName()),
           "v3 browser abi rule: moq text export rule")
    assert(barule.v3BrowserAbiRuleHasRuleName(compilerSourceRules, browsercodec.v3BrowserContentCodecRuleMoqFountainLastErrorHandleName()),
           "v3 browser abi rule: moq error handle rule")
    assert(barule.v3BrowserAbiRuleCountOutBufferKind(compilerSourceRules, barule.v3BrowserAbiOutBufferRawHandle) == 2,
           "v3 browser abi rule: raw out buffer")
    assert(barule.v3BrowserAbiRuleCountOutBufferKind(compilerSourceRules, barule.v3BrowserAbiOutBufferTextHandle) == 3,
           "v3 browser abi rule: text out buffer")
    assert(barule.v3BrowserAbiBridgeSpecsEqual(compilerSourceBridgeSpecs, sourceBridgeSpecs),
           "v3 browser abi bridge: source slice equality")
    assert(barule.v3BrowserAbiBridgeSpecsEqual(compilerSourceBridgeSpecs, schemaBridgeSpecs),
           "v3 browser abi bridge: source slice schema equality")
    assert(barule.v3BrowserAbiBridgeSpecUniqueKeyCount(compilerSourceBridgeSpecs) == compilerSourceBridgeSpecs.len,
           "v3 browser abi bridge: unique key count")
    assert(barule.v3BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, barule.v3BrowserAbiBridgeStageInputRead) == 3,
           "v3 browser abi bridge: input read count")
    assert(barule.v3BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, barule.v3BrowserAbiBridgeStageOutputWrite) == 2,
           "v3 browser abi bridge: output write count")
    assert(barule.v3BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, barule.v3BrowserAbiBridgeStageResultExport) == 2,
           "v3 browser abi bridge: export count")
    assert(barule.v3BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, barule.v3BrowserAbiBridgeStageErrorHandleRead) == 1,
           "v3 browser abi bridge: error handle count")
    assert(barule.v3BrowserAbiBridgeSpecCountInputSchemaKind(compilerSourceBridgeSpecs, barule.v3BrowserAbiInputBytesRequired) == 1,
           "v3 browser abi bridge: bytes input schema")
    assert(barule.v3BrowserAbiBridgeSpecCountOutputSchemaKind(compilerSourceBridgeSpecs, barule.v3BrowserAbiOutputSchemaTextHandle) == 3,
           "v3 browser abi bridge: text output schema")
    assert(barule.v3BrowserAbiBridgeSpecCountErrorSchemaKind(compilerSourceBridgeSpecs, barule.v3BrowserAbiErrorMoqFountainLastError) == 3,
           "v3 browser abi bridge: moq error schema")
    assert(barule.v3BrowserAbiBridgeHelperName(compilerSourceBridgeSpecs[0]) == "v3_browser_bridge_input_read_input_bytes_required",
           "v3 browser abi bridge: bytes helper name")
    assert(barule.v3BrowserAbiBridgeHelperName(compilerSourceBridgeSpecs[6]) == "v3_browser_bridge_result_export_export_moq_fountain_text_result",
           "v3 browser abi bridge: export helper name")
    assert(barule.v3BrowserAbiBridgePlansEqual(compilerSourceBridgePlans, sourceBridgePlans),
           "v3 browser abi plan: source slice equality")
    assert(barule.v3BrowserAbiBridgePlansEqual(compilerSourceBridgePlans, schemaBridgePlans),
           "v3 browser abi plan: source slice schema equality")
    assert(compilerArtifactManifest == schemaArtifactManifest,
           "v3 browser abi artifact: schema equality")
    assert(compilerSourceArtifact == schemaSourceArtifact,
           "v3 browser abi source artifact: schema equality")
    assert(barule.v3BrowserAbiBridgePlanUniqueKeyCount(compilerSourceBridgePlans) == compilerSourceBridgePlans.len,
           "v3 browser abi plan: unique key count")
    assert(barule.v3BrowserAbiBridgePlanCountStage(compilerSourceBridgePlans, barule.v3BrowserAbiBridgeStageResultExport) == 2,
           "v3 browser abi plan: export count")
    assert(barule.v3BrowserAbiBridgePlanCountInputSchemaKind(compilerSourceBridgePlans, barule.v3BrowserAbiInputBytesRequired) == 1,
           "v3 browser abi plan: bytes input schema")
    assert(barule.v3BrowserAbiBridgePlanCountOutputSchemaKind(compilerSourceBridgePlans, barule.v3BrowserAbiOutputSchemaTextHandle) == 3,
           "v3 browser abi plan: text output schema")
    assert(barule.v3BrowserAbiBridgePlanCountErrorSchemaKind(compilerSourceBridgePlans, barule.v3BrowserAbiErrorMoqFountainLastError) == 3,
           "v3 browser abi plan: moq error schema")
    assert(barule.v3BrowserAbiBridgePlanHelperName(compilerSourceBridgePlans[6]) == "v3_browser_bridge_result_export_export_moq_fountain_text_result",
           "v3 browser abi plan: export helper name")
    assert(codegen.v3BrowserCodecBridgeKeyForRuleName(browsercodec.v3BrowserContentCodecRuleExportMoqFountainTextResultName()) ==
           compilerSourceBridgeSpecs[6].bridgeKey,
           "v3 browser abi bridge: codegen bridge key equality")
    assert(codegen.v3BrowserCodecBridgeEmitLineForSourceRuleName(browserCodecPath,
                                                                 browsercodec.v3BrowserContentCodecRuleExportMoqFountainTextResultName()) ==
           barule.v3BrowserAbiBridgePlanEmitLine(compilerSourceBridgePlans[6]),
           "v3 browser abi plan: codegen bridge line equality")
    echo("v3 browser_abi_rule_smoke ok")
    return 0
