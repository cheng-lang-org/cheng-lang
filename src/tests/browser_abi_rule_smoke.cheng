import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/lang/browser_abi_rule as barule
import cheng/libp2p/browser/browser_content_codec_codegen as codegen
import cheng/libp2p/browser/browser_content_codec_rule_schema as browsercodec

fn main(): int32 =
    let workspaceRoot = "/Users/lbcheng/cheng-lang"
    let packageRoot = "/Users/lbcheng/cheng-lang"
    let browserCodecPath = "/Users/lbcheng/cheng-lang/src/libp2p/browser/browser_content_codec_abi.cheng"
    let browserFixturePath = "/Users/lbcheng/cheng-lang/src/tests/browser_host_native_min_smoke.cheng"
    var linkPlan: slplan.SystemLinkPlanStub
    linkPlan.workspaceRoot = workspaceRoot
    linkPlan.packageRoot = packageRoot
    linkPlan.entryPath = browserCodecPath
    linkPlan.sourceClosurePaths = [
        browserFixturePath,
        browserCodecPath
    ]
    let compilerRules = ccsg.CompilerBrowserAbiRulesForLinkPlan(linkPlan)
    let compilerSourceRules = barule.BrowserAbiRulesForSource(compilerRules, browserCodecPath)
    let schemaRules = browsercodec.BrowserContentCodecRules(browserCodecPath)
    let compilerBridgeSpecs = ccsg.CompilerBrowserAbiBridgeSpecsForLinkPlan(linkPlan)
    let compilerSourceBridgeSpecs = ccsg.CompilerBrowserAbiBridgeSpecsForSource(linkPlan, browserCodecPath)
    let sourceBridgeSpecs = barule.BrowserAbiBridgeSpecsForSource(compilerBridgeSpecs, browserCodecPath)
    let schemaBridgeSpecs = barule.BrowserAbiBridgeSpecsFromRules(schemaRules)
    let compilerBridgePlans = ccsg.CompilerBrowserAbiBridgePlansForLinkPlan(linkPlan)
    let compilerSourceBridgePlans = ccsg.CompilerBrowserAbiBridgePlansForSource(linkPlan, browserCodecPath)
    let sourceBridgePlans = barule.BrowserAbiBridgePlansForSource(compilerBridgePlans, browserCodecPath)
    let schemaBridgePlans = barule.BrowserAbiBridgePlansFromRules(schemaRules)
    let compilerArtifactManifest = barule.BrowserAbiBridgePlanManifestText(compilerBridgePlans)
    let schemaArtifactManifest = barule.BrowserAbiBridgePlanManifestText(schemaBridgePlans)
    let compilerSourceArtifact = barule.BrowserAbiBridgeSourceText(compilerBridgePlans)
    let schemaSourceArtifact = barule.BrowserAbiBridgeSourceText(schemaBridgePlans)
    assert(compilerRules.len == 8, " browser abi rule: compiler rule count")
    assert(barule.BrowserAbiRulesEqual(compilerSourceRules, schemaRules),
           " browser abi rule: source slice schema equality")
    assert(barule.BrowserAbiRuleUniqueKeyCount(compilerSourceRules) == compilerSourceRules.len,
           " browser abi rule: unique key count")
    assert(barule.BrowserAbiRuleCountInputKind(compilerSourceRules, barule.BrowserAbiInputBytesRequired) == 1,
           " browser abi rule: bytes input")
    assert(barule.BrowserAbiRuleCountInputKind(compilerSourceRules, barule.BrowserAbiInputTextRequired) == 1,
           " browser abi rule: text input")
    assert(barule.BrowserAbiRuleCountInputKind(compilerSourceRules, barule.BrowserAbiInputTextOptional) == 1,
           " browser abi rule: optional text input")
    assert(barule.BrowserAbiRuleCountErrorKind(compilerSourceRules, barule.BrowserAbiErrorMoqFountainLastError) == 3,
           " browser abi rule: error channel")
    assert(barule.BrowserAbiRuleCountResultKind(compilerSourceRules, barule.BrowserAbiResultStatusI32) == 2,
           " browser abi rule: status result")
    assert(barule.BrowserAbiRuleHasRuleName(compilerSourceRules, browsercodec.BrowserContentCodecRuleExportMoqFountainBytesResultName()),
           " browser abi rule: moq bytes export rule")
    assert(barule.BrowserAbiRuleHasRuleName(compilerSourceRules, browsercodec.BrowserContentCodecRuleExportMoqFountainTextResultName()),
           " browser abi rule: moq text export rule")
    assert(barule.BrowserAbiRuleHasRuleName(compilerSourceRules, browsercodec.BrowserContentCodecRuleMoqFountainLastErrorHandleName()),
           " browser abi rule: moq error handle rule")
    assert(barule.BrowserAbiRuleCountOutBufferKind(compilerSourceRules, barule.BrowserAbiOutBufferRawHandle) == 2,
           " browser abi rule: raw out buffer")
    assert(barule.BrowserAbiRuleCountOutBufferKind(compilerSourceRules, barule.BrowserAbiOutBufferTextHandle) == 3,
           " browser abi rule: text out buffer")
    assert(barule.BrowserAbiBridgeSpecsEqual(compilerSourceBridgeSpecs, sourceBridgeSpecs),
           " browser abi bridge: source slice equality")
    assert(barule.BrowserAbiBridgeSpecsEqual(compilerSourceBridgeSpecs, schemaBridgeSpecs),
           " browser abi bridge: source slice schema equality")
    assert(barule.BrowserAbiBridgeSpecUniqueKeyCount(compilerSourceBridgeSpecs) == compilerSourceBridgeSpecs.len,
           " browser abi bridge: unique key count")
    assert(barule.BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, barule.BrowserAbiBridgeStageInputRead) == 3,
           " browser abi bridge: input read count")
    assert(barule.BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, barule.BrowserAbiBridgeStageOutputWrite) == 2,
           " browser abi bridge: output write count")
    assert(barule.BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, barule.BrowserAbiBridgeStageResultExport) == 2,
           " browser abi bridge: export count")
    assert(barule.BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, barule.BrowserAbiBridgeStageErrorHandleRead) == 1,
           " browser abi bridge: error handle count")
    assert(barule.BrowserAbiBridgeSpecCountInputSchemaKind(compilerSourceBridgeSpecs, barule.BrowserAbiInputBytesRequired) == 1,
           " browser abi bridge: bytes input schema")
    assert(barule.BrowserAbiBridgeSpecCountOutputSchemaKind(compilerSourceBridgeSpecs, barule.BrowserAbiOutputSchemaTextHandle) == 3,
           " browser abi bridge: text output schema")
    assert(barule.BrowserAbiBridgeSpecCountErrorSchemaKind(compilerSourceBridgeSpecs, barule.BrowserAbiErrorMoqFountainLastError) == 3,
           " browser abi bridge: moq error schema")
    assert(barule.BrowserAbiBridgeHelperName(compilerSourceBridgeSpecs[0]) == "cheng_browser_bridge_input_read_input_bytes_required",
           " browser abi bridge: bytes helper name")
    assert(barule.BrowserAbiBridgeHelperName(compilerSourceBridgeSpecs[6]) == "cheng_browser_bridge_result_export_export_moq_fountain_text_result",
           " browser abi bridge: export helper name")
    assert(barule.BrowserAbiBridgePlansEqual(compilerSourceBridgePlans, sourceBridgePlans),
           " browser abi plan: source slice equality")
    assert(barule.BrowserAbiBridgePlansEqual(compilerSourceBridgePlans, schemaBridgePlans),
           " browser abi plan: source slice schema equality")
    assert(compilerArtifactManifest == schemaArtifactManifest,
           " browser abi artifact: schema equality")
    assert(compilerSourceArtifact == schemaSourceArtifact,
           " browser abi source artifact: schema equality")
    assert(barule.BrowserAbiBridgePlanUniqueKeyCount(compilerSourceBridgePlans) == compilerSourceBridgePlans.len,
           " browser abi plan: unique key count")
    assert(barule.BrowserAbiBridgePlanCountStage(compilerSourceBridgePlans, barule.BrowserAbiBridgeStageResultExport) == 2,
           " browser abi plan: export count")
    assert(barule.BrowserAbiBridgePlanCountInputSchemaKind(compilerSourceBridgePlans, barule.BrowserAbiInputBytesRequired) == 1,
           " browser abi plan: bytes input schema")
    assert(barule.BrowserAbiBridgePlanCountOutputSchemaKind(compilerSourceBridgePlans, barule.BrowserAbiOutputSchemaTextHandle) == 3,
           " browser abi plan: text output schema")
    assert(barule.BrowserAbiBridgePlanCountErrorSchemaKind(compilerSourceBridgePlans, barule.BrowserAbiErrorMoqFountainLastError) == 3,
           " browser abi plan: moq error schema")
    assert(barule.BrowserAbiBridgePlanHelperName(compilerSourceBridgePlans[6]) == "cheng_browser_bridge_result_export_export_moq_fountain_text_result",
           " browser abi plan: export helper name")
    assert(codegen.BrowserCodecBridgeKeyForRuleName(browsercodec.BrowserContentCodecRuleExportMoqFountainTextResultName()) ==
           compilerSourceBridgeSpecs[6].bridgeKey,
           " browser abi bridge: codegen bridge key equality")
    assert(codegen.BrowserCodecBridgeEmitLineForSourceRuleName(browserCodecPath,
                                                                 browsercodec.BrowserContentCodecRuleExportMoqFountainTextResultName()) ==
           barule.BrowserAbiBridgePlanEmitLine(compilerSourceBridgePlans[6]),
           " browser abi plan: codegen bridge line equality")
    echo(" browser_abi_rule_smoke ok")
    return 0
