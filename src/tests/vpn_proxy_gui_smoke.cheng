import std/result
import cheng/apps/vpn_proxy/vpn_proxy_config as config
import cheng/apps/vpn_proxy/gui/vpn_proxy_gui as gui

fn main(): int32 =
    var state = gui.VpnProxyGuiStateForTest("/tmp/cheng-vpn-gui-test",
                                              "/tmp/cheng-vpn-gui-test/runtime",
                                              "/tmp/cheng-vpn-gui-test/local.json")
    let buildRes: Result[str] = gui.VpnProxyGuiBuildConfigText(state)
    assert(IsOk(buildRes), " vpn gui smoke: build config")
    let text: str = Value(buildRes)
    assert(len(text) > 0, " vpn gui smoke: config text non-empty")
    let parseRes: Result[config.VpnProxyConfig] = config.VpnProxyParseConfigTextForTest(text)
    assert(IsOk(parseRes), " vpn gui smoke: parse config")
    let cfg: config.VpnProxyConfig = Value(parseRes)
    assert(cfg.client.listen == "127.0.0.1:1086", " vpn gui smoke: default listen")
    assert(cfg.exits.len == 1, " vpn gui smoke: single exit")
    assert(cfg.exits[0].host == "64.176.84.12", " vpn gui smoke: exit host")
    echo(" vpn_proxy_gui_smoke ok")
    return 0
