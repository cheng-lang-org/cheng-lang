import cheng/std/bytes_layout as layout
import cheng/chain/consensus

type
    MiniNode =
        index: consensus.ChainIndex
        eventCids: layout.FixedBytes32[]
        events: consensus.ChainEvent[]
        tipEventCid: layout.FixedBytes32
        nextTick: int64

fn miniRebuild(node: var MiniNode) =
    node.tipEventCid = node.eventCids.len > 0 ? node.eventCids[node.eventCids.len - 1] : layout.FixedBytes32()
    node.nextTick = int64(node.eventCids.len + 1)

fn miniApplyEvent(node: var MiniNode, event: var consensus.ChainEvent): Result[layout.FixedBytes32] =
    let eventCid = consensus.ChainEventCid(event)
    var nextIndex = node.index
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(nextIndex, event, eventCid, node.eventCids.len, decision)
    node.index = nextIndex
    if !decision.accepted:
        return Err[layout.FixedBytes32]("mini provider apply rejected")
    if decision.applied:
        add(node.eventCids, eventCid)
        add(node.events, event)
        miniRebuild(node)
    return Ok[layout.FixedBytes32](eventCid)

fn miniMint(node: var MiniNode, assetId: int32, toAccount: int32, amount: int64): Result[layout.FixedBytes32] =
    if assetId <= 0 || toAccount <= 0:
        return Err[layout.FixedBytes32]("mini provider invalid mint target")
    if amount <= int64(0):
        return Err[layout.FixedBytes32]("mini provider mint amount must be positive")
    var event = consensus.ChainEventMint(
        assetId,
        toAccount,
        layout.FixedBytes32(),
        amount,
        1,
        1,
        1,
        node.nextTick
    )
    return miniApplyEvent(node, event)
