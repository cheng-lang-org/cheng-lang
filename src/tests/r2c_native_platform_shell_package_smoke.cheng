import std/os
import std/strutils as strutil
import cheng/core/tooling/path as chengpath
import cheng/r2c/native_platform_shell_package as shellpackage
import cheng/r2c/native_platform_shell_runtime as shellruntime

fn main(): int32 =
    let outDir: str = "/tmp/r2c_native_platform_shell_package_smoke_artifacts"
    let framePath: str = chengpath.PathJoin(outDir, "frame.rgba")
    let manifestPath: str = chengpath.PathJoin(outDir, "native_platform_shell_manifest_v1.json")
    let packageManifestPath: str = chengpath.PathJoin(outDir, "native_platform_shell_package_manifest_v1.json")
    assert(chengpath.MkdirP("", outDir), "r2c native platform shell package smoke: mkdir")
    if os.FileExists(framePath):
        os.RemoveFile(framePath)
    if os.FileExists(manifestPath):
        os.RemoveFile(manifestPath)
    if os.FileExists(packageManifestPath):
        os.RemoveFile(packageManifestPath)
    let framePayload: uint8[] = [
        uint8(255), uint8(0), uint8(0), uint8(255),
        uint8(0), uint8(255), uint8(0), uint8(255),
        uint8(0), uint8(0), uint8(255), uint8(255),
        uint8(255), uint8(255), uint8(255), uint8(255)
    ]
    os.WriteFileBytes(framePath, framePayload)
    assert(os.FileExists(framePath), "r2c native platform shell package smoke: frame exists")
    assert(os.FileSize(framePath) == int64(16), "r2c native platform shell package smoke: frame size")
    var manifest = "{\n"
    manifest = manifest + "  \"format\": \"native_platform_shell_manifest_v1\",\n"
    manifest = manifest + "  \"ready\": true,\n"
    manifest = manifest + "  \"generated_by\": \"cheng.native_gui_runtime_v1\",\n"
    manifest = manifest + "  \"runtime_purity\": {\"node\": false, \"react\": false, \"webview_business_layer\": false, \"business_js\": false},\n"
    manifest = manifest + "  \"surface_frame_path\": \"" + framePath + "\",\n"
    manifest = manifest + "  \"surface_manifest_path\": \"/tmp/surface_manifest.json\",\n"
    manifest = manifest + "  \"route_replay_manifest_path\": \"/tmp/route_replay_manifest.json\",\n"
    manifest = manifest + "  \"interaction_manifest_path\": \"/tmp/interaction_manifest.json\",\n"
    manifest = manifest + "  \"frame_format\": \"surface_frame_rgba_v1\",\n"
    manifest = manifest + "  \"pixel_format\": \"rgba8_unpremultiplied\",\n"
    manifest = manifest + "  \"width\": 2,\n"
    manifest = manifest + "  \"height\": 2,\n"
    manifest = manifest + "  \"stride_bytes\": 8,\n"
    manifest = manifest + "  \"frame_byte_count\": 16,\n"
    manifest = manifest + "  \"route_count\": 3,\n"
    manifest = manifest + "  \"active_route_state\": \"home_default\",\n"
    manifest = manifest + "  \"event_loop\": \"event_driven_v1\",\n"
    manifest = manifest + "  \"platforms\": [\n"
    manifest = manifest + "    {\"id\":\"android\",\"shell_kind\":\"cheng_generated_android_surface_shell_v1\",\"surface_binding\":\"ANativeWindow_rgba_blit_v1\",\"input_binding\":\"AInputQueue_event_driven_v1\",\"blit_contract\":\"rgba8_stride_copy_v1\"},\n"
    manifest = manifest + "    {\"id\":\"ios\",\"shell_kind\":\"cheng_generated_ios_surface_shell_v1\",\"surface_binding\":\"CAMetalLayer_rgba_blit_v1\",\"input_binding\":\"UIKit_touch_event_driven_v1\",\"blit_contract\":\"rgba8_stride_copy_v1\"},\n"
    manifest = manifest + "    {\"id\":\"ohos\",\"shell_kind\":\"cheng_generated_ohos_surface_shell_v1\",\"surface_binding\":\"OHNativeWindow_rgba_blit_v1\",\"input_binding\":\"XComponent_event_driven_v1\",\"blit_contract\":\"rgba8_stride_copy_v1\"}\n"
    manifest = manifest + "  ]\n"
    manifest = manifest + "}\n"
    os.WriteFile(manifestPath, manifest)
    assert(shellruntime.WriteNativePlatformShellLaunchPlans(manifestPath, outDir),
           "r2c native platform shell package smoke: write launch plans")
    assert(shellpackage.WriteNativePlatformShellPackageManifest(outDir, packageManifestPath),
           "r2c native platform shell package smoke: write package manifest")
    assert(chengpath.FileExistsNonEmpty("", packageManifestPath),
           "r2c native platform shell package smoke: package manifest exists")
    let packageText = os.ReadFile(packageManifestPath)
    assert(shellpackage.NativePlatformShellPackageManifestValid(packageText),
           "r2c native platform shell package smoke: package manifest valid")
    assert(strutil.Contains(packageText, "\"format\": \"native_platform_shell_package_manifest_v1\""),
           "r2c native platform shell package smoke: package format")
    assert(strutil.Contains(packageText, "\"package_kind\": \"cheng_generated_native_surface_shell_package_v1\""),
           "r2c native platform shell package smoke: package kind")
    assert(strutil.Contains(packageText, "\"platform_count\": 3"),
           "r2c native platform shell package smoke: platform count")
    assert(strutil.Contains(packageText, "\"surface_binding\":\"ANativeWindow_rgba_blit_v1\""),
           "r2c native platform shell package smoke: android surface")
    assert(strutil.Contains(packageText, "\"surface_binding\":\"CAMetalLayer_rgba_blit_v1\""),
           "r2c native platform shell package smoke: ios surface")
    assert(strutil.Contains(packageText, "\"surface_binding\":\"OHNativeWindow_rgba_blit_v1\""),
           "r2c native platform shell package smoke: ohos surface")
    echo("r2c_native_platform_shell_package_smoke ok")
    return 0
