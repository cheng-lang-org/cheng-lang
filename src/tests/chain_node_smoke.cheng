import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    var client: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(client, "node-b", "chain-node-b")),
           " chain_node: init")

    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node smoke: mint")

    let aliceAfterMintRes = node.ChainNodeBalance(server, 7, 1001)
    assert(aliceAfterMintRes.ok, " chain_node smoke: balance after mint")
    assert(aliceAfterMintRes.value == int64(100), " chain_node smoke: minted balance")

    let transferCidRes = node.ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, " chain_node smoke: transfer")
    assert(!layout.fixedBytes32Equal(mintCidRes.value, transferCidRes.value), " chain_node smoke: transfer cid differs")

    let aliceServerRes = node.ChainNodeBalance(server, 7, 1001)
    let bobServerRes = node.ChainNodeBalance(server, 7, 2002)
    assert(aliceServerRes.ok, " chain_node smoke: server alice balance")
    assert(bobServerRes.ok, " chain_node smoke: server bob balance")
    assert(aliceServerRes.value == int64(60), " chain_node smoke: server alice 60")
    assert(bobServerRes.value == int64(40), " chain_node smoke: server bob 40")

    let aliceClientPreRes = node.ChainNodeBalance(client, 7, 1001)
    let bobClientPreRes = node.ChainNodeBalance(client, 7, 2002)
    assert(aliceClientPreRes.ok, " chain_node smoke: client pre balance")
    assert(bobClientPreRes.ok, " chain_node smoke: client pre receiver balance")
    assert(aliceClientPreRes.value == int64(0), " chain_node smoke: client pre alice zero")
    assert(bobClientPreRes.value == int64(0), " chain_node smoke: client pre bob zero")

    var served: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(served, server)
    let syncRes = node.ChainNodeSyncOnce(client, served)
    assert(syncRes.ok, " chain_node smoke: sync once")
    assert(syncRes.value, " chain_node smoke: sync changed state")

    let aliceClientRes = node.ChainNodeBalance(client, 7, 1001)
    let bobClientRes = node.ChainNodeBalance(client, 7, 2002)
    assert(aliceClientRes.ok, " chain_node smoke: client alice balance")
    assert(bobClientRes.ok, " chain_node smoke: client bob balance")
    assert(aliceClientRes.value == int64(60), " chain_node smoke: client alice 60")
    assert(bobClientRes.value == int64(40), " chain_node smoke: client bob 40")

    var clientServed: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(clientServed, client)
    assert(layout.fixedBytes32Equal(served.tipEventCid, clientServed.tipEventCid), " chain_node smoke: tip cid一致")
    assert(layout.fixedBytes32Equal(node.ChainNodeForestCid(server), node.ChainNodeForestCid(client)), " chain_node smoke: forest cid一致")
    assert(layout.fixedBytes32Equal(served.forest.forestCid, clientServed.forest.forestCid), " chain_node smoke: served forest一致")
    assert(anti.AntiEntropySignatureEqual(served.signature, clientServed.signature), " chain_node smoke: signature一致")
    let syncAgainRes = node.ChainNodeSyncOnce(client, served)
    assert(syncAgainRes.ok, " chain_node smoke: sync again")
    assert(!syncAgainRes.value, " chain_node smoke: second sync idle")

    echo(" chain_node_smoke ok")
    return 0
