import std/result
import cheng/core/tooling/compiler_request as creq

fn BackendDriverDispatchMinUnsupported(reason: str): int32 =
    return 2

fn BackendDriverDispatchMinRunSystemLinkExecConcreteRequest(rootDir: str, reqBase: creq.CompilerRequest): int32 =
    return 0

fn BackendDriverDispatchMinRunSystemLinkExecWithRequest(rootDir: str,
                                                         reqRes: Result[creq.CompilerRequest]): int32 =
    if IsErr(reqRes):
        return BackendDriverDispatchMinUnsupported(Error(reqRes))
    let reqBase = Value(reqRes)
    return BackendDriverDispatchMinRunSystemLinkExecConcreteRequest(rootDir, reqBase)

fn main(): int32 =
    return 0
