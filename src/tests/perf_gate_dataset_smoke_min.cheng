import std/system
import std/strutils as strutil
import cheng/core/lang/intern as langintern
import cheng/core/tooling/perf_gate as perfgate

fn loadStatic(pool: langintern.InternPool): perfgate.BenchDataset =
    var samples: perfgate.BenchSample[]
    add(samples, perfgate.BenchSample(
        benchId: langintern.Intern(pool, "sha256"),
        nsPerOpMilli: 10000))
    add(samples, perfgate.BenchSample(
        benchId: langintern.Intern(pool, "x25519"),
        nsPerOpMilli: 20500))
    assert(samples.len == 2, "perf gate dataset local rows")
    var out: perfgate.BenchDataset
    out.samples.len = samples.len
    out.samples.cap = samples.cap
    out.samples.buffer = samples.buffer
    return out

fn main() =
    let pool: langintern.InternPool = langintern.InternPoolNew()
    let staticData: perfgate.BenchDataset = loadStatic(pool)
    assert(staticData.samples.len == 2, "perf gate dataset static rows")
    let text: str = "sha256 ns_per_op=10.000\nx25519 ns_per_op=20.500\n"
    let lines: str[] = strutil.Split(text, '\n')
    assert(lines.len == 3, "perf gate dataset split rows")
    var loopSamples: perfgate.BenchSample[]
    var j: int32
    for j in j..<2:
        add(loopSamples, perfgate.BenchSample(
            benchId: langintern.Intern(pool, "loop"),
            nsPerOpMilli: int64(j + 1)))
    assert(loopSamples.len == 2, "perf gate dataset loop static rows")
    var samples: perfgate.BenchSample[]
    var i: int32
    for i in i..<lines.len:
        if i == 0:
            assert(lines[i] == "sha256 ns_per_op=10.000", "perf gate dataset raw0")
        elif i == 1:
            assert(lines[i] == "x25519 ns_per_op=20.500", "perf gate dataset raw1")
        let line: str = strutil.Strip(lines[i])
        if i == 0:
            assert(line == "sha256 ns_per_op=10.000", "perf gate dataset strip0")
            assert(!strutil.StartsWith(line, "sink="), "perf gate dataset sink0")
        elif i == 1:
            assert(line == "x25519 ns_per_op=20.500", "perf gate dataset strip1")
            assert(!strutil.StartsWith(line, "sink="), "perf gate dataset sink1")
        if len(line) <= 0:
            continue
        if strutil.StartsWith(line, "sink="):
            continue
        let name: str = perfgate.BenchFirstField(line)
        let nsText: str = perfgate.BenchFindValue(line, "ns_per_op=")
        let nsMilli: int64 = perfgate.BenchParseDecimalMilli(nsText)
        if len(name) <= 0 || nsMilli < int64(0):
            continue
        if i == 0:
            assert(line == "sha256 ns_per_op=10.000", "perf gate dataset line0")
            assert(name == "sha256", "perf gate dataset name0")
            assert(nsText == "10.000", "perf gate dataset ns0")
            assert(nsMilli == int64(10000), "perf gate dataset milli0")
        elif i == 1:
            assert(line == "x25519 ns_per_op=20.500", "perf gate dataset line1")
            assert(name == "x25519", "perf gate dataset name1")
            assert(nsText == "20.500", "perf gate dataset ns1")
            assert(nsMilli == int64(20500), "perf gate dataset milli1")
        let benchId: langintern.InternId = langintern.Intern(pool, name)
        add(samples, perfgate.BenchSample(benchId: benchId, nsPerOpMilli: nsMilli))
        if i == 0:
            assert(samples.len == 1, "perf gate dataset add0")
        elif i == 1:
            assert(samples.len == 2, "perf gate dataset add1")
    assert(samples.len == 2, "perf gate dataset inline rows")
    let data: perfgate.BenchDataset = perfgate.BenchDatasetLoadText(
        pool,
        text)
    assert(data.samples.len == 2, "perf gate dataset rows")
