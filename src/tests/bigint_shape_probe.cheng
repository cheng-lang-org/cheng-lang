import std/system

const
    bigintShapeProbeLimbs = 256

type
    BigintShapeProbeValue =
        count: int32
        limbs: int32[bigintShapeProbeLimbs]

fn bigintShapeProbeWordFromU64(v: int64): int32 =
    if v >= 0:
        return int32(v)
    let mag: int64 = int64(0) - v
    let magBits: uint64 = uint64(mag)
    let magShifted: uint64 = (magBits >> uint64(32)) << uint64(32)
    let magLow: uint64 = magBits - magShifted
    if magLow == 0:
        return 0
    let lowBits: uint64 = (uint64(1) << uint64(32)) - magLow
    return 0 - int32((uint64(1) << uint64(32)) - lowBits)

fn bigintShapeProbeBuild(value: int64): BigintShapeProbeValue =
    var out: BigintShapeProbeValue
    out.limbs[0] = bigintShapeProbeWordFromU64(value)
    let hi: int64 = value >> 32
    if hi == 0:
        out.count = 1
        return out
    out.limbs[1] = bigintShapeProbeWordFromU64(hi)
    out.count = 2
    return out

fn bigintShapeProbeCopy(a: BigintShapeProbeValue): BigintShapeProbeValue =
    var out: BigintShapeProbeValue
    out.count = a.count
    for i in 0..<a.count:
        out.limbs[i] = a.limbs[i]
    return out

fn main(): int32 =
    let a: BigintShapeProbeValue = bigintShapeProbeBuild(65537)
    let b: BigintShapeProbeValue = bigintShapeProbeCopy(a)
    assert(b.count == 1, "bigint shape probe: count")
    assert(b.limbs[0] == 65537, "bigint shape probe: limb0")
    echo(" bigint_shape_probe ok")
    return 0
