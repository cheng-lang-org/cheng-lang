# cfg_multi_stmt_smoke.cheng
# Tests a function with multiple sequential statements (let + call + return).
# Verifies that typed_expr produces statement IR for each binding,
# lowering_plan emits callSequence entries, and primary_object_plan
# emits ARM64 ops for the chain.
#
# Expected exit code: 7
#   First() = 3, Second(3) = 4, UseBoth(3, 4) = 7

fn First(): int32 =
    return 3

fn Second(a: int32): int32 =
    return a + 1

fn UseBoth(a: int32, b: int32): int32 =
    return a + b

fn main(): int32 =
    let a = First()
    let b = Second(a)
    let result = UseBoth(a, b)
    if result != 7:
        return 1
    echo(" cfg_multi_stmt_smoke ok")
    return 0
