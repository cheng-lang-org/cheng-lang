import std/os
import cheng/core/tooling/host_ops as hostops
import std/strutils as strutil

fn StrConcatLoweringFlag(prefix: str, value: str): str =
    var parts: str[]
    add(parts, prefix)
    add(parts, value)
    return strutil.Join(parts, "")

fn main(): int32 =
    let root = os.GetCurrentDir()
    echo(StrConcatLoweringFlag("--root:", root))
    return 0
