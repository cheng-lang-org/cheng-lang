import std/result
import cheng/apps/vpn_proxy/vpn_proxy_main as vpn

fn main(): int32 =
    var states: vpn.VpnProxyUdpFragState[]
    var full: vpn.Hysteria2UdpMessage
    var firstMsg: vpn.Hysteria2UdpMessage
    firstMsg.sessionId = 1
    firstMsg.packetId = 7
    firstMsg.fragmentId = 0
    firstMsg.fragmentCount = 2
    firstMsg.address = "1.2.3.4:53"
    firstMsg.payload = bytesFromString("hello-")
    let firstRes = vpn.VpnProxyUdpFragFeedAt(states,
                                               firstMsg,
                                               int64(1000),
                                               full)
    assert(IsOk(firstRes), " vpn proxy udp fragment guard: first fragment")
    assert(!Value(firstRes), " vpn proxy udp fragment guard: first fragment pending")
    assert(states.len == 1, " vpn proxy udp fragment guard: one pending state")

    var secondMsg: vpn.Hysteria2UdpMessage
    secondMsg.sessionId = 1
    secondMsg.packetId = 8
    secondMsg.fragmentId = 0
    secondMsg.fragmentCount = 2
    secondMsg.address = "1.2.3.4:53"
    secondMsg.payload = bytesFromString("stale")
    let secondRes = vpn.VpnProxyUdpFragFeedAt(states,
                                                secondMsg,
                                                int64(1000 + vpn.VpnProxyUdpFragExpiryMs + 1),
                                                full)
    assert(IsOk(secondRes), " vpn proxy udp fragment guard: second fragment")
    assert(!Value(secondRes), " vpn proxy udp fragment guard: second fragment pending")
    assert(states.len == 1, " vpn proxy udp fragment guard: expired state swept")
    assert(states[0].packetId == 8, " vpn proxy udp fragment guard: stale packet removed")

    var overflowStates: vpn.VpnProxyUdpFragState[]
    for i in 0..<vpn.VpnProxyUdpFragMaxPendingPackets:
        var pendingMsg: vpn.Hysteria2UdpMessage
        pendingMsg.sessionId = 1
        pendingMsg.packetId = i
        pendingMsg.fragmentId = 0
        pendingMsg.fragmentCount = 2
        pendingMsg.address = "1.2.3.4:53"
        pendingMsg.payload = bytesFromString("xx")
        let pendingRes = vpn.VpnProxyUdpFragFeedAt(overflowStates,
                                                     pendingMsg,
                                                     int64(2000),
                                                     full)
        assert(IsOk(pendingRes), " vpn proxy udp fragment guard: fill pending states")
        assert(!Value(pendingRes), " vpn proxy udp fragment guard: fill pending states pending")
    var overflowMsg: vpn.Hysteria2UdpMessage
    overflowMsg.sessionId = 1
    overflowMsg.packetId = 999
    overflowMsg.fragmentId = 0
    overflowMsg.fragmentCount = 2
    overflowMsg.address = "1.2.3.4:53"
    overflowMsg.payload = bytesFromString("yy")
    let overflowRes = vpn.VpnProxyUdpFragFeedAt(overflowStates,
                                                  overflowMsg,
                                                  int64(2000),
                                                  full)
    assert(IsErr(overflowRes), " vpn proxy udp fragment guard: overflow hard fail")
    assert(ErrorText(overflowRes) == "vpn proxy: udp fragment state overflow",
           " vpn proxy udp fragment guard: overflow error text")

    var reassembleStates: vpn.VpnProxyUdpFragState[]
    var partAMsg: vpn.Hysteria2UdpMessage
    partAMsg.sessionId = 1
    partAMsg.packetId = 42
    partAMsg.fragmentId = 0
    partAMsg.fragmentCount = 2
    partAMsg.address = "1.2.3.4:53"
    partAMsg.payload = bytesFromString("hello-")
    let partARes = vpn.VpnProxyUdpFragFeedAt(reassembleStates,
                                               partAMsg,
                                               int64(3000),
                                               full)
    assert(IsOk(partARes), " vpn proxy udp fragment guard: reassemble part a")
    assert(!Value(partARes), " vpn proxy udp fragment guard: reassemble part a pending")
    var partBMsg: vpn.Hysteria2UdpMessage
    partBMsg.sessionId = 1
    partBMsg.packetId = 42
    partBMsg.fragmentId = 1
    partBMsg.fragmentCount = 2
    partBMsg.address = "1.2.3.4:53"
    partBMsg.payload = bytesFromString("world")
    let partBRes = vpn.VpnProxyUdpFragFeedAt(reassembleStates,
                                               partBMsg,
                                               int64(3001),
                                               full)
    assert(IsOk(partBRes), " vpn proxy udp fragment guard: reassemble part b")
    assert(Value(partBRes), " vpn proxy udp fragment guard: reassemble complete")
    assert(bytesToString(full.payload) == "hello-world",
           " vpn proxy udp fragment guard: payload reassembled")
    assert(reassembleStates.len == 0, " vpn proxy udp fragment guard: state cleared")

    echo(" vpn_proxy_udp_fragment_guard_smoke ok")
    return 0
