import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    var buf = layout.byteBufInit(16)
    lt.AppendU32BE(buf, 1)
    let span = layout.byteBufView(buf)
    assert(layout.byteSpanLen(span) == 4, " append u32: len")
    assert(layout.byteSpanAt(span, 0) == 0, " append u32: b0")
    assert(layout.byteSpanAt(span, 1) == 0, " append u32: b1")
    assert(layout.byteSpanAt(span, 2) == 0, " append u32: b2")
    assert(layout.byteSpanAt(span, 3) == 1, " append u32: b3")
    echo(" append_u32_smoke ok")
    return 0
