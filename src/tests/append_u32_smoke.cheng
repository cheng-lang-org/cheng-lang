import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    var buf = layout.byteBufInit(16)
    lt.v3AppendU32BE(buf, 1)
    let span = layout.byteBufView(buf)
    assert(layout.byteSpanLen(span) == 4, "v3 append u32: len")
    assert(layout.byteSpanAt(span, 0) == 0, "v3 append u32: b0")
    assert(layout.byteSpanAt(span, 1) == 0, "v3 append u32: b1")
    assert(layout.byteSpanAt(span, 2) == 0, "v3 append u32: b2")
    assert(layout.byteSpanAt(span, 3) == 1, "v3 append u32: b3")
    echo("v3 append_u32_smoke ok")
    return 0
