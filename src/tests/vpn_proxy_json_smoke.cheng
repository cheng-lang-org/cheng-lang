import cheng/apps/vpn_proxy/vpn_proxy_json as json

fn main(): int32 =
    let parseRes: json.ParseResult = json.ParseJsonSafe("{\"name\":\"edge\",\"port\":7443,\"tags\":[\"a\",\"b\"],\"nested\":{\"enabled\":true}}")
    assert(parseRes.ok, " vpn proxy json parse")

    let root: json.JsonNode = parseRes.value
    assert(json.IsObject(root), " vpn proxy json root kind")

    let nameNode: json.JsonNode = json.JsonGetField(root, "name")
    assert(json.IsString(nameNode), " vpn proxy json name kind")
    assert(json.GetStr(nameNode) == "edge", " vpn proxy json name value")

    let portNode: json.JsonNode = json.JsonGetField(root, "port")
    assert(json.IsInt(portNode), " vpn proxy json port kind")
    assert(json.GetInt(portNode) == 7443, " vpn proxy json port value")

    let tagsNode: json.JsonNode = json.JsonGetField(root, "tags")
    assert(json.IsArray(tagsNode), " vpn proxy json tags kind")
    assert(tagsNode.a.len == 2, " vpn proxy json tags len")
    assert(json.GetStr(tagsNode.a[0]) == "a", " vpn proxy json first tag")
    assert(json.GetStr(tagsNode.a[1]) == "b", " vpn proxy json second tag")

    let escapeRes: json.ParseResult = json.ParseJsonSafe("{\"text\":\"line1\\nline2\\t\\\\end\\\"\"}")
    assert(escapeRes.ok, " vpn proxy json escape parse")
    let escapeNode: json.JsonNode = json.JsonGetField(escapeRes.value, "text")
    assert(json.GetStr(escapeNode) == "line1\nline2\t\\end\"", " vpn proxy json escape text")

    let badRes: json.ParseResult = json.ParseJsonSafe("{\"port\":1.5}")
    assert(!badRes.ok, " vpn proxy json float reject")
    assert(badRes.error == "float numbers unsupported", " vpn proxy json float reject text")

    echo(" vpn_proxy_json_smoke ok")
    return 0
