type
    PositiveFoo =
        count: int32 = 5
        tags: str[]

    PositivePair = tuple[a: int32 = 2, b: str[]]

fn makeFoo(): PositiveFoo =
    return PositiveFoo()

fn main(): int32 =
    let flag: bool = true
    assert(flag, " explicit default init positive: bool non-default")

    let n: int32 = 1
    assert(n == 1, " explicit default init positive: int non-default")

    let text: str = "x"
    assert(text == "x", " explicit default init positive: str non-default")

    let xs: int32[] = [1, 2]
    assert(xs.len == 2, " explicit default init positive: seq literal len")
    assert(xs[0] == 1, " explicit default init positive: seq literal first")

    let fixed: int32[2] = [3, 4]
    assert(fixed[0] == 3, " explicit default init positive: fixed literal first")
    assert(fixed[1] == 4, " explicit default init positive: fixed literal last")

    let inferredFoo = PositiveFoo()
    assert(inferredFoo.count == 5, " explicit default init positive: inferred object call")
    assert(inferredFoo.tags.len == 0, " explicit default init positive: inferred object seq")

    var explicitOverride: PositiveFoo = PositiveFoo(count: 9, tags: ["real"])
    assert(explicitOverride.count == 9, " explicit default init positive: object constructor override")
    assert(explicitOverride.tags.len == 1, " explicit default init positive: object constructor seq len")
    assert(explicitOverride.tags[0] == "real", " explicit default init positive: object constructor seq item")

    let inferredPair = PositivePair()
    assert(inferredPair.a == 2, " explicit default init positive: inferred tuple call")
    assert(inferredPair.b.len == 0, " explicit default init positive: inferred tuple seq")

    var returned: PositiveFoo = makeFoo()
    assert(returned.count == 5, " explicit default init positive: returned object")
    assert(returned.tags.len == 0, " explicit default init positive: returned object seq")

    echo(" explicit_default_init_positive_smoke ok")
    return 0
