import std/os
import cheng/std/bytes_layout as layout
import cheng/chain/consensus
import cheng/apps/chain_node/chain_node as node
import std/strutils as strutil

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node cell dump probe: mint")
    let transferCidRes = node.ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, " chain_node cell dump probe: transfer")
    var served: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(served, server)
    var replayed: node.ChainNode
    node.ChainNodeZeroInto(replayed, "node-b", served.address)
    for i in 0..<served.events.len:
        var event = served.events[i]
        event.stem = event.ganzhiIndex % 10
        event.branch = event.ganzhiIndex % 12
        event.bodyCid = consensus.ChainEventBodyCid(event)
        let applyRes = node.ChainNodeApplyEvent(replayed, event)
        assert(applyRes.ok, " chain_node cell dump probe: replay apply")
    node.ChainNodeRebuildDerived(replayed)
    let serverCells = node.ChainNodeStateCells(server.index)
    let replayCells = node.ChainNodeStateCells(replayed.index)
    os.WriteLine(os.Get_stderr(), strutil.Join(["server_cell0_content=", layout.FixedBytes32Hex(serverCells[0].contentCid)], ""))
    os.WriteLine(os.Get_stderr(), strutil.Join(["server_cell1_content=", layout.FixedBytes32Hex(serverCells[1].contentCid)], ""))
    os.WriteLine(os.Get_stderr(), strutil.Join(["server_cell0_locality=", layout.FixedBytes32Hex(serverCells[0].localityCid)], ""))
    os.WriteLine(os.Get_stderr(), strutil.Join(["server_cell1_locality=", layout.FixedBytes32Hex(serverCells[1].localityCid)], ""))
    os.WriteLine(os.Get_stderr(), strutil.Join(["replay_cell0_content=", layout.FixedBytes32Hex(replayCells[0].contentCid)], ""))
    os.WriteLine(os.Get_stderr(), strutil.Join(["replay_cell1_content=", layout.FixedBytes32Hex(replayCells[1].contentCid)], ""))
    os.WriteLine(os.Get_stderr(), strutil.Join(["replay_cell0_locality=", layout.FixedBytes32Hex(replayCells[0].localityCid)], ""))
    os.WriteLine(os.Get_stderr(), strutil.Join(["replay_cell1_locality=", layout.FixedBytes32Hex(replayCells[1].localityCid)], ""))
    return 0
