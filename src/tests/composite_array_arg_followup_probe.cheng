import std/os
import std/seqs
import std/strutils as strutil
import cheng/core/tooling/path as chengpath

fn MakeFlag(prefix: str, value: str): str =
    var parts: str[]
    seqs.Add(parts, prefix)
    seqs.Add(parts, value)
    return Fmt(parts)

fn Sink(prefix: str, args: str[], suffix: str): int32 =
    if len(prefix) <= 0 || len(suffix) <= 0:
        return -1
    return args.len

fn main(): int32 =
    let root = os.GetCurrentDir()
    let sinkCount = Sink(root,
                         [
                             "system-link-exec",
                             MakeFlag("--root:", root),
                             MakeFlag("--in:", os.JoinPath(root, "src/tests/str_concat_lowering_fixture.cheng")),
                             "--emit:exe",
                             MakeFlag("--out:", os.JoinPath(root, "artifacts/str_concat_lowering_smoke/str_concat_lowering_probe"))
                         ],
                         root)
    assert(sinkCount == 5, " composite arg: sink count")
    let reportPath = os.JoinPath(root, "artifacts/str_concat_lowering_smoke/str_concat_lowering_probe.compile.report.txt")
    assert(chengpath.PathFileExists(reportPath), " composite arg: report exists")
    let reportText = os.ReadFile(reportPath)
    let reportPrefix = "native_primary_object="
    let reportLines = strutil.Split(reportText, '\n')
    var primaryObjectPath: str
    for i in 0..<reportLines.len:
        let line = strutil.Strip(reportLines[i])
        if strutil.StartsWith(line, reportPrefix):
            primaryObjectPath = chengpath.TextSlice(line, len(reportPrefix), len(line) - len(reportPrefix))
    assert(len(primaryObjectPath) > 0, " composite arg: primary object path")
    echo(" composite_array_arg_followup_probe ok")
    return 0
