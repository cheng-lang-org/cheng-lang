import std/os
import std/result
import cheng/apps/wow_export/build_info as build_info
import cheng/apps/wow_export/local_files as local_files

fn note(text: str) =
    echo(text)
    let _ = os.C_fflush(os.GetStdout())

fn main(): int32 =
    var wanted: int32[]
    add(wanted, 777828)
    add(wanted, 777829)
    add(wanted, 777830)
    add(wanted, 778028)
    add(wanted, 778029)
    add(wanted, 778030)
    add(wanted, 777833)
    add(wanted, 777834)
    add(wanted, 777835)
    add(wanted, 778033)
    add(wanted, 778034)
    add(wanted, 778035)
    note("wow_export_maid_audit before_audit")
    let auditsRes: Result[local_files.LocalFileAudit[]] =
        local_files.ResolveLocalFileAuditsRanged(build_info.DefaultClientPath, wanted)
    assert(IsOk(auditsRes), Error(auditsRes))
    note("wow_export_maid_audit after_audit")
    let audits: local_files.LocalFileAudit[] = Value(auditsRes)
    assert(audits.len == 12, "wow_export_maid_audit count")
    assert(audits[0].fileDataID == 777828, "wow_export_maid_audit fileDataID")
    assert(audits[0].contentKey == "bbc5c3395ce200670226edd91e5ac9d0",
           "wow_export_maid_audit content key")
    assert(audits[0].encodingKey == "17542edda5226efc9789a072864f3641",
           "wow_export_maid_audit encoding key")
    assert(audits[0].entry.archiveIndex == 36, "wow_export_maid_audit archive")
    assert(audits[0].entry.offset == 174124344, "wow_export_maid_audit offset")
    assert(audits[0].entry.size == 17705, "wow_export_maid_audit size")
    assert(audits[11].fileDataID == 778035, "wow_export_maid_audit last fileDataID")
    assert(audits[11].contentKey == "48bd27df1abdf98ffb023be51c2c9b70",
           "wow_export_maid_audit last content key")
    assert(audits[11].encodingKey == "a81afa892f864c07aa76cabe7613fdf5",
           "wow_export_maid_audit last encoding key")
    assert(audits[11].entry.archiveIndex == 105, "wow_export_maid_audit last archive")
    assert(audits[11].entry.offset == 2468235, "wow_export_maid_audit last offset")
    assert(audits[11].entry.size == 886758, "wow_export_maid_audit last size")
    echo("wow_export_maid_audit_smoke ok")
    return 0
