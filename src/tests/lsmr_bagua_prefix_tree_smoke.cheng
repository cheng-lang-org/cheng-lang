import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/chain/lsmr as lsmr
import cheng/chain/binary_types as types

fn main(): int32 =
    let addrGlobalRes = types.LsmrAddressFromDigits([6, 7, 9])
    let addrRegionalRes = types.LsmrAddressFromDigits([6, 7, 4])
    let addrEdgeRes = types.LsmrAddressFromDigits([6, 7, 2])
    assert(IsOk(addrGlobalRes), " lsmr tree: global address")
    assert(IsOk(addrRegionalRes), " lsmr tree: regional address")
    assert(IsOk(addrEdgeRes), " lsmr tree: edge address")

    let globalContentCid = lt.HashInts("cheng.lsmr.tree.content", [1, 11, 111])
    let regionalContentCid = lt.HashInts("cheng.lsmr.tree.content", [2, 22, 222])
    let edgeContentCid = lt.HashInts("cheng.lsmr.tree.content", [3, 33, 333])
    let globalLocalityHash = lt.HashInts("cheng.lsmr.tree.locality", [1, 101])
    let regionalLocalityHash = lt.HashInts("cheng.lsmr.tree.locality", [2, 202])
    let edgeLocalityHash = lt.HashInts("cheng.lsmr.tree.locality", [3, 303])

    var globalCell: lt.StateCell
    lsmr.LsmrStateCellFill(globalCell, 1, Value(addrGlobalRes), 1, globalContentCid, globalLocalityHash)
    var regionalCell: lt.StateCell
    lsmr.LsmrStateCellFill(regionalCell, 2, Value(addrRegionalRes), 2, regionalContentCid, regionalLocalityHash)
    var edgeCell: lt.StateCell
    lsmr.LsmrStateCellFill(edgeCell, 3, Value(addrEdgeRes), 3, edgeContentCid, edgeLocalityHash)
    var cells: lt.StateCell[]
    cells = []
    add(cells, globalCell)
    add(cells, regionalCell)
    add(cells, edgeCell)
    let forest = lsmr.BuildStateLayerForest(cells)
    assert(!layout.fixedBytes32Equal(forest.forestCid, layout.FixedBytes32()), " lsmr tree: forest cid")
    assert(forest.globalTree.entryCount == 1, " lsmr tree: global entry count")
    assert(forest.regionalTree.entryCount == 1, " lsmr tree: regional entry count")
    assert(forest.edgeTree.entryCount == 1, " lsmr tree: edge entry count")

    let regionalSummary = lsmr.StateLayerSummaryFromForest(forest, lt.LayerRegional)
    assert(regionalSummary.entryCount == 1, " lsmr tree: regional summary count")
    assert(regionalSummary.nodeCount >= 1, " lsmr tree: regional summary nodes")

    let rootSummaryRes = lsmr.BaguaRootSummaryFromTree(
        lt.LayerRegional,
        forest.regionalTree,
        regionalCell.baguaId
    )
    assert(IsOk(rootSummaryRes), " lsmr tree: bagua root summary")
    let rootSummary = Value(rootSummaryRes)
    assert(rootSummary.entryDescCount >= 1, " lsmr tree: root descendant count")

    echo(" lsmr_bagua_prefix_tree_smoke ok")
    return 0
