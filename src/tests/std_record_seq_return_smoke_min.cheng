import std/system
import std/seqs

type
    SeqBox =
        items: int32[]

fn makeSeqBox(): SeqBox =
    var items: int32[] = []
    add(items, 7)
    var out: SeqBox
    out.items.len = items.len
    out.items.cap = items.cap
    out.items.buffer = items.buffer
    return out

fn main() =
    let box: SeqBox = makeSeqBox()
    assert(box.items.len == 1, "std/record seq return len")
    assert(box.items[0] == 7, "std/record seq return value")
