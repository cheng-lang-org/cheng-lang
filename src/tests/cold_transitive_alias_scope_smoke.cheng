import cheng/codex/protocol/types
import cheng/rust-csg/core/parity

fn main(): int32 =
    var result: types.CodexExecResult
    result.exitCode = 9
    let status = parity.RustCsgBlocked("cli")
    assert(result.exitCode == 9, "cold transitive alias scope: codex types")
    assert(status.status == "explicitly_blocked", "cold transitive alias scope: rust-csg parity")
    echo("cold_transitive_alias_scope_smoke ok")
    return 0
