import std/system
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/host/host

fn main(): int32 =
    var trustedHost = host.v3Libp2pHostInit("tailnet.policy.trusted")
    var publicHost = host.v3Libp2pHostInit("tailnet.policy.public")
    host.v3Libp2pHostSetTrustedInfra(trustedHost, true)

    let remotePeer = peer_id.v3Libp2pPeerIdFromSeed("tailnet.policy.remote")
    var publicAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillQuic(publicAddr, "198.51.100.10", 4401)
    multiaddr.v3Libp2pMultiaddrSetRoutingMeta(publicAddr,
                                              types.v3Libp2pNetworkDomainPublic,
                                              types.v3Libp2pVisibilityPublic,
                                              100)
    var tailnetAddr: types.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(tailnetAddr, "100.64.0.10", 4402)
    multiaddr.v3Libp2pMultiaddrSetRoutingMeta(tailnetAddr,
                                              types.v3Libp2pNetworkDomainTailnet,
                                              types.v3Libp2pVisibilityTrustedOnly,
                                              900)

    var record: ps.V3Libp2pPeerRecord
    record.peerId = remotePeer
    record.routingRole = overlay.v3OverlayRoleRegionalRouter
    record.connected = false
    record.trustedInfra = true
    ps.v3Libp2pPeerRecordPutEndpoint(record,
                                     publicAddr,
                                     false,
                                     types.v3Libp2pReachabilityDirect,
                                     publicAddr.priority)
    ps.v3Libp2pPeerRecordPutEndpoint(record,
                                     tailnetAddr,
                                     false,
                                     types.v3Libp2pReachabilityDirect,
                                     tailnetAddr.priority)
    ps.v3Libp2pPeerstoreUpsert(trustedHost.peers, record)
    ps.v3Libp2pPeerstoreUpsert(publicHost.peers, record)

    var trustedEndpoint: ps.V3Libp2pPeerEndpoint
    let trustedRes = host.v3Libp2pSelectPeerEndpoint(trustedHost, remotePeer, trustedEndpoint)
    assert(IsOk(trustedRes), "v3 libp2p tailnet policy: trusted select")
    assert(trustedEndpoint.addr.networkDomain == types.v3Libp2pNetworkDomainTailnet,
        "v3 libp2p tailnet policy: trusted chooses tailnet")
    assert(trustedEndpoint.addr.transport == types.v3Libp2pTransportTcp,
        "v3 libp2p tailnet policy: trusted keeps tailnet over public quic")

    var publicEndpoint: ps.V3Libp2pPeerEndpoint
    let publicRes = host.v3Libp2pSelectPeerEndpoint(publicHost, remotePeer, publicEndpoint)
    assert(IsOk(publicRes), "v3 libp2p tailnet policy: public select")
    assert(publicEndpoint.addr.networkDomain == types.v3Libp2pNetworkDomainPublic,
        "v3 libp2p tailnet policy: public chooses public")
    assert(publicEndpoint.addr.transport == types.v3Libp2pTransportQuic,
        "v3 libp2p tailnet policy: public keeps public quic")

    echo("v3 libp2p_tailnet_policy_smoke ok")
    return 0
