import std/system
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/host/host

fn main(): int32 =
    var trustedHost = host.Libp2pHostInit("tailnet.policy.trusted")
    var publicHost = host.Libp2pHostInit("tailnet.policy.public")
    host.Libp2pHostSetTrustedInfra(trustedHost, true)

    let remotePeer = peer_id.Libp2pPeerIdFromSeed("tailnet.policy.remote")
    var publicAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(publicAddr, "198.51.100.10", 4401)
    multiaddr.Libp2pMultiaddrSetRoutingMeta(publicAddr,
                                              types.Libp2pNetworkDomainPublic,
                                              types.Libp2pVisibilityPublic,
                                              100)
    var tailnetAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(tailnetAddr, "100.64.0.10", 4402)
    multiaddr.Libp2pMultiaddrSetRoutingMeta(tailnetAddr,
                                              types.Libp2pNetworkDomainTailnet,
                                              types.Libp2pVisibilityTrustedOnly,
                                              900)

    var record: ps.Libp2pPeerRecord
    record.peerId = remotePeer
    record.routingRole = overlay.OverlayRoleRegionalRouter
    record.connected = false
    record.trustedInfra = true
    ps.Libp2pPeerRecordPutEndpoint(record,
                                     publicAddr,
                                     false,
                                     types.Libp2pReachabilityDirect,
                                     publicAddr.priority)
    ps.Libp2pPeerRecordPutEndpoint(record,
                                     tailnetAddr,
                                     false,
                                     types.Libp2pReachabilityDirect,
                                     tailnetAddr.priority)
    ps.Libp2pPeerstoreUpsert(trustedHost.peers, record)
    ps.Libp2pPeerstoreUpsert(publicHost.peers, record)

    var trustedEndpoint: ps.Libp2pPeerEndpoint
    let trustedRes = host.Libp2pSelectPeerEndpoint(trustedHost, remotePeer, trustedEndpoint)
    assert(IsOk(trustedRes), " libp2p tailnet policy: trusted select")
    assert(trustedEndpoint.addr.networkDomain == types.Libp2pNetworkDomainTailnet,
        " libp2p tailnet policy: trusted chooses tailnet")
    assert(trustedEndpoint.addr.transport == types.Libp2pTransportTcp,
        " libp2p tailnet policy: trusted keeps tailnet over public quic")

    var publicEndpoint: ps.Libp2pPeerEndpoint
    let publicRes = host.Libp2pSelectPeerEndpoint(publicHost, remotePeer, publicEndpoint)
    assert(IsOk(publicRes), " libp2p tailnet policy: public select")
    assert(publicEndpoint.addr.networkDomain == types.Libp2pNetworkDomainPublic,
        " libp2p tailnet policy: public chooses public")
    assert(publicEndpoint.addr.transport == types.Libp2pTransportQuic,
        " libp2p tailnet policy: public keeps public quic")

    echo(" libp2p_tailnet_policy_smoke ok")
    return 0
