import std/system
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/transports/tailnet_transport as tsnet

fn main(): int32 =
    var cfg: tsnet.Libp2pTailnetTransportConfig
    cfg.controlEndpoint = "https://control.example"
    cfg.relayEndpoint = "https://derp.default.example:443"
    cfg.syntheticIPv4 = "100.64.7.11"
    cfg.syntheticIPv6 = "fd7a:115c:a1e0::711"
    cfg.localPeerId = "tailnet-relay-override"
    cfg.exactRouting = true

    var transport = tsnet.Libp2pTailnetTransportInit(cfg)
    tsnet.Libp2pTailnetProviderStart(transport)
    tsnet.Libp2pTailnetProviderMarkProxyReady(transport)
    tsnet.Libp2pTailnetProviderDerpReady(transport)

    var rawTcp: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(rawTcp, "127.0.0.1", 7401)
    let listenRes = tsnet.Libp2pTailnetListen(transport, rawTcp)
    assert(IsOk(listenRes), " tailnet relay override: listen")
    let published = tsnet.Libp2pTailnetPublishedAddrs(transport)

    var relayOnlyPeer: tsnet.Libp2pTailnetPeerSession
    relayOnlyPeer.peerId = "peer-relay-only"
    relayOnlyPeer.remoteTailnetIp = "100.64.7.88"
    relayOnlyPeer.relayAllowed = true
    relayOnlyPeer.relayOnly = true
    relayOnlyPeer.derpRegionCode = "sfo"
    tsnet.Libp2pTailnetUpsertPeerSession(transport, relayOnlyPeer)

    let relayPlanBuild = tsnet.Libp2pTailnetDialPlanBuildWithRelay(transport,
                                                                     "peer-relay-only",
                                                                     published[0],
                                                                     true,
                                                                     false,
                                                                     "relay-peer-01",
                                                                     "https://derp.alt.example:443",
                                                                     "lax")
    assert(relayPlanBuild.ok, " tailnet relay override: relay plan")
    let relayPlan = relayPlanBuild.plan
    assert(relayPlan.pathKind == tsnet.Libp2pTailnetPathDerp,
        " tailnet relay override: derp path")
    assert(relayPlan.routeText == "https://derp.alt.example:443",
        " tailnet relay override: override route")
    assert(relayPlan.selectedRelayPeerId == "relay-peer-01",
        " tailnet relay override: selected relay peer")
    assert(relayPlan.selectedRelayRegion == "lax",
        " tailnet relay override: selected relay region")

    var directPeer: tsnet.Libp2pTailnetPeerSession
    directPeer.peerId = "peer-direct"
    directPeer.remoteTailnetIp = "100.64.7.89"
    directPeer.directReachable = true
    directPeer.relayAllowed = true
    directPeer.boundAddrText = tsnet.Libp2pTailnetAddrText(rawTcp)
    tsnet.Libp2pTailnetUpsertPeerSession(transport, directPeer)

    let directPlanBuild = tsnet.Libp2pTailnetDialPlanBuildWithRelay(transport,
                                                                      "peer-direct",
                                                                      published[0],
                                                                      false,
                                                                      false,
                                                                      "relay-peer-01",
                                                                      "https://derp.alt.example:443",
                                                                      "lax")
    assert(directPlanBuild.ok, " tailnet relay override: direct plan")
    let directPlan = directPlanBuild.plan
    assert(directPlan.pathKind == tsnet.Libp2pTailnetPathDirect,
        " tailnet relay override: direct path wins")
    assert(directPlan.routeText == tsnet.Libp2pTailnetAddrText(rawTcp),
        " tailnet relay override: direct route text")
    assert(directPlan.selectedRelayEndpoint == "",
        " tailnet relay override: direct clears relay override")

    echo(" libp2p_tailnet_relay_override_smoke ok")
    return 0
