import cheng/quic/congestion/loss_detection_model as lossdet

fn quicFeatureBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn quicFeatureAddress(): binary.LsmrAddress =
    var out: binary.LsmrAddress
    out.depth = 2
    out.digits[0] = 7
    out.digits[1] = 3
    return out

fn quicFeatureBytes(text: str): Bytes =
    return bytesFromString(text)

fn quicFeatureVerifyAckTracker() =
    var tracker = acktrack.ackTrackerInit()
    assert(!acktrack.ackTrackerTrackIncomingPacket(tracker, 10),
        " quic feature matrix: recv 10 first")
    assert(!acktrack.ackTrackerTrackIncomingPacket(tracker, 12),
        " quic feature matrix: recv 12 first")
    assert(!acktrack.ackTrackerTrackIncomingPacket(tracker, 11),
        " quic feature matrix: recv 11 merge")
    assert(acktrack.ackTrackerTrackIncomingPacket(tracker, 11),
        " quic feature matrix: recv 11 duplicate")
    assert(tracker.recvCount == 1, " quic feature matrix: recv range merged")
    assert(tracker.packetNumbersReceivedFirst[0] == 10,
        " quic feature matrix: recv range first")
    assert(tracker.packetNumbersReceivedLast[0] == 12,
        " quic feature matrix: recv range last")

    acktrack.ackTrackerMarkForAck(tracker, 10, 1000, common.ackTypeAckEliciting, 25)
    acktrack.ackTrackerMarkForAck(tracker, 12, 1200, common.ackTypeAckEliciting, 25)
    acktrack.ackTrackerMarkForAck(tracker, 11, 1400, common.ackTypeAckImmediate, 0)
    assert(tracker.ackCount == 1, " quic feature matrix: ack range merged")
    assert(tracker.packetNumbersToAckFirst[0] == 10,
        " quic feature matrix: ack range first")
    assert(tracker.packetNumbersToAckLast[0] == 12,
        " quic feature matrix: ack range last")
    assert(tracker.largestPacketNumberAcked == 12,
        " quic feature matrix: largest ack")
    assert(acktrack.ackTrackerShouldSendAck(tracker, 2, common.ackTypeAckEliciting, false),
        " quic feature matrix: send ack")
    acktrack.ackTrackerClearToAck(tracker)
    assert(tracker.ackCount == 0, " quic feature matrix: clear ack count")
    assert(tracker.counters.alreadyWrittenAckFrame,
        " quic feature matrix: clear ack flag")

fn quicFeatureVerifyLossDetection() =
    var model = lossdet.lossDetectionInit()
    lossdet.lossDetectionOnPacketSent(model,
                                      lossdet.PacketRecord(packetNumber: 1,
                                                           encryptEpoch: common.ceOneRtt,
                                                           sentTimeUs: 1000,
                                                           ackEliciting: true,
                                                           packetLength: 1200))
    lossdet.lossDetectionOnPacketSent(model,
                                      lossdet.PacketRecord(packetNumber: 2,
                                                           encryptEpoch: common.ceOneRtt,
                                                           sentTimeUs: 2000,
                                                           ackEliciting: true,
                                                           packetLength: 1200))
    lossdet.lossDetectionOnPacketSent(model,
                                      lossdet.PacketRecord(packetNumber: 3,
                                                           encryptEpoch: common.ceOneRtt,
                                                           sentTimeUs: 3000,
                                                           ackEliciting: true,
                                                           packetLength: 1200))
    assert(model.packetsInFlight == 3, " quic feature matrix: inflight sent")
    assert(model.sentCount == 3, " quic feature matrix: sent count")
    lossdet.lossDetectionMarkPacketLost(model, 2)
    assert(model.sentCount == 2, " quic feature matrix: sent remove lost")
    assert(model.lostCount == 1, " quic feature matrix: lost count")
    assert(model.packetsInFlight == 2, " quic feature matrix: inflight lost")
    assert(lossdet.lossDetectionRemoveLostPacket(model, 2),
        " quic feature matrix: lost remove")
    let basePto = lossdet.lossDetectionComputeProbeTimeout(model, 1000, 100)
    assert(basePto == 1400, " quic feature matrix: pto base")
    lossdet.lossDetectionOnProbeTimeoutFired(model)
    let doubledPto = lossdet.lossDetectionComputeProbeTimeout(model, 1000, 100)
    assert(doubledPto == 2800, " quic feature matrix: pto doubled")
    lossdet.lossDetectionOnAckReceived(model,
                                       common.AckEventSnapshot(timeNow: 5000,
                                                               largestAck: 3,
                                                               largestSentPacketNumber: 3,
                                                               totalAckedRetransmittableBytes: 2400,
                                                               ackedRetransmittableBytes: 1200,
                                                               smoothedRtt: 1000,
                                                               minRtt: 800,
                                                               oneWayDelay: 200,
                                                               adjustedAckTime: 4700,
                                                               implicitAck: false,
                                                               hasLoss: false,
                                                               largestAckAppLimited: false,
                                                               minRttValid: true))
    assert(model.probeCount == 0, " quic feature matrix: pto reset")
    assert(model.largestAck == 3, " quic feature matrix: largest ack tracked")

fn quicFeatureSettings(): qruntime.MsQuicSettings =
    var settings = qruntime.initMsQuicSettings()
    settings.migrationEnabled = true
    settings.allowDatagram = true
    settings.allow0Rtt = true
    settings.ecnEnabled = true
    settings.useBbr = true
    settings.maxDatagram = 2048
    return settings

fn quicFeatureVerifySettingsAndStream() =
    let settings = quicFeatureSettings()
    let settingsRes = qruntime.validateMsQuicSettings(settings)
    assert(IsOk(settingsRes), " quic feature matrix: validate settings")
    assert(settings.allow0Rtt, " quic feature matrix: allow 0rtt")
    assert(settings.allowDatagram, " quic feature matrix: allow datagram")
    assert(settings.migrationEnabled, " quic feature matrix: migration enabled")
    assert(settings.ecnEnabled, " quic feature matrix: ecn enabled")
    assert(settings.useBbr, " quic feature matrix: use bbr")

    var stream: qstream.MsQuicStream
    assert(IsOk(qstream.msquicStreamSetZeroRttLength(stream, 321)),
        " quic feature matrix: set 0rtt length")
    assert(IsOk(qstream.msquicStreamSetReliableOffset(stream, 123)),
        " quic feature matrix: set reliable offset")
    assert(qstream.msquicStreamZeroRttLength(stream) == 321,
        " quic feature matrix: read 0rtt length")
    assert(qstream.msquicStreamReliableOffset(stream) == 123,
        " quic feature matrix: read reliable offset")

fn quicFeatureVerifyDatagramTransport() =
    let settings = quicFeatureSettings()
    var listener = qtransport.InitMsQuicTransport()
    assert(IsOk(qtransport.setMsQuicTransportSettings(listener, settings)),
        " quic feature matrix: listener settings")
    assert(IsOk(quic_transport.Libp2pQuicConfigureTls(listener)),
        " quic feature matrix: listener tls")
    let listenAddrRes = quic_transport.Libp2pQuicAddrFromHostPort("127.0.0.1", 0)
    assert(IsOk(listenAddrRes), " quic feature matrix: listener addr")
    qtransport.start(listener, Value(listenAddrRes))
    assert(listener.running, " quic feature matrix: listener start")
    assert(quic_transport.Libp2pQuicBoundPort(listener.listenAddr) > 0,
        " quic feature matrix: listener port")

    var client = qtransport.InitMsQuicTransport()
    assert(IsOk(qtransport.setMsQuicTransportSettings(client, settings)),
        " quic feature matrix: client settings")
    assert(IsOk(quic_transport.Libp2pQuicConfigureTls(client)),
        " quic feature matrix: client tls")
    let dialRes = qtransport.dial(client, listener.listenAddr)
    assert(IsOk(dialRes), " quic feature matrix: dial")
    var clientConn = Value(dialRes)
    let acceptRes = qtransport.accept(listener)
    assert(IsOk(acceptRes), " quic feature matrix: accept")
    var serverConn = Value(acceptRes)

    let clientPayload = quicFeatureBytes("quic-feature-client-dgram")
    let clientWriteRes = qtransport.msquicTransportDatagramWrite(client, clientConn, clientPayload)
    assert(IsOk(clientWriteRes), " quic feature matrix: datagram write client")
    assert(Value(clientWriteRes) == bytesLen(clientPayload),
        " quic feature matrix: datagram write client len")
    let serverReadRes = qtransport.msquicTransportDatagramRead(listener, serverConn)
    assert(IsOk(serverReadRes), " quic feature matrix: datagram read server")
    assert(quicFeatureBytesEqual(Value(serverReadRes), clientPayload),
        " quic feature matrix: datagram payload server")

    let serverPayload = quicFeatureBytes("quic-feature-server-dgram")
    let serverWriteRes = qtransport.msquicTransportDatagramWrite(listener, serverConn, serverPayload)
    assert(IsOk(serverWriteRes), " quic feature matrix: datagram write server")
    let clientReadRes = qtransport.msquicTransportDatagramRead(client, clientConn)
    assert(IsOk(clientReadRes), " quic feature matrix: datagram read client")
    assert(quicFeatureBytesEqual(Value(clientReadRes), serverPayload),
        " quic feature matrix: datagram payload client")

    qconn.ConnClose(serverConn)
    qconn.ConnClose(clientConn)
    qtransport.Stop(listener)

fn quicFeatureVerifySessionTicket() =
    var state: tls13hs.MsQuicTls13HandshakeState
    tls13hs.initMsQuicTls13HandshakeStateInto(state, tls13hs.TlsRoleClient)
    state.handshakeSecrets.resumptionMasterSecret = quicFeatureBytes("0123456789abcdef0123456789abcdef")
    let ticketWireRes = tls13hs.msquicTls13BuildNewSessionTicket(60,
                                                                 77,
                                                                 quicFeatureBytes("nonce"),
                                                                 quicFeatureBytes("ticket-payload"))
    assert(IsOk(ticketWireRes), " quic feature matrix: build ticket")
    let ticketWire = Value(ticketWireRes)
    let ticketBody = bytesSlice(ticketWire, 4, bytesLen(ticketWire) - 4)
    let parseRes = tls13hs.msquicTls13ParseNewSessionTicket(state, ticketBody)
    assert(IsOk(parseRes), " quic feature matrix: parse ticket")
    assert(state.newSessionTicketReceived, " quic feature matrix: ticket received")
    assert(state.resumptionPskReady, " quic feature matrix: psk ready")
    assert(bytesLen(state.resumptionPsk) > 0, " quic feature matrix: psk bytes")

fn quicFeatureVerifyLibp2pSync() =
    var server = host.Libp2pHostInit("quic.feature.server")
    var client = host.Libp2pHostInit("quic.feature.client")
    let address = quicFeatureAddress()
    let payload = quicFeatureBytes("cheng.libp2p.quic.feature.payload")
    let payloadCid = hash256.sha256Fixed(layout.byteSpanFromBytes(payload))
    let sourcePeer = peer_id.Libp2pPeerIdFromSeed("quic.feature.source")

    var ingress: overlay.IngressEnvelope
    ingress.sourcePeerId = sourcePeer.value
    ingress.topicScope = overlay.OverlayScopeRegion
    ingress.address = address
    ingress.payload = payload
    ingress.payloadCid = payloadCid
    ingress.payloadLen = bytesLen(payload)
    ingress.stampEpoch = 19
    ingress.stampGanzhi = 23
    bridge.Libp2pRelayPublish(server, ingress)

    var listenAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(listenAddr, "127.0.0.1", 0)
    let listenRes = host.Libp2pListen(server, listenAddr)
    assert(IsOk(listenRes), " quic feature matrix: host listen")
    host.Libp2pRegisterHandler(server, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolSync)
    let dialRes = host.Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(IsOk(dialRes), " quic feature matrix: host dial")

    var query = overlay.StoreQuery()
    query.topicScope = overlay.OverlayScopeRegion
    query.address = address
    query.rangeLimit = 4
    var syncEntries: overlay.IngressEnvelope[]
    let syncRes = host_quic.Libp2pQuicSyncRequest(client, server, server.selfPeerId, query, syncEntries)
    if IsErr(syncRes):
        panic(ErrorText(syncRes))
    assert(syncRes.ok, " quic feature matrix: sync request")
    assert(syncEntries.len == 1, " quic feature matrix: sync count")
    let synced = syncEntries[0]
    assert(layout.fixedBytes32Equal(synced.payloadCid, payloadCid),
        " quic feature matrix: sync payload cid")
    assert(synced.payloadLen == bytesLen(payload),
        " quic feature matrix: sync payload len")
    assert(quicFeatureBytesEqual(synced.payload, payload),
        " quic feature matrix: sync payload bytes")

fn main(): int32 =
    quicFeatureVerifyAckTracker()
    quicFeatureVerifyLossDetection()
    quicFeatureVerifySettingsAndStream()
    quicFeatureVerifyDatagramTransport()
    quicFeatureVerifySessionTicket()
    quicFeatureVerifyLibp2pSync()
    echo(" quic_feature_matrix_smoke ok")
    return 0
