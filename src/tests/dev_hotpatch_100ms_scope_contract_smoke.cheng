import std/os
import cheng/core/tooling/path as chengpath
import std/strutils as strutil

fn devHotpatchScopeRequire(text: str,
                           expected: str,
                           label: str) =
    assert(chengpath.TextContains(text, expected), strutil.Join([" dev hotpatch 100ms scope: ", label], ""))

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let specPath = chengpath.PathJoin(workspaceRoot, "docs/cheng-formal-spec.md")
    let repoSkillPath = chengpath.PathJoin(workspaceRoot, "docs/cheng-skill/SKILL.md")
    let readmePath = chengpath.PathJoin(workspaceRoot, "README.md")
    let toolingReadmePath = chengpath.PathJoin(workspaceRoot, "src/core/tooling/README.md")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, specPath), " dev hotpatch 100ms scope: spec exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, repoSkillPath), " dev hotpatch 100ms scope: skill exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, readmePath), " dev hotpatch 100ms scope: readme exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, toolingReadmePath), " dev hotpatch 100ms scope: tooling readme exists")

    let scopeLine = "`100ms` 编译与二进制原地更新都只属于 dev host-only `self-link + direct-exe + host runner hotpatch` 的 dedicated witness 口径；release 主线仍然是 `system-link`。"
    let noLiveCommandLine = "当前 live 子命令面不再暴露 `backend_prod_closure`、`backend-prod-publish`、`verify_backend_abi_v2_noptr`、`verify_backend_selfhost_100ms_host`"
    let notReleaseLine = "release 主线仍然是 `system-link`"

    let specText = chengpath.ReadTextFile("", specPath)
    let repoSkillText = chengpath.ReadTextFile("", repoSkillPath)
    let readmeText = chengpath.ReadTextFile("", readmePath)
    let toolingReadmeText = chengpath.ReadTextFile("", toolingReadmePath)
    devHotpatchScopeRequire(specText, scopeLine, "formal spec scope line")
    devHotpatchScopeRequire(repoSkillText, scopeLine, "repo skill scope line")
    devHotpatchScopeRequire(readmeText, scopeLine, "readme scope line")
    devHotpatchScopeRequire(toolingReadmeText, scopeLine, "tooling readme scope line")
    devHotpatchScopeRequire(specText, noLiveCommandLine, "formal spec no legacy 100ms command")
    devHotpatchScopeRequire(repoSkillText, noLiveCommandLine, "repo skill no legacy 100ms command")
    devHotpatchScopeRequire(readmeText, notReleaseLine, "readme release boundary")
    devHotpatchScopeRequire(toolingReadmeText, notReleaseLine, "tooling release boundary")

    let homeDir = os.GetEnvDefault("HOME", "")
    if len(homeDir) > 0:
        let homeSkillPath = os.JoinPath(homeDir, ".codex/skills/cheng语言/SKILL.md")
        if chengpath.FileExistsNonEmpty(workspaceRoot, homeSkillPath):
            let homeSkillText = chengpath.ReadTextFile("", homeSkillPath)
            devHotpatchScopeRequire(homeSkillText, scopeLine, "home skill scope line")
            devHotpatchScopeRequire(homeSkillText, noLiveCommandLine, "home skill no legacy 100ms command")

    echo(" dev_hotpatch_100ms_scope_contract_smoke ok")
    return 0
