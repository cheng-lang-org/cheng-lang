import std/strutils as strutil
import std/os_host_process as hostos

fn main(): int32 =
    var output: str
    var exitCode: int32 = -99
    hostos.OsHostProcessExecFileCaptureFill("/bin/echo",
                                            ["fill-ok"],
                                            [],
                                            "",
                                            true,
                                            5,
                                            output,
                                            exitCode)
    assert(exitCode == 0, "v3 hostos execFileCaptureFill rc")
    assert(strutil.Strip(output) == "fill-ok", "v3 hostos execFileCaptureFill output")
    echo("v3 host_process_exec_file_capture_fill_smoke ok")
    return 0
