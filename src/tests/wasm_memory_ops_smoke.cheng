# WASM memory operations test (runtime bridge-free)
# Tests bitwise memory-like operations using int32 arrays and pointer arithmetic

fn test_memory_copy(dst: var int32[], src: int32[], count: int32): int32 =
    var i: int32
    while i < count:
        dst[i] = src[i]
        i = i + 1
    return 0

fn test_memory_fill(buf: var int32[], value: int32, count: int32): int32 =
    var i: int32
    while i < count:
        buf[i] = value
        i = i + 1
    return 0

fn test_seq_alloc_and_write(): int32 =
    var buf: int32[4]
    buf[0] = 10
    buf[1] = 20
    buf[2] = 30
    buf[3] = 40
    if buf[0] != 10: return 1
    if buf[1] != 20: return 2
    if buf[2] != 30: return 3
    if buf[3] != 40: return 4
    return 0

fn test_seq_copy_sequential(): int32 =
    var src: int32[4]
    src[0] = 100
    src[1] = 200
    src[2] = 300
    src[3] = 400
    var dst: int32[4]
    if test_memory_copy(dst, src, 4) != 0: return 1
    if dst[0] != 100: return 2
    if dst[1] != 200: return 3
    if dst[2] != 300: return 4
    if dst[3] != 400: return 5
    return 0

fn test_seq_partial_copy(): int32 =
    var src: int32[6]
    src[0] = 1
    src[1] = 2
    src[2] = 3
    src[3] = 4
    src[4] = 5
    src[5] = 6
    var dst: int32[3]
    # Copy middle elements
    dst[0] = src[1]
    dst[1] = src[2]
    dst[2] = src[3]
    if dst[0] != 2: return 1
    if dst[1] != 3: return 2
    if dst[2] != 4: return 3
    return 0

fn test_seq_fill_and_verify(): int32 =
    var buf: int32[5]
    if test_memory_fill(buf, 42, 5) != 0: return 1
    var i: int32
    while i < 5:
        if buf[i] != 42: return 2
        i = i + 1
    return 0

fn test_seq_reverse_in_place(): int32 =
    var arr: int32[4]
    arr[0] = 1
    arr[1] = 2
    arr[2] = 3
    arr[3] = 4
    # Swap arr[0] with arr[3]
    let tmp0 = arr[0]
    arr[0] = arr[3]
    arr[3] = tmp0
    # Swap arr[1] with arr[2]
    let tmp1 = arr[1]
    arr[1] = arr[2]
    arr[2] = tmp1
    if arr[0] != 4: return 1
    if arr[1] != 3: return 2
    if arr[2] != 2: return 3
    if arr[3] != 1: return 4
    return 0

fn test_seq_bounds_check(): int32 =
    var arr: int32[3]
    arr[0] = 7
    arr[1] = 8
    arr[2] = 9
    # Access via function to simulate indexed access
    var total: int32
    total = arr[0] + arr[1] + arr[2]
    if total != 24: return 1
    return 0

fn test_byte_buffer_ops(): int32 =
    # Simulate byte-level operations using int32 array
    var buf: int32[8]
    buf[0] = 0x12
    buf[1] = 0x34
    buf[2] = 0xAB
    buf[3] = 0xCD
    # Read back
    if buf[0] != 0x12: return 1
    if buf[1] != 0x34: return 2
    if buf[2] != 0xAB: return 3
    if buf[3] != 0xCD: return 4
    # Bit manipulation
    let lowNibble = buf[2] & 0x0F
    if lowNibble != 0x0B: return 5
    let highNibble = (buf[2] >> 4) & 0x0F
    if highNibble != 0x0A: return 6
    return 0

fn test_memory_shift_ops(): int32 =
    var buf: int32[3]
    buf[0] = 1
    buf[1] = 2
    buf[2] = 3
    # Shift elements: [2,3,0]
    buf[0] = buf[1]
    buf[1] = buf[2]
    buf[2] = 0
    if buf[0] != 2: return 1
    if buf[1] != 3: return 2
    if buf[2] != 0: return 3
    return 0

fn test_clear_memory(): int32 =
    var buf: int32[4]
    buf[0] = 99
    buf[1] = 88
    buf[2] = 77
    buf[3] = 66
    # Clear all
    buf[0] = 0
    buf[1] = 0
    buf[2] = 0
    buf[3] = 0
    if buf[0] != 0: return 1
    if buf[1] != 0: return 2
    if buf[2] != 0: return 3
    if buf[3] != 0: return 4
    return 0

fn main(): int32 =
    if test_seq_alloc_and_write() != 0: return 1
    if test_seq_copy_sequential() != 0: return 2
    if test_seq_partial_copy() != 0: return 3
    if test_seq_fill_and_verify() != 0: return 4
    if test_seq_reverse_in_place() != 0: return 5
    if test_seq_bounds_check() != 0: return 6
    if test_byte_buffer_ops() != 0: return 7
    if test_memory_shift_ops() != 0: return 8
    if test_clear_memory() != 0: return 9
    return 0
