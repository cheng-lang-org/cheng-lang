import std/os
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/host_ops as hostops

fn StrConcatLoweringFlag(prefix: str, value: str): str =
    var parts: str[]
    add(parts, prefix)
    add(parts, value)
    return Fmt(parts)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let driver = os.JoinPath(root, "artifacts/bootstrap/cheng.stage3")
    let target = os.GetEnvDefault("CHENG_RUNTIME_LINK_TARGET", "arm64-apple-darwin")
    let outDir = chengpath.PathAbsolute(root, "artifacts/str_concat_precompute_probe")
    let sourcePath = os.JoinPath(root, "src/tests/str_concat_lowering_fixture.cheng")
    let outBin = os.JoinPath(outDir, "str_concat_precompute_fixture")
    let reportPath = os.JoinPath(outDir, "str_concat_precompute_fixture.compile.report.txt")
    let compileLog = os.JoinPath(outDir, "str_concat_precompute_fixture.compile.log")
    assert(chengpath.MkdirP(root, outDir), " precompute probe: mkdir")
    let argRoot = StrConcatLoweringFlag("--root:", root)
    let argIn = StrConcatLoweringFlag("--in:", sourcePath)
    let argTarget = StrConcatLoweringFlag("--target:", target)
    let argOut = StrConcatLoweringFlag("--out:", outBin)
    let argReport = StrConcatLoweringFlag("--report-out:", reportPath)
    let run = hostops.RunFileLogged(root,
                                    "str_concat_precompute_probe",
                                    driver,
                                    [
                                        "system-link-exec",
                                        argRoot,
                                        argIn,
                                        "--emit:exe",
                                        argTarget,
                                        argOut,
                                        argReport
                                    ],
                                    [],
                                    root,
                                    0,
                                    compileLog)
    assert(run.exitCode == 0, " precompute probe: compile rc")
    echo(" str_concat_precompute_probe ok")
    return 0
