# std file/process IO compile smoke: write/read helpers and streams surface

import std/system
import std/os as os
import std/streams as streams

fn main(): int32 =
    let tmpPath: str = "artifacts/std_file_io_compile_smoke.tmp"
    var outText: str = ""
    let _ = os.readFileInto(tmpPath, outText)
    os.writeFile(tmpPath, "cheng-file")
    let payload: uint8[] = [uint8(97), uint8(98), uint8(99)]
    os.writeFileBytes(tmpPath, payload)
    let stream: streams.Stream = streams.newFileStream(tmpPath, fmWrite)
    if ! streams.isNil(stream):
        streams.close(stream)
    return 0
