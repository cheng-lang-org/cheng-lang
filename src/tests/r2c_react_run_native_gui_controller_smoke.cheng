    add(controllerArgs, "--auto-close-ms")
    add(controllerArgs, "600")
    var controllerRunEnv: str[]
    add(controllerRunEnv, "CHENG_PROGRESS=1")
    add(controllerRunEnv, "CHENG_PROCESS_MAX_RSS_BYTES=34359738368")
    let controllerRun = hostops.RunFileLogged(root,
