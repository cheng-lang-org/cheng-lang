    add(nativeEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    add(nativeEnv, "CHENG_PROGRESS=1")
    add(nativeEnv, "CHENG_PROCESS_MAX_RSS_BYTES=34359738368")

    let controllerExe = os.JoinPath(outDir, "r2c_react_controller_smoke")
