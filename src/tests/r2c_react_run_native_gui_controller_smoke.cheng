        assert(false,
               " r2c run-native-gui controller smoke: set R2C_REACT_CONTROLLER_EXE or R2C_REACT_ALLOW_CONTROLLER_COMPILE=1")
    var nativeEnv: str[]
    add(nativeEnv, "R2C_REACT_TOOLING_BIN=" + stage3)
    add(nativeEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    add(nativeEnv, "CHENG_PROGRESS=1")
    add(nativeEnv, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592")

    if allowControllerCompile && len(controllerEnv) <= 0:
        let controllerCompileReport = controllerExe + ".report.txt"
        let controllerCompileLog = controllerExe + ".compile.log"
        if chengpath.PathFileExists(controllerExe):
            os.RemoveFile(controllerExe)
        if chengpath.PathFileExists(controllerExe + ".map"):
            os.RemoveFile(controllerExe + ".map")
        if chengpath.PathFileExists(controllerCompileReport):
            os.RemoveFile(controllerCompileReport)
        if chengpath.PathFileExists(controllerCompileLog):
            os.RemoveFile(controllerCompileLog)
        var controllerCompileArgs: str[]
        add(controllerCompileArgs, "system-link-exec")
        add(controllerCompileArgs, "--root:" + packageRoot)
        add(controllerCompileArgs, "--in:" + controllerSource)
        add(controllerCompileArgs, "--emit:exe")
        add(controllerCompileArgs, "--target:arm64-apple-darwin")
        add(controllerCompileArgs, "--out:" + controllerExe)
        add(controllerCompileArgs, "--report-out:" + controllerCompileReport)
        let controllerCompileRun = hostops.RunFileLogged(root,
                                                           "r2c_run_native_gui_controller_compile",
                                                           driver,
                                                           controllerCompileArgs,
                                                           r2csmoke.R2cReactSmokeControllerCompileEnv(),
                                                           root,
                                                           420,
                                                           controllerCompileLog)
        assert(hostops.LoggedRunOk(controllerCompileRun), " r2c run-native-gui controller smoke: controller compile rc")
        assert(chengpath.FileExistsNonEmpty(root, controllerExe), " r2c run-native-gui controller smoke: controller compiled exe")
        assert(chengpath.FileExistsNonEmpty(root, controllerCompileReport), " r2c run-native-gui controller smoke: controller compile report")
        let controllerCompileReportText = chengpath.ReadTextFile("", controllerCompileReport)
        assert(containsText(controllerCompileReportText, "source_closure_paths=" + controllerSource),
               " r2c run-native-gui controller smoke: controller compile source closure")
        assert(containsText(controllerCompileReportText, "/Users/lbcheng/cheng-lang/src/r2c/r2c_react_controller_main.cheng"),
               " r2c run-native-gui controller smoke: controller compile controller main closure")
        assert(containsText(controllerCompileReportText, "primary_object_cache_hit_count=0"),
