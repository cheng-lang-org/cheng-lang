import std/os
import std/strutils as strutil
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_smoke_support as r2csmoke
import cheng/r2c/r2c_react_surface_main as r2csurface

fn containsText(text: str, needle: str): bool =
    return strutil.Contains(text, needle)

fn containsJsonStringField(text: str, key: str, value: str): bool =
    let pretty = "\"" + key + "\": \"" + value + "\""
    let compact = "\"" + key + "\":\"" + value + "\""
    return containsText(text, pretty) || containsText(text, compact)

fn summaryValue(text: str, key: str): str =
    let prefix = key + "="
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let line = lines[i]
        if strutil.StartsWith(line, prefix):
            return chengpath.TextSlice(line, len(prefix), len(line) - len(prefix))
    return ""

fn assertPositiveSummaryValue(summaryText: str, key: str, label: str): str =
    let value = summaryValue(summaryText, key)
    assert(len(value) > 0, label + " summary value")
    assert(strutil.ParseInt(value) > 0, label + " positive summary value")
    return value

fn assertCatalogCountMatchesSummary(catalogText: str,
                                    fieldName: str,
                                    summaryText: str,
                                    summaryKey: str,
                                    label: str) =
    let value = assertPositiveSummaryValue(summaryText, summaryKey, label)
    assert(containsText(catalogText, "\"" + fieldName + "\": " + value),
           label)

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = chengpath.PathAbsolute(root, "artifacts/r2c_run_native_gui_controller_smoke")
    assert(chengpath.MkdirP(root, outDir), " r2c run-native-gui controller smoke: mkdir")
    let driver = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    let stage3 = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3")
    assert(chengpath.FileExistsNonEmpty(root, driver), " r2c run-native-gui controller smoke: backend_driver exists")
    assert(chengpath.FileExistsNonEmpty(root, stage3), " r2c run-native-gui controller smoke: stage3 exists")
    let packageRoot = root
    let controllerSource = chengpath.PathAbsolute(root, "src/r2c/r2c_react.cheng")
    let repoEnv = os.GetEnv("R2C_REACT_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.DirExists(repo), " r2c run-native-gui controller smoke: React.js repo exists")
    let controllerEnv = os.GetEnv("R2C_REACT_CONTROLLER_EXE")
    let allowControllerCompile = os.GetEnv("R2C_REACT_ALLOW_CONTROLLER_COMPILE") == "1"
    var controllerExe = ""
    if len(controllerEnv) > 0:
        controllerExe = chengpath.PathAbsolute(root, controllerEnv)
    elif allowControllerCompile:
        controllerExe = os.JoinPath(outDir, "r2c_react_controller_smoke")
