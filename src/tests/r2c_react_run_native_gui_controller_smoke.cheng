import std/os
import std/strutils as strutil
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_surface_main as r2csurface

fn containsText(text: str, needle: str): bool =
    return strutil.Contains(text, needle)

fn containsJsonStringField(text: str, key: str, value: str): bool =
    let pretty = "\"" + key + "\": \"" + value + "\""
    let compact = "\"" + key + "\":\"" + value + "\""
    return containsText(text, pretty) || containsText(text, compact)

fn summaryValue(text: str, key: str): str =
    let prefix = key + "="
    let lines = strutil.Split(text, '\n')
    for i in 0..<lines.len:
        let line = lines[i]
        if strutil.StartsWith(line, prefix):
            return chengpath.TextSlice(line, len(prefix), len(line) - len(prefix))
    return ""

fn assertPositiveSummaryValue(summaryText: str, key: str, label: str): str =
    let value = summaryValue(summaryText, key)
    assert(len(value) > 0, label + " summary value")
    assert(strutil.ParseInt(value) > 0, label + " positive summary value")
    return value

fn assertCatalogCountMatchesSummary(catalogText: str,
                                    fieldName: str,
                                    summaryText: str,
                                    summaryKey: str,
                                    label: str) =
    let value = assertPositiveSummaryValue(summaryText, summaryKey, label)
    assert(containsText(catalogText, "\"" + fieldName + "\": " + value),
           label)

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
