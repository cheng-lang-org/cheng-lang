import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus as consensus
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node: init")

    let parentCid = node.v3ChainNodeAccountHead(server.index, 7, 1001)
    var event = consensus.v3ChainEventMint(
        7,
        1001,
        parentCid,
        int64(100),
        server.nextEpoch,
        server.nextGanzhi,
        node.v3ChainNodeSpaceSlot(1001, 1001),
        server.nextTick
    )
    let eventCid = consensus.v3ChainEventCid(event)

    var nextIndex = server.index
    var decision = consensus.V3ConsensusDecision()
    consensus.v3ConsensusApplyChecked(nextIndex, event, eventCid, server.eventCids.len, decision)
    assert(decision.accepted, "v3 chain_node rebuild header: accepted")
    assert(decision.applied, "v3 chain_node rebuild header: applied")

    server.index = nextIndex
    add(server.eventCids, eventCid)
    add(server.events, event)
    assert(server.eventCids.len == 1, "v3 chain_node rebuild header: before rebuild len")
    assert(server.events.len == 1, "v3 chain_node rebuild header: before rebuild events len")

    node.v3ChainNodeRebuildDerived(server)
    assert(server.eventCids.len == 1, "v3 chain_node rebuild header: after rebuild len")
    assert(server.events.len == 1, "v3 chain_node rebuild header: after rebuild events len")

    echo("v3 chain_node_rebuild_eventcids_header_smoke ok")
    return 0
