import std/system
import std/os as os
import std/strings
import std/strutils as strutil

fn perfEnvInt(name: str, defaultValue: int32): int32 =
    let raw: str = os.GetEnvDefault(name, "")
    if len(raw) <= 0:
        return defaultValue
    var value: int32
    var i: int32
    for i in i..<len(raw):
        let ch: char = raw[i]
        if ch < '0' || ch > '9':
            return defaultValue
        value = value * 10 + (int32(ch) - int32('0'))
    return value

fn main() =
    let iterations: int32 = perfEnvInt("STD_PERF_ITERS", 80)
    let tmpRoot: str = os.GetEnvDefault("STD_PERF_TMPDIR", "artifacts/std_perf_file_io")
    os.CreateDir(tmpRoot)
    let filePath: str = os.JoinPath(tmpRoot, "payload.txt")
    var total: int32
    var i: int32
    for i in i..<iterations:
        let content: str = strutil.Join(["payload-", IntToStr(i & 15)], "")
        os.WriteFile(filePath, content)
        total = total + len(os.ReadFile(filePath))
    let _ = os.RemoveFile(filePath)
    os.RemoveDir(tmpRoot)
    echo(IntToStr(total))
