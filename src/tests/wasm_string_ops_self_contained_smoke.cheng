# Self-contained WASM string ops test
# Uses only primitive int32 operations (no runtime bridge imports needed)
# Tests string comparison, indexing and length via runtime bridge through status codes

fn str_compare_ascii(a: str, b: str): int32 =
    # returns 0 if equal, -1 if a<b, 1 if a>b
    let an = a.len
    let bn = b.len
    if an != bn:
        return an < bn ? -1 : 1
    var i: int32
    while i < an:
        if a[i] != b[i]:
            return int32(a[i]) < int32(b[i]) ? -1 : 1
        i = i + 1
    return 0

fn test_empty_string(): int32 =
    let s = ""
    if s.len != 0: return 1
    if s != "": return 2
    if !(s == ""): return 3
    return 0

fn test_string_eq(): int32 =
    let a = "hello"
    let b = "hello"
    if a != b: return 1
    if !(a == b): return 2
    if a.len != 5: return 3
    if b.len != 5: return 4
    let c = "world"
    if a == c: return 5
    if !(a != c): return 6
    return 0

fn test_string_index(): int32 =
    let s = "abcde"
    if s.len != 5: return 1
    if int32(s[0]) != int32('a'): return 2
    if int32(s[1]) != int32('b'): return 3
    if int32(s[2]) != int32('c'): return 4
    if int32(s[3]) != int32('d'): return 5
    if int32(s[4]) != int32('e'): return 6
    return 0

fn test_string_prefix(): int32 =
    let s = "foobar"
    let prefix = "foo"
    if prefix.len > s.len: return 1
    if int32(s[0]) != int32(prefix[0]): return 2
    if int32(s[1]) != int32(prefix[1]): return 3
    if int32(s[2]) != int32(prefix[2]): return 4
    return 0

fn test_string_char_at(): int32 =
    let s = "A\nB\tC"
    if s.len != 5: return 1
    if int32(s[0]) != int32('A'): return 2
    if int32(s[1]) != 10: return 3
    if int32(s[2]) != int32('B'): return 4
    if int32(s[3]) != 9: return 5
    if int32(s[4]) != int32('C'): return 6
    return 0

fn test_compare_equality_chain(): int32 =
    let a = "same"
    let b = "same"
    let c = "same"
    let d = "diff"
    if a != b: return 1
    if b != c: return 2
    if a != c: return 3
    if a == d: return 4
    if c == d: return 5
    return 0

fn test_str_compare(): int32 =
    if str_compare_ascii("abc", "abc") != 0: return 1
    if str_compare_ascii("", "") != 0: return 2
    if str_compare_ascii("a", "b") != -1: return 3
    if str_compare_ascii("b", "a") != 1: return 4
    if str_compare_ascii("ab", "abc") != -1: return 5
    if str_compare_ascii("abc", "ab") != 1: return 6
    return 0

fn test_short_strings(): int32 =
    let a = "x"
    let b = "y"
    let c = "x"
    if a.len != 1: return 1
    if b.len != 1: return 2
    if a == b: return 3
    if a != c: return 4
    if int32(a[0]) != int32('x'): return 5
    if int32(b[0]) != int32('y'): return 6
    return 0

fn test_longer_string(): int32 =
    let s = "abcdefghijklmnopqrstuvwxyz"
    if s.len != 26: return 1
    if int32(s[0]) != int32('a'): return 2
    if int32(s[13]) != int32('n'): return 3
    if int32(s[25]) != int32('z'): return 4
    return 0

fn main(): int32 =
    if test_empty_string() != 0: return 1
    if test_string_eq() != 0: return 2
    if test_string_index() != 0: return 3
    if test_string_prefix() != 0: return 4
    if test_string_char_at() != 0: return 5
    if test_compare_equality_chain() != 0: return 6
    if test_str_compare() != 0: return 7
    if test_short_strings() != 0: return 8
    if test_longer_string() != 0: return 9
    return 0
