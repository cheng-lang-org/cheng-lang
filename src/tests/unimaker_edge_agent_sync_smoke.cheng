import std/os as os
import std/strings as strings
import cheng/core/tooling/path as chengpath
import cheng/std/bytes_layout as layout
import cheng/apps/unimaker/unimaker_edge_types as types
import cheng/apps/unimaker/unimaker_edge_agent as agent

fn unimakerSyncCleanup(tmpRoot: str) =
    let aStore = os.JoinPath(tmpRoot, "a.did")
    let bStore = os.JoinPath(tmpRoot, "b.did")
    let aLog = os.JoinPath(tmpRoot, "a.events.jsonl")
    let bLog = os.JoinPath(tmpRoot, "b.events.jsonl")
    let aLogTmp = aLog + ".tmp"
    let bLogTmp = bLog + ".tmp"
    if os.FileExists(aStore):
        let _ = os.RemoveFile(aStore)
    if os.FileExists(bStore):
        let _ = os.RemoveFile(bStore)
    if os.FileExists(aLog):
        let _ = os.RemoveFile(aLog)
    if os.FileExists(bLog):
        let _ = os.RemoveFile(bLog)
    if os.FileExists(aLogTmp):
        let _ = os.RemoveFile(aLogTmp)
    if os.FileExists(bLogTmp):
        let _ = os.RemoveFile(bLogTmp)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

fn main(): int32 =
    let tmpRoot = "artifacts/unimaker_edge_agent_sync_smoke"
    unimakerSyncCleanup(tmpRoot)
    os.CreateDir(tmpRoot)

    var cfgA = types.UnimakerAgentConfig()
    cfgA.rootDir = chengpath.PathCurrentDir()
    cfgA.eventLogPath = os.JoinPath(tmpRoot, "a.events.jsonl")
    cfgA.identityStorePath = os.JoinPath(tmpRoot, "a.did")
    cfgA.rootSeedHint = "sync.root.seed"
    cfgA.deviceSeedHint = "sync.phone.a"
    cfgA.deviceLabelHint = "phone-a"
    cfgA.epochSeconds = int64(1711000000)

    var cfgB = types.UnimakerAgentConfig()
    cfgB.rootDir = chengpath.PathCurrentDir()
    cfgB.eventLogPath = os.JoinPath(tmpRoot, "b.events.jsonl")
    cfgB.identityStorePath = os.JoinPath(tmpRoot, "b.did")
    cfgB.rootSeedHint = "sync.root.seed"
    cfgB.deviceSeedHint = "sync.phone.b"
    cfgB.deviceLabelHint = "phone-b"
    cfgB.epochSeconds = int64(1711000000)

    var edgeA = agent.UnimakerAgentInit(cfgA)
    var edgeB = agent.UnimakerAgentInit(cfgB)

    var prevCid = layout.FixedBytes32()
    var i: int32
    while i < 100:
        var parents: layout.FixedBytes32[]
        if i > 0:
            add(parents, prevCid)
        let event = types.UnimakerEventMake(types.UnimakerEventUserInput,
                                              "task.sync",
                                              "sync observation " + strings.IntToStr(i),
                                              ["sync", "batch"],
                                              parents,
                                              types.UnimakerEdgeKindCausedBy,
                                              int64(1711000001 + i))
        let ingestRes = agent.UnimakerAgentIngest(edgeA, event)
        assert(IsOk(ingestRes), " unimaker sync: ingest a")
        prevCid = Value(ingestRes).capsuleCid
        i = i + 1
    assert(agent.UnimakerAgentCapsuleCount(edgeA) == 100, " unimaker sync: edgeA count")

    var peerAB = types.UnimakerSyncPeer()
    peerAB.peerIdText = edgeB.identity.peerIdText
    peerAB.transportKind = types.UnimakerTransportLibp2pReqResp
    peerAB.trusted = true

    var peerBA = types.UnimakerSyncPeer()
    peerBA.peerIdText = edgeA.identity.peerIdText
    peerBA.transportKind = types.UnimakerTransportLibp2pReqResp
    peerBA.trusted = true

    let pushABRes = agent.UnimakerAgentSyncPush(edgeA, peerAB)
    assert(IsOk(pushABRes), " unimaker sync: push ab")
    assert(Value(pushABRes).pushedCount == 100, " unimaker sync: push ab count")
    peerBA.inboundPushPayload = peerAB.outboundPushPayload
    let pullBARes = agent.UnimakerAgentSyncPull(edgeB, peerBA, types.SyncCursor())
    assert(IsOk(pullBARes), " unimaker sync: pull ba")
    assert(Value(pullBARes).mergedCount == 100, " unimaker sync: pull ba merged")
    assert(agent.UnimakerAgentCapsuleCount(edgeB) == 100, " unimaker sync: edgeB count")

    let secondPushABRes = agent.UnimakerAgentSyncPush(edgeA, peerAB)
    assert(IsOk(secondPushABRes), " unimaker sync: second push ab")
    assert(Value(secondPushABRes).pushedCount == 0, " unimaker sync: second push no resend")

    let confirmEvent = types.UnimakerEventMake(types.UnimakerEventToolResult,
                                                 "task.sync",
                                                 "confirmed 100 synced observations",
                                                 ["sync", "confirmed"],
                                                 [prevCid],
                                                 types.UnimakerEdgeKindRefines,
                                                 int64(1711000500))
    let confirmRes = agent.UnimakerAgentIngest(edgeB, confirmEvent)
    assert(IsOk(confirmRes), " unimaker sync: ingest b confirm")
    peerBA.remoteCursor = Value(pushABRes).cursor
    let pushBARes = agent.UnimakerAgentSyncPush(edgeB, peerBA)
    assert(IsOk(pushBARes), " unimaker sync: push ba")
    assert(Value(pushBARes).pushedCount == 1, " unimaker sync: push ba incremental")
    peerAB.inboundPushPayload = peerBA.outboundPushPayload
    let pullABRes = agent.UnimakerAgentSyncPull(edgeA, peerAB, Value(secondPushABRes).cursor)
    assert(IsOk(pullABRes), " unimaker sync: pull ab")
    assert(Value(pullABRes).mergedCount == 1, " unimaker sync: pull ab merged")

    assert(agent.UnimakerAgentCapsuleCount(edgeA) == 101, " unimaker sync: edgeA final count")
    assert(agent.UnimakerAgentCapsuleCount(edgeB) == 101, " unimaker sync: edgeB final count")
    assert(layout.FixedBytes32Equal(agent.UnimakerAgentHeadCid(edgeA),
                                    agent.UnimakerAgentHeadCid(edgeB)),
        " unimaker sync: converged head")

    var query = types.MemoryQuery()
    query.keyword = "confirmed"
    query.limit = 8
    let recallRes = agent.UnimakerAgentRecall(edgeA, query)
    assert(IsOk(recallRes), " unimaker sync: recall confirmed")
    assert(Value(recallRes).len == 1, " unimaker sync: recall confirmed count")

    unimakerSyncCleanup(tmpRoot)
    echo(" unimaker_edge_agent_sync_smoke ok")
    return 0

