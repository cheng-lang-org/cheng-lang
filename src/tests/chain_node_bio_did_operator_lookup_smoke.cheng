import std/system
import std/result
import std/strings
import cheng/std/bytes_layout as layout
import cheng/apps/chain_node/chain_node as chain
import cheng/apps/chain_node/chain_node_cli_core as cli
import cheng/apps/bio/bio_did_chain_node as flow
import cheng/mobile/hardware/biometric
import std/strutils as strutil

fn chainNodeBioDidLookupSmokeFeatureInto(out: var layout.FixedBytes32, seed: int32) =
    for i in 0..<32:
        out.data[i] = uint8(((seed * 29) + (i * 17) + 11) & 255)

fn chainNodeBioDidLookupSmokeCaptureInto(out: var flow.BioDidHardwareCapture,
                                         feature: layout.FixedBytes32,
                                         bindingSeed: str,
                                         label: str,
                                         requestId: str,
                                         purpose: int32) =
    out.verified = true
    out.feature32 = feature
    out.requestId = requestId
    out.sensorId = strutil.Join(["sensor|", bindingSeed], "")
    out.deviceBindingSeed = bindingSeed
    out.deviceLabel = label
    var req = biometric.BiometricFingerprintAuthorizeReq()
    req.requestId = requestId
    req.purpose = purpose
    req.didText = ""
    req.promptTitle = "chain node bio did lookup smoke"
    req.promptReason = "chain node bio did lookup smoke"
    req.deviceBindingSeedHint = bindingSeed
    req.deviceLabelHint = label
    let sensorId = out.sensorId
    var attestorPrivHex: str = "60d71049a0cafe01faa9948dc77ee5bc4bd5e05b8e328fdb9cc4c38237250a05"
    let attestationRes = biometric.BiometricFingerprintAttestationBuildSigned(req,
                                                                                feature,
                                                                                bindingSeed,
                                                                                label,
                                                                                sensorId,
                                                                                attestorPrivHex)
    assert(IsOk(attestationRes), "chain node bio did lookup smoke: signed attestation")
    out.hardwareAttestation = Value(attestationRes)

fn main(): int32 =
    var rootKeyId: str = "cheng.scripted.root"
    let trustRes = flow.BioDidSetTrustedAttestorRootHex(
        "04963c1356849b8478030a6eb572581063ccedf53fda0bc7241247eba977e3b0666e4bf0c12caa47487c2927f83b17d6f9f332481cd2ab0c4885f91fc2a6c547d5",
                                                          rootKeyId)
    assert(IsOk(trustRes), "chain node bio did lookup smoke: trust attestor")
    let operatorIdRes = flow.BioDidOperatorIdFromRecoverySecretHex(
        "1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef"
    )
    assert(IsOk(operatorIdRes), "chain node bio did lookup smoke: operator id")
    let operatorId = Value(operatorIdRes)
    var node: chain.ChainNode
    assert(IsOk(chain.ChainNodeInitInto(node, "bio.did.lookup.node", "bio.did.lookup.addr")),
           "chain node bio did lookup smoke: init node")
    var feature: layout.FixedBytes32
    chainNodeBioDidLookupSmokeFeatureInto(feature, 7)
    var capture: flow.BioDidHardwareCapture
    chainNodeBioDidLookupSmokeCaptureInto(capture,
                                          feature,
                                          "device.lookup.phone",
                                          "lookup-phone",
                                          "lookup-create-1",
                                                 biometric.BiometricPurposeDidCreate)
    let createRes = flow.BioDidCreateWithHardwareCapture(node, capture, int64(1000))
    assert(IsOk(createRes), "chain node bio did lookup smoke: create")
    let create = Value(createRes)
    let createBundle = create.bundle
    let anchorRes = flow.BioDidChainAppendOperatorBundleAnchor(node,
                                                                 operatorId,
                                                                 createBundle,
                                                                 "lookup-anchor-1")
    assert(IsOk(anchorRes), "chain node bio did lookup smoke: anchor")
    var snapshot: chain.ChainNodeServeSnapshot
    chain.ChainNodeServeOnceInto(snapshot, node)
    let statePath = "/tmp/chain_node_bio_did_operator_lookup_smoke.state"
    assert(cli.ChainNodeCliWriteState(statePath, snapshot),
           "chain node bio did lookup smoke: write state")
    let operatorIdHex = layout.FixedBytes32Hex(operatorId)
    var loadedNode: chain.ChainNode
    let loadStateRes = cli.ChainNodeCliLoadStateInto(loadedNode, statePath)
    assert(IsOk(loadStateRes), "chain node bio did lookup smoke: direct load state")
    var loadedState: flow.BioDidChainState
    let loadedStateRes = flow.BioDidChainStateFromNodeInto(loadedState, loadedNode)
    assert(IsOk(loadedStateRes), "chain node bio did lookup smoke: direct load bio state")
    let lookupJsonRes = cli.ChainNodeCliBioDidOperatorLookupJson(statePath,
                                                                   operatorIdHex)
    assert(IsOk(lookupJsonRes), "chain node bio did lookup smoke: lookup hit")
    let lookupJson = Value(lookupJsonRes)
    assert(strings.StrContains(lookupJson, "\"found\":true"),
           "chain node bio did lookup smoke: lookup hit found")
    assert(strings.StrContains(lookupJson, "\"bundleSeq\":1"),
           "chain node bio did lookup smoke: lookup hit seq")
    assert(strings.StrContains(lookupJson, "\"bundleKind\":\"android_bio_v1\""),
           "chain node bio did lookup smoke: lookup hit kind")
    var preferredKinds: str[]
    preferredKinds = [flow.BioDidOperatorBundleKindAndroidBioV1]
    let preferredLookupRes = cli.ChainNodeCliBioDidOperatorLookupJsonWithKinds(
        statePath,
        operatorIdHex,
        preferredKinds
    )
    assert(IsOk(preferredLookupRes), "chain node bio did lookup smoke: preferred lookup hit")
    let preferredLookupText = Value(preferredLookupRes)
    assert(strings.StrContains(preferredLookupText, "\"found\":true"),
           "chain node bio did lookup smoke: preferred lookup found")
    let missJsonRes = cli.ChainNodeCliBioDidOperatorLookupJson(
        statePath,
        "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff"
    )
    assert(IsOk(missJsonRes), "chain node bio did lookup smoke: lookup miss")
    let missLookupText = Value(missJsonRes)
    assert(strings.StrContains(missLookupText, "\"found\":false"),
           "chain node bio did lookup smoke: lookup miss found false")
    echo(" chain_node_bio_did_operator_lookup_smoke ok")
    return 0
