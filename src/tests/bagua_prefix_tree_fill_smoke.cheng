import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr as lsmr
import cheng/chain/lsmr_types as lt

fn mustAddress(digits: int32[]): types.LsmrAddress =
    let res = types.LsmrAddressFromDigits(digits)
    if IsErr(res):
        panic(Error(res))
    return Value(res)

fn makeCell(keyId: int32, digits: int32[], resolution: int32, salt: int32): lt.StateCell =
    let address = mustAddress(digits)
    let contentCid = lt.HashInts("cheng.bagua_fill.content", [keyId, salt, resolution])
    let localityHash = lt.HashInts("cheng.bagua_fill.locality", [keyId, salt, resolution])
    var cell: lt.StateCell
    lsmr.LsmrStateCellFill(cell, keyId, address, resolution, contentCid, localityHash)
    return cell

fn main(): int32 =
    var cells: lt.StateCell[]
    cells = []
    add(cells, makeCell(101, [6, 7, 9], 3, 1))
    add(cells, makeCell(102, [6, 7, 3], 3, 2))
    var tree = lt.BaguaPrefixTree()
    lsmr.BuildBaguaPrefixTreeFill(tree, cells)
    assert(tree.entryCount == 2, " bagua_prefix_tree_fill_smoke: entry count")
    assert(tree.nodeCount > 0, " bagua_prefix_tree_fill_smoke: node count")
    assert(!layout.fixedBytes32Equal(tree.treeCid, layout.FixedBytes32()),
           " bagua_prefix_tree_fill_smoke: tree cid")
    echo(" bagua_prefix_tree_fill_smoke ok")
    return 0
