import std/system
import std/result
import std/rawbytes
import cheng/quic/core/frame_model
import cheng/quic/core/packet_model
import cheng/quic/validation/protocol_validation

fn main(): int32 =
    var pkt = packet_model.initMsQuicPacket(1)
    let ping = frame_model.msquicFramePing()
    let data = frame_model.msquicFrameData(0, 0, bytesFromString("ok"))
    let addPing = packet_model.msquicPacketAddFrame(pkt, ping)
    if IsErr(addPing):
        panic(ErrorText(addPing))
    let addData = packet_model.msquicPacketAddFrame(pkt, data)
    if IsErr(addData):
        panic(ErrorText(addData))
    let validRes = protocol_validation.msquicValidatePacket(pkt)
    if IsErr(validRes):
        panic(ErrorText(validRes))
    let encodedRes = packet_model.msquicPacketPayloadEncode(pkt)
    if IsErr(encodedRes):
        panic(ErrorText(encodedRes))
    let encoded = Value(encodedRes)
    let decodedRes = packet_model.msquicPacketPayloadDecode(encoded, pkt.number)
    if IsErr(decodedRes):
        panic(ErrorText(decodedRes))
    let decoded = Value(decodedRes)
    assert(decoded.framesCount == 2, " protocol validation: decoded frame count")
    let decodedValidRes = protocol_validation.msquicValidatePacket(decoded)
    if IsErr(decodedValidRes):
        panic(ErrorText(decodedValidRes))
    let bytesRes = protocol_validation.msquicValidatePacketPayloadBytes(encoded, pkt.number)
    if IsErr(bytesRes):
        panic(ErrorText(bytesRes))
    let badFrame = frame_model.msquicFrameData(-1, 0, bytesFromString("bad"))
    let badFrameRes = protocol_validation.msquicValidateFrame(badFrame)
    assert(IsErr(badFrameRes), " protocol validation: reject bad frame")
    let badPkt = packet_model.initMsQuicPacket(-4)
    let badPktRes = protocol_validation.msquicValidatePacket(badPkt)
    assert(IsErr(badPktRes), " protocol validation: reject bad packet")
    echo(" protocol_validation_smoke ok")
    return 0
