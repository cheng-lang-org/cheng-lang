// import_chain_c.cheng — C in the A->B->C->D chain
// Imports D, provides a function using D

import cheng/tests/import_chain_d as d_mod

fn chainCMul(x: int32, y: int32): int32 =
    var result: int32 = 0
    var i: int32 = 0
    while i < y:
        result = d_mod.chainDAdd(result, x)
        i = i + 1
    return result

fn chainCTriple(x: int32): int32 =
    return d_mod.chainDSquare(d_mod.chainDAdd(x, x))
