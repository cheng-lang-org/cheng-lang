import std/os
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root = os.GetCurrentDir()
    let reportPath = os.JoinPath(root, "artifacts/str_concat_lowering_smoke/str_concat_lowering_probe.compile.report.txt")
    assert(chengpath.PathFileExists(reportPath), " report filesize: report exists")
    let size = os.FileSize(reportPath)
    assert(size > int64(0), " report filesize: positive")
    echo(" os_report_filesize_probe ok")
    return 0
