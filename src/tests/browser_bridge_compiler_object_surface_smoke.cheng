import std/os
import std/strutils as strutil
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

fn containsText(text: str, needle: str): bool =
    return strutil.Contains(text, needle)

fn browserBridgeSmokeDriver(root: str): str =
    let envDriver = strutil.Strip(os.GetEnv("CHENG_BROWSER_BRIDGE_DRIVER"))
    if len(envDriver) > 0:
        return chengpath.PathAbsolute(root, envDriver)
    let freshDriver = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3.bridge_object")
    if chengpath.FileExistsNonEmpty(root, freshDriver):
        return freshDriver
    let livefullDriver = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3.livefull")
    if chengpath.FileExistsNonEmpty(root, livefullDriver):
        return livefullDriver
    let stage3Driver = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3")
    if chengpath.FileExistsNonEmpty(root, stage3Driver):
        return stage3Driver
    return chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")

fn main(): int32 =
    let root = os.GetCurrentDir()
    let smokeLabel = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let driver = browserBridgeSmokeDriver(root)
    let packageRoot = root
    let source = chengpath.PathAbsolute(root, "src/tests/browser_host_native_min_smoke.cheng")
    let outDir = chengpath.PathAbsolute(root, strutil.Join(["artifacts/browser_bridge_compiler_object_surface/", smokeLabel], ""))
    let outBin = chengpath.PathJoin(outDir, "browser_host_native_min_smoke")
    let reportPath = strutil.Join([outBin, ".report.txt"], "")
    let compileLog = strutil.Join([outBin, ".compile.log"], "")
    let runLog = strutil.Join([outBin, ".run.log"], "")
    let bridgeObjectPath = strutil.Join([outBin, ".browser_bridge.generated.o"], "")
    assert(chengpath.MkdirP(root, outDir), " browser bridge compiler object: mkdir")
    if chengpath.PathFileExists(outBin):
        os.RemoveFile(outBin)
    if chengpath.PathFileExists(reportPath):
        os.RemoveFile(reportPath)
    if chengpath.PathFileExists(bridgeObjectPath):
        os.RemoveFile(bridgeObjectPath)
    let compileRun = hostops.RunFileLogged(root,
                                             "browser_bridge_compiler_object_surface_build",
                                             driver,
                                             [
                                                 "system-link-exec",
                                                 strutil.Join(["--root:", packageRoot], ""),
                                                 strutil.Join(["--in:", source], ""),
                                                 "--emit:exe",
                                                 "--target:arm64-apple-darwin",
                                                 strutil.Join(["--out:", outBin], ""),
                                                 strutil.Join(["--report-out:", reportPath], "")
                                             ],
                                             ["CHENG_NO_BACKEND_DRIVER_HANDOFF=1"],
                                             root,
                                             0,
                                             compileLog)
    assert(hostops.LoggedRunOk(compileRun), " browser bridge compiler object: compile rc")
    assert(chengpath.FileExistsNonEmpty(root, outBin), " browser bridge compiler object: output exists")
    assert(chengpath.FileExistsNonEmpty(root, reportPath), " browser bridge compiler object: report exists")
    assert(chengpath.FileExistsNonEmpty(root, bridgeObjectPath), " browser bridge compiler object: bridge object exists")
    let reportText = chengpath.ReadTextFile("", reportPath)
    assert(containsText(reportText, "extra_link_input=-"),
           " browser bridge compiler object: no explicit extra link input")
    assert(containsText(reportText, strutil.Join(["browser_bridge_object=", bridgeObjectPath], "")),
           " browser bridge compiler object: browser bridge object field")
    assert(containsText(reportText, strutil.Join(["native_browser_bridge_object=", bridgeObjectPath], "")),
           " browser bridge compiler object: native browser bridge object field")
    assert(containsText(reportText, "object_link_inputs="), " browser bridge compiler object: object inputs")
    assert(containsText(reportText, bridgeObjectPath), " browser bridge compiler object: object listed")
    assert(!containsText(reportText, strutil.Join(["extra_link_input=", bridgeObjectPath], "")),
           " browser bridge compiler object: internal object is not explicit link input")
    assert(containsText(reportText, "native_link_inputs="), " browser bridge compiler object: native inputs")
    let run = hostops.RunFileLogged(root,
                                      "browser_bridge_compiler_object_surface_run",
                                      outBin,
                                      [],
                                      [],
                                      root,
                                      0,
                                      runLog)
    assert(hostops.LoggedRunOk(run), " browser bridge compiler object: run rc")
    assert(containsText(run.output, " browser host wasm smoke: ok"),
           " browser bridge compiler object: runtime output")
    echo(" browser_bridge_compiler_object_surface_smoke ok")
    return 0
