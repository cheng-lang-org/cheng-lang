import std/os
import cheng/tests/str_concat_cross_module_helper as helper
import std/strutils as strutil

fn StrConcatLoweringFlag(prefix: str, value: str): str =
    var parts: str[]
    add(parts, prefix)
    add(parts, value)
    return strutil.Join(parts, "")

fn main(): int32 =
    let root = os.GetCurrentDir()
    let driver = os.JoinPath(root, "artifacts/bootstrap/cheng.stage3")
    let logPath = os.JoinPath(root, "artifacts/str_concat_cross_module_probe.log")
    let run = helper.Sink(root,
                          "str_concat_cross_module_probe",
                          driver,
                          [
                              "system-link-exec",
                              StrConcatLoweringFlag("--root:", root),
                              "--emit:exe"
                          ],
                          [],
                          root,
                          0,
                          logPath)
    assert(run.ExitCode == 0, " str concat cross module probe: rc")
    echo(run.Text)
    return 0
