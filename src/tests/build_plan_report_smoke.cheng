import cheng/core/backend/build_plan as buildplan
import std/strings

fn main(): int32 =
    let plan: buildplan.BackendBuildPlan = buildplan.BackendBuildPlanBackendDriverForTarget("/tmp/cheng-lang", "arm64-apple-darwin")
    let report: str = buildplan.BackendBuildPlanReport(plan)
    assert(strings.StrContains(report, "target=arm64-apple-darwin"),
           "build_plan_report_smoke: target")
    assert(strings.StrContains(report, "backend_driver_entry_source:/tmp/cheng-lang/src/core/tooling/backend_driver_main.cheng"),
           "build_plan_report_smoke: backend driver entry")
    assert(strings.StrContains(report, "tooling_source:/tmp/cheng-lang/src/core/tooling/export_visibility_gate.cheng"),
           "build_plan_report_smoke: export visibility gate source")
    assert(!strings.StrContains(report, "src/core/tooling/host_bridge_audit_gate.cheng"),
           "build_plan_report_smoke: no host bridge audit gate source")
    assert(!strings.StrContains(report, "src/core/tooling/hotpath_scan.cheng"),
           "build_plan_report_smoke: no hotpath scan source")
    assert(!strings.StrContains(report, "src/core/tooling/host_smoke_gate.cheng"),
           "build_plan_report_smoke: no host smoke gate source")
    assert(!strings.StrContains(report, "src/core/tooling/support_matrix.cheng"),
           "build_plan_report_smoke: no support matrix source")
    assert(!strings.StrContains(report, "src/core/tooling/wasm_binary_audit.cheng"),
           "build_plan_report_smoke: no wasm binary audit source")
    assert(!strings.StrContains(report, "src/core/tooling/wasm_smoke_gate.cheng"),
           "build_plan_report_smoke: no wasm smoke gate source")
    assert(strings.StrContains(report, "tooling_source:/tmp/cheng-lang/src/core/backend/build_plan.cheng"),
           "build_plan_report_smoke: build plan source")
    echo("build_plan_report_smoke ok")
    return 0
