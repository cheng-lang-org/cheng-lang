import cheng/core/backend/build_plan as buildplan
import std/strings

fn main(): int32 =
    let plan: buildplan.BackendBuildPlan = buildplan.BackendBuildPlanBackendDriverForTarget("/tmp/cheng-lang", "arm64-apple-darwin")
    let report: str = buildplan.BackendBuildPlanReport(plan)
    assert(strings.StrContains(report, "target=arm64-apple-darwin"),
           "build_plan_report_smoke: target")
    assert(strings.StrContains(report, "backend_driver_entry_source:/tmp/cheng-lang/src/core/tooling/backend_driver_dispatch_min.cheng"),
           "build_plan_report_smoke: backend driver entry")
    assert(strings.StrContains(report, "backend_system_link_plan_source:/tmp/cheng-lang/src/core/backend/system_link_plan.cheng"),
           "build_plan_report_smoke: system link plan source")
    assert(strings.StrContains(report, "backend_lowering_plan_source:/tmp/cheng-lang/src/core/backend/lowering_plan.cheng"),
           "build_plan_report_smoke: lowering plan source")
    assert(strings.StrContains(report, "backend_primary_object_plan_source:/tmp/cheng-lang/src/core/backend/primary_object_plan.cheng"),
           "build_plan_report_smoke: primary object plan source")
    assert(strings.StrContains(report, "backend_aarch64_encode_source:/tmp/cheng-lang/src/core/backend/aarch64_encode.cheng"),
           "build_plan_report_smoke: aarch64 encode source")
    assert(strings.StrContains(report, "backend_direct_object_emit_source:/tmp/cheng-lang/src/core/backend/direct_object_emit.cheng"),
           "build_plan_report_smoke: direct object emit source")
    assert(strings.StrContains(report, "backend_line_map_source:/tmp/cheng-lang/src/core/backend/line_map.cheng"),
           "build_plan_report_smoke: line map source")
    assert(strings.StrContains(report, "backend_system_link_exec_runtime_source:/tmp/cheng-lang/src/core/backend/system_link_exec_runtime.cheng"),
           "build_plan_report_smoke: system link exec runtime source")
    assert(strings.StrContains(report, "backend_system_link_exec_runtime_direct_source:/tmp/cheng-lang/src/core/backend/system_link_exec_runtime_direct.cheng"),
           "build_plan_report_smoke: system link exec runtime direct source")
    assert(!strings.StrContains(report, "src/core/tooling/compiler_world_libp2p.cheng"),
           "build_plan_report_smoke: no compiler world libp2p source")
    assert(!strings.StrContains(report, "src/core/tooling/compiler_publish_gate.cheng"),
           "build_plan_report_smoke: no compiler publish gate source")
    assert(!strings.StrContains(report, "src/core/tooling/compiler_csg_egraph_contract.cheng"),
           "build_plan_report_smoke: no compiler csg egraph contract source")
    assert(!strings.StrContains(report, "src/core/tooling/compiler_equivalence.cheng"),
           "build_plan_report_smoke: no compiler equivalence source")
    assert(!strings.StrContains(report, "src/core/tooling/debug_tools_gate.cheng"),
           "build_plan_report_smoke: no debug tools gate source")
    assert(!strings.StrContains(report, "src/core/tooling/export_visibility_gate.cheng"),
           "build_plan_report_smoke: no export visibility gate source")
    assert(!strings.StrContains(report, "src/core/tooling/object_debug_report.cheng"),
           "build_plan_report_smoke: no object debug report source")
    assert(!strings.StrContains(report, "src/core/tooling/host_bridge_audit_gate.cheng"),
           "build_plan_report_smoke: no host bridge audit gate source")
    assert(!strings.StrContains(report, "src/core/tooling/hotpath_scan.cheng"),
           "build_plan_report_smoke: no hotpath scan source")
    assert(!strings.StrContains(report, "src/core/tooling/host_smoke_gate.cheng"),
           "build_plan_report_smoke: no host smoke gate source")
    assert(!strings.StrContains(report, "src/core/tooling/support_matrix.cheng"),
           "build_plan_report_smoke: no support matrix source")
    assert(!strings.StrContains(report, "src/core/tooling/wasm_binary_audit.cheng"),
           "build_plan_report_smoke: no wasm binary audit source")
    assert(!strings.StrContains(report, "src/core/tooling/wasm_smoke_gate.cheng"),
           "build_plan_report_smoke: no wasm smoke gate source")
    assert(!strings.StrContains(report, "src/core/backend/primary_object_emit.cheng"),
           "build_plan_report_smoke: no asm fallback source")
    assert(strings.StrContains(report, "tooling_source:/tmp/cheng-lang/src/core/backend/build_plan.cheng"),
           "build_plan_report_smoke: build plan source")
    echo("build_plan_report_smoke ok")
    return 0
