import std/system
import cheng/core/backend/system_link_plan as slplan
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_csg as ccsg
import cheng/std/bytes_layout as layout

fn main() =
    var plan: slplan.SystemLinkPlanStub
    var err: str
    let ok = slplan.BuildSystemLinkPlanStubWithFields("/Users/lbcheng/cheng-lang",
                                                      "/Users/lbcheng/cheng-lang",
                                                      "/Users/lbcheng/cheng-lang/src/tests/ordinary_zero_exit_fixture.cheng",
                                                      "/tmp/cold_csg_out",
                                                      "arm64-apple-darwin",
                                                      creq.EmitObj,
                                                      "public",
                                                      "",
                                                      plan,
                                                      err)
    assert(ok, "cold compiler csg slplan ok")
    assert(plan.sourceClosurePaths.len == 1, "cold compiler csg slplan source len")
    var csg: ccsg.CompilerCsg
    var csgErr: str
    var cid: layout.FixedBytes32
    let built = ccsg.BuildCompilerCsgInto(plan, cid, csg, csgErr)
    if !built:
        echo(csgErr)
    assert(built, "cold compiler csg built")
