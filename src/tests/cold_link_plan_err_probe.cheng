import std/os
import cheng/core/tooling/compiler_request as creq
import cheng/core/backend/system_link_plan as slplan
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    echo("probe:start")
    let rootDir = os.GetCurrentDir()
    echo("probe:cwd")
    echo(rootDir)
    let req = creq.CompilerRequestNew(
        rootDir,
        os.JoinPath(rootDir, "src/tests/ordinary_zero_exit_fixture.cheng"),
        os.JoinPath(rootDir, "artifacts/zero_exit/ordinary_zero_exit_fixture"),
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    echo("probe:req")
    echo(req.sourcePath)
    let absSource = chengpath.PathAbsolute(rootDir, req.sourcePath)
    echo(absSource)
    if os.FileExists("."):
        echo("probe:dot-exists")
    else:
        echo("probe:dot-missing")
    if os.FileExists("src/tests/ordinary_zero_exit_fixture.cheng"):
        echo("probe:literal-rel-exists")
    else:
        echo("probe:literal-rel-missing")
    if os.FileExists("/Users/lbcheng/cheng-lang/src/tests/ordinary_zero_exit_fixture.cheng"):
        echo("probe:literal-abs-exists")
    else:
        echo("probe:literal-abs-missing")
    if chengpath.PathFileExists(absSource):
        echo("probe:source-exists")
    else:
        echo("probe:source-missing")
    var plan: slplan.SystemLinkPlanStub
    var err = ""
    if !slplan.BuildSystemLinkPlanStub(rootDir, req, plan, err):
        echo("probe:plan-false")
        echo(err)
        return 1
    echo("probe:plan-true")
    echo(slplan.SystemLinkPlanStubReport(plan))
    return 0
