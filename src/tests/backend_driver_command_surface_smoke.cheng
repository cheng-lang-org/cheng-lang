import std/strings
import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as v3path

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let driver: str = os.JoinPath(root, "artifacts/backend_driver/cheng")
    assert(os.FileExists(driver), "cheng backend driver command surface: backend_driver exists")
    let outDir = v3path.V3PathAbsolute(root, "artifacts/backend_driver_command_surface_smoke")
    assert(v3path.V3MkdirP(root, outDir), "cheng backend driver command surface: mkdir")

    let helpLog = v3path.V3PathJoin(outDir, "help.log")
    if v3path.V3PathFileExists(helpLog):
        os.RemoveFile(helpLog)
    let helpRun = hostops.v3RunFileLogged(root,
                                          "backend_driver_surface_help",
                                          driver,
                                          ["help"],
                                          [],
                                          root,
                                          0,
                                          helpLog)
    let helpOutput: str = helpRun.output
    assert(helpRun.exitCode == 0, "cheng backend driver command surface: help rc")
    assert(strings.StrContains(helpOutput, "usage: cheng <command> [args]"),
           "cheng backend driver command surface: help usage")
    assert(strings.StrContains(helpOutput, "  support-matrix"),
           "cheng backend driver command surface: help support-matrix")
    assert(strings.StrContains(helpOutput, "  run-production-regression"),
           "cheng backend driver command surface: help production regression")
    assert(strings.StrContains(helpOutput, "  verify-export-visibility"),
           "cheng backend driver command surface: help verify-export-visibility")
    assert(strings.StrContains(helpOutput, "  verify-export-visibility-parallel"),
           "cheng backend driver command surface: help verify-export-visibility-parallel")
    assert(strings.StrContains(helpOutput, "  verify-mobile-shell-build-probe"),
           "cheng backend driver command surface: help verify-mobile-shell-build-probe")
    assert(strings.StrContains(helpOutput, "  verify-chain-node-resilience"),
           "cheng backend driver command surface: help verify-chain-node-resilience")
    assert(strings.StrContains(helpOutput, "  verify-oracle-resilience"),
           "cheng backend driver command surface: help verify-oracle-resilience")
    assert(strings.StrContains(helpOutput, "  verify-oracle-bft-three-node"),
           "cheng backend driver command surface: help verify-oracle-bft-three-node")
    assert(strings.StrContains(helpOutput, "  build-zero-exit"),
           "cheng backend driver command surface: help build-zero-exit")
    assert(strings.StrContains(helpOutput, "  run-chain-node-resilience-smoke"),
           "cheng backend driver command surface: help chain-node resilience")
    assert(strings.StrContains(helpOutput, "  run-oracle-resilience-smoke"),
           "cheng backend driver command surface: help oracle resilience")
    assert(strings.StrContains(helpOutput, "  oracle-fixture-query"),
           "cheng backend driver command surface: help oracle fixture query")
    assert(strings.StrContains(helpOutput, "  build-oracle-bft-state-machine"),
           "cheng backend driver command surface: help build-oracle-bft-state-machine")
    assert(strings.StrContains(helpOutput, "  deploy-oracle-bft-three-node"),
           "cheng backend driver command surface: help deploy-oracle-bft-three-node")
    assert(strings.StrContains(helpOutput, "  status-oracle-bft-three-node"),
           "cheng backend driver command surface: help status-oracle-bft-three-node")
    assert(strings.StrContains(helpOutput, "  stop-oracle-bft-three-node"),
           "cheng backend driver command surface: help stop-oracle-bft-three-node")
    assert(strings.StrContains(helpOutput, "  r2c-react <subcommand>"),
           "cheng backend driver command surface: help r2c")
    assert(strings.StrContains(helpOutput, "  vpn-gui [flags]"),
           "cheng backend driver command surface: help vpn gui")
    assert(strings.StrContains(helpOutput, "  vpn-proxy <subcommand>"),
           "cheng backend driver command surface: help vpn proxy")
    assert(strings.StrContains(helpOutput, "  mobile-shell <subcommand>"),
           "cheng backend driver command surface: help mobile shell")

    let vpnGuiHelpLog = v3path.V3PathJoin(outDir, "vpn_gui_help.log")
    if v3path.V3PathFileExists(vpnGuiHelpLog):
        os.RemoveFile(vpnGuiHelpLog)
    let vpnGuiHelpRun = hostops.v3RunFileLogged(root,
                                                "backend_driver_surface_vpn_gui_help",
                                                driver,
                                                ["vpn-gui", "help"],
                                                [],
                                                root,
                                                0,
                                                vpnGuiHelpLog)
    let vpnGuiHelpOutput: str = vpnGuiHelpRun.output
    assert(vpnGuiHelpRun.exitCode == 0, "cheng backend driver command surface: vpn-gui help rc")
    assert(strings.StrContains(vpnGuiHelpOutput, "usage: cheng vpn-gui [--config:<path>] [--runtime-tool:<path>]"),
           "cheng backend driver command surface: vpn-gui help usage")
    assert(strings.StrContains(vpnGuiHelpOutput, "builds gui runtime + local runtime"),
           "cheng backend driver command surface: vpn-gui help summary")

    let mobileHelpLog = v3path.V3PathJoin(outDir, "mobile_shell_help.log")
    if v3path.V3PathFileExists(mobileHelpLog):
        os.RemoveFile(mobileHelpLog)
    let mobileHelpRun = hostops.v3RunFileLogged(root,
                                                "backend_driver_surface_mobile_shell_help",
                                                driver,
                                                ["mobile-shell", "help"],
                                                [],
                                                root,
                                                0,
                                                mobileHelpLog)
    let mobileHelpOutput: str = mobileHelpRun.output
    assert(mobileHelpRun.exitCode == 0, "cheng backend driver command surface: mobile-shell help rc")
    assert(strings.StrContains(mobileHelpOutput, "usage: cheng mobile-shell <subcommand> [args]"),
           "cheng backend driver command surface: mobile-shell help output")
    assert(strings.StrContains(mobileHelpOutput, "subcommands: help, export, build-probe"),
           "cheng backend driver command surface: mobile-shell build-probe help")

    let vpnHelpLog = v3path.V3PathJoin(outDir, "vpn_proxy_help.log")
    if v3path.V3PathFileExists(vpnHelpLog):
        os.RemoveFile(vpnHelpLog)
    let vpnHelpRun = hostops.v3RunFileLogged(root,
                                             "backend_driver_surface_vpn_proxy_help",
                                             driver,
                                             ["vpn-proxy", "help"],
                                             [],
                                             root,
                                             0,
                                             vpnHelpLog)
    let vpnHelpOutput: str = vpnHelpRun.output
    assert(vpnHelpRun.exitCode == 0, "cheng backend driver command surface: vpn-proxy help rc")
    assert(strings.StrContains(vpnHelpOutput, "usage: cheng vpn-proxy <local|exit|status> --config:<path>"),
           "cheng backend driver command surface: vpn-proxy help usage")
    assert(strings.StrContains(vpnHelpOutput, "status flags: --probe-timeout-ms:<n>"),
           "cheng backend driver command surface: vpn-proxy help flags")

    let supportMatrixLog = v3path.V3PathJoin(outDir, "support_matrix.log")
    if v3path.V3PathFileExists(supportMatrixLog):
        os.RemoveFile(supportMatrixLog)
    let supportMatrixRun = hostops.v3RunFileLogged(root,
                                                   "backend_driver_surface_support_matrix",
                                                   driver,
                                                   ["support-matrix"],
                                                   [],
                                                   root,
                                                   0,
                                                   supportMatrixLog)
    let supportMatrixOutput: str = supportMatrixRun.output
    assert(supportMatrixRun.exitCode == 0,
           "cheng backend driver command surface: support-matrix rc")
    assert(strings.StrContains(supportMatrixOutput, "format=cheng_support_matrix_v1"),
           "cheng backend driver command surface: support-matrix format")
    assert(strings.StrContains(supportMatrixOutput,
                               "ordinary_pipeline_state=canonical_csg_verified_primary_object_codegen_ready"),
           "cheng backend driver command surface: support-matrix pipeline")
    assert(strings.StrContains(supportMatrixOutput, "target_count=7"),
           "cheng backend driver command surface: support-matrix target count")

    let oracleQueryLog = v3path.V3PathJoin(outDir, "oracle_fixture_query.log")
    if v3path.V3PathFileExists(oracleQueryLog):
        os.RemoveFile(oracleQueryLog)
    let oracleQueryRun = hostops.v3RunFileLogged(root,
                                                 "backend_driver_surface_oracle_fixture_query",
                                                 driver,
                                                 ["oracle-fixture-query", "--pair:BTC/USD", "--window-rounds:3"],
                                                 [],
                                                 root,
                                                 0,
                                                 oracleQueryLog)
    let oracleQueryOutput: str = oracleQueryRun.output
    assert(oracleQueryRun.exitCode == 0,
           "cheng backend driver command surface: oracle-fixture-query rc")
    assert(strings.StrContains(oracleQueryOutput, "format=cheng_oracle_fixture_query_v1"),
           "cheng backend driver command surface: oracle-fixture-query format")
    assert(strings.StrContains(oracleQueryOutput, "pair=BTC/USD"),
           "cheng backend driver command surface: oracle-fixture-query pair")
    assert(strings.StrContains(oracleQueryOutput, "latest_code=0"),
           "cheng backend driver command surface: oracle-fixture-query latest")
    assert(strings.StrContains(oracleQueryOutput, "twap_code=0"),
           "cheng backend driver command surface: oracle-fixture-query twap")
    assert(strings.StrContains(oracleQueryOutput, "stale_code=9"),
           "cheng backend driver command surface: oracle-fixture-query stale")

    let chainNodeBuildLog = v3path.V3PathJoin(outDir, "build_chain_node.log")
    if v3path.V3PathFileExists(chainNodeBuildLog):
        os.RemoveFile(chainNodeBuildLog)
    let chainNodeBuildRun = hostops.v3RunFileLogged(root,
                                                    "backend_driver_surface_build_chain_node",
                                                    driver,
                                                    ["build-chain-node"],
                                                    ["CHENG_CHAIN_NODE_COMPILE_TIMEOUT_SEC=900"],
                                                    root,
                                                    960,
                                                    chainNodeBuildLog)
    let chainNodeBuildOutput: str = chainNodeBuildRun.output
    assert(chainNodeBuildRun.exitCode == 0,
           "cheng backend driver command surface: build-chain-node rc")
    assert(strings.StrContains(chainNodeBuildOutput, "cheng chain_node self-test ok"),
           "cheng backend driver command surface: build-chain-node self-test")

    echo("cheng backend_driver_command_surface_smoke ok")
    return 0
