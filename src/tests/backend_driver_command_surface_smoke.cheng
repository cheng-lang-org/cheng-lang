import std/strings
import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let driver: str = os.JoinPath(root, "artifacts/backend_driver/cheng")
    assert(os.FileExists(driver), "cheng backend driver command surface: backend_driver exists")
    let outDir = chengpath.PathAbsolute(root, "artifacts/backend_driver_command_surface_smoke")
    assert(chengpath.MkdirP(root, outDir), "cheng backend driver command surface: mkdir")

    let helpLog = chengpath.PathJoin(outDir, "help.log")
    if chengpath.PathFileExists(helpLog):
        os.RemoveFile(helpLog)
    let helpRun = hostops.RunFileLogged(root,
                                          "backend_driver_surface_help",
                                          driver,
                                          ["help"],
                                          [],
                                          root,
                                          0,
                                          helpLog)
    let helpOutput: str = helpRun.output
    assert(helpRun.exitCode == 0, "cheng backend driver command surface: help rc")
    assert(strings.StrContains(helpOutput, "usage: cheng <command> [args]"),
           "cheng backend driver command surface: help usage")
    assert(strings.StrContains(helpOutput, "core commands: status, print-build-plan, host-bridge-audit, system-link-exec"),
           "cheng backend driver command surface: help core commands")
    assert(strings.StrContains(helpOutput, "world/proof commands: world-receipt"),
           "cheng backend driver command surface: help world proof commands")
    assert(strings.StrContains(helpOutput, "debug commands:"),
           "cheng backend driver command surface: help debug section")
    assert(strings.StrContains(helpOutput, "debug-report") &&
           strings.StrContains(helpOutput, "print-symbols") &&
           strings.StrContains(helpOutput, "print-line-map") &&
           strings.StrContains(helpOutput, "print-asm"),
           "cheng backend driver command surface: help core debug commands")
    assert(strings.StrContains(helpOutput, "verify commands:"),
           "cheng backend driver command surface: help verify section")
    assert(strings.StrContains(helpOutput, "verify-export-visibility") &&
           strings.StrContains(helpOutput, "verify-backend-driver-command-surface") &&
           strings.StrContains(helpOutput, "verify-mobile-shell-build-probe") &&
           strings.StrContains(helpOutput, "verify-r2c-react-surface") &&
           strings.StrContains(helpOutput, "verify-debug-tools") &&
           strings.StrContains(helpOutput, "verify-debug-runtime"),
           "cheng backend driver command surface: help core verify commands")
    assert(strings.StrContains(helpOutput, "gate commands:") &&
           strings.StrContains(helpOutput, "run-host-smokes") &&
           strings.StrContains(helpOutput, "run-stage23-libp2p-smokes") &&
           strings.StrContains(helpOutput, "run-production-regression") &&
           strings.StrContains(helpOutput, "slice-gate"),
           "cheng backend driver command surface: help gate commands")

    let statusLog = chengpath.PathJoin(outDir, "status.log")
    if chengpath.PathFileExists(statusLog):
        os.RemoveFile(statusLog)
    let statusRun = hostops.RunFileLogged(root,
                                            "backend_driver_surface_status",
                                            driver,
                                            ["status"],
                                            [],
                                            root,
                                            0,
                                            statusLog)
    let statusOutput: str = statusRun.output
    assert(statusRun.exitCode == 0, "cheng backend driver command surface: status rc")
    assert(strings.StrContains(statusOutput, "compiler_entry="),
           "cheng backend driver command surface: status compiler entry")
    assert(strings.StrContains(statusOutput, "/src/core/tooling/backend_driver_main.cheng"),
           "cheng backend driver command surface: status core entry")

    echo("cheng backend_driver_command_surface_smoke ok")
    return 0
