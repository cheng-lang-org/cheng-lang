import std/system
import std/strings
import cheng/mobile/mobile_capi as capi
import cheng/mobile/android_bridge as mobile

fn main(): int32 =
    let selfPeer = capi.MobileCapiPeerIdFromSeed("mobile.bridge.self")
    assert(len(selfPeer) > 0, " mobile bridge: self peer")
    assert(strings.HasPrefix(selfPeer, "12D3Koo"), " mobile bridge: standard self peer")
    assert(capi.MobileCapiMultiaddrNormalize("/ip4/127.0.0.1/tcp/9001") == "/ip4/127.0.0.1/tcp/9001",
        " mobile bridge: normalize addr")
    assert(capi.MobileCapiMultiaddrNormalize("not-a-multiaddr") == "",
        " mobile bridge: reject bad addr")
    let capiDialable = capi.MobileCapiDialableAddr("/ip4/127.0.0.1/tcp/9001", selfPeer)
    assert(strContains(capiDialable, "/ip4/127.0.0.1/tcp/9001"),
        " mobile bridge: capi dialable base")
    assert(strContains(capiDialable, "/p2p/"),
        " mobile bridge: capi dialable peer suffix")

    var host = mobile.MobileHostInit("mobile.bridge.self")
    assert(mobile.MobileHostPeerIdText(host) == selfPeer,
        " mobile bridge: host peer id")
    assert(!mobile.MobileHostIsStarted(host),
        " mobile bridge: init stopped")

    mobile.MobileHostStart(host)
    mobile.MobileHostSetMdnsEnabled(host, true)
    mobile.MobileHostSetMdnsInterval(host, 9)
    mobile.MobileHostSetTrustedInfra(host, true)
    assert(mobile.MobileHostIsStarted(host),
        " mobile bridge: started")
    assert(mobile.MobileHostMdnsEnabled(host),
        " mobile bridge: mdns enabled")
    assert(mobile.MobileHostMdnsInterval(host) == 9,
        " mobile bridge: mdns interval")
    assert(mobile.MobileHostTrustedInfra(host),
        " mobile bridge: trusted infra")

    let listenRes = mobile.MobileHostListenAddText(host, "/ip4/127.0.0.1/tcp/9001")
    assert(IsOk(listenRes), " mobile bridge: listen add")
    assert(mobile.MobileHostListenAddrCount(host) == 1,
        " mobile bridge: listen count")
    let listenDialable = mobile.MobileHostDialableAddrTextAt(host, 0)
    assert(strContains(listenDialable, "/ip4/127.0.0.1/tcp/9001"),
        " mobile bridge: listen dialable base")
    assert(strContains(listenDialable, "/p2p/"),
        " mobile bridge: listen dialable peer suffix")

    let bootstrapPeer = capi.MobileCapiPeerIdFromSeed("mobile.bridge.bootstrap")
    assert(strings.HasPrefix(bootstrapPeer, "12D3Koo"), " mobile bridge: standard bootstrap peer")
    let bootstrapRes = mobile.MobileHostRegisterPeerHintText(host,
                                                               bootstrapPeer,
                                                               "/ip4/100.64.0.7/tcp/9101",
                                                               0,
                                                               true,
                                                               true)
    assert(IsOk(bootstrapRes), " mobile bridge: bootstrap register")
    assert(mobile.MobileHostPeerCount(host) == 1,
        " mobile bridge: peer count")
    assert(mobile.MobileHostBootstrapPeerCount(host) == 1,
        " mobile bridge: bootstrap count")
    let bootstrapPeerText = mobile.MobileHostBootstrapPeerTextAt(host, 0)
    assert(len(bootstrapPeerText) > 0,
        " mobile bridge: bootstrap text")
    assert(mobile.MobileHostPeerAddrCountText(host, bootstrapPeer) == 1,
        " mobile bridge: peer addr count")
    assert(mobile.MobileHostPeerAddrTextAt(host, bootstrapPeer, 0) == "/ip4/100.64.0.7/tcp/9101",
        " mobile bridge: peer addr text")
    let bootstrapDialable = mobile.MobileHostPeerDialableAddrTextAt(host, bootstrapPeer, 0)
    assert(strContains(bootstrapDialable, "/ip4/100.64.0.7/tcp/9101"),
        " mobile bridge: peer dialable base")
    assert(strContains(bootstrapDialable, "/p2p/"),
        " mobile bridge: peer dialable peer suffix")

    let connectRes = mobile.MobileHostConnectRegisteredText(host, bootstrapPeer)
    assert(IsOk(connectRes), " mobile bridge: connect bootstrap")
    assert(mobile.MobileHostIsPeerConnectedText(host, bootstrapPeer),
        " mobile bridge: connected")
    assert(mobile.MobileHostConnectedPeerCount(host) == 1,
        " mobile bridge: connected count")
    let connectedPeerText = mobile.MobileHostConnectedPeerTextAt(host, 0)
    assert(len(connectedPeerText) > 0,
        " mobile bridge: connected peer text")

    assert(mobile.MobileHostDisconnectText(host, bootstrapPeer),
        " mobile bridge: disconnect")
    assert(!mobile.MobileHostIsPeerConnectedText(host, bootstrapPeer),
        " mobile bridge: disconnected")
    assert(mobile.MobileHostReconnectBootstrap(host) == 1,
        " mobile bridge: reconnect bootstrap")
    assert(mobile.MobileHostIsPeerConnectedText(host, bootstrapPeer),
        " mobile bridge: reconnect restored")

    let adhocPeer = capi.MobileCapiPeerIdFromSeed("mobile.bridge.adhoc")
    let adhocRes = mobile.MobileHostConnectPreferredText(host,
                                                           adhocPeer,
                                                           "/ip4/127.0.0.1/tcp/9202")
    assert(IsOk(adhocRes), " mobile bridge: adhoc connect")
    assert(mobile.MobileHostPeerCount(host) == 2,
        " mobile bridge: adhoc peer count")
    let adhocDialable = mobile.MobileHostPeerDialableAddrTextAt(host, adhocPeer, 0)
    assert(strContains(adhocDialable, "/ip4/127.0.0.1/tcp/9202"),
        " mobile bridge: adhoc dialable base")
    assert(strContains(adhocDialable, "/p2p/"),
        " mobile bridge: adhoc dialable peer suffix")

    mobile.MobileHostStop(host)
    assert(!mobile.MobileHostIsStarted(host),
        " mobile bridge: stopped")

    echo(" mobile_bridge_smoke ok")
    return 0
