import std/system
import std/os as os
import std/strings
import std/strutils as strutil
import std/rawbytes
import std/seqs
import std/json as json
import std/hashmaps as hashmaps

fn perfEnvInt(name: str, defaultValue: int32): int32 =
    let raw: str = os.GetEnvDefault(name, "")
    if len(raw) <= 0:
        return defaultValue
    var value: int32 = 0
    var i: int32 = 0
    while i < len(raw):
        let ch: char = raw[i]
        if ch < '0' || ch > '9':
            return defaultValue
        value = value * 10 + (int32(ch) - int32('0'))
        i = i + 1
    return value

fn perfStringsCase(iterations: int32): int32 =
    var total: int32 = 0
    var i: int32 = 0
    while i < iterations:
        let parts: str[] = strutil.Split(" alpha beta gamma ", ' ')
        let joined: str = strutil.Join(parts, "-")
        let upper: str = strutil.ToUpperAscii(strutil.Strip(joined))
        total = total + len(upper)
        i = i + 1
    return total

fn perfStrformatCase(iterations: int32): int32 =
    var total: int32 = 0
    var i: int32 = 0
    while i < iterations:
        let tail: str = intToStr(i & 7)
        let parts: str[] = ["cheng", "-", "bench", "-", tail]
        let rendered: str = Fmt(parts)
        total = total + len(rendered)
        i = i + 1
    return total

fn perfRawbytesCase(iterations: int32): int32 =
    var total: int32 = 0
    var i: int32 = 0
    while i < iterations:
        let payload: Bytes = bytesFromString("rawbytes-bench")
        let head: Bytes = bytesSlice(payload, 0, 8)
        total = total + bytesLen(head)
        total = total + bytesGet(head, 0)
        total = total + len(bytesToString(head))
        i = i + 1
    return total

fn perfSeqsCase(iterations: int32): int32 =
    var total: int32 = 0
    var i: int32 = 0
    while i < iterations:
        var nums: int32[] = []
        var j: int32 = 0
        while j < 8:
            seqs.Add(nums, i + j)
            j = j + 1
        total = total + nums.len + nums[0] + nums[nums.len - 1]
        i = i + 1
    return total

fn perfJsonCase(iterations: int32): int32 =
    var total: int32 = 0
    var i: int32 = 0
    while i < iterations:
        var root: json.JsonNode = json.NewJObject()
        json.JsonSetField(root, "name", "cheng")
        json.JsonSetField(root, "ok", true)
        json.JsonSetField(root, "n", int64(i))
        let rendered: str = json.Pretty(root)
        total = total + len(rendered)
        total = total + json.GetInt(root["n"], 0)
        i = i + 1
    return total

fn perfHashmapsCase(iterations: int32): int32 =
    var total: int32 = 0
    var i: int32 = 0
    while i < iterations:
        var m: hashmaps.HashMapStrInt = hashmaps.HashMapStrIntInit(16)
        var found: bool = false
        hashmaps.HashMapStrIntPut(m, "alpha", i)
        hashmaps.HashMapStrIntPut(m, "beta", i + 1)
        hashmaps.HashMapStrIntPut(m, "gamma", i + 2)
        total = total + hashmaps.HashMapStrIntGetEx(m, "gamma", found)
        i = i + 1
    return total

fn main() =
    let caseName: str = os.GetEnvDefault("STD_PERF_CASE", "strings")
    let iterations: int32 = perfEnvInt("STD_PERF_ITERS", 400)
    var checksum: int32 = 0
    if caseName == "strings":
        checksum = perfStringsCase(iterations)
    elif caseName == "strformat":
        checksum = perfStrformatCase(iterations)
    elif caseName == "rawbytes":
        checksum = perfRawbytesCase(iterations)
    elif caseName == "seqs":
        checksum = perfSeqsCase(iterations)
    elif caseName == "json":
        checksum = perfJsonCase(iterations)
    elif caseName == "hashmaps":
        checksum = perfHashmapsCase(iterations)
    else:
        assert(false, "unknown std perf case")
    echo(intToStr(checksum))
