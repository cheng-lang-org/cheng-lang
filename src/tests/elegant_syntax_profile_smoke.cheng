import cheng/core/tooling/path as v3path

fn main(): int32 =
    let root = v3path.V3PathCurrentDir()
    let parserPath = v3path.V3PathJoin(root, "src/stage1/parser.cheng")
    let specPath = v3path.V3PathJoin(root, "docs/cheng-formal-spec.md")
    let skillPath = v3path.V3PathJoin(root, "docs/cheng-skill/SKILL.md")
    let grammarPath = v3path.V3PathJoin(root, "docs/cheng-skill/references/grammar.md")

    assert(v3path.V3FileExistsNonEmpty(root, parserPath), "elegant syntax: parser exists")
    assert(v3path.V3FileExistsNonEmpty(root, specPath), "elegant syntax: spec exists")
    assert(v3path.V3FileExistsNonEmpty(root, skillPath), "elegant syntax: skill exists")
    assert(v3path.V3FileExistsNonEmpty(root, grammarPath), "elegant syntax: grammar exists")

    let parserText = v3path.V3ReadTextFile("", parserPath)
    let specText = v3path.V3ReadTextFile("", specPath)
    let skillText = v3path.V3ReadTextFile("", skillPath)
    let grammarText = v3path.V3ReadTextFile("", grammarPath)

    assert(v3path.V3TextContains(parserText, "CHENG_STRICT_CALL_SYNTAX"),
           "elegant syntax: strict call env")
    assert(v3path.V3TextContains(parserText, "parserRejectSpaceCallIfStrict"),
           "elegant syntax: strict space-call reject hook")
    assert(v3path.V3TextContains(parserText, "Space call syntax is removed in the elegant syntax profile; use f(x)"),
           "elegant syntax: strict diagnostic")
    assert(!v3path.V3TextContains(parserText, "use 'f x'"),
           "elegant syntax: parser must not recommend legacy space call")
    assert(v3path.V3TextContains(specText, "调用语法统一使用小括号"),
           "elegant syntax: formal spec canonical call")
    assert(v3path.V3TextContains(specText, "CHENG_STRICT_CALL_SYNTAX=1"),
           "elegant syntax: formal spec strict gate")
    assert(v3path.V3TextContains(skillText, "单参数调用统一写 `f(x)`"),
           "elegant syntax: skill canonical call")
    assert(v3path.V3TextContains(grammarText, "旧空格单参调用"),
           "elegant syntax: grammar legacy call")
    echo("v3 elegant_syntax_profile_smoke ok")
    return 0
