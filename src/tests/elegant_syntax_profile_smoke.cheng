import std/os as os
import std/strings as strings

fn main(): int32 =
    let parserPath: str = "src/core/lang/parser.cheng"
    let specPath: str = "docs/cheng-formal-spec.md"
    let skillPath: str = "docs/cheng-skill/SKILL.md"
    let grammarPath: str = "docs/cheng-skill/references/grammar.md"
    let strictNegativePath: str = "src/tests/elegant_syntax_strict_call_negative_smoke.cheng"
    let strictNegativeFixturePath: str = "src/tests/elegant_syntax_strict_call_negative_space_call.cheng"

    assert(os.FileExists(parserPath) && os.FileSize(parserPath) > int64(0),
           "elegant syntax: parser exists")
    assert(os.FileExists(specPath) && os.FileSize(specPath) > int64(0),
           "elegant syntax: spec exists")
    assert(os.FileExists(skillPath) && os.FileSize(skillPath) > int64(0),
           "elegant syntax: skill exists")
    assert(os.FileExists(grammarPath) && os.FileSize(grammarPath) > int64(0),
           "elegant syntax: grammar exists")
    assert(os.FileExists(strictNegativePath) && os.FileSize(strictNegativePath) > int64(0),
           "elegant syntax: strict negative smoke exists")
    assert(os.FileExists(strictNegativeFixturePath) && os.FileSize(strictNegativeFixturePath) > int64(0),
           "elegant syntax: strict negative fixture exists")

    let parserText: str = os.ReadFile(parserPath)
    let specText: str = os.ReadFile(specPath)
    let skillText: str = os.ReadFile(skillPath)
    let grammarText: str = os.ReadFile(grammarPath)
    let strictNegativeText: str = os.ReadFile(strictNegativePath)
    let strictNegativeFixtureText: str = os.ReadFile(strictNegativeFixturePath)

    assert(strings.StrContains(parserText, "CHENG_STRICT_CALL_SYNTAX"),
           "elegant syntax: strict call env")
    assert(strings.StrContains(parserText, "ParserRejectSpaceCallIfStrict"),
           "elegant syntax: strict space-call reject hook")
    assert(strings.StrContains(parserText, "Space call syntax is removed in the elegant syntax profile; use f(x)"),
           "elegant syntax: strict diagnostic")
    assert(!strings.StrContains(parserText, "use 'f x'"),
           "elegant syntax: parser must not recommend legacy space call")
    assert(strings.StrContains(specText, "调用语法统一使用小括号"),
           "elegant syntax: formal spec canonical call")
    assert(strings.StrContains(specText, "CHENG_STRICT_CALL_SYNTAX=1"),
           "elegant syntax: formal spec strict gate")
    assert(strings.StrContains(skillText, "单参数调用统一写 `f(x)`"),
           "elegant syntax: skill canonical call")
    assert(strings.StrContains(grammarText, "旧空格单参调用"),
           "elegant syntax: grammar legacy call")
    assert(strings.StrContains(strictNegativeText, "CHENG_STRICT_CALL_SYNTAX=1"),
           "elegant syntax: strict negative env")
    assert(strings.StrContains(strictNegativeText, "expected space call rejection"),
           "elegant syntax: strict negative rejection")
    assert(strings.StrContains(strictNegativeFixtureText, "identity 1"),
           "elegant syntax: strict negative fixture uses legacy space call")

    echo(" elegant_syntax_profile_smoke ok")
    return 0
