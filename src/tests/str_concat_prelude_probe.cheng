import std/os
import cheng/core/tooling/path as chengpath

fn StrConcatLoweringFlag(prefix: str, value: str): str =
    var parts: str[]
    add(parts, prefix)
    add(parts, value)
    return Fmt(parts)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let compilerEnv = os.GetEnv("CHENG_SMOKE_COMPILER")
    var compilerRaw = "artifacts/bootstrap/cheng.stage3"
    if len(compilerEnv) > 0:
        compilerRaw = compilerEnv
    var driver = compilerRaw
    if !os.IsAbsolute(compilerRaw):
        driver = os.JoinPath(root, compilerRaw)
    let target = os.GetEnvDefault("CHENG_RUNTIME_LINK_TARGET", "arm64-apple-darwin")
    let outDir = chengpath.PathAbsolute(root, "artifacts/str_concat_lowering_smoke")
    let sourcePath = os.JoinPath(root, "src/tests/str_concat_lowering_fixture.cheng")
    let outBin = os.JoinPath(outDir, "str_concat_lowering_probe")
    let exeReportPath = os.JoinPath(outDir, "str_concat_lowering_probe.compile.report.txt")
    let exeCompileLog = os.JoinPath(outDir, "str_concat_lowering_probe.compile.log")
    let exeRunLog = os.JoinPath(outDir, "str_concat_lowering_probe.run.log")
    assert(chengpath.MkdirP(root, outDir), " prelude probe: mkdir")
    assert(os.FileExists(driver), " prelude probe: compiler exists")
    let missingA = os.JoinPath(outDir, "missing-a.tmp")
    let missingB = os.JoinPath(outDir, "missing-b.tmp")
    let missingC = os.JoinPath(outDir, "missing-c.tmp")
    assert(!chengpath.PathFileExists(missingA), " prelude probe: missing a")
    assert(!chengpath.PathFileExists(missingB), " prelude probe: missing b")
    assert(!chengpath.PathFileExists(missingC), " prelude probe: missing c")
    echo(StrConcatLoweringFlag("--root:", root))
    echo(StrConcatLoweringFlag("--driver:", driver))
    echo(StrConcatLoweringFlag("--target:", target))
    echo(StrConcatLoweringFlag("--outdir:", outDir))
    echo(StrConcatLoweringFlag("--source:", sourcePath))
    echo(StrConcatLoweringFlag("--out:", outBin))
    echo(StrConcatLoweringFlag("--report:", exeReportPath))
    echo(StrConcatLoweringFlag("--compile-log:", exeCompileLog))
    echo(StrConcatLoweringFlag("--run-log:", exeRunLog))
    echo(" str_concat_prelude_probe ok")
    return 0
