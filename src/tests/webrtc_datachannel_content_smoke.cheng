import std/system
import std/rawbytes
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_fetch as fetch
import cheng/chain/content_runtime as runtime
import cheng/chain/content_runtime_host_webrtc as runtime_host
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/protocols/webrtc_signal as signal
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/host/host

fn webrtcContentBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    webrtc_transport.v3Libp2pWebrtcTransportResetStats()
    let shard = bytesFromString("webrtc-shard")
    let blob = shard
    let summaryRes = dag.v3DagBlobSummaryFromBytes(blob, bytesLen(shard))
    assert(IsOk(summaryRes), "v3 webrtc datachannel content: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.v3ErasureEncodingParamsMake(swarm.v3ErasureLayoutRsSystematic, 1, 0, bytesLen(shard))
    assert(IsOk(paramsRes), "v3 webrtc datachannel content: params")
    let params = Value(paramsRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    add(shardPayloadCids, swarm.v3ErasureShardPayloadCid(shard))
    let manifestRes = swarm.v3ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), "v3 webrtc datachannel content: manifest")
    let manifest = Value(manifestRes)
    let requestRes = swarm.v3ErasureShardPullRequestMake(manifest, 0)
    assert(IsOk(requestRes), "v3 webrtc datachannel content: request")
    let request = Value(requestRes)

    var serverRuntime = runtime.v3ContentRuntimeInit()
    let storeManifestRes = runtime.v3ContentRuntimeStoreManifest(serverRuntime, manifest)
    assert(IsOk(storeManifestRes), "v3 webrtc datachannel content: store manifest")
    let storeBlobRes = runtime.v3ContentRuntimeStoreBlobPayload(serverRuntime, summary.blobCid, blob)
    assert(IsOk(storeBlobRes), "v3 webrtc datachannel content: store blob")
    let seedResponseRes = swarm.v3ErasureShardPullResponseMake(request, shard)
    assert(IsOk(seedResponseRes), "v3 webrtc datachannel content: seed response")
    let seedStoreRes = runtime.v3ContentRuntimeStoreShardResponse(serverRuntime, Value(seedResponseRes))
    assert(IsOk(seedStoreRes), "v3 webrtc datachannel content: store shard")

    var server = host.v3Libp2pHostInit("content.webrtc.server")
    var client = host.v3Libp2pHostInit("content.webrtc.client")
    var listenAddr: types.V3Libp2pMultiaddr
    listenAddr.host = "203.0.113.111"
    listenAddr.port = 9888
    listenAddr.transport = types.v3Libp2pTransportWebrtc
    listenAddr.networkDomain = types.v3Libp2pNetworkDomainBrowserWebrtc
    listenAddr.visibility = types.v3Libp2pVisibilityPublic
    let listenRes = host.v3Libp2pListen(server, listenAddr)
    assert(listenRes.ok, "v3 webrtc datachannel content: listen")

    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolContent)
    host.v3Libp2pRegisterHandler(client, types.v3Libp2pProtocolContent)
    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolWebrtcSignal)
    host.v3Libp2pRegisterHandler(client, types.v3Libp2pProtocolWebrtcSignal)
    let dialRes = host.v3Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 webrtc datachannel content: dial")

    let manifestFetchReqRes = fetch.v3ContentFetchRequestManifest(manifest.manifestCid)
    assert(IsOk(manifestFetchReqRes), "v3 webrtc datachannel content: manifest request")
    let manifestFetchRequest = Value(manifestFetchReqRes)
    let manifestFetchRes = runtime_host.v3ContentRuntimeRequestFetch(client,
                                                                     server,
                                                                     server.selfPeerId,
                                                                     serverRuntime,
                                                                     manifestFetchRequest)
    assert(IsOk(manifestFetchRes), "v3 webrtc datachannel content: manifest fetch")
    var manifestPull = swarm.V3ErasureShardManifest()
    let manifestPullRes = fetch.v3ContentFetchResponseToManifestFill(manifestPull,
                                                                     manifestFetchRequest,
                                                                     Value(manifestFetchRes))
    assert(IsOk(manifestPullRes), "v3 webrtc datachannel content: manifest pull")
    assert(layout.fixedBytes32Equal(manifestPull.manifestCid, manifest.manifestCid),
        "v3 webrtc datachannel content: manifest cid")
    assert(host.v3Libp2pWebrtcSignalEgressCount(client) == 5,
        "v3 webrtc datachannel content: manifest signal egress")
    assert(host.v3Libp2pWebrtcSignalIngressCount(server) == 5,
        "v3 webrtc datachannel content: manifest signal ingress")
    assert(webrtc_transport.v3Libp2pWebrtcNativeDatachannelRequestCountNow() == 1,
        "v3 webrtc datachannel content: manifest native count")
    assert(webrtc_transport.v3Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        "v3 webrtc datachannel content: manifest loopback count")

    let rangeReqRes = fetch.v3ContentFetchRequestRange(summary.blobCid, 0, 6)
    assert(IsOk(rangeReqRes), "v3 webrtc datachannel content: range request")
    let rangeFetchRes = runtime_host.v3ContentRuntimeRequestFetch(client,
                                                                  server,
                                                                  server.selfPeerId,
                                                                  serverRuntime,
                                                                  Value(rangeReqRes))
    assert(IsOk(rangeFetchRes), "v3 webrtc datachannel content: range fetch")
    let rangeFetch = Value(rangeFetchRes)
    assert(webrtcContentBytesEqual(rangeFetch.payload, bytesSlice(blob, 0, 6)),
        "v3 webrtc datachannel content: range bytes")
    assert(webrtc_transport.v3Libp2pWebrtcNativeDatachannelRequestCountNow() == 2,
        "v3 webrtc datachannel content: range native count")
    assert(webrtc_transport.v3Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        "v3 webrtc datachannel content: range loopback count")

    let pullRes = runtime_host.v3ContentRuntimeRequestShardPull(client,
                                                                server,
                                                                server.selfPeerId,
                                                                serverRuntime,
                                                                request)
    assert(IsOk(pullRes), "v3 webrtc datachannel content: pull")
    let response = Value(pullRes)
    assert(layout.fixedBytes32Equal(response.shardCid, request.shardCid),
        "v3 webrtc datachannel content: shard cid")
    assert(webrtcContentBytesEqual(response.payload, shard),
        "v3 webrtc datachannel content: shard payload")
    assert(webrtc_transport.v3Libp2pWebrtcNativeDatachannelRequestCountNow() == 3,
        "v3 webrtc datachannel content: shard native count")
    assert(webrtc_transport.v3Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        "v3 webrtc datachannel content: shard loopback count")

    let rebuildRes = runtime.v3ContentRuntimeRebuildBlob(manifest, params, [response])
    assert(IsOk(rebuildRes), "v3 webrtc datachannel content: rebuild")
    assert(webrtcContentBytesEqual(Value(rebuildRes), blob),
        "v3 webrtc datachannel content: rebuild bytes")

    let clientFirstSignalRes = signal.v3Libp2pWebrtcSignalDecode(client.webrtcSignalEgressPayloads[0])
    let serverFirstSignalRes = signal.v3Libp2pWebrtcSignalDecode(server.webrtcSignalIngressPayloads[0])
    assert(IsOk(clientFirstSignalRes), "v3 webrtc datachannel content: client first signal")
    assert(IsOk(serverFirstSignalRes), "v3 webrtc datachannel content: server first signal")
    assert(layout.fixedBytes32Equal(Value(clientFirstSignalRes).sessionId, Value(serverFirstSignalRes).sessionId),
        "v3 webrtc datachannel content: first session match")
    let clientLastSignalRes = signal.v3Libp2pWebrtcSignalDecode(client.webrtcSignalEgressPayloads[14])
    let serverLastSignalRes = signal.v3Libp2pWebrtcSignalDecode(server.webrtcSignalIngressPayloads[14])
    assert(IsOk(clientLastSignalRes), "v3 webrtc datachannel content: client last signal")
    assert(IsOk(serverLastSignalRes), "v3 webrtc datachannel content: server last signal")
    assert(layout.fixedBytes32Equal(Value(clientLastSignalRes).sessionId, Value(serverLastSignalRes).sessionId),
        "v3 webrtc datachannel content: last session match")

    echo("v3 webrtc_datachannel_content_smoke ok")
    return 0
