import std/system
import std/rawbytes
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_fetch as fetch
import cheng/chain/content_runtime as runtime
import cheng/chain/content_runtime_host_webrtc as runtime_host
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/protocols/webrtc_signal as signal
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/host/host

fn webrtcContentBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    webrtc_transport.Libp2pWebrtcTransportResetStats()
    let shard = bytesFromString("webrtc-shard")
    let blob = shard
    let summaryRes = dag.DagBlobSummaryFromBytes(blob, bytesLen(shard))
    assert(IsOk(summaryRes), " webrtc datachannel content: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic, 1, 0, bytesLen(shard))
    assert(IsOk(paramsRes), " webrtc datachannel content: params")
    let params = Value(paramsRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard))
    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), " webrtc datachannel content: manifest")
    let manifest = Value(manifestRes)
    let requestRes = swarm.ErasureShardPullRequestMake(manifest, 0)
    assert(IsOk(requestRes), " webrtc datachannel content: request")
    let request = Value(requestRes)

    var serverRuntime = runtime.ContentRuntimeInit()
    let storeManifestRes = runtime.ContentRuntimeStoreManifest(serverRuntime, manifest)
    assert(IsOk(storeManifestRes), " webrtc datachannel content: store manifest")
    let storeBlobRes = runtime.ContentRuntimeStoreBlobPayload(serverRuntime, summary.blobCid, blob)
    assert(IsOk(storeBlobRes), " webrtc datachannel content: store blob")
    let seedResponseRes = swarm.ErasureShardPullResponseMake(request, shard)
    assert(IsOk(seedResponseRes), " webrtc datachannel content: seed response")
    let seedStoreRes = runtime.ContentRuntimeStoreShardResponse(serverRuntime, Value(seedResponseRes))
    assert(IsOk(seedStoreRes), " webrtc datachannel content: store shard")

    var server = host.Libp2pHostInit("content.webrtc.server")
    var client = host.Libp2pHostInit("content.webrtc.client")
    var listenAddr: types.Libp2pMultiaddr
    listenAddr.host = "203.0.113.111"
    listenAddr.port = 9888
    listenAddr.transport = types.Libp2pTransportWebrtc
    listenAddr.networkDomain = types.Libp2pNetworkDomainBrowserWebrtc
    listenAddr.visibility = types.Libp2pVisibilityPublic
    let listenRes = host.Libp2pListen(server, listenAddr)
    assert(listenRes.ok, " webrtc datachannel content: listen")

    host.Libp2pRegisterHandler(server, types.Libp2pProtocolContent)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolContent)
    host.Libp2pRegisterHandler(server, types.Libp2pProtocolWebrtcSignal)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolWebrtcSignal)
    let dialRes = host.Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " webrtc datachannel content: dial")

    let manifestFetchReqRes = fetch.ContentFetchRequestManifest(manifest.manifestCid)
    assert(IsOk(manifestFetchReqRes), " webrtc datachannel content: manifest request")
    let manifestFetchRequest = Value(manifestFetchReqRes)
    let manifestFetchRes = runtime_host.ContentRuntimeRequestFetch(client,
                                                                     server,
                                                                     server.selfPeerId,
                                                                     serverRuntime,
                                                                     manifestFetchRequest)
    assert(IsOk(manifestFetchRes), " webrtc datachannel content: manifest fetch")
    var manifestPull = swarm.ErasureShardManifest()
    let manifestPullRes = fetch.ContentFetchResponseToManifestFill(manifestPull,
                                                                     manifestFetchRequest,
                                                                     Value(manifestFetchRes))
    assert(IsOk(manifestPullRes), " webrtc datachannel content: manifest pull")
    assert(layout.fixedBytes32Equal(manifestPull.manifestCid, manifest.manifestCid),
        " webrtc datachannel content: manifest cid")
    assert(host.Libp2pWebrtcSignalEgressCount(client) == 5,
        " webrtc datachannel content: manifest signal egress")
    assert(host.Libp2pWebrtcSignalIngressCount(server) == 5,
        " webrtc datachannel content: manifest signal ingress")
    assert(webrtc_transport.Libp2pWebrtcNativeDatachannelRequestCountNow() == 1,
        " webrtc datachannel content: manifest native count")
    assert(webrtc_transport.Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        " webrtc datachannel content: manifest loopback count")

    let rangeReqRes = fetch.ContentFetchRequestRange(summary.blobCid, 0, 6)
    assert(IsOk(rangeReqRes), " webrtc datachannel content: range request")
    let rangeFetchRes = runtime_host.ContentRuntimeRequestFetch(client,
                                                                  server,
                                                                  server.selfPeerId,
                                                                  serverRuntime,
                                                                  Value(rangeReqRes))
    assert(IsOk(rangeFetchRes), " webrtc datachannel content: range fetch")
    let rangeFetch = Value(rangeFetchRes)
    assert(webrtcContentBytesEqual(rangeFetch.payload, bytesSlice(blob, 0, 6)),
        " webrtc datachannel content: range bytes")
    assert(webrtc_transport.Libp2pWebrtcNativeDatachannelRequestCountNow() == 2,
        " webrtc datachannel content: range native count")
    assert(webrtc_transport.Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        " webrtc datachannel content: range loopback count")

    let pullRes = runtime_host.ContentRuntimeRequestShardPull(client,
                                                                server,
                                                                server.selfPeerId,
                                                                serverRuntime,
                                                                request)
    assert(IsOk(pullRes), " webrtc datachannel content: pull")
    let response = Value(pullRes)
    assert(layout.fixedBytes32Equal(response.shardCid, request.shardCid),
        " webrtc datachannel content: shard cid")
    assert(webrtcContentBytesEqual(response.payload, shard),
        " webrtc datachannel content: shard payload")
    assert(webrtc_transport.Libp2pWebrtcNativeDatachannelRequestCountNow() == 3,
        " webrtc datachannel content: shard native count")
    assert(webrtc_transport.Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        " webrtc datachannel content: shard loopback count")

    let rebuildRes = runtime.ContentRuntimeRebuildBlob(manifest, params, [response])
    assert(IsOk(rebuildRes), " webrtc datachannel content: rebuild")
    assert(webrtcContentBytesEqual(Value(rebuildRes), blob),
        " webrtc datachannel content: rebuild bytes")

    let clientFirstSignalRes = signal.Libp2pWebrtcSignalDecode(client.webrtcSignalEgressPayloads[0])
    let serverFirstSignalRes = signal.Libp2pWebrtcSignalDecode(server.webrtcSignalIngressPayloads[0])
    assert(IsOk(clientFirstSignalRes), " webrtc datachannel content: client first signal")
    assert(IsOk(serverFirstSignalRes), " webrtc datachannel content: server first signal")
    assert(layout.fixedBytes32Equal(Value(clientFirstSignalRes).sessionId, Value(serverFirstSignalRes).sessionId),
        " webrtc datachannel content: first session match")
    let clientLastSignalRes = signal.Libp2pWebrtcSignalDecode(client.webrtcSignalEgressPayloads[14])
    let serverLastSignalRes = signal.Libp2pWebrtcSignalDecode(server.webrtcSignalIngressPayloads[14])
    assert(IsOk(clientLastSignalRes), " webrtc datachannel content: client last signal")
    assert(IsOk(serverLastSignalRes), " webrtc datachannel content: server last signal")
    assert(layout.fixedBytes32Equal(Value(clientLastSignalRes).sessionId, Value(serverLastSignalRes).sessionId),
        " webrtc datachannel content: last session match")

    echo(" webrtc_datachannel_content_smoke ok")
    return 0
