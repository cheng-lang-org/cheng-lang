import std/system
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/binary_types as binary
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/protocols/gossipsub as gossip
import cheng/libp2p/protocols/webrtc_signal as signal
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/host/host

fn smokePubsubAddress(): binary.V3LsmrAddress =
    var out: binary.V3LsmrAddress
    out.depth = 2
    out.digits[0] = 5
    out.digits[1] = 1
    return out

fn main(): int32 =
    webrtc_transport.v3Libp2pWebrtcTransportResetStats()
    var server = host.v3Libp2pHostInit("browser.pubsub.server")
    var client = host.v3Libp2pHostInit("browser.pubsub.client")
    let address = smokePubsubAddress()

    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolIngress)
    host.v3Libp2pRegisterHandler(client, types.v3Libp2pProtocolIngress)
    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolWebrtcSignal)
    host.v3Libp2pRegisterHandler(client, types.v3Libp2pProtocolWebrtcSignal)

    var listenAddr: types.V3Libp2pMultiaddr
    listenAddr.host = "203.0.113.144"
    listenAddr.port = 9454
    listenAddr.transport = types.v3Libp2pTransportWebrtc
    listenAddr.networkDomain = types.v3Libp2pNetworkDomainBrowserWebrtc
    listenAddr.visibility = types.v3Libp2pVisibilityPublic
    let listenRes = host.v3Libp2pListen(server, listenAddr)
    assert(listenRes.ok, "v3 webrtc browser pubsub: listen")

    let dialRes = host.v3Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 webrtc browser pubsub: dial")

    let payload = bytesFromString("browser-webrtc-pubsub")
    let payloadCid = hash256.sha256Fixed(layout.byteSpanFromBytes(payload))
    let sourcePeer = peer_id.v3Libp2pPeerIdFromSeed("browser.pubsub.source")

    var ingress = overlay.V3IngressEnvelope()
    ingress.sourcePeerId = sourcePeer.value
    ingress.topicScope = overlay.v3OverlayScopeRegion
    ingress.address = address
    ingress.payloadKind = 0
    ingress.payload = payload
    ingress.payloadCid = payloadCid
    ingress.payloadLen = bytesLen(payload)
    ingress.stampEpoch = 13
    ingress.stampGanzhi = 26

    var entries: overlay.V3IngressEnvelope[]
    entries = []
    add(entries, ingress)

    let pushRes = host.v3Libp2pIngressPush(client, server, server.selfPeerId, entries)
    assert(pushRes.ok, "v3 webrtc browser pubsub: ingress push")
    assert(client.openStreamPeers.len == 2, "v3 webrtc browser pubsub: opened ingress + signal")
    assert(client.openStreamProtocols[0] == types.v3Libp2pProtocolIngress,
        "v3 webrtc browser pubsub: ingress stream")
    assert(client.openStreamProtocols[1] == types.v3Libp2pProtocolWebrtcSignal,
        "v3 webrtc browser pubsub: signal stream")
    assert(server.storeEntries.len == 1, "v3 webrtc browser pubsub: store count")
    assert(server.publishLog.len == 1, "v3 webrtc browser pubsub: publish count")

    let storedIngress = server.storeEntries[0].ingress
    assert(layout.fixedBytes32Equal(storedIngress.payloadCid, payloadCid),
        "v3 webrtc browser pubsub: stored payload cid")
    assert(bytesLen(storedIngress.payload) == bytesLen(payload),
        "v3 webrtc browser pubsub: stored payload len")

    let expectedTopic = gossip.v3Libp2pTopicForScope(overlay.v3OverlayScopeRegion, address)
    let published = server.publishLog[0]
    assert(types.v3Libp2pTopicIdEqual(published.topicId, expectedTopic),
        "v3 webrtc browser pubsub: topic")
    assert(types.v3Libp2pPeerIdEqual(published.sourcePeerId, sourcePeer),
        "v3 webrtc browser pubsub: source peer")
    assert(layout.fixedBytes32Equal(published.payloadCid, payloadCid),
        "v3 webrtc browser pubsub: publish payload cid")
    assert(host.v3Libp2pWebrtcSignalEgressCount(client) == 5,
        "v3 webrtc browser pubsub: signal egress")
    assert(host.v3Libp2pWebrtcSignalIngressCount(server) == 5,
        "v3 webrtc browser pubsub: signal ingress")
    assert(webrtc_transport.v3Libp2pWebrtcBrowserDatachannelRequestCountNow() == 1,
        "v3 webrtc browser pubsub: browser request count")
    assert(webrtc_transport.v3Libp2pWebrtcNativeDatachannelRequestCountNow() == 0,
        "v3 webrtc browser pubsub: native request count")
    assert(webrtc_transport.v3Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        "v3 webrtc browser pubsub: loopback count")

    let firstSignalRes = signal.v3Libp2pWebrtcSignalDecode(client.webrtcSignalEgressPayloads[0])
    let lastSignalRes = signal.v3Libp2pWebrtcSignalDecode(client.webrtcSignalEgressPayloads[4])
    assert(IsOk(firstSignalRes), "v3 webrtc browser pubsub: first signal")
    assert(IsOk(lastSignalRes), "v3 webrtc browser pubsub: last signal")
    assert(layout.fixedBytes32Equal(Value(firstSignalRes).sessionId, Value(lastSignalRes).sessionId),
        "v3 webrtc browser pubsub: stable session id")

    echo("v3 webrtc_browser_pubsub_smoke ok")
    return 0
