# std string/json smoke: strings/strutils/strformat/json

import std/system
import std/strings
import std/seqs as seqs
import std/strutils as strutil
import std/strformat as strfmt
import std/json as json
import std/parseutils as parseutils

fn main() =
    let fmtParts: str[] = ["cheng", "-", "lang"]
    let joined: str = strfmt.fmt(fmtParts)
    assert(joined == "cheng-lang", "std/strformat fmt")
    let lineParts: str[] = ["a", "b"]
    let lineText: str = strfmt.lines(lineParts)
    assert(lineText == "a\nb", "std/strformat lines")

    assert(len("abc") == 3, "std/strings len")
    let concatParts: str[] = ["ab", "cd"]
    assert(strutil.join(concatParts, "") == "abcd", "std/strings concat")
    assert(hasPrefix("cheng", "ch"), "std/strings hasPrefix")
    assert(hasSuffix("cheng", "eng"), "std/strings hasSuffix")
    assert(strContains("cheng-lang", "lang"), "std/strings contains")

    let parts: str[] = strutil.split("a,b,", ',')
    assert(parts.len == 3, "std/strutils split len")
    assert(strutil.join(parts, "|") == "a|b|", "std/strutils split values")
    assert(strutil.join(parts, "|") == "a|b|", "std/strutils join")
    assert(strutil.strip("  hi \n") == "hi", "std/strutils strip")
    assert(strutil.toLowerAscii("AbC!") == "abc!", "std/strutils lower")
    assert(strutil.toUpperAscii("AbC!") == "ABC!", "std/strutils upper")
    assert(strutil.contains("cheng-lang", "lang"), "std/strutils contains")

    var parsedInt: int32 = 0
    let parsedIntCount: int = parseutils.parseInt32("-42ms", parsedInt)
    assert(parsedIntCount == 3, "std/parseutils parseInt32 count")
    assert(parsedInt == -42, "std/parseutils parseInt32 value")
    var badInt: int32 = 7
    assert(parseutils.parseInt32("oops", badInt) == 0, "std/parseutils parseInt32 invalid")
    var parsedFloat: parseutils.BiggestFloat = 0.0
    let parsedFloatCount: int = parseutils.parseBiggestFloat("3ms", parsedFloat)
    assert(parsedFloatCount == 1, "std/parseutils parseBiggestFloat count")
    assert(parsedFloat == 3.0, "std/parseutils parseBiggestFloat value")

    var root: json.JsonNode = json.newJObject()
    root["name"] = json.newJString("cheng")
    root["enabled"] = json.newJBool(true)
    root["count"] = json.newJInt(2)
    assert(json.hasKey(root, "name"), "std/json hasKey")
    assert(json.getStr(root["name"], "") == "cheng", "std/json getStr")
    assert(json.getBool(root["enabled"], false), "std/json getBool")
    assert(json.getInt64(root["count"], -1) == 2, "std/json getInt64")
    let prettyText: str = json.toPretty(root, 2)
    assert(strContains(prettyText, "\"name\""), "std/json pretty")
    assert(strContains($root, "\"cheng\""), "std/json render")

    let safeParse: json.JsonParseResult = json.parseJsonSafe("{")
    assert(! safeParse.success, "std/json parseJsonSafe invalid")
    assert(len(safeParse.message) > 0, "std/json parseJsonSafe message")
