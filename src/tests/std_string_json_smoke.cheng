# std string/json smoke: strings/strutils/strformat/json

import std/system
import std/strings
import std/seqs as seqs
import std/strutils as strutil
import std/json as json
import std/parseutils as parseutils

fn main() =
    var fmtParts: str[]
    add(fmtParts, "cheng")
    add(fmtParts, "-")
    add(fmtParts, "lang")
    let joined: str = strutil.Join(fmtParts, "")
    assert(joined == "cheng-lang", "std/strformat fmt")
    let fmtName = "cheng"
    let nimFmt: str = Fmt"hello {fmtName}"
    assert(nimFmt == "hello cheng", "std/strformat nim fmt")
    let fmtRc = "0"
    let nimFmtPrefixed: str = Fmt"rc={fmtRc}"
    assert(nimFmtPrefixed == "rc=0", "std/strformat nim fmt prefixed")
    var lineParts: str[]
    add(lineParts, "a")
    add(lineParts, "b")
    let lineText: str = Lines(lineParts)
    assert(lineText == "a\nb", "std/strformat lines")

    assert(len("abc") == 3, "std/strings len")
    var concatParts: str[]
    add(concatParts, "ab")
    add(concatParts, "cd")
    let concatText = strutil.Join(concatParts, "")
    assert(concatText == "abcd", "std/strings concat")
    var publicAddParts: str[]
    seqs.Add(publicAddParts, "alpha")
    seqs.Add(publicAddParts, "beta")
    assert(publicAddParts[0] == "alpha", "std/seqs Add str slot first")
    assert(publicAddParts[1] == "beta", "std/seqs Add str slot second")
    assert(strutil.Join(publicAddParts, ",") == "alpha,beta", "std/seqs Add str join")
    assert(hasPrefix("cheng", "ch"), "std/strings hasPrefix")
    assert(hasSuffix("cheng", "eng"), "std/strings hasSuffix")
    assert(strContains("cheng-lang", "lang"), "std/strings contains")

    let commaSep: char = ','
    var parts: str[]
    strutil.SplitInto("a,b,", commaSep, parts)
    assert(parts.len == 3, "std/strutils split len")
    let partsJoined = strutil.Join(parts, "|")
    assert(partsJoined == "a|b|", "std/strutils split values")
    let newlineSep: char = '\n'
    var newlineParts: str[]
    strutil.SplitInto("left\nright\n", newlineSep, newlineParts)
    assert(newlineParts.len == 3, "std/strutils split newline len")
    let newlineJoined = strutil.Join(newlineParts, "|")
    assert(newlineJoined == "left|right|", "std/strutils split newline values")
    assert(partsJoined == "a|b|", "std/strutils join")
    assert(strutil.Strip("  hi \n") == "hi", "std/strutils strip")
    assert(strutil.ToLowerAscii("AbC!") == "abc!", "std/strutils lower")
    assert(strutil.ToUpperAscii("AbC!") == "ABC!", "std/strutils upper")
    assert(strutil.Contains("cheng-lang", "lang"), "std/strutils contains")

    var parsedInt: int32
    let parsedIntCount: int = parseutils.ParseInt32("-42ms", parsedInt)
    assert(parsedIntCount == 3, "std/parseutils parseInt32 count")
    assert(parsedInt == -42, "std/parseutils parseInt32 value")
    var badInt: int32 = 7
    assert(parseutils.ParseInt32("oops", badInt) == 0, "std/parseutils parseInt32 invalid")
    var parsedFloat: parseutils.BiggestFloat
    let parsedFloatCount: int = parseutils.ParseBiggestFloat("3ms", parsedFloat)
    assert(parsedFloatCount == 1, "std/parseutils parseBiggestFloat count")
    assert(int32(parsedFloat) == 3, "std/parseutils parseBiggestFloat value")
    var parsedExp: parseutils.BiggestFloat
    let parsedExpCount: int = parseutils.ParseBiggestFloat("1.25e2ms", parsedExp)
    assert(parsedExpCount == 6, "std/parseutils exponent count")
    assert(int32(parsedExp) == 125, "std/parseutils exponent value")

    let jsonName = "cheng"
    let jsonEnabled = true
    let jsonCount: int32 = 2
    var root: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(root, "name", jsonName)
    json.JsonSetFieldBool(root, "enabled", jsonEnabled)
    json.JsonSetFieldInt32(root, "count", jsonCount)
    let jsonQuote = "a\"b\nc"
    json.JsonSetFieldStr(root, "quote", jsonQuote)
    var tags: json.JsonNode = json.NewJArray()
    json.JsonAddStr(tags, "alpha")
    json.JsonAddInt32(tags, 7)
    json.JsonSetField(root, "tags", tags)
    var gotName: str
    var gotEnabled: bool
    var gotCount: int64 = -1
    var gotNameNode: str
    let jsonNameNode: json.JsonNode = root["name"]
    let jsonNameFound: bool = json.JsonTryGetStr(root, "name", gotName)
    let jsonEnabledFound: bool = json.JsonTryGetBool(root, "enabled", gotEnabled)
    let jsonCountFound: bool = json.JsonTryGetInt64(root, "count", gotCount)
    let jsonNameNodeFound: bool = json.JsonNodeTryGetStr(jsonNameNode, gotNameNode)
    assert(jsonNameFound, "std/json getStr found")
    assert(jsonEnabledFound, "std/json getBool found")
    assert(jsonCountFound, "std/json getInt64 found")
    assert(jsonNameNodeFound, "std/json direct index node found")
    assert(gotName == "cheng", "std/json getStr")
    assert(gotEnabled, "std/json getBool")
    assert(gotCount == 2, "std/json getInt64")
    assert(gotNameNode == "cheng", "std/json direct index node")
    let rendered = json.Pretty(root, 2)
    let renderedAlias = json.ToPretty(root, 2)
    let serialized = json.ToJsonString(root)
    let serializedAlias = json.JsonStringify(root)
    let serializedCompat = json.Stringify(root)
    assert(strContains(rendered, "\"name\":\"cheng\""), "std/json pretty name")
    assert(strContains(rendered, "\"enabled\":true"), "std/json pretty bool")
    assert(strContains(rendered, "\"count\":2"), "std/json pretty int")
    assert(strContains(rendered, "\"quote\":\"a\\\"b\\nc\""), "std/json stringify escaped string")
    assert(strContains(rendered, "\"tags\":[\"alpha\",7]"), "std/json stringify array")
    assert(renderedAlias == rendered, "std/json toPretty")
    assert(serialized == rendered, "std/json toJsonString compact")
    assert(serializedAlias == serialized, "std/json jsonStringify alias")
    assert(serializedCompat == serialized, "std/json stringify alias")
    let parseRes = json.ParseJsonSafe(rendered)
    assert(! parseRes.success, "std/json parseJsonSafe stub success")
    assert(parseRes.message == "json parsing not implemented in bootstrap", "std/json parseJsonSafe message")
