import std/os

fn StrConcatLoweringFlag(prefix: str, value: str): str =
    var parts: str[]
    add(parts, prefix)
    add(parts, value)
    return Fmt(parts)

fn Sink(root: str,
        label: str,
        filePathRaw: str,
        argv: str[],
        envOverrides: str[],
        workingDirRaw: str,
        timeoutSec: int32,
        logPathRaw: str): int32 =
    root
    label
    filePathRaw
    envOverrides
    workingDirRaw
    timeoutSec
    logPathRaw
    echo(argv[1])
    return 0

fn main(): int32 =
    let root = os.GetCurrentDir()
    let driver = os.JoinPath(root, "artifacts/bootstrap/cheng.stage3")
    let logPath = os.JoinPath(root, "artifacts/str_concat_call_arg_probe.log")
    let rc = Sink(root,
                  "str_concat_call_arg_probe",
                  driver,
                  [
                      "system-link-exec",
                      StrConcatLoweringFlag("--root:", root),
                      "--emit:exe"
                  ],
                  [],
                  root,
                  0,
                  logPath)
    assert(rc == 0, " str concat call arg probe: rc")
    return 0
