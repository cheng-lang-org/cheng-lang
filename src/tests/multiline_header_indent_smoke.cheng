fn boolIdentity(v: bool): bool =
    return v

fn multilineIfValue(): int64 =
    if !boolIdentity(
            true):
        return 0
    return 7

fn multilineWhileCount(): int32 =
    var i: int32
    var count: int32
    while boolIdentity(
              i < 3):
        count = count + 1
        i = i + 1
    return count

fn main(): int32 =
    assert(multilineIfValue() == 7, "v3 multiline header: if")
    assert(multilineWhileCount() == 3, "v3 multiline header: while")
    echo("v3 multiline_header_indent_smoke ok")
    return 0
