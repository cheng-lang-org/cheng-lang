import std/os
import std/result
import cheng/std/bytes_layout as layout
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/tooling/compiler_equivalence as ceq
import cheng/core/tooling/compiler_publish_gate as cpub
import cheng/core/lang/parser
import cheng/core/backend/system_link_plan as slplan
import std/strutils as strutil

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, strutil.Join(["artifacts/compiler_migration/", smokeLabel], ""))
    assert(chengpath.MkdirP(workspaceRoot, outDir), " compiler migration publish: mkdir")
    let currentSourcePath = chengpath.PathJoin(packageRoot, "src/tests/compiler_migration_fixture.cheng")
    let legacySourcePath = chengpath.PathJoin(packageRoot, "testdata/compiler_migration/compiler_migration_fixture_legacy.cheng")
    let outputPath = chengpath.PathJoin(outDir, "compiler_migration_publish_fixture")
    let req = creq.CompilerRequestNew(
        packageRoot,
        currentSourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), " compiler migration publish: link plan")
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    assert(IsOk(sourceBundleRes), " compiler migration publish: source bundle")
    let sourceBundleCid = Value(sourceBundleRes)
    let currentCsgRes = ccsg.BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(currentCsgRes), " compiler migration publish: build current csg")
    let currentCsg = ccsg.CompilerCsgClone(Value(currentCsgRes))
    let entryModulePath = parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, currentSourcePath)
    let migrationRes = ccsg.BuildCompilerLegacyMigration(workspaceRoot,
                                                           packageRoot,
                                                           legacySourcePath,
                                                           linkPlan.packageId,
                                                           entryModulePath)
    assert(IsOk(migrationRes), " compiler migration publish: build migration")
    let migration = ccsg.CompilerLegacyMigrationClone(Value(migrationRes))
    let providers = [
        "runtime/compiler_runtime",
        "runtime/core_runtime",
        "runtime/debug_runtime",
        "runtime/program_support",
        "runtime/program_support_get_env_bridge",
        "runtime/program_support_host_runtime"
    ]
    let worldHeadCid = layout.FixedBytes32()
    let currentReceipt = ccsg.CompileReceiptMake(worldHeadCid,
                                                   currentCsg.graphCid,
                                                   currentCsg.canonicalGraphCid,
                                                   req.targetTriple,
                                                   ccsg.CompileOutputDigest(outputPath, req.targetTriple, providers, currentCsg.graphCid),
                                                   ccsg.CompileOutputDigest(outputPath, req.targetTriple, providers, currentCsg.canonicalGraphCid),
                                                   "stage3_local",
                                                   providers)
    let migrationReceipt = ccsg.CompileReceiptMake(worldHeadCid,
                                                     migration.compilerCsg.graphCid,
                                                     migration.compilerCsg.canonicalGraphCid,
                                                     req.targetTriple,
                                                     ccsg.CompileOutputDigest(outputPath, req.targetTriple, providers, migration.compilerCsg.graphCid),
                                                     ccsg.CompileOutputDigest(outputPath, req.targetTriple, providers, migration.compilerCsg.canonicalGraphCid),
                                                     "stage3_local",
                                                     providers)
    if !ccsg.CompileReceiptEquivalent(currentReceipt, migrationReceipt):
        echo(strutil.Join([" compiler migration publish drift current_canonical_csg=", layout.FixedBytes32Hex(currentCsg.canonicalGraphCid)], ""))
        echo(strutil.Join([" compiler migration publish drift migration_canonical_csg=", layout.FixedBytes32Hex(migration.compilerCsg.canonicalGraphCid)], ""))
        echo(strutil.Join([" compiler migration publish drift current_canonical_output=", layout.FixedBytes32Hex(currentReceipt.canonicalOutputDigest)], ""))
        echo(strutil.Join([" compiler migration publish drift migration_canonical_output=", layout.FixedBytes32Hex(migrationReceipt.canonicalOutputDigest)], ""))
        echo(strutil.Join([" compiler migration publish drift current_receipt=", layout.FixedBytes32Hex(currentReceipt.receiptCid)], ""))
        echo(strutil.Join([" compiler migration publish drift migration_receipt=", layout.FixedBytes32Hex(migrationReceipt.receiptCid)], ""))
    assert(ccsg.CompileReceiptEquivalent(currentReceipt, migrationReceipt),
           " compiler migration publish: canonical receipt equivalent")
    let currentSurface = ccsg.CompilerExportSurfaceFromCsg(currentCsg)
    var proof: ceq.CompilerEquivalenceProof
    let proofRes = ceq.CompilerEquivalenceProofMake(linkPlan.packageId,
                                                      "stable",
                                                      currentCsg.canonicalGraphCid,
                                                      migration.compilerCsg.canonicalGraphCid,
                                                      currentSurface.surfaceCid,
                                                      migration.exportSurface.surfaceCid,
                                                      currentReceipt.receiptCid,
                                                      migrationReceipt.receiptCid,
                                                      req.targetTriple,
                                                      1,
                                                      1,
                                                      1,
                                                      proof)
    assert(IsOk(proofRes), " compiler migration publish: proof make")
    assert(ceq.CompilerEquivalencePassed(proof), " compiler migration publish: proof passed")
    var decisionChannel = ""
    var decisionGate = 0
    var decisionChecked = 0
    var decisionPassed = 0
    var decisionPublish = 0
    var decisionProofCid = layout.FixedBytes32()
    let decisionRes = cpub.CompilerPublishDecisionEvaluate("stable",
                                                             worldHeadCid,
                                                             true,
                                                             proof,
                                                             decisionChannel,
                                                             decisionGate,
                                                             decisionChecked,
                                                             decisionPassed,
                                                             decisionPublish,
                                                             decisionProofCid)
    assert(IsOk(decisionRes), " compiler migration publish: decision")
    assert(decisionPublish != 0, " compiler migration publish: stable allowed")
    let proofReport = ceq.CompilerEquivalenceProofReport(proof)
    assert(chengpath.TextContains(proofReport, "equivalence_kind=canonical_semantic_identity"),
           " compiler migration publish: report kind")
    echo(" compiler_migration_publish_smoke ok")
    return 0
