import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    let mintA = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintA.ok, "chain node two mints: mint a")
    let mintB = node.ChainNodeMint(server, 7, 1002, int64(40))
    assert(mintB.ok, "chain node two mints: mint b")
    return 0
