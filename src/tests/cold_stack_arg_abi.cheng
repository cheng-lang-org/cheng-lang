fn ColdStackArgAbiProbe(a: str,
                         b: str,
                         c: str,
                         d: str,
                         e: str,
                         tag: int32,
                         reportPath: str,
                         symbolVisibility: str,
                         browserBridgeObjectPath: str,
                         exportRootsText: str): int32 =
    if len(browserBridgeObjectPath) != 0:
        return len(browserBridgeObjectPath)
    if len(symbolVisibility) != 6:
        return 20 + len(symbolVisibility)
    if tag != 7:
        return 30 + tag
    if len(e) != 1:
        return 40 + len(e)
    if len(exportRootsText) != 4:
        return 50 + len(exportRootsText)
    if len(reportPath) != 6:
        return 60 + len(reportPath)
    return 0

fn main(): int32 =
    return ColdStackArgAbiProbe("a",
                                "b",
                                "c",
                                "d",
                                "e",
                                7,
                                "report",
                                "public",
                                "",
                                "tail")
