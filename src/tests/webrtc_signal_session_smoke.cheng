import std/system
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/protocols/webrtc_signal as signal

fn main(): int32 =
    var addr: types.Libp2pMultiaddr
    addr.host = "203.0.113.91"
    addr.port = 9443
    addr.transport = types.Libp2pTransportWebrtc
    addr.networkDomain = types.Libp2pNetworkDomainBrowserWebrtc
    addr.visibility = types.Libp2pVisibilityPublic

    var cfg: webrtc_transport.Libp2pWebrtcTransportConfig
    cfg.stunUrls = ["stun:browser.example.net"]
    let turnInsert: signal.Libp2pWebrtcTurnServer
    add(cfg.turnServers, turnInsert)
    cfg.turnServers[0].url = "turn:relay.example.net"
    cfg.turnServers[0].username = "webrtc-user"
    cfg.turnServers[0].credential = "pw"

    var pair: webrtc_transport.Libp2pWebrtcLoopbackPair
    let openRes = webrtc_transport.Libp2pWebrtcLoopbackOpenInto(pair, cfg, addr)
    assert(IsOk(openRes), " webrtc signal session: open")
    assert(pair.signalSession.offerSeen, " webrtc signal session: offer")
    assert(pair.signalSession.answerSeen, " webrtc signal session: answer")
    assert(pair.signalSession.policySeen, " webrtc signal session: policy")
    assert(pair.signalSession.ready, " webrtc signal session: ready")
    assert(pair.signalSession.candidateTexts.len == 2, " webrtc signal session: candidates")
    assert(pair.signalSession.turnServers.len == 1, " webrtc signal session: turn servers")
    assert(webrtc_transport.Libp2pWebrtcLoopbackSignalCount(pair) == 5,
        " webrtc signal session: transcript count")
    assert(pair.signalTranscript[0].kind == signal.Libp2pWebrtcSignalTurnPolicy,
        " webrtc signal session: transcript order policy")
    assert(pair.signalTranscript[1].kind == signal.Libp2pWebrtcSignalOffer,
        " webrtc signal session: transcript order offer")
    assert(pair.signalTranscript[2].kind == signal.Libp2pWebrtcSignalAnswer,
        " webrtc signal session: transcript order answer")
    assert(pair.signalTranscript[3].candidateText == "candidate:1 1 udp 2130706431 203.0.113.91 9443 typ host generation 0 ufrag client",
        " webrtc signal session: client candidate ufrag")
    assert(pair.signalTranscript[4].candidateText == "candidate:1 1 udp 2130706431 203.0.113.91 9443 typ host generation 0 ufrag server",
        " webrtc signal session: server candidate ufrag")
    assert(pair.selectedProtocol == 0, " webrtc signal session: protocol initially unset")

    let selectRes = webrtc_transport.Libp2pWebrtcLoopbackSelectProtocol(pair, types.Libp2pProtocolContent)
    assert(IsOk(selectRes), " webrtc signal session: select protocol")
    assert(pair.selectedProtocol == types.Libp2pProtocolContent,
        " webrtc signal session: selected protocol")
    let payload = bytesFromString("webrtc-session-payload")
    let writeRes = webrtc_transport.Libp2pWebrtcLoopbackWriteClient(pair, payload)
    assert(IsOk(writeRes), " webrtc signal session: write")
    let readRes = webrtc_transport.Libp2pWebrtcLoopbackReadServer(pair, bytesLen(payload))
    assert(IsOk(readRes), " webrtc signal session: read")
    assert(bytesEqual(Value(readRes), payload), " webrtc signal session: payload")

    webrtc_transport.Libp2pWebrtcTransportResetStats()
    let signalWire = webrtc_transport.Libp2pWebrtcLoopbackSignalTranscriptPayload(pair)
    var clientResponse: Bytes
    let nativeRes = webrtc_transport.Libp2pWebrtcNativeRequestResponse(types.Libp2pProtocolContent,
                                                                         signalWire,
                                                                         payload,
                                                                         payload,
                                                                         clientResponse)
    assert(IsOk(nativeRes), " webrtc signal session: native bridge")
    assert(webrtc_transport.Libp2pWebrtcNativeDatachannelOpenCountNow() == 1,
        " webrtc signal session: native open count")
    assert(webrtc_transport.Libp2pWebrtcNativeDatachannelRequestCountNow() == 1,
        " webrtc signal session: native request count")
    assert(webrtc_transport.Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        " webrtc signal session: loopback request-response count")
    assert(bytesEqual(clientResponse, payload), " webrtc signal session: native payload")

    echo(" webrtc_signal_session_smoke ok")
    return 0
