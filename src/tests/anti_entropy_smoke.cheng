import std/system
import cheng/chain/lsmr as lsmr
import cheng/chain/lsmr_types as lt
import cheng/chain/anti_entropy as anti

fn main(): int32 =
    let localAddrRes = lsmr.LsmrAddressFromSeed("local-qian", 1)
    assert(localAddrRes.ok, " anti_entropy: local address")
    let remoteRegionalAddrRes = lsmr.LsmrAddressFromSeed("remote-regional", 2)
    assert(remoteRegionalAddrRes.ok, " anti_entropy: remote regional address")

    let localContentCid = lt.HashInts("cheng.anti_entropy.content", [1, 101, 1001])
    let remoteGlobalContentCid = lt.HashInts("cheng.anti_entropy.content", [2, 202, 2002])
    let remoteRegionalContentCid = lt.HashInts("cheng.anti_entropy.content", [3, 303, 3003])
    let localLocalityHash = lt.HashInts("cheng.anti_entropy.locality", [1, 11, 111])
    let remoteGlobalLocalityHash = lt.HashInts("cheng.anti_entropy.locality", [2, 22, 222])
    let remoteRegionalLocalityHash = lt.HashInts("cheng.anti_entropy.locality", [3, 33, 333])
    var localCell: lt.StateCell
    lsmr.LsmrStateCellFill(
        localCell,
        1,
        localAddrRes.value,
        1,
        localContentCid,
        localLocalityHash
    )
    var remoteGlobalCell: lt.StateCell
    lsmr.LsmrStateCellFill(
        remoteGlobalCell,
        1,
        localAddrRes.value,
        1,
        remoteGlobalContentCid,
        remoteGlobalLocalityHash
    )
    var remoteRegionalCell: lt.StateCell
    lsmr.LsmrStateCellFill(
        remoteRegionalCell,
        2,
        remoteRegionalAddrRes.value,
        2,
        remoteRegionalContentCid,
        remoteRegionalLocalityHash
    )

    var localCells: lt.StateCell[]
    localCells = []
    add(localCells, localCell)
    let localForest = lsmr.BuildStateLayerForest(localCells)

    var remoteCells: lt.StateCell[]
    remoteCells = []
    add(remoteCells, remoteGlobalCell)
    add(remoteCells, remoteRegionalCell)
    let remoteForest = lsmr.BuildStateLayerForest(remoteCells)

    let localSig = anti.AntiEntropySignatureFromForest(10, 12, 3, 1, localForest)
    let remoteSig = anti.AntiEntropySignatureFromForest(11, 1, 4, 1, remoteForest)

    assert(!anti.AntiEntropySignatureEqual(localSig, remoteSig), " anti_entropy: signatures differ")
    assert(anti.PassiveAntiEntropySyncRequired(localSig, remoteSig), " anti_entropy: sync required")

    let localPlanRes = anti.AntiEntropyPlan(localSig, localSig)
    assert(localPlanRes.ok, " anti_entropy: identical plan")
    assert(localPlanRes.value.requestCount == 0, " anti_entropy: identical plan empty")
    assert(!anti.PassiveAntiEntropySyncRequired(localSig, localSig),
           " anti_entropy: identical signature no sync")

    let planRes = anti.AntiEntropyPlan(localSig, remoteSig)
    assert(planRes.ok, " anti_entropy: plan")
    let plan = planRes.value
    assert(plan.remoteNewer, " anti_entropy: remote newer")
    assert(plan.requestCount == 1, " anti_entropy: one subtree request")
    assert(plan.requests[0].layerId == lt.LayerRegional, " anti_entropy: escalates to regional layer")
    assert(plan.requests[0].prefix.baguaId == remoteGlobalCell.baguaId, " anti_entropy: request bagua")
    assert(plan.requests[0].prefix.prefixDepth == 0, " anti_entropy: request root subtree")
    assert(plan.conflictCount == 0, " anti_entropy: no equal-clock conflict")

    echo(" anti_entropy_smoke ok")
    return 0
