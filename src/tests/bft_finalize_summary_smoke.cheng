import std/system
import cheng/apps/bft/bft_state_machine as bft

fn main(): int32 =
    let appId = "bft-finalize-summary"
    var machine = bft.BftStateMachineInit(appId)
    let mint = bft.BftTxMint(7, 1001, int64(100))
    let badTransfer = bft.BftTxTransfer(7, 1001, 1001, int64(1))

    let mintCheck = bft.BftStateMachineCheckTx(machine, mint)
    assert(mintCheck.code == bft.BftCodeOk, " bft finalize summary: mint check")
    assert(machine.index.eventCids.len == 0, " bft finalize summary: checktx event log")
    assert(machine.index.accountIds.len == 0, " bft finalize summary: checktx state")

    let badTransferCheck = bft.BftStateMachineCheckTx(machine, badTransfer)
    assert(badTransferCheck.code == bft.BftCodeBadTarget, " bft finalize summary: bad transfer check")
    assert(machine.index.eventCids.len == 0, " bft finalize summary: bad check event log")

    var batch = bft.BftTxBatch()
    bft.BftTxBatchAdd(batch, mint)
    bft.BftTxBatchAdd(batch, badTransfer)

    var summary = bft.BftBlockSummaryZero(int64(0))
    bft.BftStateMachineFinalizeBatchSummary(machine, int64(1), batch, summary)

    assert(summary.txCount == 2, " bft finalize summary: tx count")
    assert(summary.appliedCount == 1, " bft finalize summary: applied count")
    assert(summary.rejectedCount == 1, " bft finalize summary: rejected count")
    assert(machine.index.eventCids.len == 1, " bft finalize summary: event cid len")
    assert(machine.index.accountIds.len == 1, " bft finalize summary: account len")
    assert(machine.lastFinalizedHeight == int64(1), " bft finalize summary: finalized height")
    echo(" bft_finalize_summary_smoke ok")
    return 0
