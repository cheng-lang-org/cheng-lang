import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var state: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(state, "snapshot-boundary-node", "snapshot-boundary-seed")),
           " chain_node snapshot boundary: init")
    var snapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(snapshot, state)
    echo(" chain_node_snapshot_return_boundary_smoke ok")
    return 0
