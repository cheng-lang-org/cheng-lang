import std/strings
import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as v3path

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let stage0: str = os.JoinPath(root, "artifacts/bootstrap/cheng.stage0")
    let stage3: str = os.JoinPath(root, "artifacts/bootstrap/cheng.stage3")
    assert(os.FileExists(stage0), "v3 stage3 command surface: stage0 exists")
    assert(os.FileExists(stage3), "v3 stage3 command surface: stage3 exists")
    let outDir = v3path.V3PathAbsolute(root, "artifacts/stage3_command_surface_smoke")
    assert(v3path.V3MkdirP(root, outDir), "v3 stage3 command surface: mkdir")

    let stage0HelpLog = v3path.V3PathJoin(outDir, "stage0_help.log")
    if v3path.V3PathFileExists(stage0HelpLog):
        os.RemoveFile(stage0HelpLog)
    let stage0HelpRun = hostops.v3RunFileLogged(root,
                                                "stage0_command_surface_help",
                                                stage0,
                                                ["help"],
                                                [],
                                                root,
                                                0,
                                                stage0HelpLog)
    let stage0HelpOutput: str = stage0HelpRun.output
    assert(stage0HelpRun.exitCode == 0, "v3 stage3 command surface: stage0 help rc")
    assert(strings.StrContains(stage0HelpOutput, "run-production-regression"),
           "v3 stage3 command surface: stage0 help production regression")
    assert(!strings.StrContains(stage0HelpOutput, "backend_prod_closure"),
           "v3 stage3 command surface: stage0 help no backend_prod_closure")
    assert(!strings.StrContains(stage0HelpOutput, "verify_backend_abi_v2_noptr"),
           "v3 stage3 command surface: stage0 help no abi v2 gate")

    let stage3HelpLog = v3path.V3PathJoin(outDir, "stage3_help.log")
    if v3path.V3PathFileExists(stage3HelpLog):
        os.RemoveFile(stage3HelpLog)
    let stage3HelpRun = hostops.v3RunFileLogged(root,
                                                "stage3_command_surface_help",
                                                stage3,
                                                ["help"],
                                                [],
                                                root,
                                                0,
                                                stage3HelpLog)
    let stage3HelpOutput: str = stage3HelpRun.output
    assert(stage3HelpRun.exitCode == 0, "v3 stage3 command surface: stage3 help rc")
    assert(strings.StrContains(stage3HelpOutput, "run-production-regression"),
           "v3 stage3 command surface: stage3 help production regression")
    assert(!strings.StrContains(stage3HelpOutput, "backend_prod_closure"),
           "v3 stage3 command surface: stage3 help no backend_prod_closure")
    assert(!strings.StrContains(stage3HelpOutput, "verify_backend_abi_v2_noptr"),
           "v3 stage3 command surface: stage3 help no abi v2 gate")
    echo("v3 stage3_command_surface_smoke ok")
    return 0
