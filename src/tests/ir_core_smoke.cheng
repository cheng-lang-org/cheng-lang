import std/system
import std/result
import cheng/core/lang/intern as langintern
import cheng/core/ir/core_types as ir

fn main() =
    let pool: langintern.InternPool = langintern.InternPoolNew()
    let fnName0: langintern.InternId = langintern.Intern(pool, "chain.sync_once")
    let fnName1: langintern.InternId = langintern.Intern(pool, "chain.sync_once")
    assert(fnName0 == fnName1, " ir: stable intern id")
    assert(langintern.InternPoolCount(pool) == 1, " ir: no duplicate symbol")

    let textRes: Result[str] = langintern.LookupIntern(pool, fnName0)
    assert(IsOk(textRes), " ir: lookup intern")
    assert(Value(textRes) == "chain.sync_once", " ir: lookup text")

    let bytes32Layout: ir.TypeLayout = ir.TypeLayoutFixedBytes(32, 32)
    assert(bytes32Layout.kind == ir.LayoutFixedBytes, " ir: fixed bytes layout")
    assert(bytes32Layout.abiClass == ir.AbiAggregate, " ir: aggregate abi")

    let func: ir.MirFunction = ir.MirFunctionNew(fnName0)
    assert(func.nameId == fnName0, " ir: mir function name")
    assert(func.values.len == 0, " ir: empty values")

    let root: ir.Place = ir.PlaceRoot(7, 9)
    assert(root.baseValue == 7, " ir: place base")
    assert(root.typeId == 9, " ir: place type")
    assert(root.fieldOrdinal == -1, " ir: root field ordinal")

    echo(" ir_core_smoke ok")
