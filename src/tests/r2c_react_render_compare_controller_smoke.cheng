import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = chengpath.PathAbsolute(root, "artifacts/r2c_render_compare_controller_smoke")
    assert(chengpath.MkdirP(root, outDir), " r2c render compare controller smoke: mkdir")
    let driver = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    let packageRoot = root
    let controllerSource = chengpath.PathAbsolute(root, "src/r2c/r2c_react.cheng")
    assert(chengpath.FileExistsNonEmpty(root, driver), " r2c render compare controller smoke: backend_driver exists")
    assert(chengpath.FileExistsNonEmpty(root, controllerSource), " r2c render compare controller smoke: controller source exists")

    let repoEnv = os.GetEnv("R2C_REACT_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.DirExists(repo), " r2c render compare controller smoke: React.js repo exists")

    let controllerExe = os.JoinPath(outDir, "r2c_react_render_compare_controller_smoke")
    let controllerCompileReport = controllerExe + ".report.txt"
    let controllerCompileLog = controllerExe + ".compile.log"
    if chengpath.PathFileExists(controllerExe):
        os.RemoveFile(controllerExe)
    if chengpath.PathFileExists(controllerCompileReport):
        os.RemoveFile(controllerCompileReport)
    let controllerCompileRun = hostops.RunFileLogged(root,
                                                       "r2c_render_compare_controller_compile",
                                                       driver,
                                                       [
                                                           "system-link-exec",
                                                           "--root:" + packageRoot,
                                                           "--in:" + controllerSource,
                                                           "--emit:exe",
                                                           "--target:arm64-apple-darwin",
                                                           "--out:" + controllerExe,
                                                           "--report-out:" + controllerCompileReport
                                                       ],
                                                       ["CHENG_BACKEND_DRIVER_READY=1"],
                                                       root,
                                                       0,
                                                       controllerCompileLog)
    assert(hostops.LoggedRunOk(controllerCompileRun), " r2c render compare controller smoke: controller compile rc")
    assert(chengpath.FileExistsNonEmpty(root, controllerExe), " r2c render compare controller smoke: controller exe")

    let nativePngPath = os.JoinPath(outDir, "native_gui_session.png")
    let truthPngPath = os.JoinPath(outDir, "truth_session.png")
    let nativeSummaryPath = os.JoinPath(outDir, "native_gui_run.summary.env")
    let truthSummaryPath = os.JoinPath(outDir, "truth.summary.env")
    let truthTracePath = os.JoinPath(outDir, "truth_trace_v2.json")
    let truthRuntimeStatePath = os.JoinPath(outDir, "truth_runtime_state_v1.json")
    let truthDomPath = os.JoinPath(outDir, "truth_dom_v1.json")
    let truthSemanticNodesPath = os.JoinPath(outDir, "truth_semantic_nodes_v1.json")
    let truthRuntimeMetaPath = os.JoinPath(outDir, "truth_runtime_meta_v1.json")
    let renderComparePath = os.JoinPath(outDir, "render_compare_report_v1.json")
    let renderCompareSummaryPath = os.JoinPath(outDir, "render_compare.summary.env")

    let pngBase64 = "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO+aXfsAAAAASUVORK5CYII="
    let pngWriterScript = "const fs=require('node:fs');" +
                          "const png=Buffer.from(process.argv[1],'base64');" +
                          "fs.writeFileSync(process.argv[2],png);" +
                          "fs.writeFileSync(process.argv[3],png);"
    let pngWriterLog = os.JoinPath(outDir, "write_png.log")
    if chengpath.PathFileExists(pngWriterLog):
        os.RemoveFile(pngWriterLog)
    let pngWriterRun = hostops.RunProgramLogged(root,
                                                  "r2c_render_compare_controller_write_png",
                                                  "node",
                                                  ["-e", pngWriterScript, pngBase64, nativePngPath, truthPngPath],
                                                  [],
                                                  root,
                                                  0,
                                                  pngWriterLog)
    assert(hostops.LoggedRunOk(pngWriterRun), " r2c render compare controller smoke: write png rc")
    assert(chengpath.FileExistsNonEmpty(root, nativePngPath), " r2c render compare controller smoke: native png")
    assert(chengpath.FileExistsNonEmpty(root, truthPngPath), " r2c render compare controller smoke: truth png")

    assert(chengpath.WriteTextFile("", truthTracePath,
                                  "{\n" +
                                  "  \"format\": \"truth_trace_v2\",\n" +
                                  "  \"snapshots\": [\n" +
                                  "    {\n" +
                                  "      \"stateId\": \"publish_selector\",\n" +
                                  "      \"route\": {\n" +
                                  "        \"routeId\": \"publish_selector\"\n" +
                                  "      },\n" +
                                  "      \"semanticNodesCount\": 67,\n" +
                                  "      \"renderReady\": true\n" +
                                  "    }\n" +
                                  "  ]\n" +
                                  "}\n"),
           " r2c render compare controller smoke: write truth trace")
    assert(chengpath.WriteTextFile("", truthRuntimeStatePath,
                                  "{\n" +
                                  "  \"format\": \"truth_runtime_state_v1\",\n" +
                                  "  \"route_state\": \"publish_selector\"\n" +
                                  "}\n"),
           " r2c render compare controller smoke: write truth runtime state")
    assert(chengpath.WriteTextFile("", truthDomPath,
                                  "{\n" +
                                  "  \"format\": \"truth_dom_v1\",\n" +
                                  "  \"route_state\": \"publish_selector\"\n" +
                                  "}\n"),
           " r2c render compare controller smoke: write truth dom")
    assert(chengpath.WriteTextFile("", truthSemanticNodesPath,
                                  "{\n" +
                                  "  \"format\": \"truth_semantic_nodes_v1\",\n" +
                                  "  \"count\": 67\n" +
                                  "}\n"),
           " r2c render compare controller smoke: write truth semantic nodes")
    assert(chengpath.WriteTextFile("", truthRuntimeMetaPath,
                                  "{\n" +
                                  "  \"format\": \"truth_runtime_meta_v1\",\n" +
                                  "  \"browser_width\": 1,\n" +
                                  "  \"browser_height\": 1\n" +
                                  "}\n"),
           " r2c render compare controller smoke: write truth runtime meta")

    assert(chengpath.WriteTextFile("", nativeSummaryPath,
                                  "native_gui_route_state=publish_selector\n" +
                                  "native_gui_screenshot_path=" + nativePngPath + "\n" +
                                  "native_gui_window_width=1\n" +
                                  "native_gui_window_height=1\n" +
                                  "native_gui_layout_item_count=24\n" +
                                  "native_gui_runtime_manifest_ready=true\n" +
                                  "native_gui_runtime_contract_payload_ready=true\n" +
                                  "native_gui_runtime_bundle_payload_ready=true\n" +
                                  "native_gui_runtime_bundle_ready=true\n" +
                                  "native_gui_runtime_contract_ready=true\n" +
                                  "native_gui_runtime_bundle_route_state=publish_selector\n" +
                                  "native_gui_runtime_bundle_route_count=1\n" +
                                  "native_gui_runtime_bundle_supported_count=4\n" +
                                  "native_gui_runtime_bundle_semantic_nodes_count=67\n" +
                                  "native_gui_runtime_bundle_layout_item_count=24\n" +
                                  "native_gui_runtime_bundle_render_command_count=35\n" +
                                  "native_gui_runtime_contract_layout_item_count=24\n" +
                                  "native_gui_runtime_contract_viewport_item_count=12\n" +
                                  "native_gui_runtime_contract_interactive_item_count=5\n" +
                                  "native_gui_native_layout_plan_item_count=24\n" +
                                  "native_gui_render_plan_command_count=35\n" +
                                  "native_gui_storage_host_ready=true\n" +
                                  "native_gui_fetch_host_ready=true\n" +
                                  "native_gui_custom_event_host_ready=false\n" +
                                  "native_gui_resize_observer_host_ready=true\n"),
           " r2c render compare controller smoke: write native summary")
    assert(chengpath.WriteTextFile("", truthSummaryPath,
                                  "truth_trace_path=" + truthTracePath + "\n" +
                                  "truth_trace_format=truth_trace_v2\n" +
                                  "runtime_state_path=" + truthRuntimeStatePath + "\n" +
                                  "dom_path=" + truthDomPath + "\n" +
                                  "semantic_nodes_path=" + truthSemanticNodesPath + "\n" +
                                  "runtime_meta_path=" + truthRuntimeMetaPath + "\n" +
                                  "screenshot_path=" + truthPngPath + "\n" +
                                  "semantic_nodes_count=67\n" +
                                  "document_nodes_count=19\n" +
                                  "dom_hash=truth_dom_hash_publish_selector\n" +
                                  "screenshot_sha256=truth_screenshot_sha256_publish_selector\n" +
                                  "pathname=/publish\n" +
                                  "search=?route=publish_selector\n" +
                                  "hash=#selector\n"),
           " r2c render compare controller smoke: write truth summary")

    let controllerLog = os.JoinPath(outDir, "render_compare_controller.log")
    if chengpath.PathFileExists(controllerLog):
        os.RemoveFile(controllerLog)
    let controllerRun = hostops.RunFileLogged(root,
                                                "r2c_render_compare_controller_smoke",
                                                controllerExe,
                                                [
                                                    "render-compare",
                                                    "--repo", repo,
                                                    "--route", "publish_selector",
                                                    "--out-dir", outDir,
                                                    "--native-summary", nativeSummaryPath,
                                                    "--truth-summary", truthSummaryPath,
                                                    "--native-screenshot", nativePngPath,
                                                    "--truth-screenshot", truthPngPath
                                                ],
                                                [],
                                                root,
                                                0,
                                                controllerLog)
    assert(hostops.LoggedRunOk(controllerRun), " r2c render compare controller smoke: controller rc")
    assert(chengpath.FileExistsNonEmpty(root, renderComparePath), " r2c render compare controller smoke: report")
    assert(chengpath.FileExistsNonEmpty(root, renderCompareSummaryPath), " r2c render compare controller smoke: summary")

    let reportText = chengpath.ReadTextFile("", renderComparePath)
    let summaryText = chengpath.ReadTextFile("", renderCompareSummaryPath)
    assert(chengpath.TextContains(reportText, "\"command\": \"render-compare\""),
           " r2c render compare controller smoke: report command")
    assert(chengpath.TextContains(reportText, "\"ok\": true"),
           " r2c render compare controller smoke: report ok")
    assert(chengpath.TextContains(reportText, "\"primary_artifact_format\": \"render_compare_v1\""),
           " r2c render compare controller smoke: report artifact format")
    assert(chengpath.TextContains(reportText, "\"helper_script\": "),
           " r2c render compare controller smoke: report helper script")
    assert(chengpath.TextContains(reportText, "\"direct_mode\": true"),
           " r2c render compare controller smoke: report direct mode")
    assert(chengpath.TextContains(reportText, "\"route_state\": \"publish_selector\""),
           " r2c render compare controller smoke: report route state")
    assert(chengpath.TextContains(reportText, "\"route_state_match\": true"),
           " r2c render compare controller smoke: report route state match")
    assert(chengpath.TextContains(reportText, "\"native_gui_runtime_bundle_ready\": true"),
           " r2c render compare controller smoke: report runtime bundle ready")
    assert(chengpath.TextContains(reportText, "\"native_gui_runtime_contract_ready\": true"),
           " r2c render compare controller smoke: report runtime contract ready")
    assert(chengpath.TextContains(reportText, "\"truth_trace_format\": \"truth_trace_v2\""),
           " r2c render compare controller smoke: report truth trace format")
    assert(chengpath.TextContains(reportText, "\"semantic_nodes_count_delta\": 0"),
           " r2c render compare controller smoke: report semantic nodes delta")
    assert(chengpath.TextContains(reportText, "\"diff_pixel_count\": 0"),
           " r2c render compare controller smoke: report diff pixel count")

    assert(chengpath.TextContains(summaryText, "ok=true"),
           " r2c render compare controller smoke: summary ok")
    assert(chengpath.TextContains(summaryText, "direct_mode=true"),
           " r2c render compare controller smoke: summary direct mode")
    assert(chengpath.TextContains(summaryText, "route_state=publish_selector"),
           " r2c render compare controller smoke: summary route state")
    assert(chengpath.TextContains(summaryText, "route_state_match=true"),
           " r2c render compare controller smoke: summary route state match")
    assert(chengpath.TextContains(summaryText, "native_gui_runtime_bundle_ready=true"),
           " r2c render compare controller smoke: summary runtime bundle ready")
    assert(chengpath.TextContains(summaryText, "native_gui_runtime_contract_ready=true"),
           " r2c render compare controller smoke: summary runtime contract ready")
    assert(chengpath.TextContains(summaryText, "truth_trace_format=truth_trace_v2"),
           " r2c render compare controller smoke: summary truth trace format")
    assert(chengpath.TextContains(summaryText, "semantic_nodes_count_delta=0"),
           " r2c render compare controller smoke: summary semantic nodes delta")
    assert(chengpath.TextContains(summaryText, "diff_pixel_count=0"),
           " r2c render compare controller smoke: summary diff pixel count")

    echo(" r2c_react_render_compare_controller_smoke ok")
    return 0
