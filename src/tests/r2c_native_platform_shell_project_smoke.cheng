import std/os
import std/strutils as strutil
import cheng/core/tooling/path as chengpath
import cheng/r2c/native_platform_shell_package as shellpackage
import cheng/r2c/native_platform_shell_project as shellproject
import cheng/r2c/native_platform_shell_runtime as shellruntime

fn main(): int32 =
    let outDir: str = "/tmp/r2c_native_platform_shell_project_smoke_artifacts"
    let projectDir: str = chengpath.PathJoin(outDir, "native_platform_shell_project_v1")
    let framePath: str = chengpath.PathJoin(outDir, "frame.rgba")
    let shellManifestPath: str = chengpath.PathJoin(outDir, "native_platform_shell_manifest_v1.json")
    let packageManifestPath: str = chengpath.PathJoin(outDir, "native_platform_shell_package_manifest_v1.json")
    let projectManifestPath: str = chengpath.PathJoin(outDir, "native_platform_shell_project_manifest_v1.json")
    let androidProjectPath: str = chengpath.PathJoin(projectDir, "android/native_surface_shell_project_v1.json")
    let iosProjectPath: str = chengpath.PathJoin(projectDir, "ios/native_surface_shell_project_v1.json")
    let ohosProjectPath: str = chengpath.PathJoin(projectDir, "ohos/native_surface_shell_project_v1.json")
    let entryManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_entry_manifest_v1.json")
    let androidEntryPath: str = chengpath.PathJoin(projectDir, "android/native_surface_shell_entry_v1.json")
    let iosEntryPath: str = chengpath.PathJoin(projectDir, "ios/native_surface_shell_entry_v1.json")
    let ohosEntryPath: str = chengpath.PathJoin(projectDir, "ohos/native_surface_shell_entry_v1.json")
    let installManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_install_manifest_v1.json")
    let androidInstallPackagePath: str = chengpath.PathJoin(projectDir, "android/android_package_manifest_v1.json")
    let iosInstallPackagePath: str = chengpath.PathJoin(projectDir, "ios/ios_package_manifest_v1.json")
    let ohosInstallPackagePath: str = chengpath.PathJoin(projectDir, "ohos/ohos_package_manifest_v1.json")
    let filesManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_files_manifest_v1.json")
    let androidPlatformManifestPath: str = chengpath.PathJoin(projectDir, "android/AndroidManifest.xml")
    let androidShellSourcePath: str = chengpath.PathJoin(projectDir, "android/ChengNativeSurfaceActivity.cheng")
    let iosInfoPlistPath: str = chengpath.PathJoin(projectDir, "ios/Info.plist")
    let iosShellSourcePath: str = chengpath.PathJoin(projectDir, "ios/ChengNativeSurfaceViewController.cheng")
    let ohosModulePath: str = chengpath.PathJoin(projectDir, "ohos/module.json5")
    let ohosShellSourcePath: str = chengpath.PathJoin(projectDir, "ohos/ChengNativeSurfaceAbility.cheng")
    let buildInputsManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_build_inputs_manifest_v1.json")
    let androidBuildInputPath: str = chengpath.PathJoin(projectDir, "android/android_build_input_v1.json")
    let iosBuildInputPath: str = chengpath.PathJoin(projectDir, "ios/ios_build_input_v1.json")
    let ohosBuildInputPath: str = chengpath.PathJoin(projectDir, "ohos/ohos_build_input_v1.json")
    let packagingPlanManifestPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_packaging_plan_manifest_v1.json")
    let androidPackagingPlanPath: str = chengpath.PathJoin(projectDir, "android/android_packaging_plan_v1.json")
    let iosPackagingPlanPath: str = chengpath.PathJoin(projectDir, "ios/ios_packaging_plan_v1.json")
    let ohosPackagingPlanPath: str = chengpath.PathJoin(projectDir, "ohos/ohos_packaging_plan_v1.json")
    let projectSummaryPath: str = chengpath.PathJoin(projectDir, "native_platform_shell_project.summary.env")
    assert(chengpath.MkdirP("", outDir), "r2c native platform shell project smoke: mkdir")
    if os.FileExists(framePath):
        os.RemoveFile(framePath)
    if os.FileExists(shellManifestPath):
        os.RemoveFile(shellManifestPath)
    if os.FileExists(packageManifestPath):
        os.RemoveFile(packageManifestPath)
    if os.FileExists(projectManifestPath):
        os.RemoveFile(projectManifestPath)
    let framePayload: uint8[] = [
        uint8(255), uint8(0), uint8(0), uint8(255),
        uint8(0), uint8(255), uint8(0), uint8(255),
        uint8(0), uint8(0), uint8(255), uint8(255),
        uint8(255), uint8(255), uint8(255), uint8(255)
    ]
    os.WriteFileBytes(framePath, framePayload)
    var manifest = "{\n"
    manifest = strutil.Join([manifest, "  \"format\": \"native_platform_shell_manifest_v1\",\n"], "")
    manifest = strutil.Join([manifest, "  \"ready\": true,\n"], "")
    manifest = strutil.Join([manifest, "  \"generated_by\": \"cheng.native_gui_runtime_v1\",\n"], "")
    manifest = strutil.Join([manifest, "  \"runtime_purity\": {\"node\": false, \"react\": false, \"webview_business_layer\": false, \"business_js\": false},\n"], "")
    manifest = strutil.Join([manifest, "  \"surface_frame_path\": \"", framePath, "\",\n"], "")
    manifest = strutil.Join([manifest, "  \"surface_manifest_path\": \"/tmp/surface_manifest.json\",\n"], "")
    manifest = strutil.Join([manifest, "  \"route_replay_manifest_path\": \"/tmp/route_replay_manifest.json\",\n"], "")
    manifest = strutil.Join([manifest, "  \"interaction_manifest_path\": \"/tmp/interaction_manifest.json\",\n"], "")
    manifest = strutil.Join([manifest, "  \"frame_format\": \"surface_frame_rgba_v1\",\n"], "")
    manifest = strutil.Join([manifest, "  \"pixel_format\": \"rgba8_unpremultiplied\",\n"], "")
    manifest = strutil.Join([manifest, "  \"width\": 2,\n"], "")
    manifest = strutil.Join([manifest, "  \"height\": 2,\n"], "")
    manifest = strutil.Join([manifest, "  \"stride_bytes\": 8,\n"], "")
    manifest = strutil.Join([manifest, "  \"frame_byte_count\": 16,\n"], "")
    manifest = strutil.Join([manifest, "  \"route_count\": 3,\n"], "")
    manifest = strutil.Join([manifest, "  \"active_route_state\": \"home_default\",\n"], "")
    manifest = strutil.Join([manifest, "  \"event_loop\": \"event_driven_v1\",\n"], "")
    manifest = strutil.Join([manifest, "  \"platforms\": [\n"], "")
    manifest = strutil.Join([manifest, "    {\"id\":\"android\",\"shell_kind\":\"cheng_generated_android_surface_shell_v1\",\"surface_binding\":\"ANativeWindow_rgba_blit_v1\",\"input_binding\":\"AInputQueue_event_driven_v1\",\"blit_contract\":\"rgba8_stride_copy_v1\"},\n"], "")
    manifest = strutil.Join([manifest, "    {\"id\":\"ios\",\"shell_kind\":\"cheng_generated_ios_surface_shell_v1\",\"surface_binding\":\"CAMetalLayer_rgba_blit_v1\",\"input_binding\":\"UIKit_touch_event_driven_v1\",\"blit_contract\":\"rgba8_stride_copy_v1\"},\n"], "")
    manifest = strutil.Join([manifest, "    {\"id\":\"ohos\",\"shell_kind\":\"cheng_generated_ohos_surface_shell_v1\",\"surface_binding\":\"OHNativeWindow_rgba_blit_v1\",\"input_binding\":\"XComponent_event_driven_v1\",\"blit_contract\":\"rgba8_stride_copy_v1\"}\n"], "")
    manifest = strutil.Join([manifest, "  ]\n"], "")
    manifest = strutil.Join([manifest, "}\n"], "")
    os.WriteFile(shellManifestPath, manifest)
    assert(shellruntime.WriteNativePlatformShellLaunchPlans(shellManifestPath, outDir),
           "r2c native platform shell project smoke: write launch plans")
    assert(shellpackage.WriteNativePlatformShellPackageManifest(outDir, packageManifestPath),
           "r2c native platform shell project smoke: write package")
    assert(shellproject.WriteNativePlatformShellProject(packageManifestPath, projectDir, projectManifestPath),
           "r2c native platform shell project smoke: write project")
    assert(chengpath.FileExistsNonEmpty("", projectManifestPath),
           "r2c native platform shell project smoke: project manifest")
    assert(chengpath.FileExistsNonEmpty("", androidProjectPath),
           "r2c native platform shell project smoke: android project")
    assert(chengpath.FileExistsNonEmpty("", iosProjectPath),
           "r2c native platform shell project smoke: ios project")
    assert(chengpath.FileExistsNonEmpty("", ohosProjectPath),
           "r2c native platform shell project smoke: ohos project")
    assert(chengpath.FileExistsNonEmpty("", entryManifestPath),
           "r2c native platform shell project smoke: entry manifest")
    assert(chengpath.FileExistsNonEmpty("", androidEntryPath),
           "r2c native platform shell project smoke: android entry")
    assert(chengpath.FileExistsNonEmpty("", iosEntryPath),
           "r2c native platform shell project smoke: ios entry")
    assert(chengpath.FileExistsNonEmpty("", ohosEntryPath),
           "r2c native platform shell project smoke: ohos entry")
    assert(chengpath.FileExistsNonEmpty("", installManifestPath),
           "r2c native platform shell project smoke: install manifest")
    assert(chengpath.FileExistsNonEmpty("", androidInstallPackagePath),
           "r2c native platform shell project smoke: android install package")
    assert(chengpath.FileExistsNonEmpty("", iosInstallPackagePath),
           "r2c native platform shell project smoke: ios install package")
    assert(chengpath.FileExistsNonEmpty("", ohosInstallPackagePath),
           "r2c native platform shell project smoke: ohos install package")
    assert(chengpath.FileExistsNonEmpty("", filesManifestPath),
           "r2c native platform shell project smoke: files manifest")
    assert(chengpath.FileExistsNonEmpty("", androidPlatformManifestPath),
           "r2c native platform shell project smoke: android platform manifest")
    assert(chengpath.FileExistsNonEmpty("", androidShellSourcePath),
           "r2c native platform shell project smoke: android shell source")
    assert(chengpath.FileExistsNonEmpty("", iosInfoPlistPath),
           "r2c native platform shell project smoke: ios info plist")
    assert(chengpath.FileExistsNonEmpty("", iosShellSourcePath),
           "r2c native platform shell project smoke: ios shell source")
    assert(chengpath.FileExistsNonEmpty("", ohosModulePath),
           "r2c native platform shell project smoke: ohos module")
    assert(chengpath.FileExistsNonEmpty("", ohosShellSourcePath),
           "r2c native platform shell project smoke: ohos shell source")
    assert(chengpath.FileExistsNonEmpty("", buildInputsManifestPath),
           "r2c native platform shell project smoke: build inputs manifest")
    assert(chengpath.FileExistsNonEmpty("", androidBuildInputPath),
           "r2c native platform shell project smoke: android build input")
    assert(chengpath.FileExistsNonEmpty("", iosBuildInputPath),
           "r2c native platform shell project smoke: ios build input")
    assert(chengpath.FileExistsNonEmpty("", ohosBuildInputPath),
           "r2c native platform shell project smoke: ohos build input")
    assert(chengpath.FileExistsNonEmpty("", packagingPlanManifestPath),
           "r2c native platform shell project smoke: packaging plan manifest")
    assert(chengpath.FileExistsNonEmpty("", androidPackagingPlanPath),
           "r2c native platform shell project smoke: android packaging plan")
    assert(chengpath.FileExistsNonEmpty("", iosPackagingPlanPath),
           "r2c native platform shell project smoke: ios packaging plan")
    assert(chengpath.FileExistsNonEmpty("", ohosPackagingPlanPath),
           "r2c native platform shell project smoke: ohos packaging plan")
    assert(chengpath.FileExistsNonEmpty("", projectSummaryPath),
           "r2c native platform shell project smoke: summary")
    let projectText = os.ReadFile(projectManifestPath)
    let androidText = os.ReadFile(androidProjectPath)
    let iosText = os.ReadFile(iosProjectPath)
    let ohosText = os.ReadFile(ohosProjectPath)
    let entryText = os.ReadFile(entryManifestPath)
    let androidEntryText = os.ReadFile(androidEntryPath)
    let iosEntryText = os.ReadFile(iosEntryPath)
    let ohosEntryText = os.ReadFile(ohosEntryPath)
    let installManifestText = os.ReadFile(installManifestPath)
    let androidInstallText = os.ReadFile(androidInstallPackagePath)
    let iosInstallText = os.ReadFile(iosInstallPackagePath)
    let ohosInstallText = os.ReadFile(ohosInstallPackagePath)
    let filesManifestText = os.ReadFile(filesManifestPath)
    let androidPlatformManifestText = os.ReadFile(androidPlatformManifestPath)
    let androidShellSourceText = os.ReadFile(androidShellSourcePath)
    let iosInfoPlistText = os.ReadFile(iosInfoPlistPath)
    let iosShellSourceText = os.ReadFile(iosShellSourcePath)
    let ohosModuleText = os.ReadFile(ohosModulePath)
    let ohosShellSourceText = os.ReadFile(ohosShellSourcePath)
    let buildInputsManifestText = os.ReadFile(buildInputsManifestPath)
    let androidBuildInputText = os.ReadFile(androidBuildInputPath)
    let iosBuildInputText = os.ReadFile(iosBuildInputPath)
    let ohosBuildInputText = os.ReadFile(ohosBuildInputPath)
    let packagingPlanManifestText = os.ReadFile(packagingPlanManifestPath)
    let androidPackagingPlanText = os.ReadFile(androidPackagingPlanPath)
    let iosPackagingPlanText = os.ReadFile(iosPackagingPlanPath)
    let ohosPackagingPlanText = os.ReadFile(ohosPackagingPlanPath)
    let summaryText = os.ReadFile(projectSummaryPath)
    assert(shellproject.NativePlatformShellProjectManifestValid(projectText),
           "r2c native platform shell project smoke: project valid")
    assert(strutil.Contains(projectText, "\"project_kind\": \"cheng_generated_native_surface_shell_project_v1\""),
           "r2c native platform shell project smoke: project kind")
    assert(strutil.Contains(projectText, "\"platform_count\": 3"),
           "r2c native platform shell project smoke: platform count")
    assert(strutil.Contains(androidText, "\"project_kind\": \"cheng_generated_android_native_surface_project_v1\""),
           "r2c native platform shell project smoke: android kind")
    assert(strutil.Contains(androidText, "\"surface_binding\": \"ANativeWindow_rgba_blit_v1\""),
           "r2c native platform shell project smoke: android surface")
    assert(strutil.Contains(iosText, "\"surface_binding\": \"CAMetalLayer_rgba_blit_v1\""),
           "r2c native platform shell project smoke: ios surface")
    assert(strutil.Contains(ohosText, "\"surface_binding\": \"OHNativeWindow_rgba_blit_v1\""),
           "r2c native platform shell project smoke: ohos surface")
    assert(strutil.Contains(entryText, "\"format\": \"native_platform_shell_entry_manifest_v1\""),
           "r2c native platform shell project smoke: entry manifest format")
    assert(strutil.Contains(entryText, "\"entry_symbol\":\"ChengNativeSurfaceShellMain\""),
           "r2c native platform shell project smoke: entry symbol")
    assert(strutil.Contains(androidEntryText, "\"entry_kind\": \"cheng_android_native_surface_entry_v1\""),
           "r2c native platform shell project smoke: android entry kind")
    assert(strutil.Contains(androidEntryText, "\"entry_symbol\": \"ChengNativeSurfaceShellMain\""),
           "r2c native platform shell project smoke: android entry symbol")
    assert(strutil.Contains(iosEntryText, "\"surface_binding\": \"CAMetalLayer_rgba_blit_v1\""),
           "r2c native platform shell project smoke: ios entry surface")
    assert(strutil.Contains(ohosEntryText, "\"surface_binding\": \"OHNativeWindow_rgba_blit_v1\""),
           "r2c native platform shell project smoke: ohos entry surface")
    assert(shellproject.NativePlatformShellInstallManifestValid(installManifestText),
           "r2c native platform shell project smoke: install manifest valid")
    assert(strutil.Contains(installManifestText, "\"format\": \"native_platform_shell_install_manifest_v1\""),
           "r2c native platform shell project smoke: install manifest format")
    assert(strutil.Contains(installManifestText, "\"install_package_count\": 3"),
           "r2c native platform shell project smoke: install package count")
    assert(strutil.Contains(androidInstallText, "\"package_kind\": \"android_native_surface_app_manifest_v1\""),
           "r2c native platform shell project smoke: android install kind")
    assert(strutil.Contains(androidInstallText, "\"c_dependency\": false"),
           "r2c native platform shell project smoke: android no c dependency")
    assert(strutil.Contains(androidInstallText, "\"primary_component\": \"ChengNativeSurfaceActivity\""),
           "r2c native platform shell project smoke: android primary component")
    assert(strutil.Contains(iosInstallText, "\"package_kind\": \"ios_native_surface_app_manifest_v1\""),
           "r2c native platform shell project smoke: ios install kind")
    assert(strutil.Contains(iosInstallText, "\"surface_binding\": \"CAMetalLayer_rgba_blit_v1\""),
           "r2c native platform shell project smoke: ios install surface")
    assert(strutil.Contains(ohosInstallText, "\"package_kind\": \"ohos_native_surface_app_manifest_v1\""),
           "r2c native platform shell project smoke: ohos install kind")
    assert(strutil.Contains(ohosInstallText, "\"surface_binding\": \"OHNativeWindow_rgba_blit_v1\""),
           "r2c native platform shell project smoke: ohos install surface")
    assert(shellproject.NativePlatformShellFilesManifestValid(filesManifestText),
           "r2c native platform shell project smoke: files manifest valid")
    assert(strutil.Contains(filesManifestText, "\"format\": \"native_platform_shell_files_manifest_v1\""),
           "r2c native platform shell project smoke: files manifest format")
    assert(strutil.Contains(filesManifestText, "\"platform_file_count\": 6"),
           "r2c native platform shell project smoke: platform file count")
    assert(strutil.Contains(androidPlatformManifestText, "ChengNativeSurfaceActivity"),
           "r2c native platform shell project smoke: android manifest activity")
    assert(!strutil.Contains(androidPlatformManifestText, "WebView"),
           "r2c native platform shell project smoke: android manifest no webview")
    assert(strutil.Contains(androidShellSourceText, "ANativeWindow_rgba_blit_v1"),
           "r2c native platform shell project smoke: android shell source surface")
    assert(strutil.Contains(androidShellSourceText, "polling=false"),
           "r2c native platform shell project smoke: android shell source event driven")
    assert(strutil.Contains(iosInfoPlistText, "org.cheng.unimaker.nativegui"),
           "r2c native platform shell project smoke: ios plist bundle id")
    assert(strutil.Contains(iosShellSourceText, "CAMetalLayer_rgba_blit_v1"),
           "r2c native platform shell project smoke: ios shell source surface")
    assert(strutil.Contains(ohosModuleText, "ChengNativeSurfaceAbility"),
           "r2c native platform shell project smoke: ohos module ability")
    assert(strutil.Contains(ohosShellSourceText, "OHNativeWindow_rgba_blit_v1"),
           "r2c native platform shell project smoke: ohos shell source surface")
    assert(shellproject.NativePlatformShellBuildInputsManifestValid(buildInputsManifestText),
           "r2c native platform shell project smoke: build inputs manifest valid")
    assert(strutil.Contains(projectText, "\"build_inputs_manifest_path\":"),
           "r2c native platform shell project smoke: project build inputs path")
    assert(strutil.Contains(projectText, "\"build_input_count\": 3"),
           "r2c native platform shell project smoke: project build input count")
    assert(strutil.Contains(buildInputsManifestText, "\"format\": \"native_platform_shell_build_inputs_manifest_v1\""),
           "r2c native platform shell project smoke: build inputs format")
    assert(strutil.Contains(buildInputsManifestText, "\"build_input_count\": 3"),
           "r2c native platform shell project smoke: build input count")
    assert(strutil.Contains(buildInputsManifestText, "\"target_triple\":\"aarch64-linux-android\""),
           "r2c native platform shell project smoke: android target")
    assert(strutil.Contains(buildInputsManifestText, "\"target_triple\":\"arm64-apple-ios\""),
           "r2c native platform shell project smoke: ios target")
    assert(strutil.Contains(buildInputsManifestText, "\"target_triple\":\"aarch64-linux-ohos\""),
           "r2c native platform shell project smoke: ohos target")
    assert(strutil.Contains(androidBuildInputText, "\"format\": \"native_platform_shell_build_input_v1\""),
           "r2c native platform shell project smoke: android build input format")
    assert(strutil.Contains(androidBuildInputText, "\"requires_node\": false"),
           "r2c native platform shell project smoke: android build input no node")
    assert(strutil.Contains(androidBuildInputText, "\"requires_c_dependency\": false"),
           "r2c native platform shell project smoke: android build input no c dependency")
    assert(strutil.Contains(androidBuildInputText, "\"requires_script\": false"),
           "r2c native platform shell project smoke: android build input no script")
    assert(strutil.Contains(androidBuildInputText, "\"platform_identifier_kind\": \"android_package_id\""),
           "r2c native platform shell project smoke: android identifier kind")
    assert(strutil.Contains(androidBuildInputText, "\"surface_binding\": \"ANativeWindow_rgba_blit_v1\""),
           "r2c native platform shell project smoke: android build input surface")
    assert(strutil.Contains(iosBuildInputText, "\"target_triple\": \"arm64-apple-ios\""),
           "r2c native platform shell project smoke: ios build input target")
    assert(strutil.Contains(iosBuildInputText, "\"platform_identifier_kind\": \"ios_bundle_id\""),
           "r2c native platform shell project smoke: ios identifier kind")
    assert(strutil.Contains(iosBuildInputText, "\"surface_binding\": \"CAMetalLayer_rgba_blit_v1\""),
           "r2c native platform shell project smoke: ios build input surface")
    assert(strutil.Contains(ohosBuildInputText, "\"target_triple\": \"aarch64-linux-ohos\""),
           "r2c native platform shell project smoke: ohos build input target")
    assert(strutil.Contains(ohosBuildInputText, "\"platform_identifier_kind\": \"ohos_bundle_name\""),
           "r2c native platform shell project smoke: ohos identifier kind")
    assert(strutil.Contains(ohosBuildInputText, "\"surface_binding\": \"OHNativeWindow_rgba_blit_v1\""),
           "r2c native platform shell project smoke: ohos build input surface")
    assert(shellproject.NativePlatformShellPackagingPlanManifestValid(packagingPlanManifestText),
           "r2c native platform shell project smoke: packaging plan manifest valid")
    assert(strutil.Contains(projectText, "\"packaging_plan_manifest_path\":"),
           "r2c native platform shell project smoke: project packaging plan path")
    assert(strutil.Contains(projectText, "\"packaging_plan_count\": 3"),
           "r2c native platform shell project smoke: project packaging plan count")
    assert(strutil.Contains(packagingPlanManifestText, "\"format\": \"native_platform_shell_packaging_plan_manifest_v1\""),
           "r2c native platform shell project smoke: packaging manifest format")
    assert(strutil.Contains(packagingPlanManifestText, "\"artifact_emitted\": false"),
           "r2c native platform shell project smoke: packaging manifest not emitted")
    assert(strutil.Contains(packagingPlanManifestText, "\"packaging_plan_count\": 3"),
           "r2c native platform shell project smoke: packaging plan count")
    assert(strutil.Contains(androidPackagingPlanText, "\"format\": \"native_platform_shell_packaging_plan_v1\""),
           "r2c native platform shell project smoke: android packaging plan format")
    assert(strutil.Contains(androidPackagingPlanText, "\"artifact_emitted\": false"),
           "r2c native platform shell project smoke: android artifact not emitted")
    assert(strutil.Contains(androidPackagingPlanText, strutil.Join(["\"build_input_path\": \"", androidBuildInputPath, "\""], "")),
           "r2c native platform shell project smoke: android packaging consumes build input")
    assert(strutil.Contains(androidPackagingPlanText, "\"requires_node\": false"),
           "r2c native platform shell project smoke: android packaging no node")
    assert(strutil.Contains(androidPackagingPlanText, "\"requires_c_dependency\": false"),
           "r2c native platform shell project smoke: android packaging no c dependency")
    assert(strutil.Contains(androidPackagingPlanText, "\"compile_contract\": \"cheng_release_native_mobile_module_v1\""),
           "r2c native platform shell project smoke: android packaging compile contract")
    assert(strutil.Contains(iosPackagingPlanText, "\"platform_identifier_kind\": \"ios_bundle_id\""),
           "r2c native platform shell project smoke: ios packaging identifier")
    assert(strutil.Contains(iosPackagingPlanText, "\"surface_binding\": \"CAMetalLayer_rgba_blit_v1\""),
           "r2c native platform shell project smoke: ios packaging surface")
    assert(strutil.Contains(ohosPackagingPlanText, "\"platform_identifier_kind\": \"ohos_bundle_name\""),
