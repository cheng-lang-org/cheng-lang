    assert(strutil.Contains(ohosPackagingPlanText, "\"surface_binding\": \"OHNativeWindow_rgba_blit_v1\""),
           "r2c native platform shell project smoke: ohos packaging surface")
    assert(strutil.Contains(summaryText, "ready=true"),
           "r2c native platform shell project smoke: summary ready")
    assert(strutil.Contains(summaryText, strutil.Join(["entry_manifest_path=", entryManifestPath], "")),
           "r2c native platform shell project smoke: summary entry manifest")
    assert(strutil.Contains(summaryText, strutil.Join(["install_manifest_path=", installManifestPath], "")),
           "r2c native platform shell project smoke: summary install manifest")
    assert(strutil.Contains(summaryText, strutil.Join(["files_manifest_path=", filesManifestPath], "")),
