import std/os
import std/result
import cheng/apps/wow_export/render as render

fn removeIfExists(path: str) =
    if os.FileExists(path):
        let _ = os.RemoveFile(path)

fn main(): int32 =
    let outPath: str = "/tmp/wow_export_render_smoke_northshire.tga"
    removeIfExists(outPath)
    let renderRes: Result[render.RenderSummary] =
        render.RenderNorthshireTga(outPath, 320, 180)
    assert(IsOk(renderRes), Error(renderRes))
    let summary: render.RenderSummary = Value(renderRes)
    assert(summary.bytesWritten == 18 + 320 * 180 * 4,
           "wow_export_render_smoke tga bytes")
    assert(summary.adtHeightSampleCount == 148480,
           "wow_export_render_smoke adt height samples")
    assert(summary.wmoVertexCount == 29304,
           "wow_export_render_smoke wmo vertices")
    assert(summary.wmoDoodadPlacementCount == 144,
           "wow_export_render_smoke wmo doodad placements")
    assert(summary.wmoDoodadModelPlacementCount == 144,
           "wow_export_render_smoke wmo doodad model placements")
    assert(summary.wmoDoodadReferencedModelFileDataIDCount == 15,
           "wow_export_render_smoke wmo doodad referenced models")
    assert(summary.wmoDoodadModelDependencyCount == 17,
           "wow_export_render_smoke wmo doodad model dependencies")
    assert(summary.m2VertexCount == 370,
           "wow_export_render_smoke m2 vertices")
    assert(summary.skinTriangleIndexCount == 1302,
           "wow_export_render_smoke skin triangles")
    assert(summary.pixelsTouched > 0,
           "wow_export_render_smoke pixels")
    assert(os.FileExists(outPath), "wow_export_render_smoke output exists")
    assert(os.FileSize(outPath) == int64(summary.bytesWritten),
           "wow_export_render_smoke output size")
    removeIfExists(outPath)
    echo("wow_export_render_smoke ok")
    return 0
