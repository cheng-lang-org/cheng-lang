import std/os
import std/result
import cheng/apps/wow_export/render as render

fn removeIfExists(path: str) =
    if os.FileExists(path):
        let _ = os.RemoveFile(path)

fn main(): int32 =
    let outPath: str = "/tmp/wow_export_render_smoke_northshire.tga"
    removeIfExists(outPath)
    let renderRes: Result[render.RenderSummary] =
        render.RenderNorthshireTga(outPath, 320, 180)
    assert(IsOk(renderRes), Error(renderRes))
    let summary: render.RenderSummary = Value(renderRes)
    assert(summary.bytesWritten == 18 + 320 * 180 * 4,
           "wow_export_render_smoke tga bytes")
    assert(summary.adtHeightSampleCount == 148480,
           "wow_export_render_smoke adt height samples")
    assert(summary.wmoVertexCount == 29304,
           "wow_export_render_smoke wmo vertices")
    assert(summary.wmoDoodadPlacementCount == 144,
           "wow_export_render_smoke wmo doodad placements")
    assert(summary.wmoDoodadModelPlacementCount == 144,
           "wow_export_render_smoke wmo doodad model placements")
    assert(summary.wmoDoodadReferencedModelFileDataIDCount == 15,
           "wow_export_render_smoke wmo doodad referenced models")
    assert(summary.wmoDoodadModelDependencyCount == 17,
           "wow_export_render_smoke wmo doodad model dependencies")
    assert(summary.wdtMaidSplitDependencyCount == 28,
           "wow_export_render_smoke wdt maid split dependencies")
    assert(summary.wdtMaidSplitDependenciesReady,
           "wow_export_render_smoke wdt maid split dependency ready")
    assert(summary.wdtMaidParsedDependencyCount == 28,
           "wow_export_render_smoke wdt maid parsed dependencies")
    assert(summary.wdtMaidAdtSplitResourceCount == 16,
           "wow_export_render_smoke wdt maid adt split resources")
    assert(summary.wdtMaidBlpResourceCount == 12,
           "wow_export_render_smoke wdt maid blp resources")
    assert(summary.wdtMaidAdtSplitChunkCount == 2164,
           "wow_export_render_smoke wdt maid split chunks")
    assert(summary.wdtMaidAdtSplitMapChunkCount == 2048,
           "wow_export_render_smoke wdt maid split mcnk chunks")
    assert(summary.wdtMaidDoodadPlacementCount == 4345,
           "wow_export_render_smoke wdt maid doodad placements")
    assert(summary.wdtMaidDoodadReferencedFileDataIDCount == 222,
           "wow_export_render_smoke wdt maid doodad fileDataIDs")
    assert(summary.wdtMaidFirstDoodadReferencedFileDataID == 189929,
           "wow_export_render_smoke wdt maid first doodad fileDataID")
    assert(summary.wdtMaidDoodadPlacementDependencyCount == 222,
           "wow_export_render_smoke wdt maid doodad placement dependencies")
    assert(summary.wdtMaidDoodadPlacementBoundsReady,
           "wow_export_render_smoke wdt maid doodad placement bounds")
    assert(summary.wdtMaidDoodadPlacementMaxX1000 - summary.wdtMaidDoodadPlacementMinX1000 == 1125287,
           "wow_export_render_smoke wdt maid doodad placement span x")
    assert(summary.wdtMaidDoodadPlacementMaxY1000 - summary.wdtMaidDoodadPlacementMinY1000 == 221256,
           "wow_export_render_smoke wdt maid doodad placement span y")
    assert(summary.wdtMaidDoodadPlacementMaxZ1000 - summary.wdtMaidDoodadPlacementMinZ1000 == 1145929,
           "wow_export_render_smoke wdt maid doodad placement span z")
    assert(summary.wdtMaidDoodadMinScale == 133 && summary.wdtMaidDoodadMaxScale == 3389,
           "wow_export_render_smoke wdt maid doodad placement scale")
    assert(summary.wdtMaidWorldModelPlacementCount == 32,
           "wow_export_render_smoke wdt maid world model placements")
    assert(summary.wdtMaidWorldModelReferencedFileDataIDCount == 18,
           "wow_export_render_smoke wdt maid world model fileDataIDs")
    assert(summary.wdtMaidFirstWorldModelReferencedFileDataID == 108104,
           "wow_export_render_smoke wdt maid first world model fileDataID")
    assert(summary.wdtMaidWorldModelPlacementDependencyCount == 18,
           "wow_export_render_smoke wdt maid world model placement dependencies")
    assert(summary.wdtMaidPlacementDependencyAuditReady,
           "wow_export_render_smoke wdt maid placement dependency audit")
    assert(summary.wdtMaidPlacementDependencyEncodedBytes == 1299207,
           "wow_export_render_smoke wdt maid placement dependency encoded bytes")
    assert(summary.wdtMaidWorldModelPlacementBoundsReady,
           "wow_export_render_smoke wdt maid world model placement bounds")
    assert(summary.wdtMaidWorldModelPlacementMaxX1000 - summary.wdtMaidWorldModelPlacementMinX1000 == 1133681,
           "wow_export_render_smoke wdt maid world model placement span x")
    assert(summary.wdtMaidWorldModelPlacementMaxY1000 - summary.wdtMaidWorldModelPlacementMinY1000 == 61759,
           "wow_export_render_smoke wdt maid world model placement span y")
    assert(summary.wdtMaidWorldModelPlacementMaxZ1000 - summary.wdtMaidWorldModelPlacementMinZ1000 == 899866,
           "wow_export_render_smoke wdt maid world model placement span z")
    assert(summary.wdtMaidWorldModelMinScale == 1024 && summary.wdtMaidWorldModelMaxScale == 1024,
           "wow_export_render_smoke wdt maid world model placement scale")
    assert(summary.wmoDoodadModelVertexCount == 31665,
           "wow_export_render_smoke wmo doodad model vertices")
    assert(summary.m2VertexCount == 370,
           "wow_export_render_smoke m2 vertices")
    assert(summary.skinTriangleIndexCount == 1302,
           "wow_export_render_smoke skin triangles")
    assert(summary.pixelsTouched > 0,
           "wow_export_render_smoke pixels")
    assert(os.FileExists(outPath), "wow_export_render_smoke output exists")
    assert(os.FileSize(outPath) == int64(summary.bytesWritten),
           "wow_export_render_smoke output size")
    removeIfExists(outPath)
    echo("wow_export_render_smoke ok")
    return 0
