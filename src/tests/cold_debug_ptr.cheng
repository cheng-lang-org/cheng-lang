type TypeKind = Int32 | Str | Bool | Void

type TypeRep =
    Primitive(kind: TypeKind, sizeBytes: int32)
    | Pointer(innerKind: TypeKind)
    | Aggregate(totalSize: int32)

fn TypeRepPrimitiveKind(rep: TypeRep): int32 =
    match rep:
        Primitive(k, sz) =>
            match k:
                Int32 => return 1
                Str => return 2
                Bool => return 3
                Void => return 0
        Pointer(inner) => return 10
        Aggregate(totalSize) => return 20

fn main(): int32 =
    let ptrRep = Pointer(Int32)
    return TypeRepPrimitiveKind(ptrRep)
