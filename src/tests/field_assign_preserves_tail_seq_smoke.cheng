import std/system

type
    Inner =
        xs: int32[]
        ys: int32[]

    Outer =
        inner: Inner
        tail: int32[]

fn main(): int32 =
    var outer = Outer()
    add(outer.tail, 11)
    assert(outer.tail.len == 1, " field assign preserves tail seq: pre len")
    assert(outer.tail[0] == 11, " field assign preserves tail seq: pre item")

    var nextInner = outer.inner
    add(nextInner.xs, 7)
    add(nextInner.ys, 9)
    outer.inner = nextInner

    assert(outer.inner.xs.len == 1, " field assign preserves tail seq: inner xs len")
    assert(outer.inner.ys.len == 1, " field assign preserves tail seq: inner ys len")
    assert(outer.tail.len == 1, " field assign preserves tail seq: post len")
    assert(outer.tail[0] == 11, " field assign preserves tail seq: post item")
    echo(" field_assign_preserves_tail_seq_smoke ok")
    return 0
