import std/os
import std/strutils as strutil
import cheng/core/tooling/host_smoke_gate as gate
import cheng/core/tooling/path as chengpath

fn writeReport(path: str,
               text: str) =
    os.WriteFile(path, text)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let outDir = chengpath.PathAbsolute(root, "artifacts/host_smoke_gate_contract")
    assert(chengpath.MkdirP(root, outDir), " host smoke gate contract: mkdir")

    let goodReport = chengpath.PathJoin(outDir, "good.report.txt")
    writeReport(goodReport, strutil.Join([
        "system_link_exec_runtime_execute=1",
        "provider_object_count=2",
        "object_link_input_count=3"
    ], "\n"))
    assert(gate.HostSmokeCompileReportOk(root,
                                         "thread_atomic_orc_runtime_gate_smoke",
                                         goodReport),
           " host smoke gate contract: good runtime report")

    let missingMarkerReport = chengpath.PathJoin(outDir, "missing_marker.report.txt")
    writeReport(missingMarkerReport, strutil.Join([
        "provider_object_count=2",
        "object_link_input_count=3"
    ], "\n"))
    assert(!gate.HostSmokeCompileReportOk(root,
                                          "thread_atomic_orc_runtime_gate_smoke",
                                          missingMarkerReport),
           " host smoke gate contract: reject missing runtime marker")

    let standaloneReport = chengpath.PathJoin(outDir, "standalone.report.txt")
    writeReport(standaloneReport, strutil.Join([
        "system_link_exec_runtime_execute=1",
        "system_link_exec_runtime_standalone_no_runtime=1",
        "provider_object_count=2"
    ], "\n"))
    assert(!gate.HostSmokeCompileReportOk(root,
                                          "thread_atomic_orc_runtime_gate_smoke",
                                          standaloneReport),
           " host smoke gate contract: reject standalone no-runtime")

    let missingProviderReport = chengpath.PathJoin(outDir, "missing_provider.report.txt")
    writeReport(missingProviderReport, strutil.Join([
        "system_link_exec_runtime_execute=1",
        "object_link_input_count=1"
    ], "\n"))
    assert(!gate.HostSmokeCompileReportOk(root,
                                          "thread_atomic_orc_runtime_gate_smoke",
                                          missingProviderReport),
           " host smoke gate contract: reject missing provider count")

    let zeroProviderReport = chengpath.PathJoin(outDir, "zero_provider.report.txt")
    writeReport(zeroProviderReport, strutil.Join([
        "system_link_exec_runtime_execute=1",
        "provider_object_count=0"
    ], "\n"))
    assert(!gate.HostSmokeCompileReportOk(root,
                                          "thread_atomic_orc_runtime_gate_smoke",
                                          zeroProviderReport),
           " host smoke gate contract: reject zero provider count")

    assert(gate.HostSmokeCompileReportOk(root,
                                         "function_task_contract_smoke",
                                         zeroProviderReport),
           " host smoke gate contract: non-runtime report skipped")
    assert(gate.HostSmokeRunMarkerOk("thread_atomic_orc_runtime_gate_smoke",
                                     " thread_atomic_orc_runtime_gate_smoke ok"),
           " host smoke gate contract: runtime marker accepted")
    assert(!gate.HostSmokeRunMarkerOk("thread_atomic_orc_runtime_gate_smoke", ""),
           " host smoke gate contract: runtime marker required")
    assert(!gate.HostSmokeRunMarkerOk("function_task_contract_smoke", ""),
           " host smoke gate contract: function task marker required")
    assert(gate.HostSmokeRunMarkerOk("compiler_csg_egraph_active_contract_smoke",
                                     " compiler_csg_egraph_active_contract_smoke ok"),
           " host smoke gate contract: compiler csg egraph marker accepted")
    assert(!gate.HostSmokeRunMarkerOk("compiler_csg_egraph_active_contract_smoke", ""),
           " host smoke gate contract: compiler csg egraph marker required")

    echo(" host_smoke_gate_contract_smoke ok")
    return 0
