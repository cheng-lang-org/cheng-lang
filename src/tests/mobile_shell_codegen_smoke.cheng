import std/monotimes
import std/os
import std/strings
import cheng/core/tooling/mobile_shell_codegen as mshell
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let stamp: str = int64ToStr(monotimes.MonoTimeNs(monotimes.GetMonoTime()))
    let outDir: str = Fmt"/tmp/cheng_mobile_shell_codegen_smoke_{stamp}"
    let madeOutDir: bool = chengpath.MkdirP(root, outDir)
    assert(madeOutDir, "mobile shell smoke: out dir")
    let runtimeInputDir: str = os.JoinPath(outDir, "runtime_inputs")
    let madeRuntimeInputDir: bool = chengpath.MkdirP(root, runtimeInputDir)
    assert(madeRuntimeInputDir, "mobile shell smoke: runtime input dir")
    let runtimeContractInput: str = os.JoinPath(runtimeInputDir, "native_gui_runtime_contract_v1.json")
    let runtimeBundleInput: str = os.JoinPath(runtimeInputDir, "native_gui_bundle_v1.json")
    let semanticInput: str = os.JoinPath(runtimeInputDir, "r2c_semantic_render_nodes.tsv")
    let truthInputDir: str = os.JoinPath(runtimeInputDir, "truth")
    let truthInputRgba: str = os.JoinPath(truthInputDir, "home_default.rgba")
    let truthInputMeta: str = os.JoinPath(truthInputDir, "home_default.meta.json")
    os.WriteFile(runtimeContractInput, "{\n  \"format\":\"native_gui_runtime_contract_v1\"\n}\n")
    os.WriteFile(runtimeBundleInput, "{\n  \"format\":\"native_gui_bundle_v1\"\n}\n")
    assert(chengpath.MkdirP(root, truthInputDir), "mobile shell smoke: truth input dir")
    os.WriteFile(semanticInput, "node_1\thome_default\ttext\t48656c6c6f\t#root\tonClick\tapp/App.tsx\t/App")
    os.WriteFile(truthInputRgba, "RGBA")
    os.WriteFile(truthInputMeta, "{\n  \"width\": 1,\n  \"height\": 1\n}")
    var opts = mshell.MobileShellDefaultOptions(root)
    opts.outDir = outDir
    opts.appId = "org.cheng.smoke"
    opts.appName = "ChengSmoke"
    opts.libName = "cheng_smoke_app"
    opts.runtimeMode = "r2c_native_gui_v1"
    opts.runtimeContractPath = runtimeContractInput
    opts.runtimeBundlePath = runtimeBundleInput
    opts.routeState = "home_default"
    opts.emitAndroid = true
    opts.emitIos = true
    opts.emitHarmony = true
    var manifestPath: str
    var errorText: str
    let exportOk: bool = mshell.MobileShellExportResolved(opts,
                                                            manifestPath,
                                                            errorText)
    let errorPath: str = os.JoinPath(outDir, "mobile_shell_error.txt")
    if !exportOk:
        os.WriteFile(errorPath, errorText)
        echo("mobile shell smoke: export failed")
        return 1
    assert(len(errorText) == 0, "mobile shell smoke: export empty error")

    let manifest: str = os.JoinPath(outDir, "mobile_shell_manifest_v1.json")
    let runtimeManifest: str = os.JoinPath(outDir, "mobile_shell_runtime_contract_v1.json")
    let runtimeContractPayload: str = os.JoinPath(outDir, "runtime/runtime_contract_payload.json")
    let runtimeBundlePayload: str = os.JoinPath(outDir, "runtime/runtime_bundle_payload.json")
    let runtimeSemanticNodes: str = os.JoinPath(outDir, "runtime/r2c_semantic_render_nodes.tsv")
    let runtimeTruthRgba: str = os.JoinPath(outDir, "runtime/truth/home_default.rgba")
    let runtimeTruthMeta: str = os.JoinPath(outDir, "runtime/truth/home_default.meta.json")
    let launchArgsKv: str = os.JoinPath(outDir, "runtime/mobile_shell_launch_args.kv")
    let launchArgsJson: str = os.JoinPath(outDir, "runtime/mobile_shell_launch_args.json")
    let androidGradleProperties: str = os.JoinPath(outDir, "android/gradle.properties")
    let androidHost: str = os.JoinPath(outDir, "android/app/src/main/cpp/cheng_generated_android_host.c")
    let androidActivity: str = os.JoinPath(outDir, "android/app/src/main/kotlin/org/cheng/smoke/ChengMainActivity.kt")
    let androidStrings: str = os.JoinPath(outDir, "android/app/src/main/res/values/strings.xml")
    let androidRuntimeManifestAsset: str = os.JoinPath(outDir, "android/app/src/main/assets/mobile_shell_runtime_contract_v1.json")
    let androidRuntimeContractAsset: str = os.JoinPath(outDir, "android/app/src/main/assets/runtime/mobile_shell_runtime_contract_payload.json")
    let androidRuntimeBundleAsset: str = os.JoinPath(outDir, "android/app/src/main/assets/runtime/mobile_shell_runtime_bundle_payload.json")
    let androidSemanticNodesAsset: str = os.JoinPath(outDir, "android/app/src/main/assets/runtime/r2c_semantic_render_nodes.tsv")
    let androidTruthRgbaAsset: str = os.JoinPath(outDir, "android/app/src/main/assets/runtime/truth/home_default.rgba")
    let androidLaunchArgsKvAsset: str = os.JoinPath(outDir, "android/app/src/main/assets/runtime/mobile_shell_launch_args.kv")
    let androidLaunchArgsJsonAsset: str = os.JoinPath(outDir, "android/app/src/main/assets/runtime/mobile_shell_launch_args.json")
    let iosInfoPlist: str = os.JoinPath(outDir, "ios/Info.plist")
    let iosViewController: str = os.JoinPath(outDir, "ios/ChengGeneratedMetalViewController.m")
    let iosProject: str = os.JoinPath(outDir, "ios/ChengGeneratedApp.xcodeproj/project.pbxproj")
    let iosRuntimeManifest: str = os.JoinPath(outDir, "ios/runtime/mobile_shell_runtime_contract_v1.json")
    let iosRuntimeContractPayload: str = os.JoinPath(outDir, "ios/runtime/mobile_shell_runtime_contract_payload.json")
    let iosRuntimeBundlePayload: str = os.JoinPath(outDir, "ios/runtime/mobile_shell_runtime_bundle_payload.json")
    let iosSemanticNodes: str = os.JoinPath(outDir, "ios/runtime/r2c_semantic_render_nodes.tsv")
    let iosTruthRgba: str = os.JoinPath(outDir, "ios/runtime/truth/home_default.rgba")
    let iosLaunchArgsKv: str = os.JoinPath(outDir, "ios/runtime/mobile_shell_launch_args.kv")
    let iosLaunchArgsJson: str = os.JoinPath(outDir, "ios/runtime/mobile_shell_launch_args.json")
    let harmonyHvigorFile: str = os.JoinPath(outDir, "harmony/hvigorfile.ts")
    let harmonyHvigorConfig: str = os.JoinPath(outDir, "harmony/hvigor/hvigor-config.json5")
    let harmonyEntryHvigorFile: str = os.JoinPath(outDir, "harmony/entry/hvigorfile.ts")
    let harmonyEntryBuildProfile: str = os.JoinPath(outDir, "harmony/entry/build-profile.json5")
    let harmonyStringJson: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/base/element/string.json")
    let harmonyColorJson: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/base/element/color.json")
    let harmonyAppIcon: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/base/media/app_icon.svg")
    let harmonyRuntimeManifest: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/rawfile/mobile_shell_runtime_contract_v1.json")
    let harmonyRuntimeContractPayload: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/rawfile/mobile_shell_runtime_contract_payload.json")
    let harmonyRuntimeBundlePayload: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/rawfile/mobile_shell_runtime_bundle_payload.json")
    let harmonySemanticNodes: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/rawfile/runtime/r2c_semantic_render_nodes.tsv")
    let harmonyTruthRgba: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/rawfile/runtime/truth/home_default.rgba")
    let harmonyLaunchArgsKv: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/rawfile/mobile_shell_launch_args.kv")
    let harmonyLaunchArgsJson: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/rawfile/mobile_shell_launch_args.json")
    let harmonyCmake: str = os.JoinPath(outDir, "harmony/entry/src/main/cpp/CMakeLists.txt")
    let harmonyHost: str = os.JoinPath(outDir, "harmony/entry/src/main/cpp/cheng_generated_harmony_host.cpp")
    let harmonyEntryAbility: str = os.JoinPath(outDir, "harmony/entry/src/main/ets/entryability/EntryAbility.ets")
    let harmonyIndexEts: str = os.JoinPath(outDir, "harmony/entry/src/main/ets/pages/Index.ets")
    let harmonyMainPages: str = os.JoinPath(outDir, "harmony/entry/src/main/resources/base/profile/main_pages.json")

    assert(os.FileExists(manifest), "mobile shell smoke: manifest exists")
    assert(os.FileExists(runtimeManifest), "mobile shell smoke: runtime manifest exists")
    assert(os.FileExists(runtimeContractPayload), "mobile shell smoke: runtime contract payload exists")
    assert(os.FileExists(runtimeBundlePayload), "mobile shell smoke: runtime bundle payload exists")
    assert(os.FileExists(runtimeSemanticNodes), "mobile shell smoke: runtime semantic nodes exists")
    assert(os.FileExists(runtimeTruthRgba), "mobile shell smoke: runtime truth rgba exists")
    assert(os.FileExists(runtimeTruthMeta), "mobile shell smoke: runtime truth meta exists")
    assert(os.FileExists(launchArgsKv), "mobile shell smoke: launch args kv exists")
    assert(os.FileExists(launchArgsJson), "mobile shell smoke: launch args json exists")
    assert(os.FileExists(androidGradleProperties), "mobile shell smoke: android gradle properties exists")
    assert(os.FileExists(androidHost), "mobile shell smoke: android host exists")
    assert(os.FileExists(androidActivity), "mobile shell smoke: android activity exists")
    assert(os.FileExists(androidStrings), "mobile shell smoke: android strings exists")
    assert(os.FileExists(androidRuntimeManifestAsset), "mobile shell smoke: android runtime manifest asset exists")
    assert(os.FileExists(androidRuntimeContractAsset), "mobile shell smoke: android runtime contract asset exists")
    assert(os.FileExists(androidRuntimeBundleAsset), "mobile shell smoke: android runtime bundle asset exists")
    assert(os.FileExists(androidSemanticNodesAsset), "mobile shell smoke: android semantic nodes asset exists")
    assert(os.FileExists(androidTruthRgbaAsset), "mobile shell smoke: android truth rgba asset exists")
    assert(os.FileExists(androidLaunchArgsKvAsset), "mobile shell smoke: android launch args kv asset exists")
    assert(os.FileExists(androidLaunchArgsJsonAsset), "mobile shell smoke: android launch args json asset exists")
    assert(os.FileExists(iosInfoPlist), "mobile shell smoke: ios info plist exists")
    assert(os.FileExists(iosViewController), "mobile shell smoke: ios controller exists")
    assert(os.FileExists(iosProject), "mobile shell smoke: ios project exists")
    assert(os.FileExists(iosRuntimeManifest), "mobile shell smoke: ios runtime manifest exists")
    assert(os.FileExists(iosRuntimeContractPayload), "mobile shell smoke: ios runtime contract payload exists")
    assert(os.FileExists(iosRuntimeBundlePayload), "mobile shell smoke: ios runtime bundle payload exists")
    assert(os.FileExists(iosSemanticNodes), "mobile shell smoke: ios semantic nodes exists")
    assert(os.FileExists(iosTruthRgba), "mobile shell smoke: ios truth rgba exists")
    assert(os.FileExists(iosLaunchArgsKv), "mobile shell smoke: ios launch args kv exists")
    assert(os.FileExists(iosLaunchArgsJson), "mobile shell smoke: ios launch args json exists")
    assert(os.FileExists(harmonyHvigorFile), "mobile shell smoke: harmony hvigor exists")
    assert(os.FileExists(harmonyHvigorConfig), "mobile shell smoke: harmony hvigor config exists")
    assert(os.FileExists(harmonyEntryHvigorFile), "mobile shell smoke: harmony entry hvigor exists")
    assert(os.FileExists(harmonyEntryBuildProfile), "mobile shell smoke: harmony entry build profile exists")
    assert(os.FileExists(harmonyStringJson), "mobile shell smoke: harmony string json exists")
    assert(os.FileExists(harmonyColorJson), "mobile shell smoke: harmony color json exists")
    assert(os.FileExists(harmonyAppIcon), "mobile shell smoke: harmony app icon exists")
    assert(os.FileExists(harmonyRuntimeManifest), "mobile shell smoke: harmony runtime manifest exists")
    assert(os.FileExists(harmonyRuntimeContractPayload), "mobile shell smoke: harmony runtime contract payload exists")
    assert(os.FileExists(harmonyRuntimeBundlePayload), "mobile shell smoke: harmony runtime bundle payload exists")
    assert(os.FileExists(harmonySemanticNodes), "mobile shell smoke: harmony semantic nodes exists")
    assert(os.FileExists(harmonyTruthRgba), "mobile shell smoke: harmony truth rgba exists")
    assert(os.FileExists(harmonyLaunchArgsKv), "mobile shell smoke: harmony launch args kv exists")
    assert(os.FileExists(harmonyLaunchArgsJson), "mobile shell smoke: harmony launch args json exists")
    assert(os.FileExists(harmonyCmake), "mobile shell smoke: harmony cmake exists")
    assert(os.FileExists(harmonyHost), "mobile shell smoke: harmony host exists")
    assert(os.FileExists(harmonyEntryAbility), "mobile shell smoke: harmony entry ability exists")
    assert(os.FileExists(harmonyIndexEts), "mobile shell smoke: harmony index ets exists")
    assert(os.FileExists(harmonyMainPages), "mobile shell smoke: harmony main pages exists")

    let manifestText: str = os.ReadFile(manifest)
    let runtimeManifestText: str = os.ReadFile(runtimeManifest)
    let runtimeContractPayloadText: str = os.ReadFile(runtimeContractPayload)
    let runtimeBundlePayloadText: str = os.ReadFile(runtimeBundlePayload)
    let runtimeSemanticNodesText: str = os.ReadFile(runtimeSemanticNodes)
    let runtimeTruthRgbaText: str = os.ReadFile(runtimeTruthRgba)
    let runtimeTruthMetaText: str = os.ReadFile(runtimeTruthMeta)
    let launchArgsKvText: str = os.ReadFile(launchArgsKv)
    let launchArgsJsonText: str = os.ReadFile(launchArgsJson)
    let androidGradlePropertiesText: str = os.ReadFile(androidGradleProperties)
    let androidHostText: str = os.ReadFile(androidHost)
    let androidStringsText: str = os.ReadFile(androidStrings)
    let androidRuntimeManifestAssetText: str = os.ReadFile(androidRuntimeManifestAsset)
    let androidRuntimeContractAssetText: str = os.ReadFile(androidRuntimeContractAsset)
    let androidRuntimeBundleAssetText: str = os.ReadFile(androidRuntimeBundleAsset)
    let androidSemanticNodesAssetText: str = os.ReadFile(androidSemanticNodesAsset)
    let androidTruthRgbaAssetText: str = os.ReadFile(androidTruthRgbaAsset)
    let androidLaunchArgsKvAssetText: str = os.ReadFile(androidLaunchArgsKvAsset)
    let androidLaunchArgsJsonAssetText: str = os.ReadFile(androidLaunchArgsJsonAsset)
    let iosInfoPlistText: str = os.ReadFile(iosInfoPlist)
    let iosViewControllerText: str = os.ReadFile(iosViewController)
    let iosProjectText: str = os.ReadFile(iosProject)
    let iosRuntimeManifestText: str = os.ReadFile(iosRuntimeManifest)
    let iosRuntimeContractPayloadText: str = os.ReadFile(iosRuntimeContractPayload)
    let iosRuntimeBundlePayloadText: str = os.ReadFile(iosRuntimeBundlePayload)
    let iosSemanticNodesText: str = os.ReadFile(iosSemanticNodes)
    let iosTruthRgbaText: str = os.ReadFile(iosTruthRgba)
    let iosLaunchArgsKvText: str = os.ReadFile(iosLaunchArgsKv)
    let iosLaunchArgsJsonText: str = os.ReadFile(iosLaunchArgsJson)
    let harmonyHvigorFileText: str = os.ReadFile(harmonyHvigorFile)
    let harmonyHvigorConfigText: str = os.ReadFile(harmonyHvigorConfig)
    let harmonyEntryHvigorFileText: str = os.ReadFile(harmonyEntryHvigorFile)
    let harmonyEntryBuildProfileText: str = os.ReadFile(harmonyEntryBuildProfile)
    let harmonyStringJsonText: str = os.ReadFile(harmonyStringJson)
    let harmonyColorJsonText: str = os.ReadFile(harmonyColorJson)
    let harmonyAppIconText: str = os.ReadFile(harmonyAppIcon)
    let harmonyRuntimeManifestText: str = os.ReadFile(harmonyRuntimeManifest)
    let harmonyRuntimeContractPayloadText: str = os.ReadFile(harmonyRuntimeContractPayload)
    let harmonyRuntimeBundlePayloadText: str = os.ReadFile(harmonyRuntimeBundlePayload)
    let harmonySemanticNodesText: str = os.ReadFile(harmonySemanticNodes)
    let harmonyTruthRgbaText: str = os.ReadFile(harmonyTruthRgba)
    let harmonyLaunchArgsKvText: str = os.ReadFile(harmonyLaunchArgsKv)
    let harmonyLaunchArgsJsonText: str = os.ReadFile(harmonyLaunchArgsJson)
    let harmonyCmakeText: str = os.ReadFile(harmonyCmake)
    let harmonyHostText: str = os.ReadFile(harmonyHost)
    let harmonyEntryAbilityText: str = os.ReadFile(harmonyEntryAbility)
    let harmonyIndexEtsText: str = os.ReadFile(harmonyIndexEts)
    let harmonyMainPagesText: str = os.ReadFile(harmonyMainPages)

    assert(strings.StrContains(manifestText, "\"format\":\"mobile_shell_manifest_v1\""),
           "mobile shell smoke: manifest format")
    assert(strings.StrContains(manifestText, "\"app_id\":\"org.cheng.smoke\""),
           "mobile shell smoke: manifest app id")
    assert(strings.StrContains(manifestText, "\"runtime_mode\":\"r2c_native_gui_v1\""),
           "mobile shell smoke: manifest runtime mode")
    assert(strings.StrContains(manifestText, "\"runtime_manifest\":\"mobile_shell_runtime_contract_v1.json\""),
           "mobile shell smoke: manifest runtime manifest")
    assert(strings.StrContains(manifestText, "\"semantic_nodes_path\":\"runtime/r2c_semantic_render_nodes.tsv\""),
           "mobile shell smoke: manifest semantic nodes path")
    assert(strings.StrContains(manifestText, "\"truth_root_path\":\"runtime/truth\""),
           "mobile shell smoke: manifest truth root path")
    assert(strings.StrContains(manifestText, "\"launch_args_kv\":\"runtime/mobile_shell_launch_args.kv\""),
           "mobile shell smoke: manifest launch args kv")
    assert(strings.StrContains(manifestText, "\"launch_args_json\":\"runtime/mobile_shell_launch_args.json\""),
           "mobile shell smoke: manifest launch args json")
    assert(strings.StrContains(manifestText, "\"initial_route_state\":\"home_default\""),
           "mobile shell smoke: manifest route state")
    assert(strings.StrContains(runtimeManifestText, "\"format\":\"mobile_shell_runtime_contract_v1\""),
           "mobile shell smoke: runtime manifest format")
    assert(strings.StrContains(runtimeManifestText, "\"runtime_contract_payload\":\"runtime/runtime_contract_payload.json\""),
           "mobile shell smoke: runtime manifest contract payload")
    assert(strings.StrContains(runtimeManifestText, "\"runtime_bundle_payload\":\"runtime/runtime_bundle_payload.json\""),
           "mobile shell smoke: runtime manifest bundle payload")
    assert(strings.StrContains(runtimeManifestText, "\"semantic_nodes_path\":\"runtime/r2c_semantic_render_nodes.tsv\""),
           "mobile shell smoke: runtime manifest semantic nodes path")
    assert(strings.StrContains(runtimeManifestText, "\"truth_root_path\":\"runtime/truth\""),
           "mobile shell smoke: runtime manifest truth root path")
    assert(strings.StrContains(runtimeManifestText, "\"launch_args_kv\":\"runtime/mobile_shell_launch_args.kv\""),
           "mobile shell smoke: runtime manifest launch args kv")
    assert(strings.StrContains(runtimeManifestText, "\"launch_args_json\":\"runtime/mobile_shell_launch_args.json\""),
           "mobile shell smoke: runtime manifest launch args json")
    assert(strings.StrContains(runtimeContractPayloadText, "\"format\":\"native_gui_runtime_contract_v1\""),
           "mobile shell smoke: copied runtime contract payload")
    assert(strings.StrContains(runtimeBundlePayloadText, "\"format\":\"native_gui_bundle_v1\""),
           "mobile shell smoke: copied runtime bundle payload")
    assert(runtimeSemanticNodesText == "node_1\thome_default\ttext\t48656c6c6f\t#root\tonClick\tapp/App.tsx\t/App",
           "mobile shell smoke: copied semantic nodes exact")
    assert(runtimeTruthRgbaText == "RGBA",
           "mobile shell smoke: copied truth rgba exact")
    assert(runtimeTruthMetaText == "{\n  \"width\": 1,\n  \"height\": 1\n}",
           "mobile shell smoke: copied truth meta exact")
    assert(strings.StrContains(launchArgsKvText, "route_state=home_default"),
           "mobile shell smoke: launch args kv route")
    assert(strings.StrContains(launchArgsJsonText, "\"format\":\"mobile_shell_launch_args_v1\""),
           "mobile shell smoke: launch args json format")
    assert(strings.StrContains(launchArgsJsonText, "\"route_state\":\"home_default\""),
           "mobile shell smoke: launch args json route")
    assert(strings.StrContains(androidGradlePropertiesText, "android.useAndroidX=true"),
           "mobile shell smoke: android gradle properties content")
    assert(strings.StrContains(androidHostText, "ANativeWindow_fromSurface"),
           "mobile shell smoke: android surface glue")
    assert(strings.StrContains(androidHostText, "cheng_mobile_host_runtime_set_manifest_payloads_fn"),
           "mobile shell smoke: android runtime payload setter type")
    assert(strings.StrContains(androidHostText, "cheng_set_runtime_payloads(env, runtimeManifestJson, runtimeContractPayloadJson, runtimeBundlePayloadJson);"),
           "mobile shell smoke: android runtime payload setter call")
    assert(strings.StrContains(androidHostText, "kChengRuntimeManifest = \"mobile_shell_runtime_contract_v1.json\""),
           "mobile shell smoke: android runtime manifest constant")
    assert(strings.StrContains(androidHostText, "kChengRuntimeContractPayloadRel = \"runtime/mobile_shell_runtime_contract_payload.json\""),
           "mobile shell smoke: android runtime contract rel constant")
    assert(strings.StrContains(androidHostText, "kChengRuntimeBundlePayloadRel = \"runtime/mobile_shell_runtime_bundle_payload.json\""),
           "mobile shell smoke: android runtime bundle rel constant")
    assert(strings.StrContains(androidHostText, "kChengLaunchArgsKvRel = \"runtime/mobile_shell_launch_args.kv\""),
           "mobile shell smoke: android launch args kv rel constant")
    assert(strings.StrContains(androidHostText, "kChengLaunchArgsJsonRel = \"runtime/mobile_shell_launch_args.json\""),
           "mobile shell smoke: android launch args json rel constant")
    assert(strings.StrContains(androidStringsText, "<string name=\"app_name\">ChengSmoke</string>"),
           "mobile shell smoke: android app name string")
    assert(strings.StrContains(androidRuntimeManifestAssetText, "\"format\":\"mobile_shell_runtime_contract_v1\""),
           "mobile shell smoke: android runtime manifest asset content")
    assert(strings.StrContains(androidRuntimeContractAssetText, "\"format\":\"native_gui_runtime_contract_v1\""),
           "mobile shell smoke: android runtime contract asset content")
    assert(strings.StrContains(androidRuntimeBundleAssetText, "\"format\":\"native_gui_bundle_v1\""),
           "mobile shell smoke: android runtime bundle asset content")
    assert(androidSemanticNodesAssetText == "node_1\thome_default\ttext\t48656c6c6f\t#root\tonClick\tapp/App.tsx\t/App",
           "mobile shell smoke: android semantic nodes exact")
    assert(androidTruthRgbaAssetText == "RGBA",
           "mobile shell smoke: android truth rgba exact")
    assert(strings.StrContains(androidLaunchArgsKvAssetText, "route_state=home_default"),
           "mobile shell smoke: android launch args kv asset content")
    assert(strings.StrContains(androidLaunchArgsJsonAssetText, "\"route_state\":\"home_default\""),
           "mobile shell smoke: android launch args json asset content")
    assert(strings.StrContains(iosInfoPlistText, "<key>CFBundleIdentifier</key>"),
           "mobile shell smoke: ios info plist content")
    assert(strings.StrContains(iosViewControllerText, "CAMetalLayer"),
           "mobile shell smoke: ios metal glue")
    assert(strings.StrContains(iosViewControllerText, "cheng_mobile_host_runtime_set_manifest_payloads_fn"),
           "mobile shell smoke: ios runtime payload setter type")
    assert(strings.StrContains(iosViewControllerText, "setRuntimePayloads(runtimeManifest != nil ? [runtimeManifest UTF8String] : NULL,"),
           "mobile shell smoke: ios runtime payload setter call")
    assert(strings.StrContains(iosViewControllerText, "kChengRuntimeManifest = \"runtime/mobile_shell_runtime_contract_v1.json\""),
           "mobile shell smoke: ios runtime manifest constant")
    assert(strings.StrContains(iosViewControllerText, "kChengRuntimeContractPayloadRel = \"runtime/mobile_shell_runtime_contract_payload.json\""),
           "mobile shell smoke: ios runtime contract rel constant")
    assert(strings.StrContains(iosViewControllerText, "kChengRuntimeBundlePayloadRel = \"runtime/mobile_shell_runtime_bundle_payload.json\""),
           "mobile shell smoke: ios runtime bundle rel constant")
    assert(strings.StrContains(iosViewControllerText, "kChengLaunchArgsKvRel = \"runtime/mobile_shell_launch_args.kv\""),
