    assert(strings.StrContains(iosProjectText, "PRODUCT_BUNDLE_IDENTIFIER = \"org.cheng.smoke\";"),
           "mobile shell smoke: ios bundle id")
    assert(strings.StrContains(iosProjectText, "mobile_shell_runtime_contract_v1.json in Resources"),
           "mobile shell smoke: ios runtime manifest project resource")
    assert(strings.StrContains(iosProjectText, "mobile_shell_launch_args.kv in Resources"),
           "mobile shell smoke: ios launch args kv project resource")
    assert(strings.StrContains(iosProjectText, "mobile_shell_launch_args.json in Resources"),
           "mobile shell smoke: ios launch args json project resource")
    assert(strings.StrContains(iosRuntimeManifestText, "\"format\":\"mobile_shell_runtime_contract_v1\""),
           "mobile shell smoke: ios runtime manifest content")
    assert(strings.StrContains(iosRuntimeContractPayloadText, "\"format\":\"native_gui_runtime_contract_v1\""),
           "mobile shell smoke: ios runtime contract payload content")
    assert(strings.StrContains(iosRuntimeBundlePayloadText, "\"format\":\"native_gui_bundle_v1\""),
           "mobile shell smoke: ios runtime bundle payload content")
    assert(iosSemanticNodesText == "node_1\thome_default\ttext\t48656c6c6f\t#root\tonClick\tapp/App.tsx\t/App",
           "mobile shell smoke: ios semantic nodes exact")
    assert(iosTruthRgbaText == "RGBA",
           "mobile shell smoke: ios truth rgba exact")
    assert(strings.StrContains(iosLaunchArgsKvText, "route_state=home_default"),
           "mobile shell smoke: ios launch args kv content")
    assert(strings.StrContains(iosLaunchArgsJsonText, "\"route_state\":\"home_default\""),
           "mobile shell smoke: ios launch args json content")
    assert(strings.StrContains(harmonyHvigorFileText, "appTasks"),
           "mobile shell smoke: harmony hvigor content")
    assert(strings.StrContains(harmonyHvigorConfigText, "\"modelVersion\":\"5.0.0\""),
           "mobile shell smoke: harmony hvigor config content")
    assert(strings.StrContains(harmonyEntryHvigorFileText, "hapTasks"),
           "mobile shell smoke: harmony entry hvigor content")
