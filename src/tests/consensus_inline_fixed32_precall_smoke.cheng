import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

fn fixed32Same(a: layout.FixedBytes32, b: layout.FixedBytes32): bool =
    for i in 0..<32:
        if a.data[i] != b.data[i]:
            return false
    return true

fn localApply(index: var consensus.ChainIndex,
              event: consensus.ChainEvent,
              eventCid: layout.FixedBytes32,
              logOffset: int32): Result[consensus.ConsensusDecision] =
    var out = consensus.ConsensusDecision()
    out.eventCid = eventCid
    assert(fixed32Same(eventCid, eventCid),
           " consensus inline fixed32 precall: equal")
    consensus.ConsensusApplyMint(index, event, eventCid, logOffset, out)
    assert(index.accountIds.buffer != nil, " consensus inline fixed32 precall: inner account buffer")
    assert(index.accountIds.cap >= 1, " consensus inline fixed32 precall: inner account cap")
    assert(index.accountIds.len == 1, " consensus inline fixed32 precall: inner account len")
    return Ok[consensus.ConsensusDecision](out)

fn main(): int32 =
    var index = consensus.ChainIndex()
    let zeroCid = layout.FixedBytes32()
    let event = consensus.ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let eventCid = consensus.ChainEventCid(event)
    let applyRes = localApply(index, event, eventCid, 0)
    assert(IsOk(applyRes), " consensus inline fixed32 precall: ok")
    let decision = Value(applyRes)
    assert(decision.accepted, " consensus inline fixed32 precall: accepted")
    assert(decision.applied, " consensus inline fixed32 precall: applied")
    assert(index.accountIds.buffer != nil, " consensus inline fixed32 precall: account buffer")
    assert(index.accountIds.cap >= 1, " consensus inline fixed32 precall: account cap")
    assert(index.accountIds.len == 1, " consensus inline fixed32 precall: account len")
    echo(" consensus_inline_fixed32_precall_smoke ok")
    return 0
