import std/os
import std/result
import cheng/core/tooling/path as v3path
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world_libp2p as cwlp
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_exec as sexec
import cheng/chain/pubsub
import cheng/libp2p/core/types as core
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host

fn compilerWorldReceiptProbePortBase(label: str): int32 =
    var acc: int32
    for i in 0..<label.len:
        acc = (acc + (int32(label[i]) & 255)) % 200
    return 6861 + (acc * 2)

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathJoin(workspaceRoot, "artifacts/compiler_world_receipt_probe/" + smokeLabel)
    let portBase: int32 = compilerWorldReceiptProbePortBase(smokeLabel)
    assert(v3path.V3MkdirP(workspaceRoot, outDir), "v3 compiler world receipt probe: mkdir")
    let sourcePath = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = v3path.V3PathJoin(outDir, "program_selfhost_smoke")
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    let planRes = sexec.v3BuildSystemLinkExecPlan(workspaceRoot, req)
    assert(IsOk(planRes), "v3 compiler world receipt probe: build plan")
    let plan = Value(planRes)
    var seedHost = host.v3Libp2pHostInit("compiler-world-seed")
    var syncHost = host.v3Libp2pHostInit("compiler-world-sync")
    cwlp.v3CompilerWorldRegister(seedHost)
    cwlp.v3CompilerWorldRegister(syncHost)
    var seedAddr: core.V3Libp2pMultiaddr
    var syncAddr: core.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(seedAddr, "127.0.0.1", portBase)
    multiaddr.v3Libp2pMultiaddrFillTcp(syncAddr, "127.0.0.1", portBase + 1)
    assert(IsOk(host.v3Libp2pListen(seedHost, seedAddr)), "v3 compiler world receipt probe: seed listen")
    assert(IsOk(host.v3Libp2pListen(syncHost, syncAddr)), "v3 compiler world receipt probe: sync listen")
    assert(IsOk(host.v3Libp2pDial(syncHost, seedHost.selfPeerId, seedAddr, 1)), "v3 compiler world receipt probe: dial seed")
    assert(IsOk(host.v3Libp2pDial(seedHost, syncHost.selfPeerId, syncAddr, 1)), "v3 compiler world receipt probe: dial sync")
    cwlp.v3CompilerWorldPublishUniverse(seedHost,
                                        plan.localUniverse,
                                        plan.compilerCsg,
                                        plan.exportSurface,
                                        plan.compileReceipt)
    let syncRes = cwlp.v3CompilerWorldSync(syncHost, seedHost, seedHost.selfPeerId)
    assert(IsOk(syncRes), "v3 compiler world receipt probe: sync")
    var receiptText = ""
    assert(cwlp.v3CompilerWorldFirstPayloadTextByKind(syncHost,
                                                      pubsub.v3PubSubPayloadKindCompilerCompileReceipt,
                                                      receiptText),
           "v3 compiler world receipt probe: synced receipt text")
    var parsed: ccsg.V3CompileReceipt
    let parseRes = ccsg.v3CompileReceiptFromReportText(receiptText, parsed)
    assert(IsOk(parseRes), "v3 compiler world receipt probe: parse receipt")
    var probeText = receiptText + "\n"
    probeText = probeText + "parsed_target=" + parsed.targetTriple + "\n"
    probeText = probeText + "parsed_bootstrap_stage=" + parsed.bootstrapStage + "\n"
    probeText = probeText + "parsed_provider_count=" + intToStr(parsed.runtimeProviderSet.len) + "\n"
    probeText = probeText + "plan_provider_count=" + intToStr(plan.compileReceipt.runtimeProviderSet.len) + "\n"
    for i in 0..<parsed.runtimeProviderSet.len:
        probeText = probeText + "parsed_provider[" + intToStr(i) + "]=" + parsed.runtimeProviderSet[i] + "\n"
    for i in 0..<plan.compileReceipt.runtimeProviderSet.len:
        probeText = probeText + "plan_provider[" + intToStr(i) + "]=" + plan.compileReceipt.runtimeProviderSet[i] + "\n"
    if ccsg.v3CompileReceiptEquivalent(plan.compileReceipt, parsed):
        probeText = probeText + "receipt_equivalent=1\n"
    else:
        probeText = probeText + "receipt_equivalent=0\n"
    assert(v3path.V3WriteTextFile(workspaceRoot,
                                  v3path.V3PathJoin(outDir, "receipt_probe.txt"),
                                  probeText),
           "v3 compiler world receipt probe: write probe")
    return 0
