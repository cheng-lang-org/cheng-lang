import std/os
import std/result
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world_libp2p as cwlp
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_exec as sexec
import cheng/chain/pubsub
import cheng/libp2p/core/types as core
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host
import std/strutils as strutil

fn compilerWorldReceiptProbePortBase(label: str): int32 =
    var acc: int32
    for i in 0..<label.len:
        acc = (acc + (int32(label[i]) & 255)) % 200
    return 6861 + (acc * 2)

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, strutil.Join(["artifacts/compiler_world_receipt_probe/", smokeLabel], ""))
    let portBase: int32 = compilerWorldReceiptProbePortBase(smokeLabel)
    assert(chengpath.MkdirP(workspaceRoot, outDir), " compiler world receipt probe: mkdir")
    let sourcePath = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = chengpath.PathJoin(outDir, "program_selfhost_smoke")
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    let planRes = sexec.BuildSystemLinkExecPlan(workspaceRoot, req)
    assert(IsOk(planRes), " compiler world receipt probe: build plan")
    let plan = Value(planRes)
    var seedHost = host.Libp2pHostInit("compiler-world-seed")
    var syncHost = host.Libp2pHostInit("compiler-world-sync")
    cwlp.CompilerWorldRegister(seedHost)
    cwlp.CompilerWorldRegister(syncHost)
    var seedAddr: core.Libp2pMultiaddr
    var syncAddr: core.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(seedAddr, "127.0.0.1", portBase)
    multiaddr.Libp2pMultiaddrFillTcp(syncAddr, "127.0.0.1", portBase + 1)
    assert(IsOk(host.Libp2pListen(seedHost, seedAddr)), " compiler world receipt probe: seed listen")
    assert(IsOk(host.Libp2pListen(syncHost, syncAddr)), " compiler world receipt probe: sync listen")
    assert(IsOk(host.Libp2pDial(syncHost, seedHost.selfPeerId, seedAddr, 1)), " compiler world receipt probe: dial seed")
    assert(IsOk(host.Libp2pDial(seedHost, syncHost.selfPeerId, syncAddr, 1)), " compiler world receipt probe: dial sync")
    cwlp.CompilerWorldPublishUniverse(seedHost,
                                        plan.localUniverse,
                                        plan.compilerCsg,
                                        plan.exportSurface,
                                        plan.compileReceipt)
    let syncRes = cwlp.CompilerWorldSync(syncHost, seedHost, seedHost.selfPeerId)
    assert(IsOk(syncRes), " compiler world receipt probe: sync")
    var receiptText = ""
    assert(cwlp.CompilerWorldFirstPayloadTextByKind(syncHost,
                                                      pubsub.PubSubPayloadKindCompilerCompileReceipt,
                                                      receiptText),
           " compiler world receipt probe: synced receipt text")
    var parsed: ccsg.CompileReceipt
    let parseRes = ccsg.CompileReceiptFromReportText(receiptText, parsed)
    assert(IsOk(parseRes), " compiler world receipt probe: parse receipt")
    var probeText = strutil.Join([receiptText, "\n"], "")
    probeText = strutil.Join([probeText, "parsed_target=", parsed.targetTriple, "\n"], "")
    probeText = strutil.Join([probeText, "parsed_bootstrap_stage=", parsed.bootstrapStage, "\n"], "")
    probeText = strutil.Join([probeText, "parsed_provider_count=", intToStr(parsed.runtimeProviderSet.len), "\n"], "")
    probeText = strutil.Join([probeText, "plan_provider_count=", intToStr(plan.compileReceipt.runtimeProviderSet.len), "\n"], "")
    for i in 0..<parsed.runtimeProviderSet.len:
        probeText = strutil.Join([probeText, "parsed_provider[", intToStr(i), "]=", parsed.runtimeProviderSet[i], "\n"], "")
    for i in 0..<plan.compileReceipt.runtimeProviderSet.len:
        probeText = strutil.Join([probeText, "plan_provider[", intToStr(i), "]=", plan.compileReceipt.runtimeProviderSet[i], "\n"], "")
    if ccsg.CompileReceiptEquivalent(plan.compileReceipt, parsed):
        probeText = strutil.Join([probeText, "receipt_equivalent=1\n"], "")
    else:
        probeText = strutil.Join([probeText, "receipt_equivalent=0\n"], "")
    assert(chengpath.WriteTextFile(workspaceRoot,
                                  chengpath.PathJoin(outDir, "receipt_probe.txt"),
                                  probeText),
           " compiler world receipt probe: write probe")
    return 0
