import std/os
import std/strutils as strutil
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let outDir = chengpath.PathJoin(workspaceRoot, "artifacts/cheng_skill_consistency")
    assert(chengpath.MkdirP(workspaceRoot, outDir), " cheng skill consistency: mkdir")

    let specPath = chengpath.PathJoin(workspaceRoot, "docs/cheng-formal-spec.md")
    let repoSkillPath = chengpath.PathJoin(workspaceRoot, "docs/cheng-skill/SKILL.md")
    let repoGrammarPath = chengpath.PathJoin(workspaceRoot, "docs/cheng-skill/references/grammar.md")
    let readmePath = chengpath.PathJoin(workspaceRoot, "README.md")
    let toolingReadmePath = chengpath.PathJoin(workspaceRoot, "src/core/tooling/README.md")
    let fmtSmokePath = chengpath.PathJoin(workspaceRoot, "src/tests/strformat_fmt_smoke.cheng")
    let compilerMainPath = chengpath.PathJoin(workspaceRoot, "src/core/tooling/compiler_main.cheng")
    let explicitDefaultPositiveSmokePath = chengpath.PathJoin(workspaceRoot, "src/tests/explicit_default_init_positive_smoke.cheng")
    let explicitDefaultNegativeSmokePath = chengpath.PathJoin(workspaceRoot, "src/tests/explicit_default_init_negative_smoke.cheng")
    let explicitDefaultGateSmokePath = chengpath.PathJoin(workspaceRoot, "src/tests/explicit_default_init_gate_smoke.cheng")
    let zeroHelperGateSmokePath = chengpath.PathJoin(workspaceRoot, "src/tests/composite_zero_helper_gate_smoke.cheng")
    let latestSnapshotSmokePath = chengpath.PathJoin(workspaceRoot, "src/tests/latest_snapshot_port_preserves_live_str_smoke.cheng")
    let listLiteralDepthSmokePath = chengpath.PathJoin(workspaceRoot, "src/tests/list_literal_nested_call_depth_smoke.cheng")
    let preQuicSnapshotSmokePath = chengpath.PathJoin(workspaceRoot, "src/tests/libp2p_quic_twoproc_server_pre_quic_smoke.cheng")

    assert(chengpath.FileExistsNonEmpty(workspaceRoot, specPath), " cheng skill consistency: spec exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, repoSkillPath), " cheng skill consistency: repo skill exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, repoGrammarPath), " cheng skill consistency: repo grammar exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, readmePath), " cheng skill consistency: readme exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, toolingReadmePath), " cheng skill consistency: tooling readme exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, fmtSmokePath), " cheng skill consistency: fmt smoke exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, compilerMainPath), " cheng skill consistency: compiler main exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, explicitDefaultPositiveSmokePath), " cheng skill consistency: explicit default positive smoke exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, explicitDefaultNegativeSmokePath), " cheng skill consistency: explicit default negative smoke exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, explicitDefaultGateSmokePath), " cheng skill consistency: explicit default gate smoke exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, zeroHelperGateSmokePath), " cheng skill consistency: zero helper gate smoke exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, latestSnapshotSmokePath), " cheng skill consistency: latest snapshot spill smoke exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, listLiteralDepthSmokePath), " cheng skill consistency: list literal depth smoke exists")
    assert(chengpath.FileExistsNonEmpty(workspaceRoot, preQuicSnapshotSmokePath), " cheng skill consistency: pre quic snapshot smoke exists")

    let specText = chengpath.ReadTextFile("", specPath)
    let repoSkillText = chengpath.ReadTextFile("", repoSkillPath)
    let repoGrammarText = chengpath.ReadTextFile("", repoGrammarPath)
    let readmeText = chengpath.ReadTextFile("", readmePath)
    let toolingReadmeText = chengpath.ReadTextFile("", toolingReadmePath)
    let fmtSmokeText = chengpath.ReadTextFile("", fmtSmokePath)
    let compilerMainText = chengpath.ReadTextFile("", compilerMainPath)
    let explicitDefaultPositiveSmokeText = chengpath.ReadTextFile("", explicitDefaultPositiveSmokePath)
    let explicitDefaultNegativeSmokeText = chengpath.ReadTextFile("", explicitDefaultNegativeSmokePath)
    let explicitDefaultGateSmokeText = chengpath.ReadTextFile("", explicitDefaultGateSmokePath)
    let zeroHelperGateSmokeText = chengpath.ReadTextFile("", zeroHelperGateSmokePath)

    let fmtSurfaceText = "`Fmt` 是当前稳定公开格式化表面：`Fmt\"label={expr}\"` 用于插值字符串；无分隔动态数组拼接使用 `std/strutils.Join(parts, \"\")`，按换行拼接使用 `Lines(parts)` 或 `std/strutils.Join(parts, \"\\n\")`。`Fmt(parts)`、`Fmt expr`、`Lines expr` 不再支持，小写 `fmt/lines` 不导出。"
    let fmtSurfaceSpecText = "`Fmt` 为当前稳定公开格式化表面：`Fmt\"label={expr}\"` 用于插值字符串；无分隔动态数组拼接使用 `std/strutils.Join(parts, \"\")`，按换行拼接使用 `Lines(parts)` 或 `std/strutils.Join(parts, \"\\n\")`。`Fmt(parts)`、`Fmt expr`、`Lines expr` 不再支持，小写 `fmt/lines` 不导出。"
    let exportSurfaceSpecText = "Cheng 采用 Go 风格的“首字母大写导出”规则：标识符首字符为 ASCII 大写字母的符号视为导出。"
    let exportSurfaceSkillText = "- 导出采用 Go 风格：标识符首字符为 ASCII 大写字母即导出；小写字母或 `_` 开头保持模块私有。"
    let compositeOrderSpecText = "类型零值 -> 声明顺序应用字段/元素默认值 -> 显式构造实参覆盖。"
    let compositeHelperSpecText = "- 如果只是复合类型零值/默认值构造，不再维护 `FooZero()` 这类无参镜像 helper；直接使用 `var x: Foo`、`Foo()` 或 `new(Foo)`。"
    let tupleDefaultSpecText = "`tuple` 本轮仅支持 typed implicit init 与 `T()` 物化；"
    let compositeDefaultSkillText = "- `object/ref object/tuple` 字段或元素支持 `name: Type = expr` 默认值语法；初始化优先级固定为“显式实参 > 字段默认值 > 类型零值”。"
    let compositeDefaultGrammarText = "- 初始化优先级固定为：显式实参 > 字段默认值 > 类型零值。"
    let compositeSteadyGrammarText = "- 字段默认值只允许稳态表达式：字面量（含 `T[]/T[N]` 上下文下的 `[]` 与 `[a, b, ...]`）、复合类型 `T()`、`new(Type)`、纯类型构造与 `if/?:` 组合；禁止引用同对象其他字段与副作用调用。"
    let tupleGrammarText = "- tuple 这轮只支持 typed implicit init 与 `T()`；tuple 字面量/tuple 类型构造必须显式写全所有元素。"
    let implicitDefaultSkillText = "- 隐式默认值速记：`bool=false`，整数/枚举=0，浮点=0.0，`char='\\0'`，`str/cstring=\"\"`，指针/`ref`/`var`/`void*`=`nil`，复合类型先 zero-init，再应用字段默认值。"
    let implicitDefaultGrammarText = "- `bool=false`"
    let elegantCallSpecText = "调用语法统一使用小括号"
    let elegantCallSkillText = "单参数调用统一写 `f(x)`"
    let elegantCallGrammarText = "旧空格单参调用"
    let EntryText = "- 正式入口优先用 `artifacts/bootstrap/cheng.stage3` 和 `artifacts/backend_driver/cheng`；外层脚本只视为兼容壳，不再作为主入口。"
    let ProdRegressionText = "artifacts/bootstrap/cheng.stage3 run-production-regression"
    let ProdRegressionSmokeText = "build_backend_driver_report_smoke perf_memory_gate_contract_smoke perf_memory_contract_smoke cheng_skill_consistency_smoke dev_hotpatch_100ms_scope_contract_smoke explicit_default_init_positive_smoke explicit_default_init_negative_smoke explicit_default_init_gate_smoke composite_zero_helper_gate_smoke latest_snapshot_port_preserves_live_str_smoke list_literal_nested_call_depth_smoke libp2p_quic_twoproc_server_pre_quic_smoke"
    let PerfText = "- 内建画像/门禁优先用 `artifacts/bootstrap/cheng.stage3 profile-run/profile-report` 与 `artifacts/backend_driver/cheng run-host-smokes perf_memory_contract_smoke`；不要再把外层脚本当默认路径。"
    let PerfDefaultCompilerText = "- `perf_memory_contract_smoke` 默认优先测 `artifacts/backend_driver/cheng`；只有显式 `CHENG_SMOKE_COMPILER` 才覆盖。"
    let PerfDarwinMemoryText = "- Darwin 正式内存比较值优先用 `peak memory footprint`；`maximum resident set size` 只保留原始观测，不作为稳定合同阈值。"
    let SkillCheckText = "artifacts/backend_driver/cheng run-host-smokes cheng_skill_consistency_smoke"

    assert(chengpath.TextContains(specText, fmtSurfaceSpecText),
           " cheng skill consistency: formal spec fmt/lines public surface")
    assert(chengpath.TextContains(specText, exportSurfaceSpecText),
           " cheng skill consistency: formal spec export surface")
    assert(chengpath.TextContains(specText, compositeOrderSpecText),
           " cheng skill consistency: formal spec composite default order")
    assert(chengpath.TextContains(specText, compositeHelperSpecText),
           " cheng skill consistency: formal spec composite helper surface")
    assert(chengpath.TextContains(specText, tupleDefaultSpecText),
           " cheng skill consistency: formal spec tuple default surface")
    assert(chengpath.TextContains(specText, elegantCallSpecText),
           " cheng skill consistency: formal spec elegant call surface")
    assert(chengpath.TextContains(specText, SkillCheckText),
           " cheng skill consistency: formal spec skill consistency command")
    assert(chengpath.TextContains(specText, ProdRegressionText),
           " cheng skill consistency: formal spec production regression command")
    assert(chengpath.TextContains(specText, ProdRegressionSmokeText),
           " cheng skill consistency: formal spec production regression smokes")
    assert(chengpath.TextContains(specText, PerfDefaultCompilerText),
           " cheng skill consistency: formal spec perf default compiler")
    assert(chengpath.TextContains(specText, PerfDarwinMemoryText),
           " cheng skill consistency: formal spec darwin perf memory")

    assert(chengpath.TextContains(repoSkillText, fmtSurfaceText),
           " cheng skill consistency: repo skill fmt/lines public surface")
    assert(chengpath.TextContains(repoSkillText, exportSurfaceSkillText),
           " cheng skill consistency: repo skill export surface")
    assert(chengpath.TextContains(repoSkillText, compositeDefaultSkillText),
           " cheng skill consistency: repo skill composite default surface")
    assert(chengpath.TextContains(repoSkillText, implicitDefaultSkillText),
           " cheng skill consistency: repo skill implicit default surface")
    assert(chengpath.TextContains(repoSkillText, elegantCallSkillText),
           " cheng skill consistency: repo skill elegant call surface")
    assert(chengpath.TextContains(repoSkillText, EntryText),
           " cheng skill consistency: repo skill  entry surface")
    assert(chengpath.TextContains(repoSkillText, ProdRegressionText),
           " cheng skill consistency: repo skill production regression command")
    assert(chengpath.TextContains(repoSkillText, PerfText),
           " cheng skill consistency: repo skill  perf surface")
    assert(chengpath.TextContains(repoSkillText, PerfDefaultCompilerText),
           " cheng skill consistency: repo skill perf default compiler")
    assert(chengpath.TextContains(repoSkillText, PerfDarwinMemoryText),
           " cheng skill consistency: repo skill darwin perf memory")
    assert(chengpath.TextContains(repoSkillText, SkillCheckText),
           " cheng skill consistency: repo skill skill consistency command")

    assert(chengpath.TextContains(repoGrammarText, exportSurfaceSkillText),
           " cheng skill consistency: repo grammar export surface")
    assert(chengpath.TextContains(repoGrammarText, compositeDefaultGrammarText),
           " cheng skill consistency: repo grammar composite default surface")
    assert(chengpath.TextContains(repoGrammarText, compositeSteadyGrammarText),
           " cheng skill consistency: repo grammar steady default surface")
    assert(chengpath.TextContains(repoGrammarText, tupleGrammarText),
           " cheng skill consistency: repo grammar tuple default surface")
    assert(chengpath.TextContains(repoGrammarText, implicitDefaultGrammarText),
           " cheng skill consistency: repo grammar implicit default surface")
    assert(chengpath.TextContains(repoGrammarText, elegantCallGrammarText),
           " cheng skill consistency: repo grammar elegant call surface")
    assert(chengpath.TextContains(repoGrammarText, "tags: str[]"),
           " cheng skill consistency: repo grammar sample seq implicit default")
    assert(chengpath.TextContains(repoGrammarText, "retries: int32[3] = [1, 2, 3]"),
           " cheng skill consistency: repo grammar sample fixed literal default")
    assert(chengpath.TextContains(repoGrammarText, "Fmt\"label={expr}\""),
           " cheng skill consistency: repo grammar fmt surface")

    assert(chengpath.TextContains(readmeText, "artifacts/bootstrap/cheng.stage3"),
           " cheng skill consistency: README stage3 entry")
    assert(chengpath.TextContains(readmeText, "artifacts/backend_driver/cheng"),
           " cheng skill consistency: README backend driver entry")
    assert(chengpath.TextContains(readmeText, ProdRegressionText),
           " cheng skill consistency: README production regression command")
    assert(chengpath.TextContains(readmeText, PerfDefaultCompilerText),
           " cheng skill consistency: README perf default compiler")
    assert(chengpath.TextContains(readmeText, PerfDarwinMemoryText),
           " cheng skill consistency: README darwin perf memory")
    assert(chengpath.TextContains(readmeText, "artifacts/bootstrap/cheng.stage3 profile-run / profile-report"),
           " cheng skill consistency: README profile commands")
    assert(chengpath.TextContains(readmeText, "artifacts/backend_driver/cheng run-host-smokes perf_memory_contract_smoke"),
           " cheng skill consistency: README perf memory gate command")
    assert(chengpath.TextContains(readmeText, "artifacts/backend_driver/cheng run-host-smokes cheng_skill_consistency_smoke"),
           " cheng skill consistency: README skill consistency command")

    assert(chengpath.TextContains(toolingReadmeText,
                                 "artifacts/bootstrap/cheng.stage3 run-production-regression"),
           " cheng skill consistency:  tooling readme production regression command")
    assert(chengpath.TextContains(toolingReadmeText, ProdRegressionSmokeText),
           " cheng skill consistency:  tooling readme production regression smokes")
    assert(chengpath.TextContains(toolingReadmeText, PerfDefaultCompilerText),
           " cheng skill consistency:  tooling readme perf default compiler")
    assert(chengpath.TextContains(toolingReadmeText, PerfDarwinMemoryText),
           " cheng skill consistency:  tooling readme darwin perf memory")
    assert(chengpath.TextContains(toolingReadmeText,
                                 "artifacts/bootstrap/cheng.stage3 profile-run --in:/abs/path/file.cheng --target:arm64-apple-darwin --out:/tmp/app"),
           " cheng skill consistency:  tooling readme profile-run command")
    assert(chengpath.TextContains(toolingReadmeText,
                                 "artifacts/bootstrap/cheng.stage3 profile-report --in:/tmp/app.cheng.profile.raw.txt --out:/tmp/app.profile.txt"),
           " cheng skill consistency:  tooling readme profile-report command")
    assert(chengpath.TextContains(toolingReadmeText,
                                 "artifacts/backend_driver/cheng run-host-smokes perf_memory_contract_smoke"),
           " cheng skill consistency:  tooling readme perf memory gate command")
    assert(chengpath.TextContains(toolingReadmeText,
                                 "artifacts/backend_driver/cheng run-host-smokes cheng_skill_consistency_smoke"),
           " cheng skill consistency:  tooling readme skill consistency command")
    assert(chengpath.TextContains(toolingReadmeText, "explicit_default_init_gate_smoke"),
           " cheng skill consistency:  tooling readme explicit default gate")

    assert(chengpath.TextContains(fmtSmokeText, "let joinedViaStrutils: str = strutil.Join(parts, \"\")"),
           " cheng skill consistency: strformat fmt smoke strutils join")
    assert(!chengpath.TextContains(fmtSmokeText, "Fmt(parts)"),
           " cheng skill consistency: strformat fmt smoke no callable Fmt")
    assert(!chengpath.TextContains(compilerMainText, "Fmt(["),
           " cheng skill consistency: compiler bridge no callable Fmt lowering")
    assert(chengpath.TextContains(compilerMainText, "var fmtOut = \"strutil.Join([\""),
           " cheng skill consistency: compiler bridge lowers fmt literal to strutils join")
    assert(chengpath.TextContains(fmtSmokeText, "let lines: str = Lines(lineParts)"),
           " cheng skill consistency: strformat fmt smoke direct Lines join")
    assert(chengpath.TextContains(fmtSmokeText, "let aliasedLines: str = sf.Lines(lineParts)"),
           " cheng skill consistency: strformat fmt smoke aliased Lines join")
    assert(chengpath.TextContains(explicitDefaultPositiveSmokeText,
                                 "let xs: int32[] = [1, 2]"),
           " cheng skill consistency: explicit default positive seq literal")
    assert(chengpath.TextContains(explicitDefaultPositiveSmokeText,
                                 "let inferredFoo = PositiveFoo()"),
           " cheng skill consistency: explicit default positive inferred object")
    assert(chengpath.TextContains(explicitDefaultNegativeSmokeText,
                                 "redundant explicit default init; omit initializer"),
           " cheng skill consistency: explicit default negative diagnostic")
    assert(chengpath.TextContains(explicitDefaultGateSmokeText,
                                 "redundant explicit default init forbidden"),
           " cheng skill consistency: explicit default gate diagnostic")
    assert(chengpath.TextContains(zeroHelperGateSmokeText,
                                 "composite no-arg Zero helper forbidden; use implicit init, T(), or new(T)"),
           " cheng skill consistency: zero helper gate diagnostic")

    var reportRows: str[]
    add(reportRows, "formal_spec=ok")
    add(reportRows, "repo_skill=ok")
    add(reportRows, "repo_grammar=ok")
    add(reportRows, "readme=ok")
    add(reportRows, "tooling_readme=ok")
    add(reportRows, "strformat_fmt_smoke=ok")
    add(reportRows, "explicit_default_init_positive_smoke=ok")
    add(reportRows, "explicit_default_init_negative_smoke=ok")
    add(reportRows, "explicit_default_init_gate_smoke=ok")
    add(reportRows, "composite_zero_helper_gate_smoke=ok")

    let homeDir = os.GetEnvDefault("HOME", "")
    if len(homeDir) > 0:
        let homeSkillPath = os.JoinPath(homeDir, ".codex/skills/cheng语言/SKILL.md")
        let homeGrammarPath = os.JoinPath(homeDir, ".codex/skills/cheng语言/references/grammar.md")
        if chengpath.FileExistsNonEmpty(workspaceRoot, homeSkillPath):
            let homeSkillText = chengpath.ReadTextFile("", homeSkillPath)
            assert(homeSkillText == repoSkillText, " cheng skill consistency: home skill mirror drift")
            add(reportRows, "home_skill=ok")
        else:
            add(reportRows, "home_skill=missing")
        if chengpath.FileExistsNonEmpty(workspaceRoot, homeGrammarPath):
            let homeGrammarText = chengpath.ReadTextFile("", homeGrammarPath)
            assert(homeGrammarText == repoGrammarText, " cheng skill consistency: home grammar mirror drift")
            add(reportRows, "home_grammar=ok")
        else:
            add(reportRows, "home_grammar=missing")
    else:
        add(reportRows, "home_skill=no_home_env")
        add(reportRows, "home_grammar=no_home_env")

    let reportPath = chengpath.PathJoin(outDir, "cheng_cheng_skill_consistency.report.txt")
    assert(chengpath.WriteTextFile(workspaceRoot,
                                  reportPath,
                                  strutil.Join([strutil.Join(reportRows, "\n"), "\n"], "")),
           " cheng skill consistency: write report")
    echo(" cheng_skill_consistency_smoke ok")
    return 0
