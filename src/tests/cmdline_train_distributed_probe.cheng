import std/cmdline
import std/os

fn main(): int32 =
    if cmdline.ParamCount() < 1:
        return 0
    let command: str = cmdline.ParamStr(1)
    if command != "train-distributed":
        return 0
    let inputCsv: str = cmdline.ReadFlagOrDefault("--input-csv", "")
    os.WriteFile("/tmp/cmdline_train_distributed_probe.txt", inputCsv)
    return 0
