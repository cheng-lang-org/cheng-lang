import cheng/core/backend/lowering_plan as lower
import cheng/core/ir/core_types as ir
import cheng/core/lang/parser
import cheng/core/lang/typed_expr as texpr

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn callStmt(kind: texpr.TypedExprIrStatementKind,
            index: int32,
            line: int32,
            bindingName: str,
            resultType: str,
            target: str,
            argCount: int32,
            argsText: str,
            returnRoot: bool,
            enclosingIfLine: int32): lower.PrimaryObjectIrStatement =
    var stmt: lower.PrimaryObjectIrStatement
    stmt.statementIndex = index
    stmt.lineNumber = line
    stmt.kind = kind
    stmt.bindingName = bindingName
    stmt.resultType = resultType
    stmt.callTarget = target
    stmt.callArgCount = argCount
    stmt.callArgsText = argsText
    stmt.returnRoot = returnRoot
    stmt.enclosingIfLineNumber = enclosingIfLine
    return stmt

fn returnStmt(index: int32,
              line: int32,
              surface: str,
              enclosingIfLine: int32): lower.PrimaryObjectIrStatement =
    var stmt: lower.PrimaryObjectIrStatement
    stmt.statementIndex = index
    stmt.lineNumber = line
    stmt.kind = texpr.TypedExprIrStmtReturn
    stmt.surfaceText = surface
    stmt.resultType = "int32"
    stmt.returnRoot = true
    stmt.enclosingIfLineNumber = enclosingIfLine
    return stmt

fn resultStmt(index: int32,
              line: int32,
              sourceName: str,
              resultType: str,
              detailKind: parser.NormalizedExprDetailKind,
              enclosingIfLine: int32): lower.PrimaryObjectIrStatement =
    var stmt: lower.PrimaryObjectIrStatement
    stmt.statementIndex = index
    stmt.lineNumber = line
    stmt.kind = texpr.TypedExprIrStmtResultIntrinsic
    stmt.detailKind = detailKind
    stmt.resultType = resultType
    stmt.callArgsText = sourceName
    stmt.enclosingIfLineNumber = enclosingIfLine
    return stmt

fn ifStmt(index: int32,
          line: int32,
          surface: str): lower.PrimaryObjectIrStatement =
    var stmt: lower.PrimaryObjectIrStatement
    stmt.statementIndex = index
    stmt.lineNumber = line
    stmt.kind = texpr.TypedExprIrStmtIf
    stmt.surfaceText = surface
    return stmt

fn buildLinear(): lower.PrimaryObjectIrFunction =
    var fnIr: lower.PrimaryObjectIrFunction
    fnIr.functionName = "LinearStmtFixture"
    fnIr.returnType = "int32"
    fnIr.bodyKind = texpr.BodyKindUnsupported
    add(fnIr.statements, callStmt(texpr.TypedExprIrStmtLetCall,
                                  1,
                                  2,
                                  "x",
                                  "int32",
                                  "A",
                                  0,
                                  "",
                                  false,
                                  0))
    add(fnIr.statements, callStmt(texpr.TypedExprIrStmtCall,
                                  2,
                                  3,
                                  "",
                                  "",
                                  "B",
                                  1,
                                  "x",
                                  false,
                                  0))
    add(fnIr.statements, returnStmt(3, 4, "x", 0))
    return fnIr

fn buildTopIf(): lower.PrimaryObjectIrFunction =
    var fnIr: lower.PrimaryObjectIrFunction
    fnIr.functionName = "TopIfStmtFixture"
    fnIr.returnType = "int32"
    fnIr.bodyKind = texpr.BodyKindUnsupported
    add(fnIr.statements, callStmt(texpr.TypedExprIrStmtIfCall,
                                  10,
                                  2,
                                  "",
                                  "bool",
                                  "Flag",
                                  0,
                                  "",
                                  false,
                                  0))
    add(fnIr.statements, ifStmt(11, 2, "if Flag():"))
    add(fnIr.statements, returnStmt(12, 3, "0", 2))
    add(fnIr.statements, returnStmt(13, 4, "1", 0))
    return fnIr

fn buildReturnCallShell(): lower.PrimaryObjectIrFunction =
    var fnIr: lower.PrimaryObjectIrFunction
    fnIr.functionName = "ReturnCallShellFixture"
    fnIr.returnType = "int32"
    fnIr.bodyKind = texpr.BodyKindUnsupported
    add(fnIr.statements, callStmt(texpr.TypedExprIrStmtLetCall,
                                  20,
                                  2,
                                  "text",
                                  "str",
                                  "ReadText",
                                  1,
                                  "1",
                                  false,
                                  0))
    add(fnIr.statements, returnStmt(21, 3, "RunText(text)", 0))
    add(fnIr.statements, callStmt(texpr.TypedExprIrStmtCall,
                                  22,
                                  3,
                                  "",
                                  "int32",
                                  "RunText",
                                  1,
                                  "text",
                                  true,
                                  0))
    return fnIr

fn buildResultProjection(): lower.PrimaryObjectIrFunction =
    var fnIr: lower.PrimaryObjectIrFunction
    fnIr.functionName = "ResultProjectionFixture"
    fnIr.returnType = "int32"
    fnIr.bodyKind = texpr.BodyKindUnsupported
    add(fnIr.statements, callStmt(texpr.TypedExprIrStmtLetCall,
                                  30,
                                  2,
                                  "res",
                                  "Result[str]",
                                  "GetResult",
                                  0,
                                  "",
                                  false,
                                  0))
    add(fnIr.statements, resultStmt(31,
                                    3,
                                    "res",
                                    "bool",
                                    parser.NormalizedExprDetailResultIsErr,
                                    0))
    add(fnIr.statements, ifStmt(32, 3, "if IsErr(res):"))
    add(fnIr.statements, returnStmt(33, 4, "HandleError(Error(res))", 3))
    add(fnIr.statements, callStmt(texpr.TypedExprIrStmtCall,
                                  34,
                                  4,
                                  "",
                                  "int32",
                                  "HandleError",
                                  1,
                                  "Error(res)",
                                  true,
                                  3))
    add(fnIr.statements, returnStmt(35, 5, "0", 0))
    return fnIr

fn buildCodeDispatch(): lower.PrimaryObjectIrFunction =
    var fnIr: lower.PrimaryObjectIrFunction
    fnIr.functionName = "CodeDispatchStmtFixture"
    fnIr.returnType = "int32"
    fnIr.bodyKind = texpr.BodyKindUnsupported
    add(fnIr.statements, callStmt(texpr.TypedExprIrStmtLetCall,
                                  40,
                                  2,
                                  "code",
                                  "int32",
                                  "CommandCode",
                                  0,
                                  "",
                                  false,
                                  0))
    add(fnIr.statements, ifStmt(41, 3, "if code == 1:"))
    add(fnIr.statements, returnStmt(42, 4, "HandlerOne()", 3))
    add(fnIr.statements, callStmt(texpr.TypedExprIrStmtCall,
                                  43,
                                  4,
                                  "",
                                  "int32",
                                  "HandlerOne",
                                  0,
                                  "",
                                  true,
                                  3))
    add(fnIr.statements, ifStmt(44, 5, "if code == 2:"))
    add(fnIr.statements, returnStmt(45, 6, "HandlerTwo()", 5))
    add(fnIr.statements, callStmt(texpr.TypedExprIrStmtCall,
                                  46,
                                  6,
                                  "",
                                  "int32",
                                  "HandlerTwo",
                                  0,
                                  "",
                                  true,
                                  5))
    add(fnIr.statements, returnStmt(47, 7, "2", 0))
    return fnIr

fn main(): int32 =
    var sourceTexts: texpr.TypedExprSourceText[]

    var linear = buildLinear()
    let linearOk = lower.LoweringBuildGeneralBodyIRFromStatements(linear, sourceTexts)
    let c1 = check(linearOk, 11)
    if c1 != 0: return c1
    let c2 = check(linear.bodyIR.callSequence.len == 2, 12)
    if c2 != 0: return c2
    let c3 = check(linear.bodyIR.ops.len == 2, 13)
    if c3 != 0: return c3
    let c4 = check(linear.bodyIR.blocks.len == 1, 14)
    if c4 != 0: return c4
    let c5 = check(linear.bodyIR.terms.len == 1 &&
                   linear.bodyIR.terms[0].kind == ir.BodyTermReturnTag, 15)
    if c5 != 0: return c5
    let c6 = check(linear.bodyIR.terms[0].resultSlot == 0, 16)
    if c6 != 0: return c6
    let c7 = check(linear.bodyIR.callSequence[1].argSlots.len == 1 &&
                   linear.bodyIR.callSequence[1].argSlots[0] == 0, 17)
    if c7 != 0: return c7

    var topIf = buildTopIf()
    let topIfOk = lower.LoweringBuildGeneralBodyIRFromStatements(topIf, sourceTexts)
    let c8 = check(topIfOk, 21)
    if c8 != 0: return c8
    let c9 = check(topIf.bodyIR.callSequence.len == 1, 22)
    if c9 != 0: return c9
    let c10 = check(topIf.bodyIR.blocks.len == 3, 23)
    if c10 != 0: return c10
    let c11 = check(topIf.bodyIR.terms.len == 3, 24)
    if c11 != 0: return c11
    let c12 = check(topIf.bodyIR.terms[0].kind == ir.BodyTermCbrTag, 25)
    if c12 != 0: return c12
    let c13 = check(topIf.bodyIR.terms[1].kind == ir.BodyTermReturnTag &&
                    topIf.bodyIR.terms[2].kind == ir.BodyTermReturnTag, 26)
    if c13 != 0: return c13

    var shell = buildReturnCallShell()
    let shellOk = lower.LoweringBuildGeneralBodyIRFromStatements(shell, sourceTexts)
    let c14 = check(shellOk, 31)
    if c14 != 0: return c14
    let c15 = check(shell.bodyIR.callSequence.len == 2, 32)
    if c15 != 0: return c15
    let c16 = check(shell.bodyIR.ops.len == 2 &&
                    shell.bodyIR.blocks.len == 1 &&
                    shell.bodyIR.terms.len == 1, 33)
    if c16 != 0: return c16
    let c17 = check(shell.bodyIR.callSequence[1].argSlots.len == 1 &&
                    shell.bodyIR.callSequence[1].argSlots[0] == shell.bodyIR.callSequence[0].resultSlot, 34)
    if c17 != 0: return c17
    let c18 = check(shell.bodyIR.terms[0].resultSlot == shell.bodyIR.callSequence[1].resultSlot, 35)
    if c18 != 0: return c18

    var resultCfg = buildResultProjection()
    let resultOk = lower.LoweringBuildGeneralBodyIRFromStatements(resultCfg, sourceTexts)
    let c19 = check(resultOk, 41)
    if c19 != 0: return c19
    let c20 = check(resultCfg.bodyIR.callSequence.len == 2, 42)
    if c20 != 0: return c20
    var projectCount: int32
    for opIndex in 0..<resultCfg.bodyIR.ops.len:
        if resultCfg.bodyIR.ops[opIndex].kind == ir.BodyOpResultProjectTag:
            projectCount = projectCount + 1
    let c21 = check(projectCount == 2, 43)
    if c21 != 0: return c21
    let c22 = check(resultCfg.bodyIR.blocks.len == 3 &&
                    resultCfg.bodyIR.terms.len == 3, 44)
    if c22 != 0: return c22
    let c23 = check(resultCfg.bodyIR.callSequence[1].argSlots.len == 1 &&
                    resultCfg.bodyIR.callSequence[1].argSlots[0] >= 0, 45)
    if c23 != 0: return c23

    var dispatch = buildCodeDispatch()
    let dispatchOk = lower.LoweringBuildGeneralBodyIRFromStatements(dispatch, sourceTexts)
    let c24 = check(dispatchOk, 51)
    if c24 != 0: return c24
    let c25 = check(dispatch.bodyIR.callSequence.len == 3, 52)
    if c25 != 0: return c25
    let c26 = check(dispatch.bodyIR.blocks.len == 5 &&
                    dispatch.bodyIR.terms.len == 5, 53)
    if c26 != 0: return c26
    let c27 = check(dispatch.bodyIR.terms[0].kind == ir.BodyTermCbrTag &&
                    dispatch.bodyIR.terms[0].conditionKind == ir.BodyCondI32EqTag &&
                    dispatch.bodyIR.terms[0].rhsSlot >= 0, 54)
    if c27 != 0: return c27
    let c28 = check(dispatch.bodyIR.terms[2].kind == ir.BodyTermCbrTag &&
                    dispatch.bodyIR.terms[2].conditionKind == ir.BodyCondI32EqTag &&
                    dispatch.bodyIR.terms[2].rhsSlot >= 0, 55)
    if c28 != 0: return c28

    echo(" cfg_typed_stmt_bodyir_lowering_smoke ok")
    return 0
