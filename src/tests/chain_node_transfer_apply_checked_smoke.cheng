import std/system
import cheng/chain/consensus as consensus
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node transfer apply checked: mint")

    let fromParentCid = node.ChainNodeAccountHead(server.index, 7, 1001)
    let toParentCid = node.ChainNodeAccountHead(server.index, 7, 2002)
    var event: consensus.ChainEvent
    event.version = 1
    event.kind = consensus.ConsensusKindTransferCommit
    event.assetId = 7
    event.fromAccount = 1001
    event.toAccount = 2002
    event.fromParentCid = fromParentCid
    event.toParentCid = toParentCid
    event.amount = int64(40)
    event.epoch = server.nextEpoch
    event.ganzhiIndex = server.nextGanzhi
    event.spaceSlot = node.ChainNodeSpaceSlot(1001, 2002)
    event.tick = server.nextTick
    event.stem = event.ganzhiIndex % 10
    event.branch = event.ganzhiIndex % 12
    event.bodyCid = consensus.ChainEventBodyCid(event)

    let eventCid = consensus.ChainEventCid(event)
    var nextIndex = server.index
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(nextIndex, event, eventCid, server.eventCids.len, decision)
    assert(decision.accepted, " chain_node transfer apply checked: accepted")
    assert(decision.applied, " chain_node transfer apply checked: applied")
    assert(nextIndex.accountIds.len == 2, " chain_node transfer apply checked: account len")
    assert(nextIndex.balances.len == 2, " chain_node transfer apply checked: balance len")
    assert(consensus.ConsensusAccountPos(nextIndex, 7, 1001) == 0,
           " chain_node transfer apply checked: sender pos")
    assert(consensus.ConsensusAccountPos(nextIndex, 7, 2002) == 1,
           " chain_node transfer apply checked: receiver pos")
    assert(nextIndex.balances[0] == int64(60), " chain_node transfer apply checked: sender 60")
    assert(nextIndex.balances[1] == int64(40), " chain_node transfer apply checked: receiver 40")
    echo(" chain_node_transfer_apply_checked_smoke ok")
    return 0
