import std/system
import cheng/chain/consensus as consensus
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node: init")
    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "v3 chain_node transfer apply checked: mint")

    let fromParentCid = node.v3ChainNodeAccountHead(server.index, 7, 1001)
    let toParentCid = node.v3ChainNodeAccountHead(server.index, 7, 2002)
    var event: consensus.V3ChainEvent
    event.version = 1
    event.kind = consensus.v3ConsensusKindTransferCommit
    event.assetId = 7
    event.fromAccount = 1001
    event.toAccount = 2002
    event.fromParentCid = fromParentCid
    event.toParentCid = toParentCid
    event.amount = int64(40)
    event.epoch = server.nextEpoch
    event.ganzhiIndex = server.nextGanzhi
    event.spaceSlot = node.v3ChainNodeSpaceSlot(1001, 2002)
    event.tick = server.nextTick
    event.stem = event.ganzhiIndex % 10
    event.branch = event.ganzhiIndex % 12
    event.bodyCid = consensus.v3ChainEventBodyCid(event)

    let eventCid = consensus.v3ChainEventCid(event)
    var nextIndex = server.index
    var decision = consensus.V3ConsensusDecision()
    consensus.v3ConsensusApplyChecked(nextIndex, event, eventCid, server.eventCids.len, decision)
    assert(decision.accepted, "v3 chain_node transfer apply checked: accepted")
    assert(decision.applied, "v3 chain_node transfer apply checked: applied")
    assert(nextIndex.accountIds.len == 2, "v3 chain_node transfer apply checked: account len")
    assert(nextIndex.balances.len == 2, "v3 chain_node transfer apply checked: balance len")
    assert(consensus.v3ConsensusAccountPos(nextIndex, 7, 1001) == 0,
           "v3 chain_node transfer apply checked: sender pos")
    assert(consensus.v3ConsensusAccountPos(nextIndex, 7, 2002) == 1,
           "v3 chain_node transfer apply checked: receiver pos")
    assert(nextIndex.balances[0] == int64(60), "v3 chain_node transfer apply checked: sender 60")
    assert(nextIndex.balances[1] == int64(40), "v3 chain_node transfer apply checked: receiver 40")
    echo("v3 chain_node_transfer_apply_checked_smoke ok")
    return 0
