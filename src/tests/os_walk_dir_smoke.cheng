import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_walk_dir_smoke_tmp"
    let childDir: str = os.JoinPath(tmpRoot, "nested")
    let childFile: str = os.JoinPath(tmpRoot, "top.txt")
    let grandChildFile: str = os.JoinPath(childDir, "deep.txt")

    if os.FileExists(grandChildFile):
        assert(os.RemoveFile(grandChildFile), " ordinary os.WalkDir cleanup deep file")
    if os.FileExists(childFile):
        assert(os.RemoveFile(childFile), " ordinary os.WalkDir cleanup top file")
    if os.DirExists(childDir):
        os.RemoveDir(childDir)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

    os.CreateDir(tmpRoot)
    os.CreateDir(childDir)
    os.WriteFile(childFile, "top")
    os.WriteFile(grandChildFile, "deep")

    let entries = os.WalkDir(tmpRoot)
    var sawChildDir: bool
    var sawChildFile: bool
    var sawGrandChildFile: bool
    for i in 0..<entries.len:
        let entry = entries[i]
        let kind = os.WalkDirEntryKind(entry)
        let path = os.WalkDirEntryPath(entry)
        if path == childDir && kind == os.PathComponent(1):
            sawChildDir = true
        elif path == childFile && kind == os.PathComponent(0):
            sawChildFile = true
        elif path == grandChildFile:
            sawGrandChildFile = true

    assert(entries.len == 2, " ordinary os.WalkDir direct child count")
    assert(sawChildDir, " ordinary os.WalkDir dir entry")
    assert(sawChildFile, " ordinary os.WalkDir file entry")
    let leakedNested: bool = sawGrandChildFile
    if leakedNested:
        assert(false, " ordinary os.WalkDir excludes nested file")

    if os.FileExists(grandChildFile):
        assert(os.RemoveFile(grandChildFile), " ordinary os.WalkDir remove deep file")
    if os.FileExists(childFile):
        assert(os.RemoveFile(childFile), " ordinary os.WalkDir remove top file")
    if os.DirExists(childDir):
        os.RemoveDir(childDir)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)
    echo(" os_walk_dir_smoke ok")
    return 0
