fn hot_mul(n: int32): int32 =
    var acc: int32
    var i: int32
    for i in i..<n:
        acc = acc + ((i * 3) % 17)
    return acc

fn hot_mix(n: int32): int32 =
    var acc: int32
    var i: int32
    for i in i..<n:
        acc = acc + ((i * 5) % 23)
    return acc

fn main(): int32 =
    var total: int32
    var round: int32
    for round in round..<512:
        total = total + hot_mul(160000)
        total = total + hot_mix(80000)
    if total == -1:
        return 1
    return 0
