import std/os
import std/result
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_csg as ccsg

fn main(): int32 =
    let literalText = "version=1\n" +
                      "package_id=cheng\n" +
                      "exported_count=1\n" +
                      "surface_cid=24686d7dbf11d6fab7cc8c8a976ea819aba0449ff21ebefbf0c029131424660a\n" +
                      "export[0]=cheng/tests/program_selfhost_smoke::main|main|5|2|2\n"
    var literalSurface: ccsg.CsgExportSurface
    let literalRes = ccsg.CompilerExportSurfaceFromReportText(literalText, literalSurface)
    if IsErr(literalRes):
        echo(Error(literalRes))
        assert(false, "export surface parse probe: literal parse")
    assert(literalSurface.exportedSymbolCount == 1, "export surface parse probe: literal count")
    assert(literalSurface.exportedTargetNames[0] == "main", "export surface parse probe: literal target")
    let root = os.GetCurrentDir()
    let filePath = chengpath.PathAbsolute(root, "artifacts/fresh_node_gate/host/program_selfhost_smoke.sync.surface.txt")
    let fileText = chengpath.ReadTextFile("", filePath)
    var fileSurface: ccsg.CsgExportSurface
    let fileRes = ccsg.CompilerExportSurfaceFromReportText(fileText, fileSurface)
    if IsErr(fileRes):
        echo(Error(fileRes))
        assert(false, "export surface parse probe: file parse")
    assert(fileSurface.exportedSymbolCount == 1, "export surface parse probe: file count")
    echo(" export_surface_parse_probe ok")
    return 0
