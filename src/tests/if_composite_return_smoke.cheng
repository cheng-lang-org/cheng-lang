fn v3IfCompositeReturn(flag: bool): str =
    if flag:
        return "yes"
    return "no"

fn main(): int32 =
    assert(v3IfCompositeReturn(true) == "yes", "v3 if composite return: true")
    assert(v3IfCompositeReturn(false) == "no", "v3 if composite return: false")
    echo("v3 if_composite_return_smoke ok")
    return 0
