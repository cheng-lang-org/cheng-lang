fn IfCompositeReturn(flag: bool): str =
    if flag:
        return "yes"
    return "no"

fn main(): int32 =
    assert(IfCompositeReturn(true) == "yes", " if composite return: true")
    assert(IfCompositeReturn(false) == "no", " if composite return: false")
    echo(" if_composite_return_smoke ok")
    return 0
