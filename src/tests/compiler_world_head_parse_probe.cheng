import std/os
import std/result
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_world_libp2p as cwlp
import cheng/core/backend/system_link_exec as sexec
import cheng/chain/pubsub
import cheng/libp2p/core/types as core
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host
import std/strutils as strutil

fn compilerWorldHeadProbePortBase(label: str): int32 =
    var acc: int32
    for i in 0..<label.len:
        acc = (acc + (int32(label[i]) & 255)) % 200
    return 6661 + (acc * 2)

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, strutil.Join(["artifacts/compiler_world_head_probe/", smokeLabel], ""))
    let portBase: int32 = compilerWorldHeadProbePortBase(smokeLabel)
    assert(chengpath.MkdirP(workspaceRoot, outDir), " compiler world head probe: mkdir")
    let sourcePath = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = chengpath.PathJoin(outDir, "program_selfhost_smoke")
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    let planRes = sexec.BuildSystemLinkExecPlan(workspaceRoot, req)
    assert(IsOk(planRes), " compiler world head probe: build plan")
    let plan = Value(planRes)
    var seedHost = host.Libp2pHostInit("compiler-world-seed")
    var syncHost = host.Libp2pHostInit("compiler-world-sync")
    cwlp.CompilerWorldRegister(seedHost)
    cwlp.CompilerWorldRegister(syncHost)
    var seedAddr: core.Libp2pMultiaddr
    var syncAddr: core.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(seedAddr, "127.0.0.1", portBase)
    multiaddr.Libp2pMultiaddrFillTcp(syncAddr, "127.0.0.1", portBase + 1)
    assert(IsOk(host.Libp2pListen(seedHost, seedAddr)), " compiler world head probe: seed listen")
    assert(IsOk(host.Libp2pListen(syncHost, syncAddr)), " compiler world head probe: sync listen")
    assert(IsOk(host.Libp2pDial(syncHost, seedHost.selfPeerId, seedAddr, 1)), " compiler world head probe: dial seed")
    assert(IsOk(host.Libp2pDial(seedHost, syncHost.selfPeerId, syncAddr, 1)), " compiler world head probe: dial sync")
    cwlp.CompilerWorldPublishUniverse(seedHost,
                                        plan.localUniverse,
                                        plan.compilerCsg,
                                        plan.exportSurface,
                                        plan.compileReceipt)
    let syncRes = cwlp.CompilerWorldSync(syncHost, seedHost, seedHost.selfPeerId)
    assert(IsOk(syncRes), " compiler world head probe: sync")
    var worldText = ""
    assert(cwlp.CompilerWorldFirstPayloadTextByKind(syncHost,
                                                      pubsub.PubSubPayloadKindCompilerWorldHead,
                                                      worldText),
           " compiler world head probe: synced head text")
    let probeText = strutil.Join([worldText, "\nprobe_prev=", cworld.CompilerWorldLineValue(worldText, "prev_head_cid"), "\nprobe_manifest=", cworld.CompilerWorldLineValue(worldText, "manifest_root_cid"), "\n"], "")
    assert(chengpath.WriteTextFile(workspaceRoot,
                                  chengpath.PathJoin(outDir, "world_head_probe.txt"),
                                  probeText),
           " compiler world head probe: write probe")
    var parsed: cworld.CompilerWorldHead
    let parseRes = cworld.CompilerWorldHeadFromReportText(worldText, parsed)
    assert(IsOk(parseRes), " compiler world head probe: parse head")
    return 0
