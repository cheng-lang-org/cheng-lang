import std/system
import std/result
import std/net/transports/udp_syscall as udp
import std/rawbytes
import std/os

fn main(): int32 =
    let listenerFd = os.UdpBindFdBridge("127.0.0.1", 0, 0)
    assert(listenerFd >= 0, " udp importc: listener bind")
    var listenerLocalAddr: udp.UdpSockAddr
    let listenerLocalAddrRes: Result[bool] = udp.UdpGetSockName(listenerFd, listenerLocalAddr)
    assert(IsOk(listenerLocalAddrRes), " udp importc: listener getsockname")
    assert(len(listenerLocalAddr.host) > 0, " udp importc: listener local host")
    assert(listenerLocalAddr.port > 0, " udp importc: listener local port")

    let senderFd = os.UdpBindFdBridge("127.0.0.1", 0, 0)
    assert(senderFd >= 0, " udp importc: sender bind")
    var senderLocalAddr: udp.UdpSockAddr
    let senderLocalAddrRes: Result[bool] = udp.UdpGetSockName(senderFd, senderLocalAddr)
    assert(IsOk(senderLocalAddrRes), " udp importc: sender getsockname")

    let payload: Bytes = bytesFromString("ping")
    var targetAddr: udp.UdpSockAddr
    let targetAddrRes: Result[bool] = udp.UdpSockAddrFromHostPort(
        listenerLocalAddr.host,
        listenerLocalAddr.port,
        listenerLocalAddr.isV6,
        listenerLocalAddr.family,
        true,
        targetAddr
    )
    assert(IsOk(targetAddrRes), " udp importc: target addr")
    let sendRes: Result[int32] = udp.UdpSendTo(senderFd, payload, targetAddr)
    assert(IsOk(sendRes), " udp importc: send")
    assert(Value(sendRes) == bytesLen(payload), " udp importc: send size")

    var recv: udp.UdpRecvResult
    let recvRes: Result[bool] = udp.UdpRecvFromBlocking(listenerFd, 64, recv)
    if IsErr(recvRes):
        panic(ErrorText(recvRes))
    assert(IsOk(recvRes), " udp importc: recv")
    assert(bytesEqual(recv.data, payload), " udp importc: recv payload")
    assert(recv.fromAddr.port == senderLocalAddr.port, " udp importc: recv peer port")
    assert(len(recv.fromAddr.host) > 0, " udp importc: recv peer host")

    let senderCloseRc = os.UdpCloseFd(senderFd)
    assert(senderCloseRc == 0, " udp importc: sender close")
    let listenerCloseRc = os.UdpCloseFd(listenerFd)
    assert(listenerCloseRc == 0, " udp importc: listener close")
    echo(" udp_importc_smoke ok")
    return 0
