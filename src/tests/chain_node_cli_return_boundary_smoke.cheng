import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_cli_core as cli

fn main(): int32 =
    var state: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(state, "return-boundary-node", "return-boundary-seed")),
           " chain_node cli return boundary: init")
    var snapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(snapshot, state)
    let statePath = "/tmp/chain_node_cli_return_boundary_smoke.state"
    assert(cli.ChainNodeCliWriteState(statePath, snapshot),
           " chain_node cli return boundary: write")
    cli.ChainNodeCliPrintSnapshotReport(snapshot)
    echo(" chain_node_cli_return_boundary_smoke ok")
    return 0
