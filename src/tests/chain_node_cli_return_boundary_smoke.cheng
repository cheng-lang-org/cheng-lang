import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_cli_core as cli

fn main(): int32 =
    var state: node.V3ChainNode
    assert(IsOk(node.V3ChainNodeInitInto(state, "return-boundary-node", "return-boundary-seed")),
           "v3 chain_node cli return boundary: init")
    var snapshot: node.V3ChainNodeServeSnapshot
    node.V3ChainNodeServeOnceInto(snapshot, state)
    let statePath = "/tmp/chain_node_cli_return_boundary_smoke.state"
    assert(cli.V3ChainNodeCliWriteState(statePath, snapshot),
           "v3 chain_node cli return boundary: write")
    cli.V3ChainNodeCliPrintSnapshotReport(snapshot)
    echo("v3 chain_node_cli_return_boundary_smoke ok")
    return 0
