import std/os
import std/cmdline
import cheng/std/bytes_layout as layout
import cheng/apps/bft/bft_validator_host as host
import std/strutils as strutil

fn main(): int32 =
    let statePath = cmdline.ReadFlagOrDefault("--state", "")
    let proposalFile = cmdline.ReadFlagOrDefault("--proposal-file", "")
    let votesFile = cmdline.ReadFlagOrDefault("--votes-file", "")
    if len(statePath) <= 0 || len(proposalFile) <= 0 || len(votesFile) <= 0:
        os.WriteLine(os.Get_stderr(), "bft_vote_set_probe requires --state --proposal-file --votes-file")
        return 2
    os.WriteLine(os.Get_stdout(), "stage=load_state")
    let stateRes = host.BftValidatorLoadState(statePath)
    if IsErr(stateRes):
        os.WriteLine(os.Get_stderr(), Error(stateRes))
        return 2
    os.WriteLine(os.Get_stdout(), "stage=load_proposal")
    let proposalRes = host.BftValidatorLoadProposalFile(proposalFile)
    if IsErr(proposalRes):
        os.WriteLine(os.Get_stderr(), Error(proposalRes))
        return 2
    os.WriteLine(os.Get_stdout(), "stage=preview")
    let previewRes = host.BftValidatorPreviewProposal(Value(stateRes), Value(proposalRes))
    if IsErr(previewRes):
        os.WriteLine(os.Get_stderr(), Error(previewRes))
        return 2
    os.WriteLine(os.Get_stdout(), "stage=build_self_vote")
    let selfVoteRes = host.BftValidatorBuildVote(Value(stateRes), Value(proposalRes))
    if IsErr(selfVoteRes):
        os.WriteLine(os.Get_stderr(), Error(selfVoteRes))
        return 2
    os.WriteLine(os.Get_stdout(), "stage=load_inbox")
    let inboxRes = host.BftValidatorVoteInboxLoad(votesFile)
    if IsErr(inboxRes):
        os.WriteLine(os.Get_stderr(), Error(inboxRes))
        return 2
    os.WriteLine(os.Get_stdout(), "stage=vote_set")
    let voteSetRes = host.BftValidatorVoteSetForProposal(votesFile,
                                                           Value(proposalRes),
                                                           Value(selfVoteRes),
                                                           Value(previewRes))
    if IsErr(voteSetRes):
        os.WriteLine(os.Get_stderr(), Error(voteSetRes))
        return 2
    let preview = Value(previewRes)
    let inbox = Value(inboxRes)
    let voteSet = Value(voteSetRes)
    os.WriteLine(os.Get_stdout(), "stage=commit_from_votes")
    let commitRes = host.BftValidatorCommitFromVotes(Value(proposalRes), preview, voteSet)
    if IsErr(commitRes):
        os.WriteLine(os.Get_stderr(), Error(commitRes))
        return 2
    os.WriteLine(os.Get_stdout(), "stage=apply_commit")
    var state = Value(stateRes)
    let applyRes = host.BftValidatorStateApplyCommit(state, Value(commitRes))
    if IsErr(applyRes):
        os.WriteLine(os.Get_stderr(), Error(applyRes))
        return 2
    os.WriteLine(os.Get_stdout(), strutil.Join(["inbox_count=", IntToStr(inbox.len)], ""))
    os.WriteLine(os.Get_stdout(), strutil.Join(["vote_set_count=", IntToStr(voteSet.len)], ""))
    os.WriteLine(os.Get_stdout(), strutil.Join(["proposal_hash=", layout.FixedBytes32Hex(preview.proposalHash)], ""))
    os.WriteLine(os.Get_stdout(), strutil.Join(["app_hash=", layout.FixedBytes32Hex(preview.appHash)], ""))
    os.WriteLine(os.Get_stdout(), strutil.Join(["tip_event_cid=", layout.FixedBytes32Hex(preview.tipEventCid)], ""))
    os.WriteLine(os.Get_stdout(), strutil.Join(["event_count=", IntToStr(preview.eventCount)], ""))
    os.WriteLine(os.Get_stdout(), strutil.Join(["account_count=", IntToStr(preview.accountCount)], ""))
    os.WriteLine(os.Get_stdout(), strutil.Join(["commit_app_hash=", layout.FixedBytes32Hex(Value(commitRes).appHash)], ""))
    os.WriteLine(os.Get_stdout(), strutil.Join(["commit_tip_event_cid=", layout.FixedBytes32Hex(Value(commitRes).tipEventCid)], ""))
    os.WriteLine(os.Get_stdout(), strutil.Join(["commit_event_count=", IntToStr(Value(commitRes).eventCount)], ""))
    os.WriteLine(os.Get_stdout(), strutil.Join(["commit_account_count=", IntToStr(Value(commitRes).accountCount)], ""))
    for i in 0..<inbox.len:
        os.WriteLine(os.Get_stdout(),
                     strutil.Join(["inbox_vote[", IntToStr(i), "]=", IntToStr(inbox[i].validatorSlot), ",", layout.FixedBytes32Hex(inbox[i].proposalHash), ",", layout.FixedBytes32Hex(inbox[i].appHash), ",", layout.FixedBytes32Hex(inbox[i].tipEventCid), ",", IntToStr(inbox[i].eventCount), ",", IntToStr(inbox[i].accountCount)], ""))
    for i in 0..<voteSet.len:
        os.WriteLine(os.Get_stdout(),
                     strutil.Join(["vote_set[", IntToStr(i), "]=", IntToStr(voteSet[i].validatorSlot), ",", layout.FixedBytes32Hex(voteSet[i].proposalHash), ",", layout.FixedBytes32Hex(voteSet[i].appHash), ",", layout.FixedBytes32Hex(voteSet[i].tipEventCid), ",", IntToStr(voteSet[i].eventCount), ",", IntToStr(voteSet[i].accountCount)], ""))
    return 0
