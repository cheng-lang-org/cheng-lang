type TextResult = Ok(message: str, code: int32) | Err(error: str, code: int32)

fn MakeText(): str =
    return "cold"

fn MakeResult(): TextResult =
    let message = MakeText()
    return Err(message, 38)

fn main(): int32 =
    let result = MakeResult()
    match result:
        Ok(message, code) =>
            return len(message) + code
        Err(error, code) =>
            return len(error) + code
