import cheng/core/tooling/path as chengpath
import cheng/core/lang/parser
import cheng/core/backend/lowering_plan as lower

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let sourcePath = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let ownerModulePath = parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, sourcePath)
    let symbolText = lower.LoweringFunctionSymbolText(ownerModulePath, "main")
    assert(symbolText == "cheng/tests/program_selfhost_smoke::main",
           " lowering owner module symbol")
    echo(" lowering_owner_module_symbol_smoke ok")
    return 0
