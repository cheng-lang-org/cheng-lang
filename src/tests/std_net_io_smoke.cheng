# std net IO smoke: ipaddr/bufferstream

import std/system
import std/result
import std/rawbytes
import std/net/ipaddr as ipaddr
import std/net/stream/bufferstream as bufferstream

fn main() =
    let ipRes: Result[ipaddr.IpAddr] = ipaddr.parseIpAddr("127.0.0.1")
    assert(IsOk(ipRes), "std/net/ipaddr ipv4 parse")
    let badIpRes: Result[ipaddr.IpAddr] = ipaddr.parseIpAddr("999.0.0.1")
    assert(IsErr(badIpRes), "std/net/ipaddr invalid")

    var stream: bufferstream.BufferStream = bufferstream.newBufferStream()
    let writeRes: Result[int32] = bufferstream.write(stream, bytesFromString("abc"))
    assert(IsOk(writeRes) && Value(writeRes) == 3, "std/net/bufferstream write")
    let readRes: Result[Bytes] = bufferstream.read(stream, 2)
    assert(IsOk(readRes) && bytesToString(Value(readRes)) == "ab", "std/net/bufferstream read")
    let emptyReadRes: Result[Bytes] = bufferstream.read(stream, 8)
    assert(IsOk(emptyReadRes) && bytesToString(Value(emptyReadRes)) == "c", "std/net/bufferstream remaining")
    bufferstream.closeBufferStream(stream)
    let closedReadRes: Result[Bytes] = bufferstream.read(stream, 1)
    assert(IsErr(closedReadRes), "std/net/bufferstream closed")
