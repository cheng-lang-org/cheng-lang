import std/os
import std/strings

fn main(): int32 =
    let root = os.GetCurrentDir()
    let strformatNegative = os.JoinPath(root, "src/tests/strformat_fmt_negative_smoke.cheng")
    let compositeNegative = os.JoinPath(root, "src/tests/composite_default_init_negative_smoke.cheng")
    let exportNegative = os.JoinPath(root, "src/tests/export_visibility_negative_smoke.cheng")
    let exportParallel = os.JoinPath(root, "src/tests/export_visibility_parallel_smoke.cheng")

    let strformatText = os.ReadFile(strformatNegative)
    assert(strings.StrContains(strformatText, "cmdline.ProgramName()"),
           "artifact isolation audit strformat: executable marker")
    assert(strings.StrContains(strformatText, ".workspace"),
           "artifact isolation audit strformat: workspace marker")
    assert(!strings.StrContains(strformatText, "artifacts/strformat_fmt_negative_smoke"),
           "artifact isolation audit strformat: stale shared path")

    let compositeText = os.ReadFile(compositeNegative)
    assert(strings.StrContains(compositeText, "cmdline.ProgramName()"),
           "artifact isolation audit composite: executable marker")
    assert(strings.StrContains(compositeText, ".workspace"),
           "artifact isolation audit composite: workspace marker")
    assert(!strings.StrContains(compositeText, "artifacts/composite_default_negative_smoke"),
           "artifact isolation audit composite: stale shared path")

    let exportNegativeText = os.ReadFile(exportNegative)
    assert(strings.StrContains(exportNegativeText, "currentExecutablePath(root)"),
           "artifact isolation audit export negative: executable marker")
    assert(strings.StrContains(exportNegativeText, ".workspace"),
           "artifact isolation audit export negative: workspace marker")

    let exportParallelText = os.ReadFile(exportParallel)
    assert(strings.StrContains(exportParallelText,
                               "let stage3Label = strutil.Join([\"verify_export_stage3_parallel_\", selfLabel], \"\")"),
           "artifact isolation audit export parallel: stage3 labeled hostrun")
    assert(strings.StrContains(exportParallelText,
                               "let backendLabel = strutil.Join([\"verify_export_backend_driver_parallel_\", selfLabel], \"\")"),
           "artifact isolation audit export parallel: backend labeled hostrun")

    echo(" artifact_isolation_audit_smoke ok")
    return 0
