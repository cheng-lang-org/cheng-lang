import std/os
import std/result
import std/rawbytes
import std/multiformats/multibase
import std/strutils as strutil

fn main(): int32 =
    let knownRaw = bytesAlloc(38)
    for i in 0..<38:
        bytesSet(knownRaw, i, 0)
    bytesSet(knownRaw, 1, 36)
    bytesSet(knownRaw, 2, 0x08)
    bytesSet(knownRaw, 3, 0x01)
    bytesSet(knownRaw, 4, 0x12)
    bytesSet(knownRaw, 5, 0x20)
    let expected = "12D3KooW9pNAk8aiBuGVQtWRdbkLmo5qVL3e2h5UxbN2Nz9ttwiw"
    let actual = multibase.encodeBase58(knownRaw)
    if actual != expected:
        os.WriteLine(2, actual)
        panic(" multibase: base58 mismatch")
    let decodeRes = multibase.decodeBase58(expected)
    assert(IsOk(decodeRes), " multibase: decode base58")
    let multibaseTextRes = multibase.encodeBase58Multibase(knownRaw)
    assert(IsOk(multibaseTextRes), " multibase: encode multibase")
    assert(Value(multibaseTextRes) == strutil.Join(["z", expected], ""), " multibase: multibase text")
    let multibaseDecodeRes = multibase.decodeMultibase(Value(multibaseTextRes))
    assert(IsOk(multibaseDecodeRes), " multibase: decode multibase")
    echo(" multibase_base58_smoke ok")
    return 0
