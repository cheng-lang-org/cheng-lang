import std/system
import std/result
import std/crypto/ecnist
import cheng/chain/binary_types as binary
import cheng/chain/pubsub
import cheng/oracle/oracle_runtime_host as oracle_host
import cheng/oracle/oracle_plane as oracle_plane
import cheng/oracle/oracle_types as oracle_types
import cheng/std/crypto/fixed256
import cheng/std/bytes_layout as layout
import cheng/tests/oracle_smoke_support as support
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host

fn oracleProbeVerifyLocal(batch: var oracle_plane.OracleSignedBatch, pubBytes: Bytes): bool =
    echo("probe: local structural start")
    let okRes = oracle_plane.OracleSignedBatchStructuralValidate(batch)
    echo("probe: local structural done")
    if IsErr(okRes):
        return false
    echo("probe: local signable start")
    let signableRes = oracle_plane.OracleSignedBatchSignableBytes(batch)
    echo("probe: local signable done")
    if IsErr(signableRes):
        return false
    echo("probe: local sig bytes start")
    let sigBytes = layout.FixedBytes64ToBytes(batch.sig)
    echo("probe: local sig bytes done")
    echo("probe: local verify start")
    let verifyOk = ecnist.ecdsaVerifyTrustedBytes(pubBytes, Value(signableRes), sigBytes)
    echo("probe: local verify done")
    if !verifyOk:
        return false
    return true

fn main(): int32 =
    echo("probe: start")
    let committee = support.oracleSmokeCommittee()
    echo("probe: committee")
    var gossipRuntime = oracle_host.OracleFastRuntimeInit(committee)
    var syncRuntime = oracle_host.OracleFastRuntimeInit(committee)
    echo("probe: runtimes")

    var authorHost = host.Libp2pHostInit("oracle.runtime.host.author")
    var readerHost = host.Libp2pHostInit("oracle.runtime.host.reader")
    echo("probe: hosts")

    var authorAddr: types.Libp2pMultiaddr
    var readerAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(authorAddr, "127.0.0.1", 6336)
    multiaddr.Libp2pMultiaddrFillTcp(readerAddr, "127.0.0.1", 6337)
    echo("probe: addrs")

    let authorListenRes = host.Libp2pListen(authorHost, authorAddr)
    assert(IsOk(authorListenRes), "probe: author listen")
    let readerListenRes = host.Libp2pListen(readerHost, readerAddr)
    assert(IsOk(readerListenRes), "probe: reader listen")
    echo("probe: listen")

    host.Libp2pRegisterHandler(authorHost, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(readerHost, types.Libp2pProtocolSync)
    echo("probe: handlers")

    let dialReaderRes = host.Libp2pDial(readerHost,
                                          authorHost.selfPeerId,
                                          authorAddr,
                                          overlay.OverlayRoleEdgeRelayStore)
    assert(IsOk(dialReaderRes), "probe: reader dial")
    let dialAuthorRes = host.Libp2pDial(authorHost,
                                          readerHost.selfPeerId,
                                          readerAddr,
                                          overlay.OverlayRoleEdgeRelayStore)
    assert(IsOk(dialAuthorRes), "probe: author dial")
    echo("probe: dial")

    let addressRes = binary.LsmrAddressFromDigits([2, 6, 6])
    assert(IsOk(addressRes), "probe: address")
    let address = Value(addressRes)
    let scope = overlay.OverlayScopeRegion
    echo("probe: address done")

    for reporterSlot in 1..<6:
        echo("probe: reporter")
        var batch = support.oracleSmokeBatch(int64(12), reporterSlot)
        echo("probe: batch")
        let structuralRes = oracle_plane.OracleSignedBatchStructuralValidate(batch)
        assert(IsOk(structuralRes), "probe: structural")
        echo("probe: structural")
        let signableRes = oracle_plane.OracleSignedBatchSignableBytes(batch)
        assert(IsOk(signableRes), "probe: signable")
        echo("probe: signable")
        let pubKey = committee.reporterPubKeys[batch.reporterSlot - 1]
        echo("probe: pubkey")
        let pubBytes = layout.FixedBytes65ToBytes(pubKey)
        echo("probe: pub bytes")
        let sigBytes = layout.FixedBytes64ToBytes(batch.sig)
        echo("probe: sig bytes")
        let pubTrustedOk = ecnist.validateEcdsaTrustedPublicKeyBytes(pubBytes)
        assert(pubTrustedOk, "probe: validate trusted pub")
        echo("probe: validate trusted pub")
        let sigShapeOk = ecnist.validateEcdsaSignatureBytes(sigBytes)
        assert(sigShapeOk, "probe: validate sig")
        echo("probe: validate sig")
        let verifyTrusted = ecnist.ecdsaVerifyTrustedBytes(pubBytes, Value(signableRes), sigBytes)
        assert(verifyTrusted, "probe: assert verify trusted")
        echo("probe: echo verify trusted")
        return 0
        echo("probe: before verify local")
        let verifyLocalOk = oracleProbeVerifyLocal(batch, pubBytes)
        if !verifyLocalOk:
            echo("probe: verify local err")
            return 1
        echo("probe: verify local")
        echo("probe: before verify direct")
        let verifyDirectRes = oracle_plane.OracleSignedBatchVerify(batch, pubBytes)
        if IsErr(verifyDirectRes):
            let directErr = Error(verifyDirectRes)
            echo("probe: verify direct err")
            echo(directErr)
            return 1
        echo("probe: verify direct")
        echo("probe: before verify against committee")
        let verifyRes = oracle_plane.OracleSignedBatchVerifyAgainstCommittee(batch, committee)
        if IsErr(verifyRes):
            let errText = Error(verifyRes)
            echo("probe: verify against committee err")
            echo(errText)
            return 1
        echo("probe: verify against committee")
        let storeGossipRes = oracle_host.OracleFastRuntimeStoreBatch(gossipRuntime, batch)
        assert(IsOk(storeGossipRes), "probe: store gossip")
        echo("probe: store gossip")
    echo("probe: done")
    return 0
