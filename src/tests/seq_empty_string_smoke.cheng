import std/system
import std/seqs

fn main(): int32 =
    var items: str[]
    add(items, "left")
    add(items, "")
    assert(items.len == 2, " seq empty string len")
    assert(items[0] == "left", " seq empty string first")
    assert(items[1] == "", " seq empty string second")
    echo(" seq_empty_string_smoke ok")
    return 0
