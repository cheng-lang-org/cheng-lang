import std/system
import std/result
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt
import cheng/chain/csg
import cheng/chain/pubsub
import cheng/chain/plumtree

fn main(): int32 =
    var centerRes: Result[types.LsmrAddress]
    centerRes = types.LsmrAddressFromDigits([5, 5, 5])
    assert(IsOk(centerRes), " plumtree smoke: center address")
    var center = Value(centerRes)

    var topicRes: Result[pubsub.PubSubTopic]
    topicRes = pubsub.PubSubTopicFromAddress(center,
                                               2,
                                               lt.PubSubModeXun,
                                               pubsub.PubSubSemanticFingerprint([41, 42, 43]))
    assert(IsOk(topicRes), " plumtree smoke: topic")
    var topic = Value(topicRes)

    var payloadCid = lt.HashInts("cheng.plumtree.payload", [7, 8, 9])
    var payloadSummaryCid = lt.HashInts("cheng.plumtree.summary", [3, 2, 1])
    var envelope = pubsub.PubSubEnvelopeMake(topic.topicCid,
                                               pubsub.PubSubPayloadKindStateDelta,
                                               payloadCid,
                                               payloadSummaryCid)

    var subscriptions: pubsub.PubSubSubscription[]
    subscriptions = []
    let root = pubsub.PubSubSubscriptionMake(1, center, csg.CsgBarrierModeGen, topic.topicCid)
    add(subscriptions, root)

    var eastPrimaryRes: Result[types.LsmrAddress]
    eastPrimaryRes = types.LsmrAddressFromDigits([5, 8, 1])
    assert(IsOk(eastPrimaryRes), " plumtree smoke: east primary")
    add(subscriptions,
        pubsub.PubSubSubscriptionMake(2, Value(eastPrimaryRes), csg.CsgBarrierModeGen, topic.topicCid))

    var eastBackupRes: Result[types.LsmrAddress]
    eastBackupRes = types.LsmrAddressFromDigits([5, 8, 2])
    assert(IsOk(eastBackupRes), " plumtree smoke: east backup")
    add(subscriptions,
        pubsub.PubSubSubscriptionMake(3, Value(eastBackupRes), csg.CsgBarrierModeGen, topic.topicCid))

    var eastRepairRes: Result[types.LsmrAddress]
    eastRepairRes = types.LsmrAddressFromDigits([5, 8, 6])
    assert(IsOk(eastRepairRes), " plumtree smoke: east repair")
    add(subscriptions,
        pubsub.PubSubSubscriptionMake(4, Value(eastRepairRes), csg.CsgBarrierModeGen, topic.topicCid))

    var northRes: Result[types.LsmrAddress]
    northRes = types.LsmrAddressFromDigits([5, 1, 6])
    assert(IsOk(northRes), " plumtree smoke: north")
    add(subscriptions,
        pubsub.PubSubSubscriptionMake(5, Value(northRes), csg.CsgBarrierModeGen, topic.topicCid))

    var pubPlanRes: Result[pubsub.PubSubPlan]
    pubPlanRes = pubsub.PubSubBuildPlan(topic, envelope, subscriptions)
    assert(IsOk(pubPlanRes), " plumtree smoke: pubsub plan")
    var pubPlan = Value(pubPlanRes)

    var treeRes: Result[plumtree.PlumtreePlan]
    treeRes = plumtree.PlumtreeBuildPlan(topic, root, pubPlan, subscriptions)
    assert(IsOk(treeRes), " plumtree smoke: tree")
    var tree = Value(treeRes)

    assert(tree.nodeCount == 5, " plumtree smoke: node count")
    assert(tree.eagerEdgeCount == 4, " plumtree smoke: eager edge count")
    assert(tree.lazyPeerCount == 3, " plumtree smoke: lazy peer count")
    assert(tree.ihaveCount == 3, " plumtree smoke: ihave count")
    assert(plumtree.PlumtreeEagerParentNodeId(tree, 2) == 1, " plumtree smoke: primary parent root")
    assert(plumtree.PlumtreeEagerParentNodeId(tree, 3) == 2, " plumtree smoke: backup parent primary")
    assert(plumtree.PlumtreeEagerParentNodeId(tree, 4) == 2, " plumtree smoke: repair node parent primary")
    assert(plumtree.PlumtreeLazyPeerCount(tree, 4) == 2, " plumtree smoke: repair node lazy peers")

    var repairRes: Result[plumtree.PlumtreeIwant]
    repairRes = plumtree.PlumtreeSelectRepair(tree, 4)
    assert(IsOk(repairRes), " plumtree smoke: repair")
    var repair = Value(repairRes)
    assert(repair.sourceNodeId == 3, " plumtree smoke: repair picks deepest lazy peer")
    assert(repair.branchDigit == 8, " plumtree smoke: repair branch")

    echo(" plumtree_smoke ok")
    return 0
