import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as binary
import cheng/chain/lsmr_types as lt
import cheng/overlay/contracts as overlay
import cheng/overlay/libp2p_bridge as bridge
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/host/host

fn main(): int32 =
    let overlayDepth = 3

    var node: host.Libp2pHost
    var selfPeer: types.Libp2pPeerId
    peer_id.Libp2pPeerIdFillFromSeed(selfPeer, "overlay.alpha")
    node.selfPeerId = selfPeer
    var ingress: overlay.IngressEnvelope
    let sourcePeer = peer_id.Libp2pPeerIdFromSeed("source")
    ingress.sourcePeerId = sourcePeer.value
    ingress.topicScope = overlay.OverlayScopeRegion
    ingress.address.depth = overlayDepth
    ingress.address.digits[0] = 5
    ingress.address.digits[1] = 8
    ingress.address.digits[2] = 1
    ingress.payloadKind = 0
    var payloadInts: int32[]
    payloadInts = []
    add(payloadInts, 1)
    add(payloadInts, 2)
    add(payloadInts, 3)
    let payloadCid = lt.HashInts("cheng.libp2p.overlay.payload", payloadInts)
    ingress.payloadCid = payloadCid
    ingress.payloadLen = 96
    ingress.stampEpoch = 7
    ingress.stampGanzhi = 19
    bridge.Libp2pRelayPublish(node, ingress)

    assert(node.storeEntries.len == 1, " libp2p overlay: store query count")
    let queriedFirst = node.storeEntries[0].ingress
    assert(layout.fixedBytes32Equal(queriedFirst.payloadCid, ingress.payloadCid),
        " libp2p overlay: stored payload")

    var better: overlay.NeighborCandidate
    let betterPeer = peer_id.Libp2pPeerIdFromSeed("better")
    better.peerId = betterPeer.value
    better.role = overlay.OverlayRoleRegionalRouter
    better.coordHint.address.depth = overlayDepth
    better.coordHint.address.digits[0] = 5
    better.coordHint.address.digits[1] = 8
    better.coordHint.address.digits[2] = 1
    better.coordHint.confidencePermille = 900
    better.scoreInput.lsmrDistance = 1
    better.scoreInput.rttEwmaMicros = 800
    better.scoreInput.lossPermille = 1
    better.scoreInput.loadPermille = 1
    better.scoreInput.trustPermille = 900

    var worse: overlay.NeighborCandidate
    let worsePeer = peer_id.Libp2pPeerIdFromSeed("worse")
    worse.peerId = worsePeer.value
    worse.role = overlay.OverlayRoleRegionalRouter
    worse.coordHint.address.depth = overlayDepth
    worse.coordHint.address.digits[0] = 5
    worse.coordHint.address.digits[1] = 8
    worse.coordHint.address.digits[2] = 1
    worse.coordHint.confidencePermille = 900
    worse.scoreInput.lsmrDistance = 1
    worse.scoreInput.rttEwmaMicros = 4000
    worse.scoreInput.lossPermille = 10
    worse.scoreInput.loadPermille = 10
    worse.scoreInput.trustPermille = 100

    var candidates: overlay.NeighborCandidate[]
    candidates = []
    add(candidates, worse)
    add(candidates, better)
    let nextRes = bridge.Libp2pSelectNextHop(candidates)
    assert(nextRes.ok, " libp2p overlay: next hop")
    let selectedPeer = nextRes.value
    let expectedPeer = types.Libp2pPeerId(value: better.peerId)
    assert(types.Libp2pPeerIdEqual(selectedPeer, expectedPeer),
        " libp2p overlay: score prefers better")

    var forestInts: int32[]
    forestInts = []
    add(forestInts, 9)
    let forestCid = lt.HashInts("cheng.libp2p.overlay.forest", forestInts)
    let digest = host.Libp2pSyncDigest(node,
                                         overlay.OverlayScopeRegion,
                                         forestCid,
                                         ingress.payloadCid,
                                         ingress.stampEpoch,
                                         ingress.stampGanzhi)
    assert(digest.eventCount == 1, " libp2p overlay: digest event count")
    assert(digest.accountCount == 1, " libp2p overlay: digest account count")
    echo(" libp2p_overlay_smoke ok")
    return 0
