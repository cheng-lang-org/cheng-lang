import std/bytes as bytes
import std/result
import std/system
import cheng/apps/wow_export/asset_formats as asset_formats

fn makeBuf(len: int32): bytes.ByteBuffer =
    var out: bytes.ByteBuffer
    out.len = len
    if len > 0:
        out.data = alloc(len)
    return out

fn putFourCC(buf: bytes.ByteBuffer, offset: int32, text: str) =
    bytes.BufSetByte(buf, offset, int32(text[0]))
    bytes.BufSetByte(buf, offset + 1, int32(text[1]))
    bytes.BufSetByte(buf, offset + 2, int32(text[2]))
    bytes.BufSetByte(buf, offset + 3, int32(text[3]))

fn putU32LE(buf: bytes.ByteBuffer, offset: int32, value: int32) =
    bytes.BufSetByte(buf, offset, value & 255)
    bytes.BufSetByte(buf, offset + 1, (value >> 8) & 255)
    bytes.BufSetByte(buf, offset + 2, (value >> 16) & 255)
    bytes.BufSetByte(buf, offset + 3, (value >> 24) & 255)

fn putU16LE(buf: bytes.ByteBuffer, offset: int32, value: int32) =
    bytes.BufSetByte(buf, offset, value & 255)
    bytes.BufSetByte(buf, offset + 1, (value >> 8) & 255)

fn seedClassicM2Header(buf: bytes.ByteBuffer, start: int32) =
    putFourCC(buf, start, "MD20")
    putU32LE(buf, start + 4, 272)
    putU32LE(buf, start + 0x1c, 2)
    putU32LE(buf, start + 0x2c, 7)
    putU32LE(buf, start + 0x3c, 370)
    putU32LE(buf, start + 0x44, 1)
    putU32LE(buf, start + 0x50, 2)

fn seedGeometryM2Header(buf: bytes.ByteBuffer, start: int32, vertexCount: int32, vertexOffset: int32) =
    seedClassicM2Header(buf, start)
    putU32LE(buf, start + 0x3c, vertexCount)
    putU32LE(buf, start + 0x40, vertexOffset)

fn seedM2VertexPosition(buf: bytes.ByteBuffer, start: int32, xBits: int32, yBits: int32, zBits: int32) =
    putU32LE(buf, start, xBits)
    putU32LE(buf, start + 4, yBits)
    putU32LE(buf, start + 8, zBits)

fn assertHeader(header: asset_formats.M2Header) =
    assert(header.version == 272, "wow_export_asset_formats_smoke version")
    assert(header.sequenceCount == 2, "wow_export_asset_formats_smoke sequences")
    assert(header.boneCount == 7, "wow_export_asset_formats_smoke bones")
    assert(header.vertexCount == 370, "wow_export_asset_formats_smoke vertices")
    assert(header.skinProfileCount == 1, "wow_export_asset_formats_smoke skins")
    assert(header.textureCount == 2, "wow_export_asset_formats_smoke textures")

fn main(): int32 =
    let classic: bytes.ByteBuffer = makeBuf(0x54)
    seedClassicM2Header(classic, 0)
    let classicRes: Result[asset_formats.M2Header] = asset_formats.ParseM2Header(classic)
    assert(IsOk(classicRes), Error(classicRes))
    assertHeader(Value(classicRes))
    bytes.FreeByteBuffer(classic)

    let wrapped: bytes.ByteBuffer = makeBuf(8 + 0x54)
    putFourCC(wrapped, 0, "MD21")
    putU32LE(wrapped, 4, 0x4f30)
    seedClassicM2Header(wrapped, 8)
    let wrappedRes: Result[asset_formats.M2Header] = asset_formats.ParseM2Header(wrapped)
    assert(IsOk(wrappedRes), Error(wrappedRes))
    assertHeader(Value(wrappedRes))
    bytes.FreeByteBuffer(wrapped)

    let bad: bytes.ByteBuffer = makeBuf(8)
    let badRes: Result[asset_formats.M2Header] = asset_formats.ParseM2Header(bad)
    assert(IsErr(badRes), "wow_export_asset_formats_smoke bad magic rejects")
    bytes.FreeByteBuffer(bad)

    let geomOffset: int32 = 0x80
    let geom: bytes.ByteBuffer = makeBuf(8 + geomOffset + 2 * 48)
    putFourCC(geom, 0, "MD21")
    putU32LE(geom, 4, geomOffset + 2 * 48)
    seedGeometryM2Header(geom, 8, 2, geomOffset)
    seedM2VertexPosition(geom, 8 + geomOffset, 0x3f800000, 0x40000000, 0x40400000)
    seedM2VertexPosition(geom, 8 + geomOffset + 48, 0x40800000, 0x40c00000, 0x41100000)
    let geomRes: Result[asset_formats.M2GeometrySummary] = asset_formats.ParseM2GeometrySummary(geom)
    assert(IsOk(geomRes), Error(geomRes))
    assert(Value(geomRes).header.vertexOffset == 8 + geomOffset,
           "wow_export_asset_formats_smoke geometry offset")
    assert(asset_formats.M2GeometrySpanX1000(Value(geomRes)) == 3000,
           "wow_export_asset_formats_smoke geometry span x")
    assert(asset_formats.M2GeometrySpanY1000(Value(geomRes)) == 4000,
           "wow_export_asset_formats_smoke geometry span y")
    assert(asset_formats.M2GeometrySpanZ1000(Value(geomRes)) == 6000,
           "wow_export_asset_formats_smoke geometry span z")
    bytes.FreeByteBuffer(geom)

    let wdt: bytes.ByteBuffer = makeBuf(8 + 4 + 8 + 16 + 8 + 32)
    putFourCC(wdt, 0, "REVM")
    putU32LE(wdt, 4, 4)
    putU32LE(wdt, 8, 18)
    putFourCC(wdt, 12, "NIAM")
    putU32LE(wdt, 16, 16)
    putU32LE(wdt, 20, 2)
    putU32LE(wdt, 24, 0)
    putU32LE(wdt, 28, 0)
    putU32LE(wdt, 32, 0)
    putFourCC(wdt, 36, "DIAM")
    putU32LE(wdt, 40, 32)
    putU32LE(wdt, 44, 1001)
    putU32LE(wdt, 48, 1002)
    let wdtRes: Result[asset_formats.WdtSummary] = asset_formats.ParseWdtSummary(wdt)
    assert(IsOk(wdtRes), Error(wdtRes))
    assert(Value(wdtRes).mainEntryCount == 2, "wow_export_asset_formats_smoke wdt main count")
    assert(Value(wdtRes).activeTileCount == 1, "wow_export_asset_formats_smoke wdt active count")
    assert(Value(wdtRes).maidReferencedFileCount == 2, "wow_export_asset_formats_smoke wdt maid refs")
    assert(Value(wdtRes).firstMaidFileDataID == 1001, "wow_export_asset_formats_smoke wdt first maid")
    let maidTileRes: Result[asset_formats.WdtMaidTile] =
        asset_formats.ParseWdtMaidTileFileDataIDs(wdt, 0, 0)
    assert(IsOk(maidTileRes), Error(maidTileRes))
    assert(Value(maidTileRes).fileDataIDCount == 2,
           "wow_export_asset_formats_smoke wdt maid tile count")
    assert(Value(maidTileRes).fileDataIDs.len == 8,
           "wow_export_asset_formats_smoke wdt maid tile slots")
    assert(Value(maidTileRes).fileDataIDs[0] == 1001,
           "wow_export_asset_formats_smoke wdt maid tile first slot")
    assert(Value(maidTileRes).fileDataIDs[1] == 1002,
           "wow_export_asset_formats_smoke wdt maid tile second slot")
    let maidTileMissingRes: Result[asset_formats.WdtMaidTile] =
        asset_formats.ParseWdtMaidTileFileDataIDs(wdt, 1, 0)
    assert(IsErr(maidTileMissingRes),
           "wow_export_asset_formats_smoke wdt maid tile missing rejects")
    bytes.FreeByteBuffer(wdt)

    let maidSplit: bytes.ByteBuffer = makeBuf(128)
    putFourCC(maidSplit, 0, "REVM")
    putU32LE(maidSplit, 4, 4)
    putU32LE(maidSplit, 8, 18)
    putFourCC(maidSplit, 12, "FDDM")
    putU32LE(maidSplit, 16, 36)
    putU32LE(maidSplit, 20, 77)
    putU32LE(maidSplit, 24, 88)
    putU32LE(maidSplit, 28, 0x3f800000)
    putU32LE(maidSplit, 32, 0x40000000)
    putU32LE(maidSplit, 36, 0x40400000)
    putU32LE(maidSplit, 40, 0)
    putU32LE(maidSplit, 44, 0)
    putU32LE(maidSplit, 48, 0)
    putU16LE(maidSplit, 52, 1024)
    putU16LE(maidSplit, 54, 1)
    putFourCC(maidSplit, 56, "FDOM")
    putU32LE(maidSplit, 60, 64)
    putU32LE(maidSplit, 64, 99)
    putU32LE(maidSplit, 68, 111)
    putU32LE(maidSplit, 72, 0x40800000)
    putU32LE(maidSplit, 76, 0x40a00000)
    putU32LE(maidSplit, 80, 0x40c00000)
    putU32LE(maidSplit, 84, 0)
    putU32LE(maidSplit, 88, 0)
    putU32LE(maidSplit, 92, 0)
    putU32LE(maidSplit, 96, 0x40400000)
    putU32LE(maidSplit, 100, 0x40800000)
    putU32LE(maidSplit, 104, 0x40a00000)
    putU32LE(maidSplit, 108, 0x40a00000)
    putU32LE(maidSplit, 112, 0x40c00000)
    putU32LE(maidSplit, 116, 0x40e00000)
    putU16LE(maidSplit, 120, 0)
    putU16LE(maidSplit, 122, 1)
    putU16LE(maidSplit, 124, 2)
    putU16LE(maidSplit, 126, 1024)
    let maidSplitRes: Result[asset_formats.WdtMaidResourceSummary] =
        asset_formats.ParseWdtMaidResourceSummary(maidSplit)
    assert(IsOk(maidSplitRes), Error(maidSplitRes))
    assert(Value(maidSplitRes).formatKind == "adt_split",
           "wow_export_asset_formats_smoke maid split format")
    assert(Value(maidSplitRes).secondMagic == "FDDM",
           "wow_export_asset_formats_smoke maid split second chunk")
    let maidSplitSummaryRes: Result[asset_formats.WdtMaidAdtSplitSummary] =
        asset_formats.ParseWdtMaidAdtSplitSummary(maidSplit)
    assert(IsOk(maidSplitSummaryRes), Error(maidSplitSummaryRes))
    let maidSummary: asset_formats.WdtMaidAdtSplitSummary = Value(maidSplitSummaryRes)
    assert(maidSummary.chunkCount == 3,
           "wow_export_asset_formats_smoke maid split chunk count")
    assert(maidSummary.doodadPlacementCount == 1,
           "wow_export_asset_formats_smoke maid split doodad count")
    assert(maidSummary.firstDoodadNameID == 77,
           "wow_export_asset_formats_smoke maid split doodad first name")
    assert(maidSummary.firstDoodadUniqueID == 88,
           "wow_export_asset_formats_smoke maid split doodad first unique")
    assert(maidSummary.doodadPlacementFileDataIDCount == 1,
           "wow_export_asset_formats_smoke maid split doodad fileDataID count")
    assert(maidSummary.firstDoodadPlacementFileDataID == 77,
           "wow_export_asset_formats_smoke maid split doodad fileDataID")
    assert(maidSummary.doodadPlacementPositionBoundsReady,
           "wow_export_asset_formats_smoke maid split doodad bounds")
    assert(asset_formats.WdtMaidDoodadPlacementSpanX1000(maidSummary) == 0,
           "wow_export_asset_formats_smoke maid split doodad span x")
    assert(maidSummary.minDoodadScale == 1024 && maidSummary.maxDoodadScale == 1024,
           "wow_export_asset_formats_smoke maid split doodad scale")
    assert(maidSummary.worldModelPlacementCount == 1,
           "wow_export_asset_formats_smoke maid split world model count")
    assert(maidSummary.firstWorldModelNameID == 99,
           "wow_export_asset_formats_smoke maid split world model first name")
    assert(maidSummary.firstWorldModelUniqueID == 111,
           "wow_export_asset_formats_smoke maid split world model first unique")
    assert(maidSummary.worldModelPlacementFileDataIDCount == 1,
           "wow_export_asset_formats_smoke maid split world model fileDataID count")
    assert(maidSummary.firstWorldModelPlacementFileDataID == 99,
           "wow_export_asset_formats_smoke maid split world model fileDataID")
    assert(maidSummary.worldModelPlacementPositionBoundsReady,
           "wow_export_asset_formats_smoke maid split world model bounds")
    assert(asset_formats.WdtMaidWorldModelPlacementSpanY1000(maidSummary) == 0,
           "wow_export_asset_formats_smoke maid split world model span y")
    assert(maidSummary.minWorldModelScale == 1024 && maidSummary.maxWorldModelScale == 1024,
           "wow_export_asset_formats_smoke maid split world model scale")
    bytes.FreeByteBuffer(maidSplit)

    let maidBlp: bytes.ByteBuffer = makeBuf(12)
    putFourCC(maidBlp, 0, "BLP2")
    putU32LE(maidBlp, 4, 1)
    putU32LE(maidBlp, 8, 2)
    let maidBlpRes: Result[asset_formats.WdtMaidResourceSummary] =
        asset_formats.ParseWdtMaidResourceSummary(maidBlp)
    assert(IsOk(maidBlpRes), Error(maidBlpRes))
    assert(Value(maidBlpRes).formatKind == "blp",
           "wow_export_asset_formats_smoke maid blp format")
    assert(Value(maidBlpRes).firstMagic == "BLP2",
           "wow_export_asset_formats_smoke maid blp magic")
    bytes.FreeByteBuffer(maidBlp)

    let adtMcnkSize: int32 = 128 + 8 + 580
    let adt: bytes.ByteBuffer = makeBuf(8 + 4 + 8 + adtMcnkSize)
    putFourCC(adt, 0, "REVM")
    putU32LE(adt, 4, 4)
    putU32LE(adt, 8, 18)
    putFourCC(adt, 12, "KNCM")
    putU32LE(adt, 16, adtMcnkSize)
    let adtMcnkData: int32 = 20
    putU32LE(adt, adtMcnkData + 112, 0x41200000)
    let adtMcvT: int32 = adtMcnkData + 128
    putFourCC(adt, adtMcvT, "TVCM")
    putU32LE(adt, adtMcvT + 4, 580)
    var adtSample: int32
    while adtSample < 145:
        putU32LE(adt, adtMcvT + 8 + adtSample * 4, 0)
        adtSample = adtSample + 1
    putU32LE(adt, adtMcvT + 8 + 144 * 4, 0x40400000)
    let adtRes: Result[asset_formats.AdtTerrainSummary] =
        asset_formats.ParseAdtTerrainSummary(adt)
    assert(IsOk(adtRes), Error(adtRes))
    assert(Value(adtRes).mapChunkCount == 1,
           "wow_export_asset_formats_smoke adt map chunks")
    assert(Value(adtRes).heightChunkCount == 1,
           "wow_export_asset_formats_smoke adt height chunks")
    assert(Value(adtRes).heightSampleCount == 145,
           "wow_export_asset_formats_smoke adt height samples")
    assert(Value(adtRes).minHeight1000 == 10000,
           "wow_export_asset_formats_smoke adt min height")
    assert(Value(adtRes).maxHeight1000 == 13000,
           "wow_export_asset_formats_smoke adt max height")
    bytes.FreeByteBuffer(adt)

    let wmo: bytes.ByteBuffer = makeBuf(8 + 4 + 8 + 64 + 8 + 32 + 8 + 40 + 8 + 8 + 8 + 12)
    putFourCC(wmo, 0, "REVM")
    putU32LE(wmo, 4, 4)
    putU32LE(wmo, 8, 17)
    putFourCC(wmo, 12, "DHOM")
    putU32LE(wmo, 16, 64)
    putU32LE(wmo, 20, 30)
    putU32LE(wmo, 24, 13)
    putU32LE(wmo, 28, 12)
    putU32LE(wmo, 32, 1)
    putU32LE(wmo, 36, 17)
    putU32LE(wmo, 40, 165)
    putU32LE(wmo, 44, 2)
    putFourCC(wmo, 84, "SDOM")
    putU32LE(wmo, 88, 32)
    putU32LE(wmo, 112, 0)
    putU32LE(wmo, 116, 1)
    putFourCC(wmo, 124, "DDOM")
    putU32LE(wmo, 128, 40)
    putU32LE(wmo, 132, 0)
    putU32LE(wmo, 136, 0x3f800000)
    putU32LE(wmo, 140, 0x40000000)
    putU32LE(wmo, 144, 0x40400000)
    putFourCC(wmo, 172, "DIFG")
    putU32LE(wmo, 176, 8)
    putU32LE(wmo, 180, 107075)
    putU32LE(wmo, 184, 107076)
    putFourCC(wmo, 188, "IDOM")
    putU32LE(wmo, 192, 12)
    putU32LE(wmo, 196, 198056)
    putU32LE(wmo, 200, 0)
    putU32LE(wmo, 204, 198558)
    let wmoRes: Result[asset_formats.WmoRootSummary] = asset_formats.ParseWmoRootSummary(wmo)
    assert(IsOk(wmoRes), Error(wmoRes))
    assert(Value(wmoRes).materialCount == 30, "wow_export_asset_formats_smoke wmo materials")
    assert(Value(wmoRes).groupCount == 13, "wow_export_asset_formats_smoke wmo groups")
    assert(Value(wmoRes).doodadCount == 165, "wow_export_asset_formats_smoke wmo doodads")
    assert(Value(wmoRes).doodadSetDefinitionCount == 1, "wow_export_asset_formats_smoke wmo doodad sets")
    assert(Value(wmoRes).doodadPlacementCount == 1, "wow_export_asset_formats_smoke wmo doodad placements")
    assert(Value(wmoRes).doodadSetPlacementCount == 1, "wow_export_asset_formats_smoke wmo doodad set placements")
    assert(Value(wmoRes).firstDoodadNameIndex == 0, "wow_export_asset_formats_smoke wmo first doodad")
    assert(Value(wmoRes).doodadBoundsReady, "wow_export_asset_formats_smoke wmo doodad bounds")
    assert(Value(wmoRes).minDoodadX1000 == 1000, "wow_export_asset_formats_smoke wmo doodad x")
    assert(Value(wmoRes).maxDoodadZ1000 == 3000, "wow_export_asset_formats_smoke wmo doodad z")
    assert(Value(wmoRes).groupFileDataIDCount == 2, "wow_export_asset_formats_smoke wmo gfid count")
    assert(Value(wmoRes).firstGroupFileDataID == 107075, "wow_export_asset_formats_smoke wmo first gfid")
    assert(Value(wmoRes).modelSlotCount == 3, "wow_export_asset_formats_smoke wmo modi slot count")
    assert(Value(wmoRes).modelFileDataIDCount == 2, "wow_export_asset_formats_smoke wmo modi count")
    assert(Value(wmoRes).firstModelFileDataID == 198056, "wow_export_asset_formats_smoke wmo first modi")
    assert(Value(wmoRes).doodadResolvedModelPlacementCount == 1,
           "wow_export_asset_formats_smoke wmo doodad model placements")
    assert(Value(wmoRes).doodadReferencedModelFileDataIDCount == 1,
           "wow_export_asset_formats_smoke wmo doodad referenced models")
    assert(Value(wmoRes).firstDoodadModelFileDataID == 198056,
           "wow_export_asset_formats_smoke wmo first doodad model")
    let wmoIdsRes: Result[int32[]] = asset_formats.ParseWmoModelFileDataIDs(wmo)
    assert(IsOk(wmoIdsRes), Error(wmoIdsRes))
    let wmoIds: int32[] = Value(wmoIdsRes)
    assert(wmoIds.len == 2, "wow_export_asset_formats_smoke wmo modi id count")
    assert(wmoIds[0] == 198056, "wow_export_asset_formats_smoke wmo modi id first")
    assert(wmoIds[1] == 198558, "wow_export_asset_formats_smoke wmo modi id second")
    let wmoDoodadIdsRes: Result[int32[]] = asset_formats.ParseWmoDoodadModelFileDataIDs(wmo)
    assert(IsOk(wmoDoodadIdsRes), Error(wmoDoodadIdsRes))
    let wmoDoodadIds: int32[] = Value(wmoDoodadIdsRes)
    assert(wmoDoodadIds.len == 1, "wow_export_asset_formats_smoke wmo doodad model id count")
    assert(wmoDoodadIds[0] == 198056, "wow_export_asset_formats_smoke wmo doodad model id")
    putU32LE(wmo, 132, 1)
    let badDoodadZeroRes: Result[asset_formats.WmoRootSummary] = asset_formats.ParseWmoRootSummary(wmo)
    assert(IsErr(badDoodadZeroRes), "wow_export_asset_formats_smoke wmo zero modi slot rejects")
    putU32LE(wmo, 132, 9)
    let badDoodadRangeRes: Result[asset_formats.WmoRootSummary] = asset_formats.ParseWmoRootSummary(wmo)
    assert(IsErr(badDoodadRangeRes), "wow_export_asset_formats_smoke wmo out of range modi slot rejects")
    bytes.FreeByteBuffer(wmo)

    let groupSize: int32 = 68 + 8 + 4 + 8 + 6 + 8 + 24 + 8 + 24
    let group: bytes.ByteBuffer = makeBuf(8 + 4 + 8 + groupSize)
    putFourCC(group, 0, "REVM")
    putU32LE(group, 4, 4)
    putU32LE(group, 8, 17)
    putFourCC(group, 12, "PGOM")
    putU32LE(group, 16, groupSize)
    let nested: int32 = 12 + 8 + 68
    putFourCC(group, nested, "YPOM")
    putU32LE(group, nested + 4, 4)
    putFourCC(group, nested + 12, "IVOM")
    putU32LE(group, nested + 16, 6)
    putFourCC(group, nested + 26, "TVOM")
    putU32LE(group, nested + 30, 24)
    putFourCC(group, nested + 58, "ABOM")
    putU32LE(group, nested + 62, 24)
    let groupRes: Result[asset_formats.WmoGroupSummary] = asset_formats.ParseWmoGroupSummary(group)
    assert(IsOk(groupRes), Error(groupRes))
    assert(Value(groupRes).vertexCount == 2, "wow_export_asset_formats_smoke group vertices")
    assert(Value(groupRes).indexCount == 3, "wow_export_asset_formats_smoke group indices")
    assert(Value(groupRes).batchCount == 1, "wow_export_asset_formats_smoke group batches")
    assert(Value(groupRes).materialInfoCount == 2, "wow_export_asset_formats_smoke group materials")
    bytes.FreeByteBuffer(group)

    let dep: bytes.ByteBuffer = makeBuf(8 + 0x54 + 8 + 4 + 8 + 8)
    putFourCC(dep, 0, "MD21")
    putU32LE(dep, 4, 0x54)
    seedClassicM2Header(dep, 8)
    putFourCC(dep, 8 + 0x54, "SFID")
    putU32LE(dep, 8 + 0x54 + 4, 4)
    putU32LE(dep, 8 + 0x54 + 8, 494438)
    putFourCC(dep, 8 + 0x54 + 12, "TXID")
    putU32LE(dep, 8 + 0x54 + 16, 8)
    putU32LE(dep, 8 + 0x54 + 20, 127489)
    putU32LE(dep, 8 + 0x54 + 24, 189598)
    let depRes: Result[asset_formats.M2DependencySummary] = asset_formats.ParseM2DependencySummary(dep)
    assert(IsOk(depRes), Error(depRes))
    assert(Value(depRes).skinFileDataIDCount == 1, "wow_export_asset_formats_smoke m2 skin deps")
    assert(Value(depRes).firstSkinFileDataID == 494438, "wow_export_asset_formats_smoke m2 first skin")
    assert(Value(depRes).textureFileDataIDCount == 2, "wow_export_asset_formats_smoke m2 texture deps")
    assert(Value(depRes).firstTextureFileDataID == 127489, "wow_export_asset_formats_smoke m2 first texture")
    bytes.FreeByteBuffer(dep)

    let skin: bytes.ByteBuffer = makeBuf(132)
    putFourCC(skin, 0, "SKIN")
    putU32LE(skin, 4, 3)
    putU32LE(skin, 8, 44)
    putU32LE(skin, 12, 3)
    putU32LE(skin, 16, 50)
    putU32LE(skin, 20, 1)
    putU32LE(skin, 24, 56)
    putU32LE(skin, 28, 1)
    putU32LE(skin, 32, 60)
    putU32LE(skin, 36, 1)
    putU32LE(skin, 40, 108)
    let skinRes: Result[asset_formats.M2SkinSummary] = asset_formats.ParseM2SkinSummary(skin)
    assert(IsOk(skinRes), Error(skinRes))
    assert(Value(skinRes).indexCount == 3, "wow_export_asset_formats_smoke skin indices")
    assert(Value(skinRes).triangleIndexCount == 3, "wow_export_asset_formats_smoke skin triangles")
    assert(Value(skinRes).submeshCount == 1, "wow_export_asset_formats_smoke skin submeshes")
    assert(Value(skinRes).textureUnitCount == 1, "wow_export_asset_formats_smoke skin texture units")
    bytes.FreeByteBuffer(skin)

    echo("wow_export_asset_formats_smoke ok")
    return 0
