import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt
import cheng/chain/lsmr as lsmr

fn main(): int32 =
    let addr0Res: Result[types.LsmrAddress] = types.LsmrAddressFromDigits([6, 7, 9, 3])
    assert(IsOk(addr0Res), " lsmr: address from digits")
    let addr1Res: Result[types.LsmrAddress] = types.LsmrAddressFromDigits([6, 7, 4, 2])
    assert(IsOk(addr1Res), " lsmr: second address from digits")
    let addr0 = Value(addr0Res)
    let addr1 = Value(addr1Res)
    assert(addr0.depth == 4, " lsmr: depth")
    assert(types.LsmrDigitOk(addr0.digits[0]), " lsmr: first digit valid")

    let baguaId = lsmr.LsmrAddressBagua(addr0, "peer-0")
    assert(lt.BaguaValid(baguaId), " lsmr: address bagua")
    assert(lsmr.LsmrSharedPrefixDepth(addr0, addr0) == addr0.depth, " lsmr: self shared prefix")

    let locality0 = lt.HashInts("cheng.lsmr.locality", [1, 10, 100])
    let locality1 = lt.HashInts("cheng.lsmr.locality", [1, 10, 100])
    assert(layout.fixedBytes32Equal(locality0, locality1), " lsmr: locality hash stable")

    let contentRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa")
    assert(IsOk(contentRes), " lsmr: content cid")
    let localityCidRes: Result[lt.LocalityCid] = lsmr.LsmrLocalityCidMake(7, addr0, 2, Value(contentRes), locality0)
    assert(IsOk(localityCidRes), " lsmr: locality cid")
    assert(Value(localityCidRes).layerId == lt.LayerRegional, " lsmr: resolution to layer")
    assert(Value(localityCidRes).prefix.prefixDepth == 2, " lsmr: locality prefix depth")

    var cell: lt.StateCell
    lsmr.LsmrStateCellFill(cell, 7, addr0, 2, Value(contentRes), locality0)
    assert(cell.baguaId == Value(localityCidRes).baguaId, " lsmr: state cell bagua")

    let routeRes: Result[lsmr.RoutePlan] = lsmr.LsmrRoutePlanFromAddresses(addr0, addr1)
    assert(IsOk(routeRes), " lsmr: route plan")
    assert(Value(routeRes).hopCount >= 0, " lsmr: hop count")
    assert(Value(routeRes).firstHopDigits.len <= 1, " lsmr: first hop collapsed")

    let treeRes: Result[lsmr.MulticastTree] = lsmr.LsmrBuildMulticastTree(addr0, [addr0, addr1])
    assert(IsOk(treeRes), " lsmr: multicast tree")
    assert(Value(treeRes).branchCount >= 1, " lsmr: multicast branches")

    echo(" lsmr_locality_storage_smoke ok")
    return 0
