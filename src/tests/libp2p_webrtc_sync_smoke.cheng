import std/system
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/binary_types as binary
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/multiaddr
import cheng/libp2p/protocols/webrtc_signal as signal
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/host/host

fn smokeAddress(): binary.LsmrAddress =
    var out: binary.LsmrAddress
    out.depth = 2
    out.digits[0] = 3
    out.digits[1] = 6
    return out

fn main(): int32 =
    webrtc_transport.Libp2pWebrtcTransportResetStats()
    var server = host.Libp2pHostInit("webrtc.sync.server")
    var client = host.Libp2pHostInit("webrtc.sync.client")
    let address = smokeAddress()

    host.Libp2pRegisterHandler(server, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(server, types.Libp2pProtocolWebrtcSignal)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolWebrtcSignal)

    var listenAddr: types.Libp2pMultiaddr
    listenAddr.host = "203.0.113.101"
    listenAddr.port = 9777
    listenAddr.transport = types.Libp2pTransportWebrtc
    listenAddr.networkDomain = types.Libp2pNetworkDomainBrowserWebrtc
    listenAddr.visibility = types.Libp2pVisibilityPublic
    let listenRes = host.Libp2pListen(server, listenAddr)
    assert(listenRes.ok, " libp2p webrtc sync: listen")

    let dialRes = host.Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " libp2p webrtc sync: dial")

    let payload = bytesFromString("cheng.webrtc.sync.payload")
    let payloadCid = hash256.sha256Fixed(layout.byteSpanFromBytes(payload))
    let sourcePeer = peer_id.Libp2pPeerIdFromSeed("webrtc.sync.source")

    var ingress: overlay.IngressEnvelope
    ingress.sourcePeerId = sourcePeer.value
    ingress.topicScope = overlay.OverlayScopeRegion
    ingress.address = address
    ingress.payloadKind = 0
    ingress.payload = payload
    ingress.payloadCid = payloadCid
    ingress.payloadLen = bytesLen(payload)
    ingress.stampEpoch = 9
    ingress.stampGanzhi = 18
    host.Libp2pStorePut(server, ingress)

    var query = overlay.StoreQuery()
    query.topicScope = overlay.OverlayScopeRegion
    query.address = address
    query.rangeLimit = 2

    var entries: overlay.IngressEnvelope[]
    let syncRes = host.Libp2pSyncRequest(client, server, server.selfPeerId, query, entries)
    assert(syncRes.ok, " libp2p webrtc sync: sync request")
    assert(entries.len == 1, " libp2p webrtc sync: entry count")
    assert(layout.fixedBytes32Equal(entries[0].payloadCid, payloadCid),
        " libp2p webrtc sync: payload cid")
    assert(client.openStreamPeers.len == 2, " libp2p webrtc sync: opened sync + signal")
    assert(client.openStreamProtocols[0] == types.Libp2pProtocolSync,
        " libp2p webrtc sync: sync stream")
    assert(client.openStreamProtocols[1] == types.Libp2pProtocolWebrtcSignal,
        " libp2p webrtc sync: signal stream")
    assert(host.Libp2pWebrtcSignalEgressCount(client) == 5,
        " libp2p webrtc sync: signal egress count")
    assert(host.Libp2pWebrtcSignalIngressCount(server) == 5,
        " libp2p webrtc sync: signal ingress count")
    let firstSignalRes = signal.Libp2pWebrtcSignalDecode(client.webrtcSignalEgressPayloads[0])
    assert(IsOk(firstSignalRes), " libp2p webrtc sync: decode first signal")
    let lastSignalRes = signal.Libp2pWebrtcSignalDecode(client.webrtcSignalEgressPayloads[4])
    assert(IsOk(lastSignalRes), " libp2p webrtc sync: decode last signal")
    let firstSignal = Value(firstSignalRes)
    let lastSignal = Value(lastSignalRes)
    assert(firstSignal.kind == signal.Libp2pWebrtcSignalTurnPolicy,
        " libp2p webrtc sync: first signal kind")
    assert(lastSignal.kind == signal.Libp2pWebrtcSignalIceCandidate,
        " libp2p webrtc sync: last signal kind")
    assert(webrtc_transport.Libp2pWebrtcBrowserDatachannelRequestCountNow() == 1,
        " libp2p webrtc sync: browser request count")
    assert(webrtc_transport.Libp2pWebrtcNativeDatachannelRequestCountNow() == 0,
        " libp2p webrtc sync: native request count")
    assert(webrtc_transport.Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        " libp2p webrtc sync: loopback request count")

    echo(" libp2p_webrtc_sync_smoke ok")
    return 0
