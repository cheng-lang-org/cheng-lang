import cheng/core/tooling/compiler_csg as ccsg

fn main() =
    var items: str[]
    var seen = ccsg.CompilerCsgTextSetInit(9)
    ccsg.CompilerCsgAddUniqueFast(items, seen, "cheng/tests/ordinary_zero_exit_fixture")
    assert(items.len == 1, "cold compiler csg text set add")
    ccsg.CompilerCsgAddUniqueFast(items, seen, "cheng/tests/ordinary_zero_exit_fixture")
    assert(items.len == 1, "cold compiler csg text set dedup")
    ccsg.CompilerCsgSortStrs(items)
    assert(items.len == 1, "cold compiler csg sort keeps len")
    assert(items[0] == "cheng/tests/ordinary_zero_exit_fixture", "cold compiler csg sort keeps item")
    var ids: int32[]
    add(ids, 7)
    assert(ccsg.CompilerCsgModuleNodeIdIndexed(items,
                                               ids,
                                               "cheng/tests/ordinary_zero_exit_fixture") == 7,
           "cold compiler csg module id indexed")
