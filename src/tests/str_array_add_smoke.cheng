fn main(): int32 =
    var args: str[]
    add(args, "system-link-exec")
    add(args, "--target:x86_64-unknown-linux-gnu")
    add(args, "--emit:exe")
    assert(args.len == 3, " str array add len")
    assert(args[0] == "system-link-exec", " str array add item0")
    assert(args[1] == "--target:x86_64-unknown-linux-gnu", " str array add item1")
    assert(args[2] == "--emit:exe", " str array add item2")
    echo(" str_array_add_smoke ok")
    return 0
