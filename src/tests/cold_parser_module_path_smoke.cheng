import std/system
import cheng/core/lang/parser as parser

fn main() =
    let modulePath = parser.ParserSourcePathToModulePath("/Users/lbcheng/cheng-lang",
                                                         "/Users/lbcheng/cheng-lang",
                                                         "/Users/lbcheng/cheng-lang/src/tests/ordinary_zero_exit_fixture.cheng")
    echo(modulePath)
    assert(modulePath == "cheng/tests/ordinary_zero_exit_fixture", "cold parser module path")
