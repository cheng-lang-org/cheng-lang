import std/os
import std/strutils as strutil
import cheng/core/lang/parser
import cheng/core/tooling/path as chengpath

fn parserNormalizedExprFixturePath(): str =
    return chengpath.PathJoin(chengpath.PathCurrentDir(),
                             "src/tests/parser_normalized_expr_fixture.cheng")

fn parserNormalizedExprFixtureLine(fixtureLines: str[], lineNumber: int32): str =
    if lineNumber <= 0 || lineNumber > fixtureLines.len:
        return ""
    return fixtureLines[lineNumber - 1]

fn assertFixtureLayerSummary(layer: parser.NormalizedExprLayer) =
    assert(layer.sourceCount == 1, " parser normalized expr: source count")
    assert(parser.NormalizedExprLayerExprCount(layer) == 21, " parser normalized expr: expr count")
    assert(parser.NormalizedExprLayerIfCount(layer) == 4, " parser normalized expr: if count")
    assert(parser.NormalizedExprLayerRangeCount(layer) == 2, " parser normalized expr: range count")
    assert(parser.NormalizedExprLayerComprehensionCount(layer) == 1, " parser normalized expr: comprehension count")
    assert(parser.NormalizedExprLayerStrFormatCount(layer) == 3, " parser normalized expr: fmt count")
    assert(parser.NormalizedExprLayerResultIntrinsicCount(layer) == 3, " parser normalized expr: result intrinsic count")
    assert(parser.NormalizedExprLayerCallCount(layer) == 3, " parser normalized expr: call count")
    assert(parser.NormalizedExprLayerTryCount(layer) == 1, " parser normalized expr: try count")
    assert(parser.NormalizedExprLayerDefaultInitCount(layer) == 2, " parser normalized expr: default init count")
    assert(parser.NormalizedExprLayerConstructorCount(layer) == 2, " parser normalized expr: constructor count")
    assert(layer.questionResidualCount == 0, " parser normalized expr: question normalized")
    assert(layer.exprs[0].exprId != "", " parser normalized expr: expr id")
    assert(layer.exprs[0].endLineNumber == layer.exprs[0].lineNumber, " parser normalized expr: same line span")
    assert(layer.exprs[0].endColumnNumber >= layer.exprs[0].columnNumber, " parser normalized expr: end column")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprIf,
                                                    parser.NormalizedExprDetailIfTernary,
                                                    7),
           " parser normalized expr: ternary normalized to if")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprTry,
                                                    parser.NormalizedExprDetailTryPostfixQuestion,
                                                    10),
           " parser normalized expr: postfix question normalized")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprRange,
                                                    parser.NormalizedExprDetailRangeExclusive,
                                                    11),
           " parser normalized expr: exclusive range")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprComprehension,
                                                    parser.NormalizedExprDetailComprehensionList,
                                                    14),
           " parser normalized expr: comprehension")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprResultIntrinsic,
                                                    parser.NormalizedExprDetailResultErr,
                                                    19),
           " parser normalized expr: result intrinsic")
    assert(parser.NormalizedExprLayerHasCallExpr(layer, parser.NormalizedExprSurfaceCallImportc, 16),
           " parser normalized expr: importc call")
    assert(parser.NormalizedExprLayerHasCallExpr(layer, parser.NormalizedExprSurfaceCallLocal, 17),
           " parser normalized expr: local call")
    assert(parser.NormalizedExprLayerHasCallExpr(layer, parser.NormalizedExprSurfaceCallMember, 18),
           " parser normalized expr: member call")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprDefaultInit,
                                                    parser.NormalizedExprDetailNone,
                                                    30),
           " parser normalized expr: object default init")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprDefaultInit,
                                                    parser.NormalizedExprDetailNone,
                                                    31),
           " parser normalized expr: tuple default init")
    assert(parser.NormalizedExprLayerHasConstructorExpr(layer, 34),
           " parser normalized expr: object constructor")
    assert(parser.NormalizedExprLayerHasConstructorExpr(layer, 35),
           " parser normalized expr: tuple constructor")

fn assertFixtureRangeAndFmtShapes(layer: parser.NormalizedExprLayer,
                                  fixtureLines: str[]) =
    var sawExclusiveRangeShape = false
    var sawInclusiveRangeShape = false
    var sawFmtLiteralShape = false
    var sawFmtArrayCallShape = false
    var sawFmtParenCallShape = false
    var sawComprehensionShape = false
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        let lineRaw = parserNormalizedExprFixtureLine(fixtureLines, expr.lineNumber)
        if expr.kind == parser.NormalizedExprRange && expr.lineNumber == 11:
            var startExpr = ""
            var endExpr = ""
            var endInclusive = false
            assert(parser.ParserParseRangeExprAt(lineRaw,
                                                   expr.columnNumber - 1,
                                                   startExpr,
                                                   endExpr,
                                                   endInclusive),
                   " parser normalized expr: parse exclusive range")
            assert(startExpr == "0", " parser normalized expr: exclusive range start")
            assert(endExpr == "4", " parser normalized expr: exclusive range end")
            assert(!endInclusive, " parser normalized expr: exclusive range flag")
            sawExclusiveRangeShape = true
            continue
        if expr.kind == parser.NormalizedExprRange && expr.lineNumber == 12:
            var startExpr = ""
            var endExpr = ""
            var endInclusive = false
            assert(parser.ParserParseRangeExprAt(lineRaw,
                                                   expr.columnNumber - 1,
                                                   startExpr,
                                                   endExpr,
                                                   endInclusive),
                   " parser normalized expr: parse inclusive range")
            assert(startExpr == "1", " parser normalized expr: inclusive range start")
            assert(endExpr == "5", " parser normalized expr: inclusive range end")
            assert(endInclusive, " parser normalized expr: inclusive range flag")
            sawInclusiveRangeShape = true
            continue
        if expr.kind == parser.NormalizedExprStrFormat &&
           expr.detailKind == parser.NormalizedExprDetailStrFormatLiteral &&
           expr.lineNumber == 13:
            var mode = ""
            var literal = ""
            var args = ""
            var endColumn = -1
            assert(parser.ParserParseFmtExprAt(lineRaw,
                                                 expr.columnNumber - 1,
                                                 mode,
                                                 literal,
                                                 args,
                                                 endColumn),
                   " parser normalized expr: parse fmt literal")
            assert(mode == "fmt_literal", " parser normalized expr: fmt literal mode")
            assert(literal == "picked={intToStr(settled)}", " parser normalized expr: fmt literal text")
            assert(endColumn > expr.columnNumber, " parser normalized expr: fmt literal span")
            sawFmtLiteralShape = true
            continue
        if expr.kind == parser.NormalizedExprStrFormat &&
           expr.detailKind == parser.NormalizedExprDetailStrFormatCall &&
           expr.lineNumber == 13:
            var mode = ""
            var literal = ""
            var args = ""
            var endColumn = -1
            assert(parser.ParserParseFmtExprAt(lineRaw,
                                                 expr.columnNumber - 1,
                                                 mode,
                                                 literal,
                                                 args,
                                                 endColumn),
                   " parser normalized expr: parse fmt array call")
            assert(mode == "fmt_call", " parser normalized expr: fmt array mode")
            assert(args == "[\"span\", intToStr(picked)]", " parser normalized expr: fmt array args")
            assert(endColumn > expr.columnNumber, " parser normalized expr: fmt array span")
            sawFmtArrayCallShape = true
            continue
        if expr.kind == parser.NormalizedExprComprehension && expr.lineNumber == 14:
            var itemText = ""
            var bindingText = ""
            var sourceText = ""
            var filterText = ""
            var filterColumn = -1
            var endColumn = -1
            assert(parser.ParserParseListComprehensionAt(lineRaw,
                                                           expr.columnNumber - 1,
                                                           itemText,
                                                           bindingText,
                                                           sourceText,
                                                           filterText,
                                                           filterColumn,
                                                           endColumn),
                   " parser normalized expr: parse comprehension")
            assert(itemText == "row", " parser normalized expr: comprehension item")
            assert(bindingText == "row", " parser normalized expr: comprehension binding")
            assert(sourceText == "rows", " parser normalized expr: comprehension source")
            assert(filterText == "row != \"\"", " parser normalized expr: comprehension filter")
            assert(filterColumn > expr.columnNumber, " parser normalized expr: comprehension filter column")
            assert(endColumn > filterColumn, " parser normalized expr: comprehension span")
            sawComprehensionShape = true
            continue
        if expr.kind == parser.NormalizedExprStrFormat &&
           expr.detailKind == parser.NormalizedExprDetailStrFormatCall &&
           expr.lineNumber == 15:
            var mode = ""
            var literal = ""
            var args = ""
            var endColumn = -1
            assert(parser.ParserParseFmtExprAt(lineRaw,
                                                 expr.columnNumber - 1,
                                                 mode,
                                                 literal,
                                                 args,
                                                 endColumn),
                   " parser normalized expr: parse fmt paren call")
            assert(mode == "fmt_call", " parser normalized expr: fmt paren mode")
            assert(args == "filtered", " parser normalized expr: fmt paren args")
            sawFmtParenCallShape = true
    assert(sawExclusiveRangeShape, " parser normalized expr: saw exclusive range shape")
    assert(sawInclusiveRangeShape, " parser normalized expr: saw inclusive range shape")
    assert(sawFmtLiteralShape, " parser normalized expr: saw fmt literal shape")
    assert(sawFmtArrayCallShape, " parser normalized expr: saw fmt array call shape")
    assert(sawFmtParenCallShape, " parser normalized expr: saw fmt paren call shape")
    assert(sawComprehensionShape, " parser normalized expr: saw comprehension shape")

fn assertFmtPrefixRejected() =
    let lineRaw = "let rendered = Fmt filtered"
    var mode = ""
    var literal = ""
    var args = ""
    var endColumn = -1
    assert(!parser.ParserParseFmtExprAt(lineRaw,
                                          15,
                                          mode,
                                          literal,
                                          args,
                                          endColumn),
           " parser normalized expr: reject fmt prefix call")

fn assertFixtureTypeCallShapes(layer: parser.NormalizedExprLayer) =
    var sawObjectDefaultInit = false
    var sawTupleDefaultInit = false
    var sawObjectConstructor = false
    var sawTupleConstructor = false
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind == parser.NormalizedExprDefaultInit && expr.lineNumber == 30:
            assert(parser.NormalizedExprDefaultInitType(expr) == "SurfaceWrap",
                   " parser normalized expr: object default init type")
            sawObjectDefaultInit = true
            continue
        if expr.kind == parser.NormalizedExprDefaultInit && expr.lineNumber == 31:
            assert(parser.NormalizedExprDefaultInitType(expr) == "SurfacePair",
                   " parser normalized expr: tuple default init type")
            sawTupleDefaultInit = true
            continue
        if expr.kind == parser.NormalizedExprConstructor && expr.lineNumber == 34:
            assert(parser.NormalizedExprConstructorType(expr) == "SurfaceWrap",
                   " parser normalized expr: object constructor type")
            assert(expr.callArgCount == 1, " parser normalized expr: object constructor arg count")
            assert(expr.callArgsText == "count: localCount", " parser normalized expr: object constructor args")
            sawObjectConstructor = true
            continue
        if expr.kind == parser.NormalizedExprConstructor && expr.lineNumber == 35:
            assert(parser.NormalizedExprConstructorType(expr) == "SurfacePair",
                   " parser normalized expr: tuple constructor type")
            assert(expr.callArgCount == 1, " parser normalized expr: tuple constructor arg count")
            assert(expr.callArgsText == "a: localPair", " parser normalized expr: tuple constructor args")
            sawTupleConstructor = true
    assert(sawObjectDefaultInit, " parser normalized expr: saw object default init")
    assert(sawTupleDefaultInit, " parser normalized expr: saw tuple default init")
    assert(sawObjectConstructor, " parser normalized expr: saw object constructor")
    assert(sawTupleConstructor, " parser normalized expr: saw tuple constructor")

fn assertFixtureCallShapes(layer: parser.NormalizedExprLayer) =
    var sawImportcCallSurface = false
    var sawLocalCallSurface = false
    var sawMemberReason = false
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        if expr.kind != parser.NormalizedExprCall:
            continue
        assert(expr.detailKind == parser.NormalizedExprDetailNone,
               " parser normalized expr: call detail stays empty")
        if expr.lineNumber == 16:
            assert(!expr.callPrefixStyle, " parser normalized expr: importc call paren style")
            assert(expr.callArgCount == 1, " parser normalized expr: importc call arg count")
            assert(expr.callArgsText == "rendered", " parser normalized expr: importc call args")
            assert(expr.endColumnNumber > expr.columnNumber, " parser normalized expr: importc call span")
            sawImportcCallSurface = true
            continue
        if expr.lineNumber == 17:
            assert(!expr.callPrefixStyle, " parser normalized expr: local call paren style")
            assert(expr.callArgCount == 1, " parser normalized expr: local call arg count")
            assert(expr.callArgsText == "imported", " parser normalized expr: local call args")
            sawLocalCallSurface = true
            continue
        if expr.lineNumber != 18:
            continue
        if parser.NormalizedExprCallSurfaceKind(expr) != parser.NormalizedExprSurfaceCallMember:
            continue
        assert(!expr.callPrefixStyle, " parser normalized expr: member call paren style")
        assert(expr.callArgCount == 1, " parser normalized expr: member call arg count")
        assert(expr.callArgsText == "wrapped", " parser normalized expr: member call args")
        assert(!expr.callResolved,
               " parser normalized expr: member call unresolved")
        assert(parser.NormalizedExprCallReasonKind(expr) == parser.NormalizedExprCallReasonUnknownQualifiedTarget,
               " parser normalized expr: member call reason")
        sawMemberReason = true
    assert(sawImportcCallSurface, " parser normalized expr: saw importc call surface")
    assert(sawLocalCallSurface, " parser normalized expr: saw local call surface")
    assert(sawMemberReason, " parser normalized expr: saw member call reason")

fn assertSyntheticCallContract(fixturePath: str) =
    var syntheticCallLayer = parser.NormalizedExprLayer()
    parser.NormalizedExprLayerAppendCall(syntheticCallLayer,
                                           fixturePath,
                                           99,
                                           5,
                                           "typedhelper.TypedExternalEcho",
                                           parser.NormalizedExprSurfaceCallExternal,
                                           true,
                                           parser.NormalizedExprCallReasonNone,
                                           "typedhelper",
                                           "TypedExternalEcho",
                                           "typedhelper.TypedExternalEcho",
                                           fixturePath,
                                           false,
                                           "payload",
                                           1,
                                           false,
                                           33)
    parser.NormalizedExprLayerAppendCall(syntheticCallLayer,
                                           fixturePath,
                                           99,
                                           5,
                                           "typedhelper.TypedExternalEcho",
                                           parser.NormalizedExprSurfaceCallExternal,
                                           true,
                                           parser.NormalizedExprCallReasonNone,
                                           "typedhelper",
                                           "TypedExternalEcho",
                                           "typedhelper.TypedExternalEcho",
                                           fixturePath,
                                           false,
                                           "payload",
                                           1,
                                           false,
                                           33)
    assert(parser.NormalizedExprLayerExprCount(syntheticCallLayer) == 1,
           " parser normalized expr: call dedup ignores compat detail")
    parser.NormalizedExprLayerAppendCall(syntheticCallLayer,
                                           fixturePath,
                                           99,
                                           5,
                                           "typedhelper.TypedExternalEcho",
                                           parser.NormalizedExprSurfaceCallExternal,
                                           false,
                                           parser.NormalizedExprCallReasonAmbiguousExternalTarget,
                                           "typedhelper",
                                           "TypedExternalEcho",
                                           "typedhelper.TypedExternalEcho",
                                           "",
                                           false,
                                           "payload",
                                           1,
                                           false,
                                           33)
    assert(parser.NormalizedExprLayerExprCount(syntheticCallLayer) == 2,
           " parser normalized expr: call dedup uses structured facts")
    assert(syntheticCallLayer.exprs[0].detailKind == parser.NormalizedExprDetailNone,
           " parser normalized expr: synthetic call detail empty")
    assert(syntheticCallLayer.exprs[1].detailKind == parser.NormalizedExprDetailNone,
           " parser normalized expr: synthetic call detail empty second")
    assert(syntheticCallLayer.exprs[0].exprId != syntheticCallLayer.exprs[1].exprId,
           " parser normalized expr: call expr id uses structured facts")

fn assertSyntheticConstructorContract(fixturePath: str) =
    var syntheticConstructorLayer = parser.NormalizedExprLayer()
    parser.NormalizedExprLayerAppendConstructor(syntheticConstructorLayer,
                                                  fixturePath,
                                                  120,
                                                  9,
                                                  "SurfaceWrap",
                                                  "count: 7",
                                                  1,
                                                  false,
                                                  27)
    parser.NormalizedExprLayerAppendConstructor(syntheticConstructorLayer,
                                                  fixturePath,
                                                  120,
                                                  9,
                                                  "SurfaceWrap",
                                                  "count: 7",
                                                  1,
                                                  false,
                                                  27)
    assert(parser.NormalizedExprLayerExprCount(syntheticConstructorLayer) == 1,
           " parser normalized expr: constructor dedup")

fn assertResolveUnknownTargetContract() =
    var emptyProfile: parser.NormalizedExprCallProfile
    var emptyProfiles: parser.NormalizedExprCallProfile[]
    var emptyLookup: parser.ParserSourcePathIndexLookup
    var emptyCache: parser.ParserProfileCallLookupCacheEntry[]
    let unknownExternalTarget = parser.ParserResolveCallTarget(emptyProfile,
                                                                 emptyProfiles,
                                                                 emptyLookup,
                                                                 emptyCache,
                                                                 parser.NormalizedExprSurfaceCallExternal,
                                                                 "",
                                                                 "")
    assert(unknownExternalTarget.reason == parser.NormalizedExprCallReasonUnknownExternalTarget,
           " parser normalized expr: direct resolve unknown external target")
    let unknownCallTarget = parser.ParserResolveCallTarget(emptyProfile,
                                                             emptyProfiles,
                                                             emptyLookup,
                                                             emptyCache,
                                                             parser.NormalizedExprSurfaceCallMember,
                                                             "",
                                                             "")
    assert(unknownCallTarget.reason == parser.NormalizedExprCallReasonUnknownCallTarget,
           " parser normalized expr: direct resolve unknown call target")

fn assertCallExprDetailContract(fixturePath: str) =
    let resolvedDetail = parser.ParserCallExprDetailExact("external_call",
                                                            "TypedExternalEcho",
                                                            "typedhelper",
                                                            "typedhelper.TypedExternalEcho",
                                                            true,
                                                            parser.NormalizedExprCallReasonNone,
                                                            fixturePath,
                                                            false)
    assert(resolvedDetail ==
           "kind=external_call;callee=TypedExternalEcho;qualifier=typedhelper;target=typedhelper.TypedExternalEcho;resolved=1;target_source_path=" + fixturePath,
           " parser normalized expr: resolved call detail contract")
    let importcDetail = parser.ParserCallExprDetailExact("importc_call",
                                                           "panic",
                                                           "",
                                                           "panic",
                                                           false,
                                                           parser.NormalizedExprCallReasonUnknownExternalTarget,
                                                           "",
                                                           true)
    assert(importcDetail ==
           "kind=importc_call;callee=panic;target=panic;reason=unknown_external_target;target_importc=1",
           " parser normalized expr: importc call detail contract")

fn parserNormalizedExprImportEdge(targetSourcePath: str): parser.ImportEdge =
    var edge: parser.ImportEdge
    edge.targetSourcePath = targetSourcePath
    edge.targetSourcePathLen = targetSourcePath.len
    if targetSourcePath != "":
        edge.targetSourcePathFirstCode = int32(targetSourcePath[0])
        edge.targetSourcePathLastCode = int32(targetSourcePath[targetSourcePath.len - 1])
        edge.targetSourcePathDotCount = parser.ParserTextLookupDotCount(targetSourcePath)
        edge.targetSourcePathHash = parser.ParserTextLookupContentHash(targetSourcePath)
    edge.targetProfileIndex = -1
    return edge

fn assertSourcePathLookupContract(fixturePath: str) =
    let typedFixturePath = chengpath.PathJoin(chengpath.PathCurrentDir(),
                                             "src/tests/typed_expr_fact_fixture.cheng")
    var profiles: parser.NormalizedExprCallProfile[]
    var fixtureProfile: parser.NormalizedExprCallProfile
    fixtureProfile.sourcePath = fixturePath
    add(profiles, fixtureProfile)
    var typedProfile: parser.NormalizedExprCallProfile
    typedProfile.sourcePath = typedFixturePath
    add(profiles, typedProfile)
    let lookup = parser.ParserSourcePathIndexLookupBuild(profiles)
    assert(parser.ParserProfileIndexLookupForSourcePath(lookup, fixturePath) == 0,
           " parser normalized expr: source path lookup fixture")
    assert(parser.ParserProfileIndexLookupForSourcePath(lookup, fixturePath + "/") == 0,
           " parser normalized expr: source path lookup trims trailing slash")
    assert(parser.ParserProfileIndexLookupForSourcePath(lookup, typedFixturePath) == 1,
           " parser normalized expr: source path lookup typed fixture")
    let typedEdge = parserNormalizedExprImportEdge(typedFixturePath)
    assert(parser.ParserProfileIndexLookupForImportEdgeTargetSourcePath(lookup, typedEdge) == 1,
           " parser normalized expr: import edge target lookup")
    assert(parser.ParserImportEdgeTargetProfileIndex(typedEdge, lookup) == 1,
           " parser normalized expr: import edge profile index")

fn main(): int32 =
    let fixturePath = parserNormalizedExprFixturePath()
    var layer = parser.NormalizedExprLayer()
    var err = ""
    assert(parser.ParserReadNormalizedExprLayerFromPath(fixturePath, layer, err),
           " parser normalized expr: read layer")
    let fixtureLines = strutil.Split(os.ReadFile(fixturePath), '\n')
    assertFixtureLayerSummary(layer)
    assertFixtureRangeAndFmtShapes(layer, fixtureLines)
    assertFmtPrefixRejected()
    assertFixtureTypeCallShapes(layer)
    assertFixtureCallShapes(layer)
    assertSyntheticCallContract(fixturePath)
    assertSyntheticConstructorContract(fixturePath)
    assertResolveUnknownTargetContract()
    assertCallExprDetailContract(fixturePath)
    assertSourcePathLookupContract(fixturePath)
    echo(" parser_normalized_expr_smoke ok")
    return 0
