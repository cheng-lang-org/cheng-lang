import std/os
import std/result
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/core/tooling/path as v3path
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world as cworld
import cheng/core/backend/system_link_exec as sexec

fn compilerWorldReplaceTomlQuotedLine(text: str,
                                      key: str,
                                      quotedValue: str): str =
    let lines = strutil.Split(text, '\n')
    let prefix = key + " = "
    var out = ""
    var replaced = false
    for i in 0..<lines.len:
        let line = strutil.Strip(lines[i])
        var nextLine = line
        if strutil.StartsWith(line, prefix):
            nextLine = prefix + quotedValue
            replaced = true
        if len(out) > 0:
            out = out + "\n"
        out = out + nextLine
    if !replaced:
        if len(out) > 0:
            out = out + "\n"
        out = out + prefix + quotedValue
    return out

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let packageRoot = workspaceRoot
    let sourcePath = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = v3path.V3PathJoin(workspaceRoot, "artifacts/compiler_world_manifest_closure/program_selfhost_smoke")
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    let planRes = sexec.v3BuildSystemLinkExecPlan(workspaceRoot, req)
    assert(IsOk(planRes), "v3 compiler world manifest closure: build plan")
    let plan = Value(planRes)
    let manifestReport = cworld.v3CompilerUniverseManifestReport(plan.localUniverse.manifest)
    var parsedManifest: cworld.V3CompilerUniverseManifest
    let parseManifestRes = cworld.v3CompilerUniverseManifestFromReportText(manifestReport, parsedManifest)
    assert(IsOk(parseManifestRes), "v3 compiler world manifest closure: parse manifest")
    assert(layout.fixedBytes32Equal(parsedManifest.manifestCid, plan.localUniverse.manifest.manifestCid),
           "v3 compiler world manifest closure: manifest cid")
    assert(parsedManifest.entryCount == 3, "v3 compiler world manifest closure: manifest entry count")
    var wrongManifestEntries: cworld.V3CompilerUniverseManifestEntry[]
    for i in 0..<parsedManifest.entries.len:
        add(wrongManifestEntries, parsedManifest.entries[i])
    wrongManifestEntries[0].migrationProofCid = cworld.v3CompilerWorldHashText("wrong_manifest_proof",
                                                                               [outputPath])
    let wrongManifestRes2 = cworld.v3CompilerUniverseManifestMake(parsedManifest.channel,
                                                                  wrongManifestEntries)
    assert(IsOk(wrongManifestRes2), "v3 compiler world manifest closure: wrong manifest make")
    assert(!layout.fixedBytes32Equal(Value(wrongManifestRes2).manifestCid, parsedManifest.manifestCid),
           "v3 compiler world manifest closure: manifest cid binds proof")
    let lockText = cworld.v3CompilerLockText(plan.localUniverse)
    let lockRes = cworld.v3CompilerLockSnapshotFromText(lockText, outputPath + ".lock.toml")
    assert(IsOk(lockRes), "v3 compiler world manifest closure: parse lock")
    let lock = Value(lockRes)
    let verifyLockRes = cworld.v3CompilerWorldVerifyLock(plan.localUniverse, lock)
    assert(IsOk(verifyLockRes), "v3 compiler world manifest closure: verify lock")
    let frozenWorkspaceRoot = v3path.V3PathJoin(workspaceRoot, "artifacts/compiler_world_manifest_closure/frozen_root")
    let frozenPackageRoot = v3path.V3PathJoin(frozenWorkspaceRoot, "v3")
    let frozenSourcePath = v3path.V3PathJoin(frozenPackageRoot, "src/tests/program_selfhost_smoke.cheng")
    let frozenOutputPath = v3path.V3PathJoin(workspaceRoot, "artifacts/compiler_world_manifest_closure/program_selfhost_smoke.frozen")
    let frozenStdRoot = v3path.V3PathJoin(frozenWorkspaceRoot, "src")
    assert(os.ExecCmdStatus("rm -rf " + os.QuoteShell(frozenWorkspaceRoot), "") == 0,
           "v3 compiler world manifest closure: clear frozen root")
    assert(v3path.V3MkdirP(workspaceRoot, frozenWorkspaceRoot),
           "v3 compiler world manifest closure: mkdir frozen root")
    assert(os.ExecCmdStatus("cp -R " + os.QuoteShell(packageRoot) + " " + os.QuoteShell(frozenWorkspaceRoot), "") == 0,
           "v3 compiler world manifest closure: copy frozen root")
    assert(os.ExecCmdStatus("cp -R " + os.QuoteShell(v3path.V3PathJoin(workspaceRoot, "src")) + " " +
                            os.QuoteShell(frozenWorkspaceRoot), "") == 0,
           "v3 compiler world manifest closure: copy frozen shared src")
    assert(v3path.V3PathDirExists(frozenStdRoot),
           "v3 compiler world manifest closure: frozen shared src exists")
    let frozenReq = creq.v3CompilerRequestNew(
        frozenPackageRoot,
        frozenSourcePath,
        frozenOutputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    let frozenPlanRes = sexec.v3BuildSystemLinkExecPlan(workspaceRoot, frozenReq)
    assert(IsOk(frozenPlanRes), "v3 compiler world manifest closure: build frozen plan")
    let frozenPlan = Value(frozenPlanRes)
    assert(layout.fixedBytes32Equal(frozenPlan.sourceBundleCid, plan.sourceBundleCid),
           "v3 compiler world manifest closure: source bundle stable across roots")
    assert(layout.fixedBytes32Equal(frozenPlan.localUniverse.manifest.manifestCid, plan.localUniverse.manifest.manifestCid),
           "v3 compiler world manifest closure: manifest stable across roots")
    assert(layout.fixedBytes32Equal(frozenPlan.localUniverse.worldHead.headCid, plan.localUniverse.worldHead.headCid),
           "v3 compiler world manifest closure: world head stable across roots")
    let pinnedNoLockRes = sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(workspaceRoot,
                                                                             req,
                                                                             layout.fixedBytes32Hex(plan.localUniverse.worldHead.headCid),
                                                                             "",
                                                                             "",
                                                                             "stable")
    assert(IsErr(pinnedNoLockRes),
           "v3 compiler world manifest closure: pinned world requires lock")
    let zeroHex = layout.fixedBytes32Hex(layout.FixedBytes32())
    let wrongManifestHex = layout.fixedBytes32Hex(cworld.v3CompilerWorldHashText("wrong_manifest", [outputPath]))
    let wrongManifestText = compilerWorldReplaceTomlQuotedLine(lockText,
                                                               "manifest_root_cid",
                                                               "\"" + wrongManifestHex + "\"")
    let wrongManifestRes = cworld.v3CompilerLockSnapshotFromText(wrongManifestText,
                                                                 outputPath + ".wrong_manifest.lock.toml")
    assert(IsOk(wrongManifestRes), "v3 compiler world manifest closure: parse wrong manifest lock")
    assert(IsErr(cworld.v3CompilerWorldVerifyLock(plan.localUniverse, Value(wrongManifestRes))),
           "v3 compiler world manifest closure: reject wrong manifest")
    let wrongChannelText = compilerWorldReplaceTomlQuotedLine(lockText, "channel", "\"edge\"")
    let wrongChannelRes = cworld.v3CompilerLockSnapshotFromText(wrongChannelText,
                                                                outputPath + ".wrong_channel.lock.toml")
    assert(IsOk(wrongChannelRes), "v3 compiler world manifest closure: parse wrong channel lock")
    assert(IsErr(cworld.v3CompilerWorldVerifyLock(plan.localUniverse, Value(wrongChannelRes))),
           "v3 compiler world manifest closure: reject wrong channel")
    let wrongSnapshotText = compilerWorldReplaceTomlQuotedLine(lockText,
                                                               "entry[0].snapshot_cid",
                                                               "\"" + zeroHex + "\"")
    let wrongSnapshotRes = cworld.v3CompilerLockSnapshotFromText(wrongSnapshotText,
                                                                 outputPath + ".wrong_snapshot.lock.toml")
    assert(IsOk(wrongSnapshotRes), "v3 compiler world manifest closure: parse wrong snapshot lock")
    assert(IsErr(cworld.v3CompilerWorldVerifyLock(plan.localUniverse, Value(wrongSnapshotRes))),
           "v3 compiler world manifest closure: reject wrong snapshot")
    let wrongProofHex = layout.fixedBytes32Hex(cworld.v3CompilerWorldHashText("wrong_lock_proof",
                                                                              [outputPath]))
    let wrongProofText = compilerWorldReplaceTomlQuotedLine(lockText,
                                                            "entry[0].migration_proof_cid",
                                                            "\"" + wrongProofHex + "\"")
    let wrongProofRes = cworld.v3CompilerLockSnapshotFromText(wrongProofText,
                                                              outputPath + ".wrong_proof.lock.toml")
    assert(IsOk(wrongProofRes), "v3 compiler world manifest closure: parse wrong proof lock")
    assert(IsErr(cworld.v3CompilerWorldVerifyLock(plan.localUniverse, Value(wrongProofRes))),
           "v3 compiler world manifest closure: reject wrong proof")
    echo("v3 compiler_world_manifest_closure_smoke ok")
    return 0
