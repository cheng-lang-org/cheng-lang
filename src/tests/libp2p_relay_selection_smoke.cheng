import std/system
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/discovery/kad
import cheng/libp2p/host/host
import cheng/libp2p/protocols/relay_plane
import std/strutils as strutil

fn main(): int32 =
    let now = int64(1776297600)
    var selector = host.Libp2pHostInit("relay.selection")

    let heavyPeer = peer_id.Libp2pPeerIdFromSeed("relay.selection.heavy")
    let lightPeer = peer_id.Libp2pPeerIdFromSeed("relay.selection.light")
    let badPeer = peer_id.Libp2pPeerIdFromSeed("relay.selection.bad")

    var heavyRecord: ps.Libp2pPeerRecord
    heavyRecord.peerId = heavyPeer
    heavyRecord.connected = true
    var heavyDescriptor: types.Libp2pRelayDescriptor
    heavyDescriptor.peerId = heavyPeer
    heavyDescriptor.serviceKind = types.Libp2pRelayServiceTurn
    heavyDescriptor.region = "sfo"
    heavyDescriptor.endpointText = "turn:heavy.example:3478"
    heavyDescriptor.requiresLease = true
    heavyDescriptor.advertisedAtEpochSeconds = now - int64(5)
    heavyDescriptor.ttlSeconds = 60
    heavyDescriptor.health.healthy = true
    heavyDescriptor.health.sampledAtEpochSeconds = now
    heavyDescriptor.health.successPermille = 950
    heavyDescriptor.health.loadPermille = 90
    heavyDescriptor.health.capacityPermille = 910
    ps.Libp2pPeerRecordPutRelayDescriptor(heavyRecord, heavyDescriptor)
    heavyRecord.relayEntries[0].successCount = 95
    heavyRecord.relayEntries[0].failureCount = 5
    ps.Libp2pPeerstoreUpsert(selector.peers, heavyRecord)

    var lightRecord: ps.Libp2pPeerRecord
    lightRecord.peerId = lightPeer
    lightRecord.connected = true
    var lightDescriptor: types.Libp2pRelayDescriptor
    lightDescriptor.peerId = lightPeer
    lightDescriptor.serviceKind = types.Libp2pRelayServiceTurn
    lightDescriptor.region = "sfo"
    lightDescriptor.endpointText = "turn:light.example:3478"
    lightDescriptor.requiresLease = true
    lightDescriptor.advertisedAtEpochSeconds = now - int64(5)
    lightDescriptor.ttlSeconds = 60
    lightDescriptor.health.healthy = true
    lightDescriptor.health.sampledAtEpochSeconds = now
    lightDescriptor.health.successPermille = 300
    lightDescriptor.health.loadPermille = 620
    lightDescriptor.health.capacityPermille = 360
    ps.Libp2pPeerRecordPutRelayDescriptor(lightRecord, lightDescriptor)
    lightRecord.relayEntries[0].successCount = 3
    lightRecord.relayEntries[0].failureCount = 7
    ps.Libp2pPeerstoreUpsert(selector.peers, lightRecord)

    var badRecord: ps.Libp2pPeerRecord
    badRecord.peerId = badPeer
    badRecord.connected = true
    var badDescriptor: types.Libp2pRelayDescriptor
    badDescriptor.peerId = badPeer
    badDescriptor.serviceKind = types.Libp2pRelayServiceTurn
    badDescriptor.region = "sfo"
    badDescriptor.endpointText = "turn:bad.example:3478"
    badDescriptor.requiresLease = true
    badDescriptor.advertisedAtEpochSeconds = now - int64(5)
    badDescriptor.ttlSeconds = 60
    badDescriptor.health.healthy = false
    badDescriptor.health.sampledAtEpochSeconds = now
    badDescriptor.health.successPermille = 0
    badDescriptor.health.loadPermille = 1000
    badDescriptor.health.capacityPermille = 0
    badDescriptor.health.failureCooldownUntilEpochSeconds = now + int64(60)
    ps.Libp2pPeerRecordPutRelayDescriptor(badRecord, badDescriptor)
    badRecord.relayEntries[0].failureCooldownUntilEpochSeconds = now + int64(60)
    ps.Libp2pPeerstoreUpsert(selector.peers, badRecord)

    kad.Libp2pKadStateProvide(selector.kadState,
                                relay_plane.Libp2pRelayKeyCid(types.Libp2pRelayServiceTurn, "sfo"),
                                heavyPeer)
    kad.Libp2pKadStateProvide(selector.kadState,
                                relay_plane.Libp2pRelayKeyCid(types.Libp2pRelayServiceTurn, "sfo"),
                                lightPeer)
    kad.Libp2pKadStateProvide(selector.kadState,
                                relay_plane.Libp2pRelayKeyCid(types.Libp2pRelayServiceTurn, "sfo"),
                                badPeer)

    var heavyWins = 0
    var lightWins = 0
    for i in 0..<128:
        var picks: host.Libp2pRelayCandidate[]
        let pickRes = host.Libp2pSelectRelayCandidatesWithEntropy(selector,
                                                                    types.Libp2pRelayServiceTurn,
                                                                    "sfo",
                                                                    1,
                                                                    strutil.Join(["relay-selection-", IntToStr(i)], ""),
                                                                    now,
                                                                    picks)
        assert(IsOk(pickRes), " libp2p relay selection: pick ok")
        assert(picks.len == 1, " libp2p relay selection: single pick")
        assert(!types.Libp2pPeerIdEqual(picks[0].peerId, badPeer),
            " libp2p relay selection: bad peer excluded")
        if types.Libp2pPeerIdEqual(picks[0].peerId, heavyPeer):
            heavyWins = heavyWins + 1
        elif types.Libp2pPeerIdEqual(picks[0].peerId, lightPeer):
            lightWins = lightWins + 1
    assert(heavyWins > lightWins, " libp2p relay selection: heavy peer wins more often")

    echo(" libp2p_relay_selection_smoke ok")
    return 0
