import std/system
import cheng/std/bytes_layout as layout

fn main(): int32 =
    var buf = layout.ByteBufInit(16)
    assert(layout.ByteBufLen(buf) == 0, " bytebuf basic: init len")
    layout.ByteBufAppendByte(buf, 1)
    assert(layout.ByteBufLen(buf) == 1, " bytebuf basic: append len")
    echo(" bytebuf_basic_smoke ok")
    return 0
