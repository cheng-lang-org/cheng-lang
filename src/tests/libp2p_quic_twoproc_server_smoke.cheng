import std/system
import std/cmdline as cmdline
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/host/host
import cheng/libp2p/transports/quic_transport
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net

fn main(): int32 =
    let port = cmdline.ReadInt32FlagOrDefault("--port", 0)
    let ready_path_value = cmdline.ReadFlagOrDefault("--ready-path", "")
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "quic.twoproc.server", "quic.twoproc")),
           " chain_node: init")
    var serverHost = host.Libp2pHostInit("quic.twoproc.server")
    let mintRes = node.ChainNodeMint(server, 9, 1001, int64(88))
    assert(mintRes.ok, " libp2p quic twoproc: server mint")
    let transferRes = node.ChainNodeTransfer(server, 9, 1001, 2002, int64(33))
    assert(transferRes.ok, " libp2p quic twoproc: server transfer")
    let serveRes = net.ChainNodeLibp2pServeOnce(server, serverHost)
    assert(serveRes.ok, " libp2p quic twoproc: server serve once")
    var latest: overlay.IngressEnvelope
    let latestRes = net.ChainNodeLibp2pLatestSnapshotInto(serverHost,
                                                            server.address,
                                                            latest)
    assert(latestRes.ok, " libp2p quic twoproc: server latest snapshot")
    let quicServeRes = quic_transport.Libp2pQuicServePayloadOnce("127.0.0.1",
                                                                   port,
                                                                   types.Libp2pProtocolSync,
                                                                   latest.payload,
                                                                   ready_path_value)
    assert(quicServeRes.ok, " libp2p quic twoproc: server quic serve")
    echo(" libp2p_quic_twoproc_server ok")
    return 0
