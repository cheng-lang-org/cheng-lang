import std/system
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/multistream

fn main(): int32 =
    var peerA: types.Libp2pPeerId
    peer_id.Libp2pPeerIdFillFromSeed(peerA, "alice")
    var peerB: types.Libp2pPeerId
    peer_id.Libp2pPeerIdFillFromSeed(peerB, "bob")
    assert(!types.Libp2pPeerIdEqual(peerA, peerB), " libp2p core: peer ids distinct")
    assert(peer_id.Libp2pPeerIdDistance(peerA, peerB) > int64(0),
        " libp2p core: xor distance")

    var tcpAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(tcpAddr, "127.0.0.1", 4101)
    assert(tcpAddr.transport == types.Libp2pTransportTcp, " libp2p core: tcp transport")
    assert(tcpAddr.secure == types.Libp2pSecureNoise, " libp2p core: tcp noise")
    assert(tcpAddr.mux == types.Libp2pMuxYamux, " libp2p core: tcp yamux")

    var quicAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(quicAddr, "127.0.0.1", 4201)
    assert(quicAddr.transport == types.Libp2pTransportQuic, " libp2p core: quic transport")
    assert(quicAddr.secure == types.Libp2pSecureTls, " libp2p core: quic tls")
    assert(quicAddr.mux == types.Libp2pMuxNone, " libp2p core: quic native streams")

    let header = multistream.Libp2pMultistreamHeaderText()
    assert(header == "/multistream/1.0.0\n", " libp2p core: multistream header")
    let select = multistream.Libp2pMultistreamSelectBytes(types.Libp2pProtocolIdentify)
    assert(multistream.Libp2pMultistreamAccepts(select, types.Libp2pProtocolIdentify),
        " libp2p core: multistream accept")

    echo(" libp2p_core_smoke ok")
    return 0
