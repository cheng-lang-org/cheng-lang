fn assertPreviewSummary(summary: preview.PreviewSummary) =
    assert(summary.sceneNonEmpty,
           "wow_export_northshire_mvp_smoke preview scene non empty")
    assert(summary.auditedFileCount == 22,
           "wow_export_northshire_mvp_smoke preview audited files")
    assert(summary.auditedDependencyCount == 45,
           "wow_export_northshire_mvp_smoke preview audited dependencies")
    assert(summary.wdtMaidParsedDependencyCount == 28,
           "wow_export_northshire_mvp_smoke preview maid parsed dependencies")
    assert(summary.wdtMaidAdtSplitResourceCount == 16,
           "wow_export_northshire_mvp_smoke preview maid adt split resources")
    assert(summary.wdtMaidBlpResourceCount == 12,
           "wow_export_northshire_mvp_smoke preview maid blp resources")
    assert(summary.wdtMaidDoodadPlacementCount == 4345,
           "wow_export_northshire_mvp_smoke preview doodad placements")
    assert(summary.wdtMaidDoodadReferencedFileDataIDCount == 222,
           "wow_export_northshire_mvp_smoke preview doodad fileDataIDs")
    assert(summary.wdtMaidDoodadPlacementDependencyCount == 222,
           "wow_export_northshire_mvp_smoke preview doodad placement dependencies")
    assert(summary.wdtMaidDoodadM2AssetCount == 222,
           "wow_export_northshire_mvp_smoke preview doodad m2 assets")
    assert(summary.wdtMaidWorldModelPlacementCount == 32,
           "wow_export_northshire_mvp_smoke preview world model placements")
    assert(summary.wdtMaidWorldModelReferencedFileDataIDCount == 18,
           "wow_export_northshire_mvp_smoke preview world model fileDataIDs")
    assert(summary.wdtMaidWorldModelPlacementDependencyCount == 18,
           "wow_export_northshire_mvp_smoke preview world model placement dependencies")
    assert(summary.wdtMaidWorldModelWmoAssetCount == 18,
           "wow_export_northshire_mvp_smoke preview world model wmo assets")
    assert(summary.wdtMaidPlacementDependencyAuditReady,
           "wow_export_northshire_mvp_smoke preview placement dependency audit")
    assert(summary.wdtMaidPlacementDependencyEncodedBytes == 1299207,
           "wow_export_northshire_mvp_smoke preview placement encoded bytes")
    assert(summary.wdtMaidPlacementDependencyDecodedBytes == 3221104,
           "wow_export_northshire_mvp_smoke preview placement decoded bytes")
    assert(summary.wdtMaidDependencyBytes == 8023142,
           "wow_export_northshire_mvp_smoke preview maid dependency bytes")
    assert(summary.memoryOutstanding == 0,
           "wow_export_northshire_mvp_smoke preview memory")
    let text: str = preview.PreviewSummaryText(summary)
    assert(strings.StrContains(text, "wdtMaidDoodadM2Assets=222"),
           "wow_export_northshire_mvp_smoke preview text doodad m2 assets")
    assert(strings.StrContains(text, "wdtMaidWorldModelWmoAssets=18"),
           "wow_export_northshire_mvp_smoke preview text world model wmo assets")
    assert(strings.StrContains(text, "wdtMaidPlacementDependencyDecodedBytes=3221104"),
           "wow_export_northshire_mvp_smoke preview text decoded bytes")

fn main(): int32 =
    let buildRes: Result[build_info.WowBuildEntry] = build_info.ProbeRetailDefault()
    assert(IsOk(buildRes), Error(buildRes))

    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    assertManifest(manifest)
    assertManifestAudits(manifest)

    let previewRes: Result[preview.PreviewSummary] = preview.PreviewNorthshire(1)
    assert(IsOk(previewRes), Error(previewRes))
    assertPreviewSummary(Value(previewRes))

    let outPath: str = "/tmp/wow_export_northshire_mvp_smoke.tga"
    removeIfExists(outPath)
    let renderRes: Result[render.RenderSummary] =
        render.RenderNorthshireTga(outPath, 320, 180)
    assert(IsOk(renderRes), Error(renderRes))
    let summary: render.RenderSummary = Value(renderRes)
    assertRenderSummary(summary)
    assert(os.FileExists(outPath), "wow_export_northshire_mvp_smoke output exists")
    assert(os.FileSize(outPath) == int64(summary.bytesWritten),
           "wow_export_northshire_mvp_smoke output size")
    removeIfExists(outPath)
    echo("wow_export_northshire_mvp_smoke ok")
    return 0
