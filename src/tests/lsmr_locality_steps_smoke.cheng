import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr
import cheng/chain/lsmr_types as lt

fn makePayloadCid(keyId: int32,
                  baguaId: int32,
                  resolutionLevel: int32,
                  layerId: int32,
                  address: types.LsmrAddress,
                  prefix: lt.PrefixRef,
                  localityHash: layout.FixedBytes32,
                  contentCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.locality_cid"))
    lt.AppendU32BE(buf, keyId)
    lt.AppendU32BE(buf, baguaId)
    lt.AppendU32BE(buf, resolutionLevel)
    lt.AppendU32BE(buf, layerId)
    lt.AppendAddress(buf, address)
    lt.AppendPrefix(buf, prefix)
    lt.AppendFixed32(buf, localityHash)
    lt.AppendFixed32(buf, contentCid)
    return lt.FixedCidFromBuf(buf)

fn main(): int32 =
    var digits: int32[]
    digits = []
    add(digits, 1)
    add(digits, 2)
    add(digits, 3)
    let addressRes = types.LsmrAddressFromDigits(digits)
    assert(IsOk(addressRes), " lsmr locality steps: address")
    let address = Value(addressRes)
    let keyText = IntToStr(7)
    let baguaId = lsmr.LsmrAddressBagua(address, keyText)
    assert(lt.BaguaValid(baguaId), " lsmr locality steps: bagua")
    let prefixRes = lt.PrefixRefFromDigits(baguaId, digits)
    assert(IsOk(prefixRes), " lsmr locality steps: prefix")
    let prefix = Value(prefixRes)
    let zeroCid = layout.FixedBytes32()
    let layerId = lsmr.LsmrStateLayerForResolution(3)
    let localityCid = makePayloadCid(7, baguaId, 3, layerId, address, prefix, zeroCid, zeroCid)
    var locality: lt.LocalityCid
    locality.keyId = 7
    locality.baguaId = baguaId
    locality.resolutionLevel = 3
    locality.layerId = layerId
    locality.address = address
    locality.prefix = prefix
    locality.localityHash = zeroCid
    locality.contentCid = zeroCid
    locality.cid = localityCid
    assert(locality.keyId == 7, " lsmr locality steps: locality key")
    var cell: lt.StateCell
    cell.keyId = 7
    cell.baguaId = baguaId
    cell.resolutionLevel = 3
    cell.layerId = layerId
    cell.address = address
    cell.prefix = prefix
    cell.contentCid = zeroCid
    cell.localityHash = zeroCid
    cell.localityCid = localityCid
    assert(cell.keyId == 7, " lsmr locality steps: cell key")
    echo(" lsmr_locality_steps_smoke ok")
    return 0
