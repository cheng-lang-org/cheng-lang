import std/system
import cheng/chain/consensus
import cheng/apps/bft/bft_state_machine as bft

fn main(): int32 =
    var index = consensus.ChainIndex()
    let mint = bft.BftTxMint(7, 1001, int64(100))
    let exec = bft.BftApplyTxToIndex(index, mint, int64(1), 0)
    assert(exec.code == bft.BftCodeOk, " bft apply to index: code")
    assert(exec.accepted, " bft apply to index: accepted")
    assert(exec.applied, " bft apply to index: applied")
    assert(index.eventCids.len == 1, " bft apply to index: event cid len")
    assert(index.accountIds.len == 1, " bft apply to index: account len")
    assert(index.balances[0] == int64(100), " bft apply to index: balance")
    echo(" bft_apply_to_index_smoke ok")
    return 0
