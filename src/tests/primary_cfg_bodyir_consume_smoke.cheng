import cheng/core/backend/primary_object_plan as pobj
import cheng/core/ir/core_types as ir

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn i32Slot(id: int32, offset: int32, name: str): ir.LocalSlot =
    var slot: ir.LocalSlot
    slot.id = id
    slot.name = name
    slot.typeKind = ir.LocalI32Tag
    slot.stackOffset = offset
    slot.sizeBytes = 4
    slot.alignBytes = 4
    slot.noAlias = true
    return slot

fn resultSlot(id: int32, offset: int32): ir.LocalSlot =
    var slot: ir.LocalSlot
    slot.id = id
    slot.name = "res"
    slot.typeKind = ir.LocalAggregateTag
    slot.stackOffset = offset
    slot.sizeBytes = ir.ResultStrSizeBytes
    slot.alignBytes = ir.ResultStrAlignBytes
    slot.noAlias = true
    return slot

fn strSlot(id: int32, offset: int32, name: str): ir.LocalSlot =
    var slot: ir.LocalSlot
    slot.id = id
    slot.name = name
    slot.typeKind = ir.LocalStrTag
    slot.stackOffset = offset
    slot.sizeBytes = 24
    slot.alignBytes = 8
    slot.noAlias = true
    return slot

fn callOp(ordinal: int32, target: int32): ir.BodyOp =
    var op: ir.BodyOp
    op.kind = ir.BodyOpCallTag
    op.target = target
    add(op.operands, ordinal)
    return op

fn loadConstOp(target: int32, value: int32): ir.BodyOp =
    var op: ir.BodyOp
    op.kind = ir.BodyOpLoadConstTag
    op.target = target
    add(op.operands, ir.LocalI32Tag)
    add(op.operands, value)
    return op

fn resultProjectOp(kind: int32, source: int32, target: int32): ir.BodyOp =
    var op: ir.BodyOp
    op.kind = ir.BodyOpResultProjectTag
    op.target = target
    add(op.operands, kind)
    add(op.operands, source)
    return op

fn returnLocalOp(slot: int32): ir.BodyOp =
    var op: ir.BodyOp
    op.kind = ir.BodyOpReturnTag
    op.target = slot
    add(op.operands, ir.LocalI32Tag)
    return op

fn returnConstOp(value: int32): ir.BodyOp =
    var op: ir.BodyOp
    op.kind = ir.BodyOpReturnTag
    op.target = -1
    add(op.operands, pobj.PrimaryStatementReturnModeI32Const())
    add(op.operands, value)
    return op

fn guardReturnConstOp(slot: int32, value: int32): ir.BodyOp =
    var op: ir.BodyOp
    op.kind = ir.BodyOpBranchTag
    op.target = slot
    add(op.operands, ir.BodyBranchIfLocalLeZeroReturnI32ConstTag)
    add(op.operands, slot)
    add(op.operands, value)
    return op

fn copyLocalOp(source: int32, target: int32): ir.BodyOp =
    var op: ir.BodyOp
    op.kind = ir.BodyOpCopyLocalTag
    op.target = target
    add(op.operands, source)
    return op

fn returnConstTerm(value: int32): ir.BodyTerm =
    var term: ir.BodyTerm
    term.kind = ir.BodyTermReturnTag
    term.resultSlot = -1
    add(term.operands, pobj.PrimaryStatementReturnModeI32Const())
    add(term.operands, value)
    return term

fn returnLocalTerm(slot: int32): ir.BodyTerm =
    var term: ir.BodyTerm
    term.kind = ir.BodyTermReturnTag
    term.resultSlot = slot
    add(term.operands, ir.LocalI32Tag)
    return term

fn returnCurrentCallTerm(): ir.BodyTerm =
    var term: ir.BodyTerm
    term.kind = ir.BodyTermReturnTag
    term.resultSlot = -1
    add(term.operands, ir.LocalI32Tag)
    return term

fn brTerm(targetBlock: int32): ir.BodyTerm =
    var term: ir.BodyTerm
    term.kind = ir.BodyTermBrTag
    term.trueBlock = targetBlock
    return term

fn cbrLocalRhsTerm(lhsSlot: int32,
                   rhsSlot: int32,
                   trueBlock: int32,
                   falseBlock: int32): ir.BodyTerm =
    var term: ir.BodyTerm
    term.kind = ir.BodyTermCbrTag
    term.conditionKind = ir.BodyCondI32LeTag
    term.lhsSlot = lhsSlot
    term.resultSlot = lhsSlot
    term.rhsSlot = rhsSlot
    term.trueBlock = trueBlock
    term.falseBlock = falseBlock
    return term

fn checkGeneralCfgEmit(body: ir.BodyIR, code: int32): int32 =
    let wordCount = pobj.PrimaryBodyIrGeneralCfgWordCount(body)
    if wordCount <= 0:
        return code
    var words: int32[]
    var emitted: int32
    pobj.PrimaryObjectPlanEmitBodyIR(body, words, emitted)
    if emitted != wordCount:
        return code + 1
    if words.len != wordCount:
        return code + 2
    for callOrdinal in 0..<body.callSequence.len:
        let relocOffset = pobj.PrimaryBodyIrGeneralCfgRelocWordOffset(body, 0, callOrdinal)
        if relocOffset < 0 || relocOffset >= words.len:
            return code + 3
        if relocOffset != pobj.PrimaryBodyIrRelocWordOffset(body, 0, callOrdinal):
            return code + 4
        if words[relocOffset] != -1811939328:
            return code + 5
    return 0

fn callSequenceReturnLocalBody(): ir.BodyIR =
    var body: ir.BodyIR
    add(body.localSlots, i32Slot(0, 16, "value"))
    var call: ir.CallOp
    call.targetSymbol = "Leaf"
    call.resultSlot = 0
    add(body.callSequence, call)
    add(body.ops, callOp(0, 0))
    add(body.ops, returnLocalOp(0))
    return body

fn callSequenceReturnConstBody(): ir.BodyIR =
    var body: ir.BodyIR
    add(body.localSlots, i32Slot(0, 16, "ignored"))
    var call: ir.CallOp
    call.targetSymbol = "Touch"
    call.resultSlot = 0
    add(body.callSequence, call)
    add(body.ops, callOp(0, 0))
    add(body.ops, returnConstOp(17))
    return body

fn callSequenceGuardReturnBody(): ir.BodyIR =
    var body: ir.BodyIR
    add(body.localSlots, i32Slot(0, 16, "count"))
    add(body.localSlots, i32Slot(1, 32, "finish"))
    var countCall: ir.CallOp
    countCall.targetSymbol = "Count"
    countCall.resultSlot = 0
    add(body.callSequence, countCall)
    var finishCall: ir.CallOp
    finishCall.targetSymbol = "Finish"
    finishCall.resultSlot = 1
    add(body.callSequence, finishCall)
    add(body.ops, callOp(0, 0))
    add(body.ops, guardReturnConstOp(0, 5))
    add(body.ops, callOp(1, 1))
    add(body.ops, returnLocalOp(1))
    return body

fn resultRequestDispatchBody(): ir.BodyIR =
    var body: ir.BodyIR
    add(body.localSlots, i32Slot(0, 16, "dispatch"))
    add(body.localSlots, i32Slot(1, 32, "unsupported"))
    var dispatchCall: ir.CallOp
    dispatchCall.targetSymbol = "Concrete"
    dispatchCall.resultSlot = 0
    add(body.callSequence, dispatchCall)
    var unsupportedCall: ir.CallOp
    unsupportedCall.targetSymbol = "Unsupported"
    unsupportedCall.resultSlot = 1
    add(body.callSequence, unsupportedCall)
    add(body.ops, callOp(0, 0))
    add(body.ops, callOp(1, 1))
    var entryTerm: ir.BodyTerm
    entryTerm.kind = ir.BodyTermCbrTag
    entryTerm.conditionKind = ir.BodyCondLocalZeroTag
    entryTerm.lhsSlot = 0 - 1 - 1
    entryTerm.resultSlot = 0 - 1 - 1
    entryTerm.trueBlock = 2
    entryTerm.falseBlock = 1
    add(entryTerm.operands, 0)
    add(entryTerm.operands, 8)
    add(entryTerm.operands, 208)
    add(body.terms, entryTerm)
    add(body.terms, returnLocalTerm(0))
    add(body.terms, returnLocalTerm(1))
    let _ = ir.BodyIRAppendBlock(body, 0, 0, 0)
    let _ = ir.BodyIRAppendBlock(body, 0, 1, 1)
    let _ = ir.BodyIRAppendBlock(body, 1, 1, 2)
    return body

fn callCfgWithLocalWriteBody(): ir.BodyIR =
    var body: ir.BodyIR
    add(body.localSlots, i32Slot(0, 16, "tmp"))
    add(body.localSlots, i32Slot(1, 32, "value"))
    var call: ir.CallOp
    call.targetSymbol = "Leaf"
    call.resultSlot = 1
    add(body.callSequence, call)
    add(body.ops, loadConstOp(0, 9))
    add(body.ops, callOp(0, 1))
    add(body.terms, returnLocalTerm(1))
    let _ = ir.BodyIRAppendBlock(body, 0, 2, 0)
    return body

fn generalCfgLocalCopyReturnBody(): ir.BodyIR =
    var body: ir.BodyIR
    add(body.localSlots, i32Slot(0, 16, "tmp"))
    add(body.localSlots, i32Slot(1, 32, "value"))
    add(body.localSlots, i32Slot(2, 48, "out"))
    var call: ir.CallOp
    call.targetSymbol = "UseValue"
    call.resultSlot = 2
    add(call.argSlots, 1)
    add(body.callSequence, call)
    add(body.ops, loadConstOp(0, 9))
    add(body.ops, copyLocalOp(0, 1))
    add(body.ops, callOp(0, 2))
    add(body.terms, returnLocalTerm(2))
    let _ = ir.BodyIRAppendBlock(body, 0, 3, 0)
    return body

fn generalCfgReturnConstAfterCallBody(): ir.BodyIR =
    var body: ir.BodyIR
    add(body.localSlots, i32Slot(0, 16, "ignored"))
    var call: ir.CallOp
    call.targetSymbol = "Touch"
    call.resultSlot = 0
    add(body.callSequence, call)
    add(body.ops, callOp(0, 0))
    add(body.terms, returnConstTerm(17))
    let _ = ir.BodyIRAppendBlock(body, 0, 1, 0)
    return body

fn generalCfgReturnCurrentCallBody(): ir.BodyIR =
    var body: ir.BodyIR
    var call: ir.CallOp
    call.targetSymbol = "Leaf"
    call.resultSlot = -1
    add(body.callSequence, call)
    add(body.ops, callOp(0, -1))
    add(body.terms, returnCurrentCallTerm())
    let _ = ir.BodyIRAppendBlock(body, 0, 1, 0)
    return body

fn generalCfgBrReturnBody(): ir.BodyIR =
    var body: ir.BodyIR
    add(body.localSlots, i32Slot(0, 16, "value"))
    add(body.ops, loadConstOp(0, 21))
    add(body.terms, brTerm(1))
    add(body.terms, returnLocalTerm(0))
    let _ = ir.BodyIRAppendBlock(body, 0, 1, 0)
    let _ = ir.BodyIRAppendBlock(body, 1, 0, 1)
    return body

fn generalCfgCbrLocalRhsBody(): ir.BodyIR =
    var body: ir.BodyIR
    add(body.localSlots, i32Slot(0, 16, "lhs"))
    add(body.localSlots, i32Slot(1, 32, "rhs"))
    add(body.localSlots, i32Slot(2, 48, "value"))
    add(body.ops, loadConstOp(0, 2))
    add(body.ops, loadConstOp(1, 5))
    add(body.ops, loadConstOp(2, 44))
    add(body.terms, cbrLocalRhsTerm(0, 1, 1, 2))
    add(body.terms, returnLocalTerm(2))
    add(body.terms, returnConstTerm(8))
    let _ = ir.BodyIRAppendBlock(body, 0, 3, 0)
    let _ = ir.BodyIRAppendBlock(body, 3, 0, 1)
    let _ = ir.BodyIRAppendBlock(body, 3, 0, 2)
    return body

fn strLetCallThenReturnCallCfgBody(): ir.BodyIR =
    var body: ir.BodyIR
    add(body.localSlots, strSlot(0, 16, "cmd"))
    add(body.localSlots, i32Slot(1, 48, "rc"))

    var paramCall: ir.CallOp
    paramCall.targetSymbol = "ParamStr"
    paramCall.resultSlot = 0
    add(paramCall.argSlots, ir.CallArgSlotConstTrue())
    add(body.callSequence, paramCall)

    var dispatchCall: ir.CallOp
    dispatchCall.targetSymbol = "Dispatch"
    dispatchCall.resultSlot = 1
    add(dispatchCall.argSlots, 0)
    add(body.callSequence, dispatchCall)

    add(body.ops, callOp(0, 0))
    add(body.ops, callOp(1, 1))
    add(body.terms, returnLocalTerm(1))
    let _ = ir.BodyIRAppendBlock(body, 0, 2, 0)
    return body

fn main(): int32 =
    var body: ir.BodyIR
    add(body.localSlots, resultSlot(0, 16))
    add(body.localSlots, i32Slot(1, 80, "isErr"))
    add(body.localSlots, i32Slot(2, 96, "value"))
    add(body.localSlots, strSlot(3, 112, "errText"))
    add(body.localSlots, strSlot(4, 144, "valueText"))

    var firstCall: ir.CallOp
    firstCall.targetSymbol = "MakeResult"
    firstCall.resultSlot = 0
    add(body.callSequence, firstCall)
    var secondCall: ir.CallOp
    secondCall.targetSymbol = "Finish"
    secondCall.resultSlot = 2
    add(body.callSequence, secondCall)

    add(body.ops, callOp(0, 0))
    let isErrProject = resultProjectOp(ir.BodyResultProjectIsErrTag, 0, 1)
    let errorProject = resultProjectOp(ir.BodyResultProjectErrorStrTag, 0, 3)
    let valueProject = resultProjectOp(ir.BodyResultProjectValueStrTag, 0, 4)
    add(body.ops, isErrProject)
    add(body.ops, errorProject)
    add(body.ops, valueProject)
    add(body.ops, callOp(1, 2))

    var entry: ir.BodyTerm
    entry.kind = ir.BodyTermCbrTag
    entry.conditionKind = ir.BodyCondLocalNonZeroTag
    entry.lhsSlot = 1
    entry.resultSlot = 1
    entry.trueBlock = 1
    entry.falseBlock = 2
    add(body.terms, entry)
    add(body.terms, returnConstTerm(9))
    add(body.terms, returnLocalTerm(2))
    let _ = ir.BodyIRAppendBlock(body, 0, 4, 0)
    let _ = ir.BodyIRAppendBlock(body, 4, 0, 1)
    let _ = ir.BodyIRAppendBlock(body, 4, 1, 2)

    let c1 = check(pobj.PrimaryBodyIrProjectOpSupported(body, isErrProject), 11)
    if c1 != 0: return c1
    let c1b = check(pobj.PrimaryBodyIrProjectOpSupported(body, errorProject), 19)
    if c1b != 0: return c1b
    let c1c = check(pobj.PrimaryBodyIrProjectOpSupported(body, valueProject), 20)
    if c1c != 0: return c1c
    let c2 = check(pobj.PrimaryBodyIrIsCallCfgReturnInt32(body), 12)
    if c2 != 0: return c2
    let c3 = check(pobj.PrimaryBodyIrWordCount(body) > 0, 13)
    if c3 != 0: return c3
    let c3b = checkGeneralCfgEmit(body, 70)
    if c3b != 0: return c3b
    let c4 = check(pobj.PrimaryBodyCondArm64TrueCode(ir.BodyCondI32LeTag) == 13, 14)
    if c4 != 0: return c4

    let localBody = callSequenceReturnLocalBody()
    let c9 = check(pobj.PrimaryBodyIrIsCallSequenceReturnInt32(localBody), 21)
    if c9 != 0: return c9
    let c10 = check(pobj.PrimaryBodyIrIsCallSequenceReturnSupported(localBody), 22)
    if c10 != 0: return c10
    let constBody = callSequenceReturnConstBody()
    let c11 = check(pobj.PrimaryBodyIrIsCallSequenceReturnI32Const(constBody), 23)
    if c11 != 0: return c11
    let c12 = check(pobj.PrimaryBodyIrIsCallSequenceReturnSupported(constBody), 24)
    if c12 != 0: return c12
    let guardBody = callSequenceGuardReturnBody()
    let c13 = check(pobj.PrimaryBodyIrIsCallSequenceGuardReturnInt32(guardBody), 25)
    if c13 != 0: return c13
    let c14 = check(pobj.PrimaryBodyIrIsCallSequenceReturnSupported(guardBody), 26)
    if c14 != 0: return c14
    let resultDispatchBody = resultRequestDispatchBody()
    let c15 = check(pobj.PrimaryBodyIrIsResultRequestDispatch(resultDispatchBody), 27)
    if c15 != 0: return c15
    let localWriteBody = callCfgWithLocalWriteBody()
    let c16 = check(pobj.PrimaryBodyIrIsCallCfgReturnInt32(localWriteBody), 28)
    if c16 != 0: return c16
    let c17 = check(pobj.PrimaryBodyIrCallCfgReturnInt32WordCount(localWriteBody) > 0, 29)
    if c17 != 0: return c17
    let c18 = check(pobj.PrimaryBodyIrRelocWordOffset(localWriteBody, 0, 0) > 0, 30)
    if c18 != 0: return c18
    let generalLocalBody = generalCfgLocalCopyReturnBody()
    let c18f = checkGeneralCfgEmit(generalLocalBody, 41)
    if c18f != 0: return c18f
    let generalConstBody = generalCfgReturnConstAfterCallBody()
    let c18g = checkGeneralCfgEmit(generalConstBody, 50)
    if c18g != 0: return c18g
    let generalReturnCallBody = generalCfgReturnCurrentCallBody()
    let c18h = checkGeneralCfgEmit(generalReturnCallBody, 60)
    if c18h != 0: return c18h
    let generalBrBody = generalCfgBrReturnBody()
    let c18i = checkGeneralCfgEmit(generalBrBody, 90)
    if c18i != 0: return c18i
    let generalCbrLocalRhsBody = generalCfgCbrLocalRhsBody()
    let c18j = checkGeneralCfgEmit(generalCbrLocalRhsBody, 100)
    if c18j != 0: return c18j
    let strLetBody = strLetCallThenReturnCallCfgBody()
    let c18a = check(pobj.PrimaryBodyIrIsCallCfgReturnInt32(strLetBody), 36)
    if c18a != 0: return c18a
    let c18b = check(pobj.PrimaryBodyIrWordCount(strLetBody) > 0, 37)
    if c18b != 0: return c18b
    let c18c = check(pobj.PrimaryBodyIrRequiresCallSequence(strLetBody), 38)
    if c18c != 0: return c18c
    let c18d = check(pobj.PrimaryBodyIrRelocWordOffset(strLetBody, 0, 0) > 0, 39)
    if c18d != 0: return c18d
    let c18e = check(pobj.PrimaryBodyIrRelocWordOffset(strLetBody, 0, 1) >
                     pobj.PrimaryBodyIrRelocWordOffset(strLetBody, 0, 0), 40)
    if c18e != 0: return c18e
    let c18k = checkGeneralCfgEmit(strLetBody, 80)
    if c18k != 0: return c18k
    var strEqBody: ir.BodyIR
    add(strEqBody.localSlots, i32Slot(0, 16, "isMatch"))
    var strEqOp: ir.BodyOp
    strEqOp.kind = ir.BodyOpStrEqLiteralTag
    strEqOp.target = 0
    add(strEqBody.ops, strEqOp)
    let c19 = check(pobj.PrimaryBodyIrHasSemanticSurface(strEqBody), 31)
    if c19 != 0: return c19
    let strEqMissing = pobj.PrimaryBodyIrMissingKind(strEqBody, "fallback")
    let c20 = check(strEqMissing == "body_ir_str_eq_literal_ops_1_calls_0_returns_0_locals_1", 32)
    if c20 != 0: return c20
    var cstringBody: ir.BodyIR
    let _ = ir.BodyIRAppendCStringLiteral(cstringBody, "ok", "L_ok")
    let c21 = check(pobj.PrimaryBodyIrHasSemanticSurface(cstringBody), 33)
    if c21 != 0: return c21
    let c22 = check(pobj.PrimaryBodyIrMissingKind(cstringBody, "fallback") == "body_ir_cstring_literals_unconsumed", 34)
    if c22 != 0: return c22
    let c23 = check(pobj.PrimaryBodyOpKindText(ir.BodyOpStrEqLiteralTag) == "str_eq_literal", 35)
    if c23 != 0: return c23
    return 0
