import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_surface_main as r2csurface

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = chengpath.PathAbsolute(root, "artifacts/r2c_publish_selector_smoke")
    assert(chengpath.MkdirP(root, outDir), " r2c publish selector smoke: mkdir")
    let driver = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    let stage3 = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3")
    let bundleScript = chengpath.PathAbsolute(root, "tools/r2c/experimental/r2c-react-native-gui-bundle.mjs")
    assert(chengpath.FileExistsNonEmpty(root, driver), " r2c publish selector smoke: backend_driver exists")
    assert(chengpath.FileExistsNonEmpty(root, stage3), " r2c publish selector smoke: stage3 exists")
    assert(chengpath.FileExistsNonEmpty(root, bundleScript), " r2c publish selector smoke: bundle script exists")
    let readyEnv = ["CHENG_BACKEND_DRIVER_READY=1"]
    var nativeEnv: str[]
    add(nativeEnv, "R2C_REACT_TOOLING_BIN=" + stage3)
    add(nativeEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    let repoEnv = os.GetEnv("R2C_REACT_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.DirExists(repo), " r2c publish selector smoke: React.js repo exists")

    let codegenOutDir = chengpath.PathJoin(outDir, "codegen_surface")
    let codegenLog = chengpath.PathJoin(outDir, "r2c_codegen_surface.log")
    if chengpath.PathFileExists(codegenLog):
        os.RemoveFile(codegenLog)
    let codegenRun = hostops.RunFileLogged(root,
                                             "r2c_codegen_surface_publish_selector_smoke",
                                             driver,
                                             ["r2c-react-codegen-surface-smoke",
                                              "--repo", repo,
                                              "--out-dir", codegenOutDir],
                                             readyEnv,
                                             root,
                                             0,
                                             codegenLog)
    assert(hostops.LoggedRunOk(codegenRun), " r2c publish selector smoke: codegen surface rc")
    assert(chengpath.PathFileExists(codegenLog), " r2c publish selector smoke: codegen surface log")
    assert(chengpath.TextContains(codegenRun.output, "r2c-react codegen surface smoke: ok"),
           " r2c publish selector smoke: codegen surface ok")
    let codegenManifestPath = os.JoinPath(codegenOutDir, "cheng_codegen_v1.json")
    let codegenRouteCatalogPath = os.JoinPath(codegenOutDir, "cheng_codegen_route_catalog_v1.json")
    let codegenTsxAstPath = os.JoinPath(codegenOutDir, "tsx_ast_v1.json")
    assert(chengpath.FileExistsNonEmpty(root, codegenManifestPath),
           " r2c publish selector smoke: codegen manifest")
    assert(chengpath.FileExistsNonEmpty(root, codegenRouteCatalogPath),
           " r2c publish selector smoke: codegen route catalog")
    assert(chengpath.FileExistsNonEmpty(root, codegenTsxAstPath),
           " r2c publish selector smoke: codegen tsx ast")

    let bundleOutDir = chengpath.PathJoin(outDir, "native_gui_bundle_publish_selector")
    let bundleLog = chengpath.PathJoin(outDir, "r2c_native_gui_bundle_publish_selector.log")
    if chengpath.PathFileExists(bundleLog):
        os.RemoveFile(bundleLog)
    assert(chengpath.MkdirP(root, bundleOutDir), " r2c publish selector smoke: bundle mkdir")
    let staticSummaryPath = os.JoinPath(bundleOutDir, "static_surface.summary.env")
    let bundleHostContractPath = os.JoinPath(bundleOutDir, "unimaker_host_v1.json")
    let bundleAssetManifestPath = os.JoinPath(bundleOutDir, "asset_manifest_v1.json")
    let bundleTailwindManifestPath = os.JoinPath(bundleOutDir, "tailwind_style_manifest_v1.json")
    var staticAssetRoots: str[]
    var staticSurface: r2csurface.R2cStaticSurfaceRunResult
    assert(r2csurface.r2cRunStaticSurface(repo, bundleOutDir, codegenTsxAstPath, staticSummaryPath, staticAssetRoots, staticSurface),
           " r2c publish selector smoke: static surface rc")
    assert(chengpath.FileExistsNonEmpty(root, staticSummaryPath),
           " r2c publish selector smoke: static surface summary")
    assert(chengpath.FileExistsNonEmpty(root, bundleHostContractPath),
           " r2c publish selector smoke: bundle host contract")
    assert(chengpath.FileExistsNonEmpty(root, bundleAssetManifestPath),
           " r2c publish selector smoke: bundle asset manifest")
    assert(chengpath.FileExistsNonEmpty(root, bundleTailwindManifestPath),
           " r2c publish selector smoke: bundle tailwind manifest")

    let bundleSummaryPath = os.JoinPath(bundleOutDir, "native_gui_bundle.summary.env")
    let bundleRun = hostops.RunProgramLogged(root,
                                               "r2c_native_gui_bundle_publish_selector_smoke",
                                               "node",
                                               [bundleScript,
                                                "--repo", repo,
                                                "--route-state", "publish_selector",
                                                "--out-dir", bundleOutDir,
                                                "--codegen-manifest", codegenManifestPath,
                                                "--host-contract", bundleHostContractPath,
                                                "--asset-manifest", bundleAssetManifestPath,
                                                "--tailwind-manifest", bundleTailwindManifestPath,
                                                "--route-catalog", codegenRouteCatalogPath,
                                                "--tsx-ast", codegenTsxAstPath,
                                                "--summary-out", bundleSummaryPath],
                                               nativeEnv,
                                               root,
                                               0,
                                               bundleLog)
    assert(hostops.LoggedRunOk(bundleRun), " r2c publish selector smoke: bundle rc")
    assert(chengpath.PathFileExists(bundleLog), " r2c publish selector smoke: bundle log")
    assert(chengpath.TextContains(bundleRun.output, "\"ok\": true"),
           " r2c publish selector smoke: bundle ok")
    let bundleReportPath = os.JoinPath(bundleOutDir, "native_gui_bundle_report_v1.json")
    let bundleJsonPath = os.JoinPath(bundleOutDir, "native_gui_bundle_v1.json")
    let bundleSessionPath = os.JoinPath(bundleOutDir, "native_gui_session_v1.json")
    assert(chengpath.FileExistsNonEmpty(root, bundleReportPath),
           " r2c publish selector smoke: bundle report")
    assert(chengpath.FileExistsNonEmpty(root, bundleSummaryPath),
           " r2c publish selector smoke: bundle summary")
    assert(chengpath.FileExistsNonEmpty(root, bundleJsonPath),
           " r2c publish selector smoke: bundle json")
    assert(chengpath.FileExistsNonEmpty(root, bundleSessionPath),
           " r2c publish selector smoke: session json")
    let bundleSummaryText = chengpath.ReadTextFile("", bundleSummaryPath)
    assert(chengpath.TextContains(bundleSummaryText, "native_gui_route_state=publish_selector"),
           " r2c publish selector smoke: route state")
    assert(chengpath.TextContains(bundleSummaryText, "native_gui_runtime_bundle_ready=true"),
           " r2c publish selector smoke: runtime bundle ready")
    assert(chengpath.TextContains(bundleSummaryText, "native_gui_runtime_contract_ready=true"),
           " r2c publish selector smoke: runtime contract ready")
    assert(chengpath.TextContains(bundleSummaryText, "native_gui_runtime_bundle_route_state=publish_selector"),
           " r2c publish selector smoke: runtime bundle route state")
    assert(chengpath.TextContains(bundleSummaryText, "native_gui_runtime_bundle_supported_count="),
           " r2c publish selector smoke: runtime bundle supported count")

    echo(" r2c_react_publish_selector_bundle_smoke ok")
    return 0
