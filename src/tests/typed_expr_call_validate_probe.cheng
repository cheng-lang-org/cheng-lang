import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/lang/parser
import cheng/core/lang/typed_expr as texpr
import std/strutils as strutil

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let fixturePath = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let outputPath = chengpath.PathJoin(workspaceRoot, "artifacts/compiler_csg/typed_expr_call_validate_probe")
    let req = creq.CompilerRequestNew(packageRoot, fixturePath, outputPath, "arm64-apple-darwin", creq.EmitShared, "")
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), "typed expr call validate probe: link plan")
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    assert(IsOk(sourceBundleRes), "typed expr call validate probe: source bundle")
    let sourceBundleCid = Value(sourceBundleRes)
    let csgRes = ccsg.BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(csgRes), "typed expr call validate probe: build csg")
    let csg = ccsg.CompilerCsgClone(Value(csgRes))
    var callErr = ""
    let ok = texpr.TypedExprFactsValidateCallResolution(csg.exprLayer, csg.typedExprFacts, callErr)
    echo(strutil.Join(["validate_ok=", (if ok: "1" else: "0")], ""))
    echo(strutil.Join(["validate_err=", callErr], ""))
    for i in 0..<csg.exprLayer.exprs.len:
        let expr = csg.exprLayer.exprs[i]
        if expr.kind != parser.NormalizedExprCall:
            continue
        let fact = csg.typedExprFacts[i]
        echo(strutil.Join(["line=", intToStr(expr.lineNumber), " kind=", ccsg.CompilerCsgCallSurfaceKindText(expr.callSurfaceKind), " resolved=", (if expr.callResolved: "1" else: "0"), " reason=", ccsg.CompilerCsgCallReasonText(expr.callReason), " target_source=", expr.callTargetSourcePath, " target_importc=", (if expr.callTargetImportc: "1" else: "0"), " type=", fact.typeText, " abi=", texpr.TypedExprAbiClassText(fact.abiClass), " lower=", texpr.TypedExprLoweringModeText(fact.loweringMode), " ret=", texpr.TypedExprReturnKindText(fact.returnKind)], ""))
    return 0
