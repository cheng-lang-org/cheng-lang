import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as v3path
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/lang/parser
import cheng/core/lang/typed_expr as texpr

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let packageRoot = workspaceRoot
    let fixturePath = v3path.V3PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let outputPath = v3path.V3PathJoin(workspaceRoot, "artifacts/compiler_csg/typed_expr_call_validate_probe")
    let req = creq.v3CompilerRequestNew(packageRoot, fixturePath, outputPath, "arm64-apple-darwin", creq.v3EmitShared, "")
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), "typed expr call validate probe: link plan")
    let sourceBundleRes = slplan.v3SystemLinkPlanSourceBundleCid(linkPlan)
    assert(IsOk(sourceBundleRes), "typed expr call validate probe: source bundle")
    let sourceBundleCid = Value(sourceBundleRes)
    let csgRes = ccsg.v3BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(csgRes), "typed expr call validate probe: build csg")
    let csg = ccsg.v3CompilerCsgClone(Value(csgRes))
    var callErr = ""
    let ok = texpr.v3TypedExprFactsValidateCallResolution(csg.exprLayer, csg.typedExprFacts, callErr)
    echo("validate_ok=" + (if ok: "1" else: "0"))
    echo("validate_err=" + callErr)
    for i in 0..<csg.exprLayer.exprs.len:
        let expr = csg.exprLayer.exprs[i]
        if expr.kind != parser.v3NormalizedExprCall:
            continue
        let fact = csg.typedExprFacts[i]
        echo("line=" + intToStr(expr.lineNumber) +
             " kind=" + ccsg.v3CompilerCsgCallSurfaceKindText(expr.callSurfaceKind) +
             " resolved=" + (if expr.callResolved: "1" else: "0") +
             " reason=" + ccsg.v3CompilerCsgCallReasonText(expr.callReason) +
             " target_source=" + expr.callTargetSourcePath +
             " target_importc=" + (if expr.callTargetImportc: "1" else: "0") +
             " type=" + fact.typeText +
             " abi=" + texpr.v3TypedExprAbiClassText(fact.abiClass) +
             " lower=" + texpr.v3TypedExprLoweringModeText(fact.loweringMode) +
             " ret=" + texpr.v3TypedExprReturnKindText(fact.returnKind))
    return 0
