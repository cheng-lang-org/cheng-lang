import cheng/tests/call_hir_qualified_closure_visible_mid as qmid

fn main(): int32 =
    let payload = "qualified"
    let visibleLen = qmid.QualifiedClosureVisibleLen(payload)
    let visibleEcho = qmid.QualifiedClosureVisibleEcho(payload)
    assert(visibleLen == len(visibleEcho), "v3 call hir matrix: qualified closure visible match")
    return 0
