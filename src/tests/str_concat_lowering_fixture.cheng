import std/strings

type
    Box = object
        title: str
        count: int32

fn main(): int32 =
    let name: str = "alpha"
    let count: int32 = 7
    let box = Box(title: "beta", count: 9)
    let fallback: str = "none"

    let summary: str = "box=" + name + " count=" + intToStr(count) + " rc=" + intToStr(count)
    assert(summary == "box=alpha count=7 rc=7", "v3 str concat lowering: multi chain")

    let wrapped: str = "{" + name + "}"
    assert(wrapped == "{alpha}", "v3 str concat lowering: wrapped")

    let memberText: str = box.title + ":" + intToStr(box.count)
    assert(memberText == "beta:9", "v3 str concat lowering: member access")

    let condText: str = "selected=" + (true ? box.title : fallback)
    assert(condText == "selected=beta", "v3 str concat lowering: ternary")

    let ifExprText: str = "picked=" + (if true: box.title else: fallback)
    assert(ifExprText == "picked=beta", "v3 str concat lowering: if expr")

    var parts: str[]
    add(parts, "[" + intToStr(count) + "] " + name)
    assert(parts.len == 1, "v3 str concat lowering: nested add len")
    assert(parts[0] == "[7] alpha", "v3 str concat lowering: nested add value")

    echo("v3 str_concat_lowering_fixture ok")
    return 0
