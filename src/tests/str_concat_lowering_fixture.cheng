import std/strings
import std/strutils as strutil

type
    Box = object
        title: str
        count: int32

fn main(): int32 =
    let name: str = "alpha"
    let count: int32 = 7
    let box = Box(title: "beta", count: 9)
    let fallback: str = "none"

    let summary: str = strutil.Join(["box=", name, " count=", IntToStr(count), " rc=", IntToStr(count)], "")
    assert(summary == "box=alpha count=7 rc=7", " str concat lowering: multi chain")

    let pureLiteral: str = strutil.Join(["a", "b"], "")
    assert(pureLiteral == "ab", " str concat lowering: pure literal chain")

    let wrapped: str = strutil.Join(["{", name, "}"], "")
    assert(wrapped == "{alpha}", " str concat lowering: wrapped")

    let memberText: str = strutil.Join([box.title, ":", IntToStr(box.count)], "")
    assert(memberText == "beta:9", " str concat lowering: member access")

    let condText: str = strutil.Join(["selected=", (true ? box.title : fallback)], "")
    assert(condText == "selected=beta", " str concat lowering: ternary")

    let ifExprText: str = strutil.Join(["picked=", (if true: box.title else: fallback)], "")
    assert(ifExprText == "picked=beta", " str concat lowering: if expr")

    var parts: str[]
    add(parts, strutil.Join(["[", IntToStr(count), "] ", name], ""))
    assert(parts.len == 1, " str concat lowering: nested add len")
    assert(parts[0] == "[7] alpha", " str concat lowering: nested add value")
    echo(strutil.Join([" direct_concat_echo=", name], ""))

    echo(" str_concat_lowering_fixture ok")
    return 0
