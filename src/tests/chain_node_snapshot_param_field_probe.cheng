import std/os
import cheng/std/bytes_layout as layout
import cheng/chain/consensus
import cheng/chain/lsmr
import cheng/apps/chain_node/chain_node as node

fn dumpPair(label: str, left: layout.FixedBytes32, right: layout.FixedBytes32) =
    os.WriteLine(os.Get_stderr(), label + "_left=" + layout.FixedBytes32Hex(left))
    os.WriteLine(os.Get_stderr(), label + "_right=" + layout.FixedBytes32Hex(right))

fn checkRemote(remote: node.ChainNodeServeSnapshot,
               expectedEvent0: layout.FixedBytes32,
               expectedEvent1: layout.FixedBytes32,
               expectedForest: layout.FixedBytes32): int32 =
    os.WriteLine(os.Get_stderr(), "check:len")
    if remote.eventCids.len != 2:
        os.WriteLine(os.Get_stderr(), "param_event_cids_len=" + intToStr(remote.eventCids.len))
        return 11
    if remote.events.len != 2:
        os.WriteLine(os.Get_stderr(), "param_events_len=" + intToStr(remote.events.len))
        return 12

    os.WriteLine(os.Get_stderr(), "check:event-cid")
    let remoteEvent0 = consensus.ChainEventCid(remote.events[0])
    let remoteEvent1 = consensus.ChainEventCid(remote.events[1])

    os.WriteLine(os.Get_stderr(), "check:event0")
    if !layout.FixedBytes32Equal(remote.eventCids[0], expectedEvent0):
        dumpPair("param_event0", remote.eventCids[0], expectedEvent0)
        return 21
    os.WriteLine(os.Get_stderr(), "check:event1")
    if !layout.FixedBytes32Equal(remote.eventCids[1], expectedEvent1):
        dumpPair("param_event1", remote.eventCids[1], expectedEvent1)
        return 22
    os.WriteLine(os.Get_stderr(), "check:event0-cid")
    if !layout.FixedBytes32Equal(remoteEvent0, expectedEvent0):
        dumpPair("param_event0_cid", remoteEvent0, expectedEvent0)
        return 23
    os.WriteLine(os.Get_stderr(), "check:event1-cid")
    if !layout.FixedBytes32Equal(remoteEvent1, expectedEvent1):
        dumpPair("param_event1_cid", remoteEvent1, expectedEvent1)
        return 24
    os.WriteLine(os.Get_stderr(), "check:forest")
    if !layout.FixedBytes32Equal(remote.forest.forestCid, expectedForest):
        dumpPair("param_forest", remote.forest.forestCid, expectedForest)
        return 31
    os.WriteLine(os.Get_stderr(), "check:sig-forest")
    if !layout.FixedBytes32Equal(remote.signature.stateForestCid, expectedForest):
        dumpPair("param_signature_forest", remote.signature.stateForestCid, expectedForest)
        return 32

    os.WriteLine(os.Get_stderr(), "check:replay")
    var replayed: node.ChainNode
    node.ChainNodeZeroInto(replayed, "node-b", remote.address)
    for i in 0..<remote.events.len:
        var event = remote.events[i]
        event.stem = event.ganzhiIndex % 10
        event.branch = event.ganzhiIndex % 12
        event.bodyCid = consensus.ChainEventBodyCid(event)
        let applyRes = node.ChainNodeApplyEvent(replayed, event)
        if !applyRes.ok:
            os.WriteLine(os.Get_stderr(), "replay_apply_failed_at=" + intToStr(i))
            return 41
        if i == 0:
            if !layout.FixedBytes32Equal(applyRes.value, expectedEvent0):
                os.WriteLine(os.Get_stderr(), "replay_event0_mismatch")
                return 42
        else:
            if !layout.FixedBytes32Equal(applyRes.value, expectedEvent1):
                os.WriteLine(os.Get_stderr(), "replay_event1_mismatch")
                return 43
    node.ChainNodeRebuildDerived(replayed)
    os.WriteLine(os.Get_stderr(), "check:replay-index")
    if replayed.index.accountIds.len != 2:
        os.WriteLine(os.Get_stderr(), "replay_account_len=" + intToStr(replayed.index.accountIds.len))
        return 45
    if replayed.index.accountIds[0] != 1001:
        os.WriteLine(os.Get_stderr(), "replay_account0=" + intToStr(replayed.index.accountIds[0]))
        return 46
    if replayed.index.accountIds[1] != 2002:
        os.WriteLine(os.Get_stderr(), "replay_account1=" + intToStr(replayed.index.accountIds[1]))
        return 47
    if replayed.index.accountAssetIds[0] != 7:
        os.WriteLine(os.Get_stderr(), "replay_asset0=" + intToStr(replayed.index.accountAssetIds[0]))
        return 52
    if replayed.index.accountAssetIds[1] != 7:
        os.WriteLine(os.Get_stderr(), "replay_asset1=" + intToStr(replayed.index.accountAssetIds[1]))
        return 53
    if replayed.index.balances[0] != int64(60):
        os.WriteLine(os.Get_stderr(), "replay_balance0=" + intToStr(int32(replayed.index.balances[0])))
        return 48
    if replayed.index.balances[1] != int64(40):
        os.WriteLine(os.Get_stderr(), "replay_balance1=" + intToStr(int32(replayed.index.balances[1])))
        return 49
    if replayed.index.clockEpochs[0] != 1:
        os.WriteLine(os.Get_stderr(), "replay_epoch0=" + intToStr(replayed.index.clockEpochs[0]))
        return 54
    if replayed.index.clockEpochs[1] != 1:
        os.WriteLine(os.Get_stderr(), "replay_epoch1=" + intToStr(replayed.index.clockEpochs[1]))
        return 55
    if replayed.index.clockGanzhi[0] != 2:
        os.WriteLine(os.Get_stderr(), "replay_ganzhi0=" + intToStr(replayed.index.clockGanzhi[0]))
        return 56
    if replayed.index.clockGanzhi[1] != 2:
        os.WriteLine(os.Get_stderr(), "replay_ganzhi1=" + intToStr(replayed.index.clockGanzhi[1]))
        return 57
    if replayed.index.diverged[0]:
        os.WriteLine(os.Get_stderr(), "replay_diverged0=true")
        return 58
    if replayed.index.diverged[1]:
        os.WriteLine(os.Get_stderr(), "replay_diverged1=true")
        return 59
    if !layout.FixedBytes32Equal(replayed.index.accountHeads[0], expectedEvent1):
        os.WriteLine(os.Get_stderr(), "replay_head0_mismatch")
        return 50
    if !layout.FixedBytes32Equal(replayed.index.accountHeads[1], expectedEvent1):
        os.WriteLine(os.Get_stderr(), "replay_head1_mismatch")
        return 51
    let replayCells = node.ChainNodeStateCells(replayed.index)
    if replayCells.len != 2:
        os.WriteLine(os.Get_stderr(), "replay_cells_len=" + intToStr(replayCells.len))
        return 60
    let replayExpectedLocality0 = node.ChainNodeAccountLocalityHash(replayed.index.accountAssetIds[0],
                                                                      replayed.index.accountIds[0])
    if !layout.FixedBytes32Equal(replayCells[0].localityHash, replayExpectedLocality0):
        os.WriteLine(os.Get_stderr(), "replay_cell0_locality_hash_direct_mismatch")
        return 80
    let replayDirectForest = lsmr.BuildStateLayerForest(replayCells)
    var replayDirectOk = true
    for i in 0..<layout.FixedBytes32Size:
        if replayDirectForest.forestCid.data[i] != expectedForest.data[i]:
            replayDirectOk = false
    if !replayDirectOk:
        os.WriteLine(os.Get_stderr(), "replay_direct_forest_mismatch")
        var replayGlobalOk = true
        for i in 0..<layout.FixedBytes32Size:
            if replayDirectForest.globalTree.treeCid.data[i] != remote.forest.globalTree.treeCid.data[i]:
                replayGlobalOk = false
        if !replayGlobalOk:
            os.WriteLine(os.Get_stderr(), "replay_direct_global_tree_mismatch")
            return 63
        var replayRegionalOk = true
        for i in 0..<layout.FixedBytes32Size:
            if replayDirectForest.regionalTree.treeCid.data[i] != remote.forest.regionalTree.treeCid.data[i]:
                replayRegionalOk = false
        if !replayRegionalOk:
            os.WriteLine(os.Get_stderr(), "replay_direct_regional_tree_mismatch")
            return 64
        var replayEdgeOk = true
        for i in 0..<layout.FixedBytes32Size:
            if replayDirectForest.edgeTree.treeCid.data[i] != remote.forest.edgeTree.treeCid.data[i]:
                replayEdgeOk = false
        if !replayEdgeOk:
            os.WriteLine(os.Get_stderr(), "replay_direct_edge_tree_mismatch")
            if replayDirectForest.edgeTree.entryCount != remote.forest.edgeTree.entryCount:
                os.WriteLine(os.Get_stderr(), "replay_edge_entry_count_mismatch")
                return 66
            if replayDirectForest.edgeTree.nodeCount != remote.forest.edgeTree.nodeCount:
                os.WriteLine(os.Get_stderr(), "replay_edge_node_count_mismatch")
                return 67
            if replayDirectForest.edgeTree.entryCount > 0:
                if !layout.FixedBytes32Equal(replayDirectForest.edgeTree.entryCids[0], remote.forest.edgeTree.entryCids[0]):
                    if replayDirectForest.edgeTree.entryCount > 1:
                        if layout.FixedBytes32Equal(replayDirectForest.edgeTree.entryCids[0], remote.forest.edgeTree.entryCids[1]):
                            if layout.FixedBytes32Equal(replayDirectForest.edgeTree.entryCids[1], remote.forest.edgeTree.entryCids[0]):
                                os.WriteLine(os.Get_stderr(), "replay_edge_entries_swapped")
                                return 70
                    if replayDirectForest.edgeTree.entryKeyIds[0] != remote.forest.edgeTree.entryKeyIds[0]:
                        os.WriteLine(os.Get_stderr(), "replay_edge_entry0_key_mismatch")
                        return 71
                    if replayDirectForest.edgeTree.entryResolutionLevels[0] != remote.forest.edgeTree.entryResolutionLevels[0]:
                        os.WriteLine(os.Get_stderr(), "replay_edge_entry0_resolution_mismatch")
                        return 72
                    if replayDirectForest.edgeTree.entryLayerIds[0] != remote.forest.edgeTree.entryLayerIds[0]:
                        os.WriteLine(os.Get_stderr(), "replay_edge_entry0_layer_mismatch")
                        return 73
                    if !layout.FixedBytes32Equal(replayDirectForest.edgeTree.entryContentCids[0], remote.forest.edgeTree.entryContentCids[0]):
                        os.WriteLine(os.Get_stderr(), "replay_edge_entry0_content_mismatch")
                        return 74
                    if !layout.FixedBytes32Equal(replayDirectForest.edgeTree.entryLocalityHashes[0], remote.forest.edgeTree.entryLocalityHashes[0]):
                        os.WriteLine(os.Get_stderr(), "replay_edge_entry0_locality_hash_mismatch")
                        return 76
                    if !layout.FixedBytes32Equal(replayDirectForest.edgeTree.entryLocalityCids[0], remote.forest.edgeTree.entryLocalityCids[0]):
                        if replayDirectForest.edgeTree.entryPrefixes[0].baguaId != remote.forest.edgeTree.entryPrefixes[0].baguaId:
                            os.WriteLine(os.Get_stderr(), "replay_edge_entry0_prefix_bagua_mismatch")
                            return 77
                        if replayDirectForest.edgeTree.entryPrefixes[0].prefixDepth != remote.forest.edgeTree.entryPrefixes[0].prefixDepth:
                            os.WriteLine(os.Get_stderr(), "replay_edge_entry0_prefix_depth_mismatch")
                            return 78
                        if replayDirectForest.edgeTree.entryAddresses[0].depth != remote.forest.edgeTree.entryAddresses[0].depth:
                            os.WriteLine(os.Get_stderr(), "replay_edge_entry0_address_depth_mismatch")
                            return 79
                        os.WriteLine(os.Get_stderr(), "replay_edge_entry0_locality_mismatch")
                        return 75
                    os.WriteLine(os.Get_stderr(), "replay_edge_entry0_cid_mismatch")
                    return 68
            if replayDirectForest.edgeTree.entryCount > 1:
                if !layout.FixedBytes32Equal(replayDirectForest.edgeTree.entryCids[1], remote.forest.edgeTree.entryCids[1]):
                    os.WriteLine(os.Get_stderr(), "replay_edge_entry1_cid_mismatch")
                    return 69
            return 65
        return 61
    var replayNodeForestOk = true
    for i in 0..<layout.FixedBytes32Size:
        if replayDirectForest.forestCid.data[i] != replayed.forest.forestCid.data[i]:
            replayNodeForestOk = false
    if !replayNodeForestOk:
        os.WriteLine(os.Get_stderr(), "replay_node_forest_copy_mismatch")
        return 62
    os.WriteLine(os.Get_stderr(), "check:replay-forest")
    var replayForestOk = true
    let replayForest = replayed.forest.forestCid
    for i in 0..<layout.FixedBytes32Size:
        if replayForest.data[i] != expectedForest.data[i]:
            replayForestOk = false
    if !replayForestOk:
        os.WriteLine(os.Get_stderr(), "replay_forest_mismatch")
        var replaySigForestOk = true
        for i in 0..<layout.FixedBytes32Size:
            if replayed.signature.stateForestCid.data[i] != expectedForest.data[i]:
                replaySigForestOk = false
        if !replaySigForestOk:
            os.WriteLine(os.Get_stderr(), "replay_signature_forest_mismatch")
        return 44
    return 0

fn main(): int32 =
    os.WriteLine(os.Get_stderr(), "main:init")
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node snapshot param field probe: mint")
    let transferCidRes = node.ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, " chain_node snapshot param field probe: transfer")

    os.WriteLine(os.Get_stderr(), "main:pre-serve-rebuild")
    node.ChainNodeRebuildDerived(server)
    os.WriteLine(os.Get_stderr(), "main:pre-serve-rebuild-ok")
    os.WriteLine(os.Get_stderr(), "main:serve")
    var served: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(served, server)
    let expectedForest = node.ChainNodeForestCid(server)

    os.WriteLine(os.Get_stderr(), "main:served-check")
    if !layout.FixedBytes32Equal(served.eventCids[0], mintCidRes.value):
        dumpPair("served_event0", served.eventCids[0], mintCidRes.value)
        return 1
    if !layout.FixedBytes32Equal(served.eventCids[1], transferCidRes.value):
        dumpPair("served_event1", served.eventCids[1], transferCidRes.value)
        return 2
    if !layout.FixedBytes32Equal(served.forest.forestCid, expectedForest):
        dumpPair("served_forest", served.forest.forestCid, expectedForest)
        return 3
    if !layout.FixedBytes32Equal(served.signature.stateForestCid, expectedForest):
        dumpPair("served_signature_forest", served.signature.stateForestCid, expectedForest)
        return 4
    if server.forest.edgeTree.entryCount > 0:
        if !layout.FixedBytes32Equal(served.forest.edgeTree.entryLocalityHashes[0],
                                     server.forest.edgeTree.entryLocalityHashes[0]):
            dumpPair("served_edge_locality_hash0",
                     served.forest.edgeTree.entryLocalityHashes[0],
                     server.forest.edgeTree.entryLocalityHashes[0])
            return 5
        if !layout.FixedBytes32Equal(served.forest.edgeTree.entryLocalityCids[0],
                                     server.forest.edgeTree.entryLocalityCids[0]):
            dumpPair("served_edge_locality_cid0",
                     served.forest.edgeTree.entryLocalityCids[0],
                     server.forest.edgeTree.entryLocalityCids[0])
            return 6

    os.WriteLine(os.Get_stderr(), "main:param-check")
    let remoteRc = checkRemote(served, mintCidRes.value, transferCidRes.value, expectedForest)
    if remoteRc != 0:
        return remoteRc

    echo(" chain_node_snapshot_param_field_probe ok")
    return 0
