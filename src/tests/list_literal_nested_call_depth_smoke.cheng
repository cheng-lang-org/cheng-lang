import std/strings
import std/strformat

type
    DepthLeaf = object
        text: str

    DepthRoot = object
        prefix: str
        tags: str[]
        leaves: DepthLeaf[]

fn renderDepthParts(parts: str[]): str =
    return Fmt(parts)

fn main(): int32 =
    var root: DepthRoot
    root.prefix = "node"
    add(root.tags, "7")
    add(root.leaves, DepthLeaf(text: "alpha"))
    let rendered = renderDepthParts([
        root.prefix + ":" + root.leaves[0].text,
        "[" + root.tags[0] + "]",
        ":" + strings.IntToStr(root.leaves.len)
    ])
    assert(rendered == "node:alpha[7]:1", " list literal nested call depth: rendered")
    echo(" list_literal_nested_call_depth_smoke ok")
    return 0
