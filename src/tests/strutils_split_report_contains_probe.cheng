import std/os
import std/strutils as strutil
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root = os.GetCurrentDir()
    let reportPath = os.JoinPath(root, "artifacts/str_concat_lowering_smoke/str_concat_lowering_probe.compile.report.txt")
    assert(chengpath.PathFileExists(reportPath), " split report contains: report exists")
    let reportText = os.ReadFile(reportPath)
    let reportLines = strutil.Split(reportText, '\n')
    assert(reportLines.len > 50, " split report contains: enough lines")
    var found: bool
    for i in 0..<reportLines.len:
        if strutil.Contains(reportLines[i], "native_primary_object="):
            found = true
            break
    assert(found, " split report contains: found line")
    echo(" strutils_split_report_contains_probe ok")
    return 0
