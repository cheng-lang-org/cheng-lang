fn main(): int32 =
    var x: int32 = 1
    var y: int32 = 2
    var z: int32 = x + y
    assert(z == 3, "integer arithmetic: 1 + 2 should equal 3")
    var w: int32 = z * 4
    assert(w == 12, "integer arithmetic: 3 * 4 should equal 12")
    var v: int32 = w - 5
    assert(v == 7, "integer arithmetic: 12 - 5 should equal 7")
    echo("assert-arithmetic-ok")
    return 0
