import std/cmdline as cmdline
import std/os
import std/strings
import std/strutils as strutil
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/host_ops as hostops

fn runtimeZeroCPrefix(prefix: str, value: str): str =
    return Fmt([prefix, value])

fn runtimeZeroCSurfaceTag(): str =
    let programPath = cmdline.ProgramName()
    let programParts = os.SplitFile(programPath)
    if len(programParts.dir) > 0:
        let dirParts = os.SplitFile(programParts.dir)
        if len(dirParts.name) > 0:
            return dirParts.name
    if len(programParts.name) > 0:
        return programParts.name
    return "host"

fn runtimeZeroCSurfaceCompiler(root: str): str =
    let explicit = strutil.Strip(os.GetEnv("CHENG_SMOKE_COMPILER"))
    if len(explicit) > 0:
        return chengpath.PathAbsolute(root, explicit)
    return os.JoinPath(root, "artifacts/backend_driver/cheng")

fn main(): int32 =
    let root = os.GetCurrentDir()
    let driver = runtimeZeroCSurfaceCompiler(root)
    let outDir = chengpath.PathAbsolute(root, "artifacts/runtime_zero_c_surface_smoke")
    let auditLog = os.JoinPath(outDir, "host_bridge_audit.log")
    let smokeTag = runtimeZeroCSurfaceTag()
    let browserLabel = runtimeZeroCPrefix("runtime_zero_script_surface_", smokeTag)
    let browserLog = os.JoinPath(outDir, "browser_host_wasm.log")
    let wasmLabel = runtimeZeroCPrefix("runtime_zero_script_wasm_", smokeTag)
    let wasmLog = os.JoinPath(outDir, "wasm_smokes.log")
    let browserRunnerBase = runtimeZeroCPrefix("artifacts/browser_host_wasm/browser_host_wasm_runner.",
                                               browserLabel)
    let browserRunnerRel = runtimeZeroCPrefix(browserRunnerBase, ".js")
    let browserRunnerPath = chengpath.PathAbsolute(root, browserRunnerRel)
    let wasmRunnerBase = runtimeZeroCPrefix("artifacts/wasm_smokes/run_wasm_smokes.", wasmLabel)
    let wasmRunnerRel = runtimeZeroCPrefix(wasmRunnerBase, ".js")
    let wasmRunnerPath = chengpath.PathAbsolute(root, wasmRunnerRel)
    assert(chengpath.MkdirP(root, outDir), " runtime zero c surface: mkdir")
    if chengpath.PathFileExists(auditLog):
        os.RemoveFile(auditLog)
    if chengpath.PathFileExists(browserLog):
        os.RemoveFile(browserLog)
    if chengpath.PathFileExists(wasmLog):
        os.RemoveFile(wasmLog)
    if chengpath.PathFileExists(browserRunnerPath):
        os.RemoveFile(browserRunnerPath)
    if chengpath.PathFileExists(wasmRunnerPath):
        os.RemoveFile(wasmRunnerPath)
    var runtimeZeroGateEnv: str[]
    add(runtimeZeroGateEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    add(runtimeZeroGateEnv, "CHENG_PROGRESS=1")
    add(runtimeZeroGateEnv, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592")
    add(runtimeZeroGateEnv, "CHENG_COMPILE_TIMEOUT_SEC=420")
    let run = hostops.RunFileLogged(root,
                                      "runtime_zero_c_surface_audit",
                                      driver,
                                      ["host-bridge-audit"],
                                      [],
                                      root,
                                      0,
                                      auditLog)
    assert(run.exitCode == 0, " runtime zero c surface: host bridge audit rc")
    let auditText = run.output
    assert(strings.StrContains(auditText, "pure_cheng_zero_c_ready=1"),
           " runtime zero c surface: pure ready")
    assert(strings.StrContains(auditText, "remaining_non_pure_cheng_boundary=none"),
           " runtime zero c surface: no remaining boundary")
    assert(strings.StrContains(auditText, "legacy_runtime_program_obj_command_present=0"),
           " runtime zero c surface: no runtime obj command")
    assert(strings.StrContains(auditText, "legacy_runtime_program_obj_import_present=0"),
           " runtime zero c surface: no runtime obj import")
    assert(strings.StrContains(auditText, "legacy_runtime_program_combined_smoke_present=0"),
           " runtime zero c surface: no combined smoke")
    assert(strings.StrContains(auditText, "legacy_runtime_native_source_path_present=0"),
           " runtime zero c surface: no native source path")
    assert(strings.StrContains(auditText, "legacy_runtime_combined_fallback_present=0"),
           " runtime zero c surface: no combined fallback")
    assert(strings.StrContains(auditText, "legacy_node_wasm_host_present=0"),
           " runtime zero c surface: no node wasm host")
    assert(strings.StrContains(auditText, "legacy_browser_host_wasm_runner_present=0"),
           " runtime zero c surface: no browser host wasm repo runner")
    var browserArgs: str[]
    browserArgs = []
    add(browserArgs, "run-browser-host-wasm-smoke")
    add(browserArgs, runtimeZeroCPrefix("--compiler:", driver))
    add(browserArgs, runtimeZeroCPrefix("--label:", browserLabel))
    let browserRun = hostops.RunFileLogged(root,
                                             "runtime_zero_script_browser_host_wasm",
                                             driver,
                                             browserArgs,
                                             runtimeZeroGateEnv,
                                             root,
                                             420,
                                             browserLog)
    assert(browserRun.exitCode == 0, " runtime zero c surface: browser host wasm rc")
    assert(strings.StrContains(browserRun.output, " browser host wasm smoke: ok"),
           " runtime zero c surface: browser host wasm ok")
    assert(!chengpath.PathFileExists(browserRunnerPath),
           " runtime zero c surface: no browser host wasm temp js")
    var wasmArgs: str[]
    wasmArgs = []
    add(wasmArgs, "run-wasm-smokes")
    add(wasmArgs, runtimeZeroCPrefix("--compiler:", driver))
    add(wasmArgs, runtimeZeroCPrefix("--label:", wasmLabel))
    let wasmRun = hostops.RunFileLogged(root,
                                          "runtime_zero_script_wasm_smokes",
                                          driver,
                                          wasmArgs,
                                          runtimeZeroGateEnv,
                                          root,
                                          420,
                                          wasmLog)
    assert(wasmRun.exitCode == 0, " runtime zero c surface: wasm smokes rc")
    assert(strings.StrContains(wasmRun.output, " wasm smokes: ok"),
           " runtime zero c surface: wasm smokes ok")
    assert(!chengpath.PathFileExists(wasmRunnerPath),
           " runtime zero c surface: no wasm smokes temp js")
    echo(" runtime_zero_c_surface_smoke ok")
    return 0
