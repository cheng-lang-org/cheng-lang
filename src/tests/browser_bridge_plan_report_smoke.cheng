import cheng/core/backend/system_link_exec as sexec
import cheng/core/backend/system_link_plan as slplan
import cheng/libp2p/browser/browser_content_codec_codegen as codegen
import cheng/libp2p/browser/browser_content_codec_rule_schema as browsercodec

fn browserBridgePlanReportContains(text: str, needle: str): bool =
    if len(needle) <= 0:
        return true
    if len(text) < len(needle):
        return false
    var i: int32
    while i + len(needle) <= len(text):
        var matched = true
        var j: int32
        while j < len(needle):
            if text[i + j] != needle[j]:
                matched = false
                break
            j = j + 1
        if matched:
            return true
        i = i + 1
    return false

fn main(): int32 =
    let workspaceRoot = "/Users/lbcheng/cheng-lang"
    let packageRoot = "/Users/lbcheng/cheng-lang"
    let sourcePath = "/Users/lbcheng/cheng-lang/src/tests/browser_host_native_min_smoke.cheng"
    let browserCodecMinPath = "/Users/lbcheng/cheng-lang/src/tests/browser_content_codec_abi_min.cheng"
    let browserCodecPath = "/Users/lbcheng/cheng-lang/src/libp2p/browser/browser_content_codec_abi.cheng"
    var linkPlan: slplan.V3SystemLinkPlanStub
    linkPlan.workspaceRoot = workspaceRoot
    linkPlan.packageRoot = packageRoot
    linkPlan.entryPath = sourcePath
    linkPlan.outputPath = "/tmp/browser_host_native_min_smoke"
    linkPlan.sourceClosurePaths = [
        sourcePath,
        browserCodecMinPath,
        browserCodecPath
    ]
    var plan: sexec.V3SystemLinkExecPlan
    plan.compilerEntrySource = sourcePath
    plan.systemLinkPlan = linkPlan
    plan.compileReceipt.bootstrapStage = "stage3_local"
    plan.objectPlan.pipelineStage = "primary_object_plan_to_object_plan"
    plan.nativeLinkPlan.linkerProgram = "cc"
    plan.nativeLinkPlan.pipelineStage = "primary_object_plan_to_native_link_plan"
    let reportText = sexec.v3SystemLinkExecPlanReport(plan)
    let outputTextRule = browsercodec.v3BrowserContentCodecRuleOutputTextHandleName()
    let expectedEmitLine = codegen.v3BrowserCodecBridgeEmitLineForSourceRuleName(browserCodecPath,
                                                                                  outputTextRule)
    assert(browserBridgePlanReportContains(reportText, "browser_bridge_plan_count=4"),
           "v3 browser bridge plan report: count")
    assert(browserBridgePlanReportContains(reportText, "browser_bridge_plan_unique_key_count=4"),
           "v3 browser bridge plan report: unique key count")
    assert(browserBridgePlanReportContains(reportText,
                                           "browser_bridge_artifact_path=/tmp/browser_host_native_min_smoke.browser_bridge_plan.txt"),
           "v3 browser bridge plan report: artifact path")
    assert(browserBridgePlanReportContains(reportText, "browser_bridge_artifact_format=browser_abi_bridge_plan_v1"),
           "v3 browser bridge plan report: artifact format")
    assert(browserBridgePlanReportContains(reportText, "browser_bridge_artifact_count=4"),
           "v3 browser bridge plan report: artifact count")
    assert(browserBridgePlanReportContains(reportText, "browser_bridge_artifact_unique_key_count=4"),
           "v3 browser bridge plan report: artifact unique key count")
    assert(browserBridgePlanReportContains(reportText,
                                           "browser_bridge_source_path=/tmp/browser_host_native_min_smoke.browser_bridge.generated.cheng"),
           "v3 browser bridge plan report: source path")
    assert(browserBridgePlanReportContains(reportText, "browser_bridge_source_format=browser_abi_bridge_source_v1"),
           "v3 browser bridge plan report: source format")
    assert(browserBridgePlanReportContains(reportText, "browser_bridge_source_count=4"),
           "v3 browser bridge plan report: source count")
    assert(browserBridgePlanReportContains(reportText,
                                           "browser_bridge_object_path=/tmp/browser_host_native_min_smoke.browser_bridge.generated.o"),
           "v3 browser bridge plan report: object path")
    assert(browserBridgePlanReportContains(reportText, "browser_bridge_object_count=1"),
           "v3 browser bridge plan report: object count")
    assert(browserBridgePlanReportContains(reportText, "browser_bridge_plan[3]=" + expectedEmitLine),
           "v3 browser bridge plan report: output emit line")
    assert(browserBridgePlanReportContains(reportText, "native_linker_program="),
           "v3 browser bridge plan report: compiler report body")
    echo("v3 browser_bridge_plan_report_smoke ok")
    return 0
