type
    Pair =
        a: int32
        b: int32

var
    gPairs: Pair[2]

fn fillPairs() =
    gPairs[0] = Pair(a: 1, b: 2)
    gPairs[1] = Pair(a: 3, b: 4)

fn sumPairs(): int32 =
    var total: int32
    for i in 0..<2:
        total = total + gPairs[i].a
        total = total + gPairs[i].b
    return total

fn main(): int32 =
    fillPairs()
    assert(sumPairs() == 10, " global fixed array composite")
    echo(" global_fixed_array_composite_smoke ok")
    return 0
