import cheng/moq/moq_fountain as moq
import std/strutils as strutil

fn main(): int32 =
    let buildRes = moq.MoqFountainBuild(bytesFromString("moq-fountain-smoke"),
                                        "peer-alpha",
                                        "peer-bravo,peer-charlie",
                                        "video/mp4",
                                        8,
                                        4,
                                        2)
    if IsErr(buildRes):
        echo(strutil.Join(["moq_build_err=", Error(buildRes)], ""))
        return 1
    let result = Value(buildRes)
    echo(strutil.Join(["catalog_key=", result.catalogKey], ""))
    echo(strutil.Join(["object_count=", intToStr(result.objects.len)], ""))
    echo(strutil.Join(["droplet_count=", intToStr(result.droplets.len)], ""))
    return 0
