import cheng/moq/moq_fountain as moq

fn main(): int32 =
    let buildRes = moq.v3Libp2pMoqBuild(bytesFromString("moq-fountain-smoke"),
                                        "peer-alpha",
                                        "peer-bravo,peer-charlie",
                                        "video/mp4",
                                        8,
                                        4,
                                        2)
    if IsErr(buildRes):
        echo("moq_build_err=" + Error(buildRes))
        return 1
    let result = Value(buildRes)
    echo("catalog_key=" + result.catalogKey)
    echo("object_count=" + intToStr(result.objects.len))
    echo("droplet_count=" + intToStr(result.droplets.len))
    return 0
