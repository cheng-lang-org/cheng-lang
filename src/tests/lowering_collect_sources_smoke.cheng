import std/os
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/lang/parser
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import std/strutils as strutil

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, strutil.Join(["artifacts/program_selfhost/", smokeLabel], ""))
    assert(chengpath.MkdirP(workspaceRoot, outDir), " lowering collect sources: mkdir")
    let sourcePath = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = chengpath.PathJoin(outDir, "program_selfhost_smoke")
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(packageRoot, req, linkPlan, err), " lowering collect sources: build link plan")
    let sourceClosurePaths = slplan.SystemLinkPlanSourceClosurePaths(linkPlan)
    for sourceIndex in 0..<sourceClosurePaths.len:
        let currentSource = sourceClosurePaths[sourceIndex]
        echo(currentSource)
        let ownerModulePath = parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, currentSource)
        let text = chengpath.ReadTextFile("", currentSource)
        var decls: parser.NormalizedFunctionDecl[]
        var parseErr = ""
        var exprLayer = parser.NormalizedExprLayer()
        assert(parser.ParserReadNormalizedFunctionDecls(text, decls, parseErr),
               " lowering collect sources: normalized decls")
        assert(parser.ParserReadNormalizedExprLayerFromText(currentSource, text, exprLayer, parseErr),
               " lowering collect sources: normalized expr layer")
        assert(exprLayer.sourceCount == 1, " lowering collect sources: one source summary")
        assert(exprLayer.questionResidualCount == 0, " lowering collect sources: question normalized")
        for declIndex in 0..<decls.len:
            if decls[declIndex].importc:
                continue
            let symbolText = lower.LoweringFunctionSymbolText(ownerModulePath, decls[declIndex].name)
            assert(symbolText != "", " lowering collect sources: symbol text")
    echo(" lowering_collect_sources_smoke ok")
    return 0
