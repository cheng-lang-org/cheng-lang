import std/os
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as v3path
import cheng/core/lang/parser
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathJoin(workspaceRoot, "artifacts/program_selfhost/" + smokeLabel)
    assert(v3path.V3MkdirP(workspaceRoot, outDir), "v3 lowering collect sources: mkdir")
    let sourcePath = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = v3path.V3PathJoin(outDir, "program_selfhost_smoke")
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(packageRoot, req, linkPlan, err), "v3 lowering collect sources: build link plan")
    let sourceClosurePaths = slplan.v3SystemLinkPlanSourceClosurePaths(linkPlan)
    for sourceIndex in 0..<sourceClosurePaths.len:
        let currentSource = sourceClosurePaths[sourceIndex]
        echo(currentSource)
        let ownerModulePath = parser.v3ParserSourcePathToModulePath(workspaceRoot, packageRoot, currentSource)
        let text = v3path.V3ReadTextFile("", currentSource)
        var decls: parser.V3NormalizedFunctionDecl[]
        var parseErr = ""
        var exprLayer = parser.V3NormalizedExprLayer()
        assert(parser.v3ParserReadNormalizedFunctionDecls(text, decls, parseErr),
               "v3 lowering collect sources: normalized decls")
        assert(parser.v3ParserReadNormalizedExprLayerFromText(currentSource, text, exprLayer, parseErr),
               "v3 lowering collect sources: normalized expr layer")
        assert(exprLayer.sourceCount == 1, "v3 lowering collect sources: one source summary")
        assert(exprLayer.questionResidualCount == 0, "v3 lowering collect sources: question normalized")
        for declIndex in 0..<decls.len:
            if decls[declIndex].importc:
                continue
            let symbolText = lower.v3LoweringFunctionSymbolText(ownerModulePath, decls[declIndex].name)
            assert(symbolText != "", "v3 lowering collect sources: symbol text")
    echo("v3 lowering_collect_sources_smoke ok")
    return 0
