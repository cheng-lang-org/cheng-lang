import std/system
import std/rawbytes
import cheng/std/bytes_layout as layout

fn main(): int32 =
    var buf = layout.ByteBufInit(16)
    layout.ByteBufAppendByte(buf, 7)
    layout.ByteBufAppendByte(buf, 8)
    assert(buf.len == 2, " bytebuf len probe: direct len")
    assert(layout.ByteBufLen(buf) == 2, " bytebuf len probe: helper len")
    let rawView = bytesView(buf.storage.data, buf.len)
    assert(bytesLen(rawView) == 2, " bytebuf len probe: raw view len")
    let span = layout.ByteBufView(buf)
    assert(layout.ByteSpanLen(span) == 2, " bytebuf len probe: helper view len")
    echo(" bytebuf_len_probe_smoke ok")
    return 0
