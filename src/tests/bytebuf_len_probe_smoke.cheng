import std/system
import std/rawbytes
import cheng/std/bytes_layout as layout

fn main(): int32 =
    var buf = layout.byteBufInit(16)
    layout.byteBufAppendByte(buf, 7)
    layout.byteBufAppendByte(buf, 8)
    assert(buf.len == 2, "v3 bytebuf len probe: direct len")
    assert(layout.byteBufLen(buf) == 2, "v3 bytebuf len probe: helper len")
    let rawView = bytesView(buf.storage.data, buf.len)
    assert(bytesLen(rawView) == 2, "v3 bytebuf len probe: raw view len")
    let span = layout.byteBufView(buf)
    assert(layout.byteSpanLen(span) == 2, "v3 bytebuf len probe: helper view len")
    echo("v3 bytebuf_len_probe_smoke ok")
    return 0
