type ScanState =
    pos: int32
    limit: int32
    ok: bool
    label: str
    values: int32[2]

fn Advance(state: var ScanState, amount: int32): int32 =
    state.pos = state.pos + amount
    state.ok = state.pos < state.limit && state.label[0] == 'c'
    state.label = "ok\n"
    state.values = [7, 8]
    if !state.ok:
        return 1
    if len(state.label) != 3:
        return 2
    return state.pos + state.values[1]

fn main(): int32 =
    var state: ScanState
    state.pos = 5
    state.limit = 10
    state.ok = false
    state.label = "cold"
    state.values = [1, 2]
    let score = Advance(state, 4)
    if score != 17:
        return score
    if state.pos != 9:
        return 3
    if !state.ok:
        return 4
    if state.values[0] != 7:
        return 5
    if state.values[1] != 8:
        return 6
    if state.label[2] != '\n':
        return 7
    return 42
