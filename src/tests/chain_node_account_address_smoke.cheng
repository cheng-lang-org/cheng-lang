import std/system
import cheng/chain/binary_types as types
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    let alice = node.ChainNodeAccountAddress(7, 1001)
    let aliceAgain = node.ChainNodeAccountAddress(7, 1001)
    let bob = node.ChainNodeAccountAddress(7, 2002)
    assert(alice.depth == 3, " chain_node account address smoke: depth")
    assert(types.LsmrAddressEqual(alice, aliceAgain), " chain_node account address smoke: deterministic")
    assert(!types.LsmrAddressEqual(alice, bob), " chain_node account address smoke: distinct")
    echo(" chain_node_account_address_smoke ok")
    return 0
