import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

fn main(): int32 =
    let zeroCid = layout.FixedBytes32()
    let mintA = consensus.ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let mintB = consensus.ChainEventMint(7, 2002, zeroCid, int64(40), 1, 14, 1, int64(11))

    var events: consensus.ChainEvent[]
    events = []
    add(events, mintA)
    assert(events.len == 1, " consensus event seq: first add")
    add(events, mintB)
    assert(events.len == 2, " consensus event seq: second add")
    assert(events[0].toAccount == 1001, " consensus event seq: first payload")
    assert(events[1].toAccount == 2002, " consensus event seq: second payload")
    echo(" consensus_event_seq_smoke ok")
    return 0
