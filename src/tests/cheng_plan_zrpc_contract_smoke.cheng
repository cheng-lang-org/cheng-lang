import std/os
import std/strings as strings

fn assertFileHas(path: str, needle: str, label: str) =
    assert(os.FileExists(path), label)
    assert(os.FileSize(path) > int64(0), label)
    let text: str = os.ReadFile(path)
    assert(strings.StrContains(text, needle), label)

fn assertTextHas(text: str, needle: str, label: str) =
    assert(strings.StrContains(text, needle), label)

fn main(): int32 =
    let planPath: str = "docs/cheng-plan-full.md"
    let specPath: str = "docs/cheng-formal-spec.md"

    assert(os.FileExists(planPath), " zrpc contract: plan exists")
    assert(os.FileExists(specPath), " zrpc contract: spec exists")
    assert(os.FileSize(planPath) > int64(0), " zrpc contract: plan nonempty")
    assert(os.FileSize(specPath) > int64(0), " zrpc contract: spec nonempty")

    let planText: str = os.ReadFile(planPath)
    let specText: str = os.ReadFile(specPath)

    assertTextHas(planText, "### ZRPC/no-pointer 工程任务矩阵（待验收）",
                  " zrpc contract: plan matrix title")
    assertTextHas(planText, "本节描述终局目标，不表示下面四类桥接已经全部达到发布闭环。",
                  " zrpc contract: plan no completion claim")
    assertTextHas(planText, "当前公开口径只固定三件事：默认 no-pointer；FFI、handle、borrow 是显式边界；生产链路不能把 C 脚本、C seed 强制构建或假实现写成通过依据。",
                  " zrpc contract: plan fixed contract scope")

    assertTextHas(planText, "ffi_importc_map_slice_ptr_len_i32.cheng",
                  " zrpc contract: plan slice fixture")
    assertTextHas(planText, "ffi_outptr_tuple_importc_pair_i32.cheng",
                  " zrpc contract: plan outptr pair fixture")
    assertTextHas(planText, "ffi_outptr_tuple_importc_status_i32_objonly.cheng",
                  " zrpc contract: plan outptr status fixture")
    assertTextHas(planText, "ffi_outptr_tuple_str_i64_direct_return.cheng",
                  " zrpc contract: plan outptr str i64 fixture")
    assertTextHas(planText, "ffi_importc_borrow_mut_pair_i32.cheng",
                  " zrpc contract: plan borrow fixture")
    assertTextHas(planText, "compile_fail_ffi_slice_user_raw_ptr_surface.cheng",
                  " zrpc contract: plan raw slice negative")
    assertTextHas(planText, "compile_fail_ffi_importc_voidptr_surface.cheng",
                  " zrpc contract: plan voidptr negative")
    assertTextHas(planText, "compile_fail_ffi_outptr_tuple_arity_mismatch.cheng",
                  " zrpc contract: plan outptr arity negative")
    assertTextHas(planText, "compile_fail_ffi_importc_borrow_mut_pair_i32_non_lvalue.cheng",
                  " zrpc contract: plan borrow non-lvalue negative")
    assertTextHas(planText, "compile_fail_spawn_raw_default_gate.cheng",
                  " zrpc contract: plan spawn default negative")
    assertTextHas(planText, "compile_fail_spawn_raw_ptr.cheng",
                  " zrpc contract: plan spawn raw ptr negative")
    assertTextHas(planText, "src/tests/ffi_handle_smoke.cheng",
                  " zrpc contract: plan handle smoke")
    assertTextHas(planText, "src/tests/ffi_handle_generation_reuse_smoke.cheng",
                  " zrpc contract: plan handle generation smoke")
    assertTextHas(planText, "src/tests/ffi_handle_stale_trap_smoke.cheng",
                  " zrpc contract: plan handle stale smoke")
    assertTextHas(planText, "src/tests/ffi_handle_generation_stale_trap_smoke.cheng",
                  " zrpc contract: plan handle generation stale smoke")

    assertTextHas(specText, "零裸指针生产闭环",
                  " zrpc contract: spec zrpc name")
    assertTextHas(specText, "`Zero-RawPtr Production Closure`",
                  " zrpc contract: spec zrpc english name")
    assertTextHas(specText, "no-pointer policy",
                  " zrpc contract: spec no-pointer diagnostic")
    assertTextHas(specText, "`ffi_map`：`slice -> (ptr,len)` 物理拆包。",
                  " zrpc contract: spec ffi_map contract")
    assertTextHas(specText, "`ffi_out_ptrs`：`out-ptr -> tuple` 语义回收。",
                  " zrpc contract: spec ffi_out_ptrs contract")
    assertTextHas(specText, "`ffi_handle`：`void* <-> handle(u32/u64)` runtime 槽位映射。",
                  " zrpc contract: spec ffi_handle contract")
    assertTextHas(specText, "`borrow`：`&T/&mut T -> T*` 仅在借用校验通过后桥接。",
                  " zrpc contract: spec borrow contract")
    assertTextHas(specText, "违规诊断携带 `ZRPC`/`no-pointer policy`。",
                  " zrpc contract: spec zrpc diagnostic anchor")

    let sliceFixture: str = "tests/cheng/backend/fixtures/ffi_importc_map_slice_ptr_len_i32.cheng"
    assertFileHas(sliceFixture, "@ffi_map(ptr = arg0, len = arg1)",
                  " zrpc contract: slice fixture ffi_map")
    assertFileHas(sliceFixture, "fn cheng_abi_sum_ptr_len_i32(xs: int32[]): int32",
                  " zrpc contract: slice fixture safe surface")

    let outPairFixture: str = "tests/cheng/backend/fixtures/ffi_outptr_tuple_importc_pair_i32.cheng"
    assertFileHas(outPairFixture, "@ffi_out_ptrs(arg0, arg1)",
                  " zrpc contract: outpair fixture annotation")
    assertFileHas(outPairFixture, "tuple[int32, int32]",
                  " zrpc contract: outpair fixture tuple")

    let outStatusFixture: str = "tests/cheng/backend/fixtures/ffi_outptr_tuple_importc_status_i32_objonly.cheng"
    assertFileHas(outStatusFixture, "@ffi_out_ptrs(arg1, arg2)",
                  " zrpc contract: outstatus fixture annotation")
    assertFileHas(outStatusFixture, "tuple[int32, int32, int32]",
                  " zrpc contract: outstatus fixture tuple")

    let outStrFixture: str = "tests/cheng/backend/fixtures/ffi_outptr_tuple_str_i64_direct_return.cheng"
    assertFileHas(outStrFixture, "@ffi_out_ptrs(arg3)",
                  " zrpc contract: outstr fixture annotation")
    assertFileHas(outStrFixture, "tuple[str, int64]",
                  " zrpc contract: outstr fixture tuple")

    let borrowFixture: str = "tests/cheng/backend/fixtures/ffi_importc_borrow_mut_pair_i32.cheng"
    assertFileHas(borrowFixture, "p: var PairI32",
                  " zrpc contract: borrow fixture var param")
    assertFileHas(borrowFixture, "var pair: PairI32",
                  " zrpc contract: borrow fixture lvalue")

    let rawSliceNegative: str = "tests/cheng/backend/fixtures/compile_fail_ffi_slice_user_raw_ptr_surface.cheng"
    assertFileHas(rawSliceNegative, "p: void*",
                  " zrpc contract: raw slice negative voidptr")
    assertFileHas(rawSliceNegative, "ptr_add(p, 1)",
                  " zrpc contract: raw slice negative ptr add")

    let voidPtrNegative: str = "tests/cheng/backend/fixtures/compile_fail_ffi_importc_voidptr_surface.cheng"
    assertFileHas(voidPtrNegative, "@importc(\"free\")",
                  " zrpc contract: voidptr negative importc")
    assertFileHas(voidPtrNegative, "fn cFree(p: void*)",
                  " zrpc contract: voidptr negative surface")

    let outArityNegative: str = "tests/cheng/backend/fixtures/compile_fail_ffi_outptr_tuple_arity_mismatch.cheng"
    assertFileHas(outArityNegative, "@ffi_out_ptrs(arg0, arg1)",
                  " zrpc contract: outptr arity negative annotation")
    assertFileHas(outArityNegative, "tuple[int32]",
                  " zrpc contract: outptr arity negative tuple")

    let borrowNonLvalueNegative: str = "tests/cheng/backend/fixtures/compile_fail_ffi_importc_borrow_mut_pair_i32_non_lvalue.cheng"
    assertFileHas(borrowNonLvalueNegative, "p: var PairI32",
                  " zrpc contract: borrow non-lvalue negative var param")
    assertFileHas(borrowNonLvalueNegative, "cheng_abi_borrow_mut_pair_i32(mkPair(), 1, -1)",
                  " zrpc contract: borrow non-lvalue negative call")

    let spawnDefaultNegative: str = "tests/cheng/backend/fixtures/compile_fail_spawn_raw_default_gate.cheng"
    assertFileHas(spawnDefaultNegative, "@thread_boundary",
                  " zrpc contract: spawn default negative boundary")
    assertFileHas(spawnDefaultNegative, "let fnPtr: void*",
                  " zrpc contract: spawn default negative raw fn")

    let spawnRawNegative: str = "tests/cheng/backend/fixtures/compile_fail_spawn_raw_ptr.cheng"
    assertFileHas(spawnRawNegative, "import std/async_rt",
                  " zrpc contract: spawn raw negative async import")
    assertFileHas(spawnRawNegative, "spawn(fnPtr, nil)",
                  " zrpc contract: spawn raw negative call")

    assertFileHas("src/tests/ffi_handle_smoke.cheng", "FfiHandleNewI32",
                  " zrpc contract: handle smoke new")
    assertFileHas("src/tests/ffi_handle_smoke.cheng", "FfiHandleReleaseI32",
                  " zrpc contract: handle smoke release")
    assertFileHas("src/tests/ffi_handle_generation_reuse_smoke.cheng", "generation bumped",
                  " zrpc contract: handle generation reuse")
    assertFileHas("src/tests/ffi_handle_generation_reuse_smoke.cheng", "alloc/free balanced",
                  " zrpc contract: handle generation memory")
    assertFileHas("src/tests/ffi_handle_stale_trap_smoke.cheng", "FfiHandleGetI32(h0)",
                  " zrpc contract: handle stale trap read")
    assertFileHas("src/tests/ffi_handle_generation_stale_trap_smoke.cheng", "cheng_tcp_buffer_handle_resolve_bridge(handle0)",
                  " zrpc contract: handle generation stale trap")

    echo(" cheng_plan_zrpc_contract_smoke ok")
    return 0
