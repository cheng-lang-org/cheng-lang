import std/system
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/binary_types as binary
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/protocols/gossipsub as gossip
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/host/host

fn smokeLightAddress(): binary.V3LsmrAddress =
    var out: binary.V3LsmrAddress
    out.depth = 2
    out.digits[0] = 4
    out.digits[1] = 2
    return out

fn main(): int32 =
    webrtc_transport.v3Libp2pWebrtcTransportResetStats()
    var server = host.v3Libp2pHostInit("browser.light.server")
    var client = host.v3Libp2pHostInit("browser.light.client")
    let address = smokeLightAddress()

    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(client, types.v3Libp2pProtocolSync)
    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolIngress)
    host.v3Libp2pRegisterHandler(client, types.v3Libp2pProtocolIngress)
    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolWebrtcSignal)
    host.v3Libp2pRegisterHandler(client, types.v3Libp2pProtocolWebrtcSignal)

    var listenAddr: types.V3Libp2pMultiaddr
    listenAddr.host = "203.0.113.145"
    listenAddr.port = 9455
    listenAddr.transport = types.v3Libp2pTransportWebrtc
    listenAddr.networkDomain = types.v3Libp2pNetworkDomainBrowserWebrtc
    listenAddr.visibility = types.v3Libp2pVisibilityPublic
    let listenRes = host.v3Libp2pListen(server, listenAddr)
    assert(listenRes.ok, "v3 webrtc browser light node: listen")

    let dialRes = host.v3Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 webrtc browser light node: dial")

    let syncPayload = bytesFromString("browser-light-sync")
    let syncCid = hash256.sha256Fixed(layout.byteSpanFromBytes(syncPayload))
    let syncSource = peer_id.v3Libp2pPeerIdFromSeed("browser.light.sync.source")
    var syncIngress = overlay.V3IngressEnvelope()
    syncIngress.sourcePeerId = syncSource.value
    syncIngress.topicScope = overlay.v3OverlayScopeRegion
    syncIngress.address = address
    syncIngress.payloadKind = 0
    syncIngress.payload = syncPayload
    syncIngress.payloadCid = syncCid
    syncIngress.payloadLen = bytesLen(syncPayload)
    syncIngress.stampEpoch = 5
    syncIngress.stampGanzhi = 10
    host.v3Libp2pStorePut(server, syncIngress)

    var query = overlay.V3StoreQuery()
    query.topicScope = overlay.v3OverlayScopeRegion
    query.address = address
    query.rangeLimit = 4

    var entries: overlay.V3IngressEnvelope[]
    let syncRes = host.v3Libp2pSyncRequest(client, server, server.selfPeerId, query, entries)
    assert(syncRes.ok, "v3 webrtc browser light node: sync")
    assert(entries.len == 1, "v3 webrtc browser light node: sync count")
    assert(layout.fixedBytes32Equal(entries[0].payloadCid, syncCid),
        "v3 webrtc browser light node: sync cid")

    let pushPayload = bytesFromString("browser-light-pubsub")
    let pushCid = hash256.sha256Fixed(layout.byteSpanFromBytes(pushPayload))
    let pushSource = peer_id.v3Libp2pPeerIdFromSeed("browser.light.push.source")
    var pushIngress = overlay.V3IngressEnvelope()
    pushIngress.sourcePeerId = pushSource.value
    pushIngress.topicScope = overlay.v3OverlayScopeRegion
    pushIngress.address = address
    pushIngress.payloadKind = 0
    pushIngress.payload = pushPayload
    pushIngress.payloadCid = pushCid
    pushIngress.payloadLen = bytesLen(pushPayload)
    pushIngress.stampEpoch = 6
    pushIngress.stampGanzhi = 12
    var pushed: overlay.V3IngressEnvelope[]
    pushed = []
    add(pushed, pushIngress)
    let pushRes = host.v3Libp2pIngressPush(client, server, server.selfPeerId, pushed)
    assert(pushRes.ok, "v3 webrtc browser light node: ingress push")

    assert(client.openStreamPeers.len == 3, "v3 webrtc browser light node: streams")
    assert(client.openStreamProtocols[0] == types.v3Libp2pProtocolSync,
        "v3 webrtc browser light node: sync stream")
    assert(client.openStreamProtocols[1] == types.v3Libp2pProtocolWebrtcSignal,
        "v3 webrtc browser light node: signal stream")
    assert(client.openStreamProtocols[2] == types.v3Libp2pProtocolIngress,
        "v3 webrtc browser light node: ingress stream")
    assert(host.v3Libp2pWebrtcSignalEgressCount(client) == 5,
        "v3 webrtc browser light node: signal reuse")
    assert(host.v3Libp2pWebrtcSignalIngressCount(server) == 5,
        "v3 webrtc browser light node: signal ingress reuse")
    assert(webrtc_transport.v3Libp2pWebrtcBrowserDatachannelOpenCountNow() == 1,
        "v3 webrtc browser light node: browser open count")
    assert(webrtc_transport.v3Libp2pWebrtcBrowserDatachannelRequestCountNow() == 2,
        "v3 webrtc browser light node: browser request count")
    assert(webrtc_transport.v3Libp2pWebrtcBrowserSessionActiveCountNow() == 1,
        "v3 webrtc browser light node: active session")
    assert(server.storeEntries.len == 2, "v3 webrtc browser light node: server store count")
    assert(server.publishLog.len == 1, "v3 webrtc browser light node: publish count")
    let expectedTopic = gossip.v3Libp2pTopicForScope(overlay.v3OverlayScopeRegion, address)
    assert(types.v3Libp2pTopicIdEqual(server.publishLog[0].topicId, expectedTopic),
        "v3 webrtc browser light node: publish topic")
    assert(layout.fixedBytes32Equal(server.publishLog[0].payloadCid, pushCid),
        "v3 webrtc browser light node: publish cid")

    echo("v3 webrtc_browser_light_node_smoke ok")
    return 0
