import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/apps/bio/bio_reed_solomon as rs

fn bioRsSmokeMessage(): rs.BioMessage16 =
    let raw: Bytes = bytesAlloc(rs.BioRsMessageBytes)
    for i in 0..<rs.BioRsMessageBytes:
        bytesSet(raw, i, (i + 1) & 255)
    let msgRes = rs.BioMessage16FromBytes(raw)
    assert(IsOk(msgRes), " bio rs smoke: message build")
    return Value(msgRes)

fn bioRsSmokeCorrupt(codeword: layout.FixedBytes32, positions: int32[]): layout.FixedBytes32 =
    var raw: Bytes = layout.fixedBytes32ToBytes(codeword)
    for i in 0..<positions.len:
        let pos = positions[i]
        bytesSet(raw, pos, bytesGet(raw, pos) ^ ((0x31 + i) & 255))
    let outRes = layout.fixedBytes32FromBytes(raw)
    assert(IsOk(outRes), " bio rs smoke: corrupt fixed32")
    return Value(outRes)

fn main(): int32 =
    let message = bioRsSmokeMessage()
    let encoded = rs.BioRsEncode16x32(message)
    let decodedRes = rs.BioRsDecode32x16(encoded)
    assert(IsOk(decodedRes), " bio rs smoke: exact decode")
    assert(bytesEqual(rs.BioMessage16ToBytes(Value(decodedRes)),
                      rs.BioMessage16ToBytes(message)),
           " bio rs smoke: exact roundtrip")

    let lightNoise = bioRsSmokeCorrupt(encoded, [0, 3, 7, 11, 16, 21, 25, 30])
    let lightDecodeRes = rs.BioRsDecode32x16(lightNoise)
    assert(IsOk(lightDecodeRes), " bio rs smoke: 8-byte decode")
    assert(bytesEqual(rs.BioMessage16ToBytes(Value(lightDecodeRes)),
                      rs.BioMessage16ToBytes(message)),
           " bio rs smoke: 8-byte roundtrip")

    let heavyNoise = bioRsSmokeCorrupt(encoded, [0, 2, 4, 6, 8, 10, 12, 14, 16])
    let heavyDecodeRes = rs.BioRsDecode32x16(heavyNoise)
    assert(IsErr(heavyDecodeRes), " bio rs smoke: 9-byte reject")

    echo(" bio_reed_solomon_smoke ok")
    return 0
