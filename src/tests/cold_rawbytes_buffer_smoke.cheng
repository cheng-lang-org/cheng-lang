import std/rawbytes
import std/buffer

fn main() =
    let b = rawbytes.BytesFromString("abcdef")
    assert(rawbytes.BytesLen(b) == 6, "cold rawbytes len")
    assert(b.data != nil, "cold rawbytes data")
    var buf = buffer.NewByteBuffer()
    buffer.AppendText(buf, "abcdef")
    buffer.AppendText(buf, "ghij")
    let out = rawbytes.BytesToString(buffer.ToBytes(buf))
    echo(out)
    assert(out == "abcdefghij", "cold buffer append text")
