import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm

fn erasureSwarmSmokeBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    let paramsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic, 3, 2, 1024)
    assert(IsOk(paramsRes), " erasure swarm smoke: params")
    let params = Value(paramsRes)

    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    let shardCid0 = lt.HashInts("cheng.erasure.smoke.shard", [0])
    let shardCid1 = lt.HashInts("cheng.erasure.smoke.shard", [1])
    let shardCid2 = lt.HashInts("cheng.erasure.smoke.shard", [2])
    let shardCid3 = lt.HashInts("cheng.erasure.smoke.shard", [3])
    let shardCid4 = lt.HashInts("cheng.erasure.smoke.shard", [4])
    add(shardPayloadCids, shardCid0)
    add(shardPayloadCids, shardCid1)
    add(shardPayloadCids, shardCid2)
    add(shardPayloadCids, shardCid3)
    add(shardPayloadCids, shardCid4)
    let blobCid = lt.HashInts("cheng.erasure.smoke.blob", [7, 9, 11])
    let manifestRes = swarm.ErasureShardManifestMake(blobCid, 3072, params, shardPayloadCids)
    assert(IsOk(manifestRes), " erasure swarm smoke: manifest")
    let manifest = Value(manifestRes)

    let densePeer = lt.HashInts("cheng.erasure.smoke.peer", [1])
    let peerA = lt.HashInts("cheng.erasure.smoke.peer", [2])
    let peerB = lt.HashInts("cheng.erasure.smoke.peer", [3])
    let peerC = lt.HashInts("cheng.erasure.smoke.peer", [4])

    let denseAdvertRes = swarm.ErasurePeerAdvertMake(densePeer, manifest, params, [0, 1, 2], 900, 3)
    assert(IsOk(denseAdvertRes), " erasure swarm smoke: dense advert")
    let advertARes = swarm.ErasurePeerAdvertMake(peerA, manifest, params, [0], 800, 1)
    assert(IsOk(advertARes), " erasure swarm smoke: advert a")
    let advertBRes = swarm.ErasurePeerAdvertMake(peerB, manifest, params, [1], 800, 1)
    assert(IsOk(advertBRes), " erasure swarm smoke: advert b")
    let advertCRes = swarm.ErasurePeerAdvertMake(peerC, manifest, params, [2], 800, 1)
    assert(IsOk(advertCRes), " erasure swarm smoke: advert c")

    var adverts: swarm.ErasurePeerAdvert[]
    adverts = []
    swarm.ErasurePeerAdvertAppend(adverts, Value(denseAdvertRes))
    swarm.ErasurePeerAdvertAppend(adverts, Value(advertARes))
    swarm.ErasurePeerAdvertAppend(adverts, Value(advertBRes))
    swarm.ErasurePeerAdvertAppend(adverts, Value(advertCRes))

    assert(swarm.ErasureCanRecover(manifest, params, adverts), " erasure swarm smoke: recoverable")
    let planRes = swarm.ErasureBuildRecoveryPlan(manifest, params, adverts)
    assert(IsOk(planRes), " erasure swarm smoke: plan")
    let plan = Value(planRes)
    let planOk = swarm.ErasureRecoveryPlanValidate(plan, manifest, params)
    assert(IsOk(planOk), " erasure swarm smoke: plan validate")
    assert(plan.minShardCount == 3, " erasure swarm smoke: threshold")
    assert(plan.requestCount == 3, " erasure swarm smoke: request count")
    assert(plan.uniquePeerCount == 3, " erasure swarm smoke: unique peers")
    assert(plan.uniqueShardCount == 3, " erasure swarm smoke: unique shards")
    assert(layout.FixedBytes32Equal(plan.requestPeerIds[0], peerA), " erasure swarm smoke: shard0 peer dedup")
    assert(layout.FixedBytes32Equal(plan.requestPeerIds[1], peerB), " erasure swarm smoke: shard1 peer dedup")
    assert(layout.FixedBytes32Equal(plan.requestPeerIds[2], peerC), " erasure swarm smoke: shard2 peer dedup")
    assert(plan.requestShardIndices[0] == 0, " erasure swarm smoke: shard0 selected")
    assert(plan.requestShardIndices[1] == 1, " erasure swarm smoke: shard1 selected")
    assert(plan.requestShardIndices[2] == 2, " erasure swarm smoke: shard2 selected")

    var insufficient: swarm.ErasurePeerAdvert[]
    insufficient = []
    swarm.ErasurePeerAdvertAppend(insufficient, Value(advertARes))
    swarm.ErasurePeerAdvertAppend(insufficient, Value(advertBRes))
    assert(!swarm.ErasureCanRecover(manifest, params, insufficient), " erasure swarm smoke: insufficient reject")
    let badPlanRes = swarm.ErasureBuildRecoveryPlan(manifest, params, insufficient)
    assert(IsErr(badPlanRes), " erasure swarm smoke: insufficient plan reject")

    let blob = bytesFromString(" erasure swarm parity rebuild")
    let encodedRes = swarm.ErasureEncodeShardPayloads(blob, params)
    assert(IsOk(encodedRes), " erasure swarm smoke: encode shards")
    let encoded = Value(encodedRes)
    assert(encoded.len == 5, " erasure swarm smoke: encoded shard count")
    var encodedCids: layout.FixedBytes32[]
    encodedCids = []
    for i in 0..<encoded.len:
        add(encodedCids, swarm.ErasureShardPayloadCid(encoded[i]))
    let realBlobCid = dag.DagBlobCidFromBytes(blob)
    let realManifestRes = swarm.ErasureShardManifestMake(realBlobCid, bytesLen(blob), params, encodedCids)
    assert(IsOk(realManifestRes), " erasure swarm smoke: real manifest")
    let realManifest = Value(realManifestRes)
    let realRebuildRes = swarm.ErasureRebuildBlob(realManifest,
                                                    params,
                                                    [0, 3, 4],
                                                    [encoded[0], encoded[3], encoded[4]])
    assert(IsOk(realRebuildRes), " erasure swarm smoke: parity rebuild")
    assert(erasureSwarmSmokeBytesEqual(Value(realRebuildRes), blob),
        " erasure swarm smoke: parity rebuild bytes")

    echo(" erasure_swarm_smoke ok")
    return 0
