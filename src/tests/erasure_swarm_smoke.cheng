import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm

fn erasureSwarmSmokeBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    let paramsRes = swarm.v3ErasureEncodingParamsMake(swarm.v3ErasureLayoutRsSystematic, 3, 2, 1024)
    assert(IsOk(paramsRes), "v3 erasure swarm smoke: params")
    let params = Value(paramsRes)

    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    let shardCid0 = lt.v3HashInts("v3.erasure.smoke.shard", [0])
    let shardCid1 = lt.v3HashInts("v3.erasure.smoke.shard", [1])
    let shardCid2 = lt.v3HashInts("v3.erasure.smoke.shard", [2])
    let shardCid3 = lt.v3HashInts("v3.erasure.smoke.shard", [3])
    let shardCid4 = lt.v3HashInts("v3.erasure.smoke.shard", [4])
    add(shardPayloadCids, shardCid0)
    add(shardPayloadCids, shardCid1)
    add(shardPayloadCids, shardCid2)
    add(shardPayloadCids, shardCid3)
    add(shardPayloadCids, shardCid4)
    let blobCid = lt.v3HashInts("v3.erasure.smoke.blob", [7, 9, 11])
    let manifestRes = swarm.v3ErasureShardManifestMake(blobCid, 3072, params, shardPayloadCids)
    assert(IsOk(manifestRes), "v3 erasure swarm smoke: manifest")
    let manifest = Value(manifestRes)

    let densePeer = lt.v3HashInts("v3.erasure.smoke.peer", [1])
    let peerA = lt.v3HashInts("v3.erasure.smoke.peer", [2])
    let peerB = lt.v3HashInts("v3.erasure.smoke.peer", [3])
    let peerC = lt.v3HashInts("v3.erasure.smoke.peer", [4])

    let denseAdvertRes = swarm.v3ErasurePeerAdvertMake(densePeer, manifest, params, [0, 1, 2], 900, 3)
    assert(IsOk(denseAdvertRes), "v3 erasure swarm smoke: dense advert")
    let advertARes = swarm.v3ErasurePeerAdvertMake(peerA, manifest, params, [0], 800, 1)
    assert(IsOk(advertARes), "v3 erasure swarm smoke: advert a")
    let advertBRes = swarm.v3ErasurePeerAdvertMake(peerB, manifest, params, [1], 800, 1)
    assert(IsOk(advertBRes), "v3 erasure swarm smoke: advert b")
    let advertCRes = swarm.v3ErasurePeerAdvertMake(peerC, manifest, params, [2], 800, 1)
    assert(IsOk(advertCRes), "v3 erasure swarm smoke: advert c")

    var adverts: swarm.V3ErasurePeerAdvert[]
    adverts = []
    swarm.v3ErasurePeerAdvertAppend(adverts, Value(denseAdvertRes))
    swarm.v3ErasurePeerAdvertAppend(adverts, Value(advertARes))
    swarm.v3ErasurePeerAdvertAppend(adverts, Value(advertBRes))
    swarm.v3ErasurePeerAdvertAppend(adverts, Value(advertCRes))

    assert(swarm.v3ErasureCanRecover(manifest, params, adverts), "v3 erasure swarm smoke: recoverable")
    let planRes = swarm.v3ErasureBuildRecoveryPlan(manifest, params, adverts)
    assert(IsOk(planRes), "v3 erasure swarm smoke: plan")
    let plan = Value(planRes)
    let planOk = swarm.v3ErasureRecoveryPlanValidate(plan, manifest, params)
    assert(IsOk(planOk), "v3 erasure swarm smoke: plan validate")
    assert(plan.minShardCount == 3, "v3 erasure swarm smoke: threshold")
    assert(plan.requestCount == 3, "v3 erasure swarm smoke: request count")
    assert(plan.uniquePeerCount == 3, "v3 erasure swarm smoke: unique peers")
    assert(plan.uniqueShardCount == 3, "v3 erasure swarm smoke: unique shards")
    assert(layout.fixedBytes32Equal(plan.requestPeerIds[0], peerA), "v3 erasure swarm smoke: shard0 peer dedup")
    assert(layout.fixedBytes32Equal(plan.requestPeerIds[1], peerB), "v3 erasure swarm smoke: shard1 peer dedup")
    assert(layout.fixedBytes32Equal(plan.requestPeerIds[2], peerC), "v3 erasure swarm smoke: shard2 peer dedup")
    assert(plan.requestShardIndices[0] == 0, "v3 erasure swarm smoke: shard0 selected")
    assert(plan.requestShardIndices[1] == 1, "v3 erasure swarm smoke: shard1 selected")
    assert(plan.requestShardIndices[2] == 2, "v3 erasure swarm smoke: shard2 selected")

    var insufficient: swarm.V3ErasurePeerAdvert[]
    insufficient = []
    swarm.v3ErasurePeerAdvertAppend(insufficient, Value(advertARes))
    swarm.v3ErasurePeerAdvertAppend(insufficient, Value(advertBRes))
    assert(!swarm.v3ErasureCanRecover(manifest, params, insufficient), "v3 erasure swarm smoke: insufficient reject")
    let badPlanRes = swarm.v3ErasureBuildRecoveryPlan(manifest, params, insufficient)
    assert(IsErr(badPlanRes), "v3 erasure swarm smoke: insufficient plan reject")

    let blob = bytesFromString("v3 erasure swarm parity rebuild")
    let encodedRes = swarm.v3ErasureEncodeShardPayloads(blob, params)
    assert(IsOk(encodedRes), "v3 erasure swarm smoke: encode shards")
    let encoded = Value(encodedRes)
    assert(encoded.len == 5, "v3 erasure swarm smoke: encoded shard count")
    var encodedCids: layout.FixedBytes32[]
    encodedCids = []
    for i in 0..<encoded.len:
        add(encodedCids, swarm.v3ErasureShardPayloadCid(encoded[i]))
    let realBlobCid = dag.v3DagBlobCidFromBytes(blob)
    let realManifestRes = swarm.v3ErasureShardManifestMake(realBlobCid, bytesLen(blob), params, encodedCids)
    assert(IsOk(realManifestRes), "v3 erasure swarm smoke: real manifest")
    let realManifest = Value(realManifestRes)
    let realRebuildRes = swarm.v3ErasureRebuildBlob(realManifest,
                                                    params,
                                                    [0, 3, 4],
                                                    [encoded[0], encoded[3], encoded[4]])
    assert(IsOk(realRebuildRes), "v3 erasure swarm smoke: parity rebuild")
    assert(erasureSwarmSmokeBytesEqual(Value(realRebuildRes), blob),
        "v3 erasure swarm smoke: parity rebuild bytes")

    echo("v3 erasure_swarm_smoke ok")
    return 0
