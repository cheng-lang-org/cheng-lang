@importc("ct_str_ptr_check")
fn ct_str_ptr_check(data: ptr, tag: int32): int32

fn main(): int32 =
    let value: str = "cold-str-ptr"
    let literalRc = ct_str_ptr_check("literal-data", 1)
    if literalRc != 0:
        return 10 + literalRc
    let valueRc = ct_str_ptr_check(value, 2)
    if valueRc != 0:
        return 20 + valueRc
    return 0
