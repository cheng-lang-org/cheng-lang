import std/cmdline as cmdline
import std/os
import std/strings

fn ensureDir(path: str) =
    if !os.DirExists(path):
        os.CreateDir(path)

fn currentExecutablePath(root: str): str =
    let raw = cmdline.ProgramName()
    if len(raw) <= 0:
        return ""
    if os.IsAbsolute(raw):
        return raw
    return os.JoinPath(root, raw)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let exePath = currentExecutablePath(root)
    assert(len(exePath) > 0 && os.FileExists(exePath),
           "cheng backend driver candidate output: executable path")
    let exeParts = os.SplitFile(exePath)
    let exeDir = exeParts.dir
    let exeName = exeParts.name
    let workspaceName = exeName + ".workspace"
    let outDir = os.JoinPath(exeDir, workspaceName)
    ensureDir(outDir)
    assert(os.DirExists(outDir), "cheng backend driver candidate output: mkdir")

    let backendDriver = os.JoinPath(root, "artifacts/backend_driver/cheng")
    let buildLog = os.JoinPath(root, "artifacts/backend_driver/build_backend_driver.log")
    let compileReport = os.JoinPath(root, "artifacts/backend_driver/build_backend_driver.compile.report.txt")
    let verifyExportParallelLog = os.JoinPath(root, "artifacts/backend_driver/build_backend_driver.verify_export_visibility_parallel.txt")
    assert(os.FileExists(backendDriver), "cheng backend driver candidate output: backend driver exists")
    assert(os.FileExists(backendDriver), "cheng backend driver candidate output: installed output")
    assert(os.FileExists(buildLog), "cheng backend driver candidate output: build log")
    assert(os.FileExists(compileReport), "cheng backend driver candidate output: compile report")
    assert(os.FileExists(verifyExportParallelLog), "cheng backend driver candidate output: verify export parallel log")
    let buildLogText = os.ReadFile(buildLog)
    assert(strings.StrContains(buildLogText, "artifacts/backend_driver/cheng.build_candidate"),
           "cheng backend driver candidate output: candidate path recorded")
    echo("cheng backend_driver_candidate_output_smoke ok")
    return 0
