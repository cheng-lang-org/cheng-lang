import std/system
import std/result
import cheng/quic/platform/datapath_udp as qudp

fn main(): int32 =
    let parsedRes = qudp.udpParseAddr("/ip4/127.0.0.1/udp/6210/quic-v1")
    assert(IsOk(parsedRes), "udp parse multiaddr failed")
    let parsed = Value(parsedRes)
    assert(parsed.host == "127.0.0.1", "udp parse multiaddr: host")
    assert(parsed.port == 6210, "udp parse multiaddr: port")
    assert(! parsed.isV6, "udp parse multiaddr: family")
    echo(" udp_parse_multiaddr_smoke ok")
    return 0
