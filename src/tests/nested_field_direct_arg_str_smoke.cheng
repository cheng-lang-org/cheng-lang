import std/strutils as strutil

type
    NestedFieldDirectArgInner =
        text: str

    NestedFieldDirectArgOuter =
        inner: NestedFieldDirectArgInner

    NestedFieldDirectArgWorldHead =
        universeId: str
        channel: str
        signature: str
        headEpoch: int32

    NestedFieldDirectArgLocalUniverse =
        compilerSnapshot: str
        stdSnapshot: str
        runtimeSnapshot: str
        worldHead: NestedFieldDirectArgWorldHead

    NestedFieldDirectArgSystemLinkPlan =
        packageId: str
        targetTriple: str
        outputPath: str

    NestedFieldDirectArgPlan =
        compilerEntrySource: str
        systemLinkPlan: NestedFieldDirectArgSystemLinkPlan
        localUniverse: NestedFieldDirectArgLocalUniverse
        compileReceipt: str
        note0: str
        note1: str
        note2: str

fn nestedFieldDirectArgNormalize(raw: str): str =
    return strutil.Strip(raw)

fn nestedFieldDirectArgFromParam(value: NestedFieldDirectArgOuter): str =
    return nestedFieldDirectArgNormalize(value.inner.text)

fn nestedFieldDirectArgFromPlan(plan: NestedFieldDirectArgPlan): str =
    return nestedFieldDirectArgNormalize(plan.localUniverse.worldHead.channel)

fn main(): int32 =
    let value = NestedFieldDirectArgOuter(
        inner: NestedFieldDirectArgInner(
            text: " stable "
        )
    )
    let direct = nestedFieldDirectArgNormalize(value.inner.text)
    assert(direct == "stable", " nested field direct arg direct")
    let fromParam = nestedFieldDirectArgFromParam(value)
    assert(fromParam == "stable", " nested field direct arg from param")
    let viaLocal = value.inner.text
    let local = nestedFieldDirectArgNormalize(viaLocal)
    assert(local == "stable", " nested field direct arg local")
    let plan = NestedFieldDirectArgPlan(
        compilerEntrySource: "entry",
        systemLinkPlan: NestedFieldDirectArgSystemLinkPlan(
            packageId: "cheng/tests/nested_field_direct_arg_str_smoke",
            targetTriple: "arm64-apple-darwin",
            outputPath: "/tmp/nested-field-direct"
        ),
        localUniverse: NestedFieldDirectArgLocalUniverse(
            compilerSnapshot: "compiler",
            stdSnapshot: "std",
            runtimeSnapshot: "runtime",
            worldHead: NestedFieldDirectArgWorldHead(
                universeId: "cheng/compiler_universe",
                channel: " stable ",
                signature: "sig",
                headEpoch: 1
            )
        ),
        compileReceipt: "receipt",
        note0: "n0",
        note1: "n1",
        note2: "n2"
    )
    let fromPlan = nestedFieldDirectArgFromPlan(plan)
    assert(fromPlan == "stable", " nested field direct arg from plan")
    echo(" nested_field_direct_arg_str_smoke ok")
    return 0
