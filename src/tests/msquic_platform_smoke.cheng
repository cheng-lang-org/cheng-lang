import std/system
import std/result
import cheng/quic/platform/common
import cheng/quic/platform/platform_matrix
import cheng/quic/platform/datapath_model
import cheng/quic/platform/datapath_runtime
import cheng/quic/platform/release_validation
import cheng/quic/msquicruntime

fn main(): int32 =
    let matrix = platform_matrix.initMsQuicPlatformMatrix()
    assert(matrix.count > 0, " msquic platform: matrix non-empty")
    assert(platform_matrix.msquicPlatformMatrixHas(matrix, common.MsQuicPlatformLinux),
        " msquic platform: matrix has linux")
    assert(platform_matrix.msquicPlatformMatrixSupportsHighPerf(matrix, common.MsQuicPlatformLinux),
        " msquic platform: linux highperf")

    var rt = datapath_runtime.initMsQuicDatapathRuntime()
    let idRes = datapath_runtime.msquicDatapathAdd(rt, int32(datapath_model.MsQuicDatapathBasic))
    if IsErr(idRes):
        panic(ErrorText(idRes))
    let id = Value(idRes)
    let startRes = datapath_runtime.msquicDatapathStart(rt, id)
    if IsErr(startRes):
        panic(ErrorText(startRes))
    let sendRes = datapath_runtime.msquicDatapathRecordSend(rt, id, 64)
    if IsErr(sendRes):
        panic(ErrorText(sendRes))
    let recvRes = datapath_runtime.msquicDatapathRecordRecv(rt, id, 32)
    if IsErr(recvRes):
        panic(ErrorText(recvRes))
    let summary = datapath_runtime.msquicDatapathSummary(rt, id)
    assert(len(summary) > 0, " msquic platform: datapath summary")

    let settings = msquicruntime.initMsQuicSettings()
    let validRes = release_validation.msquicReleaseValidateSettings(settings)
    if IsErr(validRes):
        panic(ErrorText(validRes))
    let relRes = release_validation.msquicReleaseValidatePlatform(common.MsQuicPlatformLinux)
    if IsErr(relRes):
        panic(ErrorText(relRes))
    let relSummary = release_validation.msquicReleaseValidationSummary(common.MsQuicPlatformLinux, settings)
    assert(len(relSummary) > 0, " msquic platform: release summary")

    echo(" msquic_platform_smoke ok")
    return 0
