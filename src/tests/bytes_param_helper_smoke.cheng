import std/system
import std/crypto/sha256
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt

fn bytesDiffer(a: Bytes, b: Bytes): bool =
    if a.len != b.len:
        return true
    for i in 0..<a.len:
        if bytesGet(a, i) != bytesGet(b, i):
            return true
    return false

fn main(): int32 =
    var probeBufA = layout.byteBufInit(16)
    var probeBufB = layout.byteBufInit(16)
    lt.v3AppendU32BE(probeBufA, 1)
    lt.v3AppendU32BE(probeBufB, 2)
    let probeSpanA = layout.byteBufView(probeBufA)
    let probeSpanB = layout.byteBufView(probeBufB)
    let rawDigestA = sha256.sha256Digest(probeSpanA.data)
    let rawDigestB = sha256.sha256Digest(probeSpanB.data)
    assert(bytesDiffer(rawDigestA, rawDigestB),
           "v3 bytes param helper: digest bytes differ")
    echo("v3 bytes_param_helper_smoke ok")
    return 0
