type
    V3IfEnumScalarSmoke = enum
        v3IfEnumScalarSmokeNo
        v3IfEnumScalarSmokeYes

fn v3IfEnumScalarReturn(flag: V3IfEnumScalarSmoke): int32 =
    if flag == v3IfEnumScalarSmokeYes:
        return 1
    return 0

fn main(): int32 =
    assert(v3IfEnumScalarReturn(v3IfEnumScalarSmokeYes) == 1, "v3 if enum scalar return: yes")
    assert(v3IfEnumScalarReturn(v3IfEnumScalarSmokeNo) == 0, "v3 if enum scalar return: no")
    echo("v3 if_enum_scalar_return_smoke ok")
    return 0
