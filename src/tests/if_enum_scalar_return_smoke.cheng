type
    IfEnumScalarSmoke = enum
        IfEnumScalarSmokeNo
        IfEnumScalarSmokeYes

fn IfEnumScalarReturn(flag: IfEnumScalarSmoke): int32 =
    if flag == IfEnumScalarSmokeYes:
        return 1
    return 0

fn main(): int32 =
    assert(IfEnumScalarReturn(IfEnumScalarSmokeYes) == 1, " if enum scalar return: yes")
    assert(IfEnumScalarReturn(IfEnumScalarSmokeNo) == 0, " if enum scalar return: no")
    echo(" if_enum_scalar_return_smoke ok")
    return 0
