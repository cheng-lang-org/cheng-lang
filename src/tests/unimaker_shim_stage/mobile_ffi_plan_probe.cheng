    return gMoqRequestWire.data

@exportc("cheng_mobile_host_moq_request_wire_len_bridge")
fn cheng_mobile_host_moq_request_wire_len_bridge_export(): int32 =
    return gMoqRequestWire.len

fn initPeerState(): PeerState =
    var out: PeerState
    return out

fn initMessageState(): MessageState =
    var out: MessageState
    return out

fn initMomentState(): MomentState =
    var out: MomentState
    return out

fn initNotificationState(): NotificationState =
    var out: NotificationState
    return out

fn initPublishTaskState(): PublishTaskState =
    var out: PublishTaskState
    out.visibility = "public"
    return out

fn initReportState(): ReportState =
    var out: ReportState
    return out

fn resetNodeSlot(slot: int32) =
    ensureNodeStorage()
    if slot < 0 || slot >= len(gNodes):
        return
    gNodes[slot] = initNodeState()

fn allocNodeSlot(): int32 =
    ensureNodeStorage()
    for i in 0..<len(gNodes):
        if !gNodes[i].used:
            return i
    return -1

fn findNodeByHandle(handle: int64): int32 =
    ensureNodeStorage()
    if handle <= 0:
        return -1
    for i in 0..<len(gNodes):
        if gNodes[i].used && gNodes[i].handle == handle:
            return i
    return -1

fn findNodeByPeerId(peerIdText: str): int32 =
    ensureNodeStorage()
    let want: str = trimText(peerIdText)
    if len(want) <= 0:
        return -1
    for i in 0..<len(gNodes):
        if gNodes[i].used && nodeLocalPeerId(i) == want:
            return i
    return -1

fn nodeLocalPeerId(idx: int32): str =
    ensureNodeStorage()
    if idx < 0 || idx >= len(gNodes):
        return ""
    if !gNodes[idx].used:
        return ""
    return gNodes[idx].localPeerId

fn normalizePeerId(peerIdText: str): str =
    let raw: str = trimText(peerIdText)
    if len(raw) <= 0:
        return ""
    let fromMultiaddr: str = hostMultiaddrPeerId(raw)
    if len(fromMultiaddr) > 0:
        return fromMultiaddr
    if len(raw) < 8:
        return ""
    return raw

fn derivePeerId(seed: str): str =
    let seedText: str = trimText(seed)
    if len(seedText) <= 0:
        return ""
    return stablePeerIdFromSeed(seedText)

fn parsePeerIdText(configText: str): str =
    let camel: str = trimText(parseConfigQuotedValue(configText, "peerId"))
    if len(camel) > 0:
        return camel
    let snake: str = trimText(parseConfigQuotedValue(configText, "peer_id"))
    if len(snake) > 0:
        return snake
    return ""

fn dialAddrWithPeer(addr: str, peerIdText: str): str =
    let base: str = trimText(addr)
    let peerText: str = trimText(peerIdText)
    if len(base) <= 0 || len(peerText) <= 0:
        return ""
    if strContains(base, "/p2p/") || strContains(base, "/ipfs/"):
        return base
    let normalizedPeer: str = normalizePeerId(peerText)
    if len(normalizedPeer) <= 0:
        return ""
    return base + "/p2p/" + normalizedPeer

fn parseDataDir(configText: str): str =
    let camel: str = trimText(parseConfigQuotedValue(configText, "dataDir"))
    if len(camel) > 0:
        return camel
    let snake: str = trimText(parseConfigQuotedValue(configText, "data_dir"))
    if len(snake) > 0:
        return snake
    return "/tmp/unimaker-mobile"

fn parseListenAddr(configText: str): str =
    let listenValues: str[] = parseConfigArrayValues(configText, "listenAddresses")
    if len(listenValues) > 0:
        let firstListen: str = trimText(listenValues[0])
        if len(firstListen) > 0:
            return firstListen
    let single: str = trimText(parseConfigQuotedValue(configText, "listenAddress"))
    if len(single) > 0:
        return single
    return "/ip4/0.0.0.0/udp/4001/webrtc-direct"

fn parseSeedText(configText: str, dataDir: str, listenAddr: str): str =
    var value: str = trimText(parseConfigQuotedValue(configText, "deviceDid"))
    if len(value) > 0:
        return value
    value = trimText(parseConfigQuotedValue(configText, "device_did"))
    if len(value) > 0:
        return value
    value = trimText(parseConfigQuotedValue(configText, "did"))
    if len(value) > 0:
        return value
    value = trimText(parseConfigQuotedValue(configText, "peerSeed"))
    if len(value) > 0:
        return value
    value = trimText(parseConfigQuotedValue(configText, "peer_seed"))
    if len(value) > 0:
        return value
    value = trimText(parseConfigQuotedValue(configText, "seed"))
    if len(value) > 0:
        return value
    value = trimText(parseConfigQuotedValue(configText, "private_key_hex"))
    if len(value) > 0:
        return value
    return dataDir + "|" + listenAddr + "|seed"

fn appendNodeEventJson(idx: int32, eventJson: str) =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return
    if gNodes[idx].eventCount < maxEvents:
        gNodes[idx].events[gNodes[idx].eventCount] = eventJson
        gNodes[idx].eventCount = gNodes[idx].eventCount + 1
    else:
        for i in 1..<maxEvents:
            gNodes[idx].events[i - 1] = gNodes[idx].events[i]
        gNodes[idx].events[maxEvents - 1] = eventJson

fn emitNodeEvent(idx: int32, eventKind: str, payloadJson: str) =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return
    let nowText: str = strings.int64ToStr(nowMs())
    let eventJson: str =
        "{" +
        "\"kind\":" + toJsonStringValue(eventKind) + "," +
        "\"payload\":" + payloadJson + "," +
        "\"timestampMs\":" + nowText +
        "}"
    appendNodeEventJson(idx, eventJson)

fn socialDmReceivedPayloadJson(peerIdText: str,
                               conversationIdText: str,
                               messageIdText: str,
                               payloadJson: str,
                               timestampMs: int64): str =
    let peerId: str = trimText(peerIdText)
    let conversationId: str = trimText(conversationIdText)
    let messageId: str = trimText(messageIdText)
    let timestampText: str = strings.int64ToStr(timestampMs)
    let fields: str =
        "\"kind\":\"social\"," +
        "\"entity\":\"dm\"," +
        "\"op\":\"recv\"," +
        "\"peerId\":" + toJsonStringValue(peerId) + "," +
        "\"from\":" + toJsonStringValue(peerId) + "," +
        "\"conversationId\":" + toJsonStringValue(conversationId) + "," +
        "\"messageId\":" + toJsonStringValue(messageId) + "," +
        "\"mid\":" + toJsonStringValue(messageId) + "," +
        "\"timestampMs\":" + timestampText + "," +
        "\"timestamp_ms\":" + timestampText
    let payloadBodyText: str = trimText(payloadJson)
    if len(payloadBodyText) > 1 && startsWith(payloadBodyText, "{") && hostEndsWith(payloadBodyText, "}"):
        return sliceBytes(payloadBodyText, 0, len(payloadBodyText) - 1) + "," + fields + "}"
    return "{" + fields + ",\"body\":" + toJsonStringValue(payloadBodyText) + ",\"content\":" + toJsonStringValue(payloadBodyText) + ",\"text\":" + toJsonStringValue(payloadBodyText) + "}"

fn drainHostMessageEventsJsonText(stateIdx: int32, limit: int32): str =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return "[]"
    let total: int32 = gNodes[stateIdx].hostMessageCount
    if total <= 0:
        return "[]"
    var safeLimit: int32 = limit
    if safeLimit <= 0 || safeLimit > total:
        safeLimit = total
    var startAt: int32
    if total > safeLimit:
        startAt = total - safeLimit
    var out: str = "["
    var wrote: bool
    for i in startAt..<total:
        let message: HostMessageState = gNodes[stateIdx].hostMessages[i]
        if message.used:
            if wrote:
                out = out + ","
            let eventPayload: str = socialDmReceivedPayloadJson(
                message.peerId,
                message.conversationId,
                message.messageId,
                message.payloadJson,
                message.timestampMs
            )
            out = out +
                "{" +
                "\"kind\":\"social\"," +
                "\"entity\":\"dm\"," +
                "\"op\":\"recv\"," +
                "\"peerId\":" + toJsonStringValue(message.peerId) + "," +
                "\"conversationId\":" + toJsonStringValue(message.conversationId) + "," +
                "\"messageId\":" + toJsonStringValue(message.messageId) + "," +
                "\"payload\":" + eventPayload + "," +
                "\"timestampMs\":" + strings.int64ToStr(message.timestampMs) +
                "}"
            wrote = true
    out = out + "]"
    for i in 0..<total:
        gNodes[stateIdx].hostMessages[i] = initHostMessageState()
    gNodes[stateIdx].hostMessageCount = 0
    return out

fn emitSocialDmReceivedEvent(idx: int32,
                             peerIdText: str,
                             conversationIdText: str,
                             messageIdText: str,
                             payloadJson: str,
                             timestampMs: int64) =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return
    let peerId: str = trimText(peerIdText)
    let conversationId: str = trimText(conversationIdText)
    let messageId: str = trimText(messageIdText)
    let timestampText: str = strings.int64ToStr(timestampMs)
    let eventPayload: str = socialDmReceivedPayloadJson(peerId, conversationId, messageId, payloadJson, timestampMs)
    let eventJson: str =
        "{" +
        "\"kind\":\"social\"," +
        "\"entity\":\"dm\"," +
        "\"op\":\"recv\"," +
        "\"peerId\":" + toJsonStringValue(peerId) + "," +
        "\"conversationId\":" + toJsonStringValue(conversationId) + "," +
        "\"messageId\":" + toJsonStringValue(messageId) + "," +
        "\"payload\":" + eventPayload + "," +
        "\"timestampMs\":" + timestampText +
        "}"
    appendNodeEventJson(idx, eventJson)

fn ensurePeerSlot(idx: int32, peerIdText: str): int32 =
    let normalized: str = normalizePeerId(peerIdText)
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || len(normalized) <= 0:
        return -1
    for i in 0..<gNodes[idx].peerCount:
        if gNodes[idx].peers[i].used && gNodes[idx].peers[i].peerId == normalized:
            return i
    if gNodes[idx].peerCount >= maxPeers:
        return -1
    let slot: int32 = gNodes[idx].peerCount
    var peer: PeerState = initPeerState()
    peer.used = true
    peer.peerId = normalized
    peer.lastSeenAtMs = nowMs()
    gNodes[idx].peers[slot] = peer
    gNodes[idx].peerCount = gNodes[idx].peerCount + 1
    return slot

fn mergePeerAddress(idx: int32, peerSlot: int32, addrText: str) =
    let value: str = trimText(addrText)
    if idx < 0 || idx >= maxNodes || peerSlot < 0 || peerSlot >= gNodes[idx].peerCount || len(value) <= 0:
        return
    for i in 0..<gNodes[idx].peers[peerSlot].addrCount:
        if gNodes[idx].peers[peerSlot].addrs[i] == value:
            return
    if gNodes[idx].peers[peerSlot].addrCount < maxPeerAddrs:
        let slot: int32 = gNodes[idx].peers[peerSlot].addrCount
        gNodes[idx].peers[peerSlot].addrs[slot] = value
        gNodes[idx].peers[peerSlot].addrCount = gNodes[idx].peers[peerSlot].addrCount + 1

fn connectPeerLocal(idx: int32, peerIdText: str, source: str): bool =
    let normalized: str = normalizePeerId(peerIdText)
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || len(normalized) <= 0:
        return false
    let peerSlot: int32 = ensurePeerSlot(idx, normalized)
    if peerSlot < 0:
        return false
    gNodes[idx].peers[peerSlot].connected = true
    gNodes[idx].peers[peerSlot].source = source
    gNodes[idx].peers[peerSlot].lastSeenAtMs = nowMs()
    let remoteIdx: int32 = findNodeByPeerId(normalized)
    if remoteIdx >= 0:
        let localSlot: int32 = ensurePeerSlot(remoteIdx, nodeLocalPeerId(idx))
        if localSlot >= 0:
            gNodes[remoteIdx].peers[localSlot].connected = true
            gNodes[remoteIdx].peers[localSlot].source = source
            gNodes[remoteIdx].peers[localSlot].lastSeenAtMs = nowMs()
    return true

fn registerPeerHintsLocal(handle: int64, peerIdTextRaw: str, addressesJsonTextRaw: str, sourceTextRaw: str): bool =
    clearLastError()
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        setLastError("register_peer_hints: invalid handle")
        return false
    var peerIdText: str = normalizePeerId(trimText(peerIdTextRaw))
    let addrs: str[] = parseQuotedValues(addressesJsonTextRaw)
    if len(peerIdText) <= 0 && len(addrs) > 0:
        peerIdText = normalizePeerId(addrs[0])
    if len(peerIdText) <= 0:
        return true
    let slot: int32 = ensurePeerSlot(idx, peerIdText)
    if slot < 0:
        setLastError("register_peer_hints: slot full")
        return false
    let sourceText: str = trimText(sourceTextRaw)
    gNodes[idx].peers[slot].source = sourceText
    for i in 0..<len(addrs):
        let addrText: str = trimText(addrs[i])
        mergePeerAddress(idx, slot, addrText)
        let hintIpv4: str = hostExtractIpv4FromMultiaddr(addrText)
        if len(hintIpv4) > 0:
            let _ = upsertHostPeer(idx, peerIdText, addrText, if len(sourceText) > 0: sourceText else: "peer_hints")
    return true

fn connectPeerHandle(handle: int64, peerIdTextRaw: str, source: str): int32 =
    clearLastError()
    let idx: int32 = findNodeByHandle(handle)
    let peerIdText: str = normalizePeerId(trimText(peerIdTextRaw))
    if idx < 0 || len(peerIdText) <= 0:
        setLastError("connect_peer: invalid args")
        return resultError
    if !connectPeerLocal(idx, peerIdText, source):
        setLastError("connect_peer: failed")
        return resultError
    return resultOk

fn clearConnectedPeer(idx: int32, peerIdText: str) =
    let normalized: str = normalizePeerId(peerIdText)
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || len(normalized) <= 0:
        return
    for i in 0..<gNodes[idx].peerCount:
        if gNodes[idx].peers[i].used && gNodes[idx].peers[i].peerId == normalized:
            gNodes[idx].peers[i].connected = false
            gNodes[idx].peers[i].lastSeenAtMs = nowMs()
            break

fn hasConnectedPeer(idx: int32, peerIdText: str): bool =
    let normalized: str = normalizePeerId(peerIdText)
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return false
    if len(normalized) <= 0:
        for i in 0..<gNodes[idx].peerCount:
            if gNodes[idx].peers[i].used && gNodes[idx].peers[i].connected:
                return true
        return false
    for i in 0..<gNodes[idx].peerCount:
        if gNodes[idx].peers[i].used && gNodes[idx].peers[i].peerId == normalized && gNodes[idx].peers[i].connected:
            return true
    return false

fn appendMessage(idx: int32,
                 peerIdText: str,
                 conversationIdText: str,
                 messageIdText: str,
                 payloadJson: str,
                 direction: str,
                 status: str) =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return
    var slot: int32 = gNodes[idx].messageCount
    if slot >= maxMessages:
        for i in 1..<maxMessages:
            gNodes[idx].messages[i - 1] = gNodes[idx].messages[i]
        slot = maxMessages - 1
    else:
        gNodes[idx].messageCount = gNodes[idx].messageCount + 1
    var message: MessageState = initMessageState()
    message.used = true
    message.peerId = normalizePeerId(peerIdText)
    message.conversationId = trimText(conversationIdText)
    message.messageId = trimText(messageIdText)
    message.payloadJson = payloadJson
    message.direction = direction
    message.status = status
    message.timestampMs = nowMs()
    gNodes[idx].messages[slot] = message

fn connectedPeersJson(idx: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    var out: str = "["
    var wrote: bool
    for i in 0..<gNodes[idx].peerCount:
        if !gNodes[idx].peers[i].used || !gNodes[idx].peers[i].connected:
            continue
        if wrote:
            out = out + ","
        out = out + toJsonStringValue(gNodes[idx].peers[i].peerId)
        wrote = true
    out = out + "]"
    return out

fn peerInfoJson(idx: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    var out: str = "["
    var wrote: bool
    for i in 0..<gNodes[idx].peerCount:
        if !gNodes[idx].peers[i].used:
            continue
        if wrote:
            out = out + ","
        out = out + "{"
        out = out + "\"peerId\":" + toJsonStringValue(gNodes[idx].peers[i].peerId) + ","
        out = out + "\"connected\":" + boolText(gNodes[idx].peers[i].connected) + ","
        out = out + "\"source\":" + toJsonStringValue(gNodes[idx].peers[i].source) + ","
        out = out + "\"lastSeenAtMs\":" + strings.int64ToStr(gNodes[idx].peers[i].lastSeenAtMs)
        out = out + "}"
        wrote = true
    out = out + "]"
    return out

fn peerMultiaddrsJson(idx: int32, peerIdText: str): str =
    let normalized: str = normalizePeerId(peerIdText)
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || len(normalized) <= 0:
        return "[]"
    for i in 0..<gNodes[idx].peerCount:
        if !gNodes[idx].peers[i].used || gNodes[idx].peers[i].peerId != normalized:
            continue
        var out: str = "["
        var wrote: bool
        for j in 0..<gNodes[idx].peers[i].addrCount:
            if wrote:
                out = out + ","
            out = out + toJsonStringValue(gNodes[idx].peers[i].addrs[j])
            wrote = true
        out = out + "]"
        return out
    return "[]"

fn discoveredPeersJson(idx: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    var out: str = "["
    var wrote: bool
    for i in 0..<gNodes[idx].peerCount:
        if !gNodes[idx].peers[i].used:
            continue
        if wrote:
            out = out + ","
        out = out + "{"
        out = out + "\"peerId\":" + toJsonStringValue(gNodes[idx].peers[i].peerId) + ","
        out = out + "\"source\":" + toJsonStringValue(gNodes[idx].peers[i].source) + ","
        out = out + "\"connected\":" + boolText(gNodes[idx].peers[i].connected)
        out = out + "}"
        wrote = true
    out = out + "]"
    return out

fn drainNodeEvents(idx: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || gNodes[idx].eventCount <= 0:
        return "[]"
    let total: int32 = gNodes[idx].eventCount
    var out: str = "["
    var wrote: bool
    var readIdx: int32
    while readIdx < total:
        let eventJson: str = gNodes[idx].events[readIdx]
        if len(eventJson) <= 0:
            readIdx = readIdx + 1
            continue
        if wrote:
            out = out + ","
        out = out + eventJson
        wrote = true
        readIdx = readIdx + 1
    out = out + "]"
    var clearIdx: int32
    while clearIdx < total:
        gNodes[idx].events[clearIdx] = ""
        clearIdx = clearIdx + 1
    gNodes[idx].eventCount = 0
    return out

fn receivedMessagesJson(idx: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || gNodes[idx].messageCount <= 0:
        return "[]"
    var out: str = "["
    var wrote: bool
    for i in 0..<gNodes[idx].messageCount:
        if !gNodes[idx].messages[i].used:
            continue
        if wrote:
            out = out + ","
        out = out + "{"
        out = out + "\"peerId\":" + toJsonStringValue(gNodes[idx].messages[i].peerId) + ","
        out = out + "\"conversationId\":" + toJsonStringValue(gNodes[idx].messages[i].conversationId) + ","
        out = out + "\"messageId\":" + toJsonStringValue(gNodes[idx].messages[i].messageId) + ","
        out = out + "\"payload\":" + gNodes[idx].messages[i].payloadJson + ","
        out = out + "\"direction\":" + toJsonStringValue(gNodes[idx].messages[i].direction) + ","
        out = out + "\"status\":" + toJsonStringValue(gNodes[idx].messages[i].status) + ","
        out = out + "\"timestampMs\":" + strings.int64ToStr(gNodes[idx].messages[i].timestampMs)
        out = out + "}"
        wrote = true
    out = out + "]"
    return out

fn feedSnapshotJson(idx: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "{\"entries\":[]}"
    var out: str = "{\"entries\":["
    for i in 0..<gNodes[idx].feedItemCount:
        if i > 0:
            out = out + ","
        out = out + gNodes[idx].feedItems[i]
    out = out + "]}"
    return out

fn momentsTimelineJson(idx: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    var out: str = "["
    for i in 0..<gNodes[idx].momentCount:
        if i > 0:
            out = out + ","
        out = out + gNodes[idx].moments[i].payloadJson
    out = out + "]"
    return out

fn notificationsListJson(idx: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    var out: str = "["
    for i in 0..<gNodes[idx].notificationCount:
        if i > 0:
            out = out + ","
        out = out + gNodes[idx].notifications[i].payloadJson
    out = out + "]"
    return out

fn notificationsSummaryJson(idx: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "{\"unreadTotal\":0,\"unreadPriority\":0,\"unreadByChannel\":{},\"unreadByEvent\":{}}"
    var unread: int32
    for i in 0..<gNodes[idx].notificationCount:
        if gNodes[idx].notifications[i].used && !gNodes[idx].notifications[i].read:
            unread = unread + 1
    return "{" +
        "\"unreadTotal\":" + strings.IntToStr(unread) + "," +
        "\"unreadPriority\":0," +
        "\"unreadByChannel\":{}," +
        "\"unreadByEvent\":{}" +
        "}"

fn addFeedEntry(idx: int32, payloadJson: str) =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return
    var slot: int32 = gNodes[idx].feedItemCount
    if slot >= maxFeedItems:
        for i in 1..<maxFeedItems:
            gNodes[idx].feedItems[i - 1] = gNodes[idx].feedItems[i]
        slot = maxFeedItems - 1
    else:
        gNodes[idx].feedItemCount = gNodes[idx].feedItemCount + 1
    gNodes[idx].feedItems[slot] = payloadJson

fn findMomentSlot(idx: int32, postIdText: str): int32 =
    let want: str = trimText(postIdText)
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || len(want) <= 0:
        return -1
    for i in 0..<gNodes[idx].momentCount:
        if gNodes[idx].moments[i].used && gNodes[idx].moments[i].postId == want:
            return i
    return -1

fn addMoment(idx: int32, postIdText: str, payloadJson: str) =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return
    var slot: int32 = findMomentSlot(idx, postIdText)
    if slot < 0:
        if gNodes[idx].momentCount < maxMoments:
            slot = gNodes[idx].momentCount
            gNodes[idx].momentCount = gNodes[idx].momentCount + 1
        else:
            slot = maxMoments - 1
    var moment: MomentState = initMomentState()
    moment.used = true
    moment.postId = postIdText
    moment.payloadJson = payloadJson
    moment.timestampMs = nowMs()
    gNodes[idx].moments[slot] = moment

fn addNotification(idx: int32, payloadJson: str) =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return
    var slot: int32 = gNodes[idx].notificationCount
    if slot >= maxNotifications:
        for i in 1..<maxNotifications:
            gNodes[idx].notifications[i - 1] = gNodes[idx].notifications[i]
        slot = maxNotifications - 1
    else:
        gNodes[idx].notificationCount = gNodes[idx].notificationCount + 1
    var notification: NotificationState = initNotificationState()
    notification.used = true
    notification.notificationId = "notif-" + strings.int64ToStr(nowMs()) + "-" + strings.IntToStr(slot)
    notification.payloadJson = payloadJson
    notification.timestampMs = nowMs()
    gNodes[idx].notifications[slot] = notification

fn jsonItemsEnvelope(itemsJson: str): str =
    return "{" +
        "\"items\":" + itemsJson + "," +
        "\"nextCursor\":\"\"," +
        "\"hasMore\":false" +
        "}"

fn jsonSummaryEnvelope(itemsJson: str, summaryJson: str): str =
    return "{" +
        "\"items\":" + itemsJson + "," +
        "\"summary\":" + summaryJson + "," +
        "\"nextCursor\":\"\"," +
        "\"hasMore\":false" +
        "}"

fn unsupportedListJson(name: str): str =
    setLastError(name + "_not_implemented")
    return jsonItemsEnvelope("[]")

fn unsupportedObjectJson(name: str): str =
    setLastError(name + "_not_implemented")
    return unsupportedJson(name)

fn unsupportedBool(name: str): bool =
    setLastError(name + "_not_implemented")
    return false

fn unsupportedInt(name: str): int32 =
    setLastError(name + "_not_implemented")
    return resultError

fn countConnectedPeers(idx: int32): int32 =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return 0
    var total: int32
    for i in 0..<gNodes[idx].peerCount:
        if gNodes[idx].peers[i].used && gNodes[idx].peers[i].connected:
            total = total + 1
    return total

fn peerListJson(idx: int32, limit: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    var safeLimit: int32 = limit
    if safeLimit <= 0 || safeLimit > gNodes[idx].peerCount:
        safeLimit = gNodes[idx].peerCount
    var out: str = "["
    var wrote: bool
    var emitted: int32
    for i in 0..<gNodes[idx].peerCount:
        if !gNodes[idx].peers[i].used || emitted >= safeLimit:
            continue
        if wrote:
            out = out + ","
        out = out + "{"
        out = out + "\"peerId\":" + toJsonStringValue(gNodes[idx].peers[i].peerId) + ","
        out = out + "\"source\":" + toJsonStringValue(gNodes[idx].peers[i].source) + ","
        out = out + "\"connected\":" + boolText(gNodes[idx].peers[i].connected) + ","
        out = out + "\"addresses\":" + peerMultiaddrsJson(idx, gNodes[idx].peers[i].peerId)
        out = out + "}"
        wrote = true
        emitted = emitted + 1
    out = out + "]"
    return out

fn feedItemsJson(idx: int32, limit: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    let total: int32 = gNodes[idx].feedItemCount
    if total <= 0:
        return "[]"
    var safeLimit: int32 = limit
    if safeLimit <= 0 || safeLimit > total:
        safeLimit = total
    var startAt: int32
    if total > safeLimit:
        startAt = total - safeLimit
    var out: str = "["
    var wrote: bool
    for i in startAt..<total:
        if wrote:
            out = out + ","
        out = out + gNodes[idx].feedItems[i]
        wrote = true
    out = out + "]"
    return out

fn momentItemsJson(idx: int32, limit: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    let total: int32 = gNodes[idx].momentCount
    if total <= 0:
        return "[]"
    var safeLimit: int32 = limit
    if safeLimit <= 0 || safeLimit > total:
        safeLimit = total
    var startAt: int32
    if total > safeLimit:
        startAt = total - safeLimit
    var out: str = "["
    var wrote: bool
    for i in startAt..<total:
        if !gNodes[idx].moments[i].used:
            continue
        if wrote:
            out = out + ","
        out = out + gNodes[idx].moments[i].payloadJson
        wrote = true
    out = out + "]"
    return out

fn notificationItemsJson(idx: int32, limit: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    let total: int32 = gNodes[idx].notificationCount
    if total <= 0:
        return "[]"
    var safeLimit: int32 = limit
    if safeLimit <= 0 || safeLimit > total:
        safeLimit = total
    var startAt: int32
    if total > safeLimit:
        startAt = total - safeLimit
    var out: str = "["
    var wrote: bool
    for i in startAt..<total:
        if !gNodes[idx].notifications[i].used:
            continue
        if wrote:
            out = out + ","
        out = out + gNodes[idx].notifications[i].payloadJson
        wrote = true
    out = out + "]"
    return out

fn directMessageItemsJson(idx: int32, limit: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    let total: int32 = gNodes[idx].messageCount
    if total <= 0:
        return "[]"
    var safeLimit: int32 = limit
    if safeLimit <= 0 || safeLimit > total:
        safeLimit = total
    var startAt: int32
    if total > safeLimit:
        startAt = total - safeLimit
    var out: str = "["
    var wrote: bool
    for i in startAt..<total:
        if !gNodes[idx].messages[i].used:
            continue
        if wrote:
            out = out + ","
        out = out + "{"
        out = out + "\"peerId\":" + toJsonStringValue(gNodes[idx].messages[i].peerId) + ","
        out = out + "\"conversationId\":" + toJsonStringValue(gNodes[idx].messages[i].conversationId) + ","
        out = out + "\"messageId\":" + toJsonStringValue(gNodes[idx].messages[i].messageId) + ","
        out = out + "\"payload\":" + gNodes[idx].messages[i].payloadJson + ","
        out = out + "\"direction\":" + toJsonStringValue(gNodes[idx].messages[i].direction) + ","
        out = out + "\"status\":" + toJsonStringValue(gNodes[idx].messages[i].status) + ","
        out = out + "\"timestampMs\":" + strings.int64ToStr(gNodes[idx].messages[i].timestampMs)
        out = out + "}"
        wrote = true
    out = out + "]"
    return out

fn findPublishTaskSlot(idx: int32, taskIdText: str): int32 =
    let want: str = trimText(taskIdText)
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || len(want) <= 0:
        return -1
    for i in 0..<gNodes[idx].publishTaskCount:
        if gNodes[idx].publishTasks[i].used && gNodes[idx].publishTasks[i].taskId == want:
            return i
    return -1

fn findPublishTaskByContentId(idx: int32, contentIdText: str): int32 =
    let want: str = trimText(contentIdText)
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || len(want) <= 0:
        return -1
    for i in 0..<gNodes[idx].publishTaskCount:
        if gNodes[idx].publishTasks[i].used && gNodes[idx].publishTasks[i].contentId == want:
            return i
    return -1

fn taskField(payloadJson: str, keyName: str): str =
    return trimText(parseConfigQuotedValue(payloadJson, keyName))

fn publishTaskJson(idx: int32, slot: int32): str =
    var out: str = "{"
    out = out + "\"id\":" + toJsonStringValue(gNodes[idx].publishTasks[slot].contentId)
    out = out + ",\"taskId\":" + toJsonStringValue(gNodes[idx].publishTasks[slot].taskId)
    out = out + ",\"contentId\":" + toJsonStringValue(gNodes[idx].publishTasks[slot].contentId)
    out = out + ",\"postId\":" + toJsonStringValue(gNodes[idx].publishTasks[slot].contentId)
    out = out + ",\"type\":" + toJsonStringValue(taskField(gNodes[idx].publishTasks[slot].payloadJson, "type"))
    out = out + ",\"title\":" + toJsonStringValue(taskField(gNodes[idx].publishTasks[slot].payloadJson, "title"))
    out = out + ",\"content\":" + toJsonStringValue(taskField(gNodes[idx].publishTasks[slot].payloadJson, "content"))
    out = out + ",\"summary\":" + toJsonStringValue(taskField(gNodes[idx].publishTasks[slot].payloadJson, "summary"))
    out = out + ",\"publishState\":" + toJsonStringValue(gNodes[idx].publishTasks[slot].publishState)
    out = out + ",\"reasonCode\":" + toJsonStringValue(gNodes[idx].publishTasks[slot].reasonCode)
    out = out + ",\"visibility\":" + toJsonStringValue(gNodes[idx].publishTasks[slot].visibility)
    out = out + ",\"homeEligible\":" + boolText(gNodes[idx].publishTasks[slot].homeEligible)
    out = out + ",\"tombstoned\":" + boolText(gNodes[idx].publishTasks[slot].tombstoned)
    out = out + ",\"createdAt\":" + strings.int64ToStr(gNodes[idx].publishTasks[slot].createdAtMs)
    out = out + ",\"updatedAt\":" + strings.int64ToStr(gNodes[idx].publishTasks[slot].updatedAtMs)
    out = out + ",\"payload\":" + gNodes[idx].publishTasks[slot].payloadJson
    out = out + "}"
    return out

fn publishTaskItemsJson(idx: int32, limit: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    let total: int32 = gNodes[idx].publishTaskCount
    if total <= 0:
        return "[]"
    var safeLimit: int32 = limit
    if safeLimit <= 0 || safeLimit > total:
        safeLimit = total
    var startAt: int32
    if total > safeLimit:
        startAt = total - safeLimit
    var out: str = "["
    var wrote: bool
    for i in startAt..<total:
        if !gNodes[idx].publishTasks[i].used:
            continue
        if wrote:
            out = out + ","
        out = out + publishTaskJson(idx, i)
        wrote = true
    out = out + "]"
    return out

fn upsertPublishTask(idx: int32, contentIdText: str, payloadJson: str): int32 =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return -1
    let normalizedContentId: str = trimText(contentIdText)
    if len(normalizedContentId) <= 0:
        return -1
    var slot: int32 = findPublishTaskByContentId(idx, normalizedContentId)
    if slot < 0:
        if gNodes[idx].publishTaskCount < maxPublishTasks:
            slot = gNodes[idx].publishTaskCount
            gNodes[idx].publishTaskCount = gNodes[idx].publishTaskCount + 1
        else:
            slot = maxPublishTasks - 1
        gNodes[idx].publishTasks[slot] = initPublishTaskState()
        gNodes[idx].publishTasks[slot].used = true
        gNodes[idx].publishTasks[slot].taskId =
            "task-" + strings.int64ToStr(nowMs()) + "-" + strings.int64ToStr(gNodes[idx].nextTaskNonce)
        gNodes[idx].nextTaskNonce = gNodes[idx].nextTaskNonce + 1
        gNodes[idx].publishTasks[slot].contentId = normalizedContentId
        gNodes[idx].publishTasks[slot].createdAtMs = nowMs()
    gNodes[idx].publishTasks[slot].payloadJson = payloadJson
    gNodes[idx].publishTasks[slot].publishState = "published"
    gNodes[idx].publishTasks[slot].reasonCode = ""
    gNodes[idx].publishTasks[slot].homeEligible = true
    gNodes[idx].publishTasks[slot].updatedAtMs = nowMs()
    return slot

fn reportJson(idx: int32, slot: int32): str =
    return "{" +
        "\"reportId\":" + toJsonStringValue(gNodes[idx].reports[slot].reportId) + "," +
        "\"createdAt\":" + strings.int64ToStr(gNodes[idx].reports[slot].createdAtMs) + "," +
        "\"payload\":" + gNodes[idx].reports[slot].payloadJson +
        "}"

fn reportItemsJson(idx: int32, limit: int32): str =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return "[]"
    let total: int32 = gNodes[idx].reportCount
    if total <= 0:
        return "[]"
    var safeLimit: int32 = limit
    if safeLimit <= 0 || safeLimit > total:
        safeLimit = total
    var startAt: int32
    if total > safeLimit:
        startAt = total - safeLimit
    var out: str = "["
    var wrote: bool
    for i in startAt..<total:
        if !gNodes[idx].reports[i].used:
            continue
        if wrote:
            out = out + ","
        out = out + reportJson(idx, i)
        wrote = true
    out = out + "]"
    return out

fn sharedFileIndex(idx: int32, keyText: str): int32 =
    let keyValue: str = trimText(keyText)
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || len(keyValue) <= 0:
        return -1
    let total: int32 =
        if gNodes[idx].sharedFileCount < maxSharedFiles:
            gNodes[idx].sharedFileCount
        else:
            maxSharedFiles
    for i in 0..<total:
        if gNodes[idx].sharedFiles[i].used && trimText(gNodes[idx].sharedFiles[i].key) == keyValue:
            return i
    return -1

fn upsertSharedFile(idx: int32,
                    keyText: str,
                    pathText: str,
                    fileNameText: str,
                    mimeTypeText: str,
                    sha256Text: str,
                    sizeBytes: int64): int32 =
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used:
        return -1
    let keyValue: str = trimText(keyText)
    let pathValue: str = normalizeFsPath(pathText)
    if len(keyValue) <= 0 || len(pathValue) <= 0 || !fileExists(pathValue):
        return -1
    var slot: int32 = sharedFileIndex(idx, keyValue)
    if slot < 0:
        if gNodes[idx].sharedFileCount < maxSharedFiles:
            slot = gNodes[idx].sharedFileCount
            gNodes[idx].sharedFileCount = gNodes[idx].sharedFileCount + 1
        else:
            slot = maxSharedFiles - 1
    gNodes[idx].sharedFiles[slot].used = true
    gNodes[idx].sharedFiles[slot].key = keyValue
    gNodes[idx].sharedFiles[slot].path = pathValue
    gNodes[idx].sharedFiles[slot].fileName = trimText(fileNameText)
    if len(gNodes[idx].sharedFiles[slot].fileName) <= 0:
        gNodes[idx].sharedFiles[slot].fileName = baseName(pathValue)
    gNodes[idx].sharedFiles[slot].mimeType = trimText(mimeTypeText)
    gNodes[idx].sharedFiles[slot].sha256 = trimText(sha256Text)
    gNodes[idx].sharedFiles[slot].sizeBytes =
        if sizeBytes > 0:
            sizeBytes
        else:
            fileSizeBytes(pathValue)
    gNodes[idx].sharedFiles[slot].registeredAtMs = nowMs()
    return slot

fn fileProvidersJson(idx: int32, keyText: str, limit: int32): str =
    let keyValue: str = trimText(keyText)
    if idx < 0 || idx >= maxNodes || !gNodes[idx].used || len(keyValue) <= 0:
        return "{\"providers\":[],\"count\":0}"
    let fileIdx: int32 = sharedFileIndex(idx, keyValue)
    if fileIdx < 0 || !fileExists(gNodes[idx].sharedFiles[fileIdx].path):
        return "{\"providers\":[],\"count\":0}"
    let maxCount: int32 = if limit > 0: limit else: 8
    var out: str = "{\"providers\":["
    var emitted: int32
    let localPeer: str = trimText(gNodes[idx].localPeerId)
    if len(localPeer) > 0 && emitted < maxCount:
        out = out + toJsonStringValue(localPeer)
        emitted = emitted + 1
    out = out + "],\"count\":" + strings.IntToStr(emitted) + "}"
    return out


@exportc("libp2p_get_last_error")
fn libp2p_get_last_error(): str =
    return cStr(gLastError)

@exportc("libp2p_string_free")
fn libp2p_string_free(value: str) =
    let _ = value
    return

@exportc("libp2p_generate_identity_json")
fn libp2p_generate_identity_json(): str =
    clearLastError()
    let seedText: str = "generate|" + strings.int64ToStr(nowMs())
    let peerIdText: str = derivePeerId(seedText)
    return cStr("{\"peerId\":" + toJsonStringValue(peerIdText) + "}")

@exportc("libp2p_identity_from_seed")
fn libp2p_identity_from_seed(seed: str, seedLen: int64): str =
    clearLastError()
    let rawSeed: str = (seed)
    if len(rawSeed) <= 0 || seedLen <= 0:
        setLastError("identity_from_seed: seed invalid")
        return cStr("{\"ok\":false}")
    var seedText: str = rawSeed
    if int64(len(rawSeed)) > seedLen:
        seedText = sliceBytes(rawSeed, 0, int32(seedLen))
    let peerIdText: str = derivePeerId(seedText)
    return cStr("{\"peerId\":" + toJsonStringValue(peerIdText) + "}")

@exportc("libp2p_identity_from_seed_text")
fn libp2p_identity_from_seed_text(seed: str): str =
    clearLastError()
    let seedText: str = trimText((seed))
    if len(seedText) <= 0:
        setLastError("identity_from_seed_text: seed invalid")
        return cStr("{\"ok\":false}")
    return cStr("{\"peerId\":" + toJsonStringValue(derivePeerId(seedText)) + "}")

@exportc("libp2p_identity_from_seed_text_cstr")
fn libp2p_identity_from_seed_text_cstr(seedRaw: cstring): str =
    let seedText: str = borrowImportedText(seedRaw)
    return libp2p_identity_from_seed_text(seedText)

@exportc("libp2p_debug_cstr_len")
fn libp2p_debug_cstr_len(rawText: cstring): int32 =
    let text: str = borrowImportedText(rawText)
    return len(text)

fn nodeInitCstrCore(configJsonRaw: cstring, stopAfterStep: int32, commit: bool): int64 =
    clearLastError()
    writeNodeInitStage("node_init_cstr:enter")
    let configTextRaw: str = borrowImportedText(configJsonRaw)
    if stopAfterStep == 0:
        writeNodeInitStage("node_init_cstr:probe_after_copy")
        return 1000
    writeNodeInitStage("node_init_cstr:after_copy")
    var configText: str = "{}"
    if len(configTextRaw) > 0:
        configText = configTextRaw
    if stopAfterStep == 1:
        writeNodeInitStage("node_init_cstr:probe_after_config")
        return 1001
    writeNodeInitStage("node_init_cstr:after_config")
    let slot: int32 = allocNodeSlot()
    if slot < 0:
        setLastError("node_init_cstr: slot full")
        writeNodeInitStage("node_init_cstr:slot_full")
        return 0
    if stopAfterStep == 20:
        writeNodeInitStage("node_init_cstr:probe_after_alloc_only")
        return 2000 + int64(slot)
    if stopAfterStep == 21:
        writeNodeInitStage("node_init_cstr:probe_after_alloc_before_reset")
        resetNodeSlot(slot)
        return 2100 + int64(slot)
    if stopAfterStep == 2:
        writeNodeInitStage("node_init_cstr:probe_after_slot")
        resetNodeSlot(slot)
        return 1002
    writeNodeInitStage("node_init_cstr:after_slot")
    let dataDir: str = parseDataDir(configText)
    if stopAfterStep == 3:
        writeNodeInitStage("node_init_cstr:probe_after_data_dir")
        resetNodeSlot(slot)
        return 1003
    writeNodeInitStage("node_init_cstr:after_data_dir")
    let listenAddr: str = parseListenAddr(configText)
    if stopAfterStep == 4:
        writeNodeInitStage("node_init_cstr:probe_after_listen_addr")
        resetNodeSlot(slot)
        return 1004
    writeNodeInitStage("node_init_cstr:after_listen_addr")
    let seedText: str = parseSeedText(configText, dataDir, listenAddr)
    if stopAfterStep == 5:
        writeNodeInitStage("node_init_cstr:probe_after_seed")
        resetNodeSlot(slot)
        return 1005
    writeNodeInitStage("node_init_cstr:after_seed")
    resetNodeSlot(slot)
    if stopAfterStep == 6:
        writeNodeInitStage("node_init_cstr:probe_after_reset")
        resetNodeSlot(slot)
        return 1006
    writeNodeInitStage("node_init_cstr:after_init_node")
    var peerIdText: str = parsePeerIdText(configText)
    if len(peerIdText) <= 0:
        peerIdText = derivePeerId(seedText)
    if stopAfterStep == 7:
        writeNodeInitStage("node_init_cstr:probe_after_peer_id")
        resetNodeSlot(slot)
        return 1007
    gNodes[slot].used = true
    gNodes[slot].handle = int64(slot + 1)
    if stopAfterStep == 8:
        writeNodeInitStage("node_init_cstr:probe_after_handle")
        resetNodeSlot(slot)
        return 1008
    gNodes[slot].dataDir = dataDir
    gNodes[slot].listenAddr = listenAddr
    if stopAfterStep == 9:
        writeNodeInitStage("node_init_cstr:probe_after_addrs")
        resetNodeSlot(slot)
        return 1009
    if stopAfterStep == 10:
        writeNodeInitStage("node_init_cstr:probe_before_last_peer")
        resetNodeSlot(slot)
        return 1010
    writeNodeInitStage("node_init_cstr:after_peer_id")
    if stopAfterStep == 11:
        writeNodeInitStage("node_init_cstr:probe_after_peer_stage")
        resetNodeSlot(slot)
        return 1011
    gNodes[slot].localPeerId = sliceBytes(peerIdText, 0, len(peerIdText))
    if stopAfterStep == 12:
        writeNodeInitStage("node_init_cstr:probe_after_local_peer")
        resetNodeSlot(slot)
        return 1012
    writeNodeInitStage("node_init_cstr:after_store")
    if stopAfterStep == 13:
        writeNodeInitStage("node_init_cstr:probe_after_store")
        resetNodeSlot(slot)
        return 1013
    if !commit:
        resetNodeSlot(slot)
        return 1014
    return gNodes[slot].handle

@exportc("libp2p_node_init")
fn libp2p_node_init(configJson: str): int64 =
    clearLastError()
    let configTextRaw: str = (configJson)
    var configText: str = "{}"
    if len(configTextRaw) > 0:
        configText = configTextRaw
    let slot: int32 = allocNodeSlot()
    if slot < 0:
        setLastError("node_init: slot full")
        return 0
    let dataDir: str = parseDataDir(configText)
    let listenAddr: str = parseListenAddr(configText)
    let seedText: str = parseSeedText(configText, dataDir, listenAddr)
    resetNodeSlot(slot)
    var peerIdText: str = parsePeerIdText(configText)
    if len(peerIdText) <= 0:
        peerIdText = derivePeerId(seedText)
    gNodes[slot].used = true
    gNodes[slot].handle = int64(slot + 1)
    gNodes[slot].dataDir = dataDir
    gNodes[slot].localPeerId = sliceBytes(peerIdText, 0, len(peerIdText))
    gNodes[slot].listenAddr = listenAddr
    return gNodes[slot].handle

@exportc("libp2p_node_init_cstr")
fn libp2p_node_init_cstr(configJsonRaw: cstring): int64 =
    return nodeInitCstrCore(configJsonRaw, -1, true)

