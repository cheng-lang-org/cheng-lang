@exportc("libp2p_join_via_random_bootstrap")
fn libp2p_join_via_random_bootstrap(handle: int64, limit: int32): str =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return cStr("{\"ok\":false,\"connected\":0}")
    var safeLimit: int32 = limit
    if safeLimit <= 0 || safeLimit > gNodes[idx].peerCount:
        safeLimit = gNodes[idx].peerCount
    var connected: int32
    for i in 0..<safeLimit:
        if gNodes[idx].peers[i].used && connectPeerLocal(idx, gNodes[idx].peers[i].peerId, "wan"):
            connected = connected + 1
    return cStr("{" +
        "\"ok\":true," +
        "\"connected\":" + strings.IntToStr(connected) + "," +
        "\"items\":" + peerListJson(idx, safeLimit) +
        "}")

