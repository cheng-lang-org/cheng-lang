fn socialNotificationsMarkPayload(handle: int64, payloadBodyText: str): str =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return unsupportedObjectJson("social_notifications_mark")
    let ids: str[] = parseConfigArrayValues(payloadBodyText, "ids")
    let markAll: bool = parseConfigHasKey(payloadBodyText, "markAll") || parseConfigHasKey(payloadBodyText, "mark_all")
    if markAll || len(ids) <= 0:
        for i in 0..<gNodes[idx].notificationCount:
            if gNodes[idx].notifications[i].used:
                gNodes[idx].notifications[i].read = true
    else:
        for i in 0..<len(ids):
            let targetId: str = trimText(ids[i])
            for j in 0..<gNodes[idx].notificationCount:
                if gNodes[idx].notifications[j].used && gNodes[idx].notifications[j].notificationId == targetId:
                    gNodes[idx].notifications[j].read = true
    return notificationsSummaryJson(idx)

