    let intervalText: str = strings.IntToStr(gNodes[idx].mdnsIntervalSeconds)
    return cStr(
        "{" +
        "\"enabled\":" + boolText(gNodes[idx].mdnsEnabled) + "," +
        "\"intervalSeconds\":" + intervalText + "," +
        "\"interface\":" + toJsonStringValue(gNodes[idx].mdnsInterface) + "," +
        "\"standardPort\":" + strings.IntToStr(standardMdnsPort) + "," +
        "\"standardFdReady\":" + boolText(gNodes[idx].hostMdnsFd > 0) +
        "}"
    )

