const
    resultOk = 0
    resultError = -1
    maxNodes = 8
    maxPeers = 128
    maxPeerAddrs = 8
    maxEvents = 128
    maxFeedItems = 128
    maxMessages = 256
    maxMoments = 128
    maxNotifications = 128
    maxPublishTasks = 128
    maxReports = 128
    maxSharedFiles = 64
    fileSeekEnd = 2
    mediaRpcProtocol = "unimaker.media.rpc.v1"
    mediaRpcBinaryChunkBytes = 1536
    stablePeerPrefix = "12D3KooW"
    maxHostPeers = 128
    maxHostMessages = 256
    hostDiscoveryPort = 48651
    hostDiscoveryLegacyPort = 53530
    hostDiscoveryPayloadBytes = 2048
    standardMdnsPort = 5353
    standardMdnsGroup = "224.0.0.251"
    standardMdnsPayloadBytes = 9000
    standardMdnsPrimaryService = "_p2p._udp.local"
    standardMdnsUnimakerService = "_unimaker._udp.local"
    standardMdnsLegacyService = "_libp2p._udp.local"
    standardMdnsMetaService = "_services._dns-sd._udp.local"
    standardDnsTypePtr = 12
    standardDnsTypeTxt = 16
    standardDnsClassIn = 1
    standardDnsCacheFlush = 32768
    standardDnsResponseFlags = 33792
    standardDnsTtlSeconds = 120
    standardDnsMaxLabelBytes = 63
    standardDnsMaxPointerJumps = 16
    standardIpAddMembership = 35
    standardIpMulticastIf = 32
    standardIpMulticastTtl = 33
    standardIpMulticastLoop = 34
    standardSoReusePort = 15
    hostRecvDontWaitLinuxFlag = 64
    hostSockaddrInLen = 16
    hostPeerFreshWindowMs32 = 45000
    asiVoiceSchema = "unimaker.asi.voice.v1"
    restoredComposerDictationGate = "4100906017"
    restoredGlobalDictationGate = "1244621283"
    restoredDictationMinRecordingMs = 250
    restoredDictationHoldToTalkDelayMs = 150
    restoredDictationEndpoint = "/transcribe"
    restoredDictationBase64Header = "X-Codex-Base64"
    restoredDictationTransport = "getUserMedia -> MediaRecorder -> multipart/form-data -> /transcribe -> transcript"
    restoredRealtimeTransport = "getUserMedia -> RTCPeerConnection -> oai-events datachannel"
    restoredRealtimeDataChannel = "oai-events"
    restoredRealtimeStartRoute = "thread/realtime/start"
    restoredRealtimeStopRoute = "thread/realtime/stop"
    restoredRealtimeAppendTextRoute = "thread/realtime/appendText"
    restoredRealtimeWebRtcTransportType = "webrtc"
    restoredRealtimeStartedEvent = "thread/realtime/started"
    restoredRealtimeSdpEvent = "thread/realtime/sdp"
    restoredRealtimeTranscriptDeltaEvent = "thread/realtime/transcript/delta"
    restoredRealtimeTranscriptDoneEvent = "thread/realtime/transcript/done"
    restoredRealtimeErrorEvent = "thread/realtime/error"
    restoredRealtimeClosedEvent = "thread/realtime/closed"
    restoredRealtimeOutputAudioStartedEvent = "output_audio_buffer.started"

type
    PeerState =
        used: bool
        connected: bool
        peerId: str
        source: str
        addrCount: int32
        addrs: str[maxPeerAddrs]
        lastSeenAtMs: int64

    MessageState =
        used: bool
        peerId: str
        conversationId: str
        messageId: str
        payloadJson: str
        direction: str
        status: str
        timestampMs: int64

    MomentState =
        used: bool
        postId: str
        payloadJson: str
        likeCount: int32
        commentCount: int32
        comments: str[16]
        timestampMs: int64

    NotificationState =
        used: bool
        notificationId: str
        payloadJson: str
        read: bool
        timestampMs: int64

    PublishTaskState =
        used: bool
        taskId: str
        contentId: str
        payloadJson: str
        publishState: str
        reasonCode: str
        visibility: str
        homeEligible: bool
        tombstoned: bool
        createdAtMs: int64
        updatedAtMs: int64

    ReportState =
        used: bool
        reportId: str
        payloadJson: str
        createdAtMs: int64

    SharedFileState =
        used: bool
        key: str
        path: str
        fileName: str
        mimeType: str
        sha256: str
        sizeBytes: int64
        registeredAtMs: int64

    HostPeerState =
        used: bool
        peerId: str
        addr: str
        connected: bool
        source: str
        lastSeenAtMs: int64

    HostMessageState =
        used: bool
        peerId: str
        conversationId: str
        messageId: str
        payloadJson: str
        timestampMs: int64

    HostDnsPacket =
        bytes: rawbytes.Bytes
        len: int32

    NodeState =
        used: bool
        handle: int64
        started: bool
        dataDir: str
        localPeerId: str
        listenAddr: str
        mdnsEnabled: bool
        mdnsIntervalSeconds: int32
        mdnsInterface: str
        lastDirectError: str
        hostNetworkStatusJson: str
        hostDiscoveryFd: int32
        hostMdnsFd: int32
        hostPeerCount: int32
        hostPeers: HostPeerState[maxHostPeers]
        hostMessageCount: int32
        hostMessages: HostMessageState[maxHostMessages]
        hostLastDiscoveredPeerId: str
        hostLastDiscoveredAddr: str
        hostLastDiscoveredAtMs: int64
        nextMessageNonce: int64
        nextPostNonce: int64
        nextNotificationNonce: int64
        nextTaskNonce: int64
        nextReportNonce: int64
        peerCount: int32
        peers: PeerState[maxPeers]
        eventCount: int32
        events: str[maxEvents]
        messageCount: int32
        messages: MessageState[maxMessages]
        feedItemCount: int32
        feedItems: str[maxFeedItems]
        momentCount: int32
        moments: MomentState[maxMoments]
        notificationCount: int32
        notifications: NotificationState[maxNotifications]
        publishTaskCount: int32
        publishTasks: PublishTaskState[maxPublishTasks]
        reportCount: int32
        reports: ReportState[maxReports]
        sharedFileCount: int32
        sharedFiles: SharedFileState[maxSharedFiles]
        lastChunkSize: int32

var
    gLastError: str
    gLastInitStage: str
    gMoqRequestPath: str
    gMoqBlob: rawbytes.Bytes
    gMoqRequestWire: rawbytes.Bytes
    gNodes: NodeState[]
    gNodesSeqBootstrapped: bool
    gHostMdnsInterfaceIpv4: str


fn cStr(text: str): str =
    return text

fn cstrToText(text: str): str =
    return text

fn borrowImportedText(raw: cstring): str =
    if ptr(raw) == nil:
        return ""
    return system.strFromCStringCopy(raw)

fn dupText(text: str): cstring =
    let n: int32 = system.strLenFast(text)
    if n <= 0:
        return system.driver_c_new_string(0)
    return system.driver_c_new_string_copy_n(system.strDataPtr(text), n)

fn hostPeersJson(handle: int64, limit: int32): str =
    if handle <= 0:
        return ""
    return trimText(borrowImportedText(hostDumpPeersLimit(handle, limit)))

fn hostReceivedMessagesJson(handle: int64, limit: int32): str =
    if handle <= 0:
        return ""
    return trimText(borrowImportedText(um_host_direct_drain_messages_json(handle, limit)))

fn initHostPeerState(): HostPeerState =
    var out: HostPeerState
    return out

fn initHostMessageState(): HostMessageState =
    var out: HostMessageState
    return out

fn initNodeState(): NodeState =
    var out: NodeState
    out.mdnsIntervalSeconds = 15
    out.hostNetworkStatusJson = "{}"
    out.hostDiscoveryFd = -1
    out.hostMdnsFd = -1
    return out

fn nodeSeqPtr(): ptr =
    return &gNodes

fn bootstrapNodeStorage() =
    if gNodesSeqBootstrapped:
        return
    let seqPtr: ptr = nodeSeqPtr()
    system.chengSeqHdrLenSet(seqPtr, 0)
    system.chengSeqHdrCapSet(seqPtr, 0)
    system.chengSeqHdrBufferSet(seqPtr, nil)
    gNodesSeqBootstrapped = true

fn ensureNodeStorage() =
    bootstrapNodeStorage()
    while len(gNodes) < maxNodes:
        add(gNodes, initNodeState())

fn hostStateNodeIndex(stateIdx: int32): int32 =
    ensureNodeStorage()
    if stateIdx < 0 || stateIdx >= len(gNodes) || !gNodes[stateIdx].used:
        return -1
    return stateIdx

fn ensureHostStateSlot(handle: int64): int32 =
    ensureNodeStorage()
    let slot: int32 = findNodeByHandle(handle)
    if slot < 0:
        return -1
    if gNodes[slot].hostDiscoveryFd == 0:
        gNodes[slot].hostDiscoveryFd = -1
    if gNodes[slot].hostMdnsFd == 0:
        gNodes[slot].hostMdnsFd = -1
    return slot

fn clearHostStateByHandle(handle: int64) =
    ensureNodeStorage()
    let slot: int32 = findNodeByHandle(handle)
    if slot < 0:
        return
    if gNodes[slot].hostDiscoveryFd > 0:
        let _ = libc_close_bridge(gNodes[slot].hostDiscoveryFd)
    gNodes[slot].hostDiscoveryFd = -1
    if gNodes[slot].hostMdnsFd > 0:
        let _ = libc_close_bridge(gNodes[slot].hostMdnsFd)
    gNodes[slot].hostMdnsFd = -1
    gNodes[slot].hostPeerCount = 0
    gNodes[slot].hostMessageCount = 0
    gNodes[slot].hostLastDiscoveredPeerId = ""
    gNodes[slot].hostLastDiscoveredAddr = ""
    gNodes[slot].hostLastDiscoveredAtMs = 0

fn closeHostMdnsSocketsForInterfaceChange() =
    ensureNodeStorage()
    for i in 0..<len(gNodes):
        if gNodes[i].used:
            if gNodes[i].hostDiscoveryFd > 0:
                let _ = libc_close_bridge(gNodes[i].hostDiscoveryFd)
            gNodes[i].hostDiscoveryFd = -1
            if gNodes[i].hostMdnsFd > 0:
                let _ = libc_close_bridge(gNodes[i].hostMdnsFd)
            gNodes[i].hostMdnsFd = -1

fn hostCopyTextFromRaw(raw: ptr, count: int32): str =
    if raw == nil || count <= 0:
        return ""
    var out: str
    var i: int32
    while i < count:
        let value: uint8 = *(UInt8Ptr(rawmem_support.RawmemPtrAdd(raw, i)))
        out = out + strings.charToStr(system.chr(int32(value)))
        i = i + 1
    return out

fn hostCopyTextFromCString(raw: cstring): str =
    return borrowImportedText(raw)

fn hostMallocCString(text: str): ptr =
    let n: int32 = len(text)
    let out: ptr = c_malloc(n + 1)
    if out == nil:
        return nil
    rawmem_support.RawmemSet(out, 0, n + 1)
    for i in 0..<n:
        *(UInt8Ptr(rawmem_support.RawmemPtrAdd(out, i))) = uint8(int32(text[i]) & 255)
    return out

fn hostParseIpv4Text(text: str, outRaw: ptr): bool =
    if outRaw == nil:
        return false
    rawmem_support.RawmemSet(outRaw, 0, 4)
    let rawText: ptr = hostMallocCString(trimText(text))
    if rawText == nil:
        return false
    let rc: int32 = libc_inet_pton_bridge(cheng_native_af_inet_bridge(), rawText, outRaw)
    c_free(rawText)
    return rc == 1

fn hostSockaddrIpv4(ipv4: str, port: int32, useLenField: bool): rawbytes.Bytes =
    let out: rawbytes.Bytes = rawbytes.bytesAlloc(hostSockaddrInLen)
    if out.data == nil:
        return out
    rawmem_support.RawmemSet(out.data, 0, hostSockaddrInLen)
    let family: int32 = cheng_native_af_inet_bridge()
    if useLenField:
        *(UInt8Ptr(out.data)) = uint8(hostSockaddrInLen & 255)
        *(UInt8Ptr(rawmem_support.RawmemPtrAdd(out.data, 1))) = uint8(family & 255)
    else:
        *(UInt8Ptr(out.data)) = uint8(family & 255)
        *(UInt8Ptr(rawmem_support.RawmemPtrAdd(out.data, 1))) = uint8((family >> 8) & 255)
    *(UInt8Ptr(rawmem_support.RawmemPtrAdd(out.data, 2))) = uint8((port >> 8) & 255)
    *(UInt8Ptr(rawmem_support.RawmemPtrAdd(out.data, 3))) = uint8(port & 255)
    let rawIp: ptr = c_malloc(4)
    if rawIp == nil:
        return rawbytes.bytesAlloc(0)
    if !hostParseIpv4Text(ipv4, rawIp):
        c_free(rawIp)
        return rawbytes.bytesAlloc(0)
    rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(out.data, 4), rawIp, 4)
    c_free(rawIp)
    return out

fn hostIpv4FromSockaddr(addr: ptr, addrLen: int32): str =
    if addr == nil || addrLen < hostSockaddrInLen:
        return ""
    let data: rawbytes.Bytes = rawbytes.bytesView(addr, addrLen)
    let part0: int32 = rawbytes.bytesGet(data, 4) & 255
    let part1: int32 = rawbytes.bytesGet(data, 5) & 255
    let part2: int32 = rawbytes.bytesGet(data, 6) & 255
    let part3: int32 = rawbytes.bytesGet(data, 7) & 255
    return strings.IntToStr(part0) + "." + strings.IntToStr(part1) + "." + strings.IntToStr(part2) + "." + strings.IntToStr(part3)

fn hostSweepPeers(stateIdx: int32) =
    let nowValue: int64 = nowMs()
    var writeIdx: int32
    var readIdx: int32
    while readIdx < gNodes[stateIdx].hostPeerCount:
        let peer: HostPeerState = gNodes[stateIdx].hostPeers[readIdx]
        var keep: bool
        if peer.used:
            if len(peer.peerId) > 0:
                if peer.peerId != gNodes[stateIdx].localPeerId:
                    let ageMs: int32 = int32(nowValue - peer.lastSeenAtMs)
                    if ageMs <= hostPeerFreshWindowMs32:
                        keep = true
        if keep:
            if writeIdx != readIdx:
                gNodes[stateIdx].hostPeers[writeIdx] = peer
            writeIdx = writeIdx + 1
        readIdx = readIdx + 1
    while writeIdx < gNodes[stateIdx].hostPeerCount:
        gNodes[stateIdx].hostPeers[writeIdx] = initHostPeerState()
        writeIdx = writeIdx + 1
    gNodes[stateIdx].hostPeerCount = writeIdx

fn hostIsAnyIpv4(text: str): bool =
    let normalized: str = trimText(strLowerAscii(text))
    return normalized == "" ||
           normalized == "0.0.0.0" ||
           normalized == "127.0.0.1" ||
           normalized == "localhost"

fn hostMultiaddrPeerId(addrText: str): str =
    let text: str = trimText(addrText)
    let pos: int32 = indexOf(text, "/p2p/", 0)
    if pos < 0:
        return ""
    return trimText(sliceBytes(text, pos + 5, len(text) - pos - 5))

fn hostAppendPeerToMultiaddr(addrText: str, peerId: str): str =
    let base: str = trimText(addrText)
    let peer: str = trimText(peerId)
    if len(base) <= 0 || len(peer) <= 0:
        return base
    let existingPeer: str = hostMultiaddrPeerId(base)
    if len(existingPeer) > 0:
        return base
    return base + "/p2p/" + peer

fn hostReplaceIp4HostInMultiaddr(addrText: str, ipv4: str): str =
    let base: str = trimText(addrText)
    let replacement: str = trimText(ipv4)
    if len(base) <= 0 || len(replacement) <= 0 || !startsWith(base, "/ip4/"):
        return base
    let afterPrefix: int32 = 5
    var slashPos: int32 = afterPrefix
    while slashPos < len(base):
        if base[slashPos] == '/':
            break
        slashPos = slashPos + 1
    if slashPos >= len(base):
        return "/ip4/" + replacement
    return "/ip4/" + replacement + sliceBytes(base, slashPos, len(base) - slashPos)

fn hostAdvertiseAddr(stateIdx: int32): str =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return ""
    var peerId: str = trimText(gNodes[stateIdx].localPeerId)
    var addr: str = trimText(gNodes[stateIdx].listenAddr)
    let nodeIdx: int32 = hostStateNodeIndex(stateIdx)
    if nodeIdx >= 0 && len(peerId) <= 0:
        peerId = nodeLocalPeerId(nodeIdx)
    if len(peerId) <= 0:
        return ""
    if len(addr) <= 0:
        if len(gHostMdnsInterfaceIpv4) > 0:
            return "/ip4/" + gHostMdnsInterfaceIpv4 + "/udp/4001/webrtc-direct/p2p/" + peerId
        return ""
    if startsWith(addr, "/ip4/"):
        let hostEndPos: int32 = indexOf(addr, "/", 5)
        if hostEndPos > 5:
            let hostText: str = sliceBytes(addr, 5, hostEndPos - 5)
            if hostIsAnyIpv4(hostText) && len(gHostMdnsInterfaceIpv4) > 0:
                addr = hostReplaceIp4HostInMultiaddr(addr, gHostMdnsInterfaceIpv4)
    return hostAppendPeerToMultiaddr(addr, peerId)

fn hostSendDiscoveryFrame(fd: int32, port: int32, payload: str): int32 =
    if fd < 0 || len(payload) <= 0:
        return 0
    let sockaddr: rawbytes.Bytes = hostSockaddrIpv4("255.255.255.255", port, cheng_native_sockaddr_use_len_field_bridge() != 0)
    if sockaddr.data == nil || sockaddr.len <= 0:
        return 0
    let sent: int32 = libc_sendto_bridge(fd, system.strDataPtr(payload), len(payload), 0, sockaddr.data, sockaddr.len)
    if sent == len(payload):
        return 1
    return 0

fn hostSendDirectedFrame(fd: int32, ipv4: str, port: int32, payload: str): int32 =
    let ipText: str = trimText(ipv4)
    if fd < 0 || len(ipText) <= 0 || len(payload) <= 0:
        return 0
    let sockaddr: rawbytes.Bytes = hostSockaddrIpv4(ipText, port, cheng_native_sockaddr_use_len_field_bridge() != 0)
    if sockaddr.data == nil || sockaddr.len <= 0:
        return 0
    let sent: int32 = libc_sendto_bridge(fd, system.strDataPtr(payload), len(payload), 0, sockaddr.data, sockaddr.len)
    if sent == len(payload):
        return 1
    return 0

fn hostEndsWith(text: str, suffix: str): bool =
    let n: int32 = len(text)
    let m: int32 = len(suffix)
    if m <= 0:
        return true
    if n < m:
        return false
    return sliceBytes(text, n - m, m) == suffix

fn hostMdnsCanonicalName(text: str): str =
    var out: str = strLowerAscii(trimText(text))
    while len(out) > 0 && out[len(out) - 1] == '.':
        out = sliceBytes(out, 0, len(out) - 1)
    if hostEndsWith(out, ".local"):
        out = sliceBytes(out, 0, len(out) - 6)
        while len(out) > 0 && out[len(out) - 1] == '.':
            out = sliceBytes(out, 0, len(out) - 1)
    if len(out) <= 0:
        return ""
    return out + ".local"

fn hostMdnsServiceValue(serviceText: str): str =
    let value: str = hostMdnsCanonicalName(serviceText)
    if len(value) > 0:
        return value
    return standardMdnsPrimaryService

fn hostMdnsServiceMatches(nameText: str, serviceText: str): bool =
    let name: str = hostMdnsCanonicalName(nameText)
    let wanted: str = hostMdnsCanonicalName(serviceText)
    if len(wanted) > 0:
        return name == wanted
    return name == standardMdnsPrimaryService ||
           name == standardMdnsUnimakerService ||
           name == standardMdnsLegacyService

fn hostMdnsQuestionMatches(nameText: str, serviceText: str): bool =
    let name: str = hostMdnsCanonicalName(nameText)
    if name == standardMdnsMetaService:
        return true
    return hostMdnsServiceMatches(name, serviceText)

fn hostMdnsInstanceName(stateIdx: int32, serviceText: str): str =
    let service: str = hostMdnsServiceValue(serviceText)
    let peerId: str = trimText(gNodes[stateIdx].localPeerId)
    if len(peerId) <= 0:
        return ""
    return "UniMaker-" + sliceBytes(peerId, if len(peerId) > 12: len(peerId) - 12 else: 0, if len(peerId) > 12: 12 else: len(peerId)) + "." + service

fn hostHasZeroPortSegment(value: str): bool =
    return indexOf(value, "/tcp/0", 0) >= 0 || indexOf(value, "/udp/0", 0) >= 0

fn hostStandardMdnsAdvertiseAddr(stateIdx: int32): str =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return ""
    var peerId: str = trimText(gNodes[stateIdx].localPeerId)
    if len(peerId) <= 0:
        let nodeIdx: int32 = hostStateNodeIndex(stateIdx)
        if nodeIdx >= 0:
            peerId = nodeLocalPeerId(nodeIdx)
    if len(peerId) <= 0:
        return ""
    var addr: str = trimText(gNodes[stateIdx].listenAddr)
    if len(addr) <= 0:
        return ""
    if hostHasZeroPortSegment(addr):
        return ""
    if startsWith(addr, "/ip4/"):
        let hostEndPos: int32 = indexOf(addr, "/", 5)
        if hostEndPos > 5:
            let hostText: str = sliceBytes(addr, 5, hostEndPos - 5)
            if hostIsAnyIpv4(hostText):
                if len(gHostMdnsInterfaceIpv4) <= 0:
                    return ""
                addr = hostReplaceIp4HostInMultiaddr(addr, gHostMdnsInterfaceIpv4)
    return hostAppendPeerToMultiaddr(addr, peerId)

fn hostEmptyDnsPacket(): HostDnsPacket =
    var out: HostDnsPacket
    return out

fn hostDnsWriteU8(buf: var rawbytes.Bytes, pos: var int32, value: int32) =
    rawbytes.bytesSet(buf, pos, value & 255)
    pos = pos + 1

fn hostDnsWriteU16(buf: var rawbytes.Bytes, pos: var int32, value: int32) =
    hostDnsWriteU8(buf, pos, (value >> 8) & 255)
    hostDnsWriteU8(buf, pos, value & 255)

fn hostDnsWriteU32(buf: var rawbytes.Bytes, pos: var int32, value: int32) =
    hostDnsWriteU8(buf, pos, (value >> 24) & 255)
    hostDnsWriteU8(buf, pos, (value >> 16) & 255)
    hostDnsWriteU8(buf, pos, (value >> 8) & 255)
    hostDnsWriteU8(buf, pos, value & 255)

fn hostDnsWriteText(buf: var rawbytes.Bytes, pos: var int32, text: str) =
    for i in 0..<len(text):
        hostDnsWriteU8(buf, pos, ord(text[i]) & 255)

fn hostDnsEncodedNameLen(nameText: str): int32 =
    let name: str = hostMdnsCanonicalName(nameText)
    if len(name) <= 0:
        return -1
    var total: int32 = 1
    var startAt: int32
    while startAt < len(name):
        var endAt: int32 = startAt
        while endAt < len(name) && name[endAt] != '.':
            endAt = endAt + 1
        let labelLen: int32 = endAt - startAt
        if labelLen <= 0 || labelLen > standardDnsMaxLabelBytes:
            return -1
        total = total + 1 + labelLen
        startAt = endAt + 1
    return total

fn hostDnsWriteName(buf: var rawbytes.Bytes, pos: var int32, nameText: str): bool =
    let name: str = hostMdnsCanonicalName(nameText)
    if len(name) <= 0:
        return false
    var startAt: int32
    while startAt < len(name):
        var endAt: int32 = startAt
        while endAt < len(name) && name[endAt] != '.':
            endAt = endAt + 1
        let labelLen: int32 = endAt - startAt
        if labelLen <= 0 || labelLen > standardDnsMaxLabelBytes:
            return false
        hostDnsWriteU8(buf, pos, labelLen)
        for i in startAt..<endAt:
            hostDnsWriteU8(buf, pos, ord(name[i]) & 255)
        startAt = endAt + 1
    hostDnsWriteU8(buf, pos, 0)
    return true

fn hostBuildStandardMdnsQuery(serviceText: str): HostDnsPacket =
    var out: HostDnsPacket
    out.bytes = rawbytes.bytesAlloc(512)
    if out.bytes.data == nil:
        return out
    var pos: int32
    hostDnsWriteU16(out.bytes, pos, 0)
    hostDnsWriteU16(out.bytes, pos, 0)
    hostDnsWriteU16(out.bytes, pos, 1)
    hostDnsWriteU16(out.bytes, pos, 0)
    hostDnsWriteU16(out.bytes, pos, 0)
    hostDnsWriteU16(out.bytes, pos, 0)
    if !hostDnsWriteName(out.bytes, pos, hostMdnsServiceValue(serviceText)):
        return hostEmptyDnsPacket()
    hostDnsWriteU16(out.bytes, pos, standardDnsTypePtr)
    hostDnsWriteU16(out.bytes, pos, standardDnsClassIn)
    if pos <= 0 || pos > out.bytes.len:
        return hostEmptyDnsPacket()
    out.len = pos
    return out

fn hostBuildStandardMdnsAnnouncement(stateIdx: int32, serviceText: str): HostDnsPacket =
    var out: HostDnsPacket
    let peerId: str = trimText(gNodes[stateIdx].localPeerId)
    let addr: str = hostStandardMdnsAdvertiseAddr(stateIdx)
    if len(peerId) <= 0 || len(addr) <= 0:
        return out
    let service: str = hostMdnsServiceValue(serviceText)
    let instance: str = hostMdnsInstanceName(stateIdx, service)
    let ptrDataLen: int32 = hostDnsEncodedNameLen(instance)
    let dnsaddrEntry: str = "dnsaddr=" + addr
    let peerEntry: str = "peerId=" + peerId
    var txtDataLen: int32
    if len(dnsaddrEntry) > 0 && len(dnsaddrEntry) <= 255:
        txtDataLen = txtDataLen + 1 + len(dnsaddrEntry)
    if len(peerEntry) > 0 && len(peerEntry) <= 255:
        txtDataLen = txtDataLen + 1 + len(peerEntry)
    if ptrDataLen <= 0 || txtDataLen <= 0:
        return out
    out.bytes = rawbytes.bytesAlloc(2048)
    if out.bytes.data == nil:
        return out
    var pos: int32
    hostDnsWriteU16(out.bytes, pos, 0)
    hostDnsWriteU16(out.bytes, pos, standardDnsResponseFlags)
    hostDnsWriteU16(out.bytes, pos, 0)
    hostDnsWriteU16(out.bytes, pos, 1)
    hostDnsWriteU16(out.bytes, pos, 0)
    hostDnsWriteU16(out.bytes, pos, 1)
    if !hostDnsWriteName(out.bytes, pos, service):
        return hostEmptyDnsPacket()
    hostDnsWriteU16(out.bytes, pos, standardDnsTypePtr)
    hostDnsWriteU16(out.bytes, pos, standardDnsClassIn)
    hostDnsWriteU32(out.bytes, pos, standardDnsTtlSeconds)
    hostDnsWriteU16(out.bytes, pos, ptrDataLen)
    if !hostDnsWriteName(out.bytes, pos, instance):
        return hostEmptyDnsPacket()
    if !hostDnsWriteName(out.bytes, pos, instance):
        return hostEmptyDnsPacket()
    hostDnsWriteU16(out.bytes, pos, standardDnsTypeTxt)
    hostDnsWriteU16(out.bytes, pos, standardDnsClassIn | standardDnsCacheFlush)
    hostDnsWriteU32(out.bytes, pos, standardDnsTtlSeconds)
    hostDnsWriteU16(out.bytes, pos, txtDataLen)
    if len(dnsaddrEntry) <= 255:
        hostDnsWriteU8(out.bytes, pos, len(dnsaddrEntry))
        hostDnsWriteText(out.bytes, pos, dnsaddrEntry)
    if len(peerEntry) <= 255:
        hostDnsWriteU8(out.bytes, pos, len(peerEntry))
        hostDnsWriteText(out.bytes, pos, peerEntry)
    if pos <= 0 || pos > out.bytes.len:
        return hostEmptyDnsPacket()
    out.len = pos
    return out

fn hostJoinStandardMdnsGroup(fd: int32, ifaceIpv4: str): int32 =
    if fd <= 0:
        return 0
    let mreq: rawbytes.Bytes = rawbytes.bytesAlloc(8)
    if mreq.data == nil:
        return 0
    let groupRaw: ptr = c_malloc(4)
    let ifaceRaw: ptr = c_malloc(4)
    if groupRaw == nil || ifaceRaw == nil:
        if groupRaw != nil:
            c_free(groupRaw)
        if ifaceRaw != nil:
            c_free(ifaceRaw)
        return 0
    rawmem_support.RawmemSet(ifaceRaw, 0, 4)
    if !hostParseIpv4Text(standardMdnsGroup, groupRaw):
        c_free(groupRaw)
        c_free(ifaceRaw)
        return 0
    let ifaceText: str = ifaceIpv4
    if len(ifaceText) > 0:
        let _ = hostParseIpv4Text(ifaceText, ifaceRaw)
    rawmem_support.RawmemCopy(mreq.data, groupRaw, 4)
    rawmem_support.RawmemCopy(rawmem_support.RawmemPtrAdd(mreq.data, 4), ifaceRaw, 4)
    let rc: int32 = libc_setsockopt_bridge(
        fd,
        cheng_native_ipproto_ip_bridge(),
        standardIpAddMembership,
        mreq.data,
        mreq.len
    )
    c_free(groupRaw)
    c_free(ifaceRaw)
    if rc == 0:
        return 1
    return 0

fn hostSetStandardMdnsMulticastInterface(fd: int32, ifaceIpv4: str): int32 =
    let ifaceText: str = ifaceIpv4
    if fd < 0 || len(ifaceText) <= 0 || ifaceText == "0.0.0.0":
        return 0
    let ifaceRaw: ptr = c_malloc(4)
    if ifaceRaw == nil:
        return 0
    if !hostParseIpv4Text(ifaceText, ifaceRaw):
        c_free(ifaceRaw)
        return 0
    let rc: int32 = libc_setsockopt_bridge(
        fd,
        cheng_native_ipproto_ip_bridge(),
        standardIpMulticastIf,
        ifaceRaw,
        4
    )
    c_free(ifaceRaw)
    if rc == 0:
        return 1
    return 0

fn ensureStandardMdnsSocket(stateIdx: int32): int32 =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return -1
    if gNodes[stateIdx].hostMdnsFd > 0:
        return gNodes[stateIdx].hostMdnsFd
    var fd: int32 = -1
    var outPort: int32
    var outFamily: int32
    var outUseLenField: int32
    let bindRc: int32 = cheng_udp_bind_host_port_bridge(
        "0.0.0.0",
        standardMdnsPort,
        0,
        fd,
        outPort,
        outFamily,
        outUseLenField
    )
    if bindRc != 0 || fd < 0:
        return -1
    var one: int32 = 1
    var zero: int32
    var ttl: int32 = 255
    let sockLevel: int32 = cheng_native_sol_socket_bridge()
    let ipLevel: int32 = cheng_native_ipproto_ip_bridge()
    let _ = libc_setsockopt_bridge(fd, sockLevel, cheng_native_so_reuseaddr_bridge(), &one, int32(sizeof int32))
    let _ = libc_setsockopt_bridge(fd, sockLevel, standardSoReusePort, &one, int32(sizeof int32))
    let _ = libc_setsockopt_bridge(fd, sockLevel, cheng_native_so_broadcast_bridge(), &one, int32(sizeof int32))
    let _ = libc_setsockopt_bridge(fd, ipLevel, standardIpMulticastLoop, &zero, int32(sizeof int32))
    let _ = libc_setsockopt_bridge(fd, ipLevel, standardIpMulticastTtl, &ttl, int32(sizeof int32))
    let _ = hostSetStandardMdnsMulticastInterface(fd, gHostMdnsInterfaceIpv4)
    var joined: int32
    if len(gHostMdnsInterfaceIpv4) > 0:
        joined = joined + hostJoinStandardMdnsGroup(fd, gHostMdnsInterfaceIpv4)
    joined = joined + hostJoinStandardMdnsGroup(fd, "0.0.0.0")
    if joined <= 0 || cheng_fd_set_nonblocking_bridge(fd, 1) != 0:
        let _ = libc_close_bridge(fd)
        return -1
    gNodes[stateIdx].hostMdnsFd = fd
    return fd

fn hostSendStandardMdnsPacket(fd: int32, ipv4: str, packet: HostDnsPacket): int32 =
    let ipText: str = ipv4
    if fd < 0 || len(ipText) <= 0 || packet.bytes.data == nil || packet.len <= 0:
        return 0
    let sockaddr: rawbytes.Bytes = hostSockaddrIpv4(ipText, standardMdnsPort, cheng_native_sockaddr_use_len_field_bridge() != 0)
    if sockaddr.data == nil || sockaddr.len <= 0:
        return 0
    let sent: int32 = libc_sendto_bridge(fd, packet.bytes.data, packet.len, 0, sockaddr.data, sockaddr.len)
    if sent == packet.len:
        return 1
    return 0

fn hostEnsureStandardMdnsSocketOnce(stateIdx: int32): int32 =
    let fd: int32 = ensureStandardMdnsSocket(stateIdx)
    if fd < 0:
        return 0
    return 1

fn hostKickStandardMdnsQueryFrame(stateIdx: int32, serviceText: str): int32 =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return 0
    let fd: int32 = ensureStandardMdnsSocket(stateIdx)
    if fd < 0:
        return 0
    let packet: HostDnsPacket = hostBuildStandardMdnsQuery(hostMdnsServiceValue(serviceText))
    let sent: int32 = hostSendStandardMdnsPacket(fd, standardMdnsGroup, packet)
    return sent

fn hostKickStandardMdnsAnnouncementFrame(stateIdx: int32, serviceText: str): int32 =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return 0
    let fd: int32 = ensureStandardMdnsSocket(stateIdx)
    if fd < 0:
        return 0
    let packet: HostDnsPacket = hostBuildStandardMdnsAnnouncement(stateIdx, hostMdnsServiceValue(serviceText))
    let sent: int32 = hostSendStandardMdnsPacket(fd, standardMdnsGroup, packet)
    return sent

fn hostKickStandardMdnsFrames(stateIdx: int32, serviceText: str): int32 =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return 0
    var okCount: int32
    let serviceName: str = hostMdnsServiceValue(serviceText)
    okCount = okCount + hostKickStandardMdnsQueryFrame(stateIdx, serviceName)
    okCount = okCount + hostKickStandardMdnsAnnouncementFrame(stateIdx, serviceName)
    return okCount

fn hostKickDiscoveryFrames(stateIdx: int32, serviceText: str, namespaceText: str): int32 =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return 0
    let fd: int32 = ensureHostDiscoverySocket(stateIdx)
    if fd < 0:
        return 0
    var okCount: int32
    let announce: str = hostAnnouncePayload(stateIdx, serviceText, namespaceText)
    if len(announce) > 0:
        okCount = okCount + hostSendDiscoveryFrame(fd, hostDiscoveryPort, announce)
        okCount = okCount + hostSendDiscoveryFrame(fd, hostDiscoveryLegacyPort, announce)
    let request: str = hostAnnounceRequestPayload(serviceText, namespaceText)
    okCount = okCount + hostSendDiscoveryFrame(fd, hostDiscoveryPort, request)
    okCount = okCount + hostSendDiscoveryFrame(fd, hostDiscoveryLegacyPort, request)
    return okCount

fn hostHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn hostHexEncodeText(text: str): str =
    return rawbytes.bytesToHex(rawbytes.bytesFromString(text))

fn hostHexDecodeText(text: str): str =
    let n: int32 = len(text)
    if n <= 0 || (n % 2) != 0:
        return ""
    var out: str
    var i: int32
    while i + 1 < n:
        let hi: int32 = hostHexValue(text[i])
        let lo: int32 = hostHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return ""
        out = out + strings.charToStr(system.chr((hi << 4) | lo))
        i = i + 2
    return out

fn hostExtractIpv4FromMultiaddr(addrText: str): str =
    let addr: str = trimText(addrText)
    if !startsWith(addr, "/ip4/"):
        return ""
    let startAt: int32 = 5
    var endAt: int32 = startAt
    while endAt < len(addr):
        if addr[endAt] == '/':
            break
        endAt = endAt + 1
    if endAt <= startAt:
        return ""
    return trimText(sliceBytes(addr, startAt, endAt - startAt))

fn hostAnnouncePayload(stateIdx: int32, serviceText: str, namespaceText: str): str =
    let peerId: str = trimText(
        if len(gNodes[stateIdx].localPeerId) > 0:
            gNodes[stateIdx].localPeerId
        else:
            nodeLocalPeerId(hostStateNodeIndex(stateIdx))
    )
    let addr: str = hostAdvertiseAddr(stateIdx)
    if len(peerId) <= 0 || len(addr) <= 0:
        return ""
    var serviceValue: str = "_p2p._udp.local"
    let trimmedService: str = trimText(serviceText)
    if len(trimmedService) > 0:
        serviceValue = trimmedService
    return "ANN|" + peerId + "|" + addr + "|" + serviceValue + "|" + trimText(namespaceText) + "|" + strings.int64ToStr(nowMs())

fn hostAnnounceRequestPayload(serviceText: str, namespaceText: str): str =
    var serviceValue: str = "_p2p._udp.local"
    let trimmedService: str = trimText(serviceText)
    if len(trimmedService) > 0:
        serviceValue = trimmedService
    return "ANNREQ|" + serviceValue + "|" + trimText(namespaceText) + "|" + strings.int64ToStr(nowMs())

fn ensureHostDiscoverySocket(stateIdx: int32): int32 =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return -1
    if gNodes[stateIdx].hostDiscoveryFd > 0:
        return gNodes[stateIdx].hostDiscoveryFd
    var outFd: int32 = -1
    var outPort: int32
    var outFamily: int32
    var outUseLenField: int32
    let bindRc: int32 = cheng_udp_bind_host_port_bridge(
        "0.0.0.0",
        hostDiscoveryPort,
        0,
        outFd,
        outPort,
        outFamily,
        outUseLenField
    )
    if bindRc != 0 || outFd < 0:
        return -1
    var one: int32 = 1
    let sockLevel: int32 = cheng_native_sol_socket_bridge()
    let reuseOk: int32 = libc_setsockopt_bridge(outFd, sockLevel, cheng_native_so_reuseaddr_bridge(), &one, int32(sizeof int32))
    let broadcastOk: int32 = libc_setsockopt_bridge(outFd, sockLevel, cheng_native_so_broadcast_bridge(), &one, int32(sizeof int32))
    if reuseOk != 0 || broadcastOk != 0 || cheng_fd_set_nonblocking_bridge(outFd, 1) != 0:
        let _ = libc_close_bridge(outFd)
        return -1
    gNodes[stateIdx].hostDiscoveryFd = outFd
    return outFd

fn openHostDirectSendSocket(): int32 =
    let fd: int32 = libc_socket_bridge(
        cheng_native_af_inet_bridge(),
        cheng_native_sock_dgram_bridge(),
        cheng_native_ipproto_ip_bridge()
    )
    if fd < 0:
        return -1
    var one: int32 = 1
    let sockLevel: int32 = cheng_native_sol_socket_bridge()
    libc_setsockopt_bridge(fd, sockLevel, cheng_native_so_reuseaddr_bridge(), &one, int32(sizeof int32))
    libc_setsockopt_bridge(fd, sockLevel, cheng_native_so_broadcast_bridge(), &one, int32(sizeof int32))
    cheng_fd_set_nonblocking_bridge(fd, 1)
    return fd

fn hostPipeFieldCount(text: str): int32 =
    let payload: str = trimText(text)
    if len(payload) <= 0:
        return 0
    var count: int32 = 1
    for i in 0..<len(payload):
        if payload[i] == '|':
            count = count + 1
    return count

fn hostPipeFieldText(text: str, fieldIndex: int32): str =
    let payload: str = trimText(text)
    if fieldIndex < 0 || len(payload) <= 0:
        return ""
    var current: int32
    var startAt: int32
    var i: int32
    while i < len(payload):
        if payload[i] == '|':
            if current == fieldIndex:
                return trimText(sliceBytes(payload, startAt, i - startAt))
            current = current + 1
            startAt = i + 1
        i = i + 1
    if current == fieldIndex:
        return trimText(sliceBytes(payload, startAt, len(payload) - startAt))
    return ""

fn hostParseAnnouncedAddr(addrText: str, remoteIpv4: str, peerId: str): str =
    var addr: str = trimText(addrText)
    let remoteIp: str = trimText(remoteIpv4)
    if len(addr) <= 0:
        if len(remoteIp) > 0:
            return "/ip4/" + remoteIp + "/udp/4001/webrtc-direct/p2p/" + trimText(peerId)
        return ""
    if startsWith(addr, "/ip4/"):
        let hostEndPos: int32 = indexOf(addr, "/", 5)
        if hostEndPos > 5:
            let hostText: str = sliceBytes(addr, 5, hostEndPos - 5)
            if hostIsAnyIpv4(hostText) && len(remoteIp) > 0:
                addr = hostReplaceIp4HostInMultiaddr(addr, remoteIp)
    return hostAppendPeerToMultiaddr(addr, peerId)

fn upsertHostPeer(stateIdx: int32, peerIdText: str, addrText: str, source: str): bool =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return false
    let peerId: str = trimText(peerIdText)
    if len(peerId) <= 0 || peerId == trimText(gNodes[stateIdx].localPeerId):
        return false
    hostSweepPeers(stateIdx)
    var created: bool = true
    var slot: int32 = -1
    for i in 0..<gNodes[stateIdx].hostPeerCount:
        if gNodes[stateIdx].hostPeers[i].used && gNodes[stateIdx].hostPeers[i].peerId == peerId:
            slot = i
            created = false
            break
    if slot < 0:
        if gNodes[stateIdx].hostPeerCount >= maxHostPeers:
            return false
        slot = gNodes[stateIdx].hostPeerCount
        gNodes[stateIdx].hostPeerCount = gNodes[stateIdx].hostPeerCount + 1
        gNodes[stateIdx].hostPeers[slot] = initHostPeerState()
        gNodes[stateIdx].hostPeers[slot].used = true
        gNodes[stateIdx].hostPeers[slot].peerId = peerId
    gNodes[stateIdx].hostPeers[slot].addr = trimText(addrText)
    gNodes[stateIdx].hostPeers[slot].source = trimText(source)
    gNodes[stateIdx].hostPeers[slot].connected = false
    gNodes[stateIdx].hostPeers[slot].lastSeenAtMs = nowMs()
    let nodeIdx: int32 = hostStateNodeIndex(stateIdx)
    if nodeIdx >= 0:
        let peerSlot: int32 = ensurePeerSlot(nodeIdx, peerId)
        if peerSlot >= 0:
            mergePeerAddress(nodeIdx, peerSlot, trimText(addrText))
            gNodes[nodeIdx].peers[peerSlot].source = trimText(source)
            gNodes[nodeIdx].peers[peerSlot].connected = false
            gNodes[nodeIdx].peers[peerSlot].lastSeenAtMs = nowMs()
    return created

fn appendHostMessage(stateIdx: int32,
                     peerIdText: str,
                     conversationIdText: str,
                     messageIdText: str,
                     payloadJson: str) =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return
    var slot: int32 = gNodes[stateIdx].hostMessageCount
    if slot >= maxHostMessages:
        for i in 1..<maxHostMessages:
            gNodes[stateIdx].hostMessages[i - 1] = gNodes[stateIdx].hostMessages[i]
        slot = maxHostMessages - 1
    else:
        gNodes[stateIdx].hostMessageCount = gNodes[stateIdx].hostMessageCount + 1
    var message: HostMessageState = initHostMessageState()
    message.used = true
    message.peerId = trimText(peerIdText)
    message.conversationId = trimText(conversationIdText)
    message.messageId = trimText(messageIdText)
    message.payloadJson = payloadJson
    message.timestampMs = nowMs()
    gNodes[stateIdx].hostMessages[slot] = message
    let nodeIdx: int32 = hostStateNodeIndex(stateIdx)
    if nodeIdx >= 0:
        appendMessage(nodeIdx, peerIdText, conversationIdText, messageIdText, payloadJson, "in", "received")
        emitSocialDmReceivedEvent(nodeIdx, peerIdText, conversationIdText, messageIdText, payloadJson, message.timestampMs)

fn hostHandleDiscoveryPayload(stateIdx: int32, payload: str, remoteIpv4: str, serviceText: str, namespaceText: str): int32 =
    let payloadBodyText: str = trimText(payload)
    let fieldCount: int32 = hostPipeFieldCount(payloadBodyText)
    if fieldCount <= 0:
        return 0
    let frameKind: str = hostPipeFieldText(payloadBodyText, 0)
    if frameKind == "MSG":
        if fieldCount < 6:
            return 0
        let peerId: str = hostPipeFieldText(payloadBodyText, 1)
        if len(peerId) <= 0 || peerId == trimText(gNodes[stateIdx].localPeerId):
            return 0
        let conversationId: str = hostPipeFieldText(payloadBodyText, 2)
        let messageId: str = hostPipeFieldText(payloadBodyText, 3)
        let payloadJson: str = hostHexDecodeText(hostPipeFieldText(payloadBodyText, 4))
        let remoteAddr: str = "/ip4/" + trimText(remoteIpv4) + "/udp/" + strings.IntToStr(hostDiscoveryPort) + "/host-direct/p2p/" + peerId
        let _ = upsertHostPeer(stateIdx, peerId, remoteAddr, "host_direct")
        appendHostMessage(stateIdx, peerId, conversationId, messageId, payloadJson)
        return 0
    if frameKind == "ANNREQ":
        return -1
    if frameKind != "ANN" || fieldCount < 5:
        return 0
    let peerId: str = hostPipeFieldText(payloadBodyText, 1)
    if len(peerId) <= 0 || peerId == trimText(gNodes[stateIdx].localPeerId):
        return 0
    let frameService: str = hostPipeFieldText(payloadBodyText, 3)
    let frameNamespace: str = hostPipeFieldText(payloadBodyText, 4)
    let wantedService: str = trimText(serviceText)
    let wantedNamespace: str = trimText(namespaceText)
    if len(wantedService) > 0 && frameService != wantedService:
        return 0
    if len(wantedNamespace) > 0 && frameNamespace != wantedNamespace:
        return 0
    let advertisedAddr: str = hostParseAnnouncedAddr(hostPipeFieldText(payloadBodyText, 2), remoteIpv4, peerId)
    let created: bool = upsertHostPeer(stateIdx, peerId, advertisedAddr, "mdns")
    gNodes[stateIdx].hostLastDiscoveredPeerId = peerId
    gNodes[stateIdx].hostLastDiscoveredAddr = advertisedAddr
    gNodes[stateIdx].hostLastDiscoveredAtMs = nowMs()
    if created:
        return 1
    return 0

fn hostDnsReadU16(data: rawbytes.Bytes, pos: int32): int32 =
    if pos < 0 || pos + 1 >= data.len:
        return -1
    return ((rawbytes.bytesGet(data, pos) & 255) << 8) | (rawbytes.bytesGet(data, pos + 1) & 255)

fn hostBytesContainsAscii(data: rawbytes.Bytes, needle: str): bool =
    if data.data == nil || len(needle) <= 0 || data.len < len(needle):
        return false
    var offset: int32
    let limit: int32 = data.len - len(needle)
    while offset <= limit:
        var matched: bool = true
        var index: int32
        while index < len(needle):
            let packetByte: int32 = rawbytes.bytesGet(data, offset + index) & 255
            let needleByte: int32 = int32(needle[index]) & 255
            if packetByte != needleByte:
                matched = false
                break
            index = index + 1
        if matched:
            return true
        offset = offset + 1
    return false

fn hostDnsReadName(data: rawbytes.Bytes, startAt: int32, nextOut: var int32): str =
    nextOut = -1
    if data.data == nil || startAt < 0 || startAt >= data.len:
        return ""
    var out: str
    var pos: int32 = startAt
    var jumped: bool
    var jumps: int32
    while pos < data.len:
        let labelLen: int32 = rawbytes.bytesGet(data, pos) & 255
        if labelLen == 0:
            if !jumped:
                nextOut = pos + 1
            elif nextOut < 0:
                nextOut = startAt + 1
            return out
        if (labelLen & 192) == 192:
            if pos + 1 >= data.len:
                return ""
            let pointer: int32 = ((labelLen & 63) << 8) | (rawbytes.bytesGet(data, pos + 1) & 255)
            if pointer < 0 || pointer >= data.len:
                return ""
            if !jumped:
                nextOut = pos + 2
            pos = pointer
            jumped = true
            jumps = jumps + 1
            if jumps > standardDnsMaxPointerJumps:
                return ""
            continue
        if (labelLen & 192) != 0:
            return ""
        if labelLen <= 0 || labelLen > standardDnsMaxLabelBytes:
            return ""
        pos = pos + 1
        if pos + labelLen > data.len:
            return ""
        let label: str = hostCopyTextFromRaw(rawmem_support.RawmemPtrAdd(data.data, pos), labelLen)
        if len(out) > 0:
            out = out + "."
        out = out + label
        pos = pos + labelLen
        if !jumped:
            nextOut = pos
    return ""

fn hostDnsSkipQuestions(data: rawbytes.Bytes, questionCount: int32): int32 =
    if questionCount < 0 || questionCount > 32:
        return -1
    var offset: int32 = 12
    var index: int32
    while index < questionCount:
        var nameNext: int32
        let _ = hostDnsReadName(data, offset, nameNext)
        if nameNext < 0 || nameNext + 4 > data.len:
            return -1
        offset = nameNext + 4
        index = index + 1
    return offset

fn hostTargetSetContains(targetSet: str, nameText: str): bool =
    let name: str = hostMdnsCanonicalName(nameText)
    if len(targetSet) <= 0 || len(name) <= 0:
        return false
    return indexOf(targetSet, "\n" + name + "\n", 0) >= 0

fn hostDnsCollectStandardTargets(data: rawbytes.Bytes, recordOffset: int32, recordCount: int32, serviceText: str): str =
    if recordOffset < 0 || recordCount <= 0 || recordCount > 64:
        return ""
    var targets: str
    var offset: int32 = recordOffset
    var index: int32
    while index < recordCount && offset < data.len:
        var nameNext: int32
        let name: str = hostDnsReadName(data, offset, nameNext)
        if nameNext < 0 || nameNext + 10 > data.len:
            return targets
        let rtype: int32 = hostDnsReadU16(data, nameNext)
        let rdLen: int32 = hostDnsReadU16(data, nameNext + 8)
        let dataStart: int32 = nameNext + 10
        let dataEnd: int32 = dataStart + rdLen
        if rdLen < 0 || dataEnd > data.len:
            return targets
        if rtype == standardDnsTypePtr && hostMdnsServiceMatches(name, serviceText):
            var targetNext: int32
            let targetName: str = hostDnsReadName(data, dataStart, targetNext)
            let target: str = hostMdnsCanonicalName(targetName)
            if len(target) > 0 && indexOf(targets, "\n" + target + "\n", 0) < 0:
                targets = targets + "\n" + target + "\n"
        offset = dataEnd
        index = index + 1
    return targets

fn hostRegisterStandardMdnsAddr(stateIdx: int32, dnsaddrText: str, peerIdHint: str, remoteIpv4: str): int32 =
    var addr: str = trimText(dnsaddrText)
    if len(addr) <= 0 || hostHasZeroPortSegment(addr):
        return 0
    var peerId: str = trimText(peerIdHint)
    if len(peerId) <= 0:
        peerId = hostMultiaddrPeerId(addr)
    if len(peerId) <= 0 || peerId == trimText(gNodes[stateIdx].localPeerId):
        return 0
    addr = hostAppendPeerToMultiaddr(addr, peerId)
    if startsWith(addr, "/ip4/"):
        let hostEndPos: int32 = indexOf(addr, "/", 5)
        if hostEndPos > 5:
            let hostText: str = sliceBytes(addr, 5, hostEndPos - 5)
            if hostIsAnyIpv4(hostText) && len(remoteIpv4) > 0:
                addr = hostReplaceIp4HostInMultiaddr(addr, remoteIpv4)
    if !startsWith(addr, "/ip4/") && !startsWith(addr, "/ip6/"):
        return 0
    let created: bool = upsertHostPeer(stateIdx, peerId, addr, "mdns")
    gNodes[stateIdx].hostLastDiscoveredPeerId = peerId
    gNodes[stateIdx].hostLastDiscoveredAddr = addr
    gNodes[stateIdx].hostLastDiscoveredAtMs = nowMs()
    if created:
        return 1
    return 0

fn hostDecodeDnsaddrEntry(entryText: str): str =
    let entry: str = trimText(entryText)
    let lower: str = strLowerAscii(entry)
    if startsWith(lower, "dnsaddr="):
        return trimText(sliceBytes(entry, 8, len(entry) - 8))
    if startsWith(lower, "addr="):
        return trimText(sliceBytes(entry, 5, len(entry) - 5))
    if startsWith(lower, "addrs="):
        return trimText(sliceBytes(entry, 6, len(entry) - 6))
    if startsWith(lower, "addr:"):
        return trimText(sliceBytes(entry, 5, len(entry) - 5))
    if startsWith(lower, "addrs:"):
        return trimText(sliceBytes(entry, 6, len(entry) - 6))
    if indexOf(lower, "/ip4/", 0) >= 0 || indexOf(lower, "/ip6/", 0) >= 0:
        return entry
    return ""

fn hostProcessStandardMdnsTxtRecord(stateIdx: int32,
                                    data: rawbytes.Bytes,
                                    dataStart: int32,
                                    dataEnd: int32,
                                    remoteIpv4: str): int32 =
    if dataStart < 0 || dataEnd > data.len || dataStart >= dataEnd:
        return 0
    var peerIdHint: str
    var rows: str
    var offset: int32 = dataStart
    while offset < dataEnd:
        let entryLen: int32 = rawbytes.bytesGet(data, offset) & 255
        offset = offset + 1
        if entryLen < 0 || offset + entryLen > dataEnd:
            return 0
        let entry: str = hostCopyTextFromRaw(rawmem_support.RawmemPtrAdd(data.data, offset), entryLen)
        let lower: str = strLowerAscii(trimText(entry))
        if startsWith(lower, "peerid="):
            peerIdHint = trimText(sliceBytes(entry, 7, len(entry) - 7))
        else:
            let dnsaddr: str = hostDecodeDnsaddrEntry(entry)
            if len(dnsaddr) > 0:
                rows = rows + "\n" + dnsaddr
        offset = offset + entryLen
    var newCount: int32
    var rowStart: int32 = 1
    while rowStart < len(rows):
        var rowEnd: int32 = rowStart
        while rowEnd < len(rows) && rows[rowEnd] != '\n':
            rowEnd = rowEnd + 1
        let dnsaddr: str = trimText(sliceBytes(rows, rowStart, rowEnd - rowStart))
        if len(dnsaddr) > 0:
            newCount = newCount + hostRegisterStandardMdnsAddr(stateIdx, dnsaddr, peerIdHint, remoteIpv4)
        rowStart = rowEnd + 1
    return newCount

fn hostCollectStandardMdnsTxtRecords(stateIdx: int32,
                                     data: rawbytes.Bytes,
                                     recordOffset: int32,
                                     recordCount: int32,
                                     targetSet: str,
                                     remoteIpv4: str): int32 =
    if recordOffset < 0 || recordCount <= 0 || recordCount > 64 || len(targetSet) <= 0:
        return 0
    var newCount: int32
    var offset: int32 = recordOffset
    var index: int32
    while index < recordCount && offset < data.len:
        var nameNext: int32
        let name: str = hostDnsReadName(data, offset, nameNext)
        if nameNext < 0 || nameNext + 10 > data.len:
            return newCount
        let rtype: int32 = hostDnsReadU16(data, nameNext)
        let rdLen: int32 = hostDnsReadU16(data, nameNext + 8)
        let dataStart: int32 = nameNext + 10
        let dataEnd: int32 = dataStart + rdLen
        if rdLen < 0 || dataEnd > data.len:
            return newCount
        if rtype == standardDnsTypeTxt && hostTargetSetContains(targetSet, name):
            newCount = newCount + hostProcessStandardMdnsTxtRecord(stateIdx, data, dataStart, dataEnd, remoteIpv4)
        offset = dataEnd
        index = index + 1
    return newCount
    
fn hostHandleStandardMdnsPayload(stateIdx: int32,
                                 data: rawbytes.Bytes,
                                 remoteIpv4: str,
                                 serviceText: str): int32 =
    if data.data == nil || data.len < 12:
        return 0
    let flags: int32 = hostDnsReadU16(data, 2)
    if flags < 0:
        return 0
    if (flags & 32768) == 0:
        return 0
    let questionCount: int32 = hostDnsReadU16(data, 4)
    let answerCount: int32 = hostDnsReadU16(data, 6)
    let authorityCount: int32 = hostDnsReadU16(data, 8)
    let additionalCount: int32 = hostDnsReadU16(data, 10)
    let recordCount: int32 = answerCount + authorityCount + additionalCount
    if questionCount < 0 || recordCount <= 0 || recordCount > 64:
        return 0
    let recordOffset: int32 = hostDnsSkipQuestions(data, questionCount)
    if recordOffset < 0:
        return 0
    let targetSet: str = hostDnsCollectStandardTargets(data, recordOffset, recordCount, serviceText)
    if len(targetSet) <= 0:
        return 0
    return hostCollectStandardMdnsTxtRecords(stateIdx, data, recordOffset, recordCount, targetSet, remoteIpv4)

fn drainStandardMdnsSocket(stateIdx: int32, serviceText: str, budget: int32): int32 =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return 0
    let fd: int32 = ensureStandardMdnsSocket(stateIdx)
    if fd < 0:
        return 0
    let recvBuf: ptr = c_malloc(standardMdnsPayloadBytes)
    let addrBuf: ptr = c_malloc(hostSockaddrInLen)
    if recvBuf == nil || addrBuf == nil:
        if recvBuf != nil:
            c_free(recvBuf)
        if addrBuf != nil:
            c_free(addrBuf)
        return 0
    var newCount: int32
    var attempts: int32
    let peerBudget: int32 = if budget > 0: budget else: 8
    let maxAttempts: int32 = if peerBudget < 8: peerBudget else: 8
    let recvFlags: int32 = hostRecvDontWaitLinuxFlag
    while attempts < maxAttempts:
        let readyRc: int32 = cheng_fd_wait_readable_bridge(fd, 0)
        if readyRc <= 0:
            break
        rawmem_support.RawmemSet(recvBuf, 0, standardMdnsPayloadBytes)
        rawmem_support.RawmemSet(addrBuf, 0, hostSockaddrInLen)
        var outAddrLen: int32 = hostSockaddrInLen
        let recvLen: int32 = libc_recvfrom_bridge(fd, recvBuf, standardMdnsPayloadBytes, recvFlags, addrBuf, &outAddrLen)
        if recvLen <= 0:
            break
        let packet: rawbytes.Bytes = rawbytes.bytesView(recvBuf, recvLen)
        let flags: int32 = hostDnsReadU16(packet, 2)
        if flags < 0:
            attempts = attempts + 1
            continue
        if (flags & 32768) == 0:
            attempts = attempts + 1
            continue
        if !hostBytesContainsAscii(packet, "dnsaddr="):
            attempts = attempts + 1
            continue
        let remoteIpv4: str = hostIpv4FromSockaddr(addrBuf, outAddrLen)
        let handled: int32 = hostHandleStandardMdnsPayload(stateIdx, packet, remoteIpv4, serviceText)
        if handled > 0:
            newCount = newCount + handled
            if newCount >= peerBudget:
                break
        attempts = attempts + 1
    c_free(recvBuf)
    c_free(addrBuf)
    hostSweepPeers(stateIdx)
    return newCount

fn drainHostDiscoverySocket(stateIdx: int32, serviceText: str, namespaceText: str, budget: int32, waitMs: int32): int32 =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return 0
    let fd: int32 = ensureHostDiscoverySocket(stateIdx)
    if fd < 0:
        return 0
    let recvBuf: ptr = c_malloc(hostDiscoveryPayloadBytes + 1)
    let addrBuf: ptr = c_malloc(hostSockaddrInLen)
    if recvBuf == nil || addrBuf == nil:
        if recvBuf != nil:
            c_free(recvBuf)
        if addrBuf != nil:
            c_free(addrBuf)
        return 0
    var newCount: int32
    var attempts: int32
    let peerBudget: int32 = if budget > 0: budget else: 8
    let maxAttempts: int32 = if peerBudget < 8: peerBudget else: 8
    let recvFlags: int32 = hostRecvDontWaitLinuxFlag
    while attempts < maxAttempts:
        let waitBudgetMs: int32 =
            if attempts == 0 && waitMs > 0:
                waitMs
            else:
                0
        let readyRc: int32 = cheng_fd_wait_readable_bridge(fd, waitBudgetMs)
        if readyRc <= 0:
            break
        rawmem_support.RawmemSet(recvBuf, 0, hostDiscoveryPayloadBytes + 1)
        rawmem_support.RawmemSet(addrBuf, 0, hostSockaddrInLen)
        var outAddrLen: int32 = hostSockaddrInLen
        let recvLen: int32 = libc_recvfrom_bridge(fd, recvBuf, hostDiscoveryPayloadBytes, recvFlags, addrBuf, &outAddrLen)
        if recvLen <= 0:
            break
        let payload: str = hostCopyTextFromRaw(recvBuf, recvLen)
        let remoteIpv4: str = hostIpv4FromSockaddr(addrBuf, outAddrLen)
        let handled: int32 = hostHandleDiscoveryPayload(stateIdx, payload, remoteIpv4, serviceText, namespaceText)
        if handled > 0:
            newCount = newCount + handled
            if newCount >= peerBudget:
                break
        attempts = attempts + 1
    c_free(recvBuf)
    c_free(addrBuf)
    hostSweepPeers(stateIdx)
    return newCount

fn hostPeersJsonText(stateIdx: int32, limit: int32): str =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return "[]"
    hostSweepPeers(stateIdx)
    var out: str = "["
    var emitted: int32
    for i in 0..<gNodes[stateIdx].hostPeerCount:
        if emitted >= limit:
            break
        let peer: HostPeerState = gNodes[stateIdx].hostPeers[i]
        if peer.used && len(peer.peerId) > 0 && len(peer.addr) > 0:
            if emitted > 0:
                out = out + ","
            out = out +
                  "{" +
                  "\"peerId\":" + toJsonStringValue(peer.peerId) + "," +
                  "\"addrs\":[" + toJsonStringValue(peer.addr) + "]," +
                  "\"connected\":false," +
                  "\"source\":" + toJsonStringValue(if len(peer.source) > 0: peer.source else: "mdns") +
                  "}"
            emitted = emitted + 1
    out = out + "]"
    return out

fn hostLastDiscoveredPeersJsonText(stateIdx: int32, limit: int32): str =
    if limit <= 0:
        return "[]"
    let ageMs: int32 = int32(nowMs() - gNodes[stateIdx].hostLastDiscoveredAtMs)
    if len(gNodes[stateIdx].hostLastDiscoveredPeerId) <= 0:
        return "[]"
    if len(gNodes[stateIdx].hostLastDiscoveredAddr) <= 0:
        return "[]"
    if ageMs > hostPeerFreshWindowMs32:
        return "[]"
    return "[" +
           "{" +
           "\"peerId\":" + toJsonStringValue(gNodes[stateIdx].hostLastDiscoveredPeerId) + "," +
           "\"addrs\":[" + toJsonStringValue(gNodes[stateIdx].hostLastDiscoveredAddr) + "]," +
           "\"connected\":false," +
           "\"source\":\"mdns-last-discovered\"" +
           "}" +
           "]"

fn drainHostMessagesJsonText(stateIdx: int32, limit: int32): str =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return "[]"
    let total: int32 = gNodes[stateIdx].hostMessageCount
    if total <= 0:
        return "[]"
    var safeLimit: int32 = limit
    if safeLimit <= 0 || safeLimit > total:
        safeLimit = total
    var startAt: int32
    if total > safeLimit:
        startAt = total - safeLimit
    var out: str = "["
    var wrote: bool
    for i in startAt..<total:
        let message: HostMessageState = gNodes[stateIdx].hostMessages[i]
        if message.used:
            if wrote:
                out = out + ","
            out = out +
                  "{" +
                  "\"peerId\":" + toJsonStringValue(message.peerId) + "," +
                  "\"conversationId\":" + toJsonStringValue(message.conversationId) + "," +
                  "\"messageId\":" + toJsonStringValue(message.messageId) + "," +
                  "\"payload\":" + message.payloadJson + "," +
                  "\"timestampMs\":" + strings.int64ToStr(message.timestampMs) +
                  "}"
            wrote = true
    out = out + "]"
    for i in 0..<total:
        gNodes[stateIdx].hostMessages[i] = initHostMessageState()
    gNodes[stateIdx].hostMessageCount = 0
    return out

fn mergeJsonArrayText(leftText: str, rightText: str): str =
    let left: str = trimText(leftText)
    let right: str = trimText(rightText)
    if len(left) <= 2 || left == "[]":
        if len(right) <= 0:
            return "[]"
        return right
    if len(right) <= 2 || right == "[]":
        return left
    if !startsWith(left, "[") || !hostEndsWith(left, "]"):
        return right
    if !startsWith(right, "[") || !hostEndsWith(right, "]"):
        return left
    return sliceBytes(left, 0, len(left) - 1) + "," + sliceBytes(right, 1, len(right))

@exportc("um_host_set_peer_id_direct")
fn um_host_set_peer_id_direct(handle: int64, peerId: cstring): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return 0
    let peerText: str = trimText(hostCopyTextFromCString(peerId))
    if len(peerText) <= 0:
        return 0
    gNodes[slot].localPeerId = peerText
    return 1

@exportc("um_host_set_listen_addr_direct")
fn um_host_set_listen_addr_direct(handle: int64, listenAddr: cstring): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return 0
    let addrText: str = trimText(hostCopyTextFromCString(listenAddr))
    if len(addrText) <= 0:
        return 0
    gNodes[slot].listenAddr = addrText
    return 1

@exportc("um_host_mdns_set_interface_direct")
fn um_host_mdns_set_interface_direct(ipv4: cstring): int32 =
    let value: str = trimText(hostCopyTextFromCString(ipv4))
    if len(value) <= 0:
        if gHostMdnsInterfaceIpv4 != "":
            closeHostMdnsSocketsForInterfaceChange()
        gHostMdnsInterfaceIpv4 = ""
        return 1
    let rawIp: ptr = c_malloc(4)
    if rawIp == nil:
        return 0
    let ok: bool = hostParseIpv4Text(value, rawIp)
    c_free(rawIp)
    if !ok:
        return 0
    if gHostMdnsInterfaceIpv4 != value:
        closeHostMdnsSocketsForInterfaceChange()
    gHostMdnsInterfaceIpv4 = value
    return 1

@exportc("um_host_mdns_advertise_direct")
fn um_host_mdns_advertise_direct(handle: int64, service: cstring, namespaceText: cstring): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return 0
    let serviceText: str = hostCopyTextFromCString(service)
    var okCount: int32
    okCount = okCount + hostKickStandardMdnsFrames(slot, serviceText)
    let fd: int32 = ensureHostDiscoverySocket(slot)
    if fd < 0:
        if okCount > 0:
            return 1
        return 0
    let payload: str = hostAnnouncePayload(slot, serviceText, hostCopyTextFromCString(namespaceText))
    if len(payload) <= 0:
        if okCount > 0:
            return 1
        return 0
    okCount = okCount + hostSendDiscoveryFrame(fd, hostDiscoveryPort, payload)
    okCount = okCount + hostSendDiscoveryFrame(fd, hostDiscoveryLegacyPort, payload)
    if okCount <= 0:
        return 0
    return 1

@exportc("um_host_mdns_drain_host_direct")
fn um_host_mdns_drain_host_direct(handle: int64, service: cstring, namespaceText: cstring, limit: int32): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return 0
    let serviceText: str = hostCopyTextFromCString(service)
    let namespaceValue: str = hostCopyTextFromCString(namespaceText)
    let budget: int32 = if limit > 0: limit else: 8
    return drainHostDiscoverySocket(slot, serviceText, namespaceValue, budget, 0)

@exportc("um_host_mdns_kick_standard_direct")
fn um_host_mdns_kick_standard_direct(handle: int64, service: cstring): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return 0
    let serviceText: str = hostCopyTextFromCString(service)
    return hostKickStandardMdnsFrames(slot, serviceText)

@exportc("um_host_mdns_open_standard_direct")
fn um_host_mdns_open_standard_direct(handle: int64): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return 0
    return hostEnsureStandardMdnsSocketOnce(slot)

@exportc("um_host_mdns_query_standard_direct")
fn um_host_mdns_query_standard_direct(handle: int64, service: cstring): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return 0
    let serviceText: str = hostCopyTextFromCString(service)
    return hostKickStandardMdnsQueryFrame(slot, serviceText)

@exportc("um_host_mdns_announce_standard_direct")
fn um_host_mdns_announce_standard_direct(handle: int64, service: cstring): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return 0
    let serviceText: str = hostCopyTextFromCString(service)
    return hostKickStandardMdnsAnnouncementFrame(slot, serviceText)

@exportc("um_host_mdns_drain_standard_direct")
fn um_host_mdns_drain_standard_direct(handle: int64, service: cstring, limit: int32): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return 0
    let serviceText: str = hostCopyTextFromCString(service)
    let budget: int32 = if limit > 0: limit else: 8
    return drainStandardMdnsSocket(slot, serviceText, budget)

@exportc("um_host_mdns_discover_direct")
fn um_host_mdns_discover_direct(handle: int64, service: cstring, namespaceText: cstring, limit: int32): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return 0
    let serviceText: str = hostCopyTextFromCString(service)
    let namespaceValue: str = hostCopyTextFromCString(namespaceText)
    let budget: int32 = if limit > 0: limit else: 8
    let hostFound: int32 = drainHostDiscoverySocket(slot, serviceText, namespaceValue, budget, 0)
    let kicked: int32 = hostKickStandardMdnsFrames(slot, serviceText)
    if kicked <= 0:
        return hostFound
    return hostFound + drainStandardMdnsSocket(slot, serviceText, budget)

@exportc("hostDumpPeersLimit")
fn hostDumpPeersLimit(handle: int64, limit: int32): cstring =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return dupText("[]")
    let safeLimit: int32 = if limit > 0 && limit < maxHostPeers: limit else: maxHostPeers
    return dupText(hostPeersJsonText(slot, safeLimit))

@exportc("um_hostDumpPeersLimit")
fn um_hostDumpPeersLimit(handle: int64, limit: int32): cstring =
    return hostDumpPeersLimit(handle, limit)

@exportc("um_host_last_discovered_peers_json")
fn um_host_last_discovered_peers_json(handle: int64, limit: int32): cstring =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return dupText("[]")
    return dupText(hostLastDiscoveredPeersJsonText(slot, limit))

@exportc("um_host_direct_send_text")
fn um_host_direct_send_text(handle: int64,
                            peerId: cstring,
                            conversationId: cstring,
                            messageId: cstring,
                            payloadJson: cstring): int32 =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        setLastError("host_direct_send: invalid_handle")
        return 0
    let peerText: str = trimText(hostCopyTextFromCString(peerId))
    if len(peerText) <= 0:
        setLastError("host_direct_send: invalid_peer")
        return 0
    let messagePayloadText: str = hostCopyTextFromCString(payloadJson)
    let _ = drainHostDiscoverySocket(slot, "", "", 2, 0)
    var remoteAddr: str
    for i in 0..<gNodes[slot].hostPeerCount:
        let peer: HostPeerState = gNodes[slot].hostPeers[i]
        if peer.used && peer.peerId == peerText:
            remoteAddr = peer.addr
            break
    var remoteIpv4: str = hostExtractIpv4FromMultiaddr(remoteAddr)
    if len(remoteIpv4) <= 0:
        remoteIpv4 = hostDirectPayloadSeedIpv4(messagePayloadText)
    if len(remoteIpv4) <= 0:
        setLastError("host_direct_send: missing_route")
        return 0
    var transientFd: bool
    var fd: int32 = ensureHostDiscoverySocket(slot)
    if fd < 0:
        fd = openHostDirectSendSocket()
        transientFd = true
    if fd < 0:
        setLastError("host_direct_send: socket_failed")
        return 0
    let frameText: str =
        "MSG|" +
        trimText(gNodes[slot].localPeerId) + "|" +
        trimText(hostCopyTextFromCString(conversationId)) + "|" +
        trimText(hostCopyTextFromCString(messageId)) + "|" +
        hostHexEncodeText(messagePayloadText) + "|" +
        strings.int64ToStr(nowMs())
    let sent: int32 = hostSendDirectedFrame(fd, remoteIpv4, hostDiscoveryPort, frameText)
    if transientFd:
        let _ = libc_close_bridge(fd)
    if sent <= 0:
        setLastError("host_direct_send: sendto_failed")
    return sent

@exportc("um_host_direct_drain_messages_json")
fn um_host_direct_drain_messages_json(handle: int64, limit: int32): cstring =
    let slot: int32 = ensureHostStateSlot(handle)
    if slot < 0:
        return dupText("[]")
    let _ = drainHostDiscoverySocket(slot, "", "", if limit > 0: limit * 2 + 2 else: 8, 40)
    return dupText(drainHostMessagesJsonText(slot, limit))

fn writeNodeInitStage(stage: str) =
    gLastInitStage = stage
    system.echo(system.strToCStringTemp(stage))

fn setLastError(text: str) =
    gLastError = text

fn clearLastError() =
    gLastError = ""

fn nowMs(): int64 =
    return c_time(nil) * 1000

fn ord(c: char): int32 =
    return system.ord(c)

fn chr(x: int32): char =
    return system.chr(x)

@exportc("driver_c_chr_i32_compat")
fn driver_c_chr_i32_compat_export(x: int32): char =
    return system.chr(x)

@exportc("driver_c_ord_char_compat")
fn driver_c_ord_char_compat_export(c: char): int32 =
    return system.ord(c)

fn charToStr(c: char): str =
    return strings.charToStr(c)

fn sliceBytes(text: str, start: int32, count: int32): str =
    return strings.sliceBytes(text, start, count)

fn trimText(text: str): str =
    let n: int32 = len(text)
    if n <= 0:
        return ""
    var left: int32
    while left < n:
        let ch: char = text[left]
        if ch != ' ' && ch != '\t' && ch != '\r' && ch != '\n':
            break
        left = left + 1
    if left >= n:
        return ""
    var right: int32 = n
    while right > left:
        let ch: char = text[right - 1]
        if ch != ' ' && ch != '\t' && ch != '\r' && ch != '\n':
            break
        right = right - 1
    return sliceBytes(text, left, right - left)

fn strLowerAscii(text: str): str =
    var out: str
    for i in 0..<len(text):
        let ch: char = text[i]
        if ch >= 'A' && ch <= 'Z':
            out = out + charToStr(chr(ord(ch) + 32))
        else:
            out = out + charToStr(ch)
    return out

fn startsWith(text: str, prefix: str): bool =
    if len(prefix) <= 0:
        return true
    if len(text) < len(prefix):
        return false
    for i in 0..<len(prefix):
        if text[i] != prefix[i]:
            return false
    return true

fn normalizeFsPath(pathText: str): str =
    let text: str = trimText(pathText)
    if len(text) <= 0:
        return ""
    var out: str
    for i in 0..<len(text):
        let ch: char = text[i]
        if ch == '\\':
            out = out + "/"
        else:
            out = out + charToStr(ch)
    return out

fn baseName(path: str): str =
    let text: str = trimText(path)
    let total: int32 = len(text)
    if total <= 0:
        return ""
    var endPos: int32 = total
    while endPos > 1 && text[endPos - 1] == '/':
        endPos = endPos - 1
    var i: int32 = endPos - 1
    while i >= 0:
        if text[i] == '/':
            if i + 1 >= endPos:
                return ""
            return sliceBytes(text, i + 1, endPos - i - 1)
        i = i - 1
    return sliceBytes(text, 0, endPos)

fn fileExists(path: str): bool =
    let safePath: str = normalizeFsPath(path)
    if len(safePath) <= 0:
        return false
    return c_cheng_file_exists(safePath) == 1

fn fileSizeBytes(path: str): int64 =
    let safePath: str = normalizeFsPath(path)
    if len(safePath) <= 0:
        return 0
    let stream: int64 = c_cheng_fopen(safePath, "rb")
    if stream == 0:
        return 0
    if c_cheng_fseek(stream, 0, fileSeekEnd) != 0:
        let _ = c_cheng_fclose(stream)
        return 0
    let size: int64 = c_cheng_ftell(stream)
    let _ = c_cheng_fclose(stream)
    if size > 0:
        return size
    return 0

fn stablePeerBase58Char(valueRaw: int32): char =
    var value: int32 = valueRaw % 58
    if value < 0:
        value = value + 58
    if value == 0:
        return '1'
    if value == 1:
        return '2'
    if value == 2:
        return '3'
    if value == 3:
        return '4'
    if value == 4:
        return '5'
    if value == 5:
        return '6'
    if value == 6:
        return '7'
    if value == 7:
        return '8'
    if value == 8:
        return '9'
    if value == 9:
        return 'A'
    if value == 10:
        return 'B'
    if value == 11:
        return 'C'
    if value == 12:
        return 'D'
    if value == 13:
        return 'E'
    if value == 14:
        return 'F'
    if value == 15:
        return 'G'
    if value == 16:
        return 'H'
    if value == 17:
        return 'J'
    if value == 18:
        return 'K'
    if value == 19:
        return 'L'
    if value == 20:
        return 'M'
    if value == 21:
        return 'N'
    if value == 22:
        return 'P'
    if value == 23:
        return 'Q'
    if value == 24:
        return 'R'
    if value == 25:
        return 'S'
    if value == 26:
        return 'T'
    if value == 27:
        return 'U'
    if value == 28:
        return 'V'
    if value == 29:
        return 'W'
    if value == 30:
        return 'X'
    if value == 31:
        return 'Y'
    if value == 32:
        return 'Z'
    if value == 33:
        return 'a'
    if value == 34:
        return 'b'
    if value == 35:
        return 'c'
    if value == 36:
        return 'd'
    if value == 37:
        return 'e'
    if value == 38:
        return 'f'
    if value == 39:
        return 'g'
    if value == 40:
        return 'h'
    if value == 41:
        return 'i'
    if value == 42:
        return 'j'
    if value == 43:
        return 'k'
    if value == 44:
        return 'm'
    if value == 45:
        return 'n'
    if value == 46:
        return 'o'
    if value == 47:
        return 'p'
    if value == 48:
        return 'q'
    if value == 49:
        return 'r'
    if value == 50:
        return 's'
    if value == 51:
        return 't'
    if value == 52:
        return 'u'
    if value == 53:
        return 'v'
    if value == 54:
        return 'w'
    if value == 55:
        return 'x'
    if value == 56:
        return 'y'
    return 'z'

fn stablePeerIdFromSeed(seedRaw: str): str =
    var seedText: str = trimText(seedRaw)
    if len(seedText) <= 0:
        seedText = "did:unimaker:unknown"
    var acc: int32 = 17
    for i in 0..<len(seedText):
        acc = (acc * 131 + (ord(seedText[i]) & 255) + i) % 1000003
    var out: str = stablePeerPrefix
    for j in 0..<44:
        let code: int32 = ord(seedText[j % len(seedText)]) & 255
        acc = (acc * 131 + code + j) % 1000003
        out = out + charToStr(stablePeerBase58Char(acc + code + j))
    return out

fn indexOf(text: str, needle: str, start: int32): int32 =
    let n: int32 = len(text)
    let m: int32 = len(needle)
    if m <= 0:
        if start < 0:
            return 0
        if start > n:
            return n
        return start
    if n < m:
        return -1
    var begin: int32 = start
    if begin < 0:
        begin = 0
    let last: int32 = n - m
    for i in begin..last:
        var ok: bool = true
        for j in 0..<m:
            if text[i + j] != needle[j]:
                ok = false
                break
        if ok:
            return i
    return -1

fn isJsonWhitespace(ch: char): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn findTopLevelConfigColon(configText: str, keyName: str): int32 =
    if len(configText) <= 0 || len(keyName) <= 0:
        return -1
    let n: int32 = len(configText)
    var objectDepth: int32
    var arrayDepth: int32
    var inString: bool
    var escapeNext: bool
    var i: int32
    while i < n:
        let ch: char = configText[i]
        if inString:
            if escapeNext:
                escapeNext = false
            elif ch == '\\':
                escapeNext = true
            elif ch == '"':
                inString = false
            i = i + 1
            continue
        if ch == '"':
            if objectDepth == 1 && arrayDepth == 0:
                let keyStart: int32 = i + 1
                var keyEnd: int32 = keyStart
                var keyEscape: bool
                while keyEnd < n:
                    let keyChar: char = configText[keyEnd]
                    if keyEscape:
                        keyEscape = false
                    elif keyChar == '\\':
                        keyEscape = true
                    elif keyChar == '"':
                        break
                    keyEnd = keyEnd + 1
                if keyEnd > keyStart && sliceBytes(configText, keyStart, keyEnd - keyStart) == keyName:
                    var cursor: int32 = keyEnd + 1
                    while cursor < n && isJsonWhitespace(configText[cursor]):
                        cursor = cursor + 1
                    if cursor < n && configText[cursor] == ':':
                        return cursor
                i = keyEnd + 1
                continue
            inString = true
            i = i + 1
            continue
        elif ch == '{':
            objectDepth = objectDepth + 1
        elif ch == '}':
            if objectDepth > 0:
                objectDepth = objectDepth - 1
        elif ch == '[':
            arrayDepth = arrayDepth + 1
        elif ch == ']':
            if arrayDepth > 0:
                arrayDepth = arrayDepth - 1
        i = i + 1
    return -1

fn parseConfigHasKey(configText: str, keyName: str): bool =
    return findTopLevelConfigColon(configText, keyName) >= 0

fn parseConfigQuotedValue(configText: str, keyName: str): str =
    let colonPos: int32 = findTopLevelConfigColon(configText, keyName)
    if colonPos < 0:
        return ""
    let n: int32 = len(configText)
    var cursor: int32 = colonPos + 1
    while cursor < n && isJsonWhitespace(configText[cursor]):
        cursor = cursor + 1
    if cursor >= n:
        return ""
    if configText[cursor] == '"':
        let valueStart: int32 = cursor + 1
        var valueEnd: int32 = valueStart
        while valueEnd < n:
            if configText[valueEnd] == '"' && configText[valueEnd - 1] != '\\':
                break
            valueEnd = valueEnd + 1
        if valueEnd <= valueStart:
            return ""
        return sliceBytes(configText, valueStart, valueEnd - valueStart)
    var valueEnd: int32 = cursor
    while valueEnd < n:
        let ch: char = configText[valueEnd]
        if ch == ',' || ch == '}' || ch == '\n' || ch == '\r':
            break
        valueEnd = valueEnd + 1
    if valueEnd <= cursor:
        return ""
    return trimText(sliceBytes(configText, cursor, valueEnd - cursor))

fn parseConfigObjectValue(configText: str, keyName: str): str =
    let colonPos: int32 = findTopLevelConfigColon(configText, keyName)
    if colonPos < 0:
        return ""
    let n: int32 = len(configText)
    var cursor: int32 = colonPos + 1
    while cursor < n && isJsonWhitespace(configText[cursor]):
        cursor = cursor + 1
    if cursor >= n || configText[cursor] != '{':
        return ""
    var depth: int32
    var inString: bool
    var escapeNext: bool
    var endPos: int32 = -1
    var i: int32 = cursor
    while i < n:
        let ch: char = configText[i]
        if inString:
            if escapeNext:
                escapeNext = false
            elif ch == '\\':
                escapeNext = true
            elif ch == '"':
                inString = false
            i = i + 1
            continue
        if ch == '"':
            inString = true
        elif ch == '{':
            depth = depth + 1
        elif ch == '}':
            depth = depth - 1
            if depth == 0:
                endPos = i
                break
        i = i + 1
    if endPos <= cursor:
        return ""
    return sliceBytes(configText, cursor, endPos - cursor + 1)

fn parsePositiveInt64Text(raw: str, fallback: int64): int64 =
    let text: str = trimText(raw)
    if len(text) <= 0:
        return fallback
    var value: int64
    var sawDigit: bool
    for i in 0..<len(text):
        let ch: char = text[i]
        if ch < '0' || ch > '9':
            break
        value = value * 10 + int64(ord(ch) - ord('0'))
        sawDigit = true
    if !sawDigit:
        return fallback
    return value

fn parsePositiveInt32Text(raw: str, fallback: int32): int32 =
    let value: int64 = parsePositiveInt64Text(raw, int64(fallback))
    if value <= 0:
        return fallback
    if value > 2147483647:
        return 2147483647
    return int32(value)

fn mediaRpcPayloadText(raw: str): str =
    let body: str = trimText(raw)
    if len(body) <= 0:
        return ""
    if startsWith(body, "{") && hostEndsWith(body, "}") &&
        trimText(parseConfigQuotedValue(body, "protocol")) == mediaRpcProtocol:
        return body
    let nestedPayload: str = parseConfigObjectValue(body, "payload")
    if len(nestedPayload) > 0 && trimText(parseConfigQuotedValue(nestedPayload, "protocol")) == mediaRpcProtocol:
        return nestedPayload
    let bodyText: str = trimText(jsonUnescapeStringValue(parseConfigQuotedValue(body, "body")))
    if startsWith(bodyText, "{") && hostEndsWith(bodyText, "}") &&
        trimText(parseConfigQuotedValue(bodyText, "protocol")) == mediaRpcProtocol:
        return bodyText
    let contentText: str = trimText(jsonUnescapeStringValue(parseConfigQuotedValue(body, "content")))
    if startsWith(contentText, "{") && hostEndsWith(contentText, "}") &&
        trimText(parseConfigQuotedValue(contentText, "protocol")) == mediaRpcProtocol:
        return contentText
    let textValue: str = trimText(jsonUnescapeStringValue(parseConfigQuotedValue(body, "text")))
    if startsWith(textValue, "{") && hostEndsWith(textValue, "}") &&
        trimText(parseConfigQuotedValue(textValue, "protocol")) == mediaRpcProtocol:
        return textValue
    return ""

fn takeMediaRpcResponsePayload(stateIdx: int32, peerIdText: str, requestIdText: str): str =
    if stateIdx < 0 || stateIdx >= maxNodes || !gNodes[stateIdx].used:
        return ""
    let peerId: str = normalizePeerId(peerIdText)
    let requestId: str = trimText(requestIdText)
    if len(peerId) <= 0 || len(requestId) <= 0:
        return ""
    let total: int32 = gNodes[stateIdx].hostMessageCount
    if total <= 0:
        return ""
    for i in 0..<total:
        let message: HostMessageState = gNodes[stateIdx].hostMessages[i]
        if !message.used || message.peerId != peerId:
            continue
        let payload: str = mediaRpcPayloadText(message.payloadJson)
        if len(payload) <= 0:
            continue
        if trimText(parseConfigQuotedValue(payload, "requestId")) != requestId:
            continue
        if trimText(parseConfigQuotedValue(payload, "kind")) != "response":
            continue
        gNodes[stateIdx].hostMessages[i] = initHostMessageState()
        return payload
    return ""

fn waitForMediaRpcResponse(stateIdx: int32, peerIdText: str, requestIdText: str, timeoutMs: int32): str =
    let startedAt: int64 = nowMs()
    let safeTimeoutMs: int32 =
        if timeoutMs > 0:
            timeoutMs
        else:
            10000
    while nowMs() - startedAt < int64(safeTimeoutMs):
        let existing: str = takeMediaRpcResponsePayload(stateIdx, peerIdText, requestIdText)
        if len(existing) > 0:
            return existing
        let elapsed: int64 = nowMs() - startedAt
        var remaining: int32 = safeTimeoutMs - int32(elapsed)
        if remaining <= 0:
            break
        if remaining > 180:
            remaining = 180
        let _ = drainHostDiscoverySocket(stateIdx, "", "", 8, remaining)
    let finalPayload: str = takeMediaRpcResponsePayload(stateIdx, peerIdText, requestIdText)
    if len(finalPayload) > 0:
        return finalPayload
    return ""

fn jsonUnescapeStringValue(text: str): str =
    var out: str
    var i: int32
    while i < len(text):
        let ch: char = text[i]
        if ch != '\\':
            out = out + charToStr(ch)
            i = i + 1
            continue
        if i + 1 >= len(text):
            out = out + charToStr(ch)
            i = i + 1
            continue
        let esc: char = text[i + 1]
        if esc == '"' || esc == '\\' || esc == '/':
            out = out + charToStr(esc)
            i = i + 2
            continue
        if esc == 'b':
            out = out + charToStr(chr(8))
            i = i + 2
            continue
        if esc == 'f':
            out = out + charToStr(chr(12))
            i = i + 2
            continue
        if esc == 'n':
            out = out + "\n"
            i = i + 2
            continue
        if esc == 'r':
            out = out + "\r"
            i = i + 2
            continue
        if esc == 't':
            out = out + "\t"
            i = i + 2
            continue
        if esc == 'u' && i + 5 < len(text):
            let h1: int32 = hostHexValue(text[i + 2])
            let h2: int32 = hostHexValue(text[i + 3])
            let h3: int32 = hostHexValue(text[i + 4])
            let h4: int32 = hostHexValue(text[i + 5])
            if h1 == 0 && h2 == 0 && h3 >= 0 && h4 >= 0:
                out = out + charToStr(chr((h3 << 4) | h4))
                i = i + 6
                continue
        out = out + charToStr(esc)
        i = i + 2
    return out

fn parseQuotedValues(text: str): str[] =
    var out: str[]
    let n: int32 = len(text)
    if n <= 1:
        return out
    var i: int32
    while i < n:
        if text[i] != '"':
            i = i + 1
            continue
        let start: int32 = i + 1
        var endPos: int32 = start
        while endPos < n:
            if text[endPos] == '"' && text[endPos - 1] != '\\':
                break
            endPos = endPos + 1
        if endPos <= start || endPos > n:
            break
        add(out, jsonUnescapeStringValue(sliceBytes(text, start, endPos - start)))
        i = endPos + 1
    return out

fn parseConfigArrayValues(configText: str, keyName: str): str[] =
    var out: str[]
    if len(configText) <= 0 || len(keyName) <= 0:
        return out
    let colonPos: int32 = findTopLevelConfigColon(configText, keyName)
    if colonPos < 0:
        return out
    var openPos: int32 = -1
    for i in (colonPos + 1)..<len(configText):
        let ch: char = configText[i]
        if isJsonWhitespace(ch):
            continue
        if ch == '[':
            openPos = i
            break
        return out
    if openPos < 0:
        return out
    var closePos: int32 = -1
    var depth: int32
    for i in openPos..<len(configText):
        let ch: char = configText[i]
        if ch == '[':
            depth = depth + 1
        elif ch == ']':
            depth = depth - 1
            if depth == 0:
                closePos = i
                break
    if closePos <= openPos:
        return out
    return parseQuotedValues(sliceBytes(configText, openPos, closePos - openPos + 1))

fn hostDirectPayloadSeedIpv4(payloadBodyText: str): str =
    var addrs: str[] = parseConfigArrayValues(payloadBodyText, "seedAddrs")
    if len(addrs) <= 0:
        addrs = parseConfigArrayValues(payloadBodyText, "multiaddrs")
    if len(addrs) <= 0:
        addrs = parseConfigArrayValues(payloadBodyText, "addresses")
    for i in 0..<len(addrs):
        let ipv4: str = hostExtractIpv4FromMultiaddr(trimText(addrs[i]))
        if len(ipv4) > 0:
            return ipv4
    return ""

fn toJsonStringValue(text: str): str =
    var out: str = "\""
    for i in 0..<len(text):
        let ch: char = text[i]
        if ch == '\\':
            out = out + "\\\\"
        elif ch == '"':
            out = out + "\\\""
        elif ch == '\n':
            out = out + "\\n"
        elif ch == '\r':
            out = out + "\\r"
        elif ch == '\t':
            out = out + "\\t"
        else:
            out = out + charToStr(ch)
    out = out + "\""
    return out

fn boolText(value: bool): str =
    if value:
        return "true"
    return "false"

fn asiVoiceTimestamp(timestampMs: int64): int64 =
    if timestampMs > 0:
        return timestampMs
    return nowMs()

fn asiVoiceDurationMs(durationMs: int64): int64 =
    if durationMs > 0:
        return durationMs
    return restoredDictationMinRecordingMs

fn asiVoiceDurationSeconds(durationMs: int64): int64 =
    let safeDurationMs: int64 = asiVoiceDurationMs(durationMs)
    var seconds: int64 = safeDurationMs / 1000
    if seconds <= 0:
        seconds = 1
    return seconds

fn asiVoiceMimeType(raw: str): str =
    let text: str = trimText(raw)
    if len(text) > 0:
        return text
    return "audio/mp4"

fn asiVoiceTranscript(raw: str): str =
    return trimText(raw)

fn asiVoiceContractJsonText(): str =
    return "{" +
        "\"schema\":" + toJsonStringValue(asiVoiceSchema) + "," +
        "\"dictation\":{" +
            "\"composerGate\":" + toJsonStringValue(restoredComposerDictationGate) + "," +
            "\"globalGate\":" + toJsonStringValue(restoredGlobalDictationGate) + "," +
            "\"minRecordingMs\":" + strings.IntToStr(restoredDictationMinRecordingMs) + "," +
            "\"holdToTalkDelayMs\":" + strings.IntToStr(restoredDictationHoldToTalkDelayMs) + "," +
            "\"endpoint\":" + toJsonStringValue(restoredDictationEndpoint) + "," +
            "\"base64Header\":" + toJsonStringValue(restoredDictationBase64Header) + "," +
            "\"transport\":" + toJsonStringValue(restoredDictationTransport) +
        "}," +
        "\"realtime\":{" +
            "\"transport\":" + toJsonStringValue(restoredRealtimeTransport) + "," +
            "\"dataChannel\":" + toJsonStringValue(restoredRealtimeDataChannel) + "," +
            "\"startRoute\":" + toJsonStringValue(restoredRealtimeStartRoute) + "," +
            "\"stopRoute\":" + toJsonStringValue(restoredRealtimeStopRoute) + "," +
            "\"appendTextRoute\":" + toJsonStringValue(restoredRealtimeAppendTextRoute) + "," +
            "\"webRtcTransportType\":" + toJsonStringValue(restoredRealtimeWebRtcTransportType) + "," +
            "\"startedEvent\":" + toJsonStringValue(restoredRealtimeStartedEvent) + "," +
            "\"sdpEvent\":" + toJsonStringValue(restoredRealtimeSdpEvent) + "," +
            "\"transcriptDeltaEvent\":" + toJsonStringValue(restoredRealtimeTranscriptDeltaEvent) + "," +
            "\"transcriptDoneEvent\":" + toJsonStringValue(restoredRealtimeTranscriptDoneEvent) + "," +
            "\"errorEvent\":" + toJsonStringValue(restoredRealtimeErrorEvent) + "," +
            "\"closedEvent\":" + toJsonStringValue(restoredRealtimeClosedEvent) + "," +
            "\"outputAudioStartedEvent\":" + toJsonStringValue(restoredRealtimeOutputAudioStartedEvent) +
        "}" +
    "}"

fn asiVoiceTurnPayloadText(transcriptRaw: str,
                           durationMsRaw: int64,
                           mimeTypeRaw: str,
                           audioRefRaw: str,
                           timestampMsRaw: int64): str =
    let transcript: str = asiVoiceTranscript(transcriptRaw)
    let safeDurationMs: int64 = asiVoiceDurationMs(durationMsRaw)
    let safeMimeType: str = asiVoiceMimeType(mimeTypeRaw)
    let audioRef: str = trimText(audioRefRaw)
    let timestampMs: int64 = asiVoiceTimestamp(timestampMsRaw)
    return "{" +
        "\"schema\":" + toJsonStringValue(asiVoiceSchema) + "," +
        "\"role\":\"user\"," +
        "\"type\":\"voice\"," +
        "\"messageType\":\"voice\"," +
        "\"transcript\":" + toJsonStringValue(transcript) + "," +
        "\"hasTranscript\":" + boolText(len(transcript) > 0) + "," +
        "\"durationMs\":" + strings.int64ToStr(safeDurationMs) + "," +
        "\"durationSeconds\":" + strings.int64ToStr(asiVoiceDurationSeconds(safeDurationMs)) + "," +
        "\"audioMime\":" + toJsonStringValue(safeMimeType) + "," +
        "\"audioRef\":" + toJsonStringValue(audioRef) + "," +
        "\"dictationTransport\":" + toJsonStringValue(restoredDictationTransport) + "," +
        "\"dictationEndpoint\":" + toJsonStringValue(restoredDictationEndpoint) + "," +
        "\"dictationBase64Header\":" + toJsonStringValue(restoredDictationBase64Header) + "," +
        "\"realtimeTransport\":" + toJsonStringValue(restoredRealtimeTransport) + "," +
        "\"realtimeDataChannel\":" + toJsonStringValue(restoredRealtimeDataChannel) + "," +
        "\"realtimeAppendTextRoute\":" + toJsonStringValue(restoredRealtimeAppendTextRoute) + "," +
        "\"realtimeWebRtcTransportType\":" + toJsonStringValue(restoredRealtimeWebRtcTransportType) + "," +
        "\"assistantAction\":\"voice_ack\"," +
        "\"timestampMs\":" + strings.int64ToStr(timestampMs) +
    "}"

fn asiVoiceReplyPayloadText(transcriptRaw: str, durationMsRaw: int64, timestampMsRaw: int64): str =
    let transcript: str = asiVoiceTranscript(transcriptRaw)
    let safeDurationMs: int64 = asiVoiceDurationMs(durationMsRaw)
    let timestampMs: int64 = asiVoiceTimestamp(timestampMsRaw)
    return "{" +
        "\"schema\":" + toJsonStringValue(asiVoiceSchema) + "," +
        "\"role\":\"assistant\"," +
        "\"type\":\"text\"," +
        "\"replyKind\":\"voice_ack\"," +
        "\"transcript\":" + toJsonStringValue(transcript) + "," +
        "\"hasTranscript\":" + boolText(len(transcript) > 0) + "," +
        "\"durationMs\":" + strings.int64ToStr(safeDurationMs) + "," +
        "\"durationSeconds\":" + strings.int64ToStr(asiVoiceDurationSeconds(safeDurationMs)) + "," +
        "\"timestampMs\":" + strings.int64ToStr(timestampMs) +
    "}"

@exportc("asi_voice_contract_json_cstr")
