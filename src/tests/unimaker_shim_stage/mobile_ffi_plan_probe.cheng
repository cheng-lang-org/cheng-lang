@exportc("libp2p_reconnect_bootstrap")
fn libp2p_reconnect_bootstrap(handle: int64): bool =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return false
    for i in 0..<gNodes[idx].peerCount:
        if gNodes[idx].peers[i].used:
            let _ = connectPeerLocal(idx, gNodes[idx].peers[i].peerId, "wan")
    return true

@exportc("libp2p_join_via_seed_bootstrap")
fn libp2p_join_via_seed_bootstrap(handle: int64,
                                  peerId: str,
                                  addressesJson: str,
                                  source: str,
                                  limit: int32): str =
    let _ = limit
    let peerIdText: str = normalizePeerId((peerId))
    let sourceText: str = trimText((source))
    let addressesText: str = (addressesJson)
    let registerOk: bool = registerPeerHintsLocal(handle, peerIdText, addressesText, sourceText)
    let connectOk: bool =
        if len(peerIdText) > 0:
            connectPeerHandle(handle, peerIdText, if len(sourceText) > 0: sourceText else: "wan") == resultOk
        else:
            false
    return cStr("{" +
        "\"ok\":" + boolText(registerOk || connectOk) + "," +
        "\"peerId\":" + toJsonStringValue(peerIdText) + "," +
        "\"source\":" + toJsonStringValue(sourceText) + "," +
        "\"connected\":" + boolText(connectOk) +
        "}")

