@exportc("libp2p_feed_publish_entry")
fn libp2p_feed_publish_entry(handle: int64, payloadJson: str): bool =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        return false
    let payloadBodyText: str = (payloadJson)
    addFeedEntry(idx, payloadBodyText)
    emitNodeEvent(idx, "feed_publish", payloadBodyText)
    for i in 0..<gNodes[idx].peerCount:
        if !gNodes[idx].peers[i].used || !gNodes[idx].peers[i].connected:
            continue
        let remoteIdx: int32 = findNodeByPeerId(gNodes[idx].peers[i].peerId)
        if remoteIdx >= 0:
            addFeedEntry(remoteIdx, payloadBodyText)
            emitNodeEvent(remoteIdx, "feed_receive", payloadBodyText)
    return true

@exportc("libp2p_fetch_file_providers")
fn libp2p_fetch_file_providers(handle: int64, key: str, limit: int32): str =
    clearLastError()
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        setLastError("fetch_file_providers: node_not_initialized")
        return cStr("{\"providers\":[],\"count\":0}")
    return cStr(fileProvidersJson(idx, (key), limit))

@exportc("libp2p_register_local_file")
fn libp2p_register_local_file(handle: int64, key: str, path: str, metaJson: str): str =
    clearLastError()
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        setLastError("register_local_file: node_not_initialized")
        return cStr("{\"ok\":false,\"error\":\"node_not_initialized\"}")
    let keyText: str = trimText((key))
    let pathText: str = normalizeFsPath((path))
    if len(keyText) <= 0:
        setLastError("register_local_file: missing_key")
        return cStr("{\"ok\":false,\"error\":\"missing_key\"}")
    if len(pathText) <= 0 || !fileExists(pathText):
        setLastError("register_local_file: file_missing")
        return cStr("{\"ok\":false,\"error\":\"file_missing\"}")
    let metaText: str = trimText((metaJson))
    let fileNameText: str = trimText(parseConfigQuotedValue(metaText, "fileName"))
    let mimeTypeText: str = trimText(parseConfigQuotedValue(metaText, "mimeType"))
    let sha256Text: str = trimText(parseConfigQuotedValue(metaText, "sha256"))
    let sizeBytes: int64 = fileSizeBytes(pathText)
    let slot: int32 = upsertSharedFile(idx, keyText, pathText, fileNameText, mimeTypeText, sha256Text, sizeBytes)
    if slot < 0:
        setLastError("register_local_file: register_failed")
        return cStr("{\"ok\":false,\"error\":\"register_failed\"}")
    let out: str =
        "{\"ok\":true,\"key\":" + toJsonStringValue(keyText) +
        ",\"path\":" + toJsonStringValue(pathText) +
        ",\"sizeBytes\":" + strings.int64ToStr(gNodes[idx].sharedFiles[slot].sizeBytes) +
        ",\"fileName\":" + toJsonStringValue(gNodes[idx].sharedFiles[slot].fileName) +
        ",\"mimeType\":" + toJsonStringValue(gNodes[idx].sharedFiles[slot].mimeType) +
        "}"
    emitNodeEvent(idx, "file.register", out)
    return cStr(out)

@exportc("libp2p_request_file_chunk")
fn libp2p_request_file_chunk(handle: int64, peerId: str, requestJson: str, maxBytes: int32): str =
    clearLastError()
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        setLastError("request_file_chunk: node_not_initialized")
        return cStr("{\"ok\":false,\"error\":\"node_not_initialized\"}")
    let peerIdText: str = normalizePeerId((peerId))
    if len(peerIdText) <= 0:
        setLastError("request_file_chunk: missing_peer")
        return cStr("{\"ok\":false,\"error\":\"missing_peer\"}")
    let requestText: str = trimText((requestJson))
    var requestPayload: str = mediaRpcPayloadText(requestText)
    if len(requestPayload) <= 0:
        requestPayload = requestText
    let keyText: str = trimText(parseConfigQuotedValue(requestPayload, "key"))
    if len(keyText) <= 0:
        setLastError("request_file_chunk: missing_key")
        return cStr("{\"ok\":false,\"error\":\"missing_key\"}")
    let offsetValue: int64 = parsePositiveInt64Text(parseConfigQuotedValue(requestPayload, "offset"), 0)
    var requestedLength: int32 = parsePositiveInt32Text(parseConfigQuotedValue(requestPayload, "length"), mediaRpcBinaryChunkBytes)
    let maxChunkBytes: int32 =
        if maxBytes > 0 && maxBytes < mediaRpcBinaryChunkBytes:
            maxBytes
        else:
            mediaRpcBinaryChunkBytes
    if requestedLength <= 0 || requestedLength > maxChunkBytes:
        requestedLength = maxChunkBytes
    let requestIdText: str =
        "ffi_media_req_" + strings.int64ToStr(nowMs()) + "_" + strings.int64ToStr(gNodes[idx].nextMessageNonce)
    gNodes[idx].nextMessageNonce = gNodes[idx].nextMessageNonce + 1
    let nowText: str = strings.int64ToStr(nowMs())
    let payloadText: str =
        "{" +
        "\"protocol\":" + toJsonStringValue(mediaRpcProtocol) + "," +
        "\"kind\":\"request\"," +
        "\"requestId\":" + toJsonStringValue(requestIdText) + "," +
        "\"key\":" + toJsonStringValue(keyText) + "," +
        "\"offset\":" + strings.int64ToStr(offsetValue) + "," +
        "\"length\":" + strings.IntToStr(requestedLength) + "," +
        "\"fromPeerId\":" + toJsonStringValue(nodeLocalPeerId(idx)) + "," +
        "\"toPeerId\":" + toJsonStringValue(peerIdText) + "," +
        "\"timestampMs\":" + nowText +
        "}"
    let conversationIdText: str = "media:" + peerIdText
    let envelopeText: str =
        "{" +
        "\"kind\":\"social\"," +
        "\"entity\":\"dm\"," +
        "\"op\":\"send\"," +
        "\"mid\":" + toJsonStringValue(requestIdText) + "," +
        "\"id\":" + toJsonStringValue(requestIdText) + "," +
        "\"messageId\":" + toJsonStringValue(requestIdText) + "," +
        "\"type\":\"text\"," +
        "\"messageType\":\"text\"," +
        "\"payload\":" + payloadText + "," +
        "\"conversationId\":" + toJsonStringValue(conversationIdText) + "," +
        "\"timestampMs\":" + nowText + "," +
        "\"timestamp_ms\":" + nowText + "," +
        "\"sender\":\"me\"," +
        "\"from\":\"me\"" +
        "}"
    gNodes[idx].lastChunkSize = 0
    let sent: int32 =
        um_host_direct_send_text(
            handle,
            system.strToCStringTemp(peerIdText),
            system.strToCStringTemp(conversationIdText),
            system.strToCStringTemp(requestIdText),
            system.strToCStringTemp(envelopeText)
        )
    if sent <= 0:
        let sendErrorText: str = trimText(gLastError)
        let errorName: str =
            if len(sendErrorText) > 0:
                sendErrorText
            else:
                "media_chunk_send_failed"
        setLastError("request_file_chunk: " + errorName)
        return cStr("{\"ok\":false,\"chunkSize\":0,\"error\":" + toJsonStringValue(errorName) + "}")
    let responsePayload: str = waitForMediaRpcResponse(idx, peerIdText, requestIdText, 11000)
    if len(responsePayload) <= 0:
        setLastError("request_file_chunk: media_chunk_timeout")
        return cStr("{\"ok\":false,\"chunkSize\":0,\"error\":\"media_chunk_timeout\"}")
    gNodes[idx].lastChunkSize = parsePositiveInt32Text(parseConfigQuotedValue(responsePayload, "chunkSize"), 0)
    return cStr(responsePayload)

