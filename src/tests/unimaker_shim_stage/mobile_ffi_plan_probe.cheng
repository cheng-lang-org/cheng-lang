    let _ = scope
    let _ = cursor
    return cStr(jsonItemsEnvelope(publishTaskItemsJson(findNodeByHandle(handle), limit)))

@exportc("social_query_presence")
fn social_query_presence(handle: int64, peerIdsJson: str): str =
    let idx: int32 = findNodeByHandle(handle)
    let peerIds: str[] = parseQuotedValues((peerIdsJson))
    if idx < 0:
        return cStr(jsonItemsEnvelope("[]"))
    var out: str = "["
    var wrote: bool
    for i in 0..<len(peerIds):
        let peerIdText: str = normalizePeerId(peerIds[i])
        if len(peerIdText) <= 0:
            continue
        if wrote:
            out = out + ","
        out = out + "{"
        out = out + "\"peerId\":" + toJsonStringValue(peerIdText) + ","
        let isOnline: bool = hasConnectedPeer(idx, peerIdText)
        let presenceText: str =
            if isOnline:
                "online"
            else:
                "offline"
        out = out + "\"online\":" + boolText(isOnline) + ","
        out = out + "\"presence\":" + toJsonStringValue(presenceText)
        out = out + "}"
        wrote = true
    out = out + "]"
    return cStr(jsonItemsEnvelope(out))

@exportc("social_report_list")
