@exportc("libp2p_send_direct_text")
fn libp2p_send_direct_text(handle: int64,
                           peerId: str,
                           messageId: str,
                           text: str,
                           replyTo: str,
                           requestAck: bool,
                           timeoutMs: int32): bool =
    let _ = replyTo
    let _ = requestAck
    let _ = timeoutMs
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        setLastError("send_direct_text: invalid handle or not started")
        return false
    let peerIdText: str = normalizePeerId((peerId))
    if len(peerIdText) <= 0:
        setLastError("send_direct_text: missing peer")
        return false
    if !hasConnectedPeer(idx, peerIdText):
        let _ = connectPeerLocal(idx, peerIdText, "direct_dm")
    let rawMessageId: str = trimText((messageId))
    var messageIdText: str = rawMessageId
    if len(messageIdText) <= 0:
        messageIdText = "msg-" + strings.int64ToStr(nowMs())
    let payloadJson: str = "{\"text\":" + toJsonStringValue((text)) + "}"
    let sendOk: bool =
        um_host_direct_send_text(
            handle,
            system.strToCStringTemp(peerIdText),
            system.strToCStringTemp("dm:" + peerIdText),
            system.strToCStringTemp(messageIdText),
            system.strToCStringTemp(payloadJson)
        ) != 0
    appendMessage(idx, peerIdText, "dm:" + peerIdText, messageIdText, payloadJson, "out", if sendOk: "sent" else: "failed")
    if !sendOk:
        setLastError("send_direct_text: host_direct_send_failed")
    return sendOk

@exportc("libp2p_send_dm_payload")
fn libp2p_send_dm_payload(handle: int64, peerId: str, payload: str, payloadLen: int64): bool =
    let payloadBodyText: str = (payload)
    var text: str = payloadBodyText
    if payloadLen > 0:
        text = sliceBytes(payloadBodyText, 0, int32(payloadLen))
    return libp2p_send_direct_text(handle, peerId, "", text, "", false, 0)

