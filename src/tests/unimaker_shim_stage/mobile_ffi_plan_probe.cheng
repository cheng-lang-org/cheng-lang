fn bootstrapSeedConnectExactPayload(handle: int64,
                                    peerIdTextRaw: str,
                                    addressesJsonTextRaw: str,
                                    sourceTextRaw: str,
                                    limit: int32,
                                    secureTimeoutMs: int32): str =
    let _ = limit
    let _ = secureTimeoutMs
    let peerIdText: str = normalizePeerId(trimText(peerIdTextRaw))
    let sourceText: str = trimText(sourceTextRaw)
    let addressesText: str = trimText(addressesJsonTextRaw)
    let registered: bool = registerPeerHintsLocal(handle, peerIdText, addressesText, sourceText)
    let connected: bool =
        if len(peerIdText) > 0:
            connectPeerHandle(handle, peerIdText, if len(sourceText) > 0: sourceText else: "wan") == resultOk
        else:
            false
    return "{" +
        "\"ok\":" + boolText(registered || connected) + "," +
        "\"peerId\":" + toJsonStringValue(peerIdText) + "," +
        "\"connected\":" + boolText(connected) +
        "}"

@exportc("libp2p_bootstrap_seed_connect_exact")
fn libp2p_bootstrap_seed_connect_exact(handle: int64,
                                       peerId: str,
                                       addressesJson: str,
                                       source: str,
                                       limit: int32,
                                       secureTimeoutMs: int32): str =
    return cStr(bootstrapSeedConnectExactPayload(handle,
                                                 (peerId),
                                                 (addressesJson),
                                                 (source),
                                                 limit,
                                                 secureTimeoutMs))

