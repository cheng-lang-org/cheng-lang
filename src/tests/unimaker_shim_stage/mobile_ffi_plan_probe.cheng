fn okJson(): str =
    return "{\"ok\":true}"

fn unsupportedJson(name: str): str =
    return "{\"ok\":false,\"error\":" + toJsonStringValue(name + "_not_implemented") + "}"

fn clearStagedBytes(value: var rawbytes.Bytes) =
    value.data = nil
    value.len = 0

fn stageBytes(value: var rawbytes.Bytes, raw: ptr, n: int32) =
    if raw == nil || n <= 0:
        clearStagedBytes(value)
        return
    let copied: rawbytes.Bytes = rawbytes.bytesAlloc(n)
    if copied.data == nil:
        clearStagedBytes(value)
        return
    system.memCopyCompat(copied.data, raw, n)
    value = copied

@exportc("cheng_mobile_host_moq_set_request_path_bridge")
fn cheng_mobile_host_moq_set_request_path_bridge_export(pathText: str) =
    gMoqRequestPath = pathText

@exportc("cheng_mobile_host_moq_stage_bridge")
fn cheng_mobile_host_moq_stage_bridge_export(blobPtr: ptr,
                                             blobLen: int32,
                                             requestWirePtr: ptr,
                                             requestWireLen: int32) =
    stageBytes(gMoqBlob, blobPtr, blobLen)
    stageBytes(gMoqRequestWire, requestWirePtr, requestWireLen)

@exportc("cheng_mobile_host_moq_request_path_bridge")
fn cheng_mobile_host_moq_request_path_bridge_export(): ptr =
    if len(gMoqRequestPath) <= 0:
        return nil
    return ptr(system.strToCStringTemp(gMoqRequestPath))

@exportc("cheng_mobile_host_moq_blob_bridge")
fn cheng_mobile_host_moq_blob_bridge_export(): ptr =
    return gMoqBlob.data

@exportc("cheng_mobile_host_moq_blob_len_bridge")
fn cheng_mobile_host_moq_blob_len_bridge_export(): int32 =
    return gMoqBlob.len

@exportc("cheng_mobile_host_moq_request_wire_bridge")
