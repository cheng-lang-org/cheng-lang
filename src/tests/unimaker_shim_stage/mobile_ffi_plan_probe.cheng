@exportc("social_publish_enqueue")
fn social_publish_enqueue(handle: int64, postJson: str): str =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        setLastError("social_publish_enqueue_failed")
        return cStr("{\"ok\":false,\"error\":\"social_publish_enqueue_failed\"}")
    let payloadBodyText: str = (postJson)
    var contentIdText: str = trimText(parseConfigQuotedValue(payloadBodyText, "contentId"))
    if len(contentIdText) <= 0:
        contentIdText = trimText(parseConfigQuotedValue(payloadBodyText, "postId"))
    if len(contentIdText) <= 0:
        contentIdText = trimText(parseConfigQuotedValue(payloadBodyText, "id"))
    if len(contentIdText) <= 0:
        contentIdText = "content-" + strings.int64ToStr(nowMs()) + "-" + strings.int64ToStr(gNodes[idx].nextPostNonce)
        gNodes[idx].nextPostNonce = gNodes[idx].nextPostNonce + 1
    let slot: int32 = upsertPublishTask(idx, contentIdText, payloadBodyText)
    if slot < 0:
        setLastError("social_publish_enqueue_failed")
        return cStr("{\"ok\":false,\"error\":\"social_publish_enqueue_failed\"}")
    addFeedEntry(idx, payloadBodyText)
    emitNodeEvent(idx, "social_publish_enqueue", publishTaskJson(idx, slot))
    return cStr(publishTaskJson(idx, slot))

@exportc("social_publish_task")
fn social_publish_task(handle: int64, taskId: str): str =
    let idx: int32 = findNodeByHandle(handle)
    let slot: int32 = findPublishTaskSlot(idx, (taskId))
    if slot < 0:
        setLastError("social_publish_task_failed")
        return cStr("{\"ok\":false,\"error\":\"social_publish_task_failed\"}")
    return cStr(publishTaskJson(idx, slot))

@exportc("social_publish_tasks")
