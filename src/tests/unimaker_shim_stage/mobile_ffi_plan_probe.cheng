@exportc("social_dm_send")
fn social_dm_send(handle: int64, peerId: str, conversationId: str, messageJson: str): bool =
    return socialDmSendText(handle, (peerId), (conversationId), (messageJson))

fn socialDmSendText(handle: int64, peerIdRaw: str, conversationIdRaw: str, messageJsonRaw: str): bool =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started:
        return false
    let peerIdText: str = normalizePeerId(trimText(peerIdRaw))
    let conversationIdText: str = trimText(conversationIdRaw)
    let payloadJson: str = messageJsonRaw
    let messageIdText: str =
        "dm-" + strings.int64ToStr(nowMs()) + "-" + strings.int64ToStr(gNodes[idx].nextMessageNonce)
    gNodes[idx].nextMessageNonce = gNodes[idx].nextMessageNonce + 1
    let sendOk: bool =
        um_host_direct_send_text(
            handle,
            system.strToCStringTemp(peerIdText),
            system.strToCStringTemp(conversationIdText),
            system.strToCStringTemp(messageIdText),
            system.strToCStringTemp(payloadJson)
        ) != 0
    appendMessage(idx, peerIdText, conversationIdText, messageIdText, payloadJson, "out", if sendOk: "sent" else: "failed")
    if !sendOk:
        let sendErrorText: str = trimText(gLastError)
        if len(sendErrorText) > 0:
            setLastError("social_dm_send: " + sendErrorText)
        else:
            setLastError("social_dm_send: host_direct_send_failed")
    return sendOk

