@exportc("social_report_submit")
fn social_report_submit(handle: int64, payloadJson: str): str =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        setLastError("social_report_submit_failed")
        return cStr("{\"ok\":false,\"error\":\"social_report_submit_failed\"}")
    var slot: int32 = gNodes[idx].reportCount
    if slot >= maxReports:
        for i in 1..<maxReports:
            gNodes[idx].reports[i - 1] = gNodes[idx].reports[i]
        slot = maxReports - 1
    else:
        gNodes[idx].reportCount = gNodes[idx].reportCount + 1
    var report: ReportState = initReportState()
    report.used = true
    report.reportId = "report-" + strings.int64ToStr(nowMs()) + "-" + strings.int64ToStr(gNodes[idx].nextReportNonce)
    gNodes[idx].nextReportNonce = gNodes[idx].nextReportNonce + 1
    report.payloadJson = (payloadJson)
    report.createdAtMs = nowMs()
    gNodes[idx].reports[slot] = report
    return cStr(reportJson(idx, slot))

