    let postIdText: str =
        "moment-" + strings.int64ToStr(nowMs()) + "-" + strings.int64ToStr(gNodes[idx].nextPostNonce)
    gNodes[idx].nextPostNonce = gNodes[idx].nextPostNonce + 1
    let payloadBodyText: str = (payloadJson)
    addMoment(idx, postIdText, payloadBodyText)
    addFeedEntry(idx, payloadBodyText)
    return true

