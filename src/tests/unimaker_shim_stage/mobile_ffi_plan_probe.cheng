    return true

@exportc("libp2p_mdns_probe")
fn libp2p_mdns_probe(handle: int64): bool =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0 || !gNodes[idx].started || !gNodes[idx].mdnsEnabled:
        return false
    let kicked: int32 = hostKickStandardMdnsFrames(idx, "")
    let hostFound: int32 = drainHostDiscoverySocket(idx, "", "", 4, 0)
    let found: int32 = hostFound + drainStandardMdnsSocket(idx, "", 4)
    let mdnsPayload: str = "{\"kick\":" + strings.IntToStr(kicked) + ",\"found\":" + strings.IntToStr(found) + "}"
    emitNodeEvent(idx, "mdns_probe_host", mdnsPayload)
    return kicked > 0

