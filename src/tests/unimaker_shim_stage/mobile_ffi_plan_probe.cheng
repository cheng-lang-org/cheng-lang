@exportc("social_poll_events")
fn social_poll_events(handle: int64, maxEvents: int32): str =
    let idx: int32 = findNodeByHandle(handle)
    let budget: int32 = if maxEvents > 0: maxEvents else: 8
    let _ = drainHostDiscoverySocket(idx, "", "", budget, 0)
    let nodeEvents: str = drainNodeEvents(idx)
    let hostDmEvents: str = drainHostMessageEventsJsonText(idx, budget)
    return cStr(mergeJsonArrayText(nodeEvents, hostDmEvents))

