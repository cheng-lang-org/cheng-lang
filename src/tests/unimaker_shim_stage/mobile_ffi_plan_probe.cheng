@exportc("social_tombstone_issue")
fn social_tombstone_issue(handle: int64, payloadJson: str): str =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return cStr(unsupportedObjectJson("social_tombstone_issue"))
    let contentIdText: str = trimText(parseConfigQuotedValue((payloadJson), "contentId"))
    let slot: int32 = findPublishTaskByContentId(idx, contentIdText)
    if slot < 0:
        setLastError("social_tombstone_issue_failed")
        return cStr("{\"ok\":false,\"error\":\"social_tombstone_issue_failed\"}")
    gNodes[idx].publishTasks[slot].tombstoned = true
    gNodes[idx].publishTasks[slot].publishState = "tombstoned"
    gNodes[idx].publishTasks[slot].reasonCode = trimText(parseConfigQuotedValue((payloadJson), "reasonCode"))
    gNodes[idx].publishTasks[slot].updatedAtMs = nowMs()
    return cStr(publishTaskJson(idx, slot))

@exportc("social_tombstone_restore")
fn social_tombstone_restore(handle: int64, payloadJson: str): str =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return cStr(unsupportedObjectJson("social_tombstone_restore"))
    let contentIdText: str = trimText(parseConfigQuotedValue((payloadJson), "contentId"))
    let slot: int32 = findPublishTaskByContentId(idx, contentIdText)
    if slot < 0:
        setLastError("social_tombstone_restore_failed")
        return cStr("{\"ok\":false,\"error\":\"social_tombstone_restore_failed\"}")
    gNodes[idx].publishTasks[slot].tombstoned = false
    gNodes[idx].publishTasks[slot].publishState = "published"
    gNodes[idx].publishTasks[slot].reasonCode = ""
    gNodes[idx].publishTasks[slot].updatedAtMs = nowMs()
    return cStr(publishTaskJson(idx, slot))

# Raw parameter bridge for native hosts. String returns stay on ChengStr ABI.
@exportc("libp2p_identity_from_seed_raw")
fn libp2p_identity_from_seed_raw(seedRaw: ptr, seedLen: int64): str =
    if seedRaw == nil || seedLen <= 0:
        return libp2p_identity_from_seed("", seedLen)
    return libp2p_identity_from_seed(bytesToString(bytesView(seedRaw, int32(seedLen))), seedLen)

