@exportc("social_governance_review")
fn social_governance_review(handle: int64, payloadJson: str): str =
    let idx: int32 = findNodeByHandle(handle)
    if idx < 0:
        return cStr(unsupportedObjectJson("social_governance_review"))
    let payloadBodyText: str = (payloadJson)
    let decision: str = trimText(parseConfigQuotedValue(payloadBodyText, "decision"))
    var slot: int32 = findPublishTaskSlot(idx, parseConfigQuotedValue(payloadBodyText, "taskId"))
    if slot < 0:
        slot = findPublishTaskByContentId(idx, parseConfigQuotedValue(payloadBodyText, "contentId"))
    if slot < 0:
        setLastError("social_governance_review_task_missing")
        return cStr("{\"ok\":false,\"error\":\"social_governance_review_task_missing\"}")
    if decision == "reject":
        gNodes[idx].publishTasks[slot].publishState = "rejected"
        gNodes[idx].publishTasks[slot].reasonCode = "governance_reject"
    elif decision == "hold":
        gNodes[idx].publishTasks[slot].publishState = "held"
        gNodes[idx].publishTasks[slot].reasonCode = "governance_hold"
    else:
        gNodes[idx].publishTasks[slot].publishState = "approved"
        gNodes[idx].publishTasks[slot].reasonCode = ""
    gNodes[idx].publishTasks[slot].updatedAtMs = nowMs()
    return cStr(publishTaskJson(idx, slot))

