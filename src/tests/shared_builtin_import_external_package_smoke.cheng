import std/os
import std/os_host_process as hostos
import std/strformat as sf
import std/strings

fn ensureDir(path: str) =
    if !os.DirExists(path):
        os.CreateDir(path)

fn resolveCompiler(root: str): str =
    let compilerEnv = os.GetEnv("CHENG_SMOKE_COMPILER")
    if len(compilerEnv) > 0:
        if os.IsAbsolute(compilerEnv):
            return compilerEnv
        return os.JoinPath(root, compilerEnv)
    let backendDriver = os.JoinPath(root, "artifacts/backend_driver/cheng")
    if os.FileExists(backendDriver):
        return backendDriver
    return os.JoinPath(root, "artifacts/bootstrap/cheng.stage3")

fn main(): int32 =
    let root = os.GetCurrentDir()
    let outDir = os.JoinPath(root, "artifacts/shared_builtin_import_external_package_smoke")
    let tmpRoot = os.GetEnvDefault("CHENG_SHARED_BUILTIN_TMPDIR",
                                   os.GetEnvDefault("TMPDIR", "/tmp"))
    let workspaceDir = os.JoinPath(tmpRoot, "cheng_shared_builtin_import_external_package_smoke")
    let packageRoot = os.JoinPath(workspaceDir, "shared_builtin_pkg")
    let srcDir = os.JoinPath(packageRoot, "src")
    ensureDir(outDir)
    ensureDir(workspaceDir)
    ensureDir(packageRoot)
    ensureDir(srcDir)

    let packageText = sf.Lines([
        "package_id = \"pkg://cheng/shared_builtin_pkg\"",
        "module_prefix = \"shared_builtin_pkg\""
    ])
    let helperText = sf.Lines([
        "fn HelperValue(): int32 =",
        "    return 11"
    ])
    let sourceText = sf.Lines([
        "import cheng/shared_builtin_pkg/helper as helper",
        "import runtime/scalars as rscalar",
        "import runtime/json_ast as json",
        "",
        "fn main(): int32 =",
        "    assert(rscalar.IsPositiveI32(7), \"external shared builtin: runtime scalar\")",
        "    let got: int32 = rscalar.IdentityI32(7)",
        "    var doc = json.NewJObject()",
        "    json.JsonSetField(doc, \"score\", json.NewJInt(7))",
        "    json.JsonSetField(doc, \"ok\", json.NewJBool(true))",
        "    var tags = json.NewJArray()",
        "    add(tags.a, json.NewJString(\"a\"))",
        "    add(tags.a, json.NewJString(\"b\"))",
        "    json.JsonSetField(doc, \"tags\", tags)",
        "    let score: int64 = json.GetInt(json.JsonGetField(doc, \"score\"))",
        "    let scoreNode: json.JsonNode = json.JsonGetField(doc, \"score\")",
        "    assert(score == 7, \"external shared builtin: json int value\")",
        "    assert(scoreNode.kind == json.JInt, \"external shared builtin: json int kind\")",
        "    assert(json.HasKey(doc, \"ok\"), \"external shared builtin: json has key\")",
        "    let parsedTags: json.JsonNode = json.JsonGetField(doc, \"tags\")",
        "    assert(got == 7, \"external shared builtin: runtime get\")",
        "    assert(parsedTags.kind == json.JArray, \"external shared builtin: json array\")",
        "    assert(parsedTags.a.len == 2, \"external shared builtin: json array len\")",
        "    assert(json.GetStr(parsedTags.a[0]) == \"a\", \"external shared builtin: json first tag\")",
        "    echo(\"external shared builtin ok\")",
        "    return 0"
    ])
    let packagePath = os.JoinPath(packageRoot, "cheng-package.toml")
    let helperPath = os.JoinPath(srcDir, "helper.cheng")
    let sourcePath = os.JoinPath(srcDir, "main.cheng")
    os.WriteFile(packagePath, packageText)
    os.WriteFile(helperPath, helperText)
    os.WriteFile(sourcePath, sourceText)

    let compiler = resolveCompiler(root)
    assert(os.FileExists(compiler), " shared builtin external package: compiler exists")
    let target = os.GetEnvDefault("CHENG_BOOTSTRAP_TARGET", "arm64-apple-darwin")
    let outBin = os.JoinPath(outDir, "shared_builtin_pkg")
    let outMap = outBin + ".map"
    let compileLog = os.JoinPath(outDir, "shared_builtin_pkg.compile.log")
    let runLog = os.JoinPath(outDir, "shared_builtin_pkg.run.log")
    if os.FileExists(outBin):
        os.RemoveFile(outBin)
    if os.FileExists(outMap):
        os.RemoveFile(outMap)
    var compileArgv: str[]
    add(compileArgv, "system-link-exec")
    add(compileArgv, "--root")
    add(compileArgv, packageRoot)
    add(compileArgv, "--in")
    add(compileArgv, sourcePath)
    add(compileArgv, "--emit")
    add(compileArgv, "exe")
    add(compileArgv, "--target")
    add(compileArgv, target)
    add(compileArgv, "--out")
    add(compileArgv, outBin)
    var compileEnv: str[]
    let noHandoff = os.GetEnv("CHENG_NO_BACKEND_DRIVER_HANDOFF")
    if len(noHandoff) > 0 && noHandoff != "0":
        add(compileEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=" + noHandoff)
    let rootEnv = os.GetEnv("CHENG_ROOT")
    if len(rootEnv) > 0:
        add(compileEnv, "CHENG_ROOT=" + rootEnv)
    let compileRes = hostos.ExecFileCapture(compiler,
                                            compileArgv,
                                            compileEnv,
                                            packageRoot,
                                            true,
                                            120)
    let compileOutput = os.ExecCmdResultOutput(compileRes)
    os.WriteFile(compileLog, compileOutput)
    assert(os.ExecCmdResultExitCode(compileRes) == 0,
           " shared builtin external package: compile rc")
    assert(os.FileExists(outBin), " shared builtin external package: output exists")
    let runRes = hostos.ExecFileCapture(outBin, [], [], packageRoot, true, 30)
    let runOutput = os.ExecCmdResultOutput(runRes)
    os.WriteFile(runLog, runOutput)
    assert(os.ExecCmdResultExitCode(runRes) == 0,
           " shared builtin external package: run rc")
    assert(strings.StrContains(runOutput, "external shared builtin ok"),
           " shared builtin external package: run output")
    echo(" shared_builtin_import_external_package_smoke ok")
    return 0
