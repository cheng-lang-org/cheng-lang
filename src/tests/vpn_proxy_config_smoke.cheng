import std/result
import cheng/apps/vpn_proxy/vpn_proxy_config as vpn

fn main(): int32 =
    var parseRes: Result[vpn.VpnProxyConfig]
    parseRes = vpn.VpnProxyParseConfigTextForTest(
        "{\"client\":{\"listen\":\"127.0.0.1:1080\",\"cert_der\":\"client.der\",\"key_pk8_der\":\"client.key\",\"trust_root_der\":\"root.der\",\"cert_chain_der\":[\"chain-a.der\",\"chain-b.der\"],\"trust_roots_der\":[\"root-b.der\"]},\"server\":{\"listen\":\"0.0.0.0:7443\",\"expected_auth\":\"shared-secret\",\"expected_authority\":\"edge.internal\",\"cc_rx_text\":\"auto\"},\"exits\":[{\"name\":\"64\",\"host\":\"64.176.84.12\",\"port\":7443,\"server_name\":\"edge-64.internal\",\"authority\":\"edge.internal\",\"auth\":\"shared-secret\",\"cc_rx\":123456},{\"name\":\"dmit\",\"host\":\"154.26.191.226\",\"port\":7443,\"server_name\":\"edge-dmit.internal\"}]}")
    assert(!IsErr(parseRes), " vpn proxy config parse")

    var cfg: vpn.VpnProxyConfig
    cfg = Value(parseRes)
    assert(cfg.client.listen == "127.0.0.1:1080", " vpn proxy config client listen")
    assert(cfg.client.certDer == "client.der", " vpn proxy config client cert")
    assert(cfg.client.keyPk8Der == "client.key", " vpn proxy config client key")
    assert(cfg.client.trustRootDer == "root.der", " vpn proxy config client root")
    assert(cfg.client.certChainDer.len == 2, " vpn proxy config client chain len")
    assert(cfg.client.trustRootsDer.len == 1, " vpn proxy config client roots len")
    assert(cfg.server.listen == "0.0.0.0:7443", " vpn proxy config server listen")
    assert(cfg.server.expectedAuth == "shared-secret", " vpn proxy config server expected auth")
    assert(cfg.server.expectedAuthority == "edge.internal", " vpn proxy config server expected authority")
    assert(cfg.server.ccRxText == "auto", " vpn proxy config server cc-rx text")
    assert(cfg.exits.len == 2, " vpn proxy config exits len")
    assert(cfg.exits[0].name == "64", " vpn proxy config first exit name")
    assert(cfg.exits[0].authority == "edge.internal", " vpn proxy config first exit authority")
    assert(cfg.exits[0].auth == "shared-secret", " vpn proxy config first exit auth")
    assert(cfg.exits[0].ccRx == 123456, " vpn proxy config first exit cc-rx")
    assert(cfg.exits[1].serverName == "edge-dmit.internal", " vpn proxy config second exit server name")

    var serverOnlyRes: Result[vpn.VpnProxyConfig]
    serverOnlyRes = vpn.VpnProxyParseConfigTextForTest("{\"server\":{\"listen\":\"0.0.0.0:7443\"}}")
    assert(!IsErr(serverOnlyRes), " vpn proxy config server-only parse")
    assert(Value(serverOnlyRes).client.listen == "", " vpn proxy config server-only empty client")

    var badRes: Result[vpn.VpnProxyConfig]
    badRes = vpn.VpnProxyParseConfigTextForTest("{\"exits\":{\"name\":\"bad\"}}")
    assert(IsErr(badRes), " vpn proxy config exits reject")
    assert(ErrorText(badRes) == "vpn proxy config: exits must be array", " vpn proxy config exits reject text")

    echo(" vpn_proxy_config_smoke ok")
    return 0
