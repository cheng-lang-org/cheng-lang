import std/system
import std/rawbytes
import std/crypto/sha256
import cheng/std/bytes_layout as layout

fn main(): int32 =
    var input = bytesFromString("abc")
    assert(bytesLen(input) == 3, " sha256 runtime: input len")
    assert(bytesGet(input, 0) == int32('a'), " sha256 runtime: input byte0")
    assert(bytesGet(input, 1) == int32('b'), " sha256 runtime: input byte1")
    assert(bytesGet(input, 2) == int32('c'), " sha256 runtime: input byte2")
    var digest = sha256.sha256Digest(input)
    assert(bytesLen(digest) == 32, " sha256 runtime: digest len")
    assert(bytesGet(digest, 0) == 0xba, " sha256 runtime: digest byte0")
    assert(bytesGet(digest, 1) == 0x78, " sha256 runtime: digest byte1")
    assert(bytesGet(digest, 31) == 0xad, " sha256 runtime: digest byte31")
    let fixedRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromBytes(digest)
    assert(IsOk(fixedRes), " sha256 runtime: fixed32 conversion")
    echo(" sha256_runtime_smoke ok")
    return 0
