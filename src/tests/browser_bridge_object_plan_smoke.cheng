import std/os
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/backend/system_link_exec as sexec

fn containsText(items: str[], value: str): bool =
    for i in 0..<items.len:
        if items[i] == value:
            return true
    return false

fn main(): int32 =
    let rootDir = chengpath.PathCurrentDir()
    let smokeLabel = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir = chengpath.PathJoin(rootDir, "artifacts/browser_bridge_object_plan/" + smokeLabel)
    assert(chengpath.MkdirP(rootDir, outDir), " browser bridge object plan: mkdir")
    let outputPath = chengpath.PathJoin(outDir, "browser_host_native_min_smoke")
    let req = creq.CompilerRequestNew(
        rootDir,
        chengpath.PathJoin(rootDir, "src/tests/browser_host_native_min_smoke.cheng"),
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    let planRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                     req,
                                                                     "",
                                                                     "",
                                                                     "",
                                                                     "stable")
    assert(IsOk(planRes), " browser bridge object plan: build plan")
    let plan = Value(planRes)
    let expectedObjectPath = outputPath + ".browser_bridge.generated.o"
    assert(plan.objectPlan.browserBridgeObjectPath == expectedObjectPath,
           " browser bridge object plan: object path")
    assert(plan.nativeLinkPlan.browserBridgeObjectPath == expectedObjectPath,
           " browser bridge object plan: native object path")
    assert(containsText(plan.objectPlan.linkInputPaths, expectedObjectPath),
           " browser bridge object plan: object link input")
    assert(containsText(plan.nativeLinkPlan.linkInputPaths, expectedObjectPath),
           " browser bridge object plan: native link input")
    echo(" browser_bridge_object_plan_smoke ok")
    return 0
