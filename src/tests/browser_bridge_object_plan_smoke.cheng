import std/os
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as v3path
import cheng/core/backend/system_link_exec as sexec

fn containsText(items: str[], value: str): bool =
    for i in 0..<items.len:
        if items[i] == value:
            return true
    return false

fn main(): int32 =
    let rootDir = v3path.V3PathCurrentDir()
    let smokeLabel = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir = v3path.V3PathJoin(rootDir, "artifacts/browser_bridge_object_plan/" + smokeLabel)
    assert(v3path.V3MkdirP(rootDir, outDir), "v3 browser bridge object plan: mkdir")
    let outputPath = v3path.V3PathJoin(outDir, "browser_host_native_min_smoke")
    let req = creq.v3CompilerRequestNew(
        v3path.V3PathJoin(rootDir, "v3"),
        v3path.V3PathJoin(rootDir, "src/tests/browser_host_native_min_smoke.cheng"),
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    let planRes = sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(rootDir,
                                                                     req,
                                                                     "",
                                                                     "",
                                                                     "",
                                                                     "stable")
    assert(IsOk(planRes), "v3 browser bridge object plan: build plan")
    let plan = Value(planRes)
    let expectedObjectPath = outputPath + ".browser_bridge.generated.o"
    assert(plan.objectPlan.browserBridgeObjectPath == expectedObjectPath,
           "v3 browser bridge object plan: object path")
    assert(plan.nativeLinkPlan.browserBridgeObjectPath == expectedObjectPath,
           "v3 browser bridge object plan: native object path")
    assert(containsText(plan.objectPlan.linkInputPaths, expectedObjectPath),
           "v3 browser bridge object plan: object link input")
    assert(containsText(plan.nativeLinkPlan.linkInputPaths, expectedObjectPath),
           "v3 browser bridge object plan: native link input")
    echo("v3 browser_bridge_object_plan_smoke ok")
    return 0

