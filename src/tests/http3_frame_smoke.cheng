import std/result
import cheng/http3/frame as http3
import cheng/qpack/min as qpack

fn main(): int32 =
    var settings: http3.Http3Setting[]
    add(settings, http3.Http3MakeSetting(http3.Http3SettingQpackMaxTableCapacity, 0))
    add(settings, http3.Http3MakeSetting(http3.Http3SettingQpackBlockedStreams, 0))

    let settingsFrameRes: Result[Bytes] = http3.Http3EncodeSettingsFrame(settings)
    assert(IsOk(settingsFrameRes), " http3 frame: settings encode")
    let settingsFrameWire: Bytes = Value(settingsFrameRes)
    let settingsDecRes: Result[http3.Http3FrameDecoded] = http3.Http3DecodeFrame(settingsFrameWire, 0)
    assert(IsOk(settingsDecRes), " http3 frame: settings decode frame")
    let settingsFrame: http3.Http3Frame = Value(settingsDecRes).frame
    assert(settingsFrame.kind == http3.Http3FrameSettings, " http3 frame: settings kind")
    let settingsPayloadRes: Result[http3.Http3Setting[]] = http3.Http3DecodeSettingsFramePayload(settingsFrame.payload)
    assert(IsOk(settingsPayloadRes), " http3 frame: settings payload decode")
    assert(Value(settingsPayloadRes).len == 2, " http3 frame: settings count")

    var headers: qpack.QpackHeaderField[]
    add(headers, qpack.QpackMakeHeaderField(":method", "POST"))
    add(headers, qpack.QpackMakeHeaderField(":path", "/auth"))
    add(headers, qpack.QpackMakeHeaderField("host", "hysteria"))
    let headersFrameRes: Result[Bytes] = http3.Http3EncodeHeadersFrame(headers)
    assert(IsOk(headersFrameRes), " http3 frame: headers encode")
    let headersDecRes: Result[http3.Http3FrameDecoded] = http3.Http3DecodeFrame(Value(headersFrameRes), 0)
    assert(IsOk(headersDecRes), " http3 frame: headers decode frame")
    let headersFrame: http3.Http3Frame = Value(headersDecRes).frame
    assert(headersFrame.kind == http3.Http3FrameHeaders, " http3 frame: headers kind")
    let headerFieldsRes: Result[qpack.QpackFieldSection] = http3.Http3DecodeHeadersFramePayload(headersFrame.payload)
    assert(IsOk(headerFieldsRes), " http3 frame: headers payload decode")
    assert(Value(headerFieldsRes).fields.len == 3, " http3 frame: headers field len")

    let preambleRes: Result[http3.Http3Preamble] = http3.Http3EncodeClientPreamble(settings)
    assert(IsOk(preambleRes), " http3 frame: preamble encode")
    let preamble: http3.Http3Preamble = Value(preambleRes)
    assert(bytesLen(preamble.control) > 0, " http3 frame: control stream bytes")
    assert(bytesLen(preamble.qpackEncoder) > 0, " http3 frame: encoder stream bytes")
    assert(bytesLen(preamble.qpackDecoder) > 0, " http3 frame: decoder stream bytes")

    echo(" http3_frame_smoke ok")
    return 0
