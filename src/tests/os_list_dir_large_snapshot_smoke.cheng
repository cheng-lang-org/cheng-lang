import std/os as os
import std/strings as strings
import std/strformat
import std/strutils as strutil

const
    osListDirLargeSnapshotFileCount = 1536

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_list_dir_large_snapshot_tmp"
    if os.DirExists(tmpRoot):
        for i in 0..<osListDirLargeSnapshotFileCount:
            let path = os.JoinPath(tmpRoot, strutil.Join(["entry_", strings.IntToStr(i), ".txt"], ""))
            if os.FileExists(path):
                assert(os.RemoveFile(path), " os.ListDir large snapshot cleanup file")
        os.RemoveDir(tmpRoot)
    os.CreateDir(tmpRoot)
    for i in 0..<osListDirLargeSnapshotFileCount:
        let path = os.JoinPath(tmpRoot, strutil.Join(["entry_", strings.IntToStr(i), ".txt"], ""))
        os.WriteFile(path, "x")

    let snapshot = os.ListDir(tmpRoot)
    assert(snapshot.len == osListDirLargeSnapshotFileCount,
           " os.ListDir large snapshot count")
    var sawEntry0: bool
    var sawLastEntry: bool
    for i in 0..<snapshot.len:
        let entry = snapshot[i]
        if entry == "entry_0.txt":
            sawEntry0 = true
        elif entry == "entry_1535.txt":
            sawLastEntry = true

    for i in 0..<osListDirLargeSnapshotFileCount:
        let path = os.JoinPath(tmpRoot, strutil.Join(["entry_", strings.IntToStr(i), ".txt"], ""))
        assert(os.RemoveFile(path), " os.ListDir large snapshot remove file")
    os.RemoveDir(tmpRoot)
    assert(sawEntry0, " os.ListDir large snapshot keeps first name")
    assert(sawLastEntry, " os.ListDir large snapshot keeps last name")
    echo(" os_list_dir_large_snapshot_smoke ok")
    return 0
