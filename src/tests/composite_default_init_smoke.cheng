import std/system

type
    Inner = object
        score: int32 = 7

    Wrap = object
        count: int32 = 4
        inner: Inner
        xs: int32[]
        tags: str[] = ["base", "default"]
        fixed: int32[3] = [1, 2, 3]

    Node = ref object
        value: int32 = 9
        inner: Inner
        pair: tuple[a: int32 = 3, b: int32[]]
        labels: str[] = ["node"]
        limbs: int32[2] = [4, 5]

    Pair = tuple[a: int32 = 6, b: int32[], c: int32[2] = [8, 9], d: str[] = ["pair"]]

fn makeWrapDefault(): Wrap =
    return Wrap()

fn makePairImplicit(): Pair =
    var out: Pair
    return out

fn main(): int32 =
    var seqDefault: int32[]
    assert(seqDefault.len == 0, "v3 composite default init: seq implicit init")
    var fixedDefault: int32[3]
    assert(fixedDefault[0] == 0, "v3 composite default init: fixed array implicit init first")
    assert(fixedDefault[2] == 0, "v3 composite default init: fixed array implicit init last")

    var wrap: Wrap
    assert(wrap.count == 4, "v3 composite default init: object field default")
    assert(wrap.inner.score == 7, "v3 composite default init: nested object field default")
    assert(wrap.xs.len == 0, "v3 composite default init: object seq zero")
    assert(wrap.tags.len == 2, "v3 composite default init: object seq literal len")
    assert(wrap.tags[0] == "base", "v3 composite default init: object seq literal first")
    assert(wrap.fixed[0] == 1, "v3 composite default init: object fixed literal first")
    assert(wrap.fixed[2] == 3, "v3 composite default init: object fixed literal last")

    var override = Wrap(count: 1, tags: ["override"], fixed: [7, 8, 9])
    assert(override.count == 1, "v3 composite default init: explicit arg wins")
    assert(override.inner.score == 7, "v3 composite default init: omitted object field default")
    assert(override.xs.len == 0, "v3 composite default init: omitted object seq zero")
    assert(override.tags.len == 1, "v3 composite default init: explicit seq literal wins")
    assert(override.tags[0] == "override", "v3 composite default init: explicit seq literal item")
    assert(override.fixed[0] == 7, "v3 composite default init: explicit fixed literal wins")
    assert(override.fixed[2] == 9, "v3 composite default init: explicit fixed literal tail")

    var wrapDefault: Wrap
    assert(wrapDefault.count == 4, "v3 composite default init: default object field")
    assert(wrapDefault.inner.score == 7, "v3 composite default init: default object nested")
    assert(wrapDefault.xs.len == 0, "v3 composite default init: default object seq")
    assert(wrapDefault.tags.len == 2, "v3 composite default init: default object seq literal")
    assert(wrapDefault.fixed[1] == 2, "v3 composite default init: default object fixed literal")

    var seqLiteral: str[] = ["left", "right"]
    assert(seqLiteral.len == 2, "v3 composite default init: seq literal bind len")
    assert(seqLiteral[1] == "right", "v3 composite default init: seq literal bind item")

    var fixedLiteral: int32[3] = [10, 11, 12]
    assert(fixedLiteral[0] == 10, "v3 composite default init: fixed literal bind first")
    assert(fixedLiteral[2] == 12, "v3 composite default init: fixed literal bind last")

    var node: Node = new(Node)
    assert(node.value == 9, "v3 composite default init: ref object field default")
    assert(node.inner.score == 7, "v3 composite default init: ref object nested")
    assert(node.pair.a == 3, "v3 composite default init: ref object tuple field default")
    assert(node.pair.b.len == 0, "v3 composite default init: ref object tuple seq")
    assert(node.labels.len == 1, "v3 composite default init: ref object seq literal")
    assert(node.labels[0] == "node", "v3 composite default init: ref object seq literal item")
    assert(node.limbs[0] == 4, "v3 composite default init: ref object fixed literal first")
    assert(node.limbs[1] == 5, "v3 composite default init: ref object fixed literal last")

    var pair: Pair
    assert(pair.a == 6, "v3 composite default init: tuple field default")
    assert(pair.b.len == 0, "v3 composite default init: tuple seq zero")
    assert(pair.c[0] == 8, "v3 composite default init: tuple fixed literal first")
    assert(pair.c[1] == 9, "v3 composite default init: tuple fixed literal last")
    assert(pair.d.len == 1, "v3 composite default init: tuple seq literal len")
    assert(pair.d[0] == "pair", "v3 composite default init: tuple seq literal item")

    var pairDefault: Pair
    assert(pairDefault.a == 6, "v3 composite default init: default tuple field")
    assert(pairDefault.b.len == 0, "v3 composite default init: default tuple seq")
    assert(pairDefault.c[0] == 8, "v3 composite default init: default tuple fixed literal")
    assert(pairDefault.d.len == 1, "v3 composite default init: default tuple seq literal")

    let pairCall = Pair()
    assert(pairCall.a == 6, "v3 composite default init: tuple type call field")
    assert(pairCall.b.len == 0, "v3 composite default init: tuple type call seq")
    assert(pairCall.c[1] == 9, "v3 composite default init: tuple type call fixed")
    assert(pairCall.d[0] == "pair", "v3 composite default init: tuple type call seq literal")
    let elemSlotSize = elemSize[int32]()
    assert(elemSlotSize > 0, "v3 composite default init: lower generic zeroarg call")

    var returnedWrap: Wrap = makeWrapDefault()
    assert(returnedWrap.count == 4, "v3 composite default init: return default object field")
    assert(returnedWrap.inner.score == 7, "v3 composite default init: return default object nested")
    assert(returnedWrap.xs.len == 0, "v3 composite default init: return default object seq")
    assert(returnedWrap.tags[1] == "default", "v3 composite default init: return default object seq literal")
    assert(returnedWrap.fixed[1] == 2, "v3 composite default init: return default object fixed literal")

    var returnedPair: Pair = makePairImplicit()
    assert(returnedPair.a == 6, "v3 composite default init: return implicit tuple field")
    assert(returnedPair.b.len == 0, "v3 composite default init: return implicit tuple seq")
    assert(returnedPair.c[1] == 9, "v3 composite default init: return implicit tuple fixed literal")
    assert(returnedPair.d[0] == "pair", "v3 composite default init: return implicit tuple seq literal")

    echo("v3 composite_default_init_smoke ok")
    return 0
