import std/os
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/path_absolute_absolute_probe")
    let absAgain: str = chengpath.PathAbsolute(root, outDir)
    if !chengpath.PathNonEmpty(absAgain):
        echo("absagain-bad")
        return 1
    echo(absAgain)
    return 0
