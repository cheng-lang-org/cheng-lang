import std/cmdline as cmdline
import std/os as os
import std/os_host_process as hostos
import std/strings as strings

fn ensureDir(path: str) =
    if !os.DirExists(path):
        os.CreateDir(path)

fn currentExecutablePath(root: str): str =
    let raw = cmdline.ProgramName()
    if len(raw) <= 0:
        return ""
    if os.IsAbsolute(raw):
        return raw
    return os.JoinPath(root, raw)

fn compileNegativeFixture(compiler: str,
                          root: str,
                          inputPath: str,
                          outputPath: str,
                          logPath: str): os.ExecCmdResult =
    let target = os.GetEnvDefault("CHENG_BOOTSTRAP_TARGET", "arm64-apple-darwin")
    var compileArgv: str[]
    add(compileArgv, "system-link-exec")
    add(compileArgv, "--root")
    add(compileArgv, root)
    add(compileArgv, "--in")
    add(compileArgv, inputPath)
    add(compileArgv, "--emit")
    add(compileArgv, "exe")
    add(compileArgv, "--target")
    add(compileArgv, target)
    add(compileArgv, "--out")
    add(compileArgv, outputPath)
    var compileEnv: str[]
    let noHandoff = os.GetEnv("CHENG_NO_BACKEND_DRIVER_HANDOFF")
    if len(noHandoff) > 0 && noHandoff != "0":
        add(compileEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=" + noHandoff)
    let compileRes = hostos.ExecFileCapture(compiler, compileArgv, compileEnv, root, true, 60)
    let compileOutput = os.ExecCmdResultOutput(compileRes)
    os.WriteFile(logPath, compileOutput)
    return compileRes

fn main(): int32 =
    let root = os.GetCurrentDir()
    let exePath = currentExecutablePath(root)
    assert(len(exePath) > 0 && os.FileExists(exePath),
           " composite default negative: executable path")
    let exeParts = os.SplitFile(exePath)
    let exeDir = exeParts.dir
    let exeName = exeParts.name
    let workspaceName = exeName + ".workspace"
    let outDir = os.JoinPath(exeDir, workspaceName)
    ensureDir(outDir)
    assert(os.DirExists(outDir), " composite default negative: mkdir")

    let compilerEnv = os.GetEnv("CHENG_SMOKE_COMPILER")
    var compilerRaw = "artifacts/bootstrap/cheng.stage3"
    if len(compilerEnv) > 0:
        compilerRaw = compilerEnv
    var compiler = compilerRaw
    if !os.IsAbsolute(compilerRaw):
        compiler = os.JoinPath(root, compilerRaw)
    assert(os.FileExists(compiler),
           " composite default negative: compiler exists")

    let duplicateLog = os.JoinPath(outDir, "duplicate_field.compile.log")
    let duplicateIn = os.JoinPath(root, "src/tests/composite_default_init_negative_duplicate_field.cheng")
    let duplicateOut = os.JoinPath(outDir, "duplicate_field")
    let duplicateRes = compileNegativeFixture(compiler, root, duplicateIn, duplicateOut, duplicateLog)
    let duplicateOutput = os.ExecCmdResultOutput(duplicateRes)
    assert(os.ExecCmdResultExitCode(duplicateRes) != 0, " composite default negative: duplicate field rejected")
    assert(strings.StrContains(duplicateOutput, "duplicate constructor field"),
           " composite default negative: duplicate field diagnostic")

    let siblingLog = os.JoinPath(outDir, "sibling_default.compile.log")
    let siblingIn = os.JoinPath(root, "src/tests/composite_default_init_negative_sibling_default.cheng")
    let siblingOut = os.JoinPath(outDir, "sibling_default")
    let siblingRes = compileNegativeFixture(compiler, root, siblingIn, siblingOut, siblingLog)
    let siblingOutput = os.ExecCmdResultOutput(siblingRes)
    assert(os.ExecCmdResultExitCode(siblingRes) != 0, " composite default negative: sibling field rejected")
    assert(strings.StrContains(siblingOutput, "field default references sibling field"),
           " composite default negative: sibling field diagnostic")

    let sideLog = os.JoinPath(outDir, "side_effect_default.compile.log")
    let sideIn = os.JoinPath(root, "src/tests/composite_default_init_negative_side_effect_default.cheng")
    let sideOut = os.JoinPath(outDir, "side_effect_default")
    let sideRes = compileNegativeFixture(compiler, root, sideIn, sideOut, sideLog)
    let sideOutput = os.ExecCmdResultOutput(sideRes)
    assert(os.ExecCmdResultExitCode(sideRes) != 0, " composite default negative: side effect rejected")
    assert(strings.StrContains(sideOutput, "field default call unsupported"),
           " composite default negative: side effect diagnostic")

    let tupleLog = os.JoinPath(outDir, "tuple_omit.compile.log")
    let tupleIn = os.JoinPath(root, "src/tests/composite_default_init_negative_tuple_omit.cheng")
    let tupleOut = os.JoinPath(outDir, "tuple_omit")
    let tupleRes = compileNegativeFixture(compiler, root, tupleIn, tupleOut, tupleLog)
    let tupleOutput = os.ExecCmdResultOutput(tupleRes)
    assert(os.ExecCmdResultExitCode(tupleRes) != 0, " composite default negative: tuple omission rejected")
    assert(strings.StrContains(tupleOutput, "tuple literal omission unsupported"),
           " composite default negative: tuple omission diagnostic")

    let tupleCtorLog = os.JoinPath(outDir, "tuple_ctor_omit.compile.log")
    let tupleCtorIn = os.JoinPath(root, "src/tests/composite_default_init_negative_tuple_ctor_omit.cheng")
    let tupleCtorOut = os.JoinPath(outDir, "tuple_ctor_omit")
    let tupleCtorRes = compileNegativeFixture(compiler, root, tupleCtorIn, tupleCtorOut, tupleCtorLog)
    let tupleCtorOutput = os.ExecCmdResultOutput(tupleCtorRes)
    assert(os.ExecCmdResultExitCode(tupleCtorRes) != 0, " composite default negative: tuple ctor omission rejected")
    assert(strings.StrContains(tupleCtorOutput, "tuple literal omission unsupported"),
           " composite default negative: tuple ctor omission diagnostic")

    let oldDefaultLog = os.JoinPath(outDir, "old_default.compile.log")
    let oldDefaultIn = os.JoinPath(root, "src/tests/composite_default_init_negative_old_default.cheng")
    let oldDefaultOut = os.JoinPath(outDir, "old_default")
    let oldDefaultRes = compileNegativeFixture(compiler, root, oldDefaultIn, oldDefaultOut, oldDefaultLog)
    let oldDefaultOutput = os.ExecCmdResultOutput(oldDefaultRes)
    assert(os.ExecCmdResultExitCode(oldDefaultRes) != 0, " composite default negative: old default syntax rejected")
    assert(strings.StrContains(oldDefaultOutput, "default[T] removed"),
           " composite default negative: old default syntax diagnostic")

    let scalarTypeCallLog = os.JoinPath(outDir, "scalar_type_call.compile.log")
    let scalarTypeCallIn = os.JoinPath(root, "src/tests/composite_default_init_negative_scalar_type_call.cheng")
    let scalarTypeCallOut = os.JoinPath(outDir, "scalar_type_call")
    let scalarTypeCallRes = compileNegativeFixture(compiler, root, scalarTypeCallIn, scalarTypeCallOut, scalarTypeCallLog)
    let scalarTypeCallOutput = os.ExecCmdResultOutput(scalarTypeCallRes)
    assert(os.ExecCmdResultExitCode(scalarTypeCallRes) != 0, " composite default negative: scalar type call rejected")
    assert(strings.StrContains(scalarTypeCallOutput, "simple type T() unsupported"),
           " composite default negative: scalar type call diagnostic")

    let refTypeCallLog = os.JoinPath(outDir, "ref_type_call.compile.log")
    let refTypeCallIn = os.JoinPath(root, "src/tests/composite_default_init_negative_ref_type_call.cheng")
    let refTypeCallOut = os.JoinPath(outDir, "ref_type_call")
    let refTypeCallRes = compileNegativeFixture(compiler, root, refTypeCallIn, refTypeCallOut, refTypeCallLog)
    let refTypeCallOutput = os.ExecCmdResultOutput(refTypeCallRes)
    assert(os.ExecCmdResultExitCode(refTypeCallRes) != 0, " composite default negative: ref type call rejected")
    assert(strings.StrContains(refTypeCallOutput, "ref object T() unsupported"),
           " composite default negative: ref type call diagnostic")

    let refTypeCallUnusedLog = os.JoinPath(outDir, "ref_type_call_unused.compile.log")
    let refTypeCallUnusedIn = os.JoinPath(root, "src/tests/composite_default_init_negative_ref_type_call_unused.cheng")
    let refTypeCallUnusedOut = os.JoinPath(outDir, "ref_type_call_unused")
    let refTypeCallUnusedRes = compileNegativeFixture(compiler, root, refTypeCallUnusedIn, refTypeCallUnusedOut, refTypeCallUnusedLog)
    let refTypeCallUnusedOutput = os.ExecCmdResultOutput(refTypeCallUnusedRes)
    assert(os.ExecCmdResultExitCode(refTypeCallUnusedRes) != 0, " composite default negative: unused ref type call rejected")
    assert(strings.StrContains(refTypeCallUnusedOutput, "ref object T() unsupported"),
           " composite default negative: unused ref type call diagnostic")

    let seqTypeCallLog = os.JoinPath(outDir, "seq_type_call.compile.log")
    let seqTypeCallIn = os.JoinPath(root, "src/tests/composite_default_init_negative_seq_type_call.cheng")
    let seqTypeCallOut = os.JoinPath(outDir, "seq_type_call")
    let seqTypeCallRes = compileNegativeFixture(compiler, root, seqTypeCallIn, seqTypeCallOut, seqTypeCallLog)
    let seqTypeCallOutput = os.ExecCmdResultOutput(seqTypeCallRes)
    assert(os.ExecCmdResultExitCode(seqTypeCallRes) != 0, " composite default negative: seq type call rejected")
    assert(strings.StrContains(seqTypeCallOutput, "seq/fixed-array T() unsupported"),
           " composite default negative: seq type call diagnostic")

    let fixedTypeCallLog = os.JoinPath(outDir, "fixed_type_call.compile.log")
    let fixedTypeCallIn = os.JoinPath(root, "src/tests/composite_default_init_negative_fixed_type_call.cheng")
    let fixedTypeCallOut = os.JoinPath(outDir, "fixed_type_call")
    let fixedTypeCallRes = compileNegativeFixture(compiler, root, fixedTypeCallIn, fixedTypeCallOut, fixedTypeCallLog)
    let fixedTypeCallOutput = os.ExecCmdResultOutput(fixedTypeCallRes)
    assert(os.ExecCmdResultExitCode(fixedTypeCallRes) != 0, " composite default negative: fixed type call rejected")
    assert(strings.StrContains(fixedTypeCallOutput, "seq/fixed-array T() unsupported"),
           " composite default negative: fixed type call diagnostic")

    echo(" composite_default_init_negative_smoke ok")
    return 0
