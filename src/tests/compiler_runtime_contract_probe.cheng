import cheng/core/tooling/compiler_runtime as crun

fn main(): int32 =
    let direct = crun.CompilerRuntimePath("/tmp/cheng-lang", "src/core/tooling/compiler_main.cheng")
    let contract = crun.CompilerRuntimeContract("/tmp/cheng-lang")
    assert(direct == "/tmp/cheng-lang/src/core/tooling/compiler_main.cheng", "direct")
    assert(contract.compilerEntry == "/tmp/cheng-lang/src/core/tooling/compiler_main.cheng", "contract")
    echo("compiler_runtime_contract_probe ok")
    return 0
