import std/os
import cheng/std/bytes_layout as layout
import cheng/chain/consensus
import cheng/chain/lsmr
import cheng/apps/chain_node/chain_node as node

fn fixed32ManualEqual(left: layout.FixedBytes32, right: layout.FixedBytes32): bool =
    for i in 0..<layout.FixedBytes32Size:
        if left.data[i] != right.data[i]:
            return false
    return true

fn dumpFixed32(label: str, value: layout.FixedBytes32) =
    os.WriteLine(os.Get_stderr(), label + "=" + layout.FixedBytes32Hex(value))

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node rebuild forest probe: mint")
    let transferCidRes = node.ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, " chain_node rebuild forest probe: transfer")

    var served: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(served, server)
    var replayed: node.ChainNode
    node.ChainNodeZeroInto(replayed, "node-b", served.address)
    for i in 0..<served.events.len:
        var event = served.events[i]
        event.stem = event.ganzhiIndex % 10
        event.branch = event.ganzhiIndex % 12
        event.bodyCid = consensus.ChainEventBodyCid(event)
        let applyRes = node.ChainNodeApplyEvent(replayed, event)
        assert(applyRes.ok, " chain_node rebuild forest probe: replay apply")
    node.ChainNodeRebuildDerived(replayed)

    let serverCells = node.ChainNodeStateCells(server.index)
    let replayedCells = node.ChainNodeStateCells(replayed.index)
    if serverCells.len != replayedCells.len:
        os.WriteLine(os.Get_stderr(), "server_cells_len=" + intToStr(serverCells.len))
        os.WriteLine(os.Get_stderr(), "replayed_cells_len=" + intToStr(replayedCells.len))
        return 11
    for i in 0..<serverCells.len:
        if serverCells[i].keyId != replayedCells[i].keyId:
            os.WriteLine(os.Get_stderr(), "cell_key_mismatch_at=" + intToStr(i))
            return 12
        if serverCells[i].baguaId != replayedCells[i].baguaId:
            os.WriteLine(os.Get_stderr(), "cell_bagua_mismatch_at=" + intToStr(i))
            return 13
        if serverCells[i].resolutionLevel != replayedCells[i].resolutionLevel:
            os.WriteLine(os.Get_stderr(), "cell_resolution_mismatch_at=" + intToStr(i))
            return 14
        if serverCells[i].layerId != replayedCells[i].layerId:
            os.WriteLine(os.Get_stderr(), "cell_layer_mismatch_at=" + intToStr(i))
            return 15
        if !fixed32ManualEqual(serverCells[i].contentCid, replayedCells[i].contentCid):
            os.WriteLine(os.Get_stderr(), "cell_content_mismatch_at=" + intToStr(i))
            return 16
        if !fixed32ManualEqual(serverCells[i].localityHash, replayedCells[i].localityHash):
            os.WriteLine(os.Get_stderr(), "cell_locality_hash_mismatch_at=" + intToStr(i))
            return 17
        if !fixed32ManualEqual(serverCells[i].localityCid, replayedCells[i].localityCid):
            os.WriteLine(os.Get_stderr(), "cell_locality_cid_mismatch_at=" + intToStr(i))
            return 18
    let serverForestDirect = lsmr.BuildStateLayerForest(serverCells)
    let replayedForestDirect = lsmr.BuildStateLayerForest(replayedCells)

    if !fixed32ManualEqual(serverForestDirect.forestCid, server.forest.forestCid):
        dumpFixed32("server_direct_forest", serverForestDirect.forestCid)
        dumpFixed32("server_node_forest", server.forest.forestCid)
        return 21
    if !fixed32ManualEqual(replayedForestDirect.forestCid, replayed.forest.forestCid):
        dumpFixed32("replayed_direct_forest", replayedForestDirect.forestCid)
        dumpFixed32("replayed_node_forest", replayed.forest.forestCid)
        return 22
    if !fixed32ManualEqual(serverForestDirect.forestCid, replayedForestDirect.forestCid):
        dumpFixed32("server_direct_forest", serverForestDirect.forestCid)
        dumpFixed32("replayed_direct_forest", replayedForestDirect.forestCid)
        dumpFixed32("server_global_tree", serverForestDirect.globalTree.treeCid)
        dumpFixed32("replayed_global_tree", replayedForestDirect.globalTree.treeCid)
        dumpFixed32("server_regional_tree", serverForestDirect.regionalTree.treeCid)
        dumpFixed32("replayed_regional_tree", replayedForestDirect.regionalTree.treeCid)
        dumpFixed32("server_edge_tree", serverForestDirect.edgeTree.treeCid)
        dumpFixed32("replayed_edge_tree", replayedForestDirect.edgeTree.treeCid)
        return 23
    echo(" chain_node_rebuild_forest_probe ok")
    return 0
