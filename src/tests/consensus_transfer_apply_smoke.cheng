import std/system
import std/rawbytes as raw
import std/crypto/sha256
import cheng/std/bytes_layout as layout
import cheng/chain/consensus
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    var index = consensus.ChainIndex()
    let zeroCid = layout.FixedBytes32()
    assert(sha256.u32Mask() == int64(4294967295), " consensus transfer apply: sha256 mask")
    assert(sha256.rotr32(int64(305419896), 4) == sha256.u32FromBytes(0x81, 0x23, 0x45, 0x67),
           " consensus transfer apply: sha256 rotr32")
    assert(sha256.ch(sha256.u32FromBytes(0x6a, 0x09, 0xe6, 0x67),
                     sha256.u32FromBytes(0xbb, 0x67, 0xae, 0x85),
                     sha256.u32FromBytes(0x3c, 0x6e, 0xf3, 0x72)) == sha256.u32FromBytes(0x3e, 0x67, 0xb7, 0x15),
           " consensus transfer apply: sha256 ch")
    assert(sha256.maj(sha256.u32FromBytes(0x6a, 0x09, 0xe6, 0x67),
                      sha256.u32FromBytes(0xbb, 0x67, 0xae, 0x85),
                      sha256.u32FromBytes(0x3c, 0x6e, 0xf3, 0x72)) == sha256.u32FromBytes(0x3a, 0x6f, 0xe6, 0x67),
           " consensus transfer apply: sha256 maj")
    assert(sha256.bigSigma0(int64(305419896)) == sha256.u32FromBytes(0x66, 0x14, 0x64, 0x74),
           " consensus transfer apply: sha256 bigSigma0")
    assert(sha256.bigSigma1(int64(305419896)) == sha256.u32FromBytes(0x35, 0x61, 0xab, 0xda),
           " consensus transfer apply: sha256 bigSigma1")
    assert(sha256.smallSigma0(int64(305419896)) == sha256.u32FromBytes(0xe7, 0xfc, 0xe6, 0xee),
           " consensus transfer apply: sha256 smallSigma0")
    assert(sha256.smallSigma1(int64(305419896)) == sha256.u32FromBytes(0xa1, 0xf7, 0x86, 0x49),
           " consensus transfer apply: sha256 smallSigma1")
    assert(sha256.k256(0) == sha256.u32FromBytes(0x42, 0x8a, 0x2f, 0x98), " consensus transfer apply: sha256 k0")
    assert(sha256.k256(63) == sha256.u32FromBytes(0xc6, 0x71, 0x78, 0xf2), " consensus transfer apply: sha256 k63")
    var probeBufA = layout.byteBufInit(16)
    var probeBufB = layout.byteBufInit(16)
    lt.AppendU32BE(probeBufA, 1)
    lt.AppendU32BE(probeBufB, 2)
    let probeSpanA = layout.byteBufView(probeBufA)
    let probeSpanB = layout.byteBufView(probeBufB)
    assert(layout.byteSpanLen(probeSpanA) == 4, " consensus transfer apply: probe a len")
    assert(layout.byteSpanLen(probeSpanB) == 4, " consensus transfer apply: probe b len")
    assert(layout.byteSpanAt(probeSpanA, 3) == 1, " consensus transfer apply: probe a byte")
    assert(layout.byteSpanAt(probeSpanB, 3) == 2, " consensus transfer apply: probe b byte")
    assert(sha256.getU32BE(probeSpanA.data, 0) == 1, " consensus transfer apply: probe a word")
    assert(sha256.getU32BE(probeSpanB.data, 0) == 2, " consensus transfer apply: probe b word")
    let rawDigestA = sha256.sha256Digest(probeSpanA.data)
    let rawDigestB = sha256.sha256Digest(probeSpanB.data)
    assert(rawDigestA.len == 32, " consensus transfer apply: raw sha256 a len")
    assert(rawDigestB.len == 32, " consensus transfer apply: raw sha256 b len")
    assert(rawDigestA.data != nil, " consensus transfer apply: raw sha256 a ptr")
    assert(rawDigestB.data != nil, " consensus transfer apply: raw sha256 b ptr")
    assert(rawDigestA.data != rawDigestB.data,
           " consensus transfer apply: raw sha256 distinct ptr")
    var rawDigestLocalDistinct = false
    for i in 0..<32:
        let aByte = raw.ChengRawbytesGetAt(rawDigestA.data, i)
        let bByte = raw.ChengRawbytesGetAt(rawDigestB.data, i)
        if aByte != bByte:
            rawDigestLocalDistinct = true
    assert(rawDigestLocalDistinct,
           " consensus transfer apply: raw sha256 local distinct")
    let probeCidA = lt.FixedCidFromBuf(probeBufA)
    let probeCidB = lt.FixedCidFromBuf(probeBufB)
    var probeCidALocalMatchesRaw = true
    var probeCidBLocalMatchesRaw = true
    var probeCidLocalDistinct = false
    for i in 0..<layout.fixedBytes32Size:
        if int32(probeCidA.data[i]) != bytesGet(rawDigestA, i):
            probeCidALocalMatchesRaw = false
        if int32(probeCidB.data[i]) != bytesGet(rawDigestB, i):
            probeCidBLocalMatchesRaw = false
        if probeCidA.data[i] != probeCidB.data[i]:
            probeCidLocalDistinct = true
    assert(probeCidALocalMatchesRaw, " consensus transfer apply: probe cid a local matches raw")
    assert(probeCidBLocalMatchesRaw, " consensus transfer apply: probe cid b local matches raw")
    assert(probeCidLocalDistinct, " consensus transfer apply: probe cid local bytes distinct")
    assert(!layout.fixedBytes32Equal(probeCidA, probeCidB),
           " consensus transfer apply: manual cid distinct")

    var mint = consensus.ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let mintCid = consensus.ChainEventCid(mint)
    var mintDecision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(index, mint, mintCid, 0, mintDecision)
    assert(mintDecision.accepted, " consensus transfer apply: mint accepted")
    assert(mintDecision.applied, " consensus transfer apply: mint applied")
    assert(index.accountIds.len == 1, " consensus transfer apply: mint created one account")

    var transfer: consensus.ChainEvent
    transfer.version = 1
    transfer.kind = consensus.ConsensusKindTransferCommit
    transfer.assetId = 7
    transfer.fromAccount = 1001
    transfer.toAccount = 2002
    transfer.fromParentCid = mintCid
    transfer.toParentCid = zeroCid
    transfer.amount = int64(40)
    transfer.epoch = 1
    transfer.ganzhiIndex = 14
    transfer.spaceSlot = 1
    transfer.tick = int64(11)
    transfer.stem = transfer.ganzhiIndex % 10
    transfer.branch = transfer.ganzhiIndex % 12
    transfer.bodyCid = consensus.ChainEventBodyCid(transfer)
    assert(transfer.kind == consensus.ConsensusKindTransferCommit, " consensus transfer apply: transfer kind set")
    assert(transfer.fromAccount == 1001, " consensus transfer apply: transfer sender set")
    assert(!layout.fixedBytes32Equal(consensus.ChainEventBodyCid(mint), consensus.ChainEventBodyCid(transfer)),
           " consensus transfer apply: distinct body cid")

    let transferCid = consensus.ChainEventCid(transfer)
    assert(!layout.fixedBytes32Equal(mintCid, transferCid), " consensus transfer apply: distinct cid")
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(index, transfer, transferCid, 1, decision)
    assert(decision.accepted, " consensus transfer apply: transfer accepted")
    assert(decision.applied, " consensus transfer apply: transfer applied")
    assert(decision.fromAccountId == 1001, " consensus transfer apply: decision sender")
    assert(decision.toAccountId == 2002, " consensus transfer apply: decision receiver")
    assert(index.accountIds.len == 2, " consensus transfer apply: two accounts")
    let senderPos = consensus.ConsensusAccountPos(index, 7, 1001)
    let receiverPos = consensus.ConsensusAccountPos(index, 7, 2002)
    assert(senderPos == 0, " consensus transfer apply: sender pos")
    assert(receiverPos == 1, " consensus transfer apply: receiver pos")
    assert(index.accountIds[senderPos] == 1001, " consensus transfer apply: sender slot")
    assert(index.accountIds[receiverPos] == 2002, " consensus transfer apply: receiver slot")
    assert(index.balances[receiverPos] == int64(40),
           " consensus transfer apply: receiver 40")
    assert(index.balances[senderPos] == int64(60),
           " consensus transfer apply: sender 60")
    echo(" consensus_transfer_apply_smoke ok")
    return 0
