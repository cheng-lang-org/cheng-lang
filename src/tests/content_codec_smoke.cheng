import std/system
import std/rawbytes
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content
import cheng/chain/content_fetch as fetch

fn contentCodecBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    let shard0 = bytesFromString("codec-0")
    let shard1 = bytesFromString("codec-1")
    let blob = bytesFromString("codec-0codec-1")
    let summaryRes = dag.DagBlobSummaryFromBytes(blob, 7)
    assert(IsOk(summaryRes), " content codec smoke: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic, 2, 0, 7)
    assert(IsOk(paramsRes), " content codec smoke: params")
    let params = Value(paramsRes)

    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard0))
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard1))
    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), " content codec smoke: manifest")
    let manifest = Value(manifestRes)

    let pullReqRes = swarm.ErasureShardPullRequestMake(manifest, 0)
    assert(IsOk(pullReqRes), " content codec smoke: pull request")
    let pullReq = Value(pullReqRes)
    let pullReqDecodedRes = swarm.ErasureShardPullRequestDecode(
        swarm.ErasureShardPullRequestEncode(pullReq)
    )
    assert(IsOk(pullReqDecodedRes), " content codec smoke: pull request decode")
    let pullReqDecoded = Value(pullReqDecodedRes)
    assert(layout.fixedBytes32Equal(pullReqDecoded.requestCid, pullReq.requestCid),
        " content codec smoke: pull request cid")

    let pullRespRes = swarm.ErasureShardPullResponseMake(pullReq, shard0)
    assert(IsOk(pullRespRes), " content codec smoke: pull response")
    let pullResp = Value(pullRespRes)
    let pullRespDecodedRes = swarm.ErasureShardPullResponseDecode(
        swarm.ErasureShardPullResponseEncode(pullResp)
    )
    assert(IsOk(pullRespDecodedRes), " content codec smoke: pull response decode")
    let pullRespDecoded = Value(pullRespDecodedRes)
    assert(layout.fixedBytes32Equal(pullRespDecoded.responseCid, pullResp.responseCid),
        " content codec smoke: pull response cid")
    assert(pullRespDecoded.payloadLen == bytesLen(shard0), " content codec smoke: pull payload len")

    let manifestFetchReqRes = fetch.ContentFetchRequestManifest(manifest.manifestCid)
    assert(IsOk(manifestFetchReqRes), " content codec smoke: manifest fetch request")
    let manifestFetchReq = Value(manifestFetchReqRes)
    let manifestFetchRespRes = fetch.ContentFetchResponseMake(manifestFetchReq,
                                                                swarm.ErasureShardManifestEncode(manifest))
    assert(IsOk(manifestFetchRespRes), " content codec smoke: manifest fetch response")
    var manifestBack = swarm.ErasureShardManifest()
    let manifestBackRes = fetch.ContentFetchResponseToManifestFill(manifestBack,
                                                                     manifestFetchReq,
                                                                     Value(manifestFetchRespRes))
    assert(IsOk(manifestBackRes), " content codec smoke: manifest fetch roundtrip")
    assert(layout.fixedBytes32Equal(manifestBack.manifestCid, manifest.manifestCid),
        " content codec smoke: manifest roundtrip cid")

    let chunkFetchReqRes = fetch.ContentFetchRequestFromShardPull(pullReq)
    assert(IsOk(chunkFetchReqRes), " content codec smoke: chunk fetch request")
    let chunkFetchReq = Value(chunkFetchReqRes)
    let chunkFetchRespRes = fetch.ContentFetchResponseMake(chunkFetchReq, shard0)
    assert(IsOk(chunkFetchRespRes), " content codec smoke: chunk fetch response")
    var pullRespBack = swarm.ErasureShardPullResponse()
    let pullRespBackRes = fetch.ContentFetchResponseToShardPullFill(pullRespBack,
                                                                      chunkFetchReq,
                                                                      Value(chunkFetchRespRes))
    assert(IsOk(pullRespBackRes), " content codec smoke: chunk fetch roundtrip")
    assert(layout.fixedBytes32Equal(pullRespBack.shardCid, pullReq.shardCid),
        " content codec smoke: chunk roundtrip shard cid")

    let stubRes = content.ContentStubMake(lt.HashInts("cheng.content.codec.topic", [1]),
                                            lt.HashInts("cheng.content.codec.bundle", [2]),
                                            summary.summaryCid,
                                            lt.HashInts("cheng.content.codec.advert", [3]),
                                            manifest.manifestCid,
                                            lt.HashInts("cheng.content.codec.plan", [4]),
                                            summary.payloadLen)
    assert(IsOk(stubRes), " content codec smoke: stub")
    let stub = Value(stubRes)
    let stubDecodedRes = content.ContentStubDecode(content.ContentStubEncode(stub))
    assert(IsOk(stubDecodedRes), " content codec smoke: stub decode")
    assert(layout.fixedBytes32Equal(Value(stubDecodedRes).stubCid, stub.stubCid),
        " content codec smoke: stub cid")

    let rangeReqRes = fetch.ContentFetchRequestRange(summary.blobCid, 2, 4)
    assert(IsOk(rangeReqRes), " content codec smoke: range request")
    let rangeReq = Value(rangeReqRes)
    let rangeRespRes = fetch.ContentFetchResponseMake(rangeReq, bytesSlice(blob, 2, 4))
    assert(IsOk(rangeRespRes), " content codec smoke: range response")
    let rangeRespDecodedRes = fetch.ContentFetchResponseDecode(
        fetch.ContentFetchResponseEncode(Value(rangeRespRes))
    )
    assert(IsOk(rangeRespDecodedRes), " content codec smoke: range response decode")
    let rangePayload = Value(rangeRespDecodedRes).payload
    assert(contentCodecBytesEqual(rangePayload, bytesSlice(blob, 2, 4)),
        " content codec smoke: range payload")

    echo(" content_codec_smoke ok")
    return 0
