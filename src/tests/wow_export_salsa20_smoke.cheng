import std/rawbytes
import std/result
import cheng/apps/wow_export/salsa20 as salsa20
import std/strutils as strutil

fn makeBytes(len: int32): rawbytes.Bytes =
    return rawbytes.BytesAlloc(len)

fn main(): int32 =
    var key: rawbytes.Bytes = makeBytes(32)
    rawbytes.BytesSet(key, 0, 0x80)
    let nonce: rawbytes.Bytes = makeBytes(8)
    let streamRes: Result[str] = salsa20.Salsa20KeystreamHex(key, nonce, 64)
    assert(IsOk(streamRes), Error(streamRes))
    let expected: str = "e3be8fdd8beca2e3ea8ef9475b29a6e7003951e1097a5c38d23b7a5fad9f6844b22c97559e2723c7cbbd3fe4fc8d9a0744652a83e72a9c461876af4d7ef1a117"
    assert(Value(streamRes) == expected, strutil.Join(["wow_export_salsa20_smoke stream vector got=", Value(streamRes)], ""))

    let plain: rawbytes.Bytes = rawbytes.BytesFromString("northshire")
    let cipherRes: Result[rawbytes.Bytes] = salsa20.Salsa20Xor(key, nonce, plain)
    assert(IsOk(cipherRes), Error(cipherRes))
    let roundRes: Result[rawbytes.Bytes] = salsa20.Salsa20Xor(key, nonce, Value(cipherRes))
    assert(IsOk(roundRes), Error(roundRes))
    assert(rawbytes.BytesEqual(Value(roundRes), plain), "wow_export_salsa20_smoke xor roundtrip")
    echo("wow_export_salsa20_smoke ok")
    return 0
