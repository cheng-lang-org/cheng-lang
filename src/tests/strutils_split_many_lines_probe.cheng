import std/strutils as strutil

fn main(): int32 =
    let text = "a\nb\nc\nd\ne\nf\ng\nh\ni\nj\nk\nl\n"
    let lines = strutil.Split(text, '\n')
    assert(lines.len == 13, " split many lines: len")
    assert(lines[0] == "a", " split many lines: first")
    assert(lines[11] == "l", " split many lines: last text")
    assert(lines[12] == "", " split many lines: trailing empty")
    echo(" strutils_split_many_lines_probe ok")
    return 0
