import std/system

fn setWord(out: var uint64, value: uint64) =
    out = value

fn main(argc: int32, argv: ptr): int32 =
    argc
    argv
    var value: uint64 = uint64(7)
    setWord(value, uint64(0))
    assert(value == uint64(0), "var_uint64_out_probe: zero writeback")
    setWord(value, uint64(1))
    assert(value == uint64(1), "var_uint64_out_probe: one writeback")
    setWord(value, uint64(0x100000001))
    assert(value == uint64(0x100000001), "var_uint64_out_probe: wide writeback")
    echo(" var_uint64_out_probe ok")
    return 0
