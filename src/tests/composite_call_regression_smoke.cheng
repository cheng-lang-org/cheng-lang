import std/rawbytes
import cheng/tests/composite_call_regression_helper as helper

fn alwaysFail(): Result[bool] =
    return Err[bool]("regression-error")

fn wrapProjectedError(): Result[bool] =
    let failRes: Result[bool] = alwaysFail()
    if IsErr(failRes):
        return Err[bool](Error(failRes))
    return Ok[bool](true)

fn main(): int32 =
    let directHex: str = bytesToHex(helper.CompositeRegressionBytes())
    assert(directHex == "6162", " composite call regression: qualified zeroarg arg")

    let pubText: str = "pub=" + bytesToHex(helper.CompositeRegressionPubBytes())
    assert(pubText == "pub=707562", " composite call regression: binary nested call")

    let wrapped: Result[bool] = wrapProjectedError()
    assert(IsErr(wrapped), " composite call regression: projected error")
    assert(Error(wrapped) == "regression-error", " composite call regression: projected error text")

    echo(" composite_call_regression_smoke ok")
    return 0
