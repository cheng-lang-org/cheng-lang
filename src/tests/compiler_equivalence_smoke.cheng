import cheng/core/tooling/compiler_equivalence as ceq
import cheng/std/bytes_layout as layout

fn main(): int32 =
    let csgText = "version=1\npackage_id=cheng\ncanonical_graph_cid=2222222222222222222222222222222222222222222222222222222222222222\ngraph_cid=1111111111111111111111111111111111111111111111111111111111111111"
    var cid = layout.FixedBytes32()
    let cidRes = ceq.CompilerEquivalenceGraphCidFromText(csgText, cid)
    assert(IsOk(cidRes), " compiler equivalence: baseline graph cid")
    assert(!layout.FixedBytes32Equal(cid, layout.FixedBytes32()),
           " compiler equivalence: parsed cid")
    let rawOnlyText = "version=1\npackage_id=cheng\ngraph_cid=1111111111111111111111111111111111111111111111111111111111111111"
    var rawOnlyCid = layout.FixedBytes32()
    let rawOnlyRes = ceq.CompilerEquivalenceGraphCidFromText(rawOnlyText, rawOnlyCid)
    assert(IsErr(rawOnlyRes), " compiler equivalence: raw graph cid rejected")
    assert(ceq.CompilerEquivalenceKind(true, true, true) == "canonical_semantic_identity",
           " compiler equivalence: canonical kind")
    assert(ceq.CompilerEquivalenceKind(true, true, false) == "incompatible",
           " compiler equivalence: incompatible kind")
    echo(" compiler_equivalence_smoke ok")
    return 0
