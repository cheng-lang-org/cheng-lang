import std/system
import cheng/std/bytes_layout as layout

fn main(): int32 =
    var xs: layout.FixedBytes32[]
    xs = []
    var a = layout.FixedBytes32()
    a.data[0] = 1
    add(xs, a)
    assert(xs.len == 1, " fixedbytes32 seq add len: len")
    assert(xs.cap >= 1, " fixedbytes32 seq add len: cap")
    echo(" fixedbytes32_seq_add_len_smoke ok")
    return 0
