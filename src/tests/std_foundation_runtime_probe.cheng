import std/system
import std/result
import std/rawbytes
import std/varint
import std/stringlist
import std/seqs

fn main() =
    echo("probe: start")
    var numbers: int32[]
    seqs.Add(numbers, 7)
    seqs.Add(numbers, 9)
    echo("probe: seq ok")

    let okRes: Result[int32] = Ok[int32](23)
    echo("probe: result ok=" + (IsOk(okRes) ? "1" : "0"))

    var data: Bytes = bytesAlloc(4)
    bytesSet(data, 0, 1)
    bytesSet(data, 1, 2)
    bytesSet(data, 2, 3)
    bytesSet(data, 3, 4)
    echo("probe: rawbytes hex=" + bytesToHex(bytesSlice(data, 1, 2)))

    let encoded: Bytes = encodeUVarint(300)
    echo("probe: encoded len=" + intToStr(bytesLen(encoded)))
    echo("probe: encoded hex=" + bytesToHex(encoded))
    let decodedRes: Result[VarintDecoded] = decodeUVarint(encoded, 0)
    echo("probe: decode ok=" + (IsOk(decodedRes) ? "1" : "0"))
    if IsOk(decodedRes):
        let decoded: VarintDecoded = Value(decodedRes)
        echo("probe: decoded value=" + int64ToStr(decoded.value))
        echo("probe: decoded next=" + intToStr(decoded.next))
    else:
        echo("probe: decode err=" + Error(decodedRes))

    var list: StringList = initStringList()
    let addRes: Result[bool] = stringListAdd(list, "a")
    echo("probe: stringlist add=" + (IsOk(addRes) ? "1" : "0"))
    let linesRes: Result[StringList] = stringListFromLines("x\ny\nx\n")
    echo("probe: lines ok=" + (IsOk(linesRes) ? "1" : "0"))
    if IsOk(linesRes):
        let list2: StringList = Value(linesRes)
        echo("probe: lines count=" + intToStr(stringListCount(list2)))
    else:
        echo("probe: lines err=" + Error(linesRes))

    echo("probe: done")
