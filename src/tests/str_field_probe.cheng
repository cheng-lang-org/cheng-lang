type
    ProbeRecord =
        version: str
        mode: str
    UInt8Ptr = uint8 *

fn makeProbe(): ProbeRecord =
    return ProbeRecord(
        version: "cheng.compiler_runtime.v1",
        mode: "argv_control_plane"
    )

fn main(): int32 =
    let rec = makeProbe()
    if rec.version.data == nil:
        return 11
    if rec.version.len == 0:
        return 12
    if rec.version.len != 22:
        return 13
    if *(UInt8Ptr(rec.version.data)) != uint8(int32('v')):
        return 14
    if rec.mode.data == nil:
        return 21
    if rec.mode.len == 0:
        return 22
    if rec.mode.len != 18:
        return 23
    if *(UInt8Ptr(rec.mode.data)) != uint8(int32('a')):
        return 24
    if rec.version != "cheng.compiler_runtime.v1":
        return 1
    if rec.mode != "argv_control_plane":
        return 2
    echo("str_field_probe ok")
    return 0
