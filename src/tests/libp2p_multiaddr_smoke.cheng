import std/system
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr

fn main(): int32 =
    let tcpText = bytesFromString("/ip4/127.0.0.1/tcp/4101")
    var tcpAddr: types.Libp2pMultiaddr
    let tcpAddrRes = multiaddr.Libp2pMultiaddrFillFromBytes(tcpAddr, tcpText)
    assert(tcpAddrRes.ok, " libp2p multiaddr: tcp parse")
    assert(tcpAddr.transport == types.Libp2pTransportTcp, " libp2p multiaddr: tcp transport")
    assert(tcpAddr.secure == types.Libp2pSecureNoise, " libp2p multiaddr: tcp noise")
    assert(tcpAddr.mux == types.Libp2pMuxYamux, " libp2p multiaddr: tcp yamux")

    let quicText = bytesFromString("/ip4/127.0.0.1/udp/4201/quic-v1")
    var quicAddr: types.Libp2pMultiaddr
    let quicAddrRes = multiaddr.Libp2pMultiaddrFillFromBytes(quicAddr, quicText)
    assert(quicAddrRes.ok, " libp2p multiaddr: quic parse")
    assert(quicAddr.transport == types.Libp2pTransportQuic, " libp2p multiaddr: quic transport")
    assert(quicAddr.secure == types.Libp2pSecureTls, " libp2p multiaddr: quic tls")
    assert(quicAddr.mux == types.Libp2pMuxNone, " libp2p multiaddr: quic mux")
    echo(" libp2p_multiaddr_smoke ok")
    return 0
