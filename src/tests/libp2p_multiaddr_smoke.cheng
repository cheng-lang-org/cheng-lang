import std/system
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr

fn main(): int32 =
    let tcpText = bytesFromString("/ip4/127.0.0.1/tcp/4101")
    var tcpAddr: types.V3Libp2pMultiaddr
    let tcpAddrRes = multiaddr.v3Libp2pMultiaddrFillFromBytes(tcpAddr, tcpText)
    assert(tcpAddrRes.ok, "v3 libp2p multiaddr: tcp parse")
    assert(tcpAddr.transport == types.v3Libp2pTransportTcp, "v3 libp2p multiaddr: tcp transport")
    assert(tcpAddr.secure == types.v3Libp2pSecureNoise, "v3 libp2p multiaddr: tcp noise")
    assert(tcpAddr.mux == types.v3Libp2pMuxYamux, "v3 libp2p multiaddr: tcp yamux")

    let quicText = bytesFromString("/ip4/127.0.0.1/udp/4201/quic-v1")
    var quicAddr: types.V3Libp2pMultiaddr
    let quicAddrRes = multiaddr.v3Libp2pMultiaddrFillFromBytes(quicAddr, quicText)
    assert(quicAddrRes.ok, "v3 libp2p multiaddr: quic parse")
    assert(quicAddr.transport == types.v3Libp2pTransportQuic, "v3 libp2p multiaddr: quic transport")
    assert(quicAddr.secure == types.v3Libp2pSecureTls, "v3 libp2p multiaddr: quic tls")
    assert(quicAddr.mux == types.v3Libp2pMuxNone, "v3 libp2p multiaddr: quic mux")
    echo("v3 libp2p_multiaddr_smoke ok")
    return 0
