import cheng/codex/protocol/types
import rust-csg/protocol/types as csg_types

fn main(): int32 =
    var result: types.CodexExecResult
    result.exitCode = 7
    assert(result.exitCode == 7, "cold nested package import: result field")
    var status: csg_types.RustCsgParityStatus
    status.ported = true
    assert(status.ported, "cold nested package import: package alias field")
    echo("cold_nested_package_import_smoke ok")
    return 0
