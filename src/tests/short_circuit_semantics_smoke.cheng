var shortCircuitCounter: int32 = 0

fn leftTrue(): bool =
    return true

fn leftFalse(): bool =
    return false

fn rightTrueProbe(): bool =
    shortCircuitCounter = shortCircuitCounter + 1
    return true

fn rightFalseProbe(): bool =
    shortCircuitCounter = shortCircuitCounter + 1
    return false

fn resetCounter() =
    shortCircuitCounter = 0

fn main(): int32 =
    resetCounter()
    let orSkip: bool = leftTrue() || rightTrueProbe()
    assert(orSkip, "v3 short circuit: or result")
    assert(shortCircuitCounter == 0, "v3 short circuit: or skip rhs")

    resetCounter()
    let andSkip: bool = leftFalse() && rightTrueProbe()
    assert(!andSkip, "v3 short circuit: and result")
    assert(shortCircuitCounter == 0, "v3 short circuit: and skip rhs")

    resetCounter()
    let orNeed: bool = leftFalse() || rightTrueProbe()
    assert(orNeed, "v3 short circuit: or eval rhs")
    assert(shortCircuitCounter == 1, "v3 short circuit: or rhs count")

    resetCounter()
    let andNeed: bool = leftTrue() && rightFalseProbe()
    assert(!andNeed, "v3 short circuit: and eval rhs")
    assert(shortCircuitCounter == 1, "v3 short circuit: and rhs count")

    echo("v3 short_circuit_semantics_smoke ok")
    return 0
