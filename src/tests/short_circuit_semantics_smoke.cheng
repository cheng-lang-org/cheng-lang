var shortCircuitCounter: int32

fn leftTrue(): bool =
    return true

fn leftFalse(): bool =
    return false

fn rightTrueProbe(): bool =
    shortCircuitCounter = shortCircuitCounter + 1
    return true

fn rightFalseProbe(): bool =
    shortCircuitCounter = shortCircuitCounter + 1
    return false

fn resetCounter() =
    shortCircuitCounter = 0

fn main(): int32 =
    resetCounter()
    let orSkip: bool = leftTrue() || rightTrueProbe()
    assert(orSkip, " short circuit: or result")
    assert(shortCircuitCounter == 0, " short circuit: or skip rhs")

    resetCounter()
    let andSkip: bool = leftFalse() && rightTrueProbe()
    assert(!andSkip, " short circuit: and result")
    assert(shortCircuitCounter == 0, " short circuit: and skip rhs")

    resetCounter()
    let orNeed: bool = leftFalse() || rightTrueProbe()
    assert(orNeed, " short circuit: or eval rhs")
    assert(shortCircuitCounter == 1, " short circuit: or rhs count")

    resetCounter()
    let andNeed: bool = leftTrue() && rightFalseProbe()
    assert(!andNeed, " short circuit: and eval rhs")
    assert(shortCircuitCounter == 1, " short circuit: and rhs count")

    echo(" short_circuit_semantics_smoke ok")
    return 0
