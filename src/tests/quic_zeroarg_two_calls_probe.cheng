import std/rawbytes
import cheng/quic/tls/handshake13

fn main(): int32 =
    let a: str = "a=" + bytesToHex(handshake13.msquicTls13ClientLocalKeySharePriv())
    let b: str = "b=" + bytesToHex(handshake13.msquicTls13ClientLocalKeySharePub())
    if len(a) + len(b) < 0:
        return 1
    return 0
