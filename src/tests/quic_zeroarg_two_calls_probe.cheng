import std/rawbytes
import cheng/quic/tls/handshake13
import std/strutils as strutil

fn main(): int32 =
    let a: str = strutil.Join(["a=", bytesToHex(handshake13.msquicTls13ClientLocalKeySharePriv())], "")
    let b: str = strutil.Join(["b=", bytesToHex(handshake13.msquicTls13ClientLocalKeySharePub())], "")
    if len(a) + len(b) < 0:
        return 1
    return 0
