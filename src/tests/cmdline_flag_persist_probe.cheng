import std/cmdline as cmdline
import std/os
import std/strutils as strutil

fn clutter(seed: str): str =
    let left = strutil.Join([seed, ":left"], "")
    let right = strutil.Join([left, ":right"], "")
    return right

fn main(): int32 =
    let value = cmdline.ReadFlagOrDefault("--value", "")
    os.WriteFile("/tmp/cmdline_flag_persist_early.txt", value)
    var sink = ""
    for i in 0..<32:
        sink = clutter(value)
        if sink == "__never__":
            os.WriteFile("/tmp/cmdline_flag_persist_sink.txt", sink)
    os.WriteFile("/tmp/cmdline_flag_persist_late.txt", value)
    return 0
