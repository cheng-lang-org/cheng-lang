import std/system
import std/crypto/sha256
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    var probeBufA = layout.byteBufInit(16)
    var probeBufB = layout.byteBufInit(16)
    lt.v3AppendU32BE(probeBufA, 1)
    lt.v3AppendU32BE(probeBufB, 2)
    let probeSpanA = layout.byteBufView(probeBufA)
    let probeSpanB = layout.byteBufView(probeBufB)
    assert(layout.byteSpanLen(probeSpanA) == 4, "v3 bytebuf probe: probe a len")
    assert(layout.byteSpanLen(probeSpanB) == 4, "v3 bytebuf probe: probe b len")
    assert(layout.byteSpanAt(probeSpanA, 3) == 1, "v3 bytebuf probe: probe a byte")
    assert(layout.byteSpanAt(probeSpanB, 3) == 2, "v3 bytebuf probe: probe b byte")
    assert(sha256.getU32BE(probeSpanA.data, 0) == 1, "v3 bytebuf probe: probe a word")
    assert(sha256.getU32BE(probeSpanB.data, 0) == 2, "v3 bytebuf probe: probe b word")
    echo("v3 bytebuf_probe_smoke ok")
    return 0
