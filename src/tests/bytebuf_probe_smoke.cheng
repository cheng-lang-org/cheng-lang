import std/system
import std/crypto/sha256
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    var probeBufA = layout.ByteBufInit(16)
    var probeBufB = layout.ByteBufInit(16)
    lt.AppendU32BE(probeBufA, 1)
    lt.AppendU32BE(probeBufB, 2)
    let probeSpanA = layout.ByteBufView(probeBufA)
    let probeSpanB = layout.ByteBufView(probeBufB)
    assert(layout.ByteSpanLen(probeSpanA) == 4, " bytebuf probe: probe a len")
    assert(layout.ByteSpanLen(probeSpanB) == 4, " bytebuf probe: probe b len")
    assert(layout.ByteSpanAt(probeSpanA, 3) == 1, " bytebuf probe: probe a byte")
    assert(layout.ByteSpanAt(probeSpanB, 3) == 2, " bytebuf probe: probe b byte")
    assert(sha256.getU32BE(probeSpanA.data, 0) == 1, " bytebuf probe: probe a word")
    assert(sha256.getU32BE(probeSpanB.data, 0) == 2, " bytebuf probe: probe b word")
    echo(" bytebuf_probe_smoke ok")
    return 0
