import std/system
import std/rawbytes

type
    PacketBox =
        payload: Bytes

fn clearBytes(data: var Bytes) =
    data = emptyBytes()

fn main(): int32 =
    var slot: PacketBox
    slot.payload = bytesAlloc(24)
    let oldPtr = slot.payload.data
    assert(memRefCount(oldPtr) == 1, "v3 bytes parent copy orc: old rc before copy")

    var rhs: PacketBox
    rhs.payload = bytesAlloc(64)
    bytesSet(rhs.payload, 0, int32('z'))
    let rhsPtr = rhs.payload.data
    assert(memRefCount(rhsPtr) == 1, "v3 bytes parent copy orc: rhs rc before copy")

    slot = rhs
    let oldAfter = memRefCount(oldPtr)
    let rhsAfter = memRefCount(rhsPtr)
    echo("v3 bytes parent copy orc: old rc after copy=" + intToStr(oldAfter))
    echo("v3 bytes parent copy orc: rhs rc after copy=" + intToStr(rhsAfter))
    assert(oldAfter == 0, "v3 bytes parent copy orc: old payload released")
    assert(rhsAfter == 2, "v3 bytes parent copy orc: rhs retained into slot")

    clearBytes(rhs.payload)
    assert(memRefCount(rhsPtr) == 1, "v3 bytes parent copy orc: rhs release leaves slot owner")
    assert(bytesGet(slot.payload, 0) == int32('z'),
           "v3 bytes parent copy orc: slot payload survives rhs release")

    clearBytes(slot.payload)
    assert(memRefCount(rhsPtr) == 0, "v3 bytes parent copy orc: final release")

    echo("v3 bytes_parent_copy_orc_smoke ok")
    return 0
