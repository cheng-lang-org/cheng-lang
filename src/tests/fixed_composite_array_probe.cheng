import std/result

type
    ProbeItem =
        value: int32

    ProbeWrap =
        items: ProbeItem[2]

    StrItem =
        value: int32
        tag: str

    StrWrap =
        items: StrItem[3]

var
    probeWrapDefault: ProbeWrap
    probeWrapZero: ProbeWrap = ProbeWrap(items: [ProbeItem(value: 0), ProbeItem(value: 0)])

fn makeItem(value: int32): ProbeItem =
    return ProbeItem(value: value)

fn makeWrapDirect(): ProbeWrap =
    return ProbeWrap(items: [ProbeItem(value: 1), ProbeItem(value: 2)])

fn makeWrapViaHelper(): ProbeWrap =
    return ProbeWrap(items: [makeItem(3), makeItem(4)])

fn makeWrapFromGlobal(): ProbeWrap =
    return probeWrapZero

fn makeWrapFromDefaultGlobal(): ProbeWrap =
    return probeWrapDefault

fn makeWrapLocalCopy(): ProbeWrap =
    var out: ProbeWrap = probeWrapZero
    out.items[0] = ProbeItem(value: 5)
    out.items[1] = ProbeItem(value: 6)
    return out

fn makeStrWrapDirect(): StrWrap =
    return StrWrap(items: [
        StrItem(value: 3, tag: "a"),
        StrItem(value: 5, tag: "b"),
        StrItem(value: 7, tag: "c")
    ])

fn sumStrItems(items: StrItem[3]): int32 =
    var total: int32
    for i in 0..<3:
        total = total + items[i].value
    return total

fn firstStrTag(items: StrItem[3]): str =
    return items[0].tag

fn sumStrWrap(wrap: StrWrap): int32 =
    return sumStrItems(wrap.items)

fn main(): int32 =
    let direct: ProbeWrap = makeWrapDirect()
    assert(direct.items[0].value == 1, "fixed composite array probe: direct 0")
    assert(direct.items[1].value == 2, "fixed composite array probe: direct 1")
    let helper: ProbeWrap = makeWrapViaHelper()
    assert(helper.items[0].value == 3, "fixed composite array probe: helper 0")
    assert(helper.items[1].value == 4, "fixed composite array probe: helper 1")
    let globalCopy: ProbeWrap = makeWrapFromGlobal()
    assert(globalCopy.items[0].value == 0, "fixed composite array probe: global 0")
    assert(globalCopy.items[1].value == 0, "fixed composite array probe: global 1")
    let defaultGlobalCopy: ProbeWrap = makeWrapFromDefaultGlobal()
    assert(defaultGlobalCopy.items[0].value == 0, "fixed composite array probe: default global 0")
    assert(defaultGlobalCopy.items[1].value == 0, "fixed composite array probe: default global 1")
    let localCopy: ProbeWrap = makeWrapLocalCopy()
    assert(localCopy.items[0].value == 5, "fixed composite array probe: local copy 0")
    assert(localCopy.items[1].value == 6, "fixed composite array probe: local copy 1")
    let strDirect: StrWrap = makeStrWrapDirect()
    assert(strDirect.items[0].value == 3, "fixed composite array probe: str direct 0")
    assert(strDirect.items[1].value == 5, "fixed composite array probe: str direct 1")
    assert(strDirect.items[2].value == 7, "fixed composite array probe: str direct 2")
    assert(sumStrItems(strDirect.items) == 15, "fixed composite array probe: str array arg")
    assert(firstStrTag(strDirect.items) == "a", "fixed composite array probe: str field arg")
    assert(sumStrWrap(strDirect) == 15, "fixed composite array probe: str wrap arg")
    return 0
