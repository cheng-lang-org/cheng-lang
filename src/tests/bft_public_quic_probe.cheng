import std/system
import std/result
import cheng/apps/bft/bft_validator_host as host
import std/strutils as strutil

@importc("cheng_sleep_ms_bridge")
fn cheng_sleep_ms_bridge(value: int32)

fn BftPublicProbeStartsWith(text: str, prefix: str): bool =
    if len(prefix) > len(text):
        return false
    for i in 0..<len(prefix):
        if text[i] != prefix[i]:
            return false
    return true

fn BftPublicProbeAttempt(proposalHost: str,
                           proposalPort: int32,
                           outErr: var str): bool =
    outErr = ""
    let proposalRes = host.BftValidatorRecvProposal(proposalHost, proposalPort)
    if IsErr(proposalRes):
        outErr = Error(proposalRes)
        return false
    let proposal = Value(proposalRes)
    echo(strutil.Join(["proposal_height=", host.BftValidatorInt64Text(proposal.height)], ""))
    echo(strutil.Join(["proposal_txs=", IntToStr(proposal.txs.len)], ""))
    return true

fn main(): int32 =
    let proposalHost = "64.176.84.12"
    let proposalPort = 42061
    var lastErr = ""
    var found = false
    var fatal = false
    for attempt in 0..<256:
        if BftPublicProbeAttempt(proposalHost, proposalPort, lastErr):
            found = true
            break
        if !BftPublicProbeStartsWith(lastErr, " libp2p quic: dial"):
            fatal = true
            break
        cheng_sleep_ms_bridge(50)
        attempt
    if found:
        return 0
    echo(lastErr)
    fatal
    return 1
