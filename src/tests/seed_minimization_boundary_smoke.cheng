import std/os
import std/strings
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root = os.GetCurrentDir()
    let driver = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    let stage3 = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage3")
    assert(chengpath.FileExistsNonEmpty(root, driver), "seed minimization boundary: backend driver exists")
    assert(chengpath.FileExistsNonEmpty(root, stage3), "seed minimization boundary: stage3 exists")

    let outDir = chengpath.PathAbsolute(root, "artifacts/seed_minimization_boundary_smoke")
    assert(chengpath.MkdirP(root, outDir), "seed minimization boundary: mkdir")

    let helpLog = chengpath.PathJoin(outDir, "help.log")
    if chengpath.PathFileExists(helpLog):
        os.RemoveFile(helpLog)
    let helpRun = hostops.RunFileLogged(root,
                                         "seed_minimization_boundary_help",
                                         driver,
                                         ["help"],
                                         [],
                                         root,
                                         0,
                                         helpLog)
    assert(helpRun.exitCode == 0, "seed minimization boundary: help rc")
    assert(strings.StrContains(helpRun.output, "core commands: status, print-build-plan, host-bridge-audit, system-link-exec"),
           "seed minimization boundary: help core commands")
    assert(strings.StrContains(helpRun.output, "world/proof commands: world-receipt"),
           "seed minimization boundary: help world proof commands")
    assert(strings.StrContains(helpRun.output, "debug commands:"),
           "seed minimization boundary: help debug section")
    assert(strings.StrContains(helpRun.output, "debug-report") &&
           strings.StrContains(helpRun.output, "print-symbols") &&
           strings.StrContains(helpRun.output, "print-line-map") &&
           strings.StrContains(helpRun.output, "print-asm"),
           "seed minimization boundary: help core debug commands")
    assert(strings.StrContains(helpRun.output, "verify commands:"),
           "seed minimization boundary: help verify section")
    assert(strings.StrContains(helpRun.output, "verify-export-visibility") &&
           strings.StrContains(helpRun.output, "verify-backend-driver-command-surface") &&
           strings.StrContains(helpRun.output, "verify-mobile-shell-build-probe") &&
           strings.StrContains(helpRun.output, "verify-r2c-react-surface") &&
           strings.StrContains(helpRun.output, "verify-debug-tools") &&
           strings.StrContains(helpRun.output, "verify-debug-runtime"),
           "seed minimization boundary: help core verify commands")
    assert(!strings.StrContains(helpRun.output, "core commands: status, print-build-plan, system-link-exec, world-receipt"),
           "seed minimization boundary: help excludes world-receipt from core")

    var migratedCommands: str[]
    add(migratedCommands, "status")
    add(migratedCommands, "print-build-plan")
    add(migratedCommands, "scan-hotpath")
    add(migratedCommands, "print-bootstrap")
    add(migratedCommands, "run-smokes")
    add(migratedCommands, "slice-gate")
    add(migratedCommands, "support-matrix")
    add(migratedCommands, "compile-exe")
    add(migratedCommands, "system-link-exec")
    add(migratedCommands, "host-bridge-audit")
    add(migratedCommands, "world-receipt")
    add(migratedCommands, "emit-csg")
    add(migratedCommands, "migrate-csg")
    add(migratedCommands, "verify-world")
    add(migratedCommands, "world-sync")
    add(migratedCommands, "prove-equivalence")
    add(migratedCommands, "prove-migration")
    add(migratedCommands, "publish-world")
    add(migratedCommands, "fresh-node-selfhost")
    add(migratedCommands, "selfhost-build")
    add(migratedCommands, "debug-report")
    add(migratedCommands, "print-symbols")
    add(migratedCommands, "print-line-map")
    add(migratedCommands, "print-asm")
    add(migratedCommands, "verify-orphan-guard")
    add(migratedCommands, "verify-export-visibility")
    add(migratedCommands, "verify-export-visibility-parallel")
    add(migratedCommands, "verify-backend-driver-command-surface")
    add(migratedCommands, "verify-mobile-shell-build-probe")
    add(migratedCommands, "verify-chain-node-resilience")
    add(migratedCommands, "verify-oracle-resilience")
    add(migratedCommands, "oracle-fixture-query")
    add(migratedCommands, "verify-r2c-react-surface")
    add(migratedCommands, "verify-debug-tools")
    add(migratedCommands, "verify-debug-runtime")
    add(migratedCommands, "verify-debug-profile")
    add(migratedCommands, "verify-diloco")
    add(migratedCommands, "verify-windows-builtin")
    add(migratedCommands, "verify-riscv64-builtin")
    add(migratedCommands, "r2c-react")
    add(migratedCommands, "build-linux-nolibc-exe")
    add(migratedCommands, "build-zero-exit")
    add(migratedCommands, "build-panic-trace")
    add(migratedCommands, "build-bounds-trace")
    add(migratedCommands, "build-signal-trace")
    add(migratedCommands, "build-call-chain")
    add(migratedCommands, "build-ffi-handle")
    add(migratedCommands, "build-program-selfhost")
    add(migratedCommands, "build-bft-state-machine")
    add(migratedCommands, "deploy-bft-validator-three-node")
    add(migratedCommands, "verify-bft-validator-three-node")
    add(migratedCommands, "status-bft-validator-three-node")
    add(migratedCommands, "stop-bft-validator-three-node")
    add(migratedCommands, "bench-bft-validator-three-node")
    add(migratedCommands, "build-oracle-bft-state-machine")
    add(migratedCommands, "deploy-oracle-bft-three-node")
    add(migratedCommands, "verify-oracle-bft-three-node")
    add(migratedCommands, "status-oracle-bft-three-node")
    add(migratedCommands, "stop-oracle-bft-three-node")
    add(migratedCommands, "build-browser-host-wasm")
    add(migratedCommands, "build-chain-node")
    add(migratedCommands, "build-rwad-bft-state-machine")
    add(migratedCommands, "build-chain-node-linux")
    add(migratedCommands, "build-rwad-bft-linux")
    add(migratedCommands, "run-host-smokes")
    add(migratedCommands, "run-stage23-libp2p-smokes")
    add(migratedCommands, "run-production-regression")
    add(migratedCommands, "run-linux-object-smokes")
    add(migratedCommands, "run-udp-importc-smoke")
    add(migratedCommands, "run-tcp-twoproc-smoke")
    add(migratedCommands, "run-quic-twoproc-smoke")
    add(migratedCommands, "run-wasm-smokes")
    add(migratedCommands, "run-browser-host-wasm-smoke")
    add(migratedCommands, "run-chain-node-cli-smoke")
    add(migratedCommands, "run-chain-node-process-smoke")
    add(migratedCommands, "run-chain-node-three-node-smoke")
    add(migratedCommands, "run-chain-node-resilience-smoke")
    add(migratedCommands, "run-oracle-resilience-smoke")
    add(migratedCommands, "run-tailnet-control-smoke")
    add(migratedCommands, "run-fresh-node-selfhost-gate")
    add(migratedCommands, "run-migration-gate")
    add(migratedCommands, "run-browser-webrtc-smokes")
    for i in 0..<migratedCommands.len:
        let command = migratedCommands[i]
        let logPath = chengpath.PathJoin(outDir, command + ".handoff-disabled.log")
        if chengpath.PathFileExists(logPath):
            os.RemoveFile(logPath)
        let boundaryRun = hostops.RunFileLogged(root,
                                                "seed_minimization_boundary_no_handoff_" + command,
                                                stage3,
                                                [command],
                                                ["CHENG_NO_BACKEND_DRIVER_HANDOFF=1"],
                                                root,
                                                30,
                                                logPath)
        assert(boundaryRun.exitCode == 2,
               "seed minimization boundary: no handoff unknown rc " + command)
        assert(strings.StrContains(boundaryRun.output, "[cheng_seed] unknown command: " + command),
               "seed minimization boundary: no handoff unknown output " + command)

    let cacheSource = chengpath.PathAbsolute(root, "src/tests/ordinary_zero_exit_fixture.cheng")
    let cacheOut = chengpath.PathJoin(outDir, "backend_driver_cache_restore_zero")
    let cacheMap = cacheOut + ".map"
    let cachePrimeReport = chengpath.PathJoin(outDir, "backend_driver_cache_restore.prime.report.txt")
    let cachePrimeLog = chengpath.PathJoin(outDir, "backend_driver_cache_restore.prime.log")
    let cacheRestoreReport = chengpath.PathJoin(outDir, "backend_driver_cache_restore.report.txt")
    let cacheRestoreLog = chengpath.PathJoin(outDir, "backend_driver_cache_restore.log")
    if chengpath.PathFileExists(cacheOut):
        os.RemoveFile(cacheOut)
    if chengpath.PathFileExists(cacheMap):
        os.RemoveFile(cacheMap)
    if chengpath.PathFileExists(cachePrimeReport):
        os.RemoveFile(cachePrimeReport)
    if chengpath.PathFileExists(cacheRestoreReport):
        os.RemoveFile(cacheRestoreReport)
    var cacheArgs: str[]
    add(cacheArgs, "system-link-exec")
    add(cacheArgs, "--root:" + root)
    add(cacheArgs, "--in:" + cacheSource)
    add(cacheArgs, "--emit:exe")
    add(cacheArgs, "--target:arm64-apple-darwin")
    add(cacheArgs, "--out:" + cacheOut)
    var cachePrimeArgs = cacheArgs
    add(cachePrimeArgs, "--report-out:" + cachePrimeReport)
    let cachePrimeRun = hostops.RunFileLogged(root,
                                               "seed_minimization_boundary_cache_prime",
                                               driver,
                                               cachePrimeArgs,
                                               [
                                                   "CHENG_ENABLE_SYSTEM_LINK_EXEC_CACHE=1",
                                                   "CHENG_PROGRESS=1",
                                                   "CHENG_PROCESS_MAX_RSS_BYTES=8589934592"
                                               ],
                                               root,
                                               0,
                                               cachePrimeLog)
    assert(cachePrimeRun.exitCode == 0,
           "seed minimization boundary: cache prime rc")
    assert(chengpath.FileExistsNonEmpty(root, cacheOut),
           "seed minimization boundary: cache prime exe")
    assert(chengpath.FileExistsNonEmpty(root, cacheMap),
           "seed minimization boundary: cache prime map")
    os.RemoveFile(cacheOut)
    os.RemoveFile(cacheMap)
    var cacheRestoreArgs = cacheArgs
    add(cacheRestoreArgs, "--report-out:" + cacheRestoreReport)
    let cacheRestoreRun = hostops.RunFileLogged(root,
                                                 "seed_minimization_boundary_cache_restore",
                                                 driver,
                                                 cacheRestoreArgs,
                                                 [
                                                     "CHENG_ENABLE_SYSTEM_LINK_EXEC_CACHE=1",
                                                     "CHENG_BACKEND_DRIVER_REQUIRE_SYSTEM_LINK_EXEC_CACHE_HIT=1",
                                                     "CHENG_PROCESS_MAX_RSS_BYTES=8589934592"
                                                 ],
                                                 root,
                                                 0,
                                                 cacheRestoreLog)
    assert(cacheRestoreRun.exitCode == 0,
           "seed minimization boundary: cache restore rc")
    assert(chengpath.FileExistsNonEmpty(root, cacheOut),
           "seed minimization boundary: cache restore exe")
    assert(chengpath.FileExistsNonEmpty(root, cacheMap),
           "seed minimization boundary: cache restore map")
    let cacheRestoreReportText = chengpath.ReadTextFile("", cacheRestoreReport)
    assert(strings.StrContains(cacheRestoreReportText, "backend_driver_system_link_exec_cache_restore=1"),
           "seed minimization boundary: cache restore pure driver marker")
    assert(strings.StrContains(cacheRestoreReportText, "exec_pipeline_stage=system_link_exec_cache_hit"),
           "seed minimization boundary: cache restore pipeline")
    let cacheRunLog = chengpath.PathJoin(outDir, "backend_driver_cache_restore.run.log")
    let cacheRun = hostops.RunFileLogged(root,
                                          "seed_minimization_boundary_cache_run",
                                          cacheOut,
                                          [],
                                          [],
                                          root,
                                          30,
                                          cacheRunLog)
    assert(cacheRun.exitCode == 0,
           "seed minimization boundary: cache restored exe rc")

    echo("cheng seed_minimization_boundary_smoke ok")
    return 0
