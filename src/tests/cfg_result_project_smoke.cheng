# cfg_result_project_smoke.cheng
# Tests Result[T] projection in the general CFG pipeline.
# Uses IsErr / Value / Error projections on a Result[int32].
# When compiled via typed_expr -> lowering_plan -> primary_object_plan,
# the BodyIR should contain BodyOpResultProject ops for the projections.
#
# Expected exit code: 42
#   GetResult() returns Ok[int32](42)
#   IsErr(res) is false, so we take Value(res) = 42

import std/result

fn GetResult(): Result[int32] =
    return Ok[int32](42)

fn ProjectResult(res: Result[int32]): int32 =
    if IsErr(res):
        return -1
    return Value(res)

fn main(): int32 =
    let res = GetResult()
    let val = ProjectResult(res)
    if val != 42:
        return 1
    echo(" cfg_result_project_smoke ok")
    return 0
