import std/os
import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/chain/consensus
import cheng/apps/chain_node/chain_node as node

fn mark(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn probeSnapshotParam(remote: node.V3ChainNodeServeSnapshot) =
    mark("stage:param-lens")
    assert(remote.eventCids.len == 2, "stage probe: param event cid len")
    assert(remote.events.len == 2, "stage probe: param event len")
    assert(remote.signature.eventCount == 2, "stage probe: param signature event count")
    assert(remote.signature.accountCount == 2, "stage probe: param signature account count")

    mark("stage:param-replay")
    mark("stage:param-zero")
    var replayed: node.V3ChainNode
    node.v3ChainNodeZeroInto(replayed, "node-b", remote.address)
    mark("stage:param-zero-ok")
    for i in 0..<remote.events.len:
        mark("stage:param-fetch")
        var event = remote.events[i]
        mark("stage:param-fetch-ok")
        event.stem = event.ganzhiIndex % 10
        event.branch = event.ganzhiIndex % 12
        mark("stage:param-body")
        event.bodyCid = consensus.v3ChainEventBodyCid(event)
        mark("stage:param-body-ok")
        mark("stage:param-apply")
        let applyRes = node.v3ChainNodeApplyEvent(replayed, event)
        mark("stage:param-apply-ok")
        assert(applyRes.ok, "stage probe: param replay apply")
        mark("stage:param-cid")
        assert(layout.fixedBytes32Equal(applyRes.value, remote.eventCids[i]), "stage probe: param replay cid")
        mark("stage:param-cid-ok")
    node.v3ChainNodeRebuildDerived(replayed)

    mark("stage:param-forest")
    assert(layout.fixedBytes32Equal(replayed.forest.forestCid, replayed.signature.stateForestCid), "stage probe: replay signature forest")
    assert(layout.fixedBytes32Equal(remote.signature.stateForestCid, remote.forest.forestCid), "stage probe: remote signature forest")
    assert(layout.fixedBytes32Equal(replayed.signature.stateForestCid, remote.signature.stateForestCid), "stage probe: signature forest equal")
    assert(layout.fixedBytes32Equal(replayed.forest.forestCid, remote.forest.forestCid), "stage probe: param forest")

    mark("stage:param-forest-helper")
    assert(layout.fixedBytes32Equal(node.v3ChainNodeForestCid(replayed), remote.forest.forestCid), "stage probe: param forest helper")

    mark("stage:param-signature")
    assert(anti.v3AntiEntropySignatureEqual(replayed.signature, remote.signature), "stage probe: param signature")

fn main(): int32 =
    mark("stage:init")
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node: init")
    var client: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(client, "node-b", "chain-node-b")),
           "v3 chain_node: init")

    mark("stage:events")
    let mintCidRes = node.v3ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, "stage probe: mint")
    let transferCidRes = node.v3ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, "stage probe: transfer")

    mark("stage:serve")
    var served: node.V3ChainNodeServeSnapshot
    node.v3ChainNodeServeOnceInto(served, server)
    assert(served.events.len == 2, "stage probe: served len")
    let serverForestCid = node.v3ChainNodeForestCid(server)
    assert(layout.fixedBytes32Equal(serverForestCid, served.signature.stateForestCid), "stage probe: served forest vs server")

    mark("stage:direct-replay")
    var direct: node.V3ChainNode
    node.v3ChainNodeZeroInto(direct, "node-c", server.address)
    for i in 0..<server.events.len:
        var directEvent = server.events[i]
        directEvent.stem = directEvent.ganzhiIndex % 10
        directEvent.branch = directEvent.ganzhiIndex % 12
        directEvent.bodyCid = consensus.v3ChainEventBodyCid(directEvent)
        let directApply = node.v3ChainNodeApplyEvent(direct, directEvent)
        assert(directApply.ok, "stage probe: direct replay apply")
        assert(layout.fixedBytes32Equal(directApply.value, server.eventCids[i]), "stage probe: direct replay cid")
    node.v3ChainNodeRebuildDerived(direct)
    assert(layout.fixedBytes32Equal(node.v3ChainNodeForestCid(direct), serverForestCid), "stage probe: direct replay forest")

    probeSnapshotParam(served)

    mark("stage:rebuild-zero")
    var replayed: node.V3ChainNode
    node.v3ChainNodeZeroInto(replayed, "node-b", client.address)

    mark("stage:rebuild-apply-0")
    var event0 = served.events[0]
    event0.stem = event0.ganzhiIndex % 10
    event0.branch = event0.ganzhiIndex % 12
    event0.bodyCid = consensus.v3ChainEventBodyCid(event0)
    let apply0 = node.v3ChainNodeApplyEvent(replayed, event0)
    assert(apply0.ok, "stage probe: apply0")

    mark("stage:rebuild-apply-1")
    var event1 = served.events[1]
    event1.stem = event1.ganzhiIndex % 10
    event1.branch = event1.ganzhiIndex % 12
    event1.bodyCid = consensus.v3ChainEventBodyCid(event1)
    let apply1 = node.v3ChainNodeApplyEvent(replayed, event1)
    assert(apply1.ok, "stage probe: apply1")

    mark("stage:rebuild-derived")
    node.v3ChainNodeRebuildDerived(replayed)

    mark("stage:sync")
    let syncRes = node.v3ChainNodeSyncOnce(client, served)
    assert(syncRes.ok, "stage probe: sync ok")

    mark("stage:done")
    return 0
