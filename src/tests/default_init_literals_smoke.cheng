var gFixed: int32[3] = [1, 2, 3]
var gIf: int32[3] = if true: [4, 5, 6] else: [7, 8, 9]
var gTernary: int32[3] = true ? [10, 11, 12] : [13, 14, 15]

type
    Wrap =
        xs: int32[3]

fn sumFixed(xs: int32[3]): int32 =
    return xs[0] + xs[1] + xs[2]

fn makeFixed(): int32[3] =
    return [7, 8, 9]

fn makeFixedIf(flag: bool): int32[3] =
    return if flag: [1, 2, 3] else: [4, 5, 6]

fn makeFixedTernary(flag: bool): int32[3] =
    return flag ? [7, 8, 9] : [10, 11, 12]

fn makeWrapIf(flag: bool): Wrap =
    return Wrap(xs: if flag: [1, 2, 3] else: [4, 5, 6])

fn makeWrapTernary(flag: bool): Wrap =
    return Wrap(xs: flag ? [7, 8, 9] : [10, 11, 12])

fn main(): int32 =
    assert(gFixed[0] == 1, "v3 default init literals: global fixed 0")
    assert(gFixed[1] == 2, "v3 default init literals: global fixed 1")
    assert(gFixed[2] == 3, "v3 default init literals: global fixed 2")
    assert(gIf[0] == 4, "v3 default init literals: global if 0")
    assert(gIf[1] == 5, "v3 default init literals: global if 1")
    assert(gIf[2] == 6, "v3 default init literals: global if 2")
    assert(gTernary[0] == 10, "v3 default init literals: global ternary 0")
    assert(gTernary[1] == 11, "v3 default init literals: global ternary 1")
    assert(gTernary[2] == 12, "v3 default init literals: global ternary 2")

    var xs: int32[]
    assert(xs.len == 0, "v3 default init literals: seq len")

    var ys: int32[3]
    assert(ys[0] == 0, "v3 default init literals: fixed zero 0")
    assert(ys[1] == 0, "v3 default init literals: fixed zero 1")
    assert(ys[2] == 0, "v3 default init literals: fixed zero 2")

    var zs = [1, 2, 3]
    assert(zs.len == 3, "v3 default init literals: inferred len")
    assert(zs[0] == 1, "v3 default init literals: inferred 0")
    assert(zs[1] == 2, "v3 default init literals: inferred 1")
    assert(zs[2] == 3, "v3 default init literals: inferred 2")

    var ws: int32[3] = [4, 5, 6]
    assert(ws[0] == 4, "v3 default init literals: fixed lit 0")
    assert(ws[1] == 5, "v3 default init literals: fixed lit 1")
    assert(ws[2] == 6, "v3 default init literals: fixed lit 2")

    var ifs: int32[3] = if true: [1, 2, 3] else: [4, 5, 6]
    assert(ifs[0] == 1, "v3 default init literals: fixed if bind 0")
    assert(ifs[1] == 2, "v3 default init literals: fixed if bind 1")
    assert(ifs[2] == 3, "v3 default init literals: fixed if bind 2")

    var ters: int32[3] = true ? [7, 8, 9] : [10, 11, 12]
    assert(ters[0] == 7, "v3 default init literals: fixed ternary bind 0")
    assert(ters[1] == 8, "v3 default init literals: fixed ternary bind 1")
    assert(ters[2] == 9, "v3 default init literals: fixed ternary bind 2")

    var fixedArgLiteral: int32 = sumFixed([1, 2, 3])
    assert(fixedArgLiteral == 6, "v3 default init literals: fixed arg literal")

    var fixedIfArg: int32 = sumFixed(if true: [1, 2, 3] else: [4, 5, 6])
    assert(fixedIfArg == 6, "v3 default init literals: fixed if arg")

    var fixedTernaryArg: int32 = sumFixed(true ? [7, 8, 9] : [10, 11, 12])
    assert(fixedTernaryArg == 24, "v3 default init literals: fixed ternary arg")

    var rs: int32[3] = makeFixed()
    assert(rs[0] == 7, "v3 default init literals: fixed return 0")
    assert(rs[1] == 8, "v3 default init literals: fixed return 1")
    assert(rs[2] == 9, "v3 default init literals: fixed return 2")

    var ris: int32[3] = makeFixedIf(false)
    assert(ris[0] == 4, "v3 default init literals: fixed if return 0")
    assert(ris[1] == 5, "v3 default init literals: fixed if return 1")
    assert(ris[2] == 6, "v3 default init literals: fixed if return 2")

    var rts: int32[3] = makeFixedTernary(true)
    assert(rts[0] == 7, "v3 default init literals: fixed ternary return 0")
    assert(rts[1] == 8, "v3 default init literals: fixed ternary return 1")
    assert(rts[2] == 9, "v3 default init literals: fixed ternary return 2")

    var wif: Wrap = makeWrapIf(false)
    assert(wif.xs[0] == 4, "v3 default init literals: wrap if return 0")
    assert(wif.xs[1] == 5, "v3 default init literals: wrap if return 1")
    assert(wif.xs[2] == 6, "v3 default init literals: wrap if return 2")

    var wter: Wrap = makeWrapTernary(true)
    assert(wter.xs[0] == 7, "v3 default init literals: wrap ternary return 0")
    assert(wter.xs[1] == 8, "v3 default init literals: wrap ternary return 1")
    assert(wter.xs[2] == 9, "v3 default init literals: wrap ternary return 2")
    return 0
