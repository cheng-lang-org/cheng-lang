import cheng/core/backend/system_link_plan as slplan
import cheng/core/tooling/compiler_request as creq
import cheng/core/lang/parser as parser

fn main(): int32 =
    var plan: slplan.SystemLinkPlanStub
    var err: str
    var roots: parser.ParserExternalPackageRoot[]
    let ok = slplan.BuildSystemLinkPlanStubWithFieldsAndExternalPackageRoots("/Users/lbcheng/cheng-lang",
                                                                             "/Users/lbcheng/cheng-lang",
                                                                             "src/tests/ordinary_zero_exit_fixture.cheng",
                                                                             "/tmp/cheng-system-link-plan-fieldload-probe-out",
                                                                             "arm64-apple-darwin",
                                                                             creq.EmitExe,
                                                                             "public",
                                                                             "",
                                                                             roots,
                                                                             plan,
                                                                             err)
    if !ok:
        return 2
    let paths = slplan.SystemLinkPlanSourceClosurePaths(plan)
    if paths.len <= 0:
        return 3
    return 0
