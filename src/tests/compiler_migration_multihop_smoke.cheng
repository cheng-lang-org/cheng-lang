import std/result
import cheng/std/bytes_layout as layout
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/tooling/compiler_equivalence as ceq

fn main(): int32 =
    let packageId = "pkg://cheng/multi-hop"
    let targetTriple = "arm64-apple-darwin"
    let providers = [
        "runtime/compiler_runtime",
        "runtime/core_runtime",
        "runtime/debug_runtime"
    ]
    let worldHeadCid = cworld.CompilerWorldHashText("world", [packageId, "stable"])
    let graphCidA = cworld.CompilerWorldHashText("graph", [packageId, "a"])
    let graphCidB = cworld.CompilerWorldHashText("graph", [packageId, "b"])
    let graphCidC = cworld.CompilerWorldHashText("graph", [packageId, "c"])
    let canonicalGraphCid = cworld.CompilerWorldHashText("canonical_graph", [packageId])
    let surfaceCid = cworld.CompilerWorldHashText("surface", [packageId])
    let canonicalOutputDigest = ccsg.CompileOutputDigest(packageId,
                                                           targetTriple,
                                                           providers,
                                                           canonicalGraphCid)
    let receiptA = ccsg.CompileReceiptMake(worldHeadCid,
                                             graphCidA,
                                             canonicalGraphCid,
                                             targetTriple,
                                             ccsg.CompileOutputDigest(packageId + ":a",
                                                                        targetTriple,
                                                                        providers,
                                                                        graphCidA),
                                             canonicalOutputDigest,
                                             "stage3_local",
                                             providers)
    let receiptB = ccsg.CompileReceiptMake(worldHeadCid,
                                             graphCidB,
                                             canonicalGraphCid,
                                             targetTriple,
                                             ccsg.CompileOutputDigest(packageId + ":b",
                                                                        targetTriple,
                                                                        providers,
                                                                        graphCidB),
                                             canonicalOutputDigest,
                                             "stage3_local",
                                             providers)
    let receiptC = ccsg.CompileReceiptMake(worldHeadCid,
                                             graphCidC,
                                             canonicalGraphCid,
                                             targetTriple,
                                             ccsg.CompileOutputDigest(packageId + ":c",
                                                                        targetTriple,
                                                                        providers,
                                                                        graphCidC),
                                             canonicalOutputDigest,
                                             "stage3_local",
                                             providers)
    assert(ccsg.CompileReceiptEquivalent(receiptA, receiptB),
           " compiler migration multihop: receipt ab equivalent")
    assert(ccsg.CompileReceiptEquivalent(receiptB, receiptC),
           " compiler migration multihop: receipt bc equivalent")
    assert(ccsg.CompileReceiptEquivalent(receiptA, receiptC),
           " compiler migration multihop: receipt ac equivalent")
    var proofAB: ceq.CompilerEquivalenceProof
    let proofABRes = ceq.CompilerEquivalenceProofMake(packageId,
                                                        "stable",
                                                        canonicalGraphCid,
                                                        canonicalGraphCid,
                                                        surfaceCid,
                                                        surfaceCid,
                                                        receiptA.receiptCid,
                                                        receiptB.receiptCid,
                                                        targetTriple,
                                                        1,
                                                        1,
                                                        1,
                                                        proofAB)
    assert(IsOk(proofABRes), " compiler migration multihop: proof ab")
    assert(ceq.CompilerEquivalencePassed(proofAB),
           " compiler migration multihop: proof ab passed")
    var proofBC: ceq.CompilerEquivalenceProof
    let proofBCRes = ceq.CompilerEquivalenceProofMake(packageId,
                                                        "stable",
                                                        canonicalGraphCid,
                                                        canonicalGraphCid,
                                                        surfaceCid,
                                                        surfaceCid,
                                                        receiptB.receiptCid,
                                                        receiptC.receiptCid,
                                                        targetTriple,
                                                        1,
                                                        1,
                                                        1,
                                                        proofBC)
    assert(IsOk(proofBCRes), " compiler migration multihop: proof bc")
    assert(ceq.CompilerEquivalencePassed(proofBC),
           " compiler migration multihop: proof bc passed")
    assert(layout.fixedBytes32Equal(proofAB.migratedReceiptCid, proofBC.baselineReceiptCid),
           " compiler migration multihop: proof chain link")
    var proofAC: ceq.CompilerEquivalenceProof
    let proofACRes = ceq.CompilerEquivalenceProofMake(packageId,
                                                        "stable",
                                                        canonicalGraphCid,
                                                        canonicalGraphCid,
                                                        surfaceCid,
                                                        surfaceCid,
                                                        receiptA.receiptCid,
                                                        receiptC.receiptCid,
                                                        targetTriple,
                                                        1,
                                                        1,
                                                        1,
                                                        proofAC)
    assert(IsOk(proofACRes), " compiler migration multihop: proof ac")
    assert(ceq.CompilerEquivalencePassed(proofAC),
           " compiler migration multihop: proof ac passed")
    echo(" compiler_migration_multihop_smoke ok")
    return 0
