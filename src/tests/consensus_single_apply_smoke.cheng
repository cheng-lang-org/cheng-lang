import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

fn main(): int32 =
    var index = consensus.ChainIndex()
    let zeroCid = layout.FixedBytes32()
    let mint = consensus.ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let mintCid = consensus.ChainEventCid(mint)
    let applyRes = consensus.ConsensusApply(index, mint, mintCid, 0)
    assert(IsOk(applyRes), " consensus single: mint apply")
    let decision = Value(applyRes)
    assert(decision.accepted, " consensus single: accepted")
    assert(decision.applied, " consensus single: applied")
    assert(index.accountIds.buffer != nil, " consensus single: account buffer")
    assert(index.accountIds.len == 1, " consensus single: account len")
    assert(index.accountIds.cap >= 1, " consensus single: account cap")
    assert(index.accountAssetIds[0] == 7, " consensus single: asset")
    assert(index.accountIds[0] == 1001, " consensus single: account")
    assert(index.balances.len == 1, " consensus single: balance len")
    assert(index.balances[0] == int64(100), " consensus single: balance")
    echo(" consensus_single_apply_smoke ok")
    return 0
