import std/system

@importc("getrandom")
fn c_getrandom(buf: ptr, size: int64, flags: int32): int64

@exportc("getentropy")
fn getentropy(buf: ptr, size: int64): int32 =
    if buf == nil || size < 0:
        return -1
    if size == 0:
        return 0
    let got: int64 = c_getrandom(buf, size, 0)
    if got != size:
        return -1
    return 0
