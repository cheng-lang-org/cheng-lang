import std/os
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as v3path
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathJoin(workspaceRoot, "artifacts/compiler_csg/" + smokeLabel)
    assert(v3path.V3MkdirP(workspaceRoot, outDir), "v3 compiler csg annotation: mkdir")
    let sourcePath = v3path.V3PathJoin(packageRoot, "src/tests/compiler_csg_annotation_fixture.cheng")
    let outputPath = v3path.V3PathJoin(outDir, "compiler_csg_annotation_fixture")
    let req = creq.v3CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitShared,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err),
           "v3 compiler csg annotation: link plan")
    assert(linkPlan.missingReasons.len == 0, "v3 compiler csg annotation: missing reasons")
    let sourceBundleRes = slplan.v3SystemLinkPlanSourceBundleCid(linkPlan)
    assert(IsOk(sourceBundleRes), "v3 compiler csg annotation: source bundle")
    let sourceBundleCid = Value(sourceBundleRes)
    let csgRes = ccsg.v3BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(csgRes), "v3 compiler csg annotation: build")
    let csg = ccsg.v3CompilerCsgClone(Value(csgRes))
    let surface = ccsg.v3CompilerExportSurfaceFromCsg(csg)
    assert(surface.exportedSymbolCount == 2, "v3 compiler csg annotation: export count")
    assert(surface.exportedSymbols[0] == "cheng/tests/compiler_csg_annotation_fixture::AlphaSeven",
           "v3 compiler csg annotation: alpha symbol")
    assert(surface.exportedTargetNames[0] == "alphaSeven",
           "v3 compiler csg annotation: alpha target")
    assert(surface.exportedSymbols[1] == "cheng/tests/compiler_csg_annotation_fixture::BetaTwice",
           "v3 compiler csg annotation: beta symbol")
    assert(surface.exportedTargetNames[1] == "betaTwice",
           "v3 compiler csg annotation: beta target")
    let report = ccsg.v3CompilerExportSurfaceReport(surface)
    assert(v3path.V3TextContains(report, "exported_count=2"),
           "v3 compiler csg annotation: report count")
    echo("v3 compiler_csg_annotation_smoke ok")
    return 0
