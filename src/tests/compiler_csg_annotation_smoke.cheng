import std/os
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, "artifacts/compiler_csg/" + smokeLabel)
    assert(chengpath.MkdirP(workspaceRoot, outDir), " compiler csg annotation: mkdir")
    let sourcePath = chengpath.PathJoin(packageRoot, "src/tests/compiler_csg_annotation_fixture.cheng")
    let outputPath = chengpath.PathJoin(outDir, "compiler_csg_annotation_fixture")
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitShared,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err),
           " compiler csg annotation: link plan")
    assert(linkPlan.missingReasons.len == 0, " compiler csg annotation: missing reasons")
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    assert(IsOk(sourceBundleRes), " compiler csg annotation: source bundle")
    let sourceBundleCid = Value(sourceBundleRes)
    let csgRes = ccsg.BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(csgRes), " compiler csg annotation: build")
    let csg = ccsg.CompilerCsgClone(Value(csgRes))
    let surface = ccsg.CompilerExportSurfaceFromCsg(csg)
    assert(surface.exportedSymbolCount == 2, " compiler csg annotation: export count")
    assert(surface.exportedSymbols[0] == "cheng/tests/compiler_csg_annotation_fixture::AlphaSeven",
           " compiler csg annotation: alpha symbol")
    assert(surface.exportedTargetNames[0] == "alphaSeven",
           " compiler csg annotation: alpha target")
    assert(surface.exportedSymbols[1] == "cheng/tests/compiler_csg_annotation_fixture::BetaTwice",
           " compiler csg annotation: beta symbol")
    assert(surface.exportedTargetNames[1] == "betaTwice",
           " compiler csg annotation: beta target")
    let report = ccsg.CompilerExportSurfaceReport(surface)
    assert(chengpath.TextContains(report, "exported_count=2"),
           " compiler csg annotation: report count")
    echo(" compiler_csg_annotation_smoke ok")
    return 0
