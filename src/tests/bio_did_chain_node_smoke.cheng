import std/system
import std/result
import std/strings
import cheng/std/bytes_layout as layout
import cheng/chain/consensus as consensus
import cheng/libp2p/core/types
import cheng/libp2p/identity/did
import cheng/mobile/hardware/biometric
import cheng/apps/chain_node/chain_node as chain
import cheng/apps/bio/bio_did_chain_node as flow

fn bioDidChainSmokeFeatureInto(out: var layout.FixedBytes32, seed: int32) =
    for i in 0..<32:
        out.data[i] = uint8(((seed * 29) + (i * 17) + 11) & 255)

fn bioDidChainSmokeCorruptInto(out: var layout.FixedBytes32,
                               feature: layout.FixedBytes32,
                               positions: int32[]) =
    out = feature
    for i in 0..<positions.len:
        let pos = positions[i]
        out.data[pos] = uint8((int32(out.data[pos]) ^ ((0x5a + i) & 255)) & 255)

fn bioDidChainSmokeCaptureInto(out: var flow.BioDidHardwareCapture,
                               feature: layout.FixedBytes32,
                               bindingSeed: str,
                               label: str,
                               requestId: str,
                               purpose: int32,
                               verified: bool) =
    out.verified = verified
    out.feature32 = feature
    out.requestId = requestId
    out.sensorId = "sensor|" + bindingSeed
    out.deviceBindingSeed = bindingSeed
    out.deviceLabel = label
    var req = biometric.BiometricFingerprintAuthorizeReq()
    req.requestId = requestId
    req.purpose = purpose
    req.didText = ""
    req.promptTitle = "bio did chain smoke"
    req.promptReason = "bio did chain smoke"
    req.deviceBindingSeedHint = bindingSeed
    req.deviceLabelHint = label
    let sensorId = out.sensorId
    var attestorPrivHex: str = "60d71049a0cafe01faa9948dc77ee5bc4bd5e05b8e328fdb9cc4c38237250a05"
    let attestationRes = biometric.BiometricFingerprintAttestationBuildSigned(req,
                                                                                feature,
                                                                                bindingSeed,
                                                                                label,
                                                                                sensorId,
                                                                                attestorPrivHex)
    assert(IsOk(attestationRes), " bio did chain smoke: signed attestation")
    out.hardwareAttestation = Value(attestationRes)

fn bioDidChainSmokeAppendBrokenOperatorAnchorInto(outCid: var layout.FixedBytes32,
                                                  node: var chain.ChainNode,
                                                  text: str): Result[bool] =
    let payload = bytesFromString(text)
    let chunkCount = flow.BioDidChunkCount(payload.len)
    outCid = layout.FixedBytes32()
    for chunkIndex in 0..<chunkCount:
        let parentCid = chain.ChainNodeAccountHeadFromNode(node,
                                                             flow.BioDidOperatorAnchorAssetId,
                                                             flow.BioDidOperatorAnchorAccountId)
        var event = consensus.ChainEventMint(flow.BioDidOperatorAnchorAssetId,
                                               flow.BioDidOperatorAnchorAccountId,
                                               parentCid,
                                               int64(chunkIndex + 1),
                                               node.nextEpoch,
                                               node.nextGanzhi,
                                               chain.ChainNodeSpaceSlot(flow.BioDidOperatorAnchorAccountId,
                                                                          flow.BioDidOperatorAnchorAccountId),
                                               node.nextTick)
        event.fromAccount = 1
        event.fromParentCid = flow.BioDidChunkFixed(payload, chunkIndex)
        event.bodyCid = consensus.ChainEventBodyCid(event)
        let applyRes = chain.ChainNodeApplyEvent(node, event)
        if IsErr(applyRes):
            return Err[bool](Error(applyRes))
        outCid = Value(applyRes)
    return Ok[bool](true)

fn main(): int32 =
    var rootKeyId: str = "cheng.scripted.root"
    let trustRes = flow.BioDidSetTrustedAttestorRootHex(
        "04963c1356849b8478030a6eb572581063ccedf53fda0bc7241247eba977e3b0666e4bf0c12caa47487c2927f83b17d6f9f332481cd2ab0c4885f91fc2a6c547d5",
                                                          rootKeyId)
    assert(IsOk(trustRes), " bio did chain smoke: add trusted attestor")
    var feature: layout.FixedBytes32
    bioDidChainSmokeFeatureInto(feature, 5)
    var matchFeature: layout.FixedBytes32
    bioDidChainSmokeCorruptInto(matchFeature, feature, [1, 9, 22])
    var badFeature: layout.FixedBytes32
    bioDidChainSmokeCorruptInto(badFeature, feature, [0, 2, 4, 6, 8, 10, 12, 14, 16])
    let operatorIdRes = flow.BioDidOperatorIdFromRecoverySecretHex(
        "00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff"
    )
    assert(IsOk(operatorIdRes), " bio did chain smoke: operator id")
    let operatorId = Value(operatorIdRes)

    var node: chain.ChainNode
    assert(IsOk(chain.ChainNodeInitInto(node, "bio.did.chain", "bio.did.chain.addr")),
           " bio did chain smoke: init node")
    var createCapture: flow.BioDidHardwareCapture
    bioDidChainSmokeCaptureInto(createCapture,
                                feature,
                                "device.phone.secure",
                                "phone",
                                "create-phone-1",
                                biometric.BiometricPurposeDidCreate,
                                true)
    let createRes = flow.BioDidCreateWithHardwareCapture(node, createCapture, int64(1000))
    assert(IsOk(createRes), " bio did chain smoke: create did")
    let created = Value(createRes)
    let createdIdentity = created.identity
    let createdSelfDevice = createdIdentity.selfDevice
    let createdPeerId = createdSelfDevice.devicePeerId
    let createdBundle = created.bundle
    let createdBundleHardware = createdBundle.hardware
    let createdBundleRecord = createdBundle.record
    let createdDocument = created.document
    let createdDidText = did.DidIdentityDid(createdIdentity)
    let didText = createdDocument.did
    let zeroCid = layout.FixedBytes32()
    assert(didText == createdDidText,
           " bio did chain smoke: created did stable")
    assert(createdBundle.bundleSeq == 1,
           " bio did chain smoke: create bundle seq")
    assert(createdDocument.devices.len == 1,
           " bio did chain smoke: create device count")
    let createdAttestationCid = createdBundleHardware.attestationCid
    assert(!layout.FixedBytes32Equal(createdAttestationCid,
                                     zeroCid),
           " bio did chain smoke: create hardware attestation cid")
    let createdBindingCid = createdBundleHardware.bindingCid
    assert(!layout.FixedBytes32Equal(createdBindingCid,
                                     zeroCid),
           " bio did chain smoke: create hardware binding cid")
    let anchorCreateRes = flow.BioDidChainAppendOperatorBundleAnchor(node,
                                                                       operatorId,
                                                                       createdBundle,
                                                                       "anchor-create-1")
    assert(IsOk(anchorCreateRes), " bio did chain smoke: anchor create")

    let latestCreateBundleRes = flow.BioDidChainLoadLatest(node, didText)
    assert(IsOk(latestCreateBundleRes), " bio did chain smoke: load create bundle")
    let latestCreateBundle = Value(latestCreateBundleRes)
    let latestCreateDocumentRes = flow.BioDidChainBundleVerify(latestCreateBundle)
    assert(IsOk(latestCreateDocumentRes), " bio did chain smoke: verify create bundle")
    let latestCreateDocument = Value(latestCreateDocumentRes)
    assert(latestCreateDocument.devices.len == 1,
           " bio did chain smoke: create chain document")

    var phoneCapture: flow.BioDidHardwareCapture
    bioDidChainSmokeCaptureInto(phoneCapture,
                                matchFeature,
                                "device.phone.secure",
                                "phone-renamed",
                                "import-phone-1",
                                biometric.BiometricPurposeDidImport,
                                true)
    let phoneImportRes = flow.BioDidImportWithHardwareCapture(node,
                                                                didText,
                                                                phoneCapture,
                                                                int64(1010))
    assert(IsOk(phoneImportRes), " bio did chain smoke: same device import")
    let phoneImport = Value(phoneImportRes)
    let phoneImportIdentity = phoneImport.identity
    let phoneImportSelfDevice = phoneImportIdentity.selfDevice
    let phoneImportPeerId = phoneImportSelfDevice.devicePeerId
    let phoneImportBundle = phoneImport.bundle
    let phoneImportBundleHardware = phoneImportBundle.hardware
    let phoneImportDocument = phoneImport.document
    assert(phoneImportBundle.bundleSeq == 2,
           " bio did chain smoke: same device bundle seq")
    assert(types.Libp2pPeerIdEqual(createdPeerId,
                                     phoneImportPeerId),
           " bio did chain smoke: same device stable peer id")
    assert(phoneImportDocument.devices.len == 1,
           " bio did chain smoke: same device no duplicate")
    let phoneImportVersion = phoneImportDocument.version
    assert(did.DidWord64Value(phoneImportVersion) == int64(1),
           " bio did chain smoke: same device version stable")
    let phoneImportRequestId = phoneImportBundleHardware.requestId
    let createdRequestId = createdBundleHardware.requestId
    assert(phoneImportRequestId != createdRequestId,
           " bio did chain smoke: same device request refresh")
    let anchorPhoneRes = flow.BioDidChainAppendOperatorBundleAnchor(node,
                                                                      operatorId,
                                                                      phoneImportBundle,
                                                                      "anchor-import-phone-1")
    assert(IsOk(anchorPhoneRes), " bio did chain smoke: anchor phone import")

    var replayCapture: flow.BioDidHardwareCapture
    bioDidChainSmokeCaptureInto(replayCapture,
                                matchFeature,
                                "device.phone.secure",
                                "phone-renamed",
                                "import-phone-1",
                                biometric.BiometricPurposeDidImport,
                                true)
    let replayImportRes = flow.BioDidImportWithHardwareCapture(node,
                                                                 didText,
                                                                 replayCapture,
                                                                 int64(1015))
    assert(IsErr(replayImportRes), " bio did chain smoke: request replay reject")

    var laptopCapture: flow.BioDidHardwareCapture
    bioDidChainSmokeCaptureInto(laptopCapture,
                                matchFeature,
                                "device.laptop.secure",
                                "laptop",
                                "import-laptop-1",
                                biometric.BiometricPurposeDidImport,
                                true)
    let laptopImportRes = flow.BioDidImportWithHardwareCapture(node,
                                                                 didText,
                                                                 laptopCapture,
                                                                 int64(1020))
    assert(IsOk(laptopImportRes), " bio did chain smoke: new device import")
    let laptopImport = Value(laptopImportRes)
    let laptopImportIdentity = laptopImport.identity
    let laptopImportSelfDevice = laptopImportIdentity.selfDevice
    let laptopImportPeerId = laptopImportSelfDevice.devicePeerId
    let laptopImportBundle = laptopImport.bundle
    let laptopImportBundleRecord = laptopImportBundle.record
    let laptopImportBundleHardware = laptopImportBundle.hardware
    let laptopImportDocument = laptopImport.document
    assert(laptopImportBundle.bundleSeq == 3,
           " bio did chain smoke: new device bundle seq")
    assert(!types.Libp2pPeerIdEqual(createdPeerId,
                                      laptopImportPeerId),
           " bio did chain smoke: new device new peer id")
    assert(laptopImportDocument.devices.len == 2,
           " bio did chain smoke: new device count")
    let laptopImportVersion = laptopImportDocument.version
    assert(did.DidWord64Value(laptopImportVersion) == int64(2),
           " bio did chain smoke: new device bumps version")
    let createdRecordCid = createdBundleRecord.recordCid
    let laptopImportRecordCid = laptopImportBundleRecord.recordCid
    assert(layout.FixedBytes32Equal(createdRecordCid,
                                    laptopImportRecordCid),
           " bio did chain smoke: record reused")
    let phoneImportBindingCid = phoneImportBundleHardware.bindingCid
    let laptopImportBindingCid = laptopImportBundleHardware.bindingCid
    assert(!layout.FixedBytes32Equal(phoneImportBindingCid,
                                     laptopImportBindingCid),
           " bio did chain smoke: different bundle different hardware binding")
    let anchorLaptopRes = flow.BioDidChainAppendOperatorBundleAnchor(node,
                                                                       operatorId,
                                                                       laptopImportBundle,
                                                                       "anchor-import-laptop-1")
    assert(IsOk(anchorLaptopRes), " bio did chain smoke: anchor laptop import")

    var laptopAgainCapture: flow.BioDidHardwareCapture
    bioDidChainSmokeCaptureInto(laptopAgainCapture,
                                matchFeature,
                                "device.laptop.secure",
                                "laptop-renamed",
                                "import-laptop-2",
                                biometric.BiometricPurposeDidImport,
                                true)
    let laptopImportAgainRes = flow.BioDidImportWithHardwareCapture(node,
                                                                      didText,
                                                                      laptopAgainCapture,
                                                                      int64(1030))
    assert(IsOk(laptopImportAgainRes), " bio did chain smoke: repeat laptop import")
    let laptopImportAgain = Value(laptopImportAgainRes)
    let laptopImportAgainIdentity = laptopImportAgain.identity
    let laptopImportAgainSelfDevice = laptopImportAgainIdentity.selfDevice
    let laptopImportAgainPeerId = laptopImportAgainSelfDevice.devicePeerId
    let laptopImportAgainBundle = laptopImportAgain.bundle
    let laptopImportAgainDocument = laptopImportAgain.document
    assert(laptopImportAgainBundle.bundleSeq == 4,
           " bio did chain smoke: repeat laptop bundle seq")
    assert(types.Libp2pPeerIdEqual(laptopImportPeerId,
                                     laptopImportAgainPeerId),
           " bio did chain smoke: repeat laptop stable peer id")
    assert(laptopImportAgainDocument.devices.len == 2,
           " bio did chain smoke: repeat laptop no duplicate")
    let laptopImportAgainVersion = laptopImportAgainDocument.version
    assert(did.DidWord64Value(laptopImportAgainVersion) == int64(2),
           " bio did chain smoke: repeat laptop version stable")
    let anchorLaptopAgainRes = flow.BioDidChainAppendOperatorBundleAnchor(node,
                                                                            operatorId,
                                                                            laptopImportAgainBundle,
                                                                            "anchor-import-laptop-2")
    assert(IsOk(anchorLaptopAgainRes), " bio did chain smoke: anchor repeat laptop import")

    let latestBundleRes = flow.BioDidChainLoadLatest(node, didText)
    assert(IsOk(latestBundleRes), " bio did chain smoke: load latest bundle")
    let latestBundle = Value(latestBundleRes)
    assert(latestBundle.bundleSeq == 4,
           " bio did chain smoke: latest seq")
    assert(flow.BioDidChainCurrentBundleSeq(node, didText) == 4,
           " bio did chain smoke: chain seq tracker")
    let latestDocumentRes = flow.BioDidChainBundleVerify(latestBundle)
    assert(IsOk(latestDocumentRes), " bio did chain smoke: verify latest bundle")
    let latestDocument = Value(latestDocumentRes)
    assert(latestDocument.devices.len == 2,
           " bio did chain smoke: latest device count")
    let latestDocumentPhonePos = did.DidDocumentFindDevicePos(latestDocument,
                                                                createdPeerId)
    let latestDocumentLaptopPos = did.DidDocumentFindDevicePos(latestDocument,
                                                                 laptopImportPeerId)
    assert(latestDocumentPhonePos >= 0,
           " bio did chain smoke: phone present")
    assert(latestDocumentLaptopPos >= 0,
           " bio did chain smoke: laptop present")
    var operatorIndex: flow.BioDidOperatorIndex
    let operatorIndexRes = flow.BioDidOperatorIndexRebuildInto(operatorIndex, node)
    assert(IsOk(operatorIndexRes), " bio did chain smoke: rebuild operator index")
    let operatorIdHex = layout.FixedBytes32Hex(operatorId)
    let operatorLookupRes = flow.BioDidOperatorIndexLookup(operatorIndex,
                                                             operatorIdHex)
    assert(IsOk(operatorLookupRes), " bio did chain smoke: operator lookup")
    let operatorLookup = Value(operatorLookupRes)
    assert(operatorLookup.didText == didText,
           " bio did chain smoke: operator did")
    assert(operatorLookup.subjectDidText == didText,
           " bio did chain smoke: operator subject did")
    assert(operatorLookup.deviceDidText == didText,
           " bio did chain smoke: operator device did")
    assert(operatorLookup.bundleKind == flow.BioDidOperatorBundleKindAndroidBioV1,
           " bio did chain smoke: operator bundle kind")
    assert(operatorLookup.bundleSeq == 4,
           " bio did chain smoke: operator latest seq")
    assert(operatorLookup.eventId == "anchor-import-laptop-2",
           " bio did chain smoke: operator latest event id")
    let laptopImportAgainBundleText = flow.BioDidChainBundleText(laptopImportAgainBundle)
    assert(operatorLookup.bundleText == laptopImportAgainBundleText,
           " bio did chain smoke: operator latest bundle text")
    var state: flow.BioDidChainState
    let stateRes = flow.BioDidChainStateFromNodeInto(state, node)
    assert(IsOk(stateRes), " bio did chain smoke: state from node")
    var preferredKinds: str[]
    let androidBundleKind = flow.BioDidOperatorBundleKindAndroidBioV1
    preferredKinds = [androidBundleKind]
    let stateOperatorKindIndex = state.operatorKindIndex
    let operatorJson = flow.BioDidOperatorLookupJson(operatorIndex,
                                                       stateOperatorKindIndex,
                                                       operatorIdHex,
                                                       preferredKinds)
    assert(strings.StrContains(operatorJson, "\"found\":true"),
           " bio did chain smoke: operator json hit")
    let operatorKindLookupRes = flow.BioDidOperatorKindIndexLookup(stateOperatorKindIndex,
                                                     operatorId,
                                                     androidBundleKind)
    assert(IsOk(operatorKindLookupRes), " bio did chain smoke: operator kind lookup")
    let operatorStateJson = flow.BioDidOperatorLookupJsonFromState(state,
                                                                     operatorIdHex)
    assert(strings.StrContains(operatorStateJson, "\"found\":true"),
           " bio did chain smoke: operator state json hit")
    var emptyKinds: str[]
    emptyKinds.len = 0
    let missJson = flow.BioDidOperatorLookupJson(operatorIndex,
                                                   stateOperatorKindIndex,
                                                   "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff",
                                                   emptyKinds)
    assert(strings.StrContains(missJson, "\"found\":false"),
           " bio did chain smoke: operator json miss")
    let missStateJson = flow.BioDidOperatorLookupJsonFromState(
        state,
        "ffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff"
    )
    assert(strings.StrContains(missStateJson, "\"found\":false"),
           " bio did chain smoke: operator state json miss")
    var snapshot: chain.ChainNodeServeSnapshot
    flow.BioDidChainStateServeOnceInto(snapshot, state)
    let replayNodeId = "bio.did.chain.replay"
    let replayNodeAddr = "bio.did.chain.addr.replay"
    var replayState: flow.BioDidChainState
    let replayStateRes = flow.BioDidChainStateReplayFromSnapshotInto(replayState,
                                                                       replayNodeId,
                                                                       replayNodeAddr,
                                                                       snapshot)
    assert(IsOk(replayStateRes), " bio did chain smoke: replay snapshot")
    let replayOperatorIndex = replayState.operatorIndex
    let replayLookupRes = flow.BioDidOperatorIndexLookup(replayOperatorIndex,
                                                           operatorIdHex)
    assert(IsOk(replayLookupRes), " bio did chain smoke: replay operator lookup")
    let replayLookup = Value(replayLookupRes)
    assert(replayLookup.bundleSeq == 4,
           " bio did chain smoke: replay operator latest seq")
    var brokenNode: chain.ChainNode
    assert(IsOk(chain.ChainNodeInitInto(brokenNode,
                                          "bio.did.chain.broken",
                                          "bio.did.chain.addr.broken")),
           " bio did chain smoke: init broken node")
    var brokenCid: layout.FixedBytes32
    let brokenAppendRes = bioDidChainSmokeAppendBrokenOperatorAnchorInto(
        brokenCid,
        brokenNode,
        "cheng_bio_did_operator_anchor_version=1\noperator_id=not_hex\n"
    )
    assert(IsOk(brokenAppendRes), " bio did chain smoke: append broken operator payload")
    var brokenState: flow.BioDidChainState
    let brokenStateRes = flow.BioDidChainStateFromNodeInto(brokenState, brokenNode)
    assert(IsErr(brokenStateRes), " bio did chain smoke: broken state rebuild reject")
    let brokenErrorText = Error(brokenStateRes)
    let brokenJson = flow.BioDidOperatorLookupErrorJson(operatorIdHex,
                                                          brokenErrorText)
    assert(strings.StrContains(brokenJson, "\"ok\":false"),
           " bio did chain smoke: operator json broken payload")

    let ensureOperatorIdRes = flow.BioDidOperatorIdFromRecoverySecretHex(
        "ffeeddccbbaa99887766554433221100ffeeddccbbaa99887766554433221100"
    )
    assert(IsOk(ensureOperatorIdRes), " bio did chain smoke: ensure operator id")
    let ensureOperatorId = Value(ensureOperatorIdRes)
    var ensureState: flow.BioDidChainState
    assert(IsOk(flow.BioDidChainStateInitInto(ensureState,
                                                "bio.did.chain.ensure",
                                                "bio.did.chain.ensure.addr")),
           " bio did chain smoke: init ensure state")
    var ensureCreateCapture: flow.BioDidHardwareCapture
    bioDidChainSmokeCaptureInto(ensureCreateCapture,
                                feature,
                                "device.ensure.phone",
                                "ensure-phone",
                                "ensure-create-1",
                                biometric.BiometricPurposeDidCreate,
                                true)
    let ensureCreateRes = flow.BioDidEnsureWithHardwareCapture(ensureState,
                                                                 ensureOperatorId,
                                                                 ensureCreateCapture,
                                                                 int64(1060))
    assert(IsOk(ensureCreateRes), " bio did chain smoke: ensure create")
    let ensureCreate = Value(ensureCreateRes)
    let ensureCreateBundle = ensureCreate.bundle
    assert(ensureCreateBundle.action == "create",
           " bio did chain smoke: ensure create action")
    var ensureImportCapture: flow.BioDidHardwareCapture
    bioDidChainSmokeCaptureInto(ensureImportCapture,
                                matchFeature,
                                "device.ensure.tablet",
                                "ensure-tablet",
                                "ensure-import-1",
                                biometric.BiometricPurposeDidImport,
                                true)
    let ensureImportRes = flow.BioDidEnsureWithHardwareCapture(ensureState,
                                                                 ensureOperatorId,
                                                                 ensureImportCapture,
                                                                 int64(1070))
    assert(IsOk(ensureImportRes), " bio did chain smoke: ensure import")
    let ensureImport = Value(ensureImportRes)
    let ensureImportBundle = ensureImport.bundle
    assert(ensureImportBundle.action == "import",
           " bio did chain smoke: ensure import action")
    let ensureOperatorIdHex = layout.FixedBytes32Hex(ensureOperatorId)
    let ensureOperatorIndex = ensureState.operatorIndex
    let ensureLookupRes = flow.BioDidOperatorIndexLookup(ensureOperatorIndex,
                                                           ensureOperatorIdHex)
    assert(IsOk(ensureLookupRes), " bio did chain smoke: ensure lookup")
    let ensureLookup = Value(ensureLookupRes)
    assert(ensureLookup.bundleSeq == 2,
           " bio did chain smoke: ensure latest seq")

    var badImportCapture: flow.BioDidHardwareCapture
    bioDidChainSmokeCaptureInto(badImportCapture,
                                badFeature,
                                "device.tablet.secure",
                                "tablet",
                                "import-tablet-bad",
                                biometric.BiometricPurposeDidImport,
                                true)
    let badImportRes = flow.BioDidImportWithHardwareCapture(node,
                                                              didText,
                                                              badImportCapture,
                                                              int64(1040))
    assert(IsErr(badImportRes), " bio did chain smoke: bad fingerprint reject")

    var unverifiedNodeVar: chain.ChainNode
    assert(IsOk(chain.ChainNodeInitInto(unverifiedNodeVar,
                                          "bio.did.chain.unverified",
                                          "bio.did.chain.addr.2")),
           " bio did chain smoke: init unverified node")
    var unverifiedCapture: flow.BioDidHardwareCapture
    bioDidChainSmokeCaptureInto(unverifiedCapture,
                                feature,
                                "device.phone.secure",
                                "phone",
                                "create-phone-unverified",
                                biometric.BiometricPurposeDidCreate,
                                false)
    let unverifiedCreateRes = flow.BioDidCreateWithHardwareCapture(unverifiedNodeVar,
                                                                     unverifiedCapture,
                                                                     int64(1050))
    assert(IsErr(unverifiedCreateRes), " bio did chain smoke: unverified reject")

    echo(" bio_did_chain_node_smoke ok")
    return 0
