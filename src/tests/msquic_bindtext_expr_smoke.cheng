import std/system
import cheng/quic/platform/common
import std/strutils as strutil

fn main(): int32 =
    let portText = common.msquicPlatformIntToString(6210)
    assert(portText == "6210", "msquic bindtext expr: port text")
    let rightStep = strutil.Join([portText, "/quic-v1"], "")
    assert(rightStep == "6210/quic-v1", "msquic bindtext expr: right step")
    let step1 = strutil.Join(["/ip4/127.0.0.1/udp/", portText], "")
    assert(step1 == "/ip4/127.0.0.1/udp/6210", "msquic bindtext expr: step1")
    let step2 = strutil.Join([step1, "/quic-v1"], "")
    assert(step2 == "/ip4/127.0.0.1/udp/6210/quic-v1", "msquic bindtext expr: step2")
    let viaRight = strutil.Join(["/ip4/127.0.0.1/udp/", rightStep], "")
    assert(viaRight == "/ip4/127.0.0.1/udp/6210/quic-v1", "msquic bindtext expr: via right")
    let bindText = strutil.Join(["/ip4/127.0.0.1/udp/", portText, "/quic-v1"], "")
    assert(bindText == "/ip4/127.0.0.1/udp/6210/quic-v1", "msquic bindtext expr: bind text")
    echo(" msquic_bindtext_expr_smoke ok")
    return 0
