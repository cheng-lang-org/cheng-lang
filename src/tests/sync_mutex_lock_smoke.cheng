import std/system
import std/sync as sync

fn main() =
    let m: sync.Mutex[int32] = sync.mutexNew(7)
    let locked: ptr = sync.mutexLock(m)
    assert(locked != nil, "sync mutexLock returns locked value")
    sync.mutexUnlock(m)

    let w: sync.RwLock[int32] = sync.rwLockNew(9)
    let writeLocked: ptr = sync.rwLockWrite(w)
    assert(writeLocked != nil, "sync rwLockWrite returns locked value")
    sync.rwLockWriteUnlock(w)
