import libc

// Test 1: str index with var int32 parameter
fn testStrIndex(s: str, idx: var int32): int32 =
    return s[idx]

// Test 2: str[] index with var int32 parameter
fn testStrSeqIndex(ss: str[], idx: var int32): str =
    return ss[idx]

// Test 3: seq_i32 index with var int32 parameter
fn testSeqI32Index(nums: int32[], idx: var int32): int32 =
    return nums[idx]

fn main(): int32 =
    let s: str = "Cheng"
    var i: int32 = 3
    let c: int32 = testStrIndex(s, i)
    assert(c == 110, "str index with var int32")  // 'n'

    // Test str[] index
    let strs: str[] = ["a", "bc", "def"]
    var j: int32 = 1
    let ss: str = testStrSeqIndex(strs, j)
    assert(ss == "bc", "str[] index with var int32")

    // Test seq_i32 index
    let nums: int32[] = [10, 20, 30, 40]
    var k: int32 = 2
    let n: int32 = testSeqI32Index(nums, k)
    assert(n == 30, "seq_i32 index with var int32")

    return 0
