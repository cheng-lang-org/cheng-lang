import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_cli_core as cli

fn main(): int32 =
    var state: node.V3ChainNode
    assert(IsOk(node.V3ChainNodeInitInto(state, "snapshot-print-node", "snapshot-print-seed")),
           "v3 chain_node snapshot print boundary: init")
    var snapshot: node.V3ChainNodeServeSnapshot
    node.V3ChainNodeServeOnceInto(snapshot, state)
    cli.V3ChainNodeCliPrintSnapshotReport(snapshot)
    echo("v3 chain_node_snapshot_print_return_boundary_smoke ok")
    return 0
