import cheng/core/runtime/program_support as prosup

fn main(): int32 =
    let h0: uint64 = prosup.FfiHandleNewI32(40)
    if h0 == 0:
        return 1
    if prosup.FfiHandleGetI32(h0) != 40:
        return 2
    if prosup.FfiHandleAddI32(h0, 2) != 42:
        return 3
    if prosup.FfiHandleGetI32(h0) != 42:
        return 4
    if prosup.FfiHandleReleaseI32(h0) != 0:
        return 5
    let h1: uint64 = prosup.FfiHandleNewI32(7)
    if h1 == 0:
        return 6
    if h1 == h0:
        return 7
    if prosup.FfiHandleGetI32(h1) != 7:
        return 8
    if prosup.FfiHandleReleaseI32(h1) != 0:
        return 9
    echo(" ffi_handle_smoke ok")
    return 0
