type Foo =
    left: int32

type Bar =
    right: int32

fn main(): int32 =
    var total: int32
    if true:
        let item = Foo(left: 7)
        total = total + item.left
    if false:
        let item = Foo(left: 1000)
        total = total + item.left
    elif true:
        let item = Bar(right: 29)
        total = total + item.right
    else:
        total = total + 1000
    var loop0: int32
    for loop0 in loop0..<1:
        let item = Foo(left: 13)
        total = total + item.left
    var loop1: int32
    for loop1 in loop1..<1:
        let item = Bar(right: 17)
        total = total + item.right
    for idx in 0..<1:
        let item = Foo(left: idx + 19)
        total = total + item.left
    for idx in 0..<1:
        let item = Bar(right: idx + 23)
        total = total + item.right
    return total - 108
