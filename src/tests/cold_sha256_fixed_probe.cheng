import cheng/std/bytes_layout as layout
import std/crypto/hash256

fn main(): int32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(16)
    layout.ByteBufAppendByte(buf, Int32('a'))
    layout.ByteBufAppendByte(buf, Int32('b'))
    layout.ByteBufAppendByte(buf, Int32('c'))
    let digest = hash256.Sha256Fixed(layout.ByteBufView(buf))
    let hex = layout.FixedBytes32Hex(digest)
    if hex != "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad":
        return 2
    return 0
