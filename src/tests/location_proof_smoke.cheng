import std/system
import std/result
import cheng/chain/binary_types as types
import cheng/chain/location_proof as lp

fn main(): int32 =
    var claimantRes: Result[types.V3LsmrAddress]
    claimantRes = types.v3LsmrAddressFromDigits([5, 8, 1])
    assert(IsOk(claimantRes), "v3 location smoke: claimant address")
    var claimant = Value(claimantRes)

    var witnesses: lp.V3LocationWitness[]
    witnesses = []
    var w1AddressRes: Result[types.V3LsmrAddress]
    w1AddressRes = types.v3LsmrAddressFromDigits([5, 1, 1])
    assert(IsOk(w1AddressRes), "v3 location smoke: witness1 address")
    var w2AddressRes: Result[types.V3LsmrAddress]
    w2AddressRes = types.v3LsmrAddressFromDigits([5, 6, 1])
    assert(IsOk(w2AddressRes), "v3 location smoke: witness2 address")
    var w3AddressRes: Result[types.V3LsmrAddress]
    w3AddressRes = types.v3LsmrAddressFromDigits([5, 3, 1])
    assert(IsOk(w3AddressRes), "v3 location smoke: witness3 address")
    var w1Res = lp.v3LocationWitnessMake(100, claimant, 201, Value(w1AddressRes), 3)
    var w2Res = lp.v3LocationWitnessMake(100, claimant, 202, Value(w2AddressRes), 3)
    var w3Res = lp.v3LocationWitnessMake(100, claimant, 203, Value(w3AddressRes), 3)
    assert(IsOk(w1Res), "v3 location smoke: witness1")
    assert(IsOk(w2Res), "v3 location smoke: witness2")
    assert(IsOk(w3Res), "v3 location smoke: witness3")
    add(witnesses, Value(w1Res))
    add(witnesses, Value(w2Res))
    add(witnesses, Value(w3Res))

    var nonceCid = lp.v3LocationNonceCid(42)
    var proofRes = lp.v3BuildLocationProof(100,
                                           claimant,
                                           42,
                                           nonceCid,
                                           witnesses)
    assert(IsOk(proofRes), "v3 location smoke: proof")
    var proof = Value(proofRes)
    var decision = lp.v3VerifyLocationProof(proof)
    assert(decision.accepted, "v3 location smoke: valid proof accepted")
    assert(decision.distinctWitnessCount == 3, "v3 location smoke: witness quorum")
    assert(decision.distinctSectorCount == 3, "v3 location smoke: sector coverage")

    var badProof = proof
    badProof.witnessRttBuckets[0] = 99
    var badDecision = lp.v3VerifyLocationProof(badProof)
    assert(!badDecision.accepted, "v3 location smoke: bad proof rejected")

    echo("v3 location_proof_smoke ok")
    return 0
