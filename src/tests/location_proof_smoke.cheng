import std/system
import std/result
import cheng/chain/binary_types as types
import cheng/chain/location_proof as lp

fn main(): int32 =
    var claimantRes: Result[types.LsmrAddress]
    claimantRes = types.LsmrAddressFromDigits([5, 8, 1])
    assert(IsOk(claimantRes), " location smoke: claimant address")
    var claimant = Value(claimantRes)

    var witnesses: lp.LocationWitness[]
    witnesses = []
    var w1AddressRes: Result[types.LsmrAddress]
    w1AddressRes = types.LsmrAddressFromDigits([5, 1, 1])
    assert(IsOk(w1AddressRes), " location smoke: witness1 address")
    var w2AddressRes: Result[types.LsmrAddress]
    w2AddressRes = types.LsmrAddressFromDigits([5, 6, 1])
    assert(IsOk(w2AddressRes), " location smoke: witness2 address")
    var w3AddressRes: Result[types.LsmrAddress]
    w3AddressRes = types.LsmrAddressFromDigits([5, 3, 1])
    assert(IsOk(w3AddressRes), " location smoke: witness3 address")
    var w1Res = lp.LocationWitnessMake(100, claimant, 201, Value(w1AddressRes), 3)
    var w2Res = lp.LocationWitnessMake(100, claimant, 202, Value(w2AddressRes), 3)
    var w3Res = lp.LocationWitnessMake(100, claimant, 203, Value(w3AddressRes), 3)
    assert(IsOk(w1Res), " location smoke: witness1")
    assert(IsOk(w2Res), " location smoke: witness2")
    assert(IsOk(w3Res), " location smoke: witness3")
    add(witnesses, Value(w1Res))
    add(witnesses, Value(w2Res))
    add(witnesses, Value(w3Res))

    var nonceCid = lp.LocationNonceCid(42)
    var proofRes = lp.BuildLocationProof(100,
                                           claimant,
                                           42,
                                           nonceCid,
                                           witnesses)
    assert(IsOk(proofRes), " location smoke: proof")
    var proof = Value(proofRes)
    var decision = lp.VerifyLocationProof(proof)
    assert(decision.accepted, " location smoke: valid proof accepted")
    assert(decision.distinctWitnessCount == 3, " location smoke: witness quorum")
    assert(decision.distinctSectorCount == 3, " location smoke: sector coverage")

    var badProof = proof
    badProof.witnessRttBuckets[0] = 99
    var badDecision = lp.VerifyLocationProof(badProof)
    assert(!badDecision.accepted, " location smoke: bad proof rejected")

    echo(" location_proof_smoke ok")
    return 0
