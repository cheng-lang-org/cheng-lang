import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net

fn main(): int32 =
    var server: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(server, "node-a", "chain-node-a")),
           "v3 chain_node zero snapshot: init")
    var served: node.V3ChainNodeServeSnapshot
    node.v3ChainNodeServeOnceInto(served, server)
    let payload = net.v3ChainNodeLibp2pEncodeSnapshot(served)
    var decoded: node.V3ChainNodeServeSnapshot
    let decodedRes = net.v3ChainNodeLibp2pDecodeSnapshotInto(payload, decoded)
    assert(decodedRes.ok, "v3 chain_node zero snapshot: decode")
    var replayed: node.V3ChainNode
    let replayRes = node.v3ChainNodeReplayFromSnapshotInto(replayed,
                                                           "node-a",
                                                           served.address,
                                                           decoded)
    assert(replayRes.ok, "v3 chain_node zero snapshot: replay")
    var replayedSnapshot: node.V3ChainNodeServeSnapshot
    node.v3ChainNodeServeOnceInto(replayedSnapshot, replayed)
    assert(layout.fixedBytes32Equal(served.forest.forestCid, replayedSnapshot.forest.forestCid),
        "v3 chain_node zero snapshot: forest cid")
    assert(anti.v3AntiEntropySignatureEqual(served.signature, replayedSnapshot.signature),
        "v3 chain_node zero snapshot: signature")
    assert(replayedSnapshot.nodeId == "node-a", "v3 chain_node zero snapshot: node id")
    echo("v3 chain_node_zero_snapshot_replay_smoke ok")
    return 0
