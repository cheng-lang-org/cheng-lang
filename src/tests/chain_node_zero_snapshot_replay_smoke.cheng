import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node zero snapshot: init")
    var served: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(served, server)
    let payload = net.ChainNodeLibp2pEncodeSnapshot(served)
    var decoded: node.ChainNodeServeSnapshot
    let decodedRes = net.ChainNodeLibp2pDecodeSnapshotInto(payload, decoded)
    assert(decodedRes.ok, " chain_node zero snapshot: decode")
    var replayed: node.ChainNode
    let replayRes = node.ChainNodeReplayFromSnapshotInto(replayed,
                                                           "node-a",
                                                           served.address,
                                                           decoded)
    assert(replayRes.ok, " chain_node zero snapshot: replay")
    var replayedSnapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(replayedSnapshot, replayed)
    assert(layout.FixedBytes32Equal(served.forest.forestCid, replayedSnapshot.forest.forestCid),
        " chain_node zero snapshot: forest cid")
    assert(anti.AntiEntropySignatureEqual(served.signature, replayedSnapshot.signature),
        " chain_node zero snapshot: signature")
    assert(replayedSnapshot.nodeId == "node-a", " chain_node zero snapshot: node id")
    echo(" chain_node_zero_snapshot_replay_smoke ok")
    return 0
