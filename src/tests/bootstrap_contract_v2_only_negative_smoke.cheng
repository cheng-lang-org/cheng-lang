import std/os
import std/strings
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

fn containsText(text: str, needle: str): bool =
    return strings.StrContains(text, needle)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let outDir = chengpath.PathAbsolute(root, "artifacts/bootstrap_contract_v2_only_negative")
    assert(chengpath.MkdirP(root, outDir), " bootstrap v2 only: mkdir")
    let stage0 = chengpath.PathAbsolute(root, "artifacts/bootstrap/cheng.stage0")
    let legacyContract = chengpath.PathAbsolute(root, "src/tests/bootstrap_contract_v1_legacy_negative.cheng")
    assert(chengpath.FileExistsNonEmpty(root, stage0), " bootstrap v2 only: stage0 exists")
    assert(chengpath.FileExistsNonEmpty(root, legacyContract), " bootstrap v2 only: legacy fixture exists")

    let selfCheckLog = chengpath.PathJoin(outDir, "self-check.log")
    if chengpath.PathFileExists(selfCheckLog):
        os.RemoveFile(selfCheckLog)
    let selfCheckRun = hostops.RunFileLogged(root,
                                               "bootstrap_v1_self_check_negative",
                                               stage0,
                                               ["self-check", "--in:" + legacyContract],
                                               [],
                                               root,
                                               20,
                                               selfCheckLog)
    assert(selfCheckRun.exitCode != 0, " bootstrap v2 only: self-check must fail")
    assert(containsText(selfCheckRun.output, "unsupported bootstrap syntax: bootstrap-v1"),
           " bootstrap v2 only: self-check unsupported syntax")
    assert(containsText(selfCheckRun.output, "expected bootstrap-v2"),
           " bootstrap v2 only: self-check expected v2")

    let printLog = chengpath.PathJoin(outDir, "print-contract.log")
    if chengpath.PathFileExists(printLog):
        os.RemoveFile(printLog)
    let printRun = hostops.RunFileLogged(root,
                                           "bootstrap_v1_print_contract_negative",
                                           stage0,
                                           ["print-contract", "--in:" + legacyContract],
                                           [],
                                           root,
                                           20,
                                           printLog)
    assert(printRun.exitCode != 0, " bootstrap v2 only: print-contract must fail")
    assert(containsText(printRun.output, "unsupported bootstrap syntax: bootstrap-v1"),
           " bootstrap v2 only: print-contract unsupported syntax")
    echo(" bootstrap_contract_v2_only_negative_smoke ok")
    return 0
