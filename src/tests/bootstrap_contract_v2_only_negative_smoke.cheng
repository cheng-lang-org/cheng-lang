import std/os
import std/strings
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as v3path

fn containsText(text: str, needle: str): bool =
    return strings.StrContains(text, needle)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let outDir = v3path.V3PathAbsolute(root, "artifacts/bootstrap_contract_v2_only_negative")
    assert(v3path.V3MkdirP(root, outDir), "v3 bootstrap v2 only: mkdir")
    let stage0 = v3path.V3PathAbsolute(root, "artifacts/bootstrap/cheng.stage0")
    let legacyContract = v3path.V3PathAbsolute(root, "src/tests/bootstrap_contract_v1_legacy_negative.cheng")
    assert(v3path.V3FileExistsNonEmpty(root, stage0), "v3 bootstrap v2 only: stage0 exists")
    assert(v3path.V3FileExistsNonEmpty(root, legacyContract), "v3 bootstrap v2 only: legacy fixture exists")

    let selfCheckLog = v3path.V3PathJoin(outDir, "self-check.log")
    if v3path.V3PathFileExists(selfCheckLog):
        os.RemoveFile(selfCheckLog)
    let selfCheckRun = hostops.v3RunFileLogged(root,
                                               "bootstrap_v1_self_check_negative",
                                               stage0,
                                               ["self-check", "--in:" + legacyContract],
                                               [],
                                               root,
                                               20,
                                               selfCheckLog)
    assert(selfCheckRun.exitCode != 0, "v3 bootstrap v2 only: self-check must fail")
    assert(containsText(selfCheckRun.output, "unsupported bootstrap syntax: v3-bootstrap-v1"),
           "v3 bootstrap v2 only: self-check unsupported syntax")
    assert(containsText(selfCheckRun.output, "expected bootstrap-v2"),
           "v3 bootstrap v2 only: self-check expected v2")

    let printLog = v3path.V3PathJoin(outDir, "print-contract.log")
    if v3path.V3PathFileExists(printLog):
        os.RemoveFile(printLog)
    let printRun = hostops.v3RunFileLogged(root,
                                           "bootstrap_v1_print_contract_negative",
                                           stage0,
                                           ["print-contract", "--in:" + legacyContract],
                                           [],
                                           root,
                                           20,
                                           printLog)
    assert(printRun.exitCode != 0, "v3 bootstrap v2 only: print-contract must fail")
    assert(containsText(printRun.output, "unsupported bootstrap syntax: v3-bootstrap-v1"),
           "v3 bootstrap v2 only: print-contract unsupported syntax")
    echo("v3 bootstrap_contract_v2_only_negative_smoke ok")
    return 0
