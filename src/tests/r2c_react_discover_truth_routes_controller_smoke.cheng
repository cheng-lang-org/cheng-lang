import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_smoke_support as r2csmoke
import std/strutils as strutil

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = chengpath.PathAbsolute(root, "artifacts/r2c_discover_truth_routes_controller_smoke")
    assert(chengpath.MkdirP(root, outDir), " r2c discover truth routes smoke: mkdir")
    let driver = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    let packageRoot = root
    let controllerSource = chengpath.PathAbsolute(root, "src/r2c/r2c_react.cheng")
    assert(chengpath.FileExistsNonEmpty(root, driver), " r2c discover truth routes smoke: backend_driver exists")
    assert(chengpath.FileExistsNonEmpty(root, controllerSource), " r2c discover truth routes smoke: controller source exists")

    let repoEnv = os.GetEnv("R2C_REACT_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.DirExists(repo), " r2c discover truth routes smoke: React.js repo exists")

    let controllerEnv = os.GetEnv("R2C_REACT_CONTROLLER_EXE")
    let allowControllerCompile = os.GetEnv("R2C_REACT_ALLOW_CONTROLLER_COMPILE") == "1"
    var controllerExe = ""
    if len(controllerEnv) > 0:
        controllerExe = chengpath.PathAbsolute(root, controllerEnv)
    elif allowControllerCompile:
        controllerExe = os.JoinPath(outDir, "r2c_react_discover_truth_routes_controller_smoke")
    else:
        assert(false,
               " r2c discover truth routes smoke: set R2C_REACT_CONTROLLER_EXE or R2C_REACT_ALLOW_CONTROLLER_COMPILE=1")
    if allowControllerCompile && len(controllerEnv) <= 0:
        let controllerCompileReport = strutil.Join([controllerExe, ".report.txt"], "")
        let controllerCompileLog = strutil.Join([controllerExe, ".compile.log"], "")
        if chengpath.PathFileExists(controllerExe):
            os.RemoveFile(controllerExe)
        if chengpath.PathFileExists(strutil.Join([controllerExe, ".map"], "")):
            os.RemoveFile(strutil.Join([controllerExe, ".map"], ""))
        if chengpath.PathFileExists(controllerCompileReport):
            os.RemoveFile(controllerCompileReport)
        if chengpath.PathFileExists(controllerCompileLog):
            os.RemoveFile(controllerCompileLog)
        let controllerCompileRun = hostops.RunFileLogged(root,
                                                           "r2c_discover_truth_routes_controller_compile",
                                                           driver,
                                                           [
                                                               "system-link-exec",
                                                               strutil.Join(["--root:", packageRoot], ""),
                                                               strutil.Join(["--in:", controllerSource], ""),
                                                               "--emit:exe",
                                                               "--target:arm64-apple-darwin",
                                                               strutil.Join(["--out:", controllerExe], ""),
                                                               strutil.Join(["--report-out:", controllerCompileReport], "")
                                                           ],
                                                           r2csmoke.R2cReactSmokeControllerCompileEnv(),
                                                           root,
                                                           420,
                                                           controllerCompileLog)
        assert(hostops.LoggedRunOk(controllerCompileRun), " r2c discover truth routes smoke: controller compile rc")
        assert(chengpath.FileExistsNonEmpty(root, controllerCompileReport), " r2c discover truth routes smoke: controller compile report")
    assert(chengpath.FileExistsNonEmpty(root, controllerExe), " r2c discover truth routes smoke: controller exe")

    let artifactDir = os.JoinPath(outDir, "controller_out")
    let truthRoutesPath = os.JoinPath(artifactDir, "truth_routes_v1.json")
    let truthRoutesSummaryPath = os.JoinPath(artifactDir, "truth_routes_v1.summary.env")
    let reportPath = os.JoinPath(artifactDir, "truth_routes_report_v1.json")
    let controllerLog = os.JoinPath(outDir, "discover_truth_routes_controller.log")
    if chengpath.PathFileExists(controllerLog):
        os.RemoveFile(controllerLog)
    let controllerRun = hostops.RunFileLogged(root,
                                                "r2c_discover_truth_routes_controller_smoke",
                                                controllerExe,
                                                [
                                                    "discover-truth-routes",
                                                    "--repo", repo,
                                                    "--out-dir", artifactDir
                                                ],
                                                [],
                                                root,
                                                120,
                                                controllerLog)
    assert(hostops.LoggedRunOk(controllerRun), " r2c discover truth routes smoke: controller rc")
    assert(chengpath.FileExistsNonEmpty(root, truthRoutesPath), " r2c discover truth routes smoke: truth routes json")
    assert(chengpath.FileExistsNonEmpty(root, truthRoutesSummaryPath), " r2c discover truth routes smoke: truth routes summary")
    assert(chengpath.FileExistsNonEmpty(root, reportPath), " r2c discover truth routes smoke: report")

    let truthRoutesText = chengpath.ReadTextFile("", truthRoutesPath)
    let truthRoutesSummaryText = chengpath.ReadTextFile("", truthRoutesSummaryPath)
    let reportText = chengpath.ReadTextFile("", reportPath)
    assert(chengpath.TextContains(truthRoutesText, "\"format\": \"truth_routes_v1\""),
           " r2c discover truth routes smoke: truth routes format")
    assert(chengpath.TextContains(truthRoutesText, "\"routeId\": \"home_default\""),
           " r2c discover truth routes smoke: truth routes home_default")
    assert(chengpath.TextContains(truthRoutesText, "\"routeId\": \"publish_selector\""),
           " r2c discover truth routes smoke: truth routes publish_selector")
    assert(chengpath.TextContains(truthRoutesSummaryText, "route_count="),
           " r2c discover truth routes smoke: summary route count key")
    assert(!chengpath.TextContains(truthRoutesSummaryText, "route_count=0"),
           " r2c discover truth routes smoke: summary route count nonzero")
    assert(chengpath.TextContains(truthRoutesSummaryText, "typescript_version="),
           " r2c discover truth routes smoke: summary typescript version")
    assert(chengpath.TextContains(reportText, "\"command\": \"discover-truth-routes\""),
           " r2c discover truth routes smoke: report command")
    assert(chengpath.TextContains(reportText, "\"ok\": true"),
           " r2c discover truth routes smoke: report ok")
    assert(chengpath.TextContains(reportText, "\"primary_artifact_format\": \"truth_routes_v1\""),
           " r2c discover truth routes smoke: report artifact format")
    assert(chengpath.TextContains(reportText, "\"helper_script\":"),
           " r2c discover truth routes smoke: report helper path")

    echo(" r2c_react_discover_truth_routes_controller_smoke ok")
    return 0
