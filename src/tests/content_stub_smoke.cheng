import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as binary
import cheng/chain/lsmr_types as lt
import cheng/chain/csg
import cheng/chain/pubsub
import cheng/chain/dag_mempool as dag
import cheng/chain/plumtree
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content
import cheng/chain/content_runtime as runtime

fn contentStubSmokeBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn contentStubSmokeBlob(shard0: Bytes, shard1: Bytes, shard2: Bytes): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(bytesLen(shard0) + bytesLen(shard1) + bytesLen(shard2))
    layout.ByteBufAppendBytes(buf, shard0)
    layout.ByteBufAppendBytes(buf, shard1)
    layout.ByteBufAppendBytes(buf, shard2)
    return layout.ByteBufToBytes(buf)

fn contentStubSmokeBuildRouting(outCenter: var binary.LsmrAddress,
                                outTopic: var pubsub.PubSubTopic,
                                outRoot: var pubsub.PubSubSubscription,
                                outSubscriptions: var pubsub.PubSubSubscription[]): Result[bool] =
    let centerRes = binary.LsmrAddressFromDigits([5, 5, 5])
    if IsErr(centerRes):
        return Err[bool](Error(centerRes))
    let center = Value(centerRes)
    let topicRes = pubsub.PubSubTopicFromAddress(center,
                                                   2,
                                                   lt.PubSubModeXun,
                                                   pubsub.PubSubSemanticFingerprint([71, 72, 73]))
    if IsErr(topicRes):
        return Err[bool](Error(topicRes))
    let topic = Value(topicRes)
    let root = pubsub.PubSubSubscriptionMake(1, center, csg.CsgBarrierModeGen, topic.topicCid)
    let eastRes = binary.LsmrAddressFromDigits([5, 8, 1])
    if IsErr(eastRes):
        return Err[bool](Error(eastRes))
    outCenter = center
    outTopic = topic
    outRoot = root
    outSubscriptions = []
    add(outSubscriptions, root)
    add(outSubscriptions, pubsub.PubSubSubscriptionMake(2, Value(eastRes), csg.CsgBarrierModeGen, topic.topicCid))
    return Ok[bool](true)

fn contentStubSmokePrepareArtifacts(out: var content.ContentPublishArtifacts,
                                    topic: pubsub.PubSubTopic,
                                    root: pubsub.PubSubSubscription,
                                    subscriptions: pubsub.PubSubSubscription[],
                                    publisherPeerId: layout.FixedBytes32): Result[bool] =
    let shard0 = bytesFromString("alpha-")
    let shard1 = bytesFromString("beta--")
    let shard2 = bytesFromString("gamma!")
    let blob = contentStubSmokeBlob(shard0, shard1, shard2)
    let summaryRes = dag.DagBlobSummaryFromBytes(blob, 6)
    if IsErr(summaryRes):
        return Err[bool](Error(summaryRes))
    let summary = Value(summaryRes)
    let paramsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic, 3, 0, 6)
    if IsErr(paramsRes):
        return Err[bool](Error(paramsRes))
    let params = Value(paramsRes)

    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard0))
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard1))
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard2))

    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    let manifest = Value(manifestRes)
    let denseAdvertRes = swarm.ErasurePeerAdvertMake(publisherPeerId,
                                                       manifest,
                                                       params,
                                                       [0, 1, 2],
                                                       950,
                                                       3)
    if IsErr(denseAdvertRes):
        return Err[bool](Error(denseAdvertRes))
    var peerAdverts: swarm.ErasurePeerAdvert[]
    peerAdverts = []
    swarm.ErasurePeerAdvertAppend(peerAdverts, Value(denseAdvertRes))
    var providerPeerIds: layout.FixedBytes32[]
    providerPeerIds = []
    add(providerPeerIds, publisherPeerId)
    var retainedUntilEpochs: int32[]
    retainedUntilEpochs = []
    add(retainedUntilEpochs, 120)

    let proofsRes = content.ContentBuildAvailabilityProofs(summary, providerPeerIds, retainedUntilEpochs)
    if IsErr(proofsRes):
        return Err[bool](Error(proofsRes))
    let proofs = Value(proofsRes)
    let certRes = dag.DagAvailabilityCertMake(summary, proofs)
    if IsErr(certRes):
        return Err[bool](Error(certRes))
    let cert = Value(certRes)
    let advertRes = dag.DagPublishAdvertMake(topic.topicCid,
                                               publisherPeerId,
                                               summary,
                                               cert,
                                               11,
                                               22)
    if IsErr(advertRes):
        return Err[bool](Error(advertRes))
    let advert = Value(advertRes)
    let envelope = pubsub.PubSubEnvelopeMake(topic.topicCid,
                                               pubsub.PubSubPayloadKindDagAdvert,
                                               advert.advertCid,
                                               summary.summaryCid)
    let pubsubPlanRes = pubsub.PubSubBuildPlan(topic, envelope, subscriptions)
    if IsErr(pubsubPlanRes):
        return Err[bool](Error(pubsubPlanRes))
    let pubsubPlan = Value(pubsubPlanRes)
    let plumtreePlanRes = plumtree.PlumtreeBuildPlan(topic, root, pubsubPlan, subscriptions)
    if IsErr(plumtreePlanRes):
        return Err[bool](Error(plumtreePlanRes))
    let plumtreePlan = Value(plumtreePlanRes)
    let recoveryPlanRes = swarm.ErasureBuildRecoveryPlan(manifest, params, peerAdverts)
    if IsErr(recoveryPlanRes):
        return Err[bool](Error(recoveryPlanRes))
    let recoveryPlan = Value(recoveryPlanRes)
    out = content.ContentPublishArtifacts()
    out.topic = topic
    out.root = root
    out.subscriptionCount = subscriptions.len
    out.subscriptions = subscriptions
    out.blobSummary = summary
    out.availabilityProofCount = proofs.len
    out.availabilityProofs = proofs
    out.availabilityCert = cert
    out.publishAdvert = advert
    out.envelope = envelope
    out.pubsubPlan = pubsubPlan
    out.plumtreePlan = plumtreePlan
    out.erasureParams = params
    out.erasureManifest = manifest
    out.peerAdvertCount = peerAdverts.len
    out.peerAdverts = peerAdverts
    out.recoveryPlan = recoveryPlan
    out.bundleCid = content.ContentPublishArtifactsExpectedBundleCid(out)
    return Ok[bool](true)

fn main(): int32 =
    var center = binary.LsmrAddress()
    var topic = pubsub.PubSubTopic()
    var root = pubsub.PubSubSubscription()
    var subscriptions: pubsub.PubSubSubscription[]
    subscriptions = []
    let routingRes = contentStubSmokeBuildRouting(center, topic, root, subscriptions)
    assert(IsOk(routingRes), " content stub smoke: routing")

    let publisherPeerId = lt.HashInts("cheng.content.stub.publisher", [17, 18, 19])
    let shard0 = bytesFromString("alpha-")
    let shard1 = bytesFromString("beta--")
    let shard2 = bytesFromString("gamma!")
    var shardPayloads: Bytes[]
    shardPayloads = []
    add(shardPayloads, shard0)
    add(shardPayloads, shard1)
    add(shardPayloads, shard2)
    let blob = contentStubSmokeBlob(shard0, shard1, shard2)

    var artifacts = content.ContentPublishArtifacts()
    let prepareRes = contentStubSmokePrepareArtifacts(artifacts,
                                                      topic,
                                                      root,
                                                      subscriptions,
                                                      publisherPeerId)
    assert(IsOk(prepareRes), " content stub smoke: prepare artifacts")
    let artifactsOk = content.ContentPublishArtifactsValidate(artifacts)
    assert(IsOk(artifactsOk), " content stub smoke: artifacts")

    let stubRes = content.ContentStubFromArtifacts(artifacts)
    assert(IsOk(stubRes), " content stub smoke: stub")
    let stub = Value(stubRes)
    let stubOk = content.ContentStubValidate(stub)
    assert(IsOk(stubOk), " content stub smoke: stub validate")
    assert(layout.FixedBytes32Equal(stub.manifestCid, artifacts.erasureManifest.manifestCid),
        " content stub smoke: stub manifest cid")
    assert(layout.FixedBytes32Equal(stub.recoveryPlanCid, artifacts.recoveryPlan.planCid),
        " content stub smoke: stub recovery cid")

    let stubDecodedRes = content.ContentStubDecode(content.ContentStubEncode(stub))
    assert(IsOk(stubDecodedRes), " content stub smoke: stub decode")
    assert(layout.FixedBytes32Equal(Value(stubDecodedRes).stubCid, stub.stubCid),
        " content stub smoke: stub decoded cid")

    var serverRuntime = runtime.ContentRuntimeInit()
    let storeManifestRes = runtime.ContentRuntimeStoreManifest(serverRuntime,
                                                                 artifacts.erasureManifest)
    assert(IsOk(storeManifestRes), " content stub smoke: store manifest")
    let storeBlobRes = runtime.ContentRuntimeStoreBlobPayload(serverRuntime,
                                                               artifacts.blobSummary.blobCid,
                                                               blob)
    assert(IsOk(storeBlobRes), " content stub smoke: store blob")

    let targetsRes = runtime.ContentRuntimeBuildPullTargets(artifacts.erasureManifest.manifestCid,
                                                              artifacts.erasureManifest.shardIndices,
                                                              artifacts.erasureManifest.shardPayloadCids,
                                                              artifacts.recoveryPlan.manifestCid,
                                                              artifacts.recoveryPlan.requestCount,
                                                              artifacts.recoveryPlan.requestPeerIds,
                                                              artifacts.recoveryPlan.requestShardIndices,
                                                              artifacts.recoveryPlan.requestShardCids)
    assert(IsOk(targetsRes), " content stub smoke: build pull targets")
    let targets = Value(targetsRes)
    assert(targets.len == shardPayloads.len, " content stub smoke: target count")

    let requestsRes = runtime.ContentRuntimeBuildPullRequests(artifacts.erasureManifest.manifestCid,
                                                                artifacts.erasureManifest.shardIndices,
                                                                artifacts.erasureManifest.shardPayloadCids,
                                                                artifacts.recoveryPlan.manifestCid,
                                                                artifacts.recoveryPlan.requestCount,
                                                                artifacts.recoveryPlan.requestPeerIds,
                                                                artifacts.recoveryPlan.requestShardIndices,
                                                                artifacts.recoveryPlan.requestShardCids)
    assert(IsOk(requestsRes), " content stub smoke: build pull requests")
    let requests = Value(requestsRes)
    assert(requests.len == shardPayloads.len, " content stub smoke: request count")

    for i in 0..<requests.len:
        let shardIndex = requests[i].shardIndex
        var response = swarm.ErasureShardPullResponse()
        let responseFillRes = swarm.ErasureShardPullResponseFill(response,
                                                                   requests[i],
                                                                   shardPayloads[shardIndex])
        assert(IsOk(responseFillRes), " content stub smoke: seed shard response")
        let storeRes = runtime.ContentRuntimeStoreShardResponse(serverRuntime, response)
        assert(IsOk(storeRes), " content stub smoke: store server cache")

    var clientRuntime = runtime.ContentRuntimeInit()
    var pulled: swarm.ErasureShardPullResponse[]
    pulled = []
    for i in 0..<targets.len:
        assert(layout.FixedBytes32Equal(targets[i].peerId, publisherPeerId),
            " content stub smoke: target peer")
        var servedPayload: Bytes
        assert(runtime.ContentRuntimeCachedShard(serverRuntime, targets[i].request, servedPayload),
            " content stub smoke: serve cached shard")
        var pulledResponse = swarm.ErasureShardPullResponse()
        let pullFillRes = swarm.ErasureShardPullResponseFill(pulledResponse,
                                                               targets[i].request,
                                                               servedPayload)
        assert(IsOk(pullFillRes), " content stub smoke: pull shard")
        let clientStoreRes = runtime.ContentRuntimeStoreShardResponse(clientRuntime, pulledResponse)
        assert(IsOk(clientStoreRes), " content stub smoke: store client cache")
        add(pulled, pulledResponse)

    var cachedShard: Bytes
    assert(runtime.ContentRuntimeCachedShard(clientRuntime, targets[0].request, cachedShard),
        " content stub smoke: cached shard")
    assert(contentStubSmokeBytesEqual(cachedShard, shardPayloads[targets[0].request.shardIndex]),
        " content stub smoke: cached shard bytes")

    let rebuildRes = runtime.ContentRuntimeRebuildBlobAgainstStub(stub,
                                                                    artifacts.erasureManifest,
                                                                    artifacts.erasureParams,
                                                                    pulled)
    assert(IsOk(rebuildRes), " content stub smoke: rebuild against stub")
    assert(contentStubSmokeBytesEqual(Value(rebuildRes), blob),
        " content stub smoke: rebuilt blob")

    assert(contentStubSmokeBytesEqual(bytesFromString("alpha-beta--gamma!"),
                                      contentStubSmokeBlob(bytesFromString("alpha-"),
                                                           bytesFromString("beta--"),
                                                           bytesFromString("gamma!"))),
        " content stub smoke: blob equality helper")

    echo(" content_stub_smoke ok")
    return 0
