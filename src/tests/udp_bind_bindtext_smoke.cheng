import std/system
import std/result
import cheng/quic/multiaddress as qaddr
import cheng/quic/native_runtime as qnative
import cheng/quic/platform/datapath_udp as qudp

fn main(): int32 =
    let addr = qaddr.makeInprocMultiAddress(qaddr.quicAddrKindMsQuic, 6210)
    assert(qnative.msquicNativeTaggedAddr(addr), "udp bind bindtext tagged")
    assert(qaddr.quicMultiAddressPort(addr) == 6210, "udp bind bindtext port")
    let bindText = qnative.msquicNativeMultiAddressBindText(addr)
    assert(bindText == "/ip4/127.0.0.1/udp/6210/quic-v1", "udp bind bindtext value")
    var bound: qudp.MsQuicUdpBound
    let bindRes = qudp.msquicUdpBindInto(bound, bindText)
    assert(IsOk(bindRes), "udp bind bindtext failed")
    qudp.msquicUdpUnbind(bound.fd)
    echo("v3 udp_bind_bindtext_smoke ok")
    return 0
