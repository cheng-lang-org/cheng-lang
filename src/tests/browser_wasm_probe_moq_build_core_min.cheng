import std/rawbytes
import cheng/moq/moq_fountain as moq

@exportc("moqBuildObjectCount")
fn moqBuildObjectCount(): int32 =
    let blob = bytesFromString("abc")
    let result = moq.MoqFountainBuild(blob,
                                      "owner",
                                      "peer-a,peer-b",
                                      "video/mp4",
                                      8,
                                      4,
                                      1)
    if IsErr(result):
        return -1
    return Value(result).objectCount

fn main(): int32 =
    return moqBuildObjectCount()
