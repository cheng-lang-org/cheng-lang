import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

type
    Outer =
        index: consensus.ChainIndex
        eventCids: layout.FixedBytes32[]
        marks: int32[]

fn main(): int32 =
    var outer = Outer()
    add(outer.eventCids, layout.FixedBytes32())
    add(outer.marks, 11)
    assert(outer.eventCids.len == 1, " chain index field assign preserves tail: pre cid len")
    assert(outer.marks.len == 1, " chain index field assign preserves tail: pre marks len")

    var nextIndex = outer.index
    add(nextIndex.accountAssetIds, 7)
    add(nextIndex.accountIds, 1001)
    add(nextIndex.accountHeads, layout.FixedBytes32())
    add(nextIndex.balances, int64(100))
    add(nextIndex.clockEpochs, 1)
    add(nextIndex.clockGanzhi, 1)
    add(nextIndex.diverged, false)
    outer.index = nextIndex

    assert(outer.index.accountIds.len == 1, " chain index field assign preserves tail: index len")
    assert(outer.eventCids.len == 1, " chain index field assign preserves tail: post cid len")
    assert(outer.marks.len == 1, " chain index field assign preserves tail: post marks len")
    assert(outer.marks[0] == 11, " chain index field assign preserves tail: mark item")
    echo(" chain_index_field_assign_preserves_tail_smoke ok")
    return 0
