import std/result
import std/os
import cheng/std/bytes_layout as layout
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/lang/parser
import cheng/core/lang/typed_expr as texpr
import std/strutils as strutil

fn reportFieldValue(report: str, key: str): str =
    let taggedReport = strutil.Join(["\n", report], "")
    let needle = strutil.Join(["\n", key, "="], "")
    let fieldPos = parser.ParserFindText(taggedReport, needle)
    if fieldPos < 0:
        return ""
    let valueStart = fieldPos + needle.len
    let tail = chengpath.TextSlice(taggedReport, valueStart, taggedReport.len - valueStart)
    let newlinePos = parser.ParserFindText(tail, "\n")
    if newlinePos < 0:
        return tail
    return chengpath.TextSlice(tail, 0, newlinePos)

fn reportFieldPositive(report: str, key: str): bool =
    let value = reportFieldValue(report, key)
    return value != "" && value != "0"

fn assertCallReportMatches(report: str,
                           layer: parser.NormalizedExprLayer,
                           label: str) =
    assert(reportFieldValue(report, "expr_surface_default_init_count") ==
           intToStr(parser.NormalizedExprLayerDefaultInitCount(layer)),
           strutil.Join([label, " report expr default init count"], ""))
    assert(reportFieldValue(report, "expr_surface_constructor_count") ==
           intToStr(parser.NormalizedExprLayerConstructorCount(layer)),
           strutil.Join([label, " report expr constructor count"], ""))
    assert(reportFieldValue(report, "typed_expr_type_call_default_init_count") ==
           intToStr(parser.NormalizedExprLayerDefaultInitCount(layer)),
           strutil.Join([label, " report default init count"], ""))
    assert(reportFieldValue(report, "typed_expr_type_call_constructor_count") ==
           intToStr(parser.NormalizedExprLayerConstructorCount(layer)),
           strutil.Join([label, " report constructor count"], ""))
    assert(reportFieldValue(report, "lowering_rule_type_call_default_init_count") ==
           intToStr(parser.NormalizedExprLayerDefaultInitCount(layer)),
           strutil.Join([label, " report lowering default init count"], ""))
    assert(reportFieldValue(report, "lowering_rule_type_call_constructor_count") ==
           intToStr(parser.NormalizedExprLayerConstructorCount(layer)),
           strutil.Join([label, " report lowering constructor count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_count") ==
           intToStr(parser.NormalizedExprLayerCallCount(layer)),
           strutil.Join([label, " report call count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_resolved_count") ==
           intToStr(parser.NormalizedExprLayerCallResolvedCount(layer)),
           strutil.Join([label, " report resolved call count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_unresolved_count") ==
           intToStr(parser.NormalizedExprLayerCallUnresolvedCount(layer)),
           strutil.Join([label, " report unresolved call count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_local_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallLocal)),
           strutil.Join([label, " report local call kind count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_external_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallExternal)),
           strutil.Join([label, " report external call kind count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_importc_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallImportc)),
           strutil.Join([label, " report importc call kind count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_member_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallMember)),
           strutil.Join([label, " report member call kind count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_target_importc_count") ==
           intToStr(parser.NormalizedExprLayerCallTargetImportcCount(layer)),
           strutil.Join([label, " report importc target count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_reason_unknown_qualified_target_count") ==
           intToStr(parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownQualifiedTarget)),
           strutil.Join([label, " report unknown qualified target count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_reason_shadowed_qualified_target_count") ==
           intToStr(parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonShadowedQualifiedTarget)),
           strutil.Join([label, " report shadowed qualified target count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_reason_ambiguous_external_target_count") ==
           intToStr(parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonAmbiguousExternalTarget)),
           strutil.Join([label, " report ambiguous external target count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_reason_ambiguous_qualified_target_count") ==
           intToStr(parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonAmbiguousQualifiedTarget)),
           strutil.Join([label, " report ambiguous qualified target count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_reason_unknown_external_target_count") ==
           intToStr(parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownExternalTarget)),
           strutil.Join([label, " report unknown external target count"], ""))
    assert(reportFieldValue(report, "expr_surface_call_reason_unknown_call_target_count") ==
           intToStr(parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownCallTarget)),
           strutil.Join([label, " report unknown call target count"], ""))

fn assertTypedCallFactsMatchLayer(facts: ccsg.TypedExprFact[],
                                  layer: parser.NormalizedExprLayer,
                                  label: str) =
    assert(texpr.TypedExprTypeCallDefaultInitCount(facts) ==
           parser.NormalizedExprLayerDefaultInitCount(layer),
           strutil.Join([label, " typed default init count"], ""))
    assert(texpr.TypedExprTypeCallConstructorCount(facts) ==
           parser.NormalizedExprLayerConstructorCount(layer),
           strutil.Join([label, " typed constructor count"], ""))
    assert(texpr.TypedExprFactCountCallResolved(facts) ==
           parser.NormalizedExprLayerCallResolvedCount(layer),
           strutil.Join([label, " typed resolved call count"], ""))
    assert(texpr.TypedExprFactCountCallUnresolved(facts) ==
           parser.NormalizedExprLayerCallUnresolvedCount(layer),
           strutil.Join([label, " typed unresolved call count"], ""))
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallLocal) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallLocal),
           strutil.Join([label, " typed local call kind count"], ""))
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallExternal) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallExternal),
           strutil.Join([label, " typed external call kind count"], ""))
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallImportc) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallImportc),
           strutil.Join([label, " typed importc call kind count"], ""))
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallMember) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallMember),
           strutil.Join([label, " typed member call kind count"], ""))
    assert(texpr.TypedExprFactCountCallTargetImportc(facts) ==
           parser.NormalizedExprLayerCallTargetImportcCount(layer),
           strutil.Join([label, " typed importc target count"], ""))
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownQualifiedTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownQualifiedTarget),
           strutil.Join([label, " typed unknown qualified target count"], ""))
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonShadowedQualifiedTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonShadowedQualifiedTarget),
           strutil.Join([label, " typed shadowed qualified target count"], ""))
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonAmbiguousExternalTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonAmbiguousExternalTarget),
           strutil.Join([label, " typed ambiguous external target count"], ""))
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonAmbiguousQualifiedTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonAmbiguousQualifiedTarget),
           strutil.Join([label, " typed ambiguous qualified target count"], ""))
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownExternalTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownExternalTarget),
           strutil.Join([label, " typed unknown external target count"], ""))
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownCallTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownCallTarget),
           strutil.Join([label, " typed unknown call target count"], ""))

fn buildPlan(workspaceRoot: str,
             packageRoot: str,
             sourcePath: str,
             outputPath: str,
             emitKind: int32): lower.LoweringPlanStub =
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err),
           " call hir matrix: build lowering link plan")
    assert(linkPlan.missingReasons.len == 0, " call hir matrix: lowering link plan ready")
    var csg = buildMinimalCsg(workspaceRoot, packageRoot, linkPlan)
    var plan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStubFromCompilerCsg(linkPlan, csg, plan, err),
           " call hir matrix: build lowering plan")
    return plan

fn buildMinimalCsg(workspaceRoot: str,
                   packageRoot: str,
                   linkPlan: slplan.SystemLinkPlanStub): ccsg.CompilerCsg =
    var sourceTexts: ccsg.TypedExprSourceText[]
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let currentSourcePath = linkPlan.sourceClosurePaths[i]
        let text = chengpath.ReadTextFile("", currentSourcePath)
        add(sourceTexts, texpr.TypedExprSourceTextNew(workspaceRoot,
                                                        packageRoot,
                                                        currentSourcePath,
                                                        text))
    var typedFacts: ccsg.TypedExprFact[]
    var err = ""
    assert(texpr.TypedExprBuildFacts(sourceTexts, linkPlan.exprLayer, typedFacts, err),
           " call hir matrix: build typed facts")
    var csg: ccsg.CompilerCsg
    csg.version = 1
    csg.packageId = linkPlan.packageId
    csg.sourceBundleCid = layout.FixedBytes32()
    csg.exprLayer = parser.NormalizedExprLayerClone(linkPlan.exprLayer)
    csg.typedExprFacts = texpr.TypedExprFactsClone(typedFacts)
    csg.nodeCount = 0
    csg.edgeCount = 0
    csg.nodes = []
    csg.edges = []
    csg.canonicalGraphCid = layout.FixedBytes32()
    csg.graphCid = layout.FixedBytes32()
    return csg

fn buildSourceTexts(workspaceRoot: str,
                    packageRoot: str,
                    sourcePaths: str[]): ccsg.TypedExprSourceText[] =
    var out: ccsg.TypedExprSourceText[]
    for i in 0..<sourcePaths.len:
        let currentSourcePath = sourcePaths[i]
        let text = chengpath.ReadTextFile("", currentSourcePath)
        add(out, texpr.TypedExprSourceTextNew(workspaceRoot,
                                                packageRoot,
                                                currentSourcePath,
                                                text))
    return out

fn assertCallReasonReport(layer: parser.NormalizedExprLayer,
                          report: str,
                          reason: parser.NormalizedExprCallReason,
                          label: str) =
    assertCallReportMatches(report, layer, label)
    let reportKey = ccsg.CompilerCsgCallReasonReportKey(reason)
    assert(reportKey != "", strutil.Join([label, " reason report key"], ""))
    assert(parser.NormalizedExprLayerCallReasonCountExact(layer, reason) > 0,
           strutil.Join([label, " reason count"], ""))
    assert(reportFieldPositive(report, reportKey),
           strutil.Join([label, " reason report"], ""))

fn buildCsg(workspaceRoot: str,
            packageRoot: str,
            sourcePath: str,
            outputPath: str,
            emitKind: int32): ccsg.CompilerCsg =
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), " call hir matrix: link plan")
    return buildMinimalCsg(workspaceRoot, packageRoot, linkPlan)

fn findCallExpr(layer: parser.NormalizedExprLayer,
                sourcePath: str,
                lineNumber: int32): parser.NormalizedExpr =
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].kind != parser.NormalizedExprCall:
            continue
        if layer.exprs[i].sourcePath != sourcePath:
            continue
        if layer.exprs[i].lineNumber != lineNumber:
            continue
        return parser.NormalizedExprClone(layer.exprs[i])
    var missing: parser.NormalizedExpr
    return missing

fn countCallExprs(layer: parser.NormalizedExprLayer,
                  sourcePath: str,
                  lineNumber: int32): int32 =
    var count: int32
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].kind != parser.NormalizedExprCall:
            continue
        if layer.exprs[i].sourcePath != sourcePath:
            continue
        if layer.exprs[i].lineNumber != lineNumber:
            continue
        count = count + 1
    return count

fn findTypedFact(facts: ccsg.TypedExprFact[],
                 sourcePath: str,
                 lineNumber: int32): ccsg.TypedExprFact =
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath:
            continue
        if facts[i].lineNumber != lineNumber:
            continue
        return texpr.TypedExprFactClone(facts[i])
    var missing: ccsg.TypedExprFact
    return missing

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir = chengpath.PathJoin(workspaceRoot, strutil.Join(["artifacts/call_hir_matrix/", smokeLabel], ""))
    assert(chengpath.MkdirP(workspaceRoot, outDir), " call hir matrix: mkdir")

    let parserFixturePath = chengpath.PathJoin(packageRoot, "src/tests/parser_normalized_expr_fixture.cheng")
    let reasonFixturePath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_reason_fixture.cheng")
    let aliasVisibilityFixturePath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_alias_visibility_fixture.cheng")
    let localShadowFixturePath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_local_shadow_fixture.cheng")
    let qualifiedLocalShadowFixturePath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_qualified_local_shadow_fixture.cheng")
    let qualifiedAmbiguousFixturePath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_qualified_ambiguous_fixture.cheng")
    let argsFixturePath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_args_fixture.cheng")
    let closureVisibleFixturePath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_closure_visible_fixture.cheng")
    let closureVisibleLeafPath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_closure_visible_leaf.cheng")
    let qualifiedClosureVisibleFixturePath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_qualified_closure_visible_fixture.cheng")
    let qualifiedClosureVisibleLeafPath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_qualified_closure_visible_leaf.cheng")
    let helperBPath = chengpath.PathJoin(packageRoot, "src/tests/call_hir_reason_helper_b.cheng")
    var parserLayer = parser.NormalizedExprLayer()
    var err = ""
    assert(parser.ParserReadNormalizedExprLayerFromPath(parserFixturePath, parserLayer, err),
           " call hir matrix: parser fixture layer")
    let parserImportc = findCallExpr(parserLayer, parserFixturePath, 16)
    let parserLocal = findCallExpr(parserLayer, parserFixturePath, 17)
    let parserUnknownMember = findCallExpr(parserLayer, parserFixturePath, 18)
    assert(parserImportc.exprId != "", " call hir matrix: parser importc call")
    assert(parserLocal.exprId != "", " call hir matrix: parser local call")
    assert(parserUnknownMember.exprId != "", " call hir matrix: parser member fallback")
    assert(parser.NormalizedExprCallSurfaceKind(parserImportc) == parser.NormalizedExprSurfaceCallImportc,
           " call hir matrix: parser importc kind")
    assert(parserImportc.callResolved,
           " call hir matrix: parser importc resolved")
    assert(parserImportc.callTargetImportc,
           " call hir matrix: parser importc flag")
    assert(parser.NormalizedExprCallSurfaceKind(parserLocal) == parser.NormalizedExprSurfaceCallLocal,
           " call hir matrix: parser local kind")
    assert(parserLocal.callResolved,
           " call hir matrix: parser local resolved")
    assert(parser.NormalizedExprCallSurfaceKind(parserUnknownMember) == parser.NormalizedExprSurfaceCallMember,
           " call hir matrix: parser member kind")
    assert(!parserUnknownMember.callResolved,
           " call hir matrix: parser member unresolved")
    assert(parserUnknownMember.callReason == parser.NormalizedExprCallReasonUnknownQualifiedTarget,
           " call hir matrix: parser member reason")

    var reasonLayer = parser.NormalizedExprLayer()
    var reasonParsed: parser.ParsedSourceStub
    err = ""
    assert(parser.ParseOrdinarySourceStub(packageRoot, reasonFixturePath, reasonParsed, err),
           " call hir matrix: reason fixture stub")
    reasonLayer = parser.NormalizedExprLayerClone(reasonParsed.normalizedExprLayer)
    let qualifiedExternalA = findCallExpr(reasonLayer, reasonFixturePath, 5)
    let qualifiedExternalB = findCallExpr(reasonLayer, reasonFixturePath, 6)
    let ambiguousExternal = findCallExpr(reasonLayer, reasonFixturePath, 7)
    assert(qualifiedExternalA.exprId != "", " call hir matrix: qualified external a")
    assert(qualifiedExternalB.exprId != "", " call hir matrix: qualified external b")
    assert(ambiguousExternal.exprId != "", " call hir matrix: ambiguous external call")
    assert(parser.NormalizedExprCallSurfaceKind(qualifiedExternalA) == parser.NormalizedExprSurfaceCallExternal,
           " call hir matrix: qualified external a kind")
    assert(parser.NormalizedExprCallSurfaceKind(qualifiedExternalB) == parser.NormalizedExprSurfaceCallExternal,
           " call hir matrix: qualified external b kind")
    assert(qualifiedExternalA.callResolved,
           " call hir matrix: qualified external a resolved")
    assert(qualifiedExternalB.callResolved,
           " call hir matrix: qualified external b resolved")
    assert(parser.NormalizedExprCallSurfaceKind(ambiguousExternal) == parser.NormalizedExprSurfaceCallExternal,
           " call hir matrix: ambiguous external kind")
    assert(!ambiguousExternal.callResolved,
           " call hir matrix: ambiguous external unresolved")
    assert(ambiguousExternal.callReason == parser.NormalizedExprCallReasonAmbiguousExternalTarget,
           " call hir matrix: ambiguous external reason")
    assert(ambiguousExternal.callTargetSourcePath == "",
           " call hir matrix: ambiguous external target empty")

    var aliasVisibilityParsed: parser.ParsedSourceStub
    err = ""
    assert(parser.ParseOrdinarySourceStub(packageRoot, aliasVisibilityFixturePath, aliasVisibilityParsed, err),
           " call hir matrix: alias visibility stub")
    let aliasVisibleExternal = findCallExpr(aliasVisibilityParsed.normalizedExprLayer, aliasVisibilityFixturePath, 5)
    assert(aliasVisibleExternal.exprId != "", " call hir matrix: alias visibility external call")
    assert(parser.NormalizedExprCallSurfaceKind(aliasVisibleExternal) == parser.NormalizedExprSurfaceCallExternal,
           " call hir matrix: alias visibility kind")
    assert(aliasVisibleExternal.callResolved,
           " call hir matrix: alias visibility resolved")
    assert(aliasVisibleExternal.callTargetSourcePath == helperBPath,
           " call hir matrix: alias visibility target source")

    var localShadowParsed: parser.ParsedSourceStub
    err = ""
    assert(parser.ParseOrdinarySourceStub(packageRoot, localShadowFixturePath, localShadowParsed, err),
           " call hir matrix: local shadow stub")
    let localShadowCall = findCallExpr(localShadowParsed.normalizedExprLayer, localShadowFixturePath, 7)
    assert(localShadowCall.exprId != "", " call hir matrix: local shadow call")
    assert(countCallExprs(localShadowParsed.normalizedExprLayer, localShadowFixturePath, 7) == 1,
           " call hir matrix: local shadow single call expr")
    assert(parser.NormalizedExprCallSurfaceKind(localShadowCall) == parser.NormalizedExprSurfaceCallLocal,
           " call hir matrix: local shadow kind")
    assert(localShadowCall.callResolved,
           " call hir matrix: local shadow resolved")
    assert(localShadowCall.callTargetSourcePath == localShadowFixturePath,
           " call hir matrix: local shadow target source")

    var qualifiedLocalShadowParsed: parser.ParsedSourceStub
    err = ""
    assert(parser.ParseOrdinarySourceStub(packageRoot, qualifiedLocalShadowFixturePath, qualifiedLocalShadowParsed, err),
           " call hir matrix: qualified local shadow stub")
    let paramShadowCall = findCallExpr(qualifiedLocalShadowParsed.normalizedExprLayer, qualifiedLocalShadowFixturePath, 4)
    let localQualifiedShadowCall = findCallExpr(qualifiedLocalShadowParsed.normalizedExprLayer, qualifiedLocalShadowFixturePath, 8)
    assert(paramShadowCall.exprId != "", " call hir matrix: qualified param shadow call")
    assert(localQualifiedShadowCall.exprId != "", " call hir matrix: qualified local shadow call")
    assert(countCallExprs(qualifiedLocalShadowParsed.normalizedExprLayer, qualifiedLocalShadowFixturePath, 4) == 1,
           " call hir matrix: qualified param shadow single call expr")
    assert(countCallExprs(qualifiedLocalShadowParsed.normalizedExprLayer, qualifiedLocalShadowFixturePath, 8) == 1,
           " call hir matrix: qualified local shadow single call expr")
    assert(parser.NormalizedExprCallSurfaceKind(paramShadowCall) == parser.NormalizedExprSurfaceCallMember,
           " call hir matrix: qualified param shadow kind")
    assert(parser.NormalizedExprCallSurfaceKind(localQualifiedShadowCall) == parser.NormalizedExprSurfaceCallMember,
           " call hir matrix: qualified local shadow kind")
    assert(!paramShadowCall.callResolved,
           " call hir matrix: qualified param shadow unresolved")
    assert(!localQualifiedShadowCall.callResolved,
           " call hir matrix: qualified local shadow unresolved")
    assert(paramShadowCall.callReason == parser.NormalizedExprCallReasonShadowedQualifiedTarget,
           " call hir matrix: qualified param shadow reason")
    assert(localQualifiedShadowCall.callReason == parser.NormalizedExprCallReasonShadowedQualifiedTarget,
           " call hir matrix: qualified local shadow reason")

    var qualifiedAmbiguousParsed: parser.ParsedSourceStub
    err = ""
    assert(parser.ParseOrdinarySourceStub(packageRoot, qualifiedAmbiguousFixturePath, qualifiedAmbiguousParsed, err),
           " call hir matrix: qualified ambiguous stub")
    let qualifiedAmbiguousExternal = findCallExpr(qualifiedAmbiguousParsed.normalizedExprLayer, qualifiedAmbiguousFixturePath, 5)
    assert(qualifiedAmbiguousExternal.exprId != "", " call hir matrix: qualified ambiguous external call")
    assert(parser.NormalizedExprCallSurfaceKind(qualifiedAmbiguousExternal) == parser.NormalizedExprSurfaceCallExternal,
           " call hir matrix: qualified ambiguous kind")
    assert(!qualifiedAmbiguousExternal.callResolved,
           " call hir matrix: qualified ambiguous unresolved")
    assert(qualifiedAmbiguousExternal.callReason == parser.NormalizedExprCallReasonAmbiguousQualifiedTarget,
           " call hir matrix: qualified ambiguous reason")

    var qualifiedClosureVisibleParsed: parser.ParsedSourceStub
    err = ""
    assert(parser.ParseOrdinarySourceStub(packageRoot, qualifiedClosureVisibleFixturePath, qualifiedClosureVisibleParsed, err),
           " call hir matrix: qualified closure visible stub")
    let qualifiedClosureVisibleLocal = findCallExpr(qualifiedClosureVisibleParsed.normalizedExprLayer, qualifiedClosureVisibleFixturePath, 5)
    let qualifiedClosureVisibleImportc = findCallExpr(qualifiedClosureVisibleParsed.normalizedExprLayer, qualifiedClosureVisibleFixturePath, 6)
    assert(qualifiedClosureVisibleLocal.exprId != "", " call hir matrix: qualified closure visible local call")
    assert(qualifiedClosureVisibleImportc.exprId != "", " call hir matrix: qualified closure visible importc call")
    assert(parser.NormalizedExprCallSurfaceKind(qualifiedClosureVisibleLocal) == parser.NormalizedExprSurfaceCallExternal,
           " call hir matrix: qualified closure visible local kind")
    assert(parser.NormalizedExprCallSurfaceKind(qualifiedClosureVisibleImportc) == parser.NormalizedExprSurfaceCallExternal,
           " call hir matrix: qualified closure visible importc kind")
    assert(qualifiedClosureVisibleLocal.callResolved,
           " call hir matrix: qualified closure visible local resolved")
    assert(qualifiedClosureVisibleImportc.callResolved,
           " call hir matrix: qualified closure visible importc resolved")
    assert(qualifiedClosureVisibleLocal.callTargetSourcePath == qualifiedClosureVisibleLeafPath,
           " call hir matrix: qualified closure visible local target")
    assert(qualifiedClosureVisibleImportc.callTargetSourcePath == qualifiedClosureVisibleLeafPath,
           " call hir matrix: qualified closure visible importc target")
    assert(!qualifiedClosureVisibleLocal.callTargetImportc,
           " call hir matrix: qualified closure visible local importc flag")
    assert(qualifiedClosureVisibleImportc.callTargetImportc,
           " call hir matrix: qualified closure visible importc flag")

    var argsParsed: parser.ParsedSourceStub
    err = ""
    assert(parser.ParseOrdinarySourceStub(packageRoot, argsFixturePath, argsParsed, err),
           " call hir matrix: args fixture stub")
    let zeroArgCall = findCallExpr(argsParsed.normalizedExprLayer, argsFixturePath, 10)
    let multiArgCall = findCallExpr(argsParsed.normalizedExprLayer, argsFixturePath, 11)
    assert(zeroArgCall.exprId != "", " call hir matrix: zero arg call")
    assert(multiArgCall.exprId != "", " call hir matrix: multi arg call")
    assert(countCallExprs(argsParsed.normalizedExprLayer, argsFixturePath, 11) == 2,
           " call hir matrix: nested call in arg list")
    assert(!zeroArgCall.callPrefixStyle, " call hir matrix: zero arg paren style")
    assert(zeroArgCall.callArgCount == 0, " call hir matrix: zero arg count")
    assert(zeroArgCall.callArgsText == "", " call hir matrix: zero arg text")
    assert(!multiArgCall.callPrefixStyle, " call hir matrix: multi arg paren style")
    assert(multiArgCall.callArgCount == 2, " call hir matrix: multi arg count")
    assert(multiArgCall.callArgsText == "payload, typedhelper.TypedExternalEcho(payload)",
           " call hir matrix: multi arg text")

    var closureVisibleParsed: parser.ParsedSourceStub
    err = ""
    assert(parser.ParseOrdinarySourceStub(packageRoot, closureVisibleFixturePath, closureVisibleParsed, err),
           " call hir matrix: closure visible stub")
    let closureVisibleLocal = findCallExpr(closureVisibleParsed.normalizedExprLayer, closureVisibleFixturePath, 5)
    let closureVisibleImportc = findCallExpr(closureVisibleParsed.normalizedExprLayer, closureVisibleFixturePath, 6)
    assert(closureVisibleLocal.exprId != "", " call hir matrix: closure visible local call")
    assert(closureVisibleImportc.exprId != "", " call hir matrix: closure visible importc call")
    assert(parser.NormalizedExprCallSurfaceKind(closureVisibleLocal) == parser.NormalizedExprSurfaceCallExternal,
           " call hir matrix: closure visible local kind")
    assert(parser.NormalizedExprCallSurfaceKind(closureVisibleImportc) == parser.NormalizedExprSurfaceCallExternal,
           " call hir matrix: closure visible importc kind")
    assert(closureVisibleLocal.callResolved,
           " call hir matrix: closure visible local resolved")
    assert(closureVisibleImportc.callResolved,
           " call hir matrix: closure visible importc resolved")
    assert(closureVisibleLocal.callTargetSourcePath == closureVisibleLeafPath,
           " call hir matrix: closure visible local target")
    assert(closureVisibleImportc.callTargetSourcePath == closureVisibleLeafPath,
           " call hir matrix: closure visible importc target")
    assert(!closureVisibleLocal.callTargetImportc,
           " call hir matrix: closure visible local importc flag")
    assert(closureVisibleImportc.callTargetImportc,
           " call hir matrix: closure visible importc flag")

    let typedFixturePath = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let typedOutputPath = chengpath.PathJoin(outDir, "typed_expr_fact_fixture")
    let typedCsg = buildCsg(workspaceRoot, packageRoot, typedFixturePath, typedOutputPath, creq.EmitShared)
    let typedFacts = texpr.TypedExprFactsForSource(typedCsg.typedExprFacts, typedFixturePath)
    assert(typedFacts.len > 0, " call hir matrix: typed facts slice")
    assertTypedCallFactsMatchLayer(typedCsg.typedExprFacts, typedCsg.exprLayer, " call hir matrix: typed fixture")
    let typedReq = creq.CompilerRequestNew(
        packageRoot,
        typedFixturePath,
        typedOutputPath,
        "arm64-apple-darwin",
        creq.EmitShared,
        ""
    )
    var typedLinkPlan: slplan.SystemLinkPlanStub
    err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, typedReq, typedLinkPlan, err),
           " call hir matrix: typed fixture link plan")
    let typedSourceTexts = buildSourceTexts(workspaceRoot, packageRoot, typedLinkPlan.sourceClosurePaths)
    assert(typedSourceTexts.len == typedLinkPlan.sourceClosurePaths.len,
           " call hir matrix: typed source text count")
    let closureVisibleOutputPath = chengpath.PathJoin(outDir, "call_hir_closure_visible_fixture")
    let closureVisibleCsg = buildCsg(workspaceRoot, packageRoot, closureVisibleFixturePath, closureVisibleOutputPath, creq.EmitExe)
    let closureVisibleFacts = texpr.TypedExprFactsForSource(closureVisibleCsg.typedExprFacts, closureVisibleFixturePath)
    assert(closureVisibleFacts.len > 0, " call hir matrix: closure visible facts slice")
    assertTypedCallFactsMatchLayer(closureVisibleCsg.typedExprFacts, closureVisibleCsg.exprLayer, " call hir matrix: closure visible fixture")
    let argsOutputPath = chengpath.PathJoin(outDir, "call_hir_args_fixture")
    let argsCsg = buildCsg(workspaceRoot, packageRoot, argsFixturePath, argsOutputPath, creq.EmitExe)
    let argsFacts = texpr.TypedExprFactsForSource(argsCsg.typedExprFacts, argsFixturePath)
    assert(argsFacts.len > 0, " call hir matrix: args facts slice")
    assertTypedCallFactsMatchLayer(argsCsg.typedExprFacts, argsCsg.exprLayer, " call hir matrix: args fixture")
    let qualifiedClosureVisibleOutputPath = chengpath.PathJoin(outDir, "call_hir_qualified_closure_visible_fixture")
    let qualifiedClosureVisibleCsg = buildCsg(workspaceRoot, packageRoot, qualifiedClosureVisibleFixturePath, qualifiedClosureVisibleOutputPath, creq.EmitExe)
    let qualifiedClosureVisibleFacts = texpr.TypedExprFactsForSource(qualifiedClosureVisibleCsg.typedExprFacts, qualifiedClosureVisibleFixturePath)
    assert(qualifiedClosureVisibleFacts.len > 0, " call hir matrix: qualified closure visible facts slice")
    assertTypedCallFactsMatchLayer(qualifiedClosureVisibleCsg.typedExprFacts, qualifiedClosureVisibleCsg.exprLayer, " call hir matrix: qualified closure visible fixture")
    let parserReasonCsg = buildCsg(workspaceRoot,
                                   packageRoot,
                                   parserFixturePath,
                                   chengpath.PathJoin(outDir, "parser_normalized_expr_fixture_report"),
                                   creq.EmitShared)
    assertTypedCallFactsMatchLayer(parserReasonCsg.typedExprFacts, parserReasonCsg.exprLayer, " call hir matrix: parser fixture compiler csg")
    assertCallReasonReport(parserReasonCsg.exprLayer,
                           ccsg.CompilerCsgReport(parserReasonCsg),
                           parser.NormalizedExprCallReasonUnknownQualifiedTarget,
                           " call hir matrix: parser fixture compiler csg")
    let reasonReportCsg = buildCsg(workspaceRoot,
                                   packageRoot,
                                   reasonFixturePath,
                                   chengpath.PathJoin(outDir, "call_hir_reason_fixture_report"),
                                   creq.EmitShared)
    assertTypedCallFactsMatchLayer(reasonReportCsg.typedExprFacts, reasonReportCsg.exprLayer, " call hir matrix: reason fixture compiler csg")
    assertCallReasonReport(reasonReportCsg.exprLayer,
                           ccsg.CompilerCsgReport(reasonReportCsg),
                           parser.NormalizedExprCallReasonAmbiguousExternalTarget,
                           " call hir matrix: reason fixture compiler csg")
    let qualifiedLocalShadowPlan = buildPlan(workspaceRoot,
                                             packageRoot,
                                             qualifiedLocalShadowFixturePath,
                                             chengpath.PathJoin(outDir, "call_hir_qualified_local_shadow_fixture_report"),
                                             creq.EmitShared)
    assertTypedCallFactsMatchLayer(qualifiedLocalShadowPlan.typedExprFacts, qualifiedLocalShadowPlan.exprLayer, " call hir matrix: qualified local shadow lowering plan")
    assertCallReasonReport(qualifiedLocalShadowPlan.exprLayer,
                           lower.LoweringPlanStubReport(qualifiedLocalShadowPlan),
                           parser.NormalizedExprCallReasonShadowedQualifiedTarget,
                           " call hir matrix: qualified local shadow lowering plan")
    let qualifiedAmbiguousPlan = buildPlan(workspaceRoot,
                                           packageRoot,
                                           qualifiedAmbiguousFixturePath,
                                           chengpath.PathJoin(outDir, "call_hir_qualified_ambiguous_fixture_report"),
                                           creq.EmitShared)
    assertTypedCallFactsMatchLayer(qualifiedAmbiguousPlan.typedExprFacts, qualifiedAmbiguousPlan.exprLayer, " call hir matrix: qualified ambiguous lowering plan")
    assertCallReasonReport(qualifiedAmbiguousPlan.exprLayer,
                           lower.LoweringPlanStubReport(qualifiedAmbiguousPlan),
                           parser.NormalizedExprCallReasonAmbiguousQualifiedTarget,
                           " call hir matrix: qualified ambiguous lowering plan")

    let helperPath = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_helper.cheng")
    let helperPlainPath = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_helper_plain.cheng")
    let helperImportcPath = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_importc_helper.cheng")

    let localImportc = findCallExpr(typedCsg.exprLayer, typedFixturePath, 26)
    let localCall = findCallExpr(typedCsg.exprLayer, typedFixturePath, 27)
    let aliasExternal = findCallExpr(typedCsg.exprLayer, typedFixturePath, 28)
    let moduleStemExternal = findCallExpr(typedCsg.exprLayer, typedFixturePath, 29)
    let nestedExternal = findCallExpr(typedCsg.exprLayer, typedFixturePath, 30)
    let aliasImportcExternal = findCallExpr(typedCsg.exprLayer, typedFixturePath, 32)
    let nestedImportcExternal = findCallExpr(typedCsg.exprLayer, typedFixturePath, 33)

    assert(localImportc.callResolved,
           " call hir matrix: local importc resolved")
    assert(localImportc.callTargetImportc,
           " call hir matrix: local importc flag")
    assert(localCall.callResolved,
           " call hir matrix: local function resolved")
    assert(aliasExternal.callResolved,
           " call hir matrix: alias external resolved")
    assert(moduleStemExternal.callResolved,
           " call hir matrix: module stem external resolved")
    assert(nestedExternal.callResolved,
           " call hir matrix: nested external resolved")
    assert(aliasImportcExternal.callResolved,
           " call hir matrix: alias importc external resolved")
    assert(nestedImportcExternal.callResolved,
           " call hir matrix: nested importc external resolved")

    assert(aliasExternal.callTargetSourcePath == helperPath,
           " call hir matrix: alias external target")
    assert(moduleStemExternal.callTargetSourcePath == helperPlainPath,
           " call hir matrix: module stem external target")
    assert(nestedExternal.callTargetSourcePath == helperPlainPath,
           " call hir matrix: nested external target")
    assert(aliasImportcExternal.callTargetSourcePath == helperImportcPath,
           " call hir matrix: alias importc target")
    assert(nestedImportcExternal.callTargetSourcePath == helperImportcPath,
           " call hir matrix: nested importc target")
    assert(aliasImportcExternal.callTargetImportc,
           " call hir matrix: alias importc flag")
    assert(nestedImportcExternal.callTargetImportc,
           " call hir matrix: nested importc flag")

    let typedAliasExternalFact = findTypedFact(typedFacts, typedFixturePath, 28)
    let typedAliasImportcFact = findTypedFact(typedFacts, typedFixturePath, 32)
    let typedNestedImportcFact = findTypedFact(typedFacts, typedFixturePath, 33)
    let typedZeroArgFact = findTypedFact(argsFacts, argsFixturePath, 10)
    let typedMultiArgFact = findTypedFact(argsFacts, argsFixturePath, 11)
    let closureVisibleLocalFact = findTypedFact(closureVisibleFacts, closureVisibleFixturePath, 5)
    let qualifiedClosureVisibleImportcFact = findTypedFact(qualifiedClosureVisibleFacts, qualifiedClosureVisibleFixturePath, 6)
    assert(typedAliasExternalFact.exprId != "", " call hir matrix: typed alias external fact")
    assert(typedAliasImportcFact.exprId != "", " call hir matrix: typed alias importc fact")
    assert(typedNestedImportcFact.exprId != "", " call hir matrix: typed nested importc fact")
    assert(typedZeroArgFact.exprId != "", " call hir matrix: typed zero arg fact")
    assert(typedMultiArgFact.exprId != "", " call hir matrix: typed multi arg fact")
    assert(closureVisibleLocalFact.exprId != "", " call hir matrix: closure visible local fact")
    assert(qualifiedClosureVisibleImportcFact.exprId != "", " call hir matrix: qualified closure visible importc fact")
    assert(typedAliasExternalFact.callResolved, " call hir matrix: typed alias external resolved")
    assert(typedAliasExternalFact.callQualifier == aliasExternal.callQualifier, " call hir matrix: typed alias external qualifier")
    assert(typedAliasExternalFact.callCallee == aliasExternal.callCallee, " call hir matrix: typed alias external callee")
    assert(typedAliasExternalFact.callTarget == aliasExternal.callTarget, " call hir matrix: typed alias external target")
    assert(typedAliasExternalFact.callTargetSourcePath == helperPath, " call hir matrix: typed alias external target source")
    assert(!typedAliasExternalFact.callTargetImportc, " call hir matrix: typed alias external importc flag")
    assert(typedAliasImportcFact.callResolved, " call hir matrix: typed alias importc resolved")
    assert(typedAliasImportcFact.callQualifier == aliasImportcExternal.callQualifier, " call hir matrix: typed alias importc qualifier")
    assert(typedAliasImportcFact.callCallee == aliasImportcExternal.callCallee, " call hir matrix: typed alias importc callee")
    assert(typedAliasImportcFact.callTarget == aliasImportcExternal.callTarget, " call hir matrix: typed alias importc target")
    assert(typedAliasImportcFact.callTargetSourcePath == helperImportcPath, " call hir matrix: typed alias importc target source")
    assert(typedAliasImportcFact.callTargetImportc, " call hir matrix: typed alias importc flag")
    assert(typedNestedImportcFact.callResolved, " call hir matrix: typed nested importc resolved")
    assert(typedNestedImportcFact.callQualifier == nestedImportcExternal.callQualifier, " call hir matrix: typed nested importc qualifier")
    assert(typedNestedImportcFact.callCallee == nestedImportcExternal.callCallee, " call hir matrix: typed nested importc callee")
    assert(typedNestedImportcFact.callTarget == nestedImportcExternal.callTarget, " call hir matrix: typed nested importc target")
    assert(!typedZeroArgFact.callPrefixStyle, " call hir matrix: typed zero arg paren style")
    assert(typedZeroArgFact.callArgCount == 0, " call hir matrix: typed zero arg count")
    assert(typedZeroArgFact.callArgsText == "", " call hir matrix: typed zero arg text")
    assert(!typedMultiArgFact.callPrefixStyle, " call hir matrix: typed multi arg paren style")
    assert(typedMultiArgFact.callArgCount == 2, " call hir matrix: typed multi arg count")
    assert(typedMultiArgFact.callArgsText == "payload, typedhelper.TypedExternalEcho(payload)",
           " call hir matrix: typed multi arg text")
    assert(closureVisibleLocalFact.callQualifier == closureVisibleLocal.callQualifier, " call hir matrix: closure visible local qualifier")
    assert(closureVisibleLocalFact.callCallee == closureVisibleLocal.callCallee, " call hir matrix: closure visible local callee")
    assert(closureVisibleLocalFact.callTarget == closureVisibleLocal.callTarget, " call hir matrix: closure visible local target")
    assert(closureVisibleLocalFact.callTargetSourcePath == closureVisibleLeafPath, " call hir matrix: closure visible local target source")
    assert(!closureVisibleLocalFact.callTargetImportc, " call hir matrix: closure visible local importc flag")
    assert(qualifiedClosureVisibleImportcFact.callQualifier == qualifiedClosureVisibleImportc.callQualifier, " call hir matrix: qualified closure visible importc qualifier")
    assert(qualifiedClosureVisibleImportcFact.callCallee == qualifiedClosureVisibleImportc.callCallee, " call hir matrix: qualified closure visible importc callee")
    assert(qualifiedClosureVisibleImportcFact.callTarget == qualifiedClosureVisibleImportc.callTarget, " call hir matrix: qualified closure visible importc target")
    assert(qualifiedClosureVisibleImportcFact.callTargetSourcePath == qualifiedClosureVisibleLeafPath, " call hir matrix: qualified closure visible importc target source")
    assert(qualifiedClosureVisibleImportcFact.callTargetImportc, " call hir matrix: qualified closure visible importc flag")

    assert(texpr.TypedExprFactsHasLineUsingImportBuffer(typedFacts,
                                                         typedFixturePath,
                                                         26),
           " call hir matrix: local importc import buffer")
    assert(texpr.TypedExprFactsHasLineUsingLocalAddressCompositeLocal(typedFacts,
                                                                       typedFixturePath,
                                                                       27),
           " call hir matrix: local composite call")
    assert(texpr.TypedExprFactsHasLineUsingImportBuffer(typedFacts,
                                                         typedFixturePath,
                                                         32),
           " call hir matrix: alias importc external import buffer")
    assert(texpr.TypedExprFactsHasLineUsingImportBuffer(typedFacts,
                                                         typedFixturePath,
                                                         33),
           " call hir matrix: nested importc external import buffer")
    assert(texpr.TypedExprAbiPolymorphicCount(typedFacts) == 0,
           " call hir matrix: no abi polymorphic")
    assert(texpr.TypedExprLowerDeferredCount(typedFacts) == 0,
           " call hir matrix: no deferred lowering")
    assert(texpr.TypedExprFactsHasLineUsingRegReturnReg(closureVisibleFacts,
                                                         closureVisibleFixturePath,
                                                         5),
           " call hir matrix: closure visible local lowering")
    assert(texpr.TypedExprFactsHasLineUsingImportBuffer(closureVisibleFacts,
                                                         closureVisibleFixturePath,
                                                         6),
           " call hir matrix: closure visible importc lowering")
    assert(texpr.TypedExprAbiPolymorphicCount(closureVisibleFacts) == 0,
           " call hir matrix: closure visible no abi polymorphic")
    assert(texpr.TypedExprLowerDeferredCount(closureVisibleFacts) == 0,
           " call hir matrix: closure visible no deferred lowering")
    assert(texpr.TypedExprFactsHasLineUsingRegReturnReg(qualifiedClosureVisibleFacts,
                                                         qualifiedClosureVisibleFixturePath,
                                                         5),
           " call hir matrix: qualified closure visible local lowering")
    assert(texpr.TypedExprFactsHasLineUsingImportBuffer(qualifiedClosureVisibleFacts,
                                                         qualifiedClosureVisibleFixturePath,
                                                         6),
           " call hir matrix: qualified closure visible importc lowering")
    assert(texpr.TypedExprAbiPolymorphicCount(qualifiedClosureVisibleFacts) == 0,
           " call hir matrix: qualified closure visible no abi polymorphic")
    assert(texpr.TypedExprLowerDeferredCount(qualifiedClosureVisibleFacts) == 0,
           " call hir matrix: qualified closure visible no deferred lowering")

    echo(" call_hir_matrix_smoke ok")
    return 0
