import std/system
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/host/host
import cheng/libp2p/transports/tailnet_transport as tsnet
import cheng/tests/smoke_ports
import std/strutils as strutil

fn main(): int32 =
    var cfg: tsnet.Libp2pTailnetTransportConfig
    cfg.controlUrl = "https://headscale.example"
    cfg.controlEndpoint = "https://headscale.example/control"
    cfg.relayEndpoint = "https://derp.sfo.example:443"
    cfg.controlProbeEndpoint = "testdata/tailnet/headscale_control_ready.json"
    cfg.relayProbeEndpoint = "testdata/tailnet/derp_ready.json"
    cfg.syntheticIPv4 = "100.64.1.9"
    cfg.syntheticIPv6 = "fd7a:115c:a1e0::109"
    cfg.localPeerId = "tailnet-derp-smoke"
    tsnet.Libp2pTailnetConfigSetHeadscale(cfg,
                                            "infra",
                                            "noise-pub-001",
                                            12,
                                            "sfo",
                                            "San Francisco",
                                            "derp.sfo.example",
                                            true)

    var transport = tsnet.Libp2pTailnetTransportInit(cfg)
    var peerA: tsnet.Libp2pTailnetPeerSession
    peerA.peerId = "peer-a"
    peerA.remoteTailnetIp = "100.64.1.21"
    peerA.directReachable = true
    peerA.relayAllowed = true
    peerA.derpRegionCode = "sfo"
    peerA.signedPreface = "preface-a"
    peerA.boundAddrText = strutil.Join(["/ip4/10.0.0.21/udp/", IntToStr(smoke_ports.SmokeLabelPort(7202)), "/quic-v1"], "")
    tsnet.Libp2pTailnetUpsertPeerSession(transport, peerA)
    tsnet.Libp2pTailnetUpsertPeerSession(transport, peerA)
    var peerB: tsnet.Libp2pTailnetPeerSession
    peerB.peerId = "peer-b"
    peerB.remoteTailnetIp = "100.64.1.22"
    peerB.relayAllowed = true
    peerB.relayOnly = true
    peerB.derpRegionCode = "sfo"
    peerB.signedPreface = "preface-b"
    peerB.boundAddrText = "/ip4/10.0.0.22/udp/7203/quic-v1"
    tsnet.Libp2pTailnetUpsertPeerSession(transport, peerB)
    tsnet.Libp2pTailnetProviderStart(transport)
    tsnet.Libp2pTailnetProviderMarkProxyReady(transport)
    tsnet.Libp2pTailnetProviderReconnectDerp(transport)
    assert(tsnet.Libp2pTailnetProviderRuntimeActiveCountNow() == 1,
        " libp2p tailnet derp: runtime active")

    var rawQuic: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(rawQuic, "127.0.0.1", smoke_ports.SmokeLabelPort(7202))
    let listenRes = tsnet.Libp2pTailnetListen(transport, rawQuic)
    assert(IsOk(listenRes), " libp2p tailnet derp: listen")

    assert(!tsnet.Libp2pTailnetDerpAvailable(transport),
        " libp2p tailnet derp: reconnect clears derp")

    var published = tsnet.Libp2pTailnetPublishedAddrs(transport)
    let reconnectPlanBuild = tsnet.Libp2pTailnetDialPlanBuild(transport,
                                                                "peer-b",
                                                                published[0],
                                                                true,
                                                                false)
    assert(!reconnectPlanBuild.ok, " libp2p tailnet derp: reconnect blocks relay-only peer")
    let reconnectPlan = reconnectPlanBuild.plan
    assert(reconnectPlan.pathKind == tsnet.Libp2pTailnetPathIdle,
        " libp2p tailnet derp: reconnect idle path")

    tsnet.Libp2pTailnetProviderDerpReady(transport)

    var status: tsnet.Libp2pTailnetStatusSnapshot
    tsnet.Libp2pTailnetStatusFill(status, transport)
    assert(status.providerLabel == "headscale", " libp2p tailnet derp: provider")
    assert(status.controlPlane == "headscale", " libp2p tailnet derp: control plane")
    assert(status.exactRouting, " libp2p tailnet derp: exact routing")
    assert(status.relayHealthy, " libp2p tailnet derp: relay healthy")
    assert(status.derpRegionCode == "sfo", " libp2p tailnet derp: region code")
    assert(status.derpHostname == "derp.sfo.example", " libp2p tailnet derp: hostname")
    assert(status.tailnetPath == "direct+derp", " libp2p tailnet derp: path")
    assert(status.sessionCount == 2, " libp2p tailnet derp: session count")
    assert(status.tailnetPeers.len == 2, " libp2p tailnet derp: peer sessions")
    assert(status.proxyListenersReady, " libp2p tailnet derp: proxy listeners ready")
    assert(status.publishedCount == 1, " libp2p tailnet derp: published count")
    assert(status.tailnetDerpMapSummary == "headscale/infra@https://headscale.example#sfo/derp.sfo.example",
        " libp2p tailnet derp: derp summary")
    assert(tsnet.Libp2pTailnetProviderUsesExactRouting(transport),
        " libp2p tailnet derp: exact routing helper")
    assert(tsnet.Libp2pTailnetDerpAvailable(transport),
        " libp2p tailnet derp: derp available helper")
    assert(status.startupStage == "derp-ready",
        " libp2p tailnet derp: startup stage")

    let derpPlanBuild = tsnet.Libp2pTailnetDialPlanBuild(transport,
                                                           "peer-b",
                                                           published[0],
                                                           true,
                                                           false)
    assert(derpPlanBuild.ok, " libp2p tailnet derp: relay plan")
    let derpPlan = derpPlanBuild.plan
    assert(derpPlan.pathKind == tsnet.Libp2pTailnetPathDerp,
        " libp2p tailnet derp: relay path")
    assert(derpPlan.reachability == types.Libp2pReachabilityRelayed,
        " libp2p tailnet derp: relay reachability plan")
    assert(derpPlan.routeText == "https://derp.sfo.example:443",
        " libp2p tailnet derp: relay route text")

    var trustedHost = host.Libp2pHostInit("tailnet.derp.trusted")
    host.Libp2pHostSetTrustedInfra(trustedHost, true)

    let mixedPeer = peer_id.Libp2pPeerIdFromSeed("tailnet.derp.mixed")
    var publicAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(publicAddr, "198.51.100.88", 7301)
    multiaddr.Libp2pMultiaddrSetRoutingMeta(publicAddr,
                                              types.Libp2pNetworkDomainPublic,
                                              types.Libp2pVisibilityPublic,
                                              100)
    var tailnetAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(tailnetAddr, "100.64.1.88", 7302)
    multiaddr.Libp2pMultiaddrSetRoutingMeta(tailnetAddr,
                                              types.Libp2pNetworkDomainTailnet,
                                              types.Libp2pVisibilityTrustedOnly,
                                              900)

    var mixedRecord: ps.Libp2pPeerRecord
    mixedRecord.peerId = mixedPeer
    mixedRecord.trustedInfra = true
    ps.Libp2pPeerRecordPutEndpoint(mixedRecord,
                                     tailnetAddr,
                                     false,
                                     types.Libp2pReachabilityRelayed,
                                     tailnetAddr.priority)
    ps.Libp2pPeerRecordPutEndpoint(mixedRecord,
                                     publicAddr,
                                     false,
                                     types.Libp2pReachabilityDirect,
                                     publicAddr.priority)
    ps.Libp2pPeerstoreUpsert(trustedHost.peers, mixedRecord)

    var mixedEndpoint: ps.Libp2pPeerEndpoint
    let mixedRes = host.Libp2pSelectPeerEndpoint(trustedHost, mixedPeer, mixedEndpoint)
    assert(IsOk(mixedRes), " libp2p tailnet derp: mixed select")
    assert(mixedEndpoint.addr.networkDomain == types.Libp2pNetworkDomainPublic,
        " libp2p tailnet derp: relay stays behind public direct")
    assert(mixedEndpoint.reachability == types.Libp2pReachabilityDirect,
        " libp2p tailnet derp: public stays direct")

    let relayPeer = peer_id.Libp2pPeerIdFromSeed("tailnet.derp.only")
    var relayRecord: ps.Libp2pPeerRecord
    relayRecord.peerId = relayPeer
    relayRecord.trustedInfra = true
    ps.Libp2pPeerRecordPutEndpoint(relayRecord,
                                     tailnetAddr,
                                     false,
                                     types.Libp2pReachabilityRelayed,
                                     tailnetAddr.priority)
    ps.Libp2pPeerstoreUpsert(trustedHost.peers, relayRecord)

    var relayEndpoint: ps.Libp2pPeerEndpoint
    let relayRes = host.Libp2pSelectPeerEndpoint(trustedHost, relayPeer, relayEndpoint)
    assert(IsOk(relayRes), " libp2p tailnet derp: relay select")
    assert(relayEndpoint.addr.networkDomain == types.Libp2pNetworkDomainTailnet,
        " libp2p tailnet derp: relay path remains tailnet")
    assert(relayEndpoint.reachability == types.Libp2pReachabilityRelayed,
        " libp2p tailnet derp: relay reachability")

    tsnet.Libp2pTailnetProviderMarkListenerRepairNeeded(transport)
    var repairStatus: tsnet.Libp2pTailnetStatusSnapshot
    tsnet.Libp2pTailnetStatusFill(repairStatus, transport)
    assert(repairStatus.tailnetPath == "repair", " libp2p tailnet derp: repair path")
    assert(tsnet.Libp2pTailnetProviderRuntimeCommandCountNow() == 5,
        " libp2p tailnet derp: runtime commands")

    echo(" libp2p_tailnet_derp_smoke ok")
    return 0
