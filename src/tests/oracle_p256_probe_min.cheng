import std/system
import std/result
import std/crypto/ecnist
import cheng/oracle/oracle_plane
import cheng/std/bytes_layout as layout
import cheng/std/crypto/fixed256
import cheng/tests/oracle_smoke_support as support

fn main(): int32 =
    echo("p256 probe: start")
    let committee = support.oracleSmokeCommittee()
    echo("p256 probe: committee")
    let batch = support.oracleSmokeBatch(int64(12), 1)
    echo("p256 probe: batch")
    assert(batch.reporterSlot == 1, "p256 probe: reporter slot")
    let pubKey = committee.reporterPubKeys[batch.reporterSlot - 1]
    echo("p256 probe: pubkey")
    assert(int32(pubKey.data[0]) == 0x04, "p256 probe: pubkey prefix")
    assert(int32(batch.sig.data[0]) >= 0, "p256 probe: sig byte0")
    echo("p256 probe: raw bytes ok")
    let pubBytes = layout.FixedBytes65ToBytes(pubKey)
    assert(len(pubBytes) == 65, "p256 probe: pub bytes len")
    echo("p256 probe: pub bytes")
    let sigBytes = layout.FixedBytes64ToBytes(batch.sig)
    assert(len(sigBytes) == 64, "p256 probe: sig bytes len")
    echo("p256 probe: sig bytes")
    let signableWireRes = oracle_plane.OracleSignedBatchSignableBytes(batch)
    assert(IsOk(signableWireRes), "p256 probe: signable")
    assert(len(Value(signableWireRes)) > 0, "p256 probe: signable len")
    echo("p256 probe: signable")
    let verifyTrusted = ecnist.ecdsaVerifyTrustedBytes(pubBytes, Value(signableWireRes), sigBytes)
    assert(verifyTrusted, "p256 probe: verify trusted")
    let verifyDirectRes = fixed256.p256VerifyMessageFixed64(pubKey, Value(signableWireRes), batch.sig)
    assert(IsOk(verifyDirectRes), "p256 probe: verify direct")
    echo("p256 probe: done")
    return 0
