import std/os
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/path_absolute_probe")
    if !chengpath.PathNonEmpty(outDir):
        echo("path-nonempty-bad")
        return 1
    echo(outDir)
    return 0
