module readfile_probe
import std/os as os
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let path = "/root/cheng-lang/src/tests/hello_pure_linux.cheng"
    let content = chengpath.ReadTextFile("", path)
    let exists = os.FileExists(path)
    os.Echo(Fmt"exists={exists}")
    os.Echo(Fmt"len={intToStr(len(content))}")
    if len(content) > 0:
        return 0
    return 1

main()
