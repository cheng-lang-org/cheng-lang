import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_rename_file_negative_smoke_tmp"
    let missingPath: str = os.JoinPath(tmpRoot, "missing.txt")
    let outPath: str = os.JoinPath(tmpRoot, "out.txt")
    if os.FileExists(outPath):
        assert(os.RemoveFile(outPath), " ordinary os.RenameFile negative cleanup out")
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)
    os.CreateDir(tmpRoot)
    let renamed = os.RenameFile(missingPath, outPath)
    assert(!renamed, " ordinary os.RenameFile missing source fails")
    assert(!os.FileExists(outPath), " ordinary os.RenameFile negative no output")
    os.RemoveDir(tmpRoot)
    echo(" os_rename_file_negative_smoke ok")
    return 0
