import std/os as os
import cheng/core/tooling/path as chengpath
import cheng/std/bytes_layout as layout
import cheng/apps/unimaker/unimaker_edge_types as types
import cheng/apps/unimaker/unimaker_edge_agent as agent
import std/strutils as strutil

fn unimakerRecoveryCleanup(tmpRoot: str) =
    let storePath = os.JoinPath(tmpRoot, "agent.did")
    let eventLogPath = os.JoinPath(tmpRoot, "events.jsonl")
    let eventLogTmpPath = strutil.Join([eventLogPath, ".tmp"], "")
    if os.FileExists(storePath):
        let _ = os.RemoveFile(storePath)
    if os.FileExists(eventLogPath):
        let _ = os.RemoveFile(eventLogPath)
    if os.FileExists(eventLogTmpPath):
        let _ = os.RemoveFile(eventLogTmpPath)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

fn main(): int32 =
    let tmpRoot = "artifacts/unimaker_edge_agent_recovery_smoke"
    unimakerRecoveryCleanup(tmpRoot)
    os.CreateDir(tmpRoot)

    var cfg = types.UnimakerAgentConfig()
    cfg.rootDir = chengpath.PathCurrentDir()
    cfg.eventLogPath = os.JoinPath(tmpRoot, "events.jsonl")
    cfg.identityStorePath = os.JoinPath(tmpRoot, "agent.did")
    cfg.rootSeedHint = "recover.root.seed"
    cfg.deviceSeedHint = "recover.phone.seed"
    cfg.deviceLabelHint = "phone"
    cfg.epochSeconds = int64(1712000000)

    var original = agent.UnimakerAgentInit(cfg)
    let eventA = types.UnimakerEventMake(types.UnimakerEventSystemNotice,
                                           "task.recovery",
                                           "app moved to background",
                                           ["recovery", "background"],
                                           [],
                                           types.UnimakerEdgeKindCausedBy,
                                           int64(1712000001))
    let capsuleARes = agent.UnimakerAgentIngest(original, eventA)
    assert(IsOk(capsuleARes), " unimaker recovery: ingest A")

    let capsuleA = Value(capsuleARes)
    let eventB = types.UnimakerEventMake(types.UnimakerEventNetworkMessage,
                                           "task.recovery",
                                           "remote sync acknowledged",
                                           ["recovery", "network"],
                                           [capsuleA.capsuleCid],
                                           types.UnimakerEdgeKindUsefulFor,
                                           int64(1712000002))
    let capsuleBRes = agent.UnimakerAgentIngest(original, eventB)
    assert(IsOk(capsuleBRes), " unimaker recovery: ingest B")
    let originalHead = agent.UnimakerAgentHeadCid(original)
    let originalCount = agent.UnimakerAgentCapsuleCount(original)
    let originalEdges = agent.UnimakerAgentEdgeCount(original)

    var reloaded = agent.UnimakerAgentInit(cfg)
    assert(agent.UnimakerAgentCapsuleCount(reloaded) == originalCount,
        " unimaker recovery: capsule count")
    assert(agent.UnimakerAgentEdgeCount(reloaded) == originalEdges,
        " unimaker recovery: edge count")
    assert(layout.FixedBytes32Equal(agent.UnimakerAgentHeadCid(reloaded), originalHead),
        " unimaker recovery: head cid")

    var query = types.MemoryQuery()
    query.taskId = "task.recovery"
    query.limit = 8
    let recallRes = agent.UnimakerAgentRecall(reloaded, query)
    assert(IsOk(recallRes), " unimaker recovery: recall")
    let recallHits = Value(recallRes)
    assert(recallHits.len == 2, " unimaker recovery: recall count")

    let capsuleB = Value(capsuleBRes)
    let followupEvent = types.UnimakerEventMake(types.UnimakerEventAppLifecycle,
                                                  "task.recovery",
                                                  "app returned to foreground",
                                                  ["recovery", "foreground"],
                                                  [capsuleB.capsuleCid],
                                                  types.UnimakerEdgeKindUsefulFor,
                                                  int64(1712000003))
    let followupRes = agent.UnimakerAgentIngest(reloaded, followupEvent)
    assert(IsOk(followupRes), " unimaker recovery: ingest after reload")
    assert(agent.UnimakerAgentCapsuleCount(reloaded) == 3, " unimaker recovery: final count")

    unimakerRecoveryCleanup(tmpRoot)
    echo(" unimaker_edge_agent_recovery_smoke ok")
    return 0
