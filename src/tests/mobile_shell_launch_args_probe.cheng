import std/monotimes
import std/os
import std/strings
import std/json as json
import cheng/core/tooling/mobile_shell_codegen as mshell
import cheng/core/tooling/path as chengpath

fn probeCStringLiteral(text: str): str =
    var out: str = "\""
    var i: int32
    while i < len(text):
        let ch: char = text[i]
        let code: int32 = int32(ch)
        if code == 92:
            out = Fmt"{out}\\\\"
        elif code == 34:
            out = Fmt"{out}\\\""
        elif code == 10:
            out = Fmt"{out}\\n"
        elif code == 13:
            out = Fmt"{out}\\r"
        elif code == 9:
            out = Fmt"{out}\\t"
        else:
            let piece: str = strings.CharToStr(ch)
            out = Fmt"{out}{piece}"
        i = i + 1
    return Fmt"{out}\""

fn probeLaunchArgsKv(routeState: str): str =
    return Fmt"gate_mode=android-semantic-visual-1to1;truth_mode=strict;route_state={routeState};route_lock=1;runtime_mode=r2c_native_gui_v1;runtime_manifest=runtime/mobile_shell_runtime_contract_v1.json;runtime_contract_payload=runtime/mobile_shell_runtime_contract_payload.json;runtime_bundle_payload=runtime/mobile_shell_runtime_bundle_payload.json"

fn probeLaunchArgsJson(routeState: str): str =
    var doc: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(doc, "format", "mobile_shell_launch_args_v1")
    json.JsonSetFieldStr(doc, "gate_mode", "android-semantic-visual-1to1")
    json.JsonSetFieldStr(doc, "truth_mode", "strict")
    json.JsonSetFieldStr(doc, "route_state", routeState)
    json.JsonSetFieldBool(doc, "route_lock", true)
    json.JsonSetFieldStr(doc, "runtime_mode", "r2c_native_gui_v1")
    json.JsonSetFieldStr(doc, "runtime_manifest", "runtime/mobile_shell_runtime_contract_v1.json")
    json.JsonSetFieldStr(doc, "runtime_contract_payload", "runtime/mobile_shell_runtime_contract_payload.json")
    json.JsonSetFieldStr(doc, "runtime_bundle_payload", "runtime/mobile_shell_runtime_bundle_payload.json")
    let rendered: str = json.Stringify(doc)
    return Fmt"{rendered}\n"

fn probeAndroidAugmentedHostSource(opts: var mshell.MobileShellOptions,
                                   kv: str,
                                   jsonText: str): str =
    let text: str = mshell.MobileShellAndroidHostSource(opts)
    let kvQuote: str = probeCStringLiteral(kv)
    let jsonQuote: str = probeCStringLiteral(jsonText)
    return Fmt"""
    {text}
    /* probe launch args begin */
    typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);
    static const char* kChengLaunchArgsKv = {kvQuote};
    static const char* kChengLaunchArgsJson = {jsonQuote};
    /* probe launch args end */

    """

fn probeIosAugmentedHostSource(opts: var mshell.MobileShellOptions,
                               kv: str,
                               jsonText: str): str =
    let text: str = mshell.MobileShellIosViewControllerImpl(opts)
    let kvQuote: str = probeCStringLiteral(kv)
    let jsonQuote: str = probeCStringLiteral(jsonText)
    return Fmt"""
    {text}
    /* probe launch args begin */
    typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);
    static const char* kChengLaunchArgsKv = {kvQuote};
    static const char* kChengLaunchArgsJson = {jsonQuote};
    /* probe launch args end */

    """

fn probeHarmonyAugmentedHostSource(opts: var mshell.MobileShellOptions,
                                   kv: str,
                                   jsonText: str): str =
    let text: str = mshell.MobileShellHarmonyHostSource(opts)
    let kvQuote: str = probeCStringLiteral(kv)
    let jsonQuote: str = probeCStringLiteral(jsonText)
    return Fmt"""
    {text}
    /* probe launch args begin */
    typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);
    static const char* kChengLaunchArgsKv = {kvQuote};
    static const char* kChengLaunchArgsJson = {jsonQuote};
    /* probe launch args end */

    """

fn writeProbeFile(path: str, text: str) =
    os.WriteFile(path, text)

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let stamp: str = int64ToStr(monotimes.MonoTimeNs(monotimes.GetMonoTime()))
    let outDir: str = Fmt"/tmp/cheng_mobile_shell_launch_args_probe_{stamp}"
    assert(chengpath.MkdirP(root, outDir), "mobile shell launch args probe: mkdir")
    var opts: mshell.MobileShellOptions = mshell.MobileShellDefaultOptions(root)
    opts.outDir = outDir
    opts.appId = "org.cheng.launchargs.probe"
    opts.appName = "ChengLaunchArgsProbe"
    opts.libName = "cheng_launch_args_probe_app"
    opts.runtimeMode = "r2c_native_gui_v1"
    opts.routeState = "home_default"
    let kv: str = probeLaunchArgsKv(opts.routeState)
    let jsonText: str = probeLaunchArgsJson(opts.routeState)
    assert(strings.StrContains(kv, "route_state=home_default"),
           "mobile shell launch args probe: kv route")
    assert(strings.StrContains(jsonText, "\"route_state\":\"home_default\""),
           "mobile shell launch args probe: json route")
    let androidText: str = probeAndroidAugmentedHostSource(opts, kv, jsonText)
    let iosText: str = probeIosAugmentedHostSource(opts, kv, jsonText)
    let harmonyText: str = probeHarmonyAugmentedHostSource(opts, kv, jsonText)
    assert(strings.StrContains(androidText, "kChengLaunchArgsKv"),
           "mobile shell launch args probe: android launch args symbol")
    assert(strings.StrContains(iosText, "kChengLaunchArgsJson"),
           "mobile shell launch args probe: ios launch args symbol")
    assert(strings.StrContains(harmonyText, "route_state=home_default"),
           "mobile shell launch args probe: harmony route text")
    writeProbeFile(os.JoinPath(outDir, "launch_args.kv.txt"), kv)
    writeProbeFile(os.JoinPath(outDir, "launch_args.json"), jsonText)
    writeProbeFile(os.JoinPath(outDir, "android_host_with_launch_args.c"), androidText)
    writeProbeFile(os.JoinPath(outDir, "ios_host_with_launch_args.m"), iosText)
    writeProbeFile(os.JoinPath(outDir, "harmony_host_with_launch_args.cpp"), harmonyText)
    echo(" mobile_shell_launch_args_probe ok")
    return 0
