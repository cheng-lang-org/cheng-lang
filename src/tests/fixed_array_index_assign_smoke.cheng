type
    SmallFixed =
        limbs: int32[8]

    LargeFixed =
        limbs: int32[256]

fn makeLargeFixed(): LargeFixed =
    var out: LargeFixed
    out.limbs[0] = 7
    out.limbs[255] = 9
    return out

fn main(): int32 =
    var small: SmallFixed
    small.limbs[0] = 11
    small.limbs[7] = 13
    let large: LargeFixed = makeLargeFixed()
    assert(small.limbs[0] == 11, "fixed array smoke small first")
    assert(small.limbs[7] == 13, "fixed array smoke small last")
    assert(large.limbs[0] == 7, "fixed array smoke large first")
    assert(large.limbs[255] == 9, "fixed array smoke large last")
    echo(" fixed_array_index_assign_smoke ok")
    return 0
