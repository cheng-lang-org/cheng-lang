import std/cmdline as cmdline
import std/os
import std/rawbytes
import std/rawmem_support
import std/result
import std/strutils as strutil
import std/net/transports/tcp_syscall as tcp
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

const
    vpnProxyTcpControlArtifactRel = "artifacts/vpn_proxy_tcp_control_bytes_smoke"

fn vpnProxyTcpControlArtifactDir(root: str): str =
    return chengpath.PathAbsolute(root, vpnProxyTcpControlArtifactRel)

fn vpnProxyTcpControlReadyPath(root: str): str =
    return chengpath.PathAbsolute(root, strutil.Join([vpnProxyTcpControlArtifactRel, "/server.ready"], ""))

fn vpnProxyTcpControlLogPath(root: str): str =
    return chengpath.PathAbsolute(root, strutil.Join([vpnProxyTcpControlArtifactRel, "/server.log"], ""))

fn vpnProxyTcpControlParsePort(textRaw: str): Result[int32] =
    let text: str = strutil.Strip(textRaw)
    if len(text) <= 0:
        return Err[int32](" vpn proxy tcp control smoke: empty port")
    var value: int32
    for i in 0..<len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int32](" vpn proxy tcp control smoke: invalid port")
        value = value * 10 + (int32(ch) - int32('0'))
    if value <= 0:
        return Err[int32](" vpn proxy tcp control smoke: invalid port value")
    return Ok[int32](value)

fn vpnProxyTcpControlReadExact(conn: var tcp.TcpConnectionHandle,
                               count: int32): Result[Bytes] =
    let out: Bytes = bytesAlloc(count)
    var filled: int32
    while filled < count:
        let dstPtr: ptr = rawmem_support.RawmemPtrAdd(out.data, filled)
        let readRes: Result[int32] = tcp.TcpRecvRaw(conn, dstPtr, count - filled)
        if IsErr(readRes):
            return Err[Bytes](ErrorText(readRes))
        let got: int32 = Value(readRes)
        if got <= 0:
            return Err[Bytes](" vpn proxy tcp control smoke: eof")
        filled = filled + got
    return Ok[Bytes](out)

fn vpnProxyTcpControlWriteAll(conn: var tcp.TcpConnectionHandle, data: var Bytes): Result[int32] =
    return tcp.TcpSendRaw(conn, data.data, bytesLen(data))

fn vpnProxyTcpControlMethodWireInto(out: var Bytes) =
    out = bytesAlloc(3)
    bytesSet(out, 0, 5)
    bytesSet(out, 1, 1)
    bytesSet(out, 2, 0)

fn vpnProxyTcpControlWaitReady(root: str,
                               readyPath: str,
                               proc: var hostops.SpawnedProcess): Result[int32] =
    for _attempt in 0..<500:
        if chengpath.FileExistsNonEmpty(root, readyPath):
            let parseRes: Result[int32] = vpnProxyTcpControlParsePort(chengpath.ReadTextFile("", readyPath))
            if IsOk(parseRes):
                return parseRes
        if !hostops.SpawnedProcessRunning(proc):
            return Err[int32](strutil.Join([" vpn proxy tcp control smoke: server exited early: ", proc.output], ""))
        os.SleepMs(10)
    return Err[int32](" vpn proxy tcp control smoke: ready timeout")

fn vpnProxyTcpControlRunServer(): int32 =
    let readyPath: str = cmdline.ReadFlagOrDefault("--ready-path", "")
    let listenPort: int32
    let listenRes: Result[tcp.TcpListenerHandle] = tcp.TcpListen("127.0.0.1", listenPort, false)
    if IsErr(listenRes):
        os.WriteLine(os.Get_stderr(), ErrorText(listenRes))
        return 1
    var listener = Value(listenRes)
    if len(readyPath) > 0:
        if !chengpath.WriteTextFile("", readyPath, intToStr(listener.addr.port)):
            tcp.TcpListenerClose(listener)
            os.WriteLine(os.Get_stderr(), " vpn proxy tcp control smoke: write ready failed")
            return 1
    let waitRes: Result[bool] = tcp.TcpListenerWaitReadable(listener, 5000)
    if IsErr(waitRes):
        tcp.TcpListenerClose(listener)
        os.WriteLine(os.Get_stderr(), ErrorText(waitRes))
        return 1
    if !Value(waitRes):
        tcp.TcpListenerClose(listener)
        os.WriteLine(os.Get_stderr(), " vpn proxy tcp control smoke: accept wait timeout")
        return 1
    let acceptRes: Result[tcp.TcpConnectionHandle] = tcp.TcpAccept(listener)
    if IsErr(acceptRes):
        tcp.TcpListenerClose(listener)
        os.WriteLine(os.Get_stderr(), ErrorText(acceptRes))
        return 1
    var conn = Value(acceptRes)
    tcp.TcpListenerClose(listener)
    let headerRes: Result[Bytes] = vpnProxyTcpControlReadExact(conn, 2)
    if IsErr(headerRes):
        tcp.TcpClose(conn)
        os.WriteLine(os.Get_stderr(), ErrorText(headerRes))
        return 1
    let methodRes: Result[Bytes] = vpnProxyTcpControlReadExact(conn, 1)
    if IsErr(methodRes):
        tcp.TcpClose(conn)
        os.WriteLine(os.Get_stderr(), ErrorText(methodRes))
        return 1
    let header: Bytes = Value(headerRes)
    let method: Bytes = Value(methodRes)
    let full: Bytes = bytesConcat(header, method)
    tcp.TcpClose(conn)
    if bytesToHex(full) != "050100":
        os.WriteLine(os.Get_stderr(),
                     strutil.Join([" vpn proxy tcp control smoke: header_hex=", bytesToHex(header), " method_hex=", bytesToHex(method), " full_hex=", bytesToHex(full)], ""))
        return 1
    echo(" vpn_proxy_tcp_control_bytes_smoke ok")
    return 0

fn vpnProxyTcpControlRunDefault(): int32 =
    let root: str = os.GetCurrentDir()
    let selfPath: str = cmdline.ProgramName()
    let artifactDir: str = vpnProxyTcpControlArtifactDir(root)
    let readyPath: str = vpnProxyTcpControlReadyPath(root)
    let logPath: str = vpnProxyTcpControlLogPath(root)
    if !chengpath.MkdirP(root, artifactDir):
        os.WriteLine(os.Get_stderr(), " vpn proxy tcp control smoke: mkdir failed")
        return 1
    if os.FileExists(readyPath):
        let _ = os.RemoveFile(readyPath)
    if os.FileExists(logPath):
        let _ = os.RemoveFile(logPath)
    let spawnRes = hostops.SpawnFile(root,
                                       "vpn_proxy_tcp_control_server",
                                       selfPath,
                                       ["--role:server", strutil.Join(["--ready-path:", readyPath], "")],
                                       [],
                                       root)
    if IsErr(spawnRes):
        os.WriteLine(os.Get_stderr(), Error(spawnRes))
        return 1
    var proc = Value(spawnRes)
    let portRes: Result[int32] = vpnProxyTcpControlWaitReady(root, readyPath, proc)
    if IsErr(portRes):
        hostops.SpawnedProcessKill(proc)
        os.WriteLine(os.Get_stderr(), ErrorText(portRes))
        return 1
    let connectRes: Result[tcp.TcpConnectionHandle] = tcp.TcpConnect("127.0.0.1", Value(portRes), false)
    if IsErr(connectRes):
        hostops.SpawnedProcessKill(proc)
        os.WriteLine(os.Get_stderr(), ErrorText(connectRes))
        return 1
    var conn = Value(connectRes)
    var methodWire: Bytes
    vpnProxyTcpControlMethodWireInto(methodWire)
    let sendRes: Result[int32] = vpnProxyTcpControlWriteAll(conn, methodWire)
    tcp.TcpClose(conn)
    if IsErr(sendRes):
        hostops.SpawnedProcessKill(proc)
        os.WriteLine(os.Get_stderr(), ErrorText(sendRes))
        return 1
    let waitRes: hostops.LoggedRun = hostops.SpawnedProcessWaitLogged(root, proc, 20, logPath)
    if !hostops.LoggedRunOk(waitRes):
        os.WriteLine(os.Get_stderr(), waitRes.output)
        return 1
    echo(" vpn_proxy_tcp_control_bytes_smoke ok")
    return 0

fn main(): int32 =
    let role: str = cmdline.ReadFlagOrDefault("--role", "")
    if role == "server":
        return vpnProxyTcpControlRunServer()
    return vpnProxyTcpControlRunDefault()
