import std/os
import std/strings
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/mobile_shell_codegen as mshell
import std/strutils as strutil

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/mobile_shell_build_probe_smoke")
    assert(chengpath.MkdirP(root, outDir), " mobile_shell_build_probe_smoke: mkdir")
    var output: str
    var errorText: str
    let rc: int32 = mshell.MobileShellRun(root,
                                           [
                                               "build-probe",
                                               "--platform:none",
                                               strutil.Join(["--out-dir:", outDir], "")
                                           ],
                                           output,
                                           errorText)
    assert(rc == 0, " mobile_shell_build_probe_smoke: verify rc")
    assert(len(errorText) == 0, " mobile_shell_build_probe_smoke: empty error")
    assert(strings.StrContains(output, "mobile-shell build-probe ok"),
           " mobile_shell_build_probe_smoke: build probe output")
    echo(output)
    echo("verify-mobile-shell-build-probe: ok")
    echo(" mobile_shell_build_probe_smoke ok")
    return 0
