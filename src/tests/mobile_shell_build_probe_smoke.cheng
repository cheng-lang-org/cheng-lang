import std/os
import std/strings
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let driver: str = os.JoinPath(root, "artifacts/backend_driver/cheng")
    assert(os.FileExists(driver), " mobile_shell_build_probe_smoke: backend_driver exists")
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/mobile_shell_build_probe_smoke")
    assert(chengpath.MkdirP(root, outDir), " mobile_shell_build_probe_smoke: mkdir")
    let logPath: str = chengpath.PathJoin(outDir, "verify_mobile_shell_build_probe.log")
    if chengpath.PathFileExists(logPath):
        os.RemoveFile(logPath)
    let run = hostops.RunFileLogged(root,
                                      "mobile_shell_build_probe_smoke",
                                      driver,
                                      ["verify-mobile-shell-build-probe"],
                                      [],
                                      root,
                                      0,
                                      logPath)
    let output: str = run.output
    assert(run.exitCode == 0, " mobile_shell_build_probe_smoke: verify rc")
    assert(strings.StrContains(output, "mobile-shell build-probe ok"),
           " mobile_shell_build_probe_smoke: build probe output")
    assert(strings.StrContains(output, "verify-mobile-shell-build-probe: ok"),
           " mobile_shell_build_probe_smoke: verify output")
    echo(" mobile_shell_build_probe_smoke ok")
    return 0
