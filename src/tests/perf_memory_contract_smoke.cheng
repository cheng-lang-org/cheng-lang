import std/system
import std/os
import std/strings
import std/strutils as strutil
import std/strformat
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/perf_memory_gate as perfgate
import cheng/core/tooling/bootstrap_contracts as boot

fn perfMemoryDeleteFileIfExists(path: str) =
    if os.FileExists(path):
        os.RemoveFile(path)

fn perfMemoryDeleteDirTree(path: str) =
    if !os.DirExists(path):
        return
    let entries = os.ListDir(path)
    for i in 0..<entries.len:
        let childPath = os.JoinPath(path, entries[i])
        if os.DirExists(childPath):
            perfMemoryDeleteDirTree(childPath)
        elif os.FileExists(childPath):
            assert(os.RemoveFile(childPath), " perf memory: remove cache file")
    os.RemoveDir(path)
    assert(!os.DirExists(path), " perf memory: remove cache dir")

fn perfMemoryClearPrimaryObjectCache(workspaceRoot: str) =
    let cacheRoot = chengpath.PathJoin(workspaceRoot, "artifacts/primary_object_cache")
    perfMemoryDeleteDirTree(cacheRoot)

fn perfMemoryAssertProviderCacheStats(summary: perfgate.PerfMemoryExecPhaseSummary,
                                      label: str) =
    assert(summary.providerObjectCacheHitCount >= int64(0), strutil.Join([label, " provider cache hits present"], ""))
    assert(summary.providerObjectCacheMissCount >= int64(0), strutil.Join([label, " provider cache misses present"], ""))
    assert(summary.providerObjectCacheHitCount + summary.providerObjectCacheMissCount > int64(0),
           strutil.Join([label, " provider cache observed"], ""))
    assert(summary.providerCacheLookupMs >= int64(0), strutil.Join([label, " provider cache lookup present"], ""))
    assert(summary.providerCacheCopyMs >= int64(0), strutil.Join([label, " provider cache copy present"], ""))
    assert(summary.providerCacheStoreMs >= int64(0), strutil.Join([label, " provider cache store present"], ""))
    assert(summary.chengProviderCompileMs >= int64(0), strutil.Join([label, " cheng provider compile present"], ""))
    assert(summary.cProviderCompileMs >= int64(0), strutil.Join([label, " c provider compile present"], ""))

fn perfMemoryAssertPrimaryObjectEmitBreakdown(summary: perfgate.PerfMemoryExecPhaseSummary,
                                              label: str) =
    assert(summary.primaryObjectCacheHitCount >= int64(0), strutil.Join([label, " primary object cache hits present"], ""))
    assert(summary.primaryObjectCacheMissCount >= int64(0), strutil.Join([label, " primary object cache misses present"], ""))
    assert(summary.primaryObjectCacheLookupMs >= int64(0), strutil.Join([label, " primary object cache lookup present"], ""))
    assert(summary.primaryObjectCacheCopyMs >= int64(0), strutil.Join([label, " primary object cache copy present"], ""))
    assert(summary.primaryObjectCacheStoreMs >= int64(0), strutil.Join([label, " primary object cache store present"], ""))
    assert(summary.primaryObjectEmitMs >= int64(0), strutil.Join([label, " primary object emit present"], ""))
    assert(summary.primaryObjectGlobalStorageMs >= int64(0), strutil.Join([label, " primary object global storage present"], ""))
    assert(summary.primaryObjectModuleInitMs >= int64(0), strutil.Join([label, " primary object module init present"], ""))
    assert(summary.primaryObjectFunctionEmitMs >= int64(0), strutil.Join([label, " primary object function emit present"], ""))
    assert(summary.primaryObjectEntryBridgeMs >= int64(0), strutil.Join([label, " primary object entry bridge present"], ""))
    assert(summary.primaryObjectLineMapEmbedMs >= int64(0), strutil.Join([label, " primary object line map embed present"], ""))
    assert(summary.primaryObjectSymbolTrailerMs >= int64(0), strutil.Join([label, " primary object symbol trailer present"], ""))
    assert(summary.primaryObjectAsmWriteMs >= int64(0), strutil.Join([label, " primary object asm write present"], ""))
    assert(summary.primaryObjectAsmCompileMs >= int64(0), strutil.Join([label, " primary object asm compile present"], ""))
    assert(summary.primaryObjectAsmBytes > int64(0), strutil.Join([label, " primary object asm bytes present"], ""))
    assert(summary.primaryObjectLineMapAsmBytes > int64(0), strutil.Join([label, " primary object line map asm bytes present"], ""))

fn perfMemoryAssertPrimaryObjectColdMiss(summary: perfgate.PerfMemoryExecPhaseSummary,
                                         label: str) =
    if summary.primaryObjectCacheHitCount + summary.primaryObjectCacheMissCount > int64(0):
        assert(summary.primaryObjectCacheHitCount == int64(0), strutil.Join([label, " primary object cache cold hit count"], ""))
        assert(summary.primaryObjectCacheMissCount > int64(0), strutil.Join([label, " primary object cache cold miss count"], ""))
    assert(summary.primaryObjectAsmCompileMs > int64(0), strutil.Join([label, " primary object cold asm compile"], ""))

fn perfMemoryAppendReport(reportFile: os.File, row: str) =
    os.WriteLine(reportFile, row)

fn perfMemoryDeleteCompileArtifacts(outputPath: str, compileLog: str) =
    perfMemoryDeleteFileIfExists(outputPath)
    perfMemoryDeleteFileIfExists(perfgate.PerfMemoryCompileReportPath(outputPath))
    perfMemoryDeleteFileIfExists(compileLog)

fn perfMemoryAssertCompileSample(sample: perfgate.PerfMemoryRun,
                                 threshold: perfgate.PerfMemoryThreshold,
                                 outputPath: str,
                                 label: str) =
    assert(sample.exitCode == 0, strutil.Join([label, " rc"], ""))
    assert(sample.elapsedMs > int64(0), strutil.Join([label, " elapsed"], ""))
    assert(sample.maxRssBytes > int64(0), strutil.Join([label, " rss"], ""))
    assert(sample.elapsedMs <= threshold.maxElapsedMs,
           strutil.Join([label, " observed max ms elapsed=", int64ToStr(sample.elapsedMs), " limit=", int64ToStr(threshold.maxElapsedMs)], ""))
    assert(sample.maxRssBytes <= threshold.maxRssBytes,
           strutil.Join([label, " observed max rss rss=", int64ToStr(sample.maxRssBytes), " limit=", int64ToStr(threshold.maxRssBytes)], ""))
    assert(os.FileExists(outputPath), strutil.Join([label, " output"], ""))
    assert(sample.outputFileSizeBytes > int64(0), strutil.Join([label, " output size"], ""))
    assert(perfgate.PerfMemoryOutputFileSizeWithinThreshold(sample, threshold),
           strutil.Join([label, " observed max output bytes size=", int64ToStr(sample.outputFileSizeBytes), " limit=", int64ToStr(threshold.maxOutputFileSizeBytes)], ""))

fn perfMemoryRunRepeatedNoHandoffCompile(workspaceRoot: str,
                                         outDir: str,
                                         compilerPath: str,
                                         compilerLabel: str,
                                         target: str,
                                         sourcePath: str,
                                         repeatCount: int32,
                                         compileTimeoutSec: int32,
                                         compileThreshold: perfgate.PerfMemoryThreshold,
                                         growthMaxBytes: int64,
                                         reportFile: os.File) =
    assert(os.FileExists(compilerPath), " perf memory: no handoff compiler exists")
    assert(os.FileExists(sourcePath), " perf memory: no handoff source exists")
    assert(repeatCount >= int32(2), " perf memory: no handoff repeat count")
    assert(growthMaxBytes >= int64(0), " perf memory: no handoff growth threshold")
    var compileEnv: str[]
    add(compileEnv, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    add(compileEnv, "CHENG_PROGRESS=1")
    var baselineRssBytes = int64(-1)
    var maxObservedRssBytes = int64(-1)
    for i in 0..<repeatCount:
        let iterText = IntToStr(i + 1)
        echo(strutil.Join([" perf memory: ", compilerLabel, " no handoff compile ", iterText, " begin"], ""))
        let outputPath = chengpath.PathJoin(outDir,
                                           strutil.Join(["libp2p_quic_twoproc_client.no_handoff.", compilerLabel, ".", iterText], ""))
        let compileLog = strutil.Join([outputPath, ".compile.log"], "")
        perfMemoryClearPrimaryObjectCache(workspaceRoot)
        perfMemoryDeleteCompileArtifacts(outputPath, compileLog)
        let sample = perfgate.PerfMemoryCompileExeWithEnv(workspaceRoot,
                                                            strutil.Join([compilerLabel, "_no_handoff_compile_", iterText], ""),
                                                            compilerPath,
                                                            target,
                                                            sourcePath,
                                                            outputPath,
                                                            compileEnv,
                                                            compileTimeoutSec,
                                                            compileLog)
        perfMemoryAssertCompileSample(sample,
                                      compileThreshold,
                                      outputPath,
                                      strutil.Join([" perf memory: ", compilerLabel, " no handoff compile ", iterText], ""))
        echo(strutil.Join([" perf memory: ", compilerLabel, " no handoff compile ", iterText, " ok"], ""))
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryReportRow(sample, compileThreshold))
        if baselineRssBytes < int64(0):
            baselineRssBytes = sample.maxRssBytes
        if sample.maxRssBytes > maxObservedRssBytes:
            maxObservedRssBytes = sample.maxRssBytes
        let growthBytes = sample.maxRssBytes - baselineRssBytes
        assert(growthBytes <= growthMaxBytes,
               strutil.Join([" perf memory: ", compilerLabel, " no handoff compile rss growth"], ""))
        perfMemoryAppendReport(reportFile, strutil.Join([compilerLabel, "_no_handoff_repeat iteration=", iterText], ""))
    perfMemoryAppendReport(reportFile, strutil.Join([compilerLabel, "_no_handoff_repeat_contract"], ""))

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir = chengpath.PathJoin(workspaceRoot, strutil.Join(["artifacts/perf_memory_contract/", smokeLabel], ""))
    assert(chengpath.MkdirP(workspaceRoot, outDir), " perf memory: mkdir")
    let reportPath = chengpath.PathJoin(outDir, "perf_memory_contract.report.txt")
    let reportFile: os.File = os.Open(reportPath, os.fmWrite)
    assert(reportFile != nil, " perf memory: open report")
    let compilerPath: str = perfgate.PerfMemoryResolveCompiler(workspaceRoot)
    assert(os.FileExists(compilerPath), " perf memory: compiler exists")
    let target: str = os.GetEnvDefault("CHENG_RUNTIME_LINK_TARGET", boot.BootstrapDefaultTarget())
    let compileTimeoutSec: int32 = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_PERF_COMPILE_TIMEOUT_SEC", "300")))
    let runTimeoutSec: int32 = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_PERF_RUN_TIMEOUT_SEC", "120")))
    var compileEnv: str[]
    add(compileEnv, "CHENG_PROGRESS=1")
    let objectCompileThreshold = perfgate.PerfMemoryThresholdWithOutputFileSize(
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_OBJECT_COMPILE_MAX_MS", "13000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_OBJECT_COMPILE_MAX_RSS_BYTES", "3200000000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_OBJECT_OUTPUT_MAX_BYTES", "0"))
    )
    let objectRunThreshold = perfgate.PerfMemoryThresholdNew(
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_OBJECT_RUN_MAX_MS", "13000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_OBJECT_RUN_MAX_RSS_BYTES", "600000000"))
    )
    let chainCompileThreshold = perfgate.PerfMemoryThresholdWithOutputFileSize(
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CHAIN_COMPILE_MAX_MS", "10000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CHAIN_COMPILE_MAX_RSS_BYTES", "3200000000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CHAIN_OUTPUT_MAX_BYTES", "0"))
    )
    let contentCompileThreshold = perfgate.PerfMemoryThresholdWithOutputFileSize(
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CONTENT_COMPILE_MAX_MS", "30000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CONTENT_COMPILE_MAX_RSS_BYTES", "3200000000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CONTENT_OUTPUT_MAX_BYTES", "0"))
    )
    let orcCompileThreshold = perfgate.PerfMemoryThresholdWithOutputFileSize(
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_ORC_COMPILE_MAX_MS", "10000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_ORC_COMPILE_MAX_RSS_BYTES", "3200000000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_ORC_OUTPUT_MAX_BYTES", "0"))
    )
    let orcRunThreshold = perfgate.PerfMemoryThresholdNew(
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_ORC_RUN_MAX_MS", "4000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_ORC_RUN_MAX_RSS_BYTES", "200000000"))
    )
    let cryptoCompileThreshold = perfgate.PerfMemoryThresholdWithOutputFileSize(
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CRYPTO_COMPILE_MAX_MS", "30000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CRYPTO_COMPILE_MAX_RSS_BYTES", "3200000000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CRYPTO_OUTPUT_MAX_BYTES", "0"))
    )
    let cryptoRunThreshold = perfgate.PerfMemoryThresholdNew(
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CRYPTO_RUN_MAX_MS", "12000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CRYPTO_RUN_MAX_RSS_BYTES", "600000000"))
    )
    let noHandoffCompileThreshold = perfgate.PerfMemoryThresholdWithOutputFileSize(
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_NO_HANDOFF_COMPILE_MAX_MS", "300000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_NO_HANDOFF_COMPILE_MAX_RSS_BYTES", "2000000000")),
        perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_NO_HANDOFF_OUTPUT_MAX_BYTES", "0"))
    )
    let noHandoffRepeatCount: int32 = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_PERF_NO_HANDOFF_REPEAT_COUNT", "2")))
    let noHandoffGrowthMaxBytes = perfgate.PerfMemoryParseUnsignedInt64(
        os.GetEnvDefault("CHENG_PERF_NO_HANDOFF_GROWTH_MAX_RSS_BYTES", "268435456"))
    let cryptoSha256MaxNs = perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CRYPTO_SHA256_MAX_NS", "50000000"))
    let cryptoX25519MaxNs = perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CRYPTO_X25519_MAX_NS", "3000000000"))
    let cryptoP256PubMaxNs = perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CRYPTO_P256_PUB_MAX_NS", "3000000000"))
    let cryptoP256SignMaxNs = perfgate.PerfMemoryParseUnsignedInt64(os.GetEnvDefault("CHENG_PERF_CRYPTO_P256_SIGN_MAX_NS", "5000000000"))
    assert(objectCompileThreshold.maxElapsedMs > int64(0), " perf memory: object compile threshold max ms")
    assert(objectCompileThreshold.maxRssBytes > int64(0), " perf memory: object compile threshold max rss")
    assert(objectRunThreshold.maxElapsedMs > int64(0), " perf memory: object run threshold max ms")
    assert(objectRunThreshold.maxRssBytes > int64(0), " perf memory: object run threshold max rss")
    assert(chainCompileThreshold.maxElapsedMs > int64(0), " perf memory: chain compile threshold max ms")
    assert(chainCompileThreshold.maxRssBytes > int64(0), " perf memory: chain compile threshold max rss")
    assert(contentCompileThreshold.maxElapsedMs > int64(0), " perf memory: content compile threshold max ms")
    assert(contentCompileThreshold.maxRssBytes > int64(0), " perf memory: content compile threshold max rss")
    assert(orcCompileThreshold.maxElapsedMs > int64(0), " perf memory: orc compile threshold max ms")
    assert(orcCompileThreshold.maxRssBytes > int64(0), " perf memory: orc compile threshold max rss")
    assert(orcRunThreshold.maxElapsedMs > int64(0), " perf memory: orc run threshold max ms")
    assert(orcRunThreshold.maxRssBytes > int64(0), " perf memory: orc run threshold max rss")
    assert(cryptoCompileThreshold.maxElapsedMs > int64(0), " perf memory: crypto compile threshold max ms")
    assert(cryptoCompileThreshold.maxRssBytes > int64(0), " perf memory: crypto compile threshold max rss")
    assert(cryptoRunThreshold.maxElapsedMs > int64(0), " perf memory: crypto run threshold max ms")
    assert(cryptoRunThreshold.maxRssBytes > int64(0), " perf memory: crypto run threshold max rss")
    assert(noHandoffCompileThreshold.maxElapsedMs > int64(0), " perf memory: no handoff compile threshold max ms")
    assert(noHandoffCompileThreshold.maxRssBytes > int64(0), " perf memory: no handoff compile threshold max rss")
    assert(noHandoffRepeatCount >= int32(2), " perf memory: no handoff repeat count")
    assert(noHandoffGrowthMaxBytes >= int64(0), " perf memory: no handoff growth max rss")
    assert(cryptoSha256MaxNs > int64(0), " perf memory: crypto sha256 max ns")
    assert(cryptoX25519MaxNs > int64(0), " perf memory: crypto x25519 max ns")
    assert(cryptoP256PubMaxNs > int64(0), " perf memory: crypto p256 pub max ns")
    assert(cryptoP256SignMaxNs > int64(0), " perf memory: crypto p256 sign max ns")
    let objectSourcePath = chengpath.PathJoin(workspaceRoot, "src/tests/object_native_link_plan_smoke.cheng")
    let objectOutputPath = chengpath.PathJoin(outDir, "object_native_link_plan_smoke")
    perfMemoryClearPrimaryObjectCache(workspaceRoot)
    perfMemoryDeleteFileIfExists(objectOutputPath)
    perfMemoryDeleteFileIfExists(perfgate.PerfMemoryCompileReportPath(objectOutputPath))
    let objectCompileLog = strutil.Join([objectOutputPath, ".compile.log"], "")
    perfMemoryDeleteFileIfExists(objectCompileLog)
    let objectCompile = perfgate.PerfMemoryCompileExeWithEnv(workspaceRoot,
                                                               "object_native_link_plan_compile",
                                                               compilerPath,
                                                               target,
                                                               objectSourcePath,
                                                               objectOutputPath,
                                                               compileEnv,
                                                               compileTimeoutSec,
                                                               objectCompileLog)
    perfMemoryAssertCompileSample(objectCompile,
                                  objectCompileThreshold,
                                  objectOutputPath,
                                  " perf memory: object compile")
    perfMemoryAppendReport(reportFile, perfgate.PerfMemoryReportRow(objectCompile, objectCompileThreshold))
    let objectCompilePhases = perfgate.PerfMemoryCompileExecPhaseSummary(workspaceRoot, objectOutputPath, "")
    if perfgate.PerfMemoryExecPhaseSummaryReady(objectCompilePhases) &&
       objectCompilePhases.totalMs <= objectCompile.elapsedMs:
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryExecPhaseReportRow(objectCompile, objectCompilePhases))
        assert(perfgate.PerfMemoryCompileGapBreakdownReady(objectCompilePhases),
               " perf memory: object compile gap breakdown ready")
        assert(perfgate.PerfMemoryExecPhaseAttributedMs(objectCompilePhases) >= objectCompilePhases.totalMs,
               " perf memory: object compile attributed phases")
        assert(perfgate.PerfMemoryCompileGapBreakdownMs(objectCompile, objectCompilePhases) >= int64(0),
               " perf memory: object compile unattributed gap")
        perfMemoryAssertProviderCacheStats(objectCompilePhases, " perf memory: object compile")
        perfMemoryAssertPrimaryObjectEmitBreakdown(objectCompilePhases, " perf memory: object compile")
        perfMemoryAssertPrimaryObjectColdMiss(objectCompilePhases, " perf memory: object compile")
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryCompileGapBreakdownRow(objectCompile, objectCompilePhases))
    let objectRunLog = strutil.Join([objectOutputPath, ".run.log"], "")
    perfMemoryDeleteFileIfExists(objectRunLog)
    let objectRun = perfgate.PerfMemoryRunBinary(workspaceRoot,
                                                   "object_native_link_plan_run",
                                                   objectOutputPath,
                                                   [],
                                                   [],
                                                   workspaceRoot,
                                                   runTimeoutSec,
                                                   objectRunLog)
    assert(objectRun.exitCode == 0, " perf memory: object run rc")
    assert(strings.StrContains(objectRun.output, " object_native_link_plan_smoke ok"),
           " perf memory: object run output")
    assert(objectRun.elapsedMs > int64(0), " perf memory: object run elapsed")
    assert(objectRun.maxRssBytes > int64(0), " perf memory: object run rss")
    assert(objectRun.elapsedMs <= objectRunThreshold.maxElapsedMs, " perf memory: object run observed max ms")
    assert(objectRun.maxRssBytes <= objectRunThreshold.maxRssBytes, " perf memory: object run observed max rss")
    perfMemoryAppendReport(reportFile, perfgate.PerfMemoryReportRow(objectRun, objectRunThreshold))
    let chainSourcePath = chengpath.PathJoin(workspaceRoot, "src/tests/chain_node_smoke.cheng")
    let chainOutputPath = chengpath.PathJoin(outDir, "chain_node_smoke")
    perfMemoryClearPrimaryObjectCache(workspaceRoot)
    perfMemoryDeleteFileIfExists(chainOutputPath)
    perfMemoryDeleteFileIfExists(perfgate.PerfMemoryCompileReportPath(chainOutputPath))
    let chainCompileLog = strutil.Join([chainOutputPath, ".compile.log"], "")
    perfMemoryDeleteFileIfExists(chainCompileLog)
    let chainCompile = perfgate.PerfMemoryCompileExeWithEnv(workspaceRoot,
                                                              "chain_node_compile",
                                                              compilerPath,
                                                              target,
                                                              chainSourcePath,
                                                              chainOutputPath,
                                                              compileEnv,
                                                              compileTimeoutSec,
                                                              chainCompileLog)
    perfMemoryAssertCompileSample(chainCompile,
                                  chainCompileThreshold,
                                  chainOutputPath,
                                  " perf memory: chain compile")
    perfMemoryAppendReport(reportFile, perfgate.PerfMemoryReportRow(chainCompile, chainCompileThreshold))
    let chainCompilePhases = perfgate.PerfMemoryCompileExecPhaseSummary(workspaceRoot, chainOutputPath, "")
    if perfgate.PerfMemoryExecPhaseSummaryReady(chainCompilePhases) &&
       chainCompilePhases.totalMs <= chainCompile.elapsedMs:
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryExecPhaseReportRow(chainCompile, chainCompilePhases))
        assert(perfgate.PerfMemoryCompileGapBreakdownReady(chainCompilePhases),
               " perf memory: chain compile gap breakdown ready")
        assert(perfgate.PerfMemoryExecPhaseAttributedMs(chainCompilePhases) >= chainCompilePhases.totalMs,
               " perf memory: chain compile attributed phases")
        assert(perfgate.PerfMemoryCompileGapBreakdownMs(chainCompile, chainCompilePhases) >= int64(0),
               " perf memory: chain compile unattributed gap")
        perfMemoryAssertProviderCacheStats(chainCompilePhases, " perf memory: chain compile")
        perfMemoryAssertPrimaryObjectEmitBreakdown(chainCompilePhases, " perf memory: chain compile")
        perfMemoryAssertPrimaryObjectColdMiss(chainCompilePhases, " perf memory: chain compile")
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryCompileGapBreakdownRow(chainCompile, chainCompilePhases))
    let contentSourcePath = chengpath.PathJoin(workspaceRoot, "src/tests/content_stub_smoke.cheng")
    let contentOutputPath = chengpath.PathJoin(outDir, "content_stub_smoke")
    perfMemoryClearPrimaryObjectCache(workspaceRoot)
    perfMemoryDeleteFileIfExists(contentOutputPath)
    perfMemoryDeleteFileIfExists(perfgate.PerfMemoryCompileReportPath(contentOutputPath))
    let contentCompileLog = strutil.Join([contentOutputPath, ".compile.log"], "")
    perfMemoryDeleteFileIfExists(contentCompileLog)
    let contentCompile = perfgate.PerfMemoryCompileExeWithEnv(workspaceRoot,
                                                                "content_stub_compile",
                                                                compilerPath,
                                                                target,
                                                                contentSourcePath,
                                                                contentOutputPath,
                                                                compileEnv,
                                                                compileTimeoutSec,
                                                                contentCompileLog)
    perfMemoryAssertCompileSample(contentCompile,
                                  contentCompileThreshold,
                                  contentOutputPath,
                                  " perf memory: content compile")
    perfMemoryAppendReport(reportFile, perfgate.PerfMemoryReportRow(contentCompile, contentCompileThreshold))
    let contentCompilePhases = perfgate.PerfMemoryCompileExecPhaseSummary(workspaceRoot, contentOutputPath, "")
    if perfgate.PerfMemoryExecPhaseSummaryReady(contentCompilePhases) &&
       contentCompilePhases.totalMs <= contentCompile.elapsedMs:
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryExecPhaseReportRow(contentCompile, contentCompilePhases))
        assert(perfgate.PerfMemoryCompileGapBreakdownReady(contentCompilePhases),
               " perf memory: content compile gap breakdown ready")
        assert(perfgate.PerfMemoryExecPhaseAttributedMs(contentCompilePhases) >= contentCompilePhases.totalMs,
               " perf memory: content compile attributed phases")
        assert(perfgate.PerfMemoryCompileGapBreakdownMs(contentCompile, contentCompilePhases) >= int64(0),
               " perf memory: content compile unattributed gap")
        perfMemoryAssertProviderCacheStats(contentCompilePhases, " perf memory: content compile")
        perfMemoryAssertPrimaryObjectEmitBreakdown(contentCompilePhases, " perf memory: content compile")
        perfMemoryAssertPrimaryObjectColdMiss(contentCompilePhases, " perf memory: content compile")
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryCompileGapBreakdownRow(contentCompile, contentCompilePhases))
    let orcSourcePath = chengpath.PathJoin(workspaceRoot, "src/tests/orc_perf_contract_smoke.cheng")
    let orcOutputPath = chengpath.PathJoin(outDir, "orc_perf_contract_smoke")
    perfMemoryClearPrimaryObjectCache(workspaceRoot)
    perfMemoryDeleteFileIfExists(orcOutputPath)
    perfMemoryDeleteFileIfExists(perfgate.PerfMemoryCompileReportPath(orcOutputPath))
    let orcCompileLog = strutil.Join([orcOutputPath, ".compile.log"], "")
    perfMemoryDeleteFileIfExists(orcCompileLog)
    let orcCompile = perfgate.PerfMemoryCompileExeWithEnv(workspaceRoot,
                                                            "orc_perf_compile",
                                                            compilerPath,
                                                            target,
                                                            orcSourcePath,
                                                            orcOutputPath,
                                                            compileEnv,
                                                            compileTimeoutSec,
                                                            orcCompileLog)
    perfMemoryAssertCompileSample(orcCompile,
                                  orcCompileThreshold,
                                  orcOutputPath,
                                  " perf memory: orc compile")
    perfMemoryAppendReport(reportFile, perfgate.PerfMemoryReportRow(orcCompile, orcCompileThreshold))
    let orcCompilePhases = perfgate.PerfMemoryCompileExecPhaseSummary(workspaceRoot, orcOutputPath, "")
    if perfgate.PerfMemoryExecPhaseSummaryReady(orcCompilePhases) &&
       orcCompilePhases.totalMs <= orcCompile.elapsedMs:
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryExecPhaseReportRow(orcCompile, orcCompilePhases))
        assert(perfgate.PerfMemoryCompileGapBreakdownReady(orcCompilePhases),
               " perf memory: orc compile gap breakdown ready")
        assert(perfgate.PerfMemoryExecPhaseAttributedMs(orcCompilePhases) >= orcCompilePhases.totalMs,
               " perf memory: orc compile attributed phases")
        assert(perfgate.PerfMemoryCompileGapBreakdownMs(orcCompile, orcCompilePhases) >= int64(0),
               " perf memory: orc compile unattributed gap")
        perfMemoryAssertProviderCacheStats(orcCompilePhases, " perf memory: orc compile")
        perfMemoryAssertPrimaryObjectEmitBreakdown(orcCompilePhases, " perf memory: orc compile")
        perfMemoryAssertPrimaryObjectColdMiss(orcCompilePhases, " perf memory: orc compile")
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryCompileGapBreakdownRow(orcCompile, orcCompilePhases))
    let orcIterations: int32 = int32(strutil.ParseInt(os.GetEnvDefault("CHENG_ORC_PERF_ITERS", "200000")))
    let orcRunLog = strutil.Join([orcOutputPath, ".run.log"], "")
    perfMemoryDeleteFileIfExists(orcRunLog)
    let orcRun = perfgate.PerfMemoryRunBinary(workspaceRoot,
                                                "orc_perf_run",
                                                orcOutputPath,
                                                [],
                                                [strutil.Join(["CHENG_ORC_PERF_ITERS=", IntToStr(orcIterations)], "")],
                                                workspaceRoot,
                                                runTimeoutSec,
                                                orcRunLog)
    assert(orcRun.exitCode == 0, " perf memory: orc run rc")
    assert(strings.StrContains(orcRun.output, " orc_perf_contract_smoke ok"),
           " perf memory: orc run output")
    assert(orcRun.elapsedMs > int64(0), " perf memory: orc run elapsed")
    assert(orcRun.maxRssBytes > int64(0), " perf memory: orc run rss")
    assert(orcRun.elapsedMs <= orcRunThreshold.maxElapsedMs, " perf memory: orc run observed max ms")
    assert(orcRun.maxRssBytes <= orcRunThreshold.maxRssBytes, " perf memory: orc run observed max rss")
    perfMemoryAppendReport(reportFile, perfgate.PerfMemoryReportRow(orcRun, orcRunThreshold))
    let orcRetainCount: int64 = perfgate.PerfMemoryParseOutputInt64(orcRun.output, "orc_perf_retain_count")
    let orcReleaseCount: int64 = perfgate.PerfMemoryParseOutputInt64(orcRun.output, "orc_perf_release_count")
    let orcAllocDelta: int64 = perfgate.PerfMemoryParseOutputInt64(orcRun.output, "orc_perf_alloc_delta")
    let orcFreeDelta: int64 = perfgate.PerfMemoryParseOutputInt64(orcRun.output, "orc_perf_free_delta")
    let orcLiveDelta: int64 = perfgate.PerfMemoryParseOutputInt64(orcRun.output, "orc_perf_live_delta")
    assert(orcRetainCount >= int64(0), " perf memory: missing orc retain count")
    assert(orcReleaseCount >= int64(0), " perf memory: missing orc release count")
    assert(orcAllocDelta >= int64(0), " perf memory: missing orc alloc delta")
    assert(orcFreeDelta >= int64(0), " perf memory: missing orc free delta")
    assert(orcLiveDelta >= int64(0), " perf memory: missing orc live delta")
    assert(orcRetainCount == int64(orcIterations), " perf memory: orc retain count")
    assert(orcReleaseCount == int64(orcIterations), " perf memory: orc release count")
    assert(orcAllocDelta == int64(1), " perf memory: orc alloc delta")
    assert(orcFreeDelta == int64(1), " perf memory: orc free delta")
    assert(orcLiveDelta == int64(0), " perf memory: orc live delta")
    perfMemoryAppendReport(reportFile, "orc_perf_contract")
    let runtimeCBaselineReportPath = os.GetEnvDefault("CHENG_RUNTIME_C_BASELINE_REPORT", "")
    let runtimeCBaseline = perfgate.PerfMemoryRuntimeCBaselineContractFromFile(workspaceRoot,
                                                                               runtimeCBaselineReportPath)
    perfMemoryAppendReport(reportFile, runtimeCBaseline.report)
    assert(runtimeCBaseline.ok, " perf memory: runtime c baseline contract")
    let cryptoSourcePath = chengpath.PathJoin(workspaceRoot, "src/tests/crypto_hot_kernel_perf_smoke.cheng")
    let cryptoOutputPath = chengpath.PathJoin(outDir, "crypto_hot_kernel_perf_smoke")
    perfMemoryClearPrimaryObjectCache(workspaceRoot)
    perfMemoryDeleteFileIfExists(cryptoOutputPath)
    perfMemoryDeleteFileIfExists(perfgate.PerfMemoryCompileReportPath(cryptoOutputPath))
    let cryptoCompileLog = strutil.Join([cryptoOutputPath, ".compile.log"], "")
    perfMemoryDeleteFileIfExists(cryptoCompileLog)
    let cryptoCompile = perfgate.PerfMemoryCompileExeWithEnv(workspaceRoot,
                                                               "crypto_hot_kernel_compile",
                                                               compilerPath,
                                                               target,
                                                               cryptoSourcePath,
                                                               cryptoOutputPath,
                                                               compileEnv,
                                                               compileTimeoutSec,
                                                               cryptoCompileLog)
    perfMemoryAssertCompileSample(cryptoCompile,
                                  cryptoCompileThreshold,
                                  cryptoOutputPath,
                                  " perf memory: crypto compile")
    perfMemoryAppendReport(reportFile, perfgate.PerfMemoryReportRow(cryptoCompile, cryptoCompileThreshold))
    let cryptoCompilePhases = perfgate.PerfMemoryCompileExecPhaseSummary(workspaceRoot, cryptoOutputPath, "")
    if perfgate.PerfMemoryExecPhaseSummaryReady(cryptoCompilePhases) &&
       cryptoCompilePhases.totalMs <= cryptoCompile.elapsedMs:
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryExecPhaseReportRow(cryptoCompile, cryptoCompilePhases))
        assert(perfgate.PerfMemoryCompileGapBreakdownReady(cryptoCompilePhases),
               " perf memory: crypto compile gap breakdown ready")
        assert(perfgate.PerfMemoryExecPhaseAttributedMs(cryptoCompilePhases) >= cryptoCompilePhases.totalMs,
               " perf memory: crypto compile attributed phases")
        assert(perfgate.PerfMemoryCompileGapBreakdownMs(cryptoCompile, cryptoCompilePhases) >= int64(0),
               " perf memory: crypto compile unattributed gap")
        perfMemoryAssertProviderCacheStats(cryptoCompilePhases, " perf memory: crypto compile")
        perfMemoryAssertPrimaryObjectEmitBreakdown(cryptoCompilePhases, " perf memory: crypto compile")
        perfMemoryAssertPrimaryObjectColdMiss(cryptoCompilePhases, " perf memory: crypto compile")
        perfMemoryAppendReport(reportFile, perfgate.PerfMemoryCompileGapBreakdownRow(cryptoCompile, cryptoCompilePhases))
    let cryptoRunLog = strutil.Join([cryptoOutputPath, ".run.log"], "")
    perfMemoryDeleteFileIfExists(cryptoRunLog)
    let cryptoRun = perfgate.PerfMemoryRunBinary(workspaceRoot,
                                                   "crypto_hot_kernel_run",
                                                   cryptoOutputPath,
                                                   [],
                                                   [],
                                                   workspaceRoot,
                                                   runTimeoutSec,
                                                   cryptoRunLog)
    assert(cryptoRun.exitCode == 0, " perf memory: crypto run rc")
    assert(strings.StrContains(cryptoRun.output, " crypto_hot_kernel_perf_smoke ok"),
           " perf memory: crypto run output")
    assert(cryptoRun.elapsedMs > int64(0), " perf memory: crypto run elapsed")
    assert(cryptoRun.maxRssBytes > int64(0), " perf memory: crypto run rss")
    assert(cryptoRun.elapsedMs <= cryptoRunThreshold.maxElapsedMs, " perf memory: crypto run observed max ms")
    assert(cryptoRun.maxRssBytes <= cryptoRunThreshold.maxRssBytes, " perf memory: crypto run observed max rss")
    perfMemoryAppendReport(reportFile, perfgate.PerfMemoryReportRow(cryptoRun, cryptoRunThreshold))
    let cryptoSha256Ns: int64 = perfgate.PerfMemoryParseOutputInt64(cryptoRun.output, "crypto_sha256_ns_per_op")
    let cryptoX25519Ns: int64 = perfgate.PerfMemoryParseOutputInt64(cryptoRun.output, "crypto_x25519_pubkey_ns_per_op")
    let cryptoP256PubNs: int64 = perfgate.PerfMemoryParseOutputInt64(cryptoRun.output, "crypto_p256_pubkey_ns_per_op")
    let cryptoP256SignNs: int64 = perfgate.PerfMemoryParseOutputInt64(cryptoRun.output, "crypto_p256_sign_ns_per_op")
    assert(cryptoSha256Ns > int64(0), " perf memory: crypto sha256 ns")
    assert(cryptoX25519Ns > int64(0), " perf memory: crypto x25519 ns")
    assert(cryptoP256PubNs > int64(0), " perf memory: crypto p256 pub ns")
    assert(cryptoP256SignNs > int64(0), " perf memory: crypto p256 sign ns")
    assert(cryptoSha256Ns <= cryptoSha256MaxNs, " perf memory: crypto sha256 max ns")
    assert(cryptoX25519Ns <= cryptoX25519MaxNs, " perf memory: crypto x25519 max ns")
    assert(cryptoP256PubNs <= cryptoP256PubMaxNs, " perf memory: crypto p256 pub max ns")
    assert(cryptoP256SignNs <= cryptoP256SignMaxNs, " perf memory: crypto p256 sign max ns")
    perfMemoryAppendReport(reportFile, "crypto_hot_kernel_contract")
    let noHandoffSourcePath = chengpath.PathJoin(workspaceRoot, "src/tests/libp2p_quic_twoproc_client_smoke.cheng")
    echo(" perf memory: no handoff repeat begin")
    perfMemoryRunRepeatedNoHandoffCompile(workspaceRoot,
                                          outDir,
                                          boot.BootstrapStage3Path(workspaceRoot),
                                          "stage3",
                                          target,
                                          noHandoffSourcePath,
                                          noHandoffRepeatCount,
                                          compileTimeoutSec,
                                          noHandoffCompileThreshold,
                                          noHandoffGrowthMaxBytes,
                                          reportFile)
    perfMemoryAppendReport(reportFile, " perf memory: ok")
    os.Close(reportFile)
    echo(" perf_memory_contract_smoke ok")
    return 0
