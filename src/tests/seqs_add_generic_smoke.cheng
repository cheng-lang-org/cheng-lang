import std/seqs as seqs

type
    Box =
        name: str
        items: str[]

fn buildBox(): Box =
    var out: Box
    var items: str[]
    seqs.Add(items, "alpha")
    seqs.Add(items, "beta")
    out.name = "ok"
    out.items = items
    return out

fn main(): int32 =
    let box: Box = buildBox()
    assert(box.name == "ok", " seqs add generic: zeroarg composite return")
    assert(box.items.len == 2, " seqs add generic: seq len")
    assert(box.items[0] == "alpha", " seqs add generic: first item")
    assert(box.items[1] == "beta", " seqs add generic: second item")
    echo(" seqs_add_generic_smoke ok")
    return 0
