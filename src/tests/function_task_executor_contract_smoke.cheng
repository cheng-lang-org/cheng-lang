import cheng/core/ir/function_task as ftask
import cheng/core/ir/function_task_executor as fexec

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn main(): int32 =
    var task: ftask.FunctionTask
    task.funcIndex = 1
    task.declOrdinal = 3

    var serialPlan = ftask.FunctionTaskPlanNew()
    ftask.FunctionTaskPlanAppend(serialPlan, task)
    let serialResults = fexec.FunctionTaskExecuteAuto(serialPlan)
    let c1 = check(serialResults.len == 1, 11)
    if c1 != 0: return c1
    let c2 = check(serialResults[0].funcIndex == 1, 12)
    if c2 != 0: return c2
    let c3 = check(serialResults[0].outputKind == ftask.FunctionTaskResultKindBodyIr(), 13)
    if c3 != 0: return c3
    let c4 = check(serialResults[0].diags.len == 0, 14)
    if c4 != 0: return c4

    var wsPlan = ftask.FunctionTaskPlanNew()
    wsPlan.schedule = ftask.FunctionTaskScheduleWorkStealing
    wsPlan.jobCount = 4
    for i in 0..<8:
        var wsTask: ftask.FunctionTask
        wsTask.funcIndex = 10 + i
        wsTask.declOrdinal = i
        ftask.FunctionTaskPlanAppend(wsPlan, wsTask)
    let wsResults = fexec.FunctionTaskExecuteAuto(wsPlan)
    let c5 = check(wsResults.len == 8, 21)
    if c5 != 0: return c5
    let c6 = check(fexec.FunctionTaskWorkStealingLastWorkerCount() == 4, 22)
    if c6 != 0: return c6
    let c7 = check(fexec.FunctionTaskWorkStealingLastCompletedWorkerCount() == 4, 23)
    if c7 != 0: return c7
    for i in 0..<wsResults.len:
        let c8 = check(wsResults[i].funcIndex == 10 + i, 24)
        if c8 != 0: return c8
        let c9 = check(wsResults[i].outputKind == ftask.FunctionTaskResultKindBodyIr(), 25)
        if c9 != 0: return c9
        let c10 = check(wsResults[i].diags.len == 0, 26)
        if c10 != 0: return c10

    var snapshot: ftask.FunctionSharedSnapshot
    let report = fexec.FunctionTaskMergeResults(wsPlan, wsResults, snapshot)
    let c11 = check(report.errorCount == 0, 31)
    if c11 != 0: return c11
    echo(" function_task_executor_contract_smoke ok")
    return 0
