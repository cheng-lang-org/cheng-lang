import std/result
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world_libp2p as cwlp
import cheng/core/backend/system_link_exec as sexec

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let sourcePath = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = chengpath.PathJoin(workspaceRoot, "artifacts/compiler_world_fresh_node/program_selfhost_smoke")
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    let planRes = sexec.BuildSystemLinkExecPlan(workspaceRoot, req)
    assert(IsOk(planRes), " compiler world fresh-node: build plan")
    let plan = Value(planRes)
    let reportRes = cwlp.CompilerWorldFreshNodeSelfhostReport(workspaceRoot, req, plan)
    assert(IsOk(reportRes), " compiler world fresh-node: fresh report")
    let report = Value(reportRes)
    assert(chengpath.TextContains(report, "manifest_root_cid="),
           " compiler world fresh-node: manifest root")
    assert(chengpath.TextContains(report, "manifest_entry_count=3"),
           " compiler world fresh-node: manifest entry count")
    assert(chengpath.TextContains(report, "receipt_equivalent=1"),
           " compiler world fresh-node: receipt equivalence")
    assert(chengpath.TextContains(report, "receipt_cid_match=1"),
           " compiler world fresh-node: receipt cid match")
    echo(" compiler_world_fresh_node_selfhost_smoke ok")
    return 0
