import std/system
import cheng/core/lang/intern as langintern
import cheng/core/tooling/perf_gate as perfgate

fn main() =
    let pool: langintern.InternPool = langintern.InternPoolNew()
    let base: perfgate.BenchDataset = perfgate.BenchDatasetLoadText(
        pool,
        "sha256 ns_per_op=10.000\nx25519 ns_per_op=20.500\n")
    let candidate: perfgate.BenchDataset = perfgate.BenchDatasetLoadText(
        pool,
        "sha256 ns_per_op=10.100\nx25519 ns_per_op=20.500\n")
    let compare: perfgate.BenchCompare = perfgate.BenchCompare(base, candidate, int64(1010))
    assert(compare.ok, " perf gate: within threshold")
    assert(compare.rows.len == 2, " perf gate: rows")
    let report: str = perfgate.BenchCompareReport(pool, compare)
    assert(report != "", " perf gate: report")
    echo(" perf_gate_smoke ok")
