import std/system
import std/seqs

type
    Pair =
        a: int32
        b: int32

fn main() =
    var items: Pair[] = []
    add(items, Pair(a: 7, b: 9))
    assert(items.len == 1, "std/composite seq add len")
    assert(items[0].a == 7, "std/composite seq add value a")
    assert(items[0].b == 9, "std/composite seq add value b")
