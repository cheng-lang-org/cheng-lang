# std foundation smoke: result/rawbytes/varint/stringlist/seqs

import std/system
import std/result
import std/option
import std/rawbytes
import std/varint
import std/stringlist
import std/sequninit
import std/seqs

fn main() =
    var numbers: int32[] = []
    seqs.Add(numbers, 7)
    seqs.Add(numbers, 9)
    assert(numbers.len == 2, "std/seqs add len")
    assert(numbers[0] == 7 && numbers[1] == 9, "std/seqs add values")

    let okRes: Result[int32] = Ok[int32](23)
    assert(IsOk(okRes) && Value(okRes) == 23, "std/result ok")
    let errRes: Result[int32] = Err[int32]("foundation-error")
    assert(IsErr(errRes), "std/result err")

    var data: Bytes = bytesAlloc(4)
    bytesSet(data, 0, 1)
    bytesSet(data, 1, 2)
    bytesSet(data, 2, 3)
    bytesSet(data, 3, 4)
    let part: Bytes = bytesSlice(data, 1, 2)
    let partText: str = bytesToHex(part)
    assert(partText == "0203", "std/rawbytes slice")
    assert(bytesToString(bytesFromString("cheng")) == "cheng", "std/rawbytes string roundtrip")

    let encoded: Bytes = encodeUVarint(300)
    let decodedRes: Result[VarintDecoded] = decodeUVarint(encoded, 0)
    assert(IsOk(decodedRes), "std/varint decode")
    let decoded: VarintDecoded = Value(decodedRes)
    assert(decoded.value == 300, "std/varint value")
    assert(decoded.next == bytesLen(encoded), "std/varint next")

    var list: StringList = initStringList()
    let addRes: Result[bool] = stringListAdd(list, "a")
    assert(IsOk(addRes) && Value(addRes), "std/stringlist add")
    let linesRes: Result[StringList] = stringListFromLines("x\ny\nx\n")
    assert(IsOk(linesRes), "std/stringlist fromLines")
    let list2: StringList = Value(linesRes)
    assert(stringListCount(list2) == 2, "std/stringlist dedupe")
