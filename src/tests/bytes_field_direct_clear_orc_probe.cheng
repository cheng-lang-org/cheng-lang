import std/system
import std/rawbytes

type
    PacketBox =
        payload: Bytes

fn main(): int32 =
    var box: PacketBox
    box.payload = bytesAlloc(24)
    let raw = box.payload.data
    if raw == nil:
        return 101
    box.payload = emptyBytes()
    let rc = memRefCount(raw)
    if box.payload.data != nil:
        return 100 + rc
    return rc
