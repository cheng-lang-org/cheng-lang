import std/system
import cheng/std/bytes_layout as layout
import cheng/oracle/oracle_types as oracle_types
import cheng/oracle/oracle_plane as oracle_plane
import cheng/oracle/oracle_bft_state_machine as oracle_bft
import cheng/tests/oracle_smoke_support as support

fn main(): int32 =
    let committee = support.oracleSmokeCommittee()
    var replicaA = oracle_bft.OracleBftStateMachineInit("oracle.bft.replica", committee)
    var replicaB = oracle_bft.OracleBftStateMachineInit("oracle.bft.replica", committee)
    var replicaC = oracle_bft.OracleBftStateMachineInit("oracle.bft.replica", committee)
    let pairId = support.oracleSmokePairId(oracle_types.OracleAssetBtc, oracle_types.OracleQuoteUsd)
    let pairIndex = oracle_types.OraclePairIndex(pairId)

    var txBatch = oracle_bft.OracleBftTxBatch()
    var txs: oracle_plane.OracleSignedBatch[]
    var txBytes: Bytes[]
    txs = []
    txBytes = []
    for reporterSlot in 1..<6:
        let batch = support.oracleSmokeBatch(int64(40), reporterSlot)
        add(txs, batch)
        add(txBytes, oracle_plane.OracleSignedBatchEncode(batch))
        oracle_bft.OracleBftTxBatchAdd(txBatch, batch)

    let context = oracle_bft.OracleBftBlockContextMake(int64(1),
                                                         0,
                                                         oracle_types.OracleRoundEndMs(int64(40)) + int64(1),
                                                         layout.FixedBytes32())
    for i in 0..<txs.len:
        var checkContext = context
        checkContext.txIndex = i
        let checkA = oracle_bft.OracleBftStateMachineCheckTxWithContext(replicaA, checkContext, txs[i])
        let checkB = oracle_bft.OracleBftStateMachineCheckTxBytesWithContext(replicaB, checkContext, txBytes[i])
        let decodeRes = oracle_plane.OracleSignedBatchDecode(txBytes[i])
        assert(decodeRes.ok, "oracle three replica smoke: decode")
        let checkC = oracle_bft.OracleBftStateMachineCheckTxWithContext(replicaC, checkContext, decodeRes.value)
        assert(checkA.code == oracle_bft.OracleBftCodeOk, "oracle three replica smoke: checkA")
        assert(checkB.code == oracle_bft.OracleBftCodeOk, "oracle three replica smoke: checkB")
        assert(checkC.code == oracle_bft.OracleBftCodeOk, "oracle three replica smoke: checkC")

    var summaryA: oracle_bft.OracleBftBlockSummary
    var summaryB: oracle_bft.OracleBftBlockSummary
    var summaryC: oracle_bft.OracleBftBlockSummary
    oracle_bft.OracleBftStateMachineFinalizeBatchSummaryWithContext(replicaA, context, txBatch, summaryA)
    oracle_bft.OracleBftStateMachineFinalizeBlockBytesSummaryWithContext(replicaB, context, txBytes, summaryB)
    oracle_bft.OracleBftStateMachineFinalizeBlockSummaryWithContext(replicaC, context, txs, summaryC)

    let commitA = oracle_bft.OracleBftStateMachineCommit(replicaA)
    let commitB = oracle_bft.OracleBftStateMachineCommit(replicaB)
    let commitC = oracle_bft.OracleBftStateMachineCommit(replicaC)
    assert(layout.fixedBytes32Equal(commitA.appHash, commitB.appHash), "oracle three replica smoke: apphash ab")
    assert(layout.fixedBytes32Equal(commitA.appHash, commitC.appHash), "oracle three replica smoke: apphash ac")
    assert(summaryA.lastFinalizedRoundId == int64(40), "oracle three replica smoke: summaryA round")
    assert(summaryB.lastFinalizedRoundId == int64(40), "oracle three replica smoke: summaryB round")
    assert(summaryC.lastFinalizedRoundId == int64(40), "oracle three replica smoke: summaryC round")

    let latestA = oracle_bft.OracleBftStateMachineQueryLatest(replicaA,
                                                                pairId,
                                                                oracle_types.OracleRoundEndMs(int64(40)) + int64(1))
    let latestB = oracle_bft.OracleBftStateMachineQueryLatest(replicaB,
                                                                pairId,
                                                                oracle_types.OracleRoundEndMs(int64(40)) + int64(1))
    let latestC = oracle_bft.OracleBftStateMachineQueryLatest(replicaC,
                                                                pairId,
                                                                oracle_types.OracleRoundEndMs(int64(40)) + int64(1))
    assert(latestA.code == oracle_bft.OracleBftCodeOk, "oracle three replica smoke: latestA")
    assert(latestB.code == oracle_bft.OracleBftCodeOk, "oracle three replica smoke: latestB")
    assert(latestC.code == oracle_bft.OracleBftCodeOk, "oracle three replica smoke: latestC")
    let expectedMedian = support.oracleSmokePrice(int64(40), pairIndex, 3)
    assert(latestA.priceE8 == expectedMedian, "oracle three replica smoke: latestA median")
    assert(latestB.priceE8 == expectedMedian, "oracle three replica smoke: latestB median")
    assert(latestC.priceE8 == expectedMedian, "oracle three replica smoke: latestC median")

    let twapA = oracle_bft.OracleBftStateMachineQueryTwap(replicaA,
                                                            pairId,
                                                            1,
                                                            oracle_types.OracleRoundEndMs(int64(40)) + int64(1))
    let twapB = oracle_bft.OracleBftStateMachineQueryTwap(replicaB,
                                                            pairId,
                                                            1,
                                                            oracle_types.OracleRoundEndMs(int64(40)) + int64(1))
    let twapC = oracle_bft.OracleBftStateMachineQueryTwap(replicaC,
                                                            pairId,
                                                            1,
                                                            oracle_types.OracleRoundEndMs(int64(40)) + int64(1))
    assert(twapA.priceE8 == latestA.priceE8, "oracle three replica smoke: twapA")
    assert(twapB.priceE8 == latestB.priceE8, "oracle three replica smoke: twapB")
    assert(twapC.priceE8 == latestC.priceE8, "oracle three replica smoke: twapC")
    assert(commitA.lastFinalizedRoundId == commitB.lastFinalizedRoundId,
        "oracle three replica smoke: round ab")
    assert(commitA.lastFinalizedRoundId == commitC.lastFinalizedRoundId,
        "oracle three replica smoke: round ac")

    echo(" oracle_bft_three_replica_smoke ok")
    return 0
