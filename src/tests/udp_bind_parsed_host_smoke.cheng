import std/system
import std/result
import std/os
import cheng/quic/platform/datapath_udp as qudp

fn main(): int32 =
    let parsedRes = qudp.udpParseAddr("/ip4/127.0.0.1/udp/6210/quic-v1")
    assert(IsOk(parsedRes), "udp bind parsed host: parse failed")
    let parsed = Value(parsedRes)
    let hostText = qudp.udpNormalizeHost(parsed.host, parsed.isV6)
    let fd = os.UdpBindFdBridge(hostText, parsed.port, 0)
    assert(fd >= 0, "udp bind parsed host: bind failed")
    let closeRc = os.UdpCloseFd(fd)
    assert(closeRc == 0, "udp bind parsed host: close failed")
    echo("v3 udp_bind_parsed_host_smoke ok")
    return 0
