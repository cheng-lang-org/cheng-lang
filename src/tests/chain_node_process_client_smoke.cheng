import std/system
import std/cmdline as cmdline
import cheng/chain/anti_entropy as anti
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net
import cheng/libp2p/core/types
import cheng/libp2p/transports/tcp_transport

fn main(): int32 =
    let port = cmdline.ReadInt32FlagOrDefault("--port", -1)
    assert(port > 0, " chain_node process client: invalid port")

    var client: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(client, "process.client", "process.loopback")),
           " chain_node: init")
    let payloadRes = tcp_transport.Libp2pTcpRecvPayloadOnce("127.0.0.1",
                                                              port,
                                                              types.Libp2pProtocolSync)
    assert(payloadRes.ok, " chain_node process client: recv payload")

    var snapshot: node.ChainNodeServeSnapshot
    let snapshotRes = net.ChainNodeLibp2pDecodeSnapshotInto(payloadRes.value, snapshot)
    assert(snapshotRes.ok, " chain_node process client: decode snapshot")

    let syncRes = node.ChainNodeSyncOnce(client, snapshot)
    assert(syncRes.ok, " chain_node process client: sync")
    assert(syncRes.value, " chain_node process client: sync changed")

    let aliceRes = node.ChainNodeBalance(client, 11, 1001)
    let bobRes = node.ChainNodeBalance(client, 11, 2002)
    assert(aliceRes.ok, " chain_node process client: alice balance")
    assert(bobRes.ok, " chain_node process client: bob balance")
    assert(aliceRes.value == int64(55), " chain_node process client: alice 55")
    assert(bobRes.value == int64(33), " chain_node process client: bob 33")

    var clientSnapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(clientSnapshot, client)
    assert(anti.AntiEntropySignatureEqual(snapshot.signature, clientSnapshot.signature),
        " chain_node process client: signature")
    echo(" chain_node_process_client_smoke ok")
    return 0
