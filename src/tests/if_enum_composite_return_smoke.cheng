type
    IfEnumSmoke = enum
        IfEnumSmokeNo
        IfEnumSmokeYes

fn IfEnumCompositeReturn(flag: IfEnumSmoke): str =
    if flag == IfEnumSmokeYes:
        return "yes"
    return "no"

fn main(): int32 =
    assert(IfEnumCompositeReturn(IfEnumSmokeYes) == "yes", " if enum composite return: yes")
    assert(IfEnumCompositeReturn(IfEnumSmokeNo) == "no", " if enum composite return: no")
    echo(" if_enum_composite_return_smoke ok")
    return 0
