import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt
import cheng/chain/csg
import cheng/chain/pubsub

fn main(): int32 =
    var centerRes: Result[types.V3LsmrAddress]
    centerRes = types.v3LsmrAddressFromDigits([5, 5, 5])
    assert(IsOk(centerRes), "v3 pubsub smoke: center address")
    var center = Value(centerRes)
    var topicRes = pubsub.v3PubSubTopicFromAddress(center,
                                                   2,
                                                   lt.v3PubSubModeXun,
                                                   pubsub.v3PubSubSemanticFingerprint([11, 22, 33]))
    assert(IsOk(topicRes), "v3 pubsub smoke: topic")
    var topic = Value(topicRes)
    assert(topic.layerId == lt.v3LayerRegional, "v3 pubsub smoke: regional layer")
    assert(topic.scopeDepth == 1, "v3 pubsub smoke: scope depth")

    var payloadCid = lt.v3HashInts("v3.test.delta", [9, 8, 7])
    var payloadSummaryCid = lt.v3HashInts("v3.test.delta.summary", [1, 2])
    var envelope = pubsub.v3PubSubEnvelopeMake(topic.topicCid,
                                               pubsub.v3PubSubPayloadKindCsgDelta,
                                               payloadCid,
                                               payloadSummaryCid)

    var subscriptions: pubsub.V3PubSubSubscription[]
    subscriptions = []
    add(subscriptions, pubsub.v3PubSubSubscriptionMake(1, center, csg.v3CsgBarrierModeGen, topic.topicCid))
    var eastNearRes: Result[types.V3LsmrAddress]
    eastNearRes = types.v3LsmrAddressFromDigits([5, 8, 1])
    assert(IsOk(eastNearRes), "v3 pubsub smoke: east near")
    add(subscriptions, pubsub.v3PubSubSubscriptionMake(2, Value(eastNearRes), csg.v3CsgBarrierModeGen, topic.topicCid))
    var eastFarRes: Result[types.V3LsmrAddress]
    eastFarRes = types.v3LsmrAddressFromDigits([5, 8, 6])
    assert(IsOk(eastFarRes), "v3 pubsub smoke: east far")
    add(subscriptions, pubsub.v3PubSubSubscriptionMake(3, Value(eastFarRes), csg.v3CsgBarrierModeGen, topic.topicCid))
    var northRes: Result[types.V3LsmrAddress]
    northRes = types.v3LsmrAddressFromDigits([5, 1, 6])
    assert(IsOk(northRes), "v3 pubsub smoke: north")
    add(subscriptions, pubsub.v3PubSubSubscriptionMake(4, Value(northRes), csg.v3CsgBarrierModeGen, topic.topicCid))
    var westRes: Result[types.V3LsmrAddress]
    westRes = types.v3LsmrAddressFromDigits([5, 3, 4])
    assert(IsOk(westRes), "v3 pubsub smoke: west")
    add(subscriptions, pubsub.v3PubSubSubscriptionMake(5, Value(westRes), csg.v3CsgBarrierModeGen, topic.topicCid))
    var remoteRes: Result[types.V3LsmrAddress]
    remoteRes = types.v3LsmrAddressFromDigits([8, 1, 6])
    assert(IsOk(remoteRes), "v3 pubsub smoke: remote")
    add(subscriptions, pubsub.v3PubSubSubscriptionMake(6, Value(remoteRes), csg.v3CsgBarrierModeGen, topic.topicCid))

    var planRes = pubsub.v3PubSubBuildPlan(topic, envelope, subscriptions)
    assert(IsOk(planRes), "v3 pubsub smoke: plan")
    var plan = Value(planRes)
    assert(plan.subscriberCount == 4, "v3 pubsub smoke: xun selected four branches")
    assert(plan.branchCount == 4, "v3 pubsub smoke: four branches")
    var eastBranch = pubsub.v3PubSubPlanBranchPos(plan, 8)
    assert(eastBranch >= 0, "v3 pubsub smoke: east branch exists")
    assert(plan.branchNodeCounts[eastBranch] == 1, "v3 pubsub smoke: east branch minimized")
    assert(types.v3LsmrAddressText(plan.branchPrimaryAddresses[eastBranch]) == "5.8.1", "v3 pubsub smoke: nearest east branch kept")

    echo("v3 pubsub_smoke ok")
    return 0
