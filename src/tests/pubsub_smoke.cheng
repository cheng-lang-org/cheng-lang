import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt
import cheng/chain/csg
import cheng/chain/pubsub

fn main(): int32 =
    var centerRes: Result[types.LsmrAddress]
    centerRes = types.LsmrAddressFromDigits([5, 5, 5])
    assert(IsOk(centerRes), " pubsub smoke: center address")
    var center = Value(centerRes)
    var topicRes = pubsub.PubSubTopicFromAddress(center,
                                                   2,
                                                   lt.PubSubModeXun,
                                                   pubsub.PubSubSemanticFingerprint([11, 22, 33]))
    assert(IsOk(topicRes), " pubsub smoke: topic")
    var topic = Value(topicRes)
    assert(topic.layerId == lt.LayerRegional, " pubsub smoke: regional layer")
    assert(topic.scopeDepth == 1, " pubsub smoke: scope depth")

    var payloadCid = lt.HashInts("cheng.test.delta", [9, 8, 7])
    var payloadSummaryCid = lt.HashInts("cheng.test.delta.summary", [1, 2])
    var envelope = pubsub.PubSubEnvelopeMake(topic.topicCid,
                                               pubsub.PubSubPayloadKindCsgDelta,
                                               payloadCid,
                                               payloadSummaryCid)

    var subscriptions: pubsub.PubSubSubscription[]
    subscriptions = []
    add(subscriptions, pubsub.PubSubSubscriptionMake(1, center, csg.CsgBarrierModeGen, topic.topicCid))
    var eastNearRes: Result[types.LsmrAddress]
    eastNearRes = types.LsmrAddressFromDigits([5, 8, 1])
    assert(IsOk(eastNearRes), " pubsub smoke: east near")
    add(subscriptions, pubsub.PubSubSubscriptionMake(2, Value(eastNearRes), csg.CsgBarrierModeGen, topic.topicCid))
    var eastFarRes: Result[types.LsmrAddress]
    eastFarRes = types.LsmrAddressFromDigits([5, 8, 6])
    assert(IsOk(eastFarRes), " pubsub smoke: east far")
    add(subscriptions, pubsub.PubSubSubscriptionMake(3, Value(eastFarRes), csg.CsgBarrierModeGen, topic.topicCid))
    var northRes: Result[types.LsmrAddress]
    northRes = types.LsmrAddressFromDigits([5, 1, 6])
    assert(IsOk(northRes), " pubsub smoke: north")
    add(subscriptions, pubsub.PubSubSubscriptionMake(4, Value(northRes), csg.CsgBarrierModeGen, topic.topicCid))
    var westRes: Result[types.LsmrAddress]
    westRes = types.LsmrAddressFromDigits([5, 3, 4])
    assert(IsOk(westRes), " pubsub smoke: west")
    add(subscriptions, pubsub.PubSubSubscriptionMake(5, Value(westRes), csg.CsgBarrierModeGen, topic.topicCid))
    var remoteRes: Result[types.LsmrAddress]
    remoteRes = types.LsmrAddressFromDigits([8, 1, 6])
    assert(IsOk(remoteRes), " pubsub smoke: remote")
    add(subscriptions, pubsub.PubSubSubscriptionMake(6, Value(remoteRes), csg.CsgBarrierModeGen, topic.topicCid))

    var planRes = pubsub.PubSubBuildPlan(topic, envelope, subscriptions)
    assert(IsOk(planRes), " pubsub smoke: plan")
    var plan = Value(planRes)
    assert(plan.subscriberCount == 4, " pubsub smoke: xun selected four branches")
    assert(plan.branchCount == 4, " pubsub smoke: four branches")
    var eastBranch = pubsub.PubSubPlanBranchPos(plan, 8)
    assert(eastBranch >= 0, " pubsub smoke: east branch exists")
    assert(plan.branchNodeCounts[eastBranch] == 1, " pubsub smoke: east branch minimized")
    assert(types.LsmrAddressText(plan.branchPrimaryAddresses[eastBranch]) == "5.8.1", " pubsub smoke: nearest east branch kept")

    echo(" pubsub_smoke ok")
    return 0
