import std/strings
import cheng/core/backend/concurrent_assembly as cassem

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn main(): int32 =
    let c1 = check(cassem.ConcurrentAssemblyWorkerCountFor(0, 16) == 0, 11)
    if c1 != 0: return c1
    let c2 = check(cassem.ConcurrentAssemblyWorkerCountFor(10, 16) == 10, 12)
    if c2 != 0: return c2
    let c3 = check(cassem.ConcurrentAssemblyWorkerCountFor(100, 8) == 8, 13)
    if c3 != 0: return c3
    let c4 = check(cassem.ConcurrentAssemblyWorkerCountFor(5, 64) == 5, 14)
    if c4 != 0: return c4
    let c5 = check(cassem.ConcurrentAssemblyWorkerCountFor(1000, 64) == 64, 15)
    if c5 != 0: return c5

    var ctx = cassem.ConcurrentAssemblyNew(42, 8)
    let c6 = check(ctx.totalFunctions == 42, 21)
    if c6 != 0: return c6
    let c7 = check(ctx.workerCount == 8, 22)
    if c7 != 0: return c7

    let report = cassem.ConcurrentAssemblyReport(ctx)
    let c8 = check(strings.Len(report) > 0, 31)
    if c8 != 0: return c8

    let verified = cassem.ConcurrentAssemblyVerify(ctx)
    let c9 = check(!verified, 41)
    if c9 != 0: return c9

    cassem.ConcurrentAssemblyFree(ctx)

    echo("concurrent_assembly_smoke ok")
    return 0
