import std/atomic

fn main(): int32 =
    let value = atomic.NewI32(0)
    if value == nil:
        return 11
    if !atomic.CasI32(value, 0, 7):
        return 12
    if atomic.LoadI32(value) != 7:
        return 13
    atomic.StoreI32(value, 9)
    if atomic.LoadI32(value) != 9:
        return 14
    echo(" atomic_i32_runtime_smoke ok")
    return 0
