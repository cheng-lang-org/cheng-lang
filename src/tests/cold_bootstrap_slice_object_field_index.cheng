type ColdRecord = object
    base: int32
    step: int32
    values: int32[3]

fn MakeRecord(): ColdRecord =
    return ColdRecord(base: 9, step: 4, values: [5, 7, 11])

fn Score(record: ColdRecord): int32 =
    return record.base + record.step + record.values[2]

fn main(): int32 =
    let record = MakeRecord()
    return Score(record)
