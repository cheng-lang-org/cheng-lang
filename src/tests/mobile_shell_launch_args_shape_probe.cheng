import std/monotimes
import std/os
import std/strings
import std/json as json
import cheng/core/tooling/mobile_shell_codegen as mshell
import cheng/core/tooling/path as chengpath

fn probeCStringLiteral(text: str): str =
    var out: str = "\""
    var i: int32
    for i in i..<len(text):
        let ch: char = text[i]
        let code: int32 = int32(ch)
        if code == 92:
            out = Fmt"{out}\\\\"
        elif code == 34:
            out = Fmt"{out}\\\""
        elif code == 10:
            out = Fmt"{out}\\n"
        elif code == 13:
            out = Fmt"{out}\\r"
        elif code == 9:
            out = Fmt"{out}\\t"
        else:
            let piece: str = strings.CharToStr(ch)
            out = Fmt"{out}{piece}"
    return Fmt"{out}\""

fn probeLaunchArgsKv(routeState: str,
                     runtimeMode: str,
                     runtimeManifestRel: str,
                     runtimeContractPayloadRel: str,
                     runtimeBundlePayloadRel: str): str =
    return Fmt"gate_mode=android-semantic-visual-1to1;truth_mode=strict;route_state={routeState};route_lock=1;runtime_mode={runtimeMode};runtime_manifest={runtimeManifestRel};runtime_contract_payload={runtimeContractPayloadRel};runtime_bundle_payload={runtimeBundlePayloadRel}"

fn probeLaunchArgsJson(routeState: str,
                       runtimeMode: str,
                       runtimeManifestRel: str,
                       runtimeContractPayloadRel: str,
                       runtimeBundlePayloadRel: str): str =
    var doc: json.JsonNode = json.NewJObject()
    json.JsonSetFieldStr(doc, "format", "mobile_shell_launch_args_v1")
    json.JsonSetFieldStr(doc, "gate_mode", "android-semantic-visual-1to1")
    json.JsonSetFieldStr(doc, "truth_mode", "strict")
    json.JsonSetFieldStr(doc, "route_state", routeState)
    json.JsonSetFieldBool(doc, "route_lock", true)
    json.JsonSetFieldStr(doc, "runtime_mode", runtimeMode)
    json.JsonSetFieldStr(doc, "runtime_manifest", runtimeManifestRel)
    json.JsonSetFieldStr(doc, "runtime_contract_payload", runtimeContractPayloadRel)
    json.JsonSetFieldStr(doc, "runtime_bundle_payload", runtimeBundlePayloadRel)
    let rendered: str = json.Stringify(doc)
    return Fmt"{rendered}\n"

fn probeAndroidHostSourceOldShape(opts: var mshell.MobileShellOptions): str =
    let runtimeManifestRel: str = "mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "runtime/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "runtime/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKv: str = probeLaunchArgsKv(opts.routeState,
                                              opts.runtimeMode,
                                              runtimeManifestRel,
                                              runtimeContractPayloadRel,
                                              runtimeBundlePayloadRel)
    let launchArgsJson: str = probeLaunchArgsJson(opts.routeState,
                                                  opts.runtimeMode,
                                                  runtimeManifestRel,
                                                  runtimeContractPayloadRel,
                                                  runtimeBundlePayloadRel)
    let launchArgsKvQuote: str = probeCStringLiteral(launchArgsKv)
    let launchArgsJsonQuote: str = probeCStringLiteral(launchArgsJson)
    return Fmt"""
    #include <jni.h>
    #include <android/log.h>
    #include <android/native_window_jni.h>
    #include <dlfcn.h>
    #include <stdio.h>
    #include <stdint.h>
    #include <stdlib.h>
    #include <string.h>

    typedef uint64_t (*cheng_app_init_fn)(void);
    typedef void (*cheng_app_set_window_fn)(uint64_t, uint64_t, int, int, float);
    typedef void (*cheng_app_tick_fn)(uint64_t, float);
    typedef void (*cheng_app_on_touch_fn)(uint64_t, int, int, float, float);
    typedef void (*cheng_app_pause_fn)(uint64_t);
    typedef void (*cheng_app_resume_fn)(uint64_t);
    typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);

    static cheng_app_init_fn s_app_init = NULL;
    static cheng_app_set_window_fn s_app_set_window = NULL;
    static cheng_app_tick_fn s_app_tick = NULL;
    static cheng_app_on_touch_fn s_app_on_touch = NULL;
    static cheng_app_pause_fn s_app_pause = NULL;
    static cheng_app_resume_fn s_app_resume = NULL;

    static const char* kChengRuntimeManifest = "{runtimeManifestRel}";
    static const char* kChengLaunchArgsKv = {launchArgsKvQuote};
    static const char* kChengLaunchArgsJson = {launchArgsJsonQuote};

    static int cheng_resolve_exports(void) {{
      void* s_app_handle = dlopen("libcheng_launch_args_probe.so", RTLD_NOW | RTLD_GLOBAL);
      if (s_app_handle == NULL) {{
        return 0;
      }}
      s_app_init = (cheng_app_init_fn)dlsym(s_app_handle, "cheng_app_init");
      s_app_set_window = (cheng_app_set_window_fn)dlsym(s_app_handle, "cheng_app_set_window");
      s_app_tick = (cheng_app_tick_fn)dlsym(s_app_handle, "cheng_app_tick");
      s_app_on_touch = (cheng_app_on_touch_fn)dlsym(s_app_handle, "cheng_app_on_touch");
      s_app_pause = (cheng_app_pause_fn)dlsym(s_app_handle, "cheng_app_pause");
      s_app_resume = (cheng_app_resume_fn)dlsym(s_app_handle, "cheng_app_resume");
      cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(s_app_handle, "cheng_mobile_host_runtime_set_launch_args");
      if (setLaunchArgs != NULL) {{
        setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);
      }}
      return s_app_init && s_app_set_window && s_app_tick && s_app_on_touch && s_app_pause && s_app_resume;
    }}

    """

fn probeIosHostSourceOldShape(opts: var mshell.MobileShellOptions): str =
    let runtimeManifestRel: str = "runtime/mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "runtime/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "runtime/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKv: str = probeLaunchArgsKv(opts.routeState,
                                              opts.runtimeMode,
                                              runtimeManifestRel,
                                              runtimeContractPayloadRel,
                                              runtimeBundlePayloadRel)
    let launchArgsJson: str = probeLaunchArgsJson(opts.routeState,
                                                  opts.runtimeMode,
                                                  runtimeManifestRel,
                                                  runtimeContractPayloadRel,
                                                  runtimeBundlePayloadRel)
    let launchArgsKvQuote: str = probeCStringLiteral(launchArgsKv)
    let launchArgsJsonQuote: str = probeCStringLiteral(launchArgsJson)
    return Fmt"""
    #import <UIKit/UIKit.h>
    #import <QuartzCore/CAMetalLayer.h>
    #import <Metal/Metal.h>
    #import <dlfcn.h>

    typedef unsigned long long (*cheng_app_init_fn)(void);
    typedef void (*cheng_app_set_window_fn)(unsigned long long, unsigned long long, int, int, float);
    typedef void (*cheng_app_tick_fn)(unsigned long long, float);
    typedef void (*cheng_app_on_touch_fn)(unsigned long long, int, int, float, float);
    typedef void (*cheng_app_pause_fn)(unsigned long long);
    typedef void (*cheng_app_resume_fn)(unsigned long long);
    typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);

    static const char* kChengRuntimeManifest = "{runtimeManifestRel}";
    static const char* kChengLaunchArgsKv = {launchArgsKvQuote};
    static const char* kChengLaunchArgsJson = {launchArgsJsonQuote};

    @interface ChengGeneratedMetalView : UIView
    @property(nonatomic) unsigned long long appId;
    @end

    @implementation ChengGeneratedMetalView {{
        cheng_app_set_window_fn _setWindow;
        cheng_app_tick_fn _tick;
    }}

    - (instancetype)initWithFrame:(CGRect)frame {{
        self = [super initWithFrame:frame];
        if (self == nil) {{
            return nil;
        }}
        void* handle = dlopen(NULL, RTLD_NOW);
        cheng_app_init_fn initFn = (cheng_app_init_fn)dlsym(handle, "cheng_app_init");
        _setWindow = (cheng_app_set_window_fn)dlsym(handle, "cheng_app_set_window");
        _tick = (cheng_app_tick_fn)dlsym(handle, "cheng_app_tick");
        cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(handle, "cheng_mobile_host_runtime_set_launch_args");
        if (setLaunchArgs != NULL) {{
            setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);
        }}
        if (initFn != NULL) {{
            self.appId = initFn();
        }}
        return self;
    }}

    """

fn probeHarmonyHostSourceOldShape(opts: var mshell.MobileShellOptions): str =
    let runtimeManifestRel: str = "rawfile/mobile_shell_runtime_contract_v1.json"
    let runtimeContractPayloadRel: str = "rawfile/mobile_shell_runtime_contract_payload.json"
    let runtimeBundlePayloadRel: str = "rawfile/mobile_shell_runtime_bundle_payload.json"
    let launchArgsKv: str = probeLaunchArgsKv(opts.routeState,
                                              opts.runtimeMode,
                                              runtimeManifestRel,
                                              runtimeContractPayloadRel,
                                              runtimeBundlePayloadRel)
    let launchArgsJson: str = probeLaunchArgsJson(opts.routeState,
                                                  opts.runtimeMode,
                                                  runtimeManifestRel,
                                                  runtimeContractPayloadRel,
                                                  runtimeBundlePayloadRel)
    let launchArgsKvQuote: str = probeCStringLiteral(launchArgsKv)
    let launchArgsJsonQuote: str = probeCStringLiteral(launchArgsJson)
    return Fmt"""
    #include <ace/xcomponent/native_interface_xcomponent.h>
    #include <hilog/log.h>
    #include <native_window/external_window.h>
    #include <dlfcn.h>
    #include <stdint.h>

    typedef uint64_t (*cheng_app_init_fn)(void);
    typedef void (*cheng_app_set_window_fn)(uint64_t, uint64_t, int, int, float);
    typedef void (*cheng_app_tick_fn)(uint64_t, float);
    typedef void (*cheng_app_on_touch_fn)(uint64_t, int, int, float, float);
    typedef void (*cheng_app_pause_fn)(uint64_t);
    typedef void (*cheng_app_resume_fn)(uint64_t);
    typedef void (*cheng_mobile_host_runtime_set_launch_args_fn)(const char*, const char*);

    static const char* kChengRuntimeManifest = "{runtimeManifestRel}";
    static const char* kChengLaunchArgsKv = {launchArgsKvQuote};
    static const char* kChengLaunchArgsJson = {launchArgsJsonQuote};

    static int cheng_harmony_init_runtime(void) {{
      void* handle = dlopen(NULL, RTLD_NOW);
      cheng_app_init_fn initFn = (cheng_app_init_fn)dlsym(handle, "cheng_app_init");
      cheng_mobile_host_runtime_set_launch_args_fn setLaunchArgs = (cheng_mobile_host_runtime_set_launch_args_fn)dlsym(handle, "cheng_mobile_host_runtime_set_launch_args");
      if (setLaunchArgs != NULL) {{
        setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);
      }}
      return initFn != NULL;
    }}

    """

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let stamp: str = int64ToStr(monotimes.MonoTimeNs(monotimes.GetMonoTime()))
    let outDir: str = Fmt"/tmp/cheng_mobile_shell_launch_args_shape_probe_{stamp}"
    assert(chengpath.MkdirP(root, outDir), "mobile shell launch args shape probe: mkdir")
    var opts: mshell.MobileShellOptions = mshell.MobileShellDefaultOptions(root)
    opts.outDir = outDir
    opts.runtimeMode = "r2c_native_gui_v1"
    opts.routeState = "home_default"
    let androidText: str = probeAndroidHostSourceOldShape(opts)
    let iosText: str = probeIosHostSourceOldShape(opts)
    let harmonyText: str = probeHarmonyHostSourceOldShape(opts)
    let kv: str = probeLaunchArgsKv(opts.routeState,
                                    opts.runtimeMode,
                                    "mobile_shell_runtime_contract_v1.json",
                                    "runtime/mobile_shell_runtime_contract_payload.json",
                                    "runtime/mobile_shell_runtime_bundle_payload.json")
    let jsonText: str = probeLaunchArgsJson(opts.routeState,
                                            opts.runtimeMode,
                                            "mobile_shell_runtime_contract_v1.json",
                                            "runtime/mobile_shell_runtime_contract_payload.json",
                                            "runtime/mobile_shell_runtime_bundle_payload.json")
    assert(strings.StrContains(androidText, "kChengLaunchArgsKv"),
           "mobile shell launch args shape probe: kv symbol")
    assert(strings.StrContains(androidText, "route_state=home_default"),
           "mobile shell launch args shape probe: route text")
    assert(strings.StrContains(androidText, "setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);"),
           "mobile shell launch args shape probe: launch args call")
    assert(strings.StrContains(iosText, "setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);"),
           "mobile shell launch args shape probe: ios launch args call")
    assert(strings.StrContains(harmonyText, "setLaunchArgs(kChengLaunchArgsKv, kChengLaunchArgsJson);"),
           "mobile shell launch args shape probe: harmony launch args call")
    var files: str[]
    var errorText: str
    let kvPath: str = os.JoinPath(outDir, "launch_args.kv.txt")
    let jsonPath: str = os.JoinPath(outDir, "launch_args.json")
    let hostPath: str = os.JoinPath(outDir, "android_host_old_shape.c")
    let iosPath: str = os.JoinPath(outDir, "ios_host_old_shape.m")
    let harmonyPath: str = os.JoinPath(outDir, "harmony_host_old_shape.cpp")
    assert(mshell.MobileShellWriteFile(kvPath,
                                         kv,
                                         "launch_args.kv.txt",
                                         files,
                                         errorText),
           "mobile shell launch args shape probe: write kv")
    assert(mshell.MobileShellWriteFile(jsonPath,
                                         jsonText,
                                         "launch_args.json",
                                         files,
                                         errorText),
           "mobile shell launch args shape probe: write json")
    assert(mshell.MobileShellWriteFile(hostPath,
                                         androidText,
                                         "android_host_old_shape.c",
                                         files,
                                         errorText),
           "mobile shell launch args shape probe: write host")
    assert(mshell.MobileShellWriteFile(iosPath,
                                         iosText,
                                         "ios_host_old_shape.m",
                                         files,
                                         errorText),
           "mobile shell launch args shape probe: write ios")
    assert(mshell.MobileShellWriteFile(harmonyPath,
                                         harmonyText,
                                         "harmony_host_old_shape.cpp",
                                         files,
                                         errorText),
           "mobile shell launch args shape probe: write harmony")
    assert(len(errorText) == 0, "mobile shell launch args shape probe: empty error")
    assert(files.len == 5, "mobile shell launch args shape probe: file count")
    echo(" mobile_shell_launch_args_shape_probe ok")
    return 0
