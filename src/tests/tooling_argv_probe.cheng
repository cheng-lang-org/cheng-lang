import std/cmdline as cmdline
import std/os
import std/strutils as strutil

fn argvProbeLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.CaptureCmdLine(argc, argv)
    let count = cmdline.ParamCount()
    argvProbeLine(strutil.Join(["count=", IntToStr(count)], ""))
    for i in 0..count:
        var line = "arg["
        line = strutil.Join([line, IntToStr(i)], "")
        line = strutil.Join([line, "]="], "")
        line = strutil.Join([line, cmdline.ParamStr(i)], "")
        argvProbeLine(line)
    argvProbeLine(strutil.Join(["flag_emit=", cmdline.ReadFlagOrDefault("--emit", "<missing>")], ""))
    argvProbeLine(strutil.Join(["flag_root=", cmdline.ReadFlagOrDefault("--root", "<missing>")], ""))
    argvProbeLine(strutil.Join(["flag_in=", cmdline.ReadFlagOrDefault("--in", "<missing>")], ""))
    argvProbeLine(strutil.Join(["flag_out=", cmdline.ReadFlagOrDefault("--out", "<missing>")], ""))
    return 0
