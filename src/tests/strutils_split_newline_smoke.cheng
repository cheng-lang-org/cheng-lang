import std/system
import std/strutils as strutil

fn main(): int32 =
    let text = "left\nright\n"
    assert(text.len == 11, "v3 std/strutils newline string len")
    assert(text[4] == '\n', "v3 std/strutils newline char literal")
    assert(text[10] == '\n', "v3 std/strutils trailing newline char literal")
    let parts = strutil.Split(text, text[4])
    assert(parts.len == 3, "v3 std/strutils split newline len")
    assert(parts[0] == "left", "v3 std/strutils split newline first")
    assert(parts[1] == "right", "v3 std/strutils split newline second")
    assert(parts[2] == "", "v3 std/strutils split newline trailing empty")
    let escapedParts = strutil.Split(text, '\n')
    assert(escapedParts.len == 3, "v3 std/strutils split escaped newline len")
    echo("v3 strutils_split_newline_smoke ok")
    return 0
