fn FrontendIsIdentStart(ch: uint8): bool =
    return (ch >= 'A' && ch <= 'Z') || (ch >= 'a' && ch <= 'z') || ch == '_'

fn FrontendIsIdentCont(ch: uint8): bool =
    return FrontendIsIdentStart(ch) || (ch >= '0' && ch <= '9')

fn FrontendIsSpace(ch: uint8): bool =
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'

fn FrontendLineIndentWidth(line: str): int32 =
    var indent: int32 = 0
    for i in 0..<len(line):
        let ch: uint8 = line[i]
        if ch == ' ':
            indent = indent + 1
        elif ch == '\t':
            indent = indent + 4
        else:
            return indent
    return indent

fn FrontendTextIsFactSafe(text: str): bool =
    for i in 0..<len(text):
        let ch: uint8 = text[i]
        if ch == '\t' || ch == '\n' || ch == '\r':
            return false
    return true

fn FrontendIdentPrefixLen(text: str, start: int32): int32 =
    var pos: int32 = start
    if pos >= len(text):
        return 0
    if !FrontendIsIdentStart(text[pos]):
        return 0
    pos = pos + 1
    while pos < len(text) && FrontendIsIdentCont(text[pos]):
        pos = pos + 1
    return pos - start

fn FrontendFunctionNameLenFromLine(line: str): int32 =
    if len(line) < 3:
        return 0
    if line[0] != 'f' || line[1] != 'n' || line[2] != ' ':
        return 0
    var pos: int32 = 3
    while pos < len(line) && line[pos] == ' ':
        pos = pos + 1
    return FrontendIdentPrefixLen(line, pos)

fn FrontendSkipWhitespaceAndLineComments(source: str, start: int32): int32 =
    var pos: int32 = start
    while pos < len(source):
        let ch: uint8 = source[pos]
        if FrontendIsSpace(ch):
            pos = pos + 1
        elif ch == '/' && pos + 1 < len(source) && source[pos + 1] == '/':
            pos = pos + 2
            while pos < len(source) && source[pos] != '\n':
                pos = pos + 1
        else:
            return pos
    return pos

fn main(): int32 =
    let starts: bool = FrontendIsIdentStart('A') && !FrontendIsIdentStart('9')
    if !starts:
        return 11
    if !FrontendIsIdentStart('A'):
        return 1
    if FrontendIsIdentStart('9'):
        return 2
    if !FrontendIsIdentCont('9'):
        return 3
    if !FrontendIsSpace('\n'):
        return 4
    if FrontendLineIndentWidth("       body") != 7:
        return 5
    if !FrontendTextIsFactSafe("cold_fact"):
        return 7
    if FrontendIdentPrefixLen("Token42 rest", 0) != 7:
        return 8
    if FrontendFunctionNameLenFromLine("fn ParserToken(source: str)") != 11:
        return 9
    if FrontendSkipWhitespaceAndLineComments("  // skip me", 0) != 12:
        return 10
    if len("a\n") != 2:
        return 12
    if "a\n"[1] != '\n':
        return 13
    return 42
