fn BackendDispatchSurfaceOpaque(plan: ext.Plan,
                                 req: Result[ext.Request],
                                 cursor: var ext.Cursor): int32 =
    return 7

fn BackendDispatchSurfaceAppend(out: var str,
                                 line: str): int32 =
    out = line
    return len(out)

fn BackendDispatchSurfaceSeqLen(items: str[]): int32 =
    return items.len

fn BackendDispatchSurfaceSeqRefLen(out: var str[]): int32 =
    return out.len

fn main(): int32 =
    var text = ""
    let textLen = BackendDispatchSurfaceAppend(text, "hello")
    var names: str[]
    let seqLen = BackendDispatchSurfaceSeqLen(names)
    let seqRefLen = BackendDispatchSurfaceSeqRefLen(names)
    return textLen + seqLen + seqRefLen + 37
