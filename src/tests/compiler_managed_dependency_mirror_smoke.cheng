import std/os
import std/result
import cheng/std/bytes_layout as layout
import cheng/libp2p/core/types as core
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_world_bundle as cwbundle
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/tooling/compiler_world_libp2p as cwlp
import cheng/core/lang/parser
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/system_link_exec as sexec

fn compilerManagedMirrorSmokePortBase(label: str): int32 =
    var acc: int32
    for i in 0..<label.len:
        acc = (acc + (int32(label[i]) & 255)) % 200
    return 6761 + (acc * 2)

fn main(): int32 =
    let root = chengpath.PathCurrentDir()
    let outDir = "artifacts/compiler_managed_dependency_mirror"
    let workspaceDir = chengpath.PathJoin(outDir, "workspace")
    let consumerRoot = chengpath.PathJoin(workspaceDir, "consumer_pkg")
    let consumerSrcDir = chengpath.PathJoin(consumerRoot, "src")
    let consumerSource = chengpath.PathJoin(consumerSrcDir, "main.cheng")
    let outputPath = chengpath.PathAbsolute(root, chengpath.PathJoin(outDir, "consumer_pkg"))
    assert(chengpath.MkdirP(root, consumerSrcDir), " managed mirror smoke: consumer mkdir")
    os.WriteFile(chengpath.PathAbsolute(root, chengpath.PathJoin(consumerRoot, "cheng-package.toml")),
                 "package_id = \"pkg://cheng/consumer_pkg\"\nmodule_prefix = \"consumer_pkg\"\n")
    os.WriteFile(chengpath.PathAbsolute(root, consumerSource),
                 "import cheng/helper_pkg/helper as helper\n\nfn main(): int32 =\n    return helper.answer()\n")

    let helperPackageId = "cheng/helper_pkg"
    let helperSnapshotCid = cworld.CompilerWorldHashText("managed_mirror_snapshot", [outputPath])
    let helperSyntaxCid = cworld.CompilerWorldHashText("managed_mirror_syntax", [outputPath])
    let helperProofCid = cworld.CompilerWorldHashText("managed_mirror_proof", [outputPath])
    let mirrorRel = cworld.CompilerManagedMirrorRel("stable", helperPackageId, helperProofCid)
    let mirrorRoot = chengpath.PathAbsolute(root, mirrorRel)
    let mirrorSrcDir = chengpath.PathJoin(mirrorRel, "src")
    assert(chengpath.MkdirP(root, mirrorSrcDir), " managed mirror smoke: mirror mkdir")
    os.WriteFile(chengpath.PathJoin(mirrorRoot, "cheng-package.toml"),
                 "package_id = \"pkg://cheng/helper_pkg\"\nmodule_prefix = \"helper_pkg\"\n")
    os.WriteFile(chengpath.PathJoin(mirrorRoot, "src/helper.cheng"),
                 "fn answer(): int32 =\n    return 7\n")
    os.WriteFile(chengpath.PathJoin(mirrorRoot, "sources.list.txt"), "src/helper.cheng\n")
    os.WriteFile(chengpath.PathJoin(mirrorRoot, "proof.txt"), "proof=managed_mirror\n")

    let req = creq.CompilerRequestNew(
        chengpath.PathAbsolute(root, consumerRoot),
        chengpath.PathAbsolute(root, consumerSource),
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    var externalPackageRoots: parser.ParserExternalPackageRoot[]
    add(externalPackageRoots, parser.ParserExternalPackageRootNew(helperPackageId, mirrorRoot))
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStubWithExternalPackageRoots(root,
                                                                    req,
                                                                    externalPackageRoots,
                                                                    linkPlan,
                                                                    err),
           " managed mirror smoke: direct external root link plan")
    assert(linkPlan.unresolvedImportCount == 0,
           " managed mirror smoke: direct external root unresolved imports")
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    assert(IsOk(sourceBundleRes), " managed mirror smoke: source bundle")
    let sourceBundleCid = Value(sourceBundleRes)
    let csgRes = ccsg.BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(csgRes), " managed mirror smoke: build csg")
    let csg = ccsg.CompilerCsgClone(Value(csgRes))
    let exportSurface = ccsg.CompilerExportSurfaceFromCsg(csg)
    var manifestEntries: cworld.CompilerUniverseManifestEntry[]
    add(manifestEntries,
        cworld.CompilerUniverseManifestEntryMake(helperPackageId,
                                                   helperSnapshotCid,
                                                   helperSyntaxCid,
                                                   helperProofCid))
    let universeRes = cworld.CompilerLocalUniverseBuildForChannelWithManifestEntries("stable",
                                                                                       sourceBundleCid,
                                                                                       csg.graphCid,
                                                                                       exportSurface.surfaceCid,
                                                                                       layout.FixedBytes32(),
                                                                                       manifestEntries)
    assert(IsOk(universeRes), " managed mirror smoke: build universe with mirror entry")
    let universe = Value(universeRes)
    assert(universe.manifest.entryCount == 4, " managed mirror smoke: manifest entry count")
    let lockPath = chengpath.PathAbsolute(root, chengpath.PathJoin(outDir, "consumer_pkg.lock.toml"))
    os.WriteFile(lockPath, cworld.CompilerLockText(universe))
    let pinnedPlanRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(root,
                                                                           req,
                                                                           layout.fixedBytes32Hex(universe.worldHead.headCid),
                                                                           lockPath,
                                                                           "",
                                                                           "stable")
    assert(IsOk(pinnedPlanRes), " managed mirror smoke: pinned build plan")
    let pinnedPlan = Value(pinnedPlanRes)
    assert(pinnedPlan.lockVerified, " managed mirror smoke: lock verified")
    assert(pinnedPlan.localUniverse.manifest.entryCount == 4,
           " managed mirror smoke: pinned manifest entry count")
    assert(pinnedPlan.systemLinkPlan.unresolvedImportCount == 0,
           " managed mirror smoke: pinned unresolved imports")
    assert(chengpath.TextContains(cworld.CompilerLockText(pinnedPlan.localUniverse),
                                 "entry[0].package_id"),
           " managed mirror smoke: lock entries materialized")
    let bundlesRes = cwlp.CompilerWorldManagedMirrorBundlesForPlan(pinnedPlan)
    assert(IsOk(bundlesRes), " managed mirror smoke: collect mirror bundles")
    let bundles = Value(bundlesRes)
    assert(bundles.len == 1, " managed mirror smoke: bundle count")
    assert(os.ExecCmdStatus("rm -rf " + os.QuoteShell(mirrorRoot), "") == 0,
           " managed mirror smoke: remove local mirror")
    let missingMirrorPlanRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(root,
                                                                                  req,
                                                                                  layout.fixedBytes32Hex(universe.worldHead.headCid),
                                                                                  lockPath,
                                                                                  "",
                                                                                  "stable")
    assert(IsErr(missingMirrorPlanRes), " managed mirror smoke: missing mirror blocks rebuild")
    let offlineBundlePrefix = chengpath.PathAbsolute(root, chengpath.PathJoin(outDir, "offline_bundle"))
    assert(chengpath.WriteTextFile(root,
                                  offlineBundlePrefix + ".world.txt",
                                  cworld.CompilerWorldHeadReport(pinnedPlan.localUniverse.worldHead) + "\n"),
           " managed mirror smoke: write offline world report")
    assert(chengpath.WriteTextFile(root,
                                  offlineBundlePrefix + ".manifest.txt",
                                  cworld.CompilerUniverseManifestReport(pinnedPlan.localUniverse.manifest) + "\n"),
           " managed mirror smoke: write offline manifest report")
    assert(chengpath.WriteTextFile(root,
                                  offlineBundlePrefix + ".compiler.snapshot.txt",
                                  cworld.CompilerPackageSnapshotReport(pinnedPlan.localUniverse.compilerSnapshot) + "\n"),
           " managed mirror smoke: write offline compiler snapshot")
    assert(chengpath.WriteTextFile(root,
                                  offlineBundlePrefix + ".std.snapshot.txt",
                                  cworld.CompilerPackageSnapshotReport(pinnedPlan.localUniverse.stdSnapshot) + "\n"),
           " managed mirror smoke: write offline std snapshot")
    assert(chengpath.WriteTextFile(root,
                                  offlineBundlePrefix + ".runtime.snapshot.txt",
                                  cworld.CompilerPackageSnapshotReport(pinnedPlan.localUniverse.runtimeSnapshot) + "\n"),
           " managed mirror smoke: write offline runtime snapshot")
    assert(chengpath.WriteTextFile(root,
                                  offlineBundlePrefix + ".csg.txt",
                                  ccsg.CompilerCsgReport(pinnedPlan.compilerCsg) + "\n"),
           " managed mirror smoke: write offline csg report")
    assert(chengpath.WriteTextFile(root,
                                  offlineBundlePrefix + ".surface.txt",
                                  ccsg.CompilerExportSurfaceReport(pinnedPlan.exportSurface) + "\n"),
           " managed mirror smoke: write offline surface report")
    assert(chengpath.WriteTextFile(root,
                                  offlineBundlePrefix + ".receipt.txt",
                                  ccsg.CompileReceiptReport(pinnedPlan.compileReceipt) + "\n"),
           " managed mirror smoke: write offline receipt report")
    assert(chengpath.WriteTextFile(root,
                                  offlineBundlePrefix + ".lock.toml",
                                  cworld.CompilerLockText(pinnedPlan.localUniverse)),
           " managed mirror smoke: write offline lock")
    assert(cwlp.CompilerWorldWriteManagedMirrorBundleFiles(root, offlineBundlePrefix, bundles),
           " managed mirror smoke: write offline mirror bundle files")
    var offlineBundle: cwbundle.CompilerWorldBundle
    let offlineBundleRes = cwbundle.CompilerWorldBundleReadAndVerify(root, offlineBundlePrefix, offlineBundle)
    assert(IsOk(offlineBundleRes), " managed mirror smoke: verify offline full bundle")
    assert(layout.fixedBytes32Equal(offlineBundle.worldHead.headCid, universe.worldHead.headCid),
           " managed mirror smoke: offline world head matches")
    assert(offlineBundle.manifest.entryCount == 4,
           " managed mirror smoke: offline manifest entry count")
    assert(layout.fixedBytes32Equal(offlineBundle.receipt.receiptCid, pinnedPlan.compileReceipt.receiptCid),
           " managed mirror smoke: offline receipt cid")
    let offlineBundlesRes = cwlp.CompilerWorldManagedMirrorBundlesFromBundlePrefix(root, offlineBundlePrefix)
    assert(IsOk(offlineBundlesRes), " managed mirror smoke: read offline mirror bundle files")
    assert(Value(offlineBundlesRes).len == 1, " managed mirror smoke: offline bundle count")
    let offlineMaterializeRes = cwlp.CompilerWorldMaterializeManagedMirrorBundlesFromBundlePrefix(root,
                                                                                                    offlineBundlePrefix)
    assert(IsOk(offlineMaterializeRes), " managed mirror smoke: offline materialize bundles")
    assert(Value(offlineMaterializeRes) == 1, " managed mirror smoke: offline materialized mirror count")
    let offlineRebuildPlanRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(root,
                                                                                   req,
                                                                                   layout.fixedBytes32Hex(universe.worldHead.headCid),
                                                                                   lockPath,
                                                                                   "",
                                                                                   "stable")
    assert(IsOk(offlineRebuildPlanRes), " managed mirror smoke: rebuilt after offline bundle materialize")
    assert(os.ExecCmdStatus("rm -rf " + os.QuoteShell(mirrorRoot), "") == 0,
           " managed mirror smoke: remove offline-restored mirror")
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let portBase: int32 = compilerManagedMirrorSmokePortBase(smokeLabel)
    var seedHost = host.Libp2pHostInit("compiler-managed-mirror-seed")
    var syncHost = host.Libp2pHostInit("compiler-managed-mirror-sync")
    cwlp.CompilerWorldRegister(seedHost)
    cwlp.CompilerWorldRegister(syncHost)
    var seedAddr: core.Libp2pMultiaddr
    var syncAddr: core.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(seedAddr, "127.0.0.1", portBase)
    multiaddr.Libp2pMultiaddrFillTcp(syncAddr, "127.0.0.1", portBase + 1)
    assert(IsOk(host.Libp2pListen(seedHost, seedAddr)), " managed mirror smoke: seed listen")
    assert(IsOk(host.Libp2pListen(syncHost, syncAddr)), " managed mirror smoke: sync listen")
    assert(IsOk(host.Libp2pDial(syncHost, seedHost.selfPeerId, seedAddr, 1)),
           " managed mirror smoke: dial seed")
    assert(IsOk(host.Libp2pDial(seedHost, syncHost.selfPeerId, syncAddr, 1)),
           " managed mirror smoke: dial sync")
    cwlp.CompilerWorldPublishUniverseWithManagedMirrorBundles(seedHost,
                                                                pinnedPlan.localUniverse,
                                                                pinnedPlan.compilerCsg,
                                                                pinnedPlan.exportSurface,
                                                                pinnedPlan.compileReceipt,
                                                                bundles)
    let syncRes = cwlp.CompilerWorldSync(syncHost, seedHost, seedHost.selfPeerId)
    assert(IsOk(syncRes), " managed mirror smoke: world sync")
    assert(Value(syncRes) == 9, " managed mirror smoke: synced entry count")
    let syncedBundlesRes = cwlp.CompilerWorldManagedMirrorBundlesFromHost(syncHost)
    assert(IsOk(syncedBundlesRes), " managed mirror smoke: synced mirror bundles")
    let syncedBundles = Value(syncedBundlesRes)
    assert(syncedBundles.len == 1, " managed mirror smoke: synced bundle count")
    let materializeRes = cwlp.CompilerWorldMaterializeManagedMirrorBundles(root, syncedBundles)
    assert(IsOk(materializeRes), " managed mirror smoke: materialize synced bundles")
    assert(Value(materializeRes) == 1, " managed mirror smoke: materialized mirror count")
    let rebuiltPlanRes = sexec.BuildSystemLinkExecPlanWithWorldAndChannel(root,
                                                                            req,
                                                                            layout.fixedBytes32Hex(universe.worldHead.headCid),
                                                                            lockPath,
                                                                            "",
                                                                            "stable")
    assert(IsOk(rebuiltPlanRes), " managed mirror smoke: rebuilt after sync")
    echo(" compiler_managed_dependency_mirror_smoke ok")
    return 0
