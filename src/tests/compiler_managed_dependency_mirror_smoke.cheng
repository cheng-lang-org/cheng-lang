import std/os
import std/result
import cheng/std/bytes_layout as layout
import cheng/libp2p/core/types as core
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host
import cheng/core/tooling/path as v3path
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_world_bundle as cwbundle
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/tooling/compiler_world_libp2p as cwlp
import cheng/core/lang/parser
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/system_link_exec as sexec

fn compilerManagedMirrorSmokePortBase(label: str): int32 =
    var acc: int32
    for i in 0..<label.len:
        acc = (acc + (int32(label[i]) & 255)) % 200
    return 6761 + (acc * 2)

fn main(): int32 =
    let root = v3path.V3PathCurrentDir()
    let outDir = "artifacts/compiler_managed_dependency_mirror"
    let workspaceDir = v3path.V3PathJoin(outDir, "workspace")
    let consumerRoot = v3path.V3PathJoin(workspaceDir, "consumer_pkg")
    let consumerSrcDir = v3path.V3PathJoin(consumerRoot, "src")
    let consumerSource = v3path.V3PathJoin(consumerSrcDir, "main.cheng")
    let outputPath = v3path.V3PathAbsolute(root, v3path.V3PathJoin(outDir, "consumer_pkg"))
    assert(v3path.V3MkdirP(root, consumerSrcDir), "v3 managed mirror smoke: consumer mkdir")
    os.WriteFile(v3path.V3PathAbsolute(root, v3path.V3PathJoin(consumerRoot, "cheng-package.toml")),
                 "package_id = \"pkg://cheng/consumer_pkg\"\nmodule_prefix = \"consumer_pkg\"\n")
    os.WriteFile(v3path.V3PathAbsolute(root, consumerSource),
                 "import cheng/helper_pkg/helper as helper\n\nfn main(): int32 =\n    return helper.answer()\n")

    let helperPackageId = "cheng/helper_pkg"
    let helperSnapshotCid = cworld.v3CompilerWorldHashText("managed_mirror_snapshot", [outputPath])
    let helperSyntaxCid = cworld.v3CompilerWorldHashText("managed_mirror_syntax", [outputPath])
    let helperProofCid = cworld.v3CompilerWorldHashText("managed_mirror_proof", [outputPath])
    let mirrorRel = cworld.v3CompilerManagedMirrorRel("stable", helperPackageId, helperProofCid)
    let mirrorRoot = v3path.V3PathAbsolute(root, mirrorRel)
    let mirrorSrcDir = v3path.V3PathJoin(mirrorRel, "src")
    assert(v3path.V3MkdirP(root, mirrorSrcDir), "v3 managed mirror smoke: mirror mkdir")
    os.WriteFile(v3path.V3PathJoin(mirrorRoot, "cheng-package.toml"),
                 "package_id = \"pkg://cheng/helper_pkg\"\nmodule_prefix = \"helper_pkg\"\n")
    os.WriteFile(v3path.V3PathJoin(mirrorRoot, "src/helper.cheng"),
                 "fn answer(): int32 =\n    return 7\n")
    os.WriteFile(v3path.V3PathJoin(mirrorRoot, "sources.list.txt"), "src/helper.cheng\n")
    os.WriteFile(v3path.V3PathJoin(mirrorRoot, "proof.txt"), "proof=managed_mirror\n")

    let req = creq.v3CompilerRequestNew(
        v3path.V3PathAbsolute(root, consumerRoot),
        v3path.V3PathAbsolute(root, consumerSource),
        outputPath,
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    var externalPackageRoots: parser.V3ParserExternalPackageRoot[]
    add(externalPackageRoots, parser.v3ParserExternalPackageRootNew(helperPackageId, mirrorRoot))
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStubWithExternalPackageRoots(root,
                                                                    req,
                                                                    externalPackageRoots,
                                                                    linkPlan,
                                                                    err),
           "v3 managed mirror smoke: direct external root link plan")
    assert(linkPlan.unresolvedImportCount == 0,
           "v3 managed mirror smoke: direct external root unresolved imports")
    let sourceBundleRes = slplan.v3SystemLinkPlanSourceBundleCid(linkPlan)
    assert(IsOk(sourceBundleRes), "v3 managed mirror smoke: source bundle")
    let sourceBundleCid = Value(sourceBundleRes)
    let csgRes = ccsg.v3BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(csgRes), "v3 managed mirror smoke: build csg")
    let csg = ccsg.v3CompilerCsgClone(Value(csgRes))
    let exportSurface = ccsg.v3CompilerExportSurfaceFromCsg(csg)
    var manifestEntries: cworld.V3CompilerUniverseManifestEntry[]
    add(manifestEntries,
        cworld.v3CompilerUniverseManifestEntryMake(helperPackageId,
                                                   helperSnapshotCid,
                                                   helperSyntaxCid,
                                                   helperProofCid))
    let universeRes = cworld.v3CompilerLocalUniverseBuildForChannelWithManifestEntries("stable",
                                                                                       sourceBundleCid,
                                                                                       csg.graphCid,
                                                                                       exportSurface.surfaceCid,
                                                                                       layout.FixedBytes32(),
                                                                                       manifestEntries)
    assert(IsOk(universeRes), "v3 managed mirror smoke: build universe with mirror entry")
    let universe = Value(universeRes)
    assert(universe.manifest.entryCount == 4, "v3 managed mirror smoke: manifest entry count")
    let lockPath = v3path.V3PathAbsolute(root, v3path.V3PathJoin(outDir, "consumer_pkg.lock.toml"))
    os.WriteFile(lockPath, cworld.v3CompilerLockText(universe))
    let pinnedPlanRes = sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(root,
                                                                           req,
                                                                           layout.fixedBytes32Hex(universe.worldHead.headCid),
                                                                           lockPath,
                                                                           "",
                                                                           "stable")
    assert(IsOk(pinnedPlanRes), "v3 managed mirror smoke: pinned build plan")
    let pinnedPlan = Value(pinnedPlanRes)
    assert(pinnedPlan.lockVerified, "v3 managed mirror smoke: lock verified")
    assert(pinnedPlan.localUniverse.manifest.entryCount == 4,
           "v3 managed mirror smoke: pinned manifest entry count")
    assert(pinnedPlan.systemLinkPlan.unresolvedImportCount == 0,
           "v3 managed mirror smoke: pinned unresolved imports")
    assert(v3path.V3TextContains(cworld.v3CompilerLockText(pinnedPlan.localUniverse),
                                 "entry[0].package_id"),
           "v3 managed mirror smoke: lock entries materialized")
    let bundlesRes = cwlp.v3CompilerWorldManagedMirrorBundlesForPlan(pinnedPlan)
    assert(IsOk(bundlesRes), "v3 managed mirror smoke: collect mirror bundles")
    let bundles = Value(bundlesRes)
    assert(bundles.len == 1, "v3 managed mirror smoke: bundle count")
    assert(os.ExecCmdStatus("rm -rf " + os.QuoteShell(mirrorRoot), "") == 0,
           "v3 managed mirror smoke: remove local mirror")
    let missingMirrorPlanRes = sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(root,
                                                                                  req,
                                                                                  layout.fixedBytes32Hex(universe.worldHead.headCid),
                                                                                  lockPath,
                                                                                  "",
                                                                                  "stable")
    assert(IsErr(missingMirrorPlanRes), "v3 managed mirror smoke: missing mirror blocks rebuild")
    let offlineBundlePrefix = v3path.V3PathAbsolute(root, v3path.V3PathJoin(outDir, "offline_bundle"))
    assert(v3path.V3WriteTextFile(root,
                                  offlineBundlePrefix + ".world.txt",
                                  cworld.v3CompilerWorldHeadReport(pinnedPlan.localUniverse.worldHead) + "\n"),
           "v3 managed mirror smoke: write offline world report")
    assert(v3path.V3WriteTextFile(root,
                                  offlineBundlePrefix + ".manifest.txt",
                                  cworld.v3CompilerUniverseManifestReport(pinnedPlan.localUniverse.manifest) + "\n"),
           "v3 managed mirror smoke: write offline manifest report")
    assert(v3path.V3WriteTextFile(root,
                                  offlineBundlePrefix + ".compiler.snapshot.txt",
                                  cworld.v3CompilerPackageSnapshotReport(pinnedPlan.localUniverse.compilerSnapshot) + "\n"),
           "v3 managed mirror smoke: write offline compiler snapshot")
    assert(v3path.V3WriteTextFile(root,
                                  offlineBundlePrefix + ".std.snapshot.txt",
                                  cworld.v3CompilerPackageSnapshotReport(pinnedPlan.localUniverse.stdSnapshot) + "\n"),
           "v3 managed mirror smoke: write offline std snapshot")
    assert(v3path.V3WriteTextFile(root,
                                  offlineBundlePrefix + ".runtime.snapshot.txt",
                                  cworld.v3CompilerPackageSnapshotReport(pinnedPlan.localUniverse.runtimeSnapshot) + "\n"),
           "v3 managed mirror smoke: write offline runtime snapshot")
    assert(v3path.V3WriteTextFile(root,
                                  offlineBundlePrefix + ".csg.txt",
                                  ccsg.v3CompilerCsgReport(pinnedPlan.compilerCsg) + "\n"),
           "v3 managed mirror smoke: write offline csg report")
    assert(v3path.V3WriteTextFile(root,
                                  offlineBundlePrefix + ".surface.txt",
                                  ccsg.v3CompilerExportSurfaceReport(pinnedPlan.exportSurface) + "\n"),
           "v3 managed mirror smoke: write offline surface report")
    assert(v3path.V3WriteTextFile(root,
                                  offlineBundlePrefix + ".receipt.txt",
                                  ccsg.v3CompileReceiptReport(pinnedPlan.compileReceipt) + "\n"),
           "v3 managed mirror smoke: write offline receipt report")
    assert(v3path.V3WriteTextFile(root,
                                  offlineBundlePrefix + ".lock.toml",
                                  cworld.v3CompilerLockText(pinnedPlan.localUniverse)),
           "v3 managed mirror smoke: write offline lock")
    assert(cwlp.v3CompilerWorldWriteManagedMirrorBundleFiles(root, offlineBundlePrefix, bundles),
           "v3 managed mirror smoke: write offline mirror bundle files")
    var offlineBundle: cwbundle.V3CompilerWorldBundle
    let offlineBundleRes = cwbundle.v3CompilerWorldBundleReadAndVerify(root, offlineBundlePrefix, offlineBundle)
    assert(IsOk(offlineBundleRes), "v3 managed mirror smoke: verify offline full bundle")
    assert(layout.fixedBytes32Equal(offlineBundle.worldHead.headCid, universe.worldHead.headCid),
           "v3 managed mirror smoke: offline world head matches")
    assert(offlineBundle.manifest.entryCount == 4,
           "v3 managed mirror smoke: offline manifest entry count")
    assert(layout.fixedBytes32Equal(offlineBundle.receipt.receiptCid, pinnedPlan.compileReceipt.receiptCid),
           "v3 managed mirror smoke: offline receipt cid")
    let offlineBundlesRes = cwlp.v3CompilerWorldManagedMirrorBundlesFromBundlePrefix(root, offlineBundlePrefix)
    assert(IsOk(offlineBundlesRes), "v3 managed mirror smoke: read offline mirror bundle files")
    assert(Value(offlineBundlesRes).len == 1, "v3 managed mirror smoke: offline bundle count")
    let offlineMaterializeRes = cwlp.v3CompilerWorldMaterializeManagedMirrorBundlesFromBundlePrefix(root,
                                                                                                    offlineBundlePrefix)
    assert(IsOk(offlineMaterializeRes), "v3 managed mirror smoke: offline materialize bundles")
    assert(Value(offlineMaterializeRes) == 1, "v3 managed mirror smoke: offline materialized mirror count")
    let offlineRebuildPlanRes = sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(root,
                                                                                   req,
                                                                                   layout.fixedBytes32Hex(universe.worldHead.headCid),
                                                                                   lockPath,
                                                                                   "",
                                                                                   "stable")
    assert(IsOk(offlineRebuildPlanRes), "v3 managed mirror smoke: rebuilt after offline bundle materialize")
    assert(os.ExecCmdStatus("rm -rf " + os.QuoteShell(mirrorRoot), "") == 0,
           "v3 managed mirror smoke: remove offline-restored mirror")
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let portBase: int32 = compilerManagedMirrorSmokePortBase(smokeLabel)
    var seedHost = host.v3Libp2pHostInit("compiler-managed-mirror-seed")
    var syncHost = host.v3Libp2pHostInit("compiler-managed-mirror-sync")
    cwlp.v3CompilerWorldRegister(seedHost)
    cwlp.v3CompilerWorldRegister(syncHost)
    var seedAddr: core.V3Libp2pMultiaddr
    var syncAddr: core.V3Libp2pMultiaddr
    multiaddr.v3Libp2pMultiaddrFillTcp(seedAddr, "127.0.0.1", portBase)
    multiaddr.v3Libp2pMultiaddrFillTcp(syncAddr, "127.0.0.1", portBase + 1)
    assert(IsOk(host.v3Libp2pListen(seedHost, seedAddr)), "v3 managed mirror smoke: seed listen")
    assert(IsOk(host.v3Libp2pListen(syncHost, syncAddr)), "v3 managed mirror smoke: sync listen")
    assert(IsOk(host.v3Libp2pDial(syncHost, seedHost.selfPeerId, seedAddr, 1)),
           "v3 managed mirror smoke: dial seed")
    assert(IsOk(host.v3Libp2pDial(seedHost, syncHost.selfPeerId, syncAddr, 1)),
           "v3 managed mirror smoke: dial sync")
    cwlp.v3CompilerWorldPublishUniverseWithManagedMirrorBundles(seedHost,
                                                                pinnedPlan.localUniverse,
                                                                pinnedPlan.compilerCsg,
                                                                pinnedPlan.exportSurface,
                                                                pinnedPlan.compileReceipt,
                                                                bundles)
    let syncRes = cwlp.v3CompilerWorldSync(syncHost, seedHost, seedHost.selfPeerId)
    assert(IsOk(syncRes), "v3 managed mirror smoke: world sync")
    assert(Value(syncRes) == 9, "v3 managed mirror smoke: synced entry count")
    let syncedBundlesRes = cwlp.v3CompilerWorldManagedMirrorBundlesFromHost(syncHost)
    assert(IsOk(syncedBundlesRes), "v3 managed mirror smoke: synced mirror bundles")
    let syncedBundles = Value(syncedBundlesRes)
    assert(syncedBundles.len == 1, "v3 managed mirror smoke: synced bundle count")
    let materializeRes = cwlp.v3CompilerWorldMaterializeManagedMirrorBundles(root, syncedBundles)
    assert(IsOk(materializeRes), "v3 managed mirror smoke: materialize synced bundles")
    assert(Value(materializeRes) == 1, "v3 managed mirror smoke: materialized mirror count")
    let rebuiltPlanRes = sexec.v3BuildSystemLinkExecPlanWithWorldAndChannel(root,
                                                                            req,
                                                                            layout.fixedBytes32Hex(universe.worldHead.headCid),
                                                                            lockPath,
                                                                            "",
                                                                            "stable")
    assert(IsOk(rebuiltPlanRes), "v3 managed mirror smoke: rebuilt after sync")
    echo("v3 compiler_managed_dependency_mirror_smoke ok")
    return 0
