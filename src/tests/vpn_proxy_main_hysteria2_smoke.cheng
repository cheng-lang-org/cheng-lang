import std/result
import cheng/libp2p/core/types
import cheng/apps/vpn_proxy/vpn_proxy_main as vpn
import cheng/apps/vpn_proxy/vpn_proxy_socks as socks

fn main(): int32 =
    assert(vpn.VpnProxyProtocolId() == types.Libp2pProtocolProxyTcp,
        " vpn proxy main hy2: protocol id")

    var exitCfg: vpn.VpnProxyExitConfig
    exitCfg.name = "edge"
    exitCfg.host = "127.0.0.1"
    exitCfg.port = 7443
    exitCfg.serverName = "edge.internal"
    exitCfg.auth = "shared-secret"
    exitCfg.ccRx = 123456
    assert(vpn.VpnProxyExitAuthority(exitCfg) == "edge.internal",
        " vpn proxy main hy2: authority fallback")
    assert(IsOk(vpn.VpnProxyRequireExitHy2Config(exitCfg)),
        " vpn proxy main hy2: exit config ok")
    exitCfg.authority = "auth.internal"
    assert(vpn.VpnProxyExitAuthority(exitCfg) == "auth.internal",
        " vpn proxy main hy2: authority explicit")

    var serverCfg: vpn.VpnProxyIdentityConfig
    serverCfg.expectedAuth = "shared-secret"
    assert(IsOk(vpn.VpnProxyRequireServerHy2Config(serverCfg)),
        " vpn proxy main hy2: server config ok")
    serverCfg.ccRxText = "auto"
    assert(vpn.VpnProxyServerCcRxText(serverCfg) == "auto",
        " vpn proxy main hy2: server cc-rx text")

    var target: socks.VpnProxyTarget
    target.host = "1.2.3.4"
    target.port = 443
    assert(vpn.VpnProxyTargetAddress(target) == "1.2.3.4:443",
        " vpn proxy main hy2: ipv4 target address")
    let ipv4Res: Result[socks.VpnProxyTarget] = vpn.VpnProxyTargetFromAddress("1.2.3.4:443")
    assert(IsOk(ipv4Res), " vpn proxy main hy2: ipv4 parse")
    assert(Value(ipv4Res).host == "1.2.3.4", " vpn proxy main hy2: ipv4 host")
    assert(Value(ipv4Res).port == 443, " vpn proxy main hy2: ipv4 port")

    target.host = "2001:db8::1"
    target.port = 8443
    assert(vpn.VpnProxyTargetAddress(target) == "[2001:db8::1]:8443",
        " vpn proxy main hy2: ipv6 target address")
    let ipv6Res: Result[socks.VpnProxyTarget] = vpn.VpnProxyTargetFromAddress("[2001:db8::1]:8443")
    assert(IsOk(ipv6Res), " vpn proxy main hy2: ipv6 parse")
    assert(Value(ipv6Res).host == "2001:db8::1", " vpn proxy main hy2: ipv6 host")
    assert(Value(ipv6Res).port == 8443, " vpn proxy main hy2: ipv6 port")

    echo(" vpn_proxy_main_hysteria2_smoke ok")
    return 0
