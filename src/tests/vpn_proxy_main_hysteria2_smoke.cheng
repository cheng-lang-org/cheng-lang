import std/result
import cheng/libp2p/core/types
import cheng/apps/vpn_proxy/vpn_proxy_main as vpn
import cheng/apps/vpn_proxy/vpn_proxy_socks as socks

fn main(): int32 =
    assert(vpn.v3VpnProxyProtocolId() == types.v3Libp2pProtocolProxyTcp,
        "v3 vpn proxy main hy2: protocol id")

    var exitCfg: vpn.V3VpnProxyExitConfig
    exitCfg.name = "edge"
    exitCfg.host = "127.0.0.1"
    exitCfg.port = 7443
    exitCfg.serverName = "edge.internal"
    exitCfg.auth = "shared-secret"
    exitCfg.ccRx = 123456
    assert(vpn.v3VpnProxyExitAuthority(exitCfg) == "edge.internal",
        "v3 vpn proxy main hy2: authority fallback")
    assert(IsOk(vpn.v3VpnProxyRequireExitHy2Config(exitCfg)),
        "v3 vpn proxy main hy2: exit config ok")
    exitCfg.authority = "auth.internal"
    assert(vpn.v3VpnProxyExitAuthority(exitCfg) == "auth.internal",
        "v3 vpn proxy main hy2: authority explicit")

    var serverCfg: vpn.V3VpnProxyIdentityConfig
    serverCfg.expectedAuth = "shared-secret"
    assert(IsOk(vpn.v3VpnProxyRequireServerHy2Config(serverCfg)),
        "v3 vpn proxy main hy2: server config ok")
    serverCfg.ccRxText = "auto"
    assert(vpn.v3VpnProxyServerCcRxText(serverCfg) == "auto",
        "v3 vpn proxy main hy2: server cc-rx text")

    var target: socks.V3VpnProxyTarget
    target.host = "1.2.3.4"
    target.port = 443
    assert(vpn.v3VpnProxyTargetAddress(target) == "1.2.3.4:443",
        "v3 vpn proxy main hy2: ipv4 target address")
    let ipv4Res: Result[socks.V3VpnProxyTarget] = vpn.v3VpnProxyTargetFromAddress("1.2.3.4:443")
    assert(IsOk(ipv4Res), "v3 vpn proxy main hy2: ipv4 parse")
    assert(Value(ipv4Res).host == "1.2.3.4", "v3 vpn proxy main hy2: ipv4 host")
    assert(Value(ipv4Res).port == 443, "v3 vpn proxy main hy2: ipv4 port")

    target.host = "2001:db8::1"
    target.port = 8443
    assert(vpn.v3VpnProxyTargetAddress(target) == "[2001:db8::1]:8443",
        "v3 vpn proxy main hy2: ipv6 target address")
    let ipv6Res: Result[socks.V3VpnProxyTarget] = vpn.v3VpnProxyTargetFromAddress("[2001:db8::1]:8443")
    assert(IsOk(ipv6Res), "v3 vpn proxy main hy2: ipv6 parse")
    assert(Value(ipv6Res).host == "2001:db8::1", "v3 vpn proxy main hy2: ipv6 host")
    assert(Value(ipv6Res).port == 8443, "v3 vpn proxy main hy2: ipv6 port")

    echo("v3 vpn_proxy_main_hysteria2_smoke ok")
    return 0
