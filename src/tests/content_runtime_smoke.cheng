import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content
import cheng/chain/content_fetch as fetch
import cheng/chain/content_runtime as runtime
import cheng/chain/content_runtime_host as runtime_host
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host
import cheng/tests/smoke_ports

fn contentRuntimeSmokeBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn contentRuntimeSmokeBlob(shards: Bytes[]): Bytes =
    var total = 0
    for i in 0..<shards.len:
        total = total + bytesLen(shards[i])
    var buf: layout.ByteBuf = layout.byteBufInit(total)
    for i in 0..<shards.len:
        layout.byteBufAppendBytes(buf, shards[i])
    return layout.byteBufToBytes(buf)

fn main(): int32 =
    let shard0 = bytesFromString("delta-")
    let shard1 = bytesFromString("omega-")
    let shard2 = bytesFromString("sigma!")
    var shardPayloads: Bytes[]
    shardPayloads = []
    add(shardPayloads, shard0)
    add(shardPayloads, shard1)
    add(shardPayloads, shard2)
    let blob = contentRuntimeSmokeBlob(shardPayloads)

    let summaryRes = dag.DagBlobSummaryFromBytes(blob, 6)
    assert(IsOk(summaryRes), " content runtime smoke: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic, 3, 0, 6)
    assert(IsOk(paramsRes), " content runtime smoke: params")
    let params = Value(paramsRes)

    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard0))
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard1))
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard2))
    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), " content runtime smoke: manifest")
    let manifest = Value(manifestRes)

    var server = host.Libp2pHostInit("content.runtime.server")
    let peerAdvertRes = swarm.ErasurePeerAdvertMake(server.selfPeerId.value,
                                                      manifest,
                                                      params,
                                                      [0, 1, 2],
                                                      900,
                                                      3)
    assert(IsOk(peerAdvertRes), " content runtime smoke: peer advert")
    var adverts: swarm.ErasurePeerAdvert[]
    adverts = []
    swarm.ErasurePeerAdvertAppend(adverts, Value(peerAdvertRes))
    let planRes = swarm.ErasureBuildRecoveryPlan(manifest, params, adverts)
    assert(IsOk(planRes), " content runtime smoke: recovery plan")
    let plan = Value(planRes)
    let planOk = swarm.ErasureRecoveryPlanValidate(plan, manifest, params)
    assert(IsOk(planOk), " content runtime smoke: plan validate")

    let targetsRes = runtime.ContentRuntimeBuildPullTargets(manifest.manifestCid,
                                                              manifest.shardIndices,
                                                              manifest.shardPayloadCids,
                                                              plan.manifestCid,
                                                              plan.requestCount,
                                                              plan.requestPeerIds,
                                                              plan.requestShardIndices,
                                                              plan.requestShardCids)
    assert(IsOk(targetsRes), " content runtime smoke: pull targets")
    let targets = Value(targetsRes)
    assert(targets.len == 3, " content runtime smoke: target count")
    assert(layout.fixedBytes32Equal(targets[0].peerId, server.selfPeerId.value),
        " content runtime smoke: target peer")

    let requestsRes = runtime.ContentRuntimeBuildPullRequests(manifest.manifestCid,
                                                                manifest.shardIndices,
                                                                manifest.shardPayloadCids,
                                                                plan.manifestCid,
                                                                plan.requestCount,
                                                                plan.requestPeerIds,
                                                                plan.requestShardIndices,
                                                                plan.requestShardCids)
    assert(IsOk(requestsRes), " content runtime smoke: pull requests")
    let requests = Value(requestsRes)
    assert(requests.len == 3, " content runtime smoke: request count")

    var serverRuntime = runtime.ContentRuntimeInit()
    let storeManifestRes = runtime.ContentRuntimeStoreManifest(serverRuntime, manifest)
    assert(IsOk(storeManifestRes), " content runtime smoke: store manifest")

    var stub = content.ContentStub()
    let stubRes = content.ContentStubFill(stub,
                                            lt.HashInts("cheng.content.runtime.topic", [1]),
                                            lt.HashInts("cheng.content.runtime.bundle", [2]),
                                            summary.summaryCid,
                                            lt.HashInts("cheng.content.runtime.advert", [3]),
                                            manifest.manifestCid,
                                            lt.HashInts("cheng.content.runtime.plan", [4]),
                                            summary.payloadLen)
    assert(IsOk(stubRes), " content runtime smoke: stub")
    let storeBlobRes = runtime.ContentRuntimeStoreBlobPayload(serverRuntime, summary.blobCid, blob)
    assert(IsOk(storeBlobRes), " content runtime smoke: store blob")

    var cachedManifestPayload: Bytes
    assert(runtime.ContentRuntimeCachedManifestPayload(serverRuntime,
                                                         manifest.manifestCid,
                                                         cachedManifestPayload),
        " content runtime smoke: cached manifest")
    let cachedManifestOk = swarm.ErasureShardManifestValidatePayload(cachedManifestPayload,
                                                                       manifest.manifestCid)
    assert(IsOk(cachedManifestOk), " content runtime smoke: cached manifest payload")

    var cachedBlob: Bytes
    assert(runtime.ContentRuntimeCachedBlob(serverRuntime, summary.blobCid, cachedBlob),
        " content runtime smoke: cached blob")
    assert(contentRuntimeSmokeBytesEqual(cachedBlob, blob),
        " content runtime smoke: cached blob bytes")

    for i in 0..<requests.len:
        var response = swarm.ErasureShardPullResponse()
        let responseFillRes = swarm.ErasureShardPullResponseFill(response,
                                                                   requests[i],
                                                                   shardPayloads[requests[i].shardIndex])
        assert(IsOk(responseFillRes), " content runtime smoke: seed response")
        let storeRes = runtime.ContentRuntimeStoreShardResponse(serverRuntime, response)
        assert(IsOk(storeRes), " content runtime smoke: store server cache")
    assert(serverRuntime.shardCache.len == 3, " content runtime smoke: server cache count")

    var client = host.Libp2pHostInit("content.runtime.client")
    var clientRuntime = runtime.ContentRuntimeInit()
    var listenAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(listenAddr, "127.0.0.1", smoke_ports.SmokeLabelPort(6308))
    let listenRes = host.Libp2pListen(server, listenAddr)
    assert(listenRes.ok, " content runtime smoke: listen")
    host.Libp2pRegisterHandler(server, types.Libp2pProtocolContent)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolContent)
    let dialRes = host.Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " content runtime smoke: dial")

    let manifestFetchReqRes = fetch.ContentFetchRequestManifest(manifest.manifestCid)
    assert(IsOk(manifestFetchReqRes), " content runtime smoke: manifest fetch request")
    let manifestFetchRequest = Value(manifestFetchReqRes)
    let manifestFetchRes = runtime_host.ContentRuntimeRequestFetch(client,
                                                                     server,
                                                                     server.selfPeerId,
                                                                     serverRuntime,
                                                                     manifestFetchRequest)
    assert(IsOk(manifestFetchRes), " content runtime smoke: manifest fetch")
    let manifestFetchResponse = Value(manifestFetchRes)
    var manifestPull = swarm.ErasureShardManifest()
    let manifestPullRes = fetch.ContentFetchResponseToManifestFill(manifestPull,
                                                                     manifestFetchRequest,
                                                                     manifestFetchResponse)
    assert(IsOk(manifestPullRes), " content runtime smoke: manifest pull")
    assert(layout.fixedBytes32Equal(manifestPull.manifestCid, manifest.manifestCid),
        " content runtime smoke: manifest pull cid")

    let rangeReqRes = fetch.ContentFetchRequestRange(summary.blobCid, 2, 5)
    assert(IsOk(rangeReqRes), " content runtime smoke: range request")
    let rangeRequest = Value(rangeReqRes)
    let rangeFetchRes = runtime_host.ContentRuntimeRequestFetch(client,
                                                                  server,
                                                                  server.selfPeerId,
                                                                  serverRuntime,
                                                                  rangeRequest)
    assert(IsOk(rangeFetchRes), " content runtime smoke: range fetch")
    let rangeFetch = Value(rangeFetchRes)
    let rangeOk = fetch.ContentFetchResponseValidate(rangeFetch, rangeRequest)
    assert(IsOk(rangeOk), " content runtime smoke: range validate")
    assert(contentRuntimeSmokeBytesEqual(rangeFetch.payload, bytesSlice(blob, 2, 5)),
        " content runtime smoke: range bytes")

    let directChunkReqRes = fetch.ContentFetchRequestChunk(manifest.manifestCid,
                                                             requests[0].shardIndex,
                                                             requests[0].shardCid)
    assert(IsOk(directChunkReqRes), " content runtime smoke: direct chunk request")
    let directChunkReq = Value(directChunkReqRes)
    let directChunkFetchRes = runtime_host.ContentRuntimeRequestFetch(client,
                                                                        server,
                                                                        server.selfPeerId,
                                                                        serverRuntime,
                                                                        directChunkReq)
    assert(IsOk(directChunkFetchRes), " content runtime smoke: direct chunk fetch")
    let directChunkFetch = Value(directChunkFetchRes)
    var directChunk = swarm.ErasureShardPullResponse()
    let directChunkFillRes = fetch.ContentFetchResponseToShardPullFill(directChunk,
                                                                         directChunkReq,
                                                                         directChunkFetch)
    assert(IsOk(directChunkFillRes), " content runtime smoke: direct chunk decode")
    assert(directChunk.shardIndex == 0, " content runtime smoke: direct chunk index")
    assert(layout.fixedBytes32Equal(directChunk.shardCid, requests[0].shardCid),
        " content runtime smoke: direct chunk cid")
    assert(contentRuntimeSmokeBytesEqual(directChunk.payload, shard0),
        " content runtime smoke: direct chunk bytes")

    var pulled: swarm.ErasureShardPullResponse[]
    pulled = []
    for i in 0..<requests.len:
        let pullRes = runtime_host.ContentRuntimeRequestShardPull(client,
                                                                    server,
                                                                    server.selfPeerId,
                                                                    serverRuntime,
                                                                    requests[i])
        assert(IsOk(pullRes), " content runtime smoke: pull shard")
        let pulledResponse = Value(pullRes)
        let localStoreRes = runtime.ContentRuntimeStoreShardResponse(clientRuntime, pulledResponse)
        assert(IsOk(localStoreRes), " content runtime smoke: store client cache")
        add(pulled, pulledResponse)
    assert(clientRuntime.shardCache.len == 3, " content runtime smoke: client cache count")

    var cachedShard: Bytes
    assert(runtime.ContentRuntimeCachedShard(clientRuntime, requests[0], cachedShard),
        " content runtime smoke: cached shard available")
    assert(contentRuntimeSmokeBytesEqual(cachedShard, shard0),
        " content runtime smoke: cached shard bytes")

    let rebuildRes = runtime.ContentRuntimeRebuildBlob(manifest, params, pulled)
    assert(IsOk(rebuildRes), " content runtime smoke: rebuild")
    assert(contentRuntimeSmokeBytesEqual(Value(rebuildRes), blob),
        " content runtime smoke: rebuild bytes")

    echo(" content_runtime_smoke ok")
    return 0
