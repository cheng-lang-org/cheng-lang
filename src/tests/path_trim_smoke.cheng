import cheng/core/tooling/path as v3path

fn main(): int32 =
    let trimmed = v3path.V3PathTrim("  /tmp/demo  ")
    assert(trimmed == "/tmp/demo", "v3 path trim: strip bridge")
    assert(v3path.V3PathNonEmpty("  value  "), "v3 path trim: non empty")
    echo("v3 path_trim_smoke ok")
    return 0
