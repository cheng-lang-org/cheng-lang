import std/atomic
import std/thread

var
    joinPoolCounter: atomic.I32

fn JoinWorker() =
    let _ = atomic.AddI32(joinPoolCounter, 1)

fn PoolWorker(raw64: int64, index: int32, worker: int32): int32 =
    let _ = raw64
    let _ = index
    let _ = worker
    let _ = atomic.AddI32(joinPoolCounter, 1)
    return 0

fn main(): int32 =
    if thread.Parallelism() <= 0:
        return 11
    joinPoolCounter = atomic.NewI32(0)
    if joinPoolCounter == nil:
        return 12

    var handles: thread.Thread[]
    for _ in 0..<4:
        add(handles, thread.Start(&JoinWorker))
    for i in 0..<handles.len:
        if !thread.Join(handles[i]):
            return 13
    if atomic.LoadI32(joinPoolCounter) != 4:
        return 14

    atomic.StoreI32(joinPoolCounter, 0)
    for _ in 0..<4:
        if !thread.Spawn(&JoinWorker):
            return 17
    var spin = 0
    while atomic.LoadI32(joinPoolCounter) != 4 && spin < 100000:
        thread.Yield()
        spin = spin + 1
    if atomic.LoadI32(joinPoolCounter) != 4:
        return 18

    atomic.StoreI32(joinPoolCounter, 0)
    let pool = thread.PoolNew(4)
    if pool == nil:
        return 15
    thread.ParallelFor(pool, 1000, &PoolWorker, nil)
    if atomic.LoadI32(joinPoolCounter) != 1000:
        return 16

    echo(" thread_join_pool_runtime_smoke ok")
    return 0
