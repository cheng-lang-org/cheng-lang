import std/result
import std/rawbytes

fn bytesLen(value: Bytes): int32 =
    return value.len

fn textLen(value: str): int32 =
    return value.len

fn seqLen(values: int32[]): int32 =
    return values.len

fn resultOk(value: Result[int32]): bool =
    return value.ok

fn resultValue(value: Result[int32]): int32 =
    return value.value

fn echoBytes(value: Bytes): Bytes =
    return value

fn echoText(value: str): str =
    return value

fn echoSeq(values: int32[]): int32[] =
    return values

fn echoResult(value: Result[int32]): Result[int32] =
    return value

fn main(): int32 =
    let bytesValue = bytesSlice(bytesFromString("abcd"), 0, 4)
    if bytesLen(bytesValue) != 4:
        return 1
    let echoedBytes = echoBytes(bytesValue)
    if bytesLen(echoedBytes) != 4:
        return 2
    if bytesGet(echoedBytes, 0) != int32('a'):
        return 3
    if bytesGet(echoedBytes, 1) != int32('b'):
        return 4
    if bytesGet(echoedBytes, 2) != int32('c'):
        return 5
    if bytesGet(echoedBytes, 3) != int32('d'):
        return 6
    let textValue = "hello"
    if textLen(textValue) != 5:
        return 7
    let echoedText = echoText(textValue)
    if echoedText != textValue:
        return 8
    if int32(echoedText[0]) != int32('h'):
        return 9
    if int32(echoedText[1]) != int32('e'):
        return 10
    if int32(echoedText[2]) != int32('l'):
        return 11
    if int32(echoedText[3]) != int32('l'):
        return 12
    if int32(echoedText[4]) != int32('o'):
        return 13
    var seqValue: int32[]
    seqValue = []
    add(seqValue, 7)
    add(seqValue, 9)
    if seqLen(seqValue) != 2:
        return 14
    let echoedSeq = echoSeq(seqValue)
    if seqLen(echoedSeq) != 2:
        return 15
    if echoedSeq[0] != 7:
        return 16
    if echoedSeq[1] != 9:
        return 17
    let okResult = Ok[int32](42)
    let echoedOk = echoResult(okResult)
    if !resultOk(echoedOk):
        return 18
    if resultValue(echoedOk) != 42:
        return 19
    let errResult = Err[int32]("bad")
    let echoedErr = echoResult(errResult)
    if resultOk(echoedErr):
        return 20
    let errText = Error(echoedErr)
    if errText != "bad":
        return 22
    if int32(errText[0]) != int32('b'):
        return 23
    if int32(errText[1]) != int32('a'):
        return 24
    if int32(errText[2]) != int32('d'):
        return 25
    return 0
