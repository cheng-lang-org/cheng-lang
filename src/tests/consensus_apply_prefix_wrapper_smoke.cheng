import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

fn localApply(index: var consensus.ChainIndex,
              event: consensus.ChainEvent,
              eventCid: layout.FixedBytes32,
              logOffset: int32): Result[consensus.ConsensusDecision] =
    var out = consensus.ConsensusDecision()
    var duplicate = false
    out.eventCid = eventCid
    if !layout.fixedBytes32Equal(eventCid, consensus.ChainEventCid(event)):
        return Err[consensus.ConsensusDecision](" consensus apply prefix wrapper: cid mismatch")
    if !layout.fixedBytes32Equal(event.bodyCid, consensus.ChainEventBodyCid(event)):
        return Err[consensus.ConsensusDecision](" consensus apply prefix wrapper: body cid mismatch")
    for i in 0..<index.eventCids.len:
        if layout.fixedBytes32Equal(index.eventCids[i], eventCid):
            duplicate = true
            break
    if duplicate:
        return Err[consensus.ConsensusDecision](" consensus apply prefix wrapper: duplicate")
    if event.kind != 1 && event.kind != 2:
        return Err[consensus.ConsensusDecision](" consensus apply prefix wrapper: kind")
    if event.amount <= int64(0):
        return Err[consensus.ConsensusDecision](" consensus apply prefix wrapper: amount")
    if event.stem != event.ganzhiIndex % 10 || event.branch != event.ganzhiIndex % 12:
        return Err[consensus.ConsensusDecision](" consensus apply prefix wrapper: ganzhi")
    consensus.ConsensusApplyMint(index, event, eventCid, logOffset, out)
    assert(index.accountIds.buffer != nil, " consensus apply prefix wrapper: inner account buffer")
    assert(index.accountIds.cap >= 1, " consensus apply prefix wrapper: inner account cap")
    assert(index.accountIds.len == 1, " consensus apply prefix wrapper: inner account len")
    return Ok[consensus.ConsensusDecision](out)

fn main(): int32 =
    var index = consensus.ChainIndex()
    let zeroCid = layout.FixedBytes32()
    let event = consensus.ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let eventCid = consensus.ChainEventCid(event)
    let applyRes = localApply(index, event, eventCid, 0)
    assert(IsOk(applyRes), " consensus apply prefix wrapper: ok")
    let decision = Value(applyRes)
    assert(decision.accepted, " consensus apply prefix wrapper: accepted")
    assert(decision.applied, " consensus apply prefix wrapper: applied")
    assert(index.accountIds.buffer != nil, " consensus apply prefix wrapper: account buffer")
    assert(index.accountIds.cap >= 1, " consensus apply prefix wrapper: account cap")
    assert(index.accountIds.len == 1, " consensus apply prefix wrapper: account len")
    echo(" consensus_apply_prefix_wrapper_smoke ok")
    return 0
