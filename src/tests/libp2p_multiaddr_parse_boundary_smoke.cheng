import std/system
import std/result
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr

fn main(): int32 =
    let okRes = multiaddr.Libp2pMultiaddrParse("/ip4/127.0.0.1/udp/4201/quic-v1")
    assert(IsOk(okRes), " libp2p multiaddr boundary: quic parse ok")
    let okAddr = Value(okRes)
    assert(okAddr.transport == types.Libp2pTransportQuic, " libp2p multiaddr boundary: quic transport")
    assert(okAddr.secure == types.Libp2pSecureTls, " libp2p multiaddr boundary: quic secure")

    let emptyRes = multiaddr.Libp2pMultiaddrParse("")
    assert(IsErr(emptyRes), " libp2p multiaddr boundary: empty rejected")
    assert(Error(emptyRes) == " libp2p multiaddr: empty", " libp2p multiaddr boundary: empty error")

    let missingQuicRes = multiaddr.Libp2pMultiaddrParse("/ip4/127.0.0.1/udp/4201")
    assert(IsErr(missingQuicRes), " libp2p multiaddr boundary: missing quic rejected")
    assert(Error(missingQuicRes) == " libp2p multiaddr: missing quic transport",
        " libp2p multiaddr boundary: missing quic error")

    let badPortRes = multiaddr.Libp2pMultiaddrParse("/ip4/127.0.0.1/udp/abc/quic-v1")
    assert(IsErr(badPortRes), " libp2p multiaddr boundary: invalid port rejected")
    assert(Error(badPortRes) == " libp2p multiaddr: invalid number",
        " libp2p multiaddr boundary: invalid port error")

    let trailingProtoRes = multiaddr.Libp2pMultiaddrParse("/ip4/127.0.0.1/tcp/4201/quic-v1")
    assert(IsErr(trailingProtoRes), " libp2p multiaddr boundary: trailing protocol rejected")
    assert(Error(trailingProtoRes) == " libp2p multiaddr: unsupported trailing protocol",
        " libp2p multiaddr boundary: trailing protocol error")

    echo(" libp2p_multiaddr_parse_boundary_smoke ok")
    return 0
