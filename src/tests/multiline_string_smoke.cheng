fn main(): int32 =
    let raw = """
        alpha
          beta "quoted" \ slash
        gamma
        """
    if raw != "alpha\n  beta \"quoted\" \\ slash\ngamma":
        return 1

    let name = "cheng"
    let rendered = Fmt"""
        hello {name}
        brace={{ok}}
        """
    if rendered != "hello cheng\nbrace={ok}":
        return 2
    return 0
