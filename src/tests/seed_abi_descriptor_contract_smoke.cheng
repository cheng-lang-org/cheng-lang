import cheng/core/tooling/path as chengpath
import cheng/core/lang/parser

fn countText(text: str, needle: str): int32 =
    if needle == "":
        return 0
    var count: int32
    var start: int32
    while start < text.len:
        let tail = chengpath.TextSlice(text, start, text.len - start)
        let pos = parser.ParserFindText(tail, needle)
        if pos < 0:
            return count
        count = count + 1
        start = start + pos + needle.len
    return count

fn main(): int32 =
    let root = chengpath.PathCurrentDir()
    let seedPath = chengpath.PathJoin(root, "bootstrap/cheng_seed.c")
    let seedText = chengpath.ReadTextFile("", seedPath)
    assert(seedText != "", " seed abi descriptor: seed source")
    assert(chengpath.TextContains(seedText, "static ChengSeedAbiDescriptor cheng_seed_abi_descriptor_from_class"),
           " seed abi descriptor: descriptor entry")
    assert(chengpath.TextContains(seedText, "return desc.value_kind == ChengSeed_ABI_VALUE_COMPOSITE;"),
           " seed abi descriptor: composite helper uses descriptor")
    assert(chengpath.TextContains(seedText, "return cheng_seed_abi_descriptor_from_class(abi_class).wasm_i32_value;"),
           " seed abi descriptor: wasm value helper uses descriptor")
    assert(countText(seedText, "strcmp(abi_class, \"composite\") == 0") == 1,
           " seed abi descriptor: composite strcmp only in descriptor")
    assert(countText(seedText, "strcmp(field_abi, \"composite\")") == 0,
           " seed abi descriptor: no field abi composite text compare")
    assert(countText(seedText, "strcmp(value.abi_class, \"composite\")") == 0,
           " seed abi descriptor: no value abi composite text compare")
    assert(countText(seedText, "strcmp(target->return_abi_class, \"composite\")") == 0,
           " seed abi descriptor: no return abi composite text compare")
    echo(" seed_abi_descriptor_contract_smoke ok")
    return 0
