import cheng/core/tooling/path as v3path
import cheng/core/lang/parser

fn countText(text: str, needle: str): int32 =
    if needle == "":
        return 0
    var count: int32
    var start: int32
    while start < text.len:
        let tail = v3path.V3TextSlice(text, start, text.len - start)
        let pos = parser.v3ParserFindText(tail, needle)
        if pos < 0:
            return count
        count = count + 1
        start = start + pos + needle.len
    return count

fn main(): int32 =
    let root = v3path.V3PathCurrentDir()
    let seedPath = v3path.V3PathJoin(root, "bootstrap/cheng_seed.c")
    let seedText = v3path.V3ReadTextFile("", seedPath)
    assert(seedText != "", "v3 seed abi descriptor: seed source")
    assert(v3path.V3TextContains(seedText, "static V3AbiDescriptor v3_abi_descriptor_from_class"),
           "v3 seed abi descriptor: descriptor entry")
    assert(v3path.V3TextContains(seedText, "return desc.value_kind == V3_ABI_VALUE_COMPOSITE;"),
           "v3 seed abi descriptor: composite helper uses descriptor")
    assert(v3path.V3TextContains(seedText, "return v3_abi_descriptor_from_class(abi_class).wasm_i32_value;"),
           "v3 seed abi descriptor: wasm value helper uses descriptor")
    assert(countText(seedText, "strcmp(abi_class, \"composite\") == 0") == 1,
           "v3 seed abi descriptor: composite strcmp only in descriptor")
    assert(countText(seedText, "strcmp(field_abi, \"composite\")") == 0,
           "v3 seed abi descriptor: no field abi composite text compare")
    assert(countText(seedText, "strcmp(value.abi_class, \"composite\")") == 0,
           "v3 seed abi descriptor: no value abi composite text compare")
    assert(countText(seedText, "strcmp(target->return_abi_class, \"composite\")") == 0,
           "v3 seed abi descriptor: no return abi composite text compare")
    echo("v3 seed_abi_descriptor_contract_smoke ok")
    return 0
