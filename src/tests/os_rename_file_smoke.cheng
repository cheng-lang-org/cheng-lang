import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_rename_file_smoke_tmp"
    let oldPath: str = os.JoinPath(tmpRoot, "old.txt")
    let newPath: str = os.JoinPath(tmpRoot, "new.txt")

    if os.FileExists(oldPath):
        assert(os.RemoveFile(oldPath), "v3 ordinary os.RenameFile cleanup old file")
    if os.FileExists(newPath):
        assert(os.RemoveFile(newPath), "v3 ordinary os.RenameFile cleanup new file")
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

    os.CreateDir(tmpRoot)
    os.WriteFile(oldPath, "rename-ok")
    assert(os.RenameFile(oldPath, newPath), "v3 ordinary os.RenameFile success")
    let oldExists: bool = os.FileExists(oldPath)
    if oldExists:
        assert(false, "v3 ordinary os.RenameFile old removed")
    assert(os.FileExists(newPath), "v3 ordinary os.RenameFile new exists")
    assert(os.ReadFile(newPath) == "rename-ok", "v3 ordinary os.RenameFile content preserved")

    if os.FileExists(newPath):
        assert(os.RemoveFile(newPath), "v3 ordinary os.RenameFile remove new file")
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)
    echo("v3 os_rename_file_smoke ok")
    return 0
