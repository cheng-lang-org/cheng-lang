import std/os
import std/system
import std/strings
import cheng/core/tooling/path as chengpath

fn printLine(text: str) =
    puts(panicCString(text))

fn printI32(label: str, value: int32) =
    printLine(label + strings.IntToStr(value))

fn printI64(label: str, value: int64) =
    printLine(label + strings.Int64ToStr(value))

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/parentdir_probe")
    let parent: str = os.ParentDir(outDir)
    printI64("out.data=", int64(uint64(outDir.data)))
    printI32("out.len=", outDir.len)
    printI32("out.flags=", outDir.flags)
    printI64("parent.data=", int64(uint64(parent.data)))
    printI32("parent.len=", parent.len)
    printI32("parent.flags=", parent.flags)
    return 0
