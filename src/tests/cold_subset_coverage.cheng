import libc

// --- Arithmetic ---
fn test_arithmetic(): int32 =
    let a: int32 = 40 + 2
    let b: int32 = a - 1
    let c: int32 = b * 1
    let d: int32 = 84 / 2
    let e: int32 = 43 % 2
    return d

// --- Bitwise ---
fn test_bitwise(): int32 =
    let a: int32 = 0xFF & 0x0F
    let b: int32 = 0x10 | 0x01
    let c: int32 = 0xFF ^ 0x0F
    let d: int32 = 1 << 4
    let e: int32 = 256 >> 4
    return d

// --- Comparison ---
fn test_comparison(): int32 =
    let a: int32 = 10
    if a == 10 && a != 5 && a < 20 && a <= 10 && a > 0 && a >= 10:
        return 42
    return 0

// --- Control flow ---
fn test_control_flow(): int32 =
    let a: int32 = 5
    if a > 3:
        return 42
    else:
        return 0

// --- For loop ---
fn test_for_range(): int32 =
    var s: int32
    for i in 0..<10:
        s = s + i
    return s

// --- While loop ---
fn test_while(): int32 =
    var i: int32 = 5
    var s: int32
    while i > 0:
        s = s + i
        i = i - 1
    return s

// --- Match (payloadless) ---
type Color = Red | Green | Blue

fn test_match(): int32 =
    let c: Color = Color.Green
    match c:
        Red => return 1
        Green => return 42
        Blue => return 3

// --- String operations ---
fn test_strings(): int32 =
    let e: str = "the answer"
    let f: int32 = e.len
    return f

// --- Arrays ---
fn test_arrays(): int32 =
    let arr: int32[] = [1, 2, 3, 4, 5]
    let s: int32 = arr[0] + arr[4]
    return s

// --- Var mutation ---
fn test_var(): int32 =
    var x: int32 = 10
    x = x + 32
    return x

// --- Cross-function call ---
fn test_call(): int32 =
    return test_var() + test_bitwise()

// --- Variant with payload (qualified) ---
type Result = Ok(val: int32) | Err(msg: str)

fn test_variant_ok(): int32 =
    let r: Result = Result.Ok(42)
    match r:
        Ok(val) => return val
        Err(msg) => return 0

fn test_variant_err(): int32 =
    let r: Result = Result.Err("fail")
    match r:
        Ok(val) => return 0
        Err(msg) => return 1

// --- Nested if/else ---
fn test_nested_if(): int32 =
    let a: int32 = 5
    let b: int32 = 10
    if a > 0:
        if b > a:
            return 42
    return 0

// --- Early return ---
fn test_early_return(x: int32): int32 =
    if x < 0:
        return 0
    return x * 2

// --- Object with fields ---
type Point =
    x: int32
    y: int32

fn test_object(): int32 =
    let p: Point = Point{
        x: 10,
        y: 20,
    }
    return p.x + p.y

// --- Logical operators ---
fn test_logical(): int32 =
    let a: int32 = 10
    if a > 5 && a < 20 || a == -1:
        return 42
    return 0

// --- Entry point ---
fn main(): int32 =
    let r1: int32 = test_arithmetic()
    if r1 != 42: return 1

    let r2: int32 = test_bitwise()
    if r2 != 16: return 2

    let r3: int32 = test_comparison()
    if r3 != 42: return 3

    let r4: int32 = test_control_flow()
    if r4 != 42: return 4

    let r5: int32 = test_for_range()
    if r5 != 45: return 5

    let r6: int32 = test_while()
    if r6 != 15: return 6

    let r7: int32 = test_strings()
    if r7 != 10: return 7

    let r8: int32 = test_var()
    if r8 != 42: return 8

    let r9: int32 = test_arrays()
    if r9 != 6: return 9

    let r10: int32 = test_nested_if()
    if r10 != 42: return 10

    let r11: int32 = test_early_return(5)
    if r11 != 10: return 11

    let r12: int32 = test_logical()
    if r12 != 42: return 12

    let r13: int32 = test_object()
    if r13 != 30: return 13

    let r14: int32 = test_variant_ok()
    if r14 != 42: return 14

    let r15: int32 = test_variant_err()
    if r15 != 1: return 15

    return 0
