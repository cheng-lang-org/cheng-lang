import cheng/tests/call_hir_reason_helper_a
import cheng/tests/call_hir_reason_helper_b

fn callHirReasonSurface(payload: str): str =
    let first: str = call_hir_reason_helper_a.SharedEcho(payload)
    let second: str = call_hir_reason_helper_b.SharedEcho(payload)
    SharedEcho(payload)
    return first + second
