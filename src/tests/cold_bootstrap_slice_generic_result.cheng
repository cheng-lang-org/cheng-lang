type ObjType =
    id: int32
    width: int32

type Diag =
    code: int32
    text: str

type Result[T, E] = Ok(value: T) | Err(error: E)

fn MakeObj(id: int32): ObjType =
    return ObjType(id: id, width: 32)

fn Check(flag: int32): Result[ObjType, Diag] =
    if flag == 1:
        return Ok(MakeObj(10))
    return Err(Diag(code: 9, text: "bad"))

fn main(): int32 =
    let good = Check(1)
    match good:
        Ok(value) =>
            if value.id != 10:
                return 1
            if value.width != 32:
                return 2
        Err(error) =>
            return 3

    let bad: Result[ObjType, Diag] = Check(0)
    match bad:
        Ok(value) =>
            return 4
        Err(error) =>
            if error.code != 9:
                return 5
            if len(error.text) != 3:
                return 6

    return 42
