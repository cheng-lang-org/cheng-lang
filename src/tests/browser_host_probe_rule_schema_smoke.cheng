import cheng/core/lang/browser_abi_rule as barule
import cheng/libp2p/browser/browser_host_probe_rule_schema as browserprobe

fn main(): int32 =
    let rules = browserprobe.BrowserHostProbeRules("/tmp/browser_host_wasm_probe.cheng")
    assert(rules.len == 8, " browser_host_probe_rule_schema: rule count")
    assert(barule.BrowserAbiRuleCountInputKind(rules, barule.BrowserAbiInputScalarNone) == 4,
           " browser_host_probe_rule_schema: scalar none count")
    assert(barule.BrowserAbiRuleCountInputKind(rules, barule.BrowserAbiInputScalarI32_1) == 2,
           " browser_host_probe_rule_schema: scalar i32_1 count")
    assert(barule.BrowserAbiRuleCountInputKind(rules, barule.BrowserAbiInputScalarI32_2) == 1,
           " browser_host_probe_rule_schema: scalar i32_2 count")
    assert(barule.BrowserAbiRuleCountInputKind(rules, barule.BrowserAbiInputScalarI32_4) == 1,
           " browser_host_probe_rule_schema: scalar i32_4 count")
    assert(barule.BrowserAbiRuleCountOutputKind(rules, barule.BrowserAbiOutputScalarI32) == 8,
           " browser_host_probe_rule_schema: scalar output count")
    let dmWait = browserprobe.BrowserHostProbeRuleByName("/tmp/browser_host_wasm_probe.cheng",
                                                           browserprobe.BrowserHostProbeRuleDmWaitStartName())
    assert(dmWait.ruleName == browserprobe.BrowserHostProbeRuleDmWaitStartName(),
           " browser_host_probe_rule_schema: dm wait name")
    assert(dmWait.inputKind == barule.BrowserAbiInputScalarI32_2,
           " browser_host_probe_rule_schema: dm wait input")
    assert(dmWait.outputKind == barule.BrowserAbiOutputScalarI32,
           " browser_host_probe_rule_schema: dm wait output")
    assert(dmWait.errorKind == barule.BrowserAbiErrorInlineNone,
           " browser_host_probe_rule_schema: dm wait error")
    assert(barule.BrowserAbiBridgeEmitLine(barule.BrowserAbiBridgeSpecForRule(dmWait)) ==
           "source=/tmp/browser_host_wasm_probe.cheng|rule=dm_wait_start|stage=scalar_call|helper=cheng_browser_bridge_scalar_call_dm_wait_start|input_schema=scalar_i32_2|output_schema=scalar_i32|error_schema=inline_none|result=scalar_i32|out_buffer=none",
           " browser_host_probe_rule_schema: dm wait emit line")
    echo(" browser_host_probe_rule_schema_smoke ok")
    return 0
