import std/system
import std/rawbytes
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_fetch as fetch
import cheng/chain/content_runtime as runtime
import cheng/chain/content_runtime_browser_webrtc as runtime_browser
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/protocols/webrtc_signal as signal
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/host/host

fn webrtcBrowserContentBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn main(): int32 =
    webrtc_transport.Libp2pWebrtcTransportResetStats()
    let shard = bytesFromString("browser-webrtc-shard")
    let blob = shard
    let summaryRes = dag.DagBlobSummaryFromBytes(blob, bytesLen(shard))
    assert(IsOk(summaryRes), " webrtc browser content: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic, 1, 0, bytesLen(shard))
    assert(IsOk(paramsRes), " webrtc browser content: params")
    let params = Value(paramsRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    add(shardPayloadCids, swarm.ErasureShardPayloadCid(shard))
    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), " webrtc browser content: manifest")
    let manifest = Value(manifestRes)
    let requestRes = swarm.ErasureShardPullRequestMake(manifest, 0)
    assert(IsOk(requestRes), " webrtc browser content: request")
    let request = Value(requestRes)

    var serverRuntime = runtime.ContentRuntimeInit()
    let storeManifestRes = runtime.ContentRuntimeStoreManifest(serverRuntime, manifest)
    assert(IsOk(storeManifestRes), " webrtc browser content: store manifest")
    let storeBlobRes = runtime.ContentRuntimeStoreBlobPayload(serverRuntime, summary.blobCid, blob)
    assert(IsOk(storeBlobRes), " webrtc browser content: store blob")
    let seedResponseRes = swarm.ErasureShardPullResponseMake(request, shard)
    assert(IsOk(seedResponseRes), " webrtc browser content: seed response")
    let seedStoreRes = runtime.ContentRuntimeStoreShardResponse(serverRuntime, Value(seedResponseRes))
    assert(IsOk(seedStoreRes), " webrtc browser content: store shard")

    var server = host.Libp2pHostInit("content.browser.server")
    var client = host.Libp2pHostInit("content.browser.client")
    var listenAddr: types.Libp2pMultiaddr
    listenAddr.host = "203.0.113.143"
    listenAddr.port = 9453
    listenAddr.transport = types.Libp2pTransportWebrtc
    listenAddr.networkDomain = types.Libp2pNetworkDomainBrowserWebrtc
    listenAddr.visibility = types.Libp2pVisibilityPublic
    let listenRes = host.Libp2pListen(server, listenAddr)
    assert(listenRes.ok, " webrtc browser content: listen")

    host.Libp2pRegisterHandler(server, types.Libp2pProtocolContent)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolContent)
    host.Libp2pRegisterHandler(server, types.Libp2pProtocolWebrtcSignal)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolWebrtcSignal)
    let dialRes = host.Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " webrtc browser content: dial")

    let manifestFetchReqRes = fetch.ContentFetchRequestManifest(manifest.manifestCid)
    assert(IsOk(manifestFetchReqRes), " webrtc browser content: manifest request")
    let manifestFetchRequest = Value(manifestFetchReqRes)
    let manifestFetchRes = runtime_browser.ContentRuntimeRequestFetch(client,
                                                                        server,
                                                                        server.selfPeerId,
                                                                        serverRuntime,
                                                                        manifestFetchRequest)
    assert(IsOk(manifestFetchRes), " webrtc browser content: manifest fetch")
    var manifestPull = swarm.ErasureShardManifest()
    let manifestPullRes = fetch.ContentFetchResponseToManifestFill(manifestPull,
                                                                     manifestFetchRequest,
                                                                     Value(manifestFetchRes))
    assert(IsOk(manifestPullRes), " webrtc browser content: manifest pull")
    assert(layout.fixedBytes32Equal(manifestPull.manifestCid, manifest.manifestCid),
        " webrtc browser content: manifest cid")
    assert(host.Libp2pWebrtcSignalEgressCount(client) == 5,
        " webrtc browser content: manifest signal egress")
    assert(host.Libp2pWebrtcSignalIngressCount(server) == 5,
        " webrtc browser content: manifest signal ingress")
    assert(webrtc_transport.Libp2pWebrtcBrowserDatachannelOpenCountNow() == 1,
        " webrtc browser content: manifest browser open")
    assert(webrtc_transport.Libp2pWebrtcBrowserDatachannelRequestCountNow() == 1,
        " webrtc browser content: manifest browser count")
    assert(webrtc_transport.Libp2pWebrtcNativeDatachannelRequestCountNow() == 0,
        " webrtc browser content: manifest native count")

    let rangeReqRes = fetch.ContentFetchRequestRange(summary.blobCid, 0, 6)
    assert(IsOk(rangeReqRes), " webrtc browser content: range request")
    let rangeFetchRes = runtime_browser.ContentRuntimeRequestFetch(client,
                                                                     server,
                                                                     server.selfPeerId,
                                                                     serverRuntime,
                                                                     Value(rangeReqRes))
    assert(IsOk(rangeFetchRes), " webrtc browser content: range fetch")
    let rangeFetch = Value(rangeFetchRes)
    assert(webrtcBrowserContentBytesEqual(rangeFetch.payload, bytesSlice(blob, 0, 6)),
        " webrtc browser content: range bytes")
    assert(host.Libp2pWebrtcSignalEgressCount(client) == 5,
        " webrtc browser content: range signal reuse")
    assert(webrtc_transport.Libp2pWebrtcBrowserDatachannelRequestCountNow() == 2,
        " webrtc browser content: range browser count")

    let pullRes = runtime_browser.ContentRuntimeRequestShardPull(client,
                                                                   server,
                                                                   server.selfPeerId,
                                                                   serverRuntime,
                                                                   request)
    assert(IsOk(pullRes), " webrtc browser content: pull")
    let response = Value(pullRes)
    assert(layout.fixedBytes32Equal(response.shardCid, request.shardCid),
        " webrtc browser content: shard cid")
    assert(webrtcBrowserContentBytesEqual(response.payload, shard),
        " webrtc browser content: shard payload")
    assert(host.Libp2pWebrtcSignalIngressCount(server) == 5,
        " webrtc browser content: shard signal reuse")
    assert(webrtc_transport.Libp2pWebrtcBrowserDatachannelRequestCountNow() == 3,
        " webrtc browser content: shard browser count")
    assert(webrtc_transport.Libp2pWebrtcBrowserSessionActiveCountNow() == 1,
        " webrtc browser content: active session")

    let rebuildRes = runtime.ContentRuntimeRebuildBlob(manifest, params, [response])
    assert(IsOk(rebuildRes), " webrtc browser content: rebuild")
    assert(webrtcBrowserContentBytesEqual(Value(rebuildRes), blob),
        " webrtc browser content: rebuild bytes")

    let firstSignalRes = signal.Libp2pWebrtcSignalDecode(client.webrtcSignalEgressPayloads[0])
    let lastSignalRes = signal.Libp2pWebrtcSignalDecode(client.webrtcSignalEgressPayloads[4])
    assert(IsOk(firstSignalRes), " webrtc browser content: first signal")
    assert(IsOk(lastSignalRes), " webrtc browser content: last signal")
    assert(layout.fixedBytes32Equal(Value(firstSignalRes).sessionId, Value(lastSignalRes).sessionId),
        " webrtc browser content: stable session id")

    echo(" webrtc_browser_content_smoke ok")
    return 0
