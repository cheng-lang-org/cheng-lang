import std/system
import std/times
import std/strings as strings
import cheng/libp2p/core/types
import cheng/libp2p/identity/did
import cheng/libp2p/host/host
import cheng/mobile/android_bridge as mobile
import cheng/mobile/mobile_sdk as mobile_sdk
import cheng/libp2p/browser/browser_sdk as browser
import cheng/core/tooling/path as chengpath
import std/strutils as strutil

fn main(): int32 =
    let now = times.EpochTimeSeconds()
    let storeRoot = "artifacts/identity_store_smoke"
    let suffix = strings.Int64ToStr(now)
    let phoneStorePath = strutil.Join([storeRoot, "/phone_", suffix, ".did"], "")
    let laptopStorePath = strutil.Join([storeRoot, "/laptop_", suffix, ".did"], "")
    let autoStorePath = strutil.Join([storeRoot, "/auto_", suffix, ".did"], "")

    var phoneIdentity: did.DidIdentity
    let phoneStoreRes = did.DidLoadOrCreateIdentityFill(phoneIdentity,
                                                          chengpath.PathCurrentDir(),
                                                          phoneStorePath,
                                                          "alice.root.seed",
                                                          "alice.phone.device",
                                                          "phone",
                                                          now)
    assert(IsOk(phoneStoreRes), " did identity: create phone store")

    var phoneIdentityAgain: did.DidIdentity
    let phoneReloadRes = did.DidLoadOrCreateIdentityFill(phoneIdentityAgain,
                                                           chengpath.PathCurrentDir(),
                                                           phoneStorePath,
                                                           "",
                                                           "",
                                                           "",
                                                           now + int64(1))
    assert(IsOk(phoneReloadRes), " did identity: reload phone store")

    var laptopIdentity: did.DidIdentity
    let laptopStoreRes = did.DidLoadOrCreateIdentityFill(laptopIdentity,
                                                           chengpath.PathCurrentDir(),
                                                           laptopStorePath,
                                                           "alice.root.seed",
                                                           "alice.laptop.device",
                                                           "laptop",
                                                           now)
    assert(IsOk(laptopStoreRes), " did identity: create laptop store")

    var autoIdentity: did.DidIdentity
    let autoIdentityRes = did.DidLoadOrCreateIdentityFill(autoIdentity,
                                                            chengpath.PathCurrentDir(),
                                                            autoStorePath,
                                                            "",
                                                            "",
                                                            "auto",
                                                            now)
    assert(IsOk(autoIdentityRes), " did identity: create auto store")
    var autoReload: did.DidIdentity
    let autoReloadRes = did.DidLoadOrCreateIdentityFill(autoReload,
                                                          chengpath.PathCurrentDir(),
                                                          autoStorePath,
                                                          "",
                                                          "",
                                                          "",
                                                          now + int64(1))
    assert(IsOk(autoReloadRes), " did identity: reload auto store")

    assert(did.DidIdentityDid(phoneIdentity) == did.DidFromRootSeed("alice.root.seed"),
        " did identity: did text")
    assert(did.DidIdentityDid(phoneIdentity) == did.DidIdentityDid(laptopIdentity),
        " did identity: same root same did")
    let phoneStoreTextRes = did.DidIdentityStoreText(phoneIdentity)
    assert(IsOk(phoneStoreTextRes), " did identity: create store text")
    let phoneReloadStoreTextRes = did.DidIdentityStoreText(phoneIdentityAgain)
    assert(IsOk(phoneReloadStoreTextRes), " did identity: reload store text")
    assert(Value(phoneStoreTextRes) == Value(phoneReloadStoreTextRes),
        " did identity: reload device count")
    assert(types.Libp2pPeerIdEqual(phoneIdentity.selfDevice.devicePeerId,
                                     phoneIdentityAgain.selfDevice.devicePeerId),
        " did identity: same device stable peer id")
    assert(!types.Libp2pPeerIdEqual(phoneIdentity.selfDevice.devicePeerId,
                                      laptopIdentity.selfDevice.devicePeerId),
        " did identity: different device different peer id")
    assert(types.Libp2pPeerIdEqual(autoIdentity.selfDevice.devicePeerId,
                                     autoReload.selfDevice.devicePeerId),
        " did identity: auto store stable peer id")
    assert(did.DidIdentityDid(autoIdentity) == did.DidIdentityDid(autoReload),
        " did identity: auto store stable did")
    assert(chengpath.FileExistsNonEmpty(chengpath.PathCurrentDir(), phoneStorePath),
        " did identity: phone store written")
    assert(chengpath.FileExistsNonEmpty(chengpath.PathCurrentDir(), autoStorePath),
        " did identity: auto store written")

    let phoneDidText = did.DidFromRootSeed("alice.root.seed")
    let phoneRootPeerId = did.DidRootPeerIdFromSeed("alice.root.seed")
    let phoneRootSeedHash = did.DidRootSeedHash("alice.root.seed")
    let phoneGenesisCid = did.DidGenesisCid(phoneRootPeerId, phoneRootSeedHash)
    assert(strings.HasPrefix(phoneDidText, "did:cheng:g"),
        " did identity: did genesis prefix")
    let phoneSelfDevice = did.DidDeviceMethodMake(phoneDidText,
                                                    phoneRootSeedHash,
                                                    "alice.phone.device",
                                                    "phone",
                                                    now)
    var document: did.DidDocument
    document.did = phoneDidText
    document.genesisCid = phoneGenesisCid
    document.rootPeerId = phoneRootPeerId
    document.rootSeedHash = phoneRootSeedHash
    document.version = did.DidWord64FromInt64(int64(1))
    document.updatedAtEpochSeconds = did.DidWord64FromInt64(now)
    var documentDevices: did.DidDeviceMethod[]
    add(documentDevices, phoneSelfDevice)
    document.devices = documentDevices
    let enrollRes = did.DidDocumentEnrollDevice(document,
                                                  "alice.root.seed",
                                                  "alice.laptop.device",
                                                  "laptop",
                                                  now + int64(20))
    assert(IsOk(enrollRes), " did identity: enroll laptop")
    document = Value(enrollRes)
    let laptopPeerId = did.DidDevicePeerIdFromSeed("alice.laptop.device")
    let laptopPos = did.DidDocumentFindDevicePos(document, laptopPeerId)
    assert(laptopPos >= 0, " did identity: enrolled laptop present")
    let laptopDevice = document.devices[laptopPos]
    assert(document.devices.len == 2, " did identity: document device count")
    assert(did.DidWord64Value(document.version) == int64(2), " did identity: enroll bumps version")
    assert(did.DidDocumentDeviceActive(document, laptopDevice.devicePeerId),
        " did identity: laptop active")

    var persistedIdentity = did.DidIdentityClone(phoneIdentity)
    var appliedIdentity: did.DidIdentity
    let applyEnrollRes = did.DidIdentityApplyDocumentFill(appliedIdentity,
                                                            persistedIdentity,
                                                            document)
    assert(IsOk(applyEnrollRes), " did identity: apply enroll document")
    persistedIdentity = appliedIdentity
    let saveRes = did.DidSaveIdentity(chengpath.PathCurrentDir(), phoneStorePath, persistedIdentity)
    assert(IsOk(saveRes), " did identity: save enrolled document")
    var persistedReload: did.DidIdentity
    let persistedReloadRes = did.DidIdentityLoadFill(persistedReload,
                                                       chengpath.PathCurrentDir(),
                                                       phoneStorePath)
    assert(IsOk(persistedReloadRes), " did identity: reload enrolled document")
    let persistedStoreTextRes = did.DidIdentityStoreText(persistedIdentity)
    assert(IsOk(persistedStoreTextRes), " did identity: persisted store text")
    let persistedReloadStoreTextRes = did.DidIdentityStoreText(persistedReload)
    assert(IsOk(persistedReloadStoreTextRes), " did identity: persisted reload store text")
    assert(Value(persistedStoreTextRes) == Value(persistedReloadStoreTextRes),
        " did identity: persisted enrolled device count")

    let revokeRes = did.DidDocumentRevokeDevice(document,
                                                  "alice.root.seed",
                                                  laptopDevice.devicePeerId,
                                                  now + int64(30))
    assert(IsOk(revokeRes), " did identity: revoke laptop")
    document = Value(revokeRes)
    assert(did.DidWord64Value(document.version) == int64(3), " did identity: revoke bumps version")
    assert(!did.DidDocumentDeviceActive(document, laptopDevice.devicePeerId),
        " did identity: laptop revoked")

    var libHost = host.Libp2pHostInitWithDid(phoneIdentity)
    assert(host.Libp2pHostHasDidIdentity(libHost),
        " did identity: lib host attached")
    assert(host.Libp2pHostDidText(libHost) == did.DidIdentityDid(phoneIdentity),
        " did identity: lib host did text")
    assert(types.Libp2pPeerIdEqual(libHost.selfPeerId, phoneIdentity.selfDevice.devicePeerId),
        " did identity: lib host device peer")
    var libHostStored = host.Libp2pHostInit("")
    let libHostStoreRes = host.Libp2pHostInitWithDidStoreFill(libHostStored,
                                                                phoneStorePath,
                                                                "",
                                                                "",
                                                                "",
                                                                now + int64(2))
    assert(IsOk(libHostStoreRes), " did identity: lib host store init")
    assert(host.Libp2pHostDidText(libHostStored) == did.DidIdentityDid(phoneIdentity),
        " did identity: lib host store did text")

    var mobileHost = mobile.MobileHostInitWithDid(phoneIdentity)
    assert(mobile.MobileHostHasDidIdentity(mobileHost),
        " did identity: mobile host attached")
    assert(mobile.MobileHostDidText(mobileHost) == did.DidIdentityDid(phoneIdentity),
        " did identity: mobile host did text")
    assert(types.Libp2pPeerIdEqual(mobileHost.selfPeerId, phoneIdentity.selfDevice.devicePeerId),
        " did identity: mobile host device peer")
    var mobileHostStored = mobile.MobileHostInit("")
    let mobileHostStoreRes = mobile.MobileHostInitWithDidStoreFill(mobileHostStored,
                                                                     phoneStorePath,
                                                                     "",
                                                                     "",
                                                                     "",
                                                                     now + int64(2))
    assert(IsOk(mobileHostStoreRes), " did identity: mobile host store init")
    assert(mobile.MobileHostDidText(mobileHostStored) == did.DidIdentityDid(phoneIdentity),
        " did identity: mobile host store did text")

    var sdk = mobile_sdk.MobileSdkInitWithDid(phoneIdentity)
    assert(mobile_sdk.MobileSdkDidText(sdk) == did.DidIdentityDid(phoneIdentity),
        " did identity: mobile sdk did text")
    assert(mobile_sdk.MobileSdkSelfPeerText(sdk) != "",
        " did identity: mobile sdk self peer")
    var sdkStored = mobile_sdk.MobileSdkInit("")
    let sdkStoreRes = mobile_sdk.MobileSdkInitWithDidStoreFill(sdkStored,
                                                                 phoneStorePath,
                                                                 "",
                                                                 "",
                                                                 "",
                                                                 now + int64(2))
    assert(IsOk(sdkStoreRes), " did identity: mobile sdk store init")
    assert(mobile_sdk.MobileSdkDidText(sdkStored) == did.DidIdentityDid(phoneIdentity),
        " did identity: mobile sdk store did text")
    let sdkSaveRes = mobile_sdk.MobileSdkSaveDidIdentity(phoneStorePath, sdkStored)
    assert(IsOk(sdkSaveRes), " did identity: mobile sdk save did")

    var browserSdk = browser.BrowserSdkInitWithDid(phoneIdentity)
    assert(browser.BrowserSdkDidText(browserSdk) == did.DidIdentityDid(phoneIdentity),
        " did identity: browser sdk did text")
    assert(browser.BrowserSdkPeerIdText(browserSdk) != "",
        " did identity: browser sdk self peer")
    var browserStored = browser.BrowserSdkInit("")
    let browserStoreRes = browser.BrowserSdkInitWithDidStoreFill(browserStored,
                                                                   phoneStorePath,
                                                                   "",
                                                                   "",
                                                                   "",
                                                                   now + int64(2))
    assert(IsOk(browserStoreRes), " did identity: browser sdk store init")
    assert(browser.BrowserSdkDidText(browserStored) == did.DidIdentityDid(phoneIdentity),
        " did identity: browser sdk store did text")
    let browserSaveRes = browser.BrowserSdkSaveDidIdentity(phoneStorePath, browserStored)
    assert(IsOk(browserSaveRes), " did identity: browser sdk save did")

    echo(" did_identity_smoke ok")
    return 0
