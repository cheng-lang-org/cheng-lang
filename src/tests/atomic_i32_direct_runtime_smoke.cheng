@importc("cheng_atomic_cas_i32")
fn atomicCasRaw(p: ptr, expect: int32, desired: int32): int32

@importc("cheng_atomic_store_i32")
fn atomicStoreRaw(p: ptr, value: int32)

@importc("cheng_atomic_load_i32")
fn atomicLoadRaw(p: ptr): int32

fn main(): int32 =
    var cell: int32
    atomicStoreRaw(&cell, 7)
    if atomicLoadRaw(&cell) != 7:
        return 1
    if atomicCasRaw(&cell, 7, 9) == 0:
        return 2
    if atomicLoadRaw(&cell) != 9:
        return 3
    if atomicCasRaw(&cell, 7, 11) != 0:
        return 4
    if atomicLoadRaw(&cell) != 9:
        return 5
    echo(" atomic_i32_direct_runtime_smoke ok")
    return 0
