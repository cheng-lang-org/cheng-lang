import cheng/core/runtime/arena as arena

fn main(): int32 =
    var a = arena.ArenaInit(32, 8)
    let first = arena.ArenaAllocBytes(a, 3)
    if arena.ArenaBytesOffset(first) != 0:
        return 1
    if arena.ArenaBytesLen(first) != 3:
        return 2
    arena.ArenaSetByte(a, first, 0, 7)
    arena.ArenaSetByte(a, first, 1, 9)
    if arena.ArenaGetByte(a, first, 0) != 7:
        return 3
    if arena.ArenaGetByte(a, first, 1) != 9:
        return 4
    let second = arena.ArenaAllocBytesAligned(a, 5, 4)
    if arena.ArenaBytesOffset(second) != 4:
        return 5
    if arena.ArenaUsed(a) != 9:
        return 6
    if arena.ArenaRemaining(a) != 23:
        return 7
    arena.ArenaReset(a)
    if arena.ArenaUsed(a) != 0:
        return 8
    let zeroed = arena.ArenaAllocZeroBytes(a, 2)
    if arena.ArenaGetByte(a, zeroed, 0) != 0:
        return 9
    if arena.ArenaGetByte(a, zeroed, 1) != 0:
        return 10
    arena.ArenaDestroy(a)
    return 0
