import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net
import cheng/tests/smoke_ports

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node libp2p: init server")
    var client: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(client, "node-b", "chain-node-a")),
           " chain_node libp2p: init client")
    var serverHost = host.Libp2pHostInit("chain.server")
    var clientHost = host.Libp2pHostInit("chain.client")
    var serverAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(serverAddr, "127.0.0.1", smoke_ports.SmokeLabelPort(6201))
    let listenRes = host.Libp2pListen(serverHost, serverAddr)
    assert(listenRes.ok, " chain_node libp2p: listen")
    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolGossipsub)
    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolStore)
    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolGossipsub)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolStore)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolSync)
    let dialRes = host.Libp2pDial(clientHost,
                                    serverHost.selfPeerId,
                                    serverAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " chain_node libp2p: dial")
    let mintRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintRes.ok, " chain_node libp2p: mint")
    let transferRes = node.ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferRes.ok, " chain_node libp2p: transfer")
    if layout.FixedBytes32Equal(Value(mintRes), Value(transferRes)):
        assert(false, " chain_node libp2p: distinct cids")
    let serveRes = net.ChainNodeLibp2pServeOnce(server, serverHost)
    assert(serveRes.ok, " chain_node libp2p: serve")
    assert(serveRes.value, " chain_node libp2p: serve active")
    assert(serverHost.publishLog.len == 1, " chain_node libp2p: advertise published")
    assert(serverHost.storeEntries.len == 2, " chain_node libp2p: advertise plus snapshot stored")
    var query: overlay.StoreQuery
    net.ChainNodeLibp2pSnapshotQueryFill(query, server.address)
    var syncedEntries: overlay.IngressEnvelope[]
    let syncEntriesRes = host.Libp2pSyncRequest(clientHost, serverHost, serverHost.selfPeerId, query, syncedEntries)
    assert(syncEntriesRes.ok, " chain_node libp2p: sync request")
    var syncedSnapshot: node.ChainNodeServeSnapshot
    var syncedIngress: overlay.IngressEnvelope
    let syncedIndexRes = net.ChainNodeLibp2pLatestSnapshotIndexFromIngresses(syncedEntries, server.address)
    assert(IsOk(syncedIndexRes), " chain_node libp2p: synced latest")
    let syncedIndex = syncedIndexRes.value
    net.ChainNodeLibp2pCopyIngress(syncedIngress, syncedEntries[syncedIndex])
    let syncedDecodeRes = net.ChainNodeLibp2pDecodeSnapshotFill(syncedIngress.payload, syncedSnapshot)
    assert(syncedDecodeRes.ok, " chain_node libp2p: synced decode")
    let syncRes = node.ChainNodeSyncOnce(client, syncedSnapshot)
    assert(syncRes.ok, " chain_node libp2p: sync once")
    assert(syncRes.value, " chain_node libp2p: sync changed")
    assert(clientHost.openStreamPeers.len == 1, " chain_node libp2p: opened sync stream")
    assert(clientHost.syncRequestCount == 1, " chain_node libp2p: sync request count")
    assert(serverHost.syncServeCount == 1, " chain_node libp2p: sync serve count")
    let aliceRes = node.ChainNodeBalance(client, 7, 1001)
    assert(aliceRes.ok, " chain_node libp2p: alice balance")
    assert(Value(aliceRes) == int64(60), " chain_node libp2p: alice 60")
    let bobRes = node.ChainNodeBalance(client, 7, 2002)
    assert(bobRes.ok, " chain_node libp2p: bob balance")
    assert(Value(bobRes) == int64(40), " chain_node libp2p: bob 40")
    var serverSnapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(serverSnapshot, server)
    var clientSnapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(clientSnapshot, client)
    assert(layout.FixedBytes32Equal(serverSnapshot.tipEventCid, clientSnapshot.tipEventCid),
           " chain_node libp2p: tip cid")
    assert(layout.FixedBytes32Equal(serverSnapshot.forest.forestCid, clientSnapshot.forest.forestCid),
           " chain_node libp2p: forest cid")
    assert(anti.AntiEntropySignatureEqual(serverSnapshot.signature, clientSnapshot.signature),
           " chain_node libp2p: signature")
    var syncedEntriesAgain: overlay.IngressEnvelope[]
    let syncEntriesAgainRes = host.Libp2pSyncRequest(clientHost, serverHost, serverHost.selfPeerId, query, syncedEntriesAgain)
    assert(syncEntriesAgainRes.ok, " chain_node libp2p: second sync request")
    var syncedSnapshotAgain: node.ChainNodeServeSnapshot
    var syncedIngressAgain: overlay.IngressEnvelope
    let syncedIndexAgainRes = net.ChainNodeLibp2pLatestSnapshotIndexFromIngresses(syncedEntriesAgain, server.address)
    assert(IsOk(syncedIndexAgainRes), " chain_node libp2p: second synced latest")
    let syncedIndexAgain = syncedIndexAgainRes.value
    net.ChainNodeLibp2pCopyIngress(syncedIngressAgain, syncedEntriesAgain[syncedIndexAgain])
    let syncedDecodeAgainRes = net.ChainNodeLibp2pDecodeSnapshotFill(syncedIngressAgain.payload, syncedSnapshotAgain)
    assert(syncedDecodeAgainRes.ok, " chain_node libp2p: second synced decode")
    let syncAgainRes = node.ChainNodeSyncOnce(client, syncedSnapshotAgain)
    assert(syncAgainRes.ok, " chain_node libp2p: second sync")
    assert(!syncAgainRes.value, " chain_node libp2p: second sync idle")
    assert(clientHost.syncRequestCount == 2, " chain_node libp2p: second sync request count")
    assert(serverHost.syncServeCount == 2, " chain_node libp2p: second sync serve count")
    echo(" chain_node_libp2p_smoke ok")
    return 0
