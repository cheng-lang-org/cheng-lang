import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/lang/browser_abi_rule as barule
import cheng/libp2p/browser/browser_host_probe_rule_schema as browserprobe

fn main(): int32 =
    let workspaceRoot = "/Users/lbcheng/cheng-lang"
    let packageRoot = "/Users/lbcheng/cheng-lang"
    let probePath = "/Users/lbcheng/cheng-lang/src/libp2p/browser/browser_host_wasm_probe.cheng"
    var linkPlan: slplan.SystemLinkPlanStub
    linkPlan.workspaceRoot = workspaceRoot
    linkPlan.packageRoot = packageRoot
    linkPlan.entryPath = probePath
    linkPlan.sourceClosurePaths = [probePath]
    let compilerRules = ccsg.CompilerBrowserAbiRulesForLinkPlan(linkPlan)
    let compilerSourceRules = barule.BrowserAbiRulesForSource(compilerRules, probePath)
    let schemaRules = browserprobe.BrowserHostProbeRules(probePath)
    let compilerSourceBridgeSpecs = ccsg.CompilerBrowserAbiBridgeSpecsForSource(linkPlan, probePath)
    let schemaBridgeSpecs = barule.BrowserAbiBridgeSpecsFromRules(schemaRules)
    let compilerSourceBridgePlans = ccsg.CompilerBrowserAbiBridgePlansForSource(linkPlan, probePath)
    let schemaBridgePlans = barule.BrowserAbiBridgePlansFromRules(schemaRules)
    assert(compilerRules.len == 8, " browser_host_probe_abi_rule: compiler rule count")
    assert(barule.BrowserAbiRulesEqual(compilerSourceRules, schemaRules),
           " browser_host_probe_abi_rule: source slice schema equality")
    assert(barule.BrowserAbiBridgeSpecsEqual(compilerSourceBridgeSpecs, schemaBridgeSpecs),
           " browser_host_probe_abi_rule: bridge spec schema equality")
    assert(barule.BrowserAbiBridgeSpecCountStage(compilerSourceBridgeSpecs, barule.BrowserAbiBridgeStageScalarCall) == 8,
           " browser_host_probe_abi_rule: scalar call count")
    assert(barule.BrowserAbiBridgePlansEqual(compilerSourceBridgePlans, schemaBridgePlans),
           " browser_host_probe_abi_rule: bridge plan schema equality")
    assert(barule.BrowserAbiBridgePlanCountInputSchemaKind(compilerSourceBridgePlans, barule.BrowserAbiInputScalarI32_4) == 1,
           " browser_host_probe_abi_rule: scalar i32_4 count")
    echo(" browser_host_probe_abi_rule_smoke ok")
    return 0
