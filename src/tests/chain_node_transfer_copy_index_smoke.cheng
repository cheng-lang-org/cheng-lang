import std/system
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node transfer copy index: mint")

    var nextIndex = server.index
    assert(nextIndex.accountIds.len == 1, " chain_node transfer copy index: next account len")
    assert(nextIndex.balances.len == 1, " chain_node transfer copy index: next balance len")
    assert(node.ChainNodeBalanceValue(server.index, 7, 1001) == int64(100),
           " chain_node transfer copy index: server sender 100")
    assert(nextIndex.accountIds[0] == 1001, " chain_node transfer copy index: account id")
    assert(nextIndex.balances[0] == int64(100), " chain_node transfer copy index: balance")
    echo(" chain_node_transfer_copy_index_smoke ok")
    return 0
