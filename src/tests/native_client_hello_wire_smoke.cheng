import std/system
import std/result
import std/rawbytes
import cheng/quic/native_runtime as qnative
import cheng/quic/tls/policy as qpolicy
import cheng/quic/core/packet_header_model

fn smokeClientHelloPolicy(): qpolicy.MsQuicTlsPolicy =
    var out: qpolicy.MsQuicTlsPolicy
    out.serverName = "localhost"
    return out

fn main(): int32 =
    qnative.msquicNativeResetSession()
    let policy: qpolicy.MsQuicTlsPolicy = smokeClientHelloPolicy()
    qnative.msquicNativeSetClientPolicyCache(policy)

    let payloadRes: Result[Bytes] = qnative.msquicNativeDebugBuildClientHelloPayload()
    if IsErr(payloadRes):
        panic(ErrorText(payloadRes))
    let payload: Bytes = Value(payloadRes)
    let payloadLen: int32 = bytesLen(payload)
    if payloadLen <= 0:
        panic(" native_client_hello_wire: payload bytes")
    let payloadFirstByte: int32 = bytesGet(payload, 0)
    if payloadFirstByte != qnative.msquicNativeFrameCryptoCode:
        panic(" native_client_hello_wire: payload first frame kind")

    let wireRes: Result[Bytes] = qnative.msquicNativeDebugBuildClientHelloWire()
    if IsErr(wireRes):
        panic(ErrorText(wireRes))
    let wire: Bytes = Value(wireRes)
    let headerRes = packet_header_model.quicPacketHeaderDecode(wire, qnative.msquicNativeConnIdLen)
    if IsErr(headerRes):
        panic(ErrorText(headerRes))
    let headerDec: packet_header_model.QuicPacketHeaderDecoded = Value(headerRes)
    let header: packet_header_model.QuicPacketHeader = headerDec.header
    let payloadOffset: int32 = headerDec.next
    let decodedPayloadLen: int32 = int32(header.payloadLength) - header.packetNumberLen
    let decodedPayload: Bytes = bytesSlice(wire, payloadOffset, decodedPayloadLen)
    if !header.longHeader:
        panic(" native_client_hello_wire: long header")
    let decodedLen: int32 = bytesLen(decodedPayload)
    if decodedLen <= 0:
        panic(" native_client_hello_wire: decoded payload")
    let decodedFirstByte: int32 = bytesGet(decodedPayload, 0)
    if decodedFirstByte != qnative.msquicNativeFrameCryptoCode:
        panic(" native_client_hello_wire: decoded crypto")

    echo(" native_client_hello_wire_smoke ok")
    return 0
