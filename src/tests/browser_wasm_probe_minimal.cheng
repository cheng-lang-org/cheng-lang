importc fn cheng_browser_now_ms_bridge(): int32
importc fn cheng_browser_echo_i32_bridge(value: int32): int32

fn browserNowMs(): int32 =
    return cheng_browser_now_ms_bridge()

fn browserEchoI32(value: int32): int32 =
    return cheng_browser_echo_i32_bridge(value)

fn main(): int32 =
    var now: int32 = browserNowMs()
    # Verify the imported function returns a non-negative timestamp
    assert(now >= 0, "browser_now_ms should return non-negative timestamp")
    var echoed: int32 = browserEchoI32(now)
    # Verify the echo bridge returns the same value it was given
    assert(echoed == now, "echo_i32 should return the input value unchanged")
    echo("browser-wasm-probe-ok")
    return 0
