import std/system
import std/strings
import std/strutils as strutil

fn boolJson(value: bool): str =
    if value:
        return "true"
    return "false"

fn buildJson(count: int32, ok: bool, hasRouteState: bool): str =
    var missing: str[]
    if !hasRouteState:
        add(missing, "route_state")
    var out: str = "{"
    out = strutil.Join([out, "\"count\":", intToStr(count)], "")
    out = strutil.Join([out, ",\"ok\":", boolJson(ok)], "")
    out = strutil.Join([out, ",\"missing_count\":", intToStr(missing.len)], "")
    if missing.len > 0:
        out = strutil.Join([out, ",\"first_missing\":", missing[0]], "")
    out = strutil.Join([out, "}"], "")
    return out

fn main(): int32 =
    let text = buildJson(80, true, false)
    assert(text.len > 24, " ordinary truth compare subset fixture: non-empty")
    echo(" ordinary truth compare subset fixture ok")
    return 0
