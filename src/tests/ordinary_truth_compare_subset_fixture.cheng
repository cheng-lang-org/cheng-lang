import std/system
import std/strings

fn boolJson(value: bool): str =
    if value:
        return "true"
    return "false"

fn buildJson(count: int32, ok: bool, hasRouteState: bool): str =
    var missing: str[]
    if !hasRouteState:
        add(missing, "route_state")
    var out: str = "{"
    out = out + "\"count\":" + intToStr(count)
    out = out + ",\"ok\":" + boolJson(ok)
    out = out + ",\"missing_count\":" + intToStr(missing.len)
    if missing.len > 0:
        out = out + ",\"first_missing\":" + missing[0]
    out = out + "}"
    return out

fn main(): int32 =
    let text = buildJson(80, true, false)
    assert(text.len > 24, " ordinary truth compare subset fixture: non-empty")
    echo(" ordinary truth compare subset fixture ok")
    return 0
