// Positive test: @borrow annotation on imported function with &mut parameter
// This test should compile successfully (not compile-fail)

// Import a mock function that takes &mut i32 and modifies it
import "ffi_importc_borrow_mut_pair_i32_mock" as mock

fn main(): int32 =
    var x: int32 = 10
    // Call imported function with &mut - should compile
    mock.modify(@borrow x)
    if x != 20:
        echo("ffi_importc_borrow_mut_pair_i32: FAIL - value not modified correctly")
        return 1
    // Test with pair of &mut i32
    var y: int32 = 5
    var z: int32 = 15
    mock.modify_pair(@borrow y, @borrow z)
    if y != 25 || z != 5:
        echo("ffi_importc_borrow_mut_pair_i32: FAIL - pair not modified correctly")
        return 2
    echo(" ffi_importc_borrow_mut_pair_i32 ok")
    return 0
