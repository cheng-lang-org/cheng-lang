import std/strings

type
    Box = object
        title: str
        count: int32

fn probeIntToStrOnly() =
    let count: int32 = 7
    let text: str = intToStr(count)
    assert(text == "7", "cleanup intToStr")

fn probeSingleConcatOnly() =
    let name: str = "alpha"
    let text: str = "box=" + name
    text

fn probeSingleConcatAssert() =
    let name: str = "alpha"
    let text: str = "box=" + name
    assert(text == "box=alpha", "cleanup single concat")

fn probeSummary() =
    let name: str = "alpha"
    let count: int32 = 7
    let summary: str = "box=" + name + " count=" + intToStr(count) + " rc=" + intToStr(count)
    assert(summary == "box=alpha count=7 rc=7", "cleanup summary")

fn probeWrapped() =
    let name: str = "alpha"
    let wrapped: str = "{" + name + "}"
    assert(wrapped == "{alpha}", "cleanup wrapped")

fn probeMember() =
    let box = Box(title: "beta", count: 9)
    let memberText: str = box.title + ":" + intToStr(box.count)
    assert(memberText == "beta:9", "cleanup member")

fn probeTernary() =
    let box = Box(title: "beta", count: 9)
    let fallback: str = "none"
    let condText: str = "selected=" + (true ? box.title : fallback)
    assert(condText == "selected=beta", "cleanup ternary")

fn probeIfExpr() =
    let box = Box(title: "beta", count: 9)
    let fallback: str = "none"
    let ifExprText: str = "picked=" + (if true: box.title else: fallback)
    assert(ifExprText == "picked=beta", "cleanup ifexpr")

fn probeSeqAdd() =
    let name: str = "alpha"
    let count: int32 = 7
    var parts: str[]
    add(parts, "[" + intToStr(count) + "] " + name)
    assert(parts.len == 1, "cleanup seq len")
    assert(parts[0] == "[7] alpha", "cleanup seq value")

fn probeEcho() =
    let name: str = "alpha"
    echo("probe_echo=" + name)

fn main(): int32 =
    echo("before-intToStr")
    probeIntToStrOnly()
    echo("before-single-concat-only")
    probeSingleConcatOnly()
    echo("before-single-concat-assert")
    probeSingleConcatAssert()
    echo("before-summary")
    probeSummary()
    echo("before-wrapped")
    probeWrapped()
    echo("before-member")
    probeMember()
    echo("before-ternary")
    probeTernary()
    echo("before-ifexpr")
    probeIfExpr()
    echo("before-seqadd")
    probeSeqAdd()
    echo("before-echo")
    probeEcho()
    echo("cleanup-probe-ok")
    return 0
