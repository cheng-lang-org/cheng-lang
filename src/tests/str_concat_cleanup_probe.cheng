import std/strings
import std/strutils as strutil

type
    Box =
        title: str
        count: int32

fn probeIntToStrOnly() =
    let count: int32 = 7
    let text: str = IntToStr(count)
    assert(text == "7", "cleanup intToStr")

fn probeSingleConcatOnly() =
    let name: str = "alpha"
    let text: str = strutil.Join(["box=", name], "")
    text

fn probeSingleConcatAssert() =
    let name: str = "alpha"
    let text: str = strutil.Join(["box=", name], "")
    assert(text == "box=alpha", "cleanup single concat")

fn probeSummary() =
    let name: str = "alpha"
    let count: int32 = 7
    let summary: str = strutil.Join(["box=", name, " count=", IntToStr(count), " rc=", IntToStr(count)], "")
    assert(summary == "box=alpha count=7 rc=7", "cleanup summary")

fn probeWrapped() =
    let name: str = "alpha"
    let wrapped: str = strutil.Join(["{", name, "}"], "")
    assert(wrapped == "{alpha}", "cleanup wrapped")

fn probeMember() =
    let box = Box(title: "beta", count: 9)
    let memberText: str = strutil.Join([box.title, ":", IntToStr(box.count)], "")
    assert(memberText == "beta:9", "cleanup member")

fn probeTernary() =
    let box = Box(title: "beta", count: 9)
    let fallback: str = "none"
    let condText: str = strutil.Join(["selected=", (true ? box.title : fallback)], "")
    assert(condText == "selected=beta", "cleanup ternary")

fn probeIfExpr() =
    let box = Box(title: "beta", count: 9)
    let fallback: str = "none"
    let ifExprText: str = strutil.Join(["picked=", (if true: box.title else: fallback)], "")
    assert(ifExprText == "picked=beta", "cleanup ifexpr")

fn probeSeqAdd() =
    let name: str = "alpha"
    let count: int32 = 7
    var parts: str[]
    add(parts, strutil.Join(["[", IntToStr(count), "] ", name], ""))
    assert(parts.len == 1, "cleanup seq len")
    assert(parts[0] == "[7] alpha", "cleanup seq value")

fn probeEcho() =
    let name: str = "alpha"
    echo(strutil.Join(["probe_echo=", name], ""))

fn main(): int32 =
    echo("before-intToStr")
    probeIntToStrOnly()
    echo("before-single-concat-only")
    probeSingleConcatOnly()
    echo("before-single-concat-assert")
    probeSingleConcatAssert()
    echo("before-summary")
    probeSummary()
    echo("before-wrapped")
    probeWrapped()
    echo("before-member")
    probeMember()
    echo("before-ternary")
    probeTernary()
    echo("before-ifexpr")
    probeIfExpr()
    echo("before-seqadd")
    probeSeqAdd()
    echo("before-echo")
    probeEcho()
    echo("cleanup-probe-ok")
    return 0
