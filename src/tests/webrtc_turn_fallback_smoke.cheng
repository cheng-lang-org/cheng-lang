import std/system
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/protocols/webrtc_signal as signal

fn main(): int32 =
    var addr: types.Libp2pMultiaddr
    addr.host = "203.0.113.92"
    addr.port = 9555
    addr.transport = types.Libp2pTransportWebrtc
    addr.networkDomain = types.Libp2pNetworkDomainBrowserWebrtc
    addr.visibility = types.Libp2pVisibilityPublic

    var cfg: webrtc_transport.Libp2pWebrtcTransportConfig
    cfg.relayOnly = true
    cfg.stunUrls = ["stun:relay-only.example.net"]
    let turnInsert: signal.Libp2pWebrtcTurnServer
    add(cfg.turnServers, turnInsert)
    cfg.turnServers[0].url = "turn:relay-only.example.net"
    cfg.turnServers[0].username = "relay-user"
    cfg.turnServers[0].credential = "relay-secret"

    var pair: webrtc_transport.Libp2pWebrtcLoopbackPair
    let openRes = webrtc_transport.Libp2pWebrtcLoopbackOpenInto(pair, cfg, addr)
    assert(IsOk(openRes), " webrtc turn fallback: open")
    assert(pair.signalSession.ready, " webrtc turn fallback: ready")
    assert(pair.signalSession.relayOnly, " webrtc turn fallback: relay only")
    assert(pair.signalSession.turnServers.len == 1, " webrtc turn fallback: turn server")
    assert(pair.signalSession.candidateTexts.len == 2, " webrtc turn fallback: candidates")
    assert(pair.signalSession.candidateTexts[0] == "candidate:1 1 udp 2130706431 203.0.113.92 9555 typ relay generation 0 ufrag client",
        " webrtc turn fallback: client relay candidate")
    assert(pair.signalSession.candidateTexts[1] == "candidate:1 1 udp 2130706431 203.0.113.92 9555 typ relay generation 0 ufrag server",
        " webrtc turn fallback: server relay candidate")

    var signalPayloads: Bytes[]
    webrtc_transport.Libp2pWebrtcLoopbackSignalPayloadsFill(signalPayloads, pair)
    assert(signalPayloads.len == 5, " webrtc turn fallback: signal payload count")
    let policyRes = signal.Libp2pWebrtcSignalDecode(signalPayloads[0])
    assert(IsOk(policyRes), " webrtc turn fallback: decode policy")
    let policy = Value(policyRes)
    assert(policy.turnServers[0].url == cfg.turnServers[0].url,
        " webrtc turn fallback: turn url over wire")
    assert(policy.turnServers[0].username == cfg.turnServers[0].username,
        " webrtc turn fallback: turn username over wire")
    assert(policy.turnServers[0].credential == cfg.turnServers[0].credential,
        " webrtc turn fallback: turn credential over wire")

    webrtc_transport.Libp2pWebrtcTransportResetStats()
    let signalWire = webrtc_transport.Libp2pWebrtcLoopbackSignalTranscriptPayload(pair)
    var clientResponse: Bytes
    let nativeRes = webrtc_transport.Libp2pWebrtcNativeRequestResponse(types.Libp2pProtocolContent,
                                                                         signalWire,
                                                                         bytesFromString("turn-request"),
                                                                         bytesFromString("turn-response"),
                                                                         clientResponse)
    assert(IsOk(nativeRes), " webrtc turn fallback: native bridge")
    assert(webrtc_transport.Libp2pWebrtcLastRelayOnlyNow(),
        " webrtc turn fallback: relay policy recorded")
    assert(bytesEqual(clientResponse, bytesFromString("turn-response")),
        " webrtc turn fallback: native response")

    echo(" webrtc_turn_fallback_smoke ok")
    return 0
