type ObjType =
    id: int32

type Diag =
    code: int32

type Result[T, E] = Ok(value: T) | Err(error: E)

type Box = Wrapped(value: Result[ObjType, Diag]) | Empty

fn MakeObj(): ObjType =
    return ObjType(id: 17)

fn MakeResult(flag: int32): Result[ObjType, Diag] =
    if flag == 1:
        return Ok(MakeObj())
    return Err(Diag(code: 9))

fn main(): int32 =
    let box = Wrapped(MakeResult(1))
    match box:
        Wrapped(value) =>
            match value:
                Ok(obj) =>
                    return obj.id + 25
                Err(error) =>
                    return error.code
        Empty =>
            return 1
