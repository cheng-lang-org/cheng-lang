import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath
import cheng/r2c/r2c_react_smoke_support as r2csmoke

fn r2cRenderCompareMatrixWriteRoute(root: str,
                                    routeDir: str,
                                    routeState: str,
                                    semanticCount: str,
                                    documentCount: str,
                                    layoutCount: str,
                                    renderCount: str,
                                    interactiveCount: str,
                                    nativePngPath: str,
                                    truthPngPath: str): bool =
    assert(chengpath.MkdirP(root, routeDir), " r2c render compare matrix smoke: route mkdir")
    let nativeSummaryPath = os.JoinPath(routeDir, "native_gui_run.summary.env")
    let truthSummaryPath = os.JoinPath(routeDir, "truth.summary.env")
    let truthTracePath = os.JoinPath(routeDir, "truth_trace_v2.json")
    let truthRuntimeStatePath = os.JoinPath(routeDir, "truth_runtime_state_v1.json")
    let truthDomPath = os.JoinPath(routeDir, "truth_dom_v1.json")
    let truthSemanticNodesPath = os.JoinPath(routeDir, "truth_semantic_nodes_v1.json")
    let truthRuntimeMetaPath = os.JoinPath(routeDir, "truth_runtime_meta_v1.json")

    assert(chengpath.WriteTextFile("", truthTracePath,
                                  "{\n" +
                                  "  \"format\": \"truth_trace_v2\",\n" +
                                  "  \"snapshots\": [\n" +
                                  "    {\n" +
                                  "      \"stateId\": \"" + routeState + "\",\n" +
                                  "      \"route\": {\n" +
                                  "        \"routeId\": \"" + routeState + "\"\n" +
                                  "      },\n" +
                                  "      \"semanticNodesCount\": " + semanticCount + ",\n" +
                                  "      \"renderReady\": true\n" +
                                  "    }\n" +
                                  "  ]\n" +
                                  "}\n"),
           " r2c render compare matrix smoke: write truth trace")
    assert(chengpath.WriteTextFile("", truthRuntimeStatePath,
                                  "{\n" +
                                  "  \"format\": \"truth_runtime_state_v1\",\n" +
                                  "  \"route_state\": \"" + routeState + "\"\n" +
                                  "}\n"),
           " r2c render compare matrix smoke: write truth runtime state")
    assert(chengpath.WriteTextFile("", truthDomPath,
                                  "{\n" +
                                  "  \"format\": \"truth_dom_v1\",\n" +
                                  "  \"route_state\": \"" + routeState + "\"\n" +
                                  "}\n"),
           " r2c render compare matrix smoke: write truth dom")
    assert(chengpath.WriteTextFile("", truthSemanticNodesPath,
                                  "{\n" +
                                  "  \"format\": \"truth_semantic_nodes_v1\",\n" +
                                  "  \"count\": " + semanticCount + "\n" +
                                  "}\n"),
           " r2c render compare matrix smoke: write truth semantic nodes")
    assert(chengpath.WriteTextFile("", truthRuntimeMetaPath,
                                  "{\n" +
                                  "  \"format\": \"truth_runtime_meta_v1\",\n" +
                                  "  \"browser_width\": 1,\n" +
                                  "  \"browser_height\": 1\n" +
                                  "}\n"),
           " r2c render compare matrix smoke: write truth runtime meta")

    var nativeSummaryText = ""
    nativeSummaryText = nativeSummaryText + "native_gui_route_state=" + routeState + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_screenshot_path=" + nativePngPath + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_window_width=1\n"
    nativeSummaryText = nativeSummaryText + "native_gui_window_height=1\n"
    nativeSummaryText = nativeSummaryText + "native_gui_layout_item_count=" + layoutCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_manifest_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_contract_payload_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_payload_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_contract_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_route_state=" + routeState + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_route_count=2\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_supported_count=6\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_semantic_nodes_count=" + semanticCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_layout_item_count=" + layoutCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_render_command_count=" + renderCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_contract_layout_item_count=" + layoutCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_contract_viewport_item_count=1\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_contract_interactive_item_count=" + interactiveCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_native_layout_plan_item_count=" + layoutCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_render_plan_command_count=" + renderCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_storage_host_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_fetch_host_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_custom_event_host_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_resize_observer_host_ready=true\n"
    assert(chengpath.WriteTextFile("", nativeSummaryPath, nativeSummaryText),
           " r2c render compare matrix smoke: write native summary")
    var truthSummaryText = ""
    truthSummaryText = truthSummaryText + "truth_trace_path=" + truthTracePath + "\n"
    truthSummaryText = truthSummaryText + "truth_trace_format=truth_trace_v2\n"
    truthSummaryText = truthSummaryText + "runtime_state_path=" + truthRuntimeStatePath + "\n"
    truthSummaryText = truthSummaryText + "dom_path=" + truthDomPath + "\n"
    truthSummaryText = truthSummaryText + "semantic_nodes_path=" + truthSemanticNodesPath + "\n"
    truthSummaryText = truthSummaryText + "runtime_meta_path=" + truthRuntimeMetaPath + "\n"
    truthSummaryText = truthSummaryText + "screenshot_path=" + truthPngPath + "\n"
    truthSummaryText = truthSummaryText + "semantic_nodes_count=" + semanticCount + "\n"
    truthSummaryText = truthSummaryText + "document_nodes_count=" + documentCount + "\n"
    truthSummaryText = truthSummaryText + "dom_hash=truth_dom_hash_" + routeState + "\n"
    truthSummaryText = truthSummaryText + "screenshot_sha256=truth_screenshot_sha256_" + routeState + "\n"
    truthSummaryText = truthSummaryText + "pathname=/" + routeState + "\n"
    truthSummaryText = truthSummaryText + "search=?route=" + routeState + "\n"
    truthSummaryText = truthSummaryText + "hash=#top\n"
    assert(chengpath.WriteTextFile("", truthSummaryPath, truthSummaryText),
           " r2c render compare matrix smoke: write truth summary")
    return true

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = chengpath.PathAbsolute(root, "artifacts/r2c_render_compare_matrix_controller_smoke")
    assert(chengpath.MkdirP(root, outDir), " r2c render compare matrix smoke: mkdir")
    let driver = chengpath.PathAbsolute(root, "artifacts/backend_driver/cheng")
    let packageRoot = root
    let controllerSource = chengpath.PathAbsolute(root, "src/r2c/r2c_react.cheng")
    assert(chengpath.FileExistsNonEmpty(root, driver), " r2c render compare matrix smoke: backend_driver exists")
    assert(chengpath.FileExistsNonEmpty(root, controllerSource), " r2c render compare matrix smoke: controller source exists")

    let repoEnv = os.GetEnv("R2C_REACT_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.DirExists(repo), " r2c render compare matrix smoke: React.js repo exists")

    let controllerEnv = os.GetEnv("R2C_REACT_CONTROLLER_EXE")
    let allowControllerCompile = os.GetEnv("R2C_REACT_ALLOW_CONTROLLER_COMPILE") == "1"
    var controllerExe = ""
    if len(controllerEnv) > 0:
        controllerExe = chengpath.PathAbsolute(root, controllerEnv)
    elif allowControllerCompile:
        controllerExe = os.JoinPath(outDir, "r2c_react_render_compare_matrix_controller_smoke")
    else:
        assert(false,
               " r2c render compare matrix smoke: set R2C_REACT_CONTROLLER_EXE or R2C_REACT_ALLOW_CONTROLLER_COMPILE=1")
    if allowControllerCompile && len(controllerEnv) <= 0:
        let controllerCompileReport = controllerExe + ".report.txt"
        let controllerCompileLog = controllerExe + ".compile.log"
        if chengpath.PathFileExists(controllerExe):
            os.RemoveFile(controllerExe)
        if chengpath.PathFileExists(controllerExe + ".map"):
            os.RemoveFile(controllerExe + ".map")
        if chengpath.PathFileExists(controllerCompileReport):
            os.RemoveFile(controllerCompileReport)
        if chengpath.PathFileExists(controllerCompileLog):
            os.RemoveFile(controllerCompileLog)
        let controllerCompileRun = hostops.RunFileLogged(root,
                                                           "r2c_render_compare_matrix_controller_compile",
                                                           driver,
                                                           [
                                                               "system-link-exec",
                                                               "--root:" + packageRoot,
                                                               "--in:" + controllerSource,
                                                               "--emit:exe",
                                                               "--target:arm64-apple-darwin",
                                                               "--out:" + controllerExe,
                                                               "--report-out:" + controllerCompileReport
                                                           ],
                                                           r2csmoke.R2cReactSmokeControllerCompileEnv(),
                                                           root,
                                                           420,
                                                           controllerCompileLog)
        assert(hostops.LoggedRunOk(controllerCompileRun), " r2c render compare matrix smoke: controller compile rc")
        assert(chengpath.FileExistsNonEmpty(root, controllerCompileReport), " r2c render compare matrix smoke: controller compile report")
    assert(chengpath.FileExistsNonEmpty(root, controllerExe), " r2c render compare matrix smoke: controller exe")

    let inputDir = os.JoinPath(outDir, "matrix_input")
    let homeDir = os.JoinPath(inputDir, "home")
    let publishDir = os.JoinPath(inputDir, "publish")
    assert(chengpath.MkdirP(root, inputDir), " r2c render compare matrix smoke: input mkdir")
    assert(chengpath.MkdirP(root, homeDir), " r2c render compare matrix smoke: home mkdir")
    assert(chengpath.MkdirP(root, publishDir), " r2c render compare matrix smoke: publish mkdir")

    let homeNativePngPath = os.JoinPath(homeDir, "native_gui_session.png")
    let homeTruthPngPath = os.JoinPath(homeDir, "truth_session.png")
    let publishNativePngPath = os.JoinPath(publishDir, "native_gui_session.png")
    let publishTruthPngPath = os.JoinPath(publishDir, "truth_session.png")
    r2csmoke.R2cReactSmokeWriteTinyPng(homeNativePngPath)
    r2csmoke.R2cReactSmokeWriteTinyPng(homeTruthPngPath)
    r2csmoke.R2cReactSmokeWriteTinyPng(publishNativePngPath)
    r2csmoke.R2cReactSmokeWriteTinyPng(publishTruthPngPath)

    assert(r2cRenderCompareMatrixWriteRoute(root, homeDir, "home_default", "83", "21", "31", "44", "7", homeNativePngPath, homeTruthPngPath),
           " r2c render compare matrix smoke: write home route")
    assert(r2cRenderCompareMatrixWriteRoute(root, publishDir, "publish_selector", "67", "19", "24", "35", "5", publishNativePngPath, publishTruthPngPath),
           " r2c render compare matrix smoke: write publish route")

    let matrixPath = os.JoinPath(inputDir, "render_compare_matrix_entries_v1.json")
    assert(chengpath.WriteTextFile("", matrixPath,
                                  "{\n" +
                                  "  \"format\": \"render_compare_matrix_input_v1\",\n" +
                                  "  \"entries\": [\n" +
                                  "    {\n" +
                                  "      \"route\": \"home_default\",\n" +
                                  "      \"native_summary\": \"home/native_gui_run.summary.env\",\n" +
                                  "      \"truth_summary\": \"home/truth.summary.env\",\n" +
                                  "      \"native_screenshot\": \"home/native_gui_session.png\",\n" +
                                  "      \"truth_screenshot\": \"home/truth_session.png\"\n" +
                                  "    },\n" +
                                  "    {\n" +
                                  "      \"route\": \"publish_selector\",\n" +
                                  "      \"native_summary\": \"publish/native_gui_run.summary.env\",\n" +
                                  "      \"truth_summary\": \"publish/truth.summary.env\",\n" +
                                  "      \"native_screenshot\": \"publish/native_gui_session.png\",\n" +
                                  "      \"truth_screenshot\": \"publish/truth_session.png\"\n" +
                                  "    }\n" +
                                  "  ]\n" +
                                  "}\n"),
           " r2c render compare matrix smoke: write matrix")

    let matrixOutDir = os.JoinPath(outDir, "matrix_out")
    let matrixReportPath = os.JoinPath(matrixOutDir, "render_compare_matrix_report_v1.json")
    let matrixJsonPath = os.JoinPath(matrixOutDir, "render_compare_matrix_v1.json")
    let matrixSummaryPath = os.JoinPath(matrixOutDir, "render_compare_matrix.summary.env")
    let controllerLog = os.JoinPath(outDir, "render_compare_matrix_controller.log")
    if chengpath.PathFileExists(controllerLog):
        os.RemoveFile(controllerLog)
    let controllerRun = hostops.RunFileLogged(root,
                                                "r2c_render_compare_matrix_controller_smoke",
                                                controllerExe,
                                                [
                                                    "render-compare-matrix",
                                                    "--repo", repo,
                                                    "--matrix", matrixPath,
                                                    "--out-dir", matrixOutDir
                                                ],
                                                [],
                                                root,
                                                120,
                                                controllerLog)
    assert(hostops.LoggedRunOk(controllerRun), " r2c render compare matrix smoke: controller rc")
    assert(chengpath.FileExistsNonEmpty(root, matrixReportPath), " r2c render compare matrix smoke: report")
    assert(chengpath.FileExistsNonEmpty(root, matrixJsonPath), " r2c render compare matrix smoke: matrix json")
    assert(chengpath.FileExistsNonEmpty(root, matrixSummaryPath), " r2c render compare matrix smoke: matrix summary")

    let reportText = chengpath.ReadTextFile("", matrixReportPath)
    let matrixText = chengpath.ReadTextFile("", matrixJsonPath)
    let summaryText = chengpath.ReadTextFile("", matrixSummaryPath)
    assert(chengpath.TextContains(reportText, "\"command\": \"render-compare-matrix\""),
           " r2c render compare matrix smoke: report command")
    assert(chengpath.TextContains(reportText, "\"render_compare_matrix_ok\": true"),
           " r2c render compare matrix smoke: report matrix ok")
    assert(chengpath.TextContains(reportText, "\"route_count\": 2"),
           " r2c render compare matrix smoke: report route count")
    assert(chengpath.TextContains(reportText, "\"ok_count\": 2"),
           " r2c render compare matrix smoke: report ok count")
    assert(chengpath.TextContains(matrixText, "\"format\": \"render_compare_matrix_v1\""),
           " r2c render compare matrix smoke: matrix format")
    assert(chengpath.TextContains(matrixText, "\"route_state\": \"home_default\""),
           " r2c render compare matrix smoke: matrix home route")
    assert(chengpath.TextContains(matrixText, "\"route_state\": \"publish_selector\""),
           " r2c render compare matrix smoke: matrix publish route")
    assert(chengpath.TextContains(matrixText, "\"diff_pixel_count\": 0"),
           " r2c render compare matrix smoke: matrix diff pixel count")
    assert(chengpath.TextContains(matrixText, "\"semantic_nodes_count_delta\": 0"),
           " r2c render compare matrix smoke: matrix semantic delta")
    assert(chengpath.TextContains(summaryText, "render_compare_matrix_ok=true"),
           " r2c render compare matrix smoke: summary ok")
    assert(chengpath.TextContains(summaryText, "route_count=2"),
           " r2c render compare matrix smoke: summary route count")
    assert(chengpath.TextContains(summaryText, "ok_count=2"),
           " r2c render compare matrix smoke: summary ok count")
    assert(chengpath.TextContains(summaryText, "pixel_mismatch_count=0"),
           " r2c render compare matrix smoke: summary pixel mismatch")
    assert(chengpath.TextContains(summaryText, "semantic_delta_count=0"),
           " r2c render compare matrix smoke: summary semantic delta")

    echo(" r2c_react_render_compare_matrix_controller_smoke ok")
    return 0
