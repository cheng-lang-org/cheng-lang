import std/os
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as v3path

fn r2cRenderCompareMatrixWriteRoute(root: str,
                                    routeDir: str,
                                    routeState: str,
                                    semanticCount: str,
                                    documentCount: str,
                                    layoutCount: str,
                                    renderCount: str,
                                    interactiveCount: str,
                                    nativePngPath: str,
                                    truthPngPath: str): bool =
    assert(v3path.V3MkdirP(root, routeDir), "v3 r2c render compare matrix smoke: route mkdir")
    let nativeSummaryPath = os.JoinPath(routeDir, "native_gui_run.summary.env")
    let truthSummaryPath = os.JoinPath(routeDir, "truth.summary.env")
    let truthTracePath = os.JoinPath(routeDir, "truth_trace_v2.json")
    let truthRuntimeStatePath = os.JoinPath(routeDir, "truth_runtime_state_v1.json")
    let truthDomPath = os.JoinPath(routeDir, "truth_dom_v1.json")
    let truthSemanticNodesPath = os.JoinPath(routeDir, "truth_semantic_nodes_v1.json")
    let truthRuntimeMetaPath = os.JoinPath(routeDir, "truth_runtime_meta_v1.json")

    assert(v3path.V3WriteTextFile("", truthTracePath,
                                  "{\n" +
                                  "  \"format\": \"truth_trace_v2\",\n" +
                                  "  \"snapshots\": [\n" +
                                  "    {\n" +
                                  "      \"stateId\": \"" + routeState + "\",\n" +
                                  "      \"route\": {\n" +
                                  "        \"routeId\": \"" + routeState + "\"\n" +
                                  "      },\n" +
                                  "      \"semanticNodesCount\": " + semanticCount + ",\n" +
                                  "      \"renderReady\": true\n" +
                                  "    }\n" +
                                  "  ]\n" +
                                  "}\n"),
           "v3 r2c render compare matrix smoke: write truth trace")
    assert(v3path.V3WriteTextFile("", truthRuntimeStatePath,
                                  "{\n" +
                                  "  \"format\": \"truth_runtime_state_v1\",\n" +
                                  "  \"route_state\": \"" + routeState + "\"\n" +
                                  "}\n"),
           "v3 r2c render compare matrix smoke: write truth runtime state")
    assert(v3path.V3WriteTextFile("", truthDomPath,
                                  "{\n" +
                                  "  \"format\": \"truth_dom_v1\",\n" +
                                  "  \"route_state\": \"" + routeState + "\"\n" +
                                  "}\n"),
           "v3 r2c render compare matrix smoke: write truth dom")
    assert(v3path.V3WriteTextFile("", truthSemanticNodesPath,
                                  "{\n" +
                                  "  \"format\": \"truth_semantic_nodes_v1\",\n" +
                                  "  \"count\": " + semanticCount + "\n" +
                                  "}\n"),
           "v3 r2c render compare matrix smoke: write truth semantic nodes")
    assert(v3path.V3WriteTextFile("", truthRuntimeMetaPath,
                                  "{\n" +
                                  "  \"format\": \"truth_runtime_meta_v1\",\n" +
                                  "  \"browser_width\": 1,\n" +
                                  "  \"browser_height\": 1\n" +
                                  "}\n"),
           "v3 r2c render compare matrix smoke: write truth runtime meta")

    var nativeSummaryText = ""
    nativeSummaryText = nativeSummaryText + "native_gui_route_state=" + routeState + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_screenshot_path=" + nativePngPath + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_window_width=1\n"
    nativeSummaryText = nativeSummaryText + "native_gui_window_height=1\n"
    nativeSummaryText = nativeSummaryText + "native_gui_layout_item_count=" + layoutCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_manifest_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_contract_payload_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_payload_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_contract_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_route_state=" + routeState + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_route_count=2\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_supported_count=6\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_semantic_nodes_count=" + semanticCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_layout_item_count=" + layoutCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_bundle_render_command_count=" + renderCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_contract_layout_item_count=" + layoutCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_contract_viewport_item_count=1\n"
    nativeSummaryText = nativeSummaryText + "native_gui_runtime_contract_interactive_item_count=" + interactiveCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_native_layout_plan_item_count=" + layoutCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_render_plan_command_count=" + renderCount + "\n"
    nativeSummaryText = nativeSummaryText + "native_gui_storage_host_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_fetch_host_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_custom_event_host_ready=true\n"
    nativeSummaryText = nativeSummaryText + "native_gui_resize_observer_host_ready=true\n"
    assert(v3path.V3WriteTextFile("", nativeSummaryPath, nativeSummaryText),
           "v3 r2c render compare matrix smoke: write native summary")
    var truthSummaryText = ""
    truthSummaryText = truthSummaryText + "truth_trace_path=" + truthTracePath + "\n"
    truthSummaryText = truthSummaryText + "truth_trace_format=truth_trace_v2\n"
    truthSummaryText = truthSummaryText + "runtime_state_path=" + truthRuntimeStatePath + "\n"
    truthSummaryText = truthSummaryText + "dom_path=" + truthDomPath + "\n"
    truthSummaryText = truthSummaryText + "semantic_nodes_path=" + truthSemanticNodesPath + "\n"
    truthSummaryText = truthSummaryText + "runtime_meta_path=" + truthRuntimeMetaPath + "\n"
    truthSummaryText = truthSummaryText + "screenshot_path=" + truthPngPath + "\n"
    truthSummaryText = truthSummaryText + "semantic_nodes_count=" + semanticCount + "\n"
    truthSummaryText = truthSummaryText + "document_nodes_count=" + documentCount + "\n"
    truthSummaryText = truthSummaryText + "dom_hash=truth_dom_hash_" + routeState + "\n"
    truthSummaryText = truthSummaryText + "screenshot_sha256=truth_screenshot_sha256_" + routeState + "\n"
    truthSummaryText = truthSummaryText + "pathname=/" + routeState + "\n"
    truthSummaryText = truthSummaryText + "search=?route=" + routeState + "\n"
    truthSummaryText = truthSummaryText + "hash=#top\n"
    assert(v3path.V3WriteTextFile("", truthSummaryPath, truthSummaryText),
           "v3 r2c render compare matrix smoke: write truth summary")
    return true

fn main(): int32 =
    var root: str = os.GetEnv("CHENG_ROOT")
    if len(root) <= 0:
        root = "/Users/lbcheng/cheng-lang"
    let outDir = v3path.V3PathAbsolute(root, "artifacts/r2c_render_compare_matrix_controller_smoke")
    assert(v3path.V3MkdirP(root, outDir), "v3 r2c render compare matrix smoke: mkdir")
    let driver = v3path.V3PathAbsolute(root, "artifacts/backend_driver/cheng")
    let packageRoot = v3path.V3PathAbsolute(root, "v3")
    let controllerSource = v3path.V3PathAbsolute(root, "src/r2c/r2c_react.cheng")
    assert(v3path.V3FileExistsNonEmpty(root, driver), "v3 r2c render compare matrix smoke: backend_driver exists")
    assert(v3path.V3FileExistsNonEmpty(root, controllerSource), "v3 r2c render compare matrix smoke: controller source exists")

    let repoEnv = os.GetEnv("R2C_REACT_V3_REPO")
    var repo = "/Users/lbcheng/UniMaker/React.js"
    if len(repoEnv) > 0:
        repo = repoEnv
    assert(os.DirExists(repo), "v3 r2c render compare matrix smoke: React.js repo exists")

    let controllerExe = os.JoinPath(outDir, "r2c_react_render_compare_matrix_controller_smoke")
    let controllerCompileReport = controllerExe + ".report.txt"
    let controllerCompileLog = controllerExe + ".compile.log"
    if v3path.V3PathFileExists(controllerExe):
        os.RemoveFile(controllerExe)
    if v3path.V3PathFileExists(controllerCompileReport):
        os.RemoveFile(controllerCompileReport)
    let controllerCompileRun = hostops.v3RunFileLogged(root,
                                                       "r2c_render_compare_matrix_controller_compile",
                                                       driver,
                                                       [
                                                           "system-link-exec",
                                                           "--root:" + packageRoot,
                                                           "--in:" + controllerSource,
                                                           "--emit:exe",
                                                           "--target:arm64-apple-darwin",
                                                           "--out:" + controllerExe,
                                                           "--report-out:" + controllerCompileReport
                                                       ],
                                                       ["CHENG_BACKEND_DRIVER_READY=1"],
                                                       root,
                                                       0,
                                                       controllerCompileLog)
    assert(hostops.v3LoggedRunOk(controllerCompileRun), "v3 r2c render compare matrix smoke: controller compile rc")
    assert(v3path.V3FileExistsNonEmpty(root, controllerExe), "v3 r2c render compare matrix smoke: controller exe")

    let inputDir = os.JoinPath(outDir, "matrix_input")
    let homeDir = os.JoinPath(inputDir, "home")
    let publishDir = os.JoinPath(inputDir, "publish")
    assert(v3path.V3MkdirP(root, inputDir), "v3 r2c render compare matrix smoke: input mkdir")
    assert(v3path.V3MkdirP(root, homeDir), "v3 r2c render compare matrix smoke: home mkdir")
    assert(v3path.V3MkdirP(root, publishDir), "v3 r2c render compare matrix smoke: publish mkdir")

    let homeNativePngPath = os.JoinPath(homeDir, "native_gui_session.png")
    let homeTruthPngPath = os.JoinPath(homeDir, "truth_session.png")
    let publishNativePngPath = os.JoinPath(publishDir, "native_gui_session.png")
    let publishTruthPngPath = os.JoinPath(publishDir, "truth_session.png")
    let pngBase64 = "iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO+aXfsAAAAASUVORK5CYII="
    let pngWriterScript = "const fs=require('node:fs');" +
                          "const png=Buffer.from(process.argv[1],'base64');" +
                          "for (let i=2;i<process.argv.length;i++) fs.writeFileSync(process.argv[i],png);"
    let pngWriterLog = os.JoinPath(outDir, "write_png.log")
    if v3path.V3PathFileExists(pngWriterLog):
        os.RemoveFile(pngWriterLog)
    let pngWriterRun = hostops.v3RunProgramLogged(root,
                                                  "r2c_render_compare_matrix_write_png",
                                                  "node",
                                                  ["-e", pngWriterScript, pngBase64, homeNativePngPath, homeTruthPngPath, publishNativePngPath, publishTruthPngPath],
                                                  [],
                                                  root,
                                                  0,
                                                  pngWriterLog)
    assert(hostops.v3LoggedRunOk(pngWriterRun), "v3 r2c render compare matrix smoke: write png rc")

    assert(r2cRenderCompareMatrixWriteRoute(root, homeDir, "home_default", "83", "21", "31", "44", "7", homeNativePngPath, homeTruthPngPath),
           "v3 r2c render compare matrix smoke: write home route")
    assert(r2cRenderCompareMatrixWriteRoute(root, publishDir, "publish_selector", "67", "19", "24", "35", "5", publishNativePngPath, publishTruthPngPath),
           "v3 r2c render compare matrix smoke: write publish route")

    let matrixPath = os.JoinPath(inputDir, "render_compare_matrix_entries_v1.json")
    assert(v3path.V3WriteTextFile("", matrixPath,
                                  "{\n" +
                                  "  \"format\": \"render_compare_matrix_input_v1\",\n" +
                                  "  \"entries\": [\n" +
                                  "    {\n" +
                                  "      \"route\": \"home_default\",\n" +
                                  "      \"native_summary\": \"home/native_gui_run.summary.env\",\n" +
                                  "      \"truth_summary\": \"home/truth.summary.env\",\n" +
                                  "      \"native_screenshot\": \"home/native_gui_session.png\",\n" +
                                  "      \"truth_screenshot\": \"home/truth_session.png\"\n" +
                                  "    },\n" +
                                  "    {\n" +
                                  "      \"route\": \"publish_selector\",\n" +
                                  "      \"native_summary\": \"publish/native_gui_run.summary.env\",\n" +
                                  "      \"truth_summary\": \"publish/truth.summary.env\",\n" +
                                  "      \"native_screenshot\": \"publish/native_gui_session.png\",\n" +
                                  "      \"truth_screenshot\": \"publish/truth_session.png\"\n" +
                                  "    }\n" +
                                  "  ]\n" +
                                  "}\n"),
           "v3 r2c render compare matrix smoke: write matrix")

    let matrixOutDir = os.JoinPath(outDir, "matrix_out")
    let matrixReportPath = os.JoinPath(matrixOutDir, "render_compare_matrix_report_v1.json")
    let matrixJsonPath = os.JoinPath(matrixOutDir, "render_compare_matrix_v1.json")
    let matrixSummaryPath = os.JoinPath(matrixOutDir, "render_compare_matrix.summary.env")
    let controllerLog = os.JoinPath(outDir, "render_compare_matrix_controller.log")
    if v3path.V3PathFileExists(controllerLog):
        os.RemoveFile(controllerLog)
    let controllerRun = hostops.v3RunFileLogged(root,
                                                "r2c_render_compare_matrix_controller_smoke",
                                                controllerExe,
                                                [
                                                    "render-compare-matrix",
                                                    "--repo", repo,
                                                    "--matrix", matrixPath,
                                                    "--out-dir", matrixOutDir
                                                ],
                                                [],
                                                root,
                                                0,
                                                controllerLog)
    assert(hostops.v3LoggedRunOk(controllerRun), "v3 r2c render compare matrix smoke: controller rc")
    assert(v3path.V3FileExistsNonEmpty(root, matrixReportPath), "v3 r2c render compare matrix smoke: report")
    assert(v3path.V3FileExistsNonEmpty(root, matrixJsonPath), "v3 r2c render compare matrix smoke: matrix json")
    assert(v3path.V3FileExistsNonEmpty(root, matrixSummaryPath), "v3 r2c render compare matrix smoke: matrix summary")

    let reportText = v3path.V3ReadTextFile("", matrixReportPath)
    let matrixText = v3path.V3ReadTextFile("", matrixJsonPath)
    let summaryText = v3path.V3ReadTextFile("", matrixSummaryPath)
    assert(v3path.V3TextContains(reportText, "\"command\": \"render-compare-matrix\""),
           "v3 r2c render compare matrix smoke: report command")
    assert(v3path.V3TextContains(reportText, "\"render_compare_matrix_ok\": true"),
           "v3 r2c render compare matrix smoke: report matrix ok")
    assert(v3path.V3TextContains(reportText, "\"route_count\": 2"),
           "v3 r2c render compare matrix smoke: report route count")
    assert(v3path.V3TextContains(reportText, "\"ok_count\": 2"),
           "v3 r2c render compare matrix smoke: report ok count")
    assert(v3path.V3TextContains(matrixText, "\"format\": \"render_compare_matrix_v1\""),
           "v3 r2c render compare matrix smoke: matrix format")
    assert(v3path.V3TextContains(matrixText, "\"route_state\": \"home_default\""),
           "v3 r2c render compare matrix smoke: matrix home route")
    assert(v3path.V3TextContains(matrixText, "\"route_state\": \"publish_selector\""),
           "v3 r2c render compare matrix smoke: matrix publish route")
    assert(v3path.V3TextContains(matrixText, "\"diff_pixel_count\": 0"),
           "v3 r2c render compare matrix smoke: matrix diff pixel count")
    assert(v3path.V3TextContains(matrixText, "\"semantic_nodes_count_delta\": 0"),
           "v3 r2c render compare matrix smoke: matrix semantic delta")
    assert(v3path.V3TextContains(summaryText, "render_compare_matrix_ok=true"),
           "v3 r2c render compare matrix smoke: summary ok")
    assert(v3path.V3TextContains(summaryText, "route_count=2"),
           "v3 r2c render compare matrix smoke: summary route count")
    assert(v3path.V3TextContains(summaryText, "ok_count=2"),
           "v3 r2c render compare matrix smoke: summary ok count")
    assert(v3path.V3TextContains(summaryText, "pixel_mismatch_count=0"),
           "v3 r2c render compare matrix smoke: summary pixel mismatch")
    assert(v3path.V3TextContains(summaryText, "semantic_delta_count=0"),
           "v3 r2c render compare matrix smoke: summary semantic delta")

    echo("v3 r2c_react_render_compare_matrix_controller_smoke ok")
    return 0
