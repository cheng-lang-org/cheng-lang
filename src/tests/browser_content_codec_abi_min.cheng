import cheng/libp2p/browser/browser_content_codec_abi as codecabi

fn browserInputCopy(handle: int32): int32 =
    let bytesRes = codecabi.browserInputBytesRequired(handle,
                                                      "browser_input_missing_bytes",
                                                      "browser_input_copy_bytes_failed")
    if IsErr(bytesRes):
        return 0
    let handleRes = codecabi.browserBufferHandleFromBytesRequired(Value(bytesRes),
                                                                  "browser_output_bytes_handle_failed")
    if IsErr(handleRes):
        return 0
    return Value(handleRes)

fn browserInputTextCopy(handle: int32): int32 =
    let textRes = codecabi.browserInputTextRequired(handle,
                                                    "browser_input_missing_text",
                                                    "browser_input_copy_text_failed")
    if IsErr(textRes):
        return 0
    let handleRes = codecabi.browserBufferHandleFromTextRequired(Value(textRes),
                                                                 "browser_output_text_handle_failed")
    if IsErr(handleRes):
        return 0
    return Value(handleRes)

fn browserBufferHandleLen(handle: int32): int32 =
    return codecabi.browserBufferHandleLen(handle)
