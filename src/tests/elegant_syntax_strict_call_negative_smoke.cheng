import std/cmdline as cmdline
import std/os as os
import std/os_host_process as hostos
import std/strings as strings
import std/strutils as strutil

fn ensureDir(path: str) =
    if !os.DirExists(path):
        os.CreateDir(path)

fn currentExecutablePath(root: str): str =
    let raw = cmdline.ProgramName()
    if len(raw) <= 0:
        return ""
    if os.IsAbsolute(raw):
        return raw
    return os.JoinPath(root, raw)

fn compileNegativeFixture(compiler: str,
                          root: str,
                          inputPath: str,
                          outputPath: str,
                          logPath: str): os.ExecCmdResult =
    let target = os.GetEnvDefault("CHENG_BOOTSTRAP_TARGET", "arm64-apple-darwin")
    var compileArgv: str[]
    add(compileArgv, "system-link-exec")
    add(compileArgv, "--root")
    add(compileArgv, root)
    add(compileArgv, "--in")
    add(compileArgv, inputPath)
    add(compileArgv, "--emit")
    add(compileArgv, "exe")
    add(compileArgv, "--target")
    add(compileArgv, target)
    add(compileArgv, "--out")
    add(compileArgv, outputPath)

    var compileEnv: str[]
    add(compileEnv, "CHENG_STRICT_CALL_SYNTAX=1")
    add(compileEnv, strutil.Join(["CHENG_ROOT=", root], ""))
    let noHandoff = os.GetEnv("CHENG_NO_BACKEND_DRIVER_HANDOFF")
    if len(noHandoff) > 0 && noHandoff != "0":
        add(compileEnv, strutil.Join(["CHENG_NO_BACKEND_DRIVER_HANDOFF=", noHandoff], ""))

    let compileRes = hostos.ExecFileCapture(compiler, compileArgv, compileEnv, root, true, 60)
    os.WriteFile(logPath, os.ExecCmdResultOutput(compileRes))
    return compileRes

fn main(): int32 =
    let root = os.GetCurrentDir()
    let exePath = currentExecutablePath(root)
    assert(len(exePath) > 0 && os.FileExists(exePath),
           " elegant strict call negative: executable path")
    let exeParts = os.SplitFile(exePath)
    let outDir = os.JoinPath(exeParts.dir, strutil.Join([exeParts.name, ".workspace"], ""))
    ensureDir(outDir)
    assert(os.DirExists(outDir), " elegant strict call negative: mkdir")

    let compilerEnv = os.GetEnv("CHENG_SMOKE_COMPILER")
    var compilerRaw = "artifacts/backend_driver/cheng"
    if len(compilerEnv) > 0:
        compilerRaw = compilerEnv
    var compiler = compilerRaw
    if !os.IsAbsolute(compilerRaw):
        compiler = os.JoinPath(root, compilerRaw)
    assert(os.FileExists(compiler),
           " elegant strict call negative: compiler exists")

    let fixtureName = "elegant_syntax_strict_call_negative_space_call.cheng"
    let logPath = os.JoinPath(outDir, strutil.Join([fixtureName, ".compile.log"], ""))
    let inputPath = os.JoinPath(root, strutil.Join(["src/tests/", fixtureName], ""))
    let outputPath = os.JoinPath(outDir, "space_call")
    let res = compileNegativeFixture(compiler, root, inputPath, outputPath, logPath)
    let output = os.ExecCmdResultOutput(res)
    assert(os.ExecCmdResultExitCode(res) != 0,
           " elegant strict call negative: expected space call rejection")
    assert(strings.StrContains(output, "Space call syntax is removed in the elegant syntax profile; use f(x)"),
           strutil.Join([" elegant strict call negative: diagnostic\n", output], ""))

    echo(" elegant_syntax_strict_call_negative_smoke ok")
    return 0
