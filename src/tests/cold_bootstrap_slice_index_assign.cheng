type Bucket =
    fixed: int32[3]
    items: int32[]

fn Touch(bucket: var Bucket): int32 =
    bucket.fixed[1] = 9
    add(bucket.items, 2)
    add(bucket.items, 4)
    bucket.items[0] = bucket.fixed[1] + 1
    return bucket.fixed[1] + bucket.items[0] + bucket.items[1]

fn main(): int32 =
    var fixed: int32[3] = [1, 2, 3]
    fixed[0] = 5
    var xs: int32[] = [7, 8]
    xs[1] = fixed[0] + 6
    var bucket: Bucket
    bucket.fixed = [3, 3, 3]
    let score = Touch(bucket)
    if fixed[0] != 5:
        return 1
    if xs[1] != 11:
        return 2
    if bucket.fixed[1] != 9:
        return 3
    if bucket.items[0] != 10:
        return 4
    if bucket.items[1] != 4:
        return 5
    if score != 23:
        return score
    return 42
