type IntResult = OkInt(value: int32) | ErrStr(error: str)

fn Touch(x: int32): int32 =
    return x

fn Count(seed: int32): IntResult =
    var x = seed
    Touch(x)
    for i in 1..3:
        if i == 2:
            x = x + i
        elif i == 3:
            x = x + Touch(i)
        else:
            x = x + 1
    if x > 10:
        return OkInt(x)
    return ErrStr("too small")

fn main(): int32 =
    let r = Count(5)
    match r:
        OkInt(value) =>
            return value
        ErrStr(e) =>
            return len(e)
