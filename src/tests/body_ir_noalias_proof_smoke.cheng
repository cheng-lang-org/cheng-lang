import cheng/core/ir/core_types as ir
import cheng/core/ir/body_ir_noalias as noalias

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn addI32Slot(bodyIR: var ir.BodyIR,
              name: str,
              applyProof: bool): int32 =
    var slot: ir.LocalSlot
    slot.id = bodyIR.localSlots.len
    slot.name = name
    slot.typeKind = ir.LocalI32Tag
    slot.stackOffset = 16 + slot.id * 8
    slot.sizeBytes = 4
    slot.alignBytes = 4
    if applyProof:
        ir.BodyIRApplyLocalSlotDefaultProof(slot)
    add(bodyIR.localSlots, slot)
    return slot.id

fn appendLoad(bodyIR: var ir.BodyIR,
              target: int32,
              source: int32) =
    var op: ir.BodyOp
    op.kind = ir.BodyOpLoadLocalTag
    op.target = target
    add(op.operands, source)
    add(bodyIR.ops, op)

fn appendCopy(bodyIR: var ir.BodyIR,
              target: int32,
              source: int32) =
    var op: ir.BodyOp
    op.kind = ir.BodyOpCopyLocalTag
    op.target = target
    add(op.operands, source)
    add(bodyIR.ops, op)

fn buildForwardCandidate(applyProof: bool): ir.BodyIR =
    var bodyIR = ir.BodyIRNew()
    let a = addI32Slot(bodyIR, "a", applyProof)
    let b = addI32Slot(bodyIR, "b", applyProof)
    let c = addI32Slot(bodyIR, "c", applyProof)
    let d = addI32Slot(bodyIR, "d", applyProof)

    appendLoad(bodyIR, b, a)
    appendCopy(bodyIR, c, b)
    appendLoad(bodyIR, d, c)

    var term: ir.BodyTerm
    term.kind = ir.BodyTermReturnTag
    term.resultSlot = d
    let termIndex = ir.BodyIRAppendTerm(bodyIR, term)
    let _ = ir.BodyIRAppendBlock(bodyIR, 0, 3, termIndex)
    return bodyIR

fn main(): int32 =
    let unprovedBody = buildForwardCandidate(false)
    let unprovedReport = noalias.BodyIrNoAliasFinalize(unprovedBody)
    let c1 = check(unprovedReport.applied, 11)
    if c1 != 0: return c1
    let c2 = check(unprovedReport.localCount == 0, 12)
    if c2 != 0: return c2
    let c3 = check(unprovedReport.forwardRewriteCount == 0, 13)
    if c3 != 0: return c3
    let c4 = check(unprovedReport.bodyIR.ops[1].operands[0] == 1, 14)
    if c4 != 0: return c4
    let c5 = check(unprovedReport.bodyIR.ops[2].operands[0] == 2, 15)
    if c5 != 0: return c5
    let c6 = check(unprovedReport.bodyIR.terms[0].resultSlot == 3, 16)
    if c6 != 0: return c6

    let provedBody = buildForwardCandidate(true)
    let provedReport = noalias.BodyIrNoAliasFinalize(provedBody)
    let c7 = check(provedReport.applied, 21)
    if c7 != 0: return c7
    let c8 = check(provedReport.localCount == 2, 22)
    if c8 != 0: return c8
    let c9 = check(provedReport.forwardRewriteCount == 3, 23)
    if c9 != 0: return c9
    let c10 = check(provedReport.bodyIR.ops[1].operands[0] == 0, 24)
    if c10 != 0: return c10
    let c11 = check(provedReport.bodyIR.ops[2].operands[0] == 0, 25)
    if c11 != 0: return c11
    let c12 = check(provedReport.bodyIR.terms[0].resultSlot == 0, 26)
    if c12 != 0: return c12

    echo(" body_ir_noalias_proof_smoke ok")
    return 0
