import std/bytes as bytes
import std/result
import std/strings as strings
import cheng/apps/wow_export/build_info as build_info
import cheng/apps/wow_export/casc_archive as casc_archive
import cheng/apps/wow_export/config as config
import cheng/apps/wow_export/casc_index as casc_index

fn main(): int32 =
    let buildRes: Result[build_info.WowBuildEntry] = build_info.ProbeRetailDefault()
    assert(IsOk(buildRes), Error(buildRes))
    let build: build_info.WowBuildEntry = Value(buildRes)
    assert(build.product == "wow", "wow_export_casc_smoke product")
    assert(build.version == "12.0.5.67165", "wow_export_casc_smoke version")
    assert(build.buildKey == "02482dc9c788698c83e7ae0e24ab2bb7", "wow_export_casc_smoke build key")

    let cfgRes: Result[config.BuildConfig] = config.LoadBuildConfig(build_info.DefaultClientPath, build.buildKey)
    assert(IsOk(cfgRes), Error(cfgRes))
    let cfg: config.BuildConfig = Value(cfgRes)
    assert(strings.Len(cfg.root) == 32, "wow_export_casc_smoke root key length")
    assert(strings.Len(cfg.encodingEncodingKey) == 32, "wow_export_casc_smoke encoding key length")
    assert(cfg.buildName == "WOW-67165patch12.0.5_Retail", "wow_export_casc_smoke build name")

    let idxRes: Result[casc_index.CascIndexSummary] = casc_index.LoadFirstJournalIndexSummary(build_info.DefaultClientPath)
    assert(IsOk(idxRes), Error(idxRes))
    let idx: casc_index.CascIndexSummary = Value(idxRes)
    assert(idx.entryCount > 0, "wow_export_casc_smoke index entries")
    assert(strings.Len(idx.first.keyPrefix) == 18, "wow_export_casc_smoke key prefix")
    assert(idx.first.size > 0, "wow_export_casc_smoke first size")

    let encEntryRes: Result[casc_index.CascIndexEntry] =
        casc_index.LoadLocalIndexEntry(build_info.DefaultClientPath, cfg.encodingEncodingKey)
    assert(IsOk(encEntryRes), Error(encEntryRes))
    let encEntry: casc_index.CascIndexEntry = Value(encEntryRes)
    assert(encEntry.size > 0x1e, "wow_export_casc_smoke encoding local archive size")
    let firstBlockRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveReadLocalEntryFirstBlock(build_info.DefaultClientPath, encEntry)
    assert(IsOk(firstBlockRes), Error(firstBlockRes))
    var firstBlock: bytes.ByteBuffer = Value(firstBlockRes)
    assert(firstBlock.len > 0, "wow_export_casc_smoke archive block readable")
    bytes.FreeByteBuffer(firstBlock)
    echo("wow_export_casc_smoke ok")
    return 0
