import std/os
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/backend/system_link_plan as slplan
import cheng/core/lang/parser as parser
import std/strutils as strutil

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, strutil.Join(["artifacts/program_selfhost/", smokeLabel], ""))
    assert(chengpath.MkdirP(workspaceRoot, outDir), " compiler pipeline: mkdir")
    let sourcePath = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = chengpath.PathJoin(outDir, "program_selfhost_smoke")
    let packageId = parser.ParserPackageId(packageRoot)
    let contractsPath = parser.ParserModulePathToSourcePath(workspaceRoot, packageRoot, "cheng/core/tooling/bootstrap_contracts")
    let expectedContractsPath = chengpath.PathJoin(packageRoot, "src/core/tooling/bootstrap_contracts.cheng")
    assert(packageId == "cheng", " compiler pipeline: package id")
    assert(contractsPath == expectedContractsPath, " compiler pipeline: contracts path")
    assert(parser.ParserSourceExists(contractsPath), " compiler pipeline: contracts path exists")
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    var plan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(packageRoot, req, plan, err), " compiler pipeline: build plan")
    assert(plan.moduleStem == "program_selfhost_smoke", " compiler pipeline: module stem")
    assert(plan.workspaceRoot == workspaceRoot, " compiler pipeline: workspace root")
    assert(plan.packageRoot == packageRoot, " compiler pipeline: package root")
    assert(plan.linkMode == "system_link", " compiler pipeline: link mode")
    assert(plan.buildEntryPath == chengpath.PathJoin(workspaceRoot, "src/core/tooling/compiler_main.cheng"),
           " compiler pipeline: build entry")
    assert(plan.buildSourceUnitCount >= 11, " compiler pipeline: source count")
    assert(plan.sourceClosurePaths.len >= 2, " compiler pipeline: closure count")
    assert(plan.runtimeTargets.len == 1, " compiler pipeline: runtime target count")
    assert(plan.runtimeTargets[0] == "runtime/compiler.program_argv_entry",
           " compiler pipeline: program argv runtime target")
    assert(plan.providerModules.len == 5, " compiler pipeline: provider module count")
    assert(plan.providerModules[0] == "runtime/compiler_runtime",
           " compiler pipeline: compiler provider")
    assert(plan.providerModules[1] == "runtime/core_runtime",
           " compiler pipeline: core provider")
    assert(plan.providerModules[2] == "runtime/debug_runtime",
           " compiler pipeline: debug provider")
    assert(plan.providerModules[3] == "runtime/program_support",
           " compiler pipeline: program support provider")
    assert(plan.providerModules[4] == "runtime/program_support_host_runtime",
           " compiler pipeline: host support provider")
    assert(plan.entrySymbol == "main", " compiler pipeline: entry symbol")
    let report = slplan.SystemLinkPlanStubReport(plan)
    assert(plan.missingReasons.len == 0, " compiler pipeline: missing reasons")
    assert(chengpath.TextContains(report, "pipeline_stage=parser_to_system_link_plan"),
           " compiler pipeline: report stage")
    assert(chengpath.TextContains(report, "parser_syntax=cheng_normalized_source"),
           " compiler pipeline: report parser syntax")
    assert(chengpath.TextContains(report, "expr_surface_source_count="),
           " compiler pipeline: expr surface count")
    assert(chengpath.TextContains(report, "expr_surface_expr_count="),
           " compiler pipeline: expr node count")
    assert(chengpath.TextContains(report, "expr_surface_try_count="),
           " compiler pipeline: try count")
    assert(chengpath.TextContains(report, "expr_surface_question_residual_count=0"),
           " compiler pipeline: question normalized")
    assert(chengpath.TextContains(report, "runtime_targets=runtime/compiler.program_argv_entry"),
           " compiler pipeline: report runtime target")
    assert(chengpath.TextContains(report,
                            "provider_modules=runtime/compiler_runtime,runtime/core_runtime,runtime/debug_runtime,runtime/program_support,runtime/program_support_host_runtime"),
           " compiler pipeline: report providers")
    assert(chengpath.TextContains(report, "missing_reasons=-"),
           " compiler pipeline: report missing reasons cleared")
    echo(" compiler_pipeline_smoke ok")
    return 0
