import std/system
import cheng/apps/bft/bft_state_machine as bft

fn main(): int32 =
    var machine = bft.BftStateMachineInit("bft-apply-single")
    let mint = bft.BftTxMint(7, 1001, int64(100))
    let exec = bft.BftApplyTx(machine, mint, int64(1), 0)
    assert(exec.code == bft.BftCodeOk, " bft apply single: code")
    assert(exec.accepted, " bft apply single: accepted")
    assert(exec.applied, " bft apply single: applied")
    assert(machine.index.eventCids.len == 1, " bft apply single: event cid len")
    assert(machine.index.accountIds.len == 1, " bft apply single: account len")
    assert(machine.index.balances.len == 1, " bft apply single: balance len")
    assert(machine.index.balances[0] == int64(100), " bft apply single: balance value")
    echo(" bft_apply_single_smoke ok")
    return 0
