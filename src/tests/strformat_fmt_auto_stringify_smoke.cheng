import std/strings
import std/strformat as sf
import std/rawbytes
import std/strutils as strutil

type
    Box = object
        title: str
        count: int32

fn `$`(box: Box): str =
    return Fmt"{box.title}:{strings.IntToStr(box.count)}"

fn main(): int32 =
    let count: int32 = 7
    let flag: bool = true
    let mark: char = 'x'
    let small: int16 = int16(12)
    let wide: int64 = int64(34)
    let big: uint64 = uint64(56)
    let box = Box(title: "beta", count: 9)
    let flags: bool[] = [true, false]
    let nums: int32[] = [1, 2]
    var raw = bytesAlloc(2)
    bytesSet(raw, 0, int32('a'))
    bytesSet(raw, 1, int32('b'))

    let rendered: str = Fmt"count={count} flag={flag} mark={mark} small={small} wide={wide} big={big} box={box} raw={raw}"
    assert(rendered == "count=7 flag=true mark=x small=12 wide=34 big=56 box=beta:9 raw=6162",
           " strformat fmt auto stringify: literal placeholders")

    let directBox: str = $box
    let directRaw: str = $raw
    let parenBox: str = $(box)
    assert(directBox == "beta:9", " strformat fmt auto stringify: direct prefix box")
    assert(directRaw == "6162", " strformat fmt auto stringify: direct prefix raw")
    assert(parenBox == "beta:9", " strformat fmt auto stringify: paren prefix box")

    let aliasRendered: str = strutil.Join(["box=", $box, " raw=", $raw], "")
    assert(aliasRendered == "box=beta:9 raw=6162",
           " strformat fmt auto stringify: aliased fmt join")

    let seqRendered: str = Fmt"flags={flags} nums={nums}"
    assert(seqRendered == "flags=[true, false] nums=[1, 2]",
           " strformat fmt auto stringify: seq placeholders")

    BytesFree(raw)
    echo(" strformat_fmt_auto_stringify_smoke ok")
    return 0
