import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/protocols/webrtc_signal as signal
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/host/host

fn bytesHasPrefix(data: Bytes, prefix: Bytes): bool =
    if bytesLen(data) < bytesLen(prefix):
        return false
    for i in 0..<bytesLen(prefix):
        if bytesGet(data, i) != bytesGet(prefix, i):
            return false
    return true

fn main(): int32 =
    webrtc_transport.Libp2pWebrtcTransportResetStats()

    var server = host.Libp2pHostInit("browser.signal.server")
    var client = host.Libp2pHostInit("browser.signal.client")
    var listenAddr: types.Libp2pMultiaddr
    listenAddr.host = "203.0.113.141"
    listenAddr.port = 9451
    listenAddr.transport = types.Libp2pTransportWebrtc
    listenAddr.networkDomain = types.Libp2pNetworkDomainBrowserWebrtc
    listenAddr.visibility = types.Libp2pVisibilityPublic
    let listenRes = host.Libp2pListen(server, listenAddr)
    assert(listenRes.ok, " webrtc signal stream: listen")
    host.Libp2pRegisterHandler(server, types.Libp2pProtocolWebrtcSignal)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolWebrtcSignal)
    let dialRes = host.Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " webrtc signal stream: dial")

    let payload = bytesFromString("browser-webrtc-signal")
    var signalWire: Bytes
    var clientResponse: Bytes
    let browserRes = webrtc_transport.Libp2pWebrtcBrowserRequestResponse(types.Libp2pProtocolContent,
                                                                            webrtc_transport.Libp2pWebrtcTransportConfig(),
                                                                            listenAddr,
                                                                            payload,
                                                                            payload,
                                                                            signalWire,
                                                                            clientResponse)
    assert(IsOk(browserRes), " webrtc signal stream: browser bridge")
    let recordRes = host.Libp2pWebrtcRecordSignalWire(client,
                                                        server,
                                                        server.selfPeerId,
                                                        signalWire)
    assert(IsOk(recordRes), " webrtc signal stream: record signal")
    assert(bytesEqual(clientResponse, payload), " webrtc signal stream: payload")
    assert(host.Libp2pWebrtcSignalEgressCount(client) == 5, " webrtc signal stream: egress count")
    assert(host.Libp2pWebrtcSignalIngressCount(server) == 5, " webrtc signal stream: ingress count")
    assert(webrtc_transport.Libp2pWebrtcBrowserDatachannelOpenCountNow() == 1,
        " webrtc signal stream: browser open count")
    assert(webrtc_transport.Libp2pWebrtcBrowserDatachannelRequestCountNow() == 1,
        " webrtc signal stream: browser request count")
    assert(webrtc_transport.Libp2pWebrtcNativeDatachannelRequestCountNow() == 0,
        " webrtc signal stream: native request count")
    assert(webrtc_transport.Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        " webrtc signal stream: loopback count")

    var messages: signal.Libp2pWebrtcSignalMessage[]
    let decodeRes = signal.Libp2pWebrtcSignalTranscriptDecodeFill(messages, signalWire)
    assert(IsOk(decodeRes), " webrtc signal stream: transcript decode")
    assert(messages.len == 5, " webrtc signal stream: transcript count")
    assert(messages[0].kind == signal.Libp2pWebrtcSignalTurnPolicy,
        " webrtc signal stream: policy first")
    assert(messages[1].kind == signal.Libp2pWebrtcSignalOffer,
        " webrtc signal stream: offer second")
    assert(messages[2].kind == signal.Libp2pWebrtcSignalAnswer,
        " webrtc signal stream: answer third")
    assert(messages[3].kind == signal.Libp2pWebrtcSignalIceCandidate,
        " webrtc signal stream: candidate fourth")
    assert(messages[4].kind == signal.Libp2pWebrtcSignalIceCandidate,
        " webrtc signal stream: candidate fifth")
    assert(layout.FixedBytes32Equal(messages[0].sessionId, messages[4].sessionId),
        " webrtc signal stream: session ids match")
    assert(len(messages[1].sdp) > 32, " webrtc signal stream: offer sdp")
    assert(len(messages[2].sdp) > 32, " webrtc signal stream: answer sdp")
    assert(bytesHasPrefix(bytesFromString(messages[3].candidateText), bytesFromString("candidate:")),
        " webrtc signal stream: client candidate prefix")
    assert(bytesHasPrefix(bytesFromString(messages[4].candidateText), bytesFromString("candidate:")),
        " webrtc signal stream: server candidate prefix")

    echo(" webrtc_signal_stream_smoke ok")
    return 0
