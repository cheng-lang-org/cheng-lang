import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/protocols/webrtc_signal as signal
import cheng/libp2p/transports/webrtc_transport
import cheng/libp2p/host/host

fn bytesHasPrefix(data: Bytes, prefix: Bytes): bool =
    if bytesLen(data) < bytesLen(prefix):
        return false
    for i in 0..<bytesLen(prefix):
        if bytesGet(data, i) != bytesGet(prefix, i):
            return false
    return true

fn main(): int32 =
    webrtc_transport.v3Libp2pWebrtcTransportResetStats()

    var server = host.v3Libp2pHostInit("browser.signal.server")
    var client = host.v3Libp2pHostInit("browser.signal.client")
    var listenAddr: types.V3Libp2pMultiaddr
    listenAddr.host = "203.0.113.141"
    listenAddr.port = 9451
    listenAddr.transport = types.v3Libp2pTransportWebrtc
    listenAddr.networkDomain = types.v3Libp2pNetworkDomainBrowserWebrtc
    listenAddr.visibility = types.v3Libp2pVisibilityPublic
    let listenRes = host.v3Libp2pListen(server, listenAddr)
    assert(listenRes.ok, "v3 webrtc signal stream: listen")
    host.v3Libp2pRegisterHandler(server, types.v3Libp2pProtocolWebrtcSignal)
    host.v3Libp2pRegisterHandler(client, types.v3Libp2pProtocolWebrtcSignal)
    let dialRes = host.v3Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.v3OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, "v3 webrtc signal stream: dial")

    let payload = bytesFromString("browser-webrtc-signal")
    var signalWire: Bytes
    var clientResponse: Bytes
    let browserRes = webrtc_transport.v3Libp2pWebrtcBrowserRequestResponse(types.v3Libp2pProtocolContent,
                                                                            webrtc_transport.V3Libp2pWebrtcTransportConfig(),
                                                                            listenAddr,
                                                                            payload,
                                                                            payload,
                                                                            signalWire,
                                                                            clientResponse)
    assert(IsOk(browserRes), "v3 webrtc signal stream: browser bridge")
    let recordRes = host.v3Libp2pWebrtcRecordSignalWire(client,
                                                        server,
                                                        server.selfPeerId,
                                                        signalWire)
    assert(IsOk(recordRes), "v3 webrtc signal stream: record signal")
    assert(bytesEqual(clientResponse, payload), "v3 webrtc signal stream: payload")
    assert(host.v3Libp2pWebrtcSignalEgressCount(client) == 5, "v3 webrtc signal stream: egress count")
    assert(host.v3Libp2pWebrtcSignalIngressCount(server) == 5, "v3 webrtc signal stream: ingress count")
    assert(webrtc_transport.v3Libp2pWebrtcBrowserDatachannelOpenCountNow() == 1,
        "v3 webrtc signal stream: browser open count")
    assert(webrtc_transport.v3Libp2pWebrtcBrowserDatachannelRequestCountNow() == 1,
        "v3 webrtc signal stream: browser request count")
    assert(webrtc_transport.v3Libp2pWebrtcNativeDatachannelRequestCountNow() == 0,
        "v3 webrtc signal stream: native request count")
    assert(webrtc_transport.v3Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        "v3 webrtc signal stream: loopback count")

    var messages: signal.V3Libp2pWebrtcSignalMessage[]
    let decodeRes = signal.v3Libp2pWebrtcSignalTranscriptDecodeFill(messages, signalWire)
    assert(IsOk(decodeRes), "v3 webrtc signal stream: transcript decode")
    assert(messages.len == 5, "v3 webrtc signal stream: transcript count")
    assert(messages[0].kind == signal.v3Libp2pWebrtcSignalTurnPolicy,
        "v3 webrtc signal stream: policy first")
    assert(messages[1].kind == signal.v3Libp2pWebrtcSignalOffer,
        "v3 webrtc signal stream: offer second")
    assert(messages[2].kind == signal.v3Libp2pWebrtcSignalAnswer,
        "v3 webrtc signal stream: answer third")
    assert(messages[3].kind == signal.v3Libp2pWebrtcSignalIceCandidate,
        "v3 webrtc signal stream: candidate fourth")
    assert(messages[4].kind == signal.v3Libp2pWebrtcSignalIceCandidate,
        "v3 webrtc signal stream: candidate fifth")
    assert(layout.fixedBytes32Equal(messages[0].sessionId, messages[4].sessionId),
        "v3 webrtc signal stream: session ids match")
    assert(len(messages[1].sdp) > 32, "v3 webrtc signal stream: offer sdp")
    assert(len(messages[2].sdp) > 32, "v3 webrtc signal stream: answer sdp")
    assert(bytesHasPrefix(bytesFromString(messages[3].candidateText), bytesFromString("candidate:")),
        "v3 webrtc signal stream: client candidate prefix")
    assert(bytesHasPrefix(bytesFromString(messages[4].candidateText), bytesFromString("candidate:")),
        "v3 webrtc signal stream: server candidate prefix")

    echo("v3 webrtc_signal_stream_smoke ok")
    return 0
