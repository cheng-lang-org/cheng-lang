import cheng/core/lang/parser

fn main() =
    let text = "fn main(): int32 =\n    return 0\n"
    var roots: parser.ParserExternalPackageRoot[]
    var profile: parser.NormalizedExprCallProfile
    var err: str
    let ok = parser.ParserBuildExprCallProfileWithExternalPackageRoots("/Users/lbcheng/cheng-lang",
                                                                       "/Users/lbcheng/cheng-lang",
                                                                       roots,
                                                                       "/Users/lbcheng/cheng-lang/src/tests/ordinary_zero_exit_fixture.cheng",
                                                                       text,
                                                                       profile,
                                                                       err)
    assert(ok, "cold parser profile build")
    assert(profile.lines.len >= 2, "cold parser profile line count")
    assert(profile.lines[0] == "fn main(): int32 =", "cold parser profile line0")
    assert(profile.lines[1] == "    return 0", "cold parser profile line1")
    assert(profile.decls.len == 1, "cold parser profile decl count")
    assert(profile.decls[0].name == "main", "cold parser profile decl name")
