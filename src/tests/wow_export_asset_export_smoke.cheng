import std/os
import std/bytes as bytes
import std/result
import cheng/apps/wow_export/asset_export as asset_export
import cheng/apps/wow_export/asset_formats as asset_formats
import cheng/apps/wow_export/manifest/northshire_retail_12_0_5 as northshire
import std/strutils as strutil

fn removeIfExists(path: str) =
    if os.FileExists(path):
        let _ = os.RemoveFile(path)

fn removeDirFiles(dir: str) =
    if os.DirExists(dir):
        let entries: str[] = os.ListDir(dir)
        var i: int32
        for i in i..<entries.len:
            let path: str = os.JoinPath(dir, entries[i])
            if os.FileExists(path):
                let _ = os.RemoveFile(path)

fn note(text: str) =
    echo(text)
    let _ = os.C_fflush(os.GetStdout())

fn main(): int32 =
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    let m2Path: str = "/tmp/wow_export_asset_export_smoke_nsabbeyBell.m2"
    removeIfExists(m2Path)

    let m2Res: Result[asset_export.AssetExportSummary] =
        asset_export.ExportNorthshireKind(manifest, "m2", m2Path)
    assert(IsOk(m2Res), Error(m2Res))
    note("wow_export_asset_export_smoke exported_m2")
    assert(Value(m2Res).bytesWritten == 20308, "wow_export_asset_export_smoke m2 bytes")
    assert(os.FileExists(m2Path), "wow_export_asset_export_smoke m2 exists")
    assert(os.FileSize(m2Path) == int64(20308), "wow_export_asset_export_smoke m2 file size")
    let m2Buf: bytes.ByteBuffer = bytes.ReadFileBytes(m2Path)
    let geometryRes: Result[asset_formats.M2GeometrySummary] =
        asset_formats.ParseM2GeometrySummary(m2Buf)
    assert(IsOk(geometryRes), Error(geometryRes))
    assert(asset_formats.M2GeometrySpanX1000(Value(geometryRes)) == 1916,
           "wow_export_asset_export_smoke m2 span x")
    bytes.FreeByteBuffer(m2Buf)

    let overwriteRes: Result[asset_export.AssetExportSummary] =
        asset_export.ExportNorthshireKind(manifest, "m2", m2Path)
    assert(IsErr(overwriteRes), "wow_export_asset_export_smoke refuses overwrite")

    let bundleDir: str = "/tmp/wow_export_asset_export_bundle_smoke"
    let tgaPath: str = "/tmp/wow_export_asset_export_smoke_abbeyBell.tga"
    removeIfExists(tgaPath)
    removeIfExists(strutil.Join([bundleDir, "/azeroth-wdt.wdt"], ""))
    removeIfExists(strutil.Join([bundleDir, "/azeroth-31-48-adt.adt"], ""))
    removeIfExists(strutil.Join([bundleDir, "/azeroth-32-48-adt.adt"], ""))
    removeIfExists(strutil.Join([bundleDir, "/azeroth-31-49-adt.adt"], ""))
    removeIfExists(strutil.Join([bundleDir, "/azeroth-32-49-adt.adt"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-wmo.wmo"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-000.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-001.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-002.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-003.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-004.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-005.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-006.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-007.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-008.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-009.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-010.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-011.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-012.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/abbey-bell-texture.blp"], ""))
    removeIfExists(strutil.Join([bundleDir, "/abbey-bell-model.m2"], ""))
    removeIfExists(strutil.Join([bundleDir, "/abbey-bell-skin-00.skin"], ""))
    let bundleRes: Result[asset_export.AssetExportBundleSummary] =
        asset_export.ExportNorthshireBundle(manifest, bundleDir)
    assert(IsOk(bundleRes), Error(bundleRes))
    note("wow_export_asset_export_smoke exported_bundle")
    assert(Value(bundleRes).fileCount == 22, "wow_export_asset_export_smoke bundle count")
    assert(Value(bundleRes).bytesWritten == 3346856, "wow_export_asset_export_smoke bundle bytes")
    assert(os.FileSize(strutil.Join([bundleDir, "/azeroth-wdt.wdt"], "")) == int64(294988),
           "wow_export_asset_export_smoke wdt size")
    assert(os.FileSize(strutil.Join([bundleDir, "/azeroth-31-48-adt.adt"], "")) == int64(375707),
           "wow_export_asset_export_smoke adt 31 48 size")
    assert(os.FileSize(strutil.Join([bundleDir, "/azeroth-32-48-adt.adt"], "")) == int64(359854),
           "wow_export_asset_export_smoke adt 32 48 size")
    assert(os.FileSize(strutil.Join([bundleDir, "/azeroth-31-49-adt.adt"], "")) == int64(322706),
           "wow_export_asset_export_smoke adt 31 49 size")
    assert(os.FileSize(strutil.Join([bundleDir, "/azeroth-32-49-adt.adt"], "")) == int64(366237),
           "wow_export_asset_export_smoke adt 32 49 size")
    assert(os.FileSize(strutil.Join([bundleDir, "/northshire-abbey-wmo.wmo"], "")) == int64(9784),
           "wow_export_asset_export_smoke wmo size")
    assert(os.FileSize(strutil.Join([bundleDir, "/northshire-abbey-group-000.wmo_group"], "")) == int64(210244),
           "wow_export_asset_export_smoke group0 size")
    assert(os.FileSize(strutil.Join([bundleDir, "/northshire-abbey-group-010.wmo_group"], "")) == int64(290592),
           "wow_export_asset_export_smoke group10 size")
    assert(os.FileSize(strutil.Join([bundleDir, "/abbey-bell-texture.blp"], "")) == int64(44876),
           "wow_export_asset_export_smoke blp size")
    assert(os.FileSize(strutil.Join([bundleDir, "/abbey-bell-model.m2"], "")) == int64(20308),
           "wow_export_asset_export_smoke bundle m2 size")
    assert(os.FileSize(strutil.Join([bundleDir, "/abbey-bell-skin-00.skin"], "")) == int64(5088),
           "wow_export_asset_export_smoke skin size")

    let depDir: str = "/tmp/wow_export_dependency_bundle_smoke"
    removeIfExists(strutil.Join([depDir, "/dependencies.manifest.txt"], ""))
    var depRemoveIndex: int32
    for depRemoveIndex in depRemoveIndex..<manifest.auditedDependencies.len:
        let dep: northshire.NorthshireAuditedDependency = manifest.auditedDependencies[depRemoveIndex]
        removeIfExists(strutil.Join([depDir, "/", asset_export.NorthshireDependencyOutputName(dep)], ""))
    let depBundleRes: Result[asset_export.AssetExportDependencyBundleSummary] =
        asset_export.ExportNorthshireDependenciesBundle(manifest, depDir)
    assert(IsOk(depBundleRes), Error(depBundleRes))
    note("wow_export_asset_export_smoke exported_dependencies")
    assert(Value(depBundleRes).fileCount == 45,
           "wow_export_asset_export_smoke dependency bundle count")
    assert(Value(depBundleRes).bytesWritten == 8262008,
           "wow_export_asset_export_smoke dependency bundle bytes")
    assert(os.FileExists(strutil.Join([depDir, "/dependencies.manifest.txt"], "")),
           "wow_export_asset_export_smoke dependency manifest exists")
    assert(os.FileExists(strutil.Join([depDir, "/northshire-abbey-modi-000-fid-198056.m2"], "")),
           "wow_export_asset_export_smoke dependency first exists")
    assert(os.FileExists(strutil.Join([depDir, "/northshire-abbey-modi-016-fid-189599.m2"], "")),
           "wow_export_asset_export_smoke dependency duplicate m2 exists")
    assert(os.FileExists(strutil.Join([depDir, "/azeroth-31-48-maid-1-fid-777828.adt"], "")),
           "wow_export_asset_export_smoke dependency first maid split exists")
    assert(os.FileExists(strutil.Join([depDir, "/azeroth-32-49-maid-7-fid-204494.blp"], "")),
           "wow_export_asset_export_smoke dependency last maid split exists")

    let placementDir: str = "/tmp/wow_export_placement_dependency_bundle_smoke"
    removeDirFiles(placementDir)
    let placementBundleRes: Result[asset_export.AssetExportPlacementDependencyBundleSummary] =
        asset_export.ExportNorthshirePlacementDependenciesBundle(manifest, placementDir)
    assert(IsOk(placementBundleRes), Error(placementBundleRes))
    note("wow_export_asset_export_smoke exported_placement_dependencies")
    assert(Value(placementBundleRes).fileCount == 240,
           "wow_export_asset_export_smoke placement dependency bundle count")
    assert(Value(placementBundleRes).doodadFileCount == 222,
           "wow_export_asset_export_smoke placement doodad count")
    assert(Value(placementBundleRes).worldModelFileCount == 18,
           "wow_export_asset_export_smoke placement world model count")
    assert(Value(placementBundleRes).bytesWritten == 3221104,
           "wow_export_asset_export_smoke placement dependency bundle bytes")
    assert(os.FileExists(strutil.Join([placementDir, "/placement_dependencies.manifest.txt"], "")),
           "wow_export_asset_export_smoke placement manifest exists")
    assert(os.FileExists(strutil.Join([placementDir, "/maid-doodad-fid-189929.m2"], "")),
           "wow_export_asset_export_smoke placement first doodad exists")
    assert(os.FileExists(strutil.Join([placementDir, "/maid-worldmodel-fid-108104.wmo"], "")),
           "wow_export_asset_export_smoke placement first world model exists")

    let tgaRes: Result[asset_export.AssetExportSummary] =
        asset_export.ConvertNorthshireFirstBlp(manifest, tgaPath)
    assert(IsOk(tgaRes), Error(tgaRes))
    note("wow_export_asset_export_smoke converted_blp")
    assert(Value(tgaRes).bytesWritten == 262162, "wow_export_asset_export_smoke tga bytes")
    assert(os.FileSize(tgaPath) == int64(262162), "wow_export_asset_export_smoke tga file size")

    removeIfExists(m2Path)
    removeIfExists(strutil.Join([bundleDir, "/azeroth-wdt.wdt"], ""))
    removeIfExists(strutil.Join([bundleDir, "/azeroth-31-48-adt.adt"], ""))
    removeIfExists(strutil.Join([bundleDir, "/azeroth-32-48-adt.adt"], ""))
    removeIfExists(strutil.Join([bundleDir, "/azeroth-31-49-adt.adt"], ""))
    removeIfExists(strutil.Join([bundleDir, "/azeroth-32-49-adt.adt"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-wmo.wmo"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-000.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-001.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-002.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-003.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-004.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-005.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-006.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-007.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-008.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-009.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-010.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-011.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/northshire-abbey-group-012.wmo_group"], ""))
    removeIfExists(strutil.Join([bundleDir, "/abbey-bell-texture.blp"], ""))
    removeIfExists(strutil.Join([bundleDir, "/abbey-bell-model.m2"], ""))
    removeIfExists(strutil.Join([bundleDir, "/abbey-bell-skin-00.skin"], ""))
    removeIfExists(strutil.Join([depDir, "/dependencies.manifest.txt"], ""))
    removeDirFiles(placementDir)
    depRemoveIndex = 0
    for depRemoveIndex in depRemoveIndex..<manifest.auditedDependencies.len:
        let dep: northshire.NorthshireAuditedDependency = manifest.auditedDependencies[depRemoveIndex]
        removeIfExists(strutil.Join([depDir, "/", asset_export.NorthshireDependencyOutputName(dep)], ""))
    removeIfExists(tgaPath)
    echo("wow_export_asset_export_smoke ok")
    return 0
