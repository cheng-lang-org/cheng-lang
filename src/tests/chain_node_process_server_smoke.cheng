import std/system
import std/cmdline as cmdline
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net
import cheng/libp2p/core/types
import cheng/libp2p/transports/tcp_transport

fn main(): int32 =
    let port = cmdline.ReadInt32FlagOrDefault("--port", 0)
    let ready_path_value = cmdline.ReadFlagOrDefault("--ready-path", "")

    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "process.server", "process.loopback")),
           " chain_node: init")
    let mintRes = node.ChainNodeMint(server, 11, 1001, int64(88))
    assert(mintRes.ok, " chain_node process server: mint")
    let transferRes = node.ChainNodeTransfer(server, 11, 1001, 2002, int64(33))
    assert(transferRes.ok, " chain_node process server: transfer")

    var snapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(snapshot, server)
    let payload = net.ChainNodeLibp2pEncodeSnapshot(snapshot)
    let serveRes = tcp_transport.Libp2pTcpServePayloadOnce("127.0.0.1",
                                                             port,
                                                             types.Libp2pProtocolSync,
                                                             payload,
                                                             ready_path_value)
    assert(serveRes.ok, " chain_node process server: serve once")
    echo(" chain_node_process_server_smoke ok")
    return 0
