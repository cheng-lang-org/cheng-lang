# std net transport compile smoke: udp/tcp API surface

import std/system
import std/result
import std/rawbytes
import std/net/transports/udp_syscall as udp
import std/net/transports/tcp_syscall as tcp

fn main(): int32 =
    let udpSockRes: Result[udp.UdpSocketHandle] = udp.UdpSocketOpenDgram(false)
    if IsOk(udpSockRes):
        let udpSock: udp.UdpSocketHandle = Value(udpSockRes)
        var bindAddr: udp.UdpSockAddr
        let bindAddrRes: Result[bool] = udp.UdpSockAddrFromHostPort("127.0.0.1", 0, false, 0, false, bindAddr)
        if IsOk(bindAddrRes):
            let _ = udp.UdpBindAddr(udpSock.fd, bindAddr)
        udp.UdpSocketClose(udpSock.fd)

    let listenerRes: Result[tcp.TcpListenerHandle] = tcp.TcpListen("127.0.0.1", 0)
    if IsOk(listenerRes):
        var listener: tcp.TcpListenerHandle = Value(listenerRes)
        tcp.TcpListenerClose(listener)
    let _ = tcp.TcpConnect("127.0.0.1", 1)
    let _ = bytesFromString("net")
    return 0
