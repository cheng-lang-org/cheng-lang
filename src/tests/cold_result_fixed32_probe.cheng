import std/result
import cheng/std/bytes_layout as layout

fn main(): int32 =
    var zero: layout.FixedBytes32
    var bytes = layout.FixedBytes32ToBytes(zero)
    let res = layout.FixedBytes32FromBytes(bytes)
    if IsErr(res):
        return 2
    let fixed = Value(res)
    let hex = layout.FixedBytes32Hex(fixed)
    if len(hex) != 64:
        return 3
    return 0
