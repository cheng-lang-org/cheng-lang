import std/system
import cheng/core/tooling/path as chengpath

fn main() =
    let root = chengpath.PathCurrentDir()
    assert(chengpath.PathHasParentTraversal("../escape"), "path rooted: prefix traversal")
    assert(chengpath.PathHasParentTraversal("safe/../escape"), "path rooted: nested traversal")
    assert(!chengpath.PathHasParentTraversal("safe/name.txt"), "path rooted: ordinary path")
    assert(chengpath.PathRootedAbsolute(root, "../escape") == "", "path rooted: reject traversal")
    assert(chengpath.PathRootedAbsolute(root, "/tmp/escape") == "", "path rooted: reject absolute")
    let safe = chengpath.PathRootedAbsolute(root, "artifacts/path_rooted_traversal_smoke/out.txt")
    assert(chengpath.PathNonEmpty(safe), "path rooted: safe relative accepted")
