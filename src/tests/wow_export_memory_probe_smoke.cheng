import std/bytes as bytes
import std/os
import std/result
import std/strings as strings
import std/system
import cheng/apps/wow_export/asset_formats as asset_formats
import cheng/apps/wow_export/blte as blte
import cheng/apps/wow_export/blp as blp
import cheng/apps/wow_export/casc_archive as casc_archive
import cheng/apps/wow_export/casc_index as casc_index
import cheng/apps/wow_export/local_files as local_files
import cheng/apps/wow_export/manifest/northshire_retail_12_0_5 as northshire
import cheng/apps/wow_export/render as render

fn removeIfExists(path: str) =
    if os.FileExists(path):
        let _ = os.RemoveFile(path)

fn probeManifestOnce(): int32 =
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    assert(northshire.ManifestReady(manifest), "wow_export_memory_probe manifest ready")
    return manifest.auditedFileCount

fn probeDecodeOnce(): int32 =
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    assert(northshire.ManifestReady(manifest), "wow_export_memory_probe decode manifest ready")
    var totalBytes: int32
    var i: int32
    for i in i..<manifest.auditedFiles.len:
        let file: northshire.NorthshireAuditedFile = manifest.auditedFiles[i]
        let fileRes: Result[bytes.ByteBuffer] =
            local_files.ReadLocalFileByEntry(manifest.clientPath, file.archiveIndex, file.offset, file.size)
        assert(IsOk(fileRes), Error(fileRes))
        let fileBuf: bytes.ByteBuffer = Value(fileRes)
        totalBytes = totalBytes + fileBuf.len
        bytes.FreeByteBuffer(fileBuf)
    return totalBytes

fn probeDecodeFileOnce(fileIndex: int32): int32 =
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    assert(northshire.ManifestReady(manifest), "wow_export_memory_probe decode file manifest ready")
    assert(fileIndex >= 0 && fileIndex < manifest.auditedFiles.len,
           "wow_export_memory_probe decode file index")
    let file: northshire.NorthshireAuditedFile = manifest.auditedFiles[fileIndex]
    let fileRes: Result[bytes.ByteBuffer] =
        local_files.ReadLocalFileByEntry(manifest.clientPath, file.archiveIndex, file.offset, file.size)
    assert(IsOk(fileRes), Error(fileRes))
    let fileBuf: bytes.ByteBuffer = Value(fileRes)
    let outLen: int32 = fileBuf.len
    bytes.FreeByteBuffer(fileBuf)
    return outLen

fn probeBlteHeaderOnce(): int32 =
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    assert(northshire.ManifestReady(manifest), "wow_export_memory_probe blte manifest ready")
    var totalBlocks: int32
    var i: int32
    for i in i..<manifest.auditedFiles.len:
        let file: northshire.NorthshireAuditedFile = manifest.auditedFiles[i]
        var entry: casc_index.CascIndexEntry
        entry.keyPrefix = ""
        entry.archiveIndex = file.archiveIndex
        entry.offset = file.offset
        entry.size = file.size
        let firstBlockRes: Result[bytes.ByteBuffer] =
            casc_archive.CascArchiveReadLocalEntryFirstBlock(manifest.clientPath, entry)
        assert(IsOk(firstBlockRes), Error(firstBlockRes))
        let firstBlock: bytes.ByteBuffer = Value(firstBlockRes)
        let headerRes: Result[blte.BlteHeader] = blte.ParseBlteHeader(firstBlock, "", false)
        bytes.FreeByteBuffer(firstBlock)
        assert(IsOk(headerRes), Error(headerRes))
        totalBlocks = totalBlocks + Value(headerRes).blockCount
    return totalBlocks

fn probeBlteHeaderFileOnce(fileIndex: int32): int32 =
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    assert(northshire.ManifestReady(manifest), "wow_export_memory_probe blte file manifest ready")
    assert(fileIndex >= 0 && fileIndex < manifest.auditedFiles.len,
           "wow_export_memory_probe blte file index")
    let file: northshire.NorthshireAuditedFile = manifest.auditedFiles[fileIndex]
    var entry: casc_index.CascIndexEntry
    entry.keyPrefix = ""
    entry.archiveIndex = file.archiveIndex
    entry.offset = file.offset
    entry.size = file.size
    let firstBlockRes: Result[bytes.ByteBuffer] =
        casc_archive.CascArchiveReadLocalEntryFirstBlock(manifest.clientPath, entry)
    assert(IsOk(firstBlockRes), Error(firstBlockRes))
    let firstBlock: bytes.ByteBuffer = Value(firstBlockRes)
    let headerRes: Result[blte.BlteHeader] = blte.ParseBlteHeader(firstBlock, "", false)
    bytes.FreeByteBuffer(firstBlock)
    assert(IsOk(headerRes), Error(headerRes))
    return Value(headerRes).blockCount

fn probeParseOnce(): int32 =
    let manifest: northshire.NorthshireManifest = northshire.Manifest()
    assert(northshire.ManifestReady(manifest), "wow_export_memory_probe parse manifest ready")
    var totalFacts: int32
    var i: int32
    for i in i..<manifest.auditedFiles.len:
        let file: northshire.NorthshireAuditedFile = manifest.auditedFiles[i]
        let fileRes: Result[bytes.ByteBuffer] =
            local_files.ReadLocalFileByEntry(manifest.clientPath, file.archiveIndex, file.offset, file.size)
        assert(IsOk(fileRes), Error(fileRes))
        let fileBuf: bytes.ByteBuffer = Value(fileRes)
        if file.kind == "wdt":
            let headerRes: Result[asset_formats.FormatHeader] =
                asset_formats.ParseChunkedHeader(fileBuf, "memory-probe-wdt")
            assert(IsOk(headerRes), Error(headerRes))
            totalFacts = totalFacts + Value(headerRes).chunkCount
        elif file.kind == "adt":
            let adtRes: Result[asset_formats.AdtTerrainSummary] =
                asset_formats.ParseAdtTerrainSummary(fileBuf)
            assert(IsOk(adtRes), Error(adtRes))
            totalFacts = totalFacts + Value(adtRes).heightSampleCount
        elif file.kind == "wmo":
            let wmoRes: Result[asset_formats.WmoRootSummary] =
                asset_formats.ParseWmoRootSummary(fileBuf)
            assert(IsOk(wmoRes), Error(wmoRes))
            totalFacts = totalFacts + Value(wmoRes).doodadPlacementCount +
                Value(wmoRes).groupFileDataIDCount +
                Value(wmoRes).modelFileDataIDCount +
                Value(wmoRes).doodadResolvedModelPlacementCount +
                Value(wmoRes).doodadReferencedModelFileDataIDCount
        elif file.kind == "wmo_group":
            let groupRes: Result[asset_formats.WmoGroupSummary] =
                asset_formats.ParseWmoGroupSummary(fileBuf)
            assert(IsOk(groupRes), Error(groupRes))
            totalFacts = totalFacts + Value(groupRes).vertexCount +
                Value(groupRes).indexCount
        elif file.kind == "m2":
            let headerRes: Result[asset_formats.M2Header] = asset_formats.ParseM2Header(fileBuf)
            assert(IsOk(headerRes), Error(headerRes))
            totalFacts = totalFacts + Value(headerRes).version +
                Value(headerRes).vertexCount +
                Value(headerRes).sequenceCount
        elif file.kind == "skin":
            let skinRes: Result[asset_formats.M2SkinSummary] =
                asset_formats.ParseM2SkinSummary(fileBuf)
            assert(IsOk(skinRes), Error(skinRes))
            totalFacts = totalFacts + Value(skinRes).indexCount +
                Value(skinRes).triangleIndexCount
        elif file.kind == "blp":
            let headerRes: Result[blp.Blp2Header] = blp.ParseBlp2Header(fileBuf)
            assert(IsOk(headerRes), Error(headerRes))
            totalFacts = totalFacts + Value(headerRes).width + Value(headerRes).height
        else:
            assert(false, strings.ConcatStr("wow_export_memory_probe unsupported file kind ", file.kind))
        bytes.FreeByteBuffer(fileBuf)
    return totalFacts

fn probeRenderOnce(): int32 =
    let outPath: str = "/tmp/wow_export_memory_probe_render.tga"
    removeIfExists(outPath)
    let summaryRes: Result[render.RenderSummary] = render.RenderNorthshireTga(outPath, 320, 180)
    assert(IsOk(summaryRes), Error(summaryRes))
    assert(Value(summaryRes).wdtMaidDoodadM2AssetCount == 222,
           "wow_export_memory_probe render doodad m2 assets")
    assert(Value(summaryRes).wdtMaidDoodadM2RenderableAssetCount == 218,
           "wow_export_memory_probe render doodad renderable m2 assets")
    assert(Value(summaryRes).wdtMaidDoodadM2ZeroVertexAssetCount == 4,
           "wow_export_memory_probe render doodad zero vertex m2 assets")
    assert(Value(summaryRes).wdtMaidDoodadM2InstancePlacementCount == 4345,
           "wow_export_memory_probe render doodad m2 instance placements")
    assert(Value(summaryRes).wdtMaidDoodadM2InstanceVertexCount == 558543,
           "wow_export_memory_probe render doodad m2 instance vertices")
    assert(Value(summaryRes).wmoRootWorldPlacementCount == 1,
           "wow_export_memory_probe render wmo root world placements")
    assert(Value(summaryRes).wmoDoodadWorldPlacementCount == 144,
           "wow_export_memory_probe render wmo doodad world placements")
    assert(Value(summaryRes).wmoDoodadWorldBoundsReady,
           "wow_export_memory_probe render wmo doodad world bounds")
    assert(Value(summaryRes).wmoDoodadModelWorldInstanceVertexCount == 31665,
           "wow_export_memory_probe render wmo doodad model world instance vertices")
    assert(Value(summaryRes).wmoMaterialCount == 30,
           "wow_export_memory_probe render wmo materials")
    assert(Value(summaryRes).wmoGroupBatchCount == 136,
           "wow_export_memory_probe render wmo group batches")
    assert(Value(summaryRes).wmoGroupMaterialInfoCount == 30563,
           "wow_export_memory_probe render wmo group material info")
    assert(Value(summaryRes).wmoMaterialLightPassReady,
           "wow_export_memory_probe render wmo material light pass")
    assert(Value(summaryRes).textureFileCount == 1,
           "wow_export_memory_probe render texture files")
    assert(Value(summaryRes).textureMaxWidth == 256 && Value(summaryRes).textureMaxHeight == 256,
           "wow_export_memory_probe render texture size")
    assert(Value(summaryRes).textureDecodedTgaBytes == 262162,
           "wow_export_memory_probe render texture tga bytes")
    assert(Value(summaryRes).texturePassReady,
           "wow_export_memory_probe render texture pass")
    assert(Value(summaryRes).wdtMaidWorldModelWmoAssetCount == 18,
           "wow_export_memory_probe render world model wmo assets")
    assert(Value(summaryRes).wdtMaidWorldModelGroupReferenceCount == 287,
           "wow_export_memory_probe render world model group references")
    assert(Value(summaryRes).wdtMaidWorldModelGroupAssetCount == 287,
           "wow_export_memory_probe render world model group assets")
    assert(Value(summaryRes).wdtMaidWorldModelMaterialCount == 670,
           "wow_export_memory_probe render world model materials")
    assert(Value(summaryRes).wdtMaidWorldModelLightCount == 19,
           "wow_export_memory_probe render world model lights")
    assert(Value(summaryRes).wdtMaidWorldModelGroupBatchCount == 2531,
           "wow_export_memory_probe render world model group batches")
    assert(Value(summaryRes).wdtMaidWorldModelGroupMaterialInfoCount == 522540,
           "wow_export_memory_probe render world model group material info")
    assert(Value(summaryRes).wdtMaidWorldModelMaterialPassReady,
           "wow_export_memory_probe render world model material pass")
    assert(Value(summaryRes).wdtMaidWorldModelInstancePlacementCount == 32,
           "wow_export_memory_probe render world model instance placements")
    assert(Value(summaryRes).wdtMaidWorldModelInstanceVertexCount == 709092,
           "wow_export_memory_probe render world model instance vertices")
    assert(Value(summaryRes).wdtMaidWorldModelInstanceBoundsReady,
           "wow_export_memory_probe render world model instance bounds")
    assert(Value(summaryRes).wdtMaidPlacementDependencyDecodedBytes == 3221104,
           "wow_export_memory_probe render placement decoded bytes")
    let touched: int32 = Value(summaryRes).pixelsTouched
    removeIfExists(outPath)
    return touched

fn echoSteady(label: str, warmLive: int64, secondLive: int64) =
    let warmText: str = strings.Int64ToStr(warmLive)
    let secondText: str = strings.Int64ToStr(secondLive)
    let steadyText: str = strings.Int64ToStr(secondLive - warmLive)
    echo(strings.ConcatStr(strings.ConcatStr("wow_export_memory_probe ", label), strings.ConcatStr("_warm=", warmText)))
    echo(strings.ConcatStr(strings.ConcatStr("wow_export_memory_probe ", label), strings.ConcatStr("_second=", secondText)))
    echo(strings.ConcatStr(strings.ConcatStr("wow_export_memory_probe ", label), strings.ConcatStr("_steady=", steadyText)))

fn main(): int32 =
    assert(probeManifestOnce() == 22, "wow_export_memory_probe manifest count")
    let manifestWarm: int64 = memLiveCount()
    assert(probeManifestOnce() == 22, "wow_export_memory_probe manifest count second")
    let manifestSecond: int64 = memLiveCount()
    echoSteady("manifest", manifestWarm, manifestSecond)

    assert(probeDecodeOnce() > 0, "wow_export_memory_probe decode bytes")
    let decodeWarm: int64 = memLiveCount()
    assert(probeDecodeOnce() > 0, "wow_export_memory_probe decode bytes second")
    let decodeSecond: int64 = memLiveCount()
    echoSteady("decode", decodeWarm, decodeSecond)

    assert(probeDecodeFileOnce(0) > 0, "wow_export_memory_probe decode file0")
    let decodeFile0Warm: int64 = memLiveCount()
    assert(probeDecodeFileOnce(0) > 0, "wow_export_memory_probe decode file0 second")
    let decodeFile0Second: int64 = memLiveCount()
    echoSteady("decode_file0", decodeFile0Warm, decodeFile0Second)

    assert(probeDecodeFileOnce(1) > 0, "wow_export_memory_probe decode file1")
    let decodeFile1Warm: int64 = memLiveCount()
    assert(probeDecodeFileOnce(1) > 0, "wow_export_memory_probe decode file1 second")
    let decodeFile1Second: int64 = memLiveCount()
    echoSteady("decode_file1", decodeFile1Warm, decodeFile1Second)

    assert(probeDecodeFileOnce(2) > 0, "wow_export_memory_probe decode file2")
    let decodeFile2Warm: int64 = memLiveCount()
    assert(probeDecodeFileOnce(2) > 0, "wow_export_memory_probe decode file2 second")
    let decodeFile2Second: int64 = memLiveCount()
    echoSteady("decode_file2", decodeFile2Warm, decodeFile2Second)

    assert(probeDecodeFileOnce(3) > 0, "wow_export_memory_probe decode file3")
    let decodeFile3Warm: int64 = memLiveCount()
    assert(probeDecodeFileOnce(3) > 0, "wow_export_memory_probe decode file3 second")
    let decodeFile3Second: int64 = memLiveCount()
    echoSteady("decode_file3", decodeFile3Warm, decodeFile3Second)

    assert(probeBlteHeaderOnce() > 0, "wow_export_memory_probe blte blocks")
    let blteWarm: int64 = memLiveCount()
    assert(probeBlteHeaderOnce() > 0, "wow_export_memory_probe blte blocks second")
    let blteSecond: int64 = memLiveCount()
    echoSteady("blte", blteWarm, blteSecond)
    let blteFile0BlocksText: str = strings.IntToStr(probeBlteHeaderFileOnce(0))
    let blteFile1BlocksText: str = strings.IntToStr(probeBlteHeaderFileOnce(1))
    let blteFile2BlocksText: str = strings.IntToStr(probeBlteHeaderFileOnce(2))
    let blteFile3BlocksText: str = strings.IntToStr(probeBlteHeaderFileOnce(3))
    echo(strings.ConcatStr("wow_export_memory_probe blte_file0_blocks=", blteFile0BlocksText))
    echo(strings.ConcatStr("wow_export_memory_probe blte_file1_blocks=", blteFile1BlocksText))
    echo(strings.ConcatStr("wow_export_memory_probe blte_file2_blocks=", blteFile2BlocksText))
    echo(strings.ConcatStr("wow_export_memory_probe blte_file3_blocks=", blteFile3BlocksText))

    assert(probeBlteHeaderFileOnce(0) > 0, "wow_export_memory_probe blte file0")
    let blteFile0Warm: int64 = memLiveCount()
    assert(probeBlteHeaderFileOnce(0) > 0, "wow_export_memory_probe blte file0 second")
    let blteFile0Second: int64 = memLiveCount()
    echoSteady("blte_file0", blteFile0Warm, blteFile0Second)

    assert(probeBlteHeaderFileOnce(1) > 0, "wow_export_memory_probe blte file1")
    let blteFile1Warm: int64 = memLiveCount()
    assert(probeBlteHeaderFileOnce(1) > 0, "wow_export_memory_probe blte file1 second")
    let blteFile1Second: int64 = memLiveCount()
    echoSteady("blte_file1", blteFile1Warm, blteFile1Second)

    assert(probeBlteHeaderFileOnce(2) > 0, "wow_export_memory_probe blte file2")
    let blteFile2Warm: int64 = memLiveCount()
    assert(probeBlteHeaderFileOnce(2) > 0, "wow_export_memory_probe blte file2 second")
    let blteFile2Second: int64 = memLiveCount()
    echoSteady("blte_file2", blteFile2Warm, blteFile2Second)

    assert(probeBlteHeaderFileOnce(3) > 0, "wow_export_memory_probe blte file3")
    let blteFile3Warm: int64 = memLiveCount()
    assert(probeBlteHeaderFileOnce(3) > 0, "wow_export_memory_probe blte file3 second")
    let blteFile3Second: int64 = memLiveCount()
    echoSteady("blte_file3", blteFile3Warm, blteFile3Second)

    assert(probeParseOnce() > 0, "wow_export_memory_probe parse facts")
    let parseWarm: int64 = memLiveCount()
    assert(probeParseOnce() > 0, "wow_export_memory_probe parse facts second")
    let parseSecond: int64 = memLiveCount()
    echoSteady("parse", parseWarm, parseSecond)

    assert(probeRenderOnce() > 0, "wow_export_memory_probe render pixels")
    let renderWarm: int64 = memLiveCount()
    assert(probeRenderOnce() > 0, "wow_export_memory_probe render pixels second")
    let renderSecond: int64 = memLiveCount()
    echoSteady("render", renderWarm, renderSecond)
    echo("wow_export_memory_probe_smoke ok")
    return 0
