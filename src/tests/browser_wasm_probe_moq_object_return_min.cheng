import std/rawbytes
import cheng/moq/moq_fountain as moq

fn moqObjectBuildDirect(): Result[moq.V3Libp2pMoqObject] =
    let objectBytes = bytesFromString("abc")
    var peers: str[]
    peers = []
    add(peers, "peer-a")
    add(peers, "peer-b")
    return moq.v3Libp2pMoqBuildObject(objectBytes,
                                      0,
                                      100,
                                      peers,
                                      "bundle",
                                      4,
                                      1)

fn main(): int32 =
    return 0
