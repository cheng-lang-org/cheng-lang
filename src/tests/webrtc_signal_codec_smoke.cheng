import std/system
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/protocols/webrtc_signal as signal
import cheng/libp2p/transports/webrtc_transport

fn smokeSessionId(): layout.FixedBytes32 =
    var out = layout.FixedBytes32()
    out.data[0] = 11
    out.data[1] = 22
    out.data[2] = 33
    out.data[3] = 44
    return out

fn main(): int32 =
    let sessionId = smokeSessionId()

    var offer: signal.Libp2pWebrtcSignalMessage
    offer.kind = signal.Libp2pWebrtcSignalOffer
    offer.sessionId = sessionId
    offer.sdp = "v=0\no=- 1 2 IN IP4 127.0.0.1"
    let offerBytes = signal.Libp2pWebrtcSignalEncode(offer)
    let offerRes = signal.Libp2pWebrtcSignalDecode(offerBytes)
    assert(IsOk(offerRes), " webrtc signal codec: decode offer")
    let decodedOffer = Value(offerRes)
    assert(decodedOffer.kind == signal.Libp2pWebrtcSignalOffer,
        " webrtc signal codec: offer kind")
    assert(layout.FixedBytes32Equal(decodedOffer.sessionId, sessionId),
        " webrtc signal codec: offer session")
    assert(decodedOffer.sdp == offer.sdp, " webrtc signal codec: offer sdp")

    var candidate: signal.Libp2pWebrtcSignalMessage
    candidate.kind = signal.Libp2pWebrtcSignalIceCandidate
    candidate.sessionId = sessionId
    candidate.candidateMid = "0"
    candidate.candidateMLineIndex = 0
    candidate.candidateText = "candidate:1 1 udp 2130706431 127.0.0.1 3478 typ host"
    let candidateBytes = signal.Libp2pWebrtcSignalEncode(candidate)
    let candidateRes = signal.Libp2pWebrtcSignalDecode(candidateBytes)
    assert(IsOk(candidateRes), " webrtc signal codec: decode candidate")
    let decodedCandidate = Value(candidateRes)
    assert(decodedCandidate.candidateMid == "0", " webrtc signal codec: candidate mid")
    assert(decodedCandidate.candidateText == candidate.candidateText,
        " webrtc signal codec: candidate text")

    var cfg: webrtc_transport.Libp2pWebrtcTransportConfig
    cfg.relayOnly = true
    cfg.stunUrls = ["stun:stun1.example.net", "stun:stun2.example.net"]
    let turnInsert: signal.Libp2pWebrtcTurnServer
    add(cfg.turnServers, turnInsert)
    cfg.turnServers[0].url = "turn:turn.example.net"
    cfg.turnServers[0].username = "alice"
    cfg.turnServers[0].credential = "secret"

    let policyMsg = webrtc_transport.Libp2pWebrtcTransportSignalPolicy(cfg, sessionId)
    let policyBytes = signal.Libp2pWebrtcSignalEncode(policyMsg)
    let policyRes = signal.Libp2pWebrtcSignalDecode(policyBytes)
    assert(IsOk(policyRes), " webrtc signal codec: decode policy")
    let decodedPolicy = Value(policyRes)
    assert(decodedPolicy.kind == signal.Libp2pWebrtcSignalTurnPolicy,
        " webrtc signal codec: policy kind")
    assert(decodedPolicy.relayOnly, " webrtc signal codec: relay only")
    assert(decodedPolicy.stunUrls.len == 2, " webrtc signal codec: stun count")
    assert(decodedPolicy.turnServers.len == 1, " webrtc signal codec: turn count")
    assert(decodedPolicy.turnServers[0].username == "alice",
        " webrtc signal codec: turn username")

    var webrtcAddr: types.Libp2pMultiaddr
    webrtcAddr.host = "203.0.113.77"
    webrtcAddr.port = 9000
    webrtcAddr.transport = types.Libp2pTransportWebrtc
    webrtcAddr.networkDomain = types.Libp2pNetworkDomainBrowserWebrtc
    webrtcAddr.visibility = types.Libp2pVisibilityPublic
    assert(webrtc_transport.Libp2pWebrtcTransportSupportsAddr(webrtcAddr),
        " webrtc signal codec: transport supports browser addr")
    assert(types.Libp2pTransportText(types.Libp2pTransportWebrtc) == "webrtc",
        " webrtc signal codec: transport text")
    assert(types.Libp2pProtocolWireText(types.Libp2pProtocolWebrtcSignal) == "/cheng/webrtc-signal/1.0.0",
        " webrtc signal codec: protocol wire text")

    var handshakeCfg: webrtc_transport.Libp2pWebrtcTransportConfig
    handshakeCfg.stunUrls = ["stun:codec.example.net"]
    let handshakeTurnInsert: signal.Libp2pWebrtcTurnServer
    add(handshakeCfg.turnServers, handshakeTurnInsert)
    handshakeCfg.turnServers[0].url = "turn:codec.example.net"
    handshakeCfg.turnServers[0].username = "codec-user"
    handshakeCfg.turnServers[0].credential = "codec-secret"
    var pair: webrtc_transport.Libp2pWebrtcLoopbackPair
    let openRes = webrtc_transport.Libp2pWebrtcLoopbackOpenInto(pair, handshakeCfg, webrtcAddr)
    assert(IsOk(openRes), " webrtc signal codec: open session")
    assert(pair.signalTranscript.len == 5, " webrtc signal codec: transcript len")
    assert(pair.signalTranscript[0].kind == signal.Libp2pWebrtcSignalTurnPolicy,
        " webrtc signal codec: transcript turn policy")
    assert(pair.signalTranscript[1].kind == signal.Libp2pWebrtcSignalOffer,
        " webrtc signal codec: transcript offer")
    assert(pair.signalTranscript[2].kind == signal.Libp2pWebrtcSignalAnswer,
        " webrtc signal codec: transcript answer")
    assert(pair.signalTranscript[3].kind == signal.Libp2pWebrtcSignalIceCandidate,
        " webrtc signal codec: transcript client candidate")
    assert(pair.signalTranscript[4].kind == signal.Libp2pWebrtcSignalIceCandidate,
        " webrtc signal codec: transcript server candidate")
    assert(layout.FixedBytes32Equal(pair.signalTranscript[0].sessionId, pair.signalTranscript[4].sessionId),
        " webrtc signal codec: same session id")
    assert(pair.signalTranscript[1].sdp == webrtc_transport.Libp2pWebrtcOfferSdp(webrtcAddr, handshakeCfg.dataChannelLabel),
        " webrtc signal codec: offer sdp exact")
    assert(strutil.Contains(pair.signalTranscript[2].sdp, "answer-bytes="),
        " webrtc signal codec: answer bytes")
    assert(strutil.Contains(pair.signalTranscript[3].candidateText, "typ host"),
        " webrtc signal codec: client host candidate")
    assert(strutil.Contains(pair.signalTranscript[4].candidateText, "typ host"),
        " webrtc signal codec: server host candidate")

    let transcriptPayload = signal.Libp2pWebrtcSignalTranscriptEncode(pair.signalTranscript)
    var transcriptMessages: signal.Libp2pWebrtcSignalMessage[]
    let transcriptDecodeRes = signal.Libp2pWebrtcSignalTranscriptDecodeFill(transcriptMessages, transcriptPayload)
    assert(IsOk(transcriptDecodeRes), " webrtc signal codec: transcript decode")
    assert(transcriptMessages.len == 5, " webrtc signal codec: transcript decoded len")
    assert(transcriptMessages[0].kind == signal.Libp2pWebrtcSignalTurnPolicy,
        " webrtc signal codec: decoded first kind")

    handshakeCfg.relayOnly = true
    var relayPair: webrtc_transport.Libp2pWebrtcLoopbackPair
    let relayOpenRes = webrtc_transport.Libp2pWebrtcLoopbackOpenInto(relayPair, handshakeCfg, webrtcAddr)
    assert(IsOk(relayOpenRes), " webrtc signal codec: relay open")
    assert(strutil.Contains(relayPair.signalTranscript[3].candidateText, "typ relay"),
        " webrtc signal codec: relay client candidate")
    assert(strutil.Contains(relayPair.signalTranscript[4].candidateText, "typ relay"),
        " webrtc signal codec: relay server candidate")

    echo(" webrtc_signal_codec_smoke ok")
    return 0
