import std/strutils as strutil
import cheng/core/tooling/compiler_budget_contract as budget

fn main(): int32 =
    let lightThreshold = budget.CompilerBudgetLightSmokeThreshold()
    let lightSample = budget.CompilerBudgetSampleNew("light_smoke",
                                                     int64(3290),
                                                     int64(104038400),
                                                     int64(17408))
    assert(budget.CompilerBudgetSampleOk(lightSample, lightThreshold),
           " compiler budget contract: light smoke budget")

    let tooSlow = budget.CompilerBudgetSampleNew("too_slow",
                                                int64(5001),
                                                int64(104038400),
                                                int64(17408))
    assert(!budget.CompilerBudgetCompileTimeOk(tooSlow, lightThreshold),
           " compiler budget contract: time fails")

    let tooLargeRss = budget.CompilerBudgetSampleNew("too_large_rss",
                                                    int64(3290),
                                                    int64(134217729),
                                                    int64(17408))
    assert(!budget.CompilerBudgetCompilePeakRssOk(tooLargeRss, lightThreshold),
           " compiler budget contract: rss fails")

    let tooLargeExe = budget.CompilerBudgetSampleNew("too_large_exe",
                                                    int64(3290),
                                                    int64(104038400),
                                                    int64(32769))
    assert(!budget.CompilerBudgetOutputFileSizeOk(tooLargeExe, lightThreshold),
           " compiler budget contract: exe size fails")

    let backendThreshold = budget.CompilerBudgetBackendDriverTargetThreshold()
    let backendTarget = budget.CompilerBudgetSampleNew("backend_driver_target",
                                                       int64(1500),
                                                       int64(268435456),
                                                       int64(1572864))
    assert(budget.CompilerBudgetSampleOk(backendTarget, backendThreshold),
           " compiler budget contract: backend target budget")

    let row = budget.CompilerBudgetReportRow(lightSample, lightThreshold)
    assert(strutil.Contains(row, "compile_time_ms=3290"),
           " compiler budget contract: row time")
    assert(strutil.Contains(row, "compile_peak_rss_bytes=104038400"),
           " compiler budget contract: row rss")
    assert(strutil.Contains(row, "output_file_size_bytes=17408"),
           " compiler budget contract: row output size")
    assert(strutil.Contains(row, "limit_output_file_size_bytes=32768"),
           " compiler budget contract: row output limit")

    echo(" compiler_budget_contract_smoke ok")
    return 0
