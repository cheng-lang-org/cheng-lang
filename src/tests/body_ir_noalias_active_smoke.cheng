import cheng/core/ir/core_types as ir
import cheng/core/ir/body_ir_noalias as noalias

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn addI32Slot(bodyIR: var ir.BodyIR,
              name: str): int32 =
    var slot: ir.LocalSlot
    slot.id = bodyIR.localSlots.len
    slot.name = name
    slot.typeKind = ir.LocalI32Tag
    slot.stackOffset = 16 + slot.id * 8
    slot.sizeBytes = 4
    slot.alignBytes = 4
    slot.noAlias = true
    add(bodyIR.localSlots, slot)
    return slot.id

fn buildBody(): ir.BodyIR =
    var bodyIR = ir.BodyIRNew()
    let a = addI32Slot(bodyIR, "a")
    let b = addI32Slot(bodyIR, "b")
    let c = addI32Slot(bodyIR, "c")

    var loadB: ir.BodyOp
    loadB.kind = ir.BodyOpLoadLocalTag
    loadB.target = b
    add(loadB.operands, a)
    add(bodyIR.ops, loadB)

    var copyC: ir.BodyOp
    copyC.kind = ir.BodyOpCopyLocalTag
    copyC.target = c
    add(copyC.operands, b)
    add(bodyIR.ops, copyC)

    var term: ir.BodyTerm
    term.kind = ir.BodyTermReturnTag
    term.resultSlot = c
    let termIndex = ir.BodyIRAppendTerm(bodyIR, term)
    let _ = ir.BodyIRAppendBlock(bodyIR, 0, 2, termIndex)
    return bodyIR

fn buildOverwriteBody(): ir.BodyIR =
    var bodyIR = ir.BodyIRNew()
    let a = addI32Slot(bodyIR, "a")
    let b = addI32Slot(bodyIR, "b")
    let c = addI32Slot(bodyIR, "c")

    var loadB: ir.BodyOp
    loadB.kind = ir.BodyOpLoadLocalTag
    loadB.target = b
    add(loadB.operands, a)
    add(bodyIR.ops, loadB)

    var overwriteA: ir.BodyOp
    overwriteA.kind = ir.BodyOpLoadConstTag
    overwriteA.target = a
    add(bodyIR.ops, overwriteA)

    var copyC: ir.BodyOp
    copyC.kind = ir.BodyOpCopyLocalTag
    copyC.target = c
    add(copyC.operands, b)
    add(bodyIR.ops, copyC)

    var term: ir.BodyTerm
    term.kind = ir.BodyTermReturnTag
    term.resultSlot = c
    let termIndex = ir.BodyIRAppendTerm(bodyIR, term)
    let _ = ir.BodyIRAppendBlock(bodyIR, 0, 3, termIndex)
    return bodyIR

fn main(): int32 =
    let finalized = noalias.BodyIrNoAliasFinalize(buildBody())

    let c1 = check(finalized.dodSoAContractOk, 11)
    if c1 != 0: return c1
    let c2 = check(finalized.applied, 12)
    if c2 != 0: return c2
    let c3 = check(finalized.localCount >= 3, 13)
    if c3 != 0: return c3
    let c4 = check(finalized.forwardRewriteCount >= 2, 14)
    if c4 != 0: return c4
    let c5 = check(finalized.bodyIR.ops[1].operands[0] == 0, 15)
    if c5 != 0: return c5
    let c6 = check(finalized.bodyIR.terms[0].resultSlot == 0, 16)
    if c6 != 0: return c6

    let overwriteFinalized = noalias.BodyIrNoAliasFinalize(buildOverwriteBody())
    let c7 = check(overwriteFinalized.dodSoAContractOk, 17)
    if c7 != 0: return c7
    let c8 = check(overwriteFinalized.bodyIR.ops[2].operands[0] == 1, 18)
    if c8 != 0: return c8
    let c9 = check(overwriteFinalized.bodyIR.terms[0].resultSlot == 1, 19)
    if c9 != 0: return c9

    var broken = buildBody()
    broken.terms[0].resultSlot = 99
    let brokenFinalized = noalias.BodyIrNoAliasFinalize(broken)
    let c10 = check(!brokenFinalized.dodSoAContractOk, 20)
    if c10 != 0: return c10
    let c11 = check(!brokenFinalized.applied, 21)
    if c11 != 0: return c11

    echo(" body_ir_noalias_active_smoke ok")
    return 0
