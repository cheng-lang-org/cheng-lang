import std/strutils as strutil
import cheng/core/backend/lowering_plan as lower
import cheng/core/ir/core_types as ir

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn addI32Slot(bodyIR: var ir.BodyIR,
              name: str): int32 =
    var slot: ir.LocalSlot
    slot.id = bodyIR.localSlots.len
    slot.name = name
    slot.typeKind = ir.LocalI32Tag
    slot.stackOffset = 16 + slot.id * 8
    slot.sizeBytes = 4
    slot.alignBytes = 4
    slot.noAlias = true
    add(bodyIR.localSlots, slot)
    return slot.id

fn buildForwardBody(): ir.BodyIR =
    var bodyIR = ir.BodyIRNew()
    let a = addI32Slot(bodyIR, "a")
    let b = addI32Slot(bodyIR, "b")
    let c = addI32Slot(bodyIR, "c")

    var loadB: ir.BodyOp
    loadB.kind = ir.BodyOpLoadLocalTag
    loadB.target = b
    add(loadB.operands, a)
    add(bodyIR.ops, loadB)

    var copyC: ir.BodyOp
    copyC.kind = ir.BodyOpCopyLocalTag
    copyC.target = c
    add(copyC.operands, b)
    add(bodyIR.ops, copyC)

    var term: ir.BodyTerm
    term.kind = ir.BodyTermReturnTag
    term.resultSlot = c
    let termIndex = ir.BodyIRAppendTerm(bodyIR, term)
    let _ = ir.BodyIRAppendBlock(bodyIR, 0, 2, termIndex)
    return bodyIR

fn main(): int32 =
    var fnIr: lower.PrimaryObjectIrFunction
    fnIr.functionName = "NoAliasActiveFixture"
    fnIr.bodyKind = "statement_sequence"
    fnIr.bodyIR = buildForwardBody()

    lower.LoweringFinalizeBodyIrNoAlias(fnIr)

    let c1 = check(fnIr.bodyIrNoAliasApplied, 11)
    if c1 != 0: return c1
    let c2 = check(fnIr.bodyIrNoAliasLocalCount == 2, 12)
    if c2 != 0: return c2
    let c3 = check(fnIr.bodyIrNoAliasForwardRewriteCount == 2, 13)
    if c3 != 0: return c3
    let c4 = check(fnIr.bodyIR.ops[1].operands[0] == 0, 14)
    if c4 != 0: return c4
    let c5 = check(fnIr.bodyIR.terms[0].resultSlot == 0, 15)
    if c5 != 0: return c5

    var activeIr: lower.PrimaryObjectIr
    add(activeIr.functions, fnIr)
    let report = lower.LoweringPrimaryObjectIrReportText(activeIr)
    let c6 = check(strutil.Contains(report, "primary_object_ir_noalias_applied_flags=1"), 16)
    if c6 != 0: return c6
    let c7 = check(strutil.Contains(report, "primary_object_ir_noalias_local_counts=2"), 17)
    if c7 != 0: return c7
    let c8 = check(strutil.Contains(report, "primary_object_ir_noalias_forward_rewrite_counts=2"), 18)
    if c8 != 0: return c8

    var brokenFn: lower.PrimaryObjectIrFunction
    brokenFn.functionName = "NoAliasBrokenFixture"
    brokenFn.bodyKind = "statement_sequence"
    brokenFn.bodyIR = buildForwardBody()
    brokenFn.bodyIR.terms[0].resultSlot = 99
    lower.LoweringFinalizeBodyIrNoAlias(brokenFn)
    let c9 = check(!brokenFn.bodyIrNoAliasApplied, 19)
    if c9 != 0: return c9
    let c10 = check(brokenFn.bodyKind == "body_ir_dod_soa_contract_invalid", 20)
    if c10 != 0: return c10

    echo(" body_ir_noalias_active_smoke ok")
    return 0
