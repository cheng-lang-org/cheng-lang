import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as binary
import cheng/chain/codec_binary as codec
import cheng/chain/consensus
import cheng/chain/lsmr_types as lt
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net

fn appendAddressWire(address: binary.LsmrAddress): Bytes =
    var buf = layout.byteBufInit(64)
    lt.AppendAddress(buf, address)
    return layout.byteBufToBytes(buf)

fn appendAddressWireVar(address: var binary.LsmrAddress): Bytes =
    var buf = layout.byteBufInit(64)
    codec.BufAppendU32BE(buf, address.depth)
    for i in 0..<binary.LsmrMaxDepth:
        layout.byteBufAppendByte(buf, address.digits[i] & 255)
    return layout.byteBufToBytes(buf)

fn snapshotWireHasAddress(payload: Bytes,
                          offset: int32,
                          expectedAddress: var binary.LsmrAddress): bool =
    let span = layout.byteSpanFromBytes(payload)
    let rawDepthRes = codec.ReadU32BE(span, offset)
    if IsErr(rawDepthRes):
        return false
    if int32(Value(rawDepthRes)) != expectedAddress.depth:
        return false
    for i in 0..<expectedAddress.depth:
        if layout.byteSpanAt(span, offset + 4 + i) != expectedAddress.digits[i]:
            return false
    return true

fn main(): int32 =
    let seedRes = node.ChainNodeAddressFromSeed("chain-node-a")
    assert(IsOk(seedRes), " lsmr address wire probe: seed")
    var localAddress = Value(seedRes)
    var server: node.ChainNode
    let initRes = node.ChainNodeInitInto(server, "node-a", "chain-node-a")
    assert(IsOk(initRes), " lsmr address wire probe: init")
    var client: node.ChainNode
    let clientInitRes = node.ChainNodeInitInto(client, "node-b", "chain-node-a")
    assert(IsOk(clientInitRes), " lsmr address wire probe: init client")
    let mintRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(IsOk(mintRes), " lsmr address wire probe: mint")
    let transferRes = node.ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(IsOk(transferRes), " lsmr address wire probe: transfer")
    var serverHost = host.Libp2pHostInit("chain.server")
    var clientHost = host.Libp2pHostInit("chain.client")
    var serverAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(serverAddr, "127.0.0.1", 6213)
    let listenRes = host.Libp2pListen(serverHost, serverAddr)
    assert(listenRes.ok, " lsmr address wire probe: listen")
    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolGossipsub)
    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolStore)
    host.Libp2pRegisterHandler(serverHost, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolGossipsub)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolStore)
    host.Libp2pRegisterHandler(clientHost, types.Libp2pProtocolSync)
    let dialRes = host.Libp2pDial(clientHost,
                                    serverHost.selfPeerId,
                                    serverAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " lsmr address wire probe: dial")
    var snapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(snapshot, server)
    let localWire = appendAddressWire(localAddress)
    let localWireVar = appendAddressWireVar(localAddress)
    let serverWire = appendAddressWire(server.address)
    let serverWireVar = appendAddressWireVar(server.address)
    let snapshotWire = appendAddressWire(snapshot.address)
    let snapshotWireVar = appendAddressWireVar(snapshot.address)
    assert(bytesEqual(localWire, localWireVar),
           " lsmr address wire probe: local value wire")
    assert(bytesEqual(serverWire, serverWireVar),
           " lsmr address wire probe: server value wire")
    assert(bytesEqual(snapshotWire, snapshotWireVar),
           " lsmr address wire probe: snapshot value wire")
    assert(bytesEqual(localWireVar, serverWireVar),
           " lsmr address wire probe: local server wire")
    assert(bytesEqual(serverWireVar, snapshotWireVar),
           " lsmr address wire probe: server snapshot wire")
    assert(bytesEqual(localWire, serverWire),
           " lsmr address wire probe: local server value wire")
    assert(bytesEqual(serverWire, snapshotWire),
           " lsmr address wire probe: server snapshot value wire")
    var buf = layout.byteBufInit(2048)
    net.ChainNodeLibp2pAppendSnapshotMagic(buf)
    codec.BufAppendU32BE(buf, net.ChainNodeLibp2pSnapshotVersion)
    let addressOffset = net.ChainNodeLibp2pSnapshotMagicLen + 4
    lt.AppendAddress(buf, snapshot.address)
    assert(snapshotWireHasAddress(layout.byteBufToBytes(buf), addressOffset, snapshot.address),
           " lsmr address wire probe: snapshot after address")
    codec.BufAppendU32BE(buf, snapshot.serveCount)
    assert(snapshotWireHasAddress(layout.byteBufToBytes(buf), addressOffset, snapshot.address),
           " lsmr address wire probe: snapshot after serve count")
    codec.BufAppendFixed32(buf, snapshot.tipEventCid)
    assert(snapshotWireHasAddress(layout.byteBufToBytes(buf), addressOffset, snapshot.address),
           " lsmr address wire probe: snapshot after tip cid")
    net.ChainNodeLibp2pAppendSignature(buf, snapshot.signature)
    assert(snapshotWireHasAddress(layout.byteBufToBytes(buf), addressOffset, snapshot.address),
           " lsmr address wire probe: snapshot after signature")
    codec.BufAppendU32BE(buf, snapshot.eventCids.len)
    assert(snapshotWireHasAddress(layout.byteBufToBytes(buf), addressOffset, snapshot.address),
           " lsmr address wire probe: snapshot after event count")
    for i in 0..<snapshot.eventCids.len:
        var eventCid = snapshot.eventCids[i]
        var event: consensus.ChainEvent
        event = snapshot.events[i]
        net.ChainNodeLibp2pAppendEvent(buf, eventCid, event)
        if i == 0:
            assert(snapshotWireHasAddress(layout.byteBufToBytes(buf), addressOffset, snapshot.address),
                   " lsmr address wire probe: snapshot after event 0")
        if i == 1:
            assert(snapshotWireHasAddress(layout.byteBufToBytes(buf), addressOffset, snapshot.address),
                   " lsmr address wire probe: snapshot after event 1")
    let serveRes = net.ChainNodeLibp2pServeOnce(server, serverHost)
    assert(serveRes.ok, " lsmr address wire probe: serve")
    assert(serveRes.value, " lsmr address wire probe: serve active")
    var hostSnapshot: node.ChainNodeServeSnapshot
    var hostIngress: overlay.IngressEnvelope
    let hostIndexRes = net.ChainNodeLibp2pLatestSnapshotHostIndex(serverHost, server.address)
    assert(IsOk(hostIndexRes), " lsmr address wire probe: host latest")
    let hostIndex = hostIndexRes.value
    let hostEntry = serverHost.storeEntries[hostIndex]
    net.ChainNodeLibp2pCopyIngress(hostIngress, hostEntry.ingress)
    let hostDecodeRes = net.ChainNodeLibp2pDecodeSnapshotFill(hostIngress.payload, hostSnapshot)
    assert(hostDecodeRes.ok, " lsmr address wire probe: host decode")
    assert(binary.LsmrAddressEqual(hostSnapshot.address, server.address),
           " lsmr address wire probe: host decode address")
    assert(hostSnapshot.eventCids.len == 2, " lsmr address wire probe: host decode event cid len")
    var syncedEntries: overlay.IngressEnvelope[]
    var query: overlay.StoreQuery
    net.ChainNodeLibp2pSnapshotQueryFill(query, server.address)
    let syncEntriesRes = host.Libp2pSyncRequest(clientHost, serverHost, serverHost.selfPeerId, query, syncedEntries)
    assert(syncEntriesRes.ok, " lsmr address wire probe: sync request")
    var syncedSnapshot: node.ChainNodeServeSnapshot
    var syncedIngress: overlay.IngressEnvelope
    let syncedIndexRes = net.ChainNodeLibp2pLatestSnapshotIndexFromIngresses(syncedEntries, server.address)
    assert(IsOk(syncedIndexRes), " lsmr address wire probe: synced latest")
    let syncedIndex = syncedIndexRes.value
    net.ChainNodeLibp2pCopyIngress(syncedIngress, syncedEntries[syncedIndex])
    let syncedDecodeRes = net.ChainNodeLibp2pDecodeSnapshotFill(syncedIngress.payload, syncedSnapshot)
    assert(syncedDecodeRes.ok, " lsmr address wire probe: synced decode")
    assert(binary.LsmrAddressEqual(syncedSnapshot.address, server.address),
           " lsmr address wire probe: synced decode address")
    let applyRes = node.ChainNodeSyncOnce(client, syncedSnapshot)
    assert(applyRes.ok, " lsmr address wire probe: apply synced snapshot")
    assert(applyRes.value, " lsmr address wire probe: apply synced snapshot changed")
    echo(" lsmr_address_wire_probe ok")
    return 0
