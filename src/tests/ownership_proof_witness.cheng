// Ownership proof witness: cold-subset ownership tracking
// Stage 5: no-alias + ownership state machine verification

const Owned = 1
const Shared = 2
const Moved = 3

fn check_transfer(from_state: int32, to_state: int32): bool =
    if from_state == Moved: return false
    if from_state == Shared && to_state != Shared: return false
    return true

fn transfer_test(): int32 =
    var x: int32 = Owned
    var y: int32 = Moved
    if check_transfer(x, Owned):
        y = Owned
        x = Moved
        if x == Moved && y == Owned: return 0
    return 1

fn borrow_test(): int32 =
    var owner: int32 = Owned
    var bref: int32 = Shared
    if check_transfer(owner, bref):
        if owner == Owned && bref == Shared: return 0
    return 2

fn double_move_guard(): int32 =
    var x: int32 = Owned
    if check_transfer(x, Owned):
        x = Moved
        if !check_transfer(x, Owned):
            return 0
    return 3

fn main(): int32 =
    let r1: int32 = transfer_test()
    if r1 != 0: return r1
    let r2: int32 = borrow_test()
    if r2 != 0: return r2
    let r3: int32 = double_move_guard()
    if r3 != 0: return r3
    echo(" ownership_proof_witness ok")
    return 0
