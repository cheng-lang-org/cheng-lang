import std/system
import std/crypto/sha256
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    var directBuf = layout.byteBufInit(16)
    layout.byteBufAppendByte(directBuf, 0)
    layout.byteBufAppendByte(directBuf, 0)
    layout.byteBufAppendByte(directBuf, 0)
    layout.byteBufAppendByte(directBuf, 1)
    let directSpan = layout.byteBufView(directBuf)
    assert(layout.byteSpanLen(directSpan) == 4, "v3 bytes param helper probe: direct len")
    assert(layout.byteSpanAt(directSpan, 3) == 1, "v3 bytes param helper probe: direct byte")

    var helperBufA = layout.byteBufInit(16)
    var helperBufB = layout.byteBufInit(16)
    lt.v3AppendU32BE(helperBufA, 1)
    lt.v3AppendU32BE(helperBufB, 2)
    let helperSpanA = layout.byteBufView(helperBufA)
    let helperSpanB = layout.byteBufView(helperBufB)
    assert(layout.byteSpanLen(helperSpanA) == 4, "v3 bytes param helper probe: helper a len")
    assert(layout.byteSpanLen(helperSpanB) == 4, "v3 bytes param helper probe: helper b len")
    assert(layout.byteSpanAt(helperSpanA, 3) == 1, "v3 bytes param helper probe: helper a byte")
    assert(layout.byteSpanAt(helperSpanB, 3) == 2, "v3 bytes param helper probe: helper b byte")

    let rawDigestA = sha256.sha256Digest(helperSpanA.data)
    let rawDigestB = sha256.sha256Digest(helperSpanB.data)
    assert(rawDigestA.len == 32, "v3 bytes param helper probe: digest a len")
    assert(rawDigestB.len == 32, "v3 bytes param helper probe: digest b len")

    var distinct = false
    for i in 0..<32:
        if bytesGet(rawDigestA, i) != bytesGet(rawDigestB, i):
            distinct = true
    assert(distinct, "v3 bytes param helper probe: digest bytes distinct")

    echo("v3 bytes_param_helper_probe_smoke ok")
    return 0
