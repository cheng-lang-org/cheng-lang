import std/system
import std/crypto/sha256
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    var directBuf = layout.ByteBufInit(16)
    layout.ByteBufAppendByte(directBuf, 0)
    layout.ByteBufAppendByte(directBuf, 0)
    layout.ByteBufAppendByte(directBuf, 0)
    layout.ByteBufAppendByte(directBuf, 1)
    let directSpan = layout.ByteBufView(directBuf)
    assert(layout.ByteSpanLen(directSpan) == 4, " bytes param helper probe: direct len")
    assert(layout.ByteSpanAt(directSpan, 3) == 1, " bytes param helper probe: direct byte")

    var helperBufA = layout.ByteBufInit(16)
    var helperBufB = layout.ByteBufInit(16)
    lt.AppendU32BE(helperBufA, 1)
    lt.AppendU32BE(helperBufB, 2)
    let helperSpanA = layout.ByteBufView(helperBufA)
    let helperSpanB = layout.ByteBufView(helperBufB)
    assert(layout.ByteSpanLen(helperSpanA) == 4, " bytes param helper probe: helper a len")
    assert(layout.ByteSpanLen(helperSpanB) == 4, " bytes param helper probe: helper b len")
    assert(layout.ByteSpanAt(helperSpanA, 3) == 1, " bytes param helper probe: helper a byte")
    assert(layout.ByteSpanAt(helperSpanB, 3) == 2, " bytes param helper probe: helper b byte")

    let rawDigestA = sha256.sha256Digest(helperSpanA.data)
    let rawDigestB = sha256.sha256Digest(helperSpanB.data)
    assert(rawDigestA.len == 32, " bytes param helper probe: digest a len")
    assert(rawDigestB.len == 32, " bytes param helper probe: digest b len")

    var distinct = false
    for i in 0..<32:
        if bytesGet(rawDigestA, i) != bytesGet(rawDigestB, i):
            distinct = true
    assert(distinct, " bytes param helper probe: digest bytes distinct")

    echo(" bytes_param_helper_probe_smoke ok")
    return 0
