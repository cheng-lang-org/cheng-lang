import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

fn localMutate(index: var consensus.ChainIndex, eventCid: layout.FixedBytes32): int32 =
    add(index.accountIds, 1001)
    assert(index.accountIds.buffer != nil, " consensus add smoke: buffer")
    assert(index.accountIds.len == 1, " consensus add smoke: len")
    assert(index.accountIds.cap >= 1, " consensus add smoke: cap")
    return 0

fn main(): int32 =
    var index = consensus.ChainIndex()
    let eventCid = layout.FixedBytes32()
    let rc = localMutate(index, eventCid)
    assert(rc == 0, " consensus add smoke: rc")
    echo(" consensus_add_smoke ok")
    return 0
