-- Simple deterministic functions for work-stealing determinism test
-- Compiled with BACKEND_JOBS=1 and BACKEND_JOBS=4; both must produce
-- bit-identical executables regardless of parallel execution order.

fn add(a: int32, b: int32): int32 =
    return a + b

fn mul(a: int32, b: int32): int32 =
    return a * b

fn sumTo(n: int32): int32 =
    var i: int32
    var s: int32
    for i in 0..<n:
        s = s + i
    return s

fn fib(n: int32): int32 =
    if n <= 1:
        return n
    return fib(n - 1) + fib(n - 2)

fn compute(): int32 =
    let a = add(10, 20)
    let b = mul(3, 7)
    let c = sumTo(10)
    let d = fib(10)
    return a + b + c + d - 130

fn main(): int32 =
    let result = compute()
    echo(" function_task_simple: ", result)
    return 0
