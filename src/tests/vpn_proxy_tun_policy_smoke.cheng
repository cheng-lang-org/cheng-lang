import cheng/apps/vpn_proxy/vpn_proxy_tun_policy as tun

fn main(): int32 =
    assert(tun.VpnProxyTunShouldFakeDomain("www.google.com"), "tun policy fake google")
    assert(tun.VpnProxyTunShouldFakeDomain("ssl.gstatic.com"), "tun policy fake gstatic")
    assert(tun.VpnProxyTunShouldFakeDomain("mail.googleusercontent.com"), "tun policy fake googleusercontent")
    assert(tun.VpnProxyTunShouldFakeDomain("httpdns-browser.platform.dbankcloud.cn"), "tun policy proxy browser httpdns")
    assert(!tun.VpnProxyTunShouldFakeDomain("example.com"), "tun policy normal domain")
    assert(tun.VpnProxyTunRuleShouldFakeDomain("api.example.com",
                                               tun.VpnProxyTunRuleDomainSuffix,
                                               "example.com",
                                               tun.VpnProxyTunRuleTargetProxy),
           "tun policy config suffix proxy fake")
    assert(!tun.VpnProxyTunRuleShouldFakeDomain("api.example.com",
                                                tun.VpnProxyTunRuleDomainSuffix,
                                                "example.com",
                                                tun.VpnProxyTunRuleTargetDirect),
           "tun policy config direct no fake")

    assert(tun.VpnProxyTunIsFakeIp("198.18.0.2"), "tun policy fake ip")
    assert(!tun.VpnProxyTunIsFakeIp("121.36.118.233"), "tun policy normal ip")
    assert(tun.VpnProxyTunShouldProxyIpDirectly("142.250.73.74"), "tun policy google real ip direct ss")
    assert(tun.VpnProxyTunShouldProxyIpDirectly("91.108.56.155"), "tun policy telegram real ip direct ss")

    assert(tun.VpnProxyTunTransportForTarget("198.18.0.2", "www.google.com") == tun.VpnProxyTunTransportDirectSs,
           "tun policy fake target direct ss")
    assert(tun.VpnProxyTunTransportForTarget("142.250.73.74", "") == tun.VpnProxyTunTransportDirectSs,
           "tun policy cached google ip direct ss")
    assert(tun.VpnProxyTunTransportForTarget("121.36.118.233", "") == tun.VpnProxyTunTransportDirect,
           "tun policy normal target direct")

    assert(tun.VpnProxyTunUdpActionForTarget("198.18.0.2", 443) == tun.VpnProxyTunUdpDrop,
           "tun policy drop fake quic")
    assert(tun.VpnProxyTunUdpActionForTarget("142.250.73.74", 443) == tun.VpnProxyTunUdpDrop,
           "tun policy drop cached google quic")
    assert(tun.VpnProxyTunUdpActionForTarget("198.18.0.2", 53) == tun.VpnProxyTunUdpForward,
           "tun policy keep fake dns udp")
    assert(tun.VpnProxyTunUdpActionForTarget("121.36.118.233", 443) == tun.VpnProxyTunUdpForward,
           "tun policy keep normal udp")

    assert(tun.VpnProxyTunTcpChunkBytes(1500) == 1200, "tun policy mtu 1500 chunk")
    assert(tun.VpnProxyTunTcpChunkBytes(1000) == 700, "tun policy small mtu chunk")
    assert(tun.VpnProxyTunTcpChunkBytes(700) == 512, "tun policy minimum chunk")
    assert(tun.VpnProxyTunSessionLimit() == 256, "tun policy session limit")
    assert(tun.VpnProxyTunMaxRetransmitSegments() == 64, "tun policy retransmit segment limit")
    assert(tun.VpnProxyTunMaxRetransmitBytes() == 262144, "tun policy retransmit byte limit")
    assert(tun.VpnProxyTunReadIdleTimeoutMs() == 0, "tun policy long connection has no read idle timeout")
    assert(tun.VpnProxyTunShouldClearConnectedReadTimeout(), "tun policy clear connected read timeout")
    assert(tun.VpnProxyTunShouldLogHotPath(79), "tun policy hot path log before limit")
    assert(!tun.VpnProxyTunShouldLogHotPath(80), "tun policy hot path log at limit")
    assert(tun.VpnProxyTunRouteMode() == tun.VpnProxyTunRouteModeGlobal, "tun policy global route mode")

    echo(" vpn_proxy_tun_policy_smoke ok")
    return 0
