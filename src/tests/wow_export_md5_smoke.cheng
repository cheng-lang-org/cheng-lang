import std/bytes as bytes
import std/rawbytes
import std/system
import cheng/apps/wow_export/md5 as md5

fn makeBuf(len: int32): bytes.ByteBuffer =
    var out: bytes.ByteBuffer
    out.len = len
    if len > 0:
        out.data = alloc(len)
    return out

fn main(): int32 =
    assert(md5.Md5StringHex("") == "d41d8cd98f00b204e9800998ecf8427e", "wow_export_md5 empty")
    assert(md5.Md5StringHex("abc") == "900150983cd24fb0d6963f7d28e17f72", "wow_export_md5 abc")
    assert(md5.Md5StringHex("message digest") == "f96b697d7cb7938d525a2f31aaf161d0", "wow_export_md5 message digest")

    let buf: bytes.ByteBuffer = makeBuf(5)
    bytes.BufSetByte(buf, 0, int32('x'))
    bytes.BufSetByte(buf, 1, int32('a'))
    bytes.BufSetByte(buf, 2, int32('b'))
    bytes.BufSetByte(buf, 3, int32('c'))
    bytes.BufSetByte(buf, 4, int32('y'))
    assert(md5.Md5ByteBufferSliceHex(buf, 1, 3) == "900150983cd24fb0d6963f7d28e17f72", "wow_export_md5 bytebuffer slice")
    let raw: rawbytes.Bytes = rawbytes.BytesFromString("abc")
    assert(rawbytes.BytesToHex(md5.Md5Digest(raw)) == "900150983cd24fb0d6963f7d28e17f72", "wow_export_md5 digest bytes")
    echo("wow_export_md5_smoke ok")
    return 0
