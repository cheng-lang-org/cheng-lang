import cheng/std/bytes_layout as layout
import std/rawbytes

fn main(): int32 =
    let bytes = BytesAlloc(32)
    for i in 0..<32:
        BytesSet(bytes, i, i)
    let res = layout.FixedBytes32FromBytes(bytes)
    if IsErr(res):
        return 11
    let fixed = Value(res)
    let hex = layout.FixedBytes32Hex(fixed)
    if hex != "000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f":
        return 12
    return 0
