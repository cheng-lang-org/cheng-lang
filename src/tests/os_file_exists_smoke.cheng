import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_file_exists_smoke_tmp"
    let emptyPath: str = os.JoinPath(tmpRoot, "empty.txt")
    let srcDir: str = os.JoinPath("v3", "src")

    if os.FileExists(emptyPath):
        assert(os.RemoveFile(emptyPath), "v3 ordinary os.FileExists cleanup file")
    os.CreateDir(tmpRoot)
    assert(os.DirExists(tmpRoot), "v3 ordinary os.DirExists tmp root")
    let tmpRootAsFile: bool = os.FileExists(tmpRoot)
    if tmpRootAsFile:
        assert(false, "v3 ordinary os.FileExists excludes dir")

    os.WriteFile(emptyPath, "")
    assert(os.FileExists(emptyPath), "v3 ordinary os.FileExists empty file")
    let missingPath: str = os.JoinPath(tmpRoot, "missing.txt")
    let missingExists: bool = os.FileExists(missingPath)
    if missingExists:
        assert(false, "v3 ordinary os.FileExists missing file")
    assert(os.DirExists(srcDir), "v3 ordinary os.JoinPath + dirExists")

    if os.FileExists(emptyPath):
        assert(os.RemoveFile(emptyPath), "v3 ordinary os.RemoveFile empty file")
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)
    echo("v3 os_file_exists_smoke ok")
    return 0
