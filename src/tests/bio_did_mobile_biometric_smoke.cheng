import std/system
import std/result
import std/rawbytes
import std/crypto/rand
import cheng/std/bytes_layout as layout
import cheng/libp2p/core/types
import cheng/libp2p/identity/did
import cheng/libp2p/mobile/mobile_capi as capi
import cheng/apps/chain_node/chain_node as chain
import cheng/mobile/hardware/biometric
import cheng/apps/bio/bio_did_chain_node as flow
import cheng/apps/bio/bio_did_mobile_biometric as mobileflow

@importc("cheng_buffer_handle_len_bridge")
fn bioDidMobileSmokeBufferHandleLenBridge(handle: uint64): int32
@importc("cheng_buffer_handle_byte_bridge")
fn bioDidMobileSmokeBufferHandleByteBridge(handle: uint64, idx: int32): int32
@importc("cheng_buffer_handle_release_bridge")
fn bioDidMobileSmokeBufferHandleReleaseBridge(handle: uint64): int32

var bioDidMobileSmokeFeatureCurrent: layout.FixedBytes32
var bioDidMobileSmokeFeatureBad: layout.FixedBytes32

fn bioDidMobileSmokeFeature(seed: int32): layout.FixedBytes32 =
    let raw: Bytes = bytesAlloc(32)
    for i in 0..<32:
        bytesSet(raw, i, ((seed * 31) + (i * 13) + 7) & 255)
    let res = layout.fixedBytes32FromBytes(raw)
    assert(IsOk(res), "v3 bio did mobile smoke: feature build")
    return Value(res)

fn bioDidMobileSmokeCorrupt(feature: layout.FixedBytes32,
                            positions: int32[]): layout.FixedBytes32 =
    var raw: Bytes = layout.fixedBytes32ToBytes(feature)
    for i in 0..<positions.len:
        let pos = positions[i]
        bytesSet(raw, pos, bytesGet(raw, pos) ^ ((0x33 + i) & 255))
    let res = layout.fixedBytes32FromBytes(raw)
    assert(IsOk(res), "v3 bio did mobile smoke: corrupt fixed32")
    return Value(res)

fn bioDidMobileSmokeRequest(requestId: str,
                            didText: str,
                            bindingSeed: str,
                            label: str): mobileflow.V3BioDidMobileFingerprintRequest =
    var out = mobileflow.V3BioDidMobileFingerprintRequest()
    out.requestId = requestId
    out.didText = didText
    out.deviceBindingSeedHint = bindingSeed
    out.deviceLabelHint = label
    out.promptTitle = "指纹验证"
    out.promptReason = "验证当前设备并导入 DID"
    return out

fn bioDidMobileSmokeAttestorPrivHex(): str =
    return "60d71049a0cafe01faa9948dc77ee5bc4bd5e05b8e328fdb9cc4c38237250a05"

fn bioDidMobileSmokeAttestorPubKeyHex(): str =
    return "04963c1356849b8478030a6eb572581063ccedf53fda0bc7241247eba977e3b0666e4bf0c12caa47487c2927f83b17d6f9f332481cd2ab0c4885f91fc2a6c547d5"

fn bioDidMobileSmokeScriptAuthorize(feature: layout.FixedBytes32,
                                    bindingSeed: str,
                                    label: str) =
    biometric.v3BiometricSetScriptedFingerprintAuthorizedSigned(feature,
                                                                bindingSeed,
                                                                label,
                                                                "fingerprint.smoke",
                                                                bioDidMobileSmokeAttestorPrivHex())

fn bioDidMobileSmokeBytesFromHandle(handle: uint64): Bytes =
    var n: int32
    n = bioDidMobileSmokeBufferHandleLenBridge(handle)
    if n <= 0:
        var releaseRc: int32
        releaseRc = bioDidMobileSmokeBufferHandleReleaseBridge(handle)
        return emptyBytes()
    var raw: Bytes = bytesAlloc(n)
    var i = 0
    while i < n:
        var byteVal: int32
        byteVal = bioDidMobileSmokeBufferHandleByteBridge(handle, i)
        assert(byteVal >= 0 && byteVal <= 255,
               "v3 bio did mobile smoke: handle byte range")
        bytesSet(raw, i, byteVal)
        i = i + 1
    var releaseRc: int32
    releaseRc = bioDidMobileSmokeBufferHandleReleaseBridge(handle)
    return raw

fn main(): int32 =
    assert(rand.setRandomSeed(bytesFromString("v3.bio.did.mobile.seed")),
           "v3 bio did mobile smoke: seed")
    bioDidMobileSmokeFeatureCurrent = bioDidMobileSmokeFeature(9)
    bioDidMobileSmokeFeatureBad = bioDidMobileSmokeCorrupt(bioDidMobileSmokeFeatureCurrent,
                                                           [0, 2, 4, 6, 8, 10, 12, 14, 16])

    biometric.v3BiometricClearScriptedFingerprintAuthorize()

    var missingNode: chain.V3ChainNode
    assert(IsOk(chain.v3ChainNodeInitInto(missingNode, "bio.did.mobile.missing", "bio.did.mobile.addr.1")),
           "v3 chain_node: init")
    let missingRes = mobileflow.v3BioDidMobileCreateWithFingerprint(
        missingNode,
        bioDidMobileSmokeRequest("missing-create", "", "device.phone.secure", "phone"),
        int64(900)
    )
    assert(IsErr(missingRes), "v3 bio did mobile smoke: missing impl reject")

    var noTrustNode: chain.V3ChainNode
    assert(IsOk(chain.v3ChainNodeInitInto(noTrustNode, "bio.did.mobile.notrust", "bio.did.mobile.addr.0")),
           "v3 chain_node: init")
    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.phone.secure",
                                     "phone")
    let noTrustRes = mobileflow.v3BioDidMobileCreateWithFingerprint(
        noTrustNode,
        bioDidMobileSmokeRequest("create-no-trust", "", "device.phone.secure", "phone"),
        int64(950)
    )
    assert(IsErr(noTrustRes), "v3 bio did mobile smoke: trusted attestor required")

    let trustRes = flow.v3BioDidSetTrustedAttestorRootHex(bioDidMobileSmokeAttestorPubKeyHex(),
                                                          biometric.v3BiometricScriptedRootKeyId)
    assert(IsOk(trustRes), "v3 bio did mobile smoke: add trusted attestor")

    let createHandleReq = bioDidMobileSmokeRequest("create-handle", "", "device.phone.secure", "phone")
    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.phone.secure",
                                     "phone")
    let handleAuthReq = mobileflow.v3BioDidMobileFingerprintAuthorizeReq(createHandleReq, false)
    var handleAuthResp = biometric.V3BiometricFingerprintAuthorizeResp()
    let handleAuthOk = biometric.v3BiometricFingerprintAuthorizeBlockingFillV3(handleAuthResp,
                                                                               createHandleReq.requestId,
                                                                               handleAuthReq)
    assert(IsOk(handleAuthOk), "v3 bio did mobile smoke: handle auth")
    let createWire = capi.v3MobileCapiBioDidCreateRequestWire(createHandleReq.requestId,
                                                              layout.fixedBytes32Hex(handleAuthResp.feature32),
                                                              handleAuthResp.deviceBindingSeed,
                                                              handleAuthResp.deviceLabel,
                                                              handleAuthResp.sensorId,
                                                              handleAuthResp.hardwareAttestation)
    let createHandle = capi.v3MobileCapiBioDidCreateWireHandle(createWire)
    assert(createHandle != uint64(0), "v3 bio did mobile smoke: create handle nonzero")
    let createHandlePayload = bioDidMobileSmokeBytesFromHandle(createHandle)
    assert(bytesLen(createHandlePayload) > 32,
           "v3 bio did mobile smoke: create handle payload len")
    let createCString = capi.v3MobileCapiBioDidCreateWireCString(createWire)
    assert(createCString != nil, "v3 bio did mobile smoke: create cstring nonnull")
    let createCStringPayload = strFromCStringCopy(createCString)
    capi.v3MobileCapiStringFree(createCString)
    let createCStringPayloadBytes = bytesFromString(createCStringPayload)
    assert(bytesLen(createCStringPayloadBytes) > 32,
           "v3 bio did mobile smoke: create cstring payload len")
    let createDirectHandle = capi.v3MobileCapiBioDidCreateHandle(createHandleReq.requestId,
                                                                 layout.fixedBytes32Hex(handleAuthResp.feature32),
                                                                 handleAuthResp.deviceBindingSeed,
                                                                 handleAuthResp.deviceLabel,
                                                                 handleAuthResp.sensorId,
                                                                 handleAuthResp.hardwareAttestation)
    assert(createDirectHandle != uint64(0), "v3 bio did mobile smoke: create direct handle nonzero")
    let createDirectHandlePayload = bioDidMobileSmokeBytesFromHandle(createDirectHandle)
    assert(bytesLen(createDirectHandlePayload) > 32,
           "v3 bio did mobile smoke: create direct handle payload len")
    let createDirectCString = capi.v3MobileCapiBioDidCreateCString(createHandleReq.requestId,
                                                                   layout.fixedBytes32Hex(handleAuthResp.feature32),
                                                                   handleAuthResp.deviceBindingSeed,
                                                                   handleAuthResp.deviceLabel,
                                                                   handleAuthResp.sensorId,
                                                                   handleAuthResp.hardwareAttestation)
    assert(createDirectCString != nil, "v3 bio did mobile smoke: create direct cstring nonnull")
    let createDirectCStringPayload = strFromCStringCopy(createDirectCString)
    capi.v3MobileCapiStringFree(createDirectCString)
    let createDirectCStringPayloadBytes = bytesFromString(createDirectCStringPayload)
    assert(bytesLen(createDirectCStringPayloadBytes) > 32,
           "v3 bio did mobile smoke: create direct cstring payload len")
    let createRawHandle = capi.v3MobileCapiBioDidCreateHandleRaw(strToCStringTemp(createHandleReq.requestId),
                                                                 strToCStringTemp(layout.fixedBytes32Hex(handleAuthResp.feature32)),
                                                                 strToCStringTemp(handleAuthResp.deviceBindingSeed),
                                                                 strToCStringTemp(handleAuthResp.deviceLabel),
                                                                 strToCStringTemp(handleAuthResp.sensorId),
                                                                 strToCStringTemp(handleAuthResp.hardwareAttestation))
    assert(createRawHandle != uint64(0), "v3 bio did mobile smoke: create raw handle nonzero")
    let createRawHandlePayload = bioDidMobileSmokeBytesFromHandle(createRawHandle)
    assert(bytesLen(createRawHandlePayload) > 32,
           "v3 bio did mobile smoke: create raw handle payload len")
    let createRawCString = capi.v3MobileCapiBioDidCreateCStringRaw(strToCStringTemp(createHandleReq.requestId),
                                                                   strToCStringTemp(layout.fixedBytes32Hex(handleAuthResp.feature32)),
                                                                   strToCStringTemp(handleAuthResp.deviceBindingSeed),
                                                                   strToCStringTemp(handleAuthResp.deviceLabel),
                                                                   strToCStringTemp(handleAuthResp.sensorId),
                                                                   strToCStringTemp(handleAuthResp.hardwareAttestation))
    assert(createRawCString != nil, "v3 bio did mobile smoke: create raw cstring nonnull")
    let createRawCStringPayload = strFromCStringCopy(createRawCString)
    capi.v3MobileCapiStringFree(createRawCString)
    let createRawCStringPayloadBytes = bytesFromString(createRawCStringPayload)
    assert(bytesLen(createRawCStringPayloadBytes) > 32,
           "v3 bio did mobile smoke: create raw cstring payload len")
    let createWireRawHandle = capi.v3MobileCapiBioDidCreateWireHandleRaw(strToCStringTemp(createWire))
    assert(createWireRawHandle != uint64(0), "v3 bio did mobile smoke: create wire raw handle nonzero")
    let createWireRawHandlePayload = bioDidMobileSmokeBytesFromHandle(createWireRawHandle)
    assert(bytesLen(createWireRawHandlePayload) > 32,
           "v3 bio did mobile smoke: create wire raw handle payload len")
    let createWireRawCString = capi.v3MobileCapiBioDidCreateWireCStringRaw(strToCStringTemp(createWire))
    assert(createWireRawCString != nil, "v3 bio did mobile smoke: create wire raw cstring nonnull")
    let createWireRawCStringPayload = strFromCStringCopy(createWireRawCString)
    capi.v3MobileCapiStringFree(createWireRawCString)
    let createWireRawCStringPayloadBytes = bytesFromString(createWireRawCStringPayload)
    assert(bytesLen(createWireRawCStringPayloadBytes) > 32,
           "v3 bio did mobile smoke: create wire raw cstring payload len")

    var node: chain.V3ChainNode
    assert(IsOk(chain.v3ChainNodeInitInto(node, "bio.did.mobile", "bio.did.mobile.addr")),
           "v3 chain_node: init")
    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.phone.secure",
                                     "phone")
    let createRes = mobileflow.v3BioDidMobileCreateWithFingerprint(
        node,
        bioDidMobileSmokeRequest("create-phone", "", "device.phone.secure", "phone"),
        int64(1000)
    )
    assert(IsOk(createRes), "v3 bio did mobile smoke: create did")
    let created = Value(createRes)
    let didText = created.document.did
    assert(didText == did.v3DidIdentityDid(created.identity),
           "v3 bio did mobile smoke: created did stable")
    assert(created.document.devices.len == 1,
           "v3 bio did mobile smoke: create device count")
    assert(created.bundle.bundleSeq == 1,
           "v3 bio did mobile smoke: create bundle seq")
    assert(created.bundle.hardware.requestId == "create-phone",
           "v3 bio did mobile smoke: create request id")
    assert(created.bundle.hardware.sensorId == "fingerprint.smoke",
           "v3 bio did mobile smoke: create sensor id")

    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.phone.secure",
                                     "phone-renamed")
    let sameImportRes = mobileflow.v3BioDidMobileImportWithFingerprint(
        node,
        bioDidMobileSmokeRequest("import-phone",
                                 didText,
                                 "device.phone.secure",
                                 "phone-renamed"),
        int64(1010)
    )
    assert(IsOk(sameImportRes), "v3 bio did mobile smoke: same device import")
    let sameImport = Value(sameImportRes)
    assert(types.v3Libp2pPeerIdEqual(created.identity.selfDevice.devicePeerId,
                                     sameImport.identity.selfDevice.devicePeerId),
           "v3 bio did mobile smoke: same device stable peer id")
    assert(sameImport.document.devices.len == 1,
           "v3 bio did mobile smoke: same device no duplicate")
    assert(did.v3DidWord64Value(sameImport.document.version) == int64(1),
           "v3 bio did mobile smoke: same device version stable")
    assert(sameImport.bundle.bundleSeq == 2,
           "v3 bio did mobile smoke: same device bundle seq")
    assert(sameImport.bundle.hardware.requestId == "import-phone",
           "v3 bio did mobile smoke: import request id")

    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.laptop.secure",
                                     "laptop")
    let laptopImportRes = mobileflow.v3BioDidMobileImportWithFingerprint(
        node,
        bioDidMobileSmokeRequest("import-laptop",
                                 didText,
                                 "device.laptop.secure",
                                 "laptop"),
        int64(1020)
    )
    assert(IsOk(laptopImportRes), "v3 bio did mobile smoke: new device import")
    let laptopImport = Value(laptopImportRes)
    assert(!types.v3Libp2pPeerIdEqual(created.identity.selfDevice.devicePeerId,
                                      laptopImport.identity.selfDevice.devicePeerId),
           "v3 bio did mobile smoke: new device new peer id")
    assert(laptopImport.document.devices.len == 2,
           "v3 bio did mobile smoke: new device count")
    assert(did.v3DidWord64Value(laptopImport.document.version) == int64(2),
           "v3 bio did mobile smoke: new device version bump")
    assert(laptopImport.bundle.bundleSeq == 3,
           "v3 bio did mobile smoke: new device bundle seq")
    assert(!layout.fixedBytes32Equal(laptopImport.bundle.hardware.bindingCid,
                                     sameImport.bundle.hardware.bindingCid),
           "v3 bio did mobile smoke: new bundle new hardware binding")

    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.laptop.secure",
                                     "laptop-renamed")
    let laptopImportAgainRes = mobileflow.v3BioDidMobileImportWithFingerprint(
        node,
        bioDidMobileSmokeRequest("import-laptop-again",
                                 didText,
                                 "device.laptop.secure",
                                 "laptop-renamed"),
        int64(1030)
    )
    assert(IsOk(laptopImportAgainRes), "v3 bio did mobile smoke: repeat laptop import")
    let laptopImportAgain = Value(laptopImportAgainRes)
    assert(types.v3Libp2pPeerIdEqual(laptopImport.identity.selfDevice.devicePeerId,
                                     laptopImportAgain.identity.selfDevice.devicePeerId),
           "v3 bio did mobile smoke: repeat laptop stable peer id")
    assert(laptopImportAgain.document.devices.len == 2,
           "v3 bio did mobile smoke: repeat laptop no duplicate")
    assert(did.v3DidWord64Value(laptopImportAgain.document.version) == int64(2),
           "v3 bio did mobile smoke: repeat laptop version stable")
    assert(laptopImportAgain.bundle.bundleSeq == 4,
           "v3 bio did mobile smoke: repeat laptop bundle seq")

    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureBad,
                                     "device.tablet.secure",
                                     "tablet")
    let badImportRes = mobileflow.v3BioDidMobileImportWithFingerprint(
        node,
        bioDidMobileSmokeRequest("bad-import",
                                 didText,
                                 "device.tablet.secure",
                                 "tablet"),
        int64(1040)
    )
    assert(IsErr(badImportRes), "v3 bio did mobile smoke: bad fingerprint reject")

    biometric.v3BiometricClearScriptedFingerprintAuthorize()
    echo("v3 bio_did_mobile_biometric_smoke ok")
    return 0
