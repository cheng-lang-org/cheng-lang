import std/system
import std/result
import std/rawbytes
import std/crypto/rand
import cheng/std/bytes_layout as layout
import cheng/libp2p/core/types
import cheng/libp2p/identity/did
import cheng/mobile/mobile_capi as capi
import cheng/apps/chain_node/chain_node as chain
import cheng/mobile/hardware/biometric
import cheng/apps/bio/bio_did_chain_node as flow
import cheng/apps/bio/bio_did_mobile_biometric as mobileflow

@importc("cheng_buffer_handle_len_bridge")
fn bioDidMobileSmokeBufferHandleLenBridge(handle: uint64): int32
@importc("cheng_buffer_handle_byte_bridge")
fn bioDidMobileSmokeBufferHandleByteBridge(handle: uint64, idx: int32): int32
@importc("cheng_buffer_handle_release_bridge")
fn bioDidMobileSmokeBufferHandleReleaseBridge(handle: uint64): int32

var bioDidMobileSmokeFeatureCurrent: layout.FixedBytes32
var bioDidMobileSmokeFeatureBad: layout.FixedBytes32

fn bioDidMobileSmokeFeature(seed: int32): layout.FixedBytes32 =
    let raw: Bytes = bytesAlloc(32)
    for i in 0..<32:
        bytesSet(raw, i, ((seed * 31) + (i * 13) + 7) & 255)
    let res = layout.FixedBytes32FromBytes(raw)
    assert(IsOk(res), " bio did mobile smoke: feature build")
    return Value(res)

fn bioDidMobileSmokeCorrupt(feature: layout.FixedBytes32,
                            positions: int32[]): layout.FixedBytes32 =
    var raw: Bytes = layout.FixedBytes32ToBytes(feature)
    for i in 0..<positions.len:
        let pos = positions[i]
        bytesSet(raw, pos, bytesGet(raw, pos) ^ ((0x33 + i) & 255))
    let res = layout.FixedBytes32FromBytes(raw)
    assert(IsOk(res), " bio did mobile smoke: corrupt fixed32")
    return Value(res)

fn bioDidMobileSmokeRequest(requestId: str,
                            didText: str,
                            bindingSeed: str,
                            label: str): mobileflow.BioDidMobileFingerprintRequest =
    var out = mobileflow.BioDidMobileFingerprintRequest()
    out.requestId = requestId
    out.didText = didText
    out.deviceBindingSeedHint = bindingSeed
    out.deviceLabelHint = label
    out.promptTitle = "指纹验证"
    out.promptReason = "验证当前设备并导入 DID"
    return out

fn bioDidMobileSmokeAttestorPrivHex(): str =
    return "60d71049a0cafe01faa9948dc77ee5bc4bd5e05b8e328fdb9cc4c38237250a05"

fn bioDidMobileSmokeAttestorPubKeyHex(): str =
    return "04963c1356849b8478030a6eb572581063ccedf53fda0bc7241247eba977e3b0666e4bf0c12caa47487c2927f83b17d6f9f332481cd2ab0c4885f91fc2a6c547d5"

fn bioDidMobileSmokeScriptAuthorize(feature: layout.FixedBytes32,
                                    bindingSeed: str,
                                    label: str) =
    biometric.BiometricSetScriptedFingerprintAuthorizedSigned(feature,
                                                                bindingSeed,
                                                                label,
                                                                "fingerprint.smoke",
                                                                bioDidMobileSmokeAttestorPrivHex())

fn bioDidMobileSmokeBytesFromHandle(handle: uint64): Bytes =
    var n: int32
    n = bioDidMobileSmokeBufferHandleLenBridge(handle)
    if n <= 0:
        var releaseRc: int32
        releaseRc = bioDidMobileSmokeBufferHandleReleaseBridge(handle)
        return emptyBytes()
    var raw: Bytes = bytesAlloc(n)
    var i = 0
    while i < n:
        var byteVal: int32
        byteVal = bioDidMobileSmokeBufferHandleByteBridge(handle, i)
        assert(byteVal >= 0 && byteVal <= 255,
               " bio did mobile smoke: handle byte range")
        bytesSet(raw, i, byteVal)
        i = i + 1
    var releaseRc: int32
    releaseRc = bioDidMobileSmokeBufferHandleReleaseBridge(handle)
    return raw

fn main(): int32 =
    assert(rand.setRandomSeed(bytesFromString("cheng.bio.did.mobile.seed")),
           " bio did mobile smoke: seed")
    bioDidMobileSmokeFeatureCurrent = bioDidMobileSmokeFeature(9)
    bioDidMobileSmokeFeatureBad = bioDidMobileSmokeCorrupt(bioDidMobileSmokeFeatureCurrent,
                                                           [0, 2, 4, 6, 8, 10, 12, 14, 16])

    biometric.BiometricClearScriptedFingerprintAuthorize()

    var missingNode: chain.ChainNode
    assert(IsOk(chain.ChainNodeInitInto(missingNode, "bio.did.mobile.missing", "bio.did.mobile.addr.1")),
           " chain_node: init")
    let missingRes = mobileflow.BioDidMobileCreateWithFingerprint(
        missingNode,
        bioDidMobileSmokeRequest("missing-create", "", "device.phone.secure", "phone"),
        int64(900)
    )
    assert(IsErr(missingRes), " bio did mobile smoke: missing impl reject")

    var noTrustNode: chain.ChainNode
    assert(IsOk(chain.ChainNodeInitInto(noTrustNode, "bio.did.mobile.notrust", "bio.did.mobile.addr.0")),
           " chain_node: init")
    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.phone.secure",
                                     "phone")
    let noTrustRes = mobileflow.BioDidMobileCreateWithFingerprint(
        noTrustNode,
        bioDidMobileSmokeRequest("create-no-trust", "", "device.phone.secure", "phone"),
        int64(950)
    )
    assert(IsErr(noTrustRes), " bio did mobile smoke: trusted attestor required")

    let trustRes = flow.BioDidSetTrustedAttestorRootHex(bioDidMobileSmokeAttestorPubKeyHex(),
                                                          biometric.BiometricScriptedRootKeyId)
    assert(IsOk(trustRes), " bio did mobile smoke: add trusted attestor")

    let createHandleReq = bioDidMobileSmokeRequest("create-handle", "", "device.phone.secure", "phone")
    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.phone.secure",
                                     "phone")
    let handleAuthReq = mobileflow.BioDidMobileFingerprintAuthorizeReq(createHandleReq, false)
    var handleAuthResp = biometric.BiometricFingerprintAuthorizeResp()
    let handleAuthOk = biometric.BiometricFingerprintAuthorizeBlockingFill(handleAuthResp,
                                                                               createHandleReq.requestId,
                                                                               handleAuthReq)
    assert(IsOk(handleAuthOk), " bio did mobile smoke: handle auth")
    let createWire = capi.MobileCapiBioDidCreateRequestWire(createHandleReq.requestId,
                                                              layout.FixedBytes32Hex(handleAuthResp.feature32),
                                                              handleAuthResp.deviceBindingSeed,
                                                              handleAuthResp.deviceLabel,
                                                              handleAuthResp.sensorId,
                                                              handleAuthResp.hardwareAttestation)
    let createHandle = capi.MobileCapiBioDidCreateWireHandle(createWire)
    assert(createHandle != uint64(0), " bio did mobile smoke: create handle nonzero")
    let createHandlePayload = bioDidMobileSmokeBytesFromHandle(createHandle)
    assert(bytesLen(createHandlePayload) > 32,
           " bio did mobile smoke: create handle payload len")
    let createWirePayload = capi.MobileCapiBioDidCreateWire(createWire)
    let createWirePayloadBytes = bytesFromString(createWirePayload)
    assert(bytesLen(createWirePayloadBytes) > 32,
           " bio did mobile smoke: create wire payload len")
    let createDirectHandle = capi.MobileCapiBioDidCreateHandle(createHandleReq.requestId,
                                                                 layout.FixedBytes32Hex(handleAuthResp.feature32),
                                                                 handleAuthResp.deviceBindingSeed,
                                                                 handleAuthResp.deviceLabel,
                                                                 handleAuthResp.sensorId,
                                                                 handleAuthResp.hardwareAttestation)
    assert(createDirectHandle != uint64(0), " bio did mobile smoke: create direct handle nonzero")
    let createDirectHandlePayload = bioDidMobileSmokeBytesFromHandle(createDirectHandle)
    assert(bytesLen(createDirectHandlePayload) > 32,
           " bio did mobile smoke: create direct handle payload len")
    let createDirectPayload = capi.MobileCapiBioDidCreate(createHandleReq.requestId,
                                                            layout.FixedBytes32Hex(handleAuthResp.feature32),
                                                            handleAuthResp.deviceBindingSeed,
                                                            handleAuthResp.deviceLabel,
                                                            handleAuthResp.sensorId,
                                                            handleAuthResp.hardwareAttestation)
    let createDirectPayloadBytes = bytesFromString(createDirectPayload)
    assert(bytesLen(createDirectPayloadBytes) > 32,
           " bio did mobile smoke: create direct payload len")

    var node: chain.ChainNode
    assert(IsOk(chain.ChainNodeInitInto(node, "bio.did.mobile", "bio.did.mobile.addr")),
           " chain_node: init")
    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.phone.secure",
                                     "phone")
    let createRes = mobileflow.BioDidMobileCreateWithFingerprint(
        node,
        bioDidMobileSmokeRequest("create-phone", "", "device.phone.secure", "phone"),
        int64(1000)
    )
    assert(IsOk(createRes), " bio did mobile smoke: create did")
    let created = Value(createRes)
    let didText = created.document.did
    assert(didText == did.DidIdentityDid(created.identity),
           " bio did mobile smoke: created did stable")
    assert(created.document.devices.len == 1,
           " bio did mobile smoke: create device count")
    assert(created.bundle.bundleSeq == 1,
           " bio did mobile smoke: create bundle seq")
    assert(created.bundle.hardware.requestId == "create-phone",
           " bio did mobile smoke: create request id")
    assert(created.bundle.hardware.sensorId == "fingerprint.smoke",
           " bio did mobile smoke: create sensor id")

    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.phone.secure",
                                     "phone-renamed")
    let sameImportRes = mobileflow.BioDidMobileImportWithFingerprint(
        node,
        bioDidMobileSmokeRequest("import-phone",
                                 didText,
                                 "device.phone.secure",
                                 "phone-renamed"),
        int64(1010)
    )
    assert(IsOk(sameImportRes), " bio did mobile smoke: same device import")
    let sameImport = Value(sameImportRes)
    assert(types.Libp2pPeerIdEqual(created.identity.selfDevice.devicePeerId,
                                     sameImport.identity.selfDevice.devicePeerId),
           " bio did mobile smoke: same device stable peer id")
    assert(sameImport.document.devices.len == 1,
           " bio did mobile smoke: same device no duplicate")
    assert(did.DidWord64Value(sameImport.document.version) == int64(1),
           " bio did mobile smoke: same device version stable")
    assert(sameImport.bundle.bundleSeq == 2,
           " bio did mobile smoke: same device bundle seq")
    assert(sameImport.bundle.hardware.requestId == "import-phone",
           " bio did mobile smoke: import request id")

    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.laptop.secure",
                                     "laptop")
    let laptopImportRes = mobileflow.BioDidMobileImportWithFingerprint(
        node,
        bioDidMobileSmokeRequest("import-laptop",
                                 didText,
                                 "device.laptop.secure",
                                 "laptop"),
        int64(1020)
    )
    assert(IsOk(laptopImportRes), " bio did mobile smoke: new device import")
    let laptopImport = Value(laptopImportRes)
    assert(!types.Libp2pPeerIdEqual(created.identity.selfDevice.devicePeerId,
                                      laptopImport.identity.selfDevice.devicePeerId),
           " bio did mobile smoke: new device new peer id")
    assert(laptopImport.document.devices.len == 2,
           " bio did mobile smoke: new device count")
    assert(did.DidWord64Value(laptopImport.document.version) == int64(2),
           " bio did mobile smoke: new device version bump")
    assert(laptopImport.bundle.bundleSeq == 3,
           " bio did mobile smoke: new device bundle seq")
    assert(!layout.FixedBytes32Equal(laptopImport.bundle.hardware.bindingCid,
                                     sameImport.bundle.hardware.bindingCid),
           " bio did mobile smoke: new bundle new hardware binding")

    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureCurrent,
                                     "device.laptop.secure",
                                     "laptop-renamed")
    let laptopImportAgainRes = mobileflow.BioDidMobileImportWithFingerprint(
        node,
        bioDidMobileSmokeRequest("import-laptop-again",
                                 didText,
                                 "device.laptop.secure",
                                 "laptop-renamed"),
        int64(1030)
    )
    assert(IsOk(laptopImportAgainRes), " bio did mobile smoke: repeat laptop import")
    let laptopImportAgain = Value(laptopImportAgainRes)
    assert(types.Libp2pPeerIdEqual(laptopImport.identity.selfDevice.devicePeerId,
                                     laptopImportAgain.identity.selfDevice.devicePeerId),
           " bio did mobile smoke: repeat laptop stable peer id")
    assert(laptopImportAgain.document.devices.len == 2,
           " bio did mobile smoke: repeat laptop no duplicate")
    assert(did.DidWord64Value(laptopImportAgain.document.version) == int64(2),
           " bio did mobile smoke: repeat laptop version stable")
    assert(laptopImportAgain.bundle.bundleSeq == 4,
           " bio did mobile smoke: repeat laptop bundle seq")

    bioDidMobileSmokeScriptAuthorize(bioDidMobileSmokeFeatureBad,
                                     "device.tablet.secure",
                                     "tablet")
    let badImportRes = mobileflow.BioDidMobileImportWithFingerprint(
        node,
        bioDidMobileSmokeRequest("bad-import",
                                 didText,
                                 "device.tablet.secure",
                                 "tablet"),
        int64(1040)
    )
    assert(IsErr(badImportRes), " bio did mobile smoke: bad fingerprint reject")

    biometric.BiometricClearScriptedFingerprintAuthorize()
    echo(" bio_did_mobile_biometric_smoke ok")
    return 0
