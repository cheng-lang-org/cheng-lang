fn echoFloat(value: float64): float64 =
    return value

fn main(): int32 =
    let zero: float64 = echoFloat(0.0)
    let neg: float64 = echoFloat(-1.5)
    let exp: float64 = echoFloat(1.25e2)
    assert(int64(zero) == 0, " float literal arg: zero")
    assert(int64(neg) == -1, " float literal arg: negative")
    assert(int64(exp) == 125, " float literal arg: exponent")
    echo(" float_literal_scalar_arg_smoke ok")
    return 0
