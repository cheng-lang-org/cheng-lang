import cheng/tests/browser_wasm_probe_moq_build_min as moqbuildprobe
import cheng/tests/browser_wasm_probe_moq_build_core_min as moqbuildcore
import cheng/tests/browser_wasm_probe_moq_object_min as moqobjectprobe
import cheng/tests/browser_wasm_probe_seq_arg_min as seqprobe
import std/strutils as strutil

fn browserHostContractFail(label: str): int32 =
    echo(strutil.Join([" browser host native contract smoke failed: ", label], ""))
    return 1

fn main(): int32 =
    if moqbuildprobe.moqLocalSeqBoxCount() != 2:
        return browserHostContractFail("moqLocalSeqBoxCount")
    if moqbuildprobe.moqResultSeqBoxCount() != 2:
        return browserHostContractFail("moqResultSeqBoxCount")
    if moqbuildprobe.moqBuildRemoteAckCount() != 2:
        return browserHostContractFail("moqBuildRemoteAckCount")
    if moqbuildprobe.moqBuildRemoteAckFirstLen() != 6:
        return browserHostContractFail("moqBuildRemoteAckFirstLen")
    if moqbuildprobe.moqBuildLongPeerRemoteAckCount() != 2:
        return browserHostContractFail("moqBuildLongPeerRemoteAckCount")
    if moqbuildprobe.moqBuildLongPeerRemoteAckFirstLen() != 52:
        return browserHostContractFail("moqBuildLongPeerRemoteAckFirstLen")
    if moqbuildprobe.moqBuildLongPeerWireLen() <= 0:
        return browserHostContractFail("moqBuildLongPeerWireLen")
    if moqbuildcore.moqBuildObjectCount() != 1:
        return browserHostContractFail("moqBuildObjectCount")
    if moqobjectprobe.moqObjectSourceBlockCount() != 1:
        return browserHostContractFail("moqObjectSourceBlockCount")
    if moqobjectprobe.moqObjectErrorText() != "ok":
        return browserHostContractFail("moqObjectErrorText")
    if moqbuildprobe.moqBuildLongBlobObjectCount() != 1:
        return browserHostContractFail("moqBuildLongBlobObjectCount")
    if moqbuildprobe.moqBuildLongBlobDropletCount() <= 0:
        return browserHostContractFail("moqBuildLongBlobDropletCount")
    if moqbuildprobe.moqBuildLongBlobComputedBundleCidLen() != 64:
        return browserHostContractFail("moqBuildLongBlobComputedBundleCidLen")
    if seqprobe.callSeqCount() != 2:
        return browserHostContractFail("callSeqCount")
    if seqprobe.callDirectSeqCount() != 2:
        return browserHostContractFail("callDirectSeqCount")
    if seqprobe.callSplitCount() != 2:
        return browserHostContractFail("callSplitCount")
    if seqprobe.callFirstPartLen() != 6:
        return browserHostContractFail("callFirstPartLen")
    if seqprobe.callFirstTrimmedLen() != 6:
        return browserHostContractFail("callFirstTrimmedLen")
    if seqprobe.callDirectSliceLen() != 6:
        return browserHostContractFail("callDirectSliceLen")
    if seqprobe.callDirectSliceEq() != 1:
        return browserHostContractFail("callDirectSliceEq")
    if seqprobe.callLiteralLen() != 6:
        return browserHostContractFail("callLiteralLen")
    if seqprobe.callLiteralEq() != 1:
        return browserHostContractFail("callLiteralEq")
    if seqprobe.callSeqLiteralFirstLen() != 6:
        return browserHostContractFail("callSeqLiteralFirstLen")
    if seqprobe.callSeqSliceFirstLen() != 6:
        return browserHostContractFail("callSeqSliceFirstLen")
    if seqprobe.callRangeLoopSum() != 21:
        return browserHostContractFail("callRangeLoopSum")
    if seqprobe.callJoinConcatLen() <= 0:
        return browserHostContractFail("callJoinConcatLen")
    echo(" browser host wasm smoke: ok")
    return 0
