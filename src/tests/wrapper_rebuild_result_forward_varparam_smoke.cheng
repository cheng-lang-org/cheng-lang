import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

type
    MiniNode =
        index: consensus.ChainIndex
        eventCids: layout.FixedBytes32[]
        events: consensus.ChainEvent[]
        tipEventCid: layout.FixedBytes32
        nextTick: int64

fn miniMintEvent(node: MiniNode): consensus.ChainEvent =
    return consensus.ChainEventMint(
        7,
        1001,
        layout.FixedBytes32(),
        int64(100),
        1,
        1,
        1,
        node.nextTick
    )

fn miniRebuild(node: var MiniNode) =
    node.tipEventCid = node.eventCids.len > 0 ? node.eventCids[node.eventCids.len - 1] : layout.FixedBytes32()
    node.nextTick = int64(node.eventCids.len + 1)

fn miniApplyVar(node: var MiniNode, event: var consensus.ChainEvent): Result[layout.FixedBytes32] =
    let eventCid = consensus.ChainEventCid(event)
    var nextIndex = node.index
    var decision = consensus.ConsensusDecision()
    consensus.ConsensusApplyChecked(nextIndex, event, eventCid, node.eventCids.len, decision)
    node.index = nextIndex
    if !decision.accepted:
        return Err[layout.FixedBytes32]("mini apply var rebuild rejected")
    if decision.applied:
        add(node.eventCids, eventCid)
        add(node.events, event)
        miniRebuild(node)
    return Ok[layout.FixedBytes32](eventCid)

fn miniMintWrapperVar(node: var MiniNode): Result[layout.FixedBytes32] =
    var event = miniMintEvent(node)
    return miniApplyVar(node, event)

fn main(): int32 =
    var wrapperVar: MiniNode
    wrapperVar = MiniNode()
    let wrapperVarRes = miniMintWrapperVar(wrapperVar)
    assert(wrapperVarRes.ok, "wrapper rebuild result forward varparam: ok")
    assert(wrapperVar.eventCids.len == 1, "wrapper rebuild result forward varparam: cid len")
    assert(wrapperVar.events.len == 1, "wrapper rebuild result forward varparam: event len")
    assert(wrapperVar.index.accountIds.len == 1, "wrapper rebuild result forward varparam: account len")
    assert(wrapperVar.index.balances.len == 1, "wrapper rebuild result forward varparam: balance len")
    assert(layout.FixedBytes32Equal(wrapperVar.tipEventCid, wrapperVarRes.value),
           "wrapper rebuild result forward varparam: tip cid")
    assert(wrapperVar.nextTick == int64(2), "wrapper rebuild result forward varparam: next tick")
    echo(" wrapper_rebuild_result_forward_varparam_smoke ok")
    return 0
