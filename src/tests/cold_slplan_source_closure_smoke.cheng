import cheng/core/backend/system_link_plan as slplan
import cheng/core/tooling/compiler_request as creq

fn main() =
    var plan: slplan.SystemLinkPlanStub
    var err: str
    let ok = slplan.BuildSystemLinkPlanStubWithFields("/Users/lbcheng/cheng-lang",
                                                      "/Users/lbcheng/cheng-lang",
                                                      "/Users/lbcheng/cheng-lang/src/tests/ordinary_zero_exit_fixture.cheng",
                                                      "/tmp/cold_slplan_out",
                                                      "arm64-apple-darwin",
                                                      creq.EmitExe,
                                                      "",
                                                      "",
                                                      plan,
                                                      err)
    assert(ok, "cold slplan ok")
    assert(plan.sourceClosurePaths.len == 1, "cold slplan source closure len")
    assert(plan.ownerModulePaths.len == 1, "cold slplan owner module len")
    assert(plan.packageId == "cheng", "cold slplan package id")
    assert(plan.ownerModulePaths[0] == "cheng/tests/ordinary_zero_exit_fixture", "cold slplan owner module path")
