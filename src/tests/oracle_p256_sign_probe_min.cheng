import std/system
import std/result
import std/crypto/ecnist
import std/crypto/bigint
import std/crypto/sha256
import cheng/std/crypto/fixed256
import cheng/oracle/oracle_types
import cheng/oracle/oracle_plane
import cheng/tests/oracle_smoke_support as support

fn main(): int32 =
    let roundId = int64(10)
    let reporterSlot = 1
    let observedAtMs = oracle_types.OracleRoundStartMs(roundId) + int64(reporterSlot)
    var batch = oracle_plane.OracleSignedBatch()
    batch.version = oracle_types.OracleVersion
    batch.committeeSetId = 1
    batch.reporterSlot = reporterSlot
    batch.roundId = oracle_types.OracleRoundIdFromObservedAtMs(observedAtMs)
    batch.observedAtMs = observedAtMs
    batch.pricesE8 = support.oracleSmokePrices(roundId, reporterSlot)
    let signableRes = oracle_plane.OracleSignedBatchSignableBytes(batch)
    assert(IsOk(signableRes), "sign probe: signable")
    let privBytes = fixed256.scalar256ToBytes(support.oracleSmokePrivateScalar(reporterSlot))
    let dRes = bigint.bigFromBytes(privBytes)
    assert(IsOk(dRes), "sign probe: d")
    let h1 = sha256Digest(Value(signableRes))
    var v = ecnist.p256DeterministicFilledBytes(0x01)
    var kBytes = ecnist.p256DeterministicFilledBytes(0x00)
    let zero = ecnist.bytesFromByte(0x00)
    let one = ecnist.bytesFromByte(0x01)
    let seed0 = ecnist.p256DeterministicConcat4(v, zero, privBytes, h1)
    let inner0: Bytes = bytesAlloc(64 + bytesLen(seed0))
    var i: int32
    while i < 64:
        bytesSet(inner0, i, 0x36)
        i = i + 1
    i = 0
    while i < bytesLen(seed0):
        bytesSet(inner0, 64 + i, bytesGet(seed0, i))
        i = i + 1
    kBytes = ecnist.hmacSha256(kBytes, seed0)
    v = ecnist.hmacSha256(kBytes, v)
    let seed1 = ecnist.p256DeterministicConcat4(v, one, privBytes, h1)
    kBytes = ecnist.hmacSha256(kBytes, seed1)
    v = ecnist.hmacSha256(kBytes, v)
    let probeV = ecnist.hmacSha256(kBytes, v)
    let kRes = ecnist.p256DeterministicK(Value(dRes), Value(signableRes))
    if IsErr(kRes):
        echo("k_err=" + Error(kRes))
        return 1
    let k = Value(kRes)
    let kBytes = bigint.bigToBytes(k, 32)
    echo("k=" + bytesToHex(kBytes))
    let nRes = ecnist.nMod(k)
    assert(IsOk(nRes), "sign probe: nmod")
    let n = Value(nRes)
    let nBytes = bigint.bigToBytes(n, 32)
    echo("nmod=" + bytesToHex(nBytes))
    let invRes = ecnist.nModInv(k)
    if IsErr(invRes):
        echo("inv_err=" + Error(invRes))
        return 1
    let invBytes = bigint.bigToBytes(Value(invRes), 32)
    echo("inv=" + bytesToHex(invBytes))
    return 0
