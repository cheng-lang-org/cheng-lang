import std/system
import std/cmdline as cmdline
import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/libp2p/core/types
import cheng/libp2p/transports/quic_transport
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net

fn main(): int32 =
    var port = cmdline.ReadInt32FlagOrDefault("--port", -1)
    assert(port > 0, " libp2p quic twoproc: client port")
    var client: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(client, "quic.twoproc.client", "quic.twoproc")),
           " chain_node: init")
    var recvRes = quic_transport.Libp2pQuicRecvPayloadOnce("127.0.0.1",
                                                             port,
                                                             types.Libp2pProtocolSync)
    assert(recvRes.ok, " libp2p quic twoproc: client recv")
    var snapshot: node.ChainNodeServeSnapshot
    var snapshotRes = net.ChainNodeLibp2pDecodeSnapshotInto(recvRes.value, snapshot)
    assert(snapshotRes.ok, " libp2p quic twoproc: client decode")
    var syncRes = node.ChainNodeSyncOnce(client, snapshot)
    assert(syncRes.ok, " libp2p quic twoproc: client sync")
    assert(syncRes.value, " libp2p quic twoproc: client changed")
    var aliceRes = node.ChainNodeBalance(client, 9, 1001)
    var bobRes = node.ChainNodeBalance(client, 9, 2002)
    assert(aliceRes.ok, " libp2p quic twoproc: client alice")
    assert(bobRes.ok, " libp2p quic twoproc: client bob")
    assert(aliceRes.value == int64(55), " libp2p quic twoproc: alice 55")
    assert(bobRes.value == int64(33), " libp2p quic twoproc: bob 33")
    var clientSnapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(clientSnapshot, client)
    assert(layout.fixedBytes32Equal(clientSnapshot.tipEventCid, snapshot.tipEventCid),
        " libp2p quic twoproc: tip cid")
    assert(layout.fixedBytes32Equal(clientSnapshot.forest.forestCid, snapshot.forest.forestCid),
        " libp2p quic twoproc: forest cid")
    assert(anti.AntiEntropySignatureEqual(clientSnapshot.signature, snapshot.signature),
        " libp2p quic twoproc: signature")
    echo(" libp2p_quic_twoproc_client ok")
    return 0
