import std/strutils as strutil
importc fn surfaceBridge(payload: str): str

fn surfaceHelper(payload: str): str =
    return payload

fn surface(flag: bool): Result[int32] =
    let picked = flag ? 7 : 9
    let direct = if flag: picked else: 11
    let okRes = Ok[int32](direct)
    let settled = okRes?
    let openRange = 0..<4
    let closedRange = 1..5
    let rows = [Fmt"picked={intToStr(settled)}", strutil.Join(["span", intToStr(picked)], "")]
    let filtered = [row for row in rows if row != ""]
    let rendered = strutil.Join(filtered, "")
    let imported = surfaceBridge(rendered)
    let wrapped = surfaceHelper(imported)
    manifest.sourceAddrs.add(wrapped)
    return filtered.len > 0 ? Ok[int32](settled) : Err[int32](wrapped)

type
    SurfaceWrap = object
        count: int32

    SurfacePair = tuple[a: int32]

fn surfaceDefaults(): int32 =
    let localCount = 13
    let localPair = 17
    let wrap = SurfaceWrap()
    let pair = SurfacePair()
    let seq: int32[]
    let fixed: int32[2]
    let builtWrap = SurfaceWrap(count: localCount)
    let builtPair = SurfacePair(a: localPair)
    return wrap.count + pair.a + seq.len + fixed[0] + builtWrap.count + builtPair.a

fn surfaceStringify(wrap: SurfaceWrap): str =
    let direct = $wrap
    let paren = $(wrap)
    return strutil.Join([direct, paren], "")
