fn EmptyText(): str =
    var out: str
    return out

fn UseText(value: str): int32 =
    return 0

fn CountOne(): int32 =
    return 1

fn UseTextAgain(value: str): int32 =
    return 0

fn Dispatch(value: str, count: int32): int32 =
    return count

fn main(): int32 =
    let value = EmptyText()
    UseText(value)
    let count = CountOne()
    if count <= 0:
        UseTextAgain(value)
        return 0
    return Dispatch(value, count)
