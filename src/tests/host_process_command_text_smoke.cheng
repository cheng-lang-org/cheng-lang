import std/os_host_process as hostos

fn main(): int32 =
    let arg0 = "min ok"
    let arg1 = "O'Hara"
    let env0 = "KEY=O'Hara value"
    let command: str = hostos.OsHostProcessCommandText("/bin/echo", [arg0, arg1], [env0])
    let expected = "env 'KEY=O'\"'\"'Hara value' '/bin/echo' 'min ok' 'O'\"'\"'Hara'"
    assert(command == expected, "v3 hostos command text")
    echo("v3 host_process_command_text_smoke ok")
    return 0
