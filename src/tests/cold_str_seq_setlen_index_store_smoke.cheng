fn main() =
    var out: str[]
    setLen(out, 3)
    out[0] = "zero"
    out[1] = "one"
    out[2] = "two"
    assert(out.len == 3, "cold str seq setlen len")
    assert(out[0] == "zero", "cold str seq setlen item0")
    assert(out[1] == "one", "cold str seq setlen item1")
    assert(out[2] == "two", "cold str seq setlen item2")
