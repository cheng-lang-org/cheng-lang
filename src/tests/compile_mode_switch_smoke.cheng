import cheng/core/backend/compile_mode_switch as cms
import std/strings

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn main(): int32 =
    let devMode = cms.CompileModeDetect("arm64-apple-darwin", "exe", 4, "dev")
    let c1 = check(devMode.mode == cms.CompileModeDev, 11)
    if c1 != 0: return c1
    let c2 = check(devMode.isDirectExe, 12)
    if c2 != 0: return c2
    let c3 = check(devMode.isHotPatch, 13)
    if c3 != 0: return c3

    let relMode = cms.CompileModeDetect("arm64-apple-darwin", "exe", 1, "release")
    let c4 = check(relMode.mode == cms.CompileModeRelease, 21)
    if c4 != 0: return c4
    let c5 = check(!relMode.isDirectExe, 22)
    if c5 != 0: return c5
    let c6 = check(!relMode.isHotPatch, 23)
    if c6 != 0: return c6

    let bsMode = cms.CompileModeDetect("arm64-apple-darwin", "exe", 1, "bootstrap")
    let c7 = check(bsMode.mode == cms.CompileModeBootstrap, 31)
    if c7 != 0: return c7

    let autoDev = cms.CompileModeDetect("arm64-apple-darwin", "exe", 4, "")
    let c8 = check(autoDev.mode == cms.CompileModeDev, 41)
    if c8 != 0: return c8

    let autoRel = cms.CompileModeDetect("x86_64-unknown-linux-gnu", "exe", 4, "")
    let c9 = check(autoRel.mode == cms.CompileModeRelease, 42)
    if c9 != 0: return c9

    let c10 = check(cms.CompileModeText(cms.CompileModeDev) == "dev", 51)
    if c10 != 0: return c10
    let c11 = check(cms.CompileModeText(cms.CompileModeRelease) == "release", 52)
    if c11 != 0: return c11
    let c12 = check(cms.CompileModeText(cms.CompileModeBootstrap) == "bootstrap", 53)
    if c12 != 0: return c12

    let c13 = check(cms.CompileModeBoolText(true) == "true", 61)
    if c13 != 0: return c13
    let c14 = check(cms.CompileModeBoolText(false) == "false", 62)
    if c14 != 0: return c14

    let report = cms.CompileModeReport(devMode)
    let c15 = check(strings.Len(report) > 0, 71)
    if c15 != 0: return c15

    var hotPatchContract: cms.CompileModeContract
    hotPatchContract.requireHotPatch = true
    let c16 = check(cms.CompileModeGateCheck(devMode, hotPatchContract), 81)
    if c16 != 0: return c16

    var crossContract: cms.CompileModeContract
    crossContract.requireCrossCompile = true
    let c17 = check(!cms.CompileModeGateCheck(devMode, crossContract), 82)
    if c17 != 0: return c17

    var detContract: cms.CompileModeContract
    detContract.requireDeterminism = true
    let c18 = check(cms.CompileModeGateCheck(relMode, detContract), 83)
    if c18 != 0: return c18

    var bsContract: cms.CompileModeContract
    bsContract.allowBootstrap = true
    let c19 = check(cms.CompileModeGateCheck(bsMode, bsContract), 84)
    if c19 != 0: return c19

    echo("compile_mode_switch_smoke ok")
    return 0
