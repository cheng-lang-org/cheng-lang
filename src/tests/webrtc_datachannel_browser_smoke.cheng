import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/libp2p/core/types
import cheng/libp2p/protocols/webrtc_signal as signal
import cheng/libp2p/transports/webrtc_transport

fn main(): int32 =
    webrtc_transport.Libp2pWebrtcTransportResetStats()

    var addr: types.Libp2pMultiaddr
    addr.host = "203.0.113.142"
    addr.port = 9452
    addr.transport = types.Libp2pTransportWebrtc
    addr.networkDomain = types.Libp2pNetworkDomainBrowserWebrtc
    addr.visibility = types.Libp2pVisibilityPublic

    var cfg: webrtc_transport.Libp2pWebrtcTransportConfig
    cfg.dataChannelLabel = "cheng-browser-data"

    var browserSession: webrtc_transport.Libp2pWebrtcBrowserSession
    let openRes = webrtc_transport.Libp2pWebrtcBrowserSessionOpenInto(browserSession, cfg, addr)
    assert(IsOk(openRes), " webrtc datachannel browser: session open")
    let request1 = bytesFromString("browser-datachannel-request-1")
    let response1 = bytesFromString("browser-datachannel-response-1")
    let request2 = bytesFromString("browser-datachannel-request-2")
    let response2 = bytesFromString("browser-datachannel-response-2")
    var clientResponse1: Bytes
    var clientResponse2: Bytes
    let exchange1 = webrtc_transport.Libp2pWebrtcBrowserSessionExchange(browserSession,
                                                                           types.Libp2pProtocolContent,
                                                                           request1,
                                                                           response1,
                                                                           clientResponse1)
    assert(IsOk(exchange1), " webrtc datachannel browser: exchange1")
    let exchange2 = webrtc_transport.Libp2pWebrtcBrowserSessionExchange(browserSession,
                                                                           types.Libp2pProtocolSync,
                                                                           request2,
                                                                           response2,
                                                                           clientResponse2)
    assert(IsOk(exchange2), " webrtc datachannel browser: exchange2")
    assert(bytesEqual(clientResponse1, response1), " webrtc datachannel browser: payload1")
    assert(bytesEqual(clientResponse2, response2), " webrtc datachannel browser: payload2")
    assert(webrtc_transport.Libp2pWebrtcBrowserDatachannelOpenCountNow() == 1,
        " webrtc datachannel browser: open count")
    assert(webrtc_transport.Libp2pWebrtcBrowserDatachannelRequestCountNow() == 2,
        " webrtc datachannel browser: request count")
    assert(webrtc_transport.Libp2pWebrtcNativeDatachannelOpenCountNow() == 0,
        " webrtc datachannel browser: native open count")
    assert(webrtc_transport.Libp2pWebrtcLoopbackRequestResponseCountNow() == 0,
        " webrtc datachannel browser: loopback count")
    assert(webrtc_transport.Libp2pWebrtcLastProtocolNow() == types.Libp2pProtocolSync,
        " webrtc datachannel browser: last protocol")
    assert(!webrtc_transport.Libp2pWebrtcLastRelayOnlyNow(),
        " webrtc datachannel browser: relay only")
    assert(!layout.FixedBytes32Equal(webrtc_transport.Libp2pWebrtcLastSessionIdNow(),
                                     layout.FixedBytes32()),
        " webrtc datachannel browser: last session")
    assert(webrtc_transport.Libp2pWebrtcBrowserSessionActiveCountNow() == 1,
        " webrtc datachannel browser: active sessions")

    var signalSession: signal.Libp2pWebrtcSignalSession
    let applyRes = signal.Libp2pWebrtcSignalTranscriptApply(signalSession, browserSession.signalWire)
    assert(IsOk(applyRes), " webrtc datachannel browser: signal apply")
    assert(signalSession.ready, " webrtc datachannel browser: session ready")
    assert(signalSession.offerSeen, " webrtc datachannel browser: offer")
    assert(signalSession.answerSeen, " webrtc datachannel browser: answer")
    assert(signalSession.candidateTexts.len == 2, " webrtc datachannel browser: candidate count")
    assert(layout.FixedBytes32Equal(signalSession.sessionId, webrtc_transport.Libp2pWebrtcLastSessionIdNow()),
        " webrtc datachannel browser: session id")
    let closeRes = webrtc_transport.Libp2pWebrtcBrowserSessionClose(browserSession)
    assert(IsOk(closeRes), " webrtc datachannel browser: close")
    assert(webrtc_transport.Libp2pWebrtcBrowserSessionActiveCountNow() == 0,
        " webrtc datachannel browser: active sessions closed")

    echo(" webrtc_datachannel_browser_smoke ok")
    return 0
