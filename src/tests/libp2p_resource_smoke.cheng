import std/system
import std/rawbytes
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/protocols/identify as identify
import cheng/libp2p/transports/tcp_transport
import cheng/libp2p/host/host
import cheng/tests/smoke_ports

fn main(): int32 =
    var server = host.Libp2pHostInit("resource.server")
    var trustedClient = host.Libp2pHostInit("resource.trusted.client")
    var publicClient = host.Libp2pHostInit("resource.public.client")

    host.Libp2pHostSetTrustedInfra(server, true)
    host.Libp2pHostSetTrustedInfra(trustedClient, true)
    host.Libp2pRegisterHandler(server, types.Libp2pProtocolIdentify)
    host.Libp2pRegisterHandler(trustedClient, types.Libp2pProtocolIdentify)
    host.Libp2pRegisterHandler(publicClient, types.Libp2pProtocolIdentify)

    var serverAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(serverAddr, "127.0.0.1", smoke_ports.SmokeLabelPort(6321))
    let listenRes = host.Libp2pListen(server, serverAddr)
    assert(IsOk(listenRes), " libp2p resource: server listen")

    var trustedAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(trustedAddr, "127.0.0.1", smoke_ports.SmokeLabelPort(6322))
    let trustedListenRes = host.Libp2pListen(trustedClient, trustedAddr)
    assert(IsOk(trustedListenRes), " libp2p resource: trusted listen")

    let dialTrustedRes = host.Libp2pDial(trustedClient,
                                           server.selfPeerId,
                                           serverAddr,
                                           overlay.OverlayRoleEdgeRelayStore)
    assert(IsOk(dialTrustedRes), " libp2p resource: trusted dial")
    let dialBackRes = host.Libp2pDial(server,
                                        trustedClient.selfPeerId,
                                        trustedAddr,
                                        overlay.OverlayRoleRegionalRouter)
    assert(IsOk(dialBackRes), " libp2p resource: server dial back")
    host.Libp2pSetPeerTrustedInfra(server, trustedClient.selfPeerId, true)
    host.Libp2pSetPeerTrustedInfra(trustedClient, server.selfPeerId, true)
    let localTrustedRes = host.Libp2pIdentifyResourcesForPeer(server, trustedClient.selfPeerId)
    assert(IsOk(localTrustedRes), " libp2p resource: local trusted visible")
    let identifyPayload = identify.Libp2pIdentifyRequestEncode()
    let localServeRes = host.Libp2pServePayloadFromPeer(server,
                                                          trustedClient.selfPeerId,
                                                          types.Libp2pProtocolIdentify,
                                                          identifyPayload)
    assert(IsOk(localServeRes), " libp2p resource: local identify serve")
    var localServePayload: Bytes
    localServePayload = Value(localServeRes)
    var localDecoded: types.Libp2pNodeResource
    let localDecodeRes = identify.Libp2pIdentifyResponseDecodeFill(localDecoded,
                                                                     localServePayload)
    assert(IsOk(localDecodeRes), " libp2p resource: local identify decode")
    let localTcpRes = tcp_transport.Libp2pTcpLoopbackRequestResponseRaw(types.Libp2pProtocolIdentify,
                                                                          identifyPayload.data,
                                                                          identifyPayload.len,
                                                                          localServePayload.data,
                                                                          localServePayload.len)
    assert(IsOk(localTcpRes), " libp2p resource: local tcp rr")
    let localTcpPayload = Value(localTcpRes)
    assert(bytesLen(localTcpPayload) == bytesLen(localServePayload),
        " libp2p resource: local tcp rr len")
    let responseMagic = bytesFromString("cheng.identify.resource")
    for i in 0..<bytesLen(responseMagic):
        assert(bytesGet(localTcpPayload, i) == bytesGet(responseMagic, i),
            " libp2p resource: local tcp rr magic")
    var localTcpDecoded: types.Libp2pNodeResource
    let localTcpDecodeRes = identify.Libp2pIdentifyResponseDecodeFill(localTcpDecoded,
                                                                        localTcpPayload)
    assert(IsOk(localTcpDecodeRes), " libp2p resource: local tcp rr decode")

    var sample: types.Libp2pNodeResource
    let identifyRes = host.Libp2pIdentifyRequest(trustedClient,
                                                   server,
                                                   server.selfPeerId,
                                                   sample)
    assert(IsOk(identifyRes), " libp2p resource: trusted identify")
    assert(sample.sampledAtEpochSeconds > 0, " libp2p resource: sampled time")
    assert(sample.cpuLogicalCores > 0, " libp2p resource: cpu cores")
    assert(sample.memoryTotalBytes > int64(0), " libp2p resource: memory total")
    assert(sample.memoryAvailableBytes > int64(0), " libp2p resource: memory available")
    assert(sample.memoryAvailableBytes <= sample.memoryTotalBytes,
        " libp2p resource: memory range")
    assert(sample.diskTotalBytes > int64(0), " libp2p resource: disk total")
    assert(sample.diskAvailableBytes > int64(0), " libp2p resource: disk available")
    assert(sample.diskAvailableBytes <= sample.diskTotalBytes,
        " libp2p resource: disk range")
    if sample.gpuDeviceCount > 0:
        assert(sample.gpuCoreCount > 0, " libp2p resource: gpu cores")
    if sample.npuDeviceCount > 0:
        assert(sample.npuCoreCount > 0, " libp2p resource: npu cores")

    var cached: types.Libp2pNodeResource
    assert(host.Libp2pPeerResourcesFill(cached, trustedClient, server.selfPeerId),
        " libp2p resource: cached peer sample")
    assert(cached.cpuLogicalCores == sample.cpuLogicalCores,
        " libp2p resource: cached cpu")
    assert(cached.memoryTotalBytes == sample.memoryTotalBytes,
        " libp2p resource: cached memory")
    assert(cached.diskTotalBytes == sample.diskTotalBytes,
        " libp2p resource: cached disk")
    assert(cached.gpuCoreCount == sample.gpuCoreCount,
        " libp2p resource: cached gpu")
    assert(cached.npuCoreCount == sample.npuCoreCount,
        " libp2p resource: cached npu")

    let publicDialRes = host.Libp2pDial(publicClient,
                                          server.selfPeerId,
                                          serverAddr,
                                          overlay.OverlayRoleEdgeRelayStore)
    assert(IsOk(publicDialRes), " libp2p resource: public dial")
    var denied: types.Libp2pNodeResource
    let deniedRes = host.Libp2pIdentifyRequest(publicClient,
                                                 server,
                                                 server.selfPeerId,
                                                 denied)
    assert(IsErr(deniedRes), " libp2p resource: public denied")

    echo(" libp2p_resource_smoke ok")
    return 0
