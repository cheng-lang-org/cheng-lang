import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

fn main(): int32 =
    var index = consensus.ChainIndex()
    let zeroCid = layout.FixedBytes32()
    let event = consensus.ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let eventCid = consensus.ChainEventCid(event)
    var decision = consensus.ConsensusDecision()
    decision.eventCid = eventCid
    consensus.ConsensusApplyMint(index, event, eventCid, 0, decision)
    assert(decision.accepted, " consensus apply mint: accepted")
    assert(decision.applied, " consensus apply mint: applied")
    assert(index.accountIds.len == 1, " consensus apply mint: account len")
    assert(index.accountIds[0] == 1001, " consensus apply mint: account")
    assert(index.balances[0] == int64(100), " consensus apply mint: balance")
    echo(" consensus_apply_mint_smoke ok")
    return 0
