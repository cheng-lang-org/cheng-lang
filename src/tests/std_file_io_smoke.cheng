# std file/process IO smoke: runtime-stable os/process surface

import std/system
import std/os as os
import std/os_host_process as hostos
import std/strutils as strutil

fn main() =
    let tmpRoot: str = os.GetEnvDefault("STD_BASELINE_TMPDIR", "artifacts/std_file_io_smoke_runtime")
    os.CreateDir(tmpRoot)
    assert(os.DirExists(tmpRoot), "std/os createDir")

    let textPath: str = os.JoinPath(tmpRoot, "data.txt")
    os.WriteFile(textPath, "cheng-file")
    assert(os.FileExists(textPath), "std/os fileExists")
    assert(os.ReadFile(textPath) == "cheng-file", "std/os readFile")

    var readIntoText: str
    let _ = os.ReadFileInto(textPath, readIntoText)
    assert(readIntoText == "cheng-file", "std/os readFileInto")

    let bytesPath: str = os.JoinPath(tmpRoot, "bytes.txt")
    let payload: uint8[] = [uint8(97), uint8(98), uint8(99)]
    os.WriteFileBytes(bytesPath, payload)
    assert(os.ReadFile(bytesPath) == "abc", "std/os writeFileBytes")

    let renamedPath: str = os.JoinPath(tmpRoot, "renamed.txt")
    assert(os.RenameFile(textPath, renamedPath), "std/os renameFile")
    assert(os.FileExists(renamedPath), "std/os renameFile exists")

    let split: SplitFileResult = os.SplitFile(renamedPath)
    assert(split.dir == tmpRoot, "std/os splitFile dir")
    assert(split.name == "renamed", "std/os splitFile name")
    assert(split.ext == ".txt", "std/os splitFile ext")
    assert(os.JoinPath(tmpRoot, "renamed.txt") == renamedPath, "std/os joinPath")

    let walkItems: seq_WalkDirEntry = os.WalkDir(tmpRoot)
    assert(walkItems.len >= 1, "std/os walkDir")
    let walkPaths: str[] = os.WalkDirRec(tmpRoot)
    assert(walkPaths.len >= 1, "std/os walkDirRec")

    let cmdRes: ExecCmdResult = os.ExecCmdEx("printf std-file-io", uint64(0), "")
    assert(os.ExecCmdResultExitCode(cmdRes) == 0, "std/os execCmdEx rc")
    assert(os.ExecCmdResultOutput(cmdRes) == "std-file-io", "std/os execCmdEx out")

    let capArgs: str[] = ["capture-ok"]
    var capEnv: str[]
    let capRes: os.ExecCmdResult = hostos.ExecFileCapture("/bin/echo", capArgs, capEnv, "", false, 5)
    assert(os.ExecCmdResultExitCode(capRes) == 0, "std/os execFileCapture rc")
    assert(strutil.Strip(os.ExecCmdResultOutput(capRes)) == "capture-ok", "std/os execFileCapture out")

    assert(os.RemoveFile(renamedPath), "std/os removeFile")
    assert(os.RemoveFile(bytesPath), "std/os removeFile bytes")
    os.RemoveDir(tmpRoot)
    assert(! os.DirExists(tmpRoot), "std/os removeDir")
