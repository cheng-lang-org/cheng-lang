// Ownership proof driver: exercises OwnershipCtx with
// transfer/borrow/release scenarios.
// Phase 5 milestone: ownership-on proof witness.

module ownership_proof_driver

import cheng/core/analysis/ownership as own

fn check_eq(actual: int32, expected: int32, label: str): int32 =
    if actual == expected: return 0
    echo(Fmt("FAIL {label}: expected {IntToStr(expected)}, got {IntToStr(actual)}"))
    return 1

fn check_true(cond: bool, label: str): int32 =
    if cond: return 0
    echo(Fmt("FAIL {label}: expected true"))
    return 1

fn main(): int32 =
    var errs: int32 = 0

    // Test 1: legal transfer Owned→Owned
    var ctx = own.OwnershipCtxNew()
    let a: int32 = 1
    let ok = own.OwnershipCtxTransfer(ctx, a, a)
    errs = errs + check_eq(int32(ok), int32(own.Ok), "legal transfer")

    // Test 2: double move (transfer consumed var again)
    let doubleMove = own.OwnershipCtxTransfer(ctx, a, a)
    errs = errs + check_eq(int32(doubleMove), int32(own.ErrDoubleMove), "double move")

    // Test 3: shared borrow
    var ctx2 = own.OwnershipCtxNew()
    let b: int32 = 2
    let sharedOk = own.OwnershipCtxBorrowShared(ctx2, b, b)
    errs = errs + check_eq(int32(sharedOk), int32(own.Ok), "shared borrow")

    // Test 4: borrow then move fails
    var ctx3 = own.OwnershipCtxNew()
    let c: int32 = 3
    let _ = own.OwnershipCtxBorrowShared(ctx3, c, c)
    let moveAfterBorrow = own.OwnershipCtxTransfer(ctx3, c, c)
    errs = errs + check_eq(int32(moveAfterBorrow), int32(own.ErrMoveAfterBorrow), "move after borrow")

    // Test 5: release shared borrow, then transfer OK
    var ctx4 = own.OwnershipCtxNew()
    let d: int32 = 4
    let _ = own.OwnershipCtxBorrowShared(ctx4, d, d)
    let releaseOk = own.OwnershipCtxReleaseShared(ctx4, d)
    errs = errs + check_eq(int32(releaseOk), int32(own.Ok), "release shared")
    let transferOk = own.OwnershipCtxTransfer(ctx4, d, d)
    errs = errs + check_eq(int32(transferOk), int32(own.Ok), "transfer after release")

    // Test 6: noalias verification
    var ctx5 = own.OwnershipCtxNew()
    let e: int32 = 5
    let _ = own.OwnershipCtxTransfer(ctx5, e, e)
    let naOk = own.OwnershipCtxVerifyNoAlias(ctx5, e)
    errs = errs + check_true(naOk, "noalias after transfer")

    if errs == 0:
        echo("ownership_proof_driver ok")
        return 0
    echo(Fmt("ownership_proof_driver: {IntToStr(errs)} errors"))
    return errs
