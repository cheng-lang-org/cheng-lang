# cfg_regression_gate_smoke.cheng
# Regression gate for the general CFG codegen pipeline.
# Compiles ALL existing minimal fixtures through the pipeline
# (system_link_plan -> lowering_plan -> primary_object_plan)
# and verifies that missing-reasons are cleared.
#
# This smoke uses the pipeline API directly and does not shell out.
#
# Fixtures verified:
#   ordinary_zero_exit_fixture  -- zero-return entry point
#   int32_const_return_direct_fixture -- call-chain with const return
#   float64_mul_backend_smoke  -- float64 multiplication with cmp
#   function_task_contract_smoke -- function task types contract
#   cfg_body_ir_contract_smoke -- BodyIR construction contract
#   cfg_lowering_smoke -- typed stmt to CFG lowering contract
#   cfg_multi_stmt_smoke -- multi-statement CFG contract
#   cfg_result_project_smoke -- Result projection CFG contract
#   cfg_return_call_local_arg_smoke -- inferred let-call local passed into return-call
#   void_tail_if_fallthrough_fixture -- void function tail-if must keep fallthrough epilogue

import std/os
import cheng/core/tooling/compiler_request as creq
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/backend/primary_object_plan as pobj

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn compilePlan(rootDir: str,
               sourceName: str,
               emitKind: int32): int32 =
    let sourcePath = os.JoinPath(rootDir, "src/tests", sourceName)
    let outputPath = os.JoinPath(rootDir, "artifacts/regression_gate", sourceName)
    let req = creq.CompilerRequestNew(
        rootDir,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    if !slplan.BuildSystemLinkPlanStub(rootDir, req, linkPlan, err):
        return 2
    if linkPlan.missingReasons.len > 0:
        return 3
    var loweringPlan: lower.LoweringPlanStub
    if !lower.BuildLoweringPlanStub(linkPlan, loweringPlan, err):
        return 4
    if loweringPlan.missingReasons.len > 0:
        return 5
    let primary = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    if primary.missingReasons.len > 0:
        return 6
    if primary.error.functionName != "":
        return 7
    return 0

fn main(): int32 =
    let rootDir = os.GetCurrentDir()

    let artifactsDir = os.JoinPath(rootDir, "artifacts/regression_gate")
    if os.DirExists(artifactsDir):
        discard os.RemoveDir(artifactsDir)
    discard os.Mkdir(artifactsDir)

    let c1 = check(compilePlan(rootDir, "ordinary_zero_exit_fixture.cheng", creq.EmitExe) == 0, 11)
    if c1 != 0: return c1

    let c2 = check(compilePlan(rootDir, "int32_const_return_direct_fixture.cheng", creq.EmitExe) == 0, 12)
    if c2 != 0: return c2

    let c3 = check(compilePlan(rootDir, "float64_mul_backend_smoke.cheng", creq.EmitExe) == 0, 13)
    if c3 != 0: return c3

    let c4 = check(compilePlan(rootDir, "function_task_contract_smoke.cheng", creq.EmitExe) == 0, 14)
    if c4 != 0: return c4

    let c5 = check(compilePlan(rootDir, "cfg_body_ir_contract_smoke.cheng", creq.EmitExe) == 0, 15)
    if c5 != 0: return c5

    let c6 = check(compilePlan(rootDir, "cfg_lowering_smoke.cheng", creq.EmitExe) == 0, 16)
    if c6 != 0: return c6

    let c7 = check(compilePlan(rootDir, "cfg_multi_stmt_smoke.cheng", creq.EmitExe) == 0, 17)
    if c7 != 0: return c7

    let c8 = check(compilePlan(rootDir, "cfg_result_project_smoke.cheng", creq.EmitExe) == 0, 18)
    if c8 != 0: return c8

    let c9 = check(compilePlan(rootDir, "cfg_return_call_local_arg_smoke.cheng", creq.EmitExe) == 0, 19)
    if c9 != 0: return c9

    let c10 = check(compilePlan(rootDir, "void_tail_if_fallthrough_fixture.cheng", creq.EmitExe) == 0, 20)
    if c10 != 0: return c10

    echo(" cfg_regression_gate_smoke ok")
    return 0
