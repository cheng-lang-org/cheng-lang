import cheng/tests/call_hir_closure_visible_mid

fn main(): int32 =
    let payload = "visible"
    let visibleLen = TransitiveVisibleLen(payload)
    let visibleEcho = TransitiveVisibleBufferEcho(payload)
    assert(visibleLen == len(visibleEcho), " call hir matrix: closure visible match")
    return 0
