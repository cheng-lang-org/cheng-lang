import std/os
import std/system
import std/strings
import cheng/core/tooling/path as chengpath
import std/strutils as strutil

fn printLine(text: str) =
    puts(panicCString(text))

fn printI32(label: str, value: int32) =
    printLine(strutil.Join([label, strings.IntToStr(value)], ""))

fn printI64(label: str, value: int64) =
    printLine(strutil.Join([label, strings.Int64ToStr(value)], ""))

fn CalcSlice(text: str, start: int32, stop: int32): str =
    if strings.Len(text) == 0:
        return ""
    var s: int32 = start
    var e: int32 = stop
    if s < 0:
        s = 0
    let n: int32 = strings.Len(text)
    if e < s || s >= n:
        return ""
    if e >= n:
        e = n - 1
    let count: int32 = e - s + 1
    return strings.SliceBytes(text, s, count)

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/parentdir_probe")
    let sliced: str = CalcSlice(outDir, 0, 34)
    printI64("out.data=", int64(uint64(outDir.data)))
    printI32("out.len=", outDir.len)
    printI64("sliced.data=", int64(uint64(sliced.data)))
    printI32("sliced.len=", sliced.len)
    printI32("sliced.flags=", sliced.flags)
    return 0
