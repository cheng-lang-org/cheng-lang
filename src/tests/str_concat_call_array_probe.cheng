import std/os

fn StrConcatLoweringFlag(prefix: str, value: str): str =
    var parts: str[]
    add(parts, prefix)
    add(parts, value)
    return Fmt(parts)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let args = [
        "system-link-exec",
        StrConcatLoweringFlag("--root:", root),
        "--emit:exe"
    ]
    echo(args[1])
    return 0
