import cheng/core/tooling/compiler_runtime as crun

fn main(): int32 =
    let root = "/tmp/cheng-lang"
    let sep = "/"
    let rel = "src/core/tooling/compiler_main.cheng"
    let rootSlash = Fmt"{root}{sep}"
    assert(rootSlash == "/tmp/cheng-lang/", "concat root slash")
    assert(Fmt"{rootSlash}{rel}" ==
           "/tmp/cheng-lang/src/core/tooling/compiler_main.cheng",
           "concat rel")
    assert(crun.CompilerRuntimePath(root, rel) ==
           "/tmp/cheng-lang/src/core/tooling/compiler_main.cheng",
           "runtime path")
    echo("compiler_runtime_path_probe ok")
    return 0
