import std/system
import cheng/libp2p/transports/tailnet_transport as tsnet

fn main(): int32 =
    var cfg: tsnet.Libp2pTailnetTransportConfig
    cfg.controlUrl = "https://headscale.example"
    cfg.controlEndpoint = "https://headscale.example/control"
    cfg.relayEndpoint = "https://derp.sfo.example:443"
    cfg.controlProbeEndpoint = "testdata/tailnet/headscale_control_ready.json"
    cfg.relayProbeEndpoint = "testdata/tailnet/derp_ready.json"
    cfg.localPeerId = "tailnet-runtime-headscale-probe"
    tsnet.Libp2pTailnetConfigSetHeadscale(cfg,
                                            "infra",
                                            "noise-pub-probe",
                                            12,
                                            "sfo",
                                            "San Francisco",
                                            "derp.sfo.example",
                                            true)

    var transport = tsnet.Libp2pTailnetTransportInit(cfg)
    tsnet.Libp2pTailnetProviderStart(transport)
    assert(transport.runtimeHandle != uint64(0), " tailnet runtime probe: handle")
    assert(tsnet.Libp2pTailnetProviderRuntimeActiveCountNow() == 1,
        " tailnet runtime probe: active count")
    assert(tsnet.Libp2pTailnetProviderRuntimeReadyNow(transport),
        " tailnet runtime probe: provider ready now")
    assert(transport.providerReady, " tailnet runtime probe: provider ready field")

    tsnet.Libp2pTailnetProviderMarkProxyReady(transport)
    assert(transport.proxyListenersReady, " tailnet runtime probe: proxy ready")

    tsnet.Libp2pTailnetProviderDerpReady(transport)
    assert(transport.derpHealthy, " tailnet runtime probe: derp healthy")

    assert(tsnet.Libp2pTailnetProviderClose(transport),
        " tailnet runtime probe: close")
    echo(" tailnet_runtime_headscale_probe ok")
    return 0
