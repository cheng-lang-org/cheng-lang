import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_file_size_smoke_tmp"
    let emptyPath: str = os.JoinPath(tmpRoot, "empty.txt")
    let payloadPath: str = os.JoinPath(tmpRoot, "payload.txt")
    let missingPath: str = os.JoinPath(tmpRoot, "missing.txt")

    if os.FileExists(emptyPath):
        assert(os.RemoveFile(emptyPath), " ordinary os.FileSize cleanup empty file")
    if os.FileExists(payloadPath):
        assert(os.RemoveFile(payloadPath), " ordinary os.FileSize cleanup payload file")
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

    os.CreateDir(tmpRoot)
    os.WriteFile(emptyPath, "")
    os.WriteFile(payloadPath, "hello")

    assert(os.FileSize(emptyPath) == 0, " ordinary os.FileSize empty file")
    assert(os.FileSize(payloadPath) == 5, " ordinary os.FileSize payload file")
    assert(os.FileSize(missingPath) == 0, " ordinary os.FileSize missing file")

    if os.FileExists(emptyPath):
        assert(os.RemoveFile(emptyPath), " ordinary os.FileSize remove empty file")
    if os.FileExists(payloadPath):
        assert(os.RemoveFile(payloadPath), " ordinary os.FileSize remove payload file")
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)
    echo(" os_file_size_smoke ok")
    return 0
