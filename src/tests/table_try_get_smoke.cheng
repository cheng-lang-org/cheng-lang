import std/system
import std/tables

fn main() =
    var table: tables.Table[int32] = tables.TableInit[int32](8)
    tables.TablePut[int32](table, "zero", 0)
    var value: int32 = -1
    assert(tables.TableTryGet[int32](table, "zero", value), "table try get zero found")
    assert(value == 0, "table try get zero value")
    value = -1
    assert(!tables.TableTryGet[int32](table, "missing", value), "table try get missing")
    assert(value == 0, "table try get missing resets value")
