import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr

fn main(): int32 =
    var digits: int32[]
    digits = []
    add(digits, 1)
    add(digits, 2)
    add(digits, 3)
    let addressRes = types.LsmrAddressFromDigits(digits)
    assert(IsOk(addressRes), " lsmr locality smoke: address")
    let address = Value(addressRes)
    let zeroCid = layout.FixedBytes32()
    let localityRes = lsmr.LsmrLocalityCidMake(7, address, 3, zeroCid, zeroCid)
    if IsErr(localityRes):
        panic(Error(localityRes))
    let locality = Value(localityRes)
    assert(locality.keyId == 7, " lsmr locality smoke: key")
    assert(locality.resolutionLevel == 3, " lsmr locality smoke: resolution")
    let stateCellRes = lsmr.LsmrStateCellMake(7, address, 3, zeroCid, zeroCid)
    if IsErr(stateCellRes):
        panic(Error(stateCellRes))
    let cell = Value(stateCellRes)
    assert(cell.keyId == 7, " lsmr locality smoke: cell key")
    assert(cell.resolutionLevel == 3, " lsmr locality smoke: cell resolution")
    echo(" lsmr_locality_statecell_smoke ok")
    return 0
