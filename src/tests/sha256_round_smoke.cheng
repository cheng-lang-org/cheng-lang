import std/system
import std/rawbytes
import std/crypto/sha256

fn main(): int32 =
    let input: Bytes = bytesFromString("abc")
    let inputLen: int32 = bytesLen(input)
    var padZero: int32
    while ((inputLen + 1 + padZero) % 64) != 56:
        padZero = padZero + 1
    let totalLen: int32 = inputLen + 1 + padZero + 8
    let msg: Bytes = bytesAlloc(totalLen)
    for i in 0..<inputLen:
        bytesSet(msg, i, bytesGet(input, i))
    bytesSet(msg, inputLen, 0x80)
    var bitLen: int64 = int64(inputLen) * 8
    for i in 0..<8:
        let byteVal: int64 = bitLen & 255
        bytesSet(msg, totalLen - 1 - i, int32(byteVal))
        bitLen = bitLen >> 8

    let wbuf: Bytes = bytesAlloc(64 * 4)
    for t in 0..<16:
        let word: int64 = sha256.getU32BE(msg, t * 4)
        sha256.setU32BE(wbuf, t * 4, word)
    t = 16
    let __for_start_t_1 = t
    for __for_t_1 in __for_start_t_1..<64:
        t = __for_t_1
        let w2: int64 = sha256.getU32BE(wbuf, (t - 2) * 4)
        let w7: int64 = sha256.getU32BE(wbuf, (t - 7) * 4)
        let w15: int64 = sha256.getU32BE(wbuf, (t - 15) * 4)
        let w16: int64 = sha256.getU32BE(wbuf, (t - 16) * 4)
        let sum: int64 = w16 + sha256.smallSigma0(w15) + w7 + sha256.smallSigma1(w2)
        sha256.setU32BE(wbuf, t * 4, sha256.u32(sum))
        t = t + 1

    var a: int64 = sha256.u32FromBytes(0x6a, 0x09, 0xe6, 0x67)
    var b: int64 = sha256.u32FromBytes(0xbb, 0x67, 0xae, 0x85)
    var c: int64 = sha256.u32FromBytes(0x3c, 0x6e, 0xf3, 0x72)
    var d: int64 = sha256.u32FromBytes(0xa5, 0x4f, 0xf5, 0x3a)
    var e: int64 = sha256.u32FromBytes(0x51, 0x0e, 0x52, 0x7f)
    var f: int64 = sha256.u32FromBytes(0x9b, 0x05, 0x68, 0x8c)
    var g: int64 = sha256.u32FromBytes(0x1f, 0x83, 0xd9, 0xab)
    var h: int64 = sha256.u32FromBytes(0x5b, 0xe0, 0xcd, 0x19)

    for t in 0..<64:
        let wt: int64 = sha256.getU32BE(wbuf, t * 4)
        let t1: int64 = sha256.u32(h + sha256.bigSigma1(e) + sha256.ch(e, f, g) + sha256.k256(t) + wt)
        let t2: int64 = sha256.u32(sha256.bigSigma0(a) + sha256.maj(a, b, c))
        h = g
        g = f
        f = e
        e = sha256.u32(d + t1)
        d = c
        c = b
        b = a
        a = sha256.u32(t1 + t2)

        if t == 0:
            assert(a == sha256.u32FromBytes(0x5d, 0x6a, 0xeb, 0xcd), "v3 sha256 round: a0")
            assert(b == sha256.u32FromBytes(0x6a, 0x09, 0xe6, 0x67), "v3 sha256 round: b0")
            assert(c == sha256.u32FromBytes(0xbb, 0x67, 0xae, 0x85), "v3 sha256 round: c0")
            assert(d == sha256.u32FromBytes(0x3c, 0x6e, 0xf3, 0x72), "v3 sha256 round: d0")
            assert(e == sha256.u32FromBytes(0xfa, 0x2a, 0x46, 0x22), "v3 sha256 round: e0")
            assert(f == sha256.u32FromBytes(0x51, 0x0e, 0x52, 0x7f), "v3 sha256 round: f0")
            assert(g == sha256.u32FromBytes(0x9b, 0x05, 0x68, 0x8c), "v3 sha256 round: g0")
            assert(h == sha256.u32FromBytes(0x1f, 0x83, 0xd9, 0xab), "v3 sha256 round: h0")
        if t == 1:
            assert(a == sha256.u32FromBytes(0x5a, 0x6a, 0xd9, 0xad), "v3 sha256 round: a1")
            assert(e == sha256.u32FromBytes(0x78, 0xce, 0x79, 0x89), "v3 sha256 round: e1")
        if t == 2:
            assert(a == sha256.u32FromBytes(0xc8, 0xc3, 0x47, 0xa7), "v3 sha256 round: a2")
            assert(e == sha256.u32FromBytes(0xf9, 0x29, 0x39, 0xeb), "v3 sha256 round: e2")
        if t == 3:
            assert(a == sha256.u32FromBytes(0xd5, 0x50, 0xf6, 0x66), "v3 sha256 round: a3")
            assert(e == sha256.u32FromBytes(0x24, 0xe0, 0x08, 0x50), "v3 sha256 round: e3")
        if t == 7:
            assert(a == sha256.u32FromBytes(0x85, 0xa0, 0x7b, 0x5f), "v3 sha256 round: a7")
            assert(e == sha256.u32FromBytes(0x0c, 0x65, 0x7a, 0x79), "v3 sha256 round: e7")
        if t == 15:
            assert(a == sha256.u32FromBytes(0xb0, 0xfa, 0x23, 0x8e), "v3 sha256 round: a15")
            assert(e == sha256.u32FromBytes(0x07, 0x59, 0x0d, 0xcd), "v3 sha256 round: e15")
        if t == 16:
            assert(a == sha256.u32FromBytes(0x21, 0xda, 0x9a, 0x9b), "v3 sha256 round: a16")
            assert(e == sha256.u32FromBytes(0x80, 0x34, 0x22, 0x9c), "v3 sha256 round: e16")
        if t == 17:
            assert(a == sha256.u32FromBytes(0xc2, 0xfb, 0xd9, 0xd1), "v3 sha256 round: a17")
            assert(e == sha256.u32FromBytes(0x84, 0x6e, 0xe4, 0x54), "v3 sha256 round: e17")
        if t == 31:
            assert(a == sha256.u32FromBytes(0x73, 0xb3, 0x3b, 0xf5), "v3 sha256 round: a31")
            assert(e == sha256.u32FromBytes(0xba, 0x59, 0x11, 0x12), "v3 sha256 round: e31")
        if t == 32:
            assert(a == sha256.u32FromBytes(0x98, 0xe1, 0x25, 0x07), "v3 sha256 round: a32")
            assert(e == sha256.u32FromBytes(0x9c, 0xd9, 0xf5, 0xf6), "v3 sha256 round: e32")
        if t == 47:
            assert(a == sha256.u32FromBytes(0x41, 0x72, 0x32, 0x8d), "v3 sha256 round: a47")
            assert(e == sha256.u32FromBytes(0xfe, 0xcf, 0x0b, 0xc6), "v3 sha256 round: e47")
        if t == 48:
            assert(a == sha256.u32FromBytes(0x05, 0x75, 0x7c, 0xeb), "v3 sha256 round: a48")
            assert(e == sha256.u32FromBytes(0xbd, 0x71, 0x40, 0x38), "v3 sha256 round: e48")
        if t == 63:
            assert(a == sha256.u32FromBytes(0x50, 0x6e, 0x30, 0x58), "v3 sha256 round: a63")
            assert(e == sha256.u32FromBytes(0x5e, 0xf5, 0x0f, 0x24), "v3 sha256 round: e63")
    let h0: int64 = sha256.u32(sha256.u32FromBytes(0x6a, 0x09, 0xe6, 0x67) + a)
    let h1: int64 = sha256.u32(sha256.u32FromBytes(0xbb, 0x67, 0xae, 0x85) + b)
    let h2: int64 = sha256.u32(sha256.u32FromBytes(0x3c, 0x6e, 0xf3, 0x72) + c)
    let h3: int64 = sha256.u32(sha256.u32FromBytes(0xa5, 0x4f, 0xf5, 0x3a) + d)
    let h4: int64 = sha256.u32(sha256.u32FromBytes(0x51, 0x0e, 0x52, 0x7f) + e)
    let h5: int64 = sha256.u32(sha256.u32FromBytes(0x9b, 0x05, 0x68, 0x8c) + f)
    let h6: int64 = sha256.u32(sha256.u32FromBytes(0x1f, 0x83, 0xd9, 0xab) + g)
    let h7: int64 = sha256.u32(sha256.u32FromBytes(0x5b, 0xe0, 0xcd, 0x19) + h)
    let out: Bytes = bytesAlloc(32)
    sha256.setU32BE(out, 0, h0)
    sha256.setU32BE(out, 4, h1)
    sha256.setU32BE(out, 8, h2)
    sha256.setU32BE(out, 12, h3)
    sha256.setU32BE(out, 16, h4)
    sha256.setU32BE(out, 20, h5)
    sha256.setU32BE(out, 24, h6)
    sha256.setU32BE(out, 28, h7)
    assert(bytesGet(out, 0) == 0xba, "v3 sha256 round: digest byte0")
    assert(bytesGet(out, 1) == 0x78, "v3 sha256 round: digest byte1")
    assert(bytesGet(out, 31) == 0xad, "v3 sha256 round: digest byte31")
    echo("v3 sha256_round_smoke ok")
    return 0
