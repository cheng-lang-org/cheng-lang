import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr as lsmr
import cheng/chain/lsmr_types as lt

fn mustAddress(digits: int32[]): types.LsmrAddress =
    let res = types.LsmrAddressFromDigits(digits)
    if IsErr(res):
        panic(Error(res))
    return Value(res)

fn makeCell(keyId: int32, digits: int32[], resolution: int32, salt: int32): lt.StateCell =
    let address = mustAddress(digits)
    let contentCid = lt.HashInts("cheng.forest_fill.content", [keyId, salt, resolution])
    let localityHash = lt.HashInts("cheng.forest_fill.locality", [keyId, salt, resolution])
    var cell: lt.StateCell
    lsmr.LsmrStateCellFill(cell, keyId, address, resolution, contentCid, localityHash)
    return cell

fn main(): int32 =
    var cells: lt.StateCell[]
    cells = []
    add(cells, makeCell(201, [6, 7, 9], 1, 1))
    add(cells, makeCell(202, [6, 7, 3], 2, 2))
    add(cells, makeCell(203, [6, 7, 4], 3, 3))
    var forest = lt.StateLayerForest()
    lsmr.BuildStateLayerForestFill(forest, cells)
    assert(forest.globalTree.entryCount == 1, " state_layer_forest_fill_smoke: global count")
    assert(forest.regionalTree.entryCount == 1, " state_layer_forest_fill_smoke: regional count")
    assert(forest.edgeTree.entryCount == 1, " state_layer_forest_fill_smoke: edge count")
    assert(!layout.FixedBytes32Equal(forest.forestCid, layout.FixedBytes32()),
           " state_layer_forest_fill_smoke: forest cid")
    echo(" state_layer_forest_fill_smoke ok")
    return 0
