type SeqBox =
    marker: int32
    items: int32[]

fn MakeBox(): SeqBox =
    return SeqBox(marker: 5, items: [11, 13, 17])

fn ResetBox(box: var SeqBox): int32 =
    box.items = [5, 6, 7]
    box.items[1] = box.items[1] + 30
    return box.items.len

fn Clobber(seed: int32): int32 =
    let fixed: int32[3] = [seed + 1, seed + 2, seed + 3]
    let seq: int32[] = [seed + 4, seed + 5, seed + 6]
    return fixed[0] + fixed[1] + fixed[2] + seq[0] + seq[1] + seq[2]

fn main(): int32 =
    let made = MakeBox()
    let noise = Clobber(20)
    if noise != 141:
        return noise
    if made.items.len != 3:
        return 1
    if made.items[0] != 11:
        return 2
    if made.items[1] != 13:
        return 3
    if made.items[2] != 17:
        return 4

    var box: SeqBox
    box.marker = 9
    let resetLen = ResetBox(box)
    let noise2 = Clobber(40)
    if noise2 != 261:
        return noise2
    if resetLen != 3:
        return 5
    if box.items[0] != 5:
        return 6
    if box.items[1] != 36:
        return 7
    if box.items[2] != 7:
        return 8
    return 42
