# backend matrix future fixture: existing Result request dispatch shape
# current blocker after dispatch lowering: Result constructor materialization is still future work
# expected exit code when enabled: 9

import std/result

type
    CompilerRequest =
        code: int32
        label: str

fn MakeRoot(): str =
    var out: str
    return out

fn MakeRequest(): Result[CompilerRequest] =
    let req = CompilerRequest(code: 9, label: "ok")
    return Ok[CompilerRequest](req)

fn BackendDriverDispatchMinUnsupported(reason: str): int32 =
    return 2

fn BackendDriverDispatchMinRunSystemLinkExecConcreteRequest(rootDir: str,
                                                            req: CompilerRequest): int32 =
    return req.code

fn BackendDriverDispatchMinRunSystemLinkExecWithRequest(rootDir: str,
                                                        reqRes: Result[CompilerRequest]): int32 =
    if IsErr(reqRes):
        return BackendDriverDispatchMinUnsupported(Error(reqRes))
    let req = Value(reqRes)
    return BackendDriverDispatchMinRunSystemLinkExecConcreteRequest(rootDir, req)

fn main(): int32 =
    let rootDir: str = MakeRoot()
    let reqRes = MakeRequest()
    return BackendDriverDispatchMinRunSystemLinkExecWithRequest(rootDir, reqRes)
