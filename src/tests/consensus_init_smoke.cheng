import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

fn main(): int32 =
    var index = consensus.ChainIndex()
    let zeroCid = layout.FixedBytes32()
    assert(index.accountIds.len == 0, " consensus init: empty index")
    assert(layout.fixedBytes32Equal(zeroCid, layout.FixedBytes32()), " consensus init: zero cid")
    echo(" consensus_init_smoke ok")
    return 0
