import std/system
import std/rawbytes as raw
import std/crypto/sha256
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt

fn main(): int32 =
    assert(sha256.u32Mask() == int64(4294967295), " sha256 distinct: mask")
    assert(sha256.rotr32(int64(305419896), 4) == sha256.u32FromBytes(0x81, 0x23, 0x45, 0x67),
           " sha256 distinct: rotr32")
    var probeBufA = layout.ByteBufInit(16)
    var probeBufB = layout.ByteBufInit(16)
    lt.AppendU32BE(probeBufA, 1)
    lt.AppendU32BE(probeBufB, 2)
    let probeSpanA = layout.ByteBufView(probeBufA)
    let probeSpanB = layout.ByteBufView(probeBufB)
    assert(layout.ByteSpanLen(probeSpanA) == 4, " sha256 distinct: probe a len")
    assert(layout.ByteSpanLen(probeSpanB) == 4, " sha256 distinct: probe b len")
    assert(layout.ByteSpanAt(probeSpanA, 3) == 1, " sha256 distinct: probe a byte")
    assert(layout.ByteSpanAt(probeSpanB, 3) == 2, " sha256 distinct: probe b byte")
    assert(sha256.getU32BE(probeSpanA.data, 0) == 1, " sha256 distinct: probe a word")
    assert(sha256.getU32BE(probeSpanB.data, 0) == 2, " sha256 distinct: probe b word")
    let rawDigestA = sha256.sha256Digest(probeSpanA.data)
    let rawDigestB = sha256.sha256Digest(probeSpanB.data)
    assert(rawDigestA.len == 32, " sha256 distinct: digest a len")
    assert(rawDigestB.len == 32, " sha256 distinct: digest b len")
    var rawDigestLocalDistinct = false
    for i in 0..<32:
        if raw.ChengRawbytesGetAt(rawDigestA.data, i) != raw.ChengRawbytesGetAt(rawDigestB.data, i):
            rawDigestLocalDistinct = true
    assert(rawDigestLocalDistinct, " sha256 distinct: local distinct")
    echo(" sha256_distinct_smoke ok")
    return 0
