import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_runtime as crun
import cheng/core/backend/object_plan as objplan
import cheng/core/backend/target_matrix as tmat
import cheng/core/runtime/core_runtime as corun
import cheng/core/runtime/compiler_runtime as comprun
import cheng/core/runtime/debug_runtime as debrun
import cheng/core/runtime/program_support as prun

fn containsText(items: str[], value: str): bool =
    var i: int32
    while i < items.len:
        if items[i] == value:
            return true
        i = i + 1
    return false

fn main(): int32 =
    let workspaceRoot = "/tmp/cheng-lang"
    let outputPath = workspaceRoot + "/artifacts/program_selfhost/program_selfhost_smoke"
    let primaryObjectPath = outputPath + ".primary.o"
    var providerModules: str[]
    crun.RuntimeProviderModulesForTrack(crun.CompilerTrackProgram, providerModules)
    var toolingProviderModules: str[]
    crun.RuntimeProviderModulesForTrack(crun.CompilerTrackTooling, toolingProviderModules)
    let providerObjectPaths = [
        outputPath + ".provider.runtime_compiler_runtime.o",
        outputPath + ".provider.runtime_core_runtime.o",
        outputPath + ".provider.runtime_debug_runtime.o",
        outputPath + ".provider.runtime_program_support.o",
        outputPath + ".provider.runtime_program_support_host_runtime.o"
    ]
    let linkInputs = [
        primaryObjectPath,
        providerObjectPaths[0],
        providerObjectPaths[1],
        providerObjectPaths[2],
        providerObjectPaths[3],
        providerObjectPaths[4]
    ]
    var objectPlan: objplan.ObjectPlanStub
    objectPlan.workspaceRoot = workspaceRoot
    objectPlan.packageRoot = workspaceRoot
    objectPlan.packageId = "cheng"
    objectPlan.entryPath = workspaceRoot + "/src/tests/program_selfhost_smoke.cheng"
    objectPlan.outputPath = outputPath
    objectPlan.targetTriple = "arm64-apple-darwin"
    objectPlan.primaryObjectPath = primaryObjectPath
    objectPlan.providerModules = providerModules
    objectPlan.providerSourcePaths = [
        workspaceRoot + "/src/core/runtime/compiler_runtime_program_entry_provider.cheng",
        workspaceRoot + "/src/core/runtime/core_runtime_provider_darwin.cheng",
        workspaceRoot + "/src/core/runtime/debug_runtime_stub.cheng",
        workspaceRoot + "/src/core/runtime/program_support_backend.cheng",
        workspaceRoot + "/src/core/runtime/program_support_host_runtime.cheng"
    ]
    objectPlan.providerObjectPaths = providerObjectPaths
    objectPlan.linkInputPaths = linkInputs
    objectPlan.loweredFunctionSymbols = ["cheng/tests/program_selfhost_smoke::main"]
    objectPlan.entrySymbol = "main"
    objectPlan.missingReasons = []
    objectPlan.pipelineStage = "lowering_plan_to_object_plan"
    assert(objectPlan.primaryObjectPath == primaryObjectPath,
           " object plan: primary object path")
    assert(objectPlan.providerObjectPaths.len == 5, " object plan: provider count")
    assert(objectPlan.providerSourcePaths.len == 5, " object plan: provider sources")
    assert(objectPlan.linkInputPaths.len == 6, " native link plan: link input count")
    assert(tmat.TargetLinkerProgram("arm64-apple-darwin") == "cc",
           " native link plan: linker program")
    assert(tmat.TargetLinkerFlavor("arm64-apple-darwin") == "ld64",
           " native link plan: linker flavor")
    assert(tmat.TargetLinkerProgram("aarch64-unknown-linux-gnu") == "internal_elf_linker",
           " native link plan: aarch64 nolibc linker program")
    assert(tmat.TargetLinkerFlavor("riscv64-unknown-linux-gnu") == "elf_riscv64_builtin",
           " native link plan: riscv64 linker flavor")
    assert(tmat.TargetLinkerProgram("aarch64-pc-windows-msvc") == "builtin_coff_linker",
           " native link plan: windows linker program")
    assert(objectPlan.primaryObjectPath == primaryObjectPath,
           " native link plan: primary object path")
    let realWorkspaceRoot = chengpath.PathCurrentDir()
    let ordinaryProviders = [
        comprun.CompilerRuntimeProviderSourcePath(realWorkspaceRoot, comprun.CompilerRuntimeTrackProgram),
        corun.CoreRuntimeProviderSourcePath(realWorkspaceRoot, "arm64-apple-darwin"),
        debrun.DebugRuntimeProviderSourcePath(realWorkspaceRoot),
        prun.ProgramSupportProviderSourcePath(realWorkspaceRoot),
        prun.ProgramSupportHostProviderSourcePath(realWorkspaceRoot)
    ]
    let toolingProviders = [
        comprun.CompilerRuntimeProviderSourcePath(realWorkspaceRoot, comprun.CompilerRuntimeTrackTooling),
        corun.CoreRuntimeProviderSourcePath(realWorkspaceRoot, "arm64-apple-darwin"),
        debrun.DebugRuntimeProviderSourcePath(realWorkspaceRoot),
        prun.ProgramSupportProviderSourcePath(realWorkspaceRoot),
        prun.ProgramSupportHostProviderSourcePath(realWorkspaceRoot)
    ]
    assert(providerModules.len == 5, " object plan: provider module count")
    assert(toolingProviderModules.len == 5, " object plan: tooling provider module count")
    assert(providerModules[0] == "runtime/compiler_runtime", " object plan: ordinary compiler runtime module")
    assert(toolingProviderModules[0] == "runtime/compiler_runtime", " object plan: tooling compiler runtime module")
    assert(crun.CompilerProgramArgvRuntimeTarget() == "runtime/compiler.program_argv_entry",
           " object plan: ordinary argv target")
    assert(crun.CompilerToolingArgvRuntimeTarget() == "runtime/compiler.tooling_argv_entry",
           " object plan: tooling argv target")
    assert(containsText(ordinaryProviders,
                        chengpath.PathJoin(realWorkspaceRoot,
                                          "src/core/runtime/compiler_runtime_program_entry_provider.cheng")),
           " object plan: ordinary argv provider")
    assert(containsText(toolingProviders,
                        chengpath.PathJoin(realWorkspaceRoot,
                                          "src/core/runtime/compiler_runtime_tooling_entry_provider.cheng")),
           " object plan: tooling argv provider")
    assert(containsText(ordinaryProviders,
                        chengpath.PathJoin(realWorkspaceRoot, "src/core/runtime/debug_runtime_stub.cheng")),
           " object plan: ordinary debug provider")
    assert(containsText(toolingProviders,
                        chengpath.PathJoin(realWorkspaceRoot, "src/core/runtime/debug_runtime_stub.cheng")),
           " object plan: tooling debug provider")
    assert(containsText(ordinaryProviders,
                        chengpath.PathJoin(realWorkspaceRoot, "src/core/runtime/program_support_backend.cheng")),
           " object plan: ordinary support provider")
    assert(containsText(toolingProviders,
                        chengpath.PathJoin(realWorkspaceRoot, "src/core/runtime/program_support_backend.cheng")),
           " object plan: tooling support provider")
    assert(containsText(ordinaryProviders,
                        chengpath.PathJoin(realWorkspaceRoot, "src/core/runtime/program_support_host_runtime.cheng")),
           " object plan: ordinary host support provider")
    assert(containsText(toolingProviders,
                        chengpath.PathJoin(realWorkspaceRoot, "src/core/runtime/program_support_host_runtime.cheng")),
           " object plan: tooling host support provider")
    assert(containsText(ordinaryProviders,
                        chengpath.PathJoin(realWorkspaceRoot, "src/core/runtime/core_runtime_provider_darwin.cheng")),
           " object plan: ordinary core provider")
    assert(containsText(toolingProviders,
                        chengpath.PathJoin(realWorkspaceRoot, "src/core/runtime/core_runtime_provider_darwin.cheng")),
           " object plan: tooling core provider")
    assert(tmat.TargetRequiresNativeProviderModules("arm64-apple-darwin"),
           " target matrix: darwin native providers")
    assert(!tmat.TargetRequiresNativeProviderModules("wasm32-unknown-unknown"),
           " target matrix: wasm no native providers")
    assert(tmat.TargetUsesLinuxNolibcRuntime("aarch64-unknown-linux-gnu"),
           " target matrix: linux aarch64 nolibc")
    assert(!tmat.TargetUsesLinuxNolibcRuntime("riscv64-unknown-linux-gnu"),
           " target matrix: riscv64 not nolibc")
    assert(tmat.TargetIsElfObject("riscv64-unknown-linux-gnu"),
           " target matrix: riscv64 elf")
    assert(tmat.TargetIsElfObject("x86_64-unknown-linux-gnu"),
           " target matrix: linux x86_64 elf")
    assert(tmat.TargetIsCoffObject("aarch64-pc-windows-msvc"),
           " target matrix: windows aarch64 coff")
    assert(tmat.TargetIsCoffObject("x86_64-pc-windows-msvc"),
           " target matrix: windows x86_64 coff")
    assert(tmat.TargetPrimaryObjectFormat("aarch64-unknown-linux-gnu") == "elf",
           " primary object format: linux aarch64")
    assert(tmat.TargetPrimaryObjectFormat("riscv64-unknown-linux-gnu") == "elf",
           " primary object format: linux riscv64")
    assert(tmat.TargetPrimaryObjectFormat("aarch64-pc-windows-msvc") == "coff",
           " primary object format: windows aarch64")
    assert(tmat.TargetPrimaryObjectFormat("x86_64-pc-windows-msvc") == "coff",
           " primary object format: windows x86_64")
    echo(" object_native_link_plan_smoke ok")
    return 0
