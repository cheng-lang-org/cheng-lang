import std/system
import cheng/std/bytes_layout as layout
import cheng/libp2p/core/types
import cheng/libp2p/identity/did
import cheng/apps/astrology/astrology_peer_did_core as peer

fn main(): int32 =
    var peerId = "12D3KooWAstrologyPeer1111111111111111111111111111"
    let userRes = peer.AstrologyPeerDidUserMake(peerId, "", int64(1713072000))
    assert(IsOk(userRes), " astrology peer did: create user")
    let user = Value(userRes)
    assert(len(user.peerIdText) > 0, " astrology peer did: peer text stored")
    assert(!layout.fixedBytes32Equal(user.bindingDigest, layout.FixedBytes32()),
        " astrology peer did: digest written")
    assert(len(user.displayName) > 0,
        " astrology peer did: default display name")

    let sameRes = peer.AstrologyPeerDidUserMake(peerId, "自定义", int64(1713072000))
    assert(IsOk(sameRes), " astrology peer did: create same peer")
    let sameUser = Value(sameRes)
    assert(sameUser.didText == user.didText,
        " astrology peer did: same peer same did")

    let otherRes = peer.AstrologyPeerDidUserMake("12D3KooWAnotherPeer222222222222222222222222222", "", int64(1713072000))
    assert(IsOk(otherRes), " astrology peer did: create other peer")
    let otherUser = Value(otherRes)
    assert(otherUser.rootSeed != user.rootSeed,
        " astrology peer did: different peer different root seed")
    assert(!types.Libp2pPeerIdEqual(did.DidRootPeerIdFromSeed(otherUser.rootSeed),
                                      did.DidRootPeerIdFromSeed(user.rootSeed)),
        " astrology peer did: different peer different root peer")
    assert(!layout.fixedBytes32Equal(did.DidGenesisCidFromSeed(otherUser.rootSeed),
                                     did.DidGenesisCidFromSeed(user.rootSeed)),
        " astrology peer did: different peer different genesis cid")
    assert(otherUser.didText != user.didText,
        " astrology peer did: different peer different did")
    return 0
