import cheng/core/lang/parser

fn main() =
    let text = "fn main(): int32 =\n    return 0\n"
    let lines = parser.ParserSplitChar(text, '\n')
    assert(lines.len >= 2, "cold parser split line count")
    echo(lines[0])
    echo(lines[1])
    assert(lines[0] == "fn main(): int32 =", "cold parser split line0")
    assert(lines[1] == "    return 0", "cold parser split line1")
