import std/rawbytes
import cheng/moq/moq_fountain as moq

@exportc("moqObjectSourceBlockCount")
fn moqObjectSourceBlockCount(): int32 =
    var peers: str[]
    peers = []
    add(peers, "peer-a")
    add(peers, "peer-b")
    let objectBytes = bytesFromString("abc")
    let built = moq.MoqFountainBuildObject(objectBytes,
                                           0,
                                           100,
                                           peers,
                                           "bundle",
                                           4,
                                           1)
    if IsErr(built):
        return -1
    return Value(built).sourceBlockCount

fn moqObjectErrorText(): str =
    var peers: str[]
    peers = []
    add(peers, "peer-a")
    add(peers, "peer-b")
    let objectBytes = bytesFromString("abc")
    let built = moq.MoqFountainBuildObject(objectBytes,
                                           0,
                                           100,
                                           peers,
                                           "bundle",
                                           4,
                                           1)
    if IsErr(built):
        return Error(built)
    return "ok"

fn main(): int32 =
    return moqObjectSourceBlockCount()
