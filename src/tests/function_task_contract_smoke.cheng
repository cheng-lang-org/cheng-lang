import cheng/core/ir/function_task as ftask
import std/strings

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn planMutationDiffers(base: ftask.UirFnTaskPlan,
                       mutationKind: int32): bool =
    var changed = base
    if changed.tasks.len <= 0:
        return false
    if mutationKind == 1:
        changed.tasks[0].funcIndex = changed.tasks[0].funcIndex + 1
    elif mutationKind == 2:
        changed.tasks[0].declOrdinal = changed.tasks[0].declOrdinal + 1
    elif mutationKind == 3:
        changed.tasks[0].sourceSpanStart = changed.tasks[0].sourceSpanStart + 1
    elif mutationKind == 4:
        changed.tasks[0].sourceSpanEnd = changed.tasks[0].sourceSpanEnd + 1
    elif mutationKind == 5:
        changed.tasks[0].ownerModulePath = "cheng/core/other"
    elif mutationKind == 6:
        changed.tasks[0].entryFlag = changed.tasks[0].entryFlag + 1
    elif mutationKind == 7:
        changed.tasks[0].costHint = changed.tasks[0].costHint + 1
    elif mutationKind == 8:
        changed.tasks[0].genericEpoch = changed.tasks[0].genericEpoch + 1
    else:
        return false
    return !ftask.UirFnTaskPlanEquivalent(base, changed)

fn main(): int32 =
    var plan = ftask.UirFnTaskPlanNew()
    let task = ftask.UirFnTaskNew(
        7,
        3,
        101,
        145,
        9,
        2,
        1,
        "cheng/core/tooling"
    )
    ftask.UirFnTaskPlanAppend(plan, task)
    let secondTask = ftask.UirFnTaskNew(
        8,
        4,
        146,
        181,
        5,
        2,
        0,
        "cheng/core/backend"
    )
    ftask.UirFnTaskPlanAppend(plan, secondTask)
    let report = ftask.UirFnTaskPlanContractReport(plan)
    let c1 = check(report.schedule == ftask.FunctionTaskScheduleSerial, 11)
    if c1 != 0: return c1
    let c2 = check(report.jobCount == 1, 12)
    if c2 != 0: return c2
    let c3 = check(report.taskCount == 2, 13)
    if c3 != 0: return c3
    let c4 = check(report.firstFuncIndex == 7, 14)
    if c4 != 0: return c4
    let c5 = check(report.firstDeclOrdinal == 3, 15)
    if c5 != 0: return c5
    let c6 = check(report.firstSourceSpanStart == 101, 16)
    if c6 != 0: return c6
    let c7 = check(report.firstSourceSpanEnd == 145, 17)
    if c7 != 0: return c7
    let c8 = check(report.firstCostHint == 9, 18)
    if c8 != 0: return c8
    let c9 = check(report.firstGenericEpoch == 2, 19)
    if c9 != 0: return c9
    let c10 = check(report.firstEntryFlag == 1, 20)
    if c10 != 0: return c10
    let c11 = check(report.firstOwnerModulePath == "cheng/core/tooling", 21)
    if c11 != 0: return c11
    let text = ftask.UirFnTaskPlanReportText(report)
    let c12 = check(strings.StrContains(text, "uir_fn_task_schedule=serial"), 22)
    if c12 != 0: return c12
    let c13 = check(strings.StrContains(text, "uir_fn_task_job_count=1"), 23)
    if c13 != 0: return c13
    let c14 = check(strings.StrContains(text, "uir_fn_task_first_generic_epoch=2"), 24)
    if c14 != 0: return c14
    let c14b = check(strings.StrContains(text, "uir_fn_task_first_entry_flag=1"), 47)
    if c14b != 0: return c14b
    let c14c = check(strings.StrContains(text, "uir_fn_task_first_owner_module_path=cheng/core/tooling"), 48)
    if c14c != 0: return c14c
    let c14d = check(!strings.StrContains(text, "body_ir"), 49)
    if c14d != 0: return c14d
    var snapshot: ftask.UirCoreSharedSnapshot
    add(snapshot.functionNames, "BuildPrimaryObjectPlan")
    add(snapshot.functionSymbolTexts, "BuildPrimaryObjectPlan")
    add(snapshot.functionSourcePaths, "src/core/backend/primary_object_plan.cheng")
    add(snapshot.functionSourceSpanStarts, 1000)
    add(snapshot.functionSourceSpanEnds, 1064)
    add(snapshot.functionOwnerModulePaths, "cheng/core/backend")
    add(snapshot.functionEntryFlags, 0)
    add(snapshot.globalSymbolNames, "main")
    add(snapshot.typeLayoutKinds, 7)
    add(snapshot.objectLayoutKinds, 3)
    add(snapshot.overloadKeys, "BuildPrimaryObjectPlan/2")
    add(snapshot.importEdges, "core/backend/lowering_plan")
    add(snapshot.targetAbiKinds, 1)
    let snapshotReport = ftask.UirCoreSharedSnapshotContractReportFor(snapshot)
    let c14e = check(snapshotReport.ok, 50)
    if c14e != 0: return c14e
    let c14f = check(snapshotReport.bodyIrPayloadCount == 0, 51)
    if c14f != 0: return c14f
    let c14g = check(snapshotReport.mutablePayloadCount == 0, 52)
    if c14g != 0: return c14g
    let c14g2 = check(snapshotReport.firstSourceSpanStart == 1000, 56)
    if c14g2 != 0: return c14g2
    let c14g3 = check(snapshotReport.firstSourceSpanEnd == 1064, 57)
    if c14g3 != 0: return c14g3
    let snapshotText = ftask.UirCoreSharedSnapshotReportText(snapshotReport)
    let c14h = check(strings.StrContains(snapshotText, "uir_shared_snapshot_frozen=1"), 53)
    if c14h != 0: return c14h
    let c14i = check(strings.StrContains(snapshotText, "uir_shared_snapshot_body_ir_payload_count=0"), 54)
    if c14i != 0: return c14i
    let c14i2 = check(strings.StrContains(snapshotText, "uir_shared_snapshot_source_span_start_count=1"), 58)
    if c14i2 != 0: return c14i2
    var snapshotPlan: ftask.UirFnTaskPlan
    let snapshotPlanOk = ftask.UirFnTaskPlanFromSnapshot(snapshot,
                                                         5,
                                                         snapshotPlan)
    let c14i3 = check(snapshotPlanOk, 59)
    if c14i3 != 0: return c14i3
    let snapshotPlanReport = ftask.UirFnTaskPlanContractReport(snapshotPlan)
    let c14i4 = check(snapshotPlanReport.taskCount == 1, 60)
    if c14i4 != 0: return c14i4
    let c14i5 = check(snapshotPlanReport.firstFuncIndex == 0, 61)
    if c14i5 != 0: return c14i5
    let c14i6 = check(snapshotPlanReport.firstSourceSpanStart == 1000, 62)
    if c14i6 != 0: return c14i6
    let c14i7 = check(snapshotPlanReport.firstSourceSpanEnd == 1064, 63)
    if c14i7 != 0: return c14i7
    let c14i8 = check(snapshotPlanReport.firstCostHint == 64, 64)
    if c14i8 != 0: return c14i8
    let c14i9 = check(snapshotPlanReport.firstGenericEpoch == 5, 65)
    if c14i9 != 0: return c14i9
    let c14i10 = check(snapshotPlanReport.firstOwnerModulePath == "cheng/core/backend", 66)
    if c14i10 != 0: return c14i10
    var sameSnapshot = snapshot
    var sameSnapshotPlan: ftask.UirFnTaskPlan
    let sameSnapshotPlanOk = ftask.UirFnTaskPlanFromSnapshot(sameSnapshot,
                                                             5,
                                                             sameSnapshotPlan)
    let c14i11 = check(sameSnapshotPlanOk, 75)
    if c14i11 != 0: return c14i11
    let c14i12 = check(ftask.UirFnTaskPlanEquivalent(snapshotPlan, sameSnapshotPlan), 76)
    if c14i12 != 0: return c14i12
    let c14i13 = check(planMutationDiffers(snapshotPlan, 1), 77)
    if c14i13 != 0: return c14i13
    let c14i14 = check(planMutationDiffers(snapshotPlan, 2), 78)
    if c14i14 != 0: return c14i14
    let c14i15 = check(planMutationDiffers(snapshotPlan, 3), 79)
    if c14i15 != 0: return c14i15
    let c14i16 = check(planMutationDiffers(snapshotPlan, 4), 80)
    if c14i16 != 0: return c14i16
    let c14i17 = check(planMutationDiffers(snapshotPlan, 5), 81)
    if c14i17 != 0: return c14i17
    let c14i18 = check(planMutationDiffers(snapshotPlan, 6), 82)
    if c14i18 != 0: return c14i18
    let c14i19 = check(planMutationDiffers(snapshotPlan, 7), 83)
    if c14i19 != 0: return c14i19
    let c14i20 = check(planMutationDiffers(snapshotPlan, 8), 84)
    if c14i20 != 0: return c14i20
    var brokenSnapshot = snapshot
    add(brokenSnapshot.functionNames, "Extra")
    let brokenSnapshotReport = ftask.UirCoreSharedSnapshotContractReportFor(brokenSnapshot)
    let c14j = check(!brokenSnapshotReport.ok, 55)
    if c14j != 0: return c14j
    var brokenPlan: ftask.UirFnTaskPlan
    let brokenPlanOk = ftask.UirFnTaskPlanFromSnapshot(brokenSnapshot,
                                                       5,
                                                       brokenPlan)
    let c14k = check(!brokenPlanOk, 67)
    if c14k != 0: return c14k
    var result = ftask.UirFnTaskResultEmpty(task.funcIndex, task.declOrdinal)
    let c15 = check(result.funcIndex == task.funcIndex, 25)
    if c15 != 0: return c15
    let c16 = check(result.declOrdinal == task.declOrdinal, 26)
    if c16 != 0: return c16
    let c17 = check(result.loweredFuncId == ftask.InvalidFunctionIndex(), 27)
    if c17 != 0: return c17
    let c18 = check(result.objectArtifactId == ftask.InvalidFunctionIndex(), 28)
    if c18 != 0: return c18
    ftask.UirFnTaskResultAppendCStringId(result, 41)
    ftask.UirFnTaskResultAppendObjectAliasUpdateId(result, 51)
    ftask.UirFnTaskResultAppendGenericRequestId(result, 61)
    ftask.UirFnTaskResultAppendDiagId(result, 31)
    ftask.UirFnTaskResultAppendProfileCounter(result, 400)
    let resultReport = ftask.UirFnTaskResultContractReportFor(result)
    let c19 = check(resultReport.diagCount == 1, 29)
    if c19 != 0: return c19
    let c20 = check(resultReport.firstDiagId == 31, 30)
    if c20 != 0: return c20
    let c21 = check(resultReport.profileCounterCount == 1, 31)
    if c21 != 0: return c21
    let c22 = check(resultReport.firstProfileCounter == 400, 32)
    if c22 != 0: return c22
    let c22b = check(resultReport.cstringCount == 1, 68)
    if c22b != 0: return c22b
    let c22c = check(resultReport.firstCstringId == 41, 69)
    if c22c != 0: return c22c
    let c22d = check(resultReport.objectAliasUpdateCount == 1, 70)
    if c22d != 0: return c22d
    let c22e = check(resultReport.firstObjectAliasUpdateId == 51, 71)
    if c22e != 0: return c22e
    let c22f = check(resultReport.genericRequestCount == 1, 72)
    if c22f != 0: return c22f
    let c22g = check(resultReport.firstGenericRequestId == 61, 73)
    if c22g != 0: return c22g
    let resultText = ftask.UirFnTaskResultReportText(resultReport)
    let c23 = check(strings.StrContains(resultText, "uir_fn_task_result_object_artifact_id=-1"), 33)
    if c23 != 0: return c23
    let c24 = check(strings.StrContains(resultText, "uir_fn_task_result_first_diag_id=31"), 34)
    if c24 != 0: return c24
    let c25 = check(!strings.StrContains(resultText, "BodyIR"), 35)
    if c25 != 0: return c25
    let c25b = check(strings.StrContains(resultText, "uir_fn_task_result_generic_request_count=1"), 74)
    if c25b != 0: return c25b
    var secondResult = ftask.UirFnTaskResultEmpty(secondTask.funcIndex, secondTask.declOrdinal)
    secondResult.loweredFuncId = 80
    secondResult.machineFuncId = 81
    secondResult.objectArtifactId = 82
    result.loweredFuncId = 70
    result.machineFuncId = 71
    result.objectArtifactId = 72
    var workerResults: ftask.UirFnTaskResult[]
    add(workerResults, secondResult)
    add(workerResults, result)
    var mergedResults: ftask.UirFnTaskResult[]
    var mergeReport: ftask.UirFnTaskMergeReport
    let mergeOk = ftask.UirFnTaskMergeResultsByDeclaration(plan,
                                                           workerResults,
                                                           mergedResults,
                                                           mergeReport)
    let c26 = check(mergeOk, 36)
    if c26 != 0: return c26
    let c27 = check(mergedResults.len == 2, 37)
    if c27 != 0: return c27
    let c28 = check(mergedResults[0].funcIndex == 7, 38)
    if c28 != 0: return c28
    let c29 = check(mergedResults[1].funcIndex == 8, 39)
    if c29 != 0: return c29
    let c30 = check(mergedResults[0].objectArtifactId == 72, 40)
    if c30 != 0: return c30
    let c31 = check(mergedResults[1].objectArtifactId == 82, 41)
    if c31 != 0: return c31
    let c32 = check(mergeReport.mergedResultCount == 2, 42)
    if c32 != 0: return c32
    let c33 = check(mergeReport.firstFuncIndex == 7, 43)
    if c33 != 0: return c33
    let c34 = check(mergeReport.lastFuncIndex == 8, 44)
    if c34 != 0: return c34
    let mergeText = ftask.UirFnTaskMergeReportText(mergeReport)
    let c35 = check(strings.StrContains(mergeText, "uir_fn_task_merge_result_count=2"), 45)
    if c35 != 0: return c35
    let c36 = check(!strings.StrContains(mergeText, "BodyIR"), 46)
    if c36 != 0: return c36
    let parallelReport = ftask.UirFnTaskParallelMergeContractReportFor(plan, 4)
    let c37 = check(parallelReport.ok, 85)
    if c37 != 0: return c37
    let c38 = check(parallelReport.requestedJobCount == 4, 86)
    if c38 != 0: return c38
    let c39 = check(parallelReport.effectiveShardCount == 2, 87)
    if c39 != 0: return c39
    let c40 = check(parallelReport.mergeOrder == "decl_ordinal", 88)
    if c40 != 0: return c40
    let c41 = check(parallelReport.taskLocalResultOnly, 89)
    if c41 != 0: return c41
    let c42 = check(parallelReport.sharedInstructionWordsWriteCount == 0, 90)
    if c42 != 0: return c42
    let c43 = check(parallelReport.taskLocalInstructionWordsPayloadCount == 0, 91)
    if c43 != 0: return c43
    let c44 = check(parallelReport.instructionWordsMergeOwner == "main_thread_decl_ordinal", 92)
    if c44 != 0: return c44
    let parallelText = ftask.UirFnTaskParallelMergeContractReportText(parallelReport)
    let c45 = check(strings.StrContains(parallelText, "uir_fn_task_parallel_merge_order=decl_ordinal"), 93)
    if c45 != 0: return c45
    let c46 = check(strings.StrContains(parallelText, "uir_fn_task_parallel_shared_instruction_words_write_count=0"), 94)
    if c46 != 0: return c46
    var unorderedPlan = plan
    unorderedPlan.tasks[1].declOrdinal = 2
    let unorderedReport = ftask.UirFnTaskParallelMergeContractReportFor(unorderedPlan, 4)
    let c47 = check(!unorderedReport.ok, 95)
    if c47 != 0: return c47
    let c48 = check(unorderedReport.firstErrorCode == 4, 96)
    if c48 != 0: return c48
    let serialParallelReport = ftask.UirFnTaskParallelMergeContractReportFor(plan, 1)
    let c49 = check(!serialParallelReport.ok, 97)
    if c49 != 0: return c49
    let c50 = check(serialParallelReport.firstErrorCode == 1, 98)
    if c50 != 0: return c50
    echo(" function_task_contract_smoke ok")
    return 0
