import std/os as os
import std/strutils as strutil
import cheng/core/tooling/path as chengpath
import cheng/std/bytes_layout as layout
import cheng/apps/unimaker/unimaker_edge_types as types
import cheng/evomap/unimaker_evomap_protocol as proto
import cheng/apps/unimaker/unimaker_edge_agent as agent

fn unimakerSmokeCleanup(tmpRoot: str) =
    let storePath = os.JoinPath(tmpRoot, "agent.did")
    let eventLogPath = os.JoinPath(tmpRoot, "events.jsonl")
    let eventLogTmpPath = strutil.Join([eventLogPath, ".tmp"], "")
    if os.FileExists(storePath):
        let _ = os.RemoveFile(storePath)
    if os.FileExists(eventLogPath):
        let _ = os.RemoveFile(eventLogPath)
    if os.FileExists(eventLogTmpPath):
        let _ = os.RemoveFile(eventLogTmpPath)
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

fn main(): int32 =
    let tmpRoot = "artifacts/unimaker_edge_agent_smoke"
    unimakerSmokeCleanup(tmpRoot)
    os.CreateDir(tmpRoot)

    var cfg = types.UnimakerAgentConfig()
    cfg.rootDir = chengpath.PathCurrentDir()
    cfg.eventLogPath = os.JoinPath(tmpRoot, "events.jsonl")
    cfg.identityStorePath = os.JoinPath(tmpRoot, "agent.did")
    cfg.rootSeedHint = "unimaker.root.seed"
    cfg.deviceSeedHint = "unimaker.phone.seed"
    cfg.deviceLabelHint = "phone"
    cfg.epochSeconds = int64(1710000000)

    var edge = agent.UnimakerAgentInit(cfg)
    assert(agent.UnimakerAgentCapsuleCount(edge) == 0, " unimaker smoke: init capsule count")
    assert(agent.UnimakerAgentNodeCount(edge) == 0, " unimaker smoke: init node count")
    assert(edge.identity.didText != "", " unimaker smoke: did text")
    assert(edge.identity.peerIdText != "", " unimaker smoke: peer text")

    let eventA = types.UnimakerEventMake(types.UnimakerEventUserInput,
                                           "task.alpha",
                                           "translate invoice title",
                                           ["invoice", "translate"],
                                           [],
                                           types.UnimakerEdgeKindCausedBy,
                                           int64(1710000001))
    let capsuleARes = agent.UnimakerAgentIngest(edge, eventA)
    assert(IsOk(capsuleARes), " unimaker smoke: ingest A")
    let capsuleA = Value(capsuleARes)

    let eventB = types.UnimakerEventMake(types.UnimakerEventToolResult,
                                           "task.alpha",
                                           "translated invoice title to chinese",
                                           ["invoice", "translated"],
                                           [capsuleA.capsuleCid],
                                           types.UnimakerEdgeKindRefines,
                                           int64(1710000002))
    let capsuleBRes = agent.UnimakerAgentIngest(edge, eventB)
    assert(IsOk(capsuleBRes), " unimaker smoke: ingest B")
    let capsuleB = Value(capsuleBRes)

    assert(agent.UnimakerAgentCapsuleCount(edge) == 2, " unimaker smoke: capsule count")
    assert(agent.UnimakerAgentNodeCount(edge) == 2, " unimaker smoke: node count")
    assert(agent.UnimakerAgentEdgeCount(edge) == 3, " unimaker smoke: edge count")

    var queryTask = types.MemoryQuery()
    queryTask.taskId = "task.alpha"
    queryTask.limit = 8
    let taskHitsRes = agent.UnimakerAgentRecall(edge, queryTask)
    assert(IsOk(taskHitsRes), " unimaker smoke: recall task")
    assert(Value(taskHitsRes).len == 2, " unimaker smoke: recall task count")

    var queryKeyword = types.MemoryQuery()
    queryKeyword.keyword = "translated"
    queryKeyword.limit = 8
    let keywordHitsRes = agent.UnimakerAgentRecall(edge, queryKeyword)
    assert(IsOk(keywordHitsRes), " unimaker smoke: recall keyword")
    let keywordHits = Value(keywordHitsRes)
    assert(keywordHits.len == 1, " unimaker smoke: recall keyword count")
    let keywordCid = keywordHits[0].capsule.capsuleCid
    assert(layout.FixedBytes32Equal(keywordCid, capsuleB.capsuleCid),
        " unimaker smoke: recall keyword cid")

    var queryParent = types.MemoryQuery()
    queryParent.parentCid = capsuleA.capsuleCid
    queryParent.hasParent = true
    queryParent.limit = 8
    let parentHitsRes = agent.UnimakerAgentRecall(edge, queryParent)
    assert(IsOk(parentHitsRes), " unimaker smoke: recall parent")
    let parentHits = Value(parentHitsRes)
    assert(parentHits.len == 1, " unimaker smoke: recall parent count")
    let parentCid = parentHits[0].capsule.capsuleCid
    assert(layout.FixedBytes32Equal(parentCid, capsuleB.capsuleCid),
        " unimaker smoke: recall parent cid")

    var task = types.AgentTask()
    task.taskId = "task.alpha"
    task.promptText = "continue translation"
    var taskKeywords: str[]
    add(taskKeywords, "invoice")
    add(taskKeywords, "translated")
    task.keywords = taskKeywords
    let planRes = agent.UnimakerAgentPlan(edge, task)
    assert(IsOk(planRes), " unimaker smoke: plan")
    let plan = Value(planRes)
    assert(plan.actionKind == types.UnimakerPlanActionReuseMemory, " unimaker smoke: plan action")
    assert(plan.memoryHitCount == 2, " unimaker smoke: plan hit count")
    assert(plan.selectedCapsuleCids.len >= 1, " unimaker smoke: plan selected")

    let helloPayload = agent.UnimakerAgentHelloPayload(edge)
    let helloRes = proto.UnimakerProtocolDecodeHello(helloPayload)
    assert(IsOk(helloRes), " unimaker smoke: decode hello")
    assert(Value(helloRes).identity.didText == edge.identity.didText, " unimaker smoke: hello did")
    assert(Value(helloRes).genes.len == edge.genes.len, " unimaker smoke: hello genes")

    var taskWire = proto.EvoMapA2ATask()
    taskWire.version = types.UnimakerProtocolVersion
    taskWire.requesterPeerIdText = edge.identity.peerIdText
    taskWire.task = task
    var contextCapsuleCids: layout.FixedBytes32[]
    add(contextCapsuleCids, capsuleA.capsuleCid)
    add(contextCapsuleCids, capsuleB.capsuleCid)
    taskWire.contextCapsuleCids = contextCapsuleCids
    let taskPayload = proto.UnimakerProtocolEncodeTask(taskWire)
    let taskDecodeRes = proto.UnimakerProtocolDecodeTask(taskPayload)
    assert(IsOk(taskDecodeRes), " unimaker smoke: decode task")
    assert(Value(taskDecodeRes).task.taskId == task.taskId, " unimaker smoke: task id")
    assert(Value(taskDecodeRes).contextCapsuleCids.len == 2, " unimaker smoke: task context count")

    let resultPayload = agent.UnimakerAgentResultPayload(edge, plan)
    let resultRes = proto.UnimakerProtocolDecodeResult(resultPayload)
    assert(IsOk(resultRes), " unimaker smoke: decode result")
    assert(Value(resultRes).taskId == task.taskId, " unimaker smoke: result task id")
    assert(Value(resultRes).memoryHitCount == 2, " unimaker smoke: result hit count")

    var peer = types.UnimakerSyncPeer()
    peer.peerIdText = "peer.remote"
    peer.transportKind = types.UnimakerTransportHttpJson
    peer.trusted = true
    let pushRes = agent.UnimakerAgentSyncPush(edge, peer)
    assert(IsOk(pushRes), " unimaker smoke: sync push")
    assert(Value(pushRes).pushedCount == 2, " unimaker smoke: sync push count")
    let pushDecodeRes = proto.UnimakerProtocolDecodePush(peer.outboundPushPayload)
    if IsErr(pushDecodeRes):
        panic(strutil.Join([" unimaker smoke: decode push: ", Error(pushDecodeRes)], ""))
    assert(Value(pushDecodeRes).capsules.len == 2, " unimaker smoke: push capsule count")

    let badHelloPayload = strutil.Replace(helloPayload, "\"version\":1", "\"version\":2")
    let badHelloRes = proto.UnimakerProtocolDecodeHello(badHelloPayload)
    assert(IsErr(badHelloRes), " unimaker smoke: bad hello version")

    let badPushPayload = strutil.Replace(peer.outboundPushPayload,
                                         layout.FixedBytes32Hex(capsuleA.capsuleCid),
                                         layout.FixedBytes32Hex(layout.FixedBytes32()))
    let badPushRes = proto.UnimakerProtocolDecodePush(badPushPayload)
    assert(IsErr(badPushRes), " unimaker smoke: bad push cid")

    unimakerSmokeCleanup(tmpRoot)
    echo(" unimaker_edge_agent_smoke ok")
    return 0
