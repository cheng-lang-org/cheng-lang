import std/system
import cheng/core/runtime/tcp_bridge_abi as bridge
import cheng/libp2p/transports/tcp_transport as tcp

fn clearBytes(data: var Bytes) =
    data = emptyBytes()

fn main(): int32 =
    let allocBefore: int64 = memAllocCount()
    let freeBefore: int64 = memFreeCount()
    let liveBefore: int64 = memLiveCount()

    var source: Bytes = bytesAlloc(4)
    bytesSet(source, 0, int32('a'))
    bytesSet(source, 1, int32('b'))
    bytesSet(source, 2, int32('c'))
    bytesSet(source, 3, int32('d'))
    let sourcePtr = source.data
    assert(memRefCount(sourcePtr) == 1, " bytes buffer handle snapshot: source rc before first bridge")

    let handleA = bridge.cheng_buffer_handle_from_raw_bridge(source.data, source.len)
    assert(handleA != uint64(0), " bytes buffer handle snapshot: first handle create")
    assert(memRefCount(sourcePtr) == 1, " bytes buffer handle snapshot: first bridge does not retain source")

    bytesSet(source, 0, int32('z'))
    bytesSet(source, 1, int32('y'))
    bytesSet(source, 2, int32('x'))
    bytesSet(source, 3, int32('w'))

    let handleB = bridge.cheng_buffer_handle_from_raw_bridge(source.data, source.len)
    assert(handleB != uint64(0), " bytes buffer handle snapshot: second handle create")
    assert(memRefCount(sourcePtr) == 1, " bytes buffer handle snapshot: second bridge does not retain source")

    source = emptyBytes()
    assert(memRefCount(sourcePtr) == 0, " bytes buffer handle snapshot: source release")

    let copiedResA = tcp.Libp2pTcpBytesFromHandle(handleA)
    let copiedResB = tcp.Libp2pTcpBytesFromHandle(handleB)
    assert(IsOk(copiedResA), " bytes buffer handle snapshot: first handle decode")
    assert(IsOk(copiedResB), " bytes buffer handle snapshot: second handle decode")

    var copiedA: Bytes = Value(copiedResA)
    var copiedB: Bytes = Value(copiedResB)
    assert(copiedA.len == 4, " bytes buffer handle snapshot: first copy len")
    assert(copiedB.len == 4, " bytes buffer handle snapshot: second copy len")
    assert(bytesGet(copiedA, 0) == int32('a'), " bytes buffer handle snapshot: first copy byte 0")
    assert(bytesGet(copiedA, 1) == int32('b'), " bytes buffer handle snapshot: first copy byte 1")
    assert(bytesGet(copiedA, 2) == int32('c'), " bytes buffer handle snapshot: first copy byte 2")
    assert(bytesGet(copiedA, 3) == int32('d'), " bytes buffer handle snapshot: first copy byte 3")
    assert(bytesGet(copiedB, 0) == int32('z'), " bytes buffer handle snapshot: second copy byte 0")
    assert(bytesGet(copiedB, 1) == int32('y'), " bytes buffer handle snapshot: second copy byte 1")
    assert(bytesGet(copiedB, 2) == int32('x'), " bytes buffer handle snapshot: second copy byte 2")
    assert(bytesGet(copiedB, 3) == int32('w'), " bytes buffer handle snapshot: second copy byte 3")
    assert(copiedA.data != copiedB.data, " bytes buffer handle snapshot: decode copies stay disjoint")

    bytesSet(copiedA, 0, int32('q'))
    assert(bytesGet(copiedA, 0) == int32('q'), " bytes buffer handle snapshot: first copy mutate")
    assert(bytesGet(copiedB, 0) == int32('z'), " bytes buffer handle snapshot: second copy survives first mutate")

    clearBytes(copiedA)
    clearBytes(copiedB)

    let allocDelta: int64 = memAllocCount() - allocBefore
    let freeDelta: int64 = memFreeCount() - freeBefore
    let liveDelta: int64 = memLiveCount() - liveBefore
    assert(allocDelta == freeDelta, " bytes buffer handle snapshot: alloc/free balanced")
    assert(liveDelta == 0, " bytes buffer handle snapshot: live delta zero")

    echo(" bytes_buffer_handle_snapshot_smoke ok")
    return 0
