fn EmptyText(): str =
    var out: str
    return out

fn CountOne(): int32 =
    return 1

fn UseTextCount(text: str, count: int32): int32 =
    return count

fn RunWithText(text: str): int32 =
    let count: int32 = CountOne()
    return UseTextCount(text, count)

fn main(): int32 =
    let text = EmptyText()
    return RunWithText(text)
