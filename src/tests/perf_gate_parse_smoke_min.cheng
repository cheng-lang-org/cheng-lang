import std/system
import std/strutils as strutil
import cheng/core/tooling/perf_gate as perfgate

fn main() =
    let line: str = "sha256 ns_per_op=10.000"
    assert(perfgate.BenchFirstField(line) == "sha256", "perf gate first field")
    assert(perfgate.BenchFindValue(line, "ns_per_op=") == "10.000", "perf gate find value")
    assert(perfgate.BenchParseDecimalMilli("10.000") == int64(10000), "perf gate parse milli")
    let parts: str[] = strutil.Split("sha256 ns_per_op=10.000\nx25519 ns_per_op=20.500\n", '\n')
    assert(parts.len == 3, "perf gate split rows")
    let splitLine: str = strutil.Strip(parts[0])
    assert(splitLine == line, "perf gate strip line")
    assert(perfgate.BenchFirstField(splitLine) == "sha256", "perf gate split first field")
    assert(perfgate.BenchFindValue(splitLine, "ns_per_op=") == "10.000", "perf gate split find value")
