import std/system
import std/rawbytes

fn bytesLocalEpilogueValue(): int32 =
    var payload = bytesAlloc(1)
    bytesSet(payload, 0, int32('a'))
    return bytesGet(payload, 0)

fn bytesLocalEpilogueParam(payload: Bytes): int32 =
    return bytesGet(payload, 0)

fn main(): int32 =
    let liveBefore: int64 = memLiveCount()
    let localValue: int32 = bytesLocalEpilogueValue()
    let liveAfterLocal: int64 = memLiveCount()
    assert(localValue == int32('a'), " bytes local epilogue orc: local return value")
    assert(liveAfterLocal == liveBefore, " bytes local epilogue orc: local payload released")

    var shared = bytesAlloc(1)
    bytesSet(shared, 0, int32('b'))
    let liveBeforeParam: int64 = memLiveCount()
    let paramValue: int32 = bytesLocalEpilogueParam(shared)
    let liveAfterParam: int64 = memLiveCount()
    assert(paramValue == int32('b'), " bytes local epilogue orc: param return value")
    assert(liveAfterParam == liveBeforeParam, " bytes local epilogue orc: param retain balanced")

    BytesFree(shared)
    assert(memLiveCount() == liveBefore, " bytes local epilogue orc: final live delta zero")
    echo(" bytes_local_epilogue_orc_smoke ok")
    return 0
