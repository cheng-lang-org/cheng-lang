type IntResult = Ok(value: int32) | Err(code: int32)

fn Check(flag: int32): IntResult =
    if flag == 1:
        return Ok(1)
    return Err(7)

fn UseCall(): IntResult =
    Check(1)?
    Check(0)?
    return Ok(99)

fn main(): int32 =
    let result = UseCall()
    match result:
        Ok(value) =>
            return value
        Err(code) =>
            return code
