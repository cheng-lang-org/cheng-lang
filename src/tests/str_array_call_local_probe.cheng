import std/os
import std/strutils as strutil

fn MakeFlag(prefix: str, value: str): str =
    var parts: str[]
    add(parts, prefix)
    add(parts, value)
    return strutil.Join(parts, "")

fn Sink(args: str[]): int32 =
    echo(args[1])
    return args.len

fn main(): int32 =
    let root = os.GetCurrentDir()
    let args = [
        "system-link-exec",
        MakeFlag("--root:", root),
        "--emit:exe"
    ]
    let count = Sink(args)
    assert(count == 3, " str array call local: count")
    return 0
