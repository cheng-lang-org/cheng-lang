import std/system
import std/cmdline as cmdline
import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net
import cheng/libp2p/core/types
import cheng/libp2p/transports/tcp_transport

fn main(): int32 =
    let upstreamPort = cmdline.ReadInt32FlagOrDefault("--upstream-port", -1)
    assert(upstreamPort > 0, "v3 chain_node process relay: invalid upstream port")

    let port = cmdline.ReadInt32FlagOrDefault("--port", 0)
    let ready_path_value = cmdline.ReadFlagOrDefault("--ready-path", "")

    var relay: node.V3ChainNode
    assert(IsOk(node.v3ChainNodeInitInto(relay, "process.relay", "process.loopback")),
           "v3 chain_node: init")
    let payloadRes = tcp_transport.v3Libp2pTcpRecvPayloadOnce("127.0.0.1",
                                                              upstreamPort,
                                                              types.v3Libp2pProtocolSync)
    assert(payloadRes.ok, "v3 chain_node process relay: recv payload")

    var snapshot: node.V3ChainNodeServeSnapshot
    let snapshotRes = net.v3ChainNodeLibp2pDecodeSnapshotInto(payloadRes.value, snapshot)
    assert(snapshotRes.ok, "v3 chain_node process relay: decode snapshot")

    let syncRes = node.v3ChainNodeSyncOnce(relay, snapshot)
    assert(syncRes.ok, "v3 chain_node process relay: sync")
    assert(syncRes.value, "v3 chain_node process relay: sync changed")

    let aliceRes = node.v3ChainNodeBalance(relay, 11, 1001)
    let bobRes = node.v3ChainNodeBalance(relay, 11, 2002)
    assert(aliceRes.ok, "v3 chain_node process relay: alice balance")
    assert(bobRes.ok, "v3 chain_node process relay: bob balance")
    assert(aliceRes.value == int64(55), "v3 chain_node process relay: alice 55")
    assert(bobRes.value == int64(33), "v3 chain_node process relay: bob 33")

    var relaySnapshot: node.V3ChainNodeServeSnapshot
    node.v3ChainNodeServeOnceInto(relaySnapshot, relay)
    assert(layout.fixedBytes32Equal(relaySnapshot.tipEventCid, snapshot.tipEventCid),
        "v3 chain_node process relay: tip cid")
    assert(layout.fixedBytes32Equal(relaySnapshot.forest.forestCid, snapshot.forest.forestCid),
        "v3 chain_node process relay: forest cid")
    assert(anti.v3AntiEntropySignatureEqual(relaySnapshot.signature, snapshot.signature),
        "v3 chain_node process relay: signature")

    let relayPayload = net.v3ChainNodeLibp2pEncodeSnapshot(relaySnapshot)
    let serveRes = tcp_transport.v3Libp2pTcpServePayloadOnce("127.0.0.1",
                                                             port,
                                                             types.v3Libp2pProtocolSync,
                                                             relayPayload,
                                                             ready_path_value)
    assert(serveRes.ok, "v3 chain_node process relay: serve once")
    echo("v3 chain_node_process_relay_smoke ok")
    return 0
