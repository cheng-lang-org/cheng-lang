import std/system
import std/cmdline as cmdline
import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net
import cheng/libp2p/core/types
import cheng/libp2p/transports/tcp_transport

fn main(): int32 =
    let upstreamPort = cmdline.ReadInt32FlagOrDefault("--upstream-port", -1)
    assert(upstreamPort > 0, " chain_node process relay: invalid upstream port")

    let port = cmdline.ReadInt32FlagOrDefault("--port", 0)
    let ready_path_value = cmdline.ReadFlagOrDefault("--ready-path", "")

    var relay: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(relay, "process.relay", "process.loopback")),
           " chain_node: init")
    let payloadRes = tcp_transport.Libp2pTcpRecvPayloadOnce("127.0.0.1",
                                                              upstreamPort,
                                                              types.Libp2pProtocolSync)
    assert(payloadRes.ok, " chain_node process relay: recv payload")

    var snapshot: node.ChainNodeServeSnapshot
    let snapshotRes = net.ChainNodeLibp2pDecodeSnapshotInto(payloadRes.value, snapshot)
    assert(snapshotRes.ok, " chain_node process relay: decode snapshot")

    let syncRes = node.ChainNodeSyncOnce(relay, snapshot)
    assert(syncRes.ok, " chain_node process relay: sync")
    assert(syncRes.value, " chain_node process relay: sync changed")

    let aliceRes = node.ChainNodeBalance(relay, 11, 1001)
    let bobRes = node.ChainNodeBalance(relay, 11, 2002)
    assert(aliceRes.ok, " chain_node process relay: alice balance")
    assert(bobRes.ok, " chain_node process relay: bob balance")
    assert(aliceRes.value == int64(55), " chain_node process relay: alice 55")
    assert(bobRes.value == int64(33), " chain_node process relay: bob 33")

    var relaySnapshot: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(relaySnapshot, relay)
    assert(layout.FixedBytes32Equal(relaySnapshot.tipEventCid, snapshot.tipEventCid),
        " chain_node process relay: tip cid")
    assert(layout.FixedBytes32Equal(relaySnapshot.forest.forestCid, snapshot.forest.forestCid),
        " chain_node process relay: forest cid")
    assert(anti.AntiEntropySignatureEqual(relaySnapshot.signature, snapshot.signature),
        " chain_node process relay: signature")

    let relayPayload = net.ChainNodeLibp2pEncodeSnapshot(relaySnapshot)
    let serveRes = tcp_transport.Libp2pTcpServePayloadOnce("127.0.0.1",
                                                             port,
                                                             types.Libp2pProtocolSync,
                                                             relayPayload,
                                                             ready_path_value)
    assert(serveRes.ok, " chain_node process relay: serve once")
    echo(" chain_node_process_relay_smoke ok")
    return 0
