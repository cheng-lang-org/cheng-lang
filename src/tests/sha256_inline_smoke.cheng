import std/system
import std/rawbytes
import std/crypto/sha256

fn main(): int32 =
    let data: Bytes = bytesFromString("abc")
    var h0: int64 = sha256.u32FromBytes(0x6a, 0x09, 0xe6, 0x67)
    var h1: int64 = sha256.u32FromBytes(0xbb, 0x67, 0xae, 0x85)
    var h2: int64 = sha256.u32FromBytes(0x3c, 0x6e, 0xf3, 0x72)
    var h3: int64 = sha256.u32FromBytes(0xa5, 0x4f, 0xf5, 0x3a)
    var h4: int64 = sha256.u32FromBytes(0x51, 0x0e, 0x52, 0x7f)
    var h5: int64 = sha256.u32FromBytes(0x9b, 0x05, 0x68, 0x8c)
    var h6: int64 = sha256.u32FromBytes(0x1f, 0x83, 0xd9, 0xab)
    var h7: int64 = sha256.u32FromBytes(0x5b, 0xe0, 0xcd, 0x19)

    let inputLen: int32 = bytesLen(data)
    var padZero: int32
    while ((inputLen + 1 + padZero) % 64) != 56:
        padZero = padZero + 1
    let totalLen: int32 = inputLen + 1 + padZero + 8
    let msg: Bytes = bytesAlloc(totalLen)
    if inputLen > 0:
        for i in 0..<inputLen:
            bytesSet(msg, i, bytesGet(data, i))
    bytesSet(msg, inputLen, 0x80)
    var bitLen: int64 = int64(inputLen) * 8
    for i in 0..<8:
        let byteVal: int64 = bitLen & 255
        bytesSet(msg, totalLen - 1 - i, int32(byteVal))
        bitLen = bitLen >> 8

    let wbufLen: int32 = 64 * 4
    let wbuf: Bytes = bytesAlloc(wbufLen)
    var offset: int32
    var blockCount: int32
    var finalA: int64
    var finalB: int64
    var finalC: int64
    var finalD: int64
    var finalE: int64
    var finalF: int64
    var finalG: int64
    var finalH: int64
    while offset < totalLen:
        blockCount = blockCount + 1
        assert(h0 == sha256.u32FromBytes(0x6a, 0x09, 0xe6, 0x67), " sha256 inline: h0 init")
        assert(h4 == sha256.u32FromBytes(0x51, 0x0e, 0x52, 0x7f), " sha256 inline: h4 init")
        for t in 0..<16:
            let word: int64 = sha256.getU32BE(msg, offset + t * 4)
            sha256.setU32BE(wbuf, t * 4, word)
        t = 16
        let __for_start_t_1 = t
        for __for_t_1 in __for_start_t_1..<64:
            t = __for_t_1
            let w2: int64 = sha256.getU32BE(wbuf, (t - 2) * 4)
            let w7: int64 = sha256.getU32BE(wbuf, (t - 7) * 4)
            let w15: int64 = sha256.getU32BE(wbuf, (t - 15) * 4)
            let w16: int64 = sha256.getU32BE(wbuf, (t - 16) * 4)
            let sum: int64 = w16 + sha256.smallSigma0(w15) + w7 + sha256.smallSigma1(w2)
            let next: int64 = sha256.u32(sum)
            sha256.setU32BE(wbuf, t * 4, next)
            t = t + 1

        var a: int64 = h0
        var b: int64 = h1
        var c: int64 = h2
        var d: int64 = h3
        var e: int64 = h4
        var f: int64 = h5
        var g: int64 = h6
        var h: int64 = h7
        assert(a == sha256.u32FromBytes(0x6a, 0x09, 0xe6, 0x67), " sha256 inline: a init")
        assert(e == sha256.u32FromBytes(0x51, 0x0e, 0x52, 0x7f), " sha256 inline: e init")
        assert(h == sha256.u32FromBytes(0x5b, 0xe0, 0xcd, 0x19), " sha256 inline: h init")

        t = 0
        let __for_start_t_2 = t
        for __for_t_2 in __for_start_t_2..<64:
            t = __for_t_2
            let wt: int64 = sha256.getU32BE(wbuf, t * 4)
            if t == 0:
                assert(wt == sha256.u32FromBytes(0x61, 0x62, 0x63, 0x80), " sha256 inline: w0")
            let sum1: int64 = h + sha256.bigSigma1(e) + sha256.ch(e, f, g) + sha256.k256(t) + wt
            let t1: int64 = sha256.u32(sum1)
            let sum2: int64 = sha256.bigSigma0(a) + sha256.maj(a, b, c)
            let t2: int64 = sha256.u32(sum2)
            h = g
            g = f
            f = e
            let sumE: int64 = d + t1
            e = sha256.u32(sumE)
            d = c
            c = b
            b = a
            let sumA: int64 = t1 + t2
            a = sha256.u32(sumA)
            t = t + 1
            if t == 1:
                assert(a == sha256.u32FromBytes(0x5d, 0x6a, 0xeb, 0xcd), " sha256 inline: a0")
                assert(e == sha256.u32FromBytes(0xfa, 0x2a, 0x46, 0x22), " sha256 inline: e0")
            if t == 32:
                assert(a == sha256.u32FromBytes(0x73, 0xb3, 0x3b, 0xf5), " sha256 inline: a31")
                assert(e == sha256.u32FromBytes(0xba, 0x59, 0x11, 0x12), " sha256 inline: e31")
            if t == 64:
                assert(a == sha256.u32FromBytes(0x50, 0x6e, 0x30, 0x58), " sha256 inline: a63")
                assert(e == sha256.u32FromBytes(0x5e, 0xf5, 0x0f, 0x24), " sha256 inline: e63")

        finalA = a
        finalB = b
        finalC = c
        finalD = d
        finalE = e
        finalF = f
        finalG = g
        finalH = h
        offset = offset + 64

    assert(blockCount == 1, " sha256 inline: block count")
    assert(offset == 64, " sha256 inline: final offset")
    assert(finalA == sha256.u32FromBytes(0x50, 0x6e, 0x30, 0x58), " sha256 inline: finalA")
    assert(finalE == sha256.u32FromBytes(0x5e, 0xf5, 0x0f, 0x24), " sha256 inline: finalE")
    h0 = sha256.u32(h0 + finalA)
    h1 = sha256.u32(h1 + finalB)
    h2 = sha256.u32(h2 + finalC)
    h3 = sha256.u32(h3 + finalD)
    h4 = sha256.u32(h4 + finalE)
    h5 = sha256.u32(h5 + finalF)
    h6 = sha256.u32(h6 + finalG)
    h7 = sha256.u32(h7 + finalH)
    assert(h0 == sha256.u32FromBytes(0xba, 0x78, 0x16, 0xbf), " sha256 inline: h0")
    assert(h1 == sha256.u32FromBytes(0x8f, 0x01, 0xcf, 0xea), " sha256 inline: h1")
    assert(h7 == sha256.u32FromBytes(0xf2, 0x00, 0x15, 0xad), " sha256 inline: h7")
    let out: Bytes = bytesAlloc(32)
    sha256.setU32BE(out, 0, h0)
    sha256.setU32BE(out, 4, h1)
    sha256.setU32BE(out, 8, h2)
    sha256.setU32BE(out, 12, h3)
    sha256.setU32BE(out, 16, h4)
    sha256.setU32BE(out, 20, h5)
    sha256.setU32BE(out, 24, h6)
    sha256.setU32BE(out, 28, h7)
    assert(bytesGet(out, 0) == 0xba, " sha256 inline: digest byte0")
    assert(bytesGet(out, 1) == 0x78, " sha256 inline: digest byte1")
    assert(bytesGet(out, 31) == 0xad, " sha256 inline: digest byte31")
    echo(" sha256_inline_smoke ok")
    return 0
