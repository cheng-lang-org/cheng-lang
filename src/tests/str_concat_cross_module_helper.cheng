import std/strutils as strutil
type
    DummyResult =
        Label: str
        FilePath: str
        LogPath: str
        Text: str
        ExitCode: int32

fn Sink(root: str,
        label: str,
        filePathRaw: str,
        argv: str[],
        envOverrides: str[],
        workingDirRaw: str,
        timeoutSec: int32,
        logPathRaw: str): DummyResult =
    root
    label
    filePathRaw
    envOverrides
    workingDirRaw
    timeoutSec
    logPathRaw
    let joined = strutil.Join([argv[0], " ", argv[1]], "")
    return DummyResult(Label: label,
                       FilePath: filePathRaw,
                       LogPath: logPathRaw,
                       Text: joined,
                       ExitCode: 0)
