import cheng/core/tooling/path as v3path
import cheng/core/lang/parser
import cheng/core/backend/lowering_plan as lower

fn main(): int32 =
    let workspaceRoot = v3path.V3PathCurrentDir()
    let packageRoot = workspaceRoot
    let sourcePath = v3path.V3PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let text = v3path.V3ReadTextFile("", sourcePath)
    let lines = parser.v3ParserSplitChar(text, '\n')
    var functionName = ""
    for i in 0..<lines.len:
        let line = lines[i]
        let current = parser.v3ParserFunctionNameFromLine(line)
        if current != "":
            functionName = current
    assert(functionName == "main", "v3 lowering line local: function name")
    let symbolText = lower.v3LoweringFunctionSymbolText("cheng/tests/program_selfhost_smoke", functionName)
    assert(symbolText == "cheng/tests/program_selfhost_smoke::main",
           "v3 lowering line local: symbol text")
    echo("v3 lowering_line_local_smoke ok")
    return 0
