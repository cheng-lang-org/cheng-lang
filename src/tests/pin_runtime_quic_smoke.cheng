import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as binary
import cheng/chain/lsmr_types as lt
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/pubsub
import cheng/chain/pin_plane as pin
import cheng/chain/pin_runtime as runtime
import cheng/chain/pin_runtime_host as runtime_host
import cheng/chain/pin_runtime_host_quic as runtime_host_quic
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/host/host

fn pinRuntimeQuicSmokeBytesEqual(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn pinRuntimeQuicSmokeBlob(parts: Bytes[]): Bytes =
    var total = 0
    for i in 0..<parts.len:
        total = total + bytesLen(parts[i])
    var buf: layout.ByteBuf = layout.ByteBufInit(total)
    for i in 0..<parts.len:
        layout.ByteBufAppendBytes(buf, parts[i])
    return layout.ByteBufToBytes(buf)

fn pinRuntimeQuicSmokeBuildResponses(out: var swarm.ErasureShardPullResponse[],
                                     manifest: swarm.ErasureShardManifest,
                                     shardPayloads: Bytes[]) =
    out = []
    for i in 0..<manifest.shardCount:
        let requestRes = swarm.ErasureShardPullRequestMake(manifest, manifest.shardIndices[i])
        assert(IsOk(requestRes), " pin runtime quic smoke: request")
        var response = swarm.ErasureShardPullResponse()
        let responseFillRes = swarm.ErasureShardPullResponseFill(response,
                                                                   Value(requestRes),
                                                                   shardPayloads[i])
        assert(IsOk(responseFillRes), " pin runtime quic smoke: response")
        add(out, response)

fn main(): int32 =
    var authorHost = host.Libp2pHostInit("pin.runtime.quic.author")
    var providerHost = host.Libp2pHostInit("pin.runtime.quic.provider")
    var authorRuntime = runtime.PinRuntimeInit()
    var providerRuntime = runtime.PinRuntimeInit()

    var authorAddr: types.Libp2pMultiaddr
    var providerAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(authorAddr, "127.0.0.1", 0)
    multiaddr.Libp2pMultiaddrFillQuic(providerAddr, "127.0.0.1", 0)
    let authorListenRes = host.Libp2pListen(authorHost, authorAddr)
    assert(IsOk(authorListenRes), " pin runtime quic smoke: author listen")
    let providerListenRes = host.Libp2pListen(providerHost, providerAddr)
    assert(IsOk(providerListenRes), " pin runtime quic smoke: provider listen")
    host.Libp2pRegisterHandler(authorHost, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(providerHost, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(authorHost, types.Libp2pProtocolPin)
    host.Libp2pRegisterHandler(providerHost, types.Libp2pProtocolPin)
    let dialProviderToAuthorRes = host.Libp2pDial(providerHost,
                                                    authorHost.selfPeerId,
                                                    authorAddr,
                                                    overlay.OverlayRoleEdgeRelayStore)
    assert(IsOk(dialProviderToAuthorRes), " pin runtime quic smoke: provider->author dial")
    let dialAuthorToProviderRes = host.Libp2pDial(authorHost,
                                                    providerHost.selfPeerId,
                                                    providerAddr,
                                                    overlay.OverlayRoleEdgeRelayStore)
    assert(IsOk(dialAuthorToProviderRes), " pin runtime quic smoke: author->provider dial")

    var address = binary.LsmrAddress()
    let addressRes = binary.LsmrAddressFromDigits([6, 6, 6])
    assert(IsOk(addressRes), " pin runtime quic smoke: address")
    address = Value(addressRes)
    let scope = overlay.OverlayScopeRegion

    let shard0 = bytesFromString("quic-a")
    let shard1 = bytesFromString("quic-b")
    let shard2 = bytesFromString("quic-c")
    var shardPayloads: Bytes[]
    shardPayloads = []
    add(shardPayloads, shard0)
    add(shardPayloads, shard1)
    add(shardPayloads, shard2)
    let blob = pinRuntimeQuicSmokeBlob(shardPayloads)
    let summaryRes = dag.DagBlobSummaryFromBytes(blob, 6)
    assert(IsOk(summaryRes), " pin runtime quic smoke: summary")
    let summary = Value(summaryRes)
    let paramsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic, 3, 0, 6)
    assert(IsOk(paramsRes), " pin runtime quic smoke: params")
    let params = Value(paramsRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    for i in 0..<shardPayloads.len:
        add(shardPayloadCids, swarm.ErasureShardPayloadCid(shardPayloads[i]))
    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    assert(IsOk(manifestRes), " pin runtime quic smoke: manifest")
    let manifest = Value(manifestRes)

    let bundleCid = lt.HashInts("cheng.pin.runtime.quic.bundle", [44, 55, 66])
    let offerRes = pin.PinOfferMake(bundleCid,
                                      summary.summaryCid,
                                      summary.blobCid,
                                      manifest.manifestCid,
                                      140,
                                      2,
                                      88,
                                      34)
    assert(IsOk(offerRes), " pin runtime quic smoke: offer")
    let offer = Value(offerRes)
    let publishOfferRes = runtime_host.PinRuntimePublishOffer(authorHost, scope, address, offer, 21, 31)
    assert(IsOk(publishOfferRes), " pin runtime quic smoke: publish offer")
    let fetchedOfferRes = runtime_host_quic.PinRuntimeFetchOffer(providerHost,
                                                                   authorHost,
                                                                   authorHost.selfPeerId,
                                                                   scope,
                                                                   address,
                                                                   offer.offerCid)
    if IsErr(fetchedOfferRes):
        panic(ErrorText(fetchedOfferRes))
    assert(IsOk(fetchedOfferRes), " pin runtime quic smoke: fetch offer")
    let fetchedOffer = Value(fetchedOfferRes)
    assert(pinRuntimeQuicSmokeBytesEqual(pin.PinOfferEncode(fetchedOffer), pin.PinOfferEncode(offer)),
        " pin runtime quic smoke: fetched offer payload")

    let acceptRes = pin.PinAcceptMake(fetchedOffer, providerHost.selfPeerId.value, 180)
    assert(IsOk(acceptRes), " pin runtime quic smoke: accept")
    let accept = Value(acceptRes)
    var responses: swarm.ErasureShardPullResponse[]
    pinRuntimeQuicSmokeBuildResponses(responses, manifest, shardPayloads)
    let acceptedStateRes = runtime.PinRuntimeStoreAcceptedState(providerRuntime,
                                                                  fetchedOffer,
                                                                  accept,
                                                                  manifest,
                                                                  params,
                                                                  responses)
    assert(IsOk(acceptedStateRes), " pin runtime quic smoke: accepted state")
    let publishAcceptRes = runtime_host.PinRuntimePublishAccept(providerHost, scope, address, accept, 22, 32)
    assert(IsOk(publishAcceptRes), " pin runtime quic smoke: publish accept")

    let fetchedAcceptRes = runtime_host_quic.PinRuntimeFetchAccept(authorHost,
                                                                     providerHost,
                                                                     providerHost.selfPeerId,
                                                                     scope,
                                                                     address,
                                                                     accept.acceptCid)
    if IsErr(fetchedAcceptRes):
        panic(ErrorText(fetchedAcceptRes))
    assert(IsOk(fetchedAcceptRes), " pin runtime quic smoke: fetch accept")
    let fetchedAccept = Value(fetchedAcceptRes)
    let schedulerStateRes = runtime.PinRuntimeStoreChallengerState(authorRuntime,
                                                                     fetchedOffer,
                                                                     fetchedAccept,
                                                                     manifest,
                                                                     params,
                                                                     111,
                                                                     2,
                                                                     1)
    assert(IsOk(schedulerStateRes), " pin runtime quic smoke: scheduler state")
    assert(authorRuntime.schedules.len == 1, " pin runtime quic smoke: author schedule ready")

    let retryOpenRes = runtime.PinRuntimeOpenChallenge(authorRuntime, fetchedAccept.acceptCid, 111)
    assert(IsOk(retryOpenRes), " pin runtime quic smoke: retry open")
    let retryChallenge = Value(retryOpenRes)
    let retryOfferRes = runtime.PinRuntimeFindOffer(authorRuntime, retryChallenge.offerCid)
    assert(IsOk(retryOfferRes), " pin runtime quic smoke: retry offer")
    let retryOffer = Value(retryOfferRes)
    let retryAcceptRes = runtime.PinRuntimeFindAccept(authorRuntime, fetchedAccept.acceptCid)
    assert(IsOk(retryAcceptRes), " pin runtime quic smoke: retry accept")
    let retryAccept = Value(retryAcceptRes)
    let retryManifestRes = runtime.PinRuntimeFindManifest(authorRuntime, retryChallenge.manifestCid)
    assert(IsOk(retryManifestRes), " pin runtime quic smoke: retry manifest")
    let retryManifest = Value(retryManifestRes)
    let retryProofRes = runtime_host_quic.PinRuntimeRequestProof(authorHost,
                                                                   providerHost,
                                                                   providerHost.selfPeerId,
                                                                   retryChallenge,
                                                                   retryOffer,
                                                                   retryAccept,
                                                                   retryManifest)
    assert(IsErr(retryProofRes), " pin runtime quic smoke: retry proof missing")
    let retryStepRes = runtime.PinRuntimeNoteChallengeFailure(authorRuntime, fetchedAccept.acceptCid, 111)
    assert(IsOk(retryStepRes), " pin runtime quic smoke: retry step")
    let retryStep = Value(retryStepRes)
    assert(retryStep.outcomeKind == runtime.PinRuntimeStepKindRetry,
        " pin runtime quic smoke: retry outcome")
    assert(retryStep.retryCount == 1, " pin runtime quic smoke: retry count")

    host.Libp2pAttachPinRuntime(providerHost, providerRuntime)
    let rewardOpen1Res = runtime.PinRuntimeOpenChallenge(authorRuntime, fetchedAccept.acceptCid, 112)
    assert(IsOk(rewardOpen1Res), " pin runtime quic smoke: reward open1")
    let rewardChallenge1 = Value(rewardOpen1Res)
    let rewardOffer1Res = runtime.PinRuntimeFindOffer(authorRuntime, rewardChallenge1.offerCid)
    assert(IsOk(rewardOffer1Res), " pin runtime quic smoke: reward offer1")
    let rewardOffer1 = Value(rewardOffer1Res)
    let rewardAccept1Res = runtime.PinRuntimeFindAccept(authorRuntime, fetchedAccept.acceptCid)
    assert(IsOk(rewardAccept1Res), " pin runtime quic smoke: reward accept1")
    let rewardAccept1 = Value(rewardAccept1Res)
    let rewardManifest1Res = runtime.PinRuntimeFindManifest(authorRuntime, rewardChallenge1.manifestCid)
    assert(IsOk(rewardManifest1Res), " pin runtime quic smoke: reward manifest1")
    let rewardManifest1 = Value(rewardManifest1Res)
    let rewardProof1Res = runtime_host_quic.PinRuntimeRequestProof(authorHost,
                                                                     providerHost,
                                                                     providerHost.selfPeerId,
                                                                     rewardChallenge1,
                                                                     rewardOffer1,
                                                                     rewardAccept1,
                                                                     rewardManifest1)
    assert(IsOk(rewardProof1Res), " pin runtime quic smoke: reward proof1")
    let rewardStep1Res = runtime.PinRuntimeCompleteChallenge(authorRuntime,
                                                               fetchedAccept.acceptCid,
                                                               Value(rewardProof1Res),
                                                               112)
    assert(IsOk(rewardStep1Res), " pin runtime quic smoke: reward step1")
    let rewardStep1 = Value(rewardStep1Res)
    let publishSettlement1Res = runtime.PinRuntimeFindSettlement(authorRuntime, rewardStep1.settlementCid)
    assert(IsOk(publishSettlement1Res), " pin runtime quic smoke: local settlement1")
    let publishSettlement1IngressRes = runtime_host.PinRuntimePublishSettlement(authorHost,
                                                                                  scope,
                                                                                  address,
                                                                                  Value(publishSettlement1Res),
                                                                                  24,
                                                                                  34)
    assert(IsOk(publishSettlement1IngressRes), " pin runtime quic smoke: publish settlement1")
    assert(rewardStep1.outcomeKind == runtime.PinRuntimeStepKindReward,
        " pin runtime quic smoke: reward outcome1")
    let fetchedSettlement1Res = runtime_host_quic.PinRuntimeFetchSettlement(providerHost,
                                                                              authorHost,
                                                                              authorHost.selfPeerId,
                                                                              scope,
                                                                              address,
                                                                              rewardStep1.settlementCid)
    assert(IsOk(fetchedSettlement1Res), " pin runtime quic smoke: fetch settlement1")
    let fetchedSettlement1 = Value(fetchedSettlement1Res)
    assert(fetchedSettlement1.status == pin.PinSettlementStatusReward,
        " pin runtime quic smoke: reward status1")

    let rewardOpen2Res = runtime.PinRuntimeOpenChallenge(authorRuntime, fetchedAccept.acceptCid, 113)
    assert(IsOk(rewardOpen2Res), " pin runtime quic smoke: reward open2")
    let rewardChallenge2 = Value(rewardOpen2Res)
    let rewardOffer2Res = runtime.PinRuntimeFindOffer(authorRuntime, rewardChallenge2.offerCid)
    assert(IsOk(rewardOffer2Res), " pin runtime quic smoke: reward offer2")
    let rewardOffer2 = Value(rewardOffer2Res)
    let rewardAccept2Res = runtime.PinRuntimeFindAccept(authorRuntime, fetchedAccept.acceptCid)
    assert(IsOk(rewardAccept2Res), " pin runtime quic smoke: reward accept2")
    let rewardAccept2 = Value(rewardAccept2Res)
    let rewardManifest2Res = runtime.PinRuntimeFindManifest(authorRuntime, rewardChallenge2.manifestCid)
    assert(IsOk(rewardManifest2Res), " pin runtime quic smoke: reward manifest2")
    let rewardManifest2 = Value(rewardManifest2Res)
    let rewardProof2Res = runtime_host_quic.PinRuntimeRequestProof(authorHost,
                                                                     providerHost,
                                                                     providerHost.selfPeerId,
                                                                     rewardChallenge2,
                                                                     rewardOffer2,
                                                                     rewardAccept2,
                                                                     rewardManifest2)
    assert(IsOk(rewardProof2Res), " pin runtime quic smoke: reward proof2")
    let rewardStep2Res = runtime.PinRuntimeCompleteChallenge(authorRuntime,
                                                               fetchedAccept.acceptCid,
                                                               Value(rewardProof2Res),
                                                               113)
    assert(IsOk(rewardStep2Res), " pin runtime quic smoke: reward step2")
    let rewardStep2 = Value(rewardStep2Res)
    let publishSettlement2Res = runtime.PinRuntimeFindSettlement(authorRuntime, rewardStep2.settlementCid)
    assert(IsOk(publishSettlement2Res), " pin runtime quic smoke: local settlement2")
    let publishSettlement2IngressRes = runtime_host.PinRuntimePublishSettlement(authorHost,
                                                                                  scope,
                                                                                  address,
                                                                                  Value(publishSettlement2Res),
                                                                                  25,
                                                                                  35)
    assert(IsOk(publishSettlement2IngressRes), " pin runtime quic smoke: publish settlement2")
    assert(rewardStep2.outcomeKind == runtime.PinRuntimeStepKindReward,
        " pin runtime quic smoke: reward outcome2")
    let fetchedSettlement2Res = runtime_host_quic.PinRuntimeFetchSettlement(providerHost,
                                                                              authorHost,
                                                                              authorHost.selfPeerId,
                                                                              scope,
                                                                              address,
                                                                              rewardStep2.settlementCid)
    assert(IsOk(fetchedSettlement2Res), " pin runtime quic smoke: fetch settlement2")
    let fetchedSettlement2 = Value(fetchedSettlement2Res)
    assert(fetchedSettlement2.status == pin.PinSettlementStatusReward,
        " pin runtime quic smoke: reward status2")

    let challengeCountRes = host.Libp2pPinRuntimeChallengeCount(providerHost)
    assert(IsOk(challengeCountRes), " pin runtime quic smoke: challenge count")
    let proofCountRes = host.Libp2pPinRuntimeProofCount(providerHost)
    assert(IsOk(proofCountRes), " pin runtime quic smoke: proof count")
    assert(Value(challengeCountRes) == 2, " pin runtime quic smoke: challenge count value")
    assert(Value(proofCountRes) == 2, " pin runtime quic smoke: proof count value")
    assert(authorRuntime.schedules.len == 1, " pin runtime quic smoke: schedule count")
    assert(authorRuntime.schedules[0].nextChallengeEpoch == 114,
        " pin runtime quic smoke: next epoch")
    assert(authorRuntime.schedules[0].retryCount == 0, " pin runtime quic smoke: retry reset")
    assert(authorHost.publishLog.len == 3, " pin runtime quic smoke: author publish log")
    assert(authorHost.storeEntries.len == 3, " pin runtime quic smoke: author store")
    assert(providerHost.storeEntries.len == 1, " pin runtime quic smoke: provider store")
    assert(authorHost.openStreamProtocols.len == 4, " pin runtime quic smoke: author stream count")
    assert(providerHost.openStreamProtocols.len == 3, " pin runtime quic smoke: provider stream count")
    assert(authorHost.syncRequestCount == 1, " pin runtime quic smoke: author sync count")
    assert(providerHost.syncRequestCount == 3, " pin runtime quic smoke: provider sync count")

    echo(" pin_runtime_quic_smoke ok")
    return 0
