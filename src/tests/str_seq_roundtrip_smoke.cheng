import std/system
import cheng/core/tooling/path as chengpath
import std/strutils as strutil

fn splitLines(text: str): str[] =
    var out: str[]
    var start: int32
    for i in 0..<text.len:
        if text[i] == '\n':
            add(out, chengpath.TextSlice(text, start, i - start))
            start = i + 1
    if start <= text.len:
        add(out, chengpath.TextSlice(text, start, text.len - start))
    return out

fn main(): int32 =
    let nl = charToString('\n')
    let parts = splitLines(strutil.Join([" alpha ", nl, " beta ", nl], ""))
    var ordered: str[]
    add(ordered, parts[0])
    add(ordered, parts[1])
    let current = ordered[1]
    let trimmed = chengpath.PathTrim(current)
    assert(ordered.len == 2, " str_seq_roundtrip_smoke: len")
    assert(trimmed == "beta", " str_seq_roundtrip_smoke: trim after seq index")
    echo(" str_seq_roundtrip_smoke ok")
    return 0
