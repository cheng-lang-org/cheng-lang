import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/chain/csg

fn main(): int32 =
    let payload0 = lt.HashInts("cheng.test.payload", [1, 10])
    let payload1 = lt.HashInts("cheng.test.payload", [2, 20])
    let payload2 = lt.HashInts("cheng.test.payload", [3, 30])

    let safeGraphRes = csg.BuildCsgSubgraph(
        101,
        [10, 20, 30],
        [csg.CsgNodeKindSource, csg.CsgNodeKindRewrite, csg.CsgNodeKindSink],
        [csg.CsgCapabilityRead, csg.CsgCapabilityRegionalBatch, csg.CsgCapabilityEmit],
        [payload0, payload1, payload2],
        [10, 20],
        [20, 30],
        [csg.CsgEdgeKindData, csg.CsgEdgeKindEmit]
    )
    assert(IsOk(safeGraphRes), " csg smoke: build safe graph")
    let safeGraph = Value(safeGraphRes)
    let filter = csg.DefaultCsgBarrierFilter(lt.LayerRegional, csg.CsgBarrierModeGen)
    let safeDecision = csg.ApplyCsgBarrierFilter(filter, safeGraph)
    assert(safeDecision.accepted, " csg smoke: safe graph accepted")
    assert(safeDecision.deniedNodeIds.len == 0, " csg smoke: no denied nodes")

    let delta = csg.CsgDeltaFromSubgraph(layout.FixedBytes32(), safeGraph)
    assert(delta.nodeCount == 3, " csg smoke: delta node count")
    assert(delta.edgeCount == 2, " csg smoke: delta edge count")

    let unsafeGraphRes = csg.BuildCsgSubgraph(
        102,
        [1, 2],
        [csg.CsgNodeKindSource, csg.CsgNodeKindRewrite],
        [csg.CsgCapabilityRead, csg.CsgCapabilityRawmemWrite],
        [payload0, payload1],
        [1],
        [2],
        [csg.CsgEdgeKindUnsafeWrite]
    )
    assert(IsOk(unsafeGraphRes), " csg smoke: build unsafe graph")
    let unsafeDecision = csg.ApplyCsgBarrierFilter(filter, Value(unsafeGraphRes))
    assert(!unsafeDecision.accepted, " csg smoke: unsafe graph rejected")
    assert(unsafeDecision.deniedNodeIds.len == 2, " csg smoke: two denied nodes")
    assert((unsafeDecision.deniedNodeIds[0] == 1 && unsafeDecision.deniedNodeIds[1] == 2) ||
           (unsafeDecision.deniedNodeIds[0] == 2 && unsafeDecision.deniedNodeIds[1] == 1),
           " csg smoke: denied source and rewrite nodes")

    echo(" csg_smoke ok")
    return 0
