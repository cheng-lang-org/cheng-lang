import std/system
import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/consensus

fn eventValid(event: consensus.ChainEvent, eventCid: layout.FixedBytes32): bool =
    if !layout.FixedBytes32Equal(eventCid, consensus.ChainEventCid(event)):
        return false
    if !layout.FixedBytes32Equal(event.bodyCid, consensus.ChainEventBodyCid(event)):
        return false
    return true

fn localApply(index: var consensus.ChainIndex,
              event: consensus.ChainEvent,
              eventCid: layout.FixedBytes32,
              logOffset: int32): Result[consensus.ConsensusDecision] =
    var out = consensus.ConsensusDecision()
    out.eventCid = eventCid
    assert(eventValid(event, eventCid), " consensus event helper validate wrapper: valid")
    consensus.ConsensusApplyMint(index, event, eventCid, logOffset, out)
    assert(index.accountIds.buffer != nil, " consensus event helper validate wrapper: inner account buffer")
    assert(index.accountIds.cap >= 1, " consensus event helper validate wrapper: inner account cap")
    assert(index.accountIds.len == 1, " consensus event helper validate wrapper: inner account len")
    return Ok[consensus.ConsensusDecision](out)

fn main(): int32 =
    var index = consensus.ChainIndex()
    let zeroCid = layout.FixedBytes32()
    let event = consensus.ChainEventMint(7, 1001, zeroCid, int64(100), 1, 13, 1, int64(10))
    let eventCid = consensus.ChainEventCid(event)
    let applyRes = localApply(index, event, eventCid, 0)
    assert(IsOk(applyRes), " consensus event helper validate wrapper: ok")
    let decision = Value(applyRes)
    assert(decision.accepted, " consensus event helper validate wrapper: accepted")
    assert(decision.applied, " consensus event helper validate wrapper: applied")
    assert(index.accountIds.buffer != nil, " consensus event helper validate wrapper: account buffer")
    assert(index.accountIds.cap >= 1, " consensus event helper validate wrapper: account cap")
    assert(index.accountIds.len == 1, " consensus event helper validate wrapper: account len")
    echo(" consensus_event_helper_validate_wrapper_smoke ok")
    return 0
