import std/system
import std/rawbytes
import std/result
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/binary_types as binary
import cheng/overlay/contracts as overlay
import cheng/overlay/libp2p_bridge as bridge
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/peer_id
import cheng/libp2p/host/host
import cheng/libp2p/host/host_quic
import cheng/libp2p/transports/quic_transport

fn smokeQuicAddress(): binary.LsmrAddress =
    var out: binary.LsmrAddress
    out.depth = 2
    out.digits[0] = 2
    out.digits[1] = 6
    return out

fn smokeQuicBytes(text: str): Bytes =
    var out: Bytes
    out.data = strDataPtr(text)
    out.len = len(text)
    return out

fn main(): int32 =
    var server = host.Libp2pHostInit("quic.server")
    var client = host.Libp2pHostInit("quic.client")
    let address = smokeQuicAddress()
    let payload = smokeQuicBytes("cheng.libp2p.quic.payload")
    let payloadCid = hash256.Sha256Fixed(layout.ByteSpanFromBytes(payload))
    let sourcePeer = peer_id.Libp2pPeerIdFromSeed("quic.source")

    var ingress: overlay.IngressEnvelope
    ingress.sourcePeerId = sourcePeer.value
    ingress.topicScope = overlay.OverlayScopeRegion
    ingress.address = address
    ingress.payload = payload
    ingress.payloadCid = payloadCid
    ingress.payloadLen = bytesLen(payload)
    ingress.stampEpoch = 17
    ingress.stampGanzhi = 33
    bridge.Libp2pRelayPublish(server, ingress)

    var listenAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillQuic(listenAddr, "127.0.0.1", 0)
    assert(quic_transport.Libp2pQuicTransportSupportsAddr(listenAddr),
        " libp2p quic tls: supports addr")
    let listenRes = host.Libp2pListen(server, listenAddr)
    assert(listenRes.ok, " libp2p quic tls: listen")
    host.Libp2pRegisterHandler(server, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(client, types.Libp2pProtocolSync)
    let dialRes = host.Libp2pDial(client,
                                    server.selfPeerId,
                                    listenAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " libp2p quic tls: dial")

    var query = overlay.StoreQuery()
    query.topicScope = overlay.OverlayScopeRegion
    query.address = address
    query.rangeLimit = 4
    var syncEntries: overlay.IngressEnvelope[]
    let syncRes = host_quic.Libp2pQuicSyncRequest(client, server, server.selfPeerId, query, syncEntries)
    if IsErr(syncRes):
        panic(ErrorText(syncRes))
    assert(syncRes.ok, " libp2p quic tls: sync request")
    assert(syncEntries.len == 1, " libp2p quic tls: sync count")
    let synced = syncEntries[0]
    assert(layout.FixedBytes32Equal(synced.payloadCid, payloadCid),
        " libp2p quic tls: payload cid")
    assert(synced.payloadLen == bytesLen(payload),
        " libp2p quic tls: payload len")
    assert(bytesLen(synced.payload) == bytesLen(payload),
        " libp2p quic tls: raw payload len")
    assert(bytesGet(synced.payload, 0) == int32('c'),
        " libp2p quic tls: raw payload head")
    assert(client.syncRequestCount == 1, " libp2p quic tls: request count")
    assert(server.syncServeCount == 1, " libp2p quic tls: serve count")

    echo(" libp2p_quic_tls_smoke ok")
    return 0
