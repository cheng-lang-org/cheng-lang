import std/os
import std/result
import cheng/std/bytes_layout as layout
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/lang/parser
import cheng/core/lang/typed_expr as texpr

fn reportFieldValue(report: str, key: str): str =
    let taggedReport = "\n" + report
    let needle = "\n" + key + "="
    let fieldPos = parser.ParserFindText(taggedReport, needle)
    if fieldPos < 0:
        return ""
    let valueStart = fieldPos + needle.len
    let tail = chengpath.TextSlice(taggedReport, valueStart, taggedReport.len - valueStart)
    let newlinePos = parser.ParserFindText(tail, "\n")
    if newlinePos < 0:
        return tail
    return chengpath.TextSlice(tail, 0, newlinePos)

fn reportFieldPositive(report: str, key: str): bool =
    let value = reportFieldValue(report, key)
    return value != "" && value != "0"

fn assertCallReasonReportField(report: str,
                               layer: parser.NormalizedExprLayer,
                               reason: parser.NormalizedExprCallReason,
                               label: str) =
    let reportKey = ccsg.CompilerCsgCallReasonReportKey(reason)
    assert(reportKey != "", label + " report key")
    assert(reportFieldValue(report, reportKey) ==
           intToStr(parser.NormalizedExprLayerCallReasonCountExact(layer, reason)),
           label)

fn assertTypedCallFactsMatchLayer(facts: ccsg.TypedExprFact[],
                                  layer: parser.NormalizedExprLayer,
                                  label: str) =
    assert(texpr.TypedExprTypeCallDefaultInitCount(facts) ==
           parser.NormalizedExprLayerDefaultInitCount(layer),
           label + " typed default init count")
    assert(texpr.TypedExprTypeCallConstructorCount(facts) ==
           parser.NormalizedExprLayerConstructorCount(layer),
           label + " typed constructor count")
    assert(texpr.TypedExprFactCountCallResolved(facts) ==
           parser.NormalizedExprLayerCallResolvedCount(layer),
           label + " typed resolved call count")
    assert(texpr.TypedExprFactCountCallUnresolved(facts) ==
           parser.NormalizedExprLayerCallUnresolvedCount(layer),
           label + " typed unresolved call count")
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallLocal) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallLocal),
           label + " typed local call kind count")
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallExternal) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallExternal),
           label + " typed external call kind count")
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallImportc) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallImportc),
           label + " typed importc call kind count")
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallMember) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallMember),
           label + " typed member call kind count")
    assert(texpr.TypedExprFactCountCallTargetImportc(facts) ==
           parser.NormalizedExprLayerCallTargetImportcCount(layer),
           label + " typed importc target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownQualifiedTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownQualifiedTarget),
           label + " typed unknown qualified target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonShadowedQualifiedTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonShadowedQualifiedTarget),
           label + " typed shadowed qualified target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonAmbiguousExternalTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonAmbiguousExternalTarget),
           label + " typed ambiguous external target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonAmbiguousQualifiedTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonAmbiguousQualifiedTarget),
           label + " typed ambiguous qualified target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownExternalTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownExternalTarget),
           label + " typed unknown external target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownCallTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownCallTarget),
           label + " typed unknown call target count")

fn buildLinkPlan(workspaceRoot: str,
                 packageRoot: str,
                 sourcePath: str,
                 outputPath: str,
                 emitKind: int32): slplan.SystemLinkPlanStub =
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), " compiler csg: link plan")
    return linkPlan

fn buildFullCsg(workspaceRoot: str,
                packageRoot: str,
                sourcePath: str,
                outputPath: str,
                emitKind: int32): ccsg.CompilerCsg =
    let linkPlan = buildLinkPlan(workspaceRoot, packageRoot, sourcePath, outputPath, emitKind)
    var sourceTexts: ccsg.TypedExprSourceText[]
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let currentSourcePath = linkPlan.sourceClosurePaths[i]
        let text = chengpath.ReadTextFile("", currentSourcePath)
        add(sourceTexts, texpr.TypedExprSourceTextNew(workspaceRoot,
                                                        packageRoot,
                                                        currentSourcePath,
                                                        text))
    var typedFacts: ccsg.TypedExprFact[]
    var err = ""
    assert(texpr.TypedExprBuildFacts(sourceTexts, linkPlan.exprLayer, typedFacts, err),
           " compiler csg: build typed facts")
    var nodes: ccsg.CompilerCsgNode[]
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let currentSourcePath = linkPlan.sourceClosurePaths[i]
        let text = chengpath.ReadTextFile("", currentSourcePath)
        let ownerModulePath = parser.ParserSourcePathToModulePath(workspaceRoot, packageRoot, currentSourcePath)
        var decls: parser.NormalizedFunctionDecl[]
        err = ""
        assert(parser.ParserReadNormalizedFunctionDecls(text, decls, err),
               " compiler csg: decls")
        var entryHasExplicitExports = false
        if currentSourcePath == linkPlan.entryPath &&
           (linkPlan.emitKind == creq.EmitShared || linkPlan.emitKind == creq.EmitObj):
            for declIndex in 0..<decls.len:
                if decls[declIndex].importc:
                    continue
                if decls[declIndex].explicitExportName != "":
                    entryHasExplicitExports = true
                    break
        for declIndex in 0..<decls.len:
            let decl = decls[declIndex]
            if decl.importc:
                continue
            let symbolText = ownerModulePath + "::" + decl.name
            var entryFlag = 0
            if currentSourcePath == linkPlan.entryPath && decl.name == linkPlan.entrySymbol:
                entryFlag = 1
            var resultLayoutKind = 0
            if decl.name == "main":
                resultLayoutKind = 5
            var effectKind = ccsg.CompilerCsgEffectPure
            if entryFlag != 0:
                effectKind = ccsg.CompilerCsgEffectProgramEntry
            var capabilityKind = ccsg.CompilerCsgCapabilityInternal
            if entryFlag != 0:
                capabilityKind = ccsg.CompilerCsgCapabilityEntrypoint
            var exportedFlag = 0
            if ccsg.CompilerCsgShouldExportSymbol(linkPlan.emitKind,
                                                    currentSourcePath == linkPlan.entryPath,
                                                    entryHasExplicitExports,
                                                    decl.explicitExportName,
                                                    decl.name,
                                                    entryFlag):
                exportedFlag = 1
            var node: ccsg.CompilerCsgNode
            node.nodeId = nodes.len + 1
            node.nodeKind = ccsg.CompilerCsgNodeKindSymbol
            node.ownerNodeId = 0
            node.modulePath = ownerModulePath
            node.symbolText = symbolText
            node.factText = decl.name
            node.resultLayoutKind = resultLayoutKind
            node.effectKind = effectKind
            node.capabilityKind = capabilityKind
            node.callConv = 1
            node.entryFlag = entryFlag
            node.exportedFlag = exportedFlag
            node.exportSymbolName = ""
            if exportedFlag != 0:
                node.exportSymbolName = ccsg.CompilerCsgTargetExportName(symbolText,
                                                                           decl.explicitExportName,
                                                                           decl.name)
            node.factCid = layout.FixedBytes32()
            add(nodes, node)
    var edges: ccsg.CompilerCsgEdge[]
    if nodes.len > 0:
        var edge: ccsg.CompilerCsgEdge
        edge.edgeId = 1
        edge.fromNodeId = nodes[0].nodeId
        edge.toNodeId = nodes[0].nodeId
        edge.edgeKind = ccsg.CompilerCsgEdgeKindContains
        edge.edgeCid = layout.FixedBytes32()
        add(edges, edge)
    var csg: ccsg.CompilerCsg
    csg.version = 1
    csg.packageId = linkPlan.packageId
    csg.sourceBundleCid = layout.FixedBytes32()
    csg.exprLayer = parser.NormalizedExprLayerClone(linkPlan.exprLayer)
    csg.typedExprFacts = texpr.TypedExprFactsClone(typedFacts)
    csg.nodeCount = nodes.len
    csg.edgeCount = edges.len
    csg.nodes = nodes
    csg.edges = edges
    csg.canonicalGraphCid = layout.FixedBytes32()
    csg.graphCid = layout.FixedBytes32()
    return csg

fn buildMinimalCsg(workspaceRoot: str,
                   packageRoot: str,
                   sourcePath: str,
                   outputPath: str,
                   emitKind: int32): ccsg.CompilerCsg =
    let linkPlan = buildLinkPlan(workspaceRoot, packageRoot, sourcePath, outputPath, emitKind)
    var sourceTexts: ccsg.TypedExprSourceText[]
    for i in 0..<linkPlan.sourceClosurePaths.len:
        let currentSourcePath = linkPlan.sourceClosurePaths[i]
        let text = chengpath.ReadTextFile("", currentSourcePath)
        add(sourceTexts, texpr.TypedExprSourceTextNew(workspaceRoot,
                                                        packageRoot,
                                                        currentSourcePath,
                                                        text))
    var typedFacts: ccsg.TypedExprFact[]
    var err = ""
    assert(texpr.TypedExprBuildFacts(sourceTexts, linkPlan.exprLayer, typedFacts, err),
           " compiler csg: build typed facts")
    var csg: ccsg.CompilerCsg
    csg.version = 1
    csg.packageId = linkPlan.packageId
    csg.sourceBundleCid = layout.FixedBytes32()
    csg.exprLayer = parser.NormalizedExprLayerClone(linkPlan.exprLayer)
    csg.typedExprFacts = texpr.TypedExprFactsClone(typedFacts)
    csg.nodeCount = 0
    csg.edgeCount = 0
    csg.nodes = []
    csg.edges = []
    csg.canonicalGraphCid = layout.FixedBytes32()
    csg.graphCid = layout.FixedBytes32()
    return csg

fn byteBufBytesEqual(lhs: layout.ByteBuf,
                     rhs: layout.ByteBuf): bool =
    let lhsBytes = layout.ByteBufToBytes(lhs)
    let rhsBytes = layout.ByteBufToBytes(rhs)
    if len(lhsBytes) != len(rhsBytes):
        return false
    for i in 0..<len(lhsBytes):
        if lhsBytes[i] != rhsBytes[i]:
            return false
    return true

fn findCallExpr(layer: parser.NormalizedExprLayer,
                sourcePath: str,
                lineNumber: int32): parser.NormalizedExpr =
    for i in 0..<layer.exprs.len:
        if layer.exprs[i].kind != parser.NormalizedExprCall:
            continue
        if layer.exprs[i].sourcePath != sourcePath:
            continue
        if layer.exprs[i].lineNumber != lineNumber:
            continue
        return parser.NormalizedExprClone(layer.exprs[i])
    var missing: parser.NormalizedExpr
    return missing

fn findTypedFact(facts: ccsg.TypedExprFact[],
                 sourcePath: str,
                 lineNumber: int32): ccsg.TypedExprFact =
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath:
            continue
        if facts[i].lineNumber != lineNumber:
            continue
        return texpr.TypedExprFactClone(facts[i])
    var missing: ccsg.TypedExprFact
    return missing

fn main(): int32 =
    let workspaceRoot: str = chengpath.PathCurrentDir()
    let packageRoot: str = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, "artifacts/compiler_csg/" + smokeLabel)
    assert(chengpath.MkdirP(workspaceRoot, outDir), " compiler csg: mkdir")
    let sourcePath: str = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath: str = chengpath.PathJoin(outDir, "program_selfhost_smoke")
    let csg = buildFullCsg(workspaceRoot,
                           packageRoot,
                           sourcePath,
                           outputPath,
                           creq.EmitExe)
    assert(csg.nodeCount > 0, " compiler csg: node count")
    assert(csg.edgeCount > 0, " compiler csg: edge count")
    assert(csg.typedExprFacts.len == parser.NormalizedExprLayerExprCount(csg.exprLayer),
           " compiler csg: typed expr fact count")
    assert(csg.typedExprFacts[0].exprId != "", " compiler csg: typed expr id")
    let surface = ccsg.CompilerExportSurfaceFromCsg(csg)
    assert(surface.exportedSymbolCount > 0, " compiler csg: export count")
    assert(csg.exprLayer.sourceCount > 0, " compiler csg: expr surface count")
    assert(parser.NormalizedExprLayerTryCount(csg.exprLayer) >= 0, " compiler csg: try count")
    assert(csg.exprLayer.questionResidualCount == 0, " compiler csg: question normalized")
    assert(texpr.TypedExprLowerLocalAddressCount(csg.typedExprFacts) > 0,
           " compiler csg: lowering mode count")

    let typedFixturePath: str = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let typedOutputPath: str = chengpath.PathJoin(outDir, "typed_expr_fact_fixture")
    let typedCsg = buildMinimalCsg(workspaceRoot,
                                   packageRoot,
                                   typedFixturePath,
                                   typedOutputPath,
                                   creq.EmitShared)
    let typedFixtureFacts = texpr.TypedExprFactsForSource(typedCsg.typedExprFacts, typedFixturePath)
    let typedFixtureRules = texpr.TypedExprLoweringRulesFromFacts(typedFixtureFacts)
    let typedReport = ccsg.CompilerCsgReport(typedCsg)
    let aliasExternalExpr = findCallExpr(typedCsg.exprLayer, typedFixturePath, 28)
    var loweringErr = ""
    let actualTypedLinkPlan = buildLinkPlan(workspaceRoot,
                                            packageRoot,
                                            typedFixturePath,
                                            typedOutputPath,
                                            creq.EmitShared)
    let actualTypedBundleRes = slplan.SystemLinkPlanSourceBundleCid(actualTypedLinkPlan)
    assert(IsOk(actualTypedBundleRes), " compiler csg: actual typed fixture source bundle")
    let actualTypedBundleCid = Value(actualTypedBundleRes)
    let actualTypedCsgRes = ccsg.BuildCompilerCsg(actualTypedLinkPlan, actualTypedBundleCid)
    assert(IsOk(actualTypedCsgRes), " compiler csg: actual typed fixture csg")
    let actualTypedCsg = ccsg.CompilerCsgClone(Value(actualTypedCsgRes))
    assert(texpr.TypedExprFactsValidateCallResolution(actualTypedCsg.exprLayer,
                                                        actualTypedCsg.typedExprFacts,
                                                        loweringErr),
           " compiler csg: actual typed fixture call resolution validate")
    let actualTypedRules = texpr.TypedExprLoweringRulesFromFacts(actualTypedCsg.typedExprFacts)
    assert(texpr.TypedExprLoweringRulesValidate(actualTypedRules, loweringErr),
           " compiler csg: actual typed fixture lowering rules validate")
    assert(typedFixtureFacts.len > 0, " compiler csg: typed fixture fact slice")
    assert(aliasExternalExpr.exprId != "", " compiler csg: typed fixture alias external expr")
    var legacyCompatBuf = layout.ByteBufInit(128)
    var streamedCompatBuf = layout.ByteBufInit(128)
    ccsg.CompilerCsgAppendText(legacyCompatBuf, ccsg.CompilerCsgExprCompatDetail(aliasExternalExpr))
    ccsg.CompilerCsgAppendExprCompatDetail(streamedCompatBuf, aliasExternalExpr)
    assert(byteBufBytesEqual(legacyCompatBuf, streamedCompatBuf),
           " compiler csg: streamed compat detail bytes")
    assertTypedCallFactsMatchLayer(typedCsg.typedExprFacts, typedCsg.exprLayer, " compiler csg: typed fixture")
    assert(texpr.TypedExprFactsValidateCallResolution(typedCsg.exprLayer, typedCsg.typedExprFacts, loweringErr),
           " compiler csg: typed fixture call resolution validate")
    assert(texpr.TypedExprLoweringRulesValidate(typedFixtureRules, loweringErr),
           " compiler csg: typed fixture lowering rules validate")
    assert(typedFixtureRules.len == typedFixtureFacts.len,
           " compiler csg: typed fixture lowering rule count")
    assert(texpr.TypedExprLoweringRuleUniqueShapeCount(typedFixtureRules) > 0,
           " compiler csg: typed fixture lowering rule shape count")
    assert(texpr.TypedExprLoweringRuleUniqueShapeCount(typedFixtureRules) ==
           texpr.TypedExprLoweringRuleUniqueKeyCount(typedFixtureRules),
           " compiler csg: typed fixture lowering rule key count")
    assert(texpr.TypedExprAbiPolymorphicCount(typedFixtureFacts) == 0,
           " compiler csg: typed fixture no abi polymorphic")
    assert(texpr.TypedExprLowerDeferredCount(typedFixtureFacts) == 0,
           " compiler csg: typed fixture no deferred lowering")
    assert(texpr.TypedExprPlaceLocalCount(typedFixtureFacts) > 0,
           " compiler csg: typed fixture local place count")
    assert(texpr.TypedExprLowerSretCount(typedFixtureFacts) > 0,
           " compiler csg: typed fixture sret count")
    assert(texpr.TypedExprCallBuiltinCount(typedFixtureFacts) > 0,
           " compiler csg: typed fixture builtin call kind")
    assert(texpr.TypedExprCallResultIntrinsicCount(typedFixtureFacts) > 0,
           " compiler csg: typed fixture result intrinsic call kind")
    assert(texpr.TypedExprCallProjectionCount(typedFixtureFacts) > 0,
           " compiler csg: typed fixture projection call kind")
    assert(parser.NormalizedExprLayerHasConstructorExpr(typedCsg.exprLayer, 60),
           " compiler csg: typed fixture constructor expr")
    let constructorFact = findTypedFact(typedFixtureFacts, typedFixturePath, 60)
    assert(constructorFact.kind == parser.NormalizedExprConstructor,
           " compiler csg: typed fixture constructor fact kind")
    assert(constructorFact.typeCallKind == texpr.TypedExprTypeCallConstructor,
           " compiler csg: typed fixture constructor type call kind")
    assert(constructorFact.typeText == "TypedDefaultWrap",
           " compiler csg: typed fixture constructor fact type")
    assert(!constructorFact.callPrefixStyle,
           " compiler csg: typed fixture constructor call prefix")
    assert(constructorFact.callArgCount == 1,
           " compiler csg: typed fixture constructor arg count")
    assert(constructorFact.callArgsText == "count: payload.len",
           " compiler csg: typed fixture constructor args text")
    let stringifyPrefixFact = findTypedFact(typedFixtureFacts, typedFixturePath, 68)
    assert(stringifyPrefixFact.kind == parser.NormalizedExprCall,
           " compiler csg: typed fixture stringify prefix kind")
    assert(stringifyPrefixFact.callKind == texpr.TypedExprCallBuiltin,
           " compiler csg: typed fixture stringify prefix call kind")
    assert(stringifyPrefixFact.callResolved,
           " compiler csg: typed fixture stringify prefix resolved")
    assert(stringifyPrefixFact.callPrefixStyle,
           " compiler csg: typed fixture stringify prefix style")
    assert(stringifyPrefixFact.callArgCount == 1,
           " compiler csg: typed fixture stringify prefix arg count")
    assert(stringifyPrefixFact.callArgsText == "built",
           " compiler csg: typed fixture stringify prefix args text")
    assert(stringifyPrefixFact.typeText == "str",
           " compiler csg: typed fixture stringify prefix type")
    let stringifyParenFact = findTypedFact(typedFixtureFacts, typedFixturePath, 69)
    assert(stringifyParenFact.kind == parser.NormalizedExprCall,
           " compiler csg: typed fixture stringify paren kind")
    assert(stringifyParenFact.callKind == texpr.TypedExprCallBuiltin,
           " compiler csg: typed fixture stringify paren call kind")
    assert(stringifyParenFact.callResolved,
           " compiler csg: typed fixture stringify paren resolved")
    assert(!stringifyParenFact.callPrefixStyle,
           " compiler csg: typed fixture stringify paren style")
    assert(stringifyParenFact.callArgCount == 1,
           " compiler csg: typed fixture stringify paren arg count")
    assert(stringifyParenFact.callArgsText == "built",
           " compiler csg: typed fixture stringify paren args text")
    assert(stringifyParenFact.typeText == "str",
           " compiler csg: typed fixture stringify paren type")
    let constructorRules = texpr.TypedExprLoweringRulesFromFacts(typedCsg.typedExprFacts)
    var sawConstructorRule = false
    for i in 0..<constructorRules.len:
        if constructorRules[i].sourcePath == typedFixturePath &&
           constructorRules[i].lineNumber == 60 &&
           constructorRules[i].typeCallKind == texpr.TypedExprTypeCallConstructor:
            assert(constructorRules[i].callArgCount == 1,
                   " compiler csg: typed fixture constructor rule arg count")
            assert(constructorRules[i].callArgsText == "count: payload.len",
                   " compiler csg: typed fixture constructor rule args text")
            sawConstructorRule = true
    assert(sawConstructorRule, " compiler csg: typed fixture constructor lowering rule")
    var badTypeCallFacts = texpr.TypedExprFactsClone(typedCsg.typedExprFacts)
    var corruptedTypeCallFact = false
    for i in 0..<badTypeCallFacts.len:
        if badTypeCallFacts[i].sourcePath == typedFixturePath &&
           badTypeCallFacts[i].lineNumber == 60 &&
           badTypeCallFacts[i].kind == parser.NormalizedExprConstructor:
            badTypeCallFacts[i].abiClass = texpr.TypedExprAbiPolymorphic
            badTypeCallFacts[i].valueKind = texpr.TypedExprValuePolymorphic
            badTypeCallFacts[i].loweringMode = texpr.TypedExprLowerDeferred
            badTypeCallFacts[i].returnKind = texpr.TypedExprReturnDeferred
            corruptedTypeCallFact = true
    assert(corruptedTypeCallFact, " compiler csg: corrupt constructor fact")
    loweringErr = ""
    assert(!texpr.TypedExprFactsValidateCallResolution(typedCsg.exprLayer, badTypeCallFacts, loweringErr),
           " compiler csg: reject invalid constructor fact lowering")
    assert(chengpath.TextContains(loweringErr, "type-call fact"),
           " compiler csg: invalid constructor fact error")
    var badTypeCallRules = texpr.TypedExprLoweringRulesClone(constructorRules)
    var corruptedTypeCallRule = false
    for i in 0..<badTypeCallRules.len:
        if badTypeCallRules[i].sourcePath == typedFixturePath &&
           badTypeCallRules[i].lineNumber == 60 &&
           badTypeCallRules[i].typeCallKind == texpr.TypedExprTypeCallConstructor:
            badTypeCallRules[i].copyKind = texpr.TypedExprCopyScalarStore
            corruptedTypeCallRule = true
    assert(corruptedTypeCallRule, " compiler csg: corrupt constructor rule")
    loweringErr = ""
    assert(!texpr.TypedExprLoweringRulesValidate(badTypeCallRules, loweringErr),
           " compiler csg: reject invalid constructor lowering rule")
    assert(chengpath.TextContains(loweringErr, "type-call rule"),
           " compiler csg: invalid constructor rule error")
    assert(parser.NormalizedExprLayerHasCallExpr(typedCsg.exprLayer, parser.NormalizedExprSurfaceCallExternal, 28),
           " compiler csg: typed fixture alias external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedCsg.exprLayer, parser.NormalizedExprSurfaceCallExternal, 29),
           " compiler csg: typed fixture module stem external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedCsg.exprLayer, parser.NormalizedExprSurfaceCallExternal, 30),
           " compiler csg: typed fixture nested qualified external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedCsg.exprLayer, parser.NormalizedExprSurfaceCallExternal, 32),
           " compiler csg: typed fixture alias importc external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedCsg.exprLayer, parser.NormalizedExprSurfaceCallExternal, 33),
           " compiler csg: typed fixture nested importc external call")
    var sawAliasImportBuffer = false
    var sawNestedImportBuffer = false
    var sawDefaultInitFact = false
    for i in 0..<typedFixtureFacts.len:
        if typedFixtureFacts[i].lineNumber == 32 &&
           texpr.TypedExprFactUsesImportBuffer(typedFixtureFacts[i]):
            sawAliasImportBuffer = true
        if typedFixtureFacts[i].lineNumber == 33 &&
           texpr.TypedExprFactUsesImportBuffer(typedFixtureFacts[i]):
            sawNestedImportBuffer = true
        if typedFixtureFacts[i].lineNumber == 56 &&
           typedFixtureFacts[i].kind == parser.NormalizedExprDefaultInit:
            assert(typedFixtureFacts[i].typeCallKind == texpr.TypedExprTypeCallDefaultInit,
                   " compiler csg: typed fixture default init type call kind")
            assert(typedFixtureFacts[i].abiClass == texpr.TypedExprAbiComposite,
                   " compiler csg: typed fixture default init abi")
            assert(typedFixtureFacts[i].placeKind != texpr.TypedExprPlaceCallResult,
                   " compiler csg: typed fixture default init place")
            assert(typedFixtureFacts[i].loweringMode == texpr.TypedExprLowerLocalAddress,
                   " compiler csg: typed fixture default init lowering")
            assert(typedFixtureFacts[i].returnKind == texpr.TypedExprReturnCompositeLocal,
                   " compiler csg: typed fixture default init return")
            sawDefaultInitFact = true
    assert(sawAliasImportBuffer, " compiler csg: typed fixture alias importc uses import buffer")
    assert(sawNestedImportBuffer, " compiler csg: typed fixture nested importc uses import buffer")
    assert(sawDefaultInitFact, " compiler csg: typed fixture saw default init fact")
    assert(texpr.TypedExprLowerImportBufferCount(typedFixtureFacts) > 0,
           " compiler csg: typed fixture import buffer lowering")
    assert(texpr.TypedExprReturnRegCount(typedFixtureFacts) > 0,
           " compiler csg: typed fixture reg return kind")
    assert(texpr.TypedExprReturnCompositeLocalCount(typedFixtureFacts) > 0,
           " compiler csg: typed fixture composite local return kind")
    assert(texpr.TypedExprReturnSretCount(typedFixtureFacts) > 0,
           " compiler csg: typed fixture sret return kind")
    assert(texpr.TypedExprReturnImportBufferCount(typedFixtureFacts) > 0,
           " compiler csg: typed fixture import buffer return kind")
    assert(reportFieldValue(typedReport, "expr_surface_call_count") ==
           intToStr(parser.NormalizedExprLayerCallCount(typedCsg.exprLayer)),
           " compiler csg: typed fixture report call count")
    assert(reportFieldValue(typedReport, "expr_surface_default_init_count") ==
           intToStr(parser.NormalizedExprLayerDefaultInitCount(typedCsg.exprLayer)),
           " compiler csg: typed fixture report default init count")
    assert(reportFieldValue(typedReport, "expr_surface_call_resolved_count") ==
           intToStr(parser.NormalizedExprLayerCallResolvedCount(typedCsg.exprLayer)),
           " compiler csg: typed fixture report resolved call count")
    assert(reportFieldValue(typedReport, "expr_surface_call_unresolved_count") ==
           intToStr(parser.NormalizedExprLayerCallUnresolvedCount(typedCsg.exprLayer)),
           " compiler csg: typed fixture report unresolved call count")
    assert(reportFieldValue(typedReport, "expr_surface_call_local_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(typedCsg.exprLayer, parser.NormalizedExprSurfaceCallLocal)),
           " compiler csg: typed fixture report local call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_external_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(typedCsg.exprLayer, parser.NormalizedExprSurfaceCallExternal)),
           " compiler csg: typed fixture report external call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_importc_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(typedCsg.exprLayer, parser.NormalizedExprSurfaceCallImportc)),
           " compiler csg: typed fixture report importc call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_member_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(typedCsg.exprLayer, parser.NormalizedExprSurfaceCallMember)),
           " compiler csg: typed fixture report member call kind count")
    assert(reportFieldValue(typedReport, "expr_surface_call_target_importc_count") ==
           intToStr(parser.NormalizedExprLayerCallTargetImportcCount(typedCsg.exprLayer)),
           " compiler csg: typed fixture report importc target count")
    assert(reportFieldValue(typedReport, "expr_surface_constructor_count") ==
           intToStr(parser.NormalizedExprLayerConstructorCount(typedCsg.exprLayer)),
           " compiler csg: typed fixture report constructor count")
    assert(reportFieldValue(typedReport, "typed_expr_type_call_default_init_count") ==
           intToStr(parser.NormalizedExprLayerDefaultInitCount(typedCsg.exprLayer)),
           " compiler csg: typed fixture report typed default init count")
    assert(reportFieldValue(typedReport, "typed_expr_type_call_constructor_count") ==
           intToStr(parser.NormalizedExprLayerConstructorCount(typedCsg.exprLayer)),
           " compiler csg: typed fixture report typed constructor count")
    assert(reportFieldValue(typedReport, "lowering_rule_type_call_default_init_count") ==
           intToStr(parser.NormalizedExprLayerDefaultInitCount(typedCsg.exprLayer)),
           " compiler csg: typed fixture report lowering default init count")
    assert(reportFieldValue(typedReport, "lowering_rule_type_call_constructor_count") ==
           intToStr(parser.NormalizedExprLayerConstructorCount(typedCsg.exprLayer)),
           " compiler csg: typed fixture report lowering constructor count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.NormalizedExprCallReasonUnknownQualifiedTarget,
                                " compiler csg: typed fixture report unknown qualified target count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.NormalizedExprCallReasonShadowedQualifiedTarget,
                                " compiler csg: typed fixture report shadowed qualified target count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.NormalizedExprCallReasonAmbiguousExternalTarget,
                                " compiler csg: typed fixture report ambiguous external target count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.NormalizedExprCallReasonAmbiguousQualifiedTarget,
                                " compiler csg: typed fixture report ambiguous qualified target count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.NormalizedExprCallReasonUnknownExternalTarget,
                                " compiler csg: typed fixture report unknown external target count")
    assertCallReasonReportField(typedReport,
                                typedCsg.exprLayer,
                                parser.NormalizedExprCallReasonUnknownCallTarget,
                                " compiler csg: typed fixture report unknown call target count")
    assert(reportFieldPositive(typedReport, "lowering_rule_arg_address_count"),
           " compiler csg: typed fixture address arg rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_result_sret_count"),
           " compiler csg: typed fixture sret result rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_materialize_dest_address_count"),
           " compiler csg: typed fixture dest address materialize rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_copy_region_copy_count"),
           " compiler csg: typed fixture region copy rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_import_builtin_address_slot_count"),
           " compiler csg: typed fixture builtin address import rule")
    assert(reportFieldPositive(typedReport, "lowering_rule_import_import_buffer_count"),
           " compiler csg: typed fixture import buffer import rule")
    assert(reportFieldValue(typedReport, "lowering_rule_unique_key_count") ==
           reportFieldValue(typedReport, "lowering_rule_unique_shape_count"),
           " compiler csg: typed fixture report unique key count")
    assert(reportFieldValue(typedReport, "lowering_rule_entry[0]") != "",
           " compiler csg: typed fixture report rule entry")
    assert(chengpath.TextContains(reportFieldValue(typedReport, "lowering_rule_entry[0]"), "key=type="),
           " compiler csg: typed fixture report rule key text")

    echo(" compiler_csg_smoke ok")
    return 0
