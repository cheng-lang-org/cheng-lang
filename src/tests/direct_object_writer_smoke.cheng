import std/result
import std/os
import std/rawbytes
import std/strings
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/object_debug_report as objdebug
import cheng/core/tooling/path as chengpath
import cheng/core/backend/direct_object_emit as direct
import cheng/core/backend/object_buffer as obuf
import cheng/core/backend/object_symbols as osym
import cheng/core/backend/object_relocs as orel
import cheng/core/backend/primary_object_plan as pobj

fn assertByte(data: Bytes, index: int32, expected: int32, message: str) =
    assert(bytesGet(data, index) == expected, message)

fn DirectObjectWriterSmokeResultReportText(result: direct.DirectObjectEmitResult): str =
    var out = Fmt"direct_object_output_kind={result.outputKind}"
    out = Fmt"{out}\nexec_phase_direct_object_layout_ms={strings.Int64ToStr(result.directObjectLayoutMs)}"
    out = Fmt"{out}\nexec_phase_direct_object_emit_ms={strings.Int64ToStr(result.directObjectEmitMs)}"
    out = Fmt"{out}\ndirect_object_bytes={strings.IntToStr(result.bytesWritten)}"
    out = Fmt"{out}\ndirect_object_reloc_count={strings.IntToStr(result.relocCount)}"
    return out

fn main(): int32 =
    var buf = obuf.ObjectBufferInit(2)
    obuf.ObjectBufferWriteU8(buf, 18)
    obuf.ObjectBufferWriteU16LE(buf, uint64(0x3456))
    let patchOffset = obuf.ObjectBufferOffset(buf)
    obuf.ObjectBufferWriteU32LE(buf, uint64(0))
    obuf.ObjectBufferAlign(buf, 8, 0)
    obuf.ObjectBufferWriteU64LE(buf, uint64(0x0102030405060708))
    let patchRes = obuf.ObjectBufferPatchU32LE(buf, patchOffset, uint64(0x11223344))
    assert(IsOk(patchRes), " direct object writer smoke: patch u32")

    let data = obuf.ObjectBufferToBytes(buf)
    assert(bytesLen(data) == 16, " direct object writer smoke: buffer len")
    assertByte(data, 0, 18, " direct object writer smoke: u8")
    assertByte(data, 1, 86, " direct object writer smoke: u16 lo")
    assertByte(data, 2, 52, " direct object writer smoke: u16 hi")
    assertByte(data, 3, 68, " direct object writer smoke: patch b0")
    assertByte(data, 4, 51, " direct object writer smoke: patch b1")
    assertByte(data, 5, 34, " direct object writer smoke: patch b2")
    assertByte(data, 6, 17, " direct object writer smoke: patch b3")
    assertByte(data, 7, 0, " direct object writer smoke: align")
    assertByte(data, 8, 8, " direct object writer smoke: u64 b0")
    assertByte(data, 15, 1, " direct object writer smoke: u64 b7")

    var symbols = osym.ObjectSymbolsInit()
    let mainIndex = osym.ObjectSymbolsAddDefined(symbols, "_main", 0, int64(0), int64(16), true)
    let putsIndex = osym.ObjectSymbolsAddUndefined(symbols, "_puts", true)
    assert(mainIndex == 0, " direct object writer smoke: main symbol index")
    assert(putsIndex == 1, " direct object writer smoke: extern symbol index")
    assert(osym.ObjectSymbolsCount(symbols) == 2, " direct object writer smoke: symbol count")
    assert(osym.ObjectSymbolsHas(symbols, "_main"), " direct object writer smoke: has main")
    assert(osym.ObjectSymbolsAt(symbols, putsIndex).undefined, " direct object writer smoke: puts undefined")

    var relocs = orel.ObjectRelocsInit()
    let relocIndex = orel.ObjectRelocsAdd(relocs,
                                          0,
                                          int64(4),
                                          putsIndex,
                                          orel.ObjectRelocBranch26,
                                          int64(0),
                                          true)
    assert(relocIndex == 0, " direct object writer smoke: reloc index")
    assert(orel.ObjectRelocsCount(relocs) == 1, " direct object writer smoke: reloc count")
    assert(orel.ObjectRelocsCountForSection(relocs, 0) == 1, " direct object writer smoke: reloc section count")
    assert(orel.ObjectRelocsAt(relocs, 0).pcRelative, " direct object writer smoke: reloc pc relative")

    let root = os.GetCurrentDir()
    let outDir = chengpath.PathAbsolute(root, "artifacts/direct_object_writer_smoke")
    assert(chengpath.MkdirP(root, outDir), " direct object writer smoke: mkdir")
    let objectPath = chengpath.PathJoin(outDir, "return_zero_direct.o")
    let exePath = chengpath.PathJoin(outDir, "return_zero_direct")
    let linkLog = chengpath.PathJoin(outDir, "return_zero_direct.link.log")
    let runLog = chengpath.PathJoin(outDir, "return_zero_direct.run.log")
    var directSymbols: str[]
    add(directSymbols, "_main")
    let directRes = direct.DirectObjectEmitReturnZeroObject(root,
                                                            objectPath,
                                                            directSymbols)
    assert(IsOk(directRes), " direct object writer smoke: direct object write")
    let directWrite = Value(directRes)
    let directMetrics = DirectObjectWriterSmokeResultReportText(directWrite)
    assert(strings.StrContains(directMetrics, "direct_object_output_kind=object"),
           " direct object writer smoke: object metric")
    assert(strings.StrContains(directMetrics, "exec_phase_direct_object_layout_ms="),
           " direct object writer smoke: layout metric")
    assert(strings.StrContains(directMetrics, "exec_phase_direct_object_emit_ms="),
           " direct object writer smoke: emit metric")
    assert(strings.StrContains(directMetrics, "direct_object_bytes="),
           " direct object writer smoke: bytes metric")
    assert(strings.StrContains(directMetrics, "direct_object_reloc_count=0"),
           " direct object writer smoke: reloc metric")
    assert(chengpath.FileExistsNonEmpty(root, objectPath), " direct object writer smoke: object exists")
    let reportRes = objdebug.ObjectDebugReportText(objectPath)
    assert(IsOk(reportRes), " direct object writer smoke: object report")
    let report = Value(reportRes)
    assert(strings.StrContains(report, "format=macho64"), " direct object writer smoke: macho report")
    assert(strings.StrContains(report, "macho_type=relocatable"), " direct object writer smoke: relocatable")
    assert(strings.StrContains(report, "section_count=1"), " direct object writer smoke: section count")
    assert(strings.StrContains(report, "symbol_count=1"), " direct object writer smoke: symbol count")
    assert(strings.StrContains(report, "reloc_count=0"), " direct object writer smoke: reloc count")
    let link = hostops.RunProgramLogged(root,
                                        "direct_object_writer_link",
                                        "cc",
                                        ["-arch", "arm64", objectPath, "-o", exePath],
                                        [],
                                        root,
                                        0,
                                        linkLog)
    assert(link.exitCode == 0, " direct object writer smoke: link rc")
    assert(chengpath.FileExistsNonEmpty(root, exePath), " direct object writer smoke: exe exists")
    let run = hostops.RunFileLogged(root,
                                    "direct_object_writer_run",
                                    exePath,
                                    [],
                                    [],
                                    root,
                                    30,
                                    runLog)
    assert(run.exitCode == 0, " direct object writer smoke: run rc")

    let f64ObjectPath = chengpath.PathJoin(outDir, "f64_mul_direct.o")
    let f64OtoolLog = chengpath.PathJoin(outDir, "f64_mul_direct.otool.log")
    var f64Plan: pobj.PrimaryObjectPlan
    f64Plan.targetTriple = "arm64-apple-darwin"
    f64Plan.objectFormat = "macho"
    f64Plan.outputPath = f64ObjectPath
    add(f64Plan.itemIds, int32(1))
    add(f64Plan.symbolNames, "_cheng_direct_f64_mul")
    add(f64Plan.functionWordOffsets, int32(0))
    add(f64Plan.functionWordCounts, int32(2))
    add(f64Plan.functionBodyKinds, "return_f64_mul_args")
    add(f64Plan.instructionWords, int32(509675520))
    add(f64Plan.instructionWords, int32(-698416192))
    let f64Res = direct.DirectObjectEmitPlanObject(root, f64Plan)
    assert(IsOk(f64Res), " direct object writer smoke: f64 direct object write")
    let f64Write = Value(f64Res)
    assert(f64Write.relocCount == 0, " direct object writer smoke: f64 reloc count")
    assert(chengpath.FileExistsNonEmpty(root, f64ObjectPath), " direct object writer smoke: f64 object exists")
    let f64Disasm = hostops.RunProgramLogged(root,
                                             "direct_object_writer_f64_otool",
                                             "otool",
                                             ["-tV", f64ObjectPath],
                                             [],
                                             root,
                                             0,
                                             f64OtoolLog)
    assert(f64Disasm.exitCode == 0, " direct object writer smoke: f64 otool rc")
    assert(strings.StrContains(f64Disasm.output, "fmul"), " direct object writer smoke: f64 fmul")
    assert(strings.StrContains(f64Disasm.output, "d0, d0, d1"), " direct object writer smoke: f64 operands")

    let setCmdObjectPath = chengpath.PathJoin(outDir, "runtime_set_cmd_line_direct.o")
    let setCmdOtoolLog = chengpath.PathJoin(outDir, "runtime_set_cmd_line_direct.otool.log")
    var setCmdPlan: pobj.PrimaryObjectPlan
    setCmdPlan.targetTriple = "arm64-apple-darwin"
    setCmdPlan.objectFormat = "macho"
    setCmdPlan.outputPath = setCmdObjectPath
    add(setCmdPlan.itemIds, int32(2))
    add(setCmdPlan.symbolNames, "_cheng_runtime_set_cmdline_smoke____cheng_setCmdLine")
    add(setCmdPlan.functionWordOffsets, int32(0))
    add(setCmdPlan.functionWordCounts, int32(7))
    add(setCmdPlan.functionBodyKinds, "runtime_set_cmd_line")
    add(setCmdPlan.instructionWords, int32(-1879048176))
    add(setCmdPlan.instructionWords, int32(-1862270448))
    add(setCmdPlan.instructionWords, int32(-1191181824))
    add(setCmdPlan.instructionWords, int32(-1879048176))
    add(setCmdPlan.instructionWords, int32(-1862270448))
    add(setCmdPlan.instructionWords, int32(-117439999))
    add(setCmdPlan.instructionWords, int32(-698416192))
    add(setCmdPlan.dataLabels, "_cheng_runtime_set_cmdline_smoke__cheng_saved_argc")
    add(setCmdPlan.dataPayloadTexts, "zero:4")
    add(setCmdPlan.dataLabels, "_cheng_runtime_set_cmdline_smoke__cheng_saved_argc_pad")
    add(setCmdPlan.dataPayloadTexts, "zero:4")
    add(setCmdPlan.dataLabels, "_cheng_runtime_set_cmdline_smoke__cheng_saved_argv")
    add(setCmdPlan.dataPayloadTexts, "zero:8")
    let setCmdRes = direct.DirectObjectEmitPlanObject(root, setCmdPlan)
    assert(IsOk(setCmdRes), " direct object writer smoke: runtime set cmdline direct object write")
    let setCmdWrite = Value(setCmdRes)
    assert(setCmdWrite.relocCount == 4, " direct object writer smoke: runtime set cmdline reloc count")
    assert(setCmdWrite.symbolCount == 4, " direct object writer smoke: runtime set cmdline symbol count")
    let setCmdMetrics = DirectObjectWriterSmokeResultReportText(setCmdWrite)
    assert(strings.StrContains(setCmdMetrics, "direct_object_output_kind=object"),
           " direct object writer smoke: runtime set cmdline report object metric")
    assert(strings.StrContains(setCmdMetrics, "direct_object_reloc_count=4"),
           " direct object writer smoke: runtime set cmdline report reloc metric")
    assert(chengpath.FileExistsNonEmpty(root, setCmdObjectPath),
           " direct object writer smoke: runtime set cmdline object exists")
    let setCmdReportRes = objdebug.ObjectDebugReportText(setCmdObjectPath)
    assert(IsOk(setCmdReportRes), " direct object writer smoke: runtime set cmdline object report")
    let setCmdReport = Value(setCmdReportRes)
    assert(strings.StrContains(setCmdReport, "section_count=2"),
           " direct object writer smoke: runtime set cmdline data section")
    assert(strings.StrContains(setCmdReport, "reloc_count=4"),
           " direct object writer smoke: runtime set cmdline reloc report")
    let setCmdRelocs = hostops.RunProgramLogged(root,
                                                "direct_object_writer_setcmd_otool",
                                                "otool",
                                                ["-rv", setCmdObjectPath],
                                                [],
                                                root,
                                                0,
                                                setCmdOtoolLog)
    assert(setCmdRelocs.exitCode == 0, " direct object writer smoke: runtime set cmdline otool rc")
    assert(strings.StrContains(setCmdRelocs.output, "PAGE21"),
           " direct object writer smoke: runtime set cmdline page21 reloc")
    let setCmdHasPageOff = strings.StrContains(setCmdRelocs.output, "PAGOF12") ||
                           strings.StrContains(setCmdRelocs.output, "PAGEOFF12")
    assert(setCmdHasPageOff,
           " direct object writer smoke: runtime set cmdline pageoff12 reloc")
    assert(strings.StrContains(setCmdRelocs.output, "_cheng_runtime_set_cmdline_smoke__cheng_saved_argc"),
           " direct object writer smoke: runtime set cmdline argc reloc")
    assert(strings.StrContains(setCmdRelocs.output, "_cheng_runtime_set_cmdline_smoke__cheng_saved_argv"),
           " direct object writer smoke: runtime set cmdline argv reloc")

    let entryBridgeObjectPath = chengpath.PathJoin(outDir, "entry_bridge_direct.o")
    let entryBridgeOtoolLog = chengpath.PathJoin(outDir, "entry_bridge_direct.otool.log")
    var entryBridgePlan: pobj.PrimaryObjectPlan
    entryBridgePlan.targetTriple = "arm64-apple-darwin"
    entryBridgePlan.objectFormat = "macho"
    entryBridgePlan.outputPath = entryBridgeObjectPath
    entryBridgePlan.entryFunctionSymbol = "_cheng_entry_bridge_user"
    add(entryBridgePlan.itemIds, int32(3))
    add(entryBridgePlan.symbolNames, "_cheng_entry_bridge_user")
    add(entryBridgePlan.functionWordOffsets, int32(0))
    add(entryBridgePlan.functionWordCounts, int32(2))
    add(entryBridgePlan.functionBodyKinds, "return_i32_const_7")
    add(entryBridgePlan.instructionWords, int32(1384120544))
    add(entryBridgePlan.instructionWords, int32(-698416192))
    add(entryBridgePlan.itemIds, int32(4))
    add(entryBridgePlan.symbolNames, "_main")
    add(entryBridgePlan.functionWordOffsets, int32(2))
    add(entryBridgePlan.functionWordCounts, int32(17))
    add(entryBridgePlan.functionBodyKinds, "entry_bridge")
    add(entryBridgePlan.instructionWords, int32(-788495361))
    add(entryBridgePlan.instructionWords, int32(-1459615776))
    add(entryBridgePlan.instructionWords, int32(-117436418))
    add(entryBridgePlan.instructionWords, int32(-1811939328))
    add(entryBridgePlan.instructionWords, int32(-113244191))
    add(entryBridgePlan.instructionWords, int32(-113246176))
    add(entryBridgePlan.instructionWords, int32(-1811939328))
    add(entryBridgePlan.instructionWords, int32(-1455421472))
    add(entryBridgePlan.instructionWords, int32(-1811939328))
    add(entryBridgePlan.instructionWords, int32(-1191177248))
    add(entryBridgePlan.instructionWords, int32(-113244191))
    add(entryBridgePlan.instructionWords, int32(-113246176))
    add(entryBridgePlan.instructionWords, int32(-1811939328))
    add(entryBridgePlan.instructionWords, int32(-1186988032))
    add(entryBridgePlan.instructionWords, int32(-117436418))
    add(entryBridgePlan.instructionWords, int32(-1862241281))
    add(entryBridgePlan.instructionWords, int32(-698416192))
    let entryBridgeRes = direct.DirectObjectEmitPlanObject(root, entryBridgePlan)
    assert(IsOk(entryBridgeRes), " direct object writer smoke: entry bridge direct object write")
    let entryBridgeWrite = Value(entryBridgeRes)
    assert(entryBridgeWrite.relocCount == 4, " direct object writer smoke: entry bridge reloc count")
    assert(entryBridgeWrite.symbolCount == 5, " direct object writer smoke: entry bridge symbol count")
    let entryBridgeMetrics = DirectObjectWriterSmokeResultReportText(entryBridgeWrite)
    assert(strings.StrContains(entryBridgeMetrics, "direct_object_output_kind=object"),
           " direct object writer smoke: entry bridge report object metric")
    assert(strings.StrContains(entryBridgeMetrics, "direct_object_reloc_count=4"),
           " direct object writer smoke: entry bridge report reloc metric")
    let entryBridgeRelocs = hostops.RunProgramLogged(root,
                                                     "direct_object_writer_entry_bridge_otool",
                                                     "otool",
                                                     ["-rv", entryBridgeObjectPath],
                                                     [],
                                                     root,
                                                     0,
                                                     entryBridgeOtoolLog)
    assert(entryBridgeRelocs.exitCode == 0, " direct object writer smoke: entry bridge otool rc")
    assert(strings.StrContains(entryBridgeRelocs.output, "BR26"),
           " direct object writer smoke: entry bridge branch reloc")
    assert(strings.StrContains(entryBridgeRelocs.output, "_cheng_entry_bridge_user"),
           " direct object writer smoke: entry bridge target reloc")
    assert(strings.StrContains(entryBridgeRelocs.output, "_cheng_setCmdLine"),
           " direct object writer smoke: entry bridge argv reloc")
    assert(strings.StrContains(entryBridgeRelocs.output, "_cheng_register_line_map_from_argv0"),
           " direct object writer smoke: entry bridge line map reloc")
    assert(strings.StrContains(entryBridgeRelocs.output, "_cheng_debug_profile_flush_from_argv0"),
           " direct object writer smoke: entry bridge profile reloc")

    let executablePath = chengpath.PathJoin(outDir, "return_i32_const_7_linkerless")
    let executableOtoolLog = chengpath.PathJoin(outDir, "return_i32_const_7_linkerless.otool.log")
    var executablePlan: pobj.PrimaryObjectPlan
    executablePlan.targetTriple = "arm64-apple-darwin"
    executablePlan.objectFormat = "macho"
    executablePlan.outputPath = chengpath.PathJoin(outDir, "return_i32_const_7_linkerless.primary.o")
    executablePlan.entryFunctionSymbol = "_cheng_linkerless_main"
    add(executablePlan.itemIds, int32(5))
    add(executablePlan.symbolNames, "_cheng_linkerless_main")
    add(executablePlan.functionWordOffsets, int32(0))
    add(executablePlan.functionWordCounts, int32(2))
    add(executablePlan.functionBodyKinds, "return_i32_const_7")
    add(executablePlan.instructionWords, int32(1384120544))
    add(executablePlan.instructionWords, int32(-698416192))
    let executableRes = direct.DirectObjectEmitStandaloneExecutable(root,
                                                                    executablePlan,
                                                                    executablePath)
    assert(IsOk(executableRes), " direct object writer smoke: linkerless executable write")
    let executableWrite = Value(executableRes)
    assert(executableWrite.relocCount == 0, " direct object writer smoke: linkerless executable reloc count")
    let executableMetrics = DirectObjectWriterSmokeResultReportText(executableWrite)
    assert(strings.StrContains(executableMetrics, "direct_object_output_kind=executable"),
           " direct object writer smoke: linkerless executable output metric")
    assert(chengpath.FileExistsNonEmpty(root, executablePath),
           " direct object writer smoke: linkerless executable exists")
    let executableLoad = hostops.RunProgramLogged(root,
                                                  "direct_object_writer_linkerless_otool",
                                                  "otool",
                                                  ["-h", "-l", executablePath],
                                                  [],
                                                  root,
                                                  0,
                                                  executableOtoolLog)
    assert(executableLoad.exitCode == 0, " direct object writer smoke: linkerless executable otool rc")
    assert(strings.StrContains(executableLoad.output, "MH_EXECUTE"),
           " direct object writer smoke: linkerless executable macho type")
    assert(strings.StrContains(executableLoad.output, "LC_MAIN"),
           " direct object writer smoke: linkerless executable lc main")

    echo("direct_object_writer_smoke ok")
    return 0
