import cheng/core/backend/system_link_plan as slplan
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/lang/parser as parser

fn main() =
    var plan: slplan.SystemLinkPlanStub
    var err: str
    let ok = slplan.BuildSystemLinkPlanStubWithFields("/Users/lbcheng/cheng-lang",
                                                      "/Users/lbcheng/cheng-lang",
                                                      "/Users/lbcheng/cheng-lang/src/tests/ordinary_zero_exit_fixture.cheng",
                                                      "/tmp/cold_csg_out",
                                                      "arm64-apple-darwin",
                                                      creq.EmitObj,
                                                      "public",
                                                      "",
                                                      plan,
                                                      err)
    assert(ok, "cold csg module flow slplan ok")
    var modules: str[]
    var seen = ccsg.CompilerCsgTextSetInit(plan.ownerModulePaths.len + 8)
    ccsg.CompilerCsgAddUniqueFast(modules, seen, plan.ownerModulePaths[0])
    ccsg.CompilerCsgSortStrs(modules)
    var ids: int32[]
    add(ids, 7)
    var overrides: ccsg.CompilerCsgSourceText[]
    let externalPackageRoots = slplan.SystemLinkPlanExternalPackageRoots(plan)
    let sourceTextLookup = ccsg.CompilerCsgSourceTextLookupBuild(overrides)
    let modulePath = ccsg.CompilerCsgSourceModulePathFast(plan.workspaceRoot,
                                                          plan.packageRoot,
                                                          externalPackageRoots,
                                                          sourceTextLookup,
                                                          plan.sourceClosurePaths[0])
    assert(modulePath == plan.ownerModulePaths[0], "cold csg module flow module path")
    assert(ccsg.CompilerCsgModuleNodeIdIndexed(modules, ids, modulePath) == 7,
           "cold csg module flow node id")
