import std/system
import std/os as os
import std/strings
import std/result
import std/rawbytes
import std/net/transports/udp_syscall as udp

fn perfEnvInt(name: str, defaultValue: int32): int32 =
    let raw: str = os.getEnvDefault(name, "")
    if len(raw) <= 0:
        return defaultValue
    var value: int32 = 0
    var i: int32 = 0
    while i < len(raw):
        let ch: char = raw[i]
        if ch < '0' || ch > '9':
            return defaultValue
        value = value * 10 + (int32(ch) - int32('0'))
        i = i + 1
    return value

fn udpRecvLoop(fd: int32, maxBytes: int32, maxAttempts: int32, out: var udp.UdpRecvResult): Result[bool] =
    var attempts: int32 = 0
    while attempts < maxAttempts:
        let recvRes: Result[bool] = udp.udpRecvFromNonblock(fd, maxBytes, out)
        if IsOk(recvRes):
            return recvRes
        attempts = attempts + 1
    return Err[bool]("udp witness: recv timeout")

fn main() =
    let iterations: int32 = perfEnvInt("STD_PERF_ITERS", 16)
    let recvSockRes: Result[udp.UdpSocketHandle] = udp.udpSocketOpenDgram(false)
    assert(IsOk(recvSockRes), "udp witness recv open")
    var recvSock: udp.UdpSocketHandle = Value(recvSockRes)

    var bindAddr: udp.UdpSockAddr
    let bindAddrRes: Result[bool] = udp.udpSockAddrFromHostPort("127.0.0.1", 0, false, 0, false, bindAddr)
    assert(IsOk(bindAddrRes), "udp witness bind addr")
    assert(IsOk(udp.udpBindAddr(recvSock.fd, bindAddr)), "udp witness bind")

    var localAddr: udp.UdpSockAddr
    let localAddrRes: Result[bool] = udp.udpGetSockName(recvSock.fd, localAddr)
    assert(IsOk(localAddrRes), "udp witness getsockname")

    let sendSockRes: Result[udp.UdpSocketHandle] = udp.udpSocketOpenDgram(false)
    assert(IsOk(sendSockRes), "udp witness send open")
    var sendSock: udp.UdpSocketHandle = Value(sendSockRes)

    var total: int32 = 0
    var i: int32 = 0
    while i < iterations:
        let payload: Bytes = bytesFromString("ping")
        assert(IsOk(udp.udpSendTo(sendSock.fd, payload, localAddr)), "udp witness send")
        var got: udp.UdpRecvResult
        let recvRes: Result[bool] = udpRecvLoop(recvSock.fd, 64, 200, got)
        assert(IsOk(recvRes), "udp witness recv")
        total = total + bytesLen(got.data)
        i = i + 1

    udp.udpSocketClose(sendSock.fd)
    udp.udpSocketClose(recvSock.fd)
    echo(intToStr(total))
