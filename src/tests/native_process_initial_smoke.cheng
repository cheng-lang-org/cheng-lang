import std/system
import std/result
import std/rawbytes
import cheng/quic/msquicruntime as qruntime
import cheng/quic/native_runtime as qnative
import cheng/quic/tls/handshake13 as handshake13
import cheng/quic/tls/test_pki as testpki
import cheng/quic/core/frame_model
import cheng/quic/core/packet_model
import cheng/quic/core/packet_header_model

fn main(): int32 =
    qnative.msquicNativeResetSession()
    let tlsPolicy = testpki.msquicMakeLocalhostTlsPolicy()
    var settings = qruntime.initMsQuicSettings()
    qnative.msquicNativeSetServerPolicyCache(tlsPolicy)
    qnative.msquicNativeResetServerEndpoint(settings, false)
    qnative.msquicNativeSession.active = true
    qnative.msquicNativeSession.closed = false
    qnative.msquicNativeSession.serverFlightSent = true

    handshake13.msquicTls13ResetClientDefault(true)
    let genRes: Result[bool] = handshake13.msquicTls13ClientGenerateX25519()
    if IsErr(genRes):
        panic(ErrorText(genRes))

    let randomSeed: Bytes = bytesAlloc(32)
    for i in 0..<32:
        bytesSet(randomSeed, i, (i + 1) & 0xff)

    let helloRes: Result[Bytes] = handshake13.msquicTls13ClientBuildClientHello(
        randomSeed,
        "dm",
        "localhost",
        emptyBytes()
    )
    if IsErr(helloRes):
        panic(ErrorText(helloRes))
    let hello: Bytes = Value(helloRes)

    var pkt: packet_model.MsQuicPacket = packet_model.initMsQuicPacket(1)
    let addRes: Result[bool] = packet_model.msquicPacketAddFrame(pkt, frame_model.msquicFrameCrypto(0, hello))
    if IsErr(addRes):
        panic(ErrorText(addRes))
    let payloadRes: Result[Bytes] = packet_model.msquicPacketPayloadEncode(pkt)
    if IsErr(payloadRes):
        panic(ErrorText(payloadRes))
    let payload: Bytes = Value(payloadRes)

    let cid: Bytes = bytesAlloc(qnative.msquicNativeConnIdLen)
    for i in 0..<qnative.msquicNativeConnIdLen:
        bytesSet(cid, i, (0x11 + i) & 0xff)

    var header: packet_header_model.QuicPacketHeader
    header.longHeader = true
    header.packetType = packet_header_model.QuicPacketInitial
    header.version = qnative.msquicNativeVersion
    header.dcid = cid
    header.scid = cid
    header.token = emptyBytes()
    header.payloadLength = int64(bytesLen(payload) + 2)
    header.packetNumber = 1
    header.packetNumberLen = 2
    header.spinBit = false
    header.keyPhase = false

    let headerRes: Result[Bytes] = packet_header_model.quicPacketHeaderEncode(header)
    if IsErr(headerRes):
        panic(ErrorText(headerRes))
    let wire: Bytes = bytesConcat3(Value(headerRes), payload, emptyBytes())

    let procRes: Result[bool] = qnative.msquicNativeProcessPacket(
        qnative.msquicNativeServerSide,
        "/ip4/127.0.0.1/udp/6208/quic-v1",
        wire
    )
    if IsErr(procRes):
        panic(ErrorText(procRes))

    assert(
        handshake13.msquicTls13ServerClientKeyShareGroup() > 0,
        " native_process_initial: server parsed client key share"
    )
    echo(" native_process_initial_smoke ok")
    return 0
