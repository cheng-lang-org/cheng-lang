fn test_i32_bitwise(a: int32, b: int32): int32 =
    let andVal = a & b
    let orVal = a | b
    let xorVal = a ^ b
    return andVal + orVal + xorVal

fn test_i32_shift(a: int32, b: int32): int32 =
    let shlVal = a << b
    let shrVal = a >> b
    return shlVal + shrVal

fn test_i64_arith(a: int64, b: int64, c: int64): int64 =
    return a + b - c

fn test_i64_mul(a: int64, b: int64): int64 =
    return a * b

fn test_i64_const(): int64 =
    return 42

fn test_i64_const_large(): int64 =
    return 100000

fn test_cmp_eq(a: int32, b: int32): int32 =
    return a == b ? 1 : 0

fn test_cmp_ne(a: int32, b: int32): int32 =
    return a != b ? 1 : 0

fn test_cmp_lt(a: int32, b: int32): int32 =
    return a < b ? 1 : 0

fn test_cmp_gt(a: int32, b: int32): int32 =
    return a > b ? 1 : 0

fn test_cmp_le(a: int32, b: int32): int32 =
    return a <= b ? 1 : 0

fn test_cmp_ge(a: int32, b: int32): int32 =
    return a >= b ? 1 : 0

fn test_ptr_load_store_u8(): int32 =
    let buf = #[uint8, 4](0, 10, 20, 30)
    let p: *uint8 = &buf[0]
    let v0 = *p
    let v1 = *(p + 1)
    return v0 + v1

fn test_ptr_load_store_i32(): int32 =
    let buf = #[int32, 4](100, 200, 300, 400)
    let p: *int32 = &buf[0]
    let v0 = *p
    let v1 = *(p + 1)
    return v0 + v1

fn test_ptr_load_store_i64(): int64 =
    let buf = #[int64, 2](1000, 2000)
    let p: *int64 = &buf[0]
    let v0 = *p
    let v1 = *(p + 1)
    return v0 + v1

fn test_i64_mixed(a: int32, b: int32): int64 =
    let x: int64 = a
    let y: int64 = b
    return x * y + 7

fn test_str_concat(): int32 =
    let a = "hello"
    let b = "world"
    let c = a + b
    if c != "helloworld": return 1
    if c.len != 10: return 2
    if int32(c[0]) != int32('h'): return 3
    if int32(c[9]) != int32('d'): return 4
    return 0

fn test_seq_basic(): int32 =
    var s: int32[]
    s = []
    add(s, 10)
    add(s, 20)
    if s.len != 2: return 1
    if s[0] != 10: return 2
    if s[1] != 20: return 3
    var total = s[0] + s[1]
    if total != 30: return 4
    return 0

fn test_seq_with_init(): int32 =
    let s: int32[] = [5, 15, 25]
    if s.len != 3: return 1
    if s[1] != 15: return 2
    return 0

fn test_f64_basic(a: int32, b: int32): int64 =
    let x: int64 = a
    let y: int64 = b
    return x * y

fn test_i32_from_i64(): int32 =
    let big: int64 = 1000
    let small: int32 = big
    return small

fn test_ptr_load_store_u16(): int32 =
    let buf = #[uint16, 4](100, 200, 300, 400)
    let p: *uint16 = &buf[0]
    let v0 = *p
    let v1 = *(p + 2)
    return v0 + v1

fn main(): int32 =
    if test_i32_bitwise(0xFF, 0x0F) != 0xFF + 0x0F + 0xF0:
        return 1
    if test_i32_shift(16, 2) != 64 + 4:
        return 2
    if test_i64_arith(10, 20, 5) != 25:
        return 3
    if test_i64_mul(7, 6) != 42:
        return 4
    if test_i64_const() != 42:
        return 5
    if test_i64_const_large() != 100000:
        return 6
    if test_cmp_eq(5, 5) != 1 || test_cmp_eq(5, 6) != 0:
        return 7
    if test_cmp_ne(5, 6) != 1 || test_cmp_ne(5, 5) != 0:
        return 8
    if test_cmp_lt(3, 5) != 1 || test_cmp_lt(5, 3) != 0:
        return 9
    if test_cmp_gt(5, 3) != 1 || test_cmp_gt(3, 5) != 0:
        return 10
    if test_cmp_le(3, 5) != 1 || test_cmp_le(5, 3) != 0 || test_cmp_le(4, 4) != 1:
        return 11
    if test_cmp_ge(5, 3) != 1 || test_cmp_ge(3, 5) != 0 || test_cmp_ge(4, 4) != 1:
        return 12
    if test_ptr_load_store_u8() != 10:
        return 13
    if test_ptr_load_store_i32() != 300:
        return 14
    if test_ptr_load_store_i64() != 3000:
        return 15
    if test_i64_mixed(5, 3) != 22:
        return 16
    if test_str_concat() != 0:
        return 17
    if test_seq_basic() != 0:
        return 18
    if test_seq_with_init() != 0:
        return 19
    if test_i32_from_i64() != 1000:
        return 20
    if test_ptr_load_store_u16() != 500:
        return 21
    return 0
