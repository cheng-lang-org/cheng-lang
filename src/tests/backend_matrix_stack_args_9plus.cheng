fn AddPair(left: int32, right: int32): int32 =
    return left + right

fn SumStackArgs(a0: int32,
                a1: int32,
                a2: int32,
                a3: int32,
                a4: int32,
                a5: int32,
                a6: int32,
                a7: int32,
                a8: int32,
                a9: int32): int32 =
    return AddPair(a8, a9)

fn main(): int32 =
