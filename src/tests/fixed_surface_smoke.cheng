import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/std/crypto/fixed256 as fixed256

fn verifyFixed256Sha256() =
    let shaInput: Bytes = bytesFromString("abc")
    let shaSpan: layout.ByteSpan = layout.byteSpanFromBytes(shaInput)
    let shaDigest: layout.FixedBytes32 = fixed256.sha256Fixed(shaSpan)
    let shaExpectRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
    assert(IsOk(shaExpectRes), " fixed256: sha256 expect")
    let shaExpect: layout.FixedBytes32 = Value(shaExpectRes)
    assert(layout.fixedBytes32Equal(shaDigest, shaExpect), " fixed256: sha256")

fn verifyFixed256Curve25519Vectors() =
    let aliceRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex(
        "77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    assert(IsOk(aliceRes), " fixed256: x25519 alice private")
    let bobRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex(
        "5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    assert(IsOk(bobRes), " fixed256: x25519 bob private")
    let bobPubExpectRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "de9edb7d7b7dc1b4d35b61c2ece435373f8343c85b78674dadfc7e146f882b4f")
    assert(IsOk(bobPubExpectRes), " fixed256: x25519 bob public vector")
    let sharedExpectRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(
        "4a5d9d5ba4ce2de1728e3bf480350f25e07e21c947d19e3376f09b3c1e161742")
    assert(IsOk(sharedExpectRes), " fixed256: x25519 shared vector")
    let alicePubRes: Result[layout.FixedBytes32] = fixed256.curve25519PublicKey(Value(aliceRes))
    assert(IsOk(alicePubRes), " fixed256: x25519 alice public")
    let bobPubRes: Result[layout.FixedBytes32] = fixed256.curve25519PublicKey(Value(bobRes))
    assert(IsOk(bobPubRes), " fixed256: x25519 bob public")
    let bobPub: layout.FixedBytes32 = Value(bobPubRes)
    let bobPubExpect: layout.FixedBytes32 = Value(bobPubExpectRes)
    assert(layout.fixedBytes32Equal(bobPub, bobPubExpect),
           " fixed256: x25519 bob public vector")
    let sharedRes: Result[layout.FixedBytes32] = fixed256.curve25519SharedKeyFixed(Value(aliceRes), Value(bobPubRes))
    assert(IsOk(sharedRes), " fixed256: x25519 shared")
    assert(layout.fixedBytes32Equal(Value(sharedRes), Value(sharedExpectRes)), " fixed256: x25519 shared vector")

fn main(): int32 =
    verifyFixed256Sha256()
    verifyFixed256Curve25519Vectors()
    echo(" fixed_surface_smoke ok")
    return 0
