import std/system
import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/std/crypto/fixed256 as fixed256

fn main(): int32 =
    let aliceRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex(
        "77076d0a7318a57d3c16c17251b26645df4c2f87ebc0992ab177fba51db92c2a")
    assert(IsOk(aliceRes), " fixed256 curve25519: alice private")
    let bobRes: Result[fixed256.Scalar256] = fixed256.scalar256FromHex(
        "5dab087e624a8a4b79e17f8b83800ee66f3bb1292618b6fd1c2f8b27ff88e0eb")
    assert(IsOk(bobRes), " fixed256 curve25519: bob private")
    let bobPubExpectRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(
        "de9edb7d7b7dc1b4d35b61c2ece435373f8343c85b78674dadfc7e146f882b4f")
    assert(IsOk(bobPubExpectRes), " fixed256 curve25519: bob expect")
    let bobPubRes: Result[layout.FixedBytes32] = fixed256.curve25519PublicKey(Value(bobRes))
    assert(IsOk(bobPubRes), " fixed256 curve25519: bob public")
    let bobPubBytes: Bytes = layout.FixedBytes32ToBytes(Value(bobPubRes))
    let bobExpectBytes: Bytes = layout.FixedBytes32ToBytes(Value(bobPubExpectRes))
    assert(bytesGet(bobExpectBytes, 0) == 0xde, " fixed256 curve25519: expect byte0")
    assert(bytesGet(bobExpectBytes, 1) == 0x9e, " fixed256 curve25519: expect byte1")
    assert(bytesGet(bobExpectBytes, 31) == 0x4f, " fixed256 curve25519: expect byte31")
    assert(bytesGet(bobPubBytes, 0) == 0xde, " fixed256 curve25519: bob byte0")
    assert(bytesGet(bobPubBytes, 1) == 0x9e, " fixed256 curve25519: bob byte1")
    assert(bytesGet(bobPubBytes, 31) == 0x4f, " fixed256 curve25519: bob byte31")
    assert(layout.FixedBytes32Equal(Value(bobPubRes), Value(bobPubExpectRes)),
           " fixed256 curve25519: bob public vector")
    echo(" fixed256_curve25519_smoke ok")
    return 0
