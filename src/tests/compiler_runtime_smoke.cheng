import cheng/core/tooling/compiler_runtime as crun
import cheng/core/tooling/support_matrix as smatrix
import cheng/core/tooling/bootstrap_contracts as contracts
import cheng/core/backend/build_plan as buildplan
import std/os
import std/strings
import cheng/core/runtime/core_runtime as corun
import cheng/core/runtime/compiler_runtime as rtrun
import cheng/core/runtime/debug_runtime as dbrun
import cheng/core/runtime/program_support as psrun
import std/strutils as strutil

fn main(): int32 =
    let providerRoot = os.GetEnvDefault("CHENG_ROOT", "/tmp/cheng-lang")
    let contract = crun.CompilerRuntimeContract("/tmp/cheng-lang")
    assert(contract.version == "cheng.compiler_runtime.v1", " compiler runtime: version")
    assert(contract.executionModel == "argv_control_plane", " compiler runtime: execution")
    assert(contract.compilerEntry == "/tmp/cheng-lang/src/core/tooling/compiler_main.cheng",
           " compiler runtime: entry")
    assert(contract.ordinaryCommand == "system-link-exec", " compiler runtime: ordinary command")
    assert(contract.ordinaryPipelineState == "canonical_csg_verified_primary_object_codegen_ready",
           " compiler runtime: ordinary state")
    assert(crun.CompilerProgramArgvRuntimeTarget() == "runtime/compiler.program_argv_entry",
           " compiler runtime: program argv target")
    assert(crun.CompilerToolingArgvRuntimeTarget() == "runtime/compiler.tooling_argv_entry",
           " compiler runtime: tooling argv target")
    assert(crun.CompilerRuntimeProviderModule() == "runtime/compiler_runtime",
           " compiler runtime: compiler provider")
    assert(crun.CoreRuntimeProviderModule() == "runtime/core_runtime",
           " compiler runtime: core provider")
    assert(crun.DebugRuntimeProviderModule() == "runtime/debug_runtime",
           " compiler runtime: debug provider")
    let programRuntimeContract = rtrun.CompilerRuntimeProviderContract("/tmp/cheng-lang",
                                                                      rtrun.CompilerRuntimeTrackProgram)
    let toolingRuntimeContract = rtrun.CompilerRuntimeProviderContract("/tmp/cheng-lang",
                                                                      rtrun.CompilerRuntimeTrackTooling)
    let coreDarwinContract = corun.CoreRuntimeContractForTarget("/tmp/cheng-lang",
                                                                  "arm64-apple-darwin")
    let coreLinuxContract = corun.CoreRuntimeContractForTarget("/tmp/cheng-lang",
                                                                 "x86_64-unknown-linux-gnu")
    let debugRuntimeContract = dbrun.DebugRuntimeContract("/tmp/cheng-lang")
    let programSupportContract = psrun.ProgramSupportContract("/tmp/cheng-lang")
    assert(programRuntimeContract.providerNativeSources[0] ==
               strutil.Join([providerRoot, "/src/core/runtime/compiler_runtime_program_entry_provider.cheng"], ""),
           " compiler runtime: program argv provider source")
    assert(toolingRuntimeContract.providerNativeSources[0] ==
               strutil.Join([providerRoot, "/src/core/runtime/compiler_runtime_tooling_entry_provider.cheng"], ""),
           " compiler runtime: tooling argv provider source")
    assert(coreDarwinContract.providerNativeSources[0] ==
               strutil.Join([providerRoot, "/src/core/runtime/core_runtime_provider_darwin.cheng"], ""),
           " compiler runtime: darwin core provider source")
    assert(coreLinuxContract.providerNativeSources[0] ==
               strutil.Join([providerRoot, "/src/core/runtime/core_runtime_provider_linux.cheng"], ""),
           " compiler runtime: linux core provider source")
    assert(debugRuntimeContract.providerNativeSources[0] ==
               strutil.Join([providerRoot, "/src/core/runtime/debug_runtime_stub.cheng"], ""),
           " compiler runtime: debug provider source")
    assert(programSupportContract.providerNativeSources[0] ==
               strutil.Join([providerRoot, "/src/core/runtime/program_support_backend.cheng"], ""),
           " compiler runtime: support provider source")
    assert(psrun.ProgramSupportHostProviderSourcePath("/tmp/cheng-lang") ==
               strutil.Join([providerRoot, "/src/core/runtime/program_support_host_runtime.cheng"], ""),
           " compiler runtime: host support provider source")
    var providers: str[]
    crun.RuntimeProviderModulesForTrack(crun.CompilerTrackProgram, providers)
    assert(providers.len == 5, " compiler runtime: provider count")
    assert(providers[0] == "runtime/compiler_runtime",
           " compiler runtime: provider compiler")
    assert(providers[1] == "runtime/core_runtime",
           " compiler runtime: provider core")
    assert(providers[2] == "runtime/debug_runtime",
           " compiler runtime: provider debug")
    assert(providers[3] == "runtime/program_support",
           " compiler runtime: provider program support")
    assert(providers[4] == "runtime/program_support_host_runtime",
           " compiler runtime: provider host support")

    let lines = crun.CompilerUsageLines("/tmp/cheng-lang")
    assert(lines.len >= 6, " compiler runtime: usage lines")
    assert(lines[0] == "cheng", " compiler runtime: usage header")
    var sawSystemLink = false
    var sawSupportMatrix = false
    var sawBootstrapBridge = false
    var sawPrintBootstrap = false
    var sawBuildBackendDriver = false
    var sawRunProductionRegression = false
    var sawRunSmokes = false
    var sawScanHotpath = false
    var sawHostBridgeAudit = false
    var sawDebugReport = false
    var sawVerifyOrphanGuard = false
    var sawVerifyBackendDriverCommandSurface = false
    var sawVerifyR2cReactSurface = false
    var sawRunHostSmokes = false
    var sawRunChainNodeCliSmoke = false
    var sawBuildBftStateMachine = false
    var sawR2cReactEntry = false
    var sawVpnGuiEntry = false
    var sawVpnProxyEntry = false
    var sawMobileShellEntry = false
    var sawSliceGate = false
    var sawEmitCsg = false
    var sawMigrateCsg = false
    var sawVerifyWorld = false
    var sawWorldSync = false
    var sawMaterializeWorldMirrors = false
    var sawProveEquivalence = false
    var sawProveMigration = false
    var sawPublishWorld = false
    var sawFreshNodeSelfhost = false
    var sawFollowWorld = false
    var sawSelfhostBuild = false
    for i in 0..<lines.len:
        if lines[i] == "  support-matrix               print the current language/target support matrix":
            sawSupportMatrix = true
        if lines[i] == "  bootstrap-bridge             rebuild and install bootstrap stage0-stage3 via candidate artifacts":
            sawBootstrapBridge = true
        if lines[i] == "  print-bootstrap              print the current bootstrap snapshot":
            sawPrintBootstrap = true
        if lines[i] == "  build-backend-driver         rebuild and verify the ordinary backend driver":
            sawBuildBackendDriver = true
        if lines[i] == "  run-production-regression    build driver + command-surface/perf/skill/cross/libp2p live regression bundle":
            sawRunProductionRegression = true
        if lines[i] == "  run-smokes                   self-check stage0/stage1/stage2/stage3 bootstrap compilers":
            sawRunSmokes = true
        if lines[i] == "  scan-hotpath                 scan src for forbidden hotpath regressions":
            sawScanHotpath = true
        if lines[i] == "  host-bridge-audit            fail if legacy host-bridge surfaces leak back into the live path":
            sawHostBridgeAudit = true
        if lines[i] == "  debug-report                emit the stable ordinary pipeline debug report":
            sawDebugReport = true
        if lines[i] == "  verify-orphan-guard         fail on tooling residue or new Cheng U/UE after bootstrap/build":
            sawVerifyOrphanGuard = true
        if lines[i] == "  verify-backend-driver-command-surface verify live backend_driver zero-script command surface":
            sawVerifyBackendDriverCommandSurface = true
        if lines[i] == "  verify-r2c-react-surface verify live r2c-react codegen/native-gui route smoke surface":
            sawVerifyR2cReactSurface = true
        if lines[i] == "  run-host-smokes             run host ordinary/compiler/libp2p/chain smokes":
            sawRunHostSmokes = true
        if lines[i] == "  run-chain-node-cli-smoke    run the chain_node CLI smoke":
            sawRunChainNodeCliSmoke = true
        if lines[i] == "  build-bft-state-machine     build the BFT state machine daemon":
            sawBuildBftStateMachine = true
        if lines[i] == "  r2c-react <subcommand>    zero-script r2c controller entry":
            sawR2cReactEntry = true
        if lines[i] == "  vpn-gui [flags]              pure Cheng local Web GUI for vpn-proxy":
            sawVpnGuiEntry = true
        if lines[i] == "  vpn-proxy <subcommand>       QUIC+TLS dual-exit SOCKS5 proxy entry":
            sawVpnProxyEntry = true
        if lines[i] == "  mobile-shell <subcommand>    pure Cheng native shell generator for android/ios/harmony":
            sawMobileShellEntry = true
        if lines[i] == "  slice-gate                  run the full cheng gate through stage3 forwarding, incl. chain_node/bft/x86 mainline":
            sawSliceGate = true
        if lines[i] == "  system-link-exec             ordinary AOT compile entry (canonical CSG + provider object plan)":
            sawSystemLink = true
        if lines[i] == "  emit-csg                     emit the canonical compiler CSG report for a source closure":
            sawEmitCsg = true
        if lines[i] == "  migrate-csg                  migrate legacy source text into the current canonical CSG":
            sawMigrateCsg = true
        if lines[i] == "  verify-world                 verify world-head, full-closure manifest, lock, and export-surface compatibility":
            sawVerifyWorld = true
        if lines[i] == "  world-sync                   materialize a full world bundle report set for sync/distribution":
            sawWorldSync = true
        if lines[i] == "  materialize-world-mirrors    materialize managed dependency mirrors from a world-sync bundle prefix":
            sawMaterializeWorldMirrors = true
        if lines[i] == "  prove-equivalence            prove old world reports are canonically equivalent to the current CSG":
            sawProveEquivalence = true
        if lines[i] == "  prove-migration             prove legacy source migrates into a canonically equivalent CSG":
            sawProveMigration = true
        if lines[i] == "  publish-world                publish a full world bundle with stable/edge gate enforcement":
            sawPublishWorld = true
        if lines[i] == "  fresh-node-selfhost          sync a full published world bundle into a fresh node and re-verify the receipt":
            sawFreshNodeSelfhost = true
        if lines[i] == "  follow-world                 sync/verify a world bundle or bundle-prefix, rebuild backend_driver.next, and atomically install on receipt match":
            sawFollowWorld = true
        if lines[i] == "  selfhost-build               run the selfhost build gate pinned to a world head":
            sawSelfhostBuild = true
    assert(sawSupportMatrix, " compiler runtime: usage support matrix")
    assert(sawBootstrapBridge, " compiler runtime: usage bootstrap bridge")
    assert(sawPrintBootstrap, " compiler runtime: usage print bootstrap")
    assert(sawBuildBackendDriver, " compiler runtime: usage build backend driver")
    assert(sawRunProductionRegression, " compiler runtime: usage production regression")
    assert(sawRunSmokes, " compiler runtime: usage run smokes")
    assert(sawScanHotpath, " compiler runtime: usage scan hotpath")
    assert(sawHostBridgeAudit, " compiler runtime: usage host bridge audit")
    assert(sawDebugReport, " compiler runtime: usage debug report")
    assert(sawVerifyOrphanGuard, " compiler runtime: usage orphan guard")
    assert(sawVerifyBackendDriverCommandSurface,
           " compiler runtime: usage backend driver command surface")
    assert(sawVerifyR2cReactSurface, " compiler runtime: usage r2c surface")
    assert(sawRunHostSmokes, " compiler runtime: usage host smokes")
    assert(sawRunChainNodeCliSmoke, " compiler runtime: usage chain node cli smoke")
    assert(sawBuildBftStateMachine, " compiler runtime: usage build bft state machine")
    assert(sawR2cReactEntry, " compiler runtime: usage r2c controller entry")
    assert(sawVpnGuiEntry, " compiler runtime: usage vpn gui entry")
    assert(sawVpnProxyEntry, " compiler runtime: usage vpn proxy entry")
    assert(sawMobileShellEntry, " compiler runtime: usage mobile shell entry")
    assert(sawSliceGate, " compiler runtime: usage slice gate")
    assert(sawSystemLink, " compiler runtime: usage ordinary command")
    assert(sawEmitCsg, " compiler runtime: usage emit csg")
    assert(sawMigrateCsg, " compiler runtime: usage migrate csg")
    assert(sawVerifyWorld, " compiler runtime: usage verify world")
    assert(sawWorldSync, " compiler runtime: usage world sync")
    assert(sawMaterializeWorldMirrors, " compiler runtime: usage materialize world mirrors")
    assert(sawProveEquivalence, " compiler runtime: usage prove equivalence")
    assert(sawProveMigration, " compiler runtime: usage prove migration")
    assert(sawPublishWorld, " compiler runtime: usage publish world")
    assert(sawFreshNodeSelfhost, " compiler runtime: usage fresh node")
    assert(sawFollowWorld, " compiler runtime: usage follow world")
    assert(sawSelfhostBuild, " compiler runtime: usage selfhost build")

    let plan = buildplan.BackendBuildPlanDefault("/tmp/cheng-lang")
    assert(plan.entryPath == "/tmp/cheng-lang/src/core/tooling/compiler_main.cheng",
           " compiler runtime: build entry path")
    assert(plan.targetTriple == contracts.BootstrapDefaultTarget(),
           " compiler runtime: build target")
    assert(plan.linker == buildplan.BackendLinkerSystemLink, " compiler runtime: linker mode")
    assert(plan.sourceUnits.len >= 21, " compiler runtime: build sources")
    let supportReport = smatrix.SupportMatrixReport("/tmp/cheng-lang")
    assert(strings.StrContains(supportReport, "format=cheng_support_matrix_v1"),
           " compiler runtime: support matrix format")
    assert(strings.StrContains(supportReport, "language_surface=line_normalized_parser_stub"),
           " compiler runtime: support matrix language surface")
    assert(strings.StrContains(supportReport, "language_ast_authority=0"),
           " compiler runtime: support matrix ast authority")
    assert(strings.StrContains(supportReport,
                               "ordinary_pipeline_state=canonical_csg_verified_primary_object_codegen_ready"),
           " compiler runtime: support matrix pipeline")
    assert(strings.StrContains(supportReport, "target_count=7"),
           " compiler runtime: support matrix target count")
    assert(strings.StrContains(supportReport, "target[0].triple=arm64-apple-darwin"),
           " compiler runtime: support matrix host target")
    assert(strings.StrContains(supportReport, "target[2].linux_nolibc_runtime=1"),
           " compiler runtime: support matrix linux nolibc")
    assert(strings.StrContains(supportReport,
                               strutil.Join(["compiler_build_source_unit_count=", IntToStr(plan.sourceUnits.len)], "")),
           " compiler runtime: support matrix source count")

    echo(" compiler_runtime_smoke ok")
    return 0
