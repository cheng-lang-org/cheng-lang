import cheng/tests/typed_expr_fact_helper as typedhelper
import std/strutils as strutil

fn callPair(left: str, right: str): str =
    return strutil.Join([left, right], "")

fn callZero(): str =
    return "zero"

fn callArgsMatrix(payload: str): str =
    let none: str = callZero()
    let pair: str = callPair(payload, typedhelper.TypedExternalEcho(payload))
    return strutil.Join([pair, none], "")
