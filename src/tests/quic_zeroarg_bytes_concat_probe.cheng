import std/rawbytes
import cheng/quic/tls/handshake13
import std/strutils as strutil

fn main(): int32 =
    let text: str = strutil.Join(["x=", bytesToHex(handshake13.msquicTls13ClientLocalKeySharePub())], "")
    assert(len(text) >= 2, " quic zeroarg bytes concat: text")
    echo(" quic_zeroarg_bytes_concat_probe ok")
    return 0
