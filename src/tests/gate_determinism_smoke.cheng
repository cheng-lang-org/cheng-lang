import std/os
import cheng/core/tooling/determinism_driver as detdriver

fn main(): int32 =
    let root = os.Getcwd()
    let source = "src/tests/determinism_fixture_min.cheng"
    if os.FileExists(source):
        let rc = detdriver.DeterminismGateVerifyBackendDriverOutput(root, source)
        if rc != 0:
            echo("gate_determinism_smoke: FAIL - determinism gate returned error")
            return rc
        echo("gate_determinism_smoke: PASS")
        return 0
    echo("gate_determinism_smoke: SKIP - no fixture source")
    return 0
