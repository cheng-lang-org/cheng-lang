import std/os as os
import std/strings as strings
import std/strformat

const
    osListDirStressFileCount = 256
    osListDirStressRounds = 6000

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_list_dir_stress_tmp"
    if os.DirExists(tmpRoot):
        for i in 0..<osListDirStressFileCount:
            let path = os.JoinPath(tmpRoot, Fmt(["entry_", strings.IntToStr(i), ".txt"]))
            if os.FileExists(path):
                assert(os.RemoveFile(path), " os.ListDir stress cleanup file")
        os.RemoveDir(tmpRoot)
    os.CreateDir(tmpRoot)
    for i in 0..<osListDirStressFileCount:
        let path = os.JoinPath(tmpRoot, Fmt(["entry_", strings.IntToStr(i), ".txt"]))
        os.WriteFile(path, "x")

    var entries: str[]
    var round: int32
    while round < osListDirStressRounds:
        entries = os.ListDir(tmpRoot)
        assert(entries.len == osListDirStressFileCount, " os.ListDir stress count")
        entries = []
        round = round + 1

    let snapshot = os.ListDir(tmpRoot)
    var sawEntry0: bool
    var sawEntry255: bool
    for i in 0..<snapshot.len:
        let entry = snapshot[i]
        if entry == "entry_0.txt":
            sawEntry0 = true
        elif entry == "entry_255.txt":
            sawEntry255 = true

    for i in 0..<osListDirStressFileCount:
        let path = os.JoinPath(tmpRoot, Fmt(["entry_", strings.IntToStr(i), ".txt"]))
        assert(os.RemoveFile(path), " os.ListDir stress remove file")
    os.RemoveDir(tmpRoot)
    assert(sawEntry0, " os.ListDir stress snapshot keeps first name")
    assert(sawEntry255, " os.ListDir stress snapshot keeps last name")
    echo(" os_list_dir_stress_smoke ok")
    return 0
