import std/strutils as strutil

fn main(): int32 =
    let line = "export[0]=cheng/tests/program_selfhost_smoke::main|main|5|2|2"
    let eqParts = strutil.Split(line, '=')
    assert(eqParts.len == 2, "strutils split probe: eq len")
    let pipeParts = strutil.Split(eqParts[1], '|')
    assert(pipeParts.len == 5, "strutils split probe: pipe len")
    assert(pipeParts[0] == "cheng/tests/program_selfhost_smoke::main",
           "strutils split probe: symbol")
    assert(pipeParts[1] == "main", "strutils split probe: target")
    assert(pipeParts[2] == "5", "strutils split probe: layout")
    assert(pipeParts[3] == "2", "strutils split probe: effect")
    assert(pipeParts[4] == "2", "strutils split probe: capability")
    echo("v3 strutils_split_probe ok")
    return 0
