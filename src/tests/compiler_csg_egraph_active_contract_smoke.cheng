import std/strings
import cheng/core/tooling/compiler_csg_egraph_contract as econtract

fn assertContains(text: str,
                  needle: str,
                  label: str) =
    assert(strings.StrContains(text, needle), label)

fn main(): int32 =
    let activeReport = econtract.CompilerCsgEgraphActiveContractReport()
    assertContains(activeReport,
                   "egraph_active_contract=canonical_csg_equivalence",
                   " compiler csg egraph contract: active contract")
    assertContains(activeReport,
                   "egraph_equivalence_surface=canonical_graph_cid",
                   " compiler csg egraph contract: canonical surface")
    assertContains(activeReport,
                   "canonical_csg_equivalence_available=1",
                   " compiler csg egraph contract: csg equivalence available")
    assertContains(activeReport,
                   "normalization_coverage=I32_I64_bitwise_integer_only",
                   " compiler csg egraph contract: normalization coverage")
    assertContains(activeReport,
                   "uir_egraph_status=unavailable",
                   " compiler csg egraph contract: uir status")
    assertContains(activeReport,
                   "uir_egraph_available=0",
                   " compiler csg egraph contract: uir unavailable")
    assertContains(activeReport,
                   "uir_egraph_rewrite_enabled=0",
                   " compiler csg egraph contract: uir rewrite disabled")
    assertContains(activeReport,
                   "uir_egraph_rewrite_rule_count=0",
                   " compiler csg egraph contract: uir rewrite rule count")
    assertContains(activeReport,
                   "uir_egraph_hard_fail=1",
                   " compiler csg egraph contract: uir hard fail")
    assertContains(activeReport,
                   "uir_egraph_reason=not_in_active_backend_build_plan",
                   " compiler csg egraph contract: uir reason")
    assert(econtract.CompilerCsgUirEgraphUnavailableExitCode() == 2,
           " compiler csg egraph contract: uir fail exit code")
    echo(" compiler_csg_egraph_active_contract_smoke ok")
    return 0
