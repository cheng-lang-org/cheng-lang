import std/bytes as bytes

fn main(): int32 =
    let buf: bytes.ByteBuffer = bytes.ReadFileBytes("/Users/lbcheng/cheng-lang/AGENTS.md")
    assert(buf.len > 0, "no_pointer_read_file_bytes_smoke len")
    assert(bytes.BufByteAt(buf, 0) > 0, "no_pointer_read_file_bytes_smoke first byte")
    bytes.FreeByteBuffer(buf)
    let slice: bytes.ByteBuffer = bytes.ReadFileSlice("/Users/lbcheng/cheng-lang/AGENTS.md", 0, 4)
    assert(slice.len == 4, "no_pointer_read_file_bytes_smoke slice len")
    assert(bytes.BufByteAt(slice, 0) > 0, "no_pointer_read_file_bytes_smoke slice first byte")
    bytes.FreeByteBuffer(slice)
    echo("no_pointer_read_file_bytes_smoke ok")
    return 0
