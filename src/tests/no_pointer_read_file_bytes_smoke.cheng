import std/bytes as bytes

fn main(): int32 =
    let buf: bytes.ByteBuffer = bytes.ReadFileBytes("/Users/lbcheng/cheng-lang/AGENTS.md")
    assert(buf.len > 0, "no_pointer_read_file_bytes_smoke len")
    assert(bytes.BufByteAt(buf, 0) > 0, "no_pointer_read_file_bytes_smoke first byte")
    bytes.FreeByteBuffer(buf)
    echo("no_pointer_read_file_bytes_smoke ok")
    return 0
