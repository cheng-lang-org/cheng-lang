import std/result
import cheng/qpack/min as qpack

fn main(): int32 =
    var fields: qpack.V3QpackHeaderField[]
    add(fields, qpack.V3QpackMakeHeaderField(":method", "POST"))
    add(fields, qpack.V3QpackMakeHeaderField(":path", "/auth"))
    add(fields, qpack.V3QpackMakeHeaderField("host", "hysteria"))
    add(fields, qpack.V3QpackMakeSensitiveHeaderField("Hysteria-Auth", "secret-token"))
    add(fields, qpack.V3QpackMakeHeaderField("Hysteria-CC-RX", "12345"))
    add(fields, qpack.V3QpackMakeHeaderField("Hysteria-Padding", "pad"))

    let encRes: Result[Bytes] = qpack.V3QpackEncodeLiteralFieldSection(fields)
    assert(IsOk(encRes), "v3 qpack min: encode")
    let wire: Bytes = Value(encRes)
    assert(bytesLen(wire) > 2, "v3 qpack min: wire len")
    assert(bytesGet(wire, 0) == 0, "v3 qpack min: required insert count zero")
    assert(bytesGet(wire, 1) == 0, "v3 qpack min: base zero")

    let decRes: Result[qpack.V3QpackFieldSection] = qpack.V3QpackDecodeLiteralFieldSection(wire)
    assert(IsOk(decRes), "v3 qpack min: decode")
    let decoded: qpack.V3QpackFieldSection = Value(decRes)
    assert(decoded.fields.len == 6, "v3 qpack min: field len")
    assert(decoded.fields[0].name == ":method", "v3 qpack min: first name")
    assert(decoded.fields[1].value == "/auth", "v3 qpack min: second value")
    assert(decoded.fields[2].value == "hysteria", "v3 qpack min: host")
    assert(decoded.fields[3].sensitive, "v3 qpack min: sensitive")
    assert(decoded.fields[4].value == "12345", "v3 qpack min: cc-rx")
    assert(decoded.fields[5].value == "pad", "v3 qpack min: padding")

    echo("v3 qpack_min_smoke ok")
    return 0
