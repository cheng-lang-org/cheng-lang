import std/result
import cheng/qpack/min as qpack

fn main(): int32 =
    var fields: qpack.QpackHeaderField[]
    add(fields, qpack.QpackMakeHeaderField(":method", "POST"))
    add(fields, qpack.QpackMakeHeaderField(":path", "/auth"))
    add(fields, qpack.QpackMakeHeaderField("host", "hysteria"))
    add(fields, qpack.QpackMakeSensitiveHeaderField("Hysteria-Auth", "secret-token"))
    add(fields, qpack.QpackMakeHeaderField("Hysteria-CC-RX", "12345"))
    add(fields, qpack.QpackMakeHeaderField("Hysteria-Padding", "pad"))

    let encRes: Result[Bytes] = qpack.QpackEncodeLiteralFieldSection(fields)
    assert(IsOk(encRes), " qpack min: encode")
    let wire: Bytes = Value(encRes)
    assert(bytesLen(wire) > 2, " qpack min: wire len")
    assert(bytesGet(wire, 0) == 0, " qpack min: required insert count zero")
    assert(bytesGet(wire, 1) == 0, " qpack min: base zero")

    let decRes: Result[qpack.QpackFieldSection] = qpack.QpackDecodeLiteralFieldSection(wire)
    assert(IsOk(decRes), " qpack min: decode")
    let decoded: qpack.QpackFieldSection = Value(decRes)
    assert(decoded.fields.len == 6, " qpack min: field len")
    assert(decoded.fields[0].name == ":method", " qpack min: first name")
    assert(decoded.fields[1].value == "/auth", " qpack min: second value")
    assert(decoded.fields[2].value == "hysteria", " qpack min: host")
    assert(decoded.fields[3].sensitive, " qpack min: sensitive")
    assert(decoded.fields[4].value == "12345", " qpack min: cc-rx")
    assert(decoded.fields[5].value == "pad", " qpack min: padding")

    echo(" qpack_min_smoke ok")
    return 0
