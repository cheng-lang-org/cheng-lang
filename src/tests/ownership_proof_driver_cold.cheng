// Ownership proof driver: cold-compatible
// Uses ownership.cheng module functions directly

type
    OwnershipKind = enum
        Owned
        Borrowed
        Shared

    OwnershipRecord =
        varId: int32
        kind: OwnershipKind
        ownerPath: int32
        sharedRefCount: int32

    OwnershipCtx =
        records: OwnershipRecord[]
        nextVarId: int32

    OwnershipError = enum
        Ok
        ErrDoubleMove
        ErrMoveAfterBorrow
        ErrInvalidOwnership

fn OwnershipCtxNew(): OwnershipCtx =
    var out: OwnershipCtx
    out.records = []
    out.nextVarId = 0
    return out

fn OwnershipCtxGetRecord(ctx: OwnershipCtx, varId: int32, outRecord: var OwnershipRecord): bool =
    for i in 0..<ctx.records.len:
        if ctx.records[i].varId == varId:
            outRecord = ctx.records[i]
            return true
    return false

fn OwnershipCtxSetRecord(ctx: var OwnershipCtx, record: OwnershipRecord) =
    for i in 0..<ctx.records.len:
        if ctx.records[i].varId == record.varId:
            ctx.records[i] = record
            return
    add(ctx.records, record)

fn OwnershipCtxTransfer(ctx: var OwnershipCtx, fromVarId: int32, toVarId: int32): OwnershipError =
    var fromRecord: OwnershipRecord
    if !OwnershipCtxGetRecord(ctx, fromVarId, fromRecord):
        fromRecord.varId = fromVarId
        fromRecord.kind = Owned
        fromRecord.sharedRefCount = 0
    if fromRecord.kind == Borrowed:
        return ErrDoubleMove
    if fromRecord.kind == Shared:
        return ErrMoveAfterBorrow
    if fromRecord.kind != Owned:
        return ErrInvalidOwnership
    var toRecord: OwnershipRecord
    toRecord.varId = toVarId
    toRecord.kind = Owned
    toRecord.sharedRefCount = 0
    fromRecord.kind = Borrowed
    fromRecord.ownerPath = toVarId
    OwnershipCtxSetRecord(ctx, fromRecord)
    OwnershipCtxSetRecord(ctx, toRecord)
    return Ok

fn OwnershipCtxBorrowShared(ctx: var OwnershipCtx, fromVarId: int32, toVarId: int32): OwnershipError =
    var fromRecord: OwnershipRecord
    if !OwnershipCtxGetRecord(ctx, fromVarId, fromRecord):
        fromRecord.varId = fromVarId
        fromRecord.kind = Owned
        fromRecord.sharedRefCount = 0
    if fromRecord.kind == Borrowed:
        return ErrDoubleMove
    if fromRecord.kind != Owned && fromRecord.kind != Shared:
        return ErrInvalidOwnership
    var toRecord: OwnershipRecord
    toRecord.varId = toVarId
    toRecord.kind = Shared
    toRecord.ownerPath = fromVarId
    toRecord.sharedRefCount = 0
    if fromRecord.kind == Owned:
        fromRecord.kind = Shared
        fromRecord.sharedRefCount = 1
    else:
        fromRecord.sharedRefCount = fromRecord.sharedRefCount + 1
    OwnershipCtxSetRecord(ctx, fromRecord)
    OwnershipCtxSetRecord(ctx, toRecord)
    return Ok

fn check_transfer_ok(): int32 =
    var ctx: OwnershipCtx = OwnershipCtxNew()
    let r: OwnershipError = OwnershipCtxTransfer(ctx, 1, 2)
    if r == Ok: return 0
    return 1

fn check_double_move(): int32 =
    var ctx: OwnershipCtx = OwnershipCtxNew()
    let r1: OwnershipError = OwnershipCtxTransfer(ctx, 1, 2)
    if r1 != Ok: return 2
    let r2: OwnershipError = OwnershipCtxTransfer(ctx, 1, 3)
    if r2 != ErrDoubleMove: return 3
    return 0

fn check_borrow(): int32 =
    var ctx: OwnershipCtx = OwnershipCtxNew()
    let r: OwnershipError = OwnershipCtxBorrowShared(ctx, 1, 2)
    if r == Ok: return 0
    return 4

fn check_move_after_borrow(): int32 =
    var ctx: OwnershipCtx = OwnershipCtxNew()
    let r1: OwnershipError = OwnershipCtxBorrowShared(ctx, 1, 2)
    if r1 != Ok: return 5
    let r2: OwnershipError = OwnershipCtxTransfer(ctx, 1, 3)
    if r2 != ErrMoveAfterBorrow: return 6
    return 0

fn main(): int32 =
    let r1: int32 = check_transfer_ok()
    if r1 != 0: return r1
    let r2: int32 = check_double_move()
    if r2 != 0: return r2
    let r3: int32 = check_borrow()
    if r3 != 0: return r3
    let r4: int32 = check_move_after_borrow()
    if r4 != 0: return r4
    echo(" ownership_proof_driver ok")
    return 0
