import cheng/core/lang/parser
import std/strutils as strutil

fn main(): int32 =
    let sourcePath = "cheng/tests/parser_surface_scan_fixture.cheng"
    let text = strutil.Join(["fn sample(flag: bool, res: Result[int32]): int32 =\n", "    let ignored = \"if ? Ok Err Value Error IsOk IsErr ErrorInfoOf\"\n", "    let ignoredChar = '?'\n", "    let verdict = IsOk(res)\n", "    let info = ErrorInfoOf(res)\n", "    return verdict ? 1 : 0\n"], "")
    var layer = parser.NormalizedExprLayer()
    var err = ""
    assert(parser.ParserReadNormalizedExprLayerFromText(sourcePath, text, layer, err),
           " parser surface scan: read layer")
    assert(parser.NormalizedExprLayerExprCount(layer) == 3,
           " parser surface scan: expr count")
    assert(parser.NormalizedExprLayerIfCount(layer) == 1,
           " parser surface scan: if count")
    assert(parser.NormalizedExprLayerTryCount(layer) == 0,
           " parser surface scan: try count")
    assert(parser.NormalizedExprLayerResultIntrinsicCount(layer) == 2,
           " parser surface scan: result intrinsic count")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprResultIntrinsic,
                                                    parser.NormalizedExprDetailResultIsOk,
                                                    4),
           " parser surface scan: IsOk line")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprResultIntrinsic,
                                                    parser.NormalizedExprDetailResultErrorInfoOf,
                                                    5),
           " parser surface scan: ErrorInfoOf line")
    assert(parser.NormalizedExprLayerHasExprExact(layer,
                                                    parser.NormalizedExprIf,
                                                    parser.NormalizedExprDetailIfTernary,
                                                    6),
           " parser surface scan: ternary line")
    for i in 0..<layer.exprs.len:
        let expr = layer.exprs[i]
        assert(expr.lineNumber != 2, " parser surface scan: ignore string literal tokens")
        assert(expr.lineNumber != 3, " parser surface scan: ignore char literal tokens")
    echo(" parser_surface_scan_smoke ok")
    return 0
