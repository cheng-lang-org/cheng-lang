import cheng/std/bytes_layout as layout
import cheng/apps/chain_node/cheng_node_identity as identity

fn main(): int32 =
    let identityRes = identity.ChengNodeIdentityDerive("cheng-node-identity-smoke-root")
    assert(IsOk(identityRes), "cheng_node identity smoke: derive")
    let id = Value(identityRes)
    assert(identity.ChengNodeIdentityDomainCount() == 10,
           "cheng_node identity smoke: domain count")
    assert(!layout.FixedBytes32Equal(id.rootId, id.rootKey),
           "cheng_node identity smoke: root id distinct")
    assert(!layout.FixedBytes32Equal(id.chainKey, id.didKey),
           "cheng_node identity smoke: chain did distinct")
    assert(!layout.FixedBytes32Equal(id.oracleKey, id.dilocoKey),
           "cheng_node identity smoke: oracle diloco distinct")
    assert(!layout.FixedBytes32Equal(id.evomapKey, id.compilerKey),
           "cheng_node identity smoke: evomap compiler distinct")
    echo(" cheng_node_identity_smoke ok")
    return 0
