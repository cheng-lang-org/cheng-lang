import std/system
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/binary_types as binary
import cheng/overlay/contracts as overlay
import cheng/overlay/libp2p_bridge as bridge
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/discovery/kad
import cheng/libp2p/host/host
import cheng/tests/smoke_ports

fn smokeProtocolsAddress(): binary.LsmrAddress =
    var out: binary.LsmrAddress
    out.depth = 2
    out.digits[0] = 4
    out.digits[1] = 8
    return out

fn smokeProtocolsBytes(text: str): Bytes =
    var out: Bytes
    out.data = strDataPtr(text)
    out.len = len(text)
    return out

fn main(): int32 =
    var node = host.Libp2pHostInit("protocols.node")
    var requester = host.Libp2pHostInit("protocols.requester")
    let address = smokeProtocolsAddress()

    let expectedTopic = bridge.Libp2pTopicId(overlay.OverlayScopeRegion, address)
    host.Libp2pSubscribe(node, expectedTopic)
    assert(node.subscriptions.len == 1, " libp2p protocols: subscription count")

    let sourcePeer = peer_id.Libp2pPeerIdFromSeed("protocols.source")
    let payload = smokeProtocolsBytes("cheng.libp2p.payload")
    let payloadCid = hash256.sha256Fixed(layout.byteSpanFromBytes(payload))

    var ingress: overlay.IngressEnvelope
    ingress.sourcePeerId = sourcePeer.value
    ingress.topicScope = overlay.OverlayScopeRegion
    ingress.address = address
    ingress.payloadKind = 0
    ingress.payload = payload
    ingress.payloadCid = payloadCid
    ingress.payloadLen = bytesLen(payload)
    ingress.stampEpoch = 11
    ingress.stampGanzhi = 22

    bridge.Libp2pRelayPublish(node, ingress)

    assert(node.publishLog.len == 1, " libp2p protocols: publish count")
    let published = node.publishLog[0]
    assert(types.Libp2pTopicIdEqual(published.topicId, expectedTopic),
        " libp2p protocols: topic id")
    assert(layout.fixedBytes32Equal(published.payloadCid, payloadCid),
        " libp2p protocols: publish payload cid")
    assert(published.payloadKind == 0,
        " libp2p protocols: publish payload kind")
    assert(published.payloadLen == bytesLen(payload),
        " libp2p protocols: publish payload len")

    assert(node.storeEntries.len == 1, " libp2p protocols: store count")
    let storedEntry = node.storeEntries[0]
    let storedIngress = storedEntry.ingress
    assert(layout.fixedBytes32Equal(storedIngress.payloadCid, payloadCid),
        " libp2p protocols: store payload cid")
    assert(storedIngress.payloadKind == 0,
        " libp2p protocols: store payload kind")
    assert(storedIngress.payloadLen == bytesLen(payload),
        " libp2p protocols: store payload len")
    assert(bytesLen(storedIngress.payload) == bytesLen(payload),
        " libp2p protocols: store raw payload len")
    assert(bytesGet(storedIngress.payload, 0) == int32('v'),
        " libp2p protocols: store raw payload head")

    var listenAddr: types.Libp2pMultiaddr
    multiaddr.Libp2pMultiaddrFillTcp(listenAddr, "127.0.0.1", smoke_ports.SmokeLabelPort(6207))
    let listenRes = host.Libp2pListen(node, listenAddr)
    assert(listenRes.ok, " libp2p protocols: listen sync")
    host.Libp2pRegisterHandler(node, types.Libp2pProtocolSync)
    host.Libp2pRegisterHandler(requester, types.Libp2pProtocolSync)
    let dialRes = host.Libp2pDial(requester,
                                    node.selfPeerId,
                                    listenAddr,
                                    overlay.OverlayRoleEdgeRelayStore)
    assert(dialRes.ok, " libp2p protocols: dial sync")

    var query = overlay.StoreQuery()
    query.topicScope = overlay.OverlayScopeRegion
    query.address = address
    query.rangeLimit = 4
    var syncEntries: overlay.IngressEnvelope[]
    let syncRes = host.Libp2pSyncRequest(requester, node, node.selfPeerId, query, syncEntries)
    assert(syncRes.ok, " libp2p protocols: sync request")
    assert(syncEntries.len == 1, " libp2p protocols: sync count")
    let synced = syncEntries[0]
    assert(layout.fixedBytes32Equal(synced.payloadCid, payloadCid),
        " libp2p protocols: sync payload cid")
    assert(synced.payloadKind == 0,
        " libp2p protocols: sync payload kind")
    assert(synced.payloadLen == bytesLen(payload),
        " libp2p protocols: sync payload len")
    assert(bytesLen(synced.payload) == bytesLen(payload),
        " libp2p protocols: sync raw payload len")
    assert(bytesGet(synced.payload, 0) == int32('v'),
        " libp2p protocols: sync raw payload head")
    assert(requester.syncRequestCount == 1, " libp2p protocols: sync request count")
    assert(node.syncServeCount == 1, " libp2p protocols: sync serve count")

    echo(" libp2p_protocols_smoke ok")
    return 0
