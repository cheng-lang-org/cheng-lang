import std/system
import std/rawbytes
import cheng/libp2p/core/types
import cheng/libp2p/core/multiaddr

fn main(): int32 =
    let text = bytesFromString("/ip4/127.0.0.1/tcp/4101")
    var addr: types.Libp2pMultiaddr
    let addrRes = multiaddr.Libp2pMultiaddrFillFromBytes(addr, text)
    assert(addrRes.ok, " libp2p multiaddr tcp: parse")
    assert(addr.transport == types.Libp2pTransportTcp, " libp2p multiaddr tcp: transport")
    assert(addr.secure == types.Libp2pSecureNoise, " libp2p multiaddr tcp: secure")
    assert(addr.mux == types.Libp2pMuxYamux, " libp2p multiaddr tcp: mux")
    echo(" libp2p_multiaddr_tcp_smoke ok")
    return 0
