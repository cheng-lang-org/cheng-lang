import std/result
import cheng/core/backend/direct_exe_emit as dexe
import cheng/core/backend/primary_object_plan as pobj

fn check(cond: bool, code: int32): int32 =
    if cond:
        return 0
    return code

fn main(): int32 =
    let c1 = check(dexe.DirectExeAlign(16, 8) == 16, 11)
    if c1 != 0: return c1
    let c2 = check(dexe.DirectExeAlign(10, 4) == 12, 12)
    if c2 != 0: return c2
    let c3 = check(dexe.DirectExeAlign(0, 4) == 0, 13)
    if c3 != 0: return c3
    let c4 = check(dexe.DirectExeAlign(7, 8) == 8, 14)
    if c4 != 0: return c4

    let c5 = check(dexe.DirectExePageAlign(100, 4096) == 4096, 21)
    if c5 != 0: return c5
    let c6 = check(dexe.DirectExePageAlign(4096, 4096) == 4096, 22)
    if c6 != 0: return c6

    let c7 = check(dexe.DirectExeIsDarwinArm64("arm64-apple-darwin"), 31)
    if c7 != 0: return c7
    let c8 = check(!dexe.DirectExeIsDarwinArm64("x86_64-unknown-linux-gnu"), 32)
    if c8 != 0: return c8

    let c9 = check(dexe.DirectExeIsMachOFormat("macho"), 41)
    if c9 != 0: return c9
    let c10 = check(dexe.DirectExeIsElfFormat("elf"), 42)
    if c10 != 0: return c10
    let c11 = check(!dexe.DirectExeIsMachOFormat("elf"), 43)
    if c11 != 0: return c11

    var emptyPlan: pobj.PrimaryObjectPlan
    emptyPlan.targetTriple = "arm64-apple-darwin"
    emptyPlan.objectFormat = "macho"
    let c12 = check(dexe.DirectExeEmitTargetSupported(emptyPlan), 51)
    if c12 != 0: return c12

    let c13 = check(dexe.DirectExeEntryFunctionIndex(emptyPlan) == -1, 61)
    if c13 != 0: return c13

    let validateRes = dexe.DirectExeEmitValidateBuild(emptyPlan)
    let c14 = check(!dexe.IsOk(validateRes), 71)
    if c14 != 0: return c14

    let c15 = check(dexe.DirectExePayloadByteCount("zero:42") == 42, 81)
    if c15 != 0: return c15
    let c16 = check(dexe.DirectExePayloadByteCount("zero:0") == 0, 82)
    if c16 != 0: return c16
    let c17 = check(dexe.DirectExePayloadByteCount("unknown") == 0, 83)
    if c17 != 0: return c17

    let c18 = check(dexe.DirectExeEmitCStringPayloadByte("hello", 0) == int32('h'), 91)
    if c18 != 0: return c18
    let c19 = check(dexe.DirectExeEmitCStringPayloadByte("hello", 10) == 0, 92)
    if c19 != 0: return c19

    echo("direct_exe_emit_smoke ok")
    return 0
