fn EmptyText(): str =
    var out: str
    return out

fn UseText(value: str): int32 =
    return 0

fn CountZero(): int32 =
    return 0

fn UseTextAgain(value: str): int32 =
    return 0

fn main(): int32 =
    let value: str = EmptyText()
    UseText(value)
    let count: int32 = CountZero()
    if count <= 0:
        UseTextAgain(value)
        return 0
    return 0
