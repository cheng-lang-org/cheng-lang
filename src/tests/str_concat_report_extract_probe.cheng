import std/os
import std/strutils as strutil
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root = os.GetCurrentDir()
    let reportPath = os.JoinPath(root, "artifacts/str_concat_lowering_smoke/str_concat_lowering_probe.compile.report.txt")
    assert(chengpath.PathFileExists(reportPath), " report extract: report exists")
    let reportText = os.ReadFile(reportPath)
    let reportPrefix = "native_primary_object="
    let reportLines = strutil.Split(reportText, '\n')
    var primaryObjectPath: str
    for i in 0..<reportLines.len:
        let line = strutil.Strip(reportLines[i])
        if strutil.StartsWith(line, reportPrefix):
            primaryObjectPath = chengpath.TextSlice(line, len(reportPrefix), len(line) - len(reportPrefix))
    assert(len(primaryObjectPath) > 0, " report extract: primary object path")
    echo(primaryObjectPath)
    return 0
