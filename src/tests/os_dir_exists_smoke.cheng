import std/os as os

fn main(): int32 =
    let tmpRoot: str = "artifacts/os_dir_exists_smoke_tmp"
    let nestedFile: str = os.JoinPath(tmpRoot, "child.txt")
    let missingDir: str = os.JoinPath(tmpRoot, "missing")
    let srcDir: str = os.JoinPath("v3", "src")

    if os.FileExists(nestedFile):
        assert(os.RemoveFile(nestedFile), "v3 ordinary os.DirExists cleanup nested file")
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)

    os.CreateDir(tmpRoot)
    assert(os.DirExists(tmpRoot), "v3 ordinary os.DirExists created dir")
    let missingExists: bool = os.DirExists(missingDir)
    if missingExists:
        assert(false, "v3 ordinary os.DirExists missing dir")

    os.WriteFile(nestedFile, "x")
    let fileAsDir: bool = os.DirExists(nestedFile)
    if fileAsDir:
        assert(false, "v3 ordinary os.DirExists excludes file")
    assert(os.DirExists(srcDir), "v3 ordinary os.DirExists repo dir")

    if os.FileExists(nestedFile):
        assert(os.RemoveFile(nestedFile), "v3 ordinary os.DirExists remove nested file")
    if os.DirExists(tmpRoot):
        os.RemoveDir(tmpRoot)
    echo("v3 os_dir_exists_smoke ok")
    return 0
