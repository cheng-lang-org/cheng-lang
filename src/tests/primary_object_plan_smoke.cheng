import std/os
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as v3path
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/backend/primary_object_plan as pobj

fn main(): int32 =
    let rootDir = v3path.V3PathCurrentDir()
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = v3path.V3PathJoin(rootDir, "artifacts/program_selfhost/" + smokeLabel)
    assert(v3path.V3MkdirP(rootDir, outDir), "v3 primary object smoke: mkdir")
    let req = creq.v3CompilerRequestNew(
        v3path.V3PathJoin(rootDir, "v3"),
        v3path.V3PathJoin(rootDir, "src/tests/program_selfhost_smoke.cheng"),
        v3path.V3PathJoin(outDir, "program_selfhost_smoke"),
        "arm64-apple-darwin",
        creq.v3EmitExe,
        ""
    )
    var linkPlan: slplan.V3SystemLinkPlanStub
    var err = ""
    assert(slplan.v3BuildSystemLinkPlanStub(rootDir, req, linkPlan, err), "v3 primary object smoke: link plan")
    var loweringPlan: lower.V3LoweringPlanStub
    assert(lower.v3BuildLoweringPlanStub(linkPlan, loweringPlan, err), "v3 primary object smoke: lowering plan")
    let primaryRes = pobj.v3BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    assert(IsOk(primaryRes), "v3 primary object smoke: primary object plan")
    let primary = Value(primaryRes)
    assert(primary.itemIds.len > 0, "v3 primary object smoke: item ids")
    assert(primary.symbolNames.len == primary.itemIds.len, "v3 primary object smoke: symbol count")
    assert(primary.missingReasons.len > 0, "v3 primary object smoke: missing machine code is explicit")
    echo("v3 primary_object_plan_smoke ok")
    return 0
