import std/os
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/backend/primary_object_plan as pobj

fn main(): int32 =
    let rootDir = chengpath.PathCurrentDir()
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(rootDir, "artifacts/program_selfhost/" + smokeLabel)
    assert(chengpath.MkdirP(rootDir, outDir), " primary object smoke: mkdir")
    let req = creq.CompilerRequestNew(
        rootDir,
        chengpath.PathJoin(rootDir, "src/tests/program_selfhost_smoke.cheng"),
        chengpath.PathJoin(outDir, "program_selfhost_smoke"),
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(rootDir, req, linkPlan, err), " primary object smoke: link plan")
    var loweringPlan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(linkPlan, loweringPlan, err), " primary object smoke: lowering plan")
    let primaryRes = pobj.BuildPrimaryObjectPlan(linkPlan, loweringPlan)
    assert(IsOk(primaryRes), " primary object smoke: primary object plan")
    let primary = Value(primaryRes)
    assert(primary.itemIds.len > 0, " primary object smoke: item ids")
    assert(primary.symbolNames.len == primary.itemIds.len, " primary object smoke: symbol count")
    assert(primary.missingReasons.len > 0, " primary object smoke: missing machine code is explicit")
    echo(" primary_object_plan_smoke ok")
    return 0
