import std/os
import std/strings
import std/strutils as strutil
import cheng/core/tooling/path as chengpath
import cheng/r2c/native_platform_shell_runtime as shellruntime

fn main(): int32 =
    let outDir: str = "/tmp/r2c_native_platform_shell_runtime_smoke_artifacts"
    let framePath: str = chengpath.PathJoin(outDir, "frame.rgba")
    let manifestPath: str = chengpath.PathJoin(outDir, "native_platform_shell_manifest_v1.json")
    let androidPath: str = chengpath.PathJoin(outDir, "native_platform_shell_android_launch_v1.json")
    let iosPath: str = chengpath.PathJoin(outDir, "native_platform_shell_ios_launch_v1.json")
    let ohosPath: str = chengpath.PathJoin(outDir, "native_platform_shell_ohos_launch_v1.json")
    let summaryPath: str = chengpath.PathJoin(outDir, "native_platform_shell_launch.summary.env")
    assert(chengpath.MkdirP("", outDir), "r2c native platform shell runtime smoke: mkdir")
    if os.FileExists(framePath):
        os.RemoveFile(framePath)
    if os.FileExists(manifestPath):
        os.RemoveFile(manifestPath)
    if os.FileExists(androidPath):
        os.RemoveFile(androidPath)
    if os.FileExists(iosPath):
        os.RemoveFile(iosPath)
    if os.FileExists(ohosPath):
        os.RemoveFile(ohosPath)
    if os.FileExists(summaryPath):
        os.RemoveFile(summaryPath)
    let framePayload: uint8[] = [
        uint8(255), uint8(0), uint8(0), uint8(255),
        uint8(0), uint8(255), uint8(0), uint8(255),
        uint8(0), uint8(0), uint8(255), uint8(255),
        uint8(255), uint8(255), uint8(255), uint8(255)
    ]
    os.WriteFileBytes(framePath, framePayload)
    assert(os.FileExists(framePath), "r2c native platform shell runtime smoke: frame exists")
    assert(os.FileSize(framePath) == int64(16), "r2c native platform shell runtime smoke: frame size")
    let manifest = Fmt"""
    {{
      "format": "native_platform_shell_manifest_v1",
      "ready": true,
      "generated_by": "cheng.native_gui_runtime_v1",
      "runtime_purity": {{"node": false, "react": false, "webview_business_layer": false, "business_js": false}},
      "surface_frame_path": "{framePath}",
      "surface_manifest_path": "/tmp/surface_manifest.json",
      "route_replay_manifest_path": "/tmp/route_replay_manifest.json",
      "interaction_manifest_path": "/tmp/interaction_manifest.json",
      "frame_format": "surface_frame_rgba_v1",
      "pixel_format": "rgba8_unpremultiplied",
      "width": 2,
      "height": 2,
      "stride_bytes": 8,
      "frame_byte_count": 16,
      "route_count": 3,
      "active_route_state": "home_default",
      "event_loop": "event_driven_v1",
      "platforms": [
        {{"id":"android","shell_kind":"cheng_generated_android_surface_shell_v1","surface_binding":"ANativeWindow_rgba_blit_v1","input_binding":"AInputQueue_event_driven_v1","blit_contract":"rgba8_stride_copy_v1"}},
        {{"id":"ios","shell_kind":"cheng_generated_ios_surface_shell_v1","surface_binding":"CAMetalLayer_rgba_blit_v1","input_binding":"UIKit_touch_event_driven_v1","blit_contract":"rgba8_stride_copy_v1"}},
        {{"id":"ohos","shell_kind":"cheng_generated_ohos_surface_shell_v1","surface_binding":"OHNativeWindow_rgba_blit_v1","input_binding":"XComponent_event_driven_v1","blit_contract":"rgba8_stride_copy_v1"}}
      ]
    }}

    """
    os.WriteFile(manifestPath, manifest)
    let manifestText = os.ReadFile(manifestPath)
    assert(shellruntime.NativePlatformShellManifestValid(manifestText),
           "r2c native platform shell runtime smoke: manifest valid")
    assert(shellruntime.WriteNativePlatformShellLaunchPlans(manifestPath, outDir),
           "r2c native platform shell runtime smoke: write launch plans")
    assert(os.FileExists(androidPath), "r2c native platform shell runtime smoke: android exists")
    assert(os.FileExists(iosPath), "r2c native platform shell runtime smoke: ios exists")
    assert(os.FileExists(ohosPath), "r2c native platform shell runtime smoke: ohos exists")
    assert(os.FileExists(summaryPath), "r2c native platform shell runtime smoke: summary exists")
    let androidText = os.ReadFile(androidPath)
    let iosText = os.ReadFile(iosPath)
    let ohosText = os.ReadFile(ohosPath)
    let summaryText = os.ReadFile(summaryPath)
    assert(strutil.Contains(androidText, "\"platform\": \"android\""),
           "r2c native platform shell runtime smoke: android platform")
    assert(strutil.Contains(androidText, "\"surface_binding\": \"ANativeWindow_rgba_blit_v1\""),
           "r2c native platform shell runtime smoke: android surface")
    assert(strutil.Contains(iosText, "\"surface_binding\": \"CAMetalLayer_rgba_blit_v1\""),
           "r2c native platform shell runtime smoke: ios surface")
    assert(strutil.Contains(ohosText, "\"surface_binding\": \"OHNativeWindow_rgba_blit_v1\""),
           "r2c native platform shell runtime smoke: ohos surface")
    assert(strutil.Contains(summaryText, "ready=true"),
           "r2c native platform shell runtime smoke: summary ready")
    assert(strutil.Contains(summaryText, "event_loop=event_driven_v1"),
           "r2c native platform shell runtime smoke: summary event loop")
    echo("r2c_native_platform_shell_runtime_smoke ok")
    return 0
