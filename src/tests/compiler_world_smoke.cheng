import std/os
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/backend/system_link_exec as sexec
import std/strutils as strutil

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, strutil.Join(["artifacts/compiler_world/", smokeLabel], ""))
    assert(chengpath.MkdirP(workspaceRoot, outDir), " compiler world: mkdir")
    let sourcePath = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath = chengpath.PathJoin(outDir, "program_selfhost_smoke")
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    let planRes = sexec.BuildSystemLinkExecPlan(workspaceRoot, req)
    assert(IsOk(planRes), " compiler world: build plan")
    let plan = Value(planRes)
    assert(plan.compilerCsg.nodeCount > 0, " compiler world: csg node count")
    assert(plan.exportSurface.exportedSymbolCount > 0, " compiler world: export surface count")
    assert(plan.lockCheckEnabled == false, " compiler world: lock disabled by default")
    assert(plan.baselineSurfaceChecked == false, " compiler world: baseline disabled by default")
    assert(plan.compileReceipt.bootstrapStage == "stage3_local", " compiler world: bootstrap stage")
    assert(len(plan.nativeLinkPlan.missingReasons) > 0, " compiler world: native link still gated")
    echo(" compiler_world_smoke ok")
    return 0
