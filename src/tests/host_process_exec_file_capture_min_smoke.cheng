import std/os
import std/strutils as strutil
import std/os_host_process as hostos

fn main(): int32 =
    let res: os.ExecCmdResult = hostos.ExecFileCapture("/bin/echo", ["min-ok"], [], "", true, 5)
    assert(os.ExecCmdResultExitCode(res) == 0, " hostos execFileCapture min rc")
    assert(strutil.Strip(os.ExecCmdResultOutput(res)) == "min-ok", " hostos execFileCapture min output")
    echo(" host_process_exec_file_capture_min_smoke ok")
    return 0
