import std/bytes_layout as layout
import std/rawbytes as rawbytes
import std/seqs as seqs
import std/strings
import std/strutils as strutil
import std/times
import cheng/chain/lsmr_types as lt

fn jsonString(raw: str): str =
    return strutil.Join(["\"", raw, "\""], "")

fn progressLike(): str =
    var parts: str[]
    seqs.Add(parts, "{")
    seqs.Add(parts, strutil.Join(["\"time_ms\":", int64ToStr(times.EpochTimeSeconds() * 1000)], ""))
    seqs.Add(parts, strutil.Join([",\"event\":", jsonString("started")], ""))
    seqs.Add(parts, strutil.Join([",\"epoch\":", IntToStr(-1)], ""))
    seqs.Add(parts, strutil.Join([",\"worker_index\":", IntToStr(-1)], ""))
    seqs.Add(parts, strutil.Join([",\"peer_id\":", jsonString("")], ""))
    seqs.Add(parts, strutil.Join([",\"phase\":", jsonString("setup")], ""))
    seqs.Add(parts, strutil.Join([",\"completed\":", IntToStr(0)], ""))
    seqs.Add(parts, strutil.Join([",\"total\":", IntToStr(2)], ""))
    seqs.Add(parts, strutil.Join([",\"phase_elapsed_ms\":", int64ToStr(0)], ""))
    seqs.Add(parts, "}")
    return strutil.Join(parts, "")

fn main(): int32 =
    let progress: str = progressLike()
    echo(strutil.Join(["progress_len=", IntToStr(len(progress))], ""))
    let inputCsv: str = "/Users/lbcheng/dapanyouxuan/dapanyouxuan_gapup/fixtures/gapup_train_smoke.csv"
    let outputModel: str = "/tmp/m.kv"
    let label: str = strutil.Join(["gapup-libp2p|", inputCsv, "|", outputModel, "|", int64ToStr(times.EpochTimeSeconds())], "")
    echo(strutil.Join(["label_len=", IntToStr(len(label))], ""))
    var buf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, rawbytes.bytesFromString("dapanyouxuan.gapup.diloco.job"))
    layout.ByteBufAppendBytes(buf, rawbytes.bytesFromString(label))
    let cid = lt.FixedCidFromBuf(buf)
    echo(layout.FixedBytes32Hex(cid))
    return 0
