import std/system
import std/cmdline as cmdline
import cheng/overlay/contracts as overlay
import cheng/libp2p/host/host
import cheng/apps/chain_node/chain_node as node
import cheng/apps/chain_node/chain_node_libp2p as net

fn main(): int32 =
    let keep = cmdline.ReadFlagOrDefault("--value", "")
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "latest.snapshot.preserve", "quic.twoproc")),
           "latest snapshot preserve: init")
    var serverHost = host.Libp2pHostInit("latest.snapshot.preserve")
    let mintRes = node.ChainNodeMint(server, 9, 1001, int64(88))
    assert(mintRes.ok, "latest snapshot preserve: mint")
    let transferRes = node.ChainNodeTransfer(server, 9, 1001, 2002, int64(33))
    assert(transferRes.ok, "latest snapshot preserve: transfer")
    let serveRes = net.ChainNodeLibp2pServeOnce(server, serverHost)
    assert(serveRes.ok, "latest snapshot preserve: serve once")
    var latest: overlay.IngressEnvelope
    let latestRes = net.ChainNodeLibp2pLatestSnapshotHostIndex(serverHost, server.address)
    assert(IsOk(latestRes), "latest snapshot preserve: latest index")
    assert(keep == "/tmp/latest-snapshot-preserve-live-str", "latest snapshot preserve: live str after latest")
    let latestIndex = latestRes.value
    assert(latestIndex >= 0, "latest snapshot preserve: latest index value")
    assert(keep == "/tmp/latest-snapshot-preserve-live-str", "latest snapshot preserve: live str after latestIndex")
    let latestEntry = serverHost.storeEntries[latestIndex]
    assert(keep == "/tmp/latest-snapshot-preserve-live-str", "latest snapshot preserve: live str after latestEntry")
    net.ChainNodeLibp2pCopyIngress(latest, latestEntry.ingress)
    assert(keep == "/tmp/latest-snapshot-preserve-live-str", "latest snapshot preserve: live str after copy")
    echo(" latest_snapshot_preserves_live_str_smoke ok")
    return 0
