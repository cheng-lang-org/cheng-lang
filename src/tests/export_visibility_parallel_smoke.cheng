import std/os
import std/cmdline
import std/os_host_process as hostos
import std/strings
import std/strutils as strutil

fn main(): int32 =
    let root = os.GetCurrentDir()
    let selfPath = cmdline.ProgramName()
    let selfDir = os.ParentDir(selfPath)
    let selfDirParts = os.SplitFile(selfDir)
    let selfLabel = selfDirParts.name
    let stage3Label = strutil.Join(["verify_export_stage3_parallel_", selfLabel], "")
    let backendLabel = strutil.Join(["verify_export_backend_driver_parallel_", selfLabel], "")
    let stage3 = os.JoinPath(root, "artifacts/bootstrap/cheng.stage3")
    let backendDriver = os.JoinPath(root, "artifacts/backend_driver/cheng")
    assert(os.FileExists(stage3), "export visibility parallel: stage3 exists")
    assert(os.FileExists(backendDriver), "export visibility parallel: backend driver exists")

    var envOverrides: str[]
    add(envOverrides, "CHENG_NO_BACKEND_DRIVER_HANDOFF=1")
    var stage3VerifyArgv: str[]
    add(stage3VerifyArgv, "run-host-smokes")
    add(stage3VerifyArgv, strutil.Join(["--compiler:", stage3], ""))
    add(stage3VerifyArgv, strutil.Join(["--label:", stage3Label], ""))
    add(stage3VerifyArgv, "export_visibility_smoke")
    add(stage3VerifyArgv, "export_visibility_negative_smoke")
    var backendVerifyArgv: str[]
    add(backendVerifyArgv, "run-host-smokes")
    add(backendVerifyArgv, strutil.Join(["--compiler:", backendDriver], ""))
    add(backendVerifyArgv, strutil.Join(["--label:", backendLabel], ""))
    add(backendVerifyArgv, "export_visibility_smoke")
    add(backendVerifyArgv, "export_visibility_negative_smoke")

    let stage3OuterRel = strutil.Join(["artifacts/hostrun/", stage3Label, ".outer.log"], "")
    let backendOuterRel = strutil.Join(["artifacts/hostrun/", backendLabel, ".outer.log"], "")
    let stage3OuterLog = os.JoinPath(root, stage3OuterRel)
    let backendOuterLog = os.JoinPath(root, backendOuterRel)
    if os.FileExists(stage3OuterLog):
        os.RemoveFile(stage3OuterLog)
    if os.FileExists(backendOuterLog):
        os.RemoveFile(backendOuterLog)

    var stage3Command = "env "
    let stage3EnvText = envOverrides[0]
    stage3Command = strutil.Join([stage3Command, os.QuoteShell(stage3EnvText)], "")
    stage3Command = strutil.Join([stage3Command, " "], "")
    stage3Command = strutil.Join([stage3Command, os.QuoteShell(stage3)], "")
    for i in 0..<stage3VerifyArgv.len:
        let argText = stage3VerifyArgv[i]
        stage3Command = strutil.Join([stage3Command, " "], "")
        stage3Command = strutil.Join([stage3Command, os.QuoteShell(argText)], "")
    stage3Command = strutil.Join([stage3Command, " > "], "")
    stage3Command = strutil.Join([stage3Command, os.QuoteShell(stage3OuterLog)], "")
    stage3Command = strutil.Join([stage3Command, " 2>&1"], "")
    var backendCommand = "env "
    let backendEnvText = envOverrides[0]
    backendCommand = strutil.Join([backendCommand, os.QuoteShell(backendEnvText)], "")
    backendCommand = strutil.Join([backendCommand, " "], "")
    backendCommand = strutil.Join([backendCommand, os.QuoteShell(backendDriver)], "")
    for i in 0..<backendVerifyArgv.len:
        let argText = backendVerifyArgv[i]
        backendCommand = strutil.Join([backendCommand, " "], "")
        backendCommand = strutil.Join([backendCommand, os.QuoteShell(argText)], "")
    backendCommand = strutil.Join([backendCommand, " > "], "")
    backendCommand = strutil.Join([backendCommand, os.QuoteShell(backendOuterLog)], "")
    backendCommand = strutil.Join([backendCommand, " 2>&1"], "")

    let stage3Spawn = hostos.PipeSpawnShell(stage3Command, root)
    assert(stage3Spawn.ok, "export visibility parallel: stage3 spawn")
    let backendSpawn = hostos.PipeSpawnShell(backendCommand, root)
    assert(backendSpawn.ok, "export visibility parallel: backend driver spawn")
    hostos.PtyClose(stage3Spawn.readFd)
    hostos.PtyClose(stage3Spawn.writeFd)
    hostos.PtyClose(backendSpawn.readFd)
    hostos.PtyClose(backendSpawn.writeFd)

    var stage3Waited = false
    var stage3Spins: int32
    while stage3Spins < 6000:
        let waitRes = hostos.PtyWait(stage3Spawn.pid)
        if waitRes.waitStatus < 0:
            assert(false, "export visibility parallel: stage3 wait failed")
        if waitRes.waitStatus == 1:
            stage3Waited = true
            break
        stage3Spins = stage3Spins + 1
        os.SleepMs(10)
    assert(stage3Waited, "export visibility parallel: stage3 wait timeout")
    var backendWaited = false
    var backendSpins: int32
    while backendSpins < 6000:
        let waitRes = hostos.PtyWait(backendSpawn.pid)
        if waitRes.waitStatus < 0:
            assert(false, "export visibility parallel: backend driver wait failed")
        if waitRes.waitStatus == 1:
            backendWaited = true
            break
        backendSpins = backendSpins + 1
        os.SleepMs(10)
    assert(backendWaited, "export visibility parallel: backend driver wait timeout")

    let stage3Output = os.ReadFile(stage3OuterLog)
    let backendOutput = os.ReadFile(backendOuterLog)
    assert(strings.StrContains(stage3Output, "cheng host smokes: ok"),
           "export visibility parallel: stage3 output")
    assert(strings.StrContains(backendOutput, "cheng host smokes: ok"),
           "export visibility parallel: backend driver output")

    let stage3LogRel = strutil.Join(["artifacts/hostrun/", stage3Label, "/export_visibility_negative_smoke.run.log"], "")
    let backendLogRel = strutil.Join(["artifacts/hostrun/", backendLabel, "/export_visibility_negative_smoke.run.log"], "")
    let stage3Log = os.JoinPath(root, stage3LogRel)
    let backendLog = os.JoinPath(root, backendLogRel)
    assert(stage3Log != backendLog, "export visibility parallel: distinct logs")
    assert(os.FileExists(stage3Log), "export visibility parallel: stage3 log")
    assert(os.FileExists(backendLog), "export visibility parallel: backend driver log")

    echo(" export_visibility_parallel_smoke ok")
    return 0
