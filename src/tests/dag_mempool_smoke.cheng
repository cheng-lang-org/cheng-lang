import std/system
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/chain/dag_mempool as dag

fn main(): int32 =
    let payload = bytesFromString(" dag payload body")
    let summaryRes = dag.DagBlobSummaryFromBytes(payload, 8)
    assert(IsOk(summaryRes), " dag mempool smoke: summary")
    let summary = Value(summaryRes)
    let summaryOk = dag.DagBlobSummaryValidate(summary)
    assert(IsOk(summaryOk), " dag mempool smoke: summary validate")
    assert(summary.chunkCount == 3, " dag mempool smoke: chunk count")

    let providerA = lt.HashInts("cheng.dag.provider", [1, 10])
    let providerB = lt.HashInts("cheng.dag.provider", [2, 20])
    let proofARes = dag.DagAvailabilityProofMake(summary, providerA, 120)
    let proofBRes = dag.DagAvailabilityProofMake(summary, providerB, 90)
    assert(IsOk(proofARes), " dag mempool smoke: proofA")
    assert(IsOk(proofBRes), " dag mempool smoke: proofB")
    let proofA = Value(proofARes)
    let proofB = Value(proofBRes)
    let proofOk = dag.DagAvailabilityProofValidate(proofA, summary)
    assert(IsOk(proofOk), " dag mempool smoke: proof validate")

    var proofs: dag.DagAvailabilityProof[]
    proofs = []
    add(proofs, proofB)
    add(proofs, proofA)
    let certRes = dag.DagAvailabilityCertMake(summary, proofs)
    assert(IsOk(certRes), " dag mempool smoke: cert")
    let cert = Value(certRes)
    let certOk = dag.DagAvailabilityCertValidate(cert, summary, proofs)
    assert(IsOk(certOk), " dag mempool smoke: cert validate")
    assert(cert.proofCount == 2, " dag mempool smoke: cert proof count")
    assert(cert.minRetainedUntilEpoch == 90, " dag mempool smoke: cert retained epoch")
    assert(layout.fixedBytes32Equal(cert.providerPeerIds[0], providerA),
        " dag mempool smoke: provider sorted")

    let topicCid = lt.HashInts("cheng.dag.topic", [7, 8, 9])
    let publisherPeerId = lt.HashInts("cheng.dag.publisher", [3, 30])
    let advertRes = dag.DagPublishAdvertMake(topicCid,
                                               publisherPeerId,
                                               summary,
                                               cert,
                                               11,
                                               22)
    assert(IsOk(advertRes), " dag mempool smoke: advert")
    let advert = Value(advertRes)
    let advertOk = dag.DagPublishAdvertValidate(advert, summary, cert)
    assert(IsOk(advertOk), " dag mempool smoke: advert validate")

    var badAdvert = advert
    badAdvert.blobSummaryCid = layout.FixedBytes32()
    let badAdvertOk = dag.DagPublishAdvertValidate(badAdvert, summary, cert)
    assert(IsErr(badAdvertOk), " dag mempool smoke: advert reject mismatch")

    echo(" dag_mempool_smoke ok")
    return 0
