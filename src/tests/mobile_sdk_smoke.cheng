import std/system
import std/strings
import cheng/mobile/mobile_capi as capi
import cheng/mobile/mobile_sdk as sdk

fn main(): int32 =
    var mobile = sdk.MobileSdkInit("mobile.sdk.self")
    let selfPeer = capi.MobileCapiPeerIdFromSeed("mobile.sdk.self")
    assert(strings.HasPrefix(selfPeer, "12D3Koo"), " mobile sdk: standard self peer")
    assert(sdk.MobileSdkSelfPeerText(mobile) == selfPeer,
        " mobile sdk: self peer")
    assert(!sdk.MobileSdkStarted(mobile),
        " mobile sdk: init stopped")

    sdk.MobileSdkStart(mobile)
    sdk.MobileSdkSetMdns(mobile, true, 11)
    sdk.MobileSdkSetTrustedInfra(mobile, true)
    assert(sdk.MobileSdkStarted(mobile),
        " mobile sdk: started")
    assert(sdk.MobileSdkMdnsEnabled(mobile),
        " mobile sdk: mdns enabled")
    assert(sdk.MobileSdkMdnsInterval(mobile) == 11,
        " mobile sdk: mdns interval")
    assert(sdk.MobileSdkTrustedInfra(mobile),
        " mobile sdk: trusted infra")

    let listenRes = sdk.MobileSdkListen(mobile, "/ip4/127.0.0.1/tcp/9301")
    assert(IsOk(listenRes), " mobile sdk: listen")
    assert(sdk.MobileSdkListenCount(mobile) == 1,
        " mobile sdk: listen count")
    let listenDialable = sdk.MobileSdkListenDialableAddrTextAt(mobile, 0)
    assert(strContains(listenDialable, "/ip4/127.0.0.1/tcp/9301"),
        " mobile sdk: listen dialable base")
    assert(strContains(listenDialable, "/p2p/"),
        " mobile sdk: listen dialable peer suffix")

    let bootstrapPeer = capi.MobileCapiPeerIdFromSeed("mobile.sdk.bootstrap")
    assert(strings.HasPrefix(bootstrapPeer, "12D3Koo"), " mobile sdk: standard bootstrap peer")
    let bootstrapRes = sdk.MobileSdkAddBootstrapPeer(mobile,
                                                       bootstrapPeer,
                                                       "/ip4/100.64.0.31/tcp/9302")
    assert(IsOk(bootstrapRes), " mobile sdk: add bootstrap")
    assert(sdk.MobileSdkPeerCount(mobile) == 1,
        " mobile sdk: peer count")
    assert(sdk.MobileSdkBootstrapPeerCount(mobile) == 1,
        " mobile sdk: bootstrap count")

    let connectRes = sdk.MobileSdkConnectRegistered(mobile, bootstrapPeer)
    assert(IsOk(connectRes), " mobile sdk: connect registered")
    assert(sdk.MobileSdkConnectedPeerCount(mobile) == 1,
        " mobile sdk: connected count")
    assert(sdk.MobileSdkPeerConnected(mobile, bootstrapPeer),
        " mobile sdk: connected peer")

    let bootstrapDialable = sdk.MobileSdkPeerDialableAddrTextAt(mobile, bootstrapPeer, 0)
    assert(strContains(bootstrapDialable, "/ip4/100.64.0.31/tcp/9302"),
        " mobile sdk: peer dialable base")
    assert(strContains(bootstrapDialable, "/p2p/"),
        " mobile sdk: peer dialable suffix")

    assert(sdk.MobileSdkDisconnectPeer(mobile, bootstrapPeer),
        " mobile sdk: disconnect")
    assert(!sdk.MobileSdkPeerConnected(mobile, bootstrapPeer),
        " mobile sdk: disconnected")
    assert(sdk.MobileSdkReconnectBootstrap(mobile) == 1,
        " mobile sdk: reconnect bootstrap")
    assert(sdk.MobileSdkPeerConnected(mobile, bootstrapPeer),
        " mobile sdk: reconnect restored")

    let adhocPeer = capi.MobileCapiPeerIdFromSeed("mobile.sdk.adhoc")
    let adhocRes = sdk.MobileSdkConnectPreferred(mobile,
                                                   adhocPeer,
                                                   "/ip4/127.0.0.1/tcp/9303")
    assert(IsOk(adhocRes), " mobile sdk: adhoc connect")
    assert(sdk.MobileSdkPeerCount(mobile) == 2,
        " mobile sdk: adhoc peer count")

    sdk.MobileSdkStop(mobile)
    assert(!sdk.MobileSdkStarted(mobile),
        " mobile sdk: stopped")

    echo(" mobile_sdk_smoke ok")
    return 0
