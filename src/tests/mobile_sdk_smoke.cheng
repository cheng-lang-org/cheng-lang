import std/system
import std/strings
import cheng/libp2p/mobile/mobile_capi as capi
import cheng/libp2p/mobile/mobile_sdk as sdk

fn main(): int32 =
    var mobile = sdk.v3MobileSdkInit("mobile.sdk.self")
    let selfPeer = capi.v3MobileCapiPeerIdFromSeed("mobile.sdk.self")
    assert(strings.HasPrefix(selfPeer, "12D3Koo"), "v3 mobile sdk: standard self peer")
    assert(sdk.v3MobileSdkSelfPeerText(mobile) == selfPeer,
        "v3 mobile sdk: self peer")
    assert(!sdk.v3MobileSdkStarted(mobile),
        "v3 mobile sdk: init stopped")

    sdk.v3MobileSdkStart(mobile)
    sdk.v3MobileSdkSetMdns(mobile, true, 11)
    sdk.v3MobileSdkSetTrustedInfra(mobile, true)
    assert(sdk.v3MobileSdkStarted(mobile),
        "v3 mobile sdk: started")
    assert(sdk.v3MobileSdkMdnsEnabled(mobile),
        "v3 mobile sdk: mdns enabled")
    assert(sdk.v3MobileSdkMdnsInterval(mobile) == 11,
        "v3 mobile sdk: mdns interval")
    assert(sdk.v3MobileSdkTrustedInfra(mobile),
        "v3 mobile sdk: trusted infra")

    let listenRes = sdk.v3MobileSdkListen(mobile, "/ip4/127.0.0.1/tcp/9301")
    assert(IsOk(listenRes), "v3 mobile sdk: listen")
    assert(sdk.v3MobileSdkListenCount(mobile) == 1,
        "v3 mobile sdk: listen count")
    let listenDialable = sdk.v3MobileSdkListenDialableAddrTextAt(mobile, 0)
    assert(strContains(listenDialable, "/ip4/127.0.0.1/tcp/9301"),
        "v3 mobile sdk: listen dialable base")
    assert(strContains(listenDialable, "/p2p/"),
        "v3 mobile sdk: listen dialable peer suffix")

    let bootstrapPeer = capi.v3MobileCapiPeerIdFromSeed("mobile.sdk.bootstrap")
    assert(strings.HasPrefix(bootstrapPeer, "12D3Koo"), "v3 mobile sdk: standard bootstrap peer")
    let bootstrapRes = sdk.v3MobileSdkAddBootstrapPeer(mobile,
                                                       bootstrapPeer,
                                                       "/ip4/100.64.0.31/tcp/9302")
    assert(IsOk(bootstrapRes), "v3 mobile sdk: add bootstrap")
    assert(sdk.v3MobileSdkPeerCount(mobile) == 1,
        "v3 mobile sdk: peer count")
    assert(sdk.v3MobileSdkBootstrapPeerCount(mobile) == 1,
        "v3 mobile sdk: bootstrap count")

    let connectRes = sdk.v3MobileSdkConnectRegistered(mobile, bootstrapPeer)
    assert(IsOk(connectRes), "v3 mobile sdk: connect registered")
    assert(sdk.v3MobileSdkConnectedPeerCount(mobile) == 1,
        "v3 mobile sdk: connected count")
    assert(sdk.v3MobileSdkPeerConnected(mobile, bootstrapPeer),
        "v3 mobile sdk: connected peer")

    let bootstrapDialable = sdk.v3MobileSdkPeerDialableAddrTextAt(mobile, bootstrapPeer, 0)
    assert(strContains(bootstrapDialable, "/ip4/100.64.0.31/tcp/9302"),
        "v3 mobile sdk: peer dialable base")
    assert(strContains(bootstrapDialable, "/p2p/"),
        "v3 mobile sdk: peer dialable suffix")

    assert(sdk.v3MobileSdkDisconnectPeer(mobile, bootstrapPeer),
        "v3 mobile sdk: disconnect")
    assert(!sdk.v3MobileSdkPeerConnected(mobile, bootstrapPeer),
        "v3 mobile sdk: disconnected")
    assert(sdk.v3MobileSdkReconnectBootstrap(mobile) == 1,
        "v3 mobile sdk: reconnect bootstrap")
    assert(sdk.v3MobileSdkPeerConnected(mobile, bootstrapPeer),
        "v3 mobile sdk: reconnect restored")

    let adhocPeer = capi.v3MobileCapiPeerIdFromSeed("mobile.sdk.adhoc")
    let adhocRes = sdk.v3MobileSdkConnectPreferred(mobile,
                                                   adhocPeer,
                                                   "/ip4/127.0.0.1/tcp/9303")
    assert(IsOk(adhocRes), "v3 mobile sdk: adhoc connect")
    assert(sdk.v3MobileSdkPeerCount(mobile) == 2,
        "v3 mobile sdk: adhoc peer count")

    sdk.v3MobileSdkStop(mobile)
    assert(!sdk.v3MobileSdkStarted(mobile),
        "v3 mobile sdk: stopped")

    echo("v3 mobile_sdk_smoke ok")
    return 0
