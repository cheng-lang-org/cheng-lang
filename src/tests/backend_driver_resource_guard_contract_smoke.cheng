import std/os as os
import std/strings as strings

fn main(): int32 =
    let compilerMainPath: str = "src/core/tooling/compiler_main.cheng"
    let osPath: str = "src/std/os.cheng"
    let hostOpsPath: str = "src/core/tooling/host_ops.cheng"
    let systemLinkExecPath: str = "src/core/backend/system_link_exec.cheng"
    let backendDriverDispatchMinPath: str = "src/core/tooling/backend_driver_dispatch_min.cheng"
    let parserPath: str = "src/core/lang/parser.cheng"
    let typedExprPath: str = "src/core/lang/typed_expr.cheng"
    let loweringPlanPath: str = "src/core/backend/lowering_plan.cheng"
    let primaryObjectPlanPath: str = "src/core/backend/primary_object_plan.cheng"
    let seedPath: str = "bootstrap/cheng_seed.c"
    let gateMainPath: str = "src/core/tooling/gate_main.cheng"
    let hostSmokeGatePath: str = "src/core/tooling/host_smoke_gate.cheng"
    let runtimeZeroSmokePath: str = "src/tests/runtime_zero_c_surface_smoke.cheng"
    assert(os.FileExists(compilerMainPath) && os.FileSize(compilerMainPath) > int64(0),
           " backend driver resource guard: compiler main exists")
    assert(os.FileExists(osPath) && os.FileSize(osPath) > int64(0),
           " backend driver resource guard: os exists")
    assert(os.FileExists(hostOpsPath) && os.FileSize(hostOpsPath) > int64(0),
           " backend driver resource guard: host ops exists")
    assert(os.FileExists(systemLinkExecPath) && os.FileSize(systemLinkExecPath) > int64(0),
           " backend driver resource guard: system link exec exists")
    assert(os.FileExists(backendDriverDispatchMinPath) && os.FileSize(backendDriverDispatchMinPath) > int64(0),
           " backend driver resource guard: backend driver dispatch min exists")
    assert(os.FileExists(parserPath) && os.FileSize(parserPath) > int64(0),
           " backend driver resource guard: parser exists")
    assert(os.FileExists(typedExprPath) && os.FileSize(typedExprPath) > int64(0),
           " backend driver resource guard: typed expr exists")
    assert(os.FileExists(loweringPlanPath) && os.FileSize(loweringPlanPath) > int64(0),
           " backend driver resource guard: lowering plan exists")
    assert(os.FileExists(primaryObjectPlanPath) && os.FileSize(primaryObjectPlanPath) > int64(0),
           " backend driver resource guard: primary object plan exists")
    assert(os.FileExists(seedPath) && os.FileSize(seedPath) > int64(0),
           " backend driver resource guard: seed exists")
    assert(os.FileExists(gateMainPath) && os.FileSize(gateMainPath) > int64(0),
           " backend driver resource guard: gate main exists")
    assert(os.FileExists(hostSmokeGatePath) && os.FileSize(hostSmokeGatePath) > int64(0),
           " backend driver resource guard: host smoke gate exists")
    assert(os.FileExists(runtimeZeroSmokePath) && os.FileSize(runtimeZeroSmokePath) > int64(0),
           " backend driver resource guard: runtime zero smoke exists")

    let compilerText: str = os.ReadFile(compilerMainPath)
    let osText: str = os.ReadFile(osPath)
    let hostOpsText: str = os.ReadFile(hostOpsPath)
    let systemLinkExecText: str = os.ReadFile(systemLinkExecPath)
    let backendDriverDispatchMinText: str = os.ReadFile(backendDriverDispatchMinPath)
    let parserText: str = os.ReadFile(parserPath)
    let typedExprText: str = os.ReadFile(typedExprPath)
    let loweringPlanText: str = os.ReadFile(loweringPlanPath)
    let primaryObjectPlanText: str = os.ReadFile(primaryObjectPlanPath)
    let seedText: str = os.ReadFile(seedPath)
    let gateMainText: str = os.ReadFile(gateMainPath)
    let hostSmokeGateText: str = os.ReadFile(hostSmokeGatePath)
    let runtimeZeroSmokeText: str = os.ReadFile(runtimeZeroSmokePath)

    assert(strings.StrContains(compilerText, "CompilerBuildBackendDriverMaxRssBytesText"),
           " backend driver resource guard: max rss helper")
    assert(strings.StrContains(compilerText, "CompilerFollowWorldMaxRssBytesText"),
           " backend driver resource guard: follow-world max rss helper")
    assert(strings.StrContains(compilerText, "return CompilerBackendDriverDefaultMaxRssBytesText()"),
           " backend driver resource guard: build cap is fixed")
    assert(!strings.StrContains(compilerText, "let processRaw: str = strutil.Strip(os.GetEnv(\"CHENG_PROCESS_MAX_RSS_BYTES\"))"),
           " backend driver resource guard: no inherited process rss cap")
    assert(strings.StrContains(compilerText, "8589934592"),
           " backend driver resource guard: default 8g cap")
    assert(strings.StrContains(compilerText, "os.SetEnv(\"CHENG_PROGRESS\", \"1\")"),
           " backend driver resource guard: progress enabled")
    assert(strings.StrContains(compilerText, "strutil.Join([\"CHENG_PROCESS_MAX_RSS_BYTES=\", buildMaxRssBytesText], \"\")"),
           " backend driver resource guard: child rss cap")
    assert(strings.StrContains(compilerText, "strutil.Join([\"CHENG_PROCESS_MAX_RSS_BYTES=\", followMaxRssBytesText], \"\")"),
           " backend driver resource guard: follow-world child rss cap")
    assert(strings.StrContains(compilerText, "followGuardEnv"),
           " backend driver resource guard: follow-world guarded env")
    assert(strings.StrContains(compilerText, "\"BACKEND_INCREMENTAL=0\""),
           " backend driver resource guard: incremental disabled")
    assert(strings.StrContains(compilerText, "\"BACKEND_MULTI_MODULE_CACHE=0\""),
           " backend driver resource guard: module cache disabled")
    assert(strings.StrContains(compilerText, "\"CHENG_DISABLE_PRIMARY_OBJECT_CACHE=1\""),
           " backend driver resource guard: primary object cache disabled")
    assert(strings.StrContains(compilerText, "\"BACKEND_BUILD_DRIVER_QUICK_STAMP_CACHE=0\""),
           " backend driver resource guard: stamp cache disabled")
    assert(strings.StrContains(compilerText, "\"BACKEND_BUILD_DRIVER_QUICK_SHARED_CACHE=0\""),
           " backend driver resource guard: shared cache disabled")
    assert(strings.StrContains(compilerText, "CompilerProgressResourceGuardCheck"),
           " backend driver resource guard: compiler progress self guard")
    assert(strings.StrContains(compilerText, "CompilerRunFileEnvLogged(rootDir"),
           " backend driver resource guard: guarded process runner")

    assert(strings.StrContains(osText, "ProcessResourceGuardCheck"),
           " backend driver resource guard: os phase guard export")
    assert(strings.StrContains(osText, "processResourceGuardDefaultMaxRssBytes"),
           " backend driver resource guard: os default max rss helper")
    assert(strings.StrContains(osText, "return int64(8589934592)"),
           " backend driver resource guard: os default 8g cap")
    assert(strings.StrContains(osText, "CHENG_PROCESS_MAX_RSS_BYTES"),
           " backend driver resource guard: os rss env")
    assert(strings.StrContains(osText, "CHENG_PARENT_RSS_GUARD"),
           " backend driver resource guard: os parent rss guard")
    assert(strings.StrContains(osText, "for i in 0..<len(raw):"),
           " backend driver resource guard: os parser uses stable len")
    assert(strings.StrContains(osText, "@importc(\"getrusage\")"),
           " backend driver resource guard: os direct rusage bridge")
    assert(!strings.StrContains(osText, "/bin/ps -p "),
           " backend driver resource guard: os no ps rss fallback")
    assert(strings.StrContains(osText, "if maxRssBytes == int64(0):\n        return"),
           " backend driver resource guard: os parent guard disables self cap")
    assert(!strings.StrContains(osText, "fn processResourceGuardCheck() =\n    return"),
           " backend driver resource guard: os phase guard is active")
    assert(strings.StrContains(osText, "status=rss_limit_exceeded"),
           " backend driver resource guard: os rss diagnostic")
    assert(strings.StrContains(osText, "status=rss_unavailable"),
           " backend driver resource guard: os unavailable rss hard fail")

    assert(strings.StrContains(hostOpsText, "HostOpsProcessGroupRssBytes"),
           " backend driver resource guard: process group rss")
    assert(strings.StrContains(hostOpsText, "HostOpsCurrentRssBytes"),
           " backend driver resource guard: current rss")
    assert(strings.StrContains(hostOpsText, "HostOpsExitProcess"),
           " backend driver resource guard: hard exit")
    assert(strings.StrContains(hostOpsText, "var i: int32 = envOverrides.len - 1"),
           " backend driver resource guard: env override last wins")
    assert(strings.StrContains(hostOpsText, "resource_guard status=rss_limit_exceeded"),
           " backend driver resource guard: live diagnostic")
    assert(strings.StrContains(hostOpsText, "ProcessMemoryExceeded = 125"),
           " backend driver resource guard: memory exit code")

    assert(strings.StrContains(gateMainText, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592"),
           " backend driver resource guard: gate host smoke 8g cap")
    assert(!strings.StrContains(gateMainText, "CHENG_PROCESS_MAX_RSS_BYTES=34359738368"),
           " backend driver resource guard: gate host smoke no 32g cap")
    assert(strings.StrContains(hostSmokeGateText, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592"),
           " backend driver resource guard: host smoke 8g cap")
    assert(!strings.StrContains(hostSmokeGateText, "CHENG_PROCESS_MAX_RSS_BYTES=34359738368"),
           " backend driver resource guard: host smoke no 32g cap")
    assert(strings.StrContains(runtimeZeroSmokeText, "CHENG_PROCESS_MAX_RSS_BYTES=8589934592"),
           " backend driver resource guard: runtime zero 8g cap")
    assert(!strings.StrContains(runtimeZeroSmokeText, "CHENG_PROCESS_MAX_RSS_BYTES=34359738368"),
           " backend driver resource guard: runtime zero no 32g cap")

    assert(strings.StrContains(systemLinkExecText, "SystemLinkExecProgressResourceGuardCheck"),
           " backend driver resource guard: system-link self guard")
    assert(strings.StrContains(systemLinkExecText, "SystemLinkExecDefaultMaxRssBytesText"),
           " backend driver resource guard: system-link default max rss helper")
    assert(strings.StrContains(systemLinkExecText, "return \"8589934592\""),
           " backend driver resource guard: system-link default 8g cap")
    assert(strings.StrContains(systemLinkExecText, "SystemLinkExecEnsureDefaultResourceGuard"),
           " backend driver resource guard: system-link default guard installer")
    assert(strings.StrContains(systemLinkExecText, "os.SetEnv(\"CHENG_PROCESS_MAX_RSS_BYTES\", SystemLinkExecDefaultMaxRssBytesText())"),
           " backend driver resource guard: system-link default child rss env")
    assert(strings.StrContains(systemLinkExecText, "hostops.HostOpsCurrentRssBytes"),
           " backend driver resource guard: system-link rss check")
    assert(strings.StrContains(systemLinkExecText, "hostops.HostOpsExitProcess(hostops.ProcessMemoryExceeded)"),
           " backend driver resource guard: system-link hard stop")

    assert(strings.StrContains(backendDriverDispatchMinText, "BackendDriverDispatchMinProgressResourceGuardCheck"),
           " backend driver resource guard: min driver self guard")
    assert(strings.StrContains(backendDriverDispatchMinText, "CHENG_PROCESS_MAX_RSS_BYTES"),
           " backend driver resource guard: min driver rss env")
    assert(!strings.StrContains(backendDriverDispatchMinText, "len(os.GetEnv(\"CHENG_PARENT_RSS_GUARD\"))"),
           " backend driver resource guard: min driver env guard uses stable shape")
    assert(strings.StrContains(backendDriverDispatchMinText, "BackendDriverDispatchMinDefaultMaxRssBytes"),
           " backend driver resource guard: min driver default max rss helper")
    assert(strings.StrContains(backendDriverDispatchMinText, "return int64(8589934592)"),
           " backend driver resource guard: min driver default 8g cap")
    assert(strings.StrContains(backendDriverDispatchMinText, "@importc(\"getrusage\")"),
           " backend driver resource guard: min driver direct rusage bridge")
    assert(!strings.StrContains(backendDriverDispatchMinText, "/bin/ps -p "),
           " backend driver resource guard: min driver no ps rss fallback")
    assert(strings.StrContains(backendDriverDispatchMinText, "BackendDriverDispatchMinResourceGuardCheckWithMax(maxRssBytes)"),
           " backend driver resource guard: min driver initial self guard")
    assert(strings.StrContains(backendDriverDispatchMinText, "if maxRssBytes == int64(0):\n        return"),
           " backend driver resource guard: min driver parent guard disables self cap")
    assert(!strings.StrContains(backendDriverDispatchMinText, "fn BackendDriverDispatchMinProgressResourceGuardCheck() =\n    return"),
           " backend driver resource guard: min driver progress guard is active")
    assert(strings.StrContains(backendDriverDispatchMinText, "BackendDriverDispatchMinCurrentRssBytes"),
           " backend driver resource guard: min driver current rss")
    assert(strings.StrContains(backendDriverDispatchMinText, "status=rss_limit_exceeded"),
           " backend driver resource guard: min driver rss diagnostic")
    assert(strings.StrContains(backendDriverDispatchMinText, "status=rss_unavailable"),
           " backend driver resource guard: min driver unavailable rss hard fail")
    assert(strings.StrContains(backendDriverDispatchMinText, "BackendDriverDispatchMinExitBridge(BackendDriverDispatchMinProcessMemoryExceeded)"),
           " backend driver resource guard: min driver hard stop")
    assert(strings.StrContains(backendDriverDispatchMinText, "BackendDriverDispatchMinProcessMemoryExceeded = 125"),
           " backend driver resource guard: min driver memory exit code")

    assert(strings.StrContains(parserText, "os.ProcessResourceGuardCheck()"),
           " backend driver resource guard: parser phase guard")
    assert(strings.StrContains(parserText, "ParserBuildProfileCallLookupCache"),
           " backend driver resource guard: parser call lookup cache covered")
    assert(strings.StrContains(parserText, "ParserCollectExternalCallNamesRecursive"),
           " backend driver resource guard: parser call recursion covered")
    assert(strings.StrContains(parserText, "if pendingIndex % 64 == 0:\n            os.ProcessResourceGuardCheck()"),
           " backend driver resource guard: parser pending queue guard")
    assert(strings.StrContains(parserText, "if i % 4096 == 0:\n            os.ProcessResourceGuardCheck()"),
           " backend driver resource guard: parser large allocation guard")
    assert(strings.StrContains(parserText, "for i in 0..<cache.len:\n        if i % 128 == 0:"),
           " backend driver resource guard: parser cache scan for range")
    assert(strings.StrContains(typedExprText, "os.ProcessResourceGuardCheck()"),
           " backend driver resource guard: typed expr phase guard")
    assert(strings.StrContains(loweringPlanText, "os.ProcessResourceGuardCheck()"),
           " backend driver resource guard: lowering phase guard")
    assert(strings.StrContains(primaryObjectPlanText, "os.ProcessResourceGuardCheck()"),
           " backend driver resource guard: primary object phase guard")

    if strings.StrContains(seedText, "Cheng cold-bootstrap source identity marker"):
        assert(strings.StrContains(seedText, "retired generated C seed body"),
               " backend driver resource guard: retired seed marker")
    else:
        assert(strings.StrContains(seedText, "cheng_seed_resource_guard_check"),
               " backend driver resource guard: seed rss guard")
        assert(strings.StrContains(seedText, "CHENG_PROCESS_MAX_RSS_BYTES"),
               " backend driver resource guard: seed rss env")
        assert(strings.StrContains(seedText, "CHENG_SEED_DEFAULT_BACKEND_DRIVER_MAX_RSS_BYTES \"8589934592\""),
               " backend driver resource guard: seed default 8g cap")
        assert(!strings.StrContains(seedText, "raw = getenv(\"CHENG_PROCESS_MAX_RSS_BYTES\");\n    if (raw != NULL && raw[0] != '\\0')"),
               " backend driver resource guard: seed build cap is fixed")
        assert(strings.StrContains(seedText, "setenv(\"CHENG_PROGRESS\", \"1\", 1)"),
               " backend driver resource guard: seed build progress")
        assert(strings.StrContains(seedText, "setenv(\"CHENG_PROCESS_MAX_RSS_BYTES\", cheng_seed_build_backend_driver_max_rss_bytes_text(), 1)"),
               " backend driver resource guard: seed build child rss cap")
        assert(strings.StrContains(seedText, "cheng_seed_run_command_logged_argv_live"),
               " backend driver resource guard: seed live runner")
        assert(strings.StrContains(seedText, "cheng_seed_echo_progress_chunk"),
               " backend driver resource guard: seed live progress echo")
        assert(strings.StrContains(seedText, "exit(125)"),
               " backend driver resource guard: seed rss exit")
        assert(strings.StrContains(seedText, "cheng_seed_resolve_self_path(self_path"),
               " backend driver resource guard: seed self compiler")
        assert(!strings.StrContains(seedText,
                                    "cheng_seed_path_is_executable(self_path) &&\n        cheng_seed_output_is_fresh_against_inputs(self_path"),
               " backend driver resource guard: seed self compiler no freshness gate")

    echo(" backend_driver_resource_guard_contract_smoke ok")
    return 0
