// Smoke test for hot_patch module
import cheng/core/backend/hot_patch
import std/os

fn original_test(): int32 =
    return 42

fn patched_test(): int32 =
    return 100

fn smoke_test_main(): int32 =
    let engine = hot_patch.hot_patch_init(4096)
    if engine == nil:
        os.WriteLine(os.GetStderr(), "hot_patch_init failed")
        return 1

    let orig_code = &original_test as ptr
    let orig_len: int32 = 16  // Approximate size, actual depends on arch

    if !hot_patch.hot_patch_register(engine, "test", orig_code, orig_len):
        os.WriteLine(os.GetStderr(), "hot_patch_register failed")
        return 1

    let patch_code = &patched_test as ptr
    let patch_len: int32 = 16

    if !hot_patch.hot_patch_apply(engine, "test", patch_code, patch_len):
        os.WriteLine(os.GetStderr(), "hot_patch_apply failed")
        return 1

    let hash = hot_patch.hot_patch_layout_hash_compute(engine)
    if hash == 0:
        os.WriteLine(os.GetStderr(), "hash computation failed")
        return 1

    if !hot_patch.hot_patch_validate(engine):
        os.WriteLine(os.GetStderr(), "validation failed")
        return 1

    os.WriteLine(os.GetStdout(), "smoke test passed")
    return 0
