import std/os
import std/strings
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/host_ops as hostops
import std/strutils as strutil

fn main(): int32 =
    let root = os.GetCurrentDir()
    let stage3 = os.JoinPath(root, "artifacts/bootstrap/cheng.stage3")
    let source = os.JoinPath(root, "src/tests/ordinary_zero_exit_fixture.cheng")
    let target = os.GetEnvDefault("CHENG_BOOTSTRAP_TARGET", "arm64-apple-darwin")
    let outDir = chengpath.PathAbsolute(root, "artifacts/stage3_system_link_exec_handoff_smoke")
    let outBin = os.JoinPath(outDir, "ordinary_zero_exit_fixture")
    let compileLog = os.JoinPath(outDir, "ordinary_zero_exit_fixture.compile.log")
    let forwardLog = os.JoinPath(outDir, "backend_driver.forward.log")
    assert(chengpath.MkdirP(root, outDir), " stage3 system-link-exec handoff: mkdir")
    if chengpath.PathFileExists(outBin):
        os.RemoveFile(outBin)
    if chengpath.PathFileExists(compileLog):
        os.RemoveFile(compileLog)
    if chengpath.PathFileExists(forwardLog):
        os.RemoveFile(forwardLog)
    var compileArgs: str[]
    add(compileArgs, "system-link-exec")
    add(compileArgs, strutil.Join(["--root:", root], ""))
    add(compileArgs, strutil.Join(["--in:", source], ""))
    add(compileArgs, "--emit:exe")
    add(compileArgs, strutil.Join(["--target:", target], ""))
    add(compileArgs, strutil.Join(["--out:", outBin], ""))
    let compileRun = hostops.RunFileLogged(root,
                                             "stage3_system_link_exec_handoff_build",
                                             stage3,
                                             compileArgs,
                                             [
                                                 "CHENG_NO_BACKEND_DRIVER_HANDOFF=0",
                                                 strutil.Join(["CHENG_BACKEND_DRIVER_FORWARD_LOG=", forwardLog], "")
                                             ],
                                             root,
                                             0,
                                             compileLog)
    assert(compileRun.exitCode == 0, " stage3 system-link-exec handoff: compile rc")
    assert(os.FileExists(outBin), " stage3 system-link-exec handoff: output exists")
    if os.FileExists(forwardLog):
        let forwardText = os.ReadFile(forwardLog)
        assert(len(forwardText) == 0,
               " stage3 system-link-exec handoff: forward log empty on success")
    echo(" stage3_system_link_exec_handoff_smoke ok")
    return 0
