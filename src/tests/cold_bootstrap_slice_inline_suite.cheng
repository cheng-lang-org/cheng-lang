fn InlineClassify(ch: int32): int32 =
    var score: int32 = 0
    if ch == 40: score = score + 1
    elif ch == 41: score = score + 2
    else: score = score + 7
    return score

fn InlineSign(value: int32): int32 =
    if value < 0: return 11
    elif value == 0: return 13
    else: return 17

fn InlineWhileBreak(limit: int32): int32 =
    var i: int32 = 0
    while i < limit: i = i + 1; if i == 5: break
    return i

fn InlineForBody(limit: int32): int32 =
    var sum: int32 = 0
    var count: int32 = 0
    for i in 0..<limit: sum = sum + i; count = count + 1
    return sum + count

fn InlineContinue(limit: int32): int32 =
    var sum: int32 = 0
    for i in 0..<limit:
        if i == 2: continue
        sum = sum + i
    return sum

fn main(): int32 =
    let score = InlineClassify(40) + InlineClassify(41) + InlineClassify(33)
    if score != 10:
        return score
    if InlineSign(-1) != 11:
        return 1
    if InlineSign(0) != 13:
        return 2
    if InlineSign(9) != 17:
        return 3
    if InlineWhileBreak(10) != 5:
        return 4
    if InlineForBody(4) != 10:
        return 5
    if InlineContinue(5) != 8:
        return 6
    return 42
