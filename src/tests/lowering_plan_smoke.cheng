import std/os
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/lang/parser
import cheng/core/lang/typed_expr as texpr

fn reportFieldValue(report: str, key: str): str =
    let taggedReport = "\n" + report
    let needle = "\n" + key + "="
    let fieldPos = parser.ParserFindText(taggedReport, needle)
    if fieldPos < 0:
        return ""
    let valueStart = fieldPos + needle.len
    let tail = chengpath.TextSlice(taggedReport, valueStart, taggedReport.len - valueStart)
    let newlinePos = parser.ParserFindText(tail, "\n")
    if newlinePos < 0:
        return tail
    if newlinePos == 0:
        return ""
    return chengpath.TextSlice(tail, 0, newlinePos)

fn reportFieldPositive(report: str, key: str): bool =
    let value = reportFieldValue(report, key)
    return value != "" && value != "0"

fn assertCallReasonReportField(report: str,
                               layer: parser.NormalizedExprLayer,
                               reason: parser.NormalizedExprCallReason,
                               label: str) =
    let reportKey = ccsg.CompilerCsgCallReasonReportKey(reason)
    assert(reportKey != "", label + " report key")
    assert(reportFieldValue(report, reportKey) ==
           intToStr(parser.NormalizedExprLayerCallReasonCountExact(layer, reason)),
           label)

fn assertTypedCallFactsMatchLayer(facts: ccsg.TypedExprFact[],
                                  layer: parser.NormalizedExprLayer,
                                  label: str) =
    assert(texpr.TypedExprTypeCallDefaultInitCount(facts) ==
           parser.NormalizedExprLayerDefaultInitCount(layer),
           label + " typed default init count")
    assert(texpr.TypedExprTypeCallConstructorCount(facts) ==
           parser.NormalizedExprLayerConstructorCount(layer),
           label + " typed constructor count")
    assert(texpr.TypedExprFactCountCallResolved(facts) ==
           parser.NormalizedExprLayerCallResolvedCount(layer),
           label + " typed resolved call count")
    assert(texpr.TypedExprFactCountCallUnresolved(facts) ==
           parser.NormalizedExprLayerCallUnresolvedCount(layer),
           label + " typed unresolved call count")
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallLocal) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallLocal),
           label + " typed local call kind count")
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallExternal) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallExternal),
           label + " typed external call kind count")
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallImportc) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallImportc),
           label + " typed importc call kind count")
    assert(texpr.TypedExprFactCountSurfaceCallKindFromParser(facts, parser.NormalizedExprSurfaceCallMember) ==
           parser.NormalizedExprLayerCallKindCountExact(layer, parser.NormalizedExprSurfaceCallMember),
           label + " typed member call kind count")
    assert(texpr.TypedExprFactCountCallTargetImportc(facts) ==
           parser.NormalizedExprLayerCallTargetImportcCount(layer),
           label + " typed importc target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownQualifiedTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownQualifiedTarget),
           label + " typed unknown qualified target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonShadowedQualifiedTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonShadowedQualifiedTarget),
           label + " typed shadowed qualified target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonAmbiguousExternalTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonAmbiguousExternalTarget),
           label + " typed ambiguous external target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonAmbiguousQualifiedTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonAmbiguousQualifiedTarget),
           label + " typed ambiguous qualified target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownExternalTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownExternalTarget),
           label + " typed unknown external target count")
    assert(texpr.TypedExprFactCountCallReasonFromParser(facts, parser.NormalizedExprCallReasonUnknownCallTarget) ==
           parser.NormalizedExprLayerCallReasonCountExact(layer, parser.NormalizedExprCallReasonUnknownCallTarget),
           label + " typed unknown call target count")

fn buildPlan(workspaceRoot: str,
             packageRoot: str,
             sourcePath: str,
             outputPath: str,
             emitKind: int32): lower.LoweringPlanStub =
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), " lowering plan: build link plan")
    assert(linkPlan.missingReasons.len == 0, " lowering plan: link plan ready")
    var plan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(linkPlan, plan, err), " lowering plan: build lowering plan err=" + err)
    return plan

fn findTypedFact(facts: ccsg.TypedExprFact[],
                 sourcePath: str,
                 lineNumber: int32): ccsg.TypedExprFact =
    for i in 0..<facts.len:
        if facts[i].sourcePath != sourcePath:
            continue
        if facts[i].lineNumber != lineNumber:
            continue
        return texpr.TypedExprFactClone(facts[i])
    var missing: ccsg.TypedExprFact
    return missing

fn main(): int32 =
    let workspaceRoot: str = chengpath.PathCurrentDir()
    let packageRoot: str = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, "artifacts/program_selfhost/" + smokeLabel)
    assert(chengpath.MkdirP(workspaceRoot, outDir), " lowering plan: mkdir")
    let sourcePath: str = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let outputPath: str = chengpath.PathJoin(outDir, "program_selfhost_smoke")
    var err = ""
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        creq.EmitExe,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), " lowering plan: build link plan")
    assert(linkPlan.missingReasons.len == 0, " lowering plan: link plan ready")
    let plan = buildPlan(workspaceRoot, packageRoot, sourcePath, outputPath, creq.EmitExe)
    assert(plan.functionNames.len >= 1, " lowering plan: function count")
    assert(plan.functionNameIds[0] >= 0, " lowering plan: intern id")
    assert(plan.functionCallConvs[0] == lower.LoweringCallConvInternal(), " lowering plan: callconv")
    assert(plan.typedExprFacts.len == parser.NormalizedExprLayerExprCount(plan.exprLayer),
           " lowering plan: typed expr fact count")
    assert(plan.loweringRules.len == plan.typedExprFacts.len,
           " lowering plan: lowering rule count")
    assert(plan.typedExprFacts[0].exprId != "", " lowering plan: typed expr id")
    var sawMain = false
    for i in 0..<plan.functionNames.len:
        assert(!(plan.functionOwnerModulePaths[i] == "std/system" && plan.functionNames[i] == "mulCompat"),
               " lowering plan: skip importc decl")
        if plan.functionEntryFlags[i] != 0:
            sawMain = true
            assert(plan.functionNames[i] == "main", " lowering plan: entry name")
            assert(plan.functionResultLayoutKinds[i] == lower.LoweringLayoutKindI32(), " lowering plan: entry layout")
    assert(sawMain, " lowering plan: saw entry")
    assert(plan.exprLayer.sourceCount > 0, " lowering plan: expr surface count")
    assert(parser.NormalizedExprLayerExprCount(plan.exprLayer) > 0, " lowering plan: expr node count")
    assert(parser.NormalizedExprLayerTryCount(plan.exprLayer) >= 0, " lowering plan: try count")
    assert(plan.exprLayer.questionResidualCount == 0, " lowering plan: question normalized")
    assert(texpr.TypedExprLowerLocalAddressCount(plan.typedExprFacts) > 0,
           " lowering plan: typed lowering mode")
    assert(plan.missingReasons.len == 0, " lowering plan: no lowering blockers")
    assert(lower.LoweringPlanPipelineStage(plan) == "canonical_csg_to_lowering_plan",
           " lowering plan: report stage")

    let typedFixturePath: str = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let typedOutputPath: str = chengpath.PathJoin(outDir, "typed_expr_fact_fixture")
    let typedReq = creq.CompilerRequestNew(
        packageRoot,
        typedFixturePath,
        typedOutputPath,
        "arm64-apple-darwin",
        creq.EmitShared,
        ""
    )
    var typedLinkPlan: slplan.SystemLinkPlanStub
    err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, typedReq, typedLinkPlan, err),
           " lowering plan: typed build link plan")
    let typedPlan = buildPlan(workspaceRoot, packageRoot, typedFixturePath, typedOutputPath, creq.EmitShared)
    let typedSourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(typedLinkPlan)
    assert(IsOk(typedSourceBundleRes), " lowering plan: typed source bundle")
    let typedSourceBundleCid = Value(typedSourceBundleRes)
    let typedCsgRes = ccsg.BuildCompilerCsg(typedLinkPlan, typedSourceBundleCid)
    assert(IsOk(typedCsgRes), " lowering plan: typed fixture csg")
    let typedCsg = ccsg.CompilerCsgClone(Value(typedCsgRes))
    assert(texpr.TypedExprFactsEqual(typedCsg.typedExprFacts, typedPlan.typedExprFacts),
           " lowering plan: typed facts match compiler csg")
    let typedCsgRules = texpr.TypedExprLoweringRulesFromFacts(typedCsg.typedExprFacts)
    var loweringErr = ""
    assert(texpr.TypedExprFactsValidateCallResolution(typedCsg.exprLayer, typedCsg.typedExprFacts, loweringErr),
           " lowering plan: typed csg call resolution validate")
    assert(texpr.TypedExprFactsValidateCallResolution(typedPlan.exprLayer, typedPlan.typedExprFacts, loweringErr),
           " lowering plan: typed plan call resolution validate")
    assert(texpr.TypedExprLoweringRulesValidate(typedCsgRules, loweringErr),
           " lowering plan: typed csg lowering rules validate")
    assert(texpr.TypedExprLoweringRulesValidate(typedPlan.loweringRules, loweringErr),
           " lowering plan: typed plan lowering rules validate")
    assert(texpr.TypedExprLoweringRulesEqual(typedCsgRules, typedPlan.loweringRules),
           " lowering plan: lowering rules match compiler csg")
    let typedPlanReport = lower.LoweringPlanStubReport(typedPlan)
    let typedFixtureFacts = texpr.TypedExprFactsForSource(typedPlan.typedExprFacts, typedFixturePath)
    assert(typedFixtureFacts.len > 0, " lowering plan: typed fixture fact slice")
    assertTypedCallFactsMatchLayer(typedPlan.typedExprFacts, typedPlan.exprLayer, " lowering plan: typed fixture")
    assert(plan.loweringRules.len == plan.typedExprFacts.len,
           " lowering plan: typed lowering rule count")
    assert(texpr.TypedExprLoweringRuleUniqueShapeCount(typedCsgRules) > 0,
           " lowering plan: typed lowering rule shape count")
    assert(texpr.TypedExprLoweringRuleUniqueShapeCount(typedCsgRules) ==
           texpr.TypedExprLoweringRuleUniqueKeyCount(typedCsgRules),
           " lowering plan: typed lowering rule key count")
    assert(texpr.TypedExprAbiPolymorphicCount(typedFixtureFacts) == 0,
           " lowering plan: typed fixture no abi polymorphic")
    assert(texpr.TypedExprLowerDeferredCount(typedFixtureFacts) == 0,
           " lowering plan: typed fixture no deferred lowering")
    assert(texpr.TypedExprPlaceLocalCount(typedFixtureFacts) > 0,
           " lowering plan: typed fixture local place count")
    assert(texpr.TypedExprLowerSretCount(typedFixtureFacts) > 0,
           " lowering plan: typed fixture sret count")
    assert(texpr.TypedExprCallBuiltinCount(typedFixtureFacts) > 0,
           " lowering plan: typed fixture builtin call kind")
    assert(texpr.TypedExprCallResultIntrinsicCount(typedFixtureFacts) > 0,
           " lowering plan: typed fixture result intrinsic call kind")
    assert(texpr.TypedExprCallProjectionCount(typedFixtureFacts) > 0,
           " lowering plan: typed fixture projection call kind")
    assert(parser.NormalizedExprLayerHasConstructorExpr(typedPlan.exprLayer, 60),
           " lowering plan: typed fixture constructor expr")
    let constructorFact = findTypedFact(typedFixtureFacts, typedFixturePath, 60)
    assert(constructorFact.kind == parser.NormalizedExprConstructor,
           " lowering plan: typed fixture constructor fact kind")
    assert(constructorFact.typeCallKind == texpr.TypedExprTypeCallConstructor,
           " lowering plan: typed fixture constructor type call kind")
    assert(constructorFact.typeText == "TypedDefaultWrap",
           " lowering plan: typed fixture constructor fact type")
    assert(!constructorFact.callPrefixStyle,
           " lowering plan: typed fixture constructor call prefix")
    assert(constructorFact.callArgCount == 1,
           " lowering plan: typed fixture constructor arg count")
    assert(constructorFact.callArgsText == "count: payload.len",
           " lowering plan: typed fixture constructor args text")
    var sawConstructorRule = false
    for i in 0..<typedPlan.loweringRules.len:
        if typedPlan.loweringRules[i].sourcePath == typedFixturePath &&
           typedPlan.loweringRules[i].lineNumber == 60 &&
           typedPlan.loweringRules[i].typeCallKind == texpr.TypedExprTypeCallConstructor:
            assert(typedPlan.loweringRules[i].callArgCount == 1,
                   " lowering plan: typed fixture constructor rule arg count")
            assert(typedPlan.loweringRules[i].callArgsText == "count: payload.len",
                   " lowering plan: typed fixture constructor rule args text")
            sawConstructorRule = true
    assert(sawConstructorRule, " lowering plan: typed fixture constructor lowering rule")
    assert(parser.NormalizedExprLayerHasCallExpr(typedPlan.exprLayer, parser.NormalizedExprSurfaceCallExternal, 28),
           " lowering plan: typed fixture alias external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedPlan.exprLayer, parser.NormalizedExprSurfaceCallExternal, 29),
           " lowering plan: typed fixture module stem external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedPlan.exprLayer, parser.NormalizedExprSurfaceCallExternal, 30),
           " lowering plan: typed fixture nested qualified external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedPlan.exprLayer, parser.NormalizedExprSurfaceCallExternal, 32),
           " lowering plan: typed fixture alias importc external call")
    assert(parser.NormalizedExprLayerHasCallExpr(typedPlan.exprLayer, parser.NormalizedExprSurfaceCallExternal, 33),
           " lowering plan: typed fixture nested importc external call")
    var sawAliasImportBuffer = false
    var sawNestedImportBuffer = false
    var sawDefaultInitFact = false
    for i in 0..<typedFixtureFacts.len:
        if typedFixtureFacts[i].lineNumber == 32 &&
           texpr.TypedExprFactUsesImportBuffer(typedFixtureFacts[i]):
            sawAliasImportBuffer = true
        if typedFixtureFacts[i].lineNumber == 33 &&
           texpr.TypedExprFactUsesImportBuffer(typedFixtureFacts[i]):
            sawNestedImportBuffer = true
        if typedFixtureFacts[i].lineNumber == 56 &&
           typedFixtureFacts[i].kind == parser.NormalizedExprDefaultInit:
            assert(typedFixtureFacts[i].typeCallKind == texpr.TypedExprTypeCallDefaultInit,
                   " lowering plan: typed fixture default init type call kind")
            assert(typedFixtureFacts[i].abiClass == texpr.TypedExprAbiComposite,
                   " lowering plan: typed fixture default init abi")
            assert(typedFixtureFacts[i].placeKind != texpr.TypedExprPlaceCallResult,
                   " lowering plan: typed fixture default init place")
            assert(typedFixtureFacts[i].loweringMode == texpr.TypedExprLowerLocalAddress,
                   " lowering plan: typed fixture default init lowering")
            assert(typedFixtureFacts[i].returnKind == texpr.TypedExprReturnCompositeLocal,
                   " lowering plan: typed fixture default init return")
            sawDefaultInitFact = true
    assert(sawAliasImportBuffer, " lowering plan: typed fixture alias importc uses import buffer")
    assert(sawNestedImportBuffer, " lowering plan: typed fixture nested importc uses import buffer")
    assert(sawDefaultInitFact, " lowering plan: typed fixture saw default init fact")
    assert(texpr.TypedExprLowerImportBufferCount(typedFixtureFacts) > 0,
           " lowering plan: typed fixture import buffer lowering")
    assert(texpr.TypedExprReturnRegCount(typedFixtureFacts) > 0,
           " lowering plan: typed fixture reg return kind")
    assert(texpr.TypedExprReturnCompositeLocalCount(typedFixtureFacts) > 0,
           " lowering plan: typed fixture composite local return kind")
    assert(texpr.TypedExprReturnSretCount(typedFixtureFacts) > 0,
           " lowering plan: typed fixture sret return kind")
    assert(texpr.TypedExprReturnImportBufferCount(typedFixtureFacts) > 0,
           " lowering plan: typed fixture import buffer return kind")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_count") ==
           intToStr(parser.NormalizedExprLayerCallCount(typedPlan.exprLayer)),
           " lowering plan: typed report call count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_default_init_count") ==
           intToStr(parser.NormalizedExprLayerDefaultInitCount(typedPlan.exprLayer)),
           " lowering plan: typed report default init count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_resolved_count") ==
           intToStr(parser.NormalizedExprLayerCallResolvedCount(typedPlan.exprLayer)),
           " lowering plan: typed report resolved call count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_unresolved_count") ==
           intToStr(parser.NormalizedExprLayerCallUnresolvedCount(typedPlan.exprLayer)),
           " lowering plan: typed report unresolved call count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_local_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(typedPlan.exprLayer, parser.NormalizedExprSurfaceCallLocal)),
           " lowering plan: typed report local call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_external_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(typedPlan.exprLayer, parser.NormalizedExprSurfaceCallExternal)),
           " lowering plan: typed report external call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_importc_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(typedPlan.exprLayer, parser.NormalizedExprSurfaceCallImportc)),
           " lowering plan: typed report importc call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_member_kind_count") ==
           intToStr(parser.NormalizedExprLayerCallKindCountExact(typedPlan.exprLayer, parser.NormalizedExprSurfaceCallMember)),
           " lowering plan: typed report member call kind count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_call_target_importc_count") ==
           intToStr(parser.NormalizedExprLayerCallTargetImportcCount(typedPlan.exprLayer)),
           " lowering plan: typed report importc target count")
    assert(reportFieldValue(typedPlanReport, "expr_surface_constructor_count") ==
           intToStr(parser.NormalizedExprLayerConstructorCount(typedPlan.exprLayer)),
           " lowering plan: typed report constructor count")
    assert(reportFieldValue(typedPlanReport, "typed_expr_type_call_default_init_count") ==
           intToStr(parser.NormalizedExprLayerDefaultInitCount(typedPlan.exprLayer)),
           " lowering plan: typed report typed default init count")
    assert(reportFieldValue(typedPlanReport, "typed_expr_type_call_constructor_count") ==
           intToStr(parser.NormalizedExprLayerConstructorCount(typedPlan.exprLayer)),
           " lowering plan: typed report typed constructor count")
    assert(reportFieldValue(typedPlanReport, "lowering_rule_type_call_default_init_count") ==
           intToStr(parser.NormalizedExprLayerDefaultInitCount(typedPlan.exprLayer)),
           " lowering plan: typed report lowering default init count")
    assert(reportFieldValue(typedPlanReport, "lowering_rule_type_call_constructor_count") ==
           intToStr(parser.NormalizedExprLayerConstructorCount(typedPlan.exprLayer)),
           " lowering plan: typed report lowering constructor count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.NormalizedExprCallReasonUnknownQualifiedTarget,
                                " lowering plan: typed report unknown qualified target count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.NormalizedExprCallReasonShadowedQualifiedTarget,
                                " lowering plan: typed report shadowed qualified target count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.NormalizedExprCallReasonAmbiguousExternalTarget,
                                " lowering plan: typed report ambiguous external target count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.NormalizedExprCallReasonAmbiguousQualifiedTarget,
                                " lowering plan: typed report ambiguous qualified target count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.NormalizedExprCallReasonUnknownExternalTarget,
                                " lowering plan: typed report unknown external target count")
    assertCallReasonReportField(typedPlanReport,
                                typedPlan.exprLayer,
                                parser.NormalizedExprCallReasonUnknownCallTarget,
                                " lowering plan: typed report unknown call target count")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_arg_address_count"),
           " lowering plan: typed address arg rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_result_sret_count"),
           " lowering plan: typed sret result rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_materialize_dest_address_count"),
           " lowering plan: typed dest address materialize rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_copy_region_copy_count"),
           " lowering plan: typed region copy rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_import_builtin_address_slot_count"),
           " lowering plan: typed builtin address import rule")
    assert(reportFieldPositive(typedPlanReport, "lowering_rule_import_import_buffer_count"),
           " lowering plan: typed import buffer import rule")
    assert(reportFieldValue(typedPlanReport, "lowering_rule_unique_key_count") ==
           reportFieldValue(typedPlanReport, "lowering_rule_unique_shape_count"),
           " lowering plan: typed report unique key count")
    assert(reportFieldValue(typedPlanReport, "lowering_rule_entry[0]") != "",
           " lowering plan: typed report rule entry")
    assert(chengpath.TextContains(reportFieldValue(typedPlanReport, "lowering_rule_entry[0]"), "key=type="),
           " lowering plan: typed report rule key text")

    echo(" lowering_plan_smoke ok")
    return 0
