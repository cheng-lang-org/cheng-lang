import std/os
import cheng/std/bytes_layout as layout
import cheng/chain/anti_entropy as anti
import cheng/apps/chain_node/chain_node as node
import std/strutils as strutil

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node forest replay: init")
    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node forest replay: mint")
    let transferCidRes = node.ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, " chain_node forest replay: transfer")

    var served: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(served, server)
    var replayed: node.ChainNode
    let replayedRes = node.ChainNodeReplayFromSnapshotInto(replayed,
                                                             "node-b",
                                                             served.address,
                                                             served)
    if !replayedRes.ok:
        panic(Error(replayedRes))

    let serverForest = node.ChainNodeForestCid(server)
    let replayedForest = node.ChainNodeForestCid(replayed)
    if !layout.FixedBytes32Equal(serverForest, replayedForest):
        os.WriteLine(os.Get_stderr(), strutil.Join(["server_forest=", layout.FixedBytes32Hex(serverForest)], ""))
        os.WriteLine(os.Get_stderr(), strutil.Join(["replayed_forest=", layout.FixedBytes32Hex(replayedForest)], ""))
        os.WriteLine(os.Get_stderr(), strutil.Join(["served_forest=", layout.FixedBytes32Hex(served.forest.forestCid)], ""))
        os.WriteLine(os.Get_stderr(), strutil.Join(["served_sig_forest=", layout.FixedBytes32Hex(served.signature.stateForestCid)], ""))
        panic(" chain_node forest replay: forest mismatch")
    if !anti.AntiEntropySignatureEqual(server.signature, replayed.signature):
        panic(" chain_node forest replay: signature mismatch")
    echo(" chain_node_forest_replay_smoke ok")
    return 0
