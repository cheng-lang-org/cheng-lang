import std/os
import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/backend/lowering_plan as lower
import cheng/core/lang/parser
import cheng/core/lang/typed_expr as texpr
import std/strutils as strutil

fn reportFieldValue(report: str, key: str): str =
    let taggedReport = strutil.Join(["\n", report], "")
    let needle = strutil.Join(["\n", key, "="], "")
    let fieldPos = parser.ParserFindText(taggedReport, needle)
    if fieldPos < 0:
        return ""
    let valueStart = fieldPos + needle.len
    let tail = chengpath.TextSlice(taggedReport, valueStart, taggedReport.len - valueStart)
    let newlinePos = parser.ParserFindText(tail, "\n")
    if newlinePos < 0:
        return tail
    return chengpath.TextSlice(tail, 0, newlinePos)

fn buildLinkPlan(workspaceRoot: str,
                 packageRoot: str,
                 sourcePath: str,
                 outputPath: str,
                 emitKind: int32): slplan.SystemLinkPlanStub =
    let req = creq.CompilerRequestNew(
        packageRoot,
        sourcePath,
        outputPath,
        "arm64-apple-darwin",
        emitKind,
        ""
    )
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err),
           " lowering matrix: link plan")
    return linkPlan

fn main(): int32 =
    let workspaceRoot: str = chengpath.PathCurrentDir()
    let packageRoot: str = workspaceRoot
    let smokeLabel: str = os.GetEnvDefault("CHENG_SMOKE_LABEL", "host")
    let outDir: str = chengpath.PathJoin(workspaceRoot, strutil.Join(["artifacts/lowering_matrix/", smokeLabel], ""))
    assert(chengpath.MkdirP(workspaceRoot, outDir), " lowering matrix: mkdir")
    let fixturePath: str = chengpath.PathJoin(packageRoot, "src/tests/lowering_matrix_fixture.cheng")
    let outputPath: str = chengpath.PathJoin(outDir, "lowering_matrix_fixture")
    let linkPlan = buildLinkPlan(workspaceRoot,
                                 packageRoot,
                                 fixturePath,
                                 outputPath,
                                 creq.EmitShared)
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    assert(IsOk(sourceBundleRes), " lowering matrix: source bundle")
    let sourceBundleCid = Value(sourceBundleRes)
    var err = ""
    var plan: lower.LoweringPlanStub
    assert(lower.BuildLoweringPlanStub(linkPlan, plan, err),
           " lowering matrix: lowering plan")
    let csgRes = ccsg.BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(csgRes), " lowering matrix: compiler csg")
    let csg = ccsg.CompilerCsgClone(Value(csgRes))
    let fixtureFacts = texpr.TypedExprFactsForSource(csg.typedExprFacts, fixturePath)
    let fixtureRules = texpr.TypedExprLoweringRulesFromFacts(fixtureFacts)
    let planRules = lower.LoweringPlanRulesForSource(plan, fixturePath)
    let csgReport = ccsg.CompilerCsgReport(csg)
    let planReport = lower.LoweringPlanStubReport(plan)
    assert(fixtureRules.len > 0, " lowering matrix: fixture rules")
    assert(texpr.TypedExprLoweringRulesEqual(fixtureRules, planRules),
           " lowering matrix: compiler csg vs lowering plan")
    assert(texpr.TypedExprLoweringRuleUniqueShapeCount(fixtureRules) ==
           texpr.TypedExprLoweringRuleUniqueKeyCount(fixtureRules),
           " lowering matrix: rule shape count vs key count")
    assert(chengpath.TextContains(csgReport, "lowering_rule_arg_address_count="),
           " lowering matrix: csg address arg key")
    assert(chengpath.TextContains(planReport, "lowering_rule_arg_address_count="),
           " lowering matrix: plan address arg key")
    assert(reportFieldValue(csgReport, "lowering_rule_unique_key_count") ==
           reportFieldValue(planReport, "lowering_rule_unique_key_count"),
           " lowering matrix: report unique key count")
    assert(!chengpath.TextContains(planReport, "lowering_rule_arg_address_count=0\n"),
           " lowering matrix: address arg rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_arg_call_result_address_count=0\n"),
           " lowering matrix: call-result address arg rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_arg_value_count=0\n"),
           " lowering matrix: value arg rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_result_reg_count=0\n"),
           " lowering matrix: reg result rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_result_local_address_count=0\n"),
           " lowering matrix: local-address result rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_result_sret_count=0\n"),
           " lowering matrix: sret result rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_materialize_register_count=0\n"),
           " lowering matrix: register materialize rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_materialize_local_slot_count=0\n"),
           " lowering matrix: local-slot materialize rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_materialize_call_result_local_count=0\n"),
           " lowering matrix: call-result local materialize rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_materialize_dest_address_count=0\n"),
           " lowering matrix: dest-address materialize rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_copy_scalar_store_count=0\n"),
           " lowering matrix: scalar-store copy rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_copy_region_copy_count=0\n"),
           " lowering matrix: region-copy rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_import_builtin_address_slot_count=0\n"),
           " lowering matrix: builtin address import rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_import_i32_value_slot_count=0\n"),
           " lowering matrix: value-slot import rule")
    assert(!chengpath.TextContains(planReport, "lowering_rule_import_i32_address_slot_count=0\n"),
           " lowering matrix: address-slot import rule")
    for i in 0..<fixtureRules.len:
        let key = strutil.Join(["lowering_rule_entry[", intToStr(i), "]"], "")
        let csgEntry = reportFieldValue(csgReport, key)
        let planEntry = reportFieldValue(planReport, key)
        assert(csgEntry != "", " lowering matrix: csg rule entry")
        assert(planEntry != "", " lowering matrix: plan rule entry")
        assert(csgEntry == planEntry, " lowering matrix: rule entry text match")
        assert(chengpath.TextContains(csgEntry, "key=type="),
               " lowering matrix: rule entry carries key text")
    echo(" lowering_matrix_smoke ok")
    return 0
