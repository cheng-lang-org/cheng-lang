import std/result
import cheng/core/tooling/compiler_request as creq
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/compiler_world as cworld
import cheng/core/tooling/compiler_csg as ccsg
import cheng/core/backend/system_link_plan as slplan
import cheng/core/lang/parser
import cheng/core/lang/typed_expr as texpr
import std/strutils as strutil

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let fixturePath = chengpath.PathJoin(packageRoot, "src/tests/typed_expr_fact_fixture.cheng")
    let outputPath = chengpath.PathJoin(workspaceRoot, "artifacts/compiler_csg/typed_expr_cross_file_probe")
    let req = creq.CompilerRequestNew(packageRoot, fixturePath, outputPath, "arm64-apple-darwin", creq.EmitShared, "")
    var linkPlan: slplan.SystemLinkPlanStub
    var err = ""
    assert(slplan.BuildSystemLinkPlanStub(workspaceRoot, req, linkPlan, err), "typed expr cross file probe: link plan")
    let sourceBundleRes = slplan.SystemLinkPlanSourceBundleCid(linkPlan)
    assert(IsOk(sourceBundleRes), "typed expr cross file probe: source bundle")
    let sourceBundleCid = Value(sourceBundleRes)
    let csgRes = ccsg.BuildCompilerCsg(linkPlan, sourceBundleCid)
    assert(IsOk(csgRes), "typed expr cross file probe: build csg")
    let csg = ccsg.CompilerCsgClone(Value(csgRes))
    let facts = texpr.TypedExprFactsForSource(csg.typedExprFacts, fixturePath)
    for i in 0..<facts.len:
        let fact = facts[i]
        if texpr.TypedExprFactAbiIsPolymorphic(fact):
            echo(strutil.Join(["poly line=", intToStr(fact.lineNumber), " col=", intToStr(fact.columnNumber), " kind=", parser.NormalizedExprKindText(fact.kind), " type=", fact.typeText, " lower=", texpr.TypedExprLoweringModeText(fact.loweringMode), " call=", texpr.TypedExprCallKindText(fact.callKind), " ret=", texpr.TypedExprReturnKindText(fact.returnKind)], ""))
    for i in 0..<facts.len:
        let fact = facts[i]
        if fact.kind == parser.NormalizedExprCall:
            echo(strutil.Join(["call line=", intToStr(fact.lineNumber), " col=", intToStr(fact.columnNumber), " type=", fact.typeText, " abi=", texpr.TypedExprAbiClassText(fact.abiClass), " lower=", texpr.TypedExprLoweringModeText(fact.loweringMode), " ret=", texpr.TypedExprReturnKindText(fact.returnKind)], ""))
    return 0
