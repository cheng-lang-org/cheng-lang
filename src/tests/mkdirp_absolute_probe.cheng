import std/os
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root: str = os.GetCurrentDir()
    let outDir: str = chengpath.PathAbsolute(root, "artifacts/mkdirp_absolute_probe")
    if !chengpath.MkdirP(root, outDir):
        echo("mkdirp-bad")
        return 1
    echo("mkdirp-ok")
    return 0
