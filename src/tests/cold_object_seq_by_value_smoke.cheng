type
    Plan =
        paths: str[]

fn pathCount(plan: Plan): int32 =
    return plan.paths.len

fn main() =
    var plan: Plan
    var paths: str[]
    add(paths, "alpha")
    plan.paths = paths
    assert(plan.paths.len == 1, "cold object seq direct len")
    assert(pathCount(plan) == 1, "cold object seq by value len")
