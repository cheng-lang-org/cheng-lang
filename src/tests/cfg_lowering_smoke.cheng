# cfg_lowering_smoke.cheng
# Tests a function with let/if/return (general CFG lowering).
# The function takes a value from GetValue(), guards against <= 0,
# and returns the value otherwise.
#
# Expected exit code: 5 (GetValue returns 5, which is > 0)

fn GetValue(): int32 =
    return 5

fn RunGuard(value: int32): int32 =
    if value <= 0:
        return 0
    return value

fn main(): int32 =
    let x = GetValue()
    let result = RunGuard(x)
    if result != 5:
        return 1
    echo(" cfg_lowering_smoke ok")
    return 0
