import std/system

type
    IndexedAssignSrc =
        count: int32
        limbs: int32[16]

    IndexedAssignDst =
        limbs: int32[8]

fn fillIndexed(dst: var IndexedAssignDst, src: var IndexedAssignSrc) =
    for i in 0..<src.count:
        dst.limbs[i] = src.limbs[i]

fn main(): int32 =
    var src: IndexedAssignSrc
    src.count = 3
    src.limbs[0] = 7
    src.limbs[1] = 11
    src.limbs[2] = 13
    var dst: IndexedAssignDst
    fillIndexed(dst, src)
    assert(dst.limbs[0] == 7, "indexed assign probe: limb0")
    assert(dst.limbs[1] == 11, "indexed assign probe: limb1")
    assert(dst.limbs[2] == 13, "indexed assign probe: limb2")
    assert(src.limbs[0] == 7, "indexed assign probe: source intact")
    echo("v3 indexed_lvalue_scalar_assignment_probe ok")
    return 0
