import std/system
import cheng/std/bytes_layout as layout
import cheng/apps/rwad/rwad_serial_state_machine as serial
import cheng/apps/rwad/rwad_bft_state_machine as rwad

fn main(): int32 =
    let alice = serial.RwadOwnerIdFromText("alice")
    let bob = serial.RwadOwnerIdFromText("bob")
    var machine = rwad.RwadBftStateMachineInit("rwad-bft-smoke")

    let mint = rwad.RwadBftTxMint(alice, int64(100))
    let mintRaw = rwad.RwadBftEncodeTx(mint)
    let mintRoundtrip = rwad.RwadBftDecodeTx(layout.byteSpanFromBytes(mintRaw))
    assert(mintRoundtrip.ok, " rwad bft smoke: mint roundtrip")
    let mintCheck = rwad.RwadBftStateMachineCheckTx(machine,
                                                      rwad.RwadBftBlockContextMake(int64(1), 0, int64(0), layout.FixedBytes32()),
                                                      mint)
    assert(mintCheck.code == serial.RwadSerialCodeOk, " rwad bft smoke: mint check")
    assert(machine.ledger.notes.len == 0, " rwad bft smoke: mint check no mutate")

    var block1: rwad.RwadBftTx[]
    block1 = []
    add(block1, mint)
    var block1Summary = rwad.RwadBftBlockSummaryZero(int64(0))
    rwad.RwadBftStateMachineFinalizeBlockSummary(machine, int64(1), block1, block1Summary)
    assert(block1Summary.txCount == 1, " rwad bft smoke: block1 tx count")
    assert(block1Summary.appliedCount == 1, " rwad bft smoke: block1 applied")
    assert(machine.ledger.lastFinalizedHeight == int64(1), " rwad bft smoke: block1 height")

    let transfer = rwad.RwadBftTxTransfer(int64(1), alice, bob, int64(21), int64(40))
    let transferRaw = rwad.RwadBftEncodeTx(transfer)
    let transferCheckBytes = rwad.RwadBftStateMachineCheckTxBytes(machine,
                                                                    rwad.RwadBftBlockContextMake(int64(2), 0, int64(0), layout.FixedBytes32()),
                                                                    transferRaw)
    assert(transferCheckBytes.code == serial.RwadSerialCodeOk, " rwad bft smoke: transfer check bytes")
    let transferCheck = rwad.RwadBftStateMachineCheckTx(machine,
                                                          rwad.RwadBftBlockContextMake(int64(2), 0, int64(0), layout.FixedBytes32()),
                                                          transfer)
    assert(transferCheck.code == serial.RwadSerialCodeOk, " rwad bft smoke: transfer check")

    var block2: rwad.RwadBftTx[]
    block2 = []
    add(block2, transfer)
    var block2Summary = rwad.RwadBftBlockSummaryZero(int64(0))
    rwad.RwadBftStateMachineFinalizeBlockSummary(machine, int64(2), block2, block2Summary)
    assert(block2Summary.appliedCount == 1, " rwad bft smoke: block2 applied")
    assert(!layout.fixedBytes32Equal(block2Summary.serialRoot, layout.FixedBytes32()),
           " rwad bft smoke: block2 serial root")
    assert(!layout.fixedBytes32Equal(block2Summary.nullifierRoot, layout.FixedBytes32()),
           " rwad bft smoke: block2 nullifier root")

    let aliceQuery = rwad.RwadBftStateMachineQueryOwner(machine, alice)
    let bobQuery = rwad.RwadBftStateMachineQueryOwner(machine, bob)
    assert(aliceQuery.balance == int64(80), " rwad bft smoke: alice balance")
    assert(aliceQuery.liveNoteCount == 2, " rwad bft smoke: alice notes")
    assert(bobQuery.balance == int64(20), " rwad bft smoke: bob balance")
    assert(bobQuery.liveNoteCount == 1, " rwad bft smoke: bob notes")
    assert(layout.fixedBytes32Equal(block2Summary.appHash, rwad.RwadBftStateMachineQueryAppHash(machine)),
           " rwad bft smoke: app hash")

    var bytesMachine = rwad.RwadBftStateMachineInit("rwad-bft-smoke-bytes")
    var rawBlock1: Bytes[]
    rawBlock1 = []
    add(rawBlock1, mintRaw)
    var rawBlock1Summary = rwad.RwadBftBlockSummaryZero(int64(0))
    rwad.RwadBftStateMachineFinalizeBlockBytesSummary(bytesMachine, int64(1), rawBlock1, rawBlock1Summary)
    assert(rawBlock1Summary.appliedCount == 1, " rwad bft smoke: raw block1")
    var rawBlock2: Bytes[]
    rawBlock2 = []
    add(rawBlock2, transferRaw)
    var rawBlock2Summary = rwad.RwadBftBlockSummaryZero(int64(0))
    rwad.RwadBftStateMachineFinalizeBlockBytesSummary(bytesMachine, int64(2), rawBlock2, rawBlock2Summary)
    assert(rawBlock2Summary.appliedCount == 1, " rwad bft smoke: raw block2")

    var staleBlock: rwad.RwadBftTx[]
    staleBlock = []
    add(staleBlock, transfer)
    var staleSummary = rwad.RwadBftBlockSummaryZero(int64(0))
    rwad.RwadBftStateMachineFinalizeBlockSummary(machine, int64(2), staleBlock, staleSummary)
    assert(staleSummary.appliedCount == 0, " rwad bft smoke: stale applied")
    assert(staleSummary.rejectedCount == 1, " rwad bft smoke: stale rejected")
    echo(" rwad_bft_state_machine_smoke ok")
    return 0
