import std/result
import cheng/apps/wow_export/build_info as build_info
import cheng/apps/wow_export/cdn_config as cdn_config

const
    wowExportCdnKey = "3c5ad7aaa7b670c73022dbcca72119b1"
    wowExportArchiveGroup = "ec89b5e883f7098df159708d38fee73e"
    wowExportFileIndex = "303b4155efa35ae393a48c869f1d1899"
    wowExportPatchFileIndex = "802a8dfe1e5717a6310be2c7a444368a"
    wowExportEncodingEKey = "00f6dcef63eafe6254ab5408ea8baa09"
    wowExportVfsRootEKey = "2aece4e2ec64a8c89753c53f4d0207ca"

fn main(): int32 =
    let buildRes: Result[build_info.WowBuildEntry] = build_info.ProbeRetailDefault()
    assert(IsOk(buildRes), Error(buildRes))
    let build: build_info.WowBuildEntry = Value(buildRes)
    assert(build.cdnKey == wowExportCdnKey,
           "wow_export_cdn_config_smoke CDN key")

    let cfgRes: Result[cdn_config.CdnConfig] =
        cdn_config.LoadCdnConfig(build_info.DefaultClientPath, build.cdnKey)
    assert(IsOk(cfgRes), Error(cfgRes))
    let cfg: cdn_config.CdnConfig = Value(cfgRes)
    assert(cfg.archiveGroup == wowExportArchiveGroup,
           "wow_export_cdn_config_smoke archive-group")
    assert(cfg.fileIndex == wowExportFileIndex,
           "wow_export_cdn_config_smoke file-index")
    assert(cfg.fileIndexSize == 502668,
           "wow_export_cdn_config_smoke file-index-size")
    assert(cfg.patchFileIndex == wowExportPatchFileIndex,
           "wow_export_cdn_config_smoke patch-file-index")
    assert(cfg.patchFileIndexSize == 131868,
           "wow_export_cdn_config_smoke patch-file-index-size")

    let encodingPathRes: Result[str] = cdn_config.CdnLooseDataPath(wowExportEncodingEKey)
    assert(IsOk(encodingPathRes), Error(encodingPathRes))
    assert(Value(encodingPathRes) == "data/00/f6/00f6dcef63eafe6254ab5408ea8baa09",
           "wow_export_cdn_config_smoke encoding loose path")

    let vfsPathRes: Result[str] = cdn_config.CdnLooseDataPath(wowExportVfsRootEKey)
    assert(IsOk(vfsPathRes), Error(vfsPathRes))
    assert(Value(vfsPathRes) == "data/2a/ec/2aece4e2ec64a8c89753c53f4d0207ca",
           "wow_export_cdn_config_smoke vfs loose path")

    let encodingUrlRes: Result[str] = cdn_config.CdnLooseDataUrl(build, wowExportEncodingEKey, true)
    assert(IsOk(encodingUrlRes), Error(encodingUrlRes))
    assert(Value(encodingUrlRes) ==
           "https://blzdist-wow.necdn.leihuo.netease.com/tpr/wow/data/00/f6/00f6dcef63eafe6254ab5408ea8baa09",
           "wow_export_cdn_config_smoke encoding loose URL")

    let vfsUrlRes: Result[str] = cdn_config.CdnLooseDataUrl(build, wowExportVfsRootEKey, true)
    assert(IsOk(vfsUrlRes), Error(vfsUrlRes))
    assert(Value(vfsUrlRes) ==
           "https://blzdist-wow.necdn.leihuo.netease.com/tpr/wow/data/2a/ec/2aece4e2ec64a8c89753c53f4d0207ca",
           "wow_export_cdn_config_smoke vfs loose URL")

    echo("wow_export_cdn_config_smoke ok")
    return 0
