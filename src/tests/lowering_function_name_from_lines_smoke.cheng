import cheng/core/tooling/path as chengpath
import cheng/core/lang/parser
import cheng/core/backend/lowering_plan as lower

fn main(): int32 =
    let workspaceRoot = chengpath.PathCurrentDir()
    let packageRoot = workspaceRoot
    let sourcePath = chengpath.PathJoin(packageRoot, "src/tests/program_selfhost_smoke.cheng")
    let text = chengpath.ReadTextFile("", sourcePath)
    let lines = parser.ParserSplitChar(text, '\n')
    var functionName = ""
    for i in 0..<lines.len:
        let current = parser.ParserFunctionNameFromLine(lines[i])
        if current != "":
            functionName = current
    assert(functionName == "main", " lowering function name from lines")
    let symbolText = lower.LoweringFunctionSymbolText("cheng/tests/program_selfhost_smoke", functionName)
    assert(symbolText == "cheng/tests/program_selfhost_smoke::main",
           " lowering function name symbol text")
    echo(" lowering_function_name_from_lines_smoke ok")
    return 0
