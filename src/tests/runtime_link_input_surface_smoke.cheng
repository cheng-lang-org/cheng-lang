import std/os
import std/buffer
import std/rawbytes
import std/strings
import cheng/core/tooling/path as chengpath
import cheng/core/tooling/host_ops as hostops

fn runtimeLinkInputPrefix(prefix: str, value: str): str =
    var out: buffer.ByteBuffer
    out.data = rawbytes.emptyBytes()
    buffer.AppendBytes(out, prefix)
    buffer.AppendBytes(out, value)
    return rawbytes.bytesToString(buffer.ToBytes(out))

fn main(): int32 =
    let root = os.GetCurrentDir()
    let driver = os.JoinPath(root, "artifacts/backend_driver/cheng")
    let target = os.GetEnvDefault("CHENG_RUNTIME_LINK_TARGET", "arm64-apple-darwin")
    let source = os.JoinPath(root, "src/tests/ordinary_zero_exit_fixture.cheng")
    let outDir = chengpath.PathAbsolute(root, "artifacts/runtime_link_input_surface_smoke")
    let outBin = os.JoinPath(outDir, "ordinary_zero_exit_fixture")
    let reportPath = os.JoinPath(outDir, "ordinary_zero_exit_fixture.compile.report.txt")
    let compileLog = os.JoinPath(outDir, "ordinary_zero_exit_fixture.compile.log")
    assert(chengpath.MkdirP(root, outDir), " runtime link input surface: mkdir")
    if chengpath.PathFileExists(outBin):
        os.RemoveFile(outBin)
    if chengpath.PathFileExists(reportPath):
        os.RemoveFile(reportPath)
    if chengpath.PathFileExists(compileLog):
        os.RemoveFile(compileLog)
    var compileArgs: str[]
    compileArgs = []
    add(compileArgs, "system-link-exec")
    add(compileArgs, runtimeLinkInputPrefix("--root:", root))
    add(compileArgs, runtimeLinkInputPrefix("--in:", source))
    add(compileArgs, "--emit:exe")
    add(compileArgs, runtimeLinkInputPrefix("--target:", target))
    add(compileArgs, runtimeLinkInputPrefix("--out:", outBin))
    add(compileArgs, runtimeLinkInputPrefix("--report-out:", reportPath))
    let compileRun = hostops.RunFileLogged(root,
                                             "runtime_link_input_surface_build",
                                             driver,
                                             compileArgs,
                                             [],
                                             root,
                                             0,
                                             compileLog)
    assert(compileRun.exitCode == 0, " runtime link input surface: compile rc")
    assert(os.FileExists(outBin), " runtime link input surface: output exists")
    assert(os.FileExists(reportPath), " runtime link input surface: report exists")
    let reportText = os.ReadFile(reportPath)
    assert(strings.StrContains(reportText, "object_link_input_count=6"),
           " runtime link input surface: object count")
    assert(strings.StrContains(reportText, "native_link_input_count=6"),
           " runtime link input surface: native count")
    assert(strings.StrContains(reportText, "provider.runtime_program_support_host_runtime.o"),
           " runtime link input surface: host provider present")
    assert(!strings.StrContains(reportText, "program_runtime.combined"),
           " runtime link input surface: no combined runtime obj")
    assert(!strings.StrContains(reportText, "system_helpers_compat_bridge"),
           " runtime link input surface: no compat split")
    echo(" runtime_link_input_surface_smoke ok")
    return 0
