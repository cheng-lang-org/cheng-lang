import std/os
import std/strutils as strutil

fn echoParam(path: str): bool =
    echo(strutil.Join(["concat_param=", path], ""))
    return true

fn existsParam(path: str): bool =
    if !os.FileExists(path):
        echo("exists_param=missing_literal")
        echo(strutil.Join(["exists_param=missing_path:", path], ""))
        return false
    echo("exists_param=found")
    return true

fn main(): int32 =
    if !echoParam("/tmp/no_model"):
        return 1
    if !existsParam("/tmp/no_model"):
        return 2
    return 0
