import std/os
import std/strutils as strutil
import cheng/core/tooling/path as chengpath

fn main(): int32 =
    let root = os.GetCurrentDir()
    let reportPath = os.JoinPath(root, "artifacts/str_concat_lowering_smoke/str_concat_lowering_probe.compile.report.txt")
    assert(chengpath.PathFileExists(reportPath), " split report extract simple: report exists")
    let reportText = os.ReadFile(reportPath)
    let prefix = "native_primary_object="
    let reportLines = strutil.Split(reportText, '\n')
    var found: bool
    var i: int32
    for i in i..<reportLines.len:
        let line = reportLines[i]
        if strutil.StartsWith(line, prefix):
            found = true
            let value = chengpath.TextSlice(line, len(prefix), len(line) - len(prefix))
            assert(len(value) > 0, " split report extract simple: value len")
            break
    assert(found, " split report extract simple: found line")
    echo(" strutils_split_report_extract_simple_probe ok")
    return 0
