import cheng/std/bytes_layout as layout
import cheng/apps/rwad/rwad_accumulator as accum
import cheng/apps/rwad/rwad_serial_state_machine as rwad

fn main(): int32 =
    let alice = rwad.RwadOwnerIdFromText("alice")
    let bob = rwad.RwadOwnerIdFromText("bob")
    var machine = rwad.RwadStateMachineInit("rwad-accumulator-smoke")

    let mintTx = rwad.RwadMintTxMake(alice, int64(100))
    let mintApply = rwad.RwadStateMachineApplyMint(machine, int64(1), mintTx)
    assert(mintApply.applied, " rwad accumulator smoke: mint applied")

    let transferTx = rwad.RwadTransferTxMake(int64(1), alice, bob, int64(21), int64(40))
    let transferApply = rwad.RwadStateMachineApplyTransfer(machine, int64(2), transferTx)
    assert(transferApply.applied, " rwad accumulator smoke: transfer applied")

    var noteProof: accum.RwadAccumulatorProof
    assert(rwad.RwadSerialAccumulatorProof(machine, int64(3), noteProof),
           " rwad accumulator smoke: note proof built")
    assert(accum.RwadAccumulatorProofVerify(noteProof),
           " rwad accumulator smoke: note proof verify")
    assert(layout.FixedBytes32Equal(noteProof.rootCid, rwad.RwadSerialAccumulatorRoot(machine)),
           " rwad accumulator smoke: note root")

    var nullifierProof: accum.RwadAccumulatorProof
    assert(rwad.RwadNullifierAccumulatorProof(machine, int64(1), nullifierProof),
           " rwad accumulator smoke: nullifier proof built")
    assert(accum.RwadAccumulatorProofVerify(nullifierProof),
           " rwad accumulator smoke: nullifier proof verify")
    assert(layout.FixedBytes32Equal(nullifierProof.rootCid, rwad.RwadNullifierAccumulatorRoot(machine)),
           " rwad accumulator smoke: nullifier root")

    let commit = rwad.RwadStateMachineCommit(machine)
    assert(layout.FixedBytes32Equal(commit.serialAccumulatorRoot, noteProof.rootCid),
           " rwad accumulator smoke: commit serial accumulator")
    assert(layout.FixedBytes32Equal(commit.nullifierAccumulatorRoot, nullifierProof.rootCid),
           " rwad accumulator smoke: commit nullifier accumulator")
    echo(" rwad_accumulator_smoke ok")
    return 0
