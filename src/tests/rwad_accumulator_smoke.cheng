import cheng/std/bytes_layout as layout
import cheng/apps/rwad/rwad_accumulator as accum
import cheng/apps/rwad/rwad_serial_state_machine as rwad

fn main(): int32 =
    let alice = rwad.v3RwadOwnerIdFromText("alice")
    let bob = rwad.v3RwadOwnerIdFromText("bob")
    var machine = rwad.v3RwadStateMachineInit("rwad-accumulator-smoke")

    let mintTx = rwad.v3RwadMintTxMake(alice, int64(100))
    let mintApply = rwad.v3RwadStateMachineApplyMint(machine, int64(1), mintTx)
    assert(mintApply.applied, "v3 rwad accumulator smoke: mint applied")

    let transferTx = rwad.v3RwadTransferTxMake(int64(1), alice, bob, int64(21), int64(40))
    let transferApply = rwad.v3RwadStateMachineApplyTransfer(machine, int64(2), transferTx)
    assert(transferApply.applied, "v3 rwad accumulator smoke: transfer applied")

    var noteProof: accum.V3RwadAccumulatorProof
    assert(rwad.v3RwadSerialAccumulatorProof(machine, int64(3), noteProof),
           "v3 rwad accumulator smoke: note proof built")
    assert(accum.v3RwadAccumulatorProofVerify(noteProof),
           "v3 rwad accumulator smoke: note proof verify")
    assert(layout.fixedBytes32Equal(noteProof.rootCid, rwad.v3RwadSerialAccumulatorRoot(machine)),
           "v3 rwad accumulator smoke: note root")

    var nullifierProof: accum.V3RwadAccumulatorProof
    assert(rwad.v3RwadNullifierAccumulatorProof(machine, int64(1), nullifierProof),
           "v3 rwad accumulator smoke: nullifier proof built")
    assert(accum.v3RwadAccumulatorProofVerify(nullifierProof),
           "v3 rwad accumulator smoke: nullifier proof verify")
    assert(layout.fixedBytes32Equal(nullifierProof.rootCid, rwad.v3RwadNullifierAccumulatorRoot(machine)),
           "v3 rwad accumulator smoke: nullifier root")

    let commit = rwad.v3RwadStateMachineCommit(machine)
    assert(layout.fixedBytes32Equal(commit.serialAccumulatorRoot, noteProof.rootCid),
           "v3 rwad accumulator smoke: commit serial accumulator")
    assert(layout.fixedBytes32Equal(commit.nullifierAccumulatorRoot, nullifierProof.rootCid),
           "v3 rwad accumulator smoke: commit nullifier accumulator")
    echo("v3 rwad_accumulator_smoke ok")
    return 0
