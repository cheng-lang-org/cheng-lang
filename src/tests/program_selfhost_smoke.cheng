import std/system
import cheng/core/tooling/bootstrap_contracts as contracts

fn main(): int32 =
    let snapshot: contracts.V3BootstrapSnapshot = contracts.v3BootstrapSnapshotDefault("/tmp/cheng-lang")

    assert(snapshot.bootstrapMode == "selfhost", "v3 program selfhost smoke: bootstrap mode")
    assert(snapshot.stage2Compiler.path == "/tmp/cheng-lang/artifacts/bootstrap/cheng.stage2",
           "v3 program selfhost smoke: stage2 path")
    assert(snapshot.stage3Compiler.path == "/tmp/cheng-lang/artifacts/bootstrap/cheng.stage3",
           "v3 program selfhost smoke: stage3 path")
    assert(snapshot.backendDriverOut.path == "/tmp/cheng-lang/artifacts/backend_driver/cheng",
           "v3 program selfhost smoke: backend driver path")
    assert(snapshot.chainNodeOut.path == "/tmp/cheng-lang/artifacts/cheng_node_main/cheng_node_main",
           "v3 program selfhost smoke: chain node path")

    echo("v3 program_selfhost_smoke ok")
    return 0
