import std/system
import cheng/std/bytes_layout as layout
import cheng/apps/chain_node/chain_node as node

fn main(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node: init")
    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node eventcids after first mint: mint")
    add(server.eventCids, layout.FixedBytes32())
    assert(server.eventCids.len == 2, " chain_node eventcids after first mint: second add")
    echo(" chain_node_eventcids_after_first_mint_smoke ok")
    return 0
