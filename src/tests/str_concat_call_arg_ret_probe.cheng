import std/os
import std/strutils as strutil

type
    DummyResult = object
        text: str
        exitCode: int32

fn StrConcatLoweringFlag(prefix: str, value: str): str =
    var parts: str[]
    add(parts, prefix)
    add(parts, value)
    return strutil.Join(parts, "")

fn Sink(root: str,
        label: str,
        filePathRaw: str,
        argv: str[],
        envOverrides: str[],
        workingDirRaw: str,
        timeoutSec: int32,
        logPathRaw: str): DummyResult =
    root
    label
    filePathRaw
    envOverrides
    workingDirRaw
    timeoutSec
    logPathRaw
    let joined = strutil.Join([argv[0], " ", argv[1]], "")
    return DummyResult(text: joined, exitCode: 0)

fn main(): int32 =
    let root = os.GetCurrentDir()
    let driver = os.JoinPath(root, "artifacts/bootstrap/cheng.stage3")
    let target = os.GetEnvDefault("CHENG_RUNTIME_LINK_TARGET", "arm64-apple-darwin")
    let sourcePath = os.JoinPath(root, "src/tests/str_concat_lowering_fixture.cheng")
    let outBin = os.JoinPath(root, "artifacts/str_concat_call_arg_ret_probe.bin")
    let logPath = os.JoinPath(root, "artifacts/str_concat_call_arg_ret_probe.log")
    let run = Sink(root,
                   "str_concat_call_arg_ret_probe",
                   driver,
                   [
                       "system-link-exec",
                       StrConcatLoweringFlag("--root:", root),
                       StrConcatLoweringFlag("--in:", sourcePath),
                       "--emit:exe"
                       ,
                       StrConcatLoweringFlag("--target:", target),
                       StrConcatLoweringFlag("--out:", outBin),
                       StrConcatLoweringFlag("--report-out:", logPath)
                   ],
                   [],
                   root,
                   0,
                   logPath)
    assert(run.exitCode == 0, " str concat call arg ret probe: rc")
    echo(run.text)
    return 0
