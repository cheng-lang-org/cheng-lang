import std/os as os

fn main(): int32 =
    let missingDir: str = "artifacts/os_list_dir_negative_missing"
    if os.DirExists(missingDir):
        os.RemoveDir(missingDir)
    let entries = os.ListDir(missingDir)
    assert(entries.len == 0, "v3 ordinary os.ListDir missing returns empty")
    echo("v3 os_list_dir_negative_smoke ok")
    return 0
