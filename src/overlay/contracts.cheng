import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt
import std/rawbytes

const
    OverlayRoleLeafClient: int32 = 1
    OverlayRoleEdgeRelayStore: int32 = 2
    OverlayRoleRegionalRouter: int32 = 3
    OverlayRoleGlobalAnchor: int32 = 4

    OverlayScopeCell: int32 = 1
    OverlayScopeRegion: int32 = 2
    OverlayScopeGlobal: int32 = 3

    OverlayTrustPermilleMax: int32 = 1000

type
    OverlayNodeRole = int32
    OverlayTopicScope = int32

    CoordHint =
        address: types.LsmrAddress
        confidencePermille: int32
        witnessCount: int32
        rttEwmaMicros: int32

    WitnessProof =
        subjectPeerId: layout.FixedBytes32
        witnessPeerId: layout.FixedBytes32
        address: types.LsmrAddress
        confidencePermille: int32
        stampEpoch: int32
        stampGanzhi: int32

    TrustScoreInput =
        lsmrDistance: int32
        rttEwmaMicros: int32
        lossPermille: int32
        loadPermille: int32
        trustPermille: int32

    IngressEnvelope =
        sourcePeerId: layout.FixedBytes32
        topicScope: OverlayTopicScope = 1
        address: types.LsmrAddress
        payloadKind: int32
        payload: Bytes
        payloadCid: layout.FixedBytes32
        payloadLen: int32
        stampEpoch: int32
        stampGanzhi: int32

    StoreQuery =
        sourcePeerId: layout.FixedBytes32
        topicScope: OverlayTopicScope = 1
        address: types.LsmrAddress
        prefix: lt.PrefixRef
        wantForestCid: layout.FixedBytes32
        wantEventCid: layout.FixedBytes32
        rangeStart: int32
        rangeLimit: int32

    SyncDigest =
        sourcePeerId: layout.FixedBytes32
        topicScope: OverlayTopicScope = 1
        stateForestCid: layout.FixedBytes32
        tipEventCid: layout.FixedBytes32
        stampEpoch: int32
        stampGanzhi: int32
        eventCount: int32
        accountCount: int32

    NeighborCandidate =
        peerId: layout.FixedBytes32
        role: OverlayNodeRole = 1
        coordHint: CoordHint
        scoreInput: TrustScoreInput
        bucketId: int32

fn OverlayClampPermille(value: int32): int32 =
    if value < 0:
        return 0
    if value > OverlayTrustPermilleMax:
        return OverlayTrustPermilleMax
    return value

fn OverlayRoleMayRoute(role: OverlayNodeRole): bool =
    if role == OverlayRoleLeafClient:
        return false
    if role == OverlayRoleEdgeRelayStore:
        return true
    if role == OverlayRoleRegionalRouter:
        return true
    if role == OverlayRoleGlobalAnchor:
        return true
    return false

fn OverlayRoleText(role: OverlayNodeRole): str =
    if role == OverlayRoleLeafClient:
        return "leaf_client"
    if role == OverlayRoleEdgeRelayStore:
        return "edge_relay_store"
    if role == OverlayRoleRegionalRouter:
        return "regional_router"
    if role == OverlayRoleGlobalAnchor:
        return "global_anchor"
    return "unknown"

fn OverlayScopeText(scope: OverlayTopicScope): str =
    if scope == OverlayScopeCell:
        return "cell"
    if scope == OverlayScopeRegion:
        return "region"
    if scope == OverlayScopeGlobal:
        return "global"
    return "unknown"

fn OverlayTrustScore(input: TrustScoreInput): int64 =
    let loss = OverlayClampPermille(input.lossPermille)
    let load = OverlayClampPermille(input.loadPermille)
    let trustPenalty = OverlayTrustPermilleMax - OverlayClampPermille(input.trustPermille)
    return int64(input.lsmrDistance) * int64(1000000) +
        int64(input.rttEwmaMicros) +
        int64(loss) * int64(1000) +
        int64(load) * int64(1000) +
        int64(trustPenalty) * int64(1000)

fn OverlayNeighborEligible(candidate: NeighborCandidate): bool =
    if !OverlayRoleMayRoute(candidate.role):
        return false
    if candidate.coordHint.address.depth <= 0:
        return false
    if candidate.coordHint.confidencePermille <= 0:
        return false
    return true

fn OverlayWitnessFreshEnough(proof: WitnessProof): bool =
    if proof.address.depth <= 0:
        return false
    if proof.stampEpoch <= 0:
        return false
    if proof.stampGanzhi <= 0:
        return false
    if proof.confidencePermille <= 0:
        return false
    return true
