import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as binary
import cheng/chain/lsmr_types as lt
import cheng/chain/pubsub
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content
import cheng/overlay/contracts as overlay
import cheng/libp2p/core/types as core
import cheng/libp2p/host/host
import cheng/libp2p/protocols/gossipsub as gossip

fn Libp2pScoreNeighbor(candidate: overlay.NeighborCandidate): int64 =
    let scoreInput = candidate.scoreInput
    return overlay.OverlayTrustScore(scoreInput)

fn Libp2pSelectNextHop(candidates: overlay.NeighborCandidate[]): Result[core.Libp2pPeerId] =
    var bestScore: int64 = int64(0)
    var found = false
    var bestPeerValue: layout.FixedBytes32
    for i in 0..<candidates.len:
        let candidate = candidates[i]
        if !overlay.OverlayNeighborEligible(candidate):
            continue
        let score = Libp2pScoreNeighbor(candidate)
        if !found || score < bestScore:
            found = true
            bestScore = score
            bestPeerValue = candidate.peerId
    if !found:
        return Err[core.Libp2pPeerId](" overlay libp2p: no eligible next hop")
    let bestPeer = core.Libp2pPeerId(value: bestPeerValue)
    return Ok[core.Libp2pPeerId](bestPeer)

fn Libp2pRelayPublish(hostState: var host.Libp2pHost,
                        ingress: overlay.IngressEnvelope) =
    let sourcePeerId = hostState.selfPeerId
    var pubEntry: gossip.Libp2pPubRecord
    gossip.Libp2pPubRecordFillFromIngress(pubEntry, sourcePeerId, ingress)
    host.Libp2pPublish(hostState, pubEntry)
    host.Libp2pStorePut(hostState, ingress)

fn Libp2pTopicId(scope: overlay.OverlayTopicScope,
                   address: binary.LsmrAddress): core.Libp2pTopicId =
    return gossip.Libp2pTopicForScope(scope, address)

fn Libp2pScopeFromLayerId(layerId: int32): overlay.OverlayTopicScope =
    if layerId == lt.LayerGlobal:
        return overlay.OverlayScopeGlobal
    if layerId == lt.LayerRegional:
        return overlay.OverlayScopeRegion
    return overlay.OverlayScopeCell

fn Libp2pIngressMake(sourcePeerId: core.Libp2pPeerId,
                       scope: overlay.OverlayTopicScope,
                       address: binary.LsmrAddress,
                       payloadKind: int32,
                       payloadCid: layout.FixedBytes32,
                       payload: Bytes,
                       stampEpoch: int32,
                       stampGanzhi: int32): overlay.IngressEnvelope =
    var out = overlay.IngressEnvelope()
    out.sourcePeerId = sourcePeerId.value
    out.topicScope = scope
    out.address = address
    out.payloadKind = payloadKind
    out.payload = payload
    out.payloadCid = payloadCid
    out.payloadLen = bytesLen(payload)
    out.stampEpoch = stampEpoch
    out.stampGanzhi = stampGanzhi
    return out

fn Libp2pRelayPublishContent(hostState: var host.Libp2pHost,
                               artifacts: content.ContentPublishArtifacts): Result[bool] =
    let artifactsOk = content.ContentPublishArtifactsValidate(artifacts)
    if IsErr(artifactsOk):
        return Err[bool](Error(artifactsOk))
    let stubRes = content.ContentStubFromArtifacts(artifacts)
    if IsErr(stubRes):
        return Err[bool](Error(stubRes))
    let stub = Value(stubRes)
    let scope = Libp2pScopeFromLayerId(artifacts.topic.layerId)
    let address = artifacts.topic.centerAddress
    let sourcePeerId = hostState.selfPeerId
    let stampEpoch = artifacts.publishAdvert.stampEpoch
    let stampGanzhi = artifacts.publishAdvert.stampGanzhi
    let manifestPayload = swarm.ErasureShardManifestEncode(artifacts.erasureManifest)
    let manifestPayloadOk = swarm.ErasureShardManifestValidatePayload(manifestPayload,
                                                                        artifacts.erasureManifest.manifestCid)
    if IsErr(manifestPayloadOk):
        return Err[bool](Error(manifestPayloadOk))
    let recoveryPlanPayload = swarm.ErasureRecoveryPlanEncode(artifacts.recoveryPlan)
    let recoveryPlanPayloadOk = swarm.ErasureRecoveryPlanValidatePayload(recoveryPlanPayload,
                                                                           artifacts.recoveryPlan.planCid)
    if IsErr(recoveryPlanPayloadOk):
        return Err[bool](Error(recoveryPlanPayloadOk))

    let stubIngress = Libp2pIngressMake(sourcePeerId,
                                          scope,
                                          address,
                                          pubsub.PubSubPayloadKindContentStub,
                                          stub.stubCid,
                                          content.ContentStubEncode(stub),
                                          stampEpoch,
                                          stampGanzhi)
    let advertIngress = Libp2pIngressMake(sourcePeerId,
                                            scope,
                                            address,
                                            pubsub.PubSubPayloadKindDagAdvert,
                                            artifacts.publishAdvert.advertCid,
                                            dag.DagPublishAdvertEncode(artifacts.publishAdvert),
                                            stampEpoch,
                                            stampGanzhi)
    let manifestIngress = Libp2pIngressMake(sourcePeerId,
                                              scope,
                                              address,
                                              pubsub.PubSubPayloadKindErasureManifest,
                                              artifacts.erasureManifest.manifestCid,
                                              manifestPayload,
                                              stampEpoch,
                                              stampGanzhi)
    let recoveryPlanIngress = Libp2pIngressMake(sourcePeerId,
                                                  scope,
                                                  address,
                                                  pubsub.PubSubPayloadKindErasureRecoveryPlan,
                                                  artifacts.recoveryPlan.planCid,
                                                  recoveryPlanPayload,
                                                  stampEpoch,
                                                  stampGanzhi)

    Libp2pRelayPublish(hostState, stubIngress)
    host.Libp2pStorePut(hostState, advertIngress)
    host.Libp2pStorePut(hostState, manifestIngress)
    host.Libp2pStorePut(hostState, recoveryPlanIngress)
    host.Libp2pKadProvide(hostState, artifacts.bundleCid)
    host.Libp2pKadProvide(hostState, artifacts.blobSummary.blobCid)
    host.Libp2pKadProvide(hostState, artifacts.erasureManifest.manifestCid)
    return Ok[bool](true)
