import std/os
import std/result
import std/strutils as strutil
import cheng/http3/frame as http3
import cheng/quic/connection as qconn
import cheng/hysteria2/hysteria2_protocol as hy2

type
    VpnProxyHy2TcpStream =
        conn: qconn.Connection
        rxBuf: Bytes

const
    VpnProxyHy2AuthStreamId = 4
    VpnProxyHy2TcpStreamFirst = 8
    VpnProxyHy2ClientControlStreamId = 2
    VpnProxyHy2ClientQpackEncoderStreamId = 6
    VpnProxyHy2ClientQpackDecoderStreamId = 10
    VpnProxyHy2ServerControlStreamId = 3
    VpnProxyHy2ServerQpackEncoderStreamId = 7
    VpnProxyHy2ServerQpackDecoderStreamId = 11
    VpnProxyHy2ReadChunkBytes = 4096
    VpnProxyHy2ReadPollMs = 10
    VpnProxyHy2ReadAttempts = 400

fn VpnProxyHy2BytesAppend(dst: var Bytes, extra: Bytes) =
    if bytesLen(extra) <= 0:
        return
    dst = bytesConcat(dst, extra)

fn VpnProxyHy2BytesDropPrefix(data: Bytes, count: int32): Bytes =
    let total: int32 = bytesLen(data)
    var start: int32
    if count > 0:
        if count < total:
            start = count
        else:
            start = total
    return bytesSlice(data, start, total - start)

fn VpnProxyHy2BytesTakePrefix(data: var Bytes, count: int32): Bytes =
    let total: int32 = bytesLen(data)
    if count <= 0:
        var out: Bytes
        out.data = nil
        out.len = 0
        return out
    if total <= 0:
        var out: Bytes
        out.data = nil
        out.len = 0
        return out
    var take: int32 = count
    if take > total:
        take = total
    let out: Bytes = bytesSlice(data, 0, take)
    data = VpnProxyHy2BytesDropPrefix(data, take)
    return out

fn VpnProxyHy2BytesEq(left: Bytes, right: Bytes): bool =
    if bytesLen(left) != bytesLen(right):
        return false
    for i in 0..<bytesLen(left):
        if bytesGet(left, i) != bytesGet(right, i):
            return false
    return true

fn VpnProxyHy2WouldBlock(err: str): bool =
    return err == "msquic udp: queue empty" ||
           err == "pipe: empty" ||
           err == "connection: empty"

fn VpnProxyHy2Partial(err: str): bool =
    return strutil.Contains(err, "truncated")

fn VpnProxyHy2Settings(): http3.Http3Setting[] =
    var out: http3.Http3Setting[]
    add(out, http3.Http3MakeSetting(http3.Http3SettingQpackMaxTableCapacity, 0))
    add(out, http3.Http3MakeSetting(http3.Http3SettingQpackBlockedStreams, 0))
    add(out, http3.Http3MakeSetting(http3.Http3SettingMaxFieldSectionSize, 65535))
    return out

fn VpnProxyHy2Stream(base: qconn.Connection,
                       sendStreamId: int64,
                       recvStreamId: int64): Result[qconn.Connection] =
    return qconn.newNativeConnectionForStreams(base.localAddr,
                                               base.remoteAddr,
                                               base.dir,
                                               base.pipeSide,
                                               sendStreamId,
                                               recvStreamId)

fn VpnProxyHy2ReadExact(conn: var qconn.Connection, count: int32): Result[Bytes] =
    return qconn.connRead(conn, count)

fn VpnProxyHy2ReadHttp3Frame(conn: var qconn.Connection): Result[http3.Http3FrameDecoded] =
    var buf: Bytes
    buf.data = nil
    buf.len = 0
    for _attempt in 0..<VpnProxyHy2ReadAttempts:
        let frameRes: Result[http3.Http3FrameDecoded] = http3.Http3DecodeFrame(buf, 0)
        if IsOk(frameRes):
            return frameRes
        if !VpnProxyHy2Partial(ErrorText(frameRes)):
            return Err[http3.Http3FrameDecoded](ErrorText(frameRes))
        let readRes: Result[Bytes] = qconn.connReadNonblocking(conn, VpnProxyHy2ReadChunkBytes)
        if IsErr(readRes):
            if VpnProxyHy2WouldBlock(ErrorText(readRes)):
                os.SleepMs(VpnProxyHy2ReadPollMs)
                continue
            return Err[http3.Http3FrameDecoded](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) > 0:
            VpnProxyHy2BytesAppend(buf, chunk)
            continue
        os.SleepMs(VpnProxyHy2ReadPollMs)
    return Err[http3.Http3FrameDecoded]("vpn proxy hysteria2: read http3 frame timeout")

fn VpnProxyHy2ReadTcpRequestPrefix(conn: var qconn.Connection): Result[hy2.Hysteria2TcpRequestDecoded] =
    var buf: Bytes
    buf.data = nil
    buf.len = 0
    for _attempt in 0..<VpnProxyHy2ReadAttempts:
        let decodeRes: Result[hy2.Hysteria2TcpRequestDecoded] = hy2.Hysteria2DecodeTcpRequestPrefix(buf)
        if IsOk(decodeRes):
            return decodeRes
        if !VpnProxyHy2Partial(ErrorText(decodeRes)):
            return Err[hy2.Hysteria2TcpRequestDecoded](ErrorText(decodeRes))
        let readRes: Result[Bytes] = qconn.connReadNonblocking(conn, VpnProxyHy2ReadChunkBytes)
        if IsErr(readRes):
            if VpnProxyHy2WouldBlock(ErrorText(readRes)):
                os.SleepMs(VpnProxyHy2ReadPollMs)
                continue
            return Err[hy2.Hysteria2TcpRequestDecoded](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) > 0:
            VpnProxyHy2BytesAppend(buf, chunk)
            continue
        os.SleepMs(VpnProxyHy2ReadPollMs)
    return Err[hy2.Hysteria2TcpRequestDecoded]("vpn proxy hysteria2: read tcp request timeout")

fn VpnProxyHy2ReadTcpResponsePrefix(conn: var qconn.Connection): Result[hy2.Hysteria2TcpResponseDecoded] =
    var buf: Bytes
    buf.data = nil
    buf.len = 0
    for _attempt in 0..<VpnProxyHy2ReadAttempts:
        let decodeRes: Result[hy2.Hysteria2TcpResponseDecoded] = hy2.Hysteria2DecodeTcpResponsePrefix(buf)
        if IsOk(decodeRes):
            return decodeRes
        if !VpnProxyHy2Partial(ErrorText(decodeRes)):
            return Err[hy2.Hysteria2TcpResponseDecoded](ErrorText(decodeRes))
        let readRes: Result[Bytes] = qconn.connReadNonblocking(conn, VpnProxyHy2ReadChunkBytes)
        if IsErr(readRes):
            if VpnProxyHy2WouldBlock(ErrorText(readRes)):
                os.SleepMs(VpnProxyHy2ReadPollMs)
                continue
            return Err[hy2.Hysteria2TcpResponseDecoded](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) > 0:
            VpnProxyHy2BytesAppend(buf, chunk)
            continue
        os.SleepMs(VpnProxyHy2ReadPollMs)
    return Err[hy2.Hysteria2TcpResponseDecoded]("vpn proxy hysteria2: read tcp response timeout")

fn VpnProxyHy2ReadTcpRequestFromStream(stream: var VpnProxyHy2TcpStream): Result[hy2.Hysteria2TcpRequest] =
    for _attempt in 0..<VpnProxyHy2ReadAttempts:
        let decodeRes: Result[hy2.Hysteria2TcpRequestDecoded] = hy2.Hysteria2DecodeTcpRequestPrefix(stream.rxBuf)
        if IsOk(decodeRes):
            let decoded = Value(decodeRes)
            stream.rxBuf = VpnProxyHy2BytesDropPrefix(stream.rxBuf, decoded.next)
            return Ok[hy2.Hysteria2TcpRequest](decoded.req)
        if !VpnProxyHy2Partial(ErrorText(decodeRes)):
            return Err[hy2.Hysteria2TcpRequest](ErrorText(decodeRes))
        let readRes: Result[Bytes] = qconn.connReadNonblocking(stream.conn, VpnProxyHy2ReadChunkBytes)
        if IsErr(readRes):
            if VpnProxyHy2WouldBlock(ErrorText(readRes)):
                os.SleepMs(VpnProxyHy2ReadPollMs)
                continue
            return Err[hy2.Hysteria2TcpRequest](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) > 0:
            VpnProxyHy2BytesAppend(stream.rxBuf, chunk)
            continue
        os.SleepMs(VpnProxyHy2ReadPollMs)
    return Err[hy2.Hysteria2TcpRequest]("vpn proxy hysteria2: read tcp request timeout")

fn VpnProxyHy2ReadTcpResponseFromStream(stream: var VpnProxyHy2TcpStream): Result[hy2.Hysteria2TcpResponse] =
    for _attempt in 0..<VpnProxyHy2ReadAttempts:
        let decodeRes: Result[hy2.Hysteria2TcpResponseDecoded] = hy2.Hysteria2DecodeTcpResponsePrefix(stream.rxBuf)
        if IsOk(decodeRes):
            let decoded = Value(decodeRes)
            stream.rxBuf = VpnProxyHy2BytesDropPrefix(stream.rxBuf, decoded.next)
            return Ok[hy2.Hysteria2TcpResponse](decoded.resp)
        if !VpnProxyHy2Partial(ErrorText(decodeRes)):
            return Err[hy2.Hysteria2TcpResponse](ErrorText(decodeRes))
        let readRes: Result[Bytes] = qconn.connReadNonblocking(stream.conn, VpnProxyHy2ReadChunkBytes)
        if IsErr(readRes):
            if VpnProxyHy2WouldBlock(ErrorText(readRes)):
                os.SleepMs(VpnProxyHy2ReadPollMs)
                continue
            return Err[hy2.Hysteria2TcpResponse](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) > 0:
            VpnProxyHy2BytesAppend(stream.rxBuf, chunk)
            continue
        os.SleepMs(VpnProxyHy2ReadPollMs)
    return Err[hy2.Hysteria2TcpResponse]("vpn proxy hysteria2: read tcp response timeout")

fn VpnProxyHy2SendPreamble(base: qconn.Connection,
                             controlStreamId: int64,
                             encoderStreamId: int64,
                             decoderStreamId: int64): Result[bool] =
    let preambleRes: Result[http3.Http3Preamble] = http3.Http3EncodeClientPreamble(VpnProxyHy2Settings())
    if IsErr(preambleRes):
        return Err[bool](ErrorText(preambleRes))
    let preamble: http3.Http3Preamble = Value(preambleRes)
    let controlConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, controlStreamId, controlStreamId)
    if IsErr(controlConnRes):
        return Err[bool](ErrorText(controlConnRes))
    var controlConn = Value(controlConnRes)
    let encoderConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, encoderStreamId, encoderStreamId)
    if IsErr(encoderConnRes):
        return Err[bool](ErrorText(encoderConnRes))
    var encoderConn = Value(encoderConnRes)
    let decoderConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, decoderStreamId, decoderStreamId)
    if IsErr(decoderConnRes):
        return Err[bool](ErrorText(decoderConnRes))
    var decoderConn = Value(decoderConnRes)
    let controlWriteRes: Result[int32] = qconn.connWrite(controlConn, preamble.control)
    if IsErr(controlWriteRes):
        return Err[bool](ErrorText(controlWriteRes))
    let encoderWriteRes: Result[int32] = qconn.connWrite(encoderConn, preamble.qpackEncoder)
    if IsErr(encoderWriteRes):
        return Err[bool](ErrorText(encoderWriteRes))
    let decoderWriteRes: Result[int32] = qconn.connWrite(decoderConn, preamble.qpackDecoder)
    if IsErr(decoderWriteRes):
        return Err[bool](ErrorText(decoderWriteRes))
    return Ok[bool](true)

fn VpnProxyHy2ExpectPreamble(base: qconn.Connection,
                               controlStreamId: int64,
                               encoderStreamId: int64,
                               decoderStreamId: int64): Result[bool] =
    let preambleRes: Result[http3.Http3Preamble] = http3.Http3EncodeClientPreamble(VpnProxyHy2Settings())
    if IsErr(preambleRes):
        return Err[bool](ErrorText(preambleRes))
    let preamble: http3.Http3Preamble = Value(preambleRes)
    let controlConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, controlStreamId, controlStreamId)
    if IsErr(controlConnRes):
        return Err[bool](ErrorText(controlConnRes))
    var controlConn = Value(controlConnRes)
    let encoderConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, encoderStreamId, encoderStreamId)
    if IsErr(encoderConnRes):
        return Err[bool](ErrorText(encoderConnRes))
    var encoderConn = Value(encoderConnRes)
    let decoderConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, decoderStreamId, decoderStreamId)
    if IsErr(decoderConnRes):
        return Err[bool](ErrorText(decoderConnRes))
    var decoderConn = Value(decoderConnRes)
    let controlReadRes: Result[Bytes] = VpnProxyHy2ReadExact(controlConn, bytesLen(preamble.control))
    if IsErr(controlReadRes):
        return Err[bool](ErrorText(controlReadRes))
    let encoderReadRes: Result[Bytes] = VpnProxyHy2ReadExact(encoderConn, bytesLen(preamble.qpackEncoder))
    if IsErr(encoderReadRes):
        return Err[bool](ErrorText(encoderReadRes))
    let decoderReadRes: Result[Bytes] = VpnProxyHy2ReadExact(decoderConn, bytesLen(preamble.qpackDecoder))
    if IsErr(decoderReadRes):
        return Err[bool](ErrorText(decoderReadRes))
    if !VpnProxyHy2BytesEq(Value(controlReadRes), preamble.control):
        return Err[bool]("vpn proxy hysteria2: control preamble mismatch")
    if !VpnProxyHy2BytesEq(Value(encoderReadRes), preamble.qpackEncoder):
        return Err[bool]("vpn proxy hysteria2: qpack encoder preamble mismatch")
    if !VpnProxyHy2BytesEq(Value(decoderReadRes), preamble.qpackDecoder):
        return Err[bool]("vpn proxy hysteria2: qpack decoder preamble mismatch")
    return Ok[bool](true)

fn VpnProxyHy2ClientSendPreamble(base: qconn.Connection): Result[bool] =
    return VpnProxyHy2SendPreamble(base,
                                     VpnProxyHy2ClientControlStreamId,
                                     VpnProxyHy2ClientQpackEncoderStreamId,
                                     VpnProxyHy2ClientQpackDecoderStreamId)

fn VpnProxyHy2ServerSendPreamble(base: qconn.Connection): Result[bool] =
    return VpnProxyHy2SendPreamble(base,
                                     VpnProxyHy2ServerControlStreamId,
                                     VpnProxyHy2ServerQpackEncoderStreamId,
                                     VpnProxyHy2ServerQpackDecoderStreamId)

fn VpnProxyHy2ServerExpectClientPreamble(base: qconn.Connection): Result[bool] =
    return VpnProxyHy2ExpectPreamble(base,
                                       VpnProxyHy2ClientControlStreamId,
                                       VpnProxyHy2ClientQpackEncoderStreamId,
                                       VpnProxyHy2ClientQpackDecoderStreamId)

fn VpnProxyHy2ClientExpectServerPreamble(base: qconn.Connection): Result[bool] =
    return VpnProxyHy2ExpectPreamble(base,
                                       VpnProxyHy2ServerControlStreamId,
                                       VpnProxyHy2ServerQpackEncoderStreamId,
                                       VpnProxyHy2ServerQpackDecoderStreamId)

fn VpnProxyHy2ClientWriteAuth(base: qconn.Connection,
                                authority: str,
                                auth: str,
                                ccRx: int64,
                                padding: str): Result[bool] =
    let authConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base,
                                                                    VpnProxyHy2AuthStreamId,
                                                                    VpnProxyHy2AuthStreamId)
    if IsErr(authConnRes):
        return Err[bool](ErrorText(authConnRes))
    var authConn = Value(authConnRes)
    let wireRes: Result[Bytes] = hy2.Hysteria2EncodeAuthRequestFrame(hy2.Hysteria2MakeAuthRequest(authority,
                                                                                                       auth,
                                                                                                       ccRx,
                                                                                                       padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(authConn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn VpnProxyHy2ClientReadAuthResponse(base: qconn.Connection): Result[hy2.Hysteria2AuthResponse] =
    let authConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base,
                                                                    VpnProxyHy2AuthStreamId,
                                                                    VpnProxyHy2AuthStreamId)
    if IsErr(authConnRes):
        return Err[hy2.Hysteria2AuthResponse](ErrorText(authConnRes))
    var authConn = Value(authConnRes)
    let frameRes: Result[http3.Http3FrameDecoded] = VpnProxyHy2ReadHttp3Frame(authConn)
    if IsErr(frameRes):
        return Err[hy2.Hysteria2AuthResponse](ErrorText(frameRes))
    let wireBackRes: Result[Bytes] = http3.Http3EncodeFrame(Value(frameRes).frame)
    if IsErr(wireBackRes):
        return Err[hy2.Hysteria2AuthResponse](ErrorText(wireBackRes))
    return hy2.Hysteria2DecodeAuthResponseFrame(Value(wireBackRes))

fn VpnProxyHy2ClientAuth(base: qconn.Connection,
                           authority: str,
                           auth: str,
                           ccRx: int64,
                           padding: str): Result[hy2.Hysteria2AuthResponse] =
    let writeRes: Result[bool] = VpnProxyHy2ClientWriteAuth(base, authority, auth, ccRx, padding)
    if IsErr(writeRes):
        return Err[hy2.Hysteria2AuthResponse](ErrorText(writeRes))
    return VpnProxyHy2ClientReadAuthResponse(base)

fn VpnProxyHy2ServerReadAuth(base: qconn.Connection): Result[hy2.Hysteria2AuthRequest] =
    let authConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base,
                                                                    VpnProxyHy2AuthStreamId,
                                                                    VpnProxyHy2AuthStreamId)
    if IsErr(authConnRes):
        return Err[hy2.Hysteria2AuthRequest](ErrorText(authConnRes))
    var authConn = Value(authConnRes)
    let frameRes: Result[http3.Http3FrameDecoded] = VpnProxyHy2ReadHttp3Frame(authConn)
    if IsErr(frameRes):
        return Err[hy2.Hysteria2AuthRequest](ErrorText(frameRes))
    let wireRes: Result[Bytes] = http3.Http3EncodeFrame(Value(frameRes).frame)
    if IsErr(wireRes):
        return Err[hy2.Hysteria2AuthRequest](ErrorText(wireRes))
    return hy2.Hysteria2DecodeAuthRequestFrame(Value(wireRes))

fn VpnProxyHy2ServerWriteAuthResponse(base: qconn.Connection,
                                        statusCode: int32,
                                        udpEnabled: bool,
                                        ccRxText: str,
                                        padding: str): Result[bool] =
    let authConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base,
                                                                    VpnProxyHy2AuthStreamId,
                                                                    VpnProxyHy2AuthStreamId)
    if IsErr(authConnRes):
        return Err[bool](ErrorText(authConnRes))
    var authConn = Value(authConnRes)
    let wireRes: Result[Bytes] = hy2.Hysteria2EncodeAuthResponseFrame(hy2.Hysteria2MakeAuthResponse(statusCode,
                                                                                                         udpEnabled,
                                                                                                         ccRxText,
                                                                                                         padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(authConn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn VpnProxyHy2ClientWriteTcpRequest(base: qconn.Connection,
                                      streamId: int64,
                                      address: str,
                                      padding: Bytes): Result[bool] =
    let reqConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, streamId, streamId)
    if IsErr(reqConnRes):
        return Err[bool](ErrorText(reqConnRes))
    var reqConn = Value(reqConnRes)
    let wireRes: Result[Bytes] = hy2.Hysteria2EncodeTcpRequest(hy2.Hysteria2MakeTcpRequest(address, padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(reqConn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn VpnProxyHy2ServerReadTcpRequest(base: qconn.Connection,
                                     streamId: int64): Result[hy2.Hysteria2TcpRequestDecoded] =
    let reqConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, streamId, streamId)
    if IsErr(reqConnRes):
        return Err[hy2.Hysteria2TcpRequestDecoded](ErrorText(reqConnRes))
    var reqConn = Value(reqConnRes)
    return VpnProxyHy2ReadTcpRequestPrefix(reqConn)

fn VpnProxyHy2ServerWriteTcpResponse(base: qconn.Connection,
                                       streamId: int64,
                                       ok: bool,
                                       message: str,
                                       padding: Bytes): Result[bool] =
    let reqConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, streamId, streamId)
    if IsErr(reqConnRes):
        return Err[bool](ErrorText(reqConnRes))
    var reqConn = Value(reqConnRes)
    let wireRes: Result[Bytes] = hy2.Hysteria2EncodeTcpResponse(hy2.Hysteria2MakeTcpResponse(ok,
                                                                                                  message,
                                                                                                  padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(reqConn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn VpnProxyHy2ClientReadTcpResponse(base: qconn.Connection,
                                      streamId: int64): Result[hy2.Hysteria2TcpResponseDecoded] =
    let reqConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, streamId, streamId)
    if IsErr(reqConnRes):
        return Err[hy2.Hysteria2TcpResponseDecoded](ErrorText(reqConnRes))
    var reqConn = Value(reqConnRes)
    return VpnProxyHy2ReadTcpResponsePrefix(reqConn)

fn VpnProxyHy2OpenTcpStream(base: qconn.Connection,
                              streamId: int64): Result[VpnProxyHy2TcpStream] =
    let streamConnRes: Result[qconn.Connection] = VpnProxyHy2Stream(base, streamId, streamId)
    if IsErr(streamConnRes):
        return Err[VpnProxyHy2TcpStream](ErrorText(streamConnRes))
    var out: VpnProxyHy2TcpStream
    out.conn = Value(streamConnRes)
    out.rxBuf.data = nil
    out.rxBuf.len = 0
    return Ok[VpnProxyHy2TcpStream](out)

fn VpnProxyHy2TcpStreamWrite(stream: var VpnProxyHy2TcpStream,
                               data: Bytes): Result[int32] =
    return qconn.connWrite(stream.conn, data)

fn VpnProxyHy2TcpStreamReadNonblocking(stream: var VpnProxyHy2TcpStream,
                                         count: int32): Result[Bytes] =
    if count <= 0:
        var out: Bytes
        out.data = nil
        out.len = 0
        return Ok[Bytes](out)
    let buffered: Bytes = VpnProxyHy2BytesTakePrefix(stream.rxBuf, count)
    if bytesLen(buffered) > 0:
        return Ok[Bytes](buffered)
    return qconn.connReadNonblocking(stream.conn, count)

fn VpnProxyHy2TcpStreamShutdownWrite(stream: var VpnProxyHy2TcpStream): Result[bool] =
    return qconn.connShutdownWrite(stream.conn)

fn VpnProxyHy2TcpStreamClose(stream: var VpnProxyHy2TcpStream) =
    qconn.ConnClose(stream.conn)
    stream.rxBuf.data = nil
    stream.rxBuf.len = 0

fn VpnProxyHy2TcpStreamWriteRequest(stream: var VpnProxyHy2TcpStream,
                                      address: str,
                                      padding: Bytes): Result[bool] =
    let wireRes: Result[Bytes] = hy2.Hysteria2EncodeTcpRequest(hy2.Hysteria2MakeTcpRequest(address, padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(stream.conn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn VpnProxyHy2TcpStreamReadRequest(stream: var VpnProxyHy2TcpStream): Result[hy2.Hysteria2TcpRequest] =
    return VpnProxyHy2ReadTcpRequestFromStream(stream)

fn VpnProxyHy2TcpStreamTryReadRequest(stream: var VpnProxyHy2TcpStream,
                                        out: var hy2.Hysteria2TcpRequest): Result[bool] =
    let decodeRes: Result[hy2.Hysteria2TcpRequestDecoded] = hy2.Hysteria2DecodeTcpRequestPrefix(stream.rxBuf)
    if IsOk(decodeRes):
        let decoded = Value(decodeRes)
        stream.rxBuf = VpnProxyHy2BytesDropPrefix(stream.rxBuf, decoded.next)
        out = decoded.req
        return Ok[bool](true)
    if !VpnProxyHy2Partial(ErrorText(decodeRes)):
        return Err[bool](ErrorText(decodeRes))
    let readRes: Result[Bytes] = qconn.connReadNonblocking(stream.conn, VpnProxyHy2ReadChunkBytes)
    if IsErr(readRes):
        if VpnProxyHy2WouldBlock(ErrorText(readRes)):
            return Ok[bool](false)
        return Err[bool](ErrorText(readRes))
    let chunk: Bytes = Value(readRes)
    if bytesLen(chunk) <= 0:
        return Err[bool]("msquic: stream closed")
    VpnProxyHy2BytesAppend(stream.rxBuf, chunk)
    let decodeAfterRes: Result[hy2.Hysteria2TcpRequestDecoded] = hy2.Hysteria2DecodeTcpRequestPrefix(stream.rxBuf)
    if IsOk(decodeAfterRes):
        let decoded = Value(decodeAfterRes)
        stream.rxBuf = VpnProxyHy2BytesDropPrefix(stream.rxBuf, decoded.next)
        out = decoded.req
        return Ok[bool](true)
    if VpnProxyHy2Partial(ErrorText(decodeAfterRes)):
        return Ok[bool](false)
    return Err[bool](ErrorText(decodeAfterRes))

fn VpnProxyHy2TcpStreamWriteResponse(stream: var VpnProxyHy2TcpStream,
                                       ok: bool,
                                       message: str,
                                       padding: Bytes): Result[bool] =
    let wireRes: Result[Bytes] = hy2.Hysteria2EncodeTcpResponse(hy2.Hysteria2MakeTcpResponse(ok,
                                                                                                  message,
                                                                                                  padding))
    if IsErr(wireRes):
        return Err[bool](ErrorText(wireRes))
    let writeRes: Result[int32] = qconn.connWrite(stream.conn, Value(wireRes))
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn VpnProxyHy2TcpStreamReadResponse(stream: var VpnProxyHy2TcpStream): Result[hy2.Hysteria2TcpResponse] =
    return VpnProxyHy2ReadTcpResponseFromStream(stream)
