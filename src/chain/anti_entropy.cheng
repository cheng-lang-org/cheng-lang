import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr as lsmr
import cheng/chain/lsmr_types as lt

fn AntiEntropyStateLayerSummaryEqual(local: lt.StateLayerSummary,
                                       remote: lt.StateLayerSummary): bool =
    if local.layerId != remote.layerId:
        return false
    if !layout.FixedBytes32Equal(local.treeCid, remote.treeCid):
        return false
    if local.nodeCount != remote.nodeCount:
        return false
    if local.entryCount != remote.entryCount:
        return false
    return true

fn AntiEntropyRootSummaryPos(sig: lt.AntiEntropySignature, layerId: int32, baguaId: int32): int32 =
    for i in 0..<sig.rootCount:
        if sig.rootSummaries[i].layerId == layerId:
            if sig.rootSummaries[i].baguaId == baguaId:
                return i
    return -1

fn AntiEntropyLayerSummaryPos(sig: lt.AntiEntropySignature, layerId: int32): int32 =
    for i in 0..<sig.layerCount:
        if sig.layerSummaries[i].layerId == layerId:
            return i
    return -1

fn AntiEntropyLayerSummary(sig: lt.AntiEntropySignature, layerId: int32): Result[lt.StateLayerSummary] =
    let pos = AntiEntropyLayerSummaryPos(sig, layerId)
    if pos < 0:
        return Err[lt.StateLayerSummary](" anti_entropy: missing layer summary")
    return Ok[lt.StateLayerSummary](sig.layerSummaries[pos])

fn AntiEntropyAppendTreeRoots(out: var lt.AntiEntropySignature,
                                layerId: int32,
                                tree: lt.BaguaPrefixTree) =
    for baguaStep in 0..<8:
        let baguaId = baguaStep + 1
        let rootRes = lsmr.BaguaRootSummaryFromTree(layerId, tree, baguaId)
        if rootRes.ok:
            if out.rootCount >= 24:
                panic(" anti_entropy: root summary overflow")
            out.rootSummaries[out.rootCount] = rootRes.value
            out.rootCount = out.rootCount + 1

fn AntiEntropySignatureFromForest(stampEpoch: int32,
                                    stampGanzhi: int32,
                                    eventCount: int32,
                                    accountCount: int32,
                                    forest: lt.StateLayerForest): lt.AntiEntropySignature =
    var out: lt.AntiEntropySignature
    lt.AntiEntropySignatureZeroInto(out)
    out.stampEpoch = stampEpoch
    out.stampGanzhi = stampGanzhi
    out.eventCount = eventCount
    out.accountCount = accountCount
    out.stateForestCid = forest.forestCid
    out.layerCount = 3
    out.layerSummaries[0] = lsmr.StateLayerSummaryFromForest(forest, lt.LayerGlobal)
    out.layerSummaries[1] = lsmr.StateLayerSummaryFromForest(forest, lt.LayerRegional)
    out.layerSummaries[2] = lsmr.StateLayerSummaryFromForest(forest, lt.LayerEdge)
    AntiEntropyAppendTreeRoots(out, lt.LayerGlobal, forest.globalTree)
    AntiEntropyAppendTreeRoots(out, lt.LayerRegional, forest.regionalTree)
    AntiEntropyAppendTreeRoots(out, lt.LayerEdge, forest.edgeTree)
    return out

fn AntiEntropySignatureCid(sig: lt.AntiEntropySignature): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(1024)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.anti_entropy.signature"))
    lt.AppendU32BE(buf, sig.stampEpoch)
    lt.AppendU32BE(buf, sig.stampGanzhi)
    lt.AppendU32BE(buf, sig.eventCount)
    lt.AppendU32BE(buf, sig.accountCount)
    lt.AppendFixed32(buf, sig.stateForestCid)
    lt.AppendU32BE(buf, sig.layerCount)
    for i in 0..<sig.layerCount:
        lt.AppendU32BE(buf, sig.layerSummaries[i].layerId)
        lt.AppendFixed32(buf, sig.layerSummaries[i].treeCid)
        lt.AppendU32BE(buf, sig.layerSummaries[i].nodeCount)
        lt.AppendU32BE(buf, sig.layerSummaries[i].entryCount)
    lt.AppendU32BE(buf, sig.rootCount)
    for i in 0..<sig.rootCount:
        lt.AppendU32BE(buf, sig.rootSummaries[i].layerId)
        lt.AppendU32BE(buf, sig.rootSummaries[i].baguaId)
        lt.AppendFixed32(buf, sig.rootSummaries[i].nodeCid)
        lt.AppendU32BE(buf, sig.rootSummaries[i].entryDescCount)
    return lt.FixedCidFromBuf(buf)

fn AntiEntropySignatureEqual(local: lt.AntiEntropySignature, remote: lt.AntiEntropySignature): bool =
    return layout.FixedBytes32Equal(AntiEntropySignatureCid(local), AntiEntropySignatureCid(remote))

fn PassiveAntiEntropySyncRequired(local: lt.AntiEntropySignature, remote: lt.AntiEntropySignature): bool =
    if AntiEntropySignatureEqual(local, remote):
        return false
    return true

fn AntiEntropyStampCompare(local: lt.AntiEntropySignature, remote: lt.AntiEntropySignature): int32 =
    if local.stampEpoch < remote.stampEpoch:
        return -1
    if local.stampEpoch > remote.stampEpoch:
        return 1
    if local.stampGanzhi < remote.stampGanzhi:
        return -1
    if local.stampGanzhi > remote.stampGanzhi:
        return 1
    return 0

fn AntiEntropyAppendRequest(plan: var lt.AntiEntropyPlan, request: lt.StateSubtreeRef) =
    for i in 0..<plan.requestCount:
        if plan.requests[i].layerId == request.layerId:
            if lt.PrefixRefEqual(plan.requests[i].prefix, request.prefix):
                return
    if plan.requestCount >= 24:
        panic(" anti_entropy: request overflow")
    plan.requests[plan.requestCount] = request
    plan.requestCount = plan.requestCount + 1

fn AntiEntropyWantLayer(remote: lt.AntiEntropySignature, compareLayer: int32): Result[int32] =
    if compareLayer == lt.LayerGlobal:
        let regionalRes = AntiEntropyLayerSummary(remote, lt.LayerRegional)
        if !regionalRes.ok:
            return Err[int32](regionalRes.err.msg)
        if regionalRes.value.entryCount > 0:
            return Ok[int32](lt.LayerRegional)
        return Ok[int32](lt.LayerGlobal)
    if compareLayer == lt.LayerRegional:
        let edgeRes = AntiEntropyLayerSummary(remote, lt.LayerEdge)
        if !edgeRes.ok:
            return Err[int32](edgeRes.err.msg)
        if edgeRes.value.entryCount > 0:
            return Ok[int32](lt.LayerEdge)
        return Ok[int32](lt.LayerRegional)
    return Ok[int32](lt.LayerEdge)

fn AntiEntropyAppendRootMismatchRequests(plan: var lt.AntiEntropyPlan,
                                           local: lt.AntiEntropySignature,
                                           remote: lt.AntiEntropySignature,
                                           compareLayer: int32,
                                           requestLayer: int32): Result[bool] =
    for i in 0..<remote.rootCount:
        let remoteRoot = remote.rootSummaries[i]
        if remoteRoot.layerId == compareLayer:
            let localPos = AntiEntropyRootSummaryPos(local, compareLayer, remoteRoot.baguaId)
            let localMissing = localPos < 0
            var cidMismatch = false
            var countMismatch = false
            if !localMissing:
                if !layout.FixedBytes32Equal(local.rootSummaries[localPos].nodeCid, remoteRoot.nodeCid):
                    cidMismatch = true
                if local.rootSummaries[localPos].entryDescCount != remoteRoot.entryDescCount:
                    countMismatch = true
            if localMissing:
                let prefixRes = lt.PrefixRefFromDigits(remoteRoot.baguaId, [])
                if !prefixRes.ok:
                    return Err[bool](prefixRes.err.msg)
                let request = lt.StateSubtreeRefMake(requestLayer, prefixRes.value, remoteRoot.nodeCid, remoteRoot.entryDescCount)
                AntiEntropyAppendRequest(plan, request)
            elif cidMismatch:
                let prefixRes = lt.PrefixRefFromDigits(remoteRoot.baguaId, [])
                if !prefixRes.ok:
                    return Err[bool](prefixRes.err.msg)
                let request = lt.StateSubtreeRefMake(requestLayer, prefixRes.value, remoteRoot.nodeCid, remoteRoot.entryDescCount)
                AntiEntropyAppendRequest(plan, request)
            elif countMismatch:
                let prefixRes = lt.PrefixRefFromDigits(remoteRoot.baguaId, [])
                if !prefixRes.ok:
                    return Err[bool](prefixRes.err.msg)
                let request = lt.StateSubtreeRefMake(requestLayer, prefixRes.value, remoteRoot.nodeCid, remoteRoot.entryDescCount)
                AntiEntropyAppendRequest(plan, request)
    return Ok[bool](true)

fn AntiEntropyPlan(local: lt.AntiEntropySignature,
                     remote: lt.AntiEntropySignature): Result[lt.AntiEntropyPlan] =
    let localGlobalRes = AntiEntropyLayerSummary(local, lt.LayerGlobal)
    if !localGlobalRes.ok:
        return Err[lt.AntiEntropyPlan](localGlobalRes.err.msg)
    let localRegionalRes = AntiEntropyLayerSummary(local, lt.LayerRegional)
    if !localRegionalRes.ok:
        return Err[lt.AntiEntropyPlan](localRegionalRes.err.msg)
    let localEdgeRes = AntiEntropyLayerSummary(local, lt.LayerEdge)
    if !localEdgeRes.ok:
        return Err[lt.AntiEntropyPlan](localEdgeRes.err.msg)
    let remoteGlobalRes = AntiEntropyLayerSummary(remote, lt.LayerGlobal)
    if !remoteGlobalRes.ok:
        return Err[lt.AntiEntropyPlan](remoteGlobalRes.err.msg)
    let remoteRegionalRes = AntiEntropyLayerSummary(remote, lt.LayerRegional)
    if !remoteRegionalRes.ok:
        return Err[lt.AntiEntropyPlan](remoteRegionalRes.err.msg)
    let remoteEdgeRes = AntiEntropyLayerSummary(remote, lt.LayerEdge)
    if !remoteEdgeRes.ok:
        return Err[lt.AntiEntropyPlan](remoteEdgeRes.err.msg)

    var out: lt.AntiEntropyPlan
    if AntiEntropySignatureEqual(local, remote):
        return Ok[lt.AntiEntropyPlan](out)

    let stampCmp = AntiEntropyStampCompare(local, remote)
    out.remoteNewer = stampCmp < 0
    if stampCmp == 0:
        out.conflictCount = 1
    if !out.remoteNewer:
        if out.conflictCount == 0:
            return Ok[lt.AntiEntropyPlan](out)

    if !AntiEntropyStateLayerSummaryEqual(localGlobalRes.value, remoteGlobalRes.value):
        let wantLayerRes = AntiEntropyWantLayer(remote, lt.LayerGlobal)
        if !wantLayerRes.ok:
            return Err[lt.AntiEntropyPlan](wantLayerRes.err.msg)
        let appendRes = AntiEntropyAppendRootMismatchRequests(out,
                                                               local,
                                                               remote,
                                                               lt.LayerGlobal,
                                                               wantLayerRes.value)
        if !appendRes.ok:
            return Err[lt.AntiEntropyPlan](appendRes.err.msg)
        return Ok[lt.AntiEntropyPlan](out)
    if !AntiEntropyStateLayerSummaryEqual(localRegionalRes.value, remoteRegionalRes.value):
        let wantLayerRes = AntiEntropyWantLayer(remote, lt.LayerRegional)
        if !wantLayerRes.ok:
            return Err[lt.AntiEntropyPlan](wantLayerRes.err.msg)
        let appendRes = AntiEntropyAppendRootMismatchRequests(out,
                                                               local,
                                                               remote,
                                                               lt.LayerRegional,
                                                               wantLayerRes.value)
        if !appendRes.ok:
            return Err[lt.AntiEntropyPlan](appendRes.err.msg)
        return Ok[lt.AntiEntropyPlan](out)
    if !AntiEntropyStateLayerSummaryEqual(localEdgeRes.value, remoteEdgeRes.value):
        let appendRes = AntiEntropyAppendRootMismatchRequests(out,
                                                               local,
                                                               remote,
                                                               lt.LayerEdge,
                                                               lt.LayerEdge)
        if !appendRes.ok:
            return Err[lt.AntiEntropyPlan](appendRes.err.msg)
        return Ok[lt.AntiEntropyPlan](out)
    return Ok[lt.AntiEntropyPlan](out)
