import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import std/strutils as strutil

const
    ChainCodecVersion: int32 = 1
    FrameMagic: int32 = 0x56334631
    FrameHeaderSize: int32 = 96
    LsmrMaxDepth: int32 = 32
    LsmrDigitMin: int32 = 1
    LsmrDigitCenter: int32 = 5
    LsmrDigitMax: int32 = 9
    FrameKindHello: int32 = 1
    FrameKindAdvertise: int32 = 2
    FrameKindWantState: int32 = 3
    FrameKindStateChunk: int32 = 4

type
    FrameKind = int32

    InternedId =
        value: int32

    LsmrAddress =
        depth: int32
        digits: int32[LsmrMaxDepth]

    StateRootSummary =
        stateForestCid: layout.FixedBytes32
        eventRootCid: layout.FixedBytes32
        accountRootCid: layout.FixedBytes32

    FrameHeader =
        magic: int32
        version: int32
        kind: FrameKind
        flags: int32
        payloadLen: int32
        epoch: int32
        ganzhiIndex: int32
        reserved0: int32
        sourcePeerId: layout.FixedBytes32
        bodyCid: layout.FixedBytes32

    Frame =
        header: FrameHeader
        payload: Bytes

    HelloPayload =
        peerId: layout.FixedBytes32
        address: LsmrAddress
        tipEventCid: layout.FixedBytes32
        summary: StateRootSummary

    AdvertisePayload =
        peerId: layout.FixedBytes32
        stateForestCid: layout.FixedBytes32
        eventCid: layout.FixedBytes32
        accountCount: int32
        eventCount: int32
        maxStampEpoch: int32
        maxStampGanzhi: int32

    WantStatePayload =
        peerId: layout.FixedBytes32
        stateForestCid: layout.FixedBytes32
        targetBaguaId: int32
        prefixDepth: int32
        prefixDigits: int32[LsmrMaxDepth]

    StateChunkPayload =
        peerId: layout.FixedBytes32
        stateForestCid: layout.FixedBytes32
        subtreeCid: layout.FixedBytes32
        entryCount: int32
        nodeCount: int32

fn ZeroCid(): layout.FixedBytes32 =
    return layout.FixedBytes32()

fn LsmrDigitOk(digit: int32): bool =
    if digit < LsmrDigitMin:
        return false
    if digit > LsmrDigitMax:
        return false
    return true

fn LsmrAddressFromDigits(digits: int32[]): Result[LsmrAddress] =
    if digits.len > LsmrMaxDepth:
        return Err[LsmrAddress](" chain: address depth overflow")
    var out = LsmrAddress()
    out.depth = digits.len
    for i in 0..<digits.len:
        if !LsmrDigitOk(digits[i]):
            return Err[LsmrAddress](" chain: invalid LSMR digit")
        out.digits[i] = digits[i]
    return Ok[LsmrAddress](out)

fn LsmrAddressEqual(a: var LsmrAddress, b: var LsmrAddress): bool =
    if a.depth != b.depth:
        return false
    for i in 0..<a.depth:
        if a.digits[i] != b.digits[i]:
            return false
    return true

fn LsmrAddressText(addr: LsmrAddress): str =
    var out: str
    for i in 0..<addr.depth:
        if i > 0:
            out = strutil.Join([out, "."], "")
        out = strutil.Join([out, IntToStr(addr.digits[i])], "")
    return out

fn StateRootSummaryMake(stateForestCid: layout.FixedBytes32,
                          eventRootCid: layout.FixedBytes32,
                          accountRootCid: layout.FixedBytes32): StateRootSummary =
    return StateRootSummary(
        stateForestCid: stateForestCid,
        eventRootCid: eventRootCid,
        accountRootCid: accountRootCid
    )

fn FrameHeaderMake(magic: int32,
                     version: int32,
                     kind: FrameKind,
                     flags: int32,
                     payloadLen: int32,
                     epoch: int32,
                     ganzhiIndex: int32,
                     reserved0: int32,
                     sourcePeerId: layout.FixedBytes32,
                     bodyCid: layout.FixedBytes32): FrameHeader =
    return FrameHeader(
        magic: magic,
        version: version,
        kind: kind,
        flags: flags,
        payloadLen: payloadLen,
        epoch: epoch,
        ganzhiIndex: ganzhiIndex,
        reserved0: reserved0,
        sourcePeerId: sourcePeerId,
        bodyCid: bodyCid
    )

fn FrameMake(header: FrameHeader, payload: Bytes): Frame =
    return Frame(header: header, payload: payload)

fn HelloPayloadMake(peerId: layout.FixedBytes32,
                      address: LsmrAddress,
                      tipEventCid: layout.FixedBytes32,
                      summary: StateRootSummary): HelloPayload =
    return HelloPayload(
        peerId: peerId,
        address: address,
        tipEventCid: tipEventCid,
        summary: summary
    )

fn AdvertisePayloadMake(peerId: layout.FixedBytes32,
                          stateForestCid: layout.FixedBytes32,
                          eventCid: layout.FixedBytes32,
                          accountCount: int32,
                          eventCount: int32,
                          maxStampEpoch: int32,
                          maxStampGanzhi: int32): AdvertisePayload =
    return AdvertisePayload(
        peerId: peerId,
        stateForestCid: stateForestCid,
        eventCid: eventCid,
        accountCount: accountCount,
        eventCount: eventCount,
        maxStampEpoch: maxStampEpoch,
        maxStampGanzhi: maxStampGanzhi
    )

fn WantStatePayloadFromDigits(peerId: layout.FixedBytes32,
                                stateForestCid: layout.FixedBytes32,
                                targetBaguaId: int32,
                                prefixDigits: int32[]): Result[WantStatePayload] =
    if !LsmrDigitOk(targetBaguaId):
        return Err[WantStatePayload](" chain: invalid WANT_STATE bagua digit")
    if prefixDigits.len > LsmrMaxDepth:
        return Err[WantStatePayload](" chain: invalid WANT_STATE depth")
    var out: WantStatePayload
    out.peerId = peerId
    out.stateForestCid = stateForestCid
    out.targetBaguaId = targetBaguaId
    out.prefixDepth = prefixDigits.len
    for i in 0..<prefixDigits.len:
        if !LsmrDigitOk(prefixDigits[i]):
            return Err[WantStatePayload](" chain: invalid WANT_STATE digit")
        out.prefixDigits[i] = prefixDigits[i]
    return Ok[WantStatePayload](out)

fn StateChunkPayloadMake(peerId: layout.FixedBytes32,
                           stateForestCid: layout.FixedBytes32,
                           subtreeCid: layout.FixedBytes32,
                           entryCount: int32,
                           nodeCount: int32): StateChunkPayload =
    return StateChunkPayload(
        peerId: peerId,
        stateForestCid: stateForestCid,
        subtreeCid: subtreeCid,
        entryCount: entryCount,
        nodeCount: nodeCount
    )

fn FrameKindText(kind: FrameKind): str =
    if kind == FrameKindHello:
        return "HELLO"
    if kind == FrameKindAdvertise:
        return "ADVERTISE"
    if kind == FrameKindWantState:
        return "WANT_STATE"
    if kind == FrameKindStateChunk:
        return "STATE_CHUNK"
    return "UNKNOWN"
