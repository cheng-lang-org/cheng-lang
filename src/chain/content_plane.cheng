import std/result
import std/rawbytes
import std/crypto/rsa
import cheng/std/bytes_layout as layout
import cheng/chain/codec_binary as codec
import cheng/chain/lsmr_types as lt
import cheng/chain/pubsub
import cheng/chain/dag_mempool as dag
import cheng/chain/plumtree
import cheng/chain/erasure_swarm as swarm
import std/strutils as strutil

const
    ContentStubMagic: str = "cheng.content.stub"
    ContentManifestMagic: str = "cheng.content.manifest"

    ContentAccessPublic: int32 = 1
    ContentAccessPaid: int32 = 2
    ContentAccessRestricted: int32 = 3

type
    ContentStub =
        version: int32 = 1
        topicCid: layout.FixedBytes32
        bundleCid: layout.FixedBytes32
        blobSummaryCid: layout.FixedBytes32
        advertCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        recoveryPlanCid: layout.FixedBytes32
        payloadLen: int32
        stubCid: layout.FixedBytes32

    ContentManifest =
        version: int32 = 1
        postCid: layout.FixedBytes32
        authorId: layout.FixedBytes32
        publishEpoch: int32
        publishGanzhi: int32
        previewCid: layout.FixedBytes32
        manifestRoot: layout.FixedBytes32
        chunkMapRoot: layout.FixedBytes32
        contentCid: layout.FixedBytes32
        accessMode: int32
        priceUnits: int32
        authorModulusLen: int32
        authorModulus: Bytes
        authorExponentLen: int32
        authorExponent: Bytes
        signatureLen: int32
        signature: Bytes
        manifestCid: layout.FixedBytes32

    ContentPublishArtifacts =
        version: int32 = 1
        topic: pubsub.PubSubTopic
        root: pubsub.PubSubSubscription
        subscriptionCount: int32
        subscriptions: pubsub.PubSubSubscription[]
        blobSummary: dag.DagBlobSummary
        availabilityProofCount: int32
        availabilityProofs: dag.DagAvailabilityProof[]
        availabilityCert: dag.DagAvailabilityCert
        publishAdvert: dag.DagPublishAdvert
        envelope: pubsub.PubSubEnvelope
        pubsubPlan: pubsub.PubSubPlan
        plumtreePlan: plumtree.PlumtreePlan
        erasureParams: swarm.ErasureEncodingParams
        erasureManifest: swarm.ErasureShardManifest
        peerAdvertCount: int32
        peerAdverts: swarm.ErasurePeerAdvert[]
        recoveryPlan: swarm.ErasureRecoveryPlan
        bundleCid: layout.FixedBytes32

fn ContentCidSet(value: layout.FixedBytes32): bool =
    return !layout.FixedBytes32Equal(value, layout.FixedBytes32())

fn ContentAccessModeValid(accessMode: int32): bool =
    if accessMode == ContentAccessPublic:
        return true
    if accessMode == ContentAccessPaid:
        return true
    if accessMode == ContentAccessRestricted:
        return true
    return false

fn ContentAuthorId(authorModulus: Bytes, authorExponent: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(224)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.content.author"))
    lt.AppendU32BE(buf, BytesLen(authorModulus))
    layout.ByteBufAppendBytes(buf, authorModulus)
    lt.AppendU32BE(buf, BytesLen(authorExponent))
    layout.ByteBufAppendBytes(buf, authorExponent)
    return lt.FixedCidFromBuf(buf)

fn ContentManifestPostCid(authorId: Bytes,
                            publishEpoch: int32,
                            publishGanzhi: int32,
                            previewCid: Bytes,
                            manifestRoot: Bytes,
                            chunkMapRoot: Bytes,
                            contentCid: Bytes,
                            accessMode: int32,
                            priceUnits: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(224)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.content.post"))
    lt.AppendU32BE(buf, 1)
    layout.ByteBufAppendBytes(buf, authorId)
    lt.AppendU32BE(buf, publishEpoch)
    lt.AppendU32BE(buf, publishGanzhi)
    layout.ByteBufAppendBytes(buf, previewCid)
    layout.ByteBufAppendBytes(buf, manifestRoot)
    layout.ByteBufAppendBytes(buf, chunkMapRoot)
    layout.ByteBufAppendBytes(buf, contentCid)
    lt.AppendU32BE(buf, accessMode)
    lt.AppendU32BE(buf, priceUnits)
    return lt.FixedCidFromBuf(buf)

fn ContentManifestSignableBytes(postCid: Bytes,
                                  authorId: Bytes,
                                  publishEpoch: int32,
                                  publishGanzhi: int32,
                                  previewCid: Bytes,
                                  manifestRoot: Bytes,
                                  chunkMapRoot: Bytes,
                                  contentCid: Bytes,
                                  accessMode: int32,
                                  priceUnits: int32,
                                  authorPublicKey: Bytes): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(320)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.content.manifest.sign"))
    lt.AppendU32BE(buf, 1)
    layout.ByteBufAppendBytes(buf, postCid)
    layout.ByteBufAppendBytes(buf, authorId)
    lt.AppendU32BE(buf, publishEpoch)
    lt.AppendU32BE(buf, publishGanzhi)
    layout.ByteBufAppendBytes(buf, previewCid)
    layout.ByteBufAppendBytes(buf, manifestRoot)
    layout.ByteBufAppendBytes(buf, chunkMapRoot)
    layout.ByteBufAppendBytes(buf, contentCid)
    lt.AppendU32BE(buf, accessMode)
    lt.AppendU32BE(buf, priceUnits)
    lt.AppendU32BE(buf, BytesLen(authorPublicKey))
    layout.ByteBufAppendBytes(buf, authorPublicKey)
    return layout.ByteBufToBytes(buf)

fn ContentManifestCid(postCid: Bytes,
                        authorId: Bytes,
                        publishEpoch: int32,
                        publishGanzhi: int32,
                        previewCid: Bytes,
                        manifestRoot: Bytes,
                        chunkMapRoot: Bytes,
                        contentCid: Bytes,
                        accessMode: int32,
                        priceUnits: int32,
                        authorPublicKey: Bytes,
                        signature: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(448)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.content.manifest.cid"))
    lt.AppendU32BE(buf, 1)
    layout.ByteBufAppendBytes(buf, postCid)
    layout.ByteBufAppendBytes(buf, authorId)
    lt.AppendU32BE(buf, publishEpoch)
    lt.AppendU32BE(buf, publishGanzhi)
    layout.ByteBufAppendBytes(buf, previewCid)
    layout.ByteBufAppendBytes(buf, manifestRoot)
    layout.ByteBufAppendBytes(buf, chunkMapRoot)
    layout.ByteBufAppendBytes(buf, contentCid)
    lt.AppendU32BE(buf, accessMode)
    lt.AppendU32BE(buf, priceUnits)
    lt.AppendU32BE(buf, BytesLen(authorPublicKey))
    layout.ByteBufAppendBytes(buf, authorPublicKey)
    lt.AppendU32BE(buf, BytesLen(signature))
    layout.ByteBufAppendBytes(buf, signature)
    return lt.FixedCidFromBuf(buf)

fn ContentStubCid(topicCid: layout.FixedBytes32,
                    bundleCid: layout.FixedBytes32,
                    blobSummaryCid: layout.FixedBytes32,
                    advertCid: layout.FixedBytes32,
                    manifestCid: layout.FixedBytes32,
                    recoveryPlanCid: layout.FixedBytes32,
                    payloadLen: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.content.stub.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, topicCid)
    lt.AppendFixed32(buf, bundleCid)
    lt.AppendFixed32(buf, blobSummaryCid)
    lt.AppendFixed32(buf, advertCid)
    lt.AppendFixed32(buf, manifestCid)
    lt.AppendFixed32(buf, recoveryPlanCid)
    lt.AppendU32BE(buf, payloadLen)
    return lt.FixedCidFromBuf(buf)

fn ContentStubFill(out: var ContentStub,
                     topicCid: layout.FixedBytes32,
                     bundleCid: layout.FixedBytes32,
                     blobSummaryCid: layout.FixedBytes32,
                     advertCid: layout.FixedBytes32,
                     manifestCid: layout.FixedBytes32,
                     recoveryPlanCid: layout.FixedBytes32,
                     payloadLen: int32): Result[bool] =
    if !ContentCidSet(topicCid):
        return Err[bool](" content plane: missing stub topic cid")
    if !ContentCidSet(bundleCid):
        return Err[bool](" content plane: missing stub bundle cid")
    if !ContentCidSet(blobSummaryCid):
        return Err[bool](" content plane: missing stub blob summary cid")
    if !ContentCidSet(advertCid):
        return Err[bool](" content plane: missing stub advert cid")
    if !ContentCidSet(manifestCid):
        return Err[bool](" content plane: missing stub manifest cid")
    if !ContentCidSet(recoveryPlanCid):
        return Err[bool](" content plane: missing stub recovery plan cid")
    if payloadLen < 0:
        return Err[bool](" content plane: invalid stub payload length")
    out = ContentStub()
    out.topicCid = topicCid
    out.bundleCid = bundleCid
    out.blobSummaryCid = blobSummaryCid
    out.advertCid = advertCid
    out.manifestCid = manifestCid
    out.recoveryPlanCid = recoveryPlanCid
    out.payloadLen = payloadLen
    out.stubCid = ContentStubCid(out.topicCid,
                                   out.bundleCid,
                                   out.blobSummaryCid,
                                   out.advertCid,
                                   out.manifestCid,
                                   out.recoveryPlanCid,
                                   out.payloadLen)
    return Ok[bool](true)

fn ContentStubMake(topicCid: layout.FixedBytes32,
                     bundleCid: layout.FixedBytes32,
                     blobSummaryCid: layout.FixedBytes32,
                     advertCid: layout.FixedBytes32,
                     manifestCid: layout.FixedBytes32,
                     recoveryPlanCid: layout.FixedBytes32,
                     payloadLen: int32): Result[ContentStub] =
    var out: ContentStub
    let fillRes = ContentStubFill(out,
                                    topicCid,
                                    bundleCid,
                                    blobSummaryCid,
                                    advertCid,
                                    manifestCid,
                                    recoveryPlanCid,
                                    payloadLen)
    if IsErr(fillRes):
        return Err[ContentStub](Error(fillRes))
    return Ok[ContentStub](out)

fn ContentStubFromArtifactsFill(out: var ContentStub,
                                  artifacts: ContentPublishArtifacts): Result[bool] =
    let artifactsOk = ContentPublishArtifactsValidate(artifacts)
    if IsErr(artifactsOk):
        return Err[bool](Error(artifactsOk))
    return ContentStubFill(out,
                             artifacts.topic.topicCid,
                             artifacts.bundleCid,
                             artifacts.blobSummary.summaryCid,
                             artifacts.publishAdvert.advertCid,
                             artifacts.erasureManifest.manifestCid,
                             artifacts.recoveryPlan.planCid,
                             artifacts.blobSummary.payloadLen)

fn ContentStubFromArtifacts(artifacts: ContentPublishArtifacts): Result[ContentStub] =
    var out: ContentStub
    let fillRes = ContentStubFromArtifactsFill(out, artifacts)
    if IsErr(fillRes):
        return Err[ContentStub](Error(fillRes))
    return Ok[ContentStub](out)

fn ContentStubValidate(stub: ContentStub): Result[bool] =
    if stub.version != 1:
        return Err[bool](" content plane: unsupported stub version")
    if !ContentCidSet(stub.topicCid):
        return Err[bool](" content plane: missing stub topic cid")
    if !ContentCidSet(stub.bundleCid):
        return Err[bool](" content plane: missing stub bundle cid")
    if !ContentCidSet(stub.blobSummaryCid):
        return Err[bool](" content plane: missing stub blob summary cid")
    if !ContentCidSet(stub.advertCid):
        return Err[bool](" content plane: missing stub advert cid")
    if !ContentCidSet(stub.manifestCid):
        return Err[bool](" content plane: missing stub manifest cid")
    if !ContentCidSet(stub.recoveryPlanCid):
        return Err[bool](" content plane: missing stub recovery plan cid")
    if stub.payloadLen < 0:
        return Err[bool](" content plane: invalid stub payload length")
    let expectedCid = ContentStubCid(stub.topicCid,
                                       stub.bundleCid,
                                       stub.blobSummaryCid,
                                       stub.advertCid,
                                       stub.manifestCid,
                                       stub.recoveryPlanCid,
                                       stub.payloadLen)
    if !layout.FixedBytes32Equal(stub.stubCid, expectedCid):
        return Err[bool](" content plane: stub cid mismatch")
    return Ok[bool](true)

fn ContentPayloadHasMagic(payload: Bytes, magic: str): bool =
    let magicBytes = BytesFromString(magic)
    if BytesLen(payload) < BytesLen(magicBytes):
        return false
    for i in 0..<BytesLen(magicBytes):
        if BytesGet(payload, i) != BytesGet(magicBytes, i):
            return false
    return true

fn ContentStubEncode(stub: ContentStub): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString(ContentStubMagic))
    lt.AppendU32BE(buf, stub.version)
    lt.AppendFixed32(buf, stub.topicCid)
    lt.AppendFixed32(buf, stub.bundleCid)
    lt.AppendFixed32(buf, stub.blobSummaryCid)
    lt.AppendFixed32(buf, stub.advertCid)
    lt.AppendFixed32(buf, stub.manifestCid)
    lt.AppendFixed32(buf, stub.recoveryPlanCid)
    lt.AppendU32BE(buf, stub.payloadLen)
    lt.AppendFixed32(buf, stub.stubCid)
    return layout.ByteBufToBytes(buf)

fn ContentStubDecode(payload: Bytes): Result[ContentStub] =
    if !ContentPayloadHasMagic(payload, ContentStubMagic):
        return Err[ContentStub](" content plane: invalid stub magic")
    let magicLen = BytesLen(BytesFromString(ContentStubMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[ContentStub](Error(versionRes))
    let topicCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(topicCidRes):
        return Err[ContentStub](Error(topicCidRes))
    let bundleCidRes = codec.ReadFixed32(span, magicLen + 36)
    if IsErr(bundleCidRes):
        return Err[ContentStub](Error(bundleCidRes))
    let blobSummaryCidRes = codec.ReadFixed32(span, magicLen + 68)
    if IsErr(blobSummaryCidRes):
        return Err[ContentStub](Error(blobSummaryCidRes))
    let advertCidRes = codec.ReadFixed32(span, magicLen + 100)
    if IsErr(advertCidRes):
        return Err[ContentStub](Error(advertCidRes))
    let manifestCidRes = codec.ReadFixed32(span, magicLen + 132)
    if IsErr(manifestCidRes):
        return Err[ContentStub](Error(manifestCidRes))
    let recoveryPlanCidRes = codec.ReadFixed32(span, magicLen + 164)
    if IsErr(recoveryPlanCidRes):
        return Err[ContentStub](Error(recoveryPlanCidRes))
    let payloadLenRes = codec.ReadU32BE(span, magicLen + 196)
    if IsErr(payloadLenRes):
        return Err[ContentStub](Error(payloadLenRes))
    let stubCidRes = codec.ReadFixed32(span, magicLen + 200)
    if IsErr(stubCidRes):
        return Err[ContentStub](Error(stubCidRes))
    var out = ContentStub()
    out.version = int32(Value(versionRes))
    out.topicCid = Value(topicCidRes)
    out.bundleCid = Value(bundleCidRes)
    out.blobSummaryCid = Value(blobSummaryCidRes)
    out.advertCid = Value(advertCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.recoveryPlanCid = Value(recoveryPlanCidRes)
    out.payloadLen = int32(Value(payloadLenRes))
    out.stubCid = Value(stubCidRes)
    let stubOk = ContentStubValidate(out)
    if IsErr(stubOk):
        return Err[ContentStub](Error(stubOk))
    return Ok[ContentStub](out)

fn ContentManifestValidate(manifest: ContentManifest): Result[bool] =
    if manifest.version != 1:
        return Err[bool](" content plane: unsupported manifest version")
    if !ContentCidSet(manifest.postCid):
        return Err[bool](" content plane: missing manifest post cid")
    if !ContentCidSet(manifest.authorId):
        return Err[bool](" content plane: missing manifest author id")
    if manifest.publishEpoch < 0:
        return Err[bool](" content plane: invalid manifest publish epoch")
    if manifest.publishGanzhi < 0:
        return Err[bool](" content plane: invalid manifest publish ganzhi")
    if !ContentCidSet(manifest.previewCid):
        return Err[bool](" content plane: missing manifest preview cid")
    if !ContentCidSet(manifest.manifestRoot):
        return Err[bool](" content plane: missing manifest root")
    if !ContentCidSet(manifest.chunkMapRoot):
        return Err[bool](" content plane: missing chunk map root")
    if !ContentCidSet(manifest.contentCid):
        return Err[bool](" content plane: missing content cid")
    if !ContentAccessModeValid(manifest.accessMode):
        return Err[bool](" content plane: invalid access mode")
    if manifest.priceUnits < 0:
        return Err[bool](" content plane: invalid price units")
    if manifest.authorModulusLen != BytesLen(manifest.authorModulus):
        return Err[bool](" content plane: author modulus length mismatch")
    if manifest.authorModulusLen <= 0:
        return Err[bool](" content plane: missing author modulus")
    if manifest.authorExponentLen != BytesLen(manifest.authorExponent):
        return Err[bool](" content plane: author exponent length mismatch")
    if manifest.authorExponentLen <= 0:
        return Err[bool](" content plane: missing author exponent")
    if manifest.signatureLen != BytesLen(manifest.signature):
        return Err[bool](" content plane: signature length mismatch")
    if manifest.signatureLen <= 0:
        return Err[bool](" content plane: missing manifest signature")
    if !rsa.validateRsaSignatureBytes(manifest.signature):
        return Err[bool](" content plane: invalid manifest signature")
    if !rsa.rsaPublicKeyPartsValid(manifest.authorModulus, manifest.authorExponent):
        return Err[bool](" content plane: invalid author key parts")
    let authorIdBytes = layout.FixedBytes32ToBytes(manifest.authorId)
    let previewCidBytes = layout.FixedBytes32ToBytes(manifest.previewCid)
    let manifestRootBytes = layout.FixedBytes32ToBytes(manifest.manifestRoot)
    let chunkMapRootBytes = layout.FixedBytes32ToBytes(manifest.chunkMapRoot)
    let contentCidBytes = layout.FixedBytes32ToBytes(manifest.contentCid)
    let expectedAuthorId = ContentAuthorId(manifest.authorModulus, manifest.authorExponent)
    if !layout.FixedBytes32Equal(manifest.authorId, expectedAuthorId):
        return Err[bool](" content plane: author id mismatch")
    var postBuf: layout.ByteBuf = layout.ByteBufInit(224)
    layout.ByteBufAppendBytes(postBuf, BytesFromString("cheng.content.post"))
    lt.AppendU32BE(postBuf, 1)
    layout.ByteBufAppendBytes(postBuf, authorIdBytes)
    lt.AppendU32BE(postBuf, manifest.publishEpoch)
    lt.AppendU32BE(postBuf, manifest.publishGanzhi)
    layout.ByteBufAppendBytes(postBuf, previewCidBytes)
    layout.ByteBufAppendBytes(postBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(postBuf, contentCidBytes)
    lt.AppendU32BE(postBuf, manifest.accessMode)
    lt.AppendU32BE(postBuf, manifest.priceUnits)
    let expectedPostCid = lt.FixedCidFromBuf(postBuf)
    if !layout.FixedBytes32Equal(manifest.postCid, expectedPostCid):
        return Err[bool](" content plane: post cid mismatch")
    let postCidBytes = layout.FixedBytes32ToBytes(manifest.postCid)
    var signBuf: layout.ByteBuf = layout.ByteBufInit(352)
    layout.ByteBufAppendBytes(signBuf, BytesFromString("cheng.content.manifest.sign"))
    lt.AppendU32BE(signBuf, 1)
    layout.ByteBufAppendBytes(signBuf, postCidBytes)
    layout.ByteBufAppendBytes(signBuf, authorIdBytes)
    lt.AppendU32BE(signBuf, manifest.publishEpoch)
    lt.AppendU32BE(signBuf, manifest.publishGanzhi)
    layout.ByteBufAppendBytes(signBuf, previewCidBytes)
    layout.ByteBufAppendBytes(signBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(signBuf, contentCidBytes)
    lt.AppendU32BE(signBuf, manifest.accessMode)
    lt.AppendU32BE(signBuf, manifest.priceUnits)
    lt.AppendU32BE(signBuf, BytesLen(manifest.authorModulus))
    layout.ByteBufAppendBytes(signBuf, manifest.authorModulus)
    lt.AppendU32BE(signBuf, BytesLen(manifest.authorExponent))
    layout.ByteBufAppendBytes(signBuf, manifest.authorExponent)
    let signable = layout.ByteBufToBytes(signBuf)
    let verifyRes = rsa.rsaVerifyPkcs1Bytes(manifest.authorModulus,
                                            manifest.authorExponent,
                                            signable,
                                            manifest.signature,
                                            false)
    if IsErr(verifyRes) || !Value(verifyRes):
        return Err[bool](" content plane: manifest signature mismatch")
    var cidBuf: layout.ByteBuf = layout.ByteBufInit(480 + manifest.signatureLen)
    layout.ByteBufAppendBytes(cidBuf, BytesFromString("cheng.content.manifest.cid"))
    lt.AppendU32BE(cidBuf, 1)
    layout.ByteBufAppendBytes(cidBuf, postCidBytes)
    layout.ByteBufAppendBytes(cidBuf, authorIdBytes)
    lt.AppendU32BE(cidBuf, manifest.publishEpoch)
    lt.AppendU32BE(cidBuf, manifest.publishGanzhi)
    layout.ByteBufAppendBytes(cidBuf, previewCidBytes)
    layout.ByteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(cidBuf, contentCidBytes)
    lt.AppendU32BE(cidBuf, manifest.accessMode)
    lt.AppendU32BE(cidBuf, manifest.priceUnits)
    lt.AppendU32BE(cidBuf, BytesLen(manifest.authorModulus))
    layout.ByteBufAppendBytes(cidBuf, manifest.authorModulus)
    lt.AppendU32BE(cidBuf, BytesLen(manifest.authorExponent))
    layout.ByteBufAppendBytes(cidBuf, manifest.authorExponent)
    lt.AppendU32BE(cidBuf, BytesLen(manifest.signature))
    layout.ByteBufAppendBytes(cidBuf, manifest.signature)
    let expectedCid = lt.FixedCidFromBuf(cidBuf)
    if !layout.FixedBytes32Equal(manifest.manifestCid, expectedCid):
        return Err[bool](" content plane: manifest cid mismatch")
    return Ok[bool](true)

fn ContentManifestMakeFill(out: var ContentManifest,
                             previewCidBytesIn: Bytes,
                             manifestRootBytesIn: Bytes,
                             chunkMapRootBytesIn: Bytes,
                             contentCidBytesIn: Bytes,
                             authorModulus: Bytes,
                             authorExponent: Bytes,
                             authorPrivateKey: Bytes,
                             publishEpoch: int32,
                             publishGanzhi: int32,
                             accessMode: int32,
                             priceUnits: int32): Result[bool] =
    let previewCidRes = layout.FixedBytes32FromBytes(previewCidBytesIn)
    if IsErr(previewCidRes):
        return Err[bool](strutil.Join([" content plane: preview cid bytes: ", Error(previewCidRes)], ""))
    let manifestRootRes = layout.FixedBytes32FromBytes(manifestRootBytesIn)
    if IsErr(manifestRootRes):
        return Err[bool](strutil.Join([" content plane: manifest root bytes: ", Error(manifestRootRes)], ""))
    let chunkMapRootRes = layout.FixedBytes32FromBytes(chunkMapRootBytesIn)
    if IsErr(chunkMapRootRes):
        return Err[bool](strutil.Join([" content plane: chunk map root bytes: ", Error(chunkMapRootRes)], ""))
    let contentCidRes = layout.FixedBytes32FromBytes(contentCidBytesIn)
    if IsErr(contentCidRes):
        return Err[bool](strutil.Join([" content plane: content cid bytes: ", Error(contentCidRes)], ""))
    let previewCid = Value(previewCidRes)
    let manifestRoot = Value(manifestRootRes)
    let chunkMapRoot = Value(chunkMapRootRes)
    let contentCid = Value(contentCidRes)
    if !ContentCidSet(previewCid):
        return Err[bool](" content plane: missing manifest preview cid")
    if !ContentCidSet(manifestRoot):
        return Err[bool](" content plane: missing manifest root")
    if !ContentCidSet(chunkMapRoot):
        return Err[bool](" content plane: missing chunk map root")
    if !ContentCidSet(contentCid):
        return Err[bool](" content plane: missing manifest content cid")
    if publishEpoch < 0:
        return Err[bool](" content plane: invalid manifest publish epoch")
    if publishGanzhi < 0:
        return Err[bool](" content plane: invalid manifest publish ganzhi")
    if !ContentAccessModeValid(accessMode):
        return Err[bool](" content plane: invalid manifest access mode")
    if priceUnits < 0:
        return Err[bool](" content plane: invalid manifest price units")
    let authorModulusLocal = BytesSlice(authorModulus, 0, BytesLen(authorModulus))
    let authorExponentLocal = BytesSlice(authorExponent, 0, BytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        return Err[bool](" content plane: invalid author key parts")
    let authorPrivateKeyLocal = BytesSlice(authorPrivateKey, 0, BytesLen(authorPrivateKey))
    let authorId = ContentAuthorId(authorModulusLocal, authorExponentLocal)
    let authorIdBytes = layout.FixedBytes32ToBytes(authorId)
    let previewCidBytes = layout.FixedBytes32ToBytes(previewCid)
    let manifestRootBytes = layout.FixedBytes32ToBytes(manifestRoot)
    let chunkMapRootBytes = layout.FixedBytes32ToBytes(chunkMapRoot)
    let contentCidBytes = layout.FixedBytes32ToBytes(contentCid)
    var postBuf: layout.ByteBuf = layout.ByteBufInit(224)
    layout.ByteBufAppendBytes(postBuf, BytesFromString("cheng.content.post"))
    lt.AppendU32BE(postBuf, 1)
    layout.ByteBufAppendBytes(postBuf, authorIdBytes)
    lt.AppendU32BE(postBuf, publishEpoch)
    lt.AppendU32BE(postBuf, publishGanzhi)
    layout.ByteBufAppendBytes(postBuf, previewCidBytes)
    layout.ByteBufAppendBytes(postBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(postBuf, contentCidBytes)
    lt.AppendU32BE(postBuf, accessMode)
    lt.AppendU32BE(postBuf, priceUnits)
    let postCid = lt.FixedCidFromBuf(postBuf)
    let postCidBytes = layout.FixedBytes32ToBytes(postCid)
    var signBuf: layout.ByteBuf = layout.ByteBufInit(352)
    layout.ByteBufAppendBytes(signBuf, BytesFromString("cheng.content.manifest.sign"))
    lt.AppendU32BE(signBuf, 1)
    layout.ByteBufAppendBytes(signBuf, postCidBytes)
    layout.ByteBufAppendBytes(signBuf, authorIdBytes)
    lt.AppendU32BE(signBuf, publishEpoch)
    lt.AppendU32BE(signBuf, publishGanzhi)
    layout.ByteBufAppendBytes(signBuf, previewCidBytes)
    layout.ByteBufAppendBytes(signBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(signBuf, contentCidBytes)
    lt.AppendU32BE(signBuf, accessMode)
    lt.AppendU32BE(signBuf, priceUnits)
    lt.AppendU32BE(signBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(signBuf, authorModulusLocal)
    lt.AppendU32BE(signBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.ByteBufToBytes(signBuf)
    let signatureBytesRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureBytesRes):
        return Err[bool](Error(signatureBytesRes))
    let signatureBytesRaw = Value(signatureBytesRes)
    let signatureBytes = BytesSlice(signatureBytesRaw, 0, BytesLen(signatureBytesRaw))
    out = ContentManifest()
    out.postCid = postCid
    out.authorId = authorId
    out.publishEpoch = publishEpoch
    out.publishGanzhi = publishGanzhi
    out.previewCid = previewCid
    out.manifestRoot = manifestRoot
    out.chunkMapRoot = chunkMapRoot
    out.contentCid = contentCid
    out.accessMode = accessMode
    out.priceUnits = priceUnits
    out.authorModulusLen = BytesLen(authorModulusLocal)
    out.authorModulus = authorModulusLocal
    out.authorExponentLen = BytesLen(authorExponentLocal)
    out.authorExponent = authorExponentLocal
    out.signature = signatureBytes
    out.signatureLen = BytesLen(out.signature)
    var cidBuf: layout.ByteBuf = layout.ByteBufInit(480 + out.signatureLen)
    layout.ByteBufAppendBytes(cidBuf, BytesFromString("cheng.content.manifest.cid"))
    lt.AppendU32BE(cidBuf, 1)
    layout.ByteBufAppendBytes(cidBuf, postCidBytes)
    layout.ByteBufAppendBytes(cidBuf, authorIdBytes)
    lt.AppendU32BE(cidBuf, out.publishEpoch)
    lt.AppendU32BE(cidBuf, out.publishGanzhi)
    layout.ByteBufAppendBytes(cidBuf, previewCidBytes)
    layout.ByteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(cidBuf, contentCidBytes)
    lt.AppendU32BE(cidBuf, out.accessMode)
    lt.AppendU32BE(cidBuf, out.priceUnits)
    lt.AppendU32BE(cidBuf, BytesLen(out.authorModulus))
    layout.ByteBufAppendBytes(cidBuf, out.authorModulus)
    lt.AppendU32BE(cidBuf, BytesLen(out.authorExponent))
    layout.ByteBufAppendBytes(cidBuf, out.authorExponent)
    lt.AppendU32BE(cidBuf, BytesLen(out.signature))
    layout.ByteBufAppendBytes(cidBuf, out.signature)
    out.manifestCid = lt.FixedCidFromBuf(cidBuf)
    let manifestOk = ContentManifestValidate(out)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    return Ok[bool](true)

fn ContentManifestMake(previewCidBytesIn: Bytes,
                         manifestRootBytesIn: Bytes,
                         chunkMapRootBytesIn: Bytes,
                         contentCidBytesIn: Bytes,
                         authorModulus: Bytes,
                         authorExponent: Bytes,
                         authorPrivateKey: Bytes,
                         publishEpoch: int32,
                         publishGanzhi: int32,
                         accessMode: int32,
                         priceUnits: int32): Result[ContentManifest] =
    var out: ContentManifest
    let fillRes = ContentManifestMakeFill(out,
                                            previewCidBytesIn,
                                            manifestRootBytesIn,
                                            chunkMapRootBytesIn,
                                            contentCidBytesIn,
                                            authorModulus,
                                            authorExponent,
                                            authorPrivateKey,
                                            publishEpoch,
                                            publishGanzhi,
                                            accessMode,
                                            priceUnits)
    if IsErr(fillRes):
        return Err[ContentManifest](Error(fillRes))
    return Ok[ContentManifest](out)

fn ContentManifestMakeFromFixedFill(out: var ContentManifest,
                                      previewCid: layout.FixedBytes32,
                                      manifestRoot: layout.FixedBytes32,
                                      chunkMapRoot: layout.FixedBytes32,
                                      contentCid: layout.FixedBytes32,
                                      authorModulus: Bytes,
                                      authorExponent: Bytes,
                                      authorPrivateKey: Bytes,
                                      publishEpoch: int32,
                                      publishGanzhi: int32,
                                      accessMode: int32,
                                      priceUnits: int32): Result[bool] =
    if !ContentCidSet(previewCid):
        return Err[bool](" content plane: missing manifest preview cid")
    if !ContentCidSet(manifestRoot):
        return Err[bool](" content plane: missing manifest root")
    if !ContentCidSet(chunkMapRoot):
        return Err[bool](" content plane: missing chunk map root")
    if !ContentCidSet(contentCid):
        return Err[bool](" content plane: missing manifest content cid")
    if publishEpoch < 0:
        return Err[bool](" content plane: invalid manifest publish epoch")
    if publishGanzhi < 0:
        return Err[bool](" content plane: invalid manifest publish ganzhi")
    if !ContentAccessModeValid(accessMode):
        return Err[bool](" content plane: invalid manifest access mode")
    if priceUnits < 0:
        return Err[bool](" content plane: invalid manifest price units")
    let authorModulusLocal = BytesSlice(authorModulus, 0, BytesLen(authorModulus))
    let authorExponentLocal = BytesSlice(authorExponent, 0, BytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        return Err[bool](" content plane: invalid author key parts")
    let authorPrivateKeyLocal = BytesSlice(authorPrivateKey, 0, BytesLen(authorPrivateKey))
    let authorId = ContentAuthorId(authorModulusLocal, authorExponentLocal)
    var authorIdBytes: Bytes
    var previewCidBytes: Bytes
    var manifestRootBytes: Bytes
    var chunkMapRootBytes: Bytes
    var contentCidBytes: Bytes
    var postCidBytes: Bytes
    layout.FixedBytes32ToBytesInto(authorIdBytes, authorId)
    layout.FixedBytes32ToBytesInto(previewCidBytes, previewCid)
    layout.FixedBytes32ToBytesInto(manifestRootBytes, manifestRoot)
    layout.FixedBytes32ToBytesInto(chunkMapRootBytes, chunkMapRoot)
    layout.FixedBytes32ToBytesInto(contentCidBytes, contentCid)
    var postBuf: layout.ByteBuf = layout.ByteBufInit(224)
    layout.ByteBufAppendBytes(postBuf, BytesFromString("cheng.content.post"))
    lt.AppendU32BE(postBuf, 1)
    layout.ByteBufAppendBytes(postBuf, authorIdBytes)
    lt.AppendU32BE(postBuf, publishEpoch)
    lt.AppendU32BE(postBuf, publishGanzhi)
    layout.ByteBufAppendBytes(postBuf, previewCidBytes)
    layout.ByteBufAppendBytes(postBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(postBuf, contentCidBytes)
    lt.AppendU32BE(postBuf, accessMode)
    lt.AppendU32BE(postBuf, priceUnits)
    let postCid = lt.FixedCidFromBuf(postBuf)
    layout.FixedBytes32ToBytesInto(postCidBytes, postCid)
    var signBuf: layout.ByteBuf = layout.ByteBufInit(352)
    layout.ByteBufAppendBytes(signBuf, BytesFromString("cheng.content.manifest.sign"))
    lt.AppendU32BE(signBuf, 1)
    layout.ByteBufAppendBytes(signBuf, postCidBytes)
    layout.ByteBufAppendBytes(signBuf, authorIdBytes)
    lt.AppendU32BE(signBuf, publishEpoch)
    lt.AppendU32BE(signBuf, publishGanzhi)
    layout.ByteBufAppendBytes(signBuf, previewCidBytes)
    layout.ByteBufAppendBytes(signBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(signBuf, contentCidBytes)
    lt.AppendU32BE(signBuf, accessMode)
    lt.AppendU32BE(signBuf, priceUnits)
    lt.AppendU32BE(signBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(signBuf, authorModulusLocal)
    lt.AppendU32BE(signBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.ByteBufToBytes(signBuf)
    let signatureBytesRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureBytesRes):
        return Err[bool](Error(signatureBytesRes))
    let signatureBytesRaw = Value(signatureBytesRes)
    let signatureBytes = BytesSlice(signatureBytesRaw, 0, BytesLen(signatureBytesRaw))
    out = ContentManifest()
    out.postCid = postCid
    out.authorId = authorId
    out.publishEpoch = publishEpoch
    out.publishGanzhi = publishGanzhi
    out.previewCid = previewCid
    out.manifestRoot = manifestRoot
    out.chunkMapRoot = chunkMapRoot
    out.contentCid = contentCid
    out.accessMode = accessMode
    out.priceUnits = priceUnits
    out.authorModulusLen = BytesLen(authorModulusLocal)
    out.authorModulus = authorModulusLocal
    out.authorExponentLen = BytesLen(authorExponentLocal)
    out.authorExponent = authorExponentLocal
    out.signature = signatureBytes
    out.signatureLen = BytesLen(out.signature)
    var cidBuf: layout.ByteBuf = layout.ByteBufInit(480 + out.signatureLen)
    layout.ByteBufAppendBytes(cidBuf, BytesFromString("cheng.content.manifest.cid"))
    lt.AppendU32BE(cidBuf, 1)
    layout.ByteBufAppendBytes(cidBuf, postCidBytes)
    layout.ByteBufAppendBytes(cidBuf, authorIdBytes)
    lt.AppendU32BE(cidBuf, out.publishEpoch)
    lt.AppendU32BE(cidBuf, out.publishGanzhi)
    layout.ByteBufAppendBytes(cidBuf, previewCidBytes)
    layout.ByteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(cidBuf, contentCidBytes)
    lt.AppendU32BE(cidBuf, out.accessMode)
    lt.AppendU32BE(cidBuf, out.priceUnits)
    lt.AppendU32BE(cidBuf, BytesLen(out.authorModulus))
    layout.ByteBufAppendBytes(cidBuf, out.authorModulus)
    lt.AppendU32BE(cidBuf, BytesLen(out.authorExponent))
    layout.ByteBufAppendBytes(cidBuf, out.authorExponent)
    lt.AppendU32BE(cidBuf, BytesLen(out.signature))
    layout.ByteBufAppendBytes(cidBuf, out.signature)
    out.manifestCid = lt.FixedCidFromBuf(cidBuf)
    let manifestOk = ContentManifestValidate(out)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    return Ok[bool](true)

fn ContentManifestPayloadBuildFill(out: var Bytes,
                                     previewCid: layout.FixedBytes32,
                                     manifestRoot: layout.FixedBytes32,
                                     chunkMapRoot: layout.FixedBytes32,
                                     contentCid: layout.FixedBytes32,
                                     authorModulus: Bytes,
                                     authorExponent: Bytes,
                                     authorPrivateKey: Bytes,
                                     publishEpoch: int32,
                                     publishGanzhi: int32,
                                     accessMode: int32,
                                     priceUnits: int32): Result[bool] =
    var previewCidSet = false
    var manifestRootSet = false
    var chunkMapRootSet = false
    var contentCidSet = false
    for i in 0..<layout.FixedBytes32Size:
        if previewCid.data[i] != 0:
            previewCidSet = true
        if manifestRoot.data[i] != 0:
            manifestRootSet = true
        if chunkMapRoot.data[i] != 0:
            chunkMapRootSet = true
        if contentCid.data[i] != 0:
            contentCidSet = true
    if !previewCidSet:
        return Err[bool](" content plane: missing manifest preview cid")
    if !manifestRootSet:
        return Err[bool](" content plane: missing manifest root")
    if !chunkMapRootSet:
        return Err[bool](" content plane: missing chunk map root")
    if !contentCidSet:
        return Err[bool](" content plane: missing manifest content cid")
    if publishEpoch < 0:
        return Err[bool](" content plane: invalid manifest publish epoch")
    if publishGanzhi < 0:
        return Err[bool](" content plane: invalid manifest publish ganzhi")
    if !ContentAccessModeValid(accessMode):
        return Err[bool](" content plane: invalid manifest access mode")
    if priceUnits < 0:
        return Err[bool](" content plane: invalid manifest price units")
    let authorModulusLocal = BytesSlice(authorModulus, 0, BytesLen(authorModulus))
    let authorExponentLocal = BytesSlice(authorExponent, 0, BytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        return Err[bool](" content plane: invalid author key parts")
    let authorPrivateKeyLocal = BytesSlice(authorPrivateKey, 0, BytesLen(authorPrivateKey))
    let authorId = ContentAuthorId(authorModulusLocal, authorExponentLocal)
    var authorIdBytes: Bytes
    var previewCidBytes: Bytes
    var manifestRootBytes: Bytes
    var chunkMapRootBytes: Bytes
    var contentCidBytes: Bytes
    var postCidBytes: Bytes
    authorIdBytes = BytesAlloc(layout.FixedBytes32Size)
    previewCidBytes = BytesAlloc(layout.FixedBytes32Size)
    manifestRootBytes = BytesAlloc(layout.FixedBytes32Size)
    chunkMapRootBytes = BytesAlloc(layout.FixedBytes32Size)
    contentCidBytes = BytesAlloc(layout.FixedBytes32Size)
    for i in 0..<layout.FixedBytes32Size:
        BytesSet(authorIdBytes, i, int32(authorId.data[i]) & 255)
        BytesSet(previewCidBytes, i, int32(previewCid.data[i]) & 255)
        BytesSet(manifestRootBytes, i, int32(manifestRoot.data[i]) & 255)
        BytesSet(chunkMapRootBytes, i, int32(chunkMapRoot.data[i]) & 255)
        BytesSet(contentCidBytes, i, int32(contentCid.data[i]) & 255)
    var postBuf: layout.ByteBuf = layout.ByteBufInit(224)
    layout.ByteBufAppendBytes(postBuf, BytesFromString("cheng.content.post"))
    lt.AppendU32BE(postBuf, 1)
    layout.ByteBufAppendBytes(postBuf, authorIdBytes)
    lt.AppendU32BE(postBuf, publishEpoch)
    lt.AppendU32BE(postBuf, publishGanzhi)
    layout.ByteBufAppendBytes(postBuf, previewCidBytes)
    layout.ByteBufAppendBytes(postBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(postBuf, contentCidBytes)
    lt.AppendU32BE(postBuf, accessMode)
    lt.AppendU32BE(postBuf, priceUnits)
    let postCid = lt.FixedCidFromBuf(postBuf)
    postCidBytes = BytesAlloc(layout.FixedBytes32Size)
    for i in 0..<layout.FixedBytes32Size:
        BytesSet(postCidBytes, i, int32(postCid.data[i]) & 255)
    var signBuf: layout.ByteBuf = layout.ByteBufInit(352)
    layout.ByteBufAppendBytes(signBuf, BytesFromString("cheng.content.manifest.sign"))
    lt.AppendU32BE(signBuf, 1)
    layout.ByteBufAppendBytes(signBuf, postCidBytes)
    layout.ByteBufAppendBytes(signBuf, authorIdBytes)
    lt.AppendU32BE(signBuf, publishEpoch)
    lt.AppendU32BE(signBuf, publishGanzhi)
    layout.ByteBufAppendBytes(signBuf, previewCidBytes)
    layout.ByteBufAppendBytes(signBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(signBuf, contentCidBytes)
    lt.AppendU32BE(signBuf, accessMode)
    lt.AppendU32BE(signBuf, priceUnits)
    lt.AppendU32BE(signBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(signBuf, authorModulusLocal)
    lt.AppendU32BE(signBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.ByteBufToBytes(signBuf)
    let signatureRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureRes):
        return Err[bool](Error(signatureRes))
    let signature = Value(signatureRes)
    var cidBuf: layout.ByteBuf = layout.ByteBufInit(480 + BytesLen(signature))
    layout.ByteBufAppendBytes(cidBuf, BytesFromString("cheng.content.manifest.cid"))
    lt.AppendU32BE(cidBuf, 1)
    layout.ByteBufAppendBytes(cidBuf, postCidBytes)
    layout.ByteBufAppendBytes(cidBuf, authorIdBytes)
    lt.AppendU32BE(cidBuf, publishEpoch)
    lt.AppendU32BE(cidBuf, publishGanzhi)
    layout.ByteBufAppendBytes(cidBuf, previewCidBytes)
    layout.ByteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(cidBuf, contentCidBytes)
    lt.AppendU32BE(cidBuf, accessMode)
    lt.AppendU32BE(cidBuf, priceUnits)
    lt.AppendU32BE(cidBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(cidBuf, authorModulusLocal)
    lt.AppendU32BE(cidBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(cidBuf, authorExponentLocal)
    lt.AppendU32BE(cidBuf, BytesLen(signature))
    layout.ByteBufAppendBytes(cidBuf, signature)
    let manifestCid = lt.FixedCidFromBuf(cidBuf)
    var payloadBuf: layout.ByteBuf = layout.ByteBufInit(
        576 +
        BytesLen(authorModulusLocal) +
        BytesLen(authorExponentLocal) +
        BytesLen(signature)
    )
    layout.ByteBufAppendBytes(payloadBuf, BytesFromString(ContentManifestMagic))
    lt.AppendU32BE(payloadBuf, 1)
    layout.ByteBufAppendBytes(payloadBuf, postCidBytes)
    layout.ByteBufAppendBytes(payloadBuf, authorIdBytes)
    lt.AppendU32BE(payloadBuf, publishEpoch)
    lt.AppendU32BE(payloadBuf, publishGanzhi)
    layout.ByteBufAppendBytes(payloadBuf, previewCidBytes)
    layout.ByteBufAppendBytes(payloadBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(payloadBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(payloadBuf, contentCidBytes)
    lt.AppendU32BE(payloadBuf, accessMode)
    lt.AppendU32BE(payloadBuf, priceUnits)
    lt.AppendU32BE(payloadBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(payloadBuf, authorModulusLocal)
    lt.AppendU32BE(payloadBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(payloadBuf, authorExponentLocal)
    lt.AppendU32BE(payloadBuf, BytesLen(signature))
    layout.ByteBufAppendBytes(payloadBuf, signature)
    var manifestCidBytes: Bytes
    manifestCidBytes = BytesAlloc(layout.FixedBytes32Size)
    for i in 0..<layout.FixedBytes32Size:
        BytesSet(manifestCidBytes, i, int32(manifestCid.data[i]) & 255)
    layout.ByteBufAppendBytes(payloadBuf, manifestCidBytes)
    out = layout.ByteBufToBytes(payloadBuf)
    return Ok[bool](true)

fn ContentManifestPayloadBuild(out: var Bytes,
                                 previewCid: layout.FixedBytes32,
                                 manifestRoot: layout.FixedBytes32,
                                 chunkMapRoot: layout.FixedBytes32,
                                 contentCid: layout.FixedBytes32,
                                 authorModulus: Bytes,
                                 authorExponent: Bytes,
                                 authorPrivateKey: Bytes,
                                 publishEpoch: int32,
                                 publishGanzhi: int32,
                                 accessMode: int32,
                                 priceUnits: int32): bool =
    var previewCidSet = false
    var manifestRootSet = false
    var chunkMapRootSet = false
    var contentCidSet = false
    for i in 0..<layout.FixedBytes32Size:
        if previewCid.data[i] != 0:
            previewCidSet = true
        if manifestRoot.data[i] != 0:
            manifestRootSet = true
        if chunkMapRoot.data[i] != 0:
            chunkMapRootSet = true
        if contentCid.data[i] != 0:
            contentCidSet = true
    if !previewCidSet:
        return false
    if !manifestRootSet:
        return false
    if !chunkMapRootSet:
        return false
    if !contentCidSet:
        return false
    if publishEpoch < 0:
        return false
    if publishGanzhi < 0:
        return false
    if !ContentAccessModeValid(accessMode):
        return false
    if priceUnits < 0:
        return false
    let authorModulusLocal = BytesSlice(authorModulus, 0, BytesLen(authorModulus))
    let authorExponentLocal = BytesSlice(authorExponent, 0, BytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        return false
    let authorPrivateKeyLocal = BytesSlice(authorPrivateKey, 0, BytesLen(authorPrivateKey))
    let authorId = ContentAuthorId(authorModulusLocal, authorExponentLocal)
    var authorIdBytes: Bytes
    var previewCidBytes: Bytes
    var manifestRootBytes: Bytes
    var chunkMapRootBytes: Bytes
    var contentCidBytes: Bytes
    var postCidBytes: Bytes
    authorIdBytes = BytesAlloc(layout.FixedBytes32Size)
    previewCidBytes = BytesAlloc(layout.FixedBytes32Size)
    manifestRootBytes = BytesAlloc(layout.FixedBytes32Size)
    chunkMapRootBytes = BytesAlloc(layout.FixedBytes32Size)
    contentCidBytes = BytesAlloc(layout.FixedBytes32Size)
    for i in 0..<layout.FixedBytes32Size:
        BytesSet(authorIdBytes, i, int32(authorId.data[i]) & 255)
        BytesSet(previewCidBytes, i, int32(previewCid.data[i]) & 255)
        BytesSet(manifestRootBytes, i, int32(manifestRoot.data[i]) & 255)
        BytesSet(chunkMapRootBytes, i, int32(chunkMapRoot.data[i]) & 255)
        BytesSet(contentCidBytes, i, int32(contentCid.data[i]) & 255)
    var postBuf: layout.ByteBuf = layout.ByteBufInit(224)
    layout.ByteBufAppendBytes(postBuf, BytesFromString("cheng.content.post"))
    lt.AppendU32BE(postBuf, 1)
    layout.ByteBufAppendBytes(postBuf, authorIdBytes)
    lt.AppendU32BE(postBuf, publishEpoch)
    lt.AppendU32BE(postBuf, publishGanzhi)
    layout.ByteBufAppendBytes(postBuf, previewCidBytes)
    layout.ByteBufAppendBytes(postBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(postBuf, contentCidBytes)
    lt.AppendU32BE(postBuf, accessMode)
    lt.AppendU32BE(postBuf, priceUnits)
    let postCid = lt.FixedCidFromBuf(postBuf)
    postCidBytes = BytesAlloc(layout.FixedBytes32Size)
    for i in 0..<layout.FixedBytes32Size:
        BytesSet(postCidBytes, i, int32(postCid.data[i]) & 255)
    var signBuf: layout.ByteBuf = layout.ByteBufInit(352)
    layout.ByteBufAppendBytes(signBuf, BytesFromString("cheng.content.manifest.sign"))
    lt.AppendU32BE(signBuf, 1)
    layout.ByteBufAppendBytes(signBuf, postCidBytes)
    layout.ByteBufAppendBytes(signBuf, authorIdBytes)
    lt.AppendU32BE(signBuf, publishEpoch)
    lt.AppendU32BE(signBuf, publishGanzhi)
    layout.ByteBufAppendBytes(signBuf, previewCidBytes)
    layout.ByteBufAppendBytes(signBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(signBuf, contentCidBytes)
    lt.AppendU32BE(signBuf, accessMode)
    lt.AppendU32BE(signBuf, priceUnits)
    lt.AppendU32BE(signBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(signBuf, authorModulusLocal)
    lt.AppendU32BE(signBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.ByteBufToBytes(signBuf)
    let signatureRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureRes):
        return false
    let signature = Value(signatureRes)
    var cidBuf: layout.ByteBuf = layout.ByteBufInit(480 + BytesLen(signature))
    layout.ByteBufAppendBytes(cidBuf, BytesFromString("cheng.content.manifest.cid"))
    lt.AppendU32BE(cidBuf, 1)
    layout.ByteBufAppendBytes(cidBuf, postCidBytes)
    layout.ByteBufAppendBytes(cidBuf, authorIdBytes)
    lt.AppendU32BE(cidBuf, publishEpoch)
    lt.AppendU32BE(cidBuf, publishGanzhi)
    layout.ByteBufAppendBytes(cidBuf, previewCidBytes)
    layout.ByteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(cidBuf, contentCidBytes)
    lt.AppendU32BE(cidBuf, accessMode)
    lt.AppendU32BE(cidBuf, priceUnits)
    lt.AppendU32BE(cidBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(cidBuf, authorModulusLocal)
    lt.AppendU32BE(cidBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(cidBuf, authorExponentLocal)
    lt.AppendU32BE(cidBuf, BytesLen(signature))
    layout.ByteBufAppendBytes(cidBuf, signature)
    let manifestCid = lt.FixedCidFromBuf(cidBuf)
    var payloadBuf: layout.ByteBuf = layout.ByteBufInit(
        576 +
        BytesLen(authorModulusLocal) +
        BytesLen(authorExponentLocal) +
        BytesLen(signature)
    )
    layout.ByteBufAppendBytes(payloadBuf, BytesFromString(ContentManifestMagic))
    lt.AppendU32BE(payloadBuf, 1)
    layout.ByteBufAppendBytes(payloadBuf, postCidBytes)
    layout.ByteBufAppendBytes(payloadBuf, authorIdBytes)
    lt.AppendU32BE(payloadBuf, publishEpoch)
    lt.AppendU32BE(payloadBuf, publishGanzhi)
    layout.ByteBufAppendBytes(payloadBuf, previewCidBytes)
    layout.ByteBufAppendBytes(payloadBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(payloadBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(payloadBuf, contentCidBytes)
    lt.AppendU32BE(payloadBuf, accessMode)
    lt.AppendU32BE(payloadBuf, priceUnits)
    lt.AppendU32BE(payloadBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(payloadBuf, authorModulusLocal)
    lt.AppendU32BE(payloadBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(payloadBuf, authorExponentLocal)
    lt.AppendU32BE(payloadBuf, BytesLen(signature))
    layout.ByteBufAppendBytes(payloadBuf, signature)
    var manifestCidBytes: Bytes
    manifestCidBytes = BytesAlloc(layout.FixedBytes32Size)
    for i in 0..<layout.FixedBytes32Size:
        BytesSet(manifestCidBytes, i, int32(manifestCid.data[i]) & 255)
    layout.ByteBufAppendBytes(payloadBuf, manifestCidBytes)
    out = layout.ByteBufToBytes(payloadBuf)
    return true

fn ContentManifestPayloadMakeFill(out: var Bytes,
                                    previewCidBytesIn: Bytes,
                                    manifestRootBytesIn: Bytes,
                                    chunkMapRootBytesIn: Bytes,
                                    contentCidBytesIn: Bytes,
                                    authorModulus: Bytes,
                                    authorExponent: Bytes,
                                    authorPrivateKey: Bytes,
                                    publishEpoch: int32,
                                    publishGanzhi: int32,
                                    accessMode: int32,
                                    priceUnits: int32): Result[bool] =
    if BytesLen(previewCidBytesIn) != layout.FixedBytes32Size:
        return Err[bool](" content plane: preview cid bytes length")
    if BytesLen(manifestRootBytesIn) != layout.FixedBytes32Size:
        return Err[bool](" content plane: manifest root bytes length")
    if BytesLen(chunkMapRootBytesIn) != layout.FixedBytes32Size:
        return Err[bool](" content plane: chunk map root bytes length")
    if BytesLen(contentCidBytesIn) != layout.FixedBytes32Size:
        return Err[bool](" content plane: content cid bytes length")
    var previewCidSet = false
    var manifestRootSet = false
    var chunkMapRootSet = false
    var contentCidSet = false
    for i in 0..<layout.FixedBytes32Size:
        if BytesGet(previewCidBytesIn, i) != 0:
            previewCidSet = true
        if BytesGet(manifestRootBytesIn, i) != 0:
            manifestRootSet = true
        if BytesGet(chunkMapRootBytesIn, i) != 0:
            chunkMapRootSet = true
        if BytesGet(contentCidBytesIn, i) != 0:
            contentCidSet = true
    if !previewCidSet:
        return Err[bool](" content plane: missing manifest preview cid")
    if !manifestRootSet:
        return Err[bool](" content plane: missing manifest root")
    if !chunkMapRootSet:
        return Err[bool](" content plane: missing chunk map root")
    if !contentCidSet:
        return Err[bool](" content plane: missing manifest content cid")
    if publishEpoch < 0:
        return Err[bool](" content plane: invalid manifest publish epoch")
    if publishGanzhi < 0:
        return Err[bool](" content plane: invalid manifest publish ganzhi")
    if !ContentAccessModeValid(accessMode):
        return Err[bool](" content plane: invalid manifest access mode")
    if priceUnits < 0:
        return Err[bool](" content plane: invalid manifest price units")
    let previewCidBytes = BytesSlice(previewCidBytesIn, 0, BytesLen(previewCidBytesIn))
    let manifestRootBytes = BytesSlice(manifestRootBytesIn, 0, BytesLen(manifestRootBytesIn))
    let chunkMapRootBytes = BytesSlice(chunkMapRootBytesIn, 0, BytesLen(chunkMapRootBytesIn))
    let contentCidBytes = BytesSlice(contentCidBytesIn, 0, BytesLen(contentCidBytesIn))
    let authorModulusLocal = BytesSlice(authorModulus, 0, BytesLen(authorModulus))
    let authorExponentLocal = BytesSlice(authorExponent, 0, BytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        return Err[bool](" content plane: invalid author key parts")
    let authorPrivateKeyLocal = BytesSlice(authorPrivateKey, 0, BytesLen(authorPrivateKey))
    let authorId = ContentAuthorId(authorModulusLocal, authorExponentLocal)
    var authorIdBytes: Bytes
    var postCidBytes: Bytes
    layout.FixedBytes32ToBytesInto(authorIdBytes, authorId)
    var postBuf: layout.ByteBuf = layout.ByteBufInit(224)
    layout.ByteBufAppendBytes(postBuf, BytesFromString("cheng.content.post"))
    lt.AppendU32BE(postBuf, 1)
    layout.ByteBufAppendBytes(postBuf, authorIdBytes)
    lt.AppendU32BE(postBuf, publishEpoch)
    lt.AppendU32BE(postBuf, publishGanzhi)
    layout.ByteBufAppendBytes(postBuf, previewCidBytes)
    layout.ByteBufAppendBytes(postBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(postBuf, contentCidBytes)
    lt.AppendU32BE(postBuf, accessMode)
    lt.AppendU32BE(postBuf, priceUnits)
    let postCid = lt.FixedCidFromBuf(postBuf)
    layout.FixedBytes32ToBytesInto(postCidBytes, postCid)
    var signBuf: layout.ByteBuf = layout.ByteBufInit(352)
    layout.ByteBufAppendBytes(signBuf, BytesFromString("cheng.content.manifest.sign"))
    lt.AppendU32BE(signBuf, 1)
    layout.ByteBufAppendBytes(signBuf, postCidBytes)
    layout.ByteBufAppendBytes(signBuf, authorIdBytes)
    lt.AppendU32BE(signBuf, publishEpoch)
    lt.AppendU32BE(signBuf, publishGanzhi)
    layout.ByteBufAppendBytes(signBuf, previewCidBytes)
    layout.ByteBufAppendBytes(signBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(signBuf, contentCidBytes)
    lt.AppendU32BE(signBuf, accessMode)
    lt.AppendU32BE(signBuf, priceUnits)
    lt.AppendU32BE(signBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(signBuf, authorModulusLocal)
    lt.AppendU32BE(signBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.ByteBufToBytes(signBuf)
    let signatureRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureRes):
        return Err[bool](Error(signatureRes))
    let signature = Value(signatureRes)
    var cidBuf: layout.ByteBuf = layout.ByteBufInit(480 + BytesLen(signature))
    layout.ByteBufAppendBytes(cidBuf, BytesFromString("cheng.content.manifest.cid"))
    lt.AppendU32BE(cidBuf, 1)
    layout.ByteBufAppendBytes(cidBuf, postCidBytes)
    layout.ByteBufAppendBytes(cidBuf, authorIdBytes)
    lt.AppendU32BE(cidBuf, publishEpoch)
    lt.AppendU32BE(cidBuf, publishGanzhi)
    layout.ByteBufAppendBytes(cidBuf, previewCidBytes)
    layout.ByteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(cidBuf, contentCidBytes)
    lt.AppendU32BE(cidBuf, accessMode)
    lt.AppendU32BE(cidBuf, priceUnits)
    lt.AppendU32BE(cidBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(cidBuf, authorModulusLocal)
    lt.AppendU32BE(cidBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(cidBuf, authorExponentLocal)
    lt.AppendU32BE(cidBuf, BytesLen(signature))
    layout.ByteBufAppendBytes(cidBuf, signature)
    let manifestCid = lt.FixedCidFromBuf(cidBuf)
    var manifestCidBytes: Bytes
    layout.FixedBytes32ToBytesInto(manifestCidBytes, manifestCid)
    var payloadBuf: layout.ByteBuf = layout.ByteBufInit(
        576 +
        BytesLen(authorModulusLocal) +
        BytesLen(authorExponentLocal) +
        BytesLen(signature)
    )
    layout.ByteBufAppendBytes(payloadBuf, BytesFromString(ContentManifestMagic))
    lt.AppendU32BE(payloadBuf, 1)
    layout.ByteBufAppendBytes(payloadBuf, postCidBytes)
    layout.ByteBufAppendBytes(payloadBuf, authorIdBytes)
    lt.AppendU32BE(payloadBuf, publishEpoch)
    lt.AppendU32BE(payloadBuf, publishGanzhi)
    layout.ByteBufAppendBytes(payloadBuf, previewCidBytes)
    layout.ByteBufAppendBytes(payloadBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(payloadBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(payloadBuf, contentCidBytes)
    lt.AppendU32BE(payloadBuf, accessMode)
    lt.AppendU32BE(payloadBuf, priceUnits)
    lt.AppendU32BE(payloadBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(payloadBuf, authorModulusLocal)
    lt.AppendU32BE(payloadBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(payloadBuf, authorExponentLocal)
    lt.AppendU32BE(payloadBuf, BytesLen(signature))
    layout.ByteBufAppendBytes(payloadBuf, signature)
    layout.ByteBufAppendBytes(payloadBuf, manifestCidBytes)
    out = layout.ByteBufToBytes(payloadBuf)
    return Ok[bool](true)

fn ContentManifestPayloadMake(previewCidBytesIn: Bytes,
                                manifestRootBytesIn: Bytes,
                                chunkMapRootBytesIn: Bytes,
                                contentCidBytesIn: Bytes,
                                authorModulus: Bytes,
                                authorExponent: Bytes,
                                authorPrivateKey: Bytes,
                                publishEpoch: int32,
                                publishGanzhi: int32,
                                accessMode: int32,
                                priceUnits: int32): Result[Bytes] =
    var out: Bytes
    let fillRes = ContentManifestPayloadMakeFill(out,
                                                   previewCidBytesIn,
                                                   manifestRootBytesIn,
                                                   chunkMapRootBytesIn,
                                                   contentCidBytesIn,
                                                   authorModulus,
                                                   authorExponent,
                                                   authorPrivateKey,
                                                   publishEpoch,
                                                   publishGanzhi,
                                                   accessMode,
                                                   priceUnits)
    if IsErr(fillRes):
        return Err[Bytes](Error(fillRes))
    return Ok[Bytes](out)

fn ContentManifestFromArtifacts(artifacts: ContentPublishArtifacts,
                                  authorModulus: Bytes,
                                  authorExponent: Bytes,
                                  authorPrivateKey: Bytes,
                                  publishEpoch: int32,
                                  publishGanzhi: int32,
                                  accessMode: int32,
                                  priceUnits: int32): Result[ContentManifest] =
    let artifactsOk = ContentPublishArtifactsValidate(artifacts)
    if IsErr(artifactsOk):
        return Err[ContentManifest](Error(artifactsOk))
    var previewCidBytes: Bytes
    var manifestRootBytes: Bytes
    var chunkMapRootBytes: Bytes
    var contentCidBytes: Bytes
    layout.FixedBytes32ToBytesInto(previewCidBytes, artifacts.blobSummary.summaryCid)
    layout.FixedBytes32ToBytesInto(manifestRootBytes, artifacts.bundleCid)
    layout.FixedBytes32ToBytesInto(chunkMapRootBytes, artifacts.erasureManifest.manifestCid)
    layout.FixedBytes32ToBytesInto(contentCidBytes, artifacts.blobSummary.blobCid)
    return ContentManifestMake(previewCidBytes,
                                 manifestRootBytes,
                                 chunkMapRootBytes,
                                 contentCidBytes,
                                 authorModulus,
                                 authorExponent,
                                 authorPrivateKey,
                                 publishEpoch,
                                 publishGanzhi,
                                 accessMode,
                                 priceUnits)

fn ContentManifestPayloadFromStubFill(out: var Bytes,
                                        stub: ContentStub,
                                        contentCid: layout.FixedBytes32,
                                        authorModulus: Bytes,
                                        authorExponent: Bytes,
                                        authorPrivateKey: Bytes,
                                        publishEpoch: int32,
                                        publishGanzhi: int32,
                                        accessMode: int32,
                                        priceUnits: int32): Result[bool] =
    let stubOk = ContentStubValidate(stub)
    if IsErr(stubOk):
        return Err[bool](Error(stubOk))
    if !ContentCidSet(contentCid):
        return Err[bool](" content plane: missing manifest content cid")
    return ContentManifestPayloadBuildFill(out,
                                             stub.blobSummaryCid,
                                             stub.bundleCid,
                                             stub.manifestCid,
                                             contentCid,
                                             authorModulus,
                                             authorExponent,
                                             authorPrivateKey,
                                             publishEpoch,
                                             publishGanzhi,
                                             accessMode,
                                             priceUnits)

fn ContentManifestPayloadFromStub(stub: ContentStub,
                                    contentCid: layout.FixedBytes32,
                                    authorModulus: Bytes,
                                    authorExponent: Bytes,
                                    authorPrivateKey: Bytes,
                                    publishEpoch: int32,
                                    publishGanzhi: int32,
                                    accessMode: int32,
                                    priceUnits: int32): Result[Bytes] =
    var out: Bytes
    let fillRes = ContentManifestPayloadFromStubFill(out,
                                                       stub,
                                                       contentCid,
                                                       authorModulus,
                                                       authorExponent,
                                                       authorPrivateKey,
                                                       publishEpoch,
                                                       publishGanzhi,
                                                       accessMode,
                                                       priceUnits)
    if IsErr(fillRes):
        return Err[Bytes](Error(fillRes))
    return Ok[Bytes](out)

fn ContentManifestPayloadFromStubFieldsFill(out: var Bytes,
                                              topicCid: layout.FixedBytes32,
                                              bundleCid: layout.FixedBytes32,
                                              blobSummaryCid: layout.FixedBytes32,
                                              advertCid: layout.FixedBytes32,
                                              manifestCid: layout.FixedBytes32,
                                              recoveryPlanCid: layout.FixedBytes32,
                                              payloadLen: int32,
                                              contentCid: layout.FixedBytes32,
                                              authorModulus: Bytes,
                                              authorExponent: Bytes,
                                              authorPrivateKey: Bytes,
                                              publishEpoch: int32,
                                              publishGanzhi: int32,
                                              accessMode: int32,
                                              priceUnits: int32): Result[bool] =
    var stub: ContentStub
    let stubRes = ContentStubFill(stub,
                                    topicCid,
                                    bundleCid,
                                    blobSummaryCid,
                                    advertCid,
                                    manifestCid,
                                    recoveryPlanCid,
                                    payloadLen)
    if IsErr(stubRes):
        return Err[bool](Error(stubRes))
    return ContentManifestPayloadFromStubFill(out,
                                                stub,
                                                contentCid,
                                                authorModulus,
                                                authorExponent,
                                                authorPrivateKey,
                                                publishEpoch,
                                                publishGanzhi,
                                                accessMode,
                                                priceUnits)

fn ContentManifestPayloadFromStubFields(topicCid: layout.FixedBytes32,
                                          bundleCid: layout.FixedBytes32,
                                          blobSummaryCid: layout.FixedBytes32,
                                          advertCid: layout.FixedBytes32,
                                          manifestCid: layout.FixedBytes32,
                                          recoveryPlanCid: layout.FixedBytes32,
                                          payloadLen: int32,
                                          contentCid: layout.FixedBytes32,
                                          authorModulus: Bytes,
                                          authorExponent: Bytes,
                                          authorPrivateKey: Bytes,
                                          publishEpoch: int32,
                                          publishGanzhi: int32,
                                          accessMode: int32,
                                          priceUnits: int32): Result[Bytes] =
    var out: Bytes
    let fillRes = ContentManifestPayloadFromStubFieldsFill(out,
                                                             topicCid,
                                                             bundleCid,
                                                             blobSummaryCid,
                                                             advertCid,
                                                             manifestCid,
                                                             recoveryPlanCid,
                                                             payloadLen,
                                                             contentCid,
                                                             authorModulus,
                                                             authorExponent,
                                                             authorPrivateKey,
                                                             publishEpoch,
                                                             publishGanzhi,
                                                             accessMode,
                                                             priceUnits)
    if IsErr(fillRes):
        return Err[Bytes](Error(fillRes))
    return Ok[Bytes](out)

fn ContentManifestPayloadFromStubFieldsBuild(out: var Bytes,
                                               topicCid: layout.FixedBytes32,
                                               bundleCid: layout.FixedBytes32,
                                               blobSummaryCid: layout.FixedBytes32,
                                               advertCid: layout.FixedBytes32,
                                               manifestCid: layout.FixedBytes32,
                                               recoveryPlanCid: layout.FixedBytes32,
                                               payloadLen: int32,
                                               contentCid: layout.FixedBytes32,
                                               authorModulus: Bytes,
                                               authorExponent: Bytes,
                                               authorPrivateKey: Bytes,
                                               publishEpoch: int32,
                                               publishGanzhi: int32,
                                               accessMode: int32,
                                               priceUnits: int32): bool =
    if !ContentCidSet(topicCid):
        return false
    if !ContentCidSet(bundleCid):
        return false
    if !ContentCidSet(blobSummaryCid):
        return false
    if !ContentCidSet(advertCid):
        return false
    if !ContentCidSet(manifestCid):
        return false
    if !ContentCidSet(recoveryPlanCid):
        return false
    if payloadLen < 0:
        return false
    return ContentManifestPayloadBuild(out,
                                         blobSummaryCid,
                                         bundleCid,
                                         manifestCid,
                                         contentCid,
                                         authorModulus,
                                         authorExponent,
                                         authorPrivateKey,
                                         publishEpoch,
                                         publishGanzhi,
                                         accessMode,
                                         priceUnits)

fn ContentManifestPayloadFromStubFieldsMustFill(out: var Bytes,
                                                  topicCid: layout.FixedBytes32,
                                                  bundleCid: layout.FixedBytes32,
                                                  blobSummaryCid: layout.FixedBytes32,
                                                  advertCid: layout.FixedBytes32,
                                                  manifestCid: layout.FixedBytes32,
                                                  recoveryPlanCid: layout.FixedBytes32,
                                                  payloadLen: int32,
                                                  contentCid: layout.FixedBytes32,
                                                  authorModulus: Bytes,
                                                  authorExponent: Bytes,
                                                  authorPrivateKey: Bytes,
                                                  publishEpoch: int32,
                                                  publishGanzhi: int32,
                                                  accessMode: int32,
                                                  priceUnits: int32) =
    if !ContentCidSet(topicCid):
        Panic(" content plane: missing stub topic cid")
    if !ContentCidSet(bundleCid):
        Panic(" content plane: missing stub bundle cid")
    if !ContentCidSet(blobSummaryCid):
        Panic(" content plane: missing stub blob summary cid")
    if !ContentCidSet(advertCid):
        Panic(" content plane: missing stub advert cid")
    if !ContentCidSet(manifestCid):
        Panic(" content plane: missing stub manifest cid")
    if !ContentCidSet(recoveryPlanCid):
        Panic(" content plane: missing stub recovery plan cid")
    if payloadLen < 0:
        Panic(" content plane: invalid stub payload length")
    if !ContentCidSet(contentCid):
        Panic(" content plane: missing manifest content cid")
    if publishEpoch < 0:
        Panic(" content plane: invalid manifest publish epoch")
    if publishGanzhi < 0:
        Panic(" content plane: invalid manifest publish ganzhi")
    if !ContentAccessModeValid(accessMode):
        Panic(" content plane: invalid manifest access mode")
    if priceUnits < 0:
        Panic(" content plane: invalid manifest price units")
    let authorModulusLocal = BytesSlice(authorModulus, 0, BytesLen(authorModulus))
    let authorExponentLocal = BytesSlice(authorExponent, 0, BytesLen(authorExponent))
    if !rsa.rsaPublicKeyPartsValid(authorModulusLocal, authorExponentLocal):
        Panic(" content plane: invalid author key parts")
    let authorPrivateKeyLocal = BytesSlice(authorPrivateKey, 0, BytesLen(authorPrivateKey))
    let authorId = ContentAuthorId(authorModulusLocal, authorExponentLocal)
    var authorIdBytes: Bytes
    var previewCidBytes: Bytes
    var manifestRootBytes: Bytes
    var chunkMapRootBytes: Bytes
    var contentCidBytes: Bytes
    var postCidBytes: Bytes
    authorIdBytes = BytesAlloc(layout.FixedBytes32Size)
    previewCidBytes = BytesAlloc(layout.FixedBytes32Size)
    manifestRootBytes = BytesAlloc(layout.FixedBytes32Size)
    chunkMapRootBytes = BytesAlloc(layout.FixedBytes32Size)
    contentCidBytes = BytesAlloc(layout.FixedBytes32Size)
    for i in 0..<layout.FixedBytes32Size:
        BytesSet(authorIdBytes, i, int32(authorId.data[i]) & 255)
        BytesSet(previewCidBytes, i, int32(blobSummaryCid.data[i]) & 255)
        BytesSet(manifestRootBytes, i, int32(bundleCid.data[i]) & 255)
        BytesSet(chunkMapRootBytes, i, int32(manifestCid.data[i]) & 255)
        BytesSet(contentCidBytes, i, int32(contentCid.data[i]) & 255)
    var postBuf: layout.ByteBuf = layout.ByteBufInit(224)
    layout.ByteBufAppendBytes(postBuf, BytesFromString("cheng.content.post"))
    lt.AppendU32BE(postBuf, 1)
    layout.ByteBufAppendBytes(postBuf, authorIdBytes)
    lt.AppendU32BE(postBuf, publishEpoch)
    lt.AppendU32BE(postBuf, publishGanzhi)
    layout.ByteBufAppendBytes(postBuf, previewCidBytes)
    layout.ByteBufAppendBytes(postBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(postBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(postBuf, contentCidBytes)
    lt.AppendU32BE(postBuf, accessMode)
    lt.AppendU32BE(postBuf, priceUnits)
    let postCid = lt.FixedCidFromBuf(postBuf)
    postCidBytes = BytesAlloc(layout.FixedBytes32Size)
    for i in 0..<layout.FixedBytes32Size:
        BytesSet(postCidBytes, i, int32(postCid.data[i]) & 255)
    var signBuf: layout.ByteBuf = layout.ByteBufInit(352)
    layout.ByteBufAppendBytes(signBuf, BytesFromString("cheng.content.manifest.sign"))
    lt.AppendU32BE(signBuf, 1)
    layout.ByteBufAppendBytes(signBuf, postCidBytes)
    layout.ByteBufAppendBytes(signBuf, authorIdBytes)
    lt.AppendU32BE(signBuf, publishEpoch)
    lt.AppendU32BE(signBuf, publishGanzhi)
    layout.ByteBufAppendBytes(signBuf, previewCidBytes)
    layout.ByteBufAppendBytes(signBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(signBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(signBuf, contentCidBytes)
    lt.AppendU32BE(signBuf, accessMode)
    lt.AppendU32BE(signBuf, priceUnits)
    lt.AppendU32BE(signBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(signBuf, authorModulusLocal)
    lt.AppendU32BE(signBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(signBuf, authorExponentLocal)
    let signable = layout.ByteBufToBytes(signBuf)
    let signatureRes = rsa.rsaBigSignPkcs1Bytes(authorPrivateKeyLocal, signable, false)
    if IsErr(signatureRes):
        Panic(" content plane: manifest signature failed")
    let signature = Value(signatureRes)
    var cidBuf: layout.ByteBuf = layout.ByteBufInit(480 + BytesLen(signature))
    layout.ByteBufAppendBytes(cidBuf, BytesFromString("cheng.content.manifest.cid"))
    lt.AppendU32BE(cidBuf, 1)
    layout.ByteBufAppendBytes(cidBuf, postCidBytes)
    layout.ByteBufAppendBytes(cidBuf, authorIdBytes)
    lt.AppendU32BE(cidBuf, publishEpoch)
    lt.AppendU32BE(cidBuf, publishGanzhi)
    layout.ByteBufAppendBytes(cidBuf, previewCidBytes)
    layout.ByteBufAppendBytes(cidBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(cidBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(cidBuf, contentCidBytes)
    lt.AppendU32BE(cidBuf, accessMode)
    lt.AppendU32BE(cidBuf, priceUnits)
    lt.AppendU32BE(cidBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(cidBuf, authorModulusLocal)
    lt.AppendU32BE(cidBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(cidBuf, authorExponentLocal)
    lt.AppendU32BE(cidBuf, BytesLen(signature))
    layout.ByteBufAppendBytes(cidBuf, signature)
    let manifestCidOut = lt.FixedCidFromBuf(cidBuf)
    var payloadBuf: layout.ByteBuf = layout.ByteBufInit(
        576 +
        BytesLen(authorModulusLocal) +
        BytesLen(authorExponentLocal) +
        BytesLen(signature)
    )
    layout.ByteBufAppendBytes(payloadBuf, BytesFromString(ContentManifestMagic))
    lt.AppendU32BE(payloadBuf, 1)
    layout.ByteBufAppendBytes(payloadBuf, postCidBytes)
    layout.ByteBufAppendBytes(payloadBuf, authorIdBytes)
    lt.AppendU32BE(payloadBuf, publishEpoch)
    lt.AppendU32BE(payloadBuf, publishGanzhi)
    layout.ByteBufAppendBytes(payloadBuf, previewCidBytes)
    layout.ByteBufAppendBytes(payloadBuf, manifestRootBytes)
    layout.ByteBufAppendBytes(payloadBuf, chunkMapRootBytes)
    layout.ByteBufAppendBytes(payloadBuf, contentCidBytes)
    lt.AppendU32BE(payloadBuf, accessMode)
    lt.AppendU32BE(payloadBuf, priceUnits)
    lt.AppendU32BE(payloadBuf, BytesLen(authorModulusLocal))
    layout.ByteBufAppendBytes(payloadBuf, authorModulusLocal)
    lt.AppendU32BE(payloadBuf, BytesLen(authorExponentLocal))
    layout.ByteBufAppendBytes(payloadBuf, authorExponentLocal)
    lt.AppendU32BE(payloadBuf, BytesLen(signature))
    layout.ByteBufAppendBytes(payloadBuf, signature)
    var manifestCidBytes: Bytes
    manifestCidBytes = BytesAlloc(layout.FixedBytes32Size)
    for i in 0..<layout.FixedBytes32Size:
        BytesSet(manifestCidBytes, i, int32(manifestCidOut.data[i]) & 255)
    layout.ByteBufAppendBytes(payloadBuf, manifestCidBytes)
    out = layout.ByteBufToBytes(payloadBuf)

fn ContentManifestEncode(manifest: ContentManifest): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(
        576 +
        manifest.authorModulusLen +
        manifest.authorExponentLen +
        manifest.signatureLen
    )
    layout.ByteBufAppendBytes(buf, BytesFromString(ContentManifestMagic))
    lt.AppendU32BE(buf, manifest.version)
    lt.AppendFixed32(buf, manifest.postCid)
    lt.AppendFixed32(buf, manifest.authorId)
    lt.AppendU32BE(buf, manifest.publishEpoch)
    lt.AppendU32BE(buf, manifest.publishGanzhi)
    lt.AppendFixed32(buf, manifest.previewCid)
    lt.AppendFixed32(buf, manifest.manifestRoot)
    lt.AppendFixed32(buf, manifest.chunkMapRoot)
    lt.AppendFixed32(buf, manifest.contentCid)
    lt.AppendU32BE(buf, manifest.accessMode)
    lt.AppendU32BE(buf, manifest.priceUnits)
    lt.AppendU32BE(buf, manifest.authorModulusLen)
    layout.ByteBufAppendBytes(buf, manifest.authorModulus)
    lt.AppendU32BE(buf, manifest.authorExponentLen)
    layout.ByteBufAppendBytes(buf, manifest.authorExponent)
    lt.AppendU32BE(buf, manifest.signatureLen)
    layout.ByteBufAppendBytes(buf, manifest.signature)
    lt.AppendFixed32(buf, manifest.manifestCid)
    return layout.ByteBufToBytes(buf)

fn ContentManifestDecodeFill(out: var ContentManifest,
                               payload: Bytes): Result[bool] =
    if !ContentPayloadHasMagic(payload, ContentManifestMagic):
        return Err[bool](" content plane: invalid manifest magic")
    let magicLen = BytesLen(BytesFromString(ContentManifestMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[bool](Error(versionRes))
    let postCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(postCidRes):
        return Err[bool](Error(postCidRes))
    let authorIdRes = codec.ReadFixed32(span, magicLen + 36)
    if IsErr(authorIdRes):
        return Err[bool](Error(authorIdRes))
    let publishEpochRes = codec.ReadU32BE(span, magicLen + 68)
    if IsErr(publishEpochRes):
        return Err[bool](Error(publishEpochRes))
    let publishGanzhiRes = codec.ReadU32BE(span, magicLen + 72)
    if IsErr(publishGanzhiRes):
        return Err[bool](Error(publishGanzhiRes))
    let previewCidRes = codec.ReadFixed32(span, magicLen + 76)
    if IsErr(previewCidRes):
        return Err[bool](Error(previewCidRes))
    let manifestRootRes = codec.ReadFixed32(span, magicLen + 108)
    if IsErr(manifestRootRes):
        return Err[bool](Error(manifestRootRes))
    let chunkMapRootRes = codec.ReadFixed32(span, magicLen + 140)
    if IsErr(chunkMapRootRes):
        return Err[bool](Error(chunkMapRootRes))
    let contentCidRes = codec.ReadFixed32(span, magicLen + 172)
    if IsErr(contentCidRes):
        return Err[bool](Error(contentCidRes))
    let accessModeRes = codec.ReadU32BE(span, magicLen + 204)
    if IsErr(accessModeRes):
        return Err[bool](Error(accessModeRes))
    let priceUnitsRes = codec.ReadU32BE(span, magicLen + 208)
    if IsErr(priceUnitsRes):
        return Err[bool](Error(priceUnitsRes))
    let authorModulusLenRes = codec.ReadU32BE(span, magicLen + 212)
    if IsErr(authorModulusLenRes):
        return Err[bool](Error(authorModulusLenRes))
    let authorModulusLen = int32(Value(authorModulusLenRes))
    if authorModulusLen <= 0:
        return Err[bool](" content plane: invalid author modulus length")
    let authorModulusStart = magicLen + 216
    let authorModulusEnd = authorModulusStart + authorModulusLen
    if authorModulusEnd + 4 + 4 + layout.FixedBytes32Size > BytesLen(payload):
        return Err[bool](" content plane: truncated manifest payload")
    let authorExponentLenRes = codec.ReadU32BE(span, authorModulusEnd)
    if IsErr(authorExponentLenRes):
        return Err[bool](Error(authorExponentLenRes))
    let authorExponentLen = int32(Value(authorExponentLenRes))
    if authorExponentLen <= 0:
        return Err[bool](" content plane: invalid author exponent length")
    let authorExponentStart = authorModulusEnd + 4
    let authorExponentEnd = authorExponentStart + authorExponentLen
    if authorExponentEnd + 4 + layout.FixedBytes32Size > BytesLen(payload):
        return Err[bool](" content plane: truncated manifest payload")
    let signatureLenRes = codec.ReadU32BE(span, authorExponentEnd)
    if IsErr(signatureLenRes):
        return Err[bool](Error(signatureLenRes))
    let signatureLen = int32(Value(signatureLenRes))
    if signatureLen <= 0:
        return Err[bool](" content plane: invalid signature length")
    let signatureStart = authorExponentEnd + 4
    let signatureEnd = signatureStart + signatureLen
    if signatureEnd + layout.FixedBytes32Size > BytesLen(payload):
        return Err[bool](" content plane: truncated manifest signature")
    let authorModulus = BytesSlice(payload, authorModulusStart, authorModulusLen)
    let authorExponent = BytesSlice(payload, authorExponentStart, authorExponentLen)
    let manifestCidRes = layout.FixedBytes32FromBytes(BytesSlice(payload,
                                                                 signatureEnd,
                                                                 layout.FixedBytes32Size))
    if IsErr(manifestCidRes):
        return Err[bool](strutil.Join([" content plane: manifest cid bytes: ", Error(manifestCidRes)], ""))
    out = ContentManifest()
    out.version = int32(Value(versionRes))
    out.postCid = Value(postCidRes)
    out.authorId = Value(authorIdRes)
    out.publishEpoch = int32(Value(publishEpochRes))
    out.publishGanzhi = int32(Value(publishGanzhiRes))
    out.previewCid = Value(previewCidRes)
    out.manifestRoot = Value(manifestRootRes)
    out.chunkMapRoot = Value(chunkMapRootRes)
    out.contentCid = Value(contentCidRes)
    out.accessMode = int32(Value(accessModeRes))
    out.priceUnits = int32(Value(priceUnitsRes))
    out.authorModulusLen = authorModulusLen
    out.authorModulus = authorModulus
    out.authorExponentLen = authorExponentLen
    out.authorExponent = authorExponent
    out.signatureLen = signatureLen
    out.signature = BytesSlice(payload, signatureStart, signatureLen)
    out.manifestCid = Value(manifestCidRes)
    let manifestOk = ContentManifestValidate(out)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    return Ok[bool](true)

fn ContentManifestDecode(payload: Bytes): Result[ContentManifest] =
    var out: ContentManifest
    let fillRes = ContentManifestDecodeFill(out, payload)
    if IsErr(fillRes):
        return Err[ContentManifest](Error(fillRes))
    return Ok[ContentManifest](out)

fn ContentManifestValidatePayload(payload: Bytes,
                                    expectedPreviewCid: layout.FixedBytes32): Result[bool] =
    var manifest: ContentManifest
    let manifestRes = ContentManifestDecodeFill(manifest, payload)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    if !layout.FixedBytes32Equal(manifest.previewCid, expectedPreviewCid):
        return Err[bool](" content plane: preview payload cid mismatch")
    return Ok[bool](true)

fn ContentPublishArtifactsCid(topicCid: layout.FixedBytes32,
                                envelopeCid: layout.FixedBytes32,
                                advertCid: layout.FixedBytes32,
                                pubsubPlanCid: layout.FixedBytes32,
                                plumtreePlanCid: layout.FixedBytes32,
                                manifestCid: layout.FixedBytes32,
                                recoveryPlanCid: layout.FixedBytes32,
                                subscriptionCount: int32,
                                proofCount: int32,
                                peerAdvertCount: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.content.publish"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, topicCid)
    lt.AppendFixed32(buf, envelopeCid)
    lt.AppendFixed32(buf, advertCid)
    lt.AppendFixed32(buf, pubsubPlanCid)
    lt.AppendFixed32(buf, plumtreePlanCid)
    lt.AppendFixed32(buf, manifestCid)
    lt.AppendFixed32(buf, recoveryPlanCid)
    lt.AppendU32BE(buf, subscriptionCount)
    lt.AppendU32BE(buf, proofCount)
    lt.AppendU32BE(buf, peerAdvertCount)
    return lt.FixedCidFromBuf(buf)

fn ContentPublishArtifactsExpectedBundleCid(artifacts: ContentPublishArtifacts): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.content.publish"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, artifacts.topic.topicCid)
    lt.AppendFixed32(buf, artifacts.envelope.envelopeCid)
    lt.AppendFixed32(buf, artifacts.publishAdvert.advertCid)
    lt.AppendFixed32(buf, artifacts.pubsubPlan.planCid)
    lt.AppendFixed32(buf, artifacts.plumtreePlan.planCid)
    lt.AppendFixed32(buf, artifacts.erasureManifest.manifestCid)
    lt.AppendFixed32(buf, artifacts.recoveryPlan.planCid)
    lt.AppendU32BE(buf, artifacts.subscriptionCount)
    lt.AppendU32BE(buf, artifacts.availabilityProofCount)
    lt.AppendU32BE(buf, artifacts.peerAdvertCount)
    return lt.FixedCidFromBuf(buf)

fn ContentBuildAvailabilityProofs(summary: dag.DagBlobSummary,
                                    providerPeerIds: layout.FixedBytes32[],
                                    retainedUntilEpochs: int32[]): Result[dag.DagAvailabilityProof[]] =
    if providerPeerIds.len <= 0:
        return Err[dag.DagAvailabilityProof[]](" content plane: empty availability providers")
    if providerPeerIds.len != retainedUntilEpochs.len:
        return Err[dag.DagAvailabilityProof[]](" content plane: provider/retained count mismatch")
    var out: dag.DagAvailabilityProof[]
    out = []
    for i in 0..<providerPeerIds.len:
        let proofRes = dag.DagAvailabilityProofMake(summary, providerPeerIds[i], retainedUntilEpochs[i])
        if IsErr(proofRes):
            return Err[dag.DagAvailabilityProof[]](Error(proofRes))
        add(out, Value(proofRes))
    return Ok[dag.DagAvailabilityProof[]](out)

fn ContentPublishArtifactsFill(out: var ContentPublishArtifacts,
                                 topic: pubsub.PubSubTopic,
                                 root: pubsub.PubSubSubscription,
                                 subscriptions: pubsub.PubSubSubscription[],
                                 publisherPeerId: layout.FixedBytes32,
                                 blob: Bytes,
                                 dagChunkSize: int32,
                                 providerPeerIds: layout.FixedBytes32[],
                                 retainedUntilEpochs: int32[],
                                 stampEpoch: int32,
                                 stampGanzhi: int32,
                                 erasureDataShardCount: int32,
                                 erasureParityShardCount: int32,
                                 erasureShardPayloadBytes: int32,
                                 shardPayloadCids: layout.FixedBytes32[],
                                 peerAdverts: swarm.ErasurePeerAdvert[]): Result[bool] =
    if !layout.FixedBytes32Equal(root.topicCid, topic.topicCid):
        return Err[bool](" content plane: root topic mismatch")
    let summaryRes = dag.DagBlobSummaryFromBytes(blob, dagChunkSize)
    if IsErr(summaryRes):
        return Err[bool](Error(summaryRes))
    let summary = Value(summaryRes)
    let proofsRes = ContentBuildAvailabilityProofs(summary, providerPeerIds, retainedUntilEpochs)
    if IsErr(proofsRes):
        return Err[bool](Error(proofsRes))
    let proofs = Value(proofsRes)
    let certRes = dag.DagAvailabilityCertMake(summary, proofs)
    if IsErr(certRes):
        return Err[bool](Error(certRes))
    let cert = Value(certRes)
    let advertRes = dag.DagPublishAdvertMake(topic.topicCid,
                                               publisherPeerId,
                                               summary,
                                               cert,
                                               stampEpoch,
                                               stampGanzhi)
    if IsErr(advertRes):
        return Err[bool](Error(advertRes))
    let advert = Value(advertRes)
    let envelope = pubsub.PubSubEnvelopeMake(topic.topicCid,
                                               pubsub.PubSubPayloadKindDagAdvert,
                                               advert.advertCid,
                                               summary.summaryCid)
    let pubsubPlanRes = pubsub.PubSubBuildPlan(topic, envelope, subscriptions)
    if IsErr(pubsubPlanRes):
        return Err[bool](Error(pubsubPlanRes))
    let pubsubPlan = Value(pubsubPlanRes)
    let plumtreePlanRes = plumtree.PlumtreeBuildPlan(topic, root, pubsubPlan, subscriptions)
    if IsErr(plumtreePlanRes):
        return Err[bool](Error(plumtreePlanRes))
    let plumtreePlan = Value(plumtreePlanRes)
    let erasureParamsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic,
                                                             erasureDataShardCount,
                                                             erasureParityShardCount,
                                                             erasureShardPayloadBytes)
    if IsErr(erasureParamsRes):
        return Err[bool](Error(erasureParamsRes))
    let erasureParams = Value(erasureParamsRes)
    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       erasureParams,
                                                       shardPayloadCids)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    let manifest = Value(manifestRes)
    let recoveryPlanRes = swarm.ErasureBuildRecoveryPlan(manifest, erasureParams, peerAdverts)
    if IsErr(recoveryPlanRes):
        return Err[bool](Error(recoveryPlanRes))
    let recoveryPlan = Value(recoveryPlanRes)

    out = ContentPublishArtifacts()
    out.topic = topic
    out.root = root
    out.subscriptionCount = subscriptions.len
    out.subscriptions = subscriptions
    out.blobSummary = summary
    out.availabilityProofCount = proofs.len
    out.availabilityProofs = proofs
    out.availabilityCert = cert
    out.publishAdvert = advert
    out.envelope = envelope
    out.pubsubPlan = pubsubPlan
    out.plumtreePlan = plumtreePlan
    out.erasureParams = erasureParams
    out.erasureManifest = manifest
    out.peerAdvertCount = peerAdverts.len
    out.peerAdverts = peerAdverts
    out.recoveryPlan = recoveryPlan
    out.bundleCid = ContentPublishArtifactsExpectedBundleCid(out)
    return Ok[bool](true)

fn ContentPublishArtifactsMake(topic: pubsub.PubSubTopic,
                                 root: pubsub.PubSubSubscription,
                                 subscriptions: pubsub.PubSubSubscription[],
                                 publisherPeerId: layout.FixedBytes32,
                                 blob: Bytes,
                                 dagChunkSize: int32,
                                 providerPeerIds: layout.FixedBytes32[],
                                 retainedUntilEpochs: int32[],
                                 stampEpoch: int32,
                                 stampGanzhi: int32,
                                 erasureDataShardCount: int32,
                                 erasureParityShardCount: int32,
                                 erasureShardPayloadBytes: int32,
                                 shardPayloadCids: layout.FixedBytes32[],
                                 peerAdverts: swarm.ErasurePeerAdvert[]): Result[ContentPublishArtifacts] =
    var out = ContentPublishArtifacts()
    let fillRes = ContentPublishArtifactsFill(out,
                                                topic,
                                                root,
                                                subscriptions,
                                                publisherPeerId,
                                                blob,
                                                dagChunkSize,
                                                providerPeerIds,
                                                retainedUntilEpochs,
                                                stampEpoch,
                                                stampGanzhi,
                                                erasureDataShardCount,
                                                erasureParityShardCount,
                                                erasureShardPayloadBytes,
                                                shardPayloadCids,
                                                peerAdverts)
    if IsErr(fillRes):
        return Err[ContentPublishArtifacts](Error(fillRes))
    return Ok[ContentPublishArtifacts](out)

fn ContentPublishArtifactsValidate(artifacts: ContentPublishArtifacts): Result[bool] =
    if artifacts.version != 1:
        return Err[bool](" content plane: unsupported artifacts version")
    if artifacts.subscriptionCount != artifacts.subscriptions.len:
        return Err[bool](" content plane: subscription count mismatch")
    if artifacts.availabilityProofCount != artifacts.availabilityProofs.len:
        return Err[bool](" content plane: proof count mismatch")
    if artifacts.peerAdvertCount != artifacts.peerAdverts.len:
        return Err[bool](" content plane: peer advert count mismatch")
    if !layout.FixedBytes32Equal(artifacts.root.topicCid, artifacts.topic.topicCid):
        return Err[bool](" content plane: root topic mismatch")

    let summaryOk = dag.DagBlobSummaryValidate(artifacts.blobSummary)
    if IsErr(summaryOk):
        return Err[bool](Error(summaryOk))
    let certOk = dag.DagAvailabilityCertValidate(artifacts.availabilityCert,
                                                   artifacts.blobSummary,
                                                   artifacts.availabilityProofs)
    if IsErr(certOk):
        return Err[bool](Error(certOk))
    let advertOk = dag.DagPublishAdvertValidate(artifacts.publishAdvert,
                                                  artifacts.blobSummary,
                                                  artifacts.availabilityCert)
    if IsErr(advertOk):
        return Err[bool](Error(advertOk))
    if !layout.FixedBytes32Equal(artifacts.envelope.topicCid, artifacts.topic.topicCid):
        return Err[bool](" content plane: envelope topic mismatch")
    if artifacts.envelope.payloadKind != pubsub.PubSubPayloadKindDagAdvert:
        return Err[bool](" content plane: envelope payload kind mismatch")
    if !layout.FixedBytes32Equal(artifacts.envelope.payloadCid, artifacts.publishAdvert.advertCid):
        return Err[bool](" content plane: envelope advert cid mismatch")
    if !layout.FixedBytes32Equal(artifacts.envelope.payloadSummaryCid, artifacts.blobSummary.summaryCid):
        return Err[bool](" content plane: envelope summary cid mismatch")

    let pubsubPlanRes = pubsub.PubSubBuildPlan(artifacts.topic,
                                                 artifacts.envelope,
                                                 artifacts.subscriptions)
    if IsErr(pubsubPlanRes):
        return Err[bool](Error(pubsubPlanRes))
    let rebuiltPubsubPlan = Value(pubsubPlanRes)
    if !layout.FixedBytes32Equal(artifacts.pubsubPlan.planCid, rebuiltPubsubPlan.planCid):
        return Err[bool](" content plane: pubsub plan cid mismatch")
    if artifacts.pubsubPlan.branchCount != rebuiltPubsubPlan.branchCount:
        return Err[bool](" content plane: pubsub branch count mismatch")

    let plumtreePlanRes = plumtree.PlumtreeBuildPlan(artifacts.topic,
                                                       artifacts.root,
                                                       artifacts.pubsubPlan,
                                                       artifacts.subscriptions)
    if IsErr(plumtreePlanRes):
        return Err[bool](Error(plumtreePlanRes))
    let rebuiltPlumtreePlan = Value(plumtreePlanRes)
    if !layout.FixedBytes32Equal(artifacts.plumtreePlan.planCid, rebuiltPlumtreePlan.planCid):
        return Err[bool](" content plane: plumtree plan cid mismatch")
    if artifacts.plumtreePlan.eagerEdgeCount != rebuiltPlumtreePlan.eagerEdgeCount:
        return Err[bool](" content plane: plumtree eager edge count mismatch")
    if artifacts.plumtreePlan.lazyPeerCount != rebuiltPlumtreePlan.lazyPeerCount:
        return Err[bool](" content plane: plumtree lazy peer count mismatch")

    let paramsRes = swarm.ErasureEncodingParamsValidate(artifacts.erasureParams)
    if IsErr(paramsRes):
        return Err[bool](Error(paramsRes))
    let manifestRes = swarm.ErasureManifestValidate(artifacts.erasureManifest,
                                                      artifacts.erasureParams)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    if !layout.FixedBytes32Equal(artifacts.erasureManifest.blobCid, artifacts.blobSummary.blobCid):
        return Err[bool](" content plane: erasure manifest blob cid mismatch")
    if artifacts.erasureManifest.blobByteLen != artifacts.blobSummary.payloadLen:
        return Err[bool](" content plane: erasure manifest payload length mismatch")
    let rebuiltRecoveryPlanRes = swarm.ErasureBuildRecoveryPlan(artifacts.erasureManifest,
                                                                  artifacts.erasureParams,
                                                                  artifacts.peerAdverts)
    if IsErr(rebuiltRecoveryPlanRes):
        return Err[bool](Error(rebuiltRecoveryPlanRes))
    let rebuiltRecoveryPlan = Value(rebuiltRecoveryPlanRes)
    let recoveryPlanOk = swarm.ErasureRecoveryPlanValidate(artifacts.recoveryPlan,
                                                             artifacts.erasureManifest,
                                                             artifacts.erasureParams)
    if IsErr(recoveryPlanOk):
        return Err[bool](Error(recoveryPlanOk))
    if !layout.FixedBytes32Equal(artifacts.recoveryPlan.planCid, rebuiltRecoveryPlan.planCid):
        return Err[bool](" content plane: erasure recovery plan cid mismatch")
    if artifacts.recoveryPlan.requestCount != rebuiltRecoveryPlan.requestCount:
        return Err[bool](" content plane: erasure recovery request count mismatch")
    if artifacts.recoveryPlan.minShardCount != swarm.ErasureRecoveryThreshold(artifacts.erasureParams):
        return Err[bool](" content plane: erasure recovery threshold mismatch")

    let expectedBundleCid = ContentPublishArtifactsExpectedBundleCid(artifacts)
    if !layout.FixedBytes32Equal(artifacts.bundleCid, expectedBundleCid):
        return Err[bool](" content plane: bundle cid mismatch")
    return Ok[bool](true)
