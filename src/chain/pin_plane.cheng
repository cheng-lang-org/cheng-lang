import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/codec_binary as codec
import cheng/chain/lsmr_types as lt
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content

const
    PinSettlementStatusReward: int32 = 1
    PinSettlementStatusSlash: int32 = 2

    PinOfferMagic: str = "cheng.pin.offer"
    PinAcceptMagic: str = "cheng.pin.accept"
    PinChallengeMagic: str = "cheng.pin.challenge"
    PinProofMagic: str = "cheng.pin.proof"
    PinSettlementMagic: str = "cheng.pin.settlement"

type
    PinOffer =
        version: int32 = 1
        bundleCid: layout.FixedBytes32
        blobSummaryCid: layout.FixedBytes32
        blobCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        minRetainedUntilEpoch: int32
        challengeShardCount: int32
        rewardUnits: int32
        slashUnits: int32
        offerCid: layout.FixedBytes32

    PinAccept =
        version: int32 = 1
        offerCid: layout.FixedBytes32
        providerPeerId: layout.FixedBytes32
        retainedUntilEpoch: int32
        rewardUnits: int32
        slashUnits: int32
        acceptCid: layout.FixedBytes32

    PinChallenge =
        version: int32 = 1
        offerCid: layout.FixedBytes32
        acceptCid: layout.FixedBytes32
        providerPeerId: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        challengeEpoch: int32
        shardCount: int32
        shardIndices: int32[]
        shardCids: layout.FixedBytes32[]
        challengeCid: layout.FixedBytes32

    PinProof =
        version: int32 = 1
        challengeCid: layout.FixedBytes32
        acceptCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        shardCount: int32
        shardIndices: int32[]
        shardPayloadLens: int32[]
        payloadConcatLen: int32
        payloadConcat: Bytes
        proofCid: layout.FixedBytes32

    PinSettlement =
        version: int32 = 1
        offerCid: layout.FixedBytes32
        acceptCid: layout.FixedBytes32
        challengeCid: layout.FixedBytes32
        proofCid: layout.FixedBytes32
        settledEpoch: int32
        status: int32
        rewardUnits: int32
        slashUnits: int32
        settlementCid: layout.FixedBytes32

fn PinCidSet(value: layout.FixedBytes32): bool =
    return !layout.FixedBytes32Equal(value, layout.FixedBytes32())

fn PinPayloadHasMagic(payload: Bytes, magic: str): bool =
    let magicBytes = BytesFromString(magic)
    if BytesLen(payload) < BytesLen(magicBytes):
        return false
    for i in 0..<BytesLen(magicBytes):
        if BytesGet(payload, i) != BytesGet(magicBytes, i):
            return false
    return true

fn PinSettlementStatusValid(status: int32): bool =
    if status == PinSettlementStatusReward:
        return true
    if status == PinSettlementStatusSlash:
        return true
    return false

fn PinIndexSetContains(values: int32[], value: int32): bool =
    for i in 0..<values.len:
        if values[i] == value:
            return true
    return false

fn PinManifestShardPos(manifest: swarm.ErasureShardManifest,
                         shardIndex: int32): int32 =
    for i in 0..<manifest.shardCount:
        if manifest.shardIndices[i] == shardIndex:
            return i
    return -1

fn PinChallengeResponsePos(responses: swarm.ErasureShardPullResponse[],
                             manifestCid: layout.FixedBytes32,
                             shardIndex: int32,
                             shardCid: layout.FixedBytes32): int32 =
    for i in 0..<responses.len:
        let response = responses[i]
        if !layout.FixedBytes32Equal(response.manifestCid, manifestCid):
            continue
        if response.shardIndex != shardIndex:
            continue
        if !layout.FixedBytes32Equal(response.shardCid, shardCid):
            continue
        return i
    return -1

fn PinOfferCid(bundleCid: layout.FixedBytes32,
                 blobSummaryCid: layout.FixedBytes32,
                 blobCid: layout.FixedBytes32,
                 manifestCid: layout.FixedBytes32,
                 minRetainedUntilEpoch: int32,
                 challengeShardCount: int32,
                 rewardUnits: int32,
                 slashUnits: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(192)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.pin.offer.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, bundleCid)
    lt.AppendFixed32(buf, blobSummaryCid)
    lt.AppendFixed32(buf, blobCid)
    lt.AppendFixed32(buf, manifestCid)
    lt.AppendU32BE(buf, minRetainedUntilEpoch)
    lt.AppendU32BE(buf, challengeShardCount)
    lt.AppendU32BE(buf, rewardUnits)
    lt.AppendU32BE(buf, slashUnits)
    return lt.FixedCidFromBuf(buf)

fn PinAcceptCid(offerCid: layout.FixedBytes32,
                  providerPeerId: layout.FixedBytes32,
                  retainedUntilEpoch: int32,
                  rewardUnits: int32,
                  slashUnits: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(160)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.pin.accept.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, offerCid)
    lt.AppendFixed32(buf, providerPeerId)
    lt.AppendU32BE(buf, retainedUntilEpoch)
    lt.AppendU32BE(buf, rewardUnits)
    lt.AppendU32BE(buf, slashUnits)
    return lt.FixedCidFromBuf(buf)

fn PinChallengeCid(offerCid: layout.FixedBytes32,
                     acceptCid: layout.FixedBytes32,
                     providerPeerId: layout.FixedBytes32,
                     manifestCid: layout.FixedBytes32,
                     challengeEpoch: int32,
                     shardIndices: int32[],
                     shardCids: layout.FixedBytes32[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256 + shardIndices.len * 40)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.pin.challenge.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, offerCid)
    lt.AppendFixed32(buf, acceptCid)
    lt.AppendFixed32(buf, providerPeerId)
    lt.AppendFixed32(buf, manifestCid)
    lt.AppendU32BE(buf, challengeEpoch)
    lt.AppendU32BE(buf, shardIndices.len)
    for i in 0..<shardIndices.len:
        lt.AppendU32BE(buf, shardIndices[i])
        lt.AppendFixed32(buf, shardCids[i])
    return lt.FixedCidFromBuf(buf)

fn PinProofCid(challengeCid: layout.FixedBytes32,
                 acceptCid: layout.FixedBytes32,
                 manifestCid: layout.FixedBytes32,
                 shardIndices: int32[],
                 shardPayloadLens: int32[],
                 payloadConcat: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256 + BytesLen(payloadConcat))
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.pin.proof.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, challengeCid)
    lt.AppendFixed32(buf, acceptCid)
    lt.AppendFixed32(buf, manifestCid)
    lt.AppendU32BE(buf, shardIndices.len)
    for i in 0..<shardIndices.len:
        lt.AppendU32BE(buf, shardIndices[i])
        lt.AppendU32BE(buf, shardPayloadLens[i])
    lt.AppendU32BE(buf, BytesLen(payloadConcat))
    layout.ByteBufAppendBytes(buf, payloadConcat)
    return lt.FixedCidFromBuf(buf)

fn PinSettlementCid(offerCid: layout.FixedBytes32,
                      acceptCid: layout.FixedBytes32,
                      challengeCid: layout.FixedBytes32,
                      proofCid: layout.FixedBytes32,
                      settledEpoch: int32,
                      status: int32,
                      rewardUnits: int32,
                      slashUnits: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(192)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.pin.settlement.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, offerCid)
    lt.AppendFixed32(buf, acceptCid)
    lt.AppendFixed32(buf, challengeCid)
    lt.AppendFixed32(buf, proofCid)
    lt.AppendU32BE(buf, settledEpoch)
    lt.AppendU32BE(buf, status)
    lt.AppendU32BE(buf, rewardUnits)
    lt.AppendU32BE(buf, slashUnits)
    return lt.FixedCidFromBuf(buf)

fn PinOfferValidate(offer: PinOffer): Result[bool] =
    if offer.version != 1:
        return Err[bool](" pin: unsupported offer version")
    if !PinCidSet(offer.bundleCid):
        return Err[bool](" pin: missing offer bundle cid")
    if !PinCidSet(offer.blobSummaryCid):
        return Err[bool](" pin: missing offer blob summary cid")
    if !PinCidSet(offer.blobCid):
        return Err[bool](" pin: missing offer blob cid")
    if !PinCidSet(offer.manifestCid):
        return Err[bool](" pin: missing offer manifest cid")
    if offer.minRetainedUntilEpoch <= 0:
        return Err[bool](" pin: invalid offer retained epoch")
    if offer.challengeShardCount <= 0:
        return Err[bool](" pin: invalid offer challenge shard count")
    if offer.rewardUnits < 0:
        return Err[bool](" pin: invalid offer reward")
    if offer.slashUnits < 0:
        return Err[bool](" pin: invalid offer slash")
    if offer.rewardUnits == 0 && offer.slashUnits == 0:
        return Err[bool](" pin: empty offer economics")
    let expectedCid = PinOfferCid(offer.bundleCid,
                                    offer.blobSummaryCid,
                                    offer.blobCid,
                                    offer.manifestCid,
                                    offer.minRetainedUntilEpoch,
                                    offer.challengeShardCount,
                                    offer.rewardUnits,
                                    offer.slashUnits)
    if !layout.FixedBytes32Equal(offer.offerCid, expectedCid):
        return Err[bool](" pin: offer cid mismatch")
    return Ok[bool](true)

fn PinOfferValidateAgainstManifest(offer: PinOffer,
                                     manifest: swarm.ErasureShardManifest): Result[bool] =
    let offerOk = PinOfferValidate(offer)
    if IsErr(offerOk):
        return Err[bool](Error(offerOk))
    if !layout.FixedBytes32Equal(offer.blobCid, manifest.blobCid):
        return Err[bool](" pin: offer blob cid mismatch")
    if !layout.FixedBytes32Equal(offer.manifestCid, manifest.manifestCid):
        return Err[bool](" pin: offer manifest cid mismatch")
    if offer.challengeShardCount > manifest.shardCount:
        return Err[bool](" pin: offer challenge shard count overflow")
    return Ok[bool](true)

fn PinOfferMake(bundleCid: layout.FixedBytes32,
                  blobSummaryCid: layout.FixedBytes32,
                  blobCid: layout.FixedBytes32,
                  manifestCid: layout.FixedBytes32,
                  minRetainedUntilEpoch: int32,
                  challengeShardCount: int32,
                  rewardUnits: int32,
                  slashUnits: int32): Result[PinOffer] =
    var out = PinOffer()
    out.bundleCid = bundleCid
    out.blobSummaryCid = blobSummaryCid
    out.blobCid = blobCid
    out.manifestCid = manifestCid
    out.minRetainedUntilEpoch = minRetainedUntilEpoch
    out.challengeShardCount = challengeShardCount
    out.rewardUnits = rewardUnits
    out.slashUnits = slashUnits
    out.offerCid = PinOfferCid(out.bundleCid,
                                 out.blobSummaryCid,
                                 out.blobCid,
                                 out.manifestCid,
                                 out.minRetainedUntilEpoch,
                                 out.challengeShardCount,
                                 out.rewardUnits,
                                 out.slashUnits)
    let offerOk = PinOfferValidate(out)
    if IsErr(offerOk):
        return Err[PinOffer](Error(offerOk))
    return Ok[PinOffer](out)

fn PinOfferFromArtifacts(artifacts: content.ContentPublishArtifacts,
                           minRetainedUntilEpoch: int32,
                           challengeShardCount: int32,
                           rewardUnits: int32,
                           slashUnits: int32): Result[PinOffer] =
    if !PinCidSet(artifacts.bundleCid):
        return Err[PinOffer](" pin: artifacts missing bundle cid")
    let summaryOk = dag.DagBlobSummaryValidate(artifacts.blobSummary)
    if IsErr(summaryOk):
        return Err[PinOffer](Error(summaryOk))
    let manifestOk = swarm.ErasureManifestValidate(artifacts.erasureManifest, artifacts.erasureParams)
    if IsErr(manifestOk):
        return Err[PinOffer](Error(manifestOk))
    if !layout.FixedBytes32Equal(artifacts.erasureManifest.blobCid, artifacts.blobSummary.blobCid):
        return Err[PinOffer](" pin: artifacts blob cid mismatch")
    return PinOfferMake(artifacts.bundleCid,
                          artifacts.blobSummary.summaryCid,
                          artifacts.blobSummary.blobCid,
                          artifacts.erasureManifest.manifestCid,
                          minRetainedUntilEpoch,
                          challengeShardCount,
                          rewardUnits,
                          slashUnits)

fn PinAcceptValidate(accept: PinAccept): Result[bool] =
    if accept.version != 1:
        return Err[bool](" pin: unsupported accept version")
    if !PinCidSet(accept.offerCid):
        return Err[bool](" pin: missing accept offer cid")
    if !PinCidSet(accept.providerPeerId):
        return Err[bool](" pin: missing accept provider peer id")
    if accept.retainedUntilEpoch <= 0:
        return Err[bool](" pin: invalid accept retained epoch")
    if accept.rewardUnits < 0:
        return Err[bool](" pin: invalid accept reward")
    if accept.slashUnits < 0:
        return Err[bool](" pin: invalid accept slash")
    if accept.rewardUnits == 0 && accept.slashUnits == 0:
        return Err[bool](" pin: empty accept economics")
    let expectedCid = PinAcceptCid(accept.offerCid,
                                     accept.providerPeerId,
                                     accept.retainedUntilEpoch,
                                     accept.rewardUnits,
                                     accept.slashUnits)
    if !layout.FixedBytes32Equal(accept.acceptCid, expectedCid):
        return Err[bool](" pin: accept cid mismatch")
    return Ok[bool](true)

fn PinAcceptValidateAgainstOffer(accept: PinAccept,
                                   offer: PinOffer): Result[bool] =
    let offerOk = PinOfferValidate(offer)
    if IsErr(offerOk):
        return Err[bool](Error(offerOk))
    let acceptOk = PinAcceptValidate(accept)
    if IsErr(acceptOk):
        return Err[bool](Error(acceptOk))
    if !layout.FixedBytes32Equal(accept.offerCid, offer.offerCid):
        return Err[bool](" pin: accept offer cid mismatch")
    if accept.retainedUntilEpoch < offer.minRetainedUntilEpoch:
        return Err[bool](" pin: accept retained epoch too short")
    if accept.rewardUnits != offer.rewardUnits:
        return Err[bool](" pin: accept reward mismatch")
    if accept.slashUnits != offer.slashUnits:
        return Err[bool](" pin: accept slash mismatch")
    return Ok[bool](true)

fn PinAcceptMake(offer: PinOffer,
                   providerPeerId: layout.FixedBytes32,
                   retainedUntilEpoch: int32): Result[PinAccept] =
    var out = PinAccept()
    out.offerCid = offer.offerCid
    out.providerPeerId = providerPeerId
    out.retainedUntilEpoch = retainedUntilEpoch
    out.rewardUnits = offer.rewardUnits
    out.slashUnits = offer.slashUnits
    out.acceptCid = PinAcceptCid(out.offerCid,
                                   out.providerPeerId,
                                   out.retainedUntilEpoch,
                                   out.rewardUnits,
                                   out.slashUnits)
    let acceptOk = PinAcceptValidateAgainstOffer(out, offer)
    if IsErr(acceptOk):
        return Err[PinAccept](Error(acceptOk))
    return Ok[PinAccept](out)

fn PinChallengeValidate(challenge: PinChallenge): Result[bool] =
    if challenge.version != 1:
        return Err[bool](" pin: unsupported challenge version")
    if !PinCidSet(challenge.offerCid):
        return Err[bool](" pin: missing challenge offer cid")
    if !PinCidSet(challenge.acceptCid):
        return Err[bool](" pin: missing challenge accept cid")
    if !PinCidSet(challenge.providerPeerId):
        return Err[bool](" pin: missing challenge provider peer id")
    if !PinCidSet(challenge.manifestCid):
        return Err[bool](" pin: missing challenge manifest cid")
    if challenge.challengeEpoch < 0:
        return Err[bool](" pin: invalid challenge epoch")
    if challenge.shardCount <= 0:
        return Err[bool](" pin: invalid challenge shard count")
    if challenge.shardCount != challenge.shardIndices.len:
        return Err[bool](" pin: challenge shard index count mismatch")
    if challenge.shardCount != challenge.shardCids.len:
        return Err[bool](" pin: challenge shard cid count mismatch")
    var seen: int32[]
    seen = []
    for i in 0..<challenge.shardCount:
        if challenge.shardIndices[i] < 0:
            return Err[bool](" pin: invalid challenge shard index")
        if !PinCidSet(challenge.shardCids[i]):
            return Err[bool](" pin: missing challenge shard cid")
        if PinIndexSetContains(seen, challenge.shardIndices[i]):
            return Err[bool](" pin: duplicate challenge shard index")
        add(seen, challenge.shardIndices[i])
    let expectedCid = PinChallengeCid(challenge.offerCid,
                                        challenge.acceptCid,
                                        challenge.providerPeerId,
                                        challenge.manifestCid,
                                        challenge.challengeEpoch,
                                        challenge.shardIndices,
                                        challenge.shardCids)
    if !layout.FixedBytes32Equal(challenge.challengeCid, expectedCid):
        return Err[bool](" pin: challenge cid mismatch")
    return Ok[bool](true)

fn PinChallengeValidateAgainstInputs(challenge: PinChallenge,
                                       offer: PinOffer,
                                       accept: PinAccept,
                                       manifest: swarm.ErasureShardManifest): Result[bool] =
    let offerOk = PinOfferValidateAgainstManifest(offer, manifest)
    if IsErr(offerOk):
        return Err[bool](Error(offerOk))
    let acceptOk = PinAcceptValidateAgainstOffer(accept, offer)
    if IsErr(acceptOk):
        return Err[bool](Error(acceptOk))
    let challengeOk = PinChallengeValidate(challenge)
    if IsErr(challengeOk):
        return Err[bool](Error(challengeOk))
    if !layout.FixedBytes32Equal(challenge.offerCid, offer.offerCid):
        return Err[bool](" pin: challenge offer cid mismatch")
    if !layout.FixedBytes32Equal(challenge.acceptCid, accept.acceptCid):
        return Err[bool](" pin: challenge accept cid mismatch")
    if !layout.FixedBytes32Equal(challenge.providerPeerId, accept.providerPeerId):
        return Err[bool](" pin: challenge provider peer mismatch")
    if !layout.FixedBytes32Equal(challenge.manifestCid, manifest.manifestCid):
        return Err[bool](" pin: challenge manifest cid mismatch")
    if challenge.challengeEpoch > accept.retainedUntilEpoch:
        return Err[bool](" pin: challenge after retained epoch")
    if challenge.shardCount != offer.challengeShardCount:
        return Err[bool](" pin: challenge shard count mismatch")
    if challenge.shardCount > manifest.shardCount:
        return Err[bool](" pin: challenge shard count overflow")
    for i in 0..<challenge.shardCount:
        let pos = PinManifestShardPos(manifest, challenge.shardIndices[i])
        if pos < 0:
            return Err[bool](" pin: challenge shard missing from manifest")
        if !layout.FixedBytes32Equal(challenge.shardCids[i], manifest.shardPayloadCids[pos]):
            return Err[bool](" pin: challenge shard cid mismatch")
    return Ok[bool](true)

fn PinBuildChallenge(offer: PinOffer,
                       accept: PinAccept,
                       manifest: swarm.ErasureShardManifest,
                       challengeEpoch: int32): Result[PinChallenge] =
    let offerOk = PinOfferValidateAgainstManifest(offer, manifest)
    if IsErr(offerOk):
        return Err[PinChallenge](Error(offerOk))
    let acceptOk = PinAcceptValidateAgainstOffer(accept, offer)
    if IsErr(acceptOk):
        return Err[PinChallenge](Error(acceptOk))
    if challengeEpoch < 0:
        return Err[PinChallenge](" pin: invalid challenge epoch")
    if challengeEpoch > accept.retainedUntilEpoch:
        return Err[PinChallenge](" pin: challenge after retained epoch")
    var seedBuf: layout.ByteBuf = layout.ByteBufInit(160)
    layout.ByteBufAppendBytes(seedBuf, BytesFromString("cheng.pin.challenge.seed"))
    lt.AppendFixed32(seedBuf, offer.offerCid)
    lt.AppendFixed32(seedBuf, accept.acceptCid)
    lt.AppendFixed32(seedBuf, manifest.manifestCid)
    lt.AppendU32BE(seedBuf, challengeEpoch)
    let seed = lt.FixedCidFromBuf(seedBuf)
    let start = (int32(seed.data[0]) * 256 + int32(seed.data[1])) % manifest.shardCount
    var indices: int32[]
    var cids: layout.FixedBytes32[]
    indices = []
    cids = []
    for i in 0..<offer.challengeShardCount:
        let pos = (start + i) % manifest.shardCount
        add(indices, manifest.shardIndices[pos])
        add(cids, manifest.shardPayloadCids[pos])
    var out = PinChallenge()
    out.offerCid = offer.offerCid
    out.acceptCid = accept.acceptCid
    out.providerPeerId = accept.providerPeerId
    out.manifestCid = manifest.manifestCid
    out.challengeEpoch = challengeEpoch
    out.shardCount = indices.len
    out.shardIndices = indices
    out.shardCids = cids
    out.challengeCid = PinChallengeCid(out.offerCid,
                                         out.acceptCid,
                                         out.providerPeerId,
                                         out.manifestCid,
                                         out.challengeEpoch,
                                         out.shardIndices,
                                         out.shardCids)
    let challengeOk = PinChallengeValidateAgainstInputs(out, offer, accept, manifest)
    if IsErr(challengeOk):
        return Err[PinChallenge](Error(challengeOk))
    return Ok[PinChallenge](out)

fn PinProofValidate(proof: PinProof): Result[bool] =
    if proof.version != 1:
        return Err[bool](" pin: unsupported proof version")
    if !PinCidSet(proof.challengeCid):
        return Err[bool](" pin: missing proof challenge cid")
    if !PinCidSet(proof.acceptCid):
        return Err[bool](" pin: missing proof accept cid")
    if !PinCidSet(proof.manifestCid):
        return Err[bool](" pin: missing proof manifest cid")
    if proof.shardCount <= 0:
        return Err[bool](" pin: invalid proof shard count")
    if proof.shardCount != proof.shardIndices.len:
        return Err[bool](" pin: proof shard index count mismatch")
    if proof.shardCount != proof.shardPayloadLens.len:
        return Err[bool](" pin: proof shard payload count mismatch")
    if proof.payloadConcatLen < 0:
        return Err[bool](" pin: invalid proof payload length")
    if proof.payloadConcatLen != BytesLen(proof.payloadConcat):
        return Err[bool](" pin: proof payload length mismatch")
    var seen: int32[]
    seen = []
    var total = 0
    for i in 0..<proof.shardCount:
        if proof.shardIndices[i] < 0:
            return Err[bool](" pin: invalid proof shard index")
        if proof.shardPayloadLens[i] < 0:
            return Err[bool](" pin: invalid proof shard payload length")
        if PinIndexSetContains(seen, proof.shardIndices[i]):
            return Err[bool](" pin: duplicate proof shard index")
        add(seen, proof.shardIndices[i])
        total = total + proof.shardPayloadLens[i]
    if total != proof.payloadConcatLen:
        return Err[bool](" pin: proof payload concat mismatch")
    let expectedCid = PinProofCid(proof.challengeCid,
                                    proof.acceptCid,
                                    proof.manifestCid,
                                    proof.shardIndices,
                                    proof.shardPayloadLens,
                                    proof.payloadConcat)
    if !layout.FixedBytes32Equal(proof.proofCid, expectedCid):
        return Err[bool](" pin: proof cid mismatch")
    return Ok[bool](true)

fn PinProofValidateAgainstInputs(proof: PinProof,
                                   challenge: PinChallenge,
                                   accept: PinAccept,
                                   manifest: swarm.ErasureShardManifest): Result[bool] =
    let challengeOk = PinChallengeValidate(challenge)
    if IsErr(challengeOk):
        return Err[bool](Error(challengeOk))
    let acceptOk = PinAcceptValidate(accept)
    if IsErr(acceptOk):
        return Err[bool](Error(acceptOk))
    let proofOk = PinProofValidate(proof)
    if IsErr(proofOk):
        return Err[bool](Error(proofOk))
    if !layout.FixedBytes32Equal(proof.challengeCid, challenge.challengeCid):
        return Err[bool](" pin: proof challenge cid mismatch")
    if !layout.FixedBytes32Equal(proof.acceptCid, accept.acceptCid):
        return Err[bool](" pin: proof accept cid mismatch")
    if !layout.FixedBytes32Equal(proof.manifestCid, manifest.manifestCid):
        return Err[bool](" pin: proof manifest cid mismatch")
    if proof.shardCount != challenge.shardCount:
        return Err[bool](" pin: proof shard count mismatch")
    var next = 0
    for i in 0..<proof.shardCount:
        if proof.shardIndices[i] != challenge.shardIndices[i]:
            return Err[bool](" pin: proof shard index mismatch")
        let pos = PinManifestShardPos(manifest, challenge.shardIndices[i])
        if pos < 0:
            return Err[bool](" pin: proof shard missing from manifest")
        let payloadLen = proof.shardPayloadLens[i]
        if next + payloadLen > proof.payloadConcatLen:
            return Err[bool](" pin: truncated proof payload")
        let payload = BytesSlice(proof.payloadConcat, next, payloadLen)
        let payloadCid = swarm.ErasureShardPayloadCid(payload)
        if !layout.FixedBytes32Equal(payloadCid, challenge.shardCids[i]):
            return Err[bool](" pin: proof challenged shard cid mismatch")
        if !layout.FixedBytes32Equal(payloadCid, manifest.shardPayloadCids[pos]):
            return Err[bool](" pin: proof manifest shard cid mismatch")
        next = next + payloadLen
    if next != proof.payloadConcatLen:
        return Err[bool](" pin: proof payload concat tail mismatch")
    return Ok[bool](true)

fn PinProofMake(challenge: PinChallenge,
                  manifest: swarm.ErasureShardManifest,
                  shardPayloads: Bytes[]): Result[PinProof] =
    let challengeOk = PinChallengeValidate(challenge)
    if IsErr(challengeOk):
        return Err[PinProof](Error(challengeOk))
    if !layout.FixedBytes32Equal(challenge.manifestCid, manifest.manifestCid):
        return Err[PinProof](" pin: proof manifest cid mismatch")
    if shardPayloads.len != challenge.shardCount:
        return Err[PinProof](" pin: proof payload count mismatch")
    var concat: layout.ByteBuf = layout.ByteBufInit(256)
    var shardPayloadLens: int32[]
    shardPayloadLens = []
    for i in 0..<challenge.shardCount:
        let pos = PinManifestShardPos(manifest, challenge.shardIndices[i])
        if pos < 0:
            return Err[PinProof](" pin: proof shard missing from manifest")
        let payloadCid = swarm.ErasureShardPayloadCid(shardPayloads[i])
        if !layout.FixedBytes32Equal(payloadCid, challenge.shardCids[i]):
            return Err[PinProof](" pin: proof challenged shard cid mismatch")
        if !layout.FixedBytes32Equal(payloadCid, manifest.shardPayloadCids[pos]):
            return Err[PinProof](" pin: proof manifest shard cid mismatch")
        add(shardPayloadLens, BytesLen(shardPayloads[i]))
        layout.ByteBufAppendBytes(concat, shardPayloads[i])
    var out = PinProof()
    out.challengeCid = challenge.challengeCid
    out.acceptCid = challenge.acceptCid
    out.manifestCid = manifest.manifestCid
    out.shardCount = challenge.shardCount
    out.shardIndices = challenge.shardIndices
    out.shardPayloadLens = shardPayloadLens
    out.payloadConcat = layout.ByteBufToBytes(concat)
    out.payloadConcatLen = BytesLen(out.payloadConcat)
    out.proofCid = PinProofCid(out.challengeCid,
                                 out.acceptCid,
                                 out.manifestCid,
                                 out.shardIndices,
                                 out.shardPayloadLens,
                                 out.payloadConcat)
    let proofOk = PinProofValidate(out)
    if IsErr(proofOk):
        return Err[PinProof](Error(proofOk))
    return Ok[PinProof](out)

fn PinProofFromResponses(challenge: PinChallenge,
                           manifest: swarm.ErasureShardManifest,
                           responses: swarm.ErasureShardPullResponse[]): Result[PinProof] =
    var payloads: Bytes[]
    payloads = []
    for i in 0..<challenge.shardCount:
        let pos = PinChallengeResponsePos(responses,
                                            manifest.manifestCid,
                                            challenge.shardIndices[i],
                                            challenge.shardCids[i])
        if pos < 0:
            return Err[PinProof](" pin: proof response missing")
        let requestRes = swarm.ErasureShardPullRequestMake(manifest, challenge.shardIndices[i])
        if IsErr(requestRes):
            return Err[PinProof](Error(requestRes))
        let responseOk = swarm.ErasureShardPullResponseValidate(responses[pos], Value(requestRes))
        if IsErr(responseOk):
            return Err[PinProof](Error(responseOk))
        add(payloads, responses[pos].payload)
    return PinProofMake(challenge, manifest, payloads)

fn PinSettlementValidate(settlement: PinSettlement): Result[bool] =
    if settlement.version != 1:
        return Err[bool](" pin: unsupported settlement version")
    if !PinCidSet(settlement.offerCid):
        return Err[bool](" pin: missing settlement offer cid")
    if !PinCidSet(settlement.acceptCid):
        return Err[bool](" pin: missing settlement accept cid")
    if !PinCidSet(settlement.challengeCid):
        return Err[bool](" pin: missing settlement challenge cid")
    if !PinCidSet(settlement.proofCid):
        return Err[bool](" pin: missing settlement proof cid")
    if settlement.settledEpoch < 0:
        return Err[bool](" pin: invalid settled epoch")
    if !PinSettlementStatusValid(settlement.status):
        return Err[bool](" pin: invalid settlement status")
    if settlement.rewardUnits < 0:
        return Err[bool](" pin: invalid settlement reward")
    if settlement.slashUnits < 0:
        return Err[bool](" pin: invalid settlement slash")
    let expectedCid = PinSettlementCid(settlement.offerCid,
                                         settlement.acceptCid,
                                         settlement.challengeCid,
                                         settlement.proofCid,
                                         settlement.settledEpoch,
                                         settlement.status,
                                         settlement.rewardUnits,
                                         settlement.slashUnits)
    if !layout.FixedBytes32Equal(settlement.settlementCid, expectedCid):
        return Err[bool](" pin: settlement cid mismatch")
    return Ok[bool](true)

fn PinSettlementValidateAgainstInputs(settlement: PinSettlement,
                                        offer: PinOffer,
                                        accept: PinAccept,
                                        challenge: PinChallenge,
                                        manifest: swarm.ErasureShardManifest,
                                        proof: PinProof): Result[bool] =
    let settlementOk = PinSettlementValidate(settlement)
    if IsErr(settlementOk):
        return Err[bool](Error(settlementOk))
    let challengeOk = PinChallengeValidateAgainstInputs(challenge, offer, accept, manifest)
    if IsErr(challengeOk):
        return Err[bool](Error(challengeOk))
    if !layout.FixedBytes32Equal(settlement.offerCid, offer.offerCid):
        return Err[bool](" pin: settlement offer cid mismatch")
    if !layout.FixedBytes32Equal(settlement.acceptCid, accept.acceptCid):
        return Err[bool](" pin: settlement accept cid mismatch")
    if !layout.FixedBytes32Equal(settlement.challengeCid, challenge.challengeCid):
        return Err[bool](" pin: settlement challenge cid mismatch")
    if !layout.FixedBytes32Equal(settlement.proofCid, proof.proofCid):
        return Err[bool](" pin: settlement proof cid mismatch")
    if settlement.settledEpoch < challenge.challengeEpoch:
        return Err[bool](" pin: settlement before challenge")
    let proofOk = PinProofValidateAgainstInputs(proof, challenge, accept, manifest)
    if IsErr(proofOk):
        if settlement.status != PinSettlementStatusSlash:
            return Err[bool](" pin: settlement status mismatch")
        if settlement.rewardUnits != 0:
            return Err[bool](" pin: invalid slashed reward")
        if settlement.slashUnits != accept.slashUnits:
            return Err[bool](" pin: invalid slashed amount")
        return Ok[bool](true)
    if settlement.status != PinSettlementStatusReward:
        return Err[bool](" pin: settlement reward status mismatch")
    if settlement.rewardUnits != offer.rewardUnits:
        return Err[bool](" pin: settlement reward amount mismatch")
    if settlement.slashUnits != 0:
        return Err[bool](" pin: settlement reward slash mismatch")
    return Ok[bool](true)

fn PinSettlementMake(offerCid: layout.FixedBytes32,
                       acceptCid: layout.FixedBytes32,
                       challengeCid: layout.FixedBytes32,
                       proofCid: layout.FixedBytes32,
                       settledEpoch: int32,
                       status: int32,
                       rewardUnits: int32,
                       slashUnits: int32): Result[PinSettlement] =
    var out = PinSettlement()
    out.offerCid = offerCid
    out.acceptCid = acceptCid
    out.challengeCid = challengeCid
    out.proofCid = proofCid
    out.settledEpoch = settledEpoch
    out.status = status
    out.rewardUnits = rewardUnits
    out.slashUnits = slashUnits
    out.settlementCid = PinSettlementCid(out.offerCid,
                                           out.acceptCid,
                                           out.challengeCid,
                                           out.proofCid,
                                           out.settledEpoch,
                                           out.status,
                                           out.rewardUnits,
                                           out.slashUnits)
    let settlementOk = PinSettlementValidate(out)
    if IsErr(settlementOk):
        return Err[PinSettlement](Error(settlementOk))
    return Ok[PinSettlement](out)

fn PinBuildSettlement(offer: PinOffer,
                        accept: PinAccept,
                        challenge: PinChallenge,
                        manifest: swarm.ErasureShardManifest,
                        proof: PinProof,
                        settledEpoch: int32): Result[PinSettlement] =
    let challengeOk = PinChallengeValidateAgainstInputs(challenge, offer, accept, manifest)
    if IsErr(challengeOk):
        return Err[PinSettlement](Error(challengeOk))
    let proofOk = PinProofValidateAgainstInputs(proof, challenge, accept, manifest)
    if IsErr(proofOk):
        let slashRes = PinSettlementMake(offer.offerCid,
                                           accept.acceptCid,
                                           challenge.challengeCid,
                                           proof.proofCid,
                                           settledEpoch,
                                           PinSettlementStatusSlash,
                                           0,
                                           accept.slashUnits)
        if IsErr(slashRes):
            return Err[PinSettlement](Error(slashRes))
        let settlementOk = PinSettlementValidateAgainstInputs(Value(slashRes),
                                                                offer,
                                                                accept,
                                                                challenge,
                                                                manifest,
                                                                proof)
        if IsErr(settlementOk):
            return Err[PinSettlement](Error(settlementOk))
        return slashRes
    let rewardRes = PinSettlementMake(offer.offerCid,
                                        accept.acceptCid,
                                        challenge.challengeCid,
                                        proof.proofCid,
                                        settledEpoch,
                                        PinSettlementStatusReward,
                                        offer.rewardUnits,
                                        0)
    if IsErr(rewardRes):
        return Err[PinSettlement](Error(rewardRes))
    let settlementOk = PinSettlementValidateAgainstInputs(Value(rewardRes),
                                                            offer,
                                                            accept,
                                                            challenge,
                                                            manifest,
                                                            proof)
    if IsErr(settlementOk):
        return Err[PinSettlement](Error(settlementOk))
    return rewardRes

fn PinOfferEncode(offer: PinOffer): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString(PinOfferMagic))
    lt.AppendU32BE(buf, offer.version)
    lt.AppendFixed32(buf, offer.bundleCid)
    lt.AppendFixed32(buf, offer.blobSummaryCid)
    lt.AppendFixed32(buf, offer.blobCid)
    lt.AppendFixed32(buf, offer.manifestCid)
    lt.AppendU32BE(buf, offer.minRetainedUntilEpoch)
    lt.AppendU32BE(buf, offer.challengeShardCount)
    lt.AppendU32BE(buf, offer.rewardUnits)
    lt.AppendU32BE(buf, offer.slashUnits)
    lt.AppendFixed32(buf, offer.offerCid)
    return layout.ByteBufToBytes(buf)

fn PinOfferDecode(payload: Bytes): Result[PinOffer] =
    if !PinPayloadHasMagic(payload, PinOfferMagic):
        return Err[PinOffer](" pin: invalid offer magic")
    let magicLen = BytesLen(BytesFromString(PinOfferMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[PinOffer](Error(versionRes))
    let bundleCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(bundleCidRes):
        return Err[PinOffer](Error(bundleCidRes))
    let blobSummaryCidRes = codec.ReadFixed32(span, magicLen + 36)
    if IsErr(blobSummaryCidRes):
        return Err[PinOffer](Error(blobSummaryCidRes))
    let blobCidRes = codec.ReadFixed32(span, magicLen + 68)
    if IsErr(blobCidRes):
        return Err[PinOffer](Error(blobCidRes))
    let manifestCidRes = codec.ReadFixed32(span, magicLen + 100)
    if IsErr(manifestCidRes):
        return Err[PinOffer](Error(manifestCidRes))
    let retainedRes = codec.ReadU32BE(span, magicLen + 132)
    if IsErr(retainedRes):
        return Err[PinOffer](Error(retainedRes))
    let challengeCountRes = codec.ReadU32BE(span, magicLen + 136)
    if IsErr(challengeCountRes):
        return Err[PinOffer](Error(challengeCountRes))
    let rewardRes = codec.ReadU32BE(span, magicLen + 140)
    if IsErr(rewardRes):
        return Err[PinOffer](Error(rewardRes))
    let slashRes = codec.ReadU32BE(span, magicLen + 144)
    if IsErr(slashRes):
        return Err[PinOffer](Error(slashRes))
    let offerCidRes = codec.ReadFixed32(span, magicLen + 148)
    if IsErr(offerCidRes):
        return Err[PinOffer](Error(offerCidRes))
    var out = PinOffer()
    out.version = int32(Value(versionRes))
    out.bundleCid = Value(bundleCidRes)
    out.blobSummaryCid = Value(blobSummaryCidRes)
    out.blobCid = Value(blobCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.minRetainedUntilEpoch = int32(Value(retainedRes))
    out.challengeShardCount = int32(Value(challengeCountRes))
    out.rewardUnits = int32(Value(rewardRes))
    out.slashUnits = int32(Value(slashRes))
    out.offerCid = Value(offerCidRes)
    let offerOk = PinOfferValidate(out)
    if IsErr(offerOk):
        return Err[PinOffer](Error(offerOk))
    return Ok[PinOffer](out)

fn PinOfferValidatePayload(payload: Bytes,
                             expectedCid: layout.FixedBytes32): Result[bool] =
    let offerRes = PinOfferDecode(payload)
    if IsErr(offerRes):
        return Err[bool](Error(offerRes))
    if !layout.FixedBytes32Equal(Value(offerRes).offerCid, expectedCid):
        return Err[bool](" pin: offer payload cid mismatch")
    return Ok[bool](true)

fn PinAcceptEncode(accept: PinAccept): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(224)
    layout.ByteBufAppendBytes(buf, BytesFromString(PinAcceptMagic))
    lt.AppendU32BE(buf, accept.version)
    lt.AppendFixed32(buf, accept.offerCid)
    lt.AppendFixed32(buf, accept.providerPeerId)
    lt.AppendU32BE(buf, accept.retainedUntilEpoch)
    lt.AppendU32BE(buf, accept.rewardUnits)
    lt.AppendU32BE(buf, accept.slashUnits)
    lt.AppendFixed32(buf, accept.acceptCid)
    return layout.ByteBufToBytes(buf)

fn PinAcceptDecode(payload: Bytes): Result[PinAccept] =
    if !PinPayloadHasMagic(payload, PinAcceptMagic):
        return Err[PinAccept](" pin: invalid accept magic")
    let magicLen = BytesLen(BytesFromString(PinAcceptMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[PinAccept](Error(versionRes))
    let offerCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(offerCidRes):
        return Err[PinAccept](Error(offerCidRes))
    let providerPeerIdRes = codec.ReadFixed32(span, magicLen + 36)
    if IsErr(providerPeerIdRes):
        return Err[PinAccept](Error(providerPeerIdRes))
    let retainedRes = codec.ReadU32BE(span, magicLen + 68)
    if IsErr(retainedRes):
        return Err[PinAccept](Error(retainedRes))
    let rewardRes = codec.ReadU32BE(span, magicLen + 72)
    if IsErr(rewardRes):
        return Err[PinAccept](Error(rewardRes))
    let slashRes = codec.ReadU32BE(span, magicLen + 76)
    if IsErr(slashRes):
        return Err[PinAccept](Error(slashRes))
    let acceptCidRes = codec.ReadFixed32(span, magicLen + 80)
    if IsErr(acceptCidRes):
        return Err[PinAccept](Error(acceptCidRes))
    var out = PinAccept()
    out.version = int32(Value(versionRes))
    out.offerCid = Value(offerCidRes)
    out.providerPeerId = Value(providerPeerIdRes)
    out.retainedUntilEpoch = int32(Value(retainedRes))
    out.rewardUnits = int32(Value(rewardRes))
    out.slashUnits = int32(Value(slashRes))
    out.acceptCid = Value(acceptCidRes)
    let acceptOk = PinAcceptValidate(out)
    if IsErr(acceptOk):
        return Err[PinAccept](Error(acceptOk))
    return Ok[PinAccept](out)

fn PinAcceptValidatePayload(payload: Bytes,
                              expectedCid: layout.FixedBytes32): Result[bool] =
    let acceptRes = PinAcceptDecode(payload)
    if IsErr(acceptRes):
        return Err[bool](Error(acceptRes))
    if !layout.FixedBytes32Equal(Value(acceptRes).acceptCid, expectedCid):
        return Err[bool](" pin: accept payload cid mismatch")
    return Ok[bool](true)

fn PinChallengeEncode(challenge: PinChallenge): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(256 + challenge.shardCount * 40)
    layout.ByteBufAppendBytes(buf, BytesFromString(PinChallengeMagic))
    lt.AppendU32BE(buf, challenge.version)
    lt.AppendFixed32(buf, challenge.offerCid)
    lt.AppendFixed32(buf, challenge.acceptCid)
    lt.AppendFixed32(buf, challenge.providerPeerId)
    lt.AppendFixed32(buf, challenge.manifestCid)
    lt.AppendU32BE(buf, challenge.challengeEpoch)
    lt.AppendU32BE(buf, challenge.shardCount)
    for i in 0..<challenge.shardCount:
        lt.AppendU32BE(buf, challenge.shardIndices[i])
        lt.AppendFixed32(buf, challenge.shardCids[i])
    lt.AppendFixed32(buf, challenge.challengeCid)
    return layout.ByteBufToBytes(buf)

fn PinChallengeDecode(payload: Bytes): Result[PinChallenge] =
    if !PinPayloadHasMagic(payload, PinChallengeMagic):
        return Err[PinChallenge](" pin: invalid challenge magic")
    let magicLen = BytesLen(BytesFromString(PinChallengeMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[PinChallenge](Error(versionRes))
    let offerCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(offerCidRes):
        return Err[PinChallenge](Error(offerCidRes))
    let acceptCidRes = codec.ReadFixed32(span, magicLen + 36)
    if IsErr(acceptCidRes):
        return Err[PinChallenge](Error(acceptCidRes))
    let providerPeerIdRes = codec.ReadFixed32(span, magicLen + 68)
    if IsErr(providerPeerIdRes):
        return Err[PinChallenge](Error(providerPeerIdRes))
    let manifestCidRes = codec.ReadFixed32(span, magicLen + 100)
    if IsErr(manifestCidRes):
        return Err[PinChallenge](Error(manifestCidRes))
    let epochRes = codec.ReadU32BE(span, magicLen + 132)
    if IsErr(epochRes):
        return Err[PinChallenge](Error(epochRes))
    let shardCountRes = codec.ReadU32BE(span, magicLen + 136)
    if IsErr(shardCountRes):
        return Err[PinChallenge](Error(shardCountRes))
    let shardCount = int32(Value(shardCountRes))
    if shardCount <= 0:
        return Err[PinChallenge](" pin: invalid decoded challenge shard count")
    var next = magicLen + 140
    var shardIndices: int32[]
    var shardCids: layout.FixedBytes32[]
    shardIndices = []
    shardCids = []
    for i in 0..<shardCount:
        let indexRes = codec.ReadU32BE(span, next)
        if IsErr(indexRes):
            return Err[PinChallenge](Error(indexRes))
        next = next + 4
        let shardCidRes = codec.ReadFixed32(span, next)
        if IsErr(shardCidRes):
            return Err[PinChallenge](Error(shardCidRes))
        next = next + 32
        add(shardIndices, int32(Value(indexRes)))
        add(shardCids, Value(shardCidRes))
    let challengeCidRes = codec.ReadFixed32(span, next)
    if IsErr(challengeCidRes):
        return Err[PinChallenge](Error(challengeCidRes))
    var out = PinChallenge()
    out.version = int32(Value(versionRes))
    out.offerCid = Value(offerCidRes)
    out.acceptCid = Value(acceptCidRes)
    out.providerPeerId = Value(providerPeerIdRes)
    out.manifestCid = Value(manifestCidRes)
    out.challengeEpoch = int32(Value(epochRes))
    out.shardCount = shardCount
    out.shardIndices = shardIndices
    out.shardCids = shardCids
    out.challengeCid = Value(challengeCidRes)
    let challengeOk = PinChallengeValidate(out)
    if IsErr(challengeOk):
        return Err[PinChallenge](Error(challengeOk))
    return Ok[PinChallenge](out)

fn PinChallengeValidatePayload(payload: Bytes,
                                 expectedCid: layout.FixedBytes32): Result[bool] =
    let challengeRes = PinChallengeDecode(payload)
    if IsErr(challengeRes):
        return Err[bool](Error(challengeRes))
    if !layout.FixedBytes32Equal(Value(challengeRes).challengeCid, expectedCid):
        return Err[bool](" pin: challenge payload cid mismatch")
    return Ok[bool](true)

fn PinProofEncode(proof: PinProof): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(256 + proof.payloadConcatLen)
    layout.ByteBufAppendBytes(buf, BytesFromString(PinProofMagic))
    lt.AppendU32BE(buf, proof.version)
    lt.AppendFixed32(buf, proof.challengeCid)
    lt.AppendFixed32(buf, proof.acceptCid)
    lt.AppendFixed32(buf, proof.manifestCid)
    lt.AppendU32BE(buf, proof.shardCount)
    for i in 0..<proof.shardCount:
        lt.AppendU32BE(buf, proof.shardIndices[i])
        lt.AppendU32BE(buf, proof.shardPayloadLens[i])
    lt.AppendU32BE(buf, proof.payloadConcatLen)
    layout.ByteBufAppendBytes(buf, proof.payloadConcat)
    lt.AppendFixed32(buf, proof.proofCid)
    return layout.ByteBufToBytes(buf)

fn PinProofDecode(payload: Bytes): Result[PinProof] =
    if !PinPayloadHasMagic(payload, PinProofMagic):
        return Err[PinProof](" pin: invalid proof magic")
    let magicLen = BytesLen(BytesFromString(PinProofMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[PinProof](Error(versionRes))
    let challengeCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(challengeCidRes):
        return Err[PinProof](Error(challengeCidRes))
    let acceptCidRes = codec.ReadFixed32(span, magicLen + 36)
    if IsErr(acceptCidRes):
        return Err[PinProof](Error(acceptCidRes))
    let manifestCidRes = codec.ReadFixed32(span, magicLen + 68)
    if IsErr(manifestCidRes):
        return Err[PinProof](Error(manifestCidRes))
    let shardCountRes = codec.ReadU32BE(span, magicLen + 100)
    if IsErr(shardCountRes):
        return Err[PinProof](Error(shardCountRes))
    let shardCount = int32(Value(shardCountRes))
    if shardCount <= 0:
        return Err[PinProof](" pin: invalid decoded proof shard count")
    var next = magicLen + 104
    var shardIndices: int32[]
    var shardPayloadLens: int32[]
    shardIndices = []
    shardPayloadLens = []
    for i in 0..<shardCount:
        let indexRes = codec.ReadU32BE(span, next)
        if IsErr(indexRes):
            return Err[PinProof](Error(indexRes))
        next = next + 4
        let payloadLenRes = codec.ReadU32BE(span, next)
        if IsErr(payloadLenRes):
            return Err[PinProof](Error(payloadLenRes))
        next = next + 4
        add(shardIndices, int32(Value(indexRes)))
        add(shardPayloadLens, int32(Value(payloadLenRes)))
    let concatLenRes = codec.ReadU32BE(span, next)
    if IsErr(concatLenRes):
        return Err[PinProof](Error(concatLenRes))
    next = next + 4
    let concatLen = int32(Value(concatLenRes))
    if concatLen < 0 || next + concatLen > BytesLen(payload):
        return Err[PinProof](" pin: truncated proof payload")
    let payloadConcat = BytesSlice(payload, next, concatLen)
    next = next + concatLen
    let proofCidRes = codec.ReadFixed32(span, next)
    if IsErr(proofCidRes):
        return Err[PinProof](Error(proofCidRes))
    var out = PinProof()
    out.version = int32(Value(versionRes))
    out.challengeCid = Value(challengeCidRes)
    out.acceptCid = Value(acceptCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.shardCount = shardCount
    out.shardIndices = shardIndices
    out.shardPayloadLens = shardPayloadLens
    out.payloadConcatLen = concatLen
    out.payloadConcat = payloadConcat
    out.proofCid = Value(proofCidRes)
    let proofOk = PinProofValidate(out)
    if IsErr(proofOk):
        return Err[PinProof](Error(proofOk))
    return Ok[PinProof](out)

fn PinProofValidatePayload(payload: Bytes,
                             expectedCid: layout.FixedBytes32): Result[bool] =
    let proofRes = PinProofDecode(payload)
    if IsErr(proofRes):
        return Err[bool](Error(proofRes))
    if !layout.FixedBytes32Equal(Value(proofRes).proofCid, expectedCid):
        return Err[bool](" pin: proof payload cid mismatch")
    return Ok[bool](true)

fn PinSettlementEncode(settlement: PinSettlement): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString(PinSettlementMagic))
    lt.AppendU32BE(buf, settlement.version)
    lt.AppendFixed32(buf, settlement.offerCid)
    lt.AppendFixed32(buf, settlement.acceptCid)
    lt.AppendFixed32(buf, settlement.challengeCid)
    lt.AppendFixed32(buf, settlement.proofCid)
    lt.AppendU32BE(buf, settlement.settledEpoch)
    lt.AppendU32BE(buf, settlement.status)
    lt.AppendU32BE(buf, settlement.rewardUnits)
    lt.AppendU32BE(buf, settlement.slashUnits)
    lt.AppendFixed32(buf, settlement.settlementCid)
    return layout.ByteBufToBytes(buf)

fn PinSettlementDecode(payload: Bytes): Result[PinSettlement] =
    if !PinPayloadHasMagic(payload, PinSettlementMagic):
        return Err[PinSettlement](" pin: invalid settlement magic")
    let magicLen = BytesLen(BytesFromString(PinSettlementMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[PinSettlement](Error(versionRes))
    let offerCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(offerCidRes):
        return Err[PinSettlement](Error(offerCidRes))
    let acceptCidRes = codec.ReadFixed32(span, magicLen + 36)
    if IsErr(acceptCidRes):
        return Err[PinSettlement](Error(acceptCidRes))
    let challengeCidRes = codec.ReadFixed32(span, magicLen + 68)
    if IsErr(challengeCidRes):
        return Err[PinSettlement](Error(challengeCidRes))
    let proofCidRes = codec.ReadFixed32(span, magicLen + 100)
    if IsErr(proofCidRes):
        return Err[PinSettlement](Error(proofCidRes))
    let settledEpochRes = codec.ReadU32BE(span, magicLen + 132)
    if IsErr(settledEpochRes):
        return Err[PinSettlement](Error(settledEpochRes))
    let statusRes = codec.ReadU32BE(span, magicLen + 136)
    if IsErr(statusRes):
        return Err[PinSettlement](Error(statusRes))
    let rewardRes = codec.ReadU32BE(span, magicLen + 140)
    if IsErr(rewardRes):
        return Err[PinSettlement](Error(rewardRes))
    let slashRes = codec.ReadU32BE(span, magicLen + 144)
    if IsErr(slashRes):
        return Err[PinSettlement](Error(slashRes))
    let settlementCidRes = codec.ReadFixed32(span, magicLen + 148)
    if IsErr(settlementCidRes):
        return Err[PinSettlement](Error(settlementCidRes))
    var out = PinSettlement()
    out.version = int32(Value(versionRes))
    out.offerCid = Value(offerCidRes)
    out.acceptCid = Value(acceptCidRes)
    out.challengeCid = Value(challengeCidRes)
    out.proofCid = Value(proofCidRes)
    out.settledEpoch = int32(Value(settledEpochRes))
    out.status = int32(Value(statusRes))
    out.rewardUnits = int32(Value(rewardRes))
    out.slashUnits = int32(Value(slashRes))
    out.settlementCid = Value(settlementCidRes)
    let settlementOk = PinSettlementValidate(out)
    if IsErr(settlementOk):
        return Err[PinSettlement](Error(settlementOk))
    return Ok[PinSettlement](out)

fn PinSettlementValidatePayload(payload: Bytes,
                                  expectedCid: layout.FixedBytes32): Result[bool] =
    let settlementRes = PinSettlementDecode(payload)
    if IsErr(settlementRes):
        return Err[bool](Error(settlementRes))
    if !layout.FixedBytes32Equal(Value(settlementRes).settlementCid, expectedCid):
        return Err[bool](" pin: settlement payload cid mismatch")
    return Ok[bool](true)
