import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt

const
    ConsensusKindMint: int32 = 1
    ConsensusKindTransferCommit: int32 = 2

    ConsensusReasonOk: int32 = 1
    ConsensusReasonDuplicate: int32 = 2
    ConsensusReasonMintApplied: int32 = 3
    ConsensusReasonTransferApplied: int32 = 4
    ConsensusReasonDivergedTarget: int32 = 5
    ConsensusReasonForkParentMismatch: int32 = 6
    ConsensusReasonDivergedAccount: int32 = 7
    ConsensusReasonInsufficientBalance: int32 = 8

type
    ChainEvent =
        version: int32
        kind: int32
        assetId: int32
        fromAccount: int32
        toAccount: int32
        fromParentCid: layout.FixedBytes32
        toParentCid: layout.FixedBytes32
        bodyCid: layout.FixedBytes32
        amount: int64
        epoch: int32
        ganzhiIndex: int32
        spaceSlot: int32
        tick: int64
        stem: int32
        branch: int32

    ChainIndex =
        eventCids: layout.FixedBytes32[]
        eventKinds: int32[]
        logOffsets: int32[]
        accountAssetIds: int32[]
        accountIds: int32[]
        accountHeads: layout.FixedBytes32[]
        balances: int64[]
        clockEpochs: int32[]
        clockGanzhi: int32[]
        diverged: bool[]
        stateTreeDirty: bool

    ConsensusDecision =
        eventCid: layout.FixedBytes32
        accepted: bool
        applied: bool
        reasonCode: int32 = 1
        fromAssetId: int32
        fromAccountId: int32
        toAssetId: int32
        toAccountId: int32

fn ChainEventBodyCid(event: ChainEvent): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    let prefix = BytesFromString("cheng.consensus.body")
    layout.ByteBufAppendBytes(buf, prefix)
    lt.AppendU32BE(buf, event.kind)
    lt.AppendU32BE(buf, event.assetId)
    lt.AppendU32BE(buf, event.fromAccount)
    lt.AppendU32BE(buf, event.toAccount)
    lt.AppendFixed32(buf, event.fromParentCid)
    lt.AppendFixed32(buf, event.toParentCid)
    lt.AppendU32BE(buf, event.epoch)
    lt.AppendU32BE(buf, event.ganzhiIndex)
    lt.AppendU32BE(buf, event.spaceSlot)
    lt.AppendU32BE(buf, int32(event.tick >> 32))
    lt.AppendU32BE(buf, int32(event.tick & int64(0xffffffff)))
    lt.AppendU32BE(buf, int32(event.amount >> 32))
    lt.AppendU32BE(buf, int32(event.amount & int64(0xffffffff)))
    return lt.FixedCidFromBuf(buf)

fn ChainEventCid(event: ChainEvent): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(128)
    let prefix = BytesFromString("cheng.consensus.event")
    layout.ByteBufAppendBytes(buf, prefix)
    lt.AppendFixed32(buf, ChainEventBodyCid(event))
    lt.AppendU32BE(buf, event.stem)
    lt.AppendU32BE(buf, event.branch)
    return lt.FixedCidFromBuf(buf)

fn ChainEventMint(assetId: int32,
                    toAccount: int32,
                    toParentCid: layout.FixedBytes32,
                    amount: int64,
                    epoch: int32,
                    ganzhiIndex: int32,
                    spaceSlot: int32,
                    tick: int64): ChainEvent =
    var out: ChainEvent
    out.version = 1
    out.kind = ConsensusKindMint
    out.assetId = assetId
    out.toAccount = toAccount
    out.toParentCid = toParentCid
    out.amount = amount
    out.epoch = epoch
    out.ganzhiIndex = ganzhiIndex
    out.spaceSlot = spaceSlot
    out.tick = tick
    out.stem = ganzhiIndex % 10
    out.branch = ganzhiIndex % 12
    out.bodyCid = ChainEventBodyCid(out)
    return out

fn ConsensusEventPos(index: ChainIndex, eventCid: layout.FixedBytes32): int32 =
    for i in 0..<index.eventCids.len:
        if layout.FixedBytes32Equal(index.eventCids[i], eventCid):
            return i
    return -1

fn ConsensusAccountPos(index: ChainIndex, assetId: int32, accountId: int32): int32 =
    for i in 0..<index.accountIds.len:
        if index.accountAssetIds[i] == assetId:
            if index.accountIds[i] == accountId:
                return i
    return -1

fn ConsensusEnsureAccount(index: var ChainIndex, assetId: int32, accountId: int32): int32 =
    var accountCount = index.accountIds.len
    for i in 0..<accountCount:
        if index.accountAssetIds[i] == assetId:
            if index.accountIds[i] == accountId:
                return i
    var zeroCid: layout.FixedBytes32
    add(index.accountAssetIds, assetId)
    add(index.accountIds, accountId)
    add(index.accountHeads, zeroCid)
    add(index.balances, int64(0))
    add(index.clockEpochs, 0)
    add(index.clockGanzhi, 0)
    add(index.diverged, false)
    return index.accountIds.len - 1

fn ConsensusReferences(event: ChainEvent, parentCid: layout.FixedBytes32): bool =
    if layout.FixedBytes32Equal(event.fromParentCid, parentCid):
        return true
    if layout.FixedBytes32Equal(event.toParentCid, parentCid):
        return true
    return false

fn ConsensusLess(aCid: layout.FixedBytes32, aEvent: ChainEvent,
                   bCid: layout.FixedBytes32, bEvent: ChainEvent): bool =
    if ConsensusReferences(bEvent, aCid):
        return true
    if ConsensusReferences(aEvent, bCid):
        return false
    if aEvent.epoch != bEvent.epoch:
        return aEvent.epoch < bEvent.epoch
    if aEvent.ganzhiIndex != bEvent.ganzhiIndex:
        return aEvent.ganzhiIndex < bEvent.ganzhiIndex
    if aEvent.spaceSlot != bEvent.spaceSlot:
        return aEvent.spaceSlot < bEvent.spaceSlot
    if aEvent.tick != bEvent.tick:
        return aEvent.tick < bEvent.tick
    return lt.FixedBytes32Less(aCid, bCid)

fn ConsensusRecordEventMeta(index: var ChainIndex, eventCid: layout.FixedBytes32, kind: int32, logOffset: int32) =
    add(index.eventCids, eventCid)
    add(index.eventKinds, kind)
    add(index.logOffsets, logOffset)
    index.stateTreeDirty = true

fn ConsensusApplyMint(index: var ChainIndex,
                        event: var ChainEvent,
                        eventCid: layout.FixedBytes32,
                        logOffset: int32,
                        decision: var ConsensusDecision) =
    let pos = ConsensusEnsureAccount(index, event.assetId, event.toAccount)
    decision.toAssetId = event.assetId
    decision.toAccountId = event.toAccount
    if index.diverged[pos]:
        decision.reasonCode = ConsensusReasonDivergedTarget
        decision.accepted = false
        return
    if !layout.FixedBytes32Equal(index.accountHeads[pos], event.toParentCid):
        index.diverged[pos] = true
        index.stateTreeDirty = true
        decision.reasonCode = ConsensusReasonForkParentMismatch
        decision.accepted = false
        return
    index.balances[pos] = index.balances[pos] + event.amount
    index.accountHeads[pos] = eventCid
    index.clockEpochs[pos] = event.epoch
    index.clockGanzhi[pos] = event.ganzhiIndex
    ConsensusRecordEventMeta(index, eventCid, event.kind, logOffset)
    decision.accepted = true
    decision.applied = true
    decision.reasonCode = ConsensusReasonMintApplied

fn ConsensusApplyTransfer(index: var ChainIndex,
                            event: var ChainEvent,
                            eventCid: layout.FixedBytes32,
                            logOffset: int32,
                            decision: var ConsensusDecision) =
    let fromPos = ConsensusEnsureAccount(index, event.assetId, event.fromAccount)
    let toPos = ConsensusEnsureAccount(index, event.assetId, event.toAccount)
    decision.fromAssetId = event.assetId
    decision.fromAccountId = event.fromAccount
    decision.toAssetId = event.assetId
    decision.toAccountId = event.toAccount
    if index.diverged[fromPos]:
        index.diverged[fromPos] = true
        index.diverged[toPos] = true
        index.stateTreeDirty = true
        decision.reasonCode = ConsensusReasonDivergedAccount
        decision.accepted = false
        return
    if index.diverged[toPos]:
        index.diverged[fromPos] = true
        index.diverged[toPos] = true
        index.stateTreeDirty = true
        decision.reasonCode = ConsensusReasonDivergedAccount
        decision.accepted = false
        return
    if !layout.FixedBytes32Equal(index.accountHeads[fromPos], event.fromParentCid):
        index.diverged[fromPos] = true
        index.diverged[toPos] = true
        index.stateTreeDirty = true
        decision.reasonCode = ConsensusReasonForkParentMismatch
        decision.accepted = false
        return
    if !layout.FixedBytes32Equal(index.accountHeads[toPos], event.toParentCid):
        index.diverged[fromPos] = true
        index.diverged[toPos] = true
        index.stateTreeDirty = true
        decision.reasonCode = ConsensusReasonForkParentMismatch
        decision.accepted = false
        return
    if index.balances[fromPos] < event.amount:
        index.diverged[fromPos] = true
        index.diverged[toPos] = true
        index.stateTreeDirty = true
        decision.reasonCode = ConsensusReasonInsufficientBalance
        decision.accepted = false
        return
    index.balances[fromPos] = index.balances[fromPos] - event.amount
    index.balances[toPos] = index.balances[toPos] + event.amount
    index.accountHeads[fromPos] = eventCid
    index.accountHeads[toPos] = eventCid
    index.clockEpochs[fromPos] = event.epoch
    index.clockEpochs[toPos] = event.epoch
    index.clockGanzhi[fromPos] = event.ganzhiIndex
    index.clockGanzhi[toPos] = event.ganzhiIndex
    ConsensusRecordEventMeta(index, eventCid, event.kind, logOffset)
    decision.accepted = true
    decision.applied = true
    decision.reasonCode = ConsensusReasonTransferApplied

fn ConsensusApply(index: var ChainIndex,
                    event: var ChainEvent,
                    eventCid: layout.FixedBytes32,
                    logOffset: int32): Result[ConsensusDecision] =
    var out: ConsensusDecision
    ConsensusApplyChecked(index, event, eventCid, logOffset, out)
    return Ok[ConsensusDecision](out)

fn ConsensusApplyChecked(index: var ChainIndex,
                           event: var ChainEvent,
                           eventCid: layout.FixedBytes32,
                           logOffset: int32,
                           out: var ConsensusDecision) =
    out.eventCid = eventCid
    out.accepted = false
    out.applied = false
    out.reasonCode = ConsensusReasonOk
    out.fromAssetId = 0
    out.fromAccountId = 0
    out.toAssetId = 0
    out.toAccountId = 0
    if !layout.FixedBytes32Equal(eventCid, ChainEventCid(event)):
        Panic(" consensus: cid mismatch")
    if !layout.FixedBytes32Equal(event.bodyCid, ChainEventBodyCid(event)):
        Panic(" consensus: body cid mismatch")
    for i in 0..<index.eventCids.len:
        if layout.FixedBytes32Equal(index.eventCids[i], eventCid):
            out.accepted = true
            out.applied = false
            out.reasonCode = ConsensusReasonDuplicate
            return
    if event.kind != ConsensusKindMint:
        if event.kind != ConsensusKindTransferCommit:
            Panic(" consensus: unsupported kind")
    if event.amount <= int64(0):
        Panic(" consensus: amount must be positive")
    if event.stem != event.ganzhiIndex % 10:
        Panic(" consensus: ganzhi decomposition mismatch")
    if event.branch != event.ganzhiIndex % 12:
        Panic(" consensus: ganzhi decomposition mismatch")
    if event.kind == ConsensusKindMint:
        if event.toAccount <= 0:
            Panic(" consensus: invalid mint target")
        if event.assetId <= 0:
            Panic(" consensus: invalid mint target")
        ConsensusApplyMint(index, event, eventCid, logOffset, out)
        return
    if event.fromAccount <= 0:
        Panic(" consensus: invalid transfer accounts")
    if event.toAccount <= 0:
        Panic(" consensus: invalid transfer accounts")
    if event.fromAccount == event.toAccount:
        Panic(" consensus: invalid transfer accounts")
    ConsensusApplyTransfer(index, event, eventCid, logOffset, out)
    return
