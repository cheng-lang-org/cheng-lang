import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt
import cheng/chain/lsmr
import cheng/chain/pubsub

type
    PlumtreeEagerEdge =
        parentNodeId: int32
        parentAddress: types.LsmrAddress
        childNodeId: int32
        childAddress: types.LsmrAddress
        branchDigit: int32
        routeCid: layout.FixedBytes32

    PlumtreeLazyPeer =
        ownerNodeId: int32
        ownerAddress: types.LsmrAddress
        peerNodeId: int32
        peerAddress: types.LsmrAddress
        branchDigit: int32
        sharedPrefixDepth: int32
        hopCount: int32
        routeCid: layout.FixedBytes32

    PlumtreeIhave =
        envelopeCid: layout.FixedBytes32
        fromNodeId: int32
        fromAddress: types.LsmrAddress
        toNodeId: int32
        toAddress: types.LsmrAddress
        branchDigit: int32
        routeCid: layout.FixedBytes32
        advertCid: layout.FixedBytes32

    PlumtreeIwant =
        envelopeCid: layout.FixedBytes32
        missingNodeId: int32
        missingAddress: types.LsmrAddress
        sourceNodeId: int32
        sourceAddress: types.LsmrAddress
        branchDigit: int32
        routeCid: layout.FixedBytes32
        requestCid: layout.FixedBytes32

    PlumtreePlan =
        version: int32
        topicCid: layout.FixedBytes32
        envelopeCid: layout.FixedBytes32
        rootNodeId: int32
        rootAddress: types.LsmrAddress
        nodeCount: int32
        branchCount: int32
        eagerEdgeCount: int32
        lazyPeerCount: int32
        ihaveCount: int32
        branchDigits: int32[]
        eagerEdges: PlumtreeEagerEdge[]
        lazyPeers: PlumtreeLazyPeer[]
        ihaves: PlumtreeIhave[]
        planCid: layout.FixedBytes32

fn PlumtreeBranchPos(plan: PlumtreePlan, digit: int32): int32 =
    for i in 0..<plan.branchDigits.len:
        if plan.branchDigits[i] == digit:
            return i
    return -1

fn PlumtreeMemberPos(subscriptions: pubsub.PubSubSubscription[],
                       nodeId: int32,
                       address: types.LsmrAddress): int32 =
    for i in 0..<subscriptions.len:
        if subscriptions[i].nodeId == nodeId &&
           types.LsmrAddressEqual(subscriptions[i].address, address):
            return i
    return -1

fn PlumtreeSubscriptionIsPrimary(subscription: pubsub.PubSubSubscription,
                                   primaryNodeId: int32,
                                   primaryAddress: types.LsmrAddress): bool =
    return subscription.nodeId == primaryNodeId &&
           types.LsmrAddressEqual(subscription.address, primaryAddress)

fn PlumtreeSubscriptionLess(rootAddress: types.LsmrAddress,
                              primaryNodeId: int32,
                              primaryAddress: types.LsmrAddress,
                              left: pubsub.PubSubSubscription,
                              right: pubsub.PubSubSubscription): bool =
    let leftPrimary = PlumtreeSubscriptionIsPrimary(left, primaryNodeId, primaryAddress)
    let rightPrimary = PlumtreeSubscriptionIsPrimary(right, primaryNodeId, primaryAddress)
    if leftPrimary != rightPrimary:
        return leftPrimary
    let leftRouteRes = lsmr.LsmrRoutePlanFromAddresses(rootAddress, left.address)
    if IsErr(leftRouteRes):
        Panic(Error(leftRouteRes))
    let rightRouteRes = lsmr.LsmrRoutePlanFromAddresses(rootAddress, right.address)
    if IsErr(rightRouteRes):
        Panic(Error(rightRouteRes))
    let leftRoute = Value(leftRouteRes)
    let rightRoute = Value(rightRouteRes)
    if leftRoute.hopCount != rightRoute.hopCount:
        return leftRoute.hopCount < rightRoute.hopCount
    let leftShared = lsmr.LsmrSharedPrefixDepth(left.address, primaryAddress)
    let rightShared = lsmr.LsmrSharedPrefixDepth(right.address, primaryAddress)
    if leftShared != rightShared:
        return leftShared > rightShared
    if pubsub.PubSubAddressLess(left.address, right.address):
        return true
    if pubsub.PubSubAddressLess(right.address, left.address):
        return false
    return left.nodeId < right.nodeId

fn PlumtreeSortBranchMembers(rootAddress: types.LsmrAddress,
                               primaryNodeId: int32,
                               primaryAddress: types.LsmrAddress,
                               members: var pubsub.PubSubSubscription[]) =
    for i in 1..<members.len:
        let current = members[i]
        var j = i - 1
        for j in range(0, = 0, -1):

            if !PlumtreeSubscriptionLess(rootAddress, primaryNodeId, primaryAddress, current, members[j]):
                break
            members[j + 1] = members[j]

        members[j + 1] = current

fn PlumtreeIhaveMake(envelopeCid: layout.FixedBytes32,
                       fromNodeId: int32,
                       fromAddress: types.LsmrAddress,
                       toNodeId: int32,
                       toAddress: types.LsmrAddress,
                       branchDigit: int32,
                       routeCid: layout.FixedBytes32): PlumtreeIhave =
    var out: PlumtreeIhave
    out.envelopeCid = envelopeCid
    out.fromNodeId = fromNodeId
    out.fromAddress = fromAddress
    out.toNodeId = toNodeId
    out.toAddress = toAddress
    out.branchDigit = branchDigit
    out.routeCid = routeCid
    var buf: layout.ByteBuf = layout.ByteBufInit(128)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.plumtree.ihave"))
    lt.AppendFixed32(buf, envelopeCid)
    lt.AppendU32BE(buf, fromNodeId)
    lt.AppendU32BE(buf, toNodeId)
    lt.AppendU32BE(buf, branchDigit)
    lt.AppendFixed32(buf, routeCid)
    out.advertCid = lt.FixedCidFromBuf(buf)
    return out

fn PlumtreeBuildPlan(topic: pubsub.PubSubTopic,
                       root: pubsub.PubSubSubscription,
                       basePlan: pubsub.PubSubPlan,
                       subscriptions: pubsub.PubSubSubscription[]): Result[PlumtreePlan] =
    if !layout.FixedBytes32Equal(root.topicCid, topic.topicCid):
        return Err[PlumtreePlan](" plumtree: root topic mismatch")
    if !layout.FixedBytes32Equal(basePlan.topicCid, topic.topicCid):
        return Err[PlumtreePlan](" plumtree: base plan topic mismatch")
    var out: PlumtreePlan
    out.topicCid = topic.topicCid
    out.envelopeCid = basePlan.envelopeCid
    out.rootNodeId = root.nodeId
    out.rootAddress = root.address
    out.nodeCount = 1
    for i in 0..<basePlan.branchDigits.len:
        add(out.branchDigits, basePlan.branchDigits[i])
    out.branchCount = out.branchDigits.len
    for branchStep in 0..<basePlan.branchDigits.len:
        let branchDigit = basePlan.branchDigits[branchStep]
        let primaryNodeId = basePlan.branchPrimaryNodeIds[branchStep]
        let primaryAddress = basePlan.branchPrimaryAddresses[branchStep]
        var members: pubsub.PubSubSubscription[]
        members = []
        for subStep in 0..<subscriptions.len:
            let subscription = subscriptions[subStep]
            if !layout.FixedBytes32Equal(subscription.topicCid, topic.topicCid):
                continue
            if !pubsub.PubSubEligible(topic, subscription.address):
                continue
            if subscription.nodeId == root.nodeId &&
               types.LsmrAddressEqual(subscription.address, root.address):
                continue
            if lsmr.LsmrMulticastBranchDigit(root.address, subscription.address) != branchDigit:
                continue
            if PlumtreeMemberPos(members, subscription.nodeId, subscription.address) >= 0:
                continue
            add(members, subscription)
        if members.len == 0:
            if primaryNodeId == root.nodeId &&
               types.LsmrAddressEqual(primaryAddress, root.address):
                continue
            return Err[PlumtreePlan](" plumtree: missing branch primary")
        PlumtreeSortBranchMembers(root.address, primaryNodeId, primaryAddress, members)
        if !PlumtreeSubscriptionIsPrimary(members[0], primaryNodeId, primaryAddress):
            return Err[PlumtreePlan](" plumtree: primary sort mismatch")
        out.nodeCount = out.nodeCount + members.len
        for memberStep in 0..<members.len:
            let member = members[memberStep]
            if memberStep == 0:
                let rootRouteRes = lsmr.LsmrRoutePlanFromAddresses(root.address, member.address)
                if IsErr(rootRouteRes):
                    return Err[PlumtreePlan](Error(rootRouteRes))
                var eagerEdge: PlumtreeEagerEdge
                eagerEdge.parentNodeId = root.nodeId
                eagerEdge.parentAddress = root.address
                eagerEdge.childNodeId = member.nodeId
                eagerEdge.childAddress = member.address
                eagerEdge.branchDigit = branchDigit
                eagerEdge.routeCid = Value(rootRouteRes).routeCid
                add(out.eagerEdges, eagerEdge)
                continue
            var bestParentPos: int32 = -1
            var bestParentShared: int32 = -1
            var bestParentHop: int32 = -1
            var bestParentRouteCid: layout.FixedBytes32
            for candidateStep in 0..<memberStep:
                let candidate = members[candidateStep]
                let candidateRouteRes = lsmr.LsmrRoutePlanFromAddresses(candidate.address, member.address)
                if IsErr(candidateRouteRes):
                    return Err[PlumtreePlan](Error(candidateRouteRes))
                let candidateRoute = Value(candidateRouteRes)
                let candidateShared = lsmr.LsmrSharedPrefixDepth(candidate.address, member.address)
                var takeCandidate = false
                if bestParentPos < 0:
                    takeCandidate = true
                elif candidateShared > bestParentShared:
                    takeCandidate = true
                elif candidateShared == bestParentShared && candidateRoute.hopCount < bestParentHop:
                    takeCandidate = true
                elif candidateShared == bestParentShared && candidateRoute.hopCount == bestParentHop:
                    let bestParent = members[bestParentPos]
                    if pubsub.PubSubAddressLess(candidate.address, bestParent.address):
                        takeCandidate = true
                    elif types.LsmrAddressEqual(candidate.address, bestParent.address) &&
                         candidate.nodeId < bestParent.nodeId:
                        takeCandidate = true
                if takeCandidate:
                    bestParentPos = candidateStep
                    bestParentShared = candidateShared
                    bestParentHop = candidateRoute.hopCount
                    bestParentRouteCid = candidateRoute.routeCid
            if bestParentPos < 0:
                return Err[PlumtreePlan](" plumtree: missing eager parent")
            let bestParent = members[bestParentPos]
            var eagerEdge: PlumtreeEagerEdge
            eagerEdge.parentNodeId = bestParent.nodeId
            eagerEdge.parentAddress = bestParent.address
            eagerEdge.childNodeId = member.nodeId
            eagerEdge.childAddress = member.address
            eagerEdge.branchDigit = branchDigit
            eagerEdge.routeCid = bestParentRouteCid
            add(out.eagerEdges, eagerEdge)

            let rootLazyRouteRes = lsmr.LsmrRoutePlanFromAddresses(root.address, member.address)
            if IsErr(rootLazyRouteRes):
                return Err[PlumtreePlan](Error(rootLazyRouteRes))
            var rootLazy: PlumtreeLazyPeer
            rootLazy.ownerNodeId = member.nodeId
            rootLazy.ownerAddress = member.address
            rootLazy.peerNodeId = root.nodeId
            rootLazy.peerAddress = root.address
            rootLazy.branchDigit = branchDigit
            rootLazy.sharedPrefixDepth = lsmr.LsmrSharedPrefixDepth(root.address, member.address)
            rootLazy.hopCount = Value(rootLazyRouteRes).hopCount
            rootLazy.routeCid = Value(rootLazyRouteRes).routeCid
            add(out.lazyPeers, rootLazy)
            add(out.ihaves,
                PlumtreeIhaveMake(out.envelopeCid,
                                    root.nodeId,
                                    root.address,
                                    member.nodeId,
                                    member.address,
                                    branchDigit,
                                    rootLazy.routeCid))

            for candidateStep in 0..<memberStep:
                if candidateStep == bestParentPos:
                    continue
                let candidate = members[candidateStep]
                let candidateRouteRes = lsmr.LsmrRoutePlanFromAddresses(candidate.address, member.address)
                if IsErr(candidateRouteRes):
                    return Err[PlumtreePlan](Error(candidateRouteRes))
                let candidateRoute = Value(candidateRouteRes)
                var lazyPeer: PlumtreeLazyPeer
                lazyPeer.ownerNodeId = member.nodeId
                lazyPeer.ownerAddress = member.address
                lazyPeer.peerNodeId = candidate.nodeId
                lazyPeer.peerAddress = candidate.address
                lazyPeer.branchDigit = branchDigit
                lazyPeer.sharedPrefixDepth = lsmr.LsmrSharedPrefixDepth(candidate.address, member.address)
                lazyPeer.hopCount = candidateRoute.hopCount
                lazyPeer.routeCid = candidateRoute.routeCid
                add(out.lazyPeers, lazyPeer)
                add(out.ihaves,
                    PlumtreeIhaveMake(out.envelopeCid,
                                        candidate.nodeId,
                                        candidate.address,
                                        member.nodeId,
                                        member.address,
                                        branchDigit,
                                        candidateRoute.routeCid))
        out.eagerEdgeCount = out.eagerEdges.len
        out.lazyPeerCount = out.lazyPeers.len
        out.ihaveCount = out.ihaves.len
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.plumtree.plan"))
    lt.AppendFixed32(buf, out.topicCid)
    lt.AppendFixed32(buf, out.envelopeCid)
    lt.AppendU32BE(buf, out.rootNodeId)
    lt.AppendAddress(buf, out.rootAddress)
    lt.AppendU32BE(buf, out.nodeCount)
    lt.AppendU32BE(buf, out.branchCount)
    lt.AppendU32BE(buf, out.eagerEdgeCount)
    lt.AppendU32BE(buf, out.lazyPeerCount)
    lt.AppendU32BE(buf, out.ihaveCount)
    for i in 0..<out.branchDigits.len:
        lt.AppendU32BE(buf, out.branchDigits[i])
    for i in 0..<out.eagerEdges.len:
        lt.AppendU32BE(buf, out.eagerEdges[i].parentNodeId)
        lt.AppendAddress(buf, out.eagerEdges[i].parentAddress)
        lt.AppendU32BE(buf, out.eagerEdges[i].childNodeId)
        lt.AppendAddress(buf, out.eagerEdges[i].childAddress)
        lt.AppendU32BE(buf, out.eagerEdges[i].branchDigit)
        lt.AppendFixed32(buf, out.eagerEdges[i].routeCid)
    for i in 0..<out.lazyPeers.len:
        lt.AppendU32BE(buf, out.lazyPeers[i].ownerNodeId)
        lt.AppendAddress(buf, out.lazyPeers[i].ownerAddress)
        lt.AppendU32BE(buf, out.lazyPeers[i].peerNodeId)
        lt.AppendAddress(buf, out.lazyPeers[i].peerAddress)
        lt.AppendU32BE(buf, out.lazyPeers[i].branchDigit)
        lt.AppendU32BE(buf, out.lazyPeers[i].sharedPrefixDepth)
        lt.AppendU32BE(buf, out.lazyPeers[i].hopCount)
        lt.AppendFixed32(buf, out.lazyPeers[i].routeCid)
    for i in 0..<out.ihaves.len:
        lt.AppendFixed32(buf, out.ihaves[i].envelopeCid)
        lt.AppendU32BE(buf, out.ihaves[i].fromNodeId)
        lt.AppendAddress(buf, out.ihaves[i].fromAddress)
        lt.AppendU32BE(buf, out.ihaves[i].toNodeId)
        lt.AppendAddress(buf, out.ihaves[i].toAddress)
        lt.AppendU32BE(buf, out.ihaves[i].branchDigit)
        lt.AppendFixed32(buf, out.ihaves[i].routeCid)
        lt.AppendFixed32(buf, out.ihaves[i].advertCid)
    out.planCid = lt.FixedCidFromBuf(buf)
    return Ok[PlumtreePlan](out)

fn PlumtreeSelectRepair(plan: PlumtreePlan, missingNodeId: int32): Result[PlumtreeIwant] =
    var bestPos: int32 = -1
    for i in 0..<plan.lazyPeers.len:
        let lazyPeer = plan.lazyPeers[i]
        if lazyPeer.ownerNodeId != missingNodeId:
            continue
        var advertised = false
        for j in 0..<plan.ihaves.len:
            if plan.ihaves[j].toNodeId == lazyPeer.ownerNodeId &&
               plan.ihaves[j].fromNodeId == lazyPeer.peerNodeId &&
               plan.ihaves[j].branchDigit == lazyPeer.branchDigit &&
               layout.FixedBytes32Equal(plan.ihaves[j].routeCid, lazyPeer.routeCid):
                advertised = true
                break
        if !advertised:
            continue
        var takeLazyPeer = false
        if bestPos < 0:
            takeLazyPeer = true
        elif lazyPeer.sharedPrefixDepth > plan.lazyPeers[bestPos].sharedPrefixDepth:
            takeLazyPeer = true
        elif lazyPeer.sharedPrefixDepth == plan.lazyPeers[bestPos].sharedPrefixDepth &&
             lazyPeer.hopCount < plan.lazyPeers[bestPos].hopCount:
            takeLazyPeer = true
        elif lazyPeer.sharedPrefixDepth == plan.lazyPeers[bestPos].sharedPrefixDepth &&
             lazyPeer.hopCount == plan.lazyPeers[bestPos].hopCount:
            let bestLazyPeer = plan.lazyPeers[bestPos]
            if pubsub.PubSubAddressLess(lazyPeer.peerAddress, bestLazyPeer.peerAddress):
                takeLazyPeer = true
            elif types.LsmrAddressEqual(lazyPeer.peerAddress, bestLazyPeer.peerAddress) &&
                 lazyPeer.peerNodeId < bestLazyPeer.peerNodeId:
                takeLazyPeer = true
        if takeLazyPeer:
            bestPos = i
    if bestPos < 0:
        return Err[PlumtreeIwant](" plumtree: missing repair source")
    let best = plan.lazyPeers[bestPos]
    var out: PlumtreeIwant
    out.envelopeCid = plan.envelopeCid
    out.missingNodeId = best.ownerNodeId
    out.missingAddress = best.ownerAddress
    out.sourceNodeId = best.peerNodeId
    out.sourceAddress = best.peerAddress
    out.branchDigit = best.branchDigit
    out.routeCid = best.routeCid
    var buf: layout.ByteBuf = layout.ByteBufInit(128)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.plumtree.iwant"))
    lt.AppendFixed32(buf, out.envelopeCid)
    lt.AppendU32BE(buf, out.missingNodeId)
    lt.AppendU32BE(buf, out.sourceNodeId)
    lt.AppendU32BE(buf, out.branchDigit)
    lt.AppendFixed32(buf, out.routeCid)
    out.requestCid = lt.FixedCidFromBuf(buf)
    return Ok[PlumtreeIwant](out)

fn PlumtreeEagerParentNodeId(plan: PlumtreePlan, childNodeId: int32): int32 =
    for i in 0..<plan.eagerEdges.len:
        if plan.eagerEdges[i].childNodeId == childNodeId:
            return plan.eagerEdges[i].parentNodeId
    return 0

fn PlumtreeLazyPeerCount(plan: PlumtreePlan, ownerNodeId: int32): int32 =
    var out: int32
    for i in 0..<plan.lazyPeers.len:
        if plan.lazyPeers[i].ownerNodeId == ownerNodeId:
            out = out + 1
    return out
