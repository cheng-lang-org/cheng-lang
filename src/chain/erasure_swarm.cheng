import std/result
import std/rawbytes
import std/crypto/gf256
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/codec_binary as codec
import cheng/chain/dag_mempool as dag
import cheng/chain/lsmr_types as lt

const
    ErasureLayoutRsSystematic: int32 = 1
    ErasureAvailabilityPermilleMax: int32 = 1000
    ErasureManifestMagic: str = "cheng.erasure.manifest.payload"
    ErasureRecoveryPlanMagic: str = "cheng.erasure.recovery.plan"
    ErasureShardPullRequestMagic: str = "cheng.erasure.pull.request"
    ErasureShardPullResponseMagic: str = "cheng.erasure.pull.response"

type
    ErasureEncodingParams =
        version: int32 = 1
        layoutKind: int32
        dataShardCount: int32
        parityShardCount: int32
        shardPayloadBytes: int32
        paramsCid: layout.FixedBytes32

    ErasureShardManifest =
        version: int32 = 1
        blobCid: layout.FixedBytes32
        blobByteLen: int32
        paramsCid: layout.FixedBytes32
        shardCount: int32
        shardIndices: int32[]
        shardPayloadCids: layout.FixedBytes32[]
        manifestCid: layout.FixedBytes32

    ErasurePeerAdvert =
        version: int32 = 1
        peerId: layout.FixedBytes32
        blobCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        shardCount: int32
        shardIndices: int32[]
        shardPayloadCids: layout.FixedBytes32[]
        availabilityPermille: int32
        maxConcurrentPulls: int32
        advertCid: layout.FixedBytes32

    ErasureRecoveryPlan =
        version: int32 = 1
        blobCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        minShardCount: int32
        requestCount: int32
        uniquePeerCount: int32
        uniqueShardCount: int32
        requestPeerIds: layout.FixedBytes32[]
        requestShardIndices: int32[]
        requestShardCids: layout.FixedBytes32[]
        requestAdvertCids: layout.FixedBytes32[]
        planCid: layout.FixedBytes32

    ErasureShardPullRequest =
        version: int32 = 1
        manifestCid: layout.FixedBytes32
        shardIndex: int32
        shardCid: layout.FixedBytes32
        requestCid: layout.FixedBytes32

    ErasureShardPullResponse =
        version: int32 = 1
        manifestCid: layout.FixedBytes32
        shardIndex: int32
        shardCid: layout.FixedBytes32
        payloadLen: int32
        payload: Bytes
        responseCid: layout.FixedBytes32

fn ErasurePeerAdvertFill(out: var ErasurePeerAdvert,
                           advert: ErasurePeerAdvert) =
    out = ErasurePeerAdvert()
    out.version = advert.version
    out.peerId = advert.peerId
    out.blobCid = advert.blobCid
    out.manifestCid = advert.manifestCid
    out.shardCount = advert.shardCount
    out.availabilityPermille = advert.availabilityPermille
    out.maxConcurrentPulls = advert.maxConcurrentPulls
    out.advertCid = advert.advertCid
    out.shardIndices = []
    for i in 0..<advert.shardIndices.len:
        add(out.shardIndices, advert.shardIndices[i])
    out.shardPayloadCids = []
    for i in 0..<advert.shardPayloadCids.len:
        add(out.shardPayloadCids, advert.shardPayloadCids[i])

fn ErasurePeerAdvertAppend(out: var ErasurePeerAdvert[],
                             advert: ErasurePeerAdvert) =
    let insert = ErasurePeerAdvert()
    add(out, insert)
    let idx = out.len - 1
    ErasurePeerAdvertFill(out[idx], advert)

fn ErasurePayloadHasMagic(payload: Bytes, magic: str): bool =
    let magicBytes = BytesFromString(magic)
    if BytesLen(payload) < BytesLen(magicBytes):
        return false
    for i in 0..<BytesLen(magicBytes):
        if BytesGet(payload, i) != BytesGet(magicBytes, i):
            return false
    return true

fn ErasureShardPayloadCid(payload: Bytes): layout.FixedBytes32 =
    return hash256.Sha256Fixed(layout.ByteSpanFromBytes(payload))

fn ErasureTotalShardCount(params: ErasureEncodingParams): int32 =
    return params.dataShardCount + params.parityShardCount

fn ErasureRecoveryThreshold(params: ErasureEncodingParams): int32 =
    return params.dataShardCount

fn ErasureMatrixPos(cols: int32, row: int32, col: int32): int32 =
    return row * cols + col

fn ErasureMatrixInit(rows: int32, cols: int32): int32[] =
    var out: int32[]
    out = []
    for i in 0..<(rows * cols):
        add(out, 0)
    return out

fn ErasureMatrixSwapRows(matrix: var int32[],
                           cols: int32,
                           rowA: int32,
                           rowB: int32) =
    if rowA == rowB:
        return
    for col in 0..<cols:
        let posA = ErasureMatrixPos(cols, rowA, col)
        let posB = ErasureMatrixPos(cols, rowB, col)
        let tmp = matrix[posA]
        matrix[posA] = matrix[posB]
        matrix[posB] = tmp

fn ErasureMatrixIdentity(size: int32): int32[] =
    var out = ErasureMatrixInit(size, size)
    for i in 0..<size:
        out[ErasureMatrixPos(size, i, i)] = 1
    return out

fn ErasureMatrixVandermonde(rows: int32, cols: int32): int32[] =
    var out = ErasureMatrixInit(rows, cols)
    for row in 0..<rows:
        let x = (row + 1) & 255
        var value = 1
        for col in 0..<cols:
            out[ErasureMatrixPos(cols, row, col)] = value
            value = gf256.Gf256Mul(value, x)
    return out

fn ErasureMatrixMultiplyFill(out: var int32[],
                               left: int32[],
                               leftRows: int32,
                               leftCols: int32,
                               right: int32[],
                               rightCols: int32): Result[bool] =
    if leftRows < 0:
        return Err[bool](" erasure swarm: invalid left row count")
    if leftCols <= 0:
        return Err[bool](" erasure swarm: invalid left col count")
    if rightCols <= 0:
        return Err[bool](" erasure swarm: invalid right col count")
    if left.len != leftRows * leftCols:
        return Err[bool](" erasure swarm: invalid left matrix shape")
    if right.len != leftCols * rightCols:
        return Err[bool](" erasure swarm: invalid right matrix shape")
    out = ErasureMatrixInit(leftRows, rightCols)
    for row in 0..<leftRows:
        for col in 0..<rightCols:
            var acc = 0
            for pivot in 0..<leftCols:
                let leftValue = left[ErasureMatrixPos(leftCols, row, pivot)]
                let rightValue = right[ErasureMatrixPos(rightCols, pivot, col)]
                acc = acc ^ gf256.Gf256Mul(leftValue, rightValue)
            out[ErasureMatrixPos(rightCols, row, col)] = acc
    return Ok[bool](true)

fn ErasureMatrixInvertFill(out: var int32[],
                             matrix: int32[],
                             size: int32): Result[bool] =
    if size <= 0:
        return Err[bool](" erasure swarm: invalid matrix size")
    if matrix.len != size * size:
        return Err[bool](" erasure swarm: invalid square matrix shape")
    let augCols = size * 2
    var aug = ErasureMatrixInit(size, augCols)
    for row in 0..<size:
        for col in 0..<size:
            let augPos = ErasureMatrixPos(augCols, row, col)
            let srcPos = ErasureMatrixPos(size, row, col)
            aug[augPos] = matrix[srcPos]
        let diagPos = ErasureMatrixPos(augCols, row, size + row)
        aug[diagPos] = 1
    for pivot in 0..<size:
        var pivotRow = pivot
        while pivotRow < size && aug[ErasureMatrixPos(augCols, pivotRow, pivot)] == 0:
            pivotRow = pivotRow + 1
        if pivotRow >= size:
            return Err[bool](" erasure swarm: matrix not invertible")
        ErasureMatrixSwapRows(aug, augCols, pivot, pivotRow)
        let pivotValue = aug[ErasureMatrixPos(augCols, pivot, pivot)]
        let invPivotRes = gf256.Gf256Inv(pivotValue)
        if IsErr(invPivotRes):
            return Err[bool](Error(invPivotRes))
        let invPivot = Value(invPivotRes)
        for col in 0..<augCols:
            let pivotPos = ErasureMatrixPos(augCols, pivot, col)
            let scaled = gf256.Gf256Mul(aug[pivotPos], invPivot)
            aug[pivotPos] = scaled
        for row in 0..<size:
            if row == pivot:
                continue
            let factor = aug[ErasureMatrixPos(augCols, row, pivot)]
            if factor == 0:
                continue
            for col in 0..<augCols:
                let pivotValueAtCol = aug[ErasureMatrixPos(augCols, pivot, col)]
                let mixed = gf256.Gf256Mul(factor, pivotValueAtCol)
                let rowPos = ErasureMatrixPos(augCols, row, col)
                aug[rowPos] = aug[rowPos] ^ mixed
    out = ErasureMatrixInit(size, size)
    for row in 0..<size:
        for col in 0..<size:
            let outPos = ErasureMatrixPos(size, row, col)
            let augPos = ErasureMatrixPos(augCols, row, size + col)
            out[outPos] = aug[augPos]
    return Ok[bool](true)

fn ErasureGeneratorMatrixFill(out: var int32[],
                                params: ErasureEncodingParams): Result[bool] =
    let totalRes = ErasureEncodingParamsValidate(params)
    if IsErr(totalRes):
        return Err[bool](Error(totalRes))
    let total = Value(totalRes)
    let dataCount = params.dataShardCount
    out = ErasureMatrixInit(total, dataCount)
    for row in 0..<dataCount:
        let pos = ErasureMatrixPos(dataCount, row, row)
        out[pos] = 1
    for row in dataCount..<total:
        let x = ((row - dataCount) + 1) & 255
        var value = 1
        for col in 0..<dataCount:
            let pos = ErasureMatrixPos(dataCount, row, col)
            out[pos] = value
            value = gf256.Gf256Mul(value, x)
    return Ok[bool](true)

fn ErasureEncodeShardPayloads(blob: Bytes,
                                params: ErasureEncodingParams): Result[Bytes[]] =
    let totalRes = ErasureEncodingParamsValidate(params)
    if IsErr(totalRes):
        return Err[Bytes[]](Error(totalRes))
    let dataCount = params.dataShardCount
    let payloadBytes = params.shardPayloadBytes
    let total = Value(totalRes)
    if BytesLen(blob) > dataCount * payloadBytes:
        return Err[Bytes[]](" erasure swarm: blob exceeds shard capacity")
    var generator: int32[]
    generator = []
    let generatorRes = ErasureGeneratorMatrixFill(generator, params)
    if IsErr(generatorRes):
        return Err[Bytes[]](Error(generatorRes))
    var dataShards: Bytes[]
    dataShards = []
    for shardIndex in 0..<dataCount:
        add(dataShards, EmptyBytes())
    var next = 0
    for shardIndex in 0..<dataCount:
        let shard = BytesAlloc(payloadBytes)
        for bytePos in 0..<payloadBytes:
            if next < BytesLen(blob):
                BytesSet(shard, bytePos, BytesGet(blob, next))
                next = next + 1
            else:
                BytesSet(shard, bytePos, 0)
        dataShards[shardIndex] = shard
    var out: Bytes[]
    out = []
    for shardIndex in 0..<total:
        add(out, EmptyBytes())
    for shardIndex in 0..<dataCount:
        out[shardIndex] = dataShards[shardIndex]
    for shardIndex in dataCount..<total:
        let shard = BytesAlloc(payloadBytes)
        for bytePos in 0..<payloadBytes:
            var acc = 0
            for dataIndex in 0..<dataCount:
                let coef = generator[ErasureMatrixPos(dataCount, shardIndex, dataIndex)]
                acc = acc ^ gf256.Gf256Mul(BytesGet(dataShards[dataIndex], bytePos), coef)
            BytesSet(shard, bytePos, acc)
        out[shardIndex] = shard
    return Ok[Bytes[]](out)

fn ErasureRebuildBlob(manifest: ErasureShardManifest,
                        params: ErasureEncodingParams,
                        shardIndices: int32[],
                        shardPayloads: Bytes[]): Result[Bytes] =
    let totalRes = ErasureEncodingParamsValidate(params)
    if IsErr(totalRes):
        return Err[Bytes](Error(totalRes))
    let manifestRes = ErasureManifestValidate(manifest, params)
    if IsErr(manifestRes):
        return Err[Bytes](Error(manifestRes))
    if shardIndices.len != shardPayloads.len:
        return Err[Bytes](" erasure swarm: shard payload count mismatch")
    let threshold = ErasureRecoveryThreshold(params)
    let payloadBytes = params.shardPayloadBytes
    if params.parityShardCount == 0:
        var rawBuf: layout.ByteBuf = layout.ByteBufInit(params.dataShardCount * payloadBytes)
        for dataIndex in 0..<params.dataShardCount:
            var found = false
            for i in 0..<shardIndices.len:
                if shardIndices[i] == dataIndex:
                    if BytesLen(shardPayloads[i]) != payloadBytes:
                        return Err[Bytes](" erasure swarm: shard payload length mismatch")
                    let manifestPos = ErasureManifestShardPos(manifest, dataIndex)
                    if manifestPos < 0:
                        return Err[Bytes](" erasure swarm: shard index missing in manifest")
                    if !layout.FixedBytes32Equal(ErasureShardPayloadCid(shardPayloads[i]), manifest.shardPayloadCids[manifestPos]):
                        return Err[Bytes](" erasure swarm: shard payload cid mismatch")
                    layout.ByteBufAppendBytes(rawBuf, shardPayloads[i])
                    found = true
                    break
            if !found:
                return Err[Bytes](" erasure swarm: insufficient unique shards for rebuild")
        let rawNoParity = layout.ByteBufToBytes(rawBuf)
        if manifest.blobByteLen > BytesLen(rawNoParity):
            return Err[Bytes](" erasure swarm: rebuilt blob too short")
        let blobNoParity = BytesSlice(rawNoParity, 0, manifest.blobByteLen)
        if !layout.FixedBytes32Equal(dag.DagBlobCidFromBytes(blobNoParity), manifest.blobCid):
            return Err[Bytes](" erasure swarm: rebuilt blob cid mismatch")
        return Ok[Bytes](blobNoParity)
    var generator: int32[]
    generator = []
    let generatorRes = ErasureGeneratorMatrixFill(generator, params)
    if IsErr(generatorRes):
        return Err[Bytes](Error(generatorRes))
    var selected: bool[]
    selected = []
    for i in 0..<manifest.shardCount:
        add(selected, false)
    var chosenIndices: int32[]
    chosenIndices = []
    for i in 0..<threshold:
        add(chosenIndices, 0)
    var chosenPayloads: Bytes[]
    chosenPayloads = []
    for i in 0..<threshold:
        add(chosenPayloads, EmptyBytes())
    var chosenCount = 0
    for i in 0..<shardIndices.len:
        let shardIndex = shardIndices[i]
        if shardIndex < 0 || shardIndex >= manifest.shardCount:
            return Err[Bytes](" erasure swarm: shard index out of range")
        if selected[shardIndex]:
            continue
        if BytesLen(shardPayloads[i]) != payloadBytes:
            return Err[Bytes](" erasure swarm: shard payload length mismatch")
        let manifestPos = ErasureManifestShardPos(manifest, shardIndex)
        if manifestPos < 0:
            return Err[Bytes](" erasure swarm: shard index missing in manifest")
        if !layout.FixedBytes32Equal(ErasureShardPayloadCid(shardPayloads[i]), manifest.shardPayloadCids[manifestPos]):
            return Err[Bytes](" erasure swarm: shard payload cid mismatch")
        selected[shardIndex] = true
        chosenIndices[chosenCount] = shardIndex
        chosenPayloads[chosenCount] = shardPayloads[i]
        chosenCount = chosenCount + 1
        if chosenCount >= threshold:
            break
    if chosenCount < threshold:
        return Err[Bytes](" erasure swarm: insufficient unique shards for rebuild")
    var chosenMatrix = ErasureMatrixInit(threshold, threshold)
    for row in 0..<threshold:
        for col in 0..<threshold:
            let chosenPos = ErasureMatrixPos(threshold, row, col)
            let generatorPos = ErasureMatrixPos(threshold, chosenIndices[row], col)
            chosenMatrix[chosenPos] = generator[generatorPos]
    var chosenInv: int32[]
    chosenInv = []
    let chosenInvRes = ErasureMatrixInvertFill(chosenInv, chosenMatrix, threshold)
    if IsErr(chosenInvRes):
        return Err[Bytes](Error(chosenInvRes))
    var buf: layout.ByteBuf = layout.ByteBufInit(threshold * payloadBytes)
    for dataIndex in 0..<threshold:
        let shard = BytesAlloc(payloadBytes)
        for bytePos in 0..<payloadBytes:
            var acc = 0
            for row in 0..<threshold:
                let coef = chosenInv[ErasureMatrixPos(threshold, dataIndex, row)]
                acc = acc ^ gf256.Gf256Mul(BytesGet(chosenPayloads[row], bytePos), coef)
            BytesSet(shard, bytePos, acc)
        layout.ByteBufAppendBytes(buf, shard)
    let raw = layout.ByteBufToBytes(buf)
    if manifest.blobByteLen > BytesLen(raw):
        return Err[Bytes](" erasure swarm: rebuilt blob too short")
    let blob = BytesSlice(raw, 0, manifest.blobByteLen)
    if !layout.FixedBytes32Equal(dag.DagBlobCidFromBytes(blob), manifest.blobCid):
        return Err[Bytes](" erasure swarm: rebuilt blob cid mismatch")
    return Ok[Bytes](blob)

fn ErasureRebuildBlobFromResponses(manifest: ErasureShardManifest,
                                     params: ErasureEncodingParams,
                                     responses: ErasureShardPullResponse[]): Result[Bytes] =
    var shardIndices: int32[]
    shardIndices = []
    var shardPayloads: Bytes[]
    shardPayloads = []
    for i in 0..<responses.len:
        add(shardIndices, 0)
        add(shardPayloads, EmptyBytes())
    for i in 0..<responses.len:
        let response = responses[i]
        if response.version != 1:
            return Err[Bytes](" erasure swarm: unsupported shard pull response version")
        if !layout.FixedBytes32Equal(response.manifestCid, manifest.manifestCid):
            return Err[Bytes](" erasure swarm: shard pull response manifest mismatch")
        if response.payloadLen != BytesLen(response.payload):
            return Err[Bytes](" erasure swarm: shard pull response payload length mismatch")
        if !layout.FixedBytes32Equal(ErasureShardPayloadCid(response.payload), response.shardCid):
            return Err[Bytes](" erasure swarm: shard pull response payload cid mismatch")
        let manifestPos = ErasureManifestShardPos(manifest, response.shardIndex)
        if manifestPos < 0:
            return Err[Bytes](" erasure swarm: shard pull response index mismatch")
        if !layout.FixedBytes32Equal(response.shardCid, manifest.shardPayloadCids[manifestPos]):
            return Err[Bytes](" erasure swarm: shard pull response cid mismatch")
        shardIndices[i] = response.shardIndex
        shardPayloads[i] = response.payload
    return ErasureRebuildBlob(manifest, params, shardIndices, shardPayloads)

fn ErasureEncodingParamsValidate(params: ErasureEncodingParams): Result[int32] =
    if params.layoutKind != ErasureLayoutRsSystematic:
        return Err[int32](" erasure swarm: unsupported layout kind")
    if params.dataShardCount <= 0:
        return Err[int32](" erasure swarm: invalid data shard count")
    if params.parityShardCount < 0:
        return Err[int32](" erasure swarm: invalid parity shard count")
    if params.shardPayloadBytes <= 0:
        return Err[int32](" erasure swarm: invalid shard payload bytes")
    return Ok[int32](ErasureTotalShardCount(params))

fn ErasureEncodingParamsMake(layoutKind: int32,
                               dataShardCount: int32,
                               parityShardCount: int32,
                               shardPayloadBytes: int32): Result[ErasureEncodingParams] =
    var out = ErasureEncodingParams()
    out.layoutKind = layoutKind
    out.dataShardCount = dataShardCount
    out.parityShardCount = parityShardCount
    out.shardPayloadBytes = shardPayloadBytes
    let totalRes = ErasureEncodingParamsValidate(out)
    if IsErr(totalRes):
        return Err[ErasureEncodingParams](Error(totalRes))
    var buf: layout.ByteBuf = layout.ByteBufInit(64)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.erasure.params"))
    lt.AppendU32BE(buf, out.layoutKind)
    lt.AppendU32BE(buf, out.dataShardCount)
    lt.AppendU32BE(buf, out.parityShardCount)
    lt.AppendU32BE(buf, out.shardPayloadBytes)
    out.paramsCid = lt.FixedCidFromBuf(buf)
    return Ok[ErasureEncodingParams](out)

fn ErasureManifestShardPos(manifest: ErasureShardManifest, shardIndex: int32): int32 =
    for i in 0..<manifest.shardIndices.len:
        if manifest.shardIndices[i] == shardIndex:
            return i
    return -1

fn ErasureShardIndexPos(shardIndices: int32[],
                          shardIndex: int32): int32 =
    for i in 0..<shardIndices.len:
        if shardIndices[i] == shardIndex:
            return i
    return -1

fn ErasureManifestValidate(manifest: ErasureShardManifest,
                             params: ErasureEncodingParams): Result[int32] =
    let totalRes = ErasureEncodingParamsValidate(params)
    if IsErr(totalRes):
        return Err[int32](Error(totalRes))
    let totalShards = Value(totalRes)
    if manifest.blobByteLen < 0:
        return Err[int32](" erasure swarm: invalid blob byte length")
    if manifest.shardCount != totalShards:
        return Err[int32](" erasure swarm: manifest shard count mismatch")
    if manifest.shardIndices.len != manifest.shardCount:
        return Err[int32](" erasure swarm: manifest shard index count mismatch")
    if manifest.shardPayloadCids.len != manifest.shardCount:
        return Err[int32](" erasure swarm: manifest shard cid count mismatch")
    for i in 0..<manifest.shardCount:
        if manifest.shardIndices[i] < 0 || manifest.shardIndices[i] >= manifest.shardCount:
            return Err[int32](" erasure swarm: manifest shard index out of range")
    return Ok[int32](totalShards)

fn ErasureShardManifestMake(blobCid: layout.FixedBytes32,
                              blobByteLen: int32,
                              params: ErasureEncodingParams,
                              shardPayloadCids: layout.FixedBytes32[]): Result[ErasureShardManifest] =
    let totalRes = ErasureEncodingParamsValidate(params)
    if IsErr(totalRes):
        return Err[ErasureShardManifest](Error(totalRes))
    let totalShards = Value(totalRes)
    if shardPayloadCids.len != totalShards:
        return Err[ErasureShardManifest](" erasure swarm: shard payload cid count mismatch")
    var out = ErasureShardManifest()
    out.blobCid = blobCid
    out.blobByteLen = blobByteLen
    out.paramsCid = params.paramsCid
    out.shardCount = totalShards
    for i in 0..<totalShards:
        add(out.shardIndices, 0)
        add(out.shardPayloadCids, layout.FixedBytes32())
    for i in 0..<totalShards:
        out.shardIndices[i] = i
        out.shardPayloadCids[i] = shardPayloadCids[i]
    var buf: layout.ByteBuf = layout.ByteBufInit(96 + totalShards * 36)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.erasure.manifest"))
    lt.AppendFixed32(buf, blobCid)
    lt.AppendU32BE(buf, blobByteLen)
    lt.AppendFixed32(buf, params.paramsCid)
    lt.AppendU32BE(buf, totalShards)
    for i in 0..<totalShards:
        lt.AppendU32BE(buf, i)
        lt.AppendFixed32(buf, shardPayloadCids[i])
    out.manifestCid = lt.FixedCidFromBuf(buf)
    let validateRes = ErasureManifestValidate(out, params)
    if IsErr(validateRes):
        return Err[ErasureShardManifest](Error(validateRes))
    return Ok[ErasureShardManifest](out)

fn ErasureShardManifestEncode(manifest: ErasureShardManifest): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString(ErasureManifestMagic))
    lt.AppendU32BE(buf, manifest.version)
    lt.AppendFixed32(buf, manifest.blobCid)
    lt.AppendU32BE(buf, manifest.blobByteLen)
    lt.AppendFixed32(buf, manifest.paramsCid)
    lt.AppendU32BE(buf, manifest.shardCount)
    for i in 0..<manifest.shardCount:
        lt.AppendU32BE(buf, manifest.shardIndices[i])
        lt.AppendFixed32(buf, manifest.shardPayloadCids[i])
    return layout.ByteBufToBytes(buf)

fn ErasureShardManifestDecode(payload: Bytes): Result[ErasureShardManifest] =
    if !ErasurePayloadHasMagic(payload, ErasureManifestMagic):
        return Err[ErasureShardManifest](" erasure swarm: invalid manifest magic")
    let magicLen = BytesLen(BytesFromString(ErasureManifestMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[ErasureShardManifest](Error(versionRes))
    let blobCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(blobCidRes):
        return Err[ErasureShardManifest](Error(blobCidRes))
    let blobByteLenRes = codec.ReadU32BE(span, magicLen + 36)
    if IsErr(blobByteLenRes):
        return Err[ErasureShardManifest](Error(blobByteLenRes))
    let paramsCidRes = codec.ReadFixed32(span, magicLen + 40)
    if IsErr(paramsCidRes):
        return Err[ErasureShardManifest](Error(paramsCidRes))
    let shardCountRes = codec.ReadU32BE(span, magicLen + 72)
    if IsErr(shardCountRes):
        return Err[ErasureShardManifest](Error(shardCountRes))
    let shardCount = int32(Value(shardCountRes))
    if shardCount < 0:
        return Err[ErasureShardManifest](" erasure swarm: invalid manifest shard count")
    var next = magicLen + 76
    var shardIndices: int32[]
    shardIndices = []
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    for i in 0..<shardCount:
        add(shardIndices, 0)
        add(shardPayloadCids, layout.FixedBytes32())
    var out = ErasureShardManifest()
    out.version = int32(Value(versionRes))
    out.blobCid = Value(blobCidRes)
    out.blobByteLen = int32(Value(blobByteLenRes))
    out.paramsCid = Value(paramsCidRes)
    out.shardCount = shardCount
    for i in 0..<shardCount:
        let shardIndexRes = codec.ReadU32BE(span, next)
        if IsErr(shardIndexRes):
            return Err[ErasureShardManifest](Error(shardIndexRes))
        next = next + 4
        let shardCidRes = codec.ReadFixed32(span, next)
        if IsErr(shardCidRes):
            return Err[ErasureShardManifest](Error(shardCidRes))
        next = next + 32
        shardIndices[i] = int32(Value(shardIndexRes))
        shardPayloadCids[i] = Value(shardCidRes)
    var buf: layout.ByteBuf = layout.ByteBufInit(96 + shardCount * 36)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.erasure.manifest"))
    lt.AppendFixed32(buf, out.blobCid)
    lt.AppendU32BE(buf, out.blobByteLen)
    lt.AppendFixed32(buf, out.paramsCid)
    lt.AppendU32BE(buf, out.shardCount)
    for i in 0..<shardCount:
        let shardIndex = shardIndices[i]
        if shardIndex < 0 || shardIndex >= shardCount:
            return Err[ErasureShardManifest](" erasure swarm: manifest shard index out of range")
        lt.AppendU32BE(buf, shardIndex)
        lt.AppendFixed32(buf, shardPayloadCids[i])
    out.shardIndices = shardIndices
    out.shardPayloadCids = shardPayloadCids
    out.manifestCid = lt.FixedCidFromBuf(buf)
    if out.version != 1:
        return Err[ErasureShardManifest](" erasure swarm: unsupported manifest version")
    return Ok[ErasureShardManifest](out)

fn ErasureShardManifestValidatePayload(payload: Bytes,
                                         expectedCid: layout.FixedBytes32): Result[bool] =
    let manifestRes = ErasureShardManifestDecode(payload)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    if !layout.FixedBytes32Equal(Value(manifestRes).manifestCid, expectedCid):
        return Err[bool](" erasure swarm: manifest payload cid mismatch")
    return Ok[bool](true)

fn ErasureAdvertShardPos(advert: ErasurePeerAdvert, shardIndex: int32): int32 =
    for i in 0..<advert.shardIndices.len:
        if advert.shardIndices[i] == shardIndex:
            return i
    return -1

fn ErasurePeerAdvertValidate(advert: ErasurePeerAdvert,
                               manifest: ErasureShardManifest,
                               params: ErasureEncodingParams): Result[int32] =
    let manifestRes = ErasureManifestValidate(manifest, params)
    if IsErr(manifestRes):
        return Err[int32](Error(manifestRes))
    if !layout.FixedBytes32Equal(advert.blobCid, manifest.blobCid):
        return Err[int32](" erasure swarm: advert blob cid mismatch")
    if !layout.FixedBytes32Equal(advert.manifestCid, manifest.manifestCid):
        return Err[int32](" erasure swarm: advert manifest cid mismatch")
    if advert.shardCount <= 0:
        return Err[int32](" erasure swarm: advert shard count must be positive")
    if advert.shardIndices.len != advert.shardCount:
        return Err[int32](" erasure swarm: advert shard index count mismatch")
    if advert.shardPayloadCids.len != advert.shardCount:
        return Err[int32](" erasure swarm: advert shard cid count mismatch")
    if advert.availabilityPermille <= 0 ||
       advert.availabilityPermille > ErasureAvailabilityPermilleMax:
        return Err[int32](" erasure swarm: invalid advert availability permille")
    if advert.maxConcurrentPulls <= 0:
        return Err[int32](" erasure swarm: invalid advert concurrent pull limit")
    for i in 0..<advert.shardCount:
        let shardIndex = advert.shardIndices[i]
        let manifestPos = ErasureManifestShardPos(manifest, shardIndex)
        if manifestPos < 0:
            return Err[int32](" erasure swarm: advert shard index out of range")
        if !layout.FixedBytes32Equal(advert.shardPayloadCids[i], manifest.shardPayloadCids[manifestPos]):
            return Err[int32](" erasure swarm: advert shard cid mismatch")
        for j in i + 1..<advert.shardCount:
            if advert.shardIndices[j] == shardIndex:
                return Err[int32](" erasure swarm: advert shard index duplicated")
    return Ok[int32](advert.shardCount)

fn ErasurePeerAdvertMake(peerId: layout.FixedBytes32,
                           manifest: ErasureShardManifest,
                           params: ErasureEncodingParams,
                           shardIndices: int32[],
                           availabilityPermille: int32,
                           maxConcurrentPulls: int32): Result[ErasurePeerAdvert] =
    let manifestRes = ErasureManifestValidate(manifest, params)
    if IsErr(manifestRes):
        return Err[ErasurePeerAdvert](Error(manifestRes))
    var out = ErasurePeerAdvert()
    out.peerId = peerId
    out.blobCid = manifest.blobCid
    out.manifestCid = manifest.manifestCid
    out.availabilityPermille = availabilityPermille
    out.maxConcurrentPulls = maxConcurrentPulls
    out.shardCount = shardIndices.len
    for i in 0..<out.shardCount:
        add(out.shardIndices, 0)
        add(out.shardPayloadCids, layout.FixedBytes32())
    for i in 0..<shardIndices.len:
        let manifestPos = ErasureManifestShardPos(manifest, shardIndices[i])
        if manifestPos < 0:
            return Err[ErasurePeerAdvert](" erasure swarm: advert shard index out of range")
        out.shardIndices[i] = shardIndices[i]
        out.shardPayloadCids[i] = manifest.shardPayloadCids[manifestPos]
    var buf: layout.ByteBuf = layout.ByteBufInit(128 + out.shardCount * 36)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.erasure.advert"))
    lt.AppendFixed32(buf, out.peerId)
    lt.AppendFixed32(buf, out.blobCid)
    lt.AppendFixed32(buf, out.manifestCid)
    lt.AppendU32BE(buf, out.availabilityPermille)
    lt.AppendU32BE(buf, out.maxConcurrentPulls)
    lt.AppendU32BE(buf, out.shardCount)
    for i in 0..<out.shardCount:
        lt.AppendU32BE(buf, out.shardIndices[i])
        lt.AppendFixed32(buf, out.shardPayloadCids[i])
    out.advertCid = lt.FixedCidFromBuf(buf)
    let validateRes = ErasurePeerAdvertValidate(out, manifest, params)
    if IsErr(validateRes):
        return Err[ErasurePeerAdvert](Error(validateRes))
    return Ok[ErasurePeerAdvert](out)

fn ErasureCountAvailableUniqueShards(manifest: ErasureShardManifest,
                                       params: ErasureEncodingParams,
                                       adverts: ErasurePeerAdvert[]): Result[int32] =
    let manifestRes = ErasureManifestValidate(manifest, params)
    if IsErr(manifestRes):
        return Err[int32](Error(manifestRes))
    var selected: bool[]
    selected = []
    for i in 0..<manifest.shardCount:
        add(selected, false)
    var count = 0
    for i in 0..<adverts.len:
        var advert = ErasurePeerAdvert()
        ErasurePeerAdvertFill(advert, adverts[i])
        let advertRes = ErasurePeerAdvertValidate(advert, manifest, params)
        if IsErr(advertRes):
            return Err[int32](Error(advertRes))
        for j in 0..<advert.shardCount:
            let shardIndex = advert.shardIndices[j]
            if !selected[shardIndex]:
                selected[shardIndex] = true
                count = count + 1
            if count >= ErasureRecoveryThreshold(params):
                return Ok[int32](count)
    return Ok[int32](count)

fn ErasureCanRecover(manifest: ErasureShardManifest,
                       params: ErasureEncodingParams,
                       adverts: ErasurePeerAdvert[]): bool =
    let countRes = ErasureCountAvailableUniqueShards(manifest, params, adverts)
    if IsErr(countRes):
        return false
    return Value(countRes) >= ErasureRecoveryThreshold(params)

fn ErasureSelectPeerForShard(adverts: ErasurePeerAdvert[],
                               shardIndex: int32,
                               peerUseCounts: int32[]): int32 =
    var bestAdvert = -1
    var bestReuse = 0
    var bestShardCount = 0
    var bestAvailability = 0
    for i in 0..<adverts.len:
        var advert = ErasurePeerAdvert()
        ErasurePeerAdvertFill(advert, adverts[i])
        if ErasureAdvertShardPos(advert, shardIndex) < 0:
            continue
        let reuse = peerUseCounts[i]
        let shardCount = advert.shardCount
        let availability = advert.availabilityPermille
        if bestAdvert < 0:
            bestAdvert = i
            bestReuse = reuse
            bestShardCount = shardCount
            bestAvailability = availability
            continue
        var take = false
        if reuse < bestReuse:
            take = true
        elif reuse == bestReuse && shardCount < bestShardCount:
            take = true
        elif reuse == bestReuse && shardCount == bestShardCount && availability > bestAvailability:
            take = true
        elif reuse == bestReuse && shardCount == bestShardCount && availability == bestAvailability &&
             bestAdvert >= 0:
            var bestAdvertInfo = ErasurePeerAdvert()
            ErasurePeerAdvertFill(bestAdvertInfo, adverts[bestAdvert])
            if lt.FixedBytes32Less(advert.peerId, bestAdvertInfo.peerId):
                take = true
        if take:
            bestAdvert = i
            bestReuse = reuse
            bestShardCount = shardCount
            bestAvailability = availability
    return bestAdvert

fn ErasureBuildRecoveryPlan(manifest: ErasureShardManifest,
                              params: ErasureEncodingParams,
                              adverts: ErasurePeerAdvert[]): Result[ErasureRecoveryPlan] =
    let manifestRes = ErasureManifestValidate(manifest, params)
    if IsErr(manifestRes):
        return Err[ErasureRecoveryPlan](Error(manifestRes))
    for i in 0..<adverts.len:
        var advert = ErasurePeerAdvert()
        ErasurePeerAdvertFill(advert, adverts[i])
        let advertRes = ErasurePeerAdvertValidate(advert, manifest, params)
        if IsErr(advertRes):
            return Err[ErasureRecoveryPlan](Error(advertRes))
    let threshold = ErasureRecoveryThreshold(params)
    let availableRes = ErasureCountAvailableUniqueShards(manifest, params, adverts)
    if IsErr(availableRes):
        return Err[ErasureRecoveryPlan](Error(availableRes))
    if Value(availableRes) < threshold:
        return Err[ErasureRecoveryPlan](" erasure swarm: insufficient shards for recovery")
    var out = ErasureRecoveryPlan()
    out.blobCid = manifest.blobCid
    out.manifestCid = manifest.manifestCid
    out.minShardCount = threshold
    var requestPeerIds: layout.FixedBytes32[]
    requestPeerIds = []
    var requestShardIndices: int32[]
    requestShardIndices = []
    var requestShardCids: layout.FixedBytes32[]
    requestShardCids = []
    var requestAdvertCids: layout.FixedBytes32[]
    requestAdvertCids = []
    for i in 0..<threshold:
        add(requestPeerIds, layout.FixedBytes32())
        add(requestShardIndices, 0)
        add(requestShardCids, layout.FixedBytes32())
        add(requestAdvertCids, layout.FixedBytes32())
    var requestCount = 0
    var selected: bool[]
    selected = []
    var peerUseCounts: int32[]
    peerUseCounts = []
    for i in 0..<manifest.shardCount:
        add(selected, false)
    for i in 0..<adverts.len:
        add(peerUseCounts, 0)
    while requestCount < threshold:
        var bestShard = -1
        var bestAdvert = -1
        var bestCandidateCount = manifest.shardCount + adverts.len + 1
        var bestReuse = threshold + 1
        var bestAdvertShardCount = manifest.shardCount + 1
        var bestAvailability = -1
        for shardIndex in 0..<manifest.shardCount:
            if selected[shardIndex]:
                continue
            var candidateCount = 0
            for advertPos in 0..<adverts.len:
                var advert = ErasurePeerAdvert()
                ErasurePeerAdvertFill(advert, adverts[advertPos])
                if ErasureAdvertShardPos(advert, shardIndex) >= 0:
                    candidateCount = candidateCount + 1
            if candidateCount <= 0:
                continue
            let chosenAdvert = ErasureSelectPeerForShard(adverts, shardIndex, peerUseCounts)
            if chosenAdvert < 0:
                continue
            let chosenReuse = peerUseCounts[chosenAdvert]
            var chosenAdvertInfo = ErasurePeerAdvert()
            ErasurePeerAdvertFill(chosenAdvertInfo, adverts[chosenAdvert])
            let chosenAdvertShardCount = chosenAdvertInfo.shardCount
            let chosenAvailability = chosenAdvertInfo.availabilityPermille
            if bestShard < 0 ||
               candidateCount < bestCandidateCount ||
               (candidateCount == bestCandidateCount && chosenReuse < bestReuse) ||
               (candidateCount == bestCandidateCount && chosenReuse == bestReuse &&
                chosenAdvertShardCount < bestAdvertShardCount) ||
               (candidateCount == bestCandidateCount && chosenReuse == bestReuse &&
                chosenAdvertShardCount == bestAdvertShardCount && chosenAvailability > bestAvailability) ||
               (candidateCount == bestCandidateCount && chosenReuse == bestReuse &&
                chosenAdvertShardCount == bestAdvertShardCount && chosenAvailability == bestAvailability &&
                shardIndex < bestShard):
                bestShard = shardIndex
                bestAdvert = chosenAdvert
                bestCandidateCount = candidateCount
                bestReuse = chosenReuse
                bestAdvertShardCount = chosenAdvertShardCount
                bestAvailability = chosenAvailability
        if bestShard < 0 || bestAdvert < 0:
            return Err[ErasureRecoveryPlan](" erasure swarm: failed to construct recovery plan")
        selected[bestShard] = true
        peerUseCounts[bestAdvert] = peerUseCounts[bestAdvert] + 1
        let manifestPos = ErasureManifestShardPos(manifest, bestShard)
        var bestAdvertInfo = ErasurePeerAdvert()
        ErasurePeerAdvertFill(bestAdvertInfo, adverts[bestAdvert])
        let requestPeerId = bestAdvertInfo.peerId
        let requestShardCid = manifest.shardPayloadCids[manifestPos]
        let requestAdvertCid = bestAdvertInfo.advertCid
        requestPeerIds[requestCount] = requestPeerId
        requestShardIndices[requestCount] = bestShard
        requestShardCids[requestCount] = requestShardCid
        requestAdvertCids[requestCount] = requestAdvertCid
        requestCount = requestCount + 1
    out.requestCount = requestCount
    out.requestPeerIds = requestPeerIds
    out.requestShardIndices = requestShardIndices
    out.requestShardCids = requestShardCids
    out.requestAdvertCids = requestAdvertCids
    out.uniqueShardCount = requestCount
    for i in 0..<peerUseCounts.len:
        if peerUseCounts[i] > 0:
            out.uniquePeerCount = out.uniquePeerCount + 1
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.erasure.plan"))
    lt.AppendFixed32(buf, out.blobCid)
    lt.AppendFixed32(buf, out.manifestCid)
    lt.AppendU32BE(buf, out.minShardCount)
    lt.AppendU32BE(buf, out.requestCount)
    lt.AppendU32BE(buf, out.uniquePeerCount)
    lt.AppendU32BE(buf, out.uniqueShardCount)
    for i in 0..<out.requestCount:
        lt.AppendFixed32(buf, out.requestPeerIds[i])
        lt.AppendU32BE(buf, out.requestShardIndices[i])
        lt.AppendFixed32(buf, out.requestShardCids[i])
        lt.AppendFixed32(buf, out.requestAdvertCids[i])
    out.planCid = lt.FixedCidFromBuf(buf)
    return Ok[ErasureRecoveryPlan](out)

fn ErasureRecoveryPlanValidate(plan: ErasureRecoveryPlan,
                                 manifest: ErasureShardManifest,
                                 params: ErasureEncodingParams): Result[bool] =
    let manifestOk = ErasureManifestValidate(manifest, params)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    if plan.version != 1:
        return Err[bool](" erasure swarm: unsupported recovery plan version")
    if !layout.FixedBytes32Equal(plan.blobCid, manifest.blobCid):
        return Err[bool](" erasure swarm: recovery plan blob cid mismatch")
    if !layout.FixedBytes32Equal(plan.manifestCid, manifest.manifestCid):
        return Err[bool](" erasure swarm: recovery plan manifest cid mismatch")
    if plan.minShardCount != ErasureRecoveryThreshold(params):
        return Err[bool](" erasure swarm: recovery plan threshold mismatch")
    if plan.requestCount != plan.requestPeerIds.len:
        return Err[bool](" erasure swarm: recovery plan peer count mismatch")
    if plan.requestCount != plan.requestShardIndices.len:
        return Err[bool](" erasure swarm: recovery plan shard index count mismatch")
    if plan.requestCount != plan.requestShardCids.len:
        return Err[bool](" erasure swarm: recovery plan shard cid count mismatch")
    if plan.requestCount != plan.requestAdvertCids.len:
        return Err[bool](" erasure swarm: recovery plan advert count mismatch")
    for i in 0..<plan.requestCount:
        let manifestPos = ErasureManifestShardPos(manifest, plan.requestShardIndices[i])
        if manifestPos < 0:
            return Err[bool](" erasure swarm: recovery plan shard missing")
        if !layout.FixedBytes32Equal(plan.requestShardCids[i], manifest.shardPayloadCids[manifestPos]):
            return Err[bool](" erasure swarm: recovery plan shard cid mismatch")
    var uniquePeerCount = 0
    var uniqueShardCount = 0
    for i in 0..<plan.requestCount:
        var peerSeen = false
        var shardSeen = false
        for j in 0..<i:
            if layout.FixedBytes32Equal(plan.requestPeerIds[j], plan.requestPeerIds[i]):
                peerSeen = true
            if plan.requestShardIndices[j] == plan.requestShardIndices[i]:
                shardSeen = true
        if !peerSeen:
            uniquePeerCount = uniquePeerCount + 1
        if !shardSeen:
            uniqueShardCount = uniqueShardCount + 1
    if plan.uniquePeerCount != uniquePeerCount:
        return Err[bool](" erasure swarm: recovery plan unique peer count mismatch")
    if plan.uniqueShardCount != uniqueShardCount:
        return Err[bool](" erasure swarm: recovery plan unique shard count mismatch")
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.erasure.plan"))
    lt.AppendFixed32(buf, plan.blobCid)
    lt.AppendFixed32(buf, plan.manifestCid)
    lt.AppendU32BE(buf, plan.minShardCount)
    lt.AppendU32BE(buf, plan.requestCount)
    lt.AppendU32BE(buf, plan.uniquePeerCount)
    lt.AppendU32BE(buf, plan.uniqueShardCount)
    for i in 0..<plan.requestCount:
        lt.AppendFixed32(buf, plan.requestPeerIds[i])
        lt.AppendU32BE(buf, plan.requestShardIndices[i])
        lt.AppendFixed32(buf, plan.requestShardCids[i])
        lt.AppendFixed32(buf, plan.requestAdvertCids[i])
    let expectedCid = lt.FixedCidFromBuf(buf)
    if !layout.FixedBytes32Equal(plan.planCid, expectedCid):
        return Err[bool](" erasure swarm: recovery plan cid mismatch")
    return Ok[bool](true)

fn ErasureRecoveryPlanEncode(plan: ErasureRecoveryPlan): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(192 + plan.requestCount * 100)
    layout.ByteBufAppendBytes(buf, BytesFromString(ErasureRecoveryPlanMagic))
    lt.AppendU32BE(buf, plan.version)
    lt.AppendFixed32(buf, plan.blobCid)
    lt.AppendFixed32(buf, plan.manifestCid)
    lt.AppendU32BE(buf, plan.minShardCount)
    lt.AppendU32BE(buf, plan.requestCount)
    lt.AppendU32BE(buf, plan.uniquePeerCount)
    lt.AppendU32BE(buf, plan.uniqueShardCount)
    for i in 0..<plan.requestCount:
        lt.AppendFixed32(buf, plan.requestPeerIds[i])
        lt.AppendU32BE(buf, plan.requestShardIndices[i])
        lt.AppendFixed32(buf, plan.requestShardCids[i])
        lt.AppendFixed32(buf, plan.requestAdvertCids[i])
    lt.AppendFixed32(buf, plan.planCid)
    return layout.ByteBufToBytes(buf)

fn ErasureRecoveryPlanDecode(payload: Bytes): Result[ErasureRecoveryPlan] =
    if !ErasurePayloadHasMagic(payload, ErasureRecoveryPlanMagic):
        return Err[ErasureRecoveryPlan](" erasure swarm: invalid recovery plan magic")
    let magicLen = BytesLen(BytesFromString(ErasureRecoveryPlanMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[ErasureRecoveryPlan](Error(versionRes))
    let blobCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(blobCidRes):
        return Err[ErasureRecoveryPlan](Error(blobCidRes))
    let manifestCidRes = codec.ReadFixed32(span, magicLen + 36)
    if IsErr(manifestCidRes):
        return Err[ErasureRecoveryPlan](Error(manifestCidRes))
    let minShardCountRes = codec.ReadU32BE(span, magicLen + 68)
    if IsErr(minShardCountRes):
        return Err[ErasureRecoveryPlan](Error(minShardCountRes))
    let requestCountRes = codec.ReadU32BE(span, magicLen + 72)
    if IsErr(requestCountRes):
        return Err[ErasureRecoveryPlan](Error(requestCountRes))
    let uniquePeerCountRes = codec.ReadU32BE(span, magicLen + 76)
    if IsErr(uniquePeerCountRes):
        return Err[ErasureRecoveryPlan](Error(uniquePeerCountRes))
    let uniqueShardCountRes = codec.ReadU32BE(span, magicLen + 80)
    if IsErr(uniqueShardCountRes):
        return Err[ErasureRecoveryPlan](Error(uniqueShardCountRes))
    let requestCount = int32(Value(requestCountRes))
    if requestCount < 0:
        return Err[ErasureRecoveryPlan](" erasure swarm: invalid recovery plan request count")
    let entryWidth = 100
    let planCidOffset = magicLen + 84 + requestCount * entryWidth
    if planCidOffset + 32 > BytesLen(payload):
        return Err[ErasureRecoveryPlan](" erasure swarm: truncated recovery plan payload")
    var next = magicLen + 84
    var requestPeerIds: layout.FixedBytes32[]
    requestPeerIds = []
    var requestShardIndices: int32[]
    requestShardIndices = []
    var requestShardCids: layout.FixedBytes32[]
    requestShardCids = []
    var requestAdvertCids: layout.FixedBytes32[]
    requestAdvertCids = []
    for i in 0..<requestCount:
        add(requestPeerIds, layout.FixedBytes32())
        add(requestShardIndices, 0)
        add(requestShardCids, layout.FixedBytes32())
        add(requestAdvertCids, layout.FixedBytes32())
    var out = ErasureRecoveryPlan()
    out.version = int32(Value(versionRes))
    out.blobCid = Value(blobCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.minShardCount = int32(Value(minShardCountRes))
    out.requestCount = requestCount
    out.uniquePeerCount = int32(Value(uniquePeerCountRes))
    out.uniqueShardCount = int32(Value(uniqueShardCountRes))
    for i in 0..<requestCount:
        let peerIdRes = codec.ReadFixed32(span, next)
        if IsErr(peerIdRes):
            return Err[ErasureRecoveryPlan](Error(peerIdRes))
        next = next + 32
        let shardIndexRes = codec.ReadU32BE(span, next)
        if IsErr(shardIndexRes):
            return Err[ErasureRecoveryPlan](Error(shardIndexRes))
        next = next + 4
        let shardCidRes = codec.ReadFixed32(span, next)
        if IsErr(shardCidRes):
            return Err[ErasureRecoveryPlan](Error(shardCidRes))
        next = next + 32
        let advertCidRes = codec.ReadFixed32(span, next)
        if IsErr(advertCidRes):
            return Err[ErasureRecoveryPlan](Error(advertCidRes))
        next = next + 32
        requestPeerIds[i] = Value(peerIdRes)
        requestShardIndices[i] = int32(Value(shardIndexRes))
        requestShardCids[i] = Value(shardCidRes)
        requestAdvertCids[i] = Value(advertCidRes)
    let planCidRes = codec.ReadFixed32(span, planCidOffset)
    if IsErr(planCidRes):
        return Err[ErasureRecoveryPlan](Error(planCidRes))
    out.requestPeerIds = requestPeerIds
    out.requestShardIndices = requestShardIndices
    out.requestShardCids = requestShardCids
    out.requestAdvertCids = requestAdvertCids
    out.planCid = Value(planCidRes)
    if out.version != 1:
        return Err[ErasureRecoveryPlan](" erasure swarm: unsupported recovery plan version")
    if out.requestPeerIds.len != out.requestCount:
        return Err[ErasureRecoveryPlan](" erasure swarm: recovery plan peer count mismatch")
    if out.requestShardIndices.len != out.requestCount:
        return Err[ErasureRecoveryPlan](" erasure swarm: recovery plan shard index count mismatch")
    if out.requestShardCids.len != out.requestCount:
        return Err[ErasureRecoveryPlan](" erasure swarm: recovery plan shard cid count mismatch")
    if out.requestAdvertCids.len != out.requestCount:
        return Err[ErasureRecoveryPlan](" erasure swarm: recovery plan advert count mismatch")
    var uniquePeerCount = 0
    var uniqueShardCount = 0
    for i in 0..<out.requestCount:
        var peerSeen = false
        var shardSeen = false
        for j in 0..<i:
            if layout.FixedBytes32Equal(out.requestPeerIds[j], out.requestPeerIds[i]):
                peerSeen = true
            if out.requestShardIndices[j] == out.requestShardIndices[i]:
                shardSeen = true
        if !peerSeen:
            uniquePeerCount = uniquePeerCount + 1
        if !shardSeen:
            uniqueShardCount = uniqueShardCount + 1
    if out.uniquePeerCount != uniquePeerCount:
        return Err[ErasureRecoveryPlan](" erasure swarm: recovery plan unique peer count mismatch")
    if out.uniqueShardCount != uniqueShardCount:
        return Err[ErasureRecoveryPlan](" erasure swarm: recovery plan unique shard count mismatch")
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.erasure.plan"))
    lt.AppendFixed32(buf, out.blobCid)
    lt.AppendFixed32(buf, out.manifestCid)
    lt.AppendU32BE(buf, out.minShardCount)
    lt.AppendU32BE(buf, out.requestCount)
    lt.AppendU32BE(buf, out.uniquePeerCount)
    lt.AppendU32BE(buf, out.uniqueShardCount)
    for i in 0..<out.requestCount:
        lt.AppendFixed32(buf, out.requestPeerIds[i])
        lt.AppendU32BE(buf, out.requestShardIndices[i])
        lt.AppendFixed32(buf, out.requestShardCids[i])
        lt.AppendFixed32(buf, out.requestAdvertCids[i])
    let expectedCid = lt.FixedCidFromBuf(buf)
    if !layout.FixedBytes32Equal(out.planCid, expectedCid):
        return Err[ErasureRecoveryPlan](" erasure swarm: recovery plan cid mismatch")
    return Ok[ErasureRecoveryPlan](out)

fn ErasureRecoveryPlanValidatePayload(payload: Bytes,
                                        expectedCid: layout.FixedBytes32): Result[bool] =
    let planRes = ErasureRecoveryPlanDecode(payload)
    if IsErr(planRes):
        return Err[bool](Error(planRes))
    if !layout.FixedBytes32Equal(Value(planRes).planCid, expectedCid):
        return Err[bool](" erasure swarm: recovery plan payload cid mismatch")
    return Ok[bool](true)

fn ErasureShardPullRequestCid(manifestCid: layout.FixedBytes32,
                                shardIndex: int32,
                                shardCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(96)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.erasure.pull.request.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, manifestCid)
    lt.AppendU32BE(buf, shardIndex)
    lt.AppendFixed32(buf, shardCid)
    return lt.FixedCidFromBuf(buf)

fn ErasureShardPullResponseCid(manifestCid: layout.FixedBytes32,
                                 shardIndex: int32,
                                 shardCid: layout.FixedBytes32,
                                 payloadLen: int32,
                                 payload: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(128 + payloadLen)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.erasure.pull.response.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendFixed32(buf, manifestCid)
    lt.AppendU32BE(buf, shardIndex)
    lt.AppendFixed32(buf, shardCid)
    lt.AppendU32BE(buf, payloadLen)
    layout.ByteBufAppendBytes(buf, payload)
    return lt.FixedCidFromBuf(buf)

fn ErasureShardPullRequestMake(manifest: ErasureShardManifest,
                                 shardIndex: int32): Result[ErasureShardPullRequest] =
    var out = ErasureShardPullRequest()
    let fillRes = ErasureShardPullRequestFill(out, manifest, shardIndex)
    if IsErr(fillRes):
        return Err[ErasureShardPullRequest](Error(fillRes))
    return Ok[ErasureShardPullRequest](out)

fn ErasureShardPullRequestFillFromFields(out: var ErasureShardPullRequest,
                                           manifestCid: layout.FixedBytes32,
                                           shardIndices: int32[],
                                           shardPayloadCids: layout.FixedBytes32[],
                                           shardIndex: int32): Result[bool] =
    if shardIndices.len != shardPayloadCids.len:
        return Err[bool](" erasure swarm: shard pull arrays mismatch")
    let pos = ErasureShardIndexPos(shardIndices, shardIndex)
    if pos < 0:
        return Err[bool](" erasure swarm: shard pull index missing")
    out = ErasureShardPullRequest()
    out.manifestCid = manifestCid
    out.shardIndex = shardIndex
    out.shardCid = shardPayloadCids[pos]
    out.requestCid = ErasureShardPullRequestCid(out.manifestCid, out.shardIndex, out.shardCid)
    return Ok[bool](true)

fn ErasureShardPullRequestFill(out: var ErasureShardPullRequest,
                                 manifest: ErasureShardManifest,
                                 shardIndex: int32): Result[bool] =
    return ErasureShardPullRequestFillFromFields(out,
                                                   manifest.manifestCid,
                                                   manifest.shardIndices,
                                                   manifest.shardPayloadCids,
                                                   shardIndex)

fn ErasureShardPullRequestValidate(request: ErasureShardPullRequest,
                                     manifest: ErasureShardManifest): Result[bool] =
    if request.version != 1:
        return Err[bool](" erasure swarm: unsupported shard pull request version")
    if !layout.FixedBytes32Equal(request.manifestCid, manifest.manifestCid):
        return Err[bool](" erasure swarm: shard pull request manifest mismatch")
    let pos = ErasureManifestShardPos(manifest, request.shardIndex)
    if pos < 0:
        return Err[bool](" erasure swarm: shard pull request index missing")
    if !layout.FixedBytes32Equal(request.shardCid, manifest.shardPayloadCids[pos]):
        return Err[bool](" erasure swarm: shard pull request cid mismatch")
    let expectedCid = ErasureShardPullRequestCid(request.manifestCid,
                                                   request.shardIndex,
                                                   request.shardCid)
    if !layout.FixedBytes32Equal(request.requestCid, expectedCid):
        return Err[bool](" erasure swarm: shard pull request cid mismatch")
    return Ok[bool](true)

fn ErasureShardPullResponseMake(request: ErasureShardPullRequest,
                                  payload: Bytes): Result[ErasureShardPullResponse] =
    var out = ErasureShardPullResponse()
    let fillRes = ErasureShardPullResponseFill(out, request, payload)
    if IsErr(fillRes):
        return Err[ErasureShardPullResponse](Error(fillRes))
    return Ok[ErasureShardPullResponse](out)

fn ErasureShardPullResponseFill(out: var ErasureShardPullResponse,
                                  request: ErasureShardPullRequest,
                                  payload: Bytes): Result[bool] =
    if !layout.FixedBytes32Equal(ErasureShardPayloadCid(payload), request.shardCid):
        return Err[bool](" erasure swarm: shard pull response payload cid mismatch")
    out = ErasureShardPullResponse()
    out.manifestCid = request.manifestCid
    out.shardIndex = request.shardIndex
    out.shardCid = request.shardCid
    out.payloadLen = BytesLen(payload)
    out.payload = payload
    out.responseCid = ErasureShardPullResponseCid(out.manifestCid,
                                                    out.shardIndex,
                                                    out.shardCid,
                                                    out.payloadLen,
                                                    out.payload)
    return Ok[bool](true)

fn ErasureShardPullResponseValidate(response: ErasureShardPullResponse,
                                      request: ErasureShardPullRequest): Result[bool] =
    if response.version != 1:
        return Err[bool](" erasure swarm: unsupported shard pull response version")
    if !layout.FixedBytes32Equal(response.manifestCid, request.manifestCid):
        return Err[bool](" erasure swarm: shard pull response manifest mismatch")
    if response.shardIndex != request.shardIndex:
        return Err[bool](" erasure swarm: shard pull response index mismatch")
    if !layout.FixedBytes32Equal(response.shardCid, request.shardCid):
        return Err[bool](" erasure swarm: shard pull response cid mismatch")
    if response.payloadLen != BytesLen(response.payload):
        return Err[bool](" erasure swarm: shard pull response payload length mismatch")
    if !layout.FixedBytes32Equal(ErasureShardPayloadCid(response.payload), response.shardCid):
        return Err[bool](" erasure swarm: shard pull response payload cid mismatch")
    let expectedCid = ErasureShardPullResponseCid(response.manifestCid,
                                                    response.shardIndex,
                                                    response.shardCid,
                                                    response.payloadLen,
                                                    response.payload)
    if !layout.FixedBytes32Equal(response.responseCid, expectedCid):
        return Err[bool](" erasure swarm: shard pull response cid mismatch")
    return Ok[bool](true)

fn ErasureShardPullRequestEncode(request: ErasureShardPullRequest): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(128)
    layout.ByteBufAppendBytes(buf, BytesFromString(ErasureShardPullRequestMagic))
    lt.AppendU32BE(buf, request.version)
    lt.AppendFixed32(buf, request.manifestCid)
    lt.AppendU32BE(buf, request.shardIndex)
    lt.AppendFixed32(buf, request.shardCid)
    lt.AppendFixed32(buf, request.requestCid)
    return layout.ByteBufToBytes(buf)

fn ErasureShardPullRequestDecode(payload: Bytes): Result[ErasureShardPullRequest] =
    if !ErasurePayloadHasMagic(payload, ErasureShardPullRequestMagic):
        return Err[ErasureShardPullRequest](" erasure swarm: invalid shard pull request magic")
    let magicLen = BytesLen(BytesFromString(ErasureShardPullRequestMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[ErasureShardPullRequest](Error(versionRes))
    let manifestCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(manifestCidRes):
        return Err[ErasureShardPullRequest](Error(manifestCidRes))
    let shardIndexRes = codec.ReadU32BE(span, magicLen + 36)
    if IsErr(shardIndexRes):
        return Err[ErasureShardPullRequest](Error(shardIndexRes))
    let shardCidRes = codec.ReadFixed32(span, magicLen + 40)
    if IsErr(shardCidRes):
        return Err[ErasureShardPullRequest](Error(shardCidRes))
    let requestCidRes = codec.ReadFixed32(span, magicLen + 72)
    if IsErr(requestCidRes):
        return Err[ErasureShardPullRequest](Error(requestCidRes))
    var out = ErasureShardPullRequest()
    out.version = int32(Value(versionRes))
    out.manifestCid = Value(manifestCidRes)
    out.shardIndex = int32(Value(shardIndexRes))
    out.shardCid = Value(shardCidRes)
    out.requestCid = Value(requestCidRes)
    if out.version != 1:
        return Err[ErasureShardPullRequest](" erasure swarm: unsupported shard pull request version")
    let expectedCid = ErasureShardPullRequestCid(out.manifestCid, out.shardIndex, out.shardCid)
    if !layout.FixedBytes32Equal(out.requestCid, expectedCid):
        return Err[ErasureShardPullRequest](" erasure swarm: shard pull request cid mismatch")
    return Ok[ErasureShardPullRequest](out)

fn ErasureShardPullResponseEncode(response: ErasureShardPullResponse): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(160 + response.payloadLen)
    layout.ByteBufAppendBytes(buf, BytesFromString(ErasureShardPullResponseMagic))
    lt.AppendU32BE(buf, response.version)
    lt.AppendFixed32(buf, response.manifestCid)
    lt.AppendU32BE(buf, response.shardIndex)
    lt.AppendFixed32(buf, response.shardCid)
    lt.AppendU32BE(buf, response.payloadLen)
    layout.ByteBufAppendBytes(buf, response.payload)
    lt.AppendFixed32(buf, response.responseCid)
    return layout.ByteBufToBytes(buf)

fn ErasureShardPullResponseDecode(payload: Bytes): Result[ErasureShardPullResponse] =
    if !ErasurePayloadHasMagic(payload, ErasureShardPullResponseMagic):
        return Err[ErasureShardPullResponse](" erasure swarm: invalid shard pull response magic")
    let magicLen = BytesLen(BytesFromString(ErasureShardPullResponseMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[ErasureShardPullResponse](Error(versionRes))
    let manifestCidRes = codec.ReadFixed32(span, magicLen + 4)
    if IsErr(manifestCidRes):
        return Err[ErasureShardPullResponse](Error(manifestCidRes))
    let shardIndexRes = codec.ReadU32BE(span, magicLen + 36)
    if IsErr(shardIndexRes):
        return Err[ErasureShardPullResponse](Error(shardIndexRes))
    let shardCidRes = codec.ReadFixed32(span, magicLen + 40)
    if IsErr(shardCidRes):
        return Err[ErasureShardPullResponse](Error(shardCidRes))
    let payloadLenRes = codec.ReadU32BE(span, magicLen + 72)
    if IsErr(payloadLenRes):
        return Err[ErasureShardPullResponse](Error(payloadLenRes))
    let payloadLen = int32(Value(payloadLenRes))
    let payloadStart = magicLen + 76
    if payloadLen < 0 || payloadStart + payloadLen + 32 > BytesLen(payload):
        return Err[ErasureShardPullResponse](" erasure swarm: truncated shard pull response payload")
    let responseCidRes = codec.ReadFixed32(span, payloadStart + payloadLen)
    if IsErr(responseCidRes):
        return Err[ErasureShardPullResponse](Error(responseCidRes))
    var out = ErasureShardPullResponse()
    out.version = int32(Value(versionRes))
    out.manifestCid = Value(manifestCidRes)
    out.shardIndex = int32(Value(shardIndexRes))
    out.shardCid = Value(shardCidRes)
    out.payloadLen = payloadLen
    out.payload = BytesSlice(payload, payloadStart, payloadLen)
    out.responseCid = Value(responseCidRes)
    if out.version != 1:
        return Err[ErasureShardPullResponse](" erasure swarm: unsupported shard pull response version")
    let expectedCid = ErasureShardPullResponseCid(out.manifestCid,
                                                    out.shardIndex,
                                                    out.shardCid,
                                                    out.payloadLen,
                                                    out.payload)
    if !layout.FixedBytes32Equal(out.responseCid, expectedCid):
        return Err[ErasureShardPullResponse](" erasure swarm: shard pull response cid mismatch")
    if !layout.FixedBytes32Equal(ErasureShardPayloadCid(out.payload), out.shardCid):
        return Err[ErasureShardPullResponse](" erasure swarm: shard pull response payload cid mismatch")
    return Ok[ErasureShardPullResponse](out)
