import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as types
import cheng/chain/lsmr_types as lt
import cheng/chain/lsmr
import cheng/chain/csg

const
    PubSubPayloadKindCsgDelta: int32 = 1
    PubSubPayloadKindStateDelta: int32 = 2
    PubSubPayloadKindDagAdvert: int32 = 3
    PubSubPayloadKindErasureManifest: int32 = 4
    PubSubPayloadKindContentStub: int32 = 5
    PubSubPayloadKindErasureRecoveryPlan: int32 = 6
    PubSubPayloadKindPinOffer: int32 = 7
    PubSubPayloadKindPinAccept: int32 = 8
    PubSubPayloadKindPinSettlement: int32 = 9
    PubSubPayloadKindCompilerWorldHead: int32 = 10
    PubSubPayloadKindCompilerPackageSnapshot: int32 = 11
    PubSubPayloadKindCompilerCsg: int32 = 12
    PubSubPayloadKindCompilerExportSurface: int32 = 13
    PubSubPayloadKindCompilerCompileReceipt: int32 = 14
    PubSubPayloadKindOracleBatch: int32 = 15
    PubSubPayloadKindCompilerUniverseManifest: int32 = 16
    PubSubPayloadKindCompilerManagedMirrorBundle: int32 = 17

type
    PubSubTopic =
        version: int32 = 1
        centerAddress: types.LsmrAddress
        depth: int32
        resolutionLevel: int32
        layerId: int32
        baguaMode: int32
        scopeDepth: int32
        semanticFingerprint: layout.FixedBytes32
        topicCid: layout.FixedBytes32

    PubSubSubscription =
        version: int32 = 1
        nodeId: int32
        address: types.LsmrAddress
        baguaId: int32
        barrierMode: int32
        topicCid: layout.FixedBytes32

    PubSubEnvelope =
        version: int32 = 1
        topicCid: layout.FixedBytes32
        payloadKind: int32
        payloadCid: layout.FixedBytes32
        payloadSummaryCid: layout.FixedBytes32
        envelopeCid: layout.FixedBytes32

    PubSubPlan =
        version: int32 = 1
        topicCid: layout.FixedBytes32
        envelopeCid: layout.FixedBytes32
        subscriberCount: int32
        branchCount: int32
        branchDigits: int32[]
        branchNodeCounts: int32[]
        branchPrimaryNodeIds: int32[]
        branchPrimaryAddresses: types.LsmrAddress[]
        branchDeliveryPhases: int32[]
        branchRouteCids: layout.FixedBytes32[]
        planCid: layout.FixedBytes32

fn PubSubSemanticFingerprint(ids: int32[]): layout.FixedBytes32 =
    return lt.HashInts("cheng.pubsub.semantic", ids)

fn PubSubScopeDepth(layerId: int32, depth: int32): int32 =
    if layerId == lt.LayerGlobal:
        return 0
    if layerId == lt.LayerRegional:
        return 1
    if depth <= 1:
        return 1
    return depth - 1

fn PubSubAddressLess(left: types.LsmrAddress, right: types.LsmrAddress): bool =
    if left.depth != right.depth:
        return left.depth < right.depth
    for i in 0..<types.LsmrMaxDepth:
        if left.digits[i] != right.digits[i]:
            return left.digits[i] < right.digits[i]
    return false

fn PubSubTopicFromAddress(centerAddress: types.LsmrAddress,
                            resolutionLevel: int32,
                            baguaMode: int32,
                            semanticFingerprint: layout.FixedBytes32): Result[PubSubTopic] =
    if !lt.PubSubModeValid(baguaMode):
        return Err[PubSubTopic](" pubsub: invalid bagua mode")
    if resolutionLevel <= 0 || resolutionLevel > centerAddress.depth:
        return Err[PubSubTopic](" pubsub: invalid resolution level")
    var out: PubSubTopic
    out.centerAddress = centerAddress
    out.depth = centerAddress.depth
    out.resolutionLevel = resolutionLevel
    out.layerId = lsmr.LsmrStateLayerForResolution(resolutionLevel)
    out.baguaMode = baguaMode
    out.scopeDepth = PubSubScopeDepth(out.layerId, out.depth)
    out.semanticFingerprint = semanticFingerprint
    var buf: layout.ByteBuf = layout.byteBufInit(128)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.pubsub.topic"))
    lt.AppendAddress(buf, centerAddress)
    lt.AppendU32BE(buf, resolutionLevel)
    lt.AppendU32BE(buf, out.layerId)
    lt.AppendU32BE(buf, baguaMode)
    lt.AppendU32BE(buf, out.scopeDepth)
    for i in 0..<out.scopeDepth:
        lt.AppendU32BE(buf, centerAddress.digits[i])
    lt.AppendFixed32(buf, semanticFingerprint)
    out.topicCid = lt.FixedCidFromBuf(buf)
    return Ok[PubSubTopic](out)

fn PubSubSubscriptionMake(nodeId: int32,
                            address: types.LsmrAddress,
                            barrierMode: int32,
                            topicCid: layout.FixedBytes32): PubSubSubscription =
    var out: PubSubSubscription
    out.nodeId = nodeId
    out.address = address
    out.baguaId = lt.BaguaKan
    var baguaResolved = false
    for i in 0..<address.depth:
        let digit = address.digits[i]
        if digit == types.LsmrDigitCenter:
            continue
        if digit == 6:
            out.baguaId = lt.BaguaQian
        elif digit == 7:
            out.baguaId = lt.BaguaDui
        elif digit == 9:
            out.baguaId = lt.BaguaLi
        elif digit == 3:
            out.baguaId = lt.BaguaZhen
        elif digit == 4:
            out.baguaId = lt.BaguaXun
        elif digit == 1:
            out.baguaId = lt.BaguaKan
        elif digit == 8:
            out.baguaId = lt.BaguaGen
        elif digit == 2:
            out.baguaId = lt.BaguaKun
        else:
            panic(" lsmr: center digit has no bagua")
        baguaResolved = true
        break
    if !baguaResolved:
        let fallbackRes = lsmr.LsmrAddressFromSeed("bagua|" + intToStr(nodeId), 1)
        if IsErr(fallbackRes):
            panic(Error(fallbackRes))
        let fallback = Value(fallbackRes)
        for i in 0..<fallback.depth:
            let digit = fallback.digits[i]
            if digit == types.LsmrDigitCenter:
                continue
            if digit == 6:
                out.baguaId = lt.BaguaQian
            elif digit == 7:
                out.baguaId = lt.BaguaDui
            elif digit == 9:
                out.baguaId = lt.BaguaLi
            elif digit == 3:
                out.baguaId = lt.BaguaZhen
            elif digit == 4:
                out.baguaId = lt.BaguaXun
            elif digit == 1:
                out.baguaId = lt.BaguaKan
            elif digit == 8:
                out.baguaId = lt.BaguaGen
            elif digit == 2:
                out.baguaId = lt.BaguaKun
            else:
                panic(" lsmr: center digit has no bagua")
            break
    out.barrierMode = barrierMode
    out.topicCid = topicCid
    return out

fn PubSubEnvelopeMake(topicCid: layout.FixedBytes32,
                        payloadKind: int32,
                        payloadCid: layout.FixedBytes32,
                        payloadSummaryCid: layout.FixedBytes32): PubSubEnvelope =
    var out: PubSubEnvelope
    out.topicCid = topicCid
    out.payloadKind = payloadKind
    out.payloadCid = payloadCid
    out.payloadSummaryCid = payloadSummaryCid
    var buf: layout.ByteBuf = layout.byteBufInit(128)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.pubsub.envelope"))
    lt.AppendFixed32(buf, topicCid)
    lt.AppendU32BE(buf, payloadKind)
    lt.AppendFixed32(buf, payloadCid)
    lt.AppendFixed32(buf, payloadSummaryCid)
    out.envelopeCid = lt.FixedCidFromBuf(buf)
    return out

fn PubSubEligible(topic: PubSubTopic, subscriberAddress: types.LsmrAddress): bool =
    if subscriberAddress.depth != topic.centerAddress.depth:
        return false
    for i in 0..<topic.scopeDepth:
        if subscriberAddress.digits[i] != topic.centerAddress.digits[i]:
            return false
    return true

fn PubSubDeliveryPhase(topic: PubSubTopic,
                         subscriberAddress: types.LsmrAddress): int32 =
    if types.LsmrAddressEqual(topic.centerAddress, subscriberAddress):
        return lt.RouteDeliveryKun
    if topic.layerId == lt.LayerGlobal:
        return lt.RouteDeliveryLi
    return lt.RouteDeliveryDui

fn PubSubPlanBranchPos(plan: PubSubPlan, digit: int32): int32 =
    for i in 0..<plan.branchDigits.len:
        if plan.branchDigits[i] == digit:
            return i
    return -1

fn PubSubEnsureBranch(plan: var PubSubPlan, digit: int32): int32 =
    let pos = PubSubPlanBranchPos(plan, digit)
    if pos >= 0:
        return pos
    add(plan.branchDigits, digit)
    add(plan.branchNodeCounts, 0)
    add(plan.branchPrimaryNodeIds, 0)
    add(plan.branchPrimaryAddresses, types.LsmrAddress())
    add(plan.branchDeliveryPhases, 0)
    add(plan.branchRouteCids, layout.FixedBytes32())
    return plan.branchDigits.len - 1

fn PubSubSortBranches(plan: var PubSubPlan) =
    for i in 1..<plan.branchDigits.len:
        let digit = plan.branchDigits[i]
        let nodeCount = plan.branchNodeCounts[i]
        let nodeId = plan.branchPrimaryNodeIds[i]
        let address = plan.branchPrimaryAddresses[i]
        let phase = plan.branchDeliveryPhases[i]
        let routeCid = plan.branchRouteCids[i]
        var j = i - 1
        while j >= 0:
            if plan.branchDigits[j] <= digit:
                break
            plan.branchDigits[j + 1] = plan.branchDigits[j]
            plan.branchNodeCounts[j + 1] = plan.branchNodeCounts[j]
            plan.branchPrimaryNodeIds[j + 1] = plan.branchPrimaryNodeIds[j]
            plan.branchPrimaryAddresses[j + 1] = plan.branchPrimaryAddresses[j]
            plan.branchDeliveryPhases[j + 1] = plan.branchDeliveryPhases[j]
            plan.branchRouteCids[j + 1] = plan.branchRouteCids[j]
            j = j - 1
        plan.branchDigits[j + 1] = digit
        plan.branchNodeCounts[j + 1] = nodeCount
        plan.branchPrimaryNodeIds[j + 1] = nodeId
        plan.branchPrimaryAddresses[j + 1] = address
        plan.branchDeliveryPhases[j + 1] = phase
        plan.branchRouteCids[j + 1] = routeCid

fn PubSubBuildPlan(topic: PubSubTopic,
                     envelope: PubSubEnvelope,
                     subscriptions: PubSubSubscription[]): Result[PubSubPlan] =
    if !layout.fixedBytes32Equal(envelope.topicCid, topic.topicCid):
        return Err[PubSubPlan](" pubsub: envelope topic mismatch")
    var out: PubSubPlan
    out.topicCid = topic.topicCid
    out.envelopeCid = envelope.envelopeCid
    var branchBestHops: int32[]
    branchBestHops = []
    for i in 0..<subscriptions.len:
        if !layout.fixedBytes32Equal(subscriptions[i].topicCid, topic.topicCid):
            continue
        if !PubSubEligible(topic, subscriptions[i].address):
            continue
        let routeRes = lsmr.LsmrRoutePlanFromAddresses(topic.centerAddress, subscriptions[i].address)
        if IsErr(routeRes):
            return Err[PubSubPlan](Error(routeRes))
        let route = Value(routeRes)
        let branchDigit = lsmr.LsmrMulticastBranchDigit(topic.centerAddress, subscriptions[i].address)
        let branchPos = PubSubEnsureBranch(out, branchDigit)
        while branchBestHops.len < out.branchDigits.len:
            add(branchBestHops, -1)
        let phase = PubSubDeliveryPhase(topic, subscriptions[i].address)
        if topic.baguaMode == lt.PubSubModeXun:
            let bestHop = branchBestHops[branchPos]
            if bestHop >= 0 && route.hopCount > bestHop:
                continue
            if bestHop >= 0 && route.hopCount == bestHop &&
               !PubSubAddressLess(subscriptions[i].address, out.branchPrimaryAddresses[branchPos]):
                continue
            branchBestHops[branchPos] = route.hopCount
            if out.branchNodeCounts[branchPos] == 0:
                out.subscriberCount = out.subscriberCount + 1
            
            out.branchNodeCounts[branchPos] = 1
            out.branchPrimaryNodeIds[branchPos] = subscriptions[i].nodeId
            out.branchPrimaryAddresses[branchPos] = subscriptions[i].address
            out.branchDeliveryPhases[branchPos] = phase
            out.branchRouteCids[branchPos] = route.routeCid
            continue
        if out.branchNodeCounts[branchPos] == 0 ||
           route.hopCount < branchBestHops[branchPos] ||
           branchBestHops[branchPos] < 0 ||
           (route.hopCount == branchBestHops[branchPos] &&
            PubSubAddressLess(subscriptions[i].address, out.branchPrimaryAddresses[branchPos])):
            out.branchPrimaryNodeIds[branchPos] = subscriptions[i].nodeId
            out.branchPrimaryAddresses[branchPos] = subscriptions[i].address
            out.branchDeliveryPhases[branchPos] = phase
            out.branchRouteCids[branchPos] = route.routeCid
            branchBestHops[branchPos] = route.hopCount
        
        out.branchNodeCounts[branchPos] = out.branchNodeCounts[branchPos] + 1
        out.subscriberCount = out.subscriberCount + 1
    out.branchCount = out.branchDigits.len
    PubSubSortBranches(out)
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.pubsub.plan"))
    lt.AppendFixed32(buf, out.topicCid)
    lt.AppendFixed32(buf, out.envelopeCid)
    lt.AppendU32BE(buf, out.subscriberCount)
    lt.AppendU32BE(buf, out.branchCount)
    for i in 0..<out.branchDigits.len:
        lt.AppendU32BE(buf, out.branchDigits[i])
        lt.AppendU32BE(buf, out.branchNodeCounts[i])
        lt.AppendU32BE(buf, out.branchPrimaryNodeIds[i])
        lt.AppendAddress(buf, out.branchPrimaryAddresses[i])
        lt.AppendU32BE(buf, out.branchDeliveryPhases[i])
        lt.AppendFixed32(buf, out.branchRouteCids[i])
    out.planCid = lt.FixedCidFromBuf(buf)
    return Ok[PubSubPlan](out)

fn PubSubCsgDecision(topic: PubSubTopic,
                       subscription: PubSubSubscription,
                       subgraph: csg.CsgSubgraph): csg.CsgFilterDecision =
    let barrierMode = subscription.barrierMode > 0 ? subscription.barrierMode : csg.CsgBarrierModeGen
    let filter = csg.DefaultCsgBarrierFilter(topic.layerId, barrierMode)
    return csg.ApplyCsgBarrierFilter(filter, subgraph)
