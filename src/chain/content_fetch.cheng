import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/codec_binary as codec
import cheng/chain/lsmr_types as lt
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content

const
    ContentFetchMethodManifest: int32 = 1
    ContentFetchMethodPreview: int32 = 2
    ContentFetchMethodChunk: int32 = 3
    ContentFetchMethodRange: int32 = 4

    ContentFetchRequestMagic: str = "cheng.content.fetch.request"
    ContentFetchResponseMagic: str = "cheng.content.fetch.response"

type
    ContentFetchRequest =
        version: int32 = 1
        method: int32
        targetCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        shardIndex: int32
        rangeStart: int32
        rangeLen: int32
        requestCid: layout.FixedBytes32

    ContentFetchResponse =
        version: int32 = 1
        method: int32
        targetCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        shardIndex: int32
        rangeStart: int32
        rangeLen: int32
        payloadLen: int32
        payload: Bytes
        responseCid: layout.FixedBytes32

fn ContentFetchCidSet(value: layout.FixedBytes32): bool =
    return !layout.FixedBytes32Equal(value, layout.FixedBytes32())

fn ContentFetchMethodValid(method: int32): bool =
    if method == ContentFetchMethodManifest:
        return true
    if method == ContentFetchMethodPreview:
        return true
    if method == ContentFetchMethodChunk:
        return true
    if method == ContentFetchMethodRange:
        return true
    return false

fn ContentFetchRequestCid(method: int32,
                            targetCid: layout.FixedBytes32,
                            manifestCid: layout.FixedBytes32,
                            shardIndex: int32,
                            rangeStart: int32,
                            rangeLen: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(192)
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.content.fetch.request.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendU32BE(buf, method)
    lt.AppendFixed32(buf, targetCid)
    lt.AppendFixed32(buf, manifestCid)
    lt.AppendU32BE(buf, shardIndex)
    lt.AppendU32BE(buf, rangeStart)
    lt.AppendU32BE(buf, rangeLen)
    return lt.FixedCidFromBuf(buf)

fn ContentFetchResponseCid(request: ContentFetchRequest,
                             payload: Bytes): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256 + BytesLen(payload))
    layout.ByteBufAppendBytes(buf, BytesFromString("cheng.content.fetch.response.cid"))
    lt.AppendU32BE(buf, 1)
    lt.AppendU32BE(buf, request.method)
    lt.AppendFixed32(buf, request.targetCid)
    lt.AppendFixed32(buf, request.manifestCid)
    lt.AppendU32BE(buf, request.shardIndex)
    lt.AppendU32BE(buf, request.rangeStart)
    lt.AppendU32BE(buf, request.rangeLen)
    lt.AppendU32BE(buf, BytesLen(payload))
    layout.ByteBufAppendBytes(buf, payload)
    return lt.FixedCidFromBuf(buf)

fn ContentFetchRequestValidate(request: ContentFetchRequest): Result[bool] =
    if request.version != 1:
        return Err[bool](" content fetch: unsupported request version")
    if !ContentFetchMethodValid(request.method):
        return Err[bool](" content fetch: invalid request method")
    if !ContentFetchCidSet(request.targetCid):
        return Err[bool](" content fetch: missing request target cid")
    if request.method == ContentFetchMethodManifest:
        if !ContentFetchCidSet(request.manifestCid):
            return Err[bool](" content fetch: missing manifest request cid")
        if !layout.FixedBytes32Equal(request.targetCid, request.manifestCid):
            return Err[bool](" content fetch: manifest target mismatch")
        if request.shardIndex != 0 || request.rangeStart != 0 || request.rangeLen != 0:
            return Err[bool](" content fetch: invalid manifest request selectors")
    elif request.method == ContentFetchMethodPreview:
        if ContentFetchCidSet(request.manifestCid):
            return Err[bool](" content fetch: preview request must not carry manifest cid")
        if request.shardIndex != 0 || request.rangeStart != 0 || request.rangeLen != 0:
            return Err[bool](" content fetch: invalid preview request selectors")
    elif request.method == ContentFetchMethodChunk:
        if !ContentFetchCidSet(request.manifestCid):
            return Err[bool](" content fetch: missing chunk request manifest cid")
        if request.shardIndex < 0:
            return Err[bool](" content fetch: invalid chunk request shard index")
        if request.rangeStart != 0 || request.rangeLen != 0:
            return Err[bool](" content fetch: invalid chunk request range")
    else:
        if ContentFetchCidSet(request.manifestCid):
            return Err[bool](" content fetch: range request must not carry manifest cid")
        if request.rangeStart < 0:
            return Err[bool](" content fetch: invalid range request start")
        if request.rangeLen <= 0:
            return Err[bool](" content fetch: invalid range request length")
        if request.shardIndex != 0:
            return Err[bool](" content fetch: range request must not carry shard index")
    let expectedCid = ContentFetchRequestCid(request.method,
                                               request.targetCid,
                                               request.manifestCid,
                                               request.shardIndex,
                                               request.rangeStart,
                                               request.rangeLen)
    if !layout.FixedBytes32Equal(request.requestCid, expectedCid):
        return Err[bool](" content fetch: request cid mismatch")
    return Ok[bool](true)

fn ContentFetchRequestMake(method: int32,
                             targetCid: layout.FixedBytes32,
                             manifestCid: layout.FixedBytes32,
                             shardIndex: int32,
                             rangeStart: int32,
                             rangeLen: int32): Result[ContentFetchRequest] =
    var out = ContentFetchRequest()
    out.version = 1
    out.method = method
    out.targetCid = targetCid
    out.manifestCid = manifestCid
    out.shardIndex = shardIndex
    out.rangeStart = rangeStart
    out.rangeLen = rangeLen
    out.requestCid = ContentFetchRequestCid(out.method,
                                              out.targetCid,
                                              out.manifestCid,
                                              out.shardIndex,
                                              out.rangeStart,
                                              out.rangeLen)
    let requestOk = ContentFetchRequestValidate(out)
    if IsErr(requestOk):
        return Err[ContentFetchRequest](Error(requestOk))
    return Ok[ContentFetchRequest](out)

fn ContentFetchRequestManifest(manifestCid: layout.FixedBytes32): Result[ContentFetchRequest] =
    return ContentFetchRequestMake(ContentFetchMethodManifest, manifestCid, manifestCid, 0, 0, 0)

fn ContentFetchRequestPreview(previewCid: layout.FixedBytes32): Result[ContentFetchRequest] =
    return ContentFetchRequestMake(ContentFetchMethodPreview,
                                     previewCid,
                                     layout.FixedBytes32(),
                                     0,
                                     0,
                                     0)

fn ContentFetchRequestChunk(manifestCid: layout.FixedBytes32,
                              shardIndex: int32,
                              shardCid: layout.FixedBytes32): Result[ContentFetchRequest] =
    return ContentFetchRequestMake(ContentFetchMethodChunk, shardCid, manifestCid, shardIndex, 0, 0)

fn ContentFetchRequestRange(blobCid: layout.FixedBytes32,
                              rangeStart: int32,
                              rangeLen: int32): Result[ContentFetchRequest] =
    return ContentFetchRequestMake(ContentFetchMethodRange,
                                     blobCid,
                                     layout.FixedBytes32(),
                                     0,
                                     rangeStart,
                                     rangeLen)

fn ContentFetchRequestFromShardPull(request: swarm.ErasureShardPullRequest): Result[ContentFetchRequest] =
    return ContentFetchRequestChunk(request.manifestCid, request.shardIndex, request.shardCid)

fn ContentFetchRequestToShardPull(request: ContentFetchRequest): Result[swarm.ErasureShardPullRequest] =
    let requestOk = ContentFetchRequestValidate(request)
    if IsErr(requestOk):
        return Err[swarm.ErasureShardPullRequest](Error(requestOk))
    if request.method != ContentFetchMethodChunk:
        return Err[swarm.ErasureShardPullRequest](" content fetch: request is not chunk fetch")
    var out = swarm.ErasureShardPullRequest()
    out.manifestCid = request.manifestCid
    out.shardIndex = request.shardIndex
    out.shardCid = request.targetCid
    out.requestCid = swarm.ErasureShardPullRequestCid(out.manifestCid, out.shardIndex, out.shardCid)
    return Ok[swarm.ErasureShardPullRequest](out)

fn ContentPayloadHasMagic(payload: Bytes, magic: str): bool =
    let magicBytes = BytesFromString(magic)
    if BytesLen(payload) < BytesLen(magicBytes):
        return false
    for i in 0..<BytesLen(magicBytes):
        if BytesGet(payload, i) != BytesGet(magicBytes, i):
            return false
    return true

fn ContentFetchRequestEncode(request: ContentFetchRequest): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(192)
    layout.ByteBufAppendBytes(buf, BytesFromString(ContentFetchRequestMagic))
    lt.AppendU32BE(buf, request.version)
    lt.AppendU32BE(buf, request.method)
    lt.AppendFixed32(buf, request.targetCid)
    lt.AppendFixed32(buf, request.manifestCid)
    lt.AppendU32BE(buf, request.shardIndex)
    lt.AppendU32BE(buf, request.rangeStart)
    lt.AppendU32BE(buf, request.rangeLen)
    lt.AppendFixed32(buf, request.requestCid)
    return layout.ByteBufToBytes(buf)

fn ContentFetchRequestDecode(payload: Bytes): Result[ContentFetchRequest] =
    if !ContentPayloadHasMagic(payload, ContentFetchRequestMagic):
        return Err[ContentFetchRequest](" content fetch: invalid request magic")
    let magicLen = BytesLen(BytesFromString(ContentFetchRequestMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[ContentFetchRequest](Error(versionRes))
    let methodRes = codec.ReadU32BE(span, magicLen + 4)
    if IsErr(methodRes):
        return Err[ContentFetchRequest](Error(methodRes))
    let targetCidRes = codec.ReadFixed32(span, magicLen + 8)
    if IsErr(targetCidRes):
        return Err[ContentFetchRequest](Error(targetCidRes))
    let manifestCidRes = codec.ReadFixed32(span, magicLen + 40)
    if IsErr(manifestCidRes):
        return Err[ContentFetchRequest](Error(manifestCidRes))
    let shardIndexRes = codec.ReadU32BE(span, magicLen + 72)
    if IsErr(shardIndexRes):
        return Err[ContentFetchRequest](Error(shardIndexRes))
    let rangeStartRes = codec.ReadU32BE(span, magicLen + 76)
    if IsErr(rangeStartRes):
        return Err[ContentFetchRequest](Error(rangeStartRes))
    let rangeLenRes = codec.ReadU32BE(span, magicLen + 80)
    if IsErr(rangeLenRes):
        return Err[ContentFetchRequest](Error(rangeLenRes))
    let requestCidRes = codec.ReadFixed32(span, magicLen + 84)
    if IsErr(requestCidRes):
        return Err[ContentFetchRequest](Error(requestCidRes))
    var out = ContentFetchRequest()
    out.version = int32(Value(versionRes))
    out.method = int32(Value(methodRes))
    out.targetCid = Value(targetCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.shardIndex = int32(Value(shardIndexRes))
    out.rangeStart = int32(Value(rangeStartRes))
    out.rangeLen = int32(Value(rangeLenRes))
    out.requestCid = Value(requestCidRes)
    let requestOk = ContentFetchRequestValidate(out)
    if IsErr(requestOk):
        return Err[ContentFetchRequest](Error(requestOk))
    return Ok[ContentFetchRequest](out)

fn ContentFetchResponseValidate(response: ContentFetchResponse,
                                  request: ContentFetchRequest): Result[bool] =
    let requestOk = ContentFetchRequestValidate(request)
    if IsErr(requestOk):
        return Err[bool](Error(requestOk))
    if response.version != 1:
        return Err[bool](" content fetch: unsupported response version")
    if response.method != request.method:
        return Err[bool](" content fetch: response method mismatch")
    if !layout.FixedBytes32Equal(response.targetCid, request.targetCid):
        return Err[bool](" content fetch: response target mismatch")
    if !layout.FixedBytes32Equal(response.manifestCid, request.manifestCid):
        return Err[bool](" content fetch: response manifest mismatch")
    if response.shardIndex != request.shardIndex:
        return Err[bool](" content fetch: response shard index mismatch")
    if response.rangeStart != request.rangeStart:
        return Err[bool](" content fetch: response range start mismatch")
    if response.rangeLen != request.rangeLen:
        return Err[bool](" content fetch: response range length mismatch")
    if response.payloadLen != BytesLen(response.payload):
        return Err[bool](" content fetch: response payload length mismatch")
    let expectedCid = ContentFetchResponseCid(request, response.payload)
    if !layout.FixedBytes32Equal(response.responseCid, expectedCid):
        return Err[bool](" content fetch: response cid mismatch")
    return Ok[bool](true)

fn ContentFetchResponseMake(request: ContentFetchRequest,
                              payload: Bytes): Result[ContentFetchResponse] =
    let requestOk = ContentFetchRequestValidate(request)
    if IsErr(requestOk):
        return Err[ContentFetchResponse](Error(requestOk))
    var out = ContentFetchResponse()
    out.version = request.version
    out.method = request.method
    out.targetCid = request.targetCid
    out.manifestCid = request.manifestCid
    out.shardIndex = request.shardIndex
    out.rangeStart = request.rangeStart
    out.rangeLen = request.rangeLen
    out.payloadLen = BytesLen(payload)
    out.payload = payload
    out.responseCid = ContentFetchResponseCid(request, payload)
    return Ok[ContentFetchResponse](out)

fn ContentFetchResponseEncode(response: ContentFetchResponse): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(256 + response.payloadLen)
    layout.ByteBufAppendBytes(buf, BytesFromString(ContentFetchResponseMagic))
    lt.AppendU32BE(buf, response.version)
    lt.AppendU32BE(buf, response.method)
    lt.AppendFixed32(buf, response.targetCid)
    lt.AppendFixed32(buf, response.manifestCid)
    lt.AppendU32BE(buf, response.shardIndex)
    lt.AppendU32BE(buf, response.rangeStart)
    lt.AppendU32BE(buf, response.rangeLen)
    lt.AppendU32BE(buf, response.payloadLen)
    layout.ByteBufAppendBytes(buf, response.payload)
    lt.AppendFixed32(buf, response.responseCid)
    return layout.ByteBufToBytes(buf)

fn ContentFetchResponseDecode(payload: Bytes): Result[ContentFetchResponse] =
    if !ContentPayloadHasMagic(payload, ContentFetchResponseMagic):
        return Err[ContentFetchResponse](" content fetch: invalid response magic")
    let magicLen = BytesLen(BytesFromString(ContentFetchResponseMagic))
    let span = layout.ByteSpanFromBytes(payload)
    let versionRes = codec.ReadU32BE(span, magicLen)
    if IsErr(versionRes):
        return Err[ContentFetchResponse](Error(versionRes))
    let methodRes = codec.ReadU32BE(span, magicLen + 4)
    if IsErr(methodRes):
        return Err[ContentFetchResponse](Error(methodRes))
    let targetCidRes = codec.ReadFixed32(span, magicLen + 8)
    if IsErr(targetCidRes):
        return Err[ContentFetchResponse](Error(targetCidRes))
    let manifestCidRes = codec.ReadFixed32(span, magicLen + 40)
    if IsErr(manifestCidRes):
        return Err[ContentFetchResponse](Error(manifestCidRes))
    let shardIndexRes = codec.ReadU32BE(span, magicLen + 72)
    if IsErr(shardIndexRes):
        return Err[ContentFetchResponse](Error(shardIndexRes))
    let rangeStartRes = codec.ReadU32BE(span, magicLen + 76)
    if IsErr(rangeStartRes):
        return Err[ContentFetchResponse](Error(rangeStartRes))
    let rangeLenRes = codec.ReadU32BE(span, magicLen + 80)
    if IsErr(rangeLenRes):
        return Err[ContentFetchResponse](Error(rangeLenRes))
    let payloadLenRes = codec.ReadU32BE(span, magicLen + 84)
    if IsErr(payloadLenRes):
        return Err[ContentFetchResponse](Error(payloadLenRes))
    let payloadLen = int32(Value(payloadLenRes))
    let payloadOffset = magicLen + 88
    if payloadLen < 0 || payloadOffset + payloadLen + 32 > BytesLen(payload):
        return Err[ContentFetchResponse](" content fetch: truncated response payload")
    let responsePayload = BytesSlice(payload, payloadOffset, payloadLen)
    let responseCidRes = codec.ReadFixed32(span, payloadOffset + payloadLen)
    if IsErr(responseCidRes):
        return Err[ContentFetchResponse](Error(responseCidRes))
    var out = ContentFetchResponse()
    out.version = int32(Value(versionRes))
    out.method = int32(Value(methodRes))
    out.targetCid = Value(targetCidRes)
    out.manifestCid = Value(manifestCidRes)
    out.shardIndex = int32(Value(shardIndexRes))
    out.rangeStart = int32(Value(rangeStartRes))
    out.rangeLen = int32(Value(rangeLenRes))
    out.payloadLen = payloadLen
    out.payload = responsePayload
    out.responseCid = Value(responseCidRes)
    let requestRes = ContentFetchRequestMake(out.method,
                                               out.targetCid,
                                               out.manifestCid,
                                               out.shardIndex,
                                               out.rangeStart,
                                               out.rangeLen)
    if IsErr(requestRes):
        return Err[ContentFetchResponse](Error(requestRes))
    let responseOk = ContentFetchResponseValidate(out, Value(requestRes))
    if IsErr(responseOk):
        return Err[ContentFetchResponse](Error(responseOk))
    return Ok[ContentFetchResponse](out)

fn ContentFetchResponseToManifestFill(out: var swarm.ErasureShardManifest,
                                        request: ContentFetchRequest,
                                        response: ContentFetchResponse): Result[bool] =
    let responseOk = ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[bool](Error(responseOk))
    if request.method != ContentFetchMethodManifest:
        return Err[bool](" content fetch: request is not manifest fetch")
    let payloadOk = swarm.ErasureShardManifestValidatePayload(response.payload, request.manifestCid)
    if IsErr(payloadOk):
        return Err[bool](Error(payloadOk))
    let manifestRes = swarm.ErasureShardManifestDecode(response.payload)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    out = Value(manifestRes)
    return Ok[bool](true)

fn ContentFetchResponseToManifest(request: ContentFetchRequest,
                                    response: ContentFetchResponse): Result[swarm.ErasureShardManifest] =
    let responseOk = ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[swarm.ErasureShardManifest](Error(responseOk))
    if request.method != ContentFetchMethodManifest:
        return Err[swarm.ErasureShardManifest](" content fetch: request is not manifest fetch")
    let payloadOk = swarm.ErasureShardManifestValidatePayload(response.payload, request.manifestCid)
    if IsErr(payloadOk):
        return Err[swarm.ErasureShardManifest](Error(payloadOk))
    let manifestRes = swarm.ErasureShardManifestDecode(response.payload)
    if IsErr(manifestRes):
        return Err[swarm.ErasureShardManifest](Error(manifestRes))
    return Ok[swarm.ErasureShardManifest](Value(manifestRes))

fn ContentFetchResponseToPreviewFill(out: var content.ContentManifest,
                                       request: ContentFetchRequest,
                                       response: ContentFetchResponse): Result[bool] =
    let responseOk = ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[bool](Error(responseOk))
    if request.method != ContentFetchMethodPreview:
        return Err[bool](" content fetch: request is not preview fetch")
    let manifestOk = content.ContentManifestValidatePayload(response.payload, request.targetCid)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    var manifest = content.ContentManifest()
    let manifestRes = content.ContentManifestDecodeFill(manifest, response.payload)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    if !layout.FixedBytes32Equal(manifest.previewCid, request.targetCid):
        return Err[bool](" content fetch: preview target mismatch")
    out = manifest
    return Ok[bool](true)

fn ContentFetchResponseToPreview(request: ContentFetchRequest,
                                   response: ContentFetchResponse): Result[content.ContentManifest] =
    let responseOk = ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[content.ContentManifest](Error(responseOk))
    if request.method != ContentFetchMethodPreview:
        return Err[content.ContentManifest](" content fetch: request is not preview fetch")
    let manifestOk = content.ContentManifestValidatePayload(response.payload, request.targetCid)
    if IsErr(manifestOk):
        return Err[content.ContentManifest](Error(manifestOk))
    var manifest = content.ContentManifest()
    let manifestRes = content.ContentManifestDecodeFill(manifest, response.payload)
    if IsErr(manifestRes):
        return Err[content.ContentManifest](Error(manifestRes))
    if !layout.FixedBytes32Equal(manifest.previewCid, request.targetCid):
        return Err[content.ContentManifest](" content fetch: preview target mismatch")
    return Ok[content.ContentManifest](manifest)

fn ContentFetchResponseToShardPullFill(out: var swarm.ErasureShardPullResponse,
                                         request: ContentFetchRequest,
                                         response: ContentFetchResponse): Result[bool] =
    let responseOk = ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[bool](Error(responseOk))
    let shardRequestRes = ContentFetchRequestToShardPull(request)
    if IsErr(shardRequestRes):
        return Err[bool](Error(shardRequestRes))
    let shardRequest = Value(shardRequestRes)
    let shardResponseRes = swarm.ErasureShardPullResponseMake(shardRequest, response.payload)
    if IsErr(shardResponseRes):
        return Err[bool](Error(shardResponseRes))
    out = Value(shardResponseRes)
    return Ok[bool](true)

fn ContentFetchResponseToShardPull(request: ContentFetchRequest,
                                     response: ContentFetchResponse): Result[swarm.ErasureShardPullResponse] =
    let responseOk = ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[swarm.ErasureShardPullResponse](Error(responseOk))
    let shardRequestRes = ContentFetchRequestToShardPull(request)
    if IsErr(shardRequestRes):
        return Err[swarm.ErasureShardPullResponse](Error(shardRequestRes))
    let shardResponseRes = swarm.ErasureShardPullResponseMake(Value(shardRequestRes), response.payload)
    if IsErr(shardResponseRes):
        return Err[swarm.ErasureShardPullResponse](Error(shardResponseRes))
    return Ok[swarm.ErasureShardPullResponse](Value(shardResponseRes))
