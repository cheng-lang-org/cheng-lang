import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/binary_types as types

const
    CodecLsmrMaxDepth: int32 = 32
    CodecFixed32Size: int32 = 32

type
    DecodedFrameHeader =
        kind: types.FrameKind
        payloadLen: int32
        epoch: int32
        ganzhiIndex: int32
        sourcePeerId: layout.FixedBytes32
        bodyCid: layout.FixedBytes32

    DecodedStateRootSummary =
        stateForestCid: layout.FixedBytes32
        eventRootCid: layout.FixedBytes32
        accountRootCid: layout.FixedBytes32

    DecodedHelloPayload =
        peerId: layout.FixedBytes32
        address: types.LsmrAddress
        tipEventCid: layout.FixedBytes32
        summary: DecodedStateRootSummary

    DecodedAdvertisePayload =
        peerId: layout.FixedBytes32
        stateForestCid: layout.FixedBytes32
        eventCid: layout.FixedBytes32
        accountCount: int32
        eventCount: int32
        maxStampEpoch: int32
        maxStampGanzhi: int32

    DecodedWantStatePayload =
        peerId: layout.FixedBytes32
        stateForestCid: layout.FixedBytes32
        targetBaguaId: int32
        prefixDepth: int32
        prefixDigits: int32[CodecLsmrMaxDepth]

fn DecodedFrameHeaderMake(kind: types.FrameKind,
                            payloadLen: int32,
                            epoch: int32,
                            ganzhiIndex: int32,
                            sourcePeerId: layout.FixedBytes32,
                            bodyCid: layout.FixedBytes32): DecodedFrameHeader =
    return DecodedFrameHeader(
        kind: kind,
        payloadLen: payloadLen,
        epoch: epoch,
        ganzhiIndex: ganzhiIndex,
        sourcePeerId: sourcePeerId,
        bodyCid: bodyCid
    )

fn DecodedStateRootSummaryMake(stateForestCid: layout.FixedBytes32,
                                 eventRootCid: layout.FixedBytes32,
                                 accountRootCid: layout.FixedBytes32): DecodedStateRootSummary =
    return DecodedStateRootSummary(
        stateForestCid: stateForestCid,
        eventRootCid: eventRootCid,
        accountRootCid: accountRootCid
    )

fn DecodedHelloPayloadMake(peerId: layout.FixedBytes32,
                             address: types.LsmrAddress,
                             tipEventCid: layout.FixedBytes32,
                             summary: DecodedStateRootSummary): DecodedHelloPayload =
    return DecodedHelloPayload(
        peerId: peerId,
        address: address,
        tipEventCid: tipEventCid,
        summary: summary
    )

fn DecodedAdvertisePayloadMake(peerId: layout.FixedBytes32,
                                 stateForestCid: layout.FixedBytes32,
                                 eventCid: layout.FixedBytes32,
                                 accountCount: int32,
                                 eventCount: int32,
                                 maxStampEpoch: int32,
                                 maxStampGanzhi: int32): DecodedAdvertisePayload =
    return DecodedAdvertisePayload(
        peerId: peerId,
        stateForestCid: stateForestCid,
        eventCid: eventCid,
        accountCount: accountCount,
        eventCount: eventCount,
        maxStampEpoch: maxStampEpoch,
        maxStampGanzhi: maxStampGanzhi
    )

fn DecodedWantStatePayloadMake(peerId: layout.FixedBytes32,
                                 stateForestCid: layout.FixedBytes32,
                                 targetBaguaId: int32,
                                 prefixDigitsRaw: int32[]): Result[DecodedWantStatePayload] =
    if !types.LsmrDigitOk(targetBaguaId):
        return Err[DecodedWantStatePayload](" chain codec: invalid WANT_STATE bagua digit")
    if prefixDigitsRaw.len > types.LsmrMaxDepth:
        return Err[DecodedWantStatePayload](" chain codec: invalid WANT_STATE depth")
    var out: DecodedWantStatePayload
    out.peerId = peerId
    out.stateForestCid = stateForestCid
    out.targetBaguaId = targetBaguaId
    out.prefixDepth = prefixDigitsRaw.len
    for i in 0..<prefixDigitsRaw.len:
        if !types.LsmrDigitOk(prefixDigitsRaw[i]):
            return Err[DecodedWantStatePayload](" chain codec: invalid WANT_STATE digit")
        out.prefixDigits[i] = prefixDigitsRaw[i]
    return Ok[DecodedWantStatePayload](out)

fn BufAppendU32BE(buf: var layout.ByteBuf, value: int64) =
    layout.ByteBufAppendByte(buf, int32((value >> 24) & 255))
    layout.ByteBufAppendByte(buf, int32((value >> 16) & 255))
    layout.ByteBufAppendByte(buf, int32((value >> 8) & 255))
    layout.ByteBufAppendByte(buf, int32(value & 255))

fn CodecSpanHasRange(span: layout.ByteSpan,
                       offset: int32,
                       size: int32): bool =
    if offset < 0:
        return false
    if size < 0:
        return false
    let spanLen = layout.ByteSpanLen(span)
    if spanLen < size:
        return false
    if offset > spanLen - size:
        return false
    return true

fn ReadU32BE(span: layout.ByteSpan, offset: int32): Result[int64] =
    if !CodecSpanHasRange(span, offset, 4):
        return Err[int64](" chain codec: short u32")
    let b0: int64 = int64(layout.ByteSpanAt(span, offset))
    let b1: int64 = int64(layout.ByteSpanAt(span, offset + 1))
    let b2: int64 = int64(layout.ByteSpanAt(span, offset + 2))
    let b3: int64 = int64(layout.ByteSpanAt(span, offset + 3))
    return Ok[int64]((b0 << 24) | (b1 << 16) | (b2 << 8) | b3)

fn BufAppendFixed32(buf: var layout.ByteBuf, value: layout.FixedBytes32) =
    var i: int32
    for i in i..<CodecFixed32Size:
        layout.ByteBufAppendByte(buf, int32(value.data[i]) & 255)

fn ReadFixed32(span: layout.ByteSpan, offset: int32): Result[layout.FixedBytes32] =
    if !CodecSpanHasRange(span, offset, CodecFixed32Size):
        return Err[layout.FixedBytes32](" chain codec: short fixed32")
    var out = layout.FixedBytes32()
    var i: int32
    for i in i..<CodecFixed32Size:
        out.data[i] = uint8(layout.ByteSpanAt(span, offset + i))
    return Ok[layout.FixedBytes32](out)

fn BufAppendAddress(buf: var layout.ByteBuf, addr: types.LsmrAddress) =
    BufAppendU32BE(buf, addr.depth)
    for i in 0..<types.LsmrMaxDepth:
        layout.ByteBufAppendByte(buf, addr.digits[i] & 255)

fn ReadAddress(span: layout.ByteSpan, offset: int32): Result[types.LsmrAddress] =
    var out: types.LsmrAddress
    let fillRes = ReadAddressFill(span, offset, out)
    if IsErr(fillRes):
        return Err[types.LsmrAddress](Error(fillRes))
    return Ok[types.LsmrAddress](out)

fn ReadAddressFill(span: layout.ByteSpan,
                     offset: int32,
                     out: var types.LsmrAddress): Result[bool] =
    if !CodecSpanHasRange(span, offset, 4 + types.LsmrMaxDepth):
        return Err[bool](" chain codec: short address")
    let depthRes: Result[int64] = ReadU32BE(span, offset)
    if IsErr(depthRes):
        return Err[bool](Error(depthRes))
    let depth: int32 = int32(Value(depthRes))
    if depth < 0:
        return Err[bool](" chain codec: invalid address depth")
    if depth > types.LsmrMaxDepth:
        return Err[bool](" chain codec: invalid address depth")
    out = types.LsmrAddress()
    out.depth = depth
    for i in 0..<depth:
        let digit: int32 = layout.ByteSpanAt(span, offset + 4 + i)
        if !types.LsmrDigitOk(digit):
            return Err[bool](" chain codec: invalid address digit")
        out.digits[i] = digit
    return Ok[bool](true)

fn BufAppendStateSummary(buf: var layout.ByteBuf, summary: types.StateRootSummary) =
    BufAppendFixed32(buf, summary.stateForestCid)
    BufAppendFixed32(buf, summary.eventRootCid)
    BufAppendFixed32(buf, summary.accountRootCid)

fn BufAppendStateSummaryRaw(buf: var layout.ByteBuf, summary: DecodedStateRootSummary) =
    BufAppendFixed32(buf, summary.stateForestCid)
    BufAppendFixed32(buf, summary.eventRootCid)
    BufAppendFixed32(buf, summary.accountRootCid)

fn ReadStateSummary(span: layout.ByteSpan, offset: int32): Result[types.StateRootSummary] =
    let stateRes = ReadFixed32(span, offset)
    if IsErr(stateRes):
        return Err[types.StateRootSummary](Error(stateRes))
    let eventRes = ReadFixed32(span, offset + 32)
    if IsErr(eventRes):
        return Err[types.StateRootSummary](Error(eventRes))
    let accountRes = ReadFixed32(span, offset + 64)
    if IsErr(accountRes):
        return Err[types.StateRootSummary](Error(accountRes))
    return Ok[types.StateRootSummary](types.StateRootSummaryMake(
        Value(stateRes),
        Value(eventRes),
        Value(accountRes)
    ))

fn ReadStateSummaryRaw(span: layout.ByteSpan, offset: int32): Result[DecodedStateRootSummary] =
    let stateRes = ReadFixed32(span, offset)
    if IsErr(stateRes):
        return Err[DecodedStateRootSummary](Error(stateRes))
    let eventRes = ReadFixed32(span, offset + 32)
    if IsErr(eventRes):
        return Err[DecodedStateRootSummary](Error(eventRes))
    let accountRes = ReadFixed32(span, offset + 64)
    if IsErr(accountRes):
        return Err[DecodedStateRootSummary](Error(accountRes))
    return Ok[DecodedStateRootSummary](DecodedStateRootSummaryMake(
        Value(stateRes),
        Value(eventRes),
        Value(accountRes)
    ))

fn FrameBodyCid(payload: Bytes): layout.FixedBytes32 =
    return hash256.sha256Fixed(layout.ByteSpanFromBytes(payload))

fn EncodeFrameHeaderRaw(kind: types.FrameKind,
                          payloadLen: int32,
                          epoch: int32,
                          ganzhiIndex: int32,
                          sourcePeerId: layout.FixedBytes32,
                          bodyCid: layout.FixedBytes32): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(types.FrameHeaderSize)
    BufAppendU32BE(buf, types.FrameMagic)
    BufAppendU32BE(buf, types.ChainCodecVersion)
    BufAppendU32BE(buf, kind)
    BufAppendU32BE(buf, 0)
    BufAppendU32BE(buf, payloadLen)
    BufAppendU32BE(buf, epoch)
    BufAppendU32BE(buf, ganzhiIndex)
    BufAppendU32BE(buf, 0)
    BufAppendFixed32(buf, sourcePeerId)
    BufAppendFixed32(buf, bodyCid)
    return layout.ByteBufToBytes(buf)

fn DecodeFrameHeader(data: layout.ByteSpan): Result[DecodedFrameHeader] =
    if layout.ByteSpanLen(data) < types.FrameHeaderSize:
        return Err[DecodedFrameHeader](" chain codec: short frame header")
    let magicRes = ReadU32BE(data, 0)
    if IsErr(magicRes):
        return Err[DecodedFrameHeader](Error(magicRes))
    let versionRes = ReadU32BE(data, 4)
    if IsErr(versionRes):
        return Err[DecodedFrameHeader](Error(versionRes))
    let kindRes = ReadU32BE(data, 8)
    if IsErr(kindRes):
        return Err[DecodedFrameHeader](Error(kindRes))
    let flagsRes = ReadU32BE(data, 12)
    if IsErr(flagsRes):
        return Err[DecodedFrameHeader](Error(flagsRes))
    let payloadLenRes = ReadU32BE(data, 16)
    if IsErr(payloadLenRes):
        return Err[DecodedFrameHeader](Error(payloadLenRes))
    let epochRes = ReadU32BE(data, 20)
    if IsErr(epochRes):
        return Err[DecodedFrameHeader](Error(epochRes))
    let ganzhiRes = ReadU32BE(data, 24)
    if IsErr(ganzhiRes):
        return Err[DecodedFrameHeader](Error(ganzhiRes))
    let reservedRes = ReadU32BE(data, 28)
    if IsErr(reservedRes):
        return Err[DecodedFrameHeader](Error(reservedRes))
    let peerRes = ReadFixed32(data, 32)
    if IsErr(peerRes):
        return Err[DecodedFrameHeader](Error(peerRes))
    let bodyCidRes = ReadFixed32(data, 64)
    if IsErr(bodyCidRes):
        return Err[DecodedFrameHeader](Error(bodyCidRes))
    if int32(Value(magicRes)) != types.FrameMagic:
        return Err[DecodedFrameHeader](" chain codec: bad frame magic")
    if int32(Value(versionRes)) != types.ChainCodecVersion:
        return Err[DecodedFrameHeader](" chain codec: bad frame version")
    let flags = int32(Value(flagsRes))
    if flags != 0 || int32(Value(reservedRes)) != 0:
        return Err[DecodedFrameHeader](" chain codec: reserved header bits must be zero")
    return Ok[DecodedFrameHeader](DecodedFrameHeaderMake(
        int32(Value(kindRes)),
        int32(Value(payloadLenRes)),
        int32(Value(epochRes)),
        int32(Value(ganzhiRes)),
        Value(peerRes),
        Value(bodyCidRes)
    ))

fn EncodeHelloPayload(payload: types.HelloPayload): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(196)
    BufAppendFixed32(buf, payload.peerId)
    BufAppendAddress(buf, payload.address)
    BufAppendFixed32(buf, payload.tipEventCid)
    BufAppendStateSummary(buf, payload.summary)
    return layout.ByteBufToBytes(buf)

fn EncodeHelloPayloadRaw(peerId: layout.FixedBytes32,
                           address: types.LsmrAddress,
                           tipEventCid: layout.FixedBytes32,
                           summary: DecodedStateRootSummary): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(196)
    BufAppendFixed32(buf, peerId)
    BufAppendAddress(buf, address)
    BufAppendFixed32(buf, tipEventCid)
    BufAppendStateSummaryRaw(buf, summary)
    return layout.ByteBufToBytes(buf)

fn DecodeHelloPayload(data: layout.ByteSpan): Result[types.HelloPayload] =
    if layout.ByteSpanLen(data) != 196:
        return Err[types.HelloPayload](" chain codec: invalid HELLO payload size")
    let peerRes = ReadFixed32(data, 0)
    if IsErr(peerRes):
        return Err[types.HelloPayload](Error(peerRes))
    let addrRes = ReadAddress(data, 32)
    if IsErr(addrRes):
        return Err[types.HelloPayload](Error(addrRes))
    let tipRes = ReadFixed32(data, 68)
    if IsErr(tipRes):
        return Err[types.HelloPayload](Error(tipRes))
    let summaryRes = ReadStateSummary(data, 100)
    if IsErr(summaryRes):
        return Err[types.HelloPayload](Error(summaryRes))
    return Ok[types.HelloPayload](types.HelloPayloadMake(
        Value(peerRes),
        Value(addrRes),
        Value(tipRes),
        Value(summaryRes)
    ))

fn DecodeHelloPayloadRaw(data: layout.ByteSpan): Result[DecodedHelloPayload] =
    if layout.ByteSpanLen(data) != 196:
        return Err[DecodedHelloPayload](" chain codec: invalid HELLO payload size")
    let peerRes = ReadFixed32(data, 0)
    if IsErr(peerRes):
        return Err[DecodedHelloPayload](Error(peerRes))
    let addrRes = ReadAddress(data, 32)
    if IsErr(addrRes):
        return Err[DecodedHelloPayload](Error(addrRes))
    let tipRes = ReadFixed32(data, 68)
    if IsErr(tipRes):
        return Err[DecodedHelloPayload](Error(tipRes))
    let summaryRes = ReadStateSummaryRaw(data, 100)
    if IsErr(summaryRes):
        return Err[DecodedHelloPayload](Error(summaryRes))
    return Ok[DecodedHelloPayload](DecodedHelloPayloadMake(
        Value(peerRes),
        Value(addrRes),
        Value(tipRes),
        Value(summaryRes)
    ))

fn EncodeAdvertisePayload(payload: types.AdvertisePayload): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(112)
    BufAppendFixed32(buf, payload.peerId)
    BufAppendFixed32(buf, payload.stateForestCid)
    BufAppendFixed32(buf, payload.eventCid)
    BufAppendU32BE(buf, payload.accountCount)
    BufAppendU32BE(buf, payload.eventCount)
    BufAppendU32BE(buf, payload.maxStampEpoch)
    BufAppendU32BE(buf, payload.maxStampGanzhi)
    return layout.ByteBufToBytes(buf)

fn EncodeAdvertisePayloadRaw(peerId: layout.FixedBytes32,
                               stateForestCid: layout.FixedBytes32,
                               eventCid: layout.FixedBytes32,
                               accountCount: int32,
                               eventCount: int32,
                               maxStampEpoch: int32,
                               maxStampGanzhi: int32): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(112)
    BufAppendFixed32(buf, peerId)
    BufAppendFixed32(buf, stateForestCid)
    BufAppendFixed32(buf, eventCid)
    BufAppendU32BE(buf, accountCount)
    BufAppendU32BE(buf, eventCount)
    BufAppendU32BE(buf, maxStampEpoch)
    BufAppendU32BE(buf, maxStampGanzhi)
    return layout.ByteBufToBytes(buf)

fn DecodeAdvertisePayload(data: layout.ByteSpan): Result[types.AdvertisePayload] =
    if layout.ByteSpanLen(data) != 112:
        return Err[types.AdvertisePayload](" chain codec: invalid ADVERTISE payload size")
    let peerRes = ReadFixed32(data, 0)
    if IsErr(peerRes):
        return Err[types.AdvertisePayload](Error(peerRes))
    let stateRes = ReadFixed32(data, 32)
    if IsErr(stateRes):
        return Err[types.AdvertisePayload](Error(stateRes))
    let eventCidRes = ReadFixed32(data, 64)
    if IsErr(eventCidRes):
        return Err[types.AdvertisePayload](Error(eventCidRes))
    let accountRes = ReadU32BE(data, 96)
    if IsErr(accountRes):
        return Err[types.AdvertisePayload](Error(accountRes))
    let eventCountRes = ReadU32BE(data, 100)
    if IsErr(eventCountRes):
        return Err[types.AdvertisePayload](Error(eventCountRes))
    let epochRes = ReadU32BE(data, 104)
    if IsErr(epochRes):
        return Err[types.AdvertisePayload](Error(epochRes))
    let ganzhiRes = ReadU32BE(data, 108)
    if IsErr(ganzhiRes):
        return Err[types.AdvertisePayload](Error(ganzhiRes))
    return Ok[types.AdvertisePayload](types.AdvertisePayloadMake(
        Value(peerRes),
        Value(stateRes),
        Value(eventCidRes),
        int32(Value(accountRes)),
        int32(Value(eventCountRes)),
        int32(Value(epochRes)),
        int32(Value(ganzhiRes))
    ))

fn DecodeAdvertisePayloadRaw(data: layout.ByteSpan): Result[DecodedAdvertisePayload] =
    if layout.ByteSpanLen(data) != 112:
        return Err[DecodedAdvertisePayload](" chain codec: invalid ADVERTISE payload size")
    let peerRes = ReadFixed32(data, 0)
    if IsErr(peerRes):
        return Err[DecodedAdvertisePayload](Error(peerRes))
    let stateRes = ReadFixed32(data, 32)
    if IsErr(stateRes):
        return Err[DecodedAdvertisePayload](Error(stateRes))
    let eventCidRes = ReadFixed32(data, 64)
    if IsErr(eventCidRes):
        return Err[DecodedAdvertisePayload](Error(eventCidRes))
    let accountRes = ReadU32BE(data, 96)
    if IsErr(accountRes):
        return Err[DecodedAdvertisePayload](Error(accountRes))
    let eventCountRes = ReadU32BE(data, 100)
    if IsErr(eventCountRes):
        return Err[DecodedAdvertisePayload](Error(eventCountRes))
    let epochRes = ReadU32BE(data, 104)
    if IsErr(epochRes):
        return Err[DecodedAdvertisePayload](Error(epochRes))
    let ganzhiRes = ReadU32BE(data, 108)
    if IsErr(ganzhiRes):
        return Err[DecodedAdvertisePayload](Error(ganzhiRes))
    return Ok[DecodedAdvertisePayload](DecodedAdvertisePayloadMake(
        Value(peerRes),
        Value(stateRes),
        Value(eventCidRes),
        int32(Value(accountRes)),
        int32(Value(eventCountRes)),
        int32(Value(epochRes)),
        int32(Value(ganzhiRes))
    ))

fn EncodeWantStatePayload(payload: types.WantStatePayload): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(104)
    BufAppendFixed32(buf, payload.peerId)
    BufAppendFixed32(buf, payload.stateForestCid)
    BufAppendU32BE(buf, payload.targetBaguaId)
    BufAppendU32BE(buf, payload.prefixDepth)
    for i in 0..<types.LsmrMaxDepth:
        layout.ByteBufAppendByte(buf, payload.prefixDigits[i] & 255)
    return layout.ByteBufToBytes(buf)

fn EncodeWantStatePayloadRaw(peerId: layout.FixedBytes32,
                               stateForestCid: layout.FixedBytes32,
                               targetBaguaId: int32,
                               prefixDigitsRaw: int32[]): Result[Bytes] =
    let decodedRes = DecodedWantStatePayloadMake(peerId, stateForestCid, targetBaguaId, prefixDigitsRaw)
    if IsErr(decodedRes):
        return Err[Bytes](Error(decodedRes))
    let decoded = Value(decodedRes)
    var buf: layout.ByteBuf = layout.ByteBufInit(104)
    BufAppendFixed32(buf, decoded.peerId)
    BufAppendFixed32(buf, decoded.stateForestCid)
    BufAppendU32BE(buf, decoded.targetBaguaId)
    BufAppendU32BE(buf, decoded.prefixDepth)
    for i in 0..<types.LsmrMaxDepth:
        layout.ByteBufAppendByte(buf, decoded.prefixDigits[i] & 255)
    return Ok[Bytes](layout.ByteBufToBytes(buf))

fn DecodeWantStatePayload(data: layout.ByteSpan): Result[types.WantStatePayload] =
    if layout.ByteSpanLen(data) != 104:
        return Err[types.WantStatePayload](" chain codec: invalid WANT_STATE payload size")
    let peerRes = ReadFixed32(data, 0)
    if IsErr(peerRes):
        return Err[types.WantStatePayload](Error(peerRes))
    let stateRes = ReadFixed32(data, 32)
    if IsErr(stateRes):
        return Err[types.WantStatePayload](Error(stateRes))
    let baguaRes = ReadU32BE(data, 64)
    if IsErr(baguaRes):
        return Err[types.WantStatePayload](Error(baguaRes))
    let targetBaguaId: int32 = int32(Value(baguaRes))
    if !types.LsmrDigitOk(targetBaguaId):
        return Err[types.WantStatePayload](" chain codec: invalid WANT_STATE bagua digit")
    let depthRes = ReadU32BE(data, 68)
    if IsErr(depthRes):
        return Err[types.WantStatePayload](Error(depthRes))
    let prefixDepth: int32 = int32(Value(depthRes))
    if prefixDepth < 0:
        return Err[types.WantStatePayload](" chain codec: invalid WANT_STATE depth")
    if prefixDepth > types.LsmrMaxDepth:
        return Err[types.WantStatePayload](" chain codec: invalid WANT_STATE depth")
    var digits: int32[]
    for i in 0..<prefixDepth:
        let digit: int32 = layout.ByteSpanAt(data, 72 + i)
        if !types.LsmrDigitOk(digit):
            return Err[types.WantStatePayload](" chain codec: invalid WANT_STATE digit")
        add(digits, digit)
    return types.WantStatePayloadFromDigits(Value(peerRes), Value(stateRes), targetBaguaId, digits)

fn DecodeWantStatePayloadRaw(data: layout.ByteSpan): Result[DecodedWantStatePayload] =
    if layout.ByteSpanLen(data) != 104:
        return Err[DecodedWantStatePayload](" chain codec: invalid WANT_STATE payload size")
    let peerRes = ReadFixed32(data, 0)
    if IsErr(peerRes):
        return Err[DecodedWantStatePayload](Error(peerRes))
    let stateRes = ReadFixed32(data, 32)
    if IsErr(stateRes):
        return Err[DecodedWantStatePayload](Error(stateRes))
    let baguaRes = ReadU32BE(data, 64)
    if IsErr(baguaRes):
        return Err[DecodedWantStatePayload](Error(baguaRes))
    let prefixDepthRes = ReadU32BE(data, 68)
    if IsErr(prefixDepthRes):
        return Err[DecodedWantStatePayload](Error(prefixDepthRes))
    let prefixDepth = int32(Value(prefixDepthRes))
    if prefixDepth < 0:
        return Err[DecodedWantStatePayload](" chain codec: invalid WANT_STATE depth")
    if prefixDepth > types.LsmrMaxDepth:
        return Err[DecodedWantStatePayload](" chain codec: invalid WANT_STATE depth")
    var digits: int32[]
    for i in 0..<prefixDepth:
        let digit: int32 = layout.ByteSpanAt(data, 72 + i)
        if !types.LsmrDigitOk(digit):
            return Err[DecodedWantStatePayload](" chain codec: invalid WANT_STATE digit")
        add(digits, digit)
    return DecodedWantStatePayloadMake(Value(peerRes), Value(stateRes), int32(Value(baguaRes)), digits)

fn EncodeStateChunkPayload(payload: types.StateChunkPayload): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(104)
    BufAppendFixed32(buf, payload.peerId)
    BufAppendFixed32(buf, payload.stateForestCid)
    BufAppendFixed32(buf, payload.subtreeCid)
    BufAppendU32BE(buf, payload.entryCount)
    BufAppendU32BE(buf, payload.nodeCount)
    return layout.ByteBufToBytes(buf)

fn DecodeStateChunkPayload(data: layout.ByteSpan): Result[types.StateChunkPayload] =
    if layout.ByteSpanLen(data) != 104:
        return Err[types.StateChunkPayload](" chain codec: invalid STATE_CHUNK payload size")
    let peerRes = ReadFixed32(data, 0)
    if IsErr(peerRes):
        return Err[types.StateChunkPayload](Error(peerRes))
    let stateRes = ReadFixed32(data, 32)
    if IsErr(stateRes):
        return Err[types.StateChunkPayload](Error(stateRes))
    let subtreeRes = ReadFixed32(data, 64)
    if IsErr(subtreeRes):
        return Err[types.StateChunkPayload](Error(subtreeRes))
    let entryRes = ReadU32BE(data, 96)
    if IsErr(entryRes):
        return Err[types.StateChunkPayload](Error(entryRes))
    let nodeRes = ReadU32BE(data, 100)
    if IsErr(nodeRes):
        return Err[types.StateChunkPayload](Error(nodeRes))
    return Ok[types.StateChunkPayload](types.StateChunkPayloadMake(
        Value(peerRes),
        Value(stateRes),
        Value(subtreeRes),
        int32(Value(entryRes)),
        int32(Value(nodeRes))
    ))

fn WrapFrame(kind: types.FrameKind,
               epoch: int32,
               ganzhiIndex: int32,
               sourcePeerId: layout.FixedBytes32,
               payload: Bytes): Result[Bytes] =
    let headerBytes: Bytes = EncodeFrameHeaderRaw(
        kind,
        bytesLen(payload),
        epoch,
        ganzhiIndex,
        sourcePeerId,
        FrameBodyCid(payload)
    )
    var out: layout.ByteBuf = layout.ByteBufInit(types.FrameHeaderSize + bytesLen(payload))
    layout.ByteBufAppendBytes(out, headerBytes)
    layout.ByteBufAppendBytes(out, payload)
    return Ok[Bytes](layout.ByteBufToBytes(out))

fn UnwrapExpectedPayload(frameBytes: Bytes, expectedKind: types.FrameKind): Result[Bytes] =
    if bytesLen(frameBytes) < types.FrameHeaderSize:
        return Err[Bytes](" chain codec: short frame")
    let span: layout.ByteSpan = layout.ByteSpanFromBytes(frameBytes)
    let headerRes: Result[DecodedFrameHeader] = DecodeFrameHeader(layout.ByteSpanSlice(span, 0, types.FrameHeaderSize))
    if IsErr(headerRes):
        return Err[Bytes](Error(headerRes))
    let header: DecodedFrameHeader = Value(headerRes)
    if header.payloadLen < 0 || header.payloadLen != (bytesLen(frameBytes) - types.FrameHeaderSize):
        return Err[Bytes](" chain codec: payload length mismatch")
    if header.kind != expectedKind:
        return Err[Bytes](" chain codec: unexpected frame kind")
    let payload: Bytes = bytesSlice(frameBytes, types.FrameHeaderSize, header.payloadLen)
    let bodyCid: layout.FixedBytes32 = FrameBodyCid(payload)
    if ! layout.FixedBytes32Equal(bodyCid, header.bodyCid):
        return Err[Bytes](" chain codec: payload cid mismatch")
    return Ok[Bytes](payload)

fn EncodeHelloFrame(payload: types.HelloPayload, epoch: int32, ganzhiIndex: int32): Result[Bytes] =
    return WrapFrame(types.FrameKindHello, epoch, ganzhiIndex, payload.peerId, EncodeHelloPayload(payload))

fn EncodeHelloFrameRaw(peerId: layout.FixedBytes32,
                         address: types.LsmrAddress,
                         tipEventCid: layout.FixedBytes32,
                         summary: DecodedStateRootSummary,
                         epoch: int32,
                         ganzhiIndex: int32): Result[Bytes] =
    return WrapFrame(types.FrameKindHello, epoch, ganzhiIndex, peerId, EncodeHelloPayloadRaw(peerId, address, tipEventCid, summary))

fn DecodeHelloFrame(frameBytes: Bytes): Result[types.HelloPayload] =
    let payloadRes: Result[Bytes] = UnwrapExpectedPayload(frameBytes, types.FrameKindHello)
    if IsErr(payloadRes):
        return Err[types.HelloPayload](Error(payloadRes))
    return DecodeHelloPayload(layout.ByteSpanFromBytes(Value(payloadRes)))

fn DecodeHelloFrameRaw(frameBytes: Bytes): Result[DecodedHelloPayload] =
    let payloadRes: Result[Bytes] = UnwrapExpectedPayload(frameBytes, types.FrameKindHello)
    if IsErr(payloadRes):
        return Err[DecodedHelloPayload](Error(payloadRes))
    return DecodeHelloPayloadRaw(layout.ByteSpanFromBytes(Value(payloadRes)))

fn EncodeAdvertiseFrame(payload: types.AdvertisePayload, epoch: int32, ganzhiIndex: int32): Result[Bytes] =
    return WrapFrame(types.FrameKindAdvertise, epoch, ganzhiIndex, payload.peerId, EncodeAdvertisePayload(payload))

fn EncodeAdvertiseFrameRaw(peerId: layout.FixedBytes32,
                             stateForestCid: layout.FixedBytes32,
                             eventCid: layout.FixedBytes32,
                             accountCount: int32,
                             eventCount: int32,
                             maxStampEpoch: int32,
                             maxStampGanzhi: int32,
                             epoch: int32,
                             ganzhiIndex: int32): Result[Bytes] =
    return WrapFrame(
        types.FrameKindAdvertise,
        epoch,
        ganzhiIndex,
        peerId,
        EncodeAdvertisePayloadRaw(peerId, stateForestCid, eventCid, accountCount, eventCount, maxStampEpoch, maxStampGanzhi)
    )

fn DecodeAdvertiseFrame(frameBytes: Bytes): Result[types.AdvertisePayload] =
    let payloadRes: Result[Bytes] = UnwrapExpectedPayload(frameBytes, types.FrameKindAdvertise)
    if IsErr(payloadRes):
        return Err[types.AdvertisePayload](Error(payloadRes))
    return DecodeAdvertisePayload(layout.ByteSpanFromBytes(Value(payloadRes)))

fn DecodeAdvertiseFrameRaw(frameBytes: Bytes): Result[DecodedAdvertisePayload] =
    let payloadRes: Result[Bytes] = UnwrapExpectedPayload(frameBytes, types.FrameKindAdvertise)
    if IsErr(payloadRes):
        return Err[DecodedAdvertisePayload](Error(payloadRes))
    return DecodeAdvertisePayloadRaw(layout.ByteSpanFromBytes(Value(payloadRes)))

fn EncodeWantStateFrame(payload: types.WantStatePayload, epoch: int32, ganzhiIndex: int32): Result[Bytes] =
    return WrapFrame(types.FrameKindWantState, epoch, ganzhiIndex, payload.peerId, EncodeWantStatePayload(payload))

fn EncodeWantStateFrameRaw(peerId: layout.FixedBytes32,
                             stateForestCid: layout.FixedBytes32,
                             targetBaguaId: int32,
                             prefixDigitsRaw: int32[],
                             epoch: int32,
                             ganzhiIndex: int32): Result[Bytes] =
    let payloadRes = EncodeWantStatePayloadRaw(peerId, stateForestCid, targetBaguaId, prefixDigitsRaw)
    if IsErr(payloadRes):
        return Err[Bytes](Error(payloadRes))
    return WrapFrame(types.FrameKindWantState, epoch, ganzhiIndex, peerId, Value(payloadRes))

fn DecodeWantStateFrame(frameBytes: Bytes): Result[types.WantStatePayload] =
    let payloadRes: Result[Bytes] = UnwrapExpectedPayload(frameBytes, types.FrameKindWantState)
    if IsErr(payloadRes):
        return Err[types.WantStatePayload](Error(payloadRes))
    return DecodeWantStatePayload(layout.ByteSpanFromBytes(Value(payloadRes)))

fn DecodeWantStateFrameRaw(frameBytes: Bytes): Result[DecodedWantStatePayload] =
    let payloadRes: Result[Bytes] = UnwrapExpectedPayload(frameBytes, types.FrameKindWantState)
    if IsErr(payloadRes):
        return Err[DecodedWantStatePayload](Error(payloadRes))
    return DecodeWantStatePayloadRaw(layout.ByteSpanFromBytes(Value(payloadRes)))
