import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content
import cheng/chain/content_fetch as fetch

type
    V3ContentManifestCacheEntry =
        manifestCid: layout.FixedBytes32
        payloadLen: int32
        payload: Bytes

    V3ContentShardCacheEntry =
        manifestCid: layout.FixedBytes32
        shardIndex: int32
        shardCid: layout.FixedBytes32
        payloadLen: int32
        payload: Bytes

    V3ContentPreviewCacheEntry =
        previewCid: layout.FixedBytes32
        payloadLen: int32
        payload: Bytes

    V3ContentBlobCacheEntry =
        blobCid: layout.FixedBytes32
        payloadLen: int32
        payload: Bytes

    V3ContentRuntime =
        manifestCache: V3ContentManifestCacheEntry[]
        shardCache: V3ContentShardCacheEntry[]
        previewCache: V3ContentPreviewCacheEntry[]
        blobCache: V3ContentBlobCacheEntry[]

    V3ContentPullTarget =
        peerId: layout.FixedBytes32
        request: swarm.V3ErasureShardPullRequest

fn v3ContentRuntimeInit(): V3ContentRuntime =
    var out: V3ContentRuntime
    out.manifestCache = []
    out.shardCache = []
    out.previewCache = []
    out.blobCache = []
    return out

fn v3ContentRuntimeManifestCachePos(runtime: V3ContentRuntime,
                                    manifestCid: layout.FixedBytes32): int32 =
    for i in 0..<runtime.manifestCache.len:
        if layout.fixedBytes32Equal(runtime.manifestCache[i].manifestCid, manifestCid):
            return i
    return -1

fn v3ContentRuntimeStoreManifestPayload(runtime: var V3ContentRuntime,
                                        manifestCid: layout.FixedBytes32,
                                        payload: Bytes): Result[bool] =
    let payloadOk = swarm.v3ErasureShardManifestValidatePayload(payload, manifestCid)
    if IsErr(payloadOk):
        return Err[bool](Error(payloadOk))
    let pos = v3ContentRuntimeManifestCachePos(runtime, manifestCid)
    var entry = V3ContentManifestCacheEntry()
    entry.manifestCid = manifestCid
    entry.payloadLen = bytesLen(payload)
    entry.payload = payload
    if pos >= 0:
        runtime.manifestCache[pos] = entry
    else:
        add(runtime.manifestCache, entry)
    return Ok[bool](true)

fn v3ContentRuntimeStoreManifest(runtime: var V3ContentRuntime,
                                 manifest: swarm.V3ErasureShardManifest): Result[bool] =
    return v3ContentRuntimeStoreManifestPayload(runtime,
                                                manifest.manifestCid,
                                                swarm.v3ErasureShardManifestEncode(manifest))

fn v3ContentRuntimeCachedManifestPayload(runtime: V3ContentRuntime,
                                         manifestCid: layout.FixedBytes32,
                                         out: var Bytes): bool =
    let pos = v3ContentRuntimeManifestCachePos(runtime, manifestCid)
    if pos < 0:
        return false
    out = runtime.manifestCache[pos].payload
    return true

fn v3ContentRuntimePreviewCachePos(runtime: V3ContentRuntime,
                                   previewCid: layout.FixedBytes32): int32 =
    for i in 0..<runtime.previewCache.len:
        if layout.fixedBytes32Equal(runtime.previewCache[i].previewCid, previewCid):
            return i
    return -1

fn v3ContentRuntimeStorePreviewPayload(runtime: var V3ContentRuntime,
                                       previewCid: layout.FixedBytes32,
                                       payload: Bytes): Result[bool] =
    let manifestOk = content.v3ContentManifestValidatePayload(payload, previewCid)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    var manifest = content.V3ContentManifest()
    let manifestRes = content.v3ContentManifestDecodeFill(manifest, payload)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    if !layout.fixedBytes32Equal(manifest.previewCid, previewCid):
        return Err[bool]("v3 content runtime: preview cid mismatch")
    let pos = v3ContentRuntimePreviewCachePos(runtime, previewCid)
    var entry = V3ContentPreviewCacheEntry()
    entry.previewCid = previewCid
    entry.payloadLen = bytesLen(payload)
    entry.payload = payload
    if pos >= 0:
        runtime.previewCache[pos] = entry
    else:
        add(runtime.previewCache, entry)
    return Ok[bool](true)

fn v3ContentRuntimeStorePreview(runtime: var V3ContentRuntime,
                                manifest: content.V3ContentManifest): Result[bool] =
    let manifestOk = content.v3ContentManifestValidate(manifest)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    return v3ContentRuntimeStorePreviewPayload(runtime,
                                               manifest.previewCid,
                                               content.v3ContentManifestEncode(manifest))

fn v3ContentRuntimeCachedPreviewPayload(runtime: V3ContentRuntime,
                                        previewCid: layout.FixedBytes32,
                                        out: var Bytes): bool =
    let pos = v3ContentRuntimePreviewCachePos(runtime, previewCid)
    if pos < 0:
        return false
    out = runtime.previewCache[pos].payload
    return true

fn v3ContentRuntimeBlobCachePos(runtime: V3ContentRuntime,
                                blobCid: layout.FixedBytes32): int32 =
    for i in 0..<runtime.blobCache.len:
        if layout.fixedBytes32Equal(runtime.blobCache[i].blobCid, blobCid):
            return i
    return -1

fn v3ContentRuntimeStoreBlobPayload(runtime: var V3ContentRuntime,
                                    blobCid: layout.FixedBytes32,
                                    payload: Bytes): Result[bool] =
    if !layout.fixedBytes32Equal(dag.v3DagBlobCidFromBytes(payload), blobCid):
        return Err[bool]("v3 content runtime: blob cid mismatch")
    let pos = v3ContentRuntimeBlobCachePos(runtime, blobCid)
    var entry = V3ContentBlobCacheEntry()
    entry.blobCid = blobCid
    entry.payloadLen = bytesLen(payload)
    entry.payload = payload
    if pos >= 0:
        runtime.blobCache[pos] = entry
    else:
        add(runtime.blobCache, entry)
    return Ok[bool](true)

fn v3ContentRuntimeCachedBlob(runtime: V3ContentRuntime,
                              blobCid: layout.FixedBytes32,
                              out: var Bytes): bool =
    let pos = v3ContentRuntimeBlobCachePos(runtime, blobCid)
    if pos < 0:
        return false
    out = runtime.blobCache[pos].payload
    return true

fn v3ContentRuntimeShardCachePos(runtime: V3ContentRuntime,
                                 manifestCid: layout.FixedBytes32,
                                 shardIndex: int32,
                                 shardCid: layout.FixedBytes32): int32 =
    for i in 0..<runtime.shardCache.len:
        let entry = runtime.shardCache[i]
        if layout.fixedBytes32Equal(entry.manifestCid, manifestCid) &&
           entry.shardIndex == shardIndex &&
           layout.fixedBytes32Equal(entry.shardCid, shardCid):
            return i
    return -1

fn v3ContentRuntimeStoreShardResponse(runtime: var V3ContentRuntime,
                                      response: swarm.V3ErasureShardPullResponse): Result[bool] =
    let responseOk = swarm.v3ErasureShardPullResponseDecode(swarm.v3ErasureShardPullResponseEncode(response))
    if IsErr(responseOk):
        return Err[bool](Error(responseOk))
    let pos = v3ContentRuntimeShardCachePos(runtime,
                                            response.manifestCid,
                                            response.shardIndex,
                                            response.shardCid)
    var entry = V3ContentShardCacheEntry()
    entry.manifestCid = response.manifestCid
    entry.shardIndex = response.shardIndex
    entry.shardCid = response.shardCid
    entry.payloadLen = response.payloadLen
    entry.payload = response.payload
    if pos >= 0:
        runtime.shardCache[pos] = entry
    else:
        add(runtime.shardCache, entry)
    return Ok[bool](true)

fn v3ContentRuntimeCachedShard(runtime: V3ContentRuntime,
                               request: swarm.V3ErasureShardPullRequest,
                               out: var Bytes): bool =
    let pos = v3ContentRuntimeShardCachePos(runtime,
                                            request.manifestCid,
                                            request.shardIndex,
                                            request.shardCid)
    if pos < 0:
        return false
    out = runtime.shardCache[pos].payload
    return true

fn v3ContentRuntimeServePayload(runtime: var V3ContentRuntime,
                                requestPayload: Bytes): Result[Bytes] =
    let requestRes = swarm.v3ErasureShardPullRequestDecode(requestPayload)
    if IsErr(requestRes):
        return Err[Bytes](Error(requestRes))
    let request = Value(requestRes)
    let fetchRequestRes = fetch.v3ContentFetchRequestFromShardPull(request)
    if IsErr(fetchRequestRes):
        return Err[Bytes](Error(fetchRequestRes))
    let fetchRequest = Value(fetchRequestRes)
    let fetchPayloadRes = v3ContentRuntimeServeFetchPayload(runtime,
                                                            fetch.v3ContentFetchRequestEncode(fetchRequest))
    if IsErr(fetchPayloadRes):
        return Err[Bytes](Error(fetchPayloadRes))
    let fetchPayload = Value(fetchPayloadRes)
    let fetchResponseRes = fetch.v3ContentFetchResponseDecode(fetchPayload)
    if IsErr(fetchResponseRes):
        return Err[Bytes](Error(fetchResponseRes))
    let fetchResponse = Value(fetchResponseRes)
    var shardResponse = swarm.V3ErasureShardPullResponse()
    let shardResponseRes = fetch.v3ContentFetchResponseToShardPullFill(shardResponse,
                                                                       fetchRequest,
                                                                       fetchResponse)
    if IsErr(shardResponseRes):
        return Err[Bytes](Error(shardResponseRes))
    return Ok[Bytes](swarm.v3ErasureShardPullResponseEncode(shardResponse))

fn v3ContentRuntimeServeFetchPayload(runtime: var V3ContentRuntime,
                                     requestPayload: Bytes): Result[Bytes] =
    let fetchRequestRes = fetch.v3ContentFetchRequestDecode(requestPayload)
    if IsErr(fetchRequestRes):
        return Err[Bytes](Error(fetchRequestRes))
    let request = Value(fetchRequestRes)
    if request.method == fetch.v3ContentFetchMethodManifest:
        var manifestPayload: Bytes
        if !v3ContentRuntimeCachedManifestPayload(runtime, request.manifestCid, manifestPayload):
            return Err[Bytes]("v3 content runtime: manifest missing in cache")
        let responseRes = fetch.v3ContentFetchResponseMake(request, manifestPayload)
        if IsErr(responseRes):
            return Err[Bytes](Error(responseRes))
        let response = Value(responseRes)
        return Ok[Bytes](fetch.v3ContentFetchResponseEncode(response))
    if request.method == fetch.v3ContentFetchMethodPreview:
        var previewPayload: Bytes
        if !v3ContentRuntimeCachedPreviewPayload(runtime, request.targetCid, previewPayload):
            return Err[Bytes]("v3 content runtime: preview missing in cache")
        let responseRes = fetch.v3ContentFetchResponseMake(request, previewPayload)
        if IsErr(responseRes):
            return Err[Bytes](Error(responseRes))
        let response = Value(responseRes)
        return Ok[Bytes](fetch.v3ContentFetchResponseEncode(response))
    if request.method == fetch.v3ContentFetchMethodRange:
        var blob: Bytes
        if !v3ContentRuntimeCachedBlob(runtime, request.targetCid, blob):
            return Err[Bytes]("v3 content runtime: blob missing in cache")
        if request.rangeStart < 0 || request.rangeLen <= 0:
            return Err[Bytes]("v3 content runtime: invalid range request")
        if request.rangeStart + request.rangeLen > bytesLen(blob):
            return Err[Bytes]("v3 content runtime: range exceeds blob length")
        let rangePayload = bytesSlice(blob, request.rangeStart, request.rangeLen)
        let responseRes = fetch.v3ContentFetchResponseMake(request, rangePayload)
        if IsErr(responseRes):
            return Err[Bytes](Error(responseRes))
        let response = Value(responseRes)
        return Ok[Bytes](fetch.v3ContentFetchResponseEncode(response))
    let shardRequestRes = fetch.v3ContentFetchRequestToShardPull(request)
    if IsErr(shardRequestRes):
        return Err[Bytes](Error(shardRequestRes))
    let shardRequest = Value(shardRequestRes)
    var payload: Bytes
    if !v3ContentRuntimeCachedShard(runtime, shardRequest, payload):
        return Err[Bytes]("v3 content runtime: shard missing in cache")
    let responseRes = fetch.v3ContentFetchResponseMake(request, payload)
    if IsErr(responseRes):
        return Err[Bytes](Error(responseRes))
    let response = Value(responseRes)
    return Ok[Bytes](fetch.v3ContentFetchResponseEncode(response))

fn v3ContentRuntimeBuildPullTargets(manifestCid: layout.FixedBytes32,
                                    manifestShardIndices: int32[],
                                    manifestShardPayloadCids: layout.FixedBytes32[],
                                    planManifestCid: layout.FixedBytes32,
                                    requestCount: int32,
                                    requestPeerIds: layout.FixedBytes32[],
                                    requestShardIndices: int32[],
                                    requestShardCids: layout.FixedBytes32[]): Result[V3ContentPullTarget[]] =
    if !layout.fixedBytes32Equal(manifestCid, planManifestCid):
        return Err[V3ContentPullTarget[]]("v3 content runtime: recovery plan manifest mismatch")
    if requestCount != requestPeerIds.len:
        return Err[V3ContentPullTarget[]]("v3 content runtime: recovery plan peer count mismatch")
    if requestCount != requestShardIndices.len:
        return Err[V3ContentPullTarget[]]("v3 content runtime: recovery plan shard count mismatch")
    if requestCount != requestShardCids.len:
        return Err[V3ContentPullTarget[]]("v3 content runtime: recovery plan shard cid count mismatch")
    var out: V3ContentPullTarget[]
    out = []
    for i in 0..<requestShardIndices.len:
        var request = swarm.V3ErasureShardPullRequest()
        let requestFillRes = swarm.v3ErasureShardPullRequestFillFromFields(request,
                                                                           manifestCid,
                                                                           manifestShardIndices,
                                                                           manifestShardPayloadCids,
                                                                           requestShardIndices[i])
        if IsErr(requestFillRes):
            return Err[V3ContentPullTarget[]](Error(requestFillRes))
        if !layout.fixedBytes32Equal(request.shardCid, requestShardCids[i]):
            return Err[V3ContentPullTarget[]]("v3 content runtime: recovery plan shard cid mismatch")
        var target = V3ContentPullTarget()
        target.peerId = requestPeerIds[i]
        target.request = request
        add(out, target)
    return Ok[V3ContentPullTarget[]](out)

fn v3ContentRuntimeBuildPullRequests(manifestCid: layout.FixedBytes32,
                                     manifestShardIndices: int32[],
                                     manifestShardPayloadCids: layout.FixedBytes32[],
                                     planManifestCid: layout.FixedBytes32,
                                     requestCount: int32,
                                     requestPeerIds: layout.FixedBytes32[],
                                     requestShardIndices: int32[],
                                     requestShardCids: layout.FixedBytes32[]): Result[swarm.V3ErasureShardPullRequest[]] =
    let targetsRes = v3ContentRuntimeBuildPullTargets(manifestCid,
                                                      manifestShardIndices,
                                                      manifestShardPayloadCids,
                                                      planManifestCid,
                                                      requestCount,
                                                      requestPeerIds,
                                                      requestShardIndices,
                                                      requestShardCids)
    if IsErr(targetsRes):
        return Err[swarm.V3ErasureShardPullRequest[]](Error(targetsRes))
    var out: swarm.V3ErasureShardPullRequest[]
    out = []
    let targets = Value(targetsRes)
    for i in 0..<targets.len:
        add(out, targets[i].request)
    return Ok[swarm.V3ErasureShardPullRequest[]](out)

fn v3ContentRuntimeRebuildBlob(manifest: swarm.V3ErasureShardManifest,
                               params: swarm.V3ErasureEncodingParams,
                               responses: swarm.V3ErasureShardPullResponse[]): Result[Bytes] =
    return swarm.v3ErasureRebuildBlobFromResponses(manifest, params, responses)

fn v3ContentRuntimeRebuildBlobAgainstStub(stub: content.V3ContentStub,
                                          manifest: swarm.V3ErasureShardManifest,
                                          params: swarm.V3ErasureEncodingParams,
                                          responses: swarm.V3ErasureShardPullResponse[]): Result[Bytes] =
    let blobRes = v3ContentRuntimeRebuildBlob(manifest, params, responses)
    if IsErr(blobRes):
        return Err[Bytes](Error(blobRes))
    let blob = Value(blobRes)
    let summaryRes = dag.v3DagBlobSummaryFromBytes(blob, params.shardPayloadBytes)
    if IsErr(summaryRes):
        return Err[Bytes](Error(summaryRes))
    let summary = Value(summaryRes)
    if summary.payloadLen != stub.payloadLen:
        return Err[Bytes]("v3 content runtime: rebuilt blob payload length mismatch")
    if !layout.fixedBytes32Equal(summary.summaryCid, stub.blobSummaryCid):
        return Err[Bytes]("v3 content runtime: rebuilt blob summary cid mismatch")
    return Ok[Bytes](blob)
