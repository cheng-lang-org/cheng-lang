import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content
import cheng/chain/content_fetch as fetch

type
    ContentManifestCacheEntry =
        manifestCid: layout.FixedBytes32
        payloadLen: int32
        payload: Bytes

    ContentShardCacheEntry =
        manifestCid: layout.FixedBytes32
        shardIndex: int32
        shardCid: layout.FixedBytes32
        payloadLen: int32
        payload: Bytes

    ContentPreviewCacheEntry =
        previewCid: layout.FixedBytes32
        payloadLen: int32
        payload: Bytes

    ContentBlobCacheEntry =
        blobCid: layout.FixedBytes32
        payloadLen: int32
        payload: Bytes

    ContentRuntime =
        manifestCache: ContentManifestCacheEntry[]
        shardCache: ContentShardCacheEntry[]
        previewCache: ContentPreviewCacheEntry[]
        blobCache: ContentBlobCacheEntry[]

    ContentPullTarget =
        peerId: layout.FixedBytes32
        request: swarm.ErasureShardPullRequest

fn ContentRuntimeInit(): ContentRuntime =
    var out: ContentRuntime
    out.manifestCache = []
    out.shardCache = []
    out.previewCache = []
    out.blobCache = []
    return out

fn ContentRuntimeManifestCachePos(runtime: ContentRuntime,
                                    manifestCid: layout.FixedBytes32): int32 =
    for i in 0..<runtime.manifestCache.len:
        if layout.fixedBytes32Equal(runtime.manifestCache[i].manifestCid, manifestCid):
            return i
    return -1

fn ContentRuntimeStoreManifestPayload(runtime: var ContentRuntime,
                                        manifestCid: layout.FixedBytes32,
                                        payload: Bytes): Result[bool] =
    let payloadOk = swarm.ErasureShardManifestValidatePayload(payload, manifestCid)
    if IsErr(payloadOk):
        return Err[bool](Error(payloadOk))
    let pos = ContentRuntimeManifestCachePos(runtime, manifestCid)
    var entry = ContentManifestCacheEntry()
    entry.manifestCid = manifestCid
    entry.payloadLen = bytesLen(payload)
    entry.payload = payload
    if pos >= 0:
        runtime.manifestCache[pos] = entry
    else:
        add(runtime.manifestCache, entry)
    return Ok[bool](true)

fn ContentRuntimeStoreManifest(runtime: var ContentRuntime,
                                 manifest: swarm.ErasureShardManifest): Result[bool] =
    return ContentRuntimeStoreManifestPayload(runtime,
                                                manifest.manifestCid,
                                                swarm.ErasureShardManifestEncode(manifest))

fn ContentRuntimeCachedManifestPayload(runtime: ContentRuntime,
                                         manifestCid: layout.FixedBytes32,
                                         out: var Bytes): bool =
    let pos = ContentRuntimeManifestCachePos(runtime, manifestCid)
    if pos < 0:
        return false
    out = runtime.manifestCache[pos].payload
    return true

fn ContentRuntimePreviewCachePos(runtime: ContentRuntime,
                                   previewCid: layout.FixedBytes32): int32 =
    for i in 0..<runtime.previewCache.len:
        if layout.fixedBytes32Equal(runtime.previewCache[i].previewCid, previewCid):
            return i
    return -1

fn ContentRuntimeStorePreviewPayload(runtime: var ContentRuntime,
                                       previewCid: layout.FixedBytes32,
                                       payload: Bytes): Result[bool] =
    let manifestOk = content.ContentManifestValidatePayload(payload, previewCid)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    var manifest = content.ContentManifest()
    let manifestRes = content.ContentManifestDecodeFill(manifest, payload)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    if !layout.fixedBytes32Equal(manifest.previewCid, previewCid):
        return Err[bool](" content runtime: preview cid mismatch")
    let pos = ContentRuntimePreviewCachePos(runtime, previewCid)
    var entry = ContentPreviewCacheEntry()
    entry.previewCid = previewCid
    entry.payloadLen = bytesLen(payload)
    entry.payload = payload
    if pos >= 0:
        runtime.previewCache[pos] = entry
    else:
        add(runtime.previewCache, entry)
    return Ok[bool](true)

fn ContentRuntimeStorePreview(runtime: var ContentRuntime,
                                manifest: content.ContentManifest): Result[bool] =
    let manifestOk = content.ContentManifestValidate(manifest)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    return ContentRuntimeStorePreviewPayload(runtime,
                                               manifest.previewCid,
                                               content.ContentManifestEncode(manifest))

fn ContentRuntimeCachedPreviewPayload(runtime: ContentRuntime,
                                        previewCid: layout.FixedBytes32,
                                        out: var Bytes): bool =
    let pos = ContentRuntimePreviewCachePos(runtime, previewCid)
    if pos < 0:
        return false
    out = runtime.previewCache[pos].payload
    return true

fn ContentRuntimeBlobCachePos(runtime: ContentRuntime,
                                blobCid: layout.FixedBytes32): int32 =
    for i in 0..<runtime.blobCache.len:
        if layout.fixedBytes32Equal(runtime.blobCache[i].blobCid, blobCid):
            return i
    return -1

fn ContentRuntimeStoreBlobPayload(runtime: var ContentRuntime,
                                    blobCid: layout.FixedBytes32,
                                    payload: Bytes): Result[bool] =
    if !layout.fixedBytes32Equal(dag.DagBlobCidFromBytes(payload), blobCid):
        return Err[bool](" content runtime: blob cid mismatch")
    let pos = ContentRuntimeBlobCachePos(runtime, blobCid)
    var entry = ContentBlobCacheEntry()
    entry.blobCid = blobCid
    entry.payloadLen = bytesLen(payload)
    entry.payload = payload
    if pos >= 0:
        runtime.blobCache[pos] = entry
    else:
        add(runtime.blobCache, entry)
    return Ok[bool](true)

fn ContentRuntimeCachedBlob(runtime: ContentRuntime,
                              blobCid: layout.FixedBytes32,
                              out: var Bytes): bool =
    let pos = ContentRuntimeBlobCachePos(runtime, blobCid)
    if pos < 0:
        return false
    out = runtime.blobCache[pos].payload
    return true

fn ContentRuntimeShardCachePos(runtime: ContentRuntime,
                                 manifestCid: layout.FixedBytes32,
                                 shardIndex: int32,
                                 shardCid: layout.FixedBytes32): int32 =
    for i in 0..<runtime.shardCache.len:
        let entry = runtime.shardCache[i]
        if layout.fixedBytes32Equal(entry.manifestCid, manifestCid) &&
           entry.shardIndex == shardIndex &&
           layout.fixedBytes32Equal(entry.shardCid, shardCid):
            return i
    return -1

fn ContentRuntimeStoreShardResponse(runtime: var ContentRuntime,
                                      response: swarm.ErasureShardPullResponse): Result[bool] =
    let responseOk = swarm.ErasureShardPullResponseDecode(swarm.ErasureShardPullResponseEncode(response))
    if IsErr(responseOk):
        return Err[bool](Error(responseOk))
    let pos = ContentRuntimeShardCachePos(runtime,
                                            response.manifestCid,
                                            response.shardIndex,
                                            response.shardCid)
    var entry = ContentShardCacheEntry()
    entry.manifestCid = response.manifestCid
    entry.shardIndex = response.shardIndex
    entry.shardCid = response.shardCid
    entry.payloadLen = response.payloadLen
    entry.payload = response.payload
    if pos >= 0:
        runtime.shardCache[pos] = entry
    else:
        add(runtime.shardCache, entry)
    return Ok[bool](true)

fn ContentRuntimeCachedShard(runtime: ContentRuntime,
                               request: swarm.ErasureShardPullRequest,
                               out: var Bytes): bool =
    let pos = ContentRuntimeShardCachePos(runtime,
                                            request.manifestCid,
                                            request.shardIndex,
                                            request.shardCid)
    if pos < 0:
        return false
    out = runtime.shardCache[pos].payload
    return true

fn ContentRuntimeServePayload(runtime: var ContentRuntime,
                                requestPayload: Bytes): Result[Bytes] =
    let requestRes = swarm.ErasureShardPullRequestDecode(requestPayload)
    if IsErr(requestRes):
        return Err[Bytes](Error(requestRes))
    let request = Value(requestRes)
    let fetchRequestRes = fetch.ContentFetchRequestFromShardPull(request)
    if IsErr(fetchRequestRes):
        return Err[Bytes](Error(fetchRequestRes))
    let fetchRequest = Value(fetchRequestRes)
    let fetchPayloadRes = ContentRuntimeServeFetchPayload(runtime,
                                                            fetch.ContentFetchRequestEncode(fetchRequest))
    if IsErr(fetchPayloadRes):
        return Err[Bytes](Error(fetchPayloadRes))
    let fetchPayload = Value(fetchPayloadRes)
    let fetchResponseRes = fetch.ContentFetchResponseDecode(fetchPayload)
    if IsErr(fetchResponseRes):
        return Err[Bytes](Error(fetchResponseRes))
    let fetchResponse = Value(fetchResponseRes)
    var shardResponse = swarm.ErasureShardPullResponse()
    let shardResponseRes = fetch.ContentFetchResponseToShardPullFill(shardResponse,
                                                                       fetchRequest,
                                                                       fetchResponse)
    if IsErr(shardResponseRes):
        return Err[Bytes](Error(shardResponseRes))
    return Ok[Bytes](swarm.ErasureShardPullResponseEncode(shardResponse))

fn ContentRuntimeServeFetchPayload(runtime: var ContentRuntime,
                                     requestPayload: Bytes): Result[Bytes] =
    let fetchRequestRes = fetch.ContentFetchRequestDecode(requestPayload)
    if IsErr(fetchRequestRes):
        return Err[Bytes](Error(fetchRequestRes))
    let request = Value(fetchRequestRes)
    if request.method == fetch.ContentFetchMethodManifest:
        var manifestPayload: Bytes
        if !ContentRuntimeCachedManifestPayload(runtime, request.manifestCid, manifestPayload):
            return Err[Bytes](" content runtime: manifest missing in cache")
        let responseRes = fetch.ContentFetchResponseMake(request, manifestPayload)
        if IsErr(responseRes):
            return Err[Bytes](Error(responseRes))
        let response = Value(responseRes)
        return Ok[Bytes](fetch.ContentFetchResponseEncode(response))
    if request.method == fetch.ContentFetchMethodPreview:
        var previewPayload: Bytes
        if !ContentRuntimeCachedPreviewPayload(runtime, request.targetCid, previewPayload):
            return Err[Bytes](" content runtime: preview missing in cache")
        let responseRes = fetch.ContentFetchResponseMake(request, previewPayload)
        if IsErr(responseRes):
            return Err[Bytes](Error(responseRes))
        let response = Value(responseRes)
        return Ok[Bytes](fetch.ContentFetchResponseEncode(response))
    if request.method == fetch.ContentFetchMethodRange:
        var blob: Bytes
        if !ContentRuntimeCachedBlob(runtime, request.targetCid, blob):
            return Err[Bytes](" content runtime: blob missing in cache")
        if request.rangeStart < 0 || request.rangeLen <= 0:
            return Err[Bytes](" content runtime: invalid range request")
        if request.rangeStart + request.rangeLen > bytesLen(blob):
            return Err[Bytes](" content runtime: range exceeds blob length")
        let rangePayload = bytesSlice(blob, request.rangeStart, request.rangeLen)
        let responseRes = fetch.ContentFetchResponseMake(request, rangePayload)
        if IsErr(responseRes):
            return Err[Bytes](Error(responseRes))
        let response = Value(responseRes)
        return Ok[Bytes](fetch.ContentFetchResponseEncode(response))
    let shardRequestRes = fetch.ContentFetchRequestToShardPull(request)
    if IsErr(shardRequestRes):
        return Err[Bytes](Error(shardRequestRes))
    let shardRequest = Value(shardRequestRes)
    var payload: Bytes
    if !ContentRuntimeCachedShard(runtime, shardRequest, payload):
        return Err[Bytes](" content runtime: shard missing in cache")
    let responseRes = fetch.ContentFetchResponseMake(request, payload)
    if IsErr(responseRes):
        return Err[Bytes](Error(responseRes))
    let response = Value(responseRes)
    return Ok[Bytes](fetch.ContentFetchResponseEncode(response))

fn ContentRuntimeBuildPullTargets(manifestCid: layout.FixedBytes32,
                                    manifestShardIndices: int32[],
                                    manifestShardPayloadCids: layout.FixedBytes32[],
                                    planManifestCid: layout.FixedBytes32,
                                    requestCount: int32,
                                    requestPeerIds: layout.FixedBytes32[],
                                    requestShardIndices: int32[],
                                    requestShardCids: layout.FixedBytes32[]): Result[ContentPullTarget[]] =
    if !layout.fixedBytes32Equal(manifestCid, planManifestCid):
        return Err[ContentPullTarget[]](" content runtime: recovery plan manifest mismatch")
    if requestCount != requestPeerIds.len:
        return Err[ContentPullTarget[]](" content runtime: recovery plan peer count mismatch")
    if requestCount != requestShardIndices.len:
        return Err[ContentPullTarget[]](" content runtime: recovery plan shard count mismatch")
    if requestCount != requestShardCids.len:
        return Err[ContentPullTarget[]](" content runtime: recovery plan shard cid count mismatch")
    var out: ContentPullTarget[]
    out = []
    for i in 0..<requestShardIndices.len:
        var request = swarm.ErasureShardPullRequest()
        let requestFillRes = swarm.ErasureShardPullRequestFillFromFields(request,
                                                                           manifestCid,
                                                                           manifestShardIndices,
                                                                           manifestShardPayloadCids,
                                                                           requestShardIndices[i])
        if IsErr(requestFillRes):
            return Err[ContentPullTarget[]](Error(requestFillRes))
        if !layout.fixedBytes32Equal(request.shardCid, requestShardCids[i]):
            return Err[ContentPullTarget[]](" content runtime: recovery plan shard cid mismatch")
        var target = ContentPullTarget()
        target.peerId = requestPeerIds[i]
        target.request = request
        add(out, target)
    return Ok[ContentPullTarget[]](out)

fn ContentRuntimeBuildPullRequests(manifestCid: layout.FixedBytes32,
                                     manifestShardIndices: int32[],
                                     manifestShardPayloadCids: layout.FixedBytes32[],
                                     planManifestCid: layout.FixedBytes32,
                                     requestCount: int32,
                                     requestPeerIds: layout.FixedBytes32[],
                                     requestShardIndices: int32[],
                                     requestShardCids: layout.FixedBytes32[]): Result[swarm.ErasureShardPullRequest[]] =
    let targetsRes = ContentRuntimeBuildPullTargets(manifestCid,
                                                      manifestShardIndices,
                                                      manifestShardPayloadCids,
                                                      planManifestCid,
                                                      requestCount,
                                                      requestPeerIds,
                                                      requestShardIndices,
                                                      requestShardCids)
    if IsErr(targetsRes):
        return Err[swarm.ErasureShardPullRequest[]](Error(targetsRes))
    var out: swarm.ErasureShardPullRequest[]
    out = []
    let targets = Value(targetsRes)
    for i in 0..<targets.len:
        add(out, targets[i].request)
    return Ok[swarm.ErasureShardPullRequest[]](out)

fn ContentRuntimeRebuildBlob(manifest: swarm.ErasureShardManifest,
                               params: swarm.ErasureEncodingParams,
                               responses: swarm.ErasureShardPullResponse[]): Result[Bytes] =
    return swarm.ErasureRebuildBlobFromResponses(manifest, params, responses)

fn ContentRuntimeRebuildBlobAgainstStub(stub: content.ContentStub,
                                          manifest: swarm.ErasureShardManifest,
                                          params: swarm.ErasureEncodingParams,
                                          responses: swarm.ErasureShardPullResponse[]): Result[Bytes] =
    let blobRes = ContentRuntimeRebuildBlob(manifest, params, responses)
    if IsErr(blobRes):
        return Err[Bytes](Error(blobRes))
    let blob = Value(blobRes)
    let summaryRes = dag.DagBlobSummaryFromBytes(blob, params.shardPayloadBytes)
    if IsErr(summaryRes):
        return Err[Bytes](Error(summaryRes))
    let summary = Value(summaryRes)
    if summary.payloadLen != stub.payloadLen:
        return Err[Bytes](" content runtime: rebuilt blob payload length mismatch")
    if !layout.fixedBytes32Equal(summary.summaryCid, stub.blobSummaryCid):
        return Err[Bytes](" content runtime: rebuilt blob summary cid mismatch")
    return Ok[Bytes](blob)
