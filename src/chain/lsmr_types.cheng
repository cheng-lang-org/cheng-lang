import std/result
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/binary_types as types
import std/strutils as strutil

const
    BaguaQian: int32 = 1
    BaguaDui: int32 = 2
    BaguaLi: int32 = 3
    BaguaZhen: int32 = 4
    BaguaXun: int32 = 5
    BaguaKan: int32 = 6
    BaguaGen: int32 = 7
    BaguaKun: int32 = 8
    BaguaCount: int32 = 8

    LayerGlobal: int32 = 1
    LayerRegional: int32 = 2
    LayerEdge: int32 = 3

    PubSubModeZhen: int32 = 1
    PubSubModeXun: int32 = 2
    PubSubModeGen: int32 = 3
    PubSubModeDui: int32 = 4
    PubSubModeLi: int32 = 5
    PubSubModeKun: int32 = 6

    BarrierModeAllow: int32 = 1
    BarrierModeDeny: int32 = 2

    RouteDeliveryKun: int32 = 1
    RouteDeliveryLi: int32 = 2
    RouteDeliveryDui: int32 = 3

    LsmrFixedBytes32Size: int32 = 32
    LsmrMaxDepth: int32 = 32
    BaguaRootSummaryMax: int32 = 24

type
    PrefixRef =
        baguaId: int32
        prefixDepth: int32
        prefixDigits: int32[LsmrMaxDepth]

    LocalityCid =
        keyId: int32
        baguaId: int32
        resolutionLevel: int32
        layerId: int32
        address: types.LsmrAddress
        prefix: PrefixRef
        localityHash: layout.FixedBytes32
        contentCid: layout.FixedBytes32
        cid: layout.FixedBytes32

    StateCell =
        keyId: int32
        baguaId: int32
        resolutionLevel: int32
        layerId: int32
        address: types.LsmrAddress
        prefix: PrefixRef
        contentCid: layout.FixedBytes32
        localityHash: layout.FixedBytes32
        localityCid: layout.FixedBytes32

    BaguaPrefixTree =
        entryCount: int32
        nodeCount: int32
        nodePrefixes: PrefixRef[]
        nodeChildStarts: int32[]
        nodeChildCounts: int32[]
        nodeEntryStarts: int32[]
        nodeEntryCounts: int32[]
        nodeEntryDescCounts: int32[]
        nodeCids: layout.FixedBytes32[]
        entryKeyIds: int32[]
        entryResolutionLevels: int32[]
        entryLayerIds: int32[]
        entryPrefixes: PrefixRef[]
        entryAddresses: types.LsmrAddress[]
        entryContentCids: layout.FixedBytes32[]
        entryLocalityHashes: layout.FixedBytes32[]
        entryLocalityCids: layout.FixedBytes32[]
        entryCids: layout.FixedBytes32[]
        treeCid: layout.FixedBytes32

    StateLayerForest =
        edgeTree: BaguaPrefixTree
        regionalTree: BaguaPrefixTree
        globalTree: BaguaPrefixTree
        forestCid: layout.FixedBytes32

    StateLayerSummary =
        layerId: int32
        treeCid: layout.FixedBytes32
        nodeCount: int32
        entryCount: int32

    BaguaRootSummary =
        layerId: int32
        baguaId: int32
        nodeCid: layout.FixedBytes32
        entryDescCount: int32

    StateSubtreeRef =
        layerId: int32
        prefix: PrefixRef
        nodeCid: layout.FixedBytes32
        entryDescCount: int32

    AntiEntropySignature =
        stampEpoch: int32
        stampGanzhi: int32
        eventCount: int32
        accountCount: int32
        stateForestCid: layout.FixedBytes32
        layerCount: int32
        layerSummaries: StateLayerSummary[3]
        rootCount: int32
        rootSummaries: BaguaRootSummary[BaguaRootSummaryMax]

    AntiEntropyPlan =
        requestCount: int32
        remoteNewer: bool
        conflictCount: int32
        requests: StateSubtreeRef[BaguaRootSummaryMax]

fn BaguaValid(baguaId: int32): bool =
    if baguaId < BaguaQian:
        return false
    if baguaId > BaguaKun:
        return false
    return true

fn LayerValid(layerId: int32): bool =
    if layerId == LayerGlobal:
        return true
    if layerId == LayerRegional:
        return true
    if layerId == LayerEdge:
        return true
    return false

fn PubSubModeValid(modeId: int32): bool =
    if modeId < PubSubModeZhen:
        return false
    if modeId > PubSubModeKun:
        return false
    return true

fn PrefixRefFromDigits(baguaId: int32, digits: int32[]): Result[PrefixRef] =
    if !BaguaValid(baguaId):
        return Err[PrefixRef](" lsmr_types: invalid bagua")
    if digits.len > LsmrMaxDepth:
        return Err[PrefixRef](" lsmr_types: prefix depth overflow")
    var out: PrefixRef
    out.baguaId = baguaId
    out.prefixDepth = digits.len
    for i in 0..<digits.len:
        if !types.LsmrDigitOk(digits[i]):
            return Err[PrefixRef](" lsmr_types: invalid prefix digit")
        out.prefixDigits[i] = digits[i]
    return Ok[PrefixRef](out)

fn PrefixRefContains(parent: PrefixRef, child: PrefixRef): bool =
    if parent.baguaId != child.baguaId:
        return false
    if parent.prefixDepth > child.prefixDepth:
        return false
    for i in 0..<parent.prefixDepth:
        if parent.prefixDigits[i] != child.prefixDigits[i]:
            return false
    return true

fn PrefixRefEqual(a: PrefixRef, b: PrefixRef): bool =
    if a.baguaId != b.baguaId:
        return false
    if a.prefixDepth != b.prefixDepth:
        return false
    for i in 0..<LsmrMaxDepth:
        if a.prefixDigits[i] != b.prefixDigits[i]:
            return false
    return true

fn PrefixRefText(prefix: PrefixRef): str =
    var out: str
    for i in 0..<prefix.prefixDepth:
        if i > 0:
            out = strutil.Join([out, "/"], "")
        out = strutil.Join([out, IntToStr(prefix.prefixDigits[i])], "")
    return out

fn FixedBytes32Less(a: layout.FixedBytes32, b: layout.FixedBytes32): bool =
    for i in 0..<LsmrFixedBytes32Size:
        if a.data[i] != b.data[i]:
            return a.data[i] < b.data[i]
    return false

fn AppendU32BE(buf: var layout.ByteBuf, value: int64) =
    layout.ByteBufAppendByte(buf, (value >> 24) & 255)
    layout.ByteBufAppendByte(buf, (value >> 16) & 255)
    layout.ByteBufAppendByte(buf, (value >> 8) & 255)
    layout.ByteBufAppendByte(buf, value & 255)

fn AppendFixed32(buf: var layout.ByteBuf, value: layout.FixedBytes32) =
    layout.ByteBufAppendBytes(buf, layout.FixedBytes32ToBytes(value))

fn AppendAddress(buf: var layout.ByteBuf, address: types.LsmrAddress) =
    AppendU32BE(buf, address.depth)
    for i in 0..<types.LsmrMaxDepth:
        layout.ByteBufAppendByte(buf, address.digits[i] & 255)

fn AppendPrefix(buf: var layout.ByteBuf, prefix: PrefixRef) =
    AppendU32BE(buf, prefix.baguaId)
    AppendU32BE(buf, prefix.prefixDepth)
    for i in 0..<types.LsmrMaxDepth:
        layout.ByteBufAppendByte(buf, prefix.prefixDigits[i] & 255)

fn OwnedBytesFromBuf(buf: layout.ByteBuf): Bytes =
    return layout.ByteBufToBytes(buf)

fn FixedCidFromBuf(buf: layout.ByteBuf): layout.FixedBytes32 =
    let data = OwnedBytesFromBuf(buf)
    return hash256.Sha256Fixed(layout.ByteSpanFromBytes(data))

fn HashInts(tag: str, values: int32[]): layout.FixedBytes32 =
    var buf: layout.ByteBuf
    buf = layout.ByteBufInit(64)
    var tagIndex: int32
    for tagIndex in tagIndex..<len(tag):
        layout.ByteBufAppendByte(buf, tag[tagIndex])
    AppendU32BE(buf, values.len)
    for i in 0..<values.len:
        AppendU32BE(buf, values[i])
    var out: layout.FixedBytes32
    out = FixedCidFromBuf(buf)
    return out

fn HashPrefix(tag: str, prefix: PrefixRef): layout.FixedBytes32 =
    var buf: layout.ByteBuf
    buf = layout.ByteBufInit(64)
    var tagIndex: int32
    for tagIndex in tagIndex..<len(tag):
        layout.ByteBufAppendByte(buf, tag[tagIndex])
    AppendPrefix(buf, prefix)
    var out: layout.FixedBytes32
    out = FixedCidFromBuf(buf)
    return out

fn StateLayerSummaryMake(layerId: int32,
                           treeCid: layout.FixedBytes32,
                           nodeCount: int32,
                           entryCount: int32): StateLayerSummary =
    return StateLayerSummary(
        layerId: layerId,
        treeCid: treeCid,
        nodeCount: nodeCount,
        entryCount: entryCount
    )

fn BaguaRootSummaryMake(layerId: int32,
                          baguaId: int32,
                          nodeCid: layout.FixedBytes32,
                          entryDescCount: int32): BaguaRootSummary =
    return BaguaRootSummary(
        layerId: layerId,
        baguaId: baguaId,
        nodeCid: nodeCid,
        entryDescCount: entryDescCount
    )

fn StateSubtreeRefMake(layerId: int32,
                         prefix: PrefixRef,
                         nodeCid: layout.FixedBytes32,
                         entryDescCount: int32): StateSubtreeRef =
    return StateSubtreeRef(
        layerId: layerId,
        prefix: prefix,
        nodeCid: nodeCid,
        entryDescCount: entryDescCount
    )

fn BaguaPrefixTreeZeroInto(out: var BaguaPrefixTree) =
    out.entryCount = 0
    out.nodeCount = 0
    out.nodePrefixes = []
    out.nodeChildStarts = []
    out.nodeChildCounts = []
    out.nodeEntryStarts = []
    out.nodeEntryCounts = []
    out.nodeEntryDescCounts = []
    out.nodeCids = []
    out.entryKeyIds = []
    out.entryResolutionLevels = []
    out.entryLayerIds = []
    out.entryPrefixes = []
    out.entryAddresses = []
    out.entryContentCids = []
    out.entryLocalityHashes = []
    out.entryLocalityCids = []
    out.entryCids = []
    out.treeCid = layout.FixedBytes32()

fn StateLayerForestZeroInto(out: var StateLayerForest) =
    BaguaPrefixTreeZeroInto(out.edgeTree)
    BaguaPrefixTreeZeroInto(out.regionalTree)
    BaguaPrefixTreeZeroInto(out.globalTree)
    out.forestCid = layout.FixedBytes32()

fn AntiEntropySignatureZeroInto(out: var AntiEntropySignature) =
    let zeroCid = layout.FixedBytes32()
    out.stampEpoch = 0
    out.stampGanzhi = 0
    out.eventCount = 0
    out.accountCount = 0
    out.stateForestCid = zeroCid
    out.layerCount = 0
    for i in 0..<3:
        out.layerSummaries[i].layerId = 0
        out.layerSummaries[i].treeCid = zeroCid
        out.layerSummaries[i].nodeCount = 0
        out.layerSummaries[i].entryCount = 0
    out.rootCount = 0
    for i in 0..<BaguaRootSummaryMax:
        out.rootSummaries[i].layerId = 0
        out.rootSummaries[i].baguaId = 0
        out.rootSummaries[i].nodeCid = zeroCid
        out.rootSummaries[i].entryDescCount = 0
