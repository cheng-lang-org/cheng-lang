import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as binary
import cheng/chain/pubsub
import cheng/chain/dag_mempool as dag
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content
import cheng/chain/content_fetch as fetch
import cheng/chain/content_runtime as runtime
import cheng/overlay/contracts as overlay
import cheng/overlay/libp2p_bridge as bridge
import cheng/libp2p/core/types as core
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/host/host as host_base
import cheng/libp2p/transports/tcp_transport

fn ContentRuntimePublishStub(hostState: var host_base.Libp2pHost,
                               artifacts: content.ContentPublishArtifacts): Result[content.ContentStub] =
    let artifactsOk = content.ContentPublishArtifactsValidate(artifacts)
    if IsErr(artifactsOk):
        return Err[content.ContentStub](Error(artifactsOk))
    let stubRes = content.ContentStubFromArtifacts(artifacts)
    if IsErr(stubRes):
        return Err[content.ContentStub](Error(stubRes))
    let stub = Value(stubRes)
    let scope = bridge.Libp2pScopeFromLayerId(artifacts.topic.layerId)
    let address = artifacts.topic.centerAddress
    let sourcePeerId = hostState.selfPeerId
    let stampEpoch = artifacts.publishAdvert.stampEpoch
    let stampGanzhi = artifacts.publishAdvert.stampGanzhi

    let manifestPayload = swarm.ErasureShardManifestEncode(artifacts.erasureManifest)
    let manifestPayloadOk = swarm.ErasureShardManifestValidatePayload(manifestPayload,
                                                                        artifacts.erasureManifest.manifestCid)
    if IsErr(manifestPayloadOk):
        return Err[content.ContentStub](Error(manifestPayloadOk))
    let recoveryPlanPayload = swarm.ErasureRecoveryPlanEncode(artifacts.recoveryPlan)
    let recoveryPlanPayloadOk = swarm.ErasureRecoveryPlanValidatePayload(recoveryPlanPayload,
                                                                           artifacts.recoveryPlan.planCid)
    if IsErr(recoveryPlanPayloadOk):
        return Err[content.ContentStub](Error(recoveryPlanPayloadOk))

    let stubIngress = bridge.Libp2pIngressMake(sourcePeerId,
                                                 scope,
                                                 address,
                                                 pubsub.PubSubPayloadKindContentStub,
                                                 stub.stubCid,
                                                 content.ContentStubEncode(stub),
                                                 stampEpoch,
                                                 stampGanzhi)
    let advertIngress = bridge.Libp2pIngressMake(sourcePeerId,
                                                   scope,
                                                   address,
                                                   pubsub.PubSubPayloadKindDagAdvert,
                                                   artifacts.publishAdvert.advertCid,
                                                   dag.DagPublishAdvertEncode(artifacts.publishAdvert),
                                                   stampEpoch,
                                                   stampGanzhi)
    let manifestIngress = bridge.Libp2pIngressMake(sourcePeerId,
                                                     scope,
                                                     address,
                                                     pubsub.PubSubPayloadKindErasureManifest,
                                                     artifacts.erasureManifest.manifestCid,
                                                     manifestPayload,
                                                     stampEpoch,
                                                     stampGanzhi)
    let recoveryPlanIngress = bridge.Libp2pIngressMake(sourcePeerId,
                                                         scope,
                                                         address,
                                                         pubsub.PubSubPayloadKindErasureRecoveryPlan,
                                                         artifacts.recoveryPlan.planCid,
                                                         recoveryPlanPayload,
                                                         stampEpoch,
                                                         stampGanzhi)

    bridge.Libp2pRelayPublish(hostState, stubIngress)
    host_base.Libp2pStorePut(hostState, advertIngress)
    host_base.Libp2pStorePut(hostState, manifestIngress)
    host_base.Libp2pStorePut(hostState, recoveryPlanIngress)
    host_base.Libp2pKadProvide(hostState, artifacts.bundleCid)
    host_base.Libp2pKadProvide(hostState, artifacts.blobSummary.blobCid)
    host_base.Libp2pKadProvide(hostState, artifacts.erasureManifest.manifestCid)
    return Ok[content.ContentStub](stub)

fn ContentRuntimeSelectSyncRequest(localHost: var host_base.Libp2pHost,
                                     remoteHost: var host_base.Libp2pHost,
                                     remotePeerId: core.Libp2pPeerId,
                                     query: overlay.StoreQuery,
                                     out: var overlay.IngressEnvelope[]): Result[bool] =
    var endpoint: ps.Libp2pPeerEndpoint
    let endpointRes = host_base.Libp2pSelectPeerEndpoint(localHost, remotePeerId, endpoint)
    if IsErr(endpointRes):
        return Err[bool](Error(endpointRes))
    let remoteAddr = endpoint.addr
    if remoteAddr.transport == core.Libp2pTransportQuic:
        return Err[bool](" content runtime host: quic sync requires content_runtime_host_quic")
    return host_base.Libp2pSyncRequest(localHost, remoteHost, remotePeerId, query, out)

fn ContentRuntimeFindIngress(entries: overlay.IngressEnvelope[],
                               payloadCid: layout.FixedBytes32,
                               payloadKind: int32): Result[overlay.IngressEnvelope] =
    for i in 0..<entries.len:
        let ingress = entries[i]
        if !layout.fixedBytes32Equal(ingress.payloadCid, payloadCid):
            continue
        if ingress.payloadKind != payloadKind:
            continue
        return Ok[overlay.IngressEnvelope](ingress)
    return Err[overlay.IngressEnvelope](" content runtime host: ingress missing")

fn ContentRuntimeFetchAdvert(localHost: var host_base.Libp2pHost,
                               remoteHost: var host_base.Libp2pHost,
                               remotePeerId: core.Libp2pPeerId,
                               scope: overlay.OverlayTopicScope,
                               address: binary.LsmrAddress,
                               stub: content.ContentStub): Result[dag.DagPublishAdvert] =
    var query = overlay.StoreQuery()
    query.topicScope = scope
    query.address = address
    query.wantEventCid = stub.advertCid
    var entries: overlay.IngressEnvelope[]
    let entriesRes = ContentRuntimeSelectSyncRequest(localHost, remoteHost, remotePeerId, query, entries)
    if IsErr(entriesRes):
        return Err[dag.DagPublishAdvert](Error(entriesRes))
    let ingressRes = ContentRuntimeFindIngress(entries,
                                                 stub.advertCid,
                                                 pubsub.PubSubPayloadKindDagAdvert)
    if IsErr(ingressRes):
        return Err[dag.DagPublishAdvert](Error(ingressRes))
    let ingress = Value(ingressRes)
    let payloadOk = dag.DagPublishAdvertValidatePayload(ingress.payload, stub.advertCid)
    if IsErr(payloadOk):
        return Err[dag.DagPublishAdvert](Error(payloadOk))
    return dag.DagPublishAdvertDecode(ingress.payload)

fn ContentRuntimeFetchManifest(localHost: var host_base.Libp2pHost,
                                 remoteHost: var host_base.Libp2pHost,
                                 remotePeerId: core.Libp2pPeerId,
                                 scope: overlay.OverlayTopicScope,
                                 address: binary.LsmrAddress,
                                 stub: content.ContentStub): Result[swarm.ErasureShardManifest] =
    var query = overlay.StoreQuery()
    query.topicScope = scope
    query.address = address
    query.wantEventCid = stub.manifestCid
    var entries: overlay.IngressEnvelope[]
    let entriesRes = ContentRuntimeSelectSyncRequest(localHost, remoteHost, remotePeerId, query, entries)
    if IsErr(entriesRes):
        return Err[swarm.ErasureShardManifest](Error(entriesRes))
    let ingressRes = ContentRuntimeFindIngress(entries,
                                                 stub.manifestCid,
                                                 pubsub.PubSubPayloadKindErasureManifest)
    if IsErr(ingressRes):
        return Err[swarm.ErasureShardManifest](Error(ingressRes))
    let ingress = Value(ingressRes)
    let payloadOk = swarm.ErasureShardManifestValidatePayload(ingress.payload, stub.manifestCid)
    if IsErr(payloadOk):
        return Err[swarm.ErasureShardManifest](Error(payloadOk))
    return swarm.ErasureShardManifestDecode(ingress.payload)

fn ContentRuntimeRequestManifestFill(out: var swarm.ErasureShardManifest,
                                       localHost: var host_base.Libp2pHost,
                                       remoteHost: var host_base.Libp2pHost,
                                       remotePeerId: core.Libp2pPeerId,
                                       remoteRuntime: var runtime.ContentRuntime,
                                       stub: content.ContentStub): Result[bool] =
    let requestRes = fetch.ContentFetchRequestManifest(stub.manifestCid)
    if IsErr(requestRes):
        return Err[bool](Error(requestRes))
    let request = Value(requestRes)
    let responseRes = ContentRuntimeRequestFetch(localHost,
                                                   remoteHost,
                                                   remotePeerId,
                                                   remoteRuntime,
                                                   request)
    if IsErr(responseRes):
        return Err[bool](Error(responseRes))
    let response = Value(responseRes)
    let fillRes = fetch.ContentFetchResponseToManifestFill(out, request, response)
    if IsErr(fillRes):
        return Err[bool](Error(fillRes))
    return Ok[bool](true)

fn ContentRuntimeFetchRecoveryPlan(localHost: var host_base.Libp2pHost,
                                     remoteHost: var host_base.Libp2pHost,
                                     remotePeerId: core.Libp2pPeerId,
                                     scope: overlay.OverlayTopicScope,
                                     address: binary.LsmrAddress,
                                     stub: content.ContentStub): Result[swarm.ErasureRecoveryPlan] =
    var query = overlay.StoreQuery()
    query.topicScope = scope
    query.address = address
    query.wantEventCid = stub.recoveryPlanCid
    var entries: overlay.IngressEnvelope[]
    let entriesRes = ContentRuntimeSelectSyncRequest(localHost, remoteHost, remotePeerId, query, entries)
    if IsErr(entriesRes):
        return Err[swarm.ErasureRecoveryPlan](Error(entriesRes))
    let ingressRes = ContentRuntimeFindIngress(entries,
                                                 stub.recoveryPlanCid,
                                                 pubsub.PubSubPayloadKindErasureRecoveryPlan)
    if IsErr(ingressRes):
        return Err[swarm.ErasureRecoveryPlan](Error(ingressRes))
    let ingress = Value(ingressRes)
    let payloadOk = swarm.ErasureRecoveryPlanValidatePayload(ingress.payload, stub.recoveryPlanCid)
    if IsErr(payloadOk):
        return Err[swarm.ErasureRecoveryPlan](Error(payloadOk))
    return swarm.ErasureRecoveryPlanDecode(ingress.payload)

fn ContentRuntimeRequestShardPull(localHost: var host_base.Libp2pHost,
                                    remoteHost: var host_base.Libp2pHost,
                                    remotePeerId: core.Libp2pPeerId,
                                    remoteRuntime: var runtime.ContentRuntime,
                                    request: swarm.ErasureShardPullRequest): Result[swarm.ErasureShardPullResponse] =
    let fetchRequestRes = fetch.ContentFetchRequestFromShardPull(request)
    if IsErr(fetchRequestRes):
        return Err[swarm.ErasureShardPullResponse](Error(fetchRequestRes))
    let fetchRequest = Value(fetchRequestRes)
    let fetchResponseRes = ContentRuntimeRequestFetch(localHost,
                                                        remoteHost,
                                                        remotePeerId,
                                                        remoteRuntime,
                                                        fetchRequest)
    if IsErr(fetchResponseRes):
        return Err[swarm.ErasureShardPullResponse](Error(fetchResponseRes))
    let fetchResponse = Value(fetchResponseRes)
    var response = swarm.ErasureShardPullResponse()
    let responseFillRes = fetch.ContentFetchResponseToShardPullFill(response,
                                                                      fetchRequest,
                                                                      fetchResponse)
    if IsErr(responseFillRes):
        return Err[swarm.ErasureShardPullResponse](Error(responseFillRes))
    return Ok[swarm.ErasureShardPullResponse](response)

fn ContentRuntimeDecodeFetchPayload(payload: Bytes,
                                      request: fetch.ContentFetchRequest): Result[fetch.ContentFetchResponse] =
    let responseRes = fetch.ContentFetchResponseDecode(payload)
    if IsErr(responseRes):
        return Err[fetch.ContentFetchResponse](Error(responseRes))
    let response = Value(responseRes)
    let responseOk = fetch.ContentFetchResponseValidate(response, request)
    if IsErr(responseOk):
        return Err[fetch.ContentFetchResponse](Error(responseOk))
    return Ok[fetch.ContentFetchResponse](response)

fn ContentRuntimeRequestFetchTcp(requestPayload: Bytes,
                                   servePayload: Bytes,
                                   request: fetch.ContentFetchRequest): Result[fetch.ContentFetchResponse] =
    let responsePayloadRes = tcp_transport.Libp2pTcpLoopbackRequestResponse(core.Libp2pProtocolContent,
                                                                              requestPayload,
                                                                              servePayload)
    if IsErr(responsePayloadRes):
        return Err[fetch.ContentFetchResponse](Error(responsePayloadRes))
    var responsePayload: Bytes
    responsePayload = Value(responsePayloadRes)
    return ContentRuntimeDecodeFetchPayload(responsePayload, request)

fn ContentRuntimeRequestFetch(localHost: var host_base.Libp2pHost,
                                remoteHost: var host_base.Libp2pHost,
                                remotePeerId: core.Libp2pPeerId,
                                remoteRuntime: var runtime.ContentRuntime,
                                request: fetch.ContentFetchRequest): Result[fetch.ContentFetchResponse] =
    if !core.Libp2pPeerIdEqual(remoteHost.selfPeerId, remotePeerId):
        return Err[fetch.ContentFetchResponse](" content runtime host: content peer mismatch")
    if !host_base.Libp2pProtocolRegistered(remoteHost, core.Libp2pProtocolContent):
        return Err[fetch.ContentFetchResponse](" content runtime host: remote content handler missing")
    let streamRes = host_base.Libp2pOpenStream(localHost, remotePeerId, core.Libp2pProtocolContent)
    if IsErr(streamRes):
        return Err[fetch.ContentFetchResponse](Error(streamRes))
    let requestPayload = fetch.ContentFetchRequestEncode(request)
    var endpoint: ps.Libp2pPeerEndpoint
    let endpointRes = host_base.Libp2pSelectPeerEndpoint(localHost, remotePeerId, endpoint)
    if IsErr(endpointRes):
        return Err[fetch.ContentFetchResponse](Error(endpointRes))
    let remoteAddr = endpoint.addr
    let servePayloadRes = runtime.ContentRuntimeServeFetchPayload(remoteRuntime, requestPayload)
    if IsErr(servePayloadRes):
        return Err[fetch.ContentFetchResponse](Error(servePayloadRes))
    var servePayload: Bytes
    servePayload = Value(servePayloadRes)
    if remoteAddr.transport == core.Libp2pTransportQuic:
        return Err[fetch.ContentFetchResponse](" content runtime host: quic content requires content_runtime_host_quic")
    if remoteAddr.transport == core.Libp2pTransportWebrtc:
        return Err[fetch.ContentFetchResponse](" content runtime host: webrtc content requires content_runtime_host_webrtc")
    return ContentRuntimeRequestFetchTcp(requestPayload, servePayload, request)
