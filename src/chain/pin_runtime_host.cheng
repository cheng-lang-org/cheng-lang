import std/result
import cheng/std/bytes_layout as layout
import cheng/chain/binary_types as binary
import cheng/chain/pubsub
import cheng/chain/pin_plane as pin
import cheng/chain/pin_runtime as runtime
import cheng/chain/erasure_swarm as swarm
import cheng/overlay/contracts as overlay
import cheng/overlay/libp2p_bridge as bridge
import cheng/libp2p/core/types as core
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/host/host as host_base

fn PinRuntimeSelectSyncRequest(localHost: var host_base.Libp2pHost,
                                 remoteHost: var host_base.Libp2pHost,
                                 remotePeerId: core.Libp2pPeerId,
                                 query: overlay.StoreQuery,
                                 out: var overlay.IngressEnvelope[]): Result[bool] =
    var endpoint: ps.Libp2pPeerEndpoint
    let endpointRes = host_base.Libp2pSelectPeerEndpoint(localHost, remotePeerId, endpoint)
    if IsErr(endpointRes):
        return Err[bool](Error(endpointRes))
    if endpoint.addr.transport == core.Libp2pTransportQuic:
        return Err[bool](" pin runtime host: quic sync requires pin_runtime_host_quic")
    return host_base.Libp2pSyncRequest(localHost, remoteHost, remotePeerId, query, out)

fn PinRuntimeFindIngress(entries: overlay.IngressEnvelope[],
                           payloadCid: layout.FixedBytes32,
                           payloadKind: int32): Result[overlay.IngressEnvelope] =
    for i in 0..<entries.len:
        let ingress = entries[i]
        if !layout.fixedBytes32Equal(ingress.payloadCid, payloadCid):
            continue
        if ingress.payloadKind != payloadKind:
            continue
        return Ok[overlay.IngressEnvelope](ingress)
    return Err[overlay.IngressEnvelope](" pin runtime host: ingress missing")

fn PinRuntimePublishOffer(hostState: var host_base.Libp2pHost,
                            scope: overlay.OverlayTopicScope,
                            address: binary.LsmrAddress,
                            offer: pin.PinOffer,
                            stampEpoch: int32,
                            stampGanzhi: int32): Result[bool] =
    let payload = pin.PinOfferEncode(offer)
    let payloadOk = pin.PinOfferValidatePayload(payload, offer.offerCid)
    if IsErr(payloadOk):
        return Err[bool](Error(payloadOk))
    let ingress = bridge.Libp2pIngressMake(hostState.selfPeerId,
                                             scope,
                                             address,
                                             pubsub.PubSubPayloadKindPinOffer,
                                             offer.offerCid,
                                             payload,
                                             stampEpoch,
                                             stampGanzhi)
    bridge.Libp2pRelayPublish(hostState, ingress)
    host_base.Libp2pKadProvide(hostState, offer.offerCid)
    return Ok[bool](true)

fn PinRuntimePublishAccept(hostState: var host_base.Libp2pHost,
                             scope: overlay.OverlayTopicScope,
                             address: binary.LsmrAddress,
                             accept: pin.PinAccept,
                             stampEpoch: int32,
                             stampGanzhi: int32): Result[bool] =
    let payload = pin.PinAcceptEncode(accept)
    let payloadOk = pin.PinAcceptValidatePayload(payload, accept.acceptCid)
    if IsErr(payloadOk):
        return Err[bool](Error(payloadOk))
    let ingress = bridge.Libp2pIngressMake(hostState.selfPeerId,
                                             scope,
                                             address,
                                             pubsub.PubSubPayloadKindPinAccept,
                                             accept.acceptCid,
                                             payload,
                                             stampEpoch,
                                             stampGanzhi)
    bridge.Libp2pRelayPublish(hostState, ingress)
    host_base.Libp2pKadProvide(hostState, accept.acceptCid)
    return Ok[bool](true)

fn PinRuntimePublishSettlement(hostState: var host_base.Libp2pHost,
                                 scope: overlay.OverlayTopicScope,
                                 address: binary.LsmrAddress,
                                 settlement: pin.PinSettlement,
                                 stampEpoch: int32,
                                 stampGanzhi: int32): Result[bool] =
    let payload = pin.PinSettlementEncode(settlement)
    let payloadOk = pin.PinSettlementValidatePayload(payload, settlement.settlementCid)
    if IsErr(payloadOk):
        return Err[bool](Error(payloadOk))
    let ingress = bridge.Libp2pIngressMake(hostState.selfPeerId,
                                             scope,
                                             address,
                                             pubsub.PubSubPayloadKindPinSettlement,
                                             settlement.settlementCid,
                                             payload,
                                             stampEpoch,
                                             stampGanzhi)
    bridge.Libp2pRelayPublish(hostState, ingress)
    host_base.Libp2pKadProvide(hostState, settlement.settlementCid)
    return Ok[bool](true)

fn PinRuntimeFetchOffer(localHost: var host_base.Libp2pHost,
                          remoteHost: var host_base.Libp2pHost,
                          remotePeerId: core.Libp2pPeerId,
                          scope: overlay.OverlayTopicScope,
                          address: binary.LsmrAddress,
                          offerCid: layout.FixedBytes32): Result[pin.PinOffer] =
    var query = overlay.StoreQuery()
    query.topicScope = scope
    query.address = address
    query.wantEventCid = offerCid
    var entries: overlay.IngressEnvelope[]
    let entriesRes = PinRuntimeSelectSyncRequest(localHost, remoteHost, remotePeerId, query, entries)
    if IsErr(entriesRes):
        return Err[pin.PinOffer](Error(entriesRes))
    let ingressRes = PinRuntimeFindIngress(entries, offerCid, pubsub.PubSubPayloadKindPinOffer)
    if IsErr(ingressRes):
        return Err[pin.PinOffer](Error(ingressRes))
    let ingress = Value(ingressRes)
    let payloadOk = pin.PinOfferValidatePayload(ingress.payload, offerCid)
    if IsErr(payloadOk):
        return Err[pin.PinOffer](Error(payloadOk))
    return pin.PinOfferDecode(ingress.payload)

fn PinRuntimeFetchAccept(localHost: var host_base.Libp2pHost,
                           remoteHost: var host_base.Libp2pHost,
                           remotePeerId: core.Libp2pPeerId,
                           scope: overlay.OverlayTopicScope,
                           address: binary.LsmrAddress,
                           acceptCid: layout.FixedBytes32): Result[pin.PinAccept] =
    var query = overlay.StoreQuery()
    query.topicScope = scope
    query.address = address
    query.wantEventCid = acceptCid
    var entries: overlay.IngressEnvelope[]
    let entriesRes = PinRuntimeSelectSyncRequest(localHost, remoteHost, remotePeerId, query, entries)
    if IsErr(entriesRes):
        return Err[pin.PinAccept](Error(entriesRes))
    let ingressRes = PinRuntimeFindIngress(entries, acceptCid, pubsub.PubSubPayloadKindPinAccept)
    if IsErr(ingressRes):
        return Err[pin.PinAccept](Error(ingressRes))
    let ingress = Value(ingressRes)
    let payloadOk = pin.PinAcceptValidatePayload(ingress.payload, acceptCid)
    if IsErr(payloadOk):
        return Err[pin.PinAccept](Error(payloadOk))
    return pin.PinAcceptDecode(ingress.payload)

fn PinRuntimeFetchSettlement(localHost: var host_base.Libp2pHost,
                               remoteHost: var host_base.Libp2pHost,
                               remotePeerId: core.Libp2pPeerId,
                               scope: overlay.OverlayTopicScope,
                               address: binary.LsmrAddress,
                               settlementCid: layout.FixedBytes32): Result[pin.PinSettlement] =
    var query = overlay.StoreQuery()
    query.topicScope = scope
    query.address = address
    query.wantEventCid = settlementCid
    var entries: overlay.IngressEnvelope[]
    let entriesRes = PinRuntimeSelectSyncRequest(localHost, remoteHost, remotePeerId, query, entries)
    if IsErr(entriesRes):
        return Err[pin.PinSettlement](Error(entriesRes))
    let ingressRes = PinRuntimeFindIngress(entries,
                                             settlementCid,
                                             pubsub.PubSubPayloadKindPinSettlement)
    if IsErr(ingressRes):
        return Err[pin.PinSettlement](Error(ingressRes))
    let ingress = Value(ingressRes)
    let payloadOk = pin.PinSettlementValidatePayload(ingress.payload, settlementCid)
    if IsErr(payloadOk):
        return Err[pin.PinSettlement](Error(payloadOk))
    return pin.PinSettlementDecode(ingress.payload)

fn PinRuntimeRequestProof(localHost: var host_base.Libp2pHost,
                            remoteHost: var host_base.Libp2pHost,
                            remotePeerId: core.Libp2pPeerId,
                            challenge: pin.PinChallenge,
                            offer: pin.PinOffer,
                            accept: pin.PinAccept,
                            manifest: swarm.ErasureShardManifest): Result[pin.PinProof] =
    let challengeOk = pin.PinChallengeValidateAgainstInputs(challenge,
                                                              offer,
                                                              accept,
                                                              manifest)
    if IsErr(challengeOk):
        return Err[pin.PinProof](Error(challengeOk))
    let requestPayload = pin.PinChallengeEncode(challenge)
    let wireChallengeRes = pin.PinChallengeDecode(requestPayload)
    if IsErr(wireChallengeRes):
        return Err[pin.PinProof](Error(wireChallengeRes))
    let wireChallenge = Value(wireChallengeRes)
    let wirePayloadOk = pin.PinChallengeValidatePayload(requestPayload, wireChallenge.challengeCid)
    if IsErr(wirePayloadOk):
        return Err[pin.PinProof](Error(wirePayloadOk))
    let wireChallengeOk = pin.PinChallengeValidateAgainstInputs(wireChallenge,
                                                                  offer,
                                                                  accept,
                                                                  manifest)
    if IsErr(wireChallengeOk):
        return Err[pin.PinProof](Error(wireChallengeOk))
    var proofPayload: Bytes
    let proofPayloadRes = host_base.Libp2pRequestResponse(localHost,
                                                            remoteHost,
                                                            remotePeerId,
                                                            core.Libp2pProtocolPin,
                                                            requestPayload,
                                                            proofPayload)
    if IsErr(proofPayloadRes):
        return Err[pin.PinProof](Error(proofPayloadRes))
    let proofRes = pin.PinProofDecode(proofPayload)
    if IsErr(proofRes):
        return Err[pin.PinProof](Error(proofRes))
    let proof = Value(proofRes)
    let payloadOk = pin.PinProofValidatePayload(proofPayload, proof.proofCid)
    if IsErr(payloadOk):
        return Err[pin.PinProof](Error(payloadOk))
    let proofOk = pin.PinProofValidateAgainstInputs(proof, wireChallenge, accept, manifest)
    if IsErr(proofOk):
        return Err[pin.PinProof](Error(proofOk))
    return Ok[pin.PinProof](proof)

fn PinRuntimeOpenScheduledChallenge(localHost: var host_base.Libp2pHost,
                                      acceptCid: layout.FixedBytes32,
                                      nowEpoch: int32,
                                      challengeOut: var pin.PinChallenge,
                                      offerOut: var pin.PinOffer,
                                      acceptOut: var pin.PinAccept,
                                      manifestOut: var swarm.ErasureShardManifest): Result[bool] =
    if !localHost.pinRuntimeAttached:
        return Err[bool](" pin runtime host: local pin runtime missing")
    let challengeRes = runtime.PinRuntimeOpenChallenge(localHost.pinRuntime, acceptCid, nowEpoch)
    if IsErr(challengeRes):
        return Err[bool](Error(challengeRes))
    let challenge = Value(challengeRes)
    let offerRes = runtime.PinRuntimeFindOffer(localHost.pinRuntime, challenge.offerCid)
    if IsErr(offerRes):
        return Err[bool](Error(offerRes))
    let offer = Value(offerRes)
    let acceptRes = runtime.PinRuntimeFindAccept(localHost.pinRuntime, acceptCid)
    if IsErr(acceptRes):
        return Err[bool](Error(acceptRes))
    let accept = Value(acceptRes)
    let manifestRes = runtime.PinRuntimeFindManifest(localHost.pinRuntime, challenge.manifestCid)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    let manifest = Value(manifestRes)
    challengeOut = challenge
    offerOut = offer
    acceptOut = accept
    manifestOut = manifest
    return Ok[bool](true)

fn PinRuntimeRunScheduledFailure(localHost: var host_base.Libp2pHost,
                                   acceptCid: layout.FixedBytes32,
                                   scope: overlay.OverlayTopicScope,
                                   address: binary.LsmrAddress,
                                   nowEpoch: int32,
                                   stampEpoch: int32,
                                   stampGanzhi: int32,
                                   out: var runtime.PinRuntimeStepResult): Result[bool] =
    if !localHost.pinRuntimeAttached:
        return Err[bool](" pin runtime host: local pin runtime missing")
    let stepRes = runtime.PinRuntimeNoteChallengeFailure(localHost.pinRuntime, acceptCid, nowEpoch)
    if IsErr(stepRes):
        return Err[bool](Error(stepRes))
    let step = Value(stepRes)
    if step.outcomeKind == runtime.PinRuntimeStepKindSlash:
        let settlementRes = runtime.PinRuntimeFindSettlement(localHost.pinRuntime, step.settlementCid)
        if IsErr(settlementRes):
            return Err[bool](Error(settlementRes))
        let publishRes = PinRuntimePublishSettlement(localHost,
                                                       scope,
                                                       address,
                                                       Value(settlementRes),
                                                       stampEpoch,
                                                       stampGanzhi)
        if IsErr(publishRes):
            return Err[bool](Error(publishRes))
    out = step
    return Ok[bool](true)

fn PinRuntimeRunScheduledSuccess(localHost: var host_base.Libp2pHost,
                                   acceptCid: layout.FixedBytes32,
                                   proof: pin.PinProof,
                                   scope: overlay.OverlayTopicScope,
                                   address: binary.LsmrAddress,
                                   nowEpoch: int32,
                                   stampEpoch: int32,
                                   stampGanzhi: int32,
                                   out: var runtime.PinRuntimeStepResult): Result[bool] =
    if !localHost.pinRuntimeAttached:
        return Err[bool](" pin runtime host: local pin runtime missing")
    let stepRes = runtime.PinRuntimeCompleteChallenge(localHost.pinRuntime,
                                                        acceptCid,
                                                        proof,
                                                        nowEpoch)
    if IsErr(stepRes):
        return Err[bool](Error(stepRes))
    let step = Value(stepRes)
    let settlementRes = runtime.PinRuntimeFindSettlement(localHost.pinRuntime, step.settlementCid)
    if IsErr(settlementRes):
        return Err[bool](Error(settlementRes))
    let publishRes = PinRuntimePublishSettlement(localHost,
                                                   scope,
                                                   address,
                                                   Value(settlementRes),
                                                   stampEpoch,
                                                   stampGanzhi)
    if IsErr(publishRes):
        return Err[bool](Error(publishRes))
    out = step
    return Ok[bool](true)
