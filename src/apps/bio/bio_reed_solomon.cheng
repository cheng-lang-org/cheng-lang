import std/result
import std/rawbytes
import std/crypto/gf256
import cheng/std/bytes_layout as layout

const
    BioRsMessageBytes: int32 = 16
    BioRsCodeBytes: int32 = 32
    BioRsParityBytes: int32 = BioRsCodeBytes - BioRsMessageBytes
    BioRsMaxCorrectable: int32 = BioRsParityBytes / 2
    BioRsQCoeffCount: int32 = BioRsMessageBytes + BioRsMaxCorrectable
    BioRsUnknownCount: int32 = BioRsQCoeffCount + BioRsMaxCorrectable

type
    BioMessage16 =
        data: uint8[16]

    BioGf256Matrix32 =
        data: uint8[1024]

fn BioGf256Matrix32Clear(matrix: var BioGf256Matrix32) =
    for idx in range(1024):
        matrix.data[idx] = uint8(0)

fn BioMessage16FromBytes(data: Bytes): Result[BioMessage16] =
    if BytesLen(data) != BioRsMessageBytes:
        return Err[BioMessage16](" bio rs: need 16 bytes")
    var out: BioMessage16
    for i in 0..<BioRsMessageBytes:
        out.data[i] = uint8(BytesGet(data, i))
    return Ok[BioMessage16](out)

fn BioMessage16ToBytes(value: BioMessage16): Bytes =
    let out: Bytes = BytesAlloc(BioRsMessageBytes)
    for i in 0..<BioRsMessageBytes:
        BytesSet(out, i, int32(value.data[i]) & 255)
    return out

fn BioGf256PolyDegree(coeffs: layout.FixedBytes32, coeffCount: int32): int32 =
    if coeffCount <= 0:
        return -1
    let iStart2 = coeffCount - 1
    if iStart2 >= 0:
        for iOffset2 in 0..iStart2:
            let i = iStart2 - iOffset2
            if (int32(coeffs.data[i]) & 255) != 0:
                return i
    return -1

fn BioMessage16PolyEval(coeffs: BioMessage16, x: int32): int32 =
    var acc: int32
    let iStart = BioRsMessageBytes - 1
    if iStart >= 0:
        for iOffset in 0..iStart:
            let i = iStart - iOffset
            acc = gf256.Gf256Mul(acc, x)
            acc = gf256.Gf256Add(acc, int32(coeffs.data[i]) & 255)
    return acc & 255

fn BioGf256SwapFixed32(values: var layout.FixedBytes32, left: int32, right: int32) =
    if left == right:
        return
    let temp = values.data[left]
    values.data[left] = values.data[right]
    values.data[right] = temp

fn BioGf256MatrixOffset(row: int32, col: int32): int32 =
    return row * 32 + col

fn BioGf256MatrixGet(matrix: BioGf256Matrix32, row: int32, col: int32): int32 =
    return int32(matrix.data[BioGf256MatrixOffset(row, col)]) & 255

fn BioGf256MatrixSet(matrix: var BioGf256Matrix32, row: int32, col: int32, value: int32) =
    matrix.data[BioGf256MatrixOffset(row, col)] = uint8(value & 255)

fn BioGf256SwapRows(matrix: var BioGf256Matrix32, left: int32, right: int32) =
    if left == right:
        return
    for col in range(32):
        let temp = BioGf256MatrixGet(matrix, left, col)
        BioGf256MatrixSet(matrix, left, col, BioGf256MatrixGet(matrix, right, col))
        BioGf256MatrixSet(matrix, right, col, temp)

fn BioGf256SolveLinear(rows: BioGf256Matrix32,
                         rhs: layout.FixedBytes32,
                         size: int32): Result[layout.FixedBytes32] =
    if size <= 0 || size > 32:
        return Err[layout.FixedBytes32](" bio rs: invalid linear size")
    var rowsWork: BioGf256Matrix32
    for copyIdx in range(1024):
        rowsWork.data[copyIdx] = rows.data[copyIdx]
    var rhsWork: layout.FixedBytes32 = rhs
    var pivotRow: int32
    var col: int32
    for col in range(size):

        var pivot: int32 = -1
        row = pivotRow
        for row in row..<size:
            if BioGf256MatrixGet(rowsWork, row, col) != 0:
                pivot = row
                break
        row = size
        while pivot < 0 && row < 32:
            if BioGf256MatrixGet(rowsWork, row, col) != 0:
                pivot = row
                break
            row = row + 1
        if pivot < 0:
            return Err[layout.FixedBytes32](" bio rs: singular linear system")
        if pivot != pivotRow:
            BioGf256SwapRows(rowsWork, pivot, pivotRow)
            BioGf256SwapFixed32(rhsWork, pivot, pivotRow)
        let pivotInvRes = gf256.Gf256Inv(BioGf256MatrixGet(rowsWork, pivotRow, col))
        if IsErr(pivotInvRes):
            return Err[layout.FixedBytes32](Error(pivotInvRes))
        let pivotInv = Value(pivotInvRes)
        var j: int32 = col
        for j in j..<size:
            let scaled = gf256.Gf256Mul(BioGf256MatrixGet(rowsWork, pivotRow, j), pivotInv)
            BioGf256MatrixSet(rowsWork, pivotRow, j, scaled)
        rhsWork.data[pivotRow] = uint8(gf256.Gf256Mul(int32(rhsWork.data[pivotRow]) & 255, pivotInv))
        row = 0
        for row in range(size):

            if row == pivotRow:
                row = row + 1
                continue
            let factor = BioGf256MatrixGet(rowsWork, row, col)
            if factor == 0:
                row = row + 1
                continue
            j = col
            for j in j..<size:
                let pivotValue = BioGf256MatrixGet(rowsWork, pivotRow, j)
                let rowValue = BioGf256MatrixGet(rowsWork, row, j)
                let reduced = gf256.Gf256Add(rowValue, gf256.Gf256Mul(factor, pivotValue))
                BioGf256MatrixSet(rowsWork, row, j, reduced)
            let rhsReduced = gf256.Gf256Add(int32(rhsWork.data[row]) & 255,
                                            gf256.Gf256Mul(factor, int32(rhsWork.data[pivotRow]) & 255))
            rhsWork.data[row] = uint8(rhsReduced)
            row = row + 1
        row = size
        for row in range(32):

            let factor = BioGf256MatrixGet(rowsWork, row, col)
            if factor != 0:
                j = col
                for j in j..<size:
                    let pivotValue = BioGf256MatrixGet(rowsWork, pivotRow, j)
                    let rowValue = BioGf256MatrixGet(rowsWork, row, j)
                    let reduced = gf256.Gf256Add(rowValue, gf256.Gf256Mul(factor, pivotValue))
                    BioGf256MatrixSet(rowsWork, row, j, reduced)
                let rhsReduced = gf256.Gf256Add(int32(rhsWork.data[row]) & 255,
                                                gf256.Gf256Mul(factor, int32(rhsWork.data[pivotRow]) & 255))
                rhsWork.data[row] = uint8(rhsReduced)

        if BioGf256MatrixGet(rowsWork, pivotRow, col) != 1:
            return Err[layout.FixedBytes32](" bio rs: pivot normalization failed")
        pivotRow = pivotRow + 1

    row = pivotRow
    for row in row..<32:
        if (int32(rhsWork.data[row]) & 255) != 0:
            return Err[layout.FixedBytes32](" bio rs: inconsistent linear system")
    return Ok[layout.FixedBytes32](rhsWork)

fn BioGf256PolyDivideMonic(dividend: layout.FixedBytes32,
                             dividendLen: int32,
                             divisor: layout.FixedBytes32,
                             divisorLen: int32,
                             outQuotient: var BioMessage16,
                             outRemainder: var layout.FixedBytes32): Result[bool] =
    let divisorDegree = BioGf256PolyDegree(divisor, divisorLen)
    if divisorDegree < 0:
        return Err[bool](" bio rs: divide by zero polynomial")
    if (int32(divisor.data[divisorDegree]) & 255) != 1:
        return Err[bool](" bio rs: divisor must be monic")
    outQuotient = BioMessage16()
    outRemainder = dividend
    var remDegree = BioGf256PolyDegree(outRemainder, dividendLen)
    while remDegree >= divisorDegree:
        let shift = remDegree - divisorDegree
        if shift < 0 || shift >= BioRsMessageBytes:
            return Err[bool](" bio rs: quotient overflow")
        let scale = int32(outRemainder.data[remDegree]) & 255
        outQuotient.data[shift] = uint8(scale)
        for i in 0..divisorDegree:
            let pos = shift + i
            let rowValue = int32(outRemainder.data[pos]) & 255
            let divValue = int32(divisor.data[i]) & 255
            outRemainder.data[pos] = uint8(rowValue ^ gf256.Gf256Mul(scale, divValue))
        remDegree = BioGf256PolyDegree(outRemainder, dividendLen)
    return Ok[bool](true)

fn BioGf256CountMismatchedBytes(left: layout.FixedBytes32, right: layout.FixedBytes32): int32 =
    var mismatches: int32
    for i in 0..<BioRsCodeBytes:
        if left.data[i] != right.data[i]:
            mismatches = mismatches + 1
    return mismatches

fn BioRsEncode16x32(message: BioMessage16): layout.FixedBytes32 =
    var out: layout.FixedBytes32
    for i in 0..<BioRsCodeBytes:
        out.data[i] = uint8(BioMessage16PolyEval(message, i + 1))
    return out

fn BioRsBuildBerlekampWelchSystem(received: layout.FixedBytes32,
                                    errorCount: int32,
                                    outRows: var BioGf256Matrix32,
                                    outRhs: var layout.FixedBytes32,
                                    outSize: var int32) =
    BioGf256Matrix32Clear(outRows)
    outRhs = layout.FixedBytes32()
    if errorCount < 0 || errorCount > 8:
        outSize = 0
        return
    let qCount = 16 + errorCount
    let unknownCount = qCount + errorCount
    outSize = unknownCount
    var row: int32
    while row < 32:
        let x = row + 1
        let y = int32(received.data[row]) & 255
        var xPow: int32 = 1
        var j: int32
        for j in j..<qCount:
            BioGf256MatrixSet(outRows, row, j, xPow)
            xPow = gf256.Gf256Mul(xPow, x)
        xPow = 1
        j = 0
        for j in j..<errorCount:
            BioGf256MatrixSet(outRows, row, qCount + j, gf256.Gf256Mul(y, xPow))
            xPow = gf256.Gf256Mul(xPow, x)
        outRhs.data[row] = uint8(gf256.Gf256Mul(y, xPow))


fn BioRsTryDecode32x16(received: layout.FixedBytes32, errorCount: int32): Result[BioMessage16] =
    var rows: BioGf256Matrix32
    var rhs: layout.FixedBytes32
    var size: int32
    BioRsBuildBerlekampWelchSystem(received, errorCount, rows, rhs, size)
    if size <= 0:
        return Err[BioMessage16](" bio rs: invalid error count")
    let solveRes = BioGf256SolveLinear(rows, rhs, size)
    if IsErr(solveRes):
        return Err[BioMessage16](Error(solveRes))
    let solution = Value(solveRes)
    let qCount = 16 + errorCount
    var qCoeffs: layout.FixedBytes32
    var i: int32
    for i in i..<qCount:
        qCoeffs.data[i] = solution.data[i]
    var eCoeffs: layout.FixedBytes32
    i = 0
    for i in i..<errorCount:
        eCoeffs.data[i] = solution.data[qCount + i]
    eCoeffs.data[errorCount] = uint8(1)
    var quotient: BioMessage16
    var remainder: layout.FixedBytes32
    let divRes = BioGf256PolyDivideMonic(qCoeffs,
                                           qCount,
                                           eCoeffs,
                                           errorCount + 1,
                                           quotient,
                                           remainder)
    if IsErr(divRes):
        return Err[BioMessage16](Error(divRes))
    if BioGf256PolyDegree(remainder, qCount) >= 0:
        return Err[BioMessage16](" bio rs: polynomial division remainder")
    let decodedCodeword = BioRsEncode16x32(quotient)
    let mismatches = BioGf256CountMismatchedBytes(decodedCodeword, received)
    if mismatches > errorCount:
        return Err[BioMessage16](" bio rs: too many symbol errors")
    return Ok[BioMessage16](quotient)

fn BioRsDecode32x16(received: layout.FixedBytes32): Result[BioMessage16] =
    var errorCount: int32
    for errorCount in errorCount..<= 8:
        let decodeRes = BioRsTryDecode32x16(received, errorCount)
        if IsOk(decodeRes):
            return Ok[BioMessage16](Value(decodeRes))
    return Err[BioMessage16](" bio rs: decode failed")
