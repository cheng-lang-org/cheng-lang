import std/result
import std/rawbytes
import std/crypto/rand
import std/crypto/ecnist
import std/crypto/p256_fixed as pfix
import cheng/std/bytes_layout as layout
import cheng/std/crypto/fixed256
import cheng/chain/lsmr_types as lt
import cheng/apps/bio/bio_reed_solomon as rs

const
    BioVersion: int32 = 1
    BioCodeN: int32 = 32
    BioCodeK: int32 = 16
    BioMaxCorrectable: int32 = 8
    BioScalarRetryLimit: int32 = 256

type
    BioEnrollmentRecord =
        version: int32
        helper: layout.FixedBytes32
        pubKey: layout.FixedBytes65
        codeN: int32
        codeK: int32
        maxCorrectable: int32
        recordCid: layout.FixedBytes32

    BioSchnorrProof =
        commitA: layout.FixedBytes65
        responseZ: layout.FixedBytes32

    BioAssertion =
        recordCid: layout.FixedBytes32
        challengeNonce: layout.FixedBytes32
        commitA: layout.FixedBytes65
        responseZ: layout.FixedBytes32
        proofCid: layout.FixedBytes32

fn BioXorFixed32(left: layout.FixedBytes32, right: layout.FixedBytes32): layout.FixedBytes32 =
    var out: layout.FixedBytes32
    var i: int32
    while i < 32:
        out.data[i] = uint8((int32(left.data[i]) ^ int32(right.data[i])) & 255)
        i = i + 1
    return out

fn BioRandomMessage16(): Result[rs.BioMessage16] =
    var rawRes: Result[Bytes]
    rawRes = rand.randomBytes(16)
    if IsErr(rawRes):
        return Err[rs.BioMessage16](Error(rawRes))
    return rs.BioMessage16FromBytes(Value(rawRes))

fn BioRootSecretFromCodeword(codeword: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(128)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.bio.root"))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(codeword))
    return lt.FixedCidFromBuf(buf)

fn BioEnsureP256(): Result[bool] =
    return ecnist.p256EnsureInit()

fn BioScalarModulus(): pfix.P256Fixed =
    return pfix.P256ScalarModulus()

fn BioScalarFixedFromFixed32(value: layout.FixedBytes32): pfix.P256Fixed =
    var out: pfix.P256Fixed
    for limb in 0..<8:
        let offset: int32 = 28 - (limb * 4)
        let b0: uint64 = uint64(int32(value.data[offset]) & 255)
        let b1: uint64 = uint64(int32(value.data[offset + 1]) & 255)
        let b2: uint64 = uint64(int32(value.data[offset + 2]) & 255)
        let b3: uint64 = uint64(int32(value.data[offset + 3]) & 255)
        let word: uint64 = (b0 << uint64(24)) | (b1 << uint64(16)) | (b2 << uint64(8)) | b3
        out.limbs[limb] = int32(uint32(word))
    return out

fn BioScalarFixedToFixed32(value: pfix.P256Fixed): layout.FixedBytes32 =
    var out: layout.FixedBytes32
    for limb in 0..<8:
        let offset: int32 = 28 - (limb * 4)
        let word: uint64 = pfix.P256FixedWordToBitsU64(value.limbs[limb])
        out.data[offset] = uint8(int32((word >> uint64(24)) & uint64(255)))
        out.data[offset + 1] = uint8(int32((word >> uint64(16)) & uint64(255)))
        out.data[offset + 2] = uint8(int32((word >> uint64(8)) & uint64(255)))
        out.data[offset + 3] = uint8(int32(word & uint64(255)))
    return out

fn BioScalarFixedFromScalar(value: fixed256.Scalar256): pfix.P256Fixed =
    return BioScalarFixedFromFixed32(value.bytes)

fn BioScalarFromFixed(value: pfix.P256Fixed): fixed256.Scalar256 =
    return fixed256.Scalar256(bytes: BioScalarFixedToFixed32(value))

fn BioScalarModMul(left: fixed256.Scalar256,
                     right: fixed256.Scalar256): Result[fixed256.Scalar256] =
    var leftFixed: pfix.P256Fixed = BioScalarFixedFromScalar(left)
    var rightFixed: pfix.P256Fixed = BioScalarFixedFromScalar(right)
    var ctx: pfix.P256FixedMontgomeryContext
    pfix.P256ScalarMontgomeryContextInto(ctx)
    let mulRes = pfix.P256FixedModMulWithContext(leftFixed, rightFixed, ctx)
    if IsErr(mulRes):
        return Err[fixed256.Scalar256](Error(mulRes))
    return Ok[fixed256.Scalar256](BioScalarFromFixed(Value(mulRes)))

fn BioScalarModAdd(left: fixed256.Scalar256,
                     right: fixed256.Scalar256): Result[fixed256.Scalar256] =
    var leftFixed: pfix.P256Fixed = BioScalarFixedFromScalar(left)
    var rightFixed: pfix.P256Fixed = BioScalarFixedFromScalar(right)
    var modulus: pfix.P256Fixed = BioScalarModulus()
    let addRes = pfix.P256FixedModAdd(leftFixed, rightFixed, modulus)
    if IsErr(addRes):
        return Err[fixed256.Scalar256](Error(addRes))
    return Ok[fixed256.Scalar256](BioScalarFromFixed(Value(addRes)))

fn BioHashBufToScalar(buf: layout.ByteBuf): Result[fixed256.Scalar256] =
    let initRes = BioEnsureP256()
    if IsErr(initRes):
        return Err[fixed256.Scalar256](Error(initRes))
    for counter in 0..<BioScalarRetryLimit:
        var attempt: layout.ByteBuf = layout.byteBufInit(layout.byteBufLen(buf) + 8)
        layout.byteBufAppendBytes(attempt, layout.byteBufToBytes(buf))
        lt.AppendU32BE(attempt, counter)
        let digest = lt.FixedCidFromBuf(attempt)
        var reduced: pfix.P256Fixed = BioScalarFixedFromFixed32(digest)
        var modulus: pfix.P256Fixed = BioScalarModulus()
        if pfix.P256FixedCmp(reduced, modulus) >= 0:
            reduced = pfix.P256FixedModSubTrusted(reduced, modulus, modulus)
        if pfix.P256FixedIsZero(reduced):
            continue
        return Ok[fixed256.Scalar256](BioScalarFromFixed(reduced))
    return Err[fixed256.Scalar256](" bio: hash-to-scalar exhausted")

fn BioScalarFromRootSecret(rootSecret: layout.FixedBytes32): Result[fixed256.Scalar256] =
    var buf: layout.ByteBuf = layout.byteBufInit(96)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.bio.scalar"))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(rootSecret))
    return BioHashBufToScalar(buf)

fn BioNonceScalar(secret: fixed256.Scalar256,
                    challengeNonce: layout.FixedBytes32): Result[fixed256.Scalar256] =
    var buf: layout.ByteBuf = layout.byteBufInit(160)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.bio.nonce"))
    layout.byteBufAppendBytes(buf, fixed256.scalar256ToBytes(secret))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(challengeNonce))
    return BioHashBufToScalar(buf)

fn BioChallengeScalar(recordCid: layout.FixedBytes32,
                        challengeNonce: layout.FixedBytes32,
                        commitA: layout.FixedBytes65,
                        pubKey: layout.FixedBytes65): Result[fixed256.Scalar256] =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.bio.schnorr"))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(recordCid))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(challengeNonce))
    layout.byteBufAppendBytes(buf, layout.fixedBytes65ToBytes(commitA))
    layout.byteBufAppendBytes(buf, layout.fixedBytes65ToBytes(pubKey))
    return BioHashBufToScalar(buf)

fn BioScalarBytesValid(value: layout.FixedBytes32): bool =
    return ecnist.validateEcdsaPrivateKeyBytes(layout.fixedBytes32ToBytes(value))

fn BioScalarFromFixed32(value: layout.FixedBytes32): Result[fixed256.Scalar256] =
    if !BioScalarBytesValid(value):
        return Err[fixed256.Scalar256](" bio: invalid scalar bytes")
    return fixed256.scalar256FromBytes(layout.fixedBytes32ToBytes(value))

fn BioPublicKeyFromScalar(value: fixed256.Scalar256): Result[layout.FixedBytes65] =
    return fixed256.p256PublicKey65FromPrivateScalar(value)

fn BioRecordCid(record: BioEnrollmentRecord): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.bio.record"))
    lt.AppendU32BE(buf, record.version)
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(record.helper))
    layout.byteBufAppendBytes(buf, layout.fixedBytes65ToBytes(record.pubKey))
    lt.AppendU32BE(buf, record.codeN)
    lt.AppendU32BE(buf, record.codeK)
    lt.AppendU32BE(buf, record.maxCorrectable)
    return lt.FixedCidFromBuf(buf)

fn BioAssertionCid(recordCid: layout.FixedBytes32,
                     challengeNonce: layout.FixedBytes32,
                     commitA: layout.FixedBytes65,
                     responseZ: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.byteBufInit(256)
    layout.byteBufAppendBytes(buf, bytesFromString("cheng.bio.assertion"))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(recordCid))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(challengeNonce))
    layout.byteBufAppendBytes(buf, layout.fixedBytes65ToBytes(commitA))
    layout.byteBufAppendBytes(buf, layout.fixedBytes32ToBytes(responseZ))
    return lt.FixedCidFromBuf(buf)

fn BioValidateRecord(record: BioEnrollmentRecord): Result[bool] =
    if record.version != BioVersion:
        return Err[bool](" bio: unsupported record version")
    if record.codeN != BioCodeN:
        return Err[bool](" bio: unsupported record parameters")
    if record.codeK != BioCodeK:
        return Err[bool](" bio: unsupported record parameters")
    if record.maxCorrectable != BioMaxCorrectable:
        return Err[bool](" bio: unsupported record parameters")
    if !fixed256.p256PublicKey65Valid(record.pubKey):
        return Err[bool](" bio: invalid enrollment public key")
    let wantCid = BioRecordCid(record)
    if !layout.fixedBytes32Equal(wantCid, record.recordCid):
        return Err[bool](" bio: record cid mismatch")
    return Ok[bool](true)

fn BioRecoverCodeword(feature32: layout.FixedBytes32,
                        helper: layout.FixedBytes32): Result[layout.FixedBytes32] =
    let masked = BioXorFixed32(feature32, helper)
    let messageRes = rs.BioRsDecode32x16(masked)
    if IsErr(messageRes):
        return Err[layout.FixedBytes32](Error(messageRes))
    return Ok[layout.FixedBytes32](rs.BioRsEncode16x32(Value(messageRes)))

fn BioRecoverRoot(feature32: layout.FixedBytes32,
                    helper: layout.FixedBytes32): Result[layout.FixedBytes32] =
    let codewordRes = BioRecoverCodeword(feature32, helper)
    if IsErr(codewordRes):
        return Err[layout.FixedBytes32](Error(codewordRes))
    return Ok[layout.FixedBytes32](BioRootSecretFromCodeword(Value(codewordRes)))

fn BioPointFixedFromPublicKey(pubKey: layout.FixedBytes65): Result[ecnist.EcPointFixed] =
    var point: ecnist.EcPointFixed
    let parseRes = ecnist.ecdsaParsePublicKeyPointFixedBytes(layout.fixedBytes65ToBytes(pubKey), true, point)
    if IsErr(parseRes):
        return Err[ecnist.EcPointFixed](Error(parseRes))
    return Ok[ecnist.EcPointFixed](point)

fn BioFixed65FromPoint(point: ecnist.EcPointFixed): Result[layout.FixedBytes65] =
    return layout.fixedBytes65FromBytes(ecnist.ecdsaPublicPointFixedToBytes(point))

fn BioPointMulFixed(scalar: pfix.P256Fixed,
                      point: ecnist.EcPointFixed): Result[ecnist.EcPointFixed] =
    let initRes = BioEnsureP256()
    if IsErr(initRes):
        return Err[ecnist.EcPointFixed](Error(initRes))
    if point.inf:
        return Ok[ecnist.EcPointFixed](point)
    var workScalar: pfix.P256Fixed = scalar
    var result: ecnist.EcPointJacobianFixed = ecnist.pointJacobianInfinityFixed()
    var bit: int32 = 255
    while bit >= 0:
        ecnist.pointJacobianDoubleFixedInPlace(result)
        if pfix.P256FixedGetBit(workScalar, bit) != 0:
            ecnist.pointJacobianAddAffineFixedInPlace(result, point)
        bit = bit - 1
    return ecnist.pointJacobianToAffineFixed(result)

fn BioSchnorrProve(secret: fixed256.Scalar256,
                     recordCid: layout.FixedBytes32,
                     challengeNonce: layout.FixedBytes32): Result[BioSchnorrProof] =
    let initRes = BioEnsureP256()
    if IsErr(initRes):
        return Err[BioSchnorrProof](Error(initRes))
    let pubKeyRes = BioPublicKeyFromScalar(secret)
    if IsErr(pubKeyRes):
        return Err[BioSchnorrProof](Error(pubKeyRes))
    let pubKey = Value(pubKeyRes)
    let nonceScalarRes = BioNonceScalar(secret, challengeNonce)
    if IsErr(nonceScalarRes):
        return Err[BioSchnorrProof](Error(nonceScalarRes))
    let nonceScalar = Value(nonceScalarRes)
    let commitARes = BioPublicKeyFromScalar(nonceScalar)
    if IsErr(commitARes):
        return Err[BioSchnorrProof](Error(commitARes))
    let commitA = Value(commitARes)
    let challengeScalarRes = BioChallengeScalar(recordCid, challengeNonce, commitA, pubKey)
    if IsErr(challengeScalarRes):
        return Err[BioSchnorrProof](Error(challengeScalarRes))
    let challengeScalar = Value(challengeScalarRes)
    let exRes = BioScalarModMul(challengeScalar, secret)
    if IsErr(exRes):
        return Err[BioSchnorrProof](Error(exRes))
    let zRes = BioScalarModAdd(nonceScalar, Value(exRes))
    if IsErr(zRes):
        return Err[BioSchnorrProof](Error(zRes))
    var out = BioSchnorrProof()
    out.commitA = commitA
    out.responseZ = Value(zRes).bytes
    return Ok[BioSchnorrProof](out)

fn BioSchnorrVerify(pubKey: layout.FixedBytes65,
                      recordCid: layout.FixedBytes32,
                      challengeNonce: layout.FixedBytes32,
                      proof: BioSchnorrProof): Result[bool] =
    if !fixed256.p256PublicKey65Valid(pubKey):
        return Err[bool](" bio: invalid verification public key")
    if !fixed256.p256PublicKey65Valid(proof.commitA):
        return Err[bool](" bio: invalid commitment point")
    let zScalarRes = BioScalarFromFixed32(proof.responseZ)
    if IsErr(zScalarRes):
        return Err[bool](Error(zScalarRes))
    let challengeScalarRes = BioChallengeScalar(recordCid, challengeNonce, proof.commitA, pubKey)
    if IsErr(challengeScalarRes):
        return Err[bool](Error(challengeScalarRes))
    let zFixed: pfix.P256Fixed = BioScalarFixedFromScalar(Value(zScalarRes))
    let zPointRes = ecnist.pointMulGeneratorWnafFixed(zFixed)
    if IsErr(zPointRes):
        return Err[bool](Error(zPointRes))
    let pubPointRes = BioPointFixedFromPublicKey(pubKey)
    if IsErr(pubPointRes):
        return Err[bool](Error(pubPointRes))
    let commitPointRes = BioPointFixedFromPublicKey(proof.commitA)
    if IsErr(commitPointRes):
        return Err[bool](Error(commitPointRes))
    let challengeFixed: pfix.P256Fixed = BioScalarFixedFromScalar(Value(challengeScalarRes))
    let mulRes = BioPointMulFixed(challengeFixed, Value(pubPointRes))
    if IsErr(mulRes):
        return Err[bool](Error(mulRes))
    var rhsJac = ecnist.pointJacobianFromAffineFixed(Value(commitPointRes))
    rhsJac = ecnist.pointJacobianAddAffineFixed(rhsJac, Value(mulRes))
    let rhsPointRes = ecnist.pointJacobianToAffineFixed(rhsJac)
    if IsErr(rhsPointRes):
        return Err[bool](Error(rhsPointRes))
    let zPubKeyRes = BioFixed65FromPoint(Value(zPointRes))
    if IsErr(zPubKeyRes):
        return Err[bool](Error(zPubKeyRes))
    let rhsPubKeyRes = BioFixed65FromPoint(Value(rhsPointRes))
    if IsErr(rhsPubKeyRes):
        return Err[bool](Error(rhsPubKeyRes))
    return Ok[bool](layout.fixedBytes65Equal(Value(zPubKeyRes), Value(rhsPubKeyRes)))

fn BioEnroll(feature32: layout.FixedBytes32): Result[BioEnrollmentRecord] =
    let messageRes = BioRandomMessage16()
    if IsErr(messageRes):
        return Err[BioEnrollmentRecord](Error(messageRes))
    let codeword = rs.BioRsEncode16x32(Value(messageRes))
    let rootSecret = BioRootSecretFromCodeword(codeword)
    let scalarRes = BioScalarFromRootSecret(rootSecret)
    if IsErr(scalarRes):
        return Err[BioEnrollmentRecord](Error(scalarRes))
    let pubKeyRes = BioPublicKeyFromScalar(Value(scalarRes))
    if IsErr(pubKeyRes):
        return Err[BioEnrollmentRecord](Error(pubKeyRes))
    var out = BioEnrollmentRecord()
    out.version = BioVersion
    out.helper = BioXorFixed32(feature32, codeword)
    out.pubKey = Value(pubKeyRes)
    out.codeN = BioCodeN
    out.codeK = BioCodeK
    out.maxCorrectable = BioMaxCorrectable
    out.recordCid = BioRecordCid(out)
    return Ok[BioEnrollmentRecord](out)

fn BioProve(feature32: layout.FixedBytes32,
              record: BioEnrollmentRecord,
              challengeNonce: layout.FixedBytes32): Result[BioAssertion] =
    let recordOk = BioValidateRecord(record)
    if IsErr(recordOk):
        return Err[BioAssertion](Error(recordOk))
    let rootRes = BioRecoverRoot(feature32, record.helper)
    if IsErr(rootRes):
        return Err[BioAssertion](Error(rootRes))
    let scalarRes = BioScalarFromRootSecret(Value(rootRes))
    if IsErr(scalarRes):
        return Err[BioAssertion](Error(scalarRes))
    let pubKeyRes = BioPublicKeyFromScalar(Value(scalarRes))
    if IsErr(pubKeyRes):
        return Err[BioAssertion](Error(pubKeyRes))
    if !layout.fixedBytes65Equal(Value(pubKeyRes), record.pubKey):
        return Err[BioAssertion](" bio: recovered root does not match record")
    let proofRes = BioSchnorrProve(Value(scalarRes), record.recordCid, challengeNonce)
    if IsErr(proofRes):
        return Err[BioAssertion](Error(proofRes))
    let proof = Value(proofRes)
    var out = BioAssertion()
    out.recordCid = record.recordCid
    out.challengeNonce = challengeNonce
    out.commitA = proof.commitA
    out.responseZ = proof.responseZ
    out.proofCid = BioAssertionCid(out.recordCid, out.challengeNonce, out.commitA, out.responseZ)
    return Ok[BioAssertion](out)

fn BioVerify(record: BioEnrollmentRecord,
               challengeNonce: layout.FixedBytes32,
               assertion: BioAssertion): Result[bool] =
    let recordOk = BioValidateRecord(record)
    if IsErr(recordOk):
        return Err[bool](Error(recordOk))
    if !layout.fixedBytes32Equal(assertion.recordCid, record.recordCid):
        return Err[bool](" bio: assertion record cid mismatch")
    if !layout.fixedBytes32Equal(assertion.challengeNonce, challengeNonce):
        return Err[bool](" bio: assertion challenge mismatch")
    let wantProofCid = BioAssertionCid(assertion.recordCid,
                                         assertion.challengeNonce,
                                         assertion.commitA,
                                         assertion.responseZ)
    if !layout.fixedBytes32Equal(wantProofCid, assertion.proofCid):
        return Err[bool](" bio: assertion proof cid mismatch")
    var proof = BioSchnorrProof()
    proof.commitA = assertion.commitA
    proof.responseZ = assertion.responseZ
    return BioSchnorrVerify(record.pubKey, record.recordCid, challengeNonce, proof)
