import std/result
import std/strings as strings
import cheng/mobile/hardware/biometric
import cheng/apps/chain_node/chain_node as chain
import cheng/apps/bio/bio_did_chain_node as flow

type
    V3BioDidMobileFingerprintRequest =
        requestId: str
        didText: str
        deviceBindingSeedHint: str
        deviceLabelHint: str
        promptTitle: str
        promptReason: str

fn v3BioDidMobileFingerprintRequestValidate(request: V3BioDidMobileFingerprintRequest,
                                            importing: bool): Result[bool] =
    let requestId = request.requestId
    let requestIdLen = strings.Len(requestId)
    if requestIdLen <= 0:
        return Err[bool]("v3 bio did mobile: request id required")
    let didText = request.didText
    let didTextLen = strings.Len(didText)
    if importing && didTextLen <= 0:
        return Err[bool]("v3 bio did mobile: did required for import")
    let deviceBindingSeedHint = request.deviceBindingSeedHint
    let deviceBindingSeedHintLen = strings.Len(deviceBindingSeedHint)
    if deviceBindingSeedHintLen <= 0:
        return Err[bool]("v3 bio did mobile: device binding seed required")
    let deviceLabelHint = request.deviceLabelHint
    let deviceLabelHintLen = strings.Len(deviceLabelHint)
    if deviceLabelHintLen <= 0:
        return Err[bool]("v3 bio did mobile: device label required")
    let promptTitle = request.promptTitle
    let promptTitleLen = strings.Len(promptTitle)
    if promptTitleLen <= 0:
        return Err[bool]("v3 bio did mobile: prompt title required")
    let promptReason = request.promptReason
    let promptReasonLen = strings.Len(promptReason)
    if promptReasonLen <= 0:
        return Err[bool]("v3 bio did mobile: prompt reason required")
    return Ok[bool](true)

fn v3BioDidMobileFingerprintAuthorizeReq(request: V3BioDidMobileFingerprintRequest,
                                         importing: bool):
                                         biometric.V3BiometricFingerprintAuthorizeReq =
    var out = biometric.V3BiometricFingerprintAuthorizeReq()
    out.requestId = request.requestId
    if importing:
        out.purpose = biometric.v3BiometricPurposeDidImport
    else:
        out.purpose = biometric.v3BiometricPurposeDidCreate
    out.didText = request.didText
    out.promptTitle = request.promptTitle
    out.promptReason = request.promptReason
    out.deviceBindingSeedHint = request.deviceBindingSeedHint
    out.deviceLabelHint = request.deviceLabelHint
    return out

fn v3BioDidMobileHardwareCaptureFromResp(request: V3BioDidMobileFingerprintRequest,
                                         resp: biometric.V3BiometricFingerprintAuthorizeResp):
                                         Result[flow.V3BioDidHardwareCapture] =
    if resp.deviceBindingSeed != request.deviceBindingSeedHint:
        return Err[flow.V3BioDidHardwareCapture](
            "v3 bio did mobile: host device binding seed mismatch"
        )
    if resp.deviceLabel != request.deviceLabelHint:
        return Err[flow.V3BioDidHardwareCapture]("v3 bio did mobile: host device label mismatch")
    var capture = flow.V3BioDidHardwareCapture()
    capture.verified = true
    capture.feature32 = resp.feature32
    capture.requestId = request.requestId
    capture.sensorId = resp.sensorId
    capture.deviceBindingSeed = resp.deviceBindingSeed
    capture.deviceLabel = resp.deviceLabel
    capture.hardwareAttestation = resp.hardwareAttestation
    return Ok[flow.V3BioDidHardwareCapture](capture)

fn v3BioDidMobileCreateWithFingerprint(node: var chain.V3ChainNode,
                                       request: V3BioDidMobileFingerprintRequest,
                                       epochSeconds: int64): Result[flow.V3BioDidProvisionResult] =
    let reqOk = v3BioDidMobileFingerprintRequestValidate(request, false)
    if IsErr(reqOk):
        return Err[flow.V3BioDidProvisionResult](Error(reqOk))
    let authReq = v3BioDidMobileFingerprintAuthorizeReq(request, false)
    var authResp = biometric.V3BiometricFingerprintAuthorizeResp()
    let authOk = biometric.v3BiometricFingerprintAuthorizeBlockingFillV3(authResp,
                                                                         request.requestId,
                                                                         authReq)
    if IsErr(authOk):
        return Err[flow.V3BioDidProvisionResult](Error(authOk))
    let captureRes = v3BioDidMobileHardwareCaptureFromResp(request, authResp)
    if IsErr(captureRes):
        return Err[flow.V3BioDidProvisionResult](Error(captureRes))
    return flow.v3BioDidCreateWithHardwareCapture(node, Value(captureRes), epochSeconds)

fn v3BioDidMobileImportWithFingerprint(node: var chain.V3ChainNode,
                                       request: V3BioDidMobileFingerprintRequest,
                                       epochSeconds: int64): Result[flow.V3BioDidProvisionResult] =
    let reqOk = v3BioDidMobileFingerprintRequestValidate(request, true)
    if IsErr(reqOk):
        return Err[flow.V3BioDidProvisionResult](Error(reqOk))
    let authReq = v3BioDidMobileFingerprintAuthorizeReq(request, true)
    var authResp = biometric.V3BiometricFingerprintAuthorizeResp()
    let authOk = biometric.v3BiometricFingerprintAuthorizeBlockingFillV3(authResp,
                                                                         request.requestId,
                                                                         authReq)
    if IsErr(authOk):
        return Err[flow.V3BioDidProvisionResult](Error(authOk))
    let captureRes = v3BioDidMobileHardwareCaptureFromResp(request, authResp)
    if IsErr(captureRes):
        return Err[flow.V3BioDidProvisionResult](Error(captureRes))
    return flow.v3BioDidImportWithHardwareCapture(node,
                                                  request.didText,
                                                  Value(captureRes),
                                                  epochSeconds)
