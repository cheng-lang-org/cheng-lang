import std/result
import std/strings as strings
import cheng/mobile/hardware/biometric
import cheng/apps/chain_node/chain_node as chain
import cheng/apps/bio/bio_did_chain_node as flow

type
    BioDidMobileFingerprintRequest =
        requestId: str
        didText: str
        deviceBindingSeedHint: str
        deviceLabelHint: str
        promptTitle: str
        promptReason: str

fn BioDidMobileFingerprintRequestValidate(request: BioDidMobileFingerprintRequest,
                                            importing: bool): Result[bool] =
    let requestId = request.requestId
    let requestIdLen = strings.Len(requestId)
    if requestIdLen <= 0:
        return Err[bool](" bio did mobile: request id required")
    let didText = request.didText
    let didTextLen = strings.Len(didText)
    if importing && didTextLen <= 0:
        return Err[bool](" bio did mobile: did required for import")
    let deviceBindingSeedHint = request.deviceBindingSeedHint
    let deviceBindingSeedHintLen = strings.Len(deviceBindingSeedHint)
    if deviceBindingSeedHintLen <= 0:
        return Err[bool](" bio did mobile: device binding seed required")
    let deviceLabelHint = request.deviceLabelHint
    let deviceLabelHintLen = strings.Len(deviceLabelHint)
    if deviceLabelHintLen <= 0:
        return Err[bool](" bio did mobile: device label required")
    let promptTitle = request.promptTitle
    let promptTitleLen = strings.Len(promptTitle)
    if promptTitleLen <= 0:
        return Err[bool](" bio did mobile: prompt title required")
    let promptReason = request.promptReason
    let promptReasonLen = strings.Len(promptReason)
    if promptReasonLen <= 0:
        return Err[bool](" bio did mobile: prompt reason required")
    return Ok[bool](true)

fn BioDidMobileFingerprintAuthorizeReq(request: BioDidMobileFingerprintRequest,
                                         importing: bool): biometric.BiometricFingerprintAuthorizeReq =
    var out = biometric.BiometricFingerprintAuthorizeReq()
    out.requestId = request.requestId
    if importing:
        out.purpose = biometric.BiometricPurposeDidImport
    else:
        out.purpose = biometric.BiometricPurposeDidCreate
    out.didText = request.didText
    out.promptTitle = request.promptTitle
    out.promptReason = request.promptReason
    out.deviceBindingSeedHint = request.deviceBindingSeedHint
    out.deviceLabelHint = request.deviceLabelHint
    return out

fn BioDidMobileHardwareCaptureFromResp(request: BioDidMobileFingerprintRequest,
                                         resp: biometric.BiometricFingerprintAuthorizeResp): Result[flow.BioDidHardwareCapture] =
    if resp.deviceBindingSeed != request.deviceBindingSeedHint:
        return Err[flow.BioDidHardwareCapture](
            " bio did mobile: host device binding seed mismatch"
        )
    if resp.deviceLabel != request.deviceLabelHint:
        return Err[flow.BioDidHardwareCapture](" bio did mobile: host device label mismatch")
    var capture = flow.BioDidHardwareCapture()
    capture.verified = true
    capture.feature32 = resp.feature32
    capture.requestId = request.requestId
    capture.sensorId = resp.sensorId
    capture.deviceBindingSeed = resp.deviceBindingSeed
    capture.deviceLabel = resp.deviceLabel
    capture.hardwareAttestation = resp.hardwareAttestation
    return Ok[flow.BioDidHardwareCapture](capture)

fn BioDidMobileCreateWithFingerprint(node: var chain.ChainNode,
                                       request: BioDidMobileFingerprintRequest,
                                       epochSeconds: int64): Result[flow.BioDidProvisionResult] =
    let reqOk = BioDidMobileFingerprintRequestValidate(request, false)
    if IsErr(reqOk):
        return Err[flow.BioDidProvisionResult](Error(reqOk))
    let authReq = BioDidMobileFingerprintAuthorizeReq(request, false)
    var authResp = biometric.BiometricFingerprintAuthorizeResp()
    let authOk = biometric.BiometricFingerprintAuthorizeBlockingFill(authResp,
                                                                         request.requestId,
                                                                         authReq)
    if IsErr(authOk):
        return Err[flow.BioDidProvisionResult](Error(authOk))
    let captureRes = BioDidMobileHardwareCaptureFromResp(request, authResp)
    if IsErr(captureRes):
        return Err[flow.BioDidProvisionResult](Error(captureRes))
    return flow.BioDidCreateWithHardwareCapture(node, Value(captureRes), epochSeconds)

fn BioDidMobileImportWithFingerprint(node: var chain.ChainNode,
                                       request: BioDidMobileFingerprintRequest,
                                       epochSeconds: int64): Result[flow.BioDidProvisionResult] =
    let reqOk = BioDidMobileFingerprintRequestValidate(request, true)
    if IsErr(reqOk):
        return Err[flow.BioDidProvisionResult](Error(reqOk))
    let authReq = BioDidMobileFingerprintAuthorizeReq(request, true)
    var authResp = biometric.BiometricFingerprintAuthorizeResp()
    let authOk = biometric.BiometricFingerprintAuthorizeBlockingFill(authResp,
                                                                         request.requestId,
                                                                         authReq)
    if IsErr(authOk):
        return Err[flow.BioDidProvisionResult](Error(authOk))
    let captureRes = BioDidMobileHardwareCaptureFromResp(request, authResp)
    if IsErr(captureRes):
        return Err[flow.BioDidProvisionResult](Error(captureRes))
    return flow.BioDidImportWithHardwareCapture(node,
                                                  request.didText,
                                                  Value(captureRes),
                                                  epochSeconds)
