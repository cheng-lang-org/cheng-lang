const
    v3BioDidChainAssetId: int32 = 930001
    v3BioDidOperatorAnchorAssetId: int32 = 930002
    v3BioDidOperatorAnchorAccountId: int32 = 1
    v3BioDidBundleVersionText = "2"
    v3BioDidOperatorAnchorVersionText = "2"
    v3BioDidOperatorAnchorVersionTextLegacy = "1"
    v3BioDidHardwareAttestationVersion: int32 = 1
    v3BioDidRecoveryModeSecretV1 = "recovery_secret_v1"
    v3BioDidOperatorTag = "v3.bio.did.operator.v1"
    v3BioDidOperatorIndexInitCap: int32 = 64
    v3BioDidOperatorBundleKindAndroidBioV1 = "android_bio_v1"
    v3BioDidOperatorBundleKindBrowserPublicV1 = "browser_public_v1"
    v3BioDidOperatorBundleKindBrowserRecoveryDraftV1 = "browser_recovery_draft_v1"

type
    V3BioDidHardwareCapture =
        verified: bool
        feature32: layout.FixedBytes32
        requestId: str
        sensorId: str
        deviceBindingSeed: str
        deviceLabel: str
        hardwareAttestation: str

    V3BioDidHardwareAttestation =
        version: int32
        requestId: str
        sensorId: str
        verifiedAtEpochSeconds: did.V3DidWord64
        deviceBindingSeedHash: layout.FixedBytes32
        attestationText: str
        attestationCid: layout.FixedBytes32
        bindingCid: layout.FixedBytes32

    V3BioDidParsedHardwareAttestation =
        version: int32
        requestId: str
        purpose: int32
        sensorId: str
        platform: int32
        attestationKind: int32
        rootKeyId: str
        certChainCid: layout.FixedBytes32
        livenessCid: layout.FixedBytes32
        deviceBindingSeedHash: layout.FixedBytes32
        deviceLabel: str
        featureCommitment: layout.FixedBytes32
        attestorPubKey: layout.FixedBytes65
        signature: layout.FixedBytes64

    V3BioDidChainBundle =
        action: str
        bundleSeq: int32
        didText: str
        devicePeerId: types.V3Libp2pPeerId
        documentText: str
        record: bio.V3BioEnrollmentRecord
        assertion: bio.V3BioAssertion
        hardware: V3BioDidHardwareAttestation
        bundleCid: layout.FixedBytes32

    V3BioDidChainBundleHeader =
        action: str
        bundleSeq: int32
        didText: str
        bundleCid: layout.FixedBytes32

    V3BioDidProvisionResult =
        identity: did.V3DidIdentity
        document: did.V3DidDocument
        bundle: V3BioDidChainBundle

    V3BioDidOperatorAnchor =
        operatorId: layout.FixedBytes32
        bundleKind: str
        recoveryMode: str
        didText: str
        subjectDidText: str
        deviceDidText: str
        bundleSeq: int32
        bundleCid: layout.FixedBytes32
        bundleText: str
        eventId: str

    V3BioDidOperatorRecord =
        operatorId: layout.FixedBytes32
        bundleKind: str
        didText: str
        subjectDidText: str
        deviceDidText: str
        bundleSeq: int32
        bundleCid: layout.FixedBytes32
        bundleText: str
        eventId: str
        anchorSeq: int32

    V3BioDidOperatorKindKey =
        operatorId: layout.FixedBytes32
        bundleKind: str

    V3BioDidOperatorIndex =
        keys: layout.FixedBytes32[]
        vals: V3BioDidOperatorRecord[]
        used: int32[]
        len: int32

    V3BioDidOperatorKindIndex =
        keys: V3BioDidOperatorKindKey[]
        vals: V3BioDidOperatorRecord[]
        used: int32[]
        len: int32

    V3BioDidChainState =
        node: chain.V3ChainNode
        operatorIndex: V3BioDidOperatorIndex
        operatorKindIndex: V3BioDidOperatorKindIndex
        operatorAnchorSeq: int32

var v3BioDidTrustedAttestorPubKeyHex: str
var v3BioDidTrustedAttestorRootKeyId: str

fn v3BioDidCopyText(text: str): str =
    var out = ""
    out = did.v3DidTextAppend(out, text)
    return out

fn v3BioDidTextEqual(left: str, right: str): bool =
    let leftLen = strings.Len(left)
    if leftLen != strings.Len(right):
        return false
    for i in 0..<leftLen:
        if left[i] != right[i]:
            return false
    return true

fn v3BioDidTextDiffIndex(left: str, right: str): int32 =
    let leftLen = strings.Len(left)
    let rightLen = strings.Len(right)
    var stop = leftLen
    if rightLen < stop:
        stop = rightLen
    for i in 0..<stop:
        if left[i] != right[i]:
            return i
    if leftLen != rightLen:
        return stop
    return -1

fn v3BioDidTextSliceHex(text: str, start0: int32, count0: int32): str =
    let textLen = strings.Len(text)
    if textLen <= 0 || count0 <= 0:
        return ""
    var start = start0
    if start < 0:
        start = 0
    if start >= textLen:
        return ""
    var count = count0
    if start + count > textLen:
        count = textLen - start
    return did.v3DidStoreEncodeText(strings.SliceBytes(text, start, count))

fn v3BioDidTextMismatch(label: str,
                        want: str,
                        got: str): str =
    let diffAt = v3BioDidTextDiffIndex(want, got)
    var snippetStart = diffAt - 8
    if snippetStart < 0:
        snippetStart = 0
    var out = "v3 bio did: "
    out = did.v3DidTextAppend(out, label)
    out = did.v3DidTextAppend(out, " want_len=")
    out = did.v3DidTextAppend(out, strings.IntToStr(strings.Len(want)))
    out = did.v3DidTextAppend(out, " got_len=")
    out = did.v3DidTextAppend(out, strings.IntToStr(strings.Len(got)))
    out = did.v3DidTextAppend(out, " diff_at=")
    out = did.v3DidTextAppend(out, strings.IntToStr(diffAt))
    out = did.v3DidTextAppend(out, " want_hex=")
    out = did.v3DidTextAppend(out, v3BioDidTextSliceHex(want, snippetStart, 24))
    out = did.v3DidTextAppend(out, " got_hex=")
    out = did.v3DidTextAppend(out, v3BioDidTextSliceHex(got, snippetStart, 24))
    return out

fn v3BioDidOperatorBundleKindNormalize(bundleKind: str): str =
    if strings.Len(bundleKind) <= 0:
        return v3BioDidOperatorBundleKindAndroidBioV1
    return bundleKind

fn v3BioDidOperatorIndexZeroInto(out: var V3BioDidOperatorIndex) =
    var keys: layout.FixedBytes32[]
    var vals: V3BioDidOperatorRecord[]
    var used: int32[]
    keys.len = 0
    vals.len = 0
    used.len = 0
    out.keys = keys
    out.vals = vals
    out.used = used
    out.len = 0

fn v3BioDidOperatorKindIndexZeroInto(out: var V3BioDidOperatorKindIndex) =
    var keys: V3BioDidOperatorKindKey[]
    var vals: V3BioDidOperatorRecord[]
    var used: int32[]
    keys.len = 0
    vals.len = 0
    used.len = 0
    out.keys = keys
    out.vals = vals
    out.used = used
    out.len = 0

fn v3BioDidChainStateZeroInto(out: var V3BioDidChainState, node: var chain.V3ChainNode) =
    chain.v3ChainNodeCopyInto(out.node, node)
    v3BioDidOperatorIndexZeroInto(out.operatorIndex)
    v3BioDidOperatorKindIndexZeroInto(out.operatorKindIndex)
    out.operatorAnchorSeq = 0

fn v3BioDidChainStateInitInto(out: var V3BioDidChainState,
                              nodeId: str,
                              addressSeed: str): Result[bool] =
    let initRes = chain.v3ChainNodeInitInto(out.node, nodeId, addressSeed)
    if IsErr(initRes):
        return Err[bool](Error(initRes))
    v3BioDidOperatorIndexZeroInto(out.operatorIndex)
    v3BioDidOperatorKindIndexZeroInto(out.operatorKindIndex)
    out.operatorAnchorSeq = 0
    return Ok[bool](true)

fn v3BioDidOperatorIndexRoundUpPow2(x0: int32): int32 =
    if x0 < 2:
        return 1
    var x = x0 - 1
    x = x | (x >> 1)
    x = x | (x >> 2)
    x = x | (x >> 4)
    x = x | (x >> 8)
    x = x | (x >> 16)
    return x + 1

fn v3BioDidOperatorIndexInitInto(out: var V3BioDidOperatorIndex,
                                 initialCap: int32) =
    var cap = initialCap
    if cap < 8:
        cap = 8
    cap = v3BioDidOperatorIndexRoundUpPow2(cap)
    v3BioDidOperatorIndexZeroInto(out)
    var i = 0
    while i < cap:
        add(out.keys, layout.FixedBytes32())
        add(out.vals, V3BioDidOperatorRecord())
        add(out.used, 0)
        i = i + 1

fn v3BioDidOperatorIndexHash(key: layout.FixedBytes32): int32 =
    var h: int32
    for i in 0..<32:
        let code = int32(key.data[i]) & 255
        h = h + code
        h = h + (h << 10)
        h = h ^ (h >> 6)
    h = h + (h << 3)
    h = h ^ (h >> 11)
    h = h + (h << 15)
    return h

fn v3BioDidOperatorIndexFindSlot(index: V3BioDidOperatorIndex,
                                 key: layout.FixedBytes32,
                                 allowInsert: bool): int32 =
    let cap = index.keys.len
    if cap <= 0:
        return -1
    var probe = (v3BioDidOperatorIndexHash(key) & 0x7fffffff) % cap
    var scanned = 0
    while scanned < cap:
        if index.used[probe] == 0:
            if allowInsert:
                return probe
            return -1
        if layout.fixedBytes32Equal(index.keys[probe], key):
            return probe
        probe = probe + 1
        if probe >= cap:
            probe = 0
        scanned = scanned + 1
    return -1

fn v3BioDidOperatorIndexFindSlotMut(index: var V3BioDidOperatorIndex,
                                    key: layout.FixedBytes32,
                                    allowInsert: bool): int32 =
    let cap = index.keys.len
    if cap <= 0:
        return -1
    var probe = (v3BioDidOperatorIndexHash(key) & 0x7fffffff) % cap
    var scanned = 0
    while scanned < cap:
        if index.used[probe] == 0:
            if allowInsert:
                return probe
            return -1
        if layout.fixedBytes32Equal(index.keys[probe], key):
            return probe
        probe = probe + 1
        if probe >= cap:
            probe = 0
        scanned = scanned + 1
    return -1

fn v3BioDidOperatorIndexGrow(index: var V3BioDidOperatorIndex): Result[bool] =
    let oldCap = index.keys.len
    let nextCap = oldCap * 2
    var next: V3BioDidOperatorIndex
    v3BioDidOperatorIndexInitInto(next, nextCap)
    var i = 0
    while i < oldCap:
        if index.used[i] != 0:
            let putRes = v3BioDidOperatorIndexPut(next, index.keys[i], index.vals[i])
            if IsErr(putRes):
                return Err[bool](Error(putRes))
        i = i + 1
    index.keys = next.keys
    index.vals = next.vals
    index.used = next.used
    index.len = next.len
    return Ok[bool](true)

fn v3BioDidOperatorIndexPut(index: var V3BioDidOperatorIndex,
                            key: layout.FixedBytes32,
                            record: V3BioDidOperatorRecord): Result[bool] =
    if index.keys.len <= 0:
        let initCap = v3BioDidOperatorIndexInitCap
        v3BioDidOperatorIndexInitInto(index, initCap)
    if (index.len + 1) * 10 >= index.keys.len * 7:
        let growRes = v3BioDidOperatorIndexGrow(index)
        if IsErr(growRes):
            return Err[bool](Error(growRes))
    let slot = v3BioDidOperatorIndexFindSlotMut(index, key, true)
    if slot < 0:
        return Err[bool]("v3 bio did: operator index slot missing")
    if index.used[slot] == 0:
        index.len = index.len + 1
        index.used[slot] = 1
    index.keys[slot] = key
    index.vals[slot] = record
    return Ok[bool](true)

fn v3BioDidOperatorKindIndexInitInto(out: var V3BioDidOperatorKindIndex,
                                     initialCap: int32) =
    var cap = initialCap
    if cap < 8:
        cap = 8
    cap = v3BioDidOperatorIndexRoundUpPow2(cap)
    v3BioDidOperatorKindIndexZeroInto(out)
    var i = 0
    while i < cap:
        add(out.keys, V3BioDidOperatorKindKey())
        add(out.vals, V3BioDidOperatorRecord())
        add(out.used, 0)
        i = i + 1

fn v3BioDidTextHash(text: str): int32 =
    var h: int32
    for i in 0..<strings.Len(text):
        let code = int32(text[i]) & 255
        h = h + code
        h = h + (h << 10)
        h = h ^ (h >> 6)
    h = h + (h << 3)
    h = h ^ (h >> 11)
    h = h + (h << 15)
    return h

fn v3BioDidOperatorKindKeyHash(key: V3BioDidOperatorKindKey): int32 =
    return v3BioDidOperatorIndexHash(key.operatorId) ^ v3BioDidTextHash(key.bundleKind)

fn v3BioDidOperatorKindKeyEqual(left: V3BioDidOperatorKindKey,
                                right: V3BioDidOperatorKindKey): bool =
    if !layout.fixedBytes32Equal(left.operatorId, right.operatorId):
        return false
    return v3BioDidTextEqual(left.bundleKind, right.bundleKind)

fn v3BioDidOperatorKindIndexFindSlot(index: V3BioDidOperatorKindIndex,
                                     key: V3BioDidOperatorKindKey,
                                     allowInsert: bool): int32 =
    let cap = index.keys.len
    if cap <= 0:
        return -1
    var probe = (v3BioDidOperatorKindKeyHash(key) & 0x7fffffff) % cap
    var scanned = 0
    while scanned < cap:
        if index.used[probe] == 0:
            if allowInsert:
                return probe
            return -1
        if v3BioDidOperatorKindKeyEqual(index.keys[probe], key):
            return probe
        probe = probe + 1
        if probe >= cap:
            probe = 0
        scanned = scanned + 1
    return -1

fn v3BioDidOperatorKindIndexFindSlotMut(index: var V3BioDidOperatorKindIndex,
                                        key: V3BioDidOperatorKindKey,
                                        allowInsert: bool): int32 =
    let cap = index.keys.len
    if cap <= 0:
        return -1
    var probe = (v3BioDidOperatorKindKeyHash(key) & 0x7fffffff) % cap
    var scanned = 0
    while scanned < cap:
        if index.used[probe] == 0:
            if allowInsert:
                return probe
            return -1
        if v3BioDidOperatorKindKeyEqual(index.keys[probe], key):
            return probe
        probe = probe + 1
        if probe >= cap:
            probe = 0
        scanned = scanned + 1
    return -1

fn v3BioDidOperatorKindIndexGrow(index: var V3BioDidOperatorKindIndex): Result[bool] =
    let oldCap = index.keys.len
    let nextCap = oldCap * 2
    var next: V3BioDidOperatorKindIndex
    v3BioDidOperatorKindIndexInitInto(next, nextCap)
    var i = 0
    while i < oldCap:
        if index.used[i] != 0:
            let putRes = v3BioDidOperatorKindIndexPut(next, index.keys[i], index.vals[i])
            if IsErr(putRes):
                return Err[bool](Error(putRes))
        i = i + 1
    index.keys = next.keys
    index.vals = next.vals
    index.used = next.used
    index.len = next.len
    return Ok[bool](true)

fn v3BioDidOperatorKindIndexPut(index: var V3BioDidOperatorKindIndex,
                                key: V3BioDidOperatorKindKey,
                                record: V3BioDidOperatorRecord): Result[bool] =
    if index.keys.len <= 0:
        let initCap = v3BioDidOperatorIndexInitCap
        v3BioDidOperatorKindIndexInitInto(index, initCap)
    if (index.len + 1) * 10 >= index.keys.len * 7:
        let growRes = v3BioDidOperatorKindIndexGrow(index)
        if IsErr(growRes):
            return Err[bool](Error(growRes))
    let slot = v3BioDidOperatorKindIndexFindSlotMut(index, key, true)
    if slot < 0:
        return Err[bool]("v3 bio did: operator kind index slot missing")
    if index.used[slot] == 0:
        index.len = index.len + 1
        index.used[slot] = 1
    index.keys[slot] = key
    index.vals[slot] = record
    return Ok[bool](true)

fn v3BioDidOperatorRecordShouldReplace(current: V3BioDidOperatorRecord,
                                       incoming: V3BioDidOperatorRecord): bool =
    if layout.fixedBytes32Equal(current.operatorId, layout.FixedBytes32()):
        return true
    if incoming.bundleSeq != current.bundleSeq:
        return incoming.bundleSeq > current.bundleSeq
    return incoming.anchorSeq >= current.anchorSeq

fn v3BioDidOperatorKindIndexLookup(index: V3BioDidOperatorKindIndex,
                                   operatorId: layout.FixedBytes32,
                                   bundleKind: str): Result[V3BioDidOperatorRecord] =
    if strings.Len(bundleKind) <= 0:
        return Err[V3BioDidOperatorRecord]("v3 bio did: operator bundle kind required")
    let slot = v3BioDidOperatorKindIndexFindSlot(
        index,
        V3BioDidOperatorKindKey(operatorId: operatorId, bundleKind: bundleKind),
        false
    )
    if slot < 0:
        return Err[V3BioDidOperatorRecord]("v3 bio did: operator bundle not found")
    let record = index.vals[slot]
    if layout.fixedBytes32Equal(record.operatorId, layout.FixedBytes32()):
        return Err[V3BioDidOperatorRecord]("v3 bio did: operator bundle record missing")
    return Ok[V3BioDidOperatorRecord](record)

fn v3BioDidActionValid(action: str): bool =
    if action == "create":
        return true
    if action == "import":
        return true
    return false

fn v3BioDidBundleCid(text: str): layout.FixedBytes32 =
    return did.v3DidHashTagged("v3.bio.did.bundle", text)

fn v3BioDidRootSeedFromRootSecret(rootSecret: layout.FixedBytes32): str =
    return layout.fixedBytes32Hex(
        did.v3DidHashTagged("v3.bio.did.root.seed", layout.fixedBytes32Hex(rootSecret))
    )

fn v3BioDidDeviceSeedFromRootSecret(rootSecret: layout.FixedBytes32,
                                    deviceBindingSeed: str): str =
    let rootSecretHex = layout.fixedBytes32Hex(rootSecret)
    var payload = rootSecretHex
    payload = did.v3DidTextAppend(payload, "|")
    payload = did.v3DidTextAppend(payload, deviceBindingSeed)
    return layout.fixedBytes32Hex(
        did.v3DidHashTagged("v3.bio.did.device.seed", payload)
    )

fn v3BioDidDeviceBindingSeedHash(deviceBindingSeed: str): layout.FixedBytes32 =
    return biometric.v3BiometricFingerprintDeviceBindingSeedHash(deviceBindingSeed)

fn v3BioDidChallengeNonce(action: str,
                          didText: str,
                          devicePeerId: types.V3Libp2pPeerId,
                          documentVersion: did.V3DidWord64,
                          bundleSeq: int32): layout.FixedBytes32 =
    var proofText = action
    proofText = did.v3DidTextAppend(proofText, "|")
    proofText = did.v3DidTextAppend(proofText, didText)
    proofText = did.v3DidTextAppend(proofText, "|")
    proofText = did.v3DidTextAppend(proofText, peer_id.v3Libp2pPeerIdText(devicePeerId))
    proofText = did.v3DidTextAppend(proofText, "|")
    proofText = did.v3DidTextAppend(proofText, did.v3DidStoreWord64Hex(documentVersion))
    proofText = did.v3DidTextAppend(proofText, "|")
    proofText = did.v3DidTextAppend(proofText, strings.IntToStr(bundleSeq))
    return did.v3DidHashTagged("v3.bio.did.challenge", proofText)

fn v3BioDidChainAccountId(didText: str): int32 =
    let digest = did.v3DidHashTagged("v3.bio.did.account", didText)
    let value = int64(int32(digest.data[0]) & 255) * int64(16777216) +
                int64(int32(digest.data[1]) & 255) * int64(65536) +
                int64(int32(digest.data[2]) & 255) * int64(256) +
                int64(int32(digest.data[3]) & 255)
    return int32(value % int64(2147483646)) + 1

fn v3BioDidClearTrustedAttestors() =
    v3BioDidTrustedAttestorPubKeyHex = ""
    v3BioDidTrustedAttestorRootKeyId = ""

fn v3BioDidHasTrustedAttestor(pubKey: layout.FixedBytes65): bool =
    let trustedPubKeyHex = v3BioDidTrustedAttestorPubKeyHex
    if strings.Len(trustedPubKeyHex) <= 0:
        return false
    return layout.fixedBytes65Hex(pubKey) == trustedPubKeyHex

fn v3BioDidSetTrustedAttestorHex(pubKeyHex: str): Result[bool] =
    let pubRes: Result[layout.FixedBytes65] = layout.fixedBytes65FromHex(pubKeyHex)
    if IsErr(pubRes):
        return Err[bool](Error(pubRes))
    if !fixed256.p256PublicKey65Valid(Value(pubRes)):
        return Err[bool]("v3 bio did: invalid trusted attestor pubkey")
    v3BioDidTrustedAttestorPubKeyHex = v3BioDidCopyText(layout.fixedBytes65Hex(Value(pubRes)))
    v3BioDidTrustedAttestorRootKeyId = ""
    return Ok[bool](true)

fn v3BioDidSetTrustedAttestorRootHex(pubKeyHex: str,
                                     rootKeyId: str): Result[bool] =
    if strings.Len(rootKeyId) <= 0:
        return Err[bool]("v3 bio did: trusted attestor root key id required")
    let setRes = v3BioDidSetTrustedAttestorHex(pubKeyHex)
    if IsErr(setRes):
        return Err[bool](Error(setRes))
    v3BioDidTrustedAttestorRootKeyId = v3BioDidCopyText(rootKeyId)
    return Ok[bool](true)

fn v3BioDidAddTrustedAttestor(pubKey: layout.FixedBytes65): Result[bool] =
    return v3BioDidSetTrustedAttestorHex(layout.fixedBytes65Hex(pubKey))

fn v3BioDidAddTrustedAttestorRoot(pubKey: layout.FixedBytes65,
                                  rootKeyId: str): Result[bool] =
    return v3BioDidSetTrustedAttestorRootHex(layout.fixedBytes65Hex(pubKey), rootKeyId)

fn v3BioDidTrustedAttestorRequired(pubKey: layout.FixedBytes65): Result[bool] =
    let trustedPubKeyHex = v3BioDidTrustedAttestorPubKeyHex
    if strings.Len(trustedPubKeyHex) <= 0:
        return Err[bool]("v3 bio did: trusted attestor set required")
    if !v3BioDidHasTrustedAttestor(pubKey):
        return Err[bool]("v3 bio did: untrusted hardware attestor")
    return Ok[bool](true)

fn v3BioDidTrustedAttestorRootRequired(rootKeyId: str): Result[bool] =
    let trustedRootKeyId = v3BioDidTrustedAttestorRootKeyId
    if strings.Len(trustedRootKeyId) <= 0:
        return Err[bool]("v3 bio did: trusted attestor root key id required")
    if !v3BioDidTextEqual(rootKeyId, trustedRootKeyId):
        var out = "v3 bio did: hardware attestation root key mismatch expected_hex="
        out = did.v3DidTextAppend(out, did.v3DidStoreEncodeText(trustedRootKeyId))
        out = did.v3DidTextAppend(out, " got_hex=")
        out = did.v3DidTextAppend(out, did.v3DidStoreEncodeText(rootKeyId))
        return Err[bool](out)
    return Ok[bool](true)

fn v3BioDidPurposeFromAction(action: str): Result[int32] =
    if action == "create":
        return Ok[int32](biometric.v3BiometricPurposeDidCreate)
    if action == "import":
        return Ok[int32](biometric.v3BiometricPurposeDidImport)
    return Err[int32]("v3 bio did: invalid action purpose")

fn v3BioDidHardwareAttestationCid(attestationText: str): layout.FixedBytes32 =
    return did.v3DidHashTagged("v3.bio.did.hardware.attestation", attestationText)

fn v3BioDidHardwareBindingText(hardware: V3BioDidHardwareAttestation,
                               action: str,
                               didText: str,
                               devicePeerId: types.V3Libp2pPeerId,
                               documentVersion: did.V3DidWord64,
                               bundleSeq: int32,
                               challengeNonce: layout.FixedBytes32): str =
    var out = "v3_bio_did_hardware_binding_version=1"
    out = did.v3DidTextAppend(out, "|action=")
    out = did.v3DidTextAppend(out, action)
    out = did.v3DidTextAppend(out, "|did=")
    out = did.v3DidTextAppend(out, didText)
    out = did.v3DidTextAppend(out, "|device_peer_id=")
    out = did.v3DidTextAppend(out, peer_id.v3Libp2pPeerIdText(devicePeerId))
    out = did.v3DidTextAppend(out, "|document_version=")
    out = did.v3DidTextAppend(out, did.v3DidStoreWord64Hex(documentVersion))
    out = did.v3DidTextAppend(out, "|bundle_seq=")
    out = did.v3DidTextAppend(out, strings.IntToStr(bundleSeq))
    out = did.v3DidTextAppend(out, "|challenge_nonce=")
    out = did.v3DidTextAppend(out, layout.fixedBytes32Hex(challengeNonce))
    out = did.v3DidTextAppend(out, "|request_id=")
    out = did.v3DidTextAppend(out, did.v3DidStoreEncodeText(hardware.requestId))
    out = did.v3DidTextAppend(out, "|sensor_id=")
    out = did.v3DidTextAppend(out, did.v3DidStoreEncodeText(hardware.sensorId))
    out = did.v3DidTextAppend(out, "|verified_at=")
    out = did.v3DidTextAppend(out, did.v3DidStoreWord64Hex(hardware.verifiedAtEpochSeconds))
    out = did.v3DidTextAppend(out, "|device_binding_seed_hash=")
    out = did.v3DidTextAppend(out, layout.fixedBytes32Hex(hardware.deviceBindingSeedHash))
    out = did.v3DidTextAppend(out, "|attestation_cid=")
    out = did.v3DidTextAppend(out, layout.fixedBytes32Hex(hardware.attestationCid))
    return out

fn v3BioDidHardwareBindingCid(hardware: V3BioDidHardwareAttestation,
                              action: str,
                              didText: str,
                              devicePeerId: types.V3Libp2pPeerId,
                              documentVersion: did.V3DidWord64,
                              bundleSeq: int32,
                              challengeNonce: layout.FixedBytes32): layout.FixedBytes32 =
    return did.v3DidHashTagged("v3.bio.did.hardware.binding",
                               v3BioDidHardwareBindingText(hardware,
                                                           action,
                                                           didText,
                                                           devicePeerId,
                                                           documentVersion,
                                                           bundleSeq,
                                                           challengeNonce))

fn v3BioDidInvalidInt32Field(fieldName: str,
                             fieldText: str): str =
    var out = "v3 bio did: invalid int32 field "
    out = did.v3DidTextAppend(out, fieldName)
    out = did.v3DidTextAppend(out, " len=")
    out = did.v3DidTextAppend(out, strings.IntToStr(strings.Len(fieldText)))
    out = did.v3DidTextAppend(out, " hex=")
    out = did.v3DidTextAppend(out, did.v3DidStoreEncodeText(fieldText))
    return out

fn v3BioDidParseInt32Field(fieldName: str,
                           fieldText: str): Result[int32] =
    let parsedRes = did.v3DidStoreParseInt32(fieldText)
    if IsErr(parsedRes):
        return Err[int32](v3BioDidInvalidInt32Field(fieldName, fieldText))
    return parsedRes

fn v3BioDidParseHardwareAttestation(text: str): Result[V3BioDidParsedHardwareAttestation] =
    if strings.Len(text) <= 0:
        return Err[V3BioDidParsedHardwareAttestation]("v3 bio did: missing hardware attestation")
    let lines = strutil.Split(text, '\n')
    let versionTextRes = did.v3DidStoreFindValue(lines, "v3_biometric_attestation_version")
    if IsErr(versionTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(versionTextRes))
    let requestIdTextRes = did.v3DidStoreFindValue(lines, "request_id")
    if IsErr(requestIdTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(requestIdTextRes))
    let purposeTextRes = did.v3DidStoreFindValue(lines, "purpose")
    if IsErr(purposeTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(purposeTextRes))
    let sensorIdTextRes = did.v3DidStoreFindValue(lines, "sensor_id")
    if IsErr(sensorIdTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(sensorIdTextRes))
    let platformTextRes = did.v3DidStoreFindValue(lines, "platform")
    if IsErr(platformTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(platformTextRes))
    let attestationKindTextRes = did.v3DidStoreFindValue(lines, "attestation_kind")
    if IsErr(attestationKindTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(attestationKindTextRes))
    let rootKeyIdTextRes = did.v3DidStoreFindValue(lines, "root_key_id")
    if IsErr(rootKeyIdTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(rootKeyIdTextRes))
    let certChainCidTextRes = did.v3DidStoreFindValue(lines, "cert_chain_cid")
    if IsErr(certChainCidTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(certChainCidTextRes))
    let livenessCidTextRes = did.v3DidStoreFindValue(lines, "liveness_cid")
    if IsErr(livenessCidTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(livenessCidTextRes))
    let deviceBindingSeedHashTextRes = did.v3DidStoreFindValue(lines, "device_binding_seed_hash")
    if IsErr(deviceBindingSeedHashTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(deviceBindingSeedHashTextRes))
    let deviceLabelTextRes = did.v3DidStoreFindValue(lines, "device_label")
    if IsErr(deviceLabelTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(deviceLabelTextRes))
    let featureCommitmentTextRes = did.v3DidStoreFindValue(lines, "feature_commitment")
    if IsErr(featureCommitmentTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(featureCommitmentTextRes))
    let attestorPubKeyTextRes = did.v3DidStoreFindValue(lines, "attestor_pub_key")
    if IsErr(attestorPubKeyTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(attestorPubKeyTextRes))
    let signatureTextRes = did.v3DidStoreFindValue(lines, "signature")
    if IsErr(signatureTextRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(signatureTextRes))
    let versionRes = v3BioDidParseInt32Field("v3_biometric_attestation_version", Value(versionTextRes))
    if IsErr(versionRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(versionRes))
    let purposeRes = v3BioDidParseInt32Field("purpose", Value(purposeTextRes))
    if IsErr(purposeRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(purposeRes))
    let platformRes = v3BioDidParseInt32Field("platform", Value(platformTextRes))
    if IsErr(platformRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(platformRes))
    let attestationKindRes = v3BioDidParseInt32Field("attestation_kind", Value(attestationKindTextRes))
    if IsErr(attestationKindRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(attestationKindRes))
    let requestIdBytesRes = did.v3DidStoreDecodeBytes(Value(requestIdTextRes))
    if IsErr(requestIdBytesRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(requestIdBytesRes))
    let sensorIdBytesRes = did.v3DidStoreDecodeBytes(Value(sensorIdTextRes))
    if IsErr(sensorIdBytesRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(sensorIdBytesRes))
    let rootKeyIdBytesRes = did.v3DidStoreDecodeBytes(Value(rootKeyIdTextRes))
    if IsErr(rootKeyIdBytesRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(rootKeyIdBytesRes))
    let certChainCidRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(Value(certChainCidTextRes))
    if IsErr(certChainCidRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(certChainCidRes))
    let livenessCidRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(Value(livenessCidTextRes))
    if IsErr(livenessCidRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(livenessCidRes))
    let deviceBindingSeedHashRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(Value(deviceBindingSeedHashTextRes))
    if IsErr(deviceBindingSeedHashRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(deviceBindingSeedHashRes))
    let deviceLabelBytesRes = did.v3DidStoreDecodeBytes(Value(deviceLabelTextRes))
    if IsErr(deviceLabelBytesRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(deviceLabelBytesRes))
    let featureCommitmentRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(Value(featureCommitmentTextRes))
    if IsErr(featureCommitmentRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(featureCommitmentRes))
    let attestorPubKeyRes: Result[layout.FixedBytes65] = layout.fixedBytes65FromHex(Value(attestorPubKeyTextRes))
    if IsErr(attestorPubKeyRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(attestorPubKeyRes))
    let signatureRes: Result[layout.FixedBytes64] = layout.fixedBytes64FromHex(Value(signatureTextRes))
    if IsErr(signatureRes):
        return Err[V3BioDidParsedHardwareAttestation](Error(signatureRes))
    var out = V3BioDidParsedHardwareAttestation()
    out.version = Value(versionRes)
    out.requestId = bytesToString(Value(requestIdBytesRes))
    out.purpose = Value(purposeRes)
    out.sensorId = bytesToString(Value(sensorIdBytesRes))
    out.platform = Value(platformRes)
    out.attestationKind = Value(attestationKindRes)
    out.rootKeyId = bytesToString(Value(rootKeyIdBytesRes))
    out.certChainCid = Value(certChainCidRes)
    out.livenessCid = Value(livenessCidRes)
    out.deviceBindingSeedHash = Value(deviceBindingSeedHashRes)
    out.deviceLabel = bytesToString(Value(deviceLabelBytesRes))
    out.featureCommitment = Value(featureCommitmentRes)
    out.attestorPubKey = Value(attestorPubKeyRes)
    out.signature = Value(signatureRes)
    return Ok[V3BioDidParsedHardwareAttestation](out)

fn v3BioDidHardwareAttestationProofValidate(parsed: V3BioDidParsedHardwareAttestation): Result[bool] =
    if !biometric.v3BiometricAttestationPlatformValid(parsed.platform):
        return Err[bool]("v3 bio did: invalid hardware attestation platform")
    if !biometric.v3BiometricAttestationKindValid(parsed.attestationKind):
        return Err[bool]("v3 bio did: invalid hardware attestation kind")
    let parsedRootKeyId = parsed.rootKeyId
    if strings.Len(parsedRootKeyId) <= 0:
        return Err[bool]("v3 bio did: hardware attestation root key id required")
    if layout.fixedBytes32Equal(parsed.certChainCid, layout.FixedBytes32()):
        return Err[bool]("v3 bio did: hardware attestation cert chain cid required")
    if layout.fixedBytes32Equal(parsed.livenessCid, layout.FixedBytes32()):
        return Err[bool]("v3 bio did: hardware attestation liveness cid required")
    let trustRes = v3BioDidTrustedAttestorRequired(parsed.attestorPubKey)
    if IsErr(trustRes):
        return Err[bool](Error(trustRes))
    let rootRes = v3BioDidTrustedAttestorRootRequired(parsedRootKeyId)
    if IsErr(rootRes):
        return Err[bool](Error(rootRes))
    return Ok[bool](true)

fn v3BioDidHardwareAttestationSignatureVerify(parsed: V3BioDidParsedHardwareAttestation,
                                              text: str): Result[bool] =
    let proofRes = v3BioDidHardwareAttestationProofValidate(parsed)
    if IsErr(proofRes):
        return Err[bool](Error(proofRes))
    var envelope = biometric.V3BiometricFingerprintAttestationEnvelope()
    envelope.requestId = parsed.requestId
    envelope.purpose = parsed.purpose
    envelope.sensorId = parsed.sensorId
    envelope.platform = parsed.platform
    envelope.attestationKind = parsed.attestationKind
    envelope.rootKeyId = parsed.rootKeyId
    envelope.certChainCid = parsed.certChainCid
    envelope.livenessCid = parsed.livenessCid
    envelope.deviceBindingSeedHash = parsed.deviceBindingSeedHash
    envelope.deviceLabel = parsed.deviceLabel
    envelope.featureCommitment = parsed.featureCommitment
    envelope.attestorPubKey = parsed.attestorPubKey
    let signable = biometric.v3BiometricFingerprintAttestationSignable(envelope)
    let attestorPubBytes = layout.fixedBytes65ToBytes(parsed.attestorPubKey)
    let signatureBytes = layout.fixedBytes64ToBytes(parsed.signature)
    let verifyOk = ecnist.ecdsaVerifyTrustedBytes(attestorPubBytes,
                                                  bytesFromString(signable),
                                                  signatureBytes)
    if !verifyOk:
        return Err[bool]("v3 bio did: hardware attestation signature mismatch")
    let canonicalText = biometric.v3BiometricFingerprintAttestationText(envelope,
                                                                        parsed.signature)
    if !v3BioDidTextEqual(canonicalText, text):
        return Err[bool](v3BioDidTextMismatch("non canonical hardware attestation",
                                              canonicalText,
                                              text))
    return Ok[bool](true)

fn v3BioDidCaptureValidate(capture: V3BioDidHardwareCapture): Result[bool] =
    if !capture.verified:
        return Err[bool]("v3 bio did: hardware verification required")
    let captureRequestId = capture.requestId
    if strings.Len(captureRequestId) <= 0:
        return Err[bool]("v3 bio did: request id required")
    let captureSensorId = capture.sensorId
    if strings.Len(captureSensorId) <= 0:
        return Err[bool]("v3 bio did: sensor id required")
    let captureBindingSeed = capture.deviceBindingSeed
    if strings.Len(captureBindingSeed) <= 0:
        return Err[bool]("v3 bio did: device binding seed required")
    let captureDeviceLabel = capture.deviceLabel
    if strings.Len(captureDeviceLabel) <= 0:
        return Err[bool]("v3 bio did: device label required")
    let captureAttestation = capture.hardwareAttestation
    if strings.Len(captureAttestation) <= 0:
        return Err[bool]("v3 bio did: hardware attestation required")
    return Ok[bool](true)

fn v3BioDidCaptureAttestationValidate(capture: V3BioDidHardwareCapture,
                                      action: str): Result[bool] =
    let purposeRes = v3BioDidPurposeFromAction(action)
    if IsErr(purposeRes):
        return Err[bool](Error(purposeRes))
    let parsedRes = v3BioDidParseHardwareAttestation(capture.hardwareAttestation)
    if IsErr(parsedRes):
        return Err[bool](Error(parsedRes))
    let parsed = Value(parsedRes)
    if parsed.version != biometric.v3BiometricHardwareAttestationVersion:
        return Err[bool]("v3 bio did: unsupported capture attestation version")
    let verifyRes = v3BioDidHardwareAttestationSignatureVerify(parsed, capture.hardwareAttestation)
    if IsErr(verifyRes):
        return Err[bool](Error(verifyRes))
    if parsed.purpose != Value(purposeRes):
        return Err[bool]("v3 bio did: hardware attestation purpose mismatch")
    if !v3BioDidTextEqual(parsed.requestId, capture.requestId):
        return Err[bool]("v3 bio did: hardware attestation request id mismatch")
    if !v3BioDidTextEqual(parsed.sensorId, capture.sensorId):
        return Err[bool]("v3 bio did: hardware attestation sensor id mismatch")
    let wantBindingSeedHash = v3BioDidDeviceBindingSeedHash(capture.deviceBindingSeed)
    if !layout.fixedBytes32Equal(parsed.deviceBindingSeedHash, wantBindingSeedHash):
        return Err[bool]("v3 bio did: hardware attestation device binding mismatch")
    if !v3BioDidTextEqual(parsed.deviceLabel, capture.deviceLabel):
        return Err[bool]("v3 bio did: hardware attestation device label mismatch")
    let wantFeatureCommitment = biometric.v3BiometricFingerprintFeatureCommitment(capture.feature32)
    if !layout.fixedBytes32Equal(parsed.featureCommitment, wantFeatureCommitment):
        return Err[bool]("v3 bio did: hardware attestation feature commitment mismatch")
    return Ok[bool](true)

fn v3BioDidHardwareAttestationValidate(hardware: V3BioDidHardwareAttestation,
                                       action: str,
                                       didText: str,
                                       devicePeerId: types.V3Libp2pPeerId,
                                       documentVersion: did.V3DidWord64,
                                       bundleSeq: int32,
                                       challengeNonce: layout.FixedBytes32): Result[bool] =
    if hardware.version != v3BioDidHardwareAttestationVersion:
        return Err[bool]("v3 bio did: unsupported hardware attestation version")
    let hardwareRequestId = hardware.requestId
    if strings.Len(hardwareRequestId) <= 0:
        return Err[bool]("v3 bio did: hardware request id required")
    let hardwareSensorId = hardware.sensorId
    if strings.Len(hardwareSensorId) <= 0:
        return Err[bool]("v3 bio did: hardware sensor id required")
    let hardwareAttestationText = hardware.attestationText
    if strings.Len(hardwareAttestationText) <= 0:
        return Err[bool]("v3 bio did: hardware attestation text required")
    let wantAttestationCid = v3BioDidHardwareAttestationCid(hardwareAttestationText)
    if !layout.fixedBytes32Equal(wantAttestationCid, hardware.attestationCid):
        return Err[bool]("v3 bio did: hardware attestation cid mismatch")
    let parsedRes = v3BioDidParseHardwareAttestation(hardwareAttestationText)
    if IsErr(parsedRes):
        return Err[bool](Error(parsedRes))
    let parsed = Value(parsedRes)
    if parsed.version != biometric.v3BiometricHardwareAttestationVersion:
        return Err[bool]("v3 bio did: unsupported stored hardware attestation version")
    let purposeRes = v3BioDidPurposeFromAction(action)
    if IsErr(purposeRes):
        return Err[bool](Error(purposeRes))
    let verifyRes = v3BioDidHardwareAttestationSignatureVerify(parsed, hardwareAttestationText)
    if IsErr(verifyRes):
        return Err[bool](Error(verifyRes))
    if parsed.purpose != Value(purposeRes):
        return Err[bool]("v3 bio did: stored hardware attestation purpose mismatch")
    if !v3BioDidTextEqual(parsed.requestId, hardwareRequestId):
        return Err[bool]("v3 bio did: stored hardware attestation request id mismatch")
    if !v3BioDidTextEqual(parsed.sensorId, hardwareSensorId):
        return Err[bool]("v3 bio did: stored hardware attestation sensor id mismatch")
    if !layout.fixedBytes32Equal(parsed.deviceBindingSeedHash, hardware.deviceBindingSeedHash):
        return Err[bool]("v3 bio did: stored hardware attestation binding mismatch")
    let wantBindingCid = v3BioDidHardwareBindingCid(hardware,
                                                    action,
                                                    didText,
                                                    devicePeerId,
                                                    documentVersion,
                                                    bundleSeq,
                                                    challengeNonce)
    if !layout.fixedBytes32Equal(wantBindingCid, hardware.bindingCid):
        return Err[bool]("v3 bio did: hardware binding cid mismatch")
    return Ok[bool](true)

fn v3BioDidHardwareAttestationMake(capture: V3BioDidHardwareCapture,
                                   action: str,
                                   didText: str,
                                   devicePeerId: types.V3Libp2pPeerId,
                                   documentVersion: did.V3DidWord64,
                                   bundleSeq: int32,
                                   challengeNonce: layout.FixedBytes32,
                                   epochSeconds: int64): V3BioDidHardwareAttestation =
    var out = V3BioDidHardwareAttestation()
    out.version = v3BioDidHardwareAttestationVersion
    out.requestId = capture.requestId
    out.sensorId = capture.sensorId
    out.verifiedAtEpochSeconds = did.v3DidWord64FromInt64(epochSeconds)
    out.deviceBindingSeedHash = v3BioDidDeviceBindingSeedHash(capture.deviceBindingSeed)
    out.attestationText = capture.hardwareAttestation
    out.attestationCid = v3BioDidHardwareAttestationCid(capture.hardwareAttestation)
    out.bindingCid = v3BioDidHardwareBindingCid(out,
                                                action,
                                                didText,
                                                devicePeerId,
                                                documentVersion,
                                                bundleSeq,
                                                challengeNonce)
    return out

fn v3BioDidChainBundleText(bundle: V3BioDidChainBundle): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out, "v3_bio_did_bundle_version", v3BioDidBundleVersionText)
    out = did.v3DidStoreAppendLine(out, "action", bundle.action)
    out = did.v3DidStoreAppendLine(out, "bundle_seq", strings.IntToStr(bundle.bundleSeq))
    out = did.v3DidStoreAppendLine(out, "did", bundle.didText)
    out = did.v3DidStoreAppendLine(out, "device_peer_id", peer_id.v3Libp2pPeerIdText(bundle.devicePeerId))
    out = did.v3DidStoreAppendLine(out, "document_text", did.v3DidStoreEncodeText(bundle.documentText))
    out = did.v3DidStoreAppendLine(out, "record_version", strings.IntToStr(bundle.record.version))
    out = did.v3DidStoreAppendLine(out, "record_helper", layout.fixedBytes32Hex(bundle.record.helper))
    out = did.v3DidStoreAppendLine(out, "record_pub_key", layout.fixedBytes65Hex(bundle.record.pubKey))
    out = did.v3DidStoreAppendLine(out, "record_code_n", strings.IntToStr(bundle.record.codeN))
    out = did.v3DidStoreAppendLine(out, "record_code_k", strings.IntToStr(bundle.record.codeK))
    out = did.v3DidStoreAppendLine(out, "record_max_correctable", strings.IntToStr(bundle.record.maxCorrectable))
    out = did.v3DidStoreAppendLine(out, "record_cid", layout.fixedBytes32Hex(bundle.record.recordCid))
    out = did.v3DidStoreAppendLine(out, "challenge_nonce", layout.fixedBytes32Hex(bundle.assertion.challengeNonce))
    out = did.v3DidStoreAppendLine(out, "assert_commit_a", layout.fixedBytes65Hex(bundle.assertion.commitA))
    out = did.v3DidStoreAppendLine(out, "assert_response_z", layout.fixedBytes32Hex(bundle.assertion.responseZ))
    out = did.v3DidStoreAppendLine(out, "assert_proof_cid", layout.fixedBytes32Hex(bundle.assertion.proofCid))
    out = did.v3DidStoreAppendLine(out, "hardware_version", strings.IntToStr(bundle.hardware.version))
    out = did.v3DidStoreAppendLine(out, "hardware_request_id", did.v3DidStoreEncodeText(bundle.hardware.requestId))
    out = did.v3DidStoreAppendLine(out, "hardware_sensor_id", did.v3DidStoreEncodeText(bundle.hardware.sensorId))
    out = did.v3DidStoreAppendLine(out, "hardware_verified_at", did.v3DidStoreWord64Hex(bundle.hardware.verifiedAtEpochSeconds))
    out = did.v3DidStoreAppendLine(out, "hardware_device_binding_seed_hash", layout.fixedBytes32Hex(bundle.hardware.deviceBindingSeedHash))
    out = did.v3DidStoreAppendLine(out, "hardware_attestation_text", did.v3DidStoreEncodeText(bundle.hardware.attestationText))
    out = did.v3DidStoreAppendLine(out, "hardware_attestation_cid", layout.fixedBytes32Hex(bundle.hardware.attestationCid))
    out = did.v3DidStoreAppendLine(out, "hardware_binding_cid", layout.fixedBytes32Hex(bundle.hardware.bindingCid))
    return out

fn v3BioDidChainBundleHeaderParseText(text: str): Result[V3BioDidChainBundleHeader] =
    if strings.Len(text) <= 0:
        return Err[V3BioDidChainBundleHeader]("v3 bio did: missing bundle text")
    let lines = strutil.Split(text, '\n')
    let versionRes = did.v3DidStoreFindValue(lines, "v3_bio_did_bundle_version")
    if IsErr(versionRes):
        return Err[V3BioDidChainBundleHeader](Error(versionRes))
    if Value(versionRes) != v3BioDidBundleVersionText:
        return Err[V3BioDidChainBundleHeader]("v3 bio did: unsupported bundle version")
    let actionRes = did.v3DidStoreFindValue(lines, "action")
    if IsErr(actionRes):
        return Err[V3BioDidChainBundleHeader](Error(actionRes))
    if !v3BioDidActionValid(Value(actionRes)):
        return Err[V3BioDidChainBundleHeader]("v3 bio did: invalid bundle action")
    let bundleSeqTextRes = did.v3DidStoreFindValue(lines, "bundle_seq")
    if IsErr(bundleSeqTextRes):
        return Err[V3BioDidChainBundleHeader](Error(bundleSeqTextRes))
    let didTextRes = did.v3DidStoreFindValue(lines, "did")
    if IsErr(didTextRes):
        return Err[V3BioDidChainBundleHeader](Error(didTextRes))
    let parsedSeqRes = v3BioDidParseInt32Field("bundle_seq", Value(bundleSeqTextRes))
    if IsErr(parsedSeqRes):
        return Err[V3BioDidChainBundleHeader](Error(parsedSeqRes))
    if Value(parsedSeqRes) <= 0:
        return Err[V3BioDidChainBundleHeader]("v3 bio did: invalid bundle seq")
    let didText = Value(didTextRes)
    if strings.Len(didText) <= 0:
        return Err[V3BioDidChainBundleHeader]("v3 bio did: bundle did required")
    var out: V3BioDidChainBundleHeader
    out.action = Value(actionRes)
    out.bundleSeq = Value(parsedSeqRes)
    out.didText = didText
    out.bundleCid = v3BioDidBundleCid(text)
    return Ok[V3BioDidChainBundleHeader](out)

fn v3BioDidChainBundleVerify(bundle: V3BioDidChainBundle): Result[did.V3DidDocument] =
    if !v3BioDidActionValid(bundle.action):
        return Err[did.V3DidDocument]("v3 bio did: invalid bundle action")
    if bundle.bundleSeq <= 0:
        return Err[did.V3DidDocument]("v3 bio did: invalid bundle seq")
    let documentRes = did.v3DidDocumentParseText(bundle.documentText)
    if IsErr(documentRes):
        return Err[did.V3DidDocument](Error(documentRes))
    let document = Value(documentRes)
    let canonicalDocumentTextRes = did.v3DidDocumentBuildText(document)
    if IsErr(canonicalDocumentTextRes):
        return Err[did.V3DidDocument](Error(canonicalDocumentTextRes))
    if !v3BioDidTextEqual(Value(canonicalDocumentTextRes), bundle.documentText):
        return Err[did.V3DidDocument]("v3 bio did: non canonical document text")
    if !v3BioDidTextEqual(document.did, bundle.didText):
        return Err[did.V3DidDocument]("v3 bio did: bundle did mismatch")
    let devicePos = did.v3DidDocumentFindDevicePos(document, bundle.devicePeerId)
    if devicePos < 0:
        return Err[did.V3DidDocument]("v3 bio did: device missing from document")
    if document.devices[devicePos].status != did.v3DidDeviceStatusActive:
        return Err[did.V3DidDocument]("v3 bio did: device not active")
    let wantNonce = v3BioDidChallengeNonce(bundle.action,
                                           bundle.didText,
                                           bundle.devicePeerId,
                                           document.version,
                                           bundle.bundleSeq)
    if !layout.fixedBytes32Equal(bundle.assertion.challengeNonce, wantNonce):
        return Err[did.V3DidDocument]("v3 bio did: challenge nonce mismatch")
    let hardwareOk = v3BioDidHardwareAttestationValidate(bundle.hardware,
                                                         bundle.action,
                                                         bundle.didText,
                                                         bundle.devicePeerId,
                                                         document.version,
                                                         bundle.bundleSeq,
                                                         wantNonce)
    if IsErr(hardwareOk):
        return Err[did.V3DidDocument](Error(hardwareOk))
    let verifyRes = bio.v3BioVerify(bundle.record, wantNonce, bundle.assertion)
    if IsErr(verifyRes):
        return Err[did.V3DidDocument](Error(verifyRes))
    if !Value(verifyRes):
        return Err[did.V3DidDocument]("v3 bio did: assertion verify failed")
    let canonicalBundleText = v3BioDidChainBundleText(bundle)
    let wantCid = v3BioDidBundleCid(canonicalBundleText)
    if !layout.fixedBytes32Equal(bundle.bundleCid, wantCid):
        return Err[did.V3DidDocument]("v3 bio did: bundle cid mismatch")
    return Ok[did.V3DidDocument](document)

fn v3BioDidChainBundleMake(action: str,
                           bundleSeq: int32,
                           document: did.V3DidDocument,
                           devicePeerId: types.V3Libp2pPeerId,
                           record: bio.V3BioEnrollmentRecord,
                           assertion: bio.V3BioAssertion,
                           hardware: V3BioDidHardwareAttestation): Result[V3BioDidChainBundle] =
    let documentTextRes = did.v3DidDocumentBuildText(document)
    if IsErr(documentTextRes):
        return Err[V3BioDidChainBundle](Error(documentTextRes))
    var out = V3BioDidChainBundle()
    out.action = action
    out.bundleSeq = bundleSeq
    out.didText = document.did
    out.devicePeerId = devicePeerId
    out.documentText = Value(documentTextRes)
    out.record = record
    out.assertion = assertion
    out.hardware = hardware
    out.bundleCid = v3BioDidBundleCid(v3BioDidChainBundleText(out))
    let verifyRes = v3BioDidChainBundleVerify(out)
    if IsErr(verifyRes):
        return Err[V3BioDidChainBundle](Error(verifyRes))
    return Ok[V3BioDidChainBundle](out)

fn v3BioDidChainBundleParseRecord(lines: str[]): Result[bio.V3BioEnrollmentRecord] =
    let recordVersionTextRes = did.v3DidStoreFindValue(lines, "record_version")
    if IsErr(recordVersionTextRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordVersionTextRes))
    let recordHelperTextRes = did.v3DidStoreFindValue(lines, "record_helper")
    if IsErr(recordHelperTextRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordHelperTextRes))
    let recordPubKeyTextRes = did.v3DidStoreFindValue(lines, "record_pub_key")
    if IsErr(recordPubKeyTextRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordPubKeyTextRes))
    let recordCodeNTextRes = did.v3DidStoreFindValue(lines, "record_code_n")
    if IsErr(recordCodeNTextRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordCodeNTextRes))
    let recordCodeKTextRes = did.v3DidStoreFindValue(lines, "record_code_k")
    if IsErr(recordCodeKTextRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordCodeKTextRes))
    let recordMaxCorrectableTextRes = did.v3DidStoreFindValue(lines, "record_max_correctable")
    if IsErr(recordMaxCorrectableTextRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordMaxCorrectableTextRes))
    let recordCidTextRes = did.v3DidStoreFindValue(lines, "record_cid")
    if IsErr(recordCidTextRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordCidTextRes))
    let recordVersionRes = v3BioDidParseInt32Field("record_version", Value(recordVersionTextRes))
    if IsErr(recordVersionRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordVersionRes))
    let recordHelperRes = layout.fixedBytes32FromHex(Value(recordHelperTextRes))
    if IsErr(recordHelperRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordHelperRes))
    let recordPubKeyRes = layout.fixedBytes65FromHex(Value(recordPubKeyTextRes))
    if IsErr(recordPubKeyRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordPubKeyRes))
    let recordCodeNRes = v3BioDidParseInt32Field("record_code_n", Value(recordCodeNTextRes))
    if IsErr(recordCodeNRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordCodeNRes))
    let recordCodeKRes = v3BioDidParseInt32Field("record_code_k", Value(recordCodeKTextRes))
    if IsErr(recordCodeKRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordCodeKRes))
    let recordMaxCorrectableRes = v3BioDidParseInt32Field("record_max_correctable", Value(recordMaxCorrectableTextRes))
    if IsErr(recordMaxCorrectableRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordMaxCorrectableRes))
    let recordCidRes = layout.fixedBytes32FromHex(Value(recordCidTextRes))
    if IsErr(recordCidRes):
        return Err[bio.V3BioEnrollmentRecord](Error(recordCidRes))
    var record = bio.V3BioEnrollmentRecord()
    record.version = Value(recordVersionRes)
    record.helper = Value(recordHelperRes)
    record.pubKey = Value(recordPubKeyRes)
    record.codeN = Value(recordCodeNRes)
    record.codeK = Value(recordCodeKRes)
    record.maxCorrectable = Value(recordMaxCorrectableRes)
    record.recordCid = Value(recordCidRes)
    return Ok[bio.V3BioEnrollmentRecord](record)

fn v3BioDidChainBundleParseAssertion(lines: str,
                                     recordCid: layout.FixedBytes32): Result[bio.V3BioAssertion] =
    let challengeNonceTextRes = did.v3DidStoreFindValue(lines, "challenge_nonce")
    if IsErr(challengeNonceTextRes):
        return Err[bio.V3BioAssertion](Error(challengeNonceTextRes))
    let assertCommitATextRes = did.v3DidStoreFindValue(lines, "assert_commit_a")
    if IsErr(assertCommitATextRes):
        return Err[bio.V3BioAssertion](Error(assertCommitATextRes))
    let assertResponseZTextRes = did.v3DidStoreFindValue(lines, "assert_response_z")
    if IsErr(assertResponseZTextRes):
        return Err[bio.V3BioAssertion](Error(assertResponseZTextRes))
    let assertProofCidTextRes = did.v3DidStoreFindValue(lines, "assert_proof_cid")
    if IsErr(assertProofCidTextRes):
        return Err[bio.V3BioAssertion](Error(assertProofCidTextRes))
    let challengeNonceRes = layout.fixedBytes32FromHex(Value(challengeNonceTextRes))
    if IsErr(challengeNonceRes):
        return Err[bio.V3BioAssertion](Error(challengeNonceRes))
    let assertCommitARes = layout.fixedBytes65FromHex(Value(assertCommitATextRes))
    if IsErr(assertCommitARes):
        return Err[bio.V3BioAssertion](Error(assertCommitARes))
    let assertResponseZRes = layout.fixedBytes32FromHex(Value(assertResponseZTextRes))
    if IsErr(assertResponseZRes):
        return Err[bio.V3BioAssertion](Error(assertResponseZRes))
    let assertProofCidRes = layout.fixedBytes32FromHex(Value(assertProofCidTextRes))
    if IsErr(assertProofCidRes):
        return Err[bio.V3BioAssertion](Error(assertProofCidRes))
    var assertion = bio.V3BioAssertion()
    assertion.recordCid = recordCid
    assertion.challengeNonce = Value(challengeNonceRes)
    assertion.commitA = Value(assertCommitARes)
    assertion.responseZ = Value(assertResponseZRes)
    assertion.proofCid = Value(assertProofCidRes)
    return Ok[bio.V3BioAssertion](assertion)

fn v3BioDidChainBundleParseHardware(lines: str): Result[V3BioDidHardwareAttestation] =
    let hardwareVersionTextRes = did.v3DidStoreFindValue(lines, "hardware_version")
    if IsErr(hardwareVersionTextRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareVersionTextRes))
    let hardwareRequestIdTextRes = did.v3DidStoreFindValue(lines, "hardware_request_id")
    if IsErr(hardwareRequestIdTextRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareRequestIdTextRes))
    let hardwareSensorIdTextRes = did.v3DidStoreFindValue(lines, "hardware_sensor_id")
    if IsErr(hardwareSensorIdTextRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareSensorIdTextRes))
    let hardwareVerifiedAtTextRes = did.v3DidStoreFindValue(lines, "hardware_verified_at")
    if IsErr(hardwareVerifiedAtTextRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareVerifiedAtTextRes))
    let hardwareDeviceBindingSeedHashTextRes = did.v3DidStoreFindValue(lines, "hardware_device_binding_seed_hash")
    if IsErr(hardwareDeviceBindingSeedHashTextRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareDeviceBindingSeedHashTextRes))
    let hardwareAttestationTextRes = did.v3DidStoreFindValue(lines, "hardware_attestation_text")
    if IsErr(hardwareAttestationTextRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareAttestationTextRes))
    let hardwareAttestationCidTextRes = did.v3DidStoreFindValue(lines, "hardware_attestation_cid")
    if IsErr(hardwareAttestationCidTextRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareAttestationCidTextRes))
    let hardwareBindingCidTextRes = did.v3DidStoreFindValue(lines, "hardware_binding_cid")
    if IsErr(hardwareBindingCidTextRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareBindingCidTextRes))
    let hardwareVersionRes = v3BioDidParseInt32Field("hardware_version", Value(hardwareVersionTextRes))
    if IsErr(hardwareVersionRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareVersionRes))
    let hardwareRequestIdBytesRes = did.v3DidStoreDecodeBytes(Value(hardwareRequestIdTextRes))
    if IsErr(hardwareRequestIdBytesRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareRequestIdBytesRes))
    let hardwareSensorIdBytesRes = did.v3DidStoreDecodeBytes(Value(hardwareSensorIdTextRes))
    if IsErr(hardwareSensorIdBytesRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareSensorIdBytesRes))
    let hardwareVerifiedAtRes = did.v3DidStoreParseWord64Hex(Value(hardwareVerifiedAtTextRes))
    if IsErr(hardwareVerifiedAtRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareVerifiedAtRes))
    let hardwareDeviceBindingSeedHashRes = layout.fixedBytes32FromHex(Value(hardwareDeviceBindingSeedHashTextRes))
    if IsErr(hardwareDeviceBindingSeedHashRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareDeviceBindingSeedHashRes))
    let hardwareAttestationBytesRes = did.v3DidStoreDecodeBytes(Value(hardwareAttestationTextRes))
    if IsErr(hardwareAttestationBytesRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareAttestationBytesRes))
    let hardwareAttestationCidRes = layout.fixedBytes32FromHex(Value(hardwareAttestationCidTextRes))
    if IsErr(hardwareAttestationCidRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareAttestationCidRes))
    let hardwareBindingCidRes = layout.fixedBytes32FromHex(Value(hardwareBindingCidTextRes))
    if IsErr(hardwareBindingCidRes):
        return Err[V3BioDidHardwareAttestation](Error(hardwareBindingCidRes))
    var hardware = V3BioDidHardwareAttestation()
    hardware.version = Value(hardwareVersionRes)
    hardware.requestId = bytesToString(Value(hardwareRequestIdBytesRes))
    hardware.sensorId = bytesToString(Value(hardwareSensorIdBytesRes))
    hardware.verifiedAtEpochSeconds = Value(hardwareVerifiedAtRes)
    hardware.deviceBindingSeedHash = Value(hardwareDeviceBindingSeedHashRes)
    hardware.attestationText = bytesToString(Value(hardwareAttestationBytesRes))
    hardware.attestationCid = Value(hardwareAttestationCidRes)
    hardware.bindingCid = Value(hardwareBindingCidRes)
    return Ok[V3BioDidHardwareAttestation](hardware)

fn v3BioDidChainBundleParseText(text: str): Result[V3BioDidChainBundle] =
    let textLen = strings.Len(text)
    if textLen <= 0:
        return Err[V3BioDidChainBundle]("v3 bio did: missing bundle text")
    let lines = strutil.Split(text, '\n')
    let versionRes = did.v3DidStoreFindValue(lines, "v3_bio_did_bundle_version")
    if IsErr(versionRes):
        return Err[V3BioDidChainBundle](Error(versionRes))
    if Value(versionRes) != v3BioDidBundleVersionText:
        return Err[V3BioDidChainBundle]("v3 bio did: unsupported bundle version")
    let actionRes = did.v3DidStoreFindValue(lines, "action")
    if IsErr(actionRes):
        return Err[V3BioDidChainBundle](Error(actionRes))
    let bundleSeqRes = did.v3DidStoreFindValue(lines, "bundle_seq")
    if IsErr(bundleSeqRes):
        return Err[V3BioDidChainBundle](Error(bundleSeqRes))
    let didTextRes = did.v3DidStoreFindValue(lines, "did")
    if IsErr(didTextRes):
        return Err[V3BioDidChainBundle](Error(didTextRes))
    let devicePeerTextRes = did.v3DidStoreFindValue(lines, "device_peer_id")
    if IsErr(devicePeerTextRes):
        return Err[V3BioDidChainBundle](Error(devicePeerTextRes))
    let documentTextHexRes = did.v3DidStoreFindValue(lines, "document_text")
    if IsErr(documentTextHexRes):
        return Err[V3BioDidChainBundle](Error(documentTextHexRes))
    let parsedSeqRes = v3BioDidParseInt32Field("bundle_seq", Value(bundleSeqRes))
    if IsErr(parsedSeqRes):
        return Err[V3BioDidChainBundle](Error(parsedSeqRes))
    let devicePeerRes = did.v3DidPeerIdFromHex(Value(devicePeerTextRes))
    if IsErr(devicePeerRes):
        return Err[V3BioDidChainBundle](Error(devicePeerRes))
    let documentBytesRes = did.v3DidStoreDecodeBytes(Value(documentTextHexRes))
    if IsErr(documentBytesRes):
        return Err[V3BioDidChainBundle](Error(documentBytesRes))
    let recordRes = v3BioDidChainBundleParseRecord(lines)
    if IsErr(recordRes):
        return Err[V3BioDidChainBundle](Error(recordRes))
    let assertionRes = v3BioDidChainBundleParseAssertion(lines, Value(recordRes).recordCid)
    if IsErr(assertionRes):
        return Err[V3BioDidChainBundle](Error(assertionRes))
    let hardwareRes = v3BioDidChainBundleParseHardware(lines)
    if IsErr(hardwareRes):
        return Err[V3BioDidChainBundle](Error(hardwareRes))
    var out = V3BioDidChainBundle()
    out.action = Value(actionRes)
    out.bundleSeq = Value(parsedSeqRes)
    out.didText = Value(didTextRes)
    out.devicePeerId = Value(devicePeerRes)
    out.documentText = bytesToString(Value(documentBytesRes))
    out.record = Value(recordRes)
    out.assertion = Value(assertionRes)
    out.hardware = Value(hardwareRes)
    out.bundleCid = v3BioDidBundleCid(text)
    let verifyRes = v3BioDidChainBundleVerify(out)
    if IsErr(verifyRes):
        return Err[V3BioDidChainBundle](Error(verifyRes))
    if !v3BioDidTextEqual(v3BioDidChainBundleText(out), text):
        return Err[V3BioDidChainBundle]("v3 bio did: non canonical bundle text")
    out.bundleCid = v3BioDidBundleCid(text)
    return Ok[V3BioDidChainBundle](out)

fn v3BioDidChainCurrentBundleSeq(node: var chain.V3ChainNode, didText: str): int32 =
    let accountId = v3BioDidChainAccountId(didText)
    var maxSeq = 0
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.v3ConsensusKindMint:
            continue
        if event.assetId != v3BioDidChainAssetId:
            continue
        if event.toAccount != accountId:
            continue
        if event.fromAccount > maxSeq:
            maxSeq = event.fromAccount
    return maxSeq

fn v3BioDidChunkCount(payloadLen: int32): int32 =
    if payloadLen <= 28:
        return 1
    return 1 + ((payloadLen - 28 + 31) / 32)

fn v3BioDidChunkFixed(payload: Bytes, chunkIndex: int32): layout.FixedBytes32 =
    let raw = bytesAlloc(32)
    for i in 0..<32:
        bytesSet(raw, i, 0)
    if chunkIndex == 0:
        bytesSet(raw, 0, (payload.len >> 24) & 255)
        bytesSet(raw, 1, (payload.len >> 16) & 255)
        bytesSet(raw, 2, (payload.len >> 8) & 255)
        bytesSet(raw, 3, payload.len & 255)
        var copied = 0
        var limit = payload.len
        if limit > 28:
            limit = 28
        while copied < limit:
            bytesSet(raw, 4 + copied, bytesGet(payload, copied))
            copied = copied + 1
    else:
        let start = 28 + ((chunkIndex - 1) * 32)
        var copied = 0
        while copied < 32 && (start + copied) < payload.len:
            bytesSet(raw, copied, bytesGet(payload, start + copied))
            copied = copied + 1
    let fixedRes = layout.fixedBytes32FromBytes(raw)
    assert(IsOk(fixedRes), "v3 bio did: chunk fixed32")
    return Value(fixedRes)

fn v3BioDidChunksToPayload(chunks: layout.FixedBytes32[]): Result[Bytes] =
    if chunks.len <= 0:
        return Err[Bytes]("v3 bio did: missing chunks")
    let head = layout.fixedBytes32ToBytes(chunks[0])
    let payloadLen = int32(
        int64(bytesGet(head, 0) & 255) * int64(16777216) +
        int64(bytesGet(head, 1) & 255) * int64(65536) +
        int64(bytesGet(head, 2) & 255) * int64(256) +
        int64(bytesGet(head, 3) & 255)
    )
    if payloadLen < 0:
        return Err[Bytes]("v3 bio did: invalid chunk length")
    let wantChunkCount = v3BioDidChunkCount(payloadLen)
    if wantChunkCount != chunks.len:
        return Err[Bytes]("v3 bio did: chunk count mismatch")
    let out = bytesAlloc(payloadLen)
    var copied = 0
    var headPos = 4
    while headPos < 32 && copied < payloadLen:
        bytesSet(out, copied, bytesGet(head, headPos))
        copied = copied + 1
        headPos = headPos + 1
    for i in 1..<chunks.len:
        let chunkBytes = layout.fixedBytes32ToBytes(chunks[i])
        var j = 0
        while j < 32 && copied < payloadLen:
            bytesSet(out, copied, bytesGet(chunkBytes, j))
            copied = copied + 1
            j = j + 1
    if copied != payloadLen:
        return Err[Bytes]("v3 bio did: payload size mismatch")
    return Ok[Bytes](out)

fn v3BioDidChainAppendBundle(node: var chain.V3ChainNode,
                             bundle: V3BioDidChainBundle): Result[layout.FixedBytes32] =
    let verifyRes = v3BioDidChainBundleVerify(bundle)
    if IsErr(verifyRes):
        return Err[layout.FixedBytes32](Error(verifyRes))
    let expectedSeq = v3BioDidChainCurrentBundleSeq(node, bundle.didText) + 1
    if bundle.bundleSeq != expectedSeq:
        return Err[layout.FixedBytes32]("v3 bio did: bundle seq mismatch")
    let requestSeenRes = v3BioDidChainRequestIdSeen(node, bundle.didText, bundle.hardware.requestId)
    if IsErr(requestSeenRes):
        return Err[layout.FixedBytes32](Error(requestSeenRes))
    if Value(requestSeenRes):
        return Err[layout.FixedBytes32]("v3 bio did: duplicated hardware request id")
    let accountId = v3BioDidChainAccountId(bundle.didText)
    let payload = bytesFromString(v3BioDidChainBundleText(bundle))
    let chunkCount = v3BioDidChunkCount(payload.len)
    var lastEventCid = layout.FixedBytes32()
    for chunkIndex in 0..<chunkCount:
        let parentCid = chain.v3ChainNodeAccountHead(node.index, v3BioDidChainAssetId, accountId)
        var event = consensus.v3ChainEventMint(v3BioDidChainAssetId,
                                               accountId,
                                               parentCid,
                                               int64(chunkIndex + 1),
                                               node.nextEpoch,
                                               node.nextGanzhi,
                                               chain.v3ChainNodeSpaceSlot(accountId, accountId),
                                               node.nextTick)
        event.fromAccount = bundle.bundleSeq
        event.fromParentCid = v3BioDidChunkFixed(payload, chunkIndex)
        event.bodyCid = consensus.v3ChainEventBodyCid(event)
        let applyRes = chain.v3ChainNodeApplyEvent(node, event)
        if IsErr(applyRes):
            return Err[layout.FixedBytes32](Error(applyRes))
        lastEventCid = Value(applyRes)
    return Ok[layout.FixedBytes32](lastEventCid)

fn v3BioDidChainLoadTextForSeq(node: var chain.V3ChainNode,
                               didText: str,
                               bundleSeq: int32): Result[str] =
    let accountId = v3BioDidChainAccountId(didText)
    return v3BioDidChainLoadTextForAccountSeq(node, accountId, bundleSeq)

fn v3BioDidChainLoadTextForAccountSeq(node: var chain.V3ChainNode,
                                      accountId: int32,
                                      bundleSeq: int32): Result[str] =
    var maxOrdinal = 0
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.v3ConsensusKindMint:
            continue
        if event.assetId != v3BioDidChainAssetId:
            continue
        if event.toAccount != accountId:
            continue
        if event.fromAccount != bundleSeq:
            continue
        let ordinal = int32(event.amount)
        if int64(ordinal) != event.amount:
            return Err[str]("v3 bio did: chunk ordinal overflow")
        if ordinal > maxOrdinal:
            maxOrdinal = ordinal
    if maxOrdinal <= 0:
        return Err[str]("v3 bio did: bundle seq missing")
    var chunks: layout.FixedBytes32[]
    var ordinal = 1
    while ordinal <= maxOrdinal:
        var foundCount = 0
        var chunk = layout.FixedBytes32()
        for i in 0..<node.events.len:
            let event = node.events[i]
            if event.kind != consensus.v3ConsensusKindMint:
                continue
            if event.assetId != v3BioDidChainAssetId:
                continue
            if event.toAccount != accountId:
                continue
            if event.fromAccount != bundleSeq:
                continue
            if event.amount != int64(ordinal):
                continue
            foundCount = foundCount + 1
            chunk = event.fromParentCid
        if foundCount != 1:
            return Err[str]("v3 bio did: chunk multiplicity mismatch")
        add(chunks, chunk)
        ordinal = ordinal + 1
    let payloadRes = v3BioDidChunksToPayload(chunks)
    if IsErr(payloadRes):
        return Err[str](Error(payloadRes))
    return Ok[str](bytesToString(Value(payloadRes)))

fn v3BioDidChainLatestBundles(node: var chain.V3ChainNode): Result[V3BioDidChainBundle[]] =
    var accountIds: int32[]
    accountIds = []
    var maxSeqs: int32[]
    maxSeqs = []
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.v3ConsensusKindMint:
            continue
        if event.assetId != v3BioDidChainAssetId:
            continue
        let accountId = event.toAccount
        let bundleSeq = event.fromAccount
        var slot = -1
        for j in 0..<accountIds.len:
            if accountIds[j] == accountId:
                slot = j
                break
        if slot < 0:
            add(accountIds, accountId)
            add(maxSeqs, bundleSeq)
            continue
        if bundleSeq > maxSeqs[slot]:
            maxSeqs[slot] = bundleSeq
    var out: V3BioDidChainBundle[]
    out = []
    for i in 0..<accountIds.len:
        let textRes = v3BioDidChainLoadTextForAccountSeq(node, accountIds[i], maxSeqs[i])
        if IsErr(textRes):
            return Err[V3BioDidChainBundle[]](Error(textRes))
        let bundleRes = v3BioDidChainBundleParseText(Value(textRes))
        if IsErr(bundleRes):
            return Err[V3BioDidChainBundle[]](Error(bundleRes))
        let bundle = Value(bundleRes)
        if bundle.bundleSeq != maxSeqs[i]:
            return Err[V3BioDidChainBundle[]]("v3 bio did: latest bundle seq mismatch")
        add(out, bundle)
    return Ok[V3BioDidChainBundle[]](out)

fn v3BioDidChainLoadLatest(node: var chain.V3ChainNode,
                           didText: str): Result[V3BioDidChainBundle] =
    let bundleSeq = v3BioDidChainCurrentBundleSeq(node, didText)
    if bundleSeq <= 0:
        return Err[V3BioDidChainBundle]("v3 bio did: did not found on chain")
    let textRes = v3BioDidChainLoadTextForSeq(node, didText, bundleSeq)
    if IsErr(textRes):
        return Err[V3BioDidChainBundle](Error(textRes))
    let bundleRes = v3BioDidChainBundleParseText(Value(textRes))
    if IsErr(bundleRes):
        return Err[V3BioDidChainBundle](Error(bundleRes))
    if Value(bundleRes).bundleSeq != bundleSeq:
        return Err[V3BioDidChainBundle]("v3 bio did: latest bundle seq mismatch")
    if !v3BioDidTextEqual(Value(bundleRes).didText, didText):
        return Err[V3BioDidChainBundle]("v3 bio did: latest bundle did mismatch")
    return Ok[V3BioDidChainBundle](Value(bundleRes))

fn v3BioDidOperatorIdFromRecoverySecretHex(recoverySecretHex: str): Result[layout.FixedBytes32] =
    let secretRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(recoverySecretHex)
    if IsErr(secretRes):
        return Err[layout.FixedBytes32](Error(secretRes))
    return Ok[layout.FixedBytes32](
        did.v3DidHashTagged(v3BioDidOperatorTag, layout.fixedBytes32Hex(Value(secretRes)))
    )

fn v3BioDidOperatorAnchorLegacyText(anchor: V3BioDidOperatorAnchor): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out,
                                   "v3_bio_did_operator_anchor_version",
                                   v3BioDidOperatorAnchorVersionTextLegacy)
    out = did.v3DidStoreAppendLine(out, "operator_id", layout.fixedBytes32Hex(anchor.operatorId))
    out = did.v3DidStoreAppendLine(out, "recovery_mode", anchor.recoveryMode)
    out = did.v3DidStoreAppendLine(out, "did", anchor.didText)
    out = did.v3DidStoreAppendLine(out, "bundle_seq", strings.IntToStr(anchor.bundleSeq))
    out = did.v3DidStoreAppendLine(out, "bundle_cid", layout.fixedBytes32Hex(anchor.bundleCid))
    out = did.v3DidStoreAppendLine(out, "bundle_text", did.v3DidStoreEncodeText(anchor.bundleText))
    out = did.v3DidStoreAppendLine(out, "event_id", did.v3DidStoreEncodeText(anchor.eventId))
    return out

fn v3BioDidOperatorAnchorText(anchor: V3BioDidOperatorAnchor): str =
    var out = ""
    out = did.v3DidStoreAppendLine(out, "v3_bio_did_operator_anchor_version", v3BioDidOperatorAnchorVersionText)
    out = did.v3DidStoreAppendLine(out, "operator_id", layout.fixedBytes32Hex(anchor.operatorId))
    out = did.v3DidStoreAppendLine(out, "bundle_kind", v3BioDidOperatorBundleKindNormalize(anchor.bundleKind))
    out = did.v3DidStoreAppendLine(out, "recovery_mode", anchor.recoveryMode)
    out = did.v3DidStoreAppendLine(out, "did", anchor.didText)
    out = did.v3DidStoreAppendLine(out, "subject_did", anchor.subjectDidText)
    out = did.v3DidStoreAppendLine(out, "device_did", anchor.deviceDidText)
    out = did.v3DidStoreAppendLine(out, "bundle_seq", strings.IntToStr(anchor.bundleSeq))
    out = did.v3DidStoreAppendLine(out, "bundle_cid", layout.fixedBytes32Hex(anchor.bundleCid))
    out = did.v3DidStoreAppendLine(out, "bundle_text", did.v3DidStoreEncodeText(anchor.bundleText))
    out = did.v3DidStoreAppendLine(out, "event_id", did.v3DidStoreEncodeText(anchor.eventId))
    return out

fn v3BioDidOperatorAnchorVerify(anchor: V3BioDidOperatorAnchor): Result[bool] =
    if layout.fixedBytes32Equal(anchor.operatorId, layout.FixedBytes32()):
        return Err[bool]("v3 bio did: operator id required")
    let normalizedBundleKind = v3BioDidOperatorBundleKindNormalize(anchor.bundleKind)
    if strings.Len(normalizedBundleKind) <= 0:
        return Err[bool]("v3 bio did: operator bundle kind required")
    if !v3BioDidTextEqual(anchor.recoveryMode, v3BioDidRecoveryModeSecretV1):
        return Err[bool]("v3 bio did: unsupported operator recovery mode")
    let anchorDidText = anchor.didText
    if strings.Len(anchorDidText) <= 0:
        return Err[bool]("v3 bio did: operator did required")
    let anchorSubjectDidText = anchor.subjectDidText
    if strings.Len(anchorSubjectDidText) <= 0:
        return Err[bool]("v3 bio did: operator subject did required")
    let anchorDeviceDidText = anchor.deviceDidText
    if strings.Len(anchorDeviceDidText) <= 0:
        return Err[bool]("v3 bio did: operator device did required")
    if !v3BioDidTextEqual(anchorDidText, anchorSubjectDidText):
        return Err[bool]("v3 bio did: operator primary did mismatch")
    if anchor.bundleSeq <= 0:
        return Err[bool]("v3 bio did: operator bundle seq required")
    if layout.fixedBytes32Equal(anchor.bundleCid, layout.FixedBytes32()):
        return Err[bool]("v3 bio did: operator bundle cid required")
    let anchorBundleText = anchor.bundleText
    if strings.Len(anchorBundleText) <= 0:
        return Err[bool]("v3 bio did: operator bundle text required")
    let anchorEventId = anchor.eventId
    if strings.Len(anchorEventId) <= 0:
        return Err[bool]("v3 bio did: operator event id required")
    let headerRes = v3BioDidChainBundleHeaderParseText(anchorBundleText)
    if IsErr(headerRes):
        return Err[bool](Error(headerRes))
    let header = Value(headerRes)
    if !v3BioDidTextEqual(header.didText, anchorDidText):
        return Err[bool]("v3 bio did: operator did mismatch")
    if header.bundleSeq != anchor.bundleSeq:
        return Err[bool]("v3 bio did: operator bundle seq mismatch")
    if !layout.fixedBytes32Equal(header.bundleCid, anchor.bundleCid):
        return Err[bool]("v3 bio did: operator bundle cid mismatch")
    return Ok[bool](true)

fn v3BioDidOperatorAnchorParseText(text: str): Result[V3BioDidOperatorAnchor] =
    if strings.Len(text) <= 0:
        return Err[V3BioDidOperatorAnchor]("v3 bio did: missing operator anchor text")
    let lines = strutil.Split(text, '\n')
    let versionRes = did.v3DidStoreFindValue(lines, "v3_bio_did_operator_anchor_version")
    if IsErr(versionRes):
        return Err[V3BioDidOperatorAnchor](Error(versionRes))
    let versionText = Value(versionRes)
    let isV2 = v3BioDidTextEqual(versionText, v3BioDidOperatorAnchorVersionText)
    let isV1 = v3BioDidTextEqual(versionText, v3BioDidOperatorAnchorVersionTextLegacy)
    if !isV2 && !isV1:
        return Err[V3BioDidOperatorAnchor]("v3 bio did: unsupported operator anchor version")
    let operatorIdTextRes = did.v3DidStoreFindValue(lines, "operator_id")
    if IsErr(operatorIdTextRes):
        return Err[V3BioDidOperatorAnchor](Error(operatorIdTextRes))
    var bundleKindText = v3BioDidOperatorBundleKindAndroidBioV1
    if isV2:
        let bundleKindTextRes = did.v3DidStoreFindValue(lines, "bundle_kind")
        if IsErr(bundleKindTextRes):
            return Err[V3BioDidOperatorAnchor](Error(bundleKindTextRes))
        bundleKindText = v3BioDidOperatorBundleKindNormalize(Value(bundleKindTextRes))
    let recoveryModeRes = did.v3DidStoreFindValue(lines, "recovery_mode")
    if IsErr(recoveryModeRes):
        return Err[V3BioDidOperatorAnchor](Error(recoveryModeRes))
    let didTextRes = did.v3DidStoreFindValue(lines, "did")
    if IsErr(didTextRes):
        return Err[V3BioDidOperatorAnchor](Error(didTextRes))
    let didText = Value(didTextRes)
    var subjectDidText = didText
    var deviceDidText = didText
    if isV2:
        let subjectDidTextRes = did.v3DidStoreFindValue(lines, "subject_did")
        if IsErr(subjectDidTextRes):
            return Err[V3BioDidOperatorAnchor](Error(subjectDidTextRes))
        subjectDidText = Value(subjectDidTextRes)
        let deviceDidTextRes = did.v3DidStoreFindValue(lines, "device_did")
        if IsErr(deviceDidTextRes):
            return Err[V3BioDidOperatorAnchor](Error(deviceDidTextRes))
        deviceDidText = Value(deviceDidTextRes)
    let bundleSeqTextRes = did.v3DidStoreFindValue(lines, "bundle_seq")
    if IsErr(bundleSeqTextRes):
        return Err[V3BioDidOperatorAnchor](Error(bundleSeqTextRes))
    let bundleCidTextRes = did.v3DidStoreFindValue(lines, "bundle_cid")
    if IsErr(bundleCidTextRes):
        return Err[V3BioDidOperatorAnchor](Error(bundleCidTextRes))
    let bundleTextEncodedRes = did.v3DidStoreFindValue(lines, "bundle_text")
    if IsErr(bundleTextEncodedRes):
        return Err[V3BioDidOperatorAnchor](Error(bundleTextEncodedRes))
    let eventIdEncodedRes = did.v3DidStoreFindValue(lines, "event_id")
    if IsErr(eventIdEncodedRes):
        return Err[V3BioDidOperatorAnchor](Error(eventIdEncodedRes))
    let operatorIdRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(Value(operatorIdTextRes))
    if IsErr(operatorIdRes):
        return Err[V3BioDidOperatorAnchor](Error(operatorIdRes))
    let bundleSeqRes = did.v3DidStoreParseInt32(Value(bundleSeqTextRes))
    if IsErr(bundleSeqRes):
        return Err[V3BioDidOperatorAnchor](Error(bundleSeqRes))
    let bundleCidRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(Value(bundleCidTextRes))
    if IsErr(bundleCidRes):
        return Err[V3BioDidOperatorAnchor](Error(bundleCidRes))
    let bundleTextBytesRes = did.v3DidStoreDecodeBytes(Value(bundleTextEncodedRes))
    if IsErr(bundleTextBytesRes):
        return Err[V3BioDidOperatorAnchor](Error(bundleTextBytesRes))
    let eventIdBytesRes = did.v3DidStoreDecodeBytes(Value(eventIdEncodedRes))
    if IsErr(eventIdBytesRes):
        return Err[V3BioDidOperatorAnchor](Error(eventIdBytesRes))
    var out = V3BioDidOperatorAnchor()
    out.operatorId = Value(operatorIdRes)
    out.bundleKind = bundleKindText
    out.recoveryMode = Value(recoveryModeRes)
    out.didText = didText
    out.subjectDidText = subjectDidText
    out.deviceDidText = deviceDidText
    out.bundleSeq = Value(bundleSeqRes)
    out.bundleCid = Value(bundleCidRes)
    out.bundleText = bytesToString(Value(bundleTextBytesRes))
    out.eventId = bytesToString(Value(eventIdBytesRes))
    let verifyRes = v3BioDidOperatorAnchorVerify(out)
    if IsErr(verifyRes):
        return Err[V3BioDidOperatorAnchor](Error(verifyRes))
    let canonicalText = isV2 ? v3BioDidOperatorAnchorText(out) : v3BioDidOperatorAnchorLegacyText(out)
    if !v3BioDidTextEqual(canonicalText, text):
        return Err[V3BioDidOperatorAnchor]("v3 bio did: non canonical operator anchor text")
    return Ok[V3BioDidOperatorAnchor](out)

fn v3BioDidChainCurrentOperatorAnchorSeq(node: var chain.V3ChainNode): int32 =
    var maxSeq = 0
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.v3ConsensusKindMint:
            continue
        if event.assetId != v3BioDidOperatorAnchorAssetId:
            continue
        if event.toAccount != v3BioDidOperatorAnchorAccountId:
            continue
        if event.fromAccount > maxSeq:
            maxSeq = event.fromAccount
    return maxSeq

fn v3BioDidChainLoadOperatorAnchorText(node: var chain.V3ChainNode,
                                       anchorSeq: int32): Result[str] =
    var maxOrdinal = 0
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.v3ConsensusKindMint:
            continue
        if event.assetId != v3BioDidOperatorAnchorAssetId:
            continue
        if event.toAccount != v3BioDidOperatorAnchorAccountId:
            continue
        if event.fromAccount != anchorSeq:
            continue
        let ordinal = int32(event.amount)
        if int64(ordinal) != event.amount:
            return Err[str]("v3 bio did: operator chunk ordinal overflow")
        if ordinal > maxOrdinal:
            maxOrdinal = ordinal
    if maxOrdinal <= 0:
        return Err[str]("v3 bio did: operator anchor seq missing")
    var chunks: layout.FixedBytes32[]
    var ordinal = 1
    while ordinal <= maxOrdinal:
        var foundCount = 0
        var chunk = layout.FixedBytes32()
        for i in 0..<node.events.len:
            let event = node.events[i]
            if event.kind != consensus.v3ConsensusKindMint:
                continue
            if event.assetId != v3BioDidOperatorAnchorAssetId:
                continue
            if event.toAccount != v3BioDidOperatorAnchorAccountId:
                continue
            if event.fromAccount != anchorSeq:
                continue
            if event.amount != int64(ordinal):
                continue
            foundCount = foundCount + 1
            chunk = event.fromParentCid
        if foundCount != 1:
            return Err[str]("v3 bio did: operator chunk multiplicity mismatch")
        add(chunks, chunk)
        ordinal = ordinal + 1
    let payloadRes = v3BioDidChunksToPayload(chunks)
    if IsErr(payloadRes):
        return Err[str](Error(payloadRes))
    return Ok[str](bytesToString(Value(payloadRes)))

fn v3BioDidChainAppendOperatorAnchor(node: var chain.V3ChainNode,
                                     anchor: V3BioDidOperatorAnchor): Result[layout.FixedBytes32] =
    let verifyRes = v3BioDidOperatorAnchorVerify(anchor)
    if IsErr(verifyRes):
        return Err[layout.FixedBytes32](Error(verifyRes))
    let anchorSeq = v3BioDidChainCurrentOperatorAnchorSeq(node) + 1
    let payload = bytesFromString(v3BioDidOperatorAnchorText(anchor))
    let chunkCount = v3BioDidChunkCount(payload.len)
    var lastEventCid = layout.FixedBytes32()
    for chunkIndex in 0..<chunkCount:
        let parentCid = chain.v3ChainNodeAccountHead(node.index,
                                                     v3BioDidOperatorAnchorAssetId,
                                                     v3BioDidOperatorAnchorAccountId)
        var event = consensus.v3ChainEventMint(v3BioDidOperatorAnchorAssetId,
                                               v3BioDidOperatorAnchorAccountId,
                                               parentCid,
                                               int64(chunkIndex + 1),
                                               node.nextEpoch,
                                               node.nextGanzhi,
                                               chain.v3ChainNodeSpaceSlot(v3BioDidOperatorAnchorAccountId,
                                                                          v3BioDidOperatorAnchorAccountId),
                                               node.nextTick)
        event.fromAccount = anchorSeq
        event.fromParentCid = v3BioDidChunkFixed(payload, chunkIndex)
        event.bodyCid = consensus.v3ChainEventBodyCid(event)
        let applyRes = chain.v3ChainNodeApplyEvent(node, event)
        if IsErr(applyRes):
            return Err[layout.FixedBytes32](Error(applyRes))
        lastEventCid = Value(applyRes)
    return Ok[layout.FixedBytes32](lastEventCid)

fn v3BioDidChainAppendOperatorBundleAnchorWithMeta(node: var chain.V3ChainNode,
                                                   operatorId: layout.FixedBytes32,
                                                   subjectDidText: str,
                                                   deviceDidText: str,
                                                   bundleKind: str,
                                                   bundle: V3BioDidChainBundle,
                                                   eventId: str): Result[layout.FixedBytes32] =
    var anchor = V3BioDidOperatorAnchor()
    anchor.operatorId = operatorId
    anchor.bundleKind = v3BioDidOperatorBundleKindNormalize(bundleKind)
    anchor.recoveryMode = v3BioDidRecoveryModeSecretV1
    anchor.didText = subjectDidText
    anchor.subjectDidText = subjectDidText
    anchor.deviceDidText = deviceDidText
    anchor.bundleSeq = bundle.bundleSeq
    anchor.bundleCid = bundle.bundleCid
    anchor.bundleText = v3BioDidChainBundleText(bundle)
    anchor.eventId = eventId
    return v3BioDidChainAppendOperatorAnchor(node, anchor)

fn v3BioDidChainAppendOperatorBundleAnchor(node: var chain.V3ChainNode,
                                           operatorId: layout.FixedBytes32,
                                           bundle: V3BioDidChainBundle,
                                           eventId: str): Result[layout.FixedBytes32] =
    return v3BioDidChainAppendOperatorBundleAnchorWithMeta(node,
                                                           operatorId,
                                                           bundle.didText,
                                                           bundle.didText,
                                                           v3BioDidOperatorBundleKindAndroidBioV1,
                                                           bundle,
                                                           eventId)

fn v3BioDidOperatorRecordFromAnchor(anchor: V3BioDidOperatorAnchor,
                                    anchorSeq: int32): V3BioDidOperatorRecord =
    var record = V3BioDidOperatorRecord()
    record.operatorId = anchor.operatorId
    record.bundleKind = v3BioDidOperatorBundleKindNormalize(anchor.bundleKind)
    record.didText = anchor.didText
    record.subjectDidText = anchor.subjectDidText
    record.deviceDidText = anchor.deviceDidText
    record.bundleSeq = anchor.bundleSeq
    record.bundleCid = anchor.bundleCid
    record.bundleText = anchor.bundleText
    record.eventId = anchor.eventId
    record.anchorSeq = anchorSeq
    return record

fn v3BioDidOperatorIndexesPut(operatorIndex: var V3BioDidOperatorIndex,
                              operatorKindIndex: var V3BioDidOperatorKindIndex,
                              record: V3BioDidOperatorRecord): Result[bool] =
    let kindPutRes = v3BioDidOperatorKindIndexPut(
        operatorKindIndex,
        V3BioDidOperatorKindKey(
            operatorId: record.operatorId,
            bundleKind: v3BioDidOperatorBundleKindNormalize(record.bundleKind)
        ),
        record
    )
    if IsErr(kindPutRes):
        return Err[bool](Error(kindPutRes))
    let currentRes = v3BioDidOperatorIndexLookup(operatorIndex, layout.fixedBytes32Hex(record.operatorId))
    if IsErr(currentRes) || v3BioDidOperatorRecordShouldReplace(Value(currentRes), record):
        let putRes = v3BioDidOperatorIndexPut(operatorIndex, record.operatorId, record)
        if IsErr(putRes):
            return Err[bool](Error(putRes))
    return Ok[bool](true)

fn v3BioDidOperatorIndexRebuildInto(out: var V3BioDidOperatorIndex,
                                    node: var chain.V3ChainNode): Result[bool] =
    let initCap = v3BioDidOperatorIndexInitCap
    v3BioDidOperatorIndexInitInto(out, initCap)
    var kindOut: V3BioDidOperatorKindIndex
    v3BioDidOperatorKindIndexInitInto(kindOut, initCap)
    let maxSeq = v3BioDidChainCurrentOperatorAnchorSeq(node)
    var anchorSeq = 1
    while anchorSeq <= maxSeq:
        let textRes = v3BioDidChainLoadOperatorAnchorText(node, anchorSeq)
        if IsErr(textRes):
            return Err[bool](Error(textRes))
        let anchorRes = v3BioDidOperatorAnchorParseText(Value(textRes))
        if IsErr(anchorRes):
            return Err[bool](Error(anchorRes))
        let anchor = Value(anchorRes)
        let putRes = v3BioDidOperatorIndexesPut(out,
                                                kindOut,
                                                v3BioDidOperatorRecordFromAnchor(anchor, anchorSeq))
        if IsErr(putRes):
            return Err[bool](Error(putRes))
        anchorSeq = anchorSeq + 1
    return Ok[bool](true)

fn v3BioDidOperatorIndexLookup(index: V3BioDidOperatorIndex,
                               operatorIdHex: str): Result[V3BioDidOperatorRecord] =
    let operatorIdRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(operatorIdHex)
    if IsErr(operatorIdRes):
        return Err[V3BioDidOperatorRecord](Error(operatorIdRes))
    let operatorId = Value(operatorIdRes)
    let slot = v3BioDidOperatorIndexFindSlot(index, operatorId, false)
    if slot < 0:
        return Err[V3BioDidOperatorRecord]("v3 bio did: operator not found")
    let record = index.vals[slot]
    if layout.fixedBytes32Equal(record.operatorId, layout.FixedBytes32()):
        return Err[V3BioDidOperatorRecord]("v3 bio did: operator record missing")
    return Ok[V3BioDidOperatorRecord](record)

fn v3BioDidOperatorLookup(index: V3BioDidOperatorIndex,
                          operatorKindIndex: V3BioDidOperatorKindIndex,
                          operatorIdHex: str,
                          preferredKinds: str[]): Result[V3BioDidOperatorRecord] =
    let operatorIdRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(operatorIdHex)
    if IsErr(operatorIdRes):
        return Err[V3BioDidOperatorRecord](Error(operatorIdRes))
    let operatorId = Value(operatorIdRes)
    for i in 0..<preferredKinds.len:
        let bundleKind = v3BioDidOperatorBundleKindNormalize(preferredKinds[i])
        let lookupKindRes = v3BioDidOperatorKindIndexLookup(operatorKindIndex, operatorId, bundleKind)
        if IsOk(lookupKindRes):
            return lookupKindRes
    return v3BioDidOperatorIndexLookup(index, operatorIdHex)

fn v3BioDidOperatorLookupJson(index: V3BioDidOperatorIndex,
                              operatorKindIndex: V3BioDidOperatorKindIndex,
                              operatorIdHex: str,
                              preferredKinds: str[]): str =
    let operatorIdRes: Result[layout.FixedBytes32] = layout.fixedBytes32FromHex(operatorIdHex)
    if IsErr(operatorIdRes):
        return "{\"ok\":false,\"found\":false,\"operatorId\":\"\",\"error\":\"invalid_operator_id\"}"
    let operatorId = layout.fixedBytes32Hex(Value(operatorIdRes))
    let lookupRes = v3BioDidOperatorLookup(index, operatorKindIndex, operatorId, preferredKinds)
    if IsErr(lookupRes):
        return "{\"ok\":true,\"found\":false,\"operatorId\":\"" + operatorId + "\"}"
    let record = Value(lookupRes)
    let bundleTextEncoded = did.v3DidStoreEncodeText(record.bundleText)
    let eventIdEncoded = did.v3DidStoreEncodeText(record.eventId)
    var out = "{\"ok\":true,\"found\":true"
    out = out + ",\"operatorId\":\"" + operatorId + "\""
    out = out + ",\"did\":\"" + record.didText + "\""
    out = out + ",\"subjectDid\":\"" + record.subjectDidText + "\""
    out = out + ",\"deviceDid\":\"" + record.deviceDidText + "\""
    out = out + ",\"bundleSeq\":" + strings.IntToStr(record.bundleSeq)
    out = out + ",\"bundleCid\":\"" + layout.fixedBytes32Hex(record.bundleCid) + "\""
    out = out + ",\"bundleText\":\"" + bundleTextEncoded + "\""
    out = out + ",\"bundleTextEncoding\":\"did_store_hex_v1\""
    out = out + ",\"bundleKind\":\"" + v3BioDidOperatorBundleKindNormalize(record.bundleKind) + "\""
    out = out + ",\"eventId\":\"" + eventIdEncoded + "\""
    out = out + ",\"eventIdEncoding\":\"did_store_hex_v1\""
    out = out + "}"
    return out

fn v3BioDidOperatorLookupErrorJson(operatorIdHex: str,
                                   errorTextRaw: str): str =
    let errorText = did.v3DidStoreEncodeText(errorTextRaw)
    return "{\"ok\":false,\"found\":false,\"operatorId\":\"" +
           operatorIdHex +
           "\",\"error\":\"" +
           errorText +
           "\",\"errorEncoding\":\"did_store_hex_v1" +
           "\"}"

fn v3BioDidChainStateSyncOperatorIndex(state: var V3BioDidChainState): Result[bool] =
    let maxSeq = v3BioDidChainCurrentOperatorAnchorSeq(state.node)
    if maxSeq < state.operatorAnchorSeq:
        return Err[bool]("v3 bio did: operator index seq overflow")
    var changed = false
    var anchorSeq = state.operatorAnchorSeq + 1
    while anchorSeq <= maxSeq:
        let textRes = v3BioDidChainLoadOperatorAnchorText(state.node, anchorSeq)
        if IsErr(textRes):
            return Err[bool](Error(textRes))
        let anchorRes = v3BioDidOperatorAnchorParseText(Value(textRes))
        if IsErr(anchorRes):
            return Err[bool](Error(anchorRes))
        let anchor = Value(anchorRes)
        let putRes = v3BioDidOperatorIndexesPut(state.operatorIndex,
                                                state.operatorKindIndex,
                                                v3BioDidOperatorRecordFromAnchor(anchor, anchorSeq))
        if IsErr(putRes):
            return Err[bool](Error(putRes))
        changed = true
        anchorSeq = anchorSeq + 1
    state.operatorAnchorSeq = maxSeq
    return Ok[bool](changed)

fn v3BioDidChainStateFromNodeInto(out: var V3BioDidChainState,
                                  node: var chain.V3ChainNode): Result[bool] =
    v3BioDidChainStateZeroInto(out, node)
    let syncRes = v3BioDidChainStateSyncOperatorIndex(out)
    if IsErr(syncRes):
        return Err[bool](Error(syncRes))
    return Ok[bool](true)

fn v3BioDidChainStateReplayFromSnapshotInto(out: var V3BioDidChainState,
                                            nodeId: str,
                                            addressSeed: str,
                                            snapshot: chain.V3ChainNodeServeSnapshot):
                                            Result[bool] =
    let addressRes = chain.v3ChainNodeAddressFromSeed(addressSeed)
    if IsErr(addressRes):
        return Err[bool](Error(addressRes))
    let replayRes = chain.v3ChainNodeReplayFromSnapshotInto(out.node,
                                                            nodeId,
                                                            Value(addressRes),
                                                            snapshot)
    if IsErr(replayRes):
        return Err[bool](Error(replayRes))
    v3BioDidOperatorIndexZeroInto(out.operatorIndex)
    v3BioDidOperatorKindIndexZeroInto(out.operatorKindIndex)
    out.operatorAnchorSeq = 0
    return v3BioDidChainStateSyncOperatorIndex(out)

fn v3BioDidOperatorLookupJsonFromState(state: var V3BioDidChainState,
                                       operatorIdHex: str): str =
    var emptyKinds: str[]
    emptyKinds.len = 0
    return v3BioDidOperatorLookupJsonFromStateWithKinds(state, operatorIdHex, emptyKinds)

fn v3BioDidOperatorLookupJsonFromStateWithKinds(state: var V3BioDidChainState,
                                                operatorIdHex: str,
                                                preferredKinds: str[]): str =
    let syncRes = v3BioDidChainStateSyncOperatorIndex(state)
    if IsErr(syncRes):
        return v3BioDidOperatorLookupErrorJson(operatorIdHex, Error(syncRes))
    let operatorIndex = state.operatorIndex
    let operatorKindIndex = state.operatorKindIndex
    return v3BioDidOperatorLookupJson(operatorIndex,
                                      operatorKindIndex,
                                      operatorIdHex,
                                      preferredKinds)

fn v3BioDidChainRequestIdSeen(node: var chain.V3ChainNode,
                              didText: str,
                              requestId: str): Result[bool] =
    if strings.Len(requestId) <= 0:
        return Err[bool]("v3 bio did: request id required")
    let maxSeq = v3BioDidChainCurrentBundleSeq(node, didText)
    var bundleSeq = 1
    while bundleSeq <= maxSeq:
        let textRes = v3BioDidChainLoadTextForSeq(node, didText, bundleSeq)
        if IsErr(textRes):
            return Err[bool](Error(textRes))
        let bundleRes = v3BioDidChainBundleParseText(Value(textRes))
        if IsErr(bundleRes):
            return Err[bool](Error(bundleRes))
        if Value(bundleRes).hardware.requestId == requestId:
            return Ok[bool](true)
        bundleSeq = bundleSeq + 1
    return Ok[bool](false)

fn v3BioDidIdentityFromDocument(rootSeed: str,
                                deviceSeed: str,
                                document: did.V3DidDocument): Result[did.V3DidIdentity] =
    var probe: did.V3DidIdentity
    probe.rootSeed = rootSeed
    probe.deviceSeed = deviceSeed
    var out: did.V3DidIdentity
    let applyRes = did.v3DidIdentityApplyDocumentFill(out, probe, document)
    if IsErr(applyRes):
        return Err[did.V3DidIdentity](Error(applyRes))
    return Ok[did.V3DidIdentity](out)

fn v3BioDidCreateWithHardwareCapture(node: var chain.V3ChainNode,
                                     capture: V3BioDidHardwareCapture,
                                     epochSeconds: int64): Result[V3BioDidProvisionResult] =
    let captureOk = v3BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        return Err[V3BioDidProvisionResult](Error(captureOk))
    let attestationOk = v3BioDidCaptureAttestationValidate(capture, "create")
    if IsErr(attestationOk):
        return Err[V3BioDidProvisionResult](Error(attestationOk))
    let recordRes = bio.v3BioEnroll(capture.feature32)
    if IsErr(recordRes):
        return Err[V3BioDidProvisionResult](Error(recordRes))
    let record = Value(recordRes)
    let rootSecretRes = bio.v3BioRecoverRoot(capture.feature32, record.helper)
    if IsErr(rootSecretRes):
        return Err[V3BioDidProvisionResult](Error(rootSecretRes))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = v3BioDidRootSeedFromRootSecret(rootSecret)
    let deviceSeed = v3BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let identity = did.v3DidIdentityMake(rootSeed, deviceSeed, capture.deviceLabel, epochSeconds)
    var document: did.V3DidDocument
    let documentRes = did.v3DidIdentityDocumentFill(document, identity)
    if IsErr(documentRes):
        return Err[V3BioDidProvisionResult](Error(documentRes))
    if v3BioDidChainCurrentBundleSeq(node, document.did) != 0:
        return Err[V3BioDidProvisionResult]("v3 bio did: did already exists")
    let bundleSeq = 1
    let challengeNonce = v3BioDidChallengeNonce("create",
                                                document.did,
                                                identity.selfDevice.devicePeerId,
                                                document.version,
                                                bundleSeq)
    let hardware = v3BioDidHardwareAttestationMake(capture,
                                                   "create",
                                                   document.did,
                                                   identity.selfDevice.devicePeerId,
                                                   document.version,
                                                   bundleSeq,
                                                   challengeNonce,
                                                   epochSeconds)
    let assertionRes = bio.v3BioProve(capture.feature32, record, challengeNonce)
    if IsErr(assertionRes):
        return Err[V3BioDidProvisionResult](Error(assertionRes))
    let bundleRes = v3BioDidChainBundleMake("create",
                                            bundleSeq,
                                            document,
                                            identity.selfDevice.devicePeerId,
                                            record,
                                            Value(assertionRes),
                                            hardware)
    if IsErr(bundleRes):
        return Err[V3BioDidProvisionResult](Error(bundleRes))
    let appendRes = v3BioDidChainAppendBundle(node, Value(bundleRes))
    if IsErr(appendRes):
        return Err[V3BioDidProvisionResult](Error(appendRes))
    var out = V3BioDidProvisionResult()
    out.identity = identity
    out.document = document
    out.bundle = Value(bundleRes)
    return Ok[V3BioDidProvisionResult](out)

fn v3BioDidCreateBundleWithHardwareCapture(capture: V3BioDidHardwareCapture,
                                           epochSeconds: int64): Result[V3BioDidProvisionResult] =
    let captureOk = v3BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        return Err[V3BioDidProvisionResult](Error(captureOk))
    let attestationOk = v3BioDidCaptureAttestationValidate(capture, "create")
    if IsErr(attestationOk):
        return Err[V3BioDidProvisionResult](Error(attestationOk))
    let recordRes = bio.v3BioEnroll(capture.feature32)
    if IsErr(recordRes):
        return Err[V3BioDidProvisionResult](Error(recordRes))
    let record = Value(recordRes)
    let rootSecretRes = bio.v3BioRecoverRoot(capture.feature32, record.helper)
    if IsErr(rootSecretRes):
        return Err[V3BioDidProvisionResult](Error(rootSecretRes))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = v3BioDidRootSeedFromRootSecret(rootSecret)
    let deviceSeed = v3BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let identity = did.v3DidIdentityMake(rootSeed, deviceSeed, capture.deviceLabel, epochSeconds)
    var document: did.V3DidDocument
    let documentRes = did.v3DidIdentityDocumentFill(document, identity)
    if IsErr(documentRes):
        return Err[V3BioDidProvisionResult](Error(documentRes))
    let bundleSeq = 1
    let challengeNonce = v3BioDidChallengeNonce("create",
                                                document.did,
                                                identity.selfDevice.devicePeerId,
                                                document.version,
                                                bundleSeq)
    let hardware = v3BioDidHardwareAttestationMake(capture,
                                                   "create",
                                                   document.did,
                                                   identity.selfDevice.devicePeerId,
                                                   document.version,
                                                   bundleSeq,
                                                   challengeNonce,
                                                   epochSeconds)
    let assertionRes = bio.v3BioProve(capture.feature32, record, challengeNonce)
    if IsErr(assertionRes):
        return Err[V3BioDidProvisionResult](Error(assertionRes))
    let bundleRes = v3BioDidChainBundleMake("create",
                                            bundleSeq,
                                            document,
                                            identity.selfDevice.devicePeerId,
                                            record,
                                            Value(assertionRes),
                                            hardware)
    if IsErr(bundleRes):
        return Err[V3BioDidProvisionResult](Error(bundleRes))
    var out = V3BioDidProvisionResult()
    out.identity = identity
    out.document = document
    out.bundle = Value(bundleRes)
    return Ok[V3BioDidProvisionResult](out)

fn v3BioDidImportWithHardwareCapture(node: var chain.V3ChainNode,
                                     didText: str,
                                     capture: V3BioDidHardwareCapture,
                                     epochSeconds: int64): Result[V3BioDidProvisionResult] =
    let captureOk = v3BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        return Err[V3BioDidProvisionResult](Error(captureOk))
    let attestationOk = v3BioDidCaptureAttestationValidate(capture, "import")
    if IsErr(attestationOk):
        return Err[V3BioDidProvisionResult](Error(attestationOk))
    let latestBundleRes = v3BioDidChainLoadLatest(node, didText)
    if IsErr(latestBundleRes):
        return Err[V3BioDidProvisionResult](Error(latestBundleRes))
    let latestBundle = Value(latestBundleRes)
    let latestDocumentRes = v3BioDidChainBundleVerify(latestBundle)
    if IsErr(latestDocumentRes):
        return Err[V3BioDidProvisionResult](Error(latestDocumentRes))
    let latestDocument = Value(latestDocumentRes)
    let rootSecretRes = bio.v3BioRecoverRoot(capture.feature32, latestBundle.record.helper)
    if IsErr(rootSecretRes):
        return Err[V3BioDidProvisionResult](Error(rootSecretRes))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = v3BioDidRootSeedFromRootSecret(rootSecret)
    if !v3BioDidTextEqual(did.v3DidFromRootSeed(rootSeed), didText):
        return Err[V3BioDidProvisionResult]("v3 bio did: fingerprint did mismatch")
    let deviceSeed = v3BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let devicePeerId = did.v3DidDevicePeerIdFromSeed(deviceSeed)
    var document = latestDocument
    let existingPos = did.v3DidDocumentFindDevicePos(document, devicePeerId)
    if existingPos >= 0:
        if document.devices[existingPos].status != did.v3DidDeviceStatusActive:
            return Err[V3BioDidProvisionResult]("v3 bio did: device revoked")
    else:
        let enrollRes = did.v3DidDocumentEnrollDevice(document,
                                                      rootSeed,
                                                      deviceSeed,
                                                      capture.deviceLabel,
                                                      epochSeconds)
        if IsErr(enrollRes):
            return Err[V3BioDidProvisionResult](Error(enrollRes))
        document = Value(enrollRes)
    let identityRes = v3BioDidIdentityFromDocument(rootSeed, deviceSeed, document)
    if IsErr(identityRes):
        return Err[V3BioDidProvisionResult](Error(identityRes))
    let identity = Value(identityRes)
    let bundleSeq = v3BioDidChainCurrentBundleSeq(node, didText) + 1
    let challengeNonce = v3BioDidChallengeNonce("import",
                                                didText,
                                                identity.selfDevice.devicePeerId,
                                                document.version,
                                                bundleSeq)
    let hardware = v3BioDidHardwareAttestationMake(capture,
                                                   "import",
                                                   didText,
                                                   identity.selfDevice.devicePeerId,
                                                   document.version,
                                                   bundleSeq,
                                                   challengeNonce,
                                                   epochSeconds)
    let assertionRes = bio.v3BioProve(capture.feature32, latestBundle.record, challengeNonce)
    if IsErr(assertionRes):
        return Err[V3BioDidProvisionResult](Error(assertionRes))
    let bundleRes = v3BioDidChainBundleMake("import",
                                            bundleSeq,
                                            document,
                                            identity.selfDevice.devicePeerId,
                                            latestBundle.record,
                                            Value(assertionRes),
                                            hardware)
    if IsErr(bundleRes):
        return Err[V3BioDidProvisionResult](Error(bundleRes))
    let appendRes = v3BioDidChainAppendBundle(node, Value(bundleRes))
    if IsErr(appendRes):
        return Err[V3BioDidProvisionResult](Error(appendRes))
    var out = V3BioDidProvisionResult()
    out.identity = identity
    out.document = document
    out.bundle = Value(bundleRes)
    return Ok[V3BioDidProvisionResult](out)

fn v3BioDidImportFromLatestBundleWithHardwareCapture(latestBundle: V3BioDidChainBundle,
                                                     capture: V3BioDidHardwareCapture,
                                                     epochSeconds: int64): Result[V3BioDidProvisionResult] =
    let captureOk = v3BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        return Err[V3BioDidProvisionResult](Error(captureOk))
    let attestationOk = v3BioDidCaptureAttestationValidate(capture, "import")
    if IsErr(attestationOk):
        return Err[V3BioDidProvisionResult](Error(attestationOk))
    let latestDocumentRes = v3BioDidChainBundleVerify(latestBundle)
    if IsErr(latestDocumentRes):
        return Err[V3BioDidProvisionResult](Error(latestDocumentRes))
    let latestDocument = Value(latestDocumentRes)
    let rootSecretRes = bio.v3BioRecoverRoot(capture.feature32, latestBundle.record.helper)
    if IsErr(rootSecretRes):
        return Err[V3BioDidProvisionResult](Error(rootSecretRes))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = v3BioDidRootSeedFromRootSecret(rootSecret)
    if !v3BioDidTextEqual(did.v3DidFromRootSeed(rootSeed), latestBundle.didText):
        return Err[V3BioDidProvisionResult]("v3 bio did: fingerprint did mismatch")
    let deviceSeed = v3BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let devicePeerId = did.v3DidDevicePeerIdFromSeed(deviceSeed)
    var document = latestDocument
    let existingPos = did.v3DidDocumentFindDevicePos(document, devicePeerId)
    if existingPos >= 0:
        if document.devices[existingPos].status != did.v3DidDeviceStatusActive:
            return Err[V3BioDidProvisionResult]("v3 bio did: device revoked")
    else:
        let enrollRes = did.v3DidDocumentEnrollDevice(document,
                                                      rootSeed,
                                                      deviceSeed,
                                                      capture.deviceLabel,
                                                      epochSeconds)
        if IsErr(enrollRes):
            return Err[V3BioDidProvisionResult](Error(enrollRes))
        document = Value(enrollRes)
    let identityRes = v3BioDidIdentityFromDocument(rootSeed, deviceSeed, document)
    if IsErr(identityRes):
        return Err[V3BioDidProvisionResult](Error(identityRes))
    let identity = Value(identityRes)
    let bundleSeq = latestBundle.bundleSeq + 1
    let challengeNonce = v3BioDidChallengeNonce("import",
                                                latestBundle.didText,
                                                identity.selfDevice.devicePeerId,
                                                document.version,
                                                bundleSeq)
    let hardware = v3BioDidHardwareAttestationMake(capture,
                                                   "import",
                                                   latestBundle.didText,
                                                   identity.selfDevice.devicePeerId,
                                                   document.version,
                                                   bundleSeq,
                                                   challengeNonce,
                                                   epochSeconds)
    let assertionRes = bio.v3BioProve(capture.feature32, latestBundle.record, challengeNonce)
    if IsErr(assertionRes):
        return Err[V3BioDidProvisionResult](Error(assertionRes))
    let bundleRes = v3BioDidChainBundleMake("import",
                                            bundleSeq,
                                            document,
                                            identity.selfDevice.devicePeerId,
                                            latestBundle.record,
                                            Value(assertionRes),
                                            hardware)
    if IsErr(bundleRes):
        return Err[V3BioDidProvisionResult](Error(bundleRes))
    var out = V3BioDidProvisionResult()
    out.identity = identity
    out.document = document
    out.bundle = Value(bundleRes)
    return Ok[V3BioDidProvisionResult](out)

fn v3BioDidOperatorEventId(operatorId: layout.FixedBytes32,
                           bundleKind: str,
                           bundle: V3BioDidChainBundle): str =
    return bundle.action +
           "|" +
           layout.fixedBytes32Hex(operatorId) +
           "|" +
           v3BioDidOperatorBundleKindNormalize(bundleKind) +
           "|" +
           bundle.didText +
           "|" +
           strings.IntToStr(bundle.bundleSeq) +
           "|" +
           bundle.hardware.requestId

fn v3BioDidChainStateCreateWithHardwareCapture(state: var V3BioDidChainState,
                                               capture: V3BioDidHardwareCapture,
                                               epochSeconds: int64): Result[V3BioDidProvisionResult] =
    var node = state.node
    let createRes = v3BioDidCreateWithHardwareCapture(node, capture, epochSeconds)
    state.node = node
    return createRes

fn v3BioDidChainStateImportWithHardwareCapture(state: var V3BioDidChainState,
                                               didText: str,
                                               capture: V3BioDidHardwareCapture,
                                               epochSeconds: int64): Result[V3BioDidProvisionResult] =
    var node = state.node
    let importRes = v3BioDidImportWithHardwareCapture(node, didText, capture, epochSeconds)
    state.node = node
    return importRes

fn v3BioDidChainStateAppendOperatorAnchor(state: var V3BioDidChainState,
                                          anchor: V3BioDidOperatorAnchor): Result[layout.FixedBytes32] =
    let syncRes = v3BioDidChainStateSyncOperatorIndex(state)
    if IsErr(syncRes):
        return Err[layout.FixedBytes32](Error(syncRes))
    var node = state.node
    let appendRes = v3BioDidChainAppendOperatorAnchor(node, anchor)
    state.node = node
    if IsErr(appendRes):
        return Err[layout.FixedBytes32](Error(appendRes))
    let nextAnchorSeq = state.operatorAnchorSeq + 1
    let putRes = v3BioDidOperatorIndexesPut(state.operatorIndex,
                                            state.operatorKindIndex,
                                            v3BioDidOperatorRecordFromAnchor(anchor, nextAnchorSeq))
    if IsErr(putRes):
        return Err[layout.FixedBytes32](Error(putRes))
    state.operatorAnchorSeq = nextAnchorSeq
    return Ok[layout.FixedBytes32](Value(appendRes))

fn v3BioDidChainStateAppendOperatorBundleAnchorWithMeta(state: var V3BioDidChainState,
                                                        operatorId: layout.FixedBytes32,
                                                        subjectDidText: str,
                                                        deviceDidText: str,
                                                        bundleKind: str,
                                                        bundle: V3BioDidChainBundle): Result[layout.FixedBytes32] =
    return v3BioDidChainStateAppendOperatorAnchor(
        state,
        V3BioDidOperatorAnchor(
            operatorId: operatorId,
            bundleKind: v3BioDidOperatorBundleKindNormalize(bundleKind),
            recoveryMode: v3BioDidRecoveryModeSecretV1,
            didText: subjectDidText,
            subjectDidText: subjectDidText,
            deviceDidText: deviceDidText,
            bundleSeq: bundle.bundleSeq,
            bundleCid: bundle.bundleCid,
            bundleText: v3BioDidChainBundleText(bundle),
            eventId: v3BioDidOperatorEventId(operatorId,
                                             v3BioDidOperatorBundleKindNormalize(bundleKind),
                                             bundle)
        )
    )

fn v3BioDidChainStateAppendOperatorBundleAnchor(state: var V3BioDidChainState,
                                                operatorId: layout.FixedBytes32,
                                                bundle: V3BioDidChainBundle): Result[layout.FixedBytes32] =
    return v3BioDidChainStateAppendOperatorBundleAnchorWithMeta(state,
                                                                operatorId,
                                                                bundle.didText,
                                                                bundle.didText,
                                                                v3BioDidOperatorBundleKindAndroidBioV1,
                                                                bundle)

fn v3BioDidChainStateServeOnceInto(out: var chain.V3ChainNodeServeSnapshot,
                                   state: var V3BioDidChainState) =
    chain.v3ChainNodeRebuildDerived(state.node)
    state.node.servedCount = state.node.servedCount + 1
    out.nodeId = state.node.nodeId
    chain.v3ChainNodeCopyAddress(out.address, state.node.address)
    out.serveCount = state.node.servedCount
    out.tipEventCid = state.node.tipEventCid
    out.eventCids = state.node.eventCids
    out.events = state.node.events
    out.forest = state.node.forest
    chain.v3ChainNodeCopySignature(out.signature, state.node.signature)

fn v3BioDidEnsureWithHardwareCapture(state: var V3BioDidChainState,
                                     operatorId: layout.FixedBytes32,
                                     capture: V3BioDidHardwareCapture,
                                     epochSeconds: int64): Result[V3BioDidProvisionResult] =
    let syncRes = v3BioDidChainStateSyncOperatorIndex(state)
    if IsErr(syncRes):
        return Err[V3BioDidProvisionResult](Error(syncRes))
    let lookupRes = v3BioDidOperatorIndexLookup(state.operatorIndex, layout.fixedBytes32Hex(operatorId))
    if IsOk(lookupRes):
        let importRes = v3BioDidChainStateImportWithHardwareCapture(state,
                                                                    Value(lookupRes).didText,
                                                                    capture,
                                                                    epochSeconds)
        if IsErr(importRes):
            return Err[V3BioDidProvisionResult](Error(importRes))
        let anchorRes = v3BioDidChainStateAppendOperatorBundleAnchorWithMeta(
            state,
            operatorId,
            Value(lookupRes).subjectDidText,
            Value(importRes).bundle.didText,
            v3BioDidOperatorBundleKindAndroidBioV1,
            Value(importRes).bundle
        )
        if IsErr(anchorRes):
            return Err[V3BioDidProvisionResult](Error(anchorRes))
        return importRes
    let createRes = v3BioDidChainStateCreateWithHardwareCapture(state, capture, epochSeconds)
    if IsErr(createRes):
        return Err[V3BioDidProvisionResult](Error(createRes))
    let anchorRes = v3BioDidChainStateAppendOperatorBundleAnchorWithMeta(
        state,
        operatorId,
        Value(createRes).bundle.didText,
        Value(createRes).bundle.didText,
        v3BioDidOperatorBundleKindAndroidBioV1,
        Value(createRes).bundle
    )
    if IsErr(anchorRes):
        return Err[V3BioDidProvisionResult](Error(anchorRes))
    return createRes

const
    V3BioDidOperatorAnchorAssetId: int32 = v3BioDidOperatorAnchorAssetId
    V3BioDidOperatorAnchorAccountId: int32 = v3BioDidOperatorAnchorAccountId
    V3BioDidOperatorBundleKindAndroidBioV1: str = v3BioDidOperatorBundleKindAndroidBioV1
    V3BioDidOperatorBundleKindBrowserPublicV1: str = v3BioDidOperatorBundleKindBrowserPublicV1
    V3BioDidOperatorBundleKindBrowserRecoveryDraftV1: str = v3BioDidOperatorBundleKindBrowserRecoveryDraftV1

