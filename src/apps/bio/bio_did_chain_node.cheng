                                     rootKeyId: str): Result[bool] =
    return v3BioDidSetTrustedAttestorRootHex(pubKeyHex, rootKeyId)

fn V3BioDidOperatorIdFromRecoverySecretHex(recoverySecretHex: str): Result[layout.FixedBytes32] =
    return v3BioDidOperatorIdFromRecoverySecretHex(recoverySecretHex)

