    return v3BioDidChunkCount(size)

fn V3BioDidChunkFixed(payload: Bytes, chunkIndex: int32): layout.FixedBytes32 =
    return v3BioDidChunkFixed(payload, chunkIndex)

fn V3BioDidChainAppendOperatorBundleAnchor(node: var chain.V3ChainNode,
                                           operatorId: layout.FixedBytes32,
                                           bundle: V3BioDidChainBundle,
                                           eventId: str): Result[layout.FixedBytes32] =
    return v3BioDidChainAppendOperatorBundleAnchor(node, operatorId, bundle, eventId)

fn V3BioDidOperatorLookupJsonFromStateWithKinds(state: var V3BioDidChainState,
                                                operatorIdHex: str,
                                                preferredKinds: str[]): Result[str] =
