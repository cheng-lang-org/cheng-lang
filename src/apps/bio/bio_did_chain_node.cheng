const
    BioDidChainAssetId: int32 = 930001
    BioDidOperatorAnchorAssetId: int32 = 930002
    BioDidOperatorAnchorAccountId: int32 = 1
    BioDidBundleVersionText = "2"
    BioDidOperatorAnchorVersionText = "2"
    BioDidOperatorAnchorVersionTextLegacy = "1"
    BioDidHardwareAttestationVersion: int32 = 1
    BioDidRecoveryModeSecretV1 = "recovery_secret_v1"
    BioDidOperatorTag = "cheng.bio.did.operator.v1"
    BioDidOperatorIndexInitCap: int32 = 64
    BioDidOperatorBundleKindAndroidBioV1 = "android_bio_v1"
    BioDidOperatorBundleKindBrowserPublicV1 = "browser_public_v1"
    BioDidOperatorBundleKindBrowserRecoveryDraftV1 = "browser_recovery_draft_v1"

type
    BioDidHardwareCapture =
        verified: bool
        feature32: layout.FixedBytes32
        requestId: str
        sensorId: str
        deviceBindingSeed: str
        deviceLabel: str
        hardwareAttestation: str

    BioDidHardwareAttestation =
        version: int32
        requestId: str
        sensorId: str
        verifiedAtEpochSeconds: did.DidWord64
        deviceBindingSeedHash: layout.FixedBytes32
        attestationText: str
        attestationCid: layout.FixedBytes32
        bindingCid: layout.FixedBytes32

    BioDidParsedHardwareAttestation =
        version: int32
        requestId: str
        purpose: int32
        sensorId: str
        platform: int32
        attestationKind: int32
        rootKeyId: str
        certChainCid: layout.FixedBytes32
        livenessCid: layout.FixedBytes32
        deviceBindingSeedHash: layout.FixedBytes32
        deviceLabel: str
        featureCommitment: layout.FixedBytes32
        attestorPubKey: layout.FixedBytes65
        signature: layout.FixedBytes64

    BioDidChainBundle =
        action: str
        bundleSeq: int32
        didText: str
        devicePeerId: types.Libp2pPeerId
        documentText: str
        record: bio.BioEnrollmentRecord
        assertion: bio.BioAssertion
        hardware: BioDidHardwareAttestation
        bundleCid: layout.FixedBytes32

    BioDidChainBundleHeader =
        action: str
        bundleSeq: int32
        didText: str
        bundleCid: layout.FixedBytes32

    BioDidProvisionResult =
        identity: did.DidIdentity
        document: did.DidDocument
        bundle: BioDidChainBundle

    BioDidOperatorAnchor =
        operatorId: layout.FixedBytes32
        bundleKind: str
        recoveryMode: str
        didText: str
        subjectDidText: str
        deviceDidText: str
        bundleSeq: int32
        bundleCid: layout.FixedBytes32
        bundleText: str
        eventId: str

    BioDidOperatorRecord =
        operatorId: layout.FixedBytes32
        bundleKind: str
        didText: str
        subjectDidText: str
        deviceDidText: str
        bundleSeq: int32
        bundleCid: layout.FixedBytes32
        bundleText: str
        eventId: str
        anchorSeq: int32

    BioDidOperatorKindKey =
        operatorId: layout.FixedBytes32
        bundleKind: str

    BioDidOperatorIndex =
        keys: layout.FixedBytes32[]
        vals: BioDidOperatorRecord[]
        used: int32[]
        len: int32

    BioDidOperatorKindIndex =
        keys: BioDidOperatorKindKey[]
        vals: BioDidOperatorRecord[]
        used: int32[]
        len: int32

    BioDidChainState =
        node: chain.ChainNode
        operatorIndex: BioDidOperatorIndex
        operatorKindIndex: BioDidOperatorKindIndex
        operatorAnchorSeq: int32

var BioDidTrustedAttestorPubKeyHex: str
var BioDidTrustedAttestorRootKeyId: str

fn BioDidCopyText(text: str): str =
    var out = ""
    out = did.DidTextAppend(out, text)
    return out

fn BioDidTextEqual(left: str, right: str): bool =
    let leftLen = strings.Len(left)
    if leftLen != strings.Len(right):
        return false
    for i in 0..<leftLen:
        if left[i] != right[i]:
            return false
    return true

fn BioDidTextDiffIndex(left: str, right: str): int32 =
    let leftLen = strings.Len(left)
    let rightLen = strings.Len(right)
    var stop = leftLen
    if rightLen < stop:
        stop = rightLen
    for i in 0..<stop:
        if left[i] != right[i]:
            return i
    if leftLen != rightLen:
        return stop
    return -1

fn BioDidTextSliceHex(text: str, start0: int32, count0: int32): str =
    let textLen = strings.Len(text)
    if textLen <= 0 || count0 <= 0:
        return ""
    var start = start0
    if start < 0:
        start = 0
    if start >= textLen:
        return ""
    var count = count0
    if start + count > textLen:
        count = textLen - start
    return did.DidStoreEncodeText(strings.SliceBytes(text, start, count))

fn BioDidTextMismatch(label: str,
                        want: str,
                        got: str): str =
    let diffAt = BioDidTextDiffIndex(want, got)
    var snippetStart = diffAt - 8
    if snippetStart < 0:
        snippetStart = 0
    var out = " bio did: "
    out = did.DidTextAppend(out, label)
    out = did.DidTextAppend(out, " want_len=")
    out = did.DidTextAppend(out, strings.IntToStr(strings.Len(want)))
    out = did.DidTextAppend(out, " got_len=")
    out = did.DidTextAppend(out, strings.IntToStr(strings.Len(got)))
    out = did.DidTextAppend(out, " diff_at=")
    out = did.DidTextAppend(out, strings.IntToStr(diffAt))
    out = did.DidTextAppend(out, " want_hex=")
    out = did.DidTextAppend(out, BioDidTextSliceHex(want, snippetStart, 24))
    out = did.DidTextAppend(out, " got_hex=")
    out = did.DidTextAppend(out, BioDidTextSliceHex(got, snippetStart, 24))
    return out

fn BioDidOperatorBundleKindNormalize(bundleKind: str): str =
    if strings.Len(bundleKind) <= 0:
        return BioDidOperatorBundleKindAndroidBioV1
    return bundleKind

fn BioDidOperatorIndexZeroInto(out: var BioDidOperatorIndex) =
    var keys: layout.FixedBytes32[]
    var vals: BioDidOperatorRecord[]
    var used: int32[]
    keys.len = 0
    vals.len = 0
    used.len = 0
    out.keys = keys
    out.vals = vals
    out.used = used
    out.len = 0

fn BioDidOperatorKindIndexZeroInto(out: var BioDidOperatorKindIndex) =
    var keys: BioDidOperatorKindKey[]
    var vals: BioDidOperatorRecord[]
    var used: int32[]
    keys.len = 0
    vals.len = 0
    used.len = 0
    out.keys = keys
    out.vals = vals
    out.used = used
    out.len = 0

fn BioDidChainStateZeroInto(out: var BioDidChainState, node: var chain.ChainNode) =
    chain.ChainNodeCopyInto(out.node, node)
    BioDidOperatorIndexZeroInto(out.operatorIndex)
    BioDidOperatorKindIndexZeroInto(out.operatorKindIndex)
    out.operatorAnchorSeq = 0

fn BioDidChainStateInitInto(out: var BioDidChainState,
                              nodeId: str,
                              addressSeed: str): Result[bool] =
    let initRes = chain.ChainNodeInitInto(out.node, nodeId, addressSeed)
    if IsErr(initRes):
        return Err[bool](Error(initRes))
    BioDidOperatorIndexZeroInto(out.operatorIndex)
    BioDidOperatorKindIndexZeroInto(out.operatorKindIndex)
    out.operatorAnchorSeq = 0
    return Ok[bool](true)

fn BioDidOperatorIndexRoundUpPow2(x0: int32): int32 =
    if x0 < 2:
        return 1
    var x = x0 - 1
    x = x | (x >> 1)
    x = x | (x >> 2)
    x = x | (x >> 4)
    x = x | (x >> 8)
    x = x | (x >> 16)
    return x + 1

fn BioDidOperatorIndexInitInto(out: var BioDidOperatorIndex,
                                 initialCap: int32) =
    var cap = initialCap
    if cap < 8:
        cap = 8
    cap = BioDidOperatorIndexRoundUpPow2(cap)
    BioDidOperatorIndexZeroInto(out)
    for i in 0..<cap:
        seqs.Add(out.keys, layout.FixedBytes32())
        seqs.Add(out.vals, BioDidOperatorRecord())
        seqs.Add(out.used, 0)

fn BioDidOperatorIndexHash(key: layout.FixedBytes32): int32 =
    var h: int32
    for i in 0..<32:
        let code = int32(key.data[i]) & 255
        h = h + code
        h = h + (h << 10)
        h = h ^ (h >> 6)
    h = h + (h << 3)
    h = h ^ (h >> 11)
    h = h + (h << 15)
    return h

fn BioDidOperatorIndexFindSlot(index: BioDidOperatorIndex,
                                 key: layout.FixedBytes32,
                                 allowInsert: bool): int32 =
    let cap = index.keys.len
    if cap <= 0:
        return -1
    var probe = (BioDidOperatorIndexHash(key) & 0x7fffffff) % cap
    for scanned in 0..<cap:
        if index.used[probe] == 0:
            if allowInsert:
                return probe
            return -1
        if layout.FixedBytes32Equal(index.keys[probe], key):
            return probe
        probe = probe + 1
        if probe >= cap:
            probe = 0
    return -1

fn BioDidOperatorIndexFindSlotMut(index: var BioDidOperatorIndex,
                                    key: layout.FixedBytes32,
                                    allowInsert: bool): int32 =
    let cap = index.keys.len
    if cap <= 0:
        return -1
    var probe = (BioDidOperatorIndexHash(key) & 0x7fffffff) % cap
    for scanned in 0..<cap:
        if index.used[probe] == 0:
            if allowInsert:
                return probe
            return -1
        if layout.FixedBytes32Equal(index.keys[probe], key):
            return probe
        probe = probe + 1
        if probe >= cap:
            probe = 0
    return -1

fn BioDidOperatorIndexGrow(index: var BioDidOperatorIndex): Result[bool] =
    let oldCap = index.keys.len
    let nextCap = oldCap * 2
    var next: BioDidOperatorIndex
    BioDidOperatorIndexInitInto(next, nextCap)
    for i in 0..<oldCap:
        if index.used[i] != 0:
            let putRes = BioDidOperatorIndexPut(next, index.keys[i], index.vals[i])
            if IsErr(putRes):
                return Err[bool](Error(putRes))
    index.keys = next.keys
    index.vals = next.vals
    index.used = next.used
    index.len = next.len
    return Ok[bool](true)

fn BioDidOperatorIndexPut(index: var BioDidOperatorIndex,
                            key: layout.FixedBytes32,
                            record: BioDidOperatorRecord): Result[bool] =
    if index.keys.len <= 0:
        let initCap = BioDidOperatorIndexInitCap
        BioDidOperatorIndexInitInto(index, initCap)
    if (index.len + 1) * 10 >= index.keys.len * 7:
        let growRes = BioDidOperatorIndexGrow(index)
        if IsErr(growRes):
            return Err[bool](Error(growRes))
    let slot = BioDidOperatorIndexFindSlotMut(index, key, true)
    if slot < 0:
        return Err[bool](" bio did: operator index slot missing")
    if index.used[slot] == 0:
        index.len = index.len + 1
        index.used[slot] = 1
    index.keys[slot] = key
    index.vals[slot] = record
    return Ok[bool](true)

fn BioDidOperatorKindIndexInitInto(out: var BioDidOperatorKindIndex,
                                     initialCap: int32) =
    var cap = initialCap
    if cap < 8:
        cap = 8
    cap = BioDidOperatorIndexRoundUpPow2(cap)
    BioDidOperatorKindIndexZeroInto(out)
    for i in 0..<cap:
        seqs.Add(out.keys, BioDidOperatorKindKey())
        seqs.Add(out.vals, BioDidOperatorRecord())
        seqs.Add(out.used, 0)

fn BioDidTextHash(text: str): int32 =
    var h: int32
    for i in 0..<strings.Len(text):
        let code = int32(text[i]) & 255
        h = h + code
        h = h + (h << 10)
        h = h ^ (h >> 6)
    h = h + (h << 3)
    h = h ^ (h >> 11)
    h = h + (h << 15)
    return h

fn BioDidOperatorKindKeyHash(key: BioDidOperatorKindKey): int32 =
    return BioDidOperatorIndexHash(key.operatorId) ^ BioDidTextHash(key.bundleKind)

fn BioDidOperatorKindKeyEqual(left: BioDidOperatorKindKey,
                                right: BioDidOperatorKindKey): bool =
    if !layout.FixedBytes32Equal(left.operatorId, right.operatorId):
        return false
    return BioDidTextEqual(left.bundleKind, right.bundleKind)

fn BioDidOperatorKindIndexFindSlot(index: BioDidOperatorKindIndex,
                                     key: BioDidOperatorKindKey,
                                     allowInsert: bool): int32 =
    let cap = index.keys.len
    if cap <= 0:
        return -1
    var probe = (BioDidOperatorKindKeyHash(key) & 0x7fffffff) % cap
    for scanned in 0..<cap:
        if index.used[probe] == 0:
            if allowInsert:
                return probe
            return -1
        if BioDidOperatorKindKeyEqual(index.keys[probe], key):
            return probe
        probe = probe + 1
        if probe >= cap:
            probe = 0
    return -1

fn BioDidOperatorKindIndexFindSlotMut(index: var BioDidOperatorKindIndex,
                                        key: BioDidOperatorKindKey,
                                        allowInsert: bool): int32 =
    let cap = index.keys.len
    if cap <= 0:
        return -1
    var probe = (BioDidOperatorKindKeyHash(key) & 0x7fffffff) % cap
    for scanned in 0..<cap:
        if index.used[probe] == 0:
            if allowInsert:
                return probe
            return -1
        if BioDidOperatorKindKeyEqual(index.keys[probe], key):
            return probe
        probe = probe + 1
        if probe >= cap:
            probe = 0
    return -1

fn BioDidOperatorKindIndexGrow(index: var BioDidOperatorKindIndex): Result[bool] =
    let oldCap = index.keys.len
    let nextCap = oldCap * 2
    var next: BioDidOperatorKindIndex
    BioDidOperatorKindIndexInitInto(next, nextCap)
    for i in 0..<oldCap:
        if index.used[i] != 0:
            let putRes = BioDidOperatorKindIndexPut(next, index.keys[i], index.vals[i])
            if IsErr(putRes):
                return Err[bool](Error(putRes))
    index.keys = next.keys
    index.vals = next.vals
    index.used = next.used
    index.len = next.len
    return Ok[bool](true)

fn BioDidOperatorKindIndexPut(index: var BioDidOperatorKindIndex,
                                key: BioDidOperatorKindKey,
                                record: BioDidOperatorRecord): Result[bool] =
    if index.keys.len <= 0:
        let initCap = BioDidOperatorIndexInitCap
        BioDidOperatorKindIndexInitInto(index, initCap)
    if (index.len + 1) * 10 >= index.keys.len * 7:
        let growRes = BioDidOperatorKindIndexGrow(index)
        if IsErr(growRes):
            return Err[bool](Error(growRes))
    let slot = BioDidOperatorKindIndexFindSlotMut(index, key, true)
    if slot < 0:
        return Err[bool](" bio did: operator kind index slot missing")
    if index.used[slot] == 0:
        index.len = index.len + 1
        index.used[slot] = 1
    index.keys[slot] = key
    index.vals[slot] = record
    return Ok[bool](true)

fn BioDidOperatorRecordShouldReplace(current: BioDidOperatorRecord,
                                       incoming: BioDidOperatorRecord): bool =
    if layout.FixedBytes32Equal(current.operatorId, layout.FixedBytes32()):
        return true
    if incoming.bundleSeq != current.bundleSeq:
        return incoming.bundleSeq > current.bundleSeq
    return incoming.anchorSeq >= current.anchorSeq

fn BioDidOperatorKindIndexLookup(index: BioDidOperatorKindIndex,
                                   operatorId: layout.FixedBytes32,
                                   bundleKind: str): Result[BioDidOperatorRecord] =
    if strings.Len(bundleKind) <= 0:
        return Err[BioDidOperatorRecord](" bio did: operator bundle kind required")
    let slot = BioDidOperatorKindIndexFindSlot(
        index,
        BioDidOperatorKindKey(operatorId: operatorId, bundleKind: bundleKind),
        false
    )
    if slot < 0:
        return Err[BioDidOperatorRecord](" bio did: operator bundle not found")
    let record = index.vals[slot]
    if layout.FixedBytes32Equal(record.operatorId, layout.FixedBytes32()):
        return Err[BioDidOperatorRecord](" bio did: operator bundle record missing")
    return Ok[BioDidOperatorRecord](record)

fn BioDidActionValid(action: str): bool =
    if action == "create":
        return true
    if action == "import":
        return true
    return false

fn BioDidBundleCid(text: str): layout.FixedBytes32 =
    return did.DidHashTagged("cheng.bio.did.bundle", text)

fn BioDidRootSeedFromRootSecret(rootSecret: layout.FixedBytes32): str =
    return layout.FixedBytes32Hex(
        did.DidHashTagged("cheng.bio.did.root.seed", layout.FixedBytes32Hex(rootSecret))
    )

fn BioDidDeviceSeedFromRootSecret(rootSecret: layout.FixedBytes32,
                                    deviceBindingSeed: str): str =
    let rootSecretHex = layout.FixedBytes32Hex(rootSecret)
    var payload = rootSecretHex
    payload = did.DidTextAppend(payload, "|")
    payload = did.DidTextAppend(payload, deviceBindingSeed)
    return layout.FixedBytes32Hex(
        did.DidHashTagged("cheng.bio.did.device.seed", payload)
    )

fn BioDidDeviceBindingSeedHash(deviceBindingSeed: str): layout.FixedBytes32 =
    return biometric.BiometricFingerprintDeviceBindingSeedHash(deviceBindingSeed)

fn BioDidChallengeNonce(action: str,
                          didText: str,
                          devicePeerId: types.Libp2pPeerId,
                          documentVersion: did.DidWord64,
                          bundleSeq: int32): layout.FixedBytes32 =
    var proofText = action
    proofText = did.DidTextAppend(proofText, "|")
    proofText = did.DidTextAppend(proofText, didText)
    proofText = did.DidTextAppend(proofText, "|")
    proofText = did.DidTextAppend(proofText, peer_id.Libp2pPeerIdText(devicePeerId))
    proofText = did.DidTextAppend(proofText, "|")
    proofText = did.DidTextAppend(proofText, did.DidStoreWord64Hex(documentVersion))
    proofText = did.DidTextAppend(proofText, "|")
    proofText = did.DidTextAppend(proofText, strings.IntToStr(bundleSeq))
    return did.DidHashTagged("cheng.bio.did.challenge", proofText)

fn BioDidChainAccountId(didText: str): int32 =
    let digest = did.DidHashTagged("cheng.bio.did.account", didText)
    let value = int64(int32(digest.data[0]) & 255) * int64(16777216) +
                int64(int32(digest.data[1]) & 255) * int64(65536) +
                int64(int32(digest.data[2]) & 255) * int64(256) +
                int64(int32(digest.data[3]) & 255)
    return int32(value % int64(2147483646)) + 1

fn BioDidClearTrustedAttestors() =
    BioDidTrustedAttestorPubKeyHex = ""
    BioDidTrustedAttestorRootKeyId = ""

fn BioDidHasTrustedAttestor(pubKey: layout.FixedBytes65): bool =
    let trustedPubKeyHex = BioDidTrustedAttestorPubKeyHex
    if strings.Len(trustedPubKeyHex) <= 0:
        return false
    return layout.FixedBytes65Hex(pubKey) == trustedPubKeyHex

fn BioDidSetTrustedAttestorHex(pubKeyHex: str): Result[bool] =
    let pubRes: Result[layout.FixedBytes65] = layout.FixedBytes65FromHex(pubKeyHex)
    if IsErr(pubRes):
        return Err[bool](Error(pubRes))
    if !fixed256.P256PublicKey65Valid(Value(pubRes)):
        return Err[bool](" bio did: invalid trusted attestor pubkey")
    BioDidTrustedAttestorPubKeyHex = BioDidCopyText(layout.FixedBytes65Hex(Value(pubRes)))
    BioDidTrustedAttestorRootKeyId = ""
    return Ok[bool](true)

fn BioDidSetTrustedAttestorRootHex(pubKeyHex: str,
                                     rootKeyId: str): Result[bool] =
    if strings.Len(rootKeyId) <= 0:
        return Err[bool](" bio did: trusted attestor root key id required")
    let setRes = BioDidSetTrustedAttestorHex(pubKeyHex)
    if IsErr(setRes):
        return Err[bool](Error(setRes))
    BioDidTrustedAttestorRootKeyId = BioDidCopyText(rootKeyId)
    return Ok[bool](true)

fn BioDidAddTrustedAttestor(pubKey: layout.FixedBytes65): Result[bool] =
    return BioDidSetTrustedAttestorHex(layout.FixedBytes65Hex(pubKey))

fn BioDidAddTrustedAttestorRoot(pubKey: layout.FixedBytes65,
                                  rootKeyId: str): Result[bool] =
    return BioDidSetTrustedAttestorRootHex(layout.FixedBytes65Hex(pubKey), rootKeyId)

fn BioDidTrustedAttestorRequired(pubKey: layout.FixedBytes65): Result[bool] =
    let trustedPubKeyHex = BioDidTrustedAttestorPubKeyHex
    if strings.Len(trustedPubKeyHex) <= 0:
        return Err[bool](" bio did: trusted attestor set required")
    if !BioDidHasTrustedAttestor(pubKey):
        return Err[bool](" bio did: untrusted hardware attestor")
    return Ok[bool](true)

fn BioDidTrustedAttestorRootRequired(rootKeyId: str): Result[bool] =
    let trustedRootKeyId = BioDidTrustedAttestorRootKeyId
    if strings.Len(trustedRootKeyId) <= 0:
        return Err[bool](" bio did: trusted attestor root key id required")
    if !BioDidTextEqual(rootKeyId, trustedRootKeyId):
        var out = " bio did: hardware attestation root key mismatch expected_hex="
        out = did.DidTextAppend(out, did.DidStoreEncodeText(trustedRootKeyId))
        out = did.DidTextAppend(out, " got_hex=")
        out = did.DidTextAppend(out, did.DidStoreEncodeText(rootKeyId))
        return Err[bool](out)
    return Ok[bool](true)

fn BioDidPurposeFromAction(action: str): Result[int32] =
    if action == "create":
        return Ok[int32](biometric.BiometricPurposeDidCreate)
    if action == "import":
        return Ok[int32](biometric.BiometricPurposeDidImport)
    return Err[int32](" bio did: invalid action purpose")

fn BioDidHardwareAttestationCid(attestationText: str): layout.FixedBytes32 =
    return did.DidHashTagged("cheng.bio.did.hardware.attestation", attestationText)

fn BioDidHardwareBindingText(hardware: BioDidHardwareAttestation,
                               action: str,
                               didText: str,
                               devicePeerId: types.Libp2pPeerId,
                               documentVersion: did.DidWord64,
                               bundleSeq: int32,
                               challengeNonce: layout.FixedBytes32): str =
    var out = "cheng_bio_did_hardware_binding_version=1"
    out = did.DidTextAppend(out, "|action=")
    out = did.DidTextAppend(out, action)
    out = did.DidTextAppend(out, "|did=")
    out = did.DidTextAppend(out, didText)
    out = did.DidTextAppend(out, "|device_peer_id=")
    out = did.DidTextAppend(out, peer_id.Libp2pPeerIdText(devicePeerId))
    out = did.DidTextAppend(out, "|document_version=")
    out = did.DidTextAppend(out, did.DidStoreWord64Hex(documentVersion))
    out = did.DidTextAppend(out, "|bundle_seq=")
    out = did.DidTextAppend(out, strings.IntToStr(bundleSeq))
    out = did.DidTextAppend(out, "|challenge_nonce=")
    out = did.DidTextAppend(out, layout.FixedBytes32Hex(challengeNonce))
    out = did.DidTextAppend(out, "|request_id=")
    out = did.DidTextAppend(out, did.DidStoreEncodeText(hardware.requestId))
    out = did.DidTextAppend(out, "|sensor_id=")
    out = did.DidTextAppend(out, did.DidStoreEncodeText(hardware.sensorId))
    out = did.DidTextAppend(out, "|verified_at=")
    out = did.DidTextAppend(out, did.DidStoreWord64Hex(hardware.verifiedAtEpochSeconds))
    out = did.DidTextAppend(out, "|device_binding_seed_hash=")
    out = did.DidTextAppend(out, layout.FixedBytes32Hex(hardware.deviceBindingSeedHash))
    out = did.DidTextAppend(out, "|attestation_cid=")
    out = did.DidTextAppend(out, layout.FixedBytes32Hex(hardware.attestationCid))
    return out

fn BioDidHardwareBindingCid(hardware: BioDidHardwareAttestation,
                              action: str,
                              didText: str,
                              devicePeerId: types.Libp2pPeerId,
                              documentVersion: did.DidWord64,
                              bundleSeq: int32,
                              challengeNonce: layout.FixedBytes32): layout.FixedBytes32 =
    return did.DidHashTagged("cheng.bio.did.hardware.binding",
                               BioDidHardwareBindingText(hardware,
                                                           action,
                                                           didText,
                                                           devicePeerId,
                                                           documentVersion,
                                                           bundleSeq,
                                                           challengeNonce))

fn BioDidInvalidInt32Field(fieldName: str,
                             fieldText: str): str =
    var out = " bio did: invalid int32 field "
    out = did.DidTextAppend(out, fieldName)
    out = did.DidTextAppend(out, " len=")
    out = did.DidTextAppend(out, strings.IntToStr(strings.Len(fieldText)))
    out = did.DidTextAppend(out, " hex=")
    out = did.DidTextAppend(out, did.DidStoreEncodeText(fieldText))
    return out

fn BioDidParseInt32Field(fieldName: str,
                           fieldText: str): Result[int32] =
    let parsedRes = did.DidStoreParseInt32(fieldText)
    if IsErr(parsedRes):
        return Err[int32](BioDidInvalidInt32Field(fieldName, fieldText))
    return parsedRes

fn BioDidParseHardwareAttestation(text: str): Result[BioDidParsedHardwareAttestation] =
    if strings.Len(text) <= 0:
        return Err[BioDidParsedHardwareAttestation](" bio did: missing hardware attestation")
    let lines = strutil.Split(text, '\n')
    let versionTextRes = did.DidStoreFindValue(lines, "cheng_biometric_attestation_version")
    if IsErr(versionTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(versionTextRes))
    let requestIdTextRes = did.DidStoreFindValue(lines, "request_id")
    if IsErr(requestIdTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(requestIdTextRes))
    let purposeTextRes = did.DidStoreFindValue(lines, "purpose")
    if IsErr(purposeTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(purposeTextRes))
    let sensorIdTextRes = did.DidStoreFindValue(lines, "sensor_id")
    if IsErr(sensorIdTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(sensorIdTextRes))
    let platformTextRes = did.DidStoreFindValue(lines, "platform")
    if IsErr(platformTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(platformTextRes))
    let attestationKindTextRes = did.DidStoreFindValue(lines, "attestation_kind")
    if IsErr(attestationKindTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(attestationKindTextRes))
    let rootKeyIdTextRes = did.DidStoreFindValue(lines, "root_key_id")
    if IsErr(rootKeyIdTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(rootKeyIdTextRes))
    let certChainCidTextRes = did.DidStoreFindValue(lines, "cert_chain_cid")
    if IsErr(certChainCidTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(certChainCidTextRes))
    let livenessCidTextRes = did.DidStoreFindValue(lines, "liveness_cid")
    if IsErr(livenessCidTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(livenessCidTextRes))
    let deviceBindingSeedHashTextRes = did.DidStoreFindValue(lines, "device_binding_seed_hash")
    if IsErr(deviceBindingSeedHashTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(deviceBindingSeedHashTextRes))
    let deviceLabelTextRes = did.DidStoreFindValue(lines, "device_label")
    if IsErr(deviceLabelTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(deviceLabelTextRes))
    let featureCommitmentTextRes = did.DidStoreFindValue(lines, "feature_commitment")
    if IsErr(featureCommitmentTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(featureCommitmentTextRes))
    let attestorPubKeyTextRes = did.DidStoreFindValue(lines, "attestor_pub_key")
    if IsErr(attestorPubKeyTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(attestorPubKeyTextRes))
    let signatureTextRes = did.DidStoreFindValue(lines, "signature")
    if IsErr(signatureTextRes):
        return Err[BioDidParsedHardwareAttestation](Error(signatureTextRes))
    let versionRes = BioDidParseInt32Field("cheng_biometric_attestation_version", Value(versionTextRes))
    if IsErr(versionRes):
        return Err[BioDidParsedHardwareAttestation](Error(versionRes))
    let purposeRes = BioDidParseInt32Field("purpose", Value(purposeTextRes))
    if IsErr(purposeRes):
        return Err[BioDidParsedHardwareAttestation](Error(purposeRes))
    let platformRes = BioDidParseInt32Field("platform", Value(platformTextRes))
    if IsErr(platformRes):
        return Err[BioDidParsedHardwareAttestation](Error(platformRes))
    let attestationKindRes = BioDidParseInt32Field("attestation_kind", Value(attestationKindTextRes))
    if IsErr(attestationKindRes):
        return Err[BioDidParsedHardwareAttestation](Error(attestationKindRes))
    let requestIdBytesRes = did.DidStoreDecodeBytes(Value(requestIdTextRes))
    if IsErr(requestIdBytesRes):
        return Err[BioDidParsedHardwareAttestation](Error(requestIdBytesRes))
    let sensorIdBytesRes = did.DidStoreDecodeBytes(Value(sensorIdTextRes))
    if IsErr(sensorIdBytesRes):
        return Err[BioDidParsedHardwareAttestation](Error(sensorIdBytesRes))
    let rootKeyIdBytesRes = did.DidStoreDecodeBytes(Value(rootKeyIdTextRes))
    if IsErr(rootKeyIdBytesRes):
        return Err[BioDidParsedHardwareAttestation](Error(rootKeyIdBytesRes))
    let certChainCidRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(Value(certChainCidTextRes))
    if IsErr(certChainCidRes):
        return Err[BioDidParsedHardwareAttestation](Error(certChainCidRes))
    let livenessCidRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(Value(livenessCidTextRes))
    if IsErr(livenessCidRes):
        return Err[BioDidParsedHardwareAttestation](Error(livenessCidRes))
    let deviceBindingSeedHashRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(Value(deviceBindingSeedHashTextRes))
    if IsErr(deviceBindingSeedHashRes):
        return Err[BioDidParsedHardwareAttestation](Error(deviceBindingSeedHashRes))
    let deviceLabelBytesRes = did.DidStoreDecodeBytes(Value(deviceLabelTextRes))
    if IsErr(deviceLabelBytesRes):
        return Err[BioDidParsedHardwareAttestation](Error(deviceLabelBytesRes))
    let featureCommitmentRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(Value(featureCommitmentTextRes))
    if IsErr(featureCommitmentRes):
        return Err[BioDidParsedHardwareAttestation](Error(featureCommitmentRes))
    let attestorPubKeyRes: Result[layout.FixedBytes65] = layout.FixedBytes65FromHex(Value(attestorPubKeyTextRes))
    if IsErr(attestorPubKeyRes):
        return Err[BioDidParsedHardwareAttestation](Error(attestorPubKeyRes))
    let signatureRes: Result[layout.FixedBytes64] = layout.FixedBytes64FromHex(Value(signatureTextRes))
    if IsErr(signatureRes):
        return Err[BioDidParsedHardwareAttestation](Error(signatureRes))
    var out = BioDidParsedHardwareAttestation()
    out.version = Value(versionRes)
    out.requestId = BytesToString(Value(requestIdBytesRes))
    out.purpose = Value(purposeRes)
    out.sensorId = BytesToString(Value(sensorIdBytesRes))
    out.platform = Value(platformRes)
    out.attestationKind = Value(attestationKindRes)
    out.rootKeyId = BytesToString(Value(rootKeyIdBytesRes))
    out.certChainCid = Value(certChainCidRes)
    out.livenessCid = Value(livenessCidRes)
    out.deviceBindingSeedHash = Value(deviceBindingSeedHashRes)
    out.deviceLabel = BytesToString(Value(deviceLabelBytesRes))
    out.featureCommitment = Value(featureCommitmentRes)
    out.attestorPubKey = Value(attestorPubKeyRes)
    out.signature = Value(signatureRes)
    return Ok[BioDidParsedHardwareAttestation](out)

fn BioDidHardwareAttestationProofValidate(parsed: BioDidParsedHardwareAttestation): Result[bool] =
    if !biometric.BiometricAttestationPlatformValid(parsed.platform):
        return Err[bool](" bio did: invalid hardware attestation platform")
    if !biometric.BiometricAttestationKindValid(parsed.attestationKind):
        return Err[bool](" bio did: invalid hardware attestation kind")
    let parsedRootKeyId = parsed.rootKeyId
    if strings.Len(parsedRootKeyId) <= 0:
        return Err[bool](" bio did: hardware attestation root key id required")
    if layout.FixedBytes32Equal(parsed.certChainCid, layout.FixedBytes32()):
        return Err[bool](" bio did: hardware attestation cert chain cid required")
    if layout.FixedBytes32Equal(parsed.livenessCid, layout.FixedBytes32()):
        return Err[bool](" bio did: hardware attestation liveness cid required")
    let trustRes = BioDidTrustedAttestorRequired(parsed.attestorPubKey)
    if IsErr(trustRes):
        return Err[bool](Error(trustRes))
    let rootRes = BioDidTrustedAttestorRootRequired(parsedRootKeyId)
    if IsErr(rootRes):
        return Err[bool](Error(rootRes))
    return Ok[bool](true)

fn BioDidHardwareAttestationSignatureVerify(parsed: BioDidParsedHardwareAttestation,
                                              text: str): Result[bool] =
    let proofRes = BioDidHardwareAttestationProofValidate(parsed)
    if IsErr(proofRes):
        return Err[bool](Error(proofRes))
    var envelope = biometric.BiometricFingerprintAttestationEnvelope()
    envelope.requestId = parsed.requestId
    envelope.purpose = parsed.purpose
    envelope.sensorId = parsed.sensorId
    envelope.platform = parsed.platform
    envelope.attestationKind = parsed.attestationKind
    envelope.rootKeyId = parsed.rootKeyId
    envelope.certChainCid = parsed.certChainCid
    envelope.livenessCid = parsed.livenessCid
    envelope.deviceBindingSeedHash = parsed.deviceBindingSeedHash
    envelope.deviceLabel = parsed.deviceLabel
    envelope.featureCommitment = parsed.featureCommitment
    envelope.attestorPubKey = parsed.attestorPubKey
    let signable = biometric.BiometricFingerprintAttestationSignable(envelope)
    let attestorPubBytes = layout.FixedBytes65ToBytes(parsed.attestorPubKey)
    let signatureBytes = layout.FixedBytes64ToBytes(parsed.signature)
    let verifyOk = ecnist.EcdsaVerifyTrustedBytes(attestorPubBytes,
                                                  BytesFromString(signable),
                                                  signatureBytes)
    if !verifyOk:
        return Err[bool](" bio did: hardware attestation signature mismatch")
    let canonicalText = biometric.BiometricFingerprintAttestationText(envelope,
                                                                        parsed.signature)
    if !BioDidTextEqual(canonicalText, text):
        return Err[bool](BioDidTextMismatch("non canonical hardware attestation",
                                              canonicalText,
                                              text))
    return Ok[bool](true)

fn BioDidCaptureValidate(capture: BioDidHardwareCapture): Result[bool] =
    if !capture.verified:
        return Err[bool](" bio did: hardware verification required")
    let captureRequestId = capture.requestId
    if strings.Len(captureRequestId) <= 0:
        return Err[bool](" bio did: request id required")
    let captureSensorId = capture.sensorId
    if strings.Len(captureSensorId) <= 0:
        return Err[bool](" bio did: sensor id required")
    let captureBindingSeed = capture.deviceBindingSeed
    if strings.Len(captureBindingSeed) <= 0:
        return Err[bool](" bio did: device binding seed required")
    let captureDeviceLabel = capture.deviceLabel
    if strings.Len(captureDeviceLabel) <= 0:
        return Err[bool](" bio did: device label required")
    let captureAttestation = capture.hardwareAttestation
    if strings.Len(captureAttestation) <= 0:
        return Err[bool](" bio did: hardware attestation required")
    return Ok[bool](true)

fn BioDidCaptureAttestationValidate(capture: BioDidHardwareCapture,
                                      action: str): Result[bool] =
    let purposeRes = BioDidPurposeFromAction(action)
    if IsErr(purposeRes):
        return Err[bool](Error(purposeRes))
    let parsedRes = BioDidParseHardwareAttestation(capture.hardwareAttestation)
    if IsErr(parsedRes):
        return Err[bool](Error(parsedRes))
    let parsed = Value(parsedRes)
    if parsed.version != biometric.BiometricHardwareAttestationVersion:
        return Err[bool](" bio did: unsupported capture attestation version")
    let verifyRes = BioDidHardwareAttestationSignatureVerify(parsed, capture.hardwareAttestation)
    if IsErr(verifyRes):
        return Err[bool](Error(verifyRes))
    if parsed.purpose != Value(purposeRes):
        return Err[bool](" bio did: hardware attestation purpose mismatch")
    if !BioDidTextEqual(parsed.requestId, capture.requestId):
        return Err[bool](" bio did: hardware attestation request id mismatch")
    if !BioDidTextEqual(parsed.sensorId, capture.sensorId):
        return Err[bool](" bio did: hardware attestation sensor id mismatch")
    let wantBindingSeedHash = BioDidDeviceBindingSeedHash(capture.deviceBindingSeed)
    if !layout.FixedBytes32Equal(parsed.deviceBindingSeedHash, wantBindingSeedHash):
        return Err[bool](" bio did: hardware attestation device binding mismatch")
    if !BioDidTextEqual(parsed.deviceLabel, capture.deviceLabel):
        return Err[bool](" bio did: hardware attestation device label mismatch")
    let wantFeatureCommitment = biometric.BiometricFingerprintFeatureCommitment(capture.feature32)
    if !layout.FixedBytes32Equal(parsed.featureCommitment, wantFeatureCommitment):
        return Err[bool](" bio did: hardware attestation feature commitment mismatch")
    return Ok[bool](true)

fn BioDidHardwareAttestationValidate(hardware: BioDidHardwareAttestation,
                                       action: str,
                                       didText: str,
                                       devicePeerId: types.Libp2pPeerId,
                                       documentVersion: did.DidWord64,
                                       bundleSeq: int32,
                                       challengeNonce: layout.FixedBytes32): Result[bool] =
    if hardware.version != BioDidHardwareAttestationVersion:
        return Err[bool](" bio did: unsupported hardware attestation version")
    let hardwareRequestId = hardware.requestId
    if strings.Len(hardwareRequestId) <= 0:
        return Err[bool](" bio did: hardware request id required")
    let hardwareSensorId = hardware.sensorId
    if strings.Len(hardwareSensorId) <= 0:
        return Err[bool](" bio did: hardware sensor id required")
    let hardwareAttestationText = hardware.attestationText
    if strings.Len(hardwareAttestationText) <= 0:
        return Err[bool](" bio did: hardware attestation text required")
    let wantAttestationCid = BioDidHardwareAttestationCid(hardwareAttestationText)
    if !layout.FixedBytes32Equal(wantAttestationCid, hardware.attestationCid):
        return Err[bool](" bio did: hardware attestation cid mismatch")
    let parsedRes = BioDidParseHardwareAttestation(hardwareAttestationText)
    if IsErr(parsedRes):
        return Err[bool](Error(parsedRes))
    let parsed = Value(parsedRes)
    if parsed.version != biometric.BiometricHardwareAttestationVersion:
        return Err[bool](" bio did: unsupported stored hardware attestation version")
    let purposeRes = BioDidPurposeFromAction(action)
    if IsErr(purposeRes):
        return Err[bool](Error(purposeRes))
    let verifyRes = BioDidHardwareAttestationSignatureVerify(parsed, hardwareAttestationText)
    if IsErr(verifyRes):
        return Err[bool](Error(verifyRes))
    if parsed.purpose != Value(purposeRes):
        return Err[bool](" bio did: stored hardware attestation purpose mismatch")
    if !BioDidTextEqual(parsed.requestId, hardwareRequestId):
        return Err[bool](" bio did: stored hardware attestation request id mismatch")
    if !BioDidTextEqual(parsed.sensorId, hardwareSensorId):
        return Err[bool](" bio did: stored hardware attestation sensor id mismatch")
    if !layout.FixedBytes32Equal(parsed.deviceBindingSeedHash, hardware.deviceBindingSeedHash):
        return Err[bool](" bio did: stored hardware attestation binding mismatch")
    let wantBindingCid = BioDidHardwareBindingCid(hardware,
                                                    action,
                                                    didText,
                                                    devicePeerId,
                                                    documentVersion,
                                                    bundleSeq,
                                                    challengeNonce)
    if !layout.FixedBytes32Equal(wantBindingCid, hardware.bindingCid):
        return Err[bool](" bio did: hardware binding cid mismatch")
    return Ok[bool](true)

fn BioDidHardwareAttestationMake(capture: BioDidHardwareCapture,
                                   action: str,
                                   didText: str,
                                   devicePeerId: types.Libp2pPeerId,
                                   documentVersion: did.DidWord64,
                                   bundleSeq: int32,
                                   challengeNonce: layout.FixedBytes32,
                                   epochSeconds: int64): BioDidHardwareAttestation =
    var out = BioDidHardwareAttestation()
    out.version = BioDidHardwareAttestationVersion
    out.requestId = capture.requestId
    out.sensorId = capture.sensorId
    out.verifiedAtEpochSeconds = did.DidWord64FromInt64(epochSeconds)
    out.deviceBindingSeedHash = BioDidDeviceBindingSeedHash(capture.deviceBindingSeed)
    out.attestationText = capture.hardwareAttestation
    out.attestationCid = BioDidHardwareAttestationCid(capture.hardwareAttestation)
    out.bindingCid = BioDidHardwareBindingCid(out,
                                                action,
                                                didText,
                                                devicePeerId,
                                                documentVersion,
                                                bundleSeq,
                                                challengeNonce)
    return out

fn BioDidChainBundleText(bundle: BioDidChainBundle): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "cheng_bio_did_bundle_version", BioDidBundleVersionText)
    out = did.DidStoreAppendLine(out, "action", bundle.action)
    out = did.DidStoreAppendLine(out, "bundle_seq", strings.IntToStr(bundle.bundleSeq))
    out = did.DidStoreAppendLine(out, "did", bundle.didText)
    out = did.DidStoreAppendLine(out, "device_peer_id", peer_id.Libp2pPeerIdText(bundle.devicePeerId))
    out = did.DidStoreAppendLine(out, "document_text", did.DidStoreEncodeText(bundle.documentText))
    out = did.DidStoreAppendLine(out, "record_version", strings.IntToStr(bundle.record.version))
    out = did.DidStoreAppendLine(out, "record_helper", layout.FixedBytes32Hex(bundle.record.helper))
    out = did.DidStoreAppendLine(out, "record_pub_key", layout.FixedBytes65Hex(bundle.record.pubKey))
    out = did.DidStoreAppendLine(out, "record_code_n", strings.IntToStr(bundle.record.codeN))
    out = did.DidStoreAppendLine(out, "record_code_k", strings.IntToStr(bundle.record.codeK))
    out = did.DidStoreAppendLine(out, "record_max_correctable", strings.IntToStr(bundle.record.maxCorrectable))
    out = did.DidStoreAppendLine(out, "record_cid", layout.FixedBytes32Hex(bundle.record.recordCid))
    out = did.DidStoreAppendLine(out, "challenge_nonce", layout.FixedBytes32Hex(bundle.assertion.challengeNonce))
    out = did.DidStoreAppendLine(out, "assert_commit_a", layout.FixedBytes65Hex(bundle.assertion.commitA))
    out = did.DidStoreAppendLine(out, "assert_response_z", layout.FixedBytes32Hex(bundle.assertion.responseZ))
    out = did.DidStoreAppendLine(out, "assert_proof_cid", layout.FixedBytes32Hex(bundle.assertion.proofCid))
    out = did.DidStoreAppendLine(out, "hardware_version", strings.IntToStr(bundle.hardware.version))
    out = did.DidStoreAppendLine(out, "hardware_request_id", did.DidStoreEncodeText(bundle.hardware.requestId))
    out = did.DidStoreAppendLine(out, "hardware_sensor_id", did.DidStoreEncodeText(bundle.hardware.sensorId))
    out = did.DidStoreAppendLine(out, "hardware_verified_at", did.DidStoreWord64Hex(bundle.hardware.verifiedAtEpochSeconds))
    out = did.DidStoreAppendLine(out, "hardware_device_binding_seed_hash", layout.FixedBytes32Hex(bundle.hardware.deviceBindingSeedHash))
    out = did.DidStoreAppendLine(out, "hardware_attestation_text", did.DidStoreEncodeText(bundle.hardware.attestationText))
    out = did.DidStoreAppendLine(out, "hardware_attestation_cid", layout.FixedBytes32Hex(bundle.hardware.attestationCid))
    out = did.DidStoreAppendLine(out, "hardware_binding_cid", layout.FixedBytes32Hex(bundle.hardware.bindingCid))
    return out

fn BioDidChainBundleHeaderParseText(text: str): Result[BioDidChainBundleHeader] =
    if strings.Len(text) <= 0:
        return Err[BioDidChainBundleHeader](" bio did: missing bundle text")
    let lines = strutil.Split(text, '\n')
    let versionRes = did.DidStoreFindValue(lines, "cheng_bio_did_bundle_version")
    if IsErr(versionRes):
        return Err[BioDidChainBundleHeader](Error(versionRes))
    if Value(versionRes) != BioDidBundleVersionText:
        return Err[BioDidChainBundleHeader](" bio did: unsupported bundle version")
    let actionRes = did.DidStoreFindValue(lines, "action")
    if IsErr(actionRes):
        return Err[BioDidChainBundleHeader](Error(actionRes))
    if !BioDidActionValid(Value(actionRes)):
        return Err[BioDidChainBundleHeader](" bio did: invalid bundle action")
    let bundleSeqTextRes = did.DidStoreFindValue(lines, "bundle_seq")
    if IsErr(bundleSeqTextRes):
        return Err[BioDidChainBundleHeader](Error(bundleSeqTextRes))
    let didTextRes = did.DidStoreFindValue(lines, "did")
    if IsErr(didTextRes):
        return Err[BioDidChainBundleHeader](Error(didTextRes))
    let parsedSeqRes = BioDidParseInt32Field("bundle_seq", Value(bundleSeqTextRes))
    if IsErr(parsedSeqRes):
        return Err[BioDidChainBundleHeader](Error(parsedSeqRes))
    if Value(parsedSeqRes) <= 0:
        return Err[BioDidChainBundleHeader](" bio did: invalid bundle seq")
    let didText = Value(didTextRes)
    if strings.Len(didText) <= 0:
        return Err[BioDidChainBundleHeader](" bio did: bundle did required")
    var out: BioDidChainBundleHeader
    out.action = Value(actionRes)
    out.bundleSeq = Value(parsedSeqRes)
    out.didText = didText
    out.bundleCid = BioDidBundleCid(text)
    return Ok[BioDidChainBundleHeader](out)

fn BioDidChainBundleVerify(bundle: BioDidChainBundle): Result[did.DidDocument] =
    if !BioDidActionValid(bundle.action):
        return Err[did.DidDocument](" bio did: invalid bundle action")
    if bundle.bundleSeq <= 0:
        return Err[did.DidDocument](" bio did: invalid bundle seq")
    let documentRes = did.DidDocumentParseText(bundle.documentText)
    if IsErr(documentRes):
        return Err[did.DidDocument](Error(documentRes))
    let document = Value(documentRes)
    let canonicalDocumentTextRes = did.DidDocumentBuildText(document)
    if IsErr(canonicalDocumentTextRes):
        return Err[did.DidDocument](Error(canonicalDocumentTextRes))
    if !BioDidTextEqual(Value(canonicalDocumentTextRes), bundle.documentText):
        return Err[did.DidDocument](" bio did: non canonical document text")
    if !BioDidTextEqual(document.did, bundle.didText):
        return Err[did.DidDocument](" bio did: bundle did mismatch")
    let devicePos = did.DidDocumentFindDevicePos(document, bundle.devicePeerId)
    if devicePos < 0:
        return Err[did.DidDocument](" bio did: device missing from document")
    if document.devices[devicePos].status != did.DidDeviceStatusActive:
        return Err[did.DidDocument](" bio did: device not active")
    let wantNonce = BioDidChallengeNonce(bundle.action,
                                           bundle.didText,
                                           bundle.devicePeerId,
                                           document.version,
                                           bundle.bundleSeq)
    if !layout.FixedBytes32Equal(bundle.assertion.challengeNonce, wantNonce):
        return Err[did.DidDocument](" bio did: challenge nonce mismatch")
    let hardwareOk = BioDidHardwareAttestationValidate(bundle.hardware,
                                                         bundle.action,
                                                         bundle.didText,
                                                         bundle.devicePeerId,
                                                         document.version,
                                                         bundle.bundleSeq,
                                                         wantNonce)
    if IsErr(hardwareOk):
        return Err[did.DidDocument](Error(hardwareOk))
    let verifyRes = bio.BioVerify(bundle.record, wantNonce, bundle.assertion)
    if IsErr(verifyRes):
        return Err[did.DidDocument](Error(verifyRes))
    if !Value(verifyRes):
        return Err[did.DidDocument](" bio did: assertion verify failed")
    let canonicalBundleText = BioDidChainBundleText(bundle)
    let wantCid = BioDidBundleCid(canonicalBundleText)
    if !layout.FixedBytes32Equal(bundle.bundleCid, wantCid):
        return Err[did.DidDocument](" bio did: bundle cid mismatch")
    return Ok[did.DidDocument](document)

fn BioDidChainBundleMake(action: str,
                           bundleSeq: int32,
                           document: did.DidDocument,
                           devicePeerId: types.Libp2pPeerId,
                           record: bio.BioEnrollmentRecord,
                           assertion: bio.BioAssertion,
                           hardware: BioDidHardwareAttestation): Result[BioDidChainBundle] =
    let documentTextRes = did.DidDocumentBuildText(document)
    if IsErr(documentTextRes):
        return Err[BioDidChainBundle](Error(documentTextRes))
    var out = BioDidChainBundle()
    out.action = action
    out.bundleSeq = bundleSeq
    out.didText = document.did
    out.devicePeerId = devicePeerId
    out.documentText = Value(documentTextRes)
    out.record = record
    out.assertion = assertion
    out.hardware = hardware
    out.bundleCid = BioDidBundleCid(BioDidChainBundleText(out))
    let verifyRes = BioDidChainBundleVerify(out)
    if IsErr(verifyRes):
        return Err[BioDidChainBundle](Error(verifyRes))
    return Ok[BioDidChainBundle](out)

fn BioDidChainBundleParseRecord(lines: str[]): Result[bio.BioEnrollmentRecord] =
    let recordVersionTextRes = did.DidStoreFindValue(lines, "record_version")
    if IsErr(recordVersionTextRes):
        return Err[bio.BioEnrollmentRecord](Error(recordVersionTextRes))
    let recordHelperTextRes = did.DidStoreFindValue(lines, "record_helper")
    if IsErr(recordHelperTextRes):
        return Err[bio.BioEnrollmentRecord](Error(recordHelperTextRes))
    let recordPubKeyTextRes = did.DidStoreFindValue(lines, "record_pub_key")
    if IsErr(recordPubKeyTextRes):
        return Err[bio.BioEnrollmentRecord](Error(recordPubKeyTextRes))
    let recordCodeNTextRes = did.DidStoreFindValue(lines, "record_code_n")
    if IsErr(recordCodeNTextRes):
        return Err[bio.BioEnrollmentRecord](Error(recordCodeNTextRes))
    let recordCodeKTextRes = did.DidStoreFindValue(lines, "record_code_k")
    if IsErr(recordCodeKTextRes):
        return Err[bio.BioEnrollmentRecord](Error(recordCodeKTextRes))
    let recordMaxCorrectableTextRes = did.DidStoreFindValue(lines, "record_max_correctable")
    if IsErr(recordMaxCorrectableTextRes):
        return Err[bio.BioEnrollmentRecord](Error(recordMaxCorrectableTextRes))
    let recordCidTextRes = did.DidStoreFindValue(lines, "record_cid")
    if IsErr(recordCidTextRes):
        return Err[bio.BioEnrollmentRecord](Error(recordCidTextRes))
    let recordVersionRes = BioDidParseInt32Field("record_version", Value(recordVersionTextRes))
    if IsErr(recordVersionRes):
        return Err[bio.BioEnrollmentRecord](Error(recordVersionRes))
    let recordHelperRes = layout.FixedBytes32FromHex(Value(recordHelperTextRes))
    if IsErr(recordHelperRes):
        return Err[bio.BioEnrollmentRecord](Error(recordHelperRes))
    let recordPubKeyRes = layout.FixedBytes65FromHex(Value(recordPubKeyTextRes))
    if IsErr(recordPubKeyRes):
        return Err[bio.BioEnrollmentRecord](Error(recordPubKeyRes))
    let recordCodeNRes = BioDidParseInt32Field("record_code_n", Value(recordCodeNTextRes))
    if IsErr(recordCodeNRes):
        return Err[bio.BioEnrollmentRecord](Error(recordCodeNRes))
    let recordCodeKRes = BioDidParseInt32Field("record_code_k", Value(recordCodeKTextRes))
    if IsErr(recordCodeKRes):
        return Err[bio.BioEnrollmentRecord](Error(recordCodeKRes))
    let recordMaxCorrectableRes = BioDidParseInt32Field("record_max_correctable", Value(recordMaxCorrectableTextRes))
    if IsErr(recordMaxCorrectableRes):
        return Err[bio.BioEnrollmentRecord](Error(recordMaxCorrectableRes))
    let recordCidRes = layout.FixedBytes32FromHex(Value(recordCidTextRes))
    if IsErr(recordCidRes):
        return Err[bio.BioEnrollmentRecord](Error(recordCidRes))
    var record = bio.BioEnrollmentRecord()
    record.version = Value(recordVersionRes)
    record.helper = Value(recordHelperRes)
    record.pubKey = Value(recordPubKeyRes)
    record.codeN = Value(recordCodeNRes)
    record.codeK = Value(recordCodeKRes)
    record.maxCorrectable = Value(recordMaxCorrectableRes)
    record.recordCid = Value(recordCidRes)
    return Ok[bio.BioEnrollmentRecord](record)

fn BioDidChainBundleParseAssertion(lines: str,
                                     recordCid: layout.FixedBytes32): Result[bio.BioAssertion] =
    let challengeNonceTextRes = did.DidStoreFindValue(lines, "challenge_nonce")
    if IsErr(challengeNonceTextRes):
        return Err[bio.BioAssertion](Error(challengeNonceTextRes))
    let assertCommitATextRes = did.DidStoreFindValue(lines, "assert_commit_a")
    if IsErr(assertCommitATextRes):
        return Err[bio.BioAssertion](Error(assertCommitATextRes))
    let assertResponseZTextRes = did.DidStoreFindValue(lines, "assert_response_z")
    if IsErr(assertResponseZTextRes):
        return Err[bio.BioAssertion](Error(assertResponseZTextRes))
    let assertProofCidTextRes = did.DidStoreFindValue(lines, "assert_proof_cid")
    if IsErr(assertProofCidTextRes):
        return Err[bio.BioAssertion](Error(assertProofCidTextRes))
    let challengeNonceRes = layout.FixedBytes32FromHex(Value(challengeNonceTextRes))
    if IsErr(challengeNonceRes):
        return Err[bio.BioAssertion](Error(challengeNonceRes))
    let assertCommitARes = layout.FixedBytes65FromHex(Value(assertCommitATextRes))
    if IsErr(assertCommitARes):
        return Err[bio.BioAssertion](Error(assertCommitARes))
    let assertResponseZRes = layout.FixedBytes32FromHex(Value(assertResponseZTextRes))
    if IsErr(assertResponseZRes):
        return Err[bio.BioAssertion](Error(assertResponseZRes))
    let assertProofCidRes = layout.FixedBytes32FromHex(Value(assertProofCidTextRes))
    if IsErr(assertProofCidRes):
        return Err[bio.BioAssertion](Error(assertProofCidRes))
    var assertion = bio.BioAssertion()
    assertion.recordCid = recordCid
    assertion.challengeNonce = Value(challengeNonceRes)
    assertion.commitA = Value(assertCommitARes)
    assertion.responseZ = Value(assertResponseZRes)
    assertion.proofCid = Value(assertProofCidRes)
    return Ok[bio.BioAssertion](assertion)

fn BioDidChainBundleParseHardware(lines: str): Result[BioDidHardwareAttestation] =
    let hardwareVersionTextRes = did.DidStoreFindValue(lines, "hardware_version")
    if IsErr(hardwareVersionTextRes):
        return Err[BioDidHardwareAttestation](Error(hardwareVersionTextRes))
    let hardwareRequestIdTextRes = did.DidStoreFindValue(lines, "hardware_request_id")
    if IsErr(hardwareRequestIdTextRes):
        return Err[BioDidHardwareAttestation](Error(hardwareRequestIdTextRes))
    let hardwareSensorIdTextRes = did.DidStoreFindValue(lines, "hardware_sensor_id")
    if IsErr(hardwareSensorIdTextRes):
        return Err[BioDidHardwareAttestation](Error(hardwareSensorIdTextRes))
    let hardwareVerifiedAtTextRes = did.DidStoreFindValue(lines, "hardware_verified_at")
    if IsErr(hardwareVerifiedAtTextRes):
        return Err[BioDidHardwareAttestation](Error(hardwareVerifiedAtTextRes))
    let hardwareDeviceBindingSeedHashTextRes = did.DidStoreFindValue(lines, "hardware_device_binding_seed_hash")
    if IsErr(hardwareDeviceBindingSeedHashTextRes):
        return Err[BioDidHardwareAttestation](Error(hardwareDeviceBindingSeedHashTextRes))
    let hardwareAttestationTextRes = did.DidStoreFindValue(lines, "hardware_attestation_text")
    if IsErr(hardwareAttestationTextRes):
        return Err[BioDidHardwareAttestation](Error(hardwareAttestationTextRes))
    let hardwareAttestationCidTextRes = did.DidStoreFindValue(lines, "hardware_attestation_cid")
    if IsErr(hardwareAttestationCidTextRes):
        return Err[BioDidHardwareAttestation](Error(hardwareAttestationCidTextRes))
    let hardwareBindingCidTextRes = did.DidStoreFindValue(lines, "hardware_binding_cid")
    if IsErr(hardwareBindingCidTextRes):
        return Err[BioDidHardwareAttestation](Error(hardwareBindingCidTextRes))
    let hardwareVersionRes = BioDidParseInt32Field("hardware_version", Value(hardwareVersionTextRes))
    if IsErr(hardwareVersionRes):
        return Err[BioDidHardwareAttestation](Error(hardwareVersionRes))
    let hardwareRequestIdBytesRes = did.DidStoreDecodeBytes(Value(hardwareRequestIdTextRes))
    if IsErr(hardwareRequestIdBytesRes):
        return Err[BioDidHardwareAttestation](Error(hardwareRequestIdBytesRes))
    let hardwareSensorIdBytesRes = did.DidStoreDecodeBytes(Value(hardwareSensorIdTextRes))
    if IsErr(hardwareSensorIdBytesRes):
        return Err[BioDidHardwareAttestation](Error(hardwareSensorIdBytesRes))
    let hardwareVerifiedAtRes = did.DidStoreParseWord64Hex(Value(hardwareVerifiedAtTextRes))
    if IsErr(hardwareVerifiedAtRes):
        return Err[BioDidHardwareAttestation](Error(hardwareVerifiedAtRes))
    let hardwareDeviceBindingSeedHashRes = layout.FixedBytes32FromHex(Value(hardwareDeviceBindingSeedHashTextRes))
    if IsErr(hardwareDeviceBindingSeedHashRes):
        return Err[BioDidHardwareAttestation](Error(hardwareDeviceBindingSeedHashRes))
    let hardwareAttestationBytesRes = did.DidStoreDecodeBytes(Value(hardwareAttestationTextRes))
    if IsErr(hardwareAttestationBytesRes):
        return Err[BioDidHardwareAttestation](Error(hardwareAttestationBytesRes))
    let hardwareAttestationCidRes = layout.FixedBytes32FromHex(Value(hardwareAttestationCidTextRes))
    if IsErr(hardwareAttestationCidRes):
        return Err[BioDidHardwareAttestation](Error(hardwareAttestationCidRes))
    let hardwareBindingCidRes = layout.FixedBytes32FromHex(Value(hardwareBindingCidTextRes))
    if IsErr(hardwareBindingCidRes):
        return Err[BioDidHardwareAttestation](Error(hardwareBindingCidRes))
    var hardware = BioDidHardwareAttestation()
    hardware.version = Value(hardwareVersionRes)
    hardware.requestId = BytesToString(Value(hardwareRequestIdBytesRes))
    hardware.sensorId = BytesToString(Value(hardwareSensorIdBytesRes))
    hardware.verifiedAtEpochSeconds = Value(hardwareVerifiedAtRes)
    hardware.deviceBindingSeedHash = Value(hardwareDeviceBindingSeedHashRes)
    hardware.attestationText = BytesToString(Value(hardwareAttestationBytesRes))
    hardware.attestationCid = Value(hardwareAttestationCidRes)
    hardware.bindingCid = Value(hardwareBindingCidRes)
    return Ok[BioDidHardwareAttestation](hardware)

fn BioDidChainBundleParseText(text: str): Result[BioDidChainBundle] =
    let textLen = strings.Len(text)
    if textLen <= 0:
        return Err[BioDidChainBundle](" bio did: missing bundle text")
    let lines = strutil.Split(text, '\n')
    let versionRes = did.DidStoreFindValue(lines, "cheng_bio_did_bundle_version")
    if IsErr(versionRes):
        return Err[BioDidChainBundle](Error(versionRes))
    if Value(versionRes) != BioDidBundleVersionText:
        return Err[BioDidChainBundle](" bio did: unsupported bundle version")
    let actionRes = did.DidStoreFindValue(lines, "action")
    if IsErr(actionRes):
        return Err[BioDidChainBundle](Error(actionRes))
    let bundleSeqRes = did.DidStoreFindValue(lines, "bundle_seq")
    if IsErr(bundleSeqRes):
        return Err[BioDidChainBundle](Error(bundleSeqRes))
    let didTextRes = did.DidStoreFindValue(lines, "did")
    if IsErr(didTextRes):
        return Err[BioDidChainBundle](Error(didTextRes))
    let devicePeerTextRes = did.DidStoreFindValue(lines, "device_peer_id")
    if IsErr(devicePeerTextRes):
        return Err[BioDidChainBundle](Error(devicePeerTextRes))
    let documentTextHexRes = did.DidStoreFindValue(lines, "document_text")
    if IsErr(documentTextHexRes):
        return Err[BioDidChainBundle](Error(documentTextHexRes))
    let parsedSeqRes = BioDidParseInt32Field("bundle_seq", Value(bundleSeqRes))
    if IsErr(parsedSeqRes):
        return Err[BioDidChainBundle](Error(parsedSeqRes))
    let devicePeerRes = did.DidPeerIdFromHex(Value(devicePeerTextRes))
    if IsErr(devicePeerRes):
        return Err[BioDidChainBundle](Error(devicePeerRes))
    let documentBytesRes = did.DidStoreDecodeBytes(Value(documentTextHexRes))
    if IsErr(documentBytesRes):
        return Err[BioDidChainBundle](Error(documentBytesRes))
    let recordRes = BioDidChainBundleParseRecord(lines)
    if IsErr(recordRes):
        return Err[BioDidChainBundle](Error(recordRes))
    let assertionRes = BioDidChainBundleParseAssertion(lines, Value(recordRes).recordCid)
    if IsErr(assertionRes):
        return Err[BioDidChainBundle](Error(assertionRes))
    let hardwareRes = BioDidChainBundleParseHardware(lines)
    if IsErr(hardwareRes):
        return Err[BioDidChainBundle](Error(hardwareRes))
    var out = BioDidChainBundle()
    out.action = Value(actionRes)
    out.bundleSeq = Value(parsedSeqRes)
    out.didText = Value(didTextRes)
    out.devicePeerId = Value(devicePeerRes)
    out.documentText = BytesToString(Value(documentBytesRes))
    out.record = Value(recordRes)
    out.assertion = Value(assertionRes)
    out.hardware = Value(hardwareRes)
    out.bundleCid = BioDidBundleCid(text)
    let verifyRes = BioDidChainBundleVerify(out)
    if IsErr(verifyRes):
        return Err[BioDidChainBundle](Error(verifyRes))
    if !BioDidTextEqual(BioDidChainBundleText(out), text):
        return Err[BioDidChainBundle](" bio did: non canonical bundle text")
    out.bundleCid = BioDidBundleCid(text)
    return Ok[BioDidChainBundle](out)

fn BioDidChainCurrentBundleSeq(node: var chain.ChainNode, didText: str): int32 =
    let accountId = BioDidChainAccountId(didText)
    var maxSeq = 0
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.ConsensusKindMint:
            continue
        if event.assetId != BioDidChainAssetId:
            continue
        if event.toAccount != accountId:
            continue
        if event.fromAccount > maxSeq:
            maxSeq = event.fromAccount
    return maxSeq

fn BioDidChunkCount(payloadLen: int32): int32 =
    if payloadLen <= 28:
        return 1
    return 1 + ((payloadLen - 28 + 31) / 32)

fn BioDidChunkFixed(payload: Bytes, chunkIndex: int32): layout.FixedBytes32 =
    let raw = BytesAlloc(32)
    for i in 0..<32:
        BytesSet(raw, i, 0)
    if chunkIndex == 0:
        BytesSet(raw, 0, (payload.len >> 24) & 255)
        BytesSet(raw, 1, (payload.len >> 16) & 255)
        BytesSet(raw, 2, (payload.len >> 8) & 255)
        BytesSet(raw, 3, payload.len & 255)
        var copied = 0
        var limit = payload.len
        if limit > 28:
            limit = 28
        for copied in copied..<limit:
            BytesSet(raw, 4 + copied, BytesGet(payload, copied))
    else:
        let start = 28 + ((chunkIndex - 1) * 32)
        var copied = 0
        while copied < 32 && (start + copied) < payload.len:
            BytesSet(raw, copied, BytesGet(payload, start + copied))
            copied = copied + 1
    let fixedRes = layout.FixedBytes32FromBytes(raw)
    system.Assert(IsOk(fixedRes), " bio did: chunk fixed32")
    return Value(fixedRes)

fn BioDidChunksToPayload(chunks: layout.FixedBytes32[]): Result[Bytes] =
    if chunks.len <= 0:
        return Err[Bytes](" bio did: missing chunks")
    let head = layout.FixedBytes32ToBytes(chunks[0])
    let payloadLen = int32(
        int64(BytesGet(head, 0) & 255) * int64(16777216) +
        int64(BytesGet(head, 1) & 255) * int64(65536) +
        int64(BytesGet(head, 2) & 255) * int64(256) +
        int64(BytesGet(head, 3) & 255)
    )
    if payloadLen < 0:
        return Err[Bytes](" bio did: invalid chunk length")
    let wantChunkCount = BioDidChunkCount(payloadLen)
    if wantChunkCount != chunks.len:
        return Err[Bytes](" bio did: chunk count mismatch")
    let out = BytesAlloc(payloadLen)
    var copied = 0
    var headPos = 4
    while headPos < 32 && copied < payloadLen:
        BytesSet(out, copied, BytesGet(head, headPos))
        copied = copied + 1
        headPos = headPos + 1
    for i in 1..<chunks.len:
        let chunkBytes = layout.FixedBytes32ToBytes(chunks[i])
        var j = 0
        while j < 32 && copied < payloadLen:
            BytesSet(out, copied, BytesGet(chunkBytes, j))
            copied = copied + 1
            j = j + 1
    if copied != payloadLen:
        return Err[Bytes](" bio did: payload size mismatch")
    return Ok[Bytes](out)

fn BioDidChainAppendBundle(node: var chain.ChainNode,
                             bundle: BioDidChainBundle): Result[layout.FixedBytes32] =
    let verifyRes = BioDidChainBundleVerify(bundle)
    if IsErr(verifyRes):
        return Err[layout.FixedBytes32](Error(verifyRes))
    let expectedSeq = BioDidChainCurrentBundleSeq(node, bundle.didText) + 1
    if bundle.bundleSeq != expectedSeq:
        return Err[layout.FixedBytes32](" bio did: bundle seq mismatch")
    let requestSeenRes = BioDidChainRequestIdSeen(node, bundle.didText, bundle.hardware.requestId)
    if IsErr(requestSeenRes):
        return Err[layout.FixedBytes32](Error(requestSeenRes))
    if Value(requestSeenRes):
        return Err[layout.FixedBytes32](" bio did: duplicated hardware request id")
    let accountId = BioDidChainAccountId(bundle.didText)
    let payload = BytesFromString(BioDidChainBundleText(bundle))
    let chunkCount = BioDidChunkCount(payload.len)
    var lastEventCid = layout.FixedBytes32()
    for chunkIndex in 0..<chunkCount:
        let parentCid = chain.ChainNodeAccountHead(node.index, BioDidChainAssetId, accountId)
        var event = consensus.ChainEventMint(BioDidChainAssetId,
                                               accountId,
                                               parentCid,
                                               int64(chunkIndex + 1),
                                               node.nextEpoch,
                                               node.nextGanzhi,
                                               chain.ChainNodeSpaceSlot(accountId, accountId),
                                               node.nextTick)
        event.fromAccount = bundle.bundleSeq
        event.fromParentCid = BioDidChunkFixed(payload, chunkIndex)
        event.bodyCid = consensus.ChainEventBodyCid(event)
        let applyRes = chain.ChainNodeApplyEvent(node, event)
        if IsErr(applyRes):
            return Err[layout.FixedBytes32](Error(applyRes))
        lastEventCid = Value(applyRes)
    return Ok[layout.FixedBytes32](lastEventCid)

fn BioDidChainLoadTextForSeq(node: var chain.ChainNode,
                               didText: str,
                               bundleSeq: int32): Result[str] =
    let accountId = BioDidChainAccountId(didText)
    return BioDidChainLoadTextForAccountSeq(node, accountId, bundleSeq)

fn BioDidChainLoadTextForAccountSeq(node: var chain.ChainNode,
                                      accountId: int32,
                                      bundleSeq: int32): Result[str] =
    var maxOrdinal = 0
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.ConsensusKindMint:
            continue
        if event.assetId != BioDidChainAssetId:
            continue
        if event.toAccount != accountId:
            continue
        if event.fromAccount != bundleSeq:
            continue
        let ordinal = int32(event.amount)
        if int64(ordinal) != event.amount:
            return Err[str](" bio did: chunk ordinal overflow")
        if ordinal > maxOrdinal:
            maxOrdinal = ordinal
    if maxOrdinal <= 0:
        return Err[str](" bio did: bundle seq missing")
    var chunks: layout.FixedBytes32[]
    var ordinal = 1
    for ordinal in range(1, = maxOrdinal):

        var foundCount = 0
        var chunk = layout.FixedBytes32()
        for i in 0..<node.events.len:
            let event = node.events[i]
            if event.kind != consensus.ConsensusKindMint:
                continue
            if event.assetId != BioDidChainAssetId:
                continue
            if event.toAccount != accountId:
                continue
            if event.fromAccount != bundleSeq:
                continue
            if event.amount != int64(ordinal):
                continue
            foundCount = foundCount + 1
            chunk = event.fromParentCid
        if foundCount != 1:
            return Err[str](" bio did: chunk multiplicity mismatch")
        seqs.Add(chunks, chunk)
        ordinal = ordinal + 1
    let payloadRes = BioDidChunksToPayload(chunks)
    if IsErr(payloadRes):
        return Err[str](Error(payloadRes))
    return Ok[str](BytesToString(Value(payloadRes)))

fn BioDidChainLatestBundles(node: var chain.ChainNode): Result[BioDidChainBundle[]] =
    var accountIds: int32[]
    accountIds = []
    var maxSeqs: int32[]
    maxSeqs = []
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.ConsensusKindMint:
            continue
        if event.assetId != BioDidChainAssetId:
            continue
        let accountId = event.toAccount
        let bundleSeq = event.fromAccount
        var slot = -1
        for j in 0..<accountIds.len:
            if accountIds[j] == accountId:
                slot = j
                break
        if slot < 0:
            seqs.Add(accountIds, accountId)
            seqs.Add(maxSeqs, bundleSeq)
            continue
        if bundleSeq > maxSeqs[slot]:
            maxSeqs[slot] = bundleSeq
    var out: BioDidChainBundle[]
    out = []
    for i in 0..<accountIds.len:
        let textRes = BioDidChainLoadTextForAccountSeq(node, accountIds[i], maxSeqs[i])
        if IsErr(textRes):
            return Err[BioDidChainBundle[]](Error(textRes))
        let bundleRes = BioDidChainBundleParseText(Value(textRes))
        if IsErr(bundleRes):
            return Err[BioDidChainBundle[]](Error(bundleRes))
        let bundle = Value(bundleRes)
        if bundle.bundleSeq != maxSeqs[i]:
            return Err[BioDidChainBundle[]](" bio did: latest bundle seq mismatch")
        seqs.Add(out, bundle)
    return Ok[BioDidChainBundle[]](out)

fn BioDidChainLoadLatest(node: var chain.ChainNode,
                           didText: str): Result[BioDidChainBundle] =
    let bundleSeq = BioDidChainCurrentBundleSeq(node, didText)
    if bundleSeq <= 0:
        return Err[BioDidChainBundle](" bio did: did not found on chain")
    let textRes = BioDidChainLoadTextForSeq(node, didText, bundleSeq)
    if IsErr(textRes):
        return Err[BioDidChainBundle](Error(textRes))
    let bundleRes = BioDidChainBundleParseText(Value(textRes))
    if IsErr(bundleRes):
        return Err[BioDidChainBundle](Error(bundleRes))
    if Value(bundleRes).bundleSeq != bundleSeq:
        return Err[BioDidChainBundle](" bio did: latest bundle seq mismatch")
    if !BioDidTextEqual(Value(bundleRes).didText, didText):
        return Err[BioDidChainBundle](" bio did: latest bundle did mismatch")
    return Ok[BioDidChainBundle](Value(bundleRes))

fn BioDidOperatorIdFromRecoverySecretHex(recoverySecretHex: str): Result[layout.FixedBytes32] =
    let secretRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(recoverySecretHex)
    if IsErr(secretRes):
        return Err[layout.FixedBytes32](Error(secretRes))
    return Ok[layout.FixedBytes32](
        did.DidHashTagged(BioDidOperatorTag, layout.FixedBytes32Hex(Value(secretRes)))
    )

fn BioDidOperatorAnchorLegacyText(anchor: BioDidOperatorAnchor): str =
    var out = ""
    out = did.DidStoreAppendLine(out,
                                   "cheng_bio_did_operator_anchor_version",
                                   BioDidOperatorAnchorVersionTextLegacy)
    out = did.DidStoreAppendLine(out, "operator_id", layout.FixedBytes32Hex(anchor.operatorId))
    out = did.DidStoreAppendLine(out, "recovery_mode", anchor.recoveryMode)
    out = did.DidStoreAppendLine(out, "did", anchor.didText)
    out = did.DidStoreAppendLine(out, "bundle_seq", strings.IntToStr(anchor.bundleSeq))
    out = did.DidStoreAppendLine(out, "bundle_cid", layout.FixedBytes32Hex(anchor.bundleCid))
    out = did.DidStoreAppendLine(out, "bundle_text", did.DidStoreEncodeText(anchor.bundleText))
    out = did.DidStoreAppendLine(out, "event_id", did.DidStoreEncodeText(anchor.eventId))
    return out

fn BioDidOperatorAnchorText(anchor: BioDidOperatorAnchor): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "cheng_bio_did_operator_anchor_version", BioDidOperatorAnchorVersionText)
    out = did.DidStoreAppendLine(out, "operator_id", layout.FixedBytes32Hex(anchor.operatorId))
    out = did.DidStoreAppendLine(out, "bundle_kind", BioDidOperatorBundleKindNormalize(anchor.bundleKind))
    out = did.DidStoreAppendLine(out, "recovery_mode", anchor.recoveryMode)
    out = did.DidStoreAppendLine(out, "did", anchor.didText)
    out = did.DidStoreAppendLine(out, "subject_did", anchor.subjectDidText)
    out = did.DidStoreAppendLine(out, "device_did", anchor.deviceDidText)
    out = did.DidStoreAppendLine(out, "bundle_seq", strings.IntToStr(anchor.bundleSeq))
    out = did.DidStoreAppendLine(out, "bundle_cid", layout.FixedBytes32Hex(anchor.bundleCid))
    out = did.DidStoreAppendLine(out, "bundle_text", did.DidStoreEncodeText(anchor.bundleText))
    out = did.DidStoreAppendLine(out, "event_id", did.DidStoreEncodeText(anchor.eventId))
    return out

fn BioDidOperatorAnchorVerify(anchor: BioDidOperatorAnchor): Result[bool] =
    if layout.FixedBytes32Equal(anchor.operatorId, layout.FixedBytes32()):
        return Err[bool](" bio did: operator id required")
    let normalizedBundleKind = BioDidOperatorBundleKindNormalize(anchor.bundleKind)
    if strings.Len(normalizedBundleKind) <= 0:
        return Err[bool](" bio did: operator bundle kind required")
    if !BioDidTextEqual(anchor.recoveryMode, BioDidRecoveryModeSecretV1):
        return Err[bool](" bio did: unsupported operator recovery mode")
    let anchorDidText = anchor.didText
    if strings.Len(anchorDidText) <= 0:
        return Err[bool](" bio did: operator did required")
    let anchorSubjectDidText = anchor.subjectDidText
    if strings.Len(anchorSubjectDidText) <= 0:
        return Err[bool](" bio did: operator subject did required")
    let anchorDeviceDidText = anchor.deviceDidText
    if strings.Len(anchorDeviceDidText) <= 0:
        return Err[bool](" bio did: operator device did required")
    if !BioDidTextEqual(anchorDidText, anchorSubjectDidText):
        return Err[bool](" bio did: operator primary did mismatch")
    if anchor.bundleSeq <= 0:
        return Err[bool](" bio did: operator bundle seq required")
    if layout.FixedBytes32Equal(anchor.bundleCid, layout.FixedBytes32()):
        return Err[bool](" bio did: operator bundle cid required")
    let anchorBundleText = anchor.bundleText
    if strings.Len(anchorBundleText) <= 0:
        return Err[bool](" bio did: operator bundle text required")
    let anchorEventId = anchor.eventId
    if strings.Len(anchorEventId) <= 0:
        return Err[bool](" bio did: operator event id required")
    let headerRes = BioDidChainBundleHeaderParseText(anchorBundleText)
    if IsErr(headerRes):
        return Err[bool](Error(headerRes))
    let header = Value(headerRes)
    if !BioDidTextEqual(header.didText, anchorDidText):
        return Err[bool](" bio did: operator did mismatch")
    if header.bundleSeq != anchor.bundleSeq:
        return Err[bool](" bio did: operator bundle seq mismatch")
    if !layout.FixedBytes32Equal(header.bundleCid, anchor.bundleCid):
        return Err[bool](" bio did: operator bundle cid mismatch")
    return Ok[bool](true)

fn BioDidOperatorAnchorParseText(text: str): Result[BioDidOperatorAnchor] =
    if strings.Len(text) <= 0:
        return Err[BioDidOperatorAnchor](" bio did: missing operator anchor text")
    let lines = strutil.Split(text, '\n')
    let versionRes = did.DidStoreFindValue(lines, "cheng_bio_did_operator_anchor_version")
    if IsErr(versionRes):
        return Err[BioDidOperatorAnchor](Error(versionRes))
    let versionText = Value(versionRes)
    let isV2 = BioDidTextEqual(versionText, BioDidOperatorAnchorVersionText)
    let isV1 = BioDidTextEqual(versionText, BioDidOperatorAnchorVersionTextLegacy)
    if !isV2 && !isV1:
        return Err[BioDidOperatorAnchor](" bio did: unsupported operator anchor version")
    let operatorIdTextRes = did.DidStoreFindValue(lines, "operator_id")
    if IsErr(operatorIdTextRes):
        return Err[BioDidOperatorAnchor](Error(operatorIdTextRes))
    var bundleKindText = BioDidOperatorBundleKindAndroidBioV1
    if isV2:
        let bundleKindTextRes = did.DidStoreFindValue(lines, "bundle_kind")
        if IsErr(bundleKindTextRes):
            return Err[BioDidOperatorAnchor](Error(bundleKindTextRes))
        bundleKindText = BioDidOperatorBundleKindNormalize(Value(bundleKindTextRes))
    let recoveryModeRes = did.DidStoreFindValue(lines, "recovery_mode")
    if IsErr(recoveryModeRes):
        return Err[BioDidOperatorAnchor](Error(recoveryModeRes))
    let didTextRes = did.DidStoreFindValue(lines, "did")
    if IsErr(didTextRes):
        return Err[BioDidOperatorAnchor](Error(didTextRes))
    let didText = Value(didTextRes)
    var subjectDidText = didText
    var deviceDidText = didText
    if isV2:
        let subjectDidTextRes = did.DidStoreFindValue(lines, "subject_did")
        if IsErr(subjectDidTextRes):
            return Err[BioDidOperatorAnchor](Error(subjectDidTextRes))
        subjectDidText = Value(subjectDidTextRes)
        let deviceDidTextRes = did.DidStoreFindValue(lines, "device_did")
        if IsErr(deviceDidTextRes):
            return Err[BioDidOperatorAnchor](Error(deviceDidTextRes))
        deviceDidText = Value(deviceDidTextRes)
    let bundleSeqTextRes = did.DidStoreFindValue(lines, "bundle_seq")
    if IsErr(bundleSeqTextRes):
        return Err[BioDidOperatorAnchor](Error(bundleSeqTextRes))
    let bundleCidTextRes = did.DidStoreFindValue(lines, "bundle_cid")
    if IsErr(bundleCidTextRes):
        return Err[BioDidOperatorAnchor](Error(bundleCidTextRes))
    let bundleTextEncodedRes = did.DidStoreFindValue(lines, "bundle_text")
    if IsErr(bundleTextEncodedRes):
        return Err[BioDidOperatorAnchor](Error(bundleTextEncodedRes))
    let eventIdEncodedRes = did.DidStoreFindValue(lines, "event_id")
    if IsErr(eventIdEncodedRes):
        return Err[BioDidOperatorAnchor](Error(eventIdEncodedRes))
    let operatorIdRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(Value(operatorIdTextRes))
    if IsErr(operatorIdRes):
        return Err[BioDidOperatorAnchor](Error(operatorIdRes))
    let bundleSeqRes = did.DidStoreParseInt32(Value(bundleSeqTextRes))
    if IsErr(bundleSeqRes):
        return Err[BioDidOperatorAnchor](Error(bundleSeqRes))
    let bundleCidRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(Value(bundleCidTextRes))
    if IsErr(bundleCidRes):
        return Err[BioDidOperatorAnchor](Error(bundleCidRes))
    let bundleTextBytesRes = did.DidStoreDecodeBytes(Value(bundleTextEncodedRes))
    if IsErr(bundleTextBytesRes):
        return Err[BioDidOperatorAnchor](Error(bundleTextBytesRes))
    let eventIdBytesRes = did.DidStoreDecodeBytes(Value(eventIdEncodedRes))
    if IsErr(eventIdBytesRes):
        return Err[BioDidOperatorAnchor](Error(eventIdBytesRes))
    var out = BioDidOperatorAnchor()
    out.operatorId = Value(operatorIdRes)
    out.bundleKind = bundleKindText
    out.recoveryMode = Value(recoveryModeRes)
    out.didText = didText
    out.subjectDidText = subjectDidText
    out.deviceDidText = deviceDidText
    out.bundleSeq = Value(bundleSeqRes)
    out.bundleCid = Value(bundleCidRes)
    out.bundleText = BytesToString(Value(bundleTextBytesRes))
    out.eventId = BytesToString(Value(eventIdBytesRes))
    let verifyRes = BioDidOperatorAnchorVerify(out)
    if IsErr(verifyRes):
        return Err[BioDidOperatorAnchor](Error(verifyRes))
    let canonicalText = isV2 ? BioDidOperatorAnchorText(out) : BioDidOperatorAnchorLegacyText(out)
    if !BioDidTextEqual(canonicalText, text):
        return Err[BioDidOperatorAnchor](" bio did: non canonical operator anchor text")
    return Ok[BioDidOperatorAnchor](out)

fn BioDidChainCurrentOperatorAnchorSeq(node: var chain.ChainNode): int32 =
    var maxSeq = 0
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.ConsensusKindMint:
            continue
        if event.assetId != BioDidOperatorAnchorAssetId:
            continue
        if event.toAccount != BioDidOperatorAnchorAccountId:
            continue
        if event.fromAccount > maxSeq:
            maxSeq = event.fromAccount
    return maxSeq

fn BioDidChainLoadOperatorAnchorText(node: var chain.ChainNode,
                                       anchorSeq: int32): Result[str] =
    var maxOrdinal = 0
    for i in 0..<node.events.len:
        let event = node.events[i]
        if event.kind != consensus.ConsensusKindMint:
            continue
        if event.assetId != BioDidOperatorAnchorAssetId:
            continue
        if event.toAccount != BioDidOperatorAnchorAccountId:
            continue
        if event.fromAccount != anchorSeq:
            continue
        let ordinal = int32(event.amount)
        if int64(ordinal) != event.amount:
            return Err[str](" bio did: operator chunk ordinal overflow")
        if ordinal > maxOrdinal:
            maxOrdinal = ordinal
    if maxOrdinal <= 0:
        return Err[str](" bio did: operator anchor seq missing")
    var chunks: layout.FixedBytes32[]
    var ordinal = 1
    while ordinal <= maxOrdinal:
        var foundCount = 0
        var chunk = layout.FixedBytes32()
        for i in 0..<node.events.len:
            let event = node.events[i]
            if event.kind != consensus.ConsensusKindMint:
                continue
            if event.assetId != BioDidOperatorAnchorAssetId:
                continue
            if event.toAccount != BioDidOperatorAnchorAccountId:
                continue
            if event.fromAccount != anchorSeq:
                continue
            if event.amount != int64(ordinal):
                continue
            foundCount = foundCount + 1
            chunk = event.fromParentCid
        if foundCount != 1:
            return Err[str](" bio did: operator chunk multiplicity mismatch")
        seqs.Add(chunks, chunk)

    let payloadRes = BioDidChunksToPayload(chunks)
    if IsErr(payloadRes):
        return Err[str](Error(payloadRes))
    return Ok[str](BytesToString(Value(payloadRes)))

fn BioDidChainAppendOperatorAnchor(node: var chain.ChainNode,
                                     anchor: BioDidOperatorAnchor): Result[layout.FixedBytes32] =
    let verifyRes = BioDidOperatorAnchorVerify(anchor)
    if IsErr(verifyRes):
        return Err[layout.FixedBytes32](Error(verifyRes))
    let anchorSeq = BioDidChainCurrentOperatorAnchorSeq(node) + 1
    let payload = BytesFromString(BioDidOperatorAnchorText(anchor))
    let chunkCount = BioDidChunkCount(payload.len)
    var lastEventCid = layout.FixedBytes32()
    for chunkIndex in 0..<chunkCount:
        let parentCid = chain.ChainNodeAccountHead(node.index,
                                                     BioDidOperatorAnchorAssetId,
                                                     BioDidOperatorAnchorAccountId)
        var event = consensus.ChainEventMint(BioDidOperatorAnchorAssetId,
                                               BioDidOperatorAnchorAccountId,
                                               parentCid,
                                               int64(chunkIndex + 1),
                                               node.nextEpoch,
                                               node.nextGanzhi,
                                               chain.ChainNodeSpaceSlot(BioDidOperatorAnchorAccountId,
                                                                          BioDidOperatorAnchorAccountId),
                                               node.nextTick)
        event.fromAccount = anchorSeq
        event.fromParentCid = BioDidChunkFixed(payload, chunkIndex)
        event.bodyCid = consensus.ChainEventBodyCid(event)
        let applyRes = chain.ChainNodeApplyEvent(node, event)
        if IsErr(applyRes):
            return Err[layout.FixedBytes32](Error(applyRes))
        lastEventCid = Value(applyRes)
    return Ok[layout.FixedBytes32](lastEventCid)

fn BioDidChainAppendOperatorBundleAnchorWithMeta(node: var chain.ChainNode,
                                                   operatorId: layout.FixedBytes32,
                                                   subjectDidText: str,
                                                   deviceDidText: str,
                                                   bundleKind: str,
                                                   bundle: BioDidChainBundle,
                                                   eventId: str): Result[layout.FixedBytes32] =
    var anchor = BioDidOperatorAnchor()
    anchor.operatorId = operatorId
    anchor.bundleKind = BioDidOperatorBundleKindNormalize(bundleKind)
    anchor.recoveryMode = BioDidRecoveryModeSecretV1
    anchor.didText = subjectDidText
    anchor.subjectDidText = subjectDidText
    anchor.deviceDidText = deviceDidText
    anchor.bundleSeq = bundle.bundleSeq
    anchor.bundleCid = bundle.bundleCid
    anchor.bundleText = BioDidChainBundleText(bundle)
    anchor.eventId = eventId
    return BioDidChainAppendOperatorAnchor(node, anchor)

fn BioDidChainAppendOperatorBundleAnchor(node: var chain.ChainNode,
                                           operatorId: layout.FixedBytes32,
                                           bundle: BioDidChainBundle,
                                           eventId: str): Result[layout.FixedBytes32] =
    return BioDidChainAppendOperatorBundleAnchorWithMeta(node,
                                                           operatorId,
                                                           bundle.didText,
                                                           bundle.didText,
                                                           BioDidOperatorBundleKindAndroidBioV1,
                                                           bundle,
                                                           eventId)

fn BioDidOperatorRecordFromAnchor(anchor: BioDidOperatorAnchor,
                                    anchorSeq: int32): BioDidOperatorRecord =
    var record = BioDidOperatorRecord()
    record.operatorId = anchor.operatorId
    record.bundleKind = BioDidOperatorBundleKindNormalize(anchor.bundleKind)
    record.didText = anchor.didText
    record.subjectDidText = anchor.subjectDidText
    record.deviceDidText = anchor.deviceDidText
    record.bundleSeq = anchor.bundleSeq
    record.bundleCid = anchor.bundleCid
    record.bundleText = anchor.bundleText
    record.eventId = anchor.eventId
    record.anchorSeq = anchorSeq
    return record

fn BioDidOperatorIndexesPut(operatorIndex: var BioDidOperatorIndex,
                              operatorKindIndex: var BioDidOperatorKindIndex,
                              record: BioDidOperatorRecord): Result[bool] =
    let kindPutRes = BioDidOperatorKindIndexPut(
        operatorKindIndex,
        BioDidOperatorKindKey(
            operatorId: record.operatorId,
            bundleKind: BioDidOperatorBundleKindNormalize(record.bundleKind)
        ),
        record
    )
    if IsErr(kindPutRes):
        return Err[bool](Error(kindPutRes))
    let currentRes = BioDidOperatorIndexLookup(operatorIndex, layout.FixedBytes32Hex(record.operatorId))
    if IsErr(currentRes) || BioDidOperatorRecordShouldReplace(Value(currentRes), record):
        let putRes = BioDidOperatorIndexPut(operatorIndex, record.operatorId, record)
        if IsErr(putRes):
            return Err[bool](Error(putRes))
    return Ok[bool](true)

fn BioDidOperatorIndexRebuildInto(out: var BioDidOperatorIndex,
                                    node: var chain.ChainNode): Result[bool] =
    let initCap = BioDidOperatorIndexInitCap
    BioDidOperatorIndexInitInto(out, initCap)
    var kindOut: BioDidOperatorKindIndex
    BioDidOperatorKindIndexInitInto(kindOut, initCap)
    let maxSeq = BioDidChainCurrentOperatorAnchorSeq(node)
    for anchorSeq in 1..maxSeq:
        let textRes = BioDidChainLoadOperatorAnchorText(node, anchorSeq)
        if IsErr(textRes):
            return Err[bool](Error(textRes))
        let anchorRes = BioDidOperatorAnchorParseText(Value(textRes))
        if IsErr(anchorRes):
            return Err[bool](Error(anchorRes))
        let anchor = Value(anchorRes)
        let putRes = BioDidOperatorIndexesPut(out,
                                                kindOut,
                                                BioDidOperatorRecordFromAnchor(anchor, anchorSeq))
        if IsErr(putRes):
            return Err[bool](Error(putRes))
    return Ok[bool](true)

fn BioDidOperatorIndexLookup(index: BioDidOperatorIndex,
                               operatorIdHex: str): Result[BioDidOperatorRecord] =
    let operatorIdRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(operatorIdHex)
    if IsErr(operatorIdRes):
        return Err[BioDidOperatorRecord](Error(operatorIdRes))
    let operatorId = Value(operatorIdRes)
    let slot = BioDidOperatorIndexFindSlot(index, operatorId, false)
    if slot < 0:
        return Err[BioDidOperatorRecord](" bio did: operator not found")
    let record = index.vals[slot]
    if layout.FixedBytes32Equal(record.operatorId, layout.FixedBytes32()):
        return Err[BioDidOperatorRecord](" bio did: operator record missing")
    return Ok[BioDidOperatorRecord](record)

fn BioDidOperatorLookup(index: BioDidOperatorIndex,
                          operatorKindIndex: BioDidOperatorKindIndex,
                          operatorIdHex: str,
                          preferredKinds: str[]): Result[BioDidOperatorRecord] =
    let operatorIdRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(operatorIdHex)
    if IsErr(operatorIdRes):
        return Err[BioDidOperatorRecord](Error(operatorIdRes))
    let operatorId = Value(operatorIdRes)
    for i in 0..<preferredKinds.len:
        let bundleKind = BioDidOperatorBundleKindNormalize(preferredKinds[i])
        let lookupKindRes = BioDidOperatorKindIndexLookup(operatorKindIndex, operatorId, bundleKind)
        if IsOk(lookupKindRes):
            return lookupKindRes
    return BioDidOperatorIndexLookup(index, operatorIdHex)

fn BioDidOperatorLookupJson(index: BioDidOperatorIndex,
                              operatorKindIndex: BioDidOperatorKindIndex,
                              operatorIdHex: str,
                              preferredKinds: str[]): str =
    let operatorIdRes: Result[layout.FixedBytes32] = layout.FixedBytes32FromHex(operatorIdHex)
    if IsErr(operatorIdRes):
        return "{\"ok\":false,\"found\":false,\"operatorId\":\"\",\"error\":\"invalid_operator_id\"}"
    let operatorId = layout.FixedBytes32Hex(Value(operatorIdRes))
    let lookupRes = BioDidOperatorLookup(index, operatorKindIndex, operatorId, preferredKinds)
    if IsErr(lookupRes):
        return strutil.Join(["{\"ok\":true,\"found\":false,\"operatorId\":\"", operatorId, "\"}"], "")
    let record = Value(lookupRes)
    let bundleTextEncoded = did.DidStoreEncodeText(record.bundleText)
    let eventIdEncoded = did.DidStoreEncodeText(record.eventId)
    var out = "{\"ok\":true,\"found\":true"
    out = strutil.Join([out, ",\"operatorId\":\"", operatorId, "\""], "")
    out = strutil.Join([out, ",\"did\":\"", record.didText, "\""], "")
    out = strutil.Join([out, ",\"subjectDid\":\"", record.subjectDidText, "\""], "")
    out = strutil.Join([out, ",\"deviceDid\":\"", record.deviceDidText, "\""], "")
    out = strutil.Join([out, ",\"bundleSeq\":", strings.IntToStr(record.bundleSeq)], "")
    out = strutil.Join([out, ",\"bundleCid\":\"", layout.FixedBytes32Hex(record.bundleCid), "\""], "")
    out = strutil.Join([out, ",\"bundleText\":\"", bundleTextEncoded, "\""], "")
    out = strutil.Join([out, ",\"bundleTextEncoding\":\"did_store_hex_v1\""], "")
    out = strutil.Join([out, ",\"bundleKind\":\"", BioDidOperatorBundleKindNormalize(record.bundleKind), "\""], "")
    out = strutil.Join([out, ",\"eventId\":\"", eventIdEncoded, "\""], "")
    out = strutil.Join([out, ",\"eventIdEncoding\":\"did_store_hex_v1\""], "")
    out = strutil.Join([out, "}"], "")
    return out

fn BioDidOperatorLookupErrorJson(operatorIdHex: str,
                                   errorTextRaw: str): str =
    let errorText = did.DidStoreEncodeText(errorTextRaw)
    return strutil.Join(["{\"ok\":false,\"found\":false,\"operatorId\":\"", operatorIdHex, "\",\"error\":\"", errorText, "\",\"errorEncoding\":\"did_store_hex_v1", "\"}"], "")

fn BioDidChainStateSyncOperatorIndex(state: var BioDidChainState): Result[bool] =
    let maxSeq = BioDidChainCurrentOperatorAnchorSeq(state.node)
    if maxSeq < state.operatorAnchorSeq:
        return Err[bool](" bio did: operator index seq overflow")
    var changed = false
    for anchorSeq in state.operatorAnchorSeq + 1..maxSeq:
        let textRes = BioDidChainLoadOperatorAnchorText(state.node, anchorSeq)
        if IsErr(textRes):
            return Err[bool](Error(textRes))
        let anchorRes = BioDidOperatorAnchorParseText(Value(textRes))
        if IsErr(anchorRes):
            return Err[bool](Error(anchorRes))
        let anchor = Value(anchorRes)
        let putRes = BioDidOperatorIndexesPut(state.operatorIndex,
                                                state.operatorKindIndex,
                                                BioDidOperatorRecordFromAnchor(anchor, anchorSeq))
        if IsErr(putRes):
            return Err[bool](Error(putRes))
        changed = true
    state.operatorAnchorSeq = maxSeq
    return Ok[bool](changed)

fn BioDidChainStateFromNodeInto(out: var BioDidChainState,
                                  node: var chain.ChainNode): Result[bool] =
    BioDidChainStateZeroInto(out, node)
    let syncRes = BioDidChainStateSyncOperatorIndex(out)
    if IsErr(syncRes):
        return Err[bool](Error(syncRes))
    return Ok[bool](true)

fn BioDidChainStateReplayFromSnapshotInto(out: var BioDidChainState,
                                            nodeId: str,
                                            addressSeed: str,
                                            snapshot: chain.ChainNodeServeSnapshot): Result[bool] =
    let addressRes = chain.ChainNodeAddressFromSeed(addressSeed)
    if IsErr(addressRes):
        return Err[bool](Error(addressRes))
    let replayRes = chain.ChainNodeReplayFromSnapshotInto(out.node,
                                                            nodeId,
                                                            Value(addressRes),
                                                            snapshot)
    if IsErr(replayRes):
        return Err[bool](Error(replayRes))
    BioDidOperatorIndexZeroInto(out.operatorIndex)
    BioDidOperatorKindIndexZeroInto(out.operatorKindIndex)
    out.operatorAnchorSeq = 0
    return BioDidChainStateSyncOperatorIndex(out)

fn BioDidOperatorLookupJsonFromState(state: var BioDidChainState,
                                       operatorIdHex: str): str =
    var emptyKinds: str[]
    emptyKinds.len = 0
    return BioDidOperatorLookupJsonFromStateWithKinds(state, operatorIdHex, emptyKinds)

fn BioDidOperatorLookupJsonFromStateWithKinds(state: var BioDidChainState,
                                                operatorIdHex: str,
                                                preferredKinds: str[]): str =
    let syncRes = BioDidChainStateSyncOperatorIndex(state)
    if IsErr(syncRes):
        return BioDidOperatorLookupErrorJson(operatorIdHex, Error(syncRes))
    let operatorIndex = state.operatorIndex
    let operatorKindIndex = state.operatorKindIndex
    return BioDidOperatorLookupJson(operatorIndex,
                                      operatorKindIndex,
                                      operatorIdHex,
                                      preferredKinds)

fn BioDidChainRequestIdSeen(node: var chain.ChainNode,
                              didText: str,
                              requestId: str): Result[bool] =
    if strings.Len(requestId) <= 0:
        return Err[bool](" bio did: request id required")
    let maxSeq = BioDidChainCurrentBundleSeq(node, didText)
    for bundleSeq in 1..maxSeq:
        let textRes = BioDidChainLoadTextForSeq(node, didText, bundleSeq)
        if IsErr(textRes):
            return Err[bool](Error(textRes))
        let bundleRes = BioDidChainBundleParseText(Value(textRes))
        if IsErr(bundleRes):
            return Err[bool](Error(bundleRes))
        if Value(bundleRes).hardware.requestId == requestId:
            return Ok[bool](true)
    return Ok[bool](false)

fn BioDidIdentityFromDocument(rootSeed: str,
                                deviceSeed: str,
                                document: did.DidDocument): Result[did.DidIdentity] =
    var probe: did.DidIdentity
    probe.rootSeed = rootSeed
    probe.deviceSeed = deviceSeed
    var out: did.DidIdentity
    let applyRes = did.DidIdentityApplyDocumentFill(out, probe, document)
    if IsErr(applyRes):
        return Err[did.DidIdentity](Error(applyRes))
    return Ok[did.DidIdentity](out)

fn BioDidCreateWithHardwareCapture(node: var chain.ChainNode,
                                     capture: BioDidHardwareCapture,
                                     epochSeconds: int64): Result[BioDidProvisionResult] =
    let captureOk = BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        return Err[BioDidProvisionResult](Error(captureOk))
    let attestationOk = BioDidCaptureAttestationValidate(capture, "create")
    if IsErr(attestationOk):
        return Err[BioDidProvisionResult](Error(attestationOk))
    let recordRes = bio.BioEnroll(capture.feature32)
    if IsErr(recordRes):
        return Err[BioDidProvisionResult](Error(recordRes))
    let record = Value(recordRes)
    let rootSecretRes = bio.BioRecoverRoot(capture.feature32, record.helper)
    if IsErr(rootSecretRes):
        return Err[BioDidProvisionResult](Error(rootSecretRes))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = BioDidRootSeedFromRootSecret(rootSecret)
    let deviceSeed = BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let identity = did.DidIdentityMake(rootSeed, deviceSeed, capture.deviceLabel, epochSeconds)
    var document: did.DidDocument
    let documentRes = did.DidIdentityDocumentFill(document, identity)
    if IsErr(documentRes):
        return Err[BioDidProvisionResult](Error(documentRes))
    if BioDidChainCurrentBundleSeq(node, document.did) != 0:
        return Err[BioDidProvisionResult](" bio did: did already exists")
    let bundleSeq = 1
    let challengeNonce = BioDidChallengeNonce("create",
                                                document.did,
                                                identity.selfDevice.devicePeerId,
                                                document.version,
                                                bundleSeq)
    let hardware = BioDidHardwareAttestationMake(capture,
                                                   "create",
                                                   document.did,
                                                   identity.selfDevice.devicePeerId,
                                                   document.version,
                                                   bundleSeq,
                                                   challengeNonce,
                                                   epochSeconds)
    let assertionRes = bio.BioProve(capture.feature32, record, challengeNonce)
    if IsErr(assertionRes):
        return Err[BioDidProvisionResult](Error(assertionRes))
    let bundleRes = BioDidChainBundleMake("create",
                                            bundleSeq,
                                            document,
                                            identity.selfDevice.devicePeerId,
                                            record,
                                            Value(assertionRes),
                                            hardware)
    if IsErr(bundleRes):
        return Err[BioDidProvisionResult](Error(bundleRes))
    let appendRes = BioDidChainAppendBundle(node, Value(bundleRes))
    if IsErr(appendRes):
        return Err[BioDidProvisionResult](Error(appendRes))
    var out = BioDidProvisionResult()
    out.identity = identity
    out.document = document
    out.bundle = Value(bundleRes)
    return Ok[BioDidProvisionResult](out)

fn BioDidCreateBundleWithHardwareCapture(capture: BioDidHardwareCapture,
                                           epochSeconds: int64): Result[BioDidProvisionResult] =
    let captureOk = BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        return Err[BioDidProvisionResult](Error(captureOk))
    let attestationOk = BioDidCaptureAttestationValidate(capture, "create")
    if IsErr(attestationOk):
        return Err[BioDidProvisionResult](Error(attestationOk))
    let recordRes = bio.BioEnroll(capture.feature32)
    if IsErr(recordRes):
        return Err[BioDidProvisionResult](Error(recordRes))
    let record = Value(recordRes)
    let rootSecretRes = bio.BioRecoverRoot(capture.feature32, record.helper)
    if IsErr(rootSecretRes):
        return Err[BioDidProvisionResult](Error(rootSecretRes))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = BioDidRootSeedFromRootSecret(rootSecret)
    let deviceSeed = BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let identity = did.DidIdentityMake(rootSeed, deviceSeed, capture.deviceLabel, epochSeconds)
    var document: did.DidDocument
    let documentRes = did.DidIdentityDocumentFill(document, identity)
    if IsErr(documentRes):
        return Err[BioDidProvisionResult](Error(documentRes))
    let bundleSeq = 1
    let challengeNonce = BioDidChallengeNonce("create",
                                                document.did,
                                                identity.selfDevice.devicePeerId,
                                                document.version,
                                                bundleSeq)
    let hardware = BioDidHardwareAttestationMake(capture,
                                                   "create",
                                                   document.did,
                                                   identity.selfDevice.devicePeerId,
                                                   document.version,
                                                   bundleSeq,
                                                   challengeNonce,
                                                   epochSeconds)
    let assertionRes = bio.BioProve(capture.feature32, record, challengeNonce)
    if IsErr(assertionRes):
        return Err[BioDidProvisionResult](Error(assertionRes))
    let bundleRes = BioDidChainBundleMake("create",
                                            bundleSeq,
                                            document,
                                            identity.selfDevice.devicePeerId,
                                            record,
                                            Value(assertionRes),
                                            hardware)
    if IsErr(bundleRes):
        return Err[BioDidProvisionResult](Error(bundleRes))
    var out = BioDidProvisionResult()
    out.identity = identity
    out.document = document
    out.bundle = Value(bundleRes)
    return Ok[BioDidProvisionResult](out)

fn BioDidImportWithHardwareCapture(node: var chain.ChainNode,
                                     didText: str,
                                     capture: BioDidHardwareCapture,
                                     epochSeconds: int64): Result[BioDidProvisionResult] =
    let captureOk = BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        return Err[BioDidProvisionResult](Error(captureOk))
    let attestationOk = BioDidCaptureAttestationValidate(capture, "import")
    if IsErr(attestationOk):
        return Err[BioDidProvisionResult](Error(attestationOk))
    let latestBundleRes = BioDidChainLoadLatest(node, didText)
    if IsErr(latestBundleRes):
        return Err[BioDidProvisionResult](Error(latestBundleRes))
    let latestBundle = Value(latestBundleRes)
    let latestDocumentRes = BioDidChainBundleVerify(latestBundle)
    if IsErr(latestDocumentRes):
        return Err[BioDidProvisionResult](Error(latestDocumentRes))
    let latestDocument = Value(latestDocumentRes)
    let rootSecretRes = bio.BioRecoverRoot(capture.feature32, latestBundle.record.helper)
    if IsErr(rootSecretRes):
        return Err[BioDidProvisionResult](Error(rootSecretRes))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = BioDidRootSeedFromRootSecret(rootSecret)
    if !BioDidTextEqual(did.DidFromRootSeed(rootSeed), didText):
        return Err[BioDidProvisionResult](" bio did: fingerprint did mismatch")
    let deviceSeed = BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let devicePeerId = did.DidDevicePeerIdFromSeed(deviceSeed)
    var document = latestDocument
    let existingPos = did.DidDocumentFindDevicePos(document, devicePeerId)
    if existingPos >= 0:
        if document.devices[existingPos].status != did.DidDeviceStatusActive:
            return Err[BioDidProvisionResult](" bio did: device revoked")
    else:
        let enrollRes = did.DidDocumentEnrollDevice(document,
                                                      rootSeed,
                                                      deviceSeed,
                                                      capture.deviceLabel,
                                                      epochSeconds)
        if IsErr(enrollRes):
            return Err[BioDidProvisionResult](Error(enrollRes))
        document = Value(enrollRes)
    let identityRes = BioDidIdentityFromDocument(rootSeed, deviceSeed, document)
    if IsErr(identityRes):
        return Err[BioDidProvisionResult](Error(identityRes))
    let identity = Value(identityRes)
    let bundleSeq = BioDidChainCurrentBundleSeq(node, didText) + 1
    let challengeNonce = BioDidChallengeNonce("import",
                                                didText,
                                                identity.selfDevice.devicePeerId,
                                                document.version,
                                                bundleSeq)
    let hardware = BioDidHardwareAttestationMake(capture,
                                                   "import",
                                                   didText,
                                                   identity.selfDevice.devicePeerId,
                                                   document.version,
                                                   bundleSeq,
                                                   challengeNonce,
                                                   epochSeconds)
    let assertionRes = bio.BioProve(capture.feature32, latestBundle.record, challengeNonce)
    if IsErr(assertionRes):
        return Err[BioDidProvisionResult](Error(assertionRes))
    let bundleRes = BioDidChainBundleMake("import",
                                            bundleSeq,
                                            document,
                                            identity.selfDevice.devicePeerId,
                                            latestBundle.record,
                                            Value(assertionRes),
                                            hardware)
    if IsErr(bundleRes):
        return Err[BioDidProvisionResult](Error(bundleRes))
    let appendRes = BioDidChainAppendBundle(node, Value(bundleRes))
    if IsErr(appendRes):
        return Err[BioDidProvisionResult](Error(appendRes))
    var out = BioDidProvisionResult()
    out.identity = identity
    out.document = document
    out.bundle = Value(bundleRes)
    return Ok[BioDidProvisionResult](out)

fn BioDidImportFromLatestBundleWithHardwareCapture(latestBundle: BioDidChainBundle,
                                                     capture: BioDidHardwareCapture,
                                                     epochSeconds: int64): Result[BioDidProvisionResult] =
    let captureOk = BioDidCaptureValidate(capture)
    if IsErr(captureOk):
        return Err[BioDidProvisionResult](Error(captureOk))
    let attestationOk = BioDidCaptureAttestationValidate(capture, "import")
    if IsErr(attestationOk):
        return Err[BioDidProvisionResult](Error(attestationOk))
    let latestDocumentRes = BioDidChainBundleVerify(latestBundle)
    if IsErr(latestDocumentRes):
        return Err[BioDidProvisionResult](Error(latestDocumentRes))
    let latestDocument = Value(latestDocumentRes)
    let rootSecretRes = bio.BioRecoverRoot(capture.feature32, latestBundle.record.helper)
    if IsErr(rootSecretRes):
        return Err[BioDidProvisionResult](Error(rootSecretRes))
    let rootSecret = Value(rootSecretRes)
    let rootSeed = BioDidRootSeedFromRootSecret(rootSecret)
    if !BioDidTextEqual(did.DidFromRootSeed(rootSeed), latestBundle.didText):
        return Err[BioDidProvisionResult](" bio did: fingerprint did mismatch")
    let deviceSeed = BioDidDeviceSeedFromRootSecret(rootSecret, capture.deviceBindingSeed)
    let devicePeerId = did.DidDevicePeerIdFromSeed(deviceSeed)
    var document = latestDocument
    let existingPos = did.DidDocumentFindDevicePos(document, devicePeerId)
    if existingPos >= 0:
        if document.devices[existingPos].status != did.DidDeviceStatusActive:
            return Err[BioDidProvisionResult](" bio did: device revoked")
    else:
        let enrollRes = did.DidDocumentEnrollDevice(document,
                                                      rootSeed,
                                                      deviceSeed,
                                                      capture.deviceLabel,
                                                      epochSeconds)
        if IsErr(enrollRes):
            return Err[BioDidProvisionResult](Error(enrollRes))
        document = Value(enrollRes)
    let identityRes = BioDidIdentityFromDocument(rootSeed, deviceSeed, document)
    if IsErr(identityRes):
        return Err[BioDidProvisionResult](Error(identityRes))
    let identity = Value(identityRes)
    let bundleSeq = latestBundle.bundleSeq + 1
    let challengeNonce = BioDidChallengeNonce("import",
                                                latestBundle.didText,
                                                identity.selfDevice.devicePeerId,
                                                document.version,
                                                bundleSeq)
    let hardware = BioDidHardwareAttestationMake(capture,
                                                   "import",
                                                   latestBundle.didText,
                                                   identity.selfDevice.devicePeerId,
                                                   document.version,
                                                   bundleSeq,
                                                   challengeNonce,
                                                   epochSeconds)
    let assertionRes = bio.BioProve(capture.feature32, latestBundle.record, challengeNonce)
    if IsErr(assertionRes):
        return Err[BioDidProvisionResult](Error(assertionRes))
    let bundleRes = BioDidChainBundleMake("import",
                                            bundleSeq,
                                            document,
                                            identity.selfDevice.devicePeerId,
                                            latestBundle.record,
                                            Value(assertionRes),
                                            hardware)
    if IsErr(bundleRes):
        return Err[BioDidProvisionResult](Error(bundleRes))
    var out = BioDidProvisionResult()
    out.identity = identity
    out.document = document
    out.bundle = Value(bundleRes)
    return Ok[BioDidProvisionResult](out)

fn BioDidOperatorEventId(operatorId: layout.FixedBytes32,
                           bundleKind: str,
                           bundle: BioDidChainBundle): str =
    return strutil.Join([bundle.action, "|", layout.FixedBytes32Hex(operatorId), "|", BioDidOperatorBundleKindNormalize(bundleKind), "|", bundle.didText, "|", strings.IntToStr(bundle.bundleSeq), "|", bundle.hardware.requestId], "")

fn BioDidChainStateCreateWithHardwareCapture(state: var BioDidChainState,
                                               capture: BioDidHardwareCapture,
                                               epochSeconds: int64): Result[BioDidProvisionResult] =
    var node = state.node
    let createRes = BioDidCreateWithHardwareCapture(node, capture, epochSeconds)
    state.node = node
    return createRes

fn BioDidChainStateImportWithHardwareCapture(state: var BioDidChainState,
                                               didText: str,
                                               capture: BioDidHardwareCapture,
                                               epochSeconds: int64): Result[BioDidProvisionResult] =
    var node = state.node
    let importRes = BioDidImportWithHardwareCapture(node, didText, capture, epochSeconds)
    state.node = node
    return importRes

fn BioDidChainStateAppendOperatorAnchor(state: var BioDidChainState,
                                          anchor: BioDidOperatorAnchor): Result[layout.FixedBytes32] =
    let syncRes = BioDidChainStateSyncOperatorIndex(state)
    if IsErr(syncRes):
        return Err[layout.FixedBytes32](Error(syncRes))
    var node = state.node
    let appendRes = BioDidChainAppendOperatorAnchor(node, anchor)
    state.node = node
    if IsErr(appendRes):
        return Err[layout.FixedBytes32](Error(appendRes))
    let nextAnchorSeq = state.operatorAnchorSeq + 1
    let putRes = BioDidOperatorIndexesPut(state.operatorIndex,
                                            state.operatorKindIndex,
                                            BioDidOperatorRecordFromAnchor(anchor, nextAnchorSeq))
    if IsErr(putRes):
        return Err[layout.FixedBytes32](Error(putRes))
    state.operatorAnchorSeq = nextAnchorSeq
    return Ok[layout.FixedBytes32](Value(appendRes))

fn BioDidChainStateAppendOperatorBundleAnchorWithMeta(state: var BioDidChainState,
                                                        operatorId: layout.FixedBytes32,
                                                        subjectDidText: str,
                                                        deviceDidText: str,
                                                        bundleKind: str,
                                                        bundle: BioDidChainBundle): Result[layout.FixedBytes32] =
    return BioDidChainStateAppendOperatorAnchor(
        state,
        BioDidOperatorAnchor(
            operatorId: operatorId,
            bundleKind: BioDidOperatorBundleKindNormalize(bundleKind),
            recoveryMode: BioDidRecoveryModeSecretV1,
            didText: subjectDidText,
            subjectDidText: subjectDidText,
            deviceDidText: deviceDidText,
            bundleSeq: bundle.bundleSeq,
            bundleCid: bundle.bundleCid,
            bundleText: BioDidChainBundleText(bundle),
            eventId: BioDidOperatorEventId(operatorId,
                                             BioDidOperatorBundleKindNormalize(bundleKind),
                                             bundle)
        )
    )

fn BioDidChainStateAppendOperatorBundleAnchor(state: var BioDidChainState,
                                                operatorId: layout.FixedBytes32,
                                                bundle: BioDidChainBundle): Result[layout.FixedBytes32] =
    return BioDidChainStateAppendOperatorBundleAnchorWithMeta(state,
                                                                operatorId,
                                                                bundle.didText,
                                                                bundle.didText,
                                                                BioDidOperatorBundleKindAndroidBioV1,
                                                                bundle)

fn BioDidChainStateServeOnceInto(out: var chain.ChainNodeServeSnapshot,
                                   state: var BioDidChainState) =
    chain.ChainNodeRebuildDerived(state.node)
    state.node.servedCount = state.node.servedCount + 1
    out.nodeId = state.node.nodeId
    chain.ChainNodeCopyAddress(out.address, state.node.address)
    out.serveCount = state.node.servedCount
    out.tipEventCid = state.node.tipEventCid
    out.eventCids = state.node.eventCids
    out.events = state.node.events
    out.forest = state.node.forest
    chain.ChainNodeCopySignature(out.signature, state.node.signature)

fn BioDidEnsureWithHardwareCapture(state: var BioDidChainState,
                                     operatorId: layout.FixedBytes32,
                                     capture: BioDidHardwareCapture,
                                     epochSeconds: int64): Result[BioDidProvisionResult] =
    let syncRes = BioDidChainStateSyncOperatorIndex(state)
    if IsErr(syncRes):
        return Err[BioDidProvisionResult](Error(syncRes))
    let lookupRes = BioDidOperatorIndexLookup(state.operatorIndex, layout.FixedBytes32Hex(operatorId))
    if IsOk(lookupRes):
        let importRes = BioDidChainStateImportWithHardwareCapture(state,
                                                                    Value(lookupRes).didText,
                                                                    capture,
                                                                    epochSeconds)
        if IsErr(importRes):
            return Err[BioDidProvisionResult](Error(importRes))
        let anchorRes = BioDidChainStateAppendOperatorBundleAnchorWithMeta(
            state,
            operatorId,
            Value(lookupRes).subjectDidText,
            Value(importRes).bundle.didText,
            BioDidOperatorBundleKindAndroidBioV1,
            Value(importRes).bundle
        )
        if IsErr(anchorRes):
            return Err[BioDidProvisionResult](Error(anchorRes))
        return importRes
    let createRes = BioDidChainStateCreateWithHardwareCapture(state, capture, epochSeconds)
    if IsErr(createRes):
        return Err[BioDidProvisionResult](Error(createRes))
    let anchorRes = BioDidChainStateAppendOperatorBundleAnchorWithMeta(
        state,
        operatorId,
        Value(createRes).bundle.didText,
        Value(createRes).bundle.didText,
        BioDidOperatorBundleKindAndroidBioV1,
        Value(createRes).bundle
    )
    if IsErr(anchorRes):
        return Err[BioDidProvisionResult](Error(anchorRes))
    return createRes
