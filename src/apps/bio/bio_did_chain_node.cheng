fn V3BioDidCreateWithHardwareCapture(node: var chain.V3ChainNode,
                                     capture: V3BioDidHardwareCapture,
                                     verifiedAtEpochSeconds: int64): Result[V3BioDidProvisionResult] =
    return v3BioDidCreateWithHardwareCapture(node, capture, verifiedAtEpochSeconds)

fn V3BioDidImportWithHardwareCapture(node: var chain.V3ChainNode,
                                     didText: str,
                                     capture: V3BioDidHardwareCapture,
                                     verifiedAtEpochSeconds: int64): Result[V3BioDidProvisionResult] =
    return v3BioDidImportWithHardwareCapture(node, didText, capture, verifiedAtEpochSeconds)

fn V3BioDidChainLoadLatest(node: var chain.V3ChainNode,
                           didText: str): Result[V3BioDidChainBundle] =
    return v3BioDidChainLoadLatest(node, didText)

fn V3BioDidChainLatestBundles(node: var chain.V3ChainNode): Result[V3BioDidChainBundle[]] =
    return v3BioDidChainLatestBundles(node)

fn V3BioDidChainBundleVerify(bundle: V3BioDidChainBundle): Result[did.V3DidDocument] =
    return v3BioDidChainBundleVerify(bundle)

fn V3BioDidChainCurrentBundleSeq(node: var chain.V3ChainNode, didText: str): int32 =
    return v3BioDidChainCurrentBundleSeq(node, didText)

fn V3BioDidChainBundleText(bundle: V3BioDidChainBundle): str =
    return v3BioDidChainBundleText(bundle)

fn V3BioDidOperatorIndexRebuildInto(out: var V3BioDidOperatorIndex,
                                    node: var chain.V3ChainNode): Result[bool] =
