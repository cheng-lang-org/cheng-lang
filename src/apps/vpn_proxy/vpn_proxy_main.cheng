import std/buffer
import std/bytes as filebytes
import std/cmdline as cmdline
import std/monotimes
import std/os
import std/result
import std/rawbytes
import std/rawmem_support
import std/strings
import std/strutils as strutil
import std/tls/x509
import std/net/transports/tcp_syscall as tcp
import std/net/transports/udp_syscall as udp
import cheng/libp2p/core/types as lptypes
import cheng/libp2p/transports/quic_transport as quic_transport
import cheng/quic/connection as qconn
import cheng/quic/msquicruntime as qruntime
import cheng/quic/msquictransport_native as qtransport
import cheng/apps/vpn_proxy/vpn_proxy_cli as cli
import cheng/quic/tls/policy as qpolicy
import cheng/apps/vpn_proxy/vpn_proxy_listen as listen
import cheng/core/tooling/path as chengpath
import cheng/apps/vpn_proxy/vpn_proxy_config as config
import cheng/hysteria2/hysteria2_protocol as hy2
import cheng/hysteria2/vpn_proxy_hysteria2_session as hy2sess
import cheng/apps/vpn_proxy/vpn_proxy_routing as routing
import cheng/apps/vpn_proxy/vpn_proxy_socks as socks

type
    VpnProxyIdentityConfig = config.VpnProxyIdentityConfig
    VpnProxyExitConfig = config.VpnProxyExitConfig
    VpnProxyConfig = config.VpnProxyConfig

    VpnProxyLoadedIdentity =
        certs: Bytes[]
        privateKey: Bytes
        leafKeyKind: x509.X509PublicKeyKind
        trustRoots: Bytes[]

    VpnProxyExitState = routing.VpnProxyExitState

    VpnProxyCliOptions = cli.VpnProxyCliOptions
    VpnProxyHy2TcpStream = hy2sess.VpnProxyHy2TcpStream
    Hysteria2AuthResponse = hy2.Hysteria2AuthResponse
    Hysteria2UdpMessage = hy2.Hysteria2UdpMessage

    VpnProxyQuicLink =
        transport: qtransport.MsQuicTransport
        conn: qconn.Connection
        stream: VpnProxyHy2TcpStream
        streamOpen: bool
        exitIndex: int32

    VpnProxyTarget = socks.VpnProxyTarget
    VpnProxySocksRequest = socks.VpnProxySocksRequest
    VpnProxySocksUdpDatagram = socks.VpnProxySocksUdpDatagram

    VpnProxyUdpBoundSocket =
        socket: udp.UdpSocketHandle
        bindTarget: VpnProxyTarget

    VpnProxyUdpFragState =
        sessionId: int64
        packetId: int32
        address: str
        firstSeenMs: int64
        lastSeenMs: int64
        payloadBytes: int32
        fragments: Hysteria2UdpMessage[]

    VpnProxyUdpSocketPair =
        v4Open: bool
        v4: udp.UdpSocketHandle
        v6Open: bool
        v6: udp.UdpSocketHandle

const
    VpnProxySocksVersion = 5
    VpnProxySocksCmdConnect = 1
    VpnProxySocksCmdBind = 2
    VpnProxySocksCmdUdpAssoc = 3
    VpnProxySocksAtypIpv4 = 1
    VpnProxySocksAtypDomain = 3
    VpnProxySocksAtypIpv6 = 4
    VpnProxySocksReplyGeneralFailure = 1
    VpnProxySocksReplyConnectionRefused = 5
    VpnProxySocksReplyCommandUnsupported = 7
    VpnProxySocksReplyAddressUnsupported = 8
    VpnProxyRelayChunkBytes = 32768
    VpnProxyConnectTimeoutMs = 5000
    VpnProxyHy2AuthOkStatus = 233
    VpnProxyHy2AuthRejectStatus = 403
    VpnProxyHy2TcpStreamId = 8
    VpnProxyHy2ProbeAddress = "cheng-vpn-probe.invalid:0"
    VpnProxyHy2UdpSessionId = 1
    VpnProxyUdpRelayChunkBytes = 65535
    VpnProxyUdpRelaySleepMs = 10
    VpnProxyUdpFragExpiryMs = 30000
    VpnProxyUdpFragMaxPendingPackets = 64

fn VpnProxyPrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn VpnProxyPrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn VpnProxyUsage() =
    VpnProxyPrintLine("usage: cheng vpn-proxy <local|exit|status> --config:<path>")
    VpnProxyPrintLine("local flags: --ready-path:<path> --accept-count:<n> --probe-interval-ms:<n> --probe-timeout-ms:<n>")
    VpnProxyPrintLine("exit flags: --ready-path:<path> --accept-count:<n>")
    VpnProxyPrintLine("status flags: --probe-timeout-ms:<n>")

fn VpnProxyMonoNowMs(): int64 =
    return monotimes.MonoTimeNs(monotimes.GetMonoTime()) / 1000000

fn VpnProxyLocalAcceptWaitMs(probeIntervalMs: int32,
                               lastIdleProbeMs: int64,
                               nowMs: int64): int32 =
    if probeIntervalMs <= 0:
        return 1000
    let remainingMs: int64 = int64(probeIntervalMs) - (nowMs - lastIdleProbeMs)
    if remainingMs <= 0:
        return 0
    if remainingMs > 1000:
        return 1000
    return int32(remainingMs)

fn VpnProxyBytesAppend(dst: var Bytes, extra: Bytes) =
    if bytesLen(extra) <= 0:
        return
    dst = bytesConcat(dst, extra)

fn VpnProxyBytesDropPrefix(data: Bytes, count: int32): Bytes =
    let total: int32 = bytesLen(data)
    var start: int32
    if count > 0:
        if count < total:
            start = count
        else:
            start = total
    return bytesSlice(data, start, total - start)

fn VpnProxyWouldBlockUdp(err: str): bool =
    return err == "udp syscall: queue empty"

fn VpnProxyUdpUseLenField(): bool =
    return os.udpPlatformUseLenFieldBridge() != 0

fn VpnProxyUdpSocketAddrEq(left: udp.UdpSockAddr,
                             right: udp.UdpSockAddr): bool =
    return left.isV6 == right.isV6 &&
           left.port == right.port &&
           left.host == right.host

fn VpnProxyUdpTargetFromSockAddr(addr: udp.UdpSockAddr): VpnProxyTarget =
    var out: VpnProxyTarget
    out.host = addr.host
    out.port = addr.port
    return out

fn VpnProxyUdpPacketNext(nextId: var int32): int32 =
    let out: int32 = nextId
    nextId = nextId + 1
    if nextId > 65535:
        nextId = 0
    return out

fn VpnProxyUdpFragSweepExpired(states: var VpnProxyUdpFragState[],
                                 nowMs: int64) =
    var kept: VpnProxyUdpFragState[]
    for i in 0..<states.len:
        let state = states[i]
        if state.lastSeenMs <= 0:
            continue
        if nowMs - state.lastSeenMs < int64(VpnProxyUdpFragExpiryMs):
            add(kept, state)
    states = kept

fn VpnProxyUdpFragStatesRemove(states: var VpnProxyUdpFragState[],
                                 dropIdx: int32) =
    var kept: VpnProxyUdpFragState[]
    for i in 0..<states.len:
        if i != dropIdx:
            add(kept, states[i])
    states = kept

fn VpnProxyUdpMessageAssign(out: var Hysteria2UdpMessage,
                              msg: Hysteria2UdpMessage) =
    out.sessionId = msg.sessionId
    out.packetId = msg.packetId
    out.fragmentId = msg.fragmentId
    out.fragmentCount = msg.fragmentCount
    out.address = msg.address
    out.payload = msg.payload

fn VpnProxyUdpFragFeedAt(states: var VpnProxyUdpFragState[],
                           msg: Hysteria2UdpMessage,
                           nowMs: int64,
                           out: var Hysteria2UdpMessage): Result[bool] =
    if msg.fragmentCount <= 1:
        VpnProxyUdpMessageAssign(out, msg)
        return Ok[bool](true)
    if msg.fragmentId < 0 || msg.fragmentId >= msg.fragmentCount:
        return Err[bool]("vpn proxy: udp fragment invalid")
    VpnProxyUdpFragSweepExpired(states, nowMs)
    let msgBytes: int32 = bytesLen(msg.payload)
    if msgBytes < 0:
        return Err[bool]("vpn proxy: udp fragment payload invalid")
    if msgBytes > VpnProxyUdpRelayChunkBytes:
        return Err[bool]("vpn proxy: udp fragment payload too large")
    var stateIdx: int32 = -1
    for i in 0..<states.len:
        if states[i].sessionId == msg.sessionId &&
           states[i].packetId == msg.packetId &&
           states[i].address == msg.address:
            stateIdx = i
            break
    if stateIdx < 0:
        if states.len >= VpnProxyUdpFragMaxPendingPackets:
            return Err[bool]("vpn proxy: udp fragment state overflow")
        var state: VpnProxyUdpFragState
        state.sessionId = msg.sessionId
        state.packetId = msg.packetId
        state.address = msg.address
        state.firstSeenMs = nowMs
        state.lastSeenMs = nowMs
        state.payloadBytes = msgBytes
        add(state.fragments, msg)
        add(states, state)
        return Ok[bool](false)
    var state = states[stateIdx]
    for i in 0..<state.fragments.len:
        let item: Hysteria2UdpMessage = state.fragments[i]
        if item.fragmentCount != msg.fragmentCount:
            return Err[bool]("vpn proxy: udp fragment count mismatch")
        if item.fragmentId == msg.fragmentId:
            return Err[bool]("vpn proxy: udp duplicate fragment")
        if item.sessionId != msg.sessionId ||
           item.packetId != msg.packetId ||
           item.address != msg.address:
            return Err[bool]("vpn proxy: udp fragment metadata mismatch")
    if state.payloadBytes + msgBytes > VpnProxyUdpRelayChunkBytes:
        return Err[bool]("vpn proxy: udp fragment payload exceeds datagram limit")
    var nextFragments = state.fragments
    add(nextFragments, msg)
    state.fragments = nextFragments
    state.lastSeenMs = nowMs
    state.payloadBytes = state.payloadBytes + msgBytes
    if state.fragments.len != msg.fragmentCount:
        states[stateIdx] = state
        return Ok[bool](false)
    let fillRes = hy2.Hysteria2ReassembleUdpMessagesFill(state.fragments, out)
    if IsErr(fillRes):
        return Err[bool](Error(fillRes))
    VpnProxyUdpFragStatesRemove(states, stateIdx)
    return Ok[bool](true)

fn VpnProxyUdpFragFeed(states: var VpnProxyUdpFragState[],
                         msg: Hysteria2UdpMessage,
                         out: var Hysteria2UdpMessage): Result[bool] =
    return VpnProxyUdpFragFeedAt(states, msg, VpnProxyMonoNowMs(), out)

fn VpnProxyUdpLiteralTarget(target: VpnProxyTarget,
                              family: int32,
                              out: var udp.UdpSockAddr): Result[bool] =
    let isV6: bool = strings.StrContains(target.host, ":")
    return udp.UdpSockAddrFromHostPort(target.host,
                                       target.port,
                                       isV6,
                                       family,
                                       VpnProxyUdpUseLenField(),
                                       out)

fn VpnProxyHy2UdpPayloadLimit(transport: qtransport.MsQuicTransport,
                                address: str): Result[int32] =
    var emptyPayload: Bytes
    emptyPayload.data = nil
    emptyPayload.len = 0
    let headerRes: Result[Bytes] = hy2.Hysteria2EncodeUdpMessage(hy2.Hysteria2MakeUdpMessage(VpnProxyHy2UdpSessionId,
                                                                                                   0,
                                                                                                   0,
                                                                                                   1,
                                                                                                   address,
                                                                                                   emptyPayload))
    if IsErr(headerRes):
        return Err[int32](ErrorText(headerRes))
    let limit: int32 = transport.settings.maxDatagram - bytesLen(Value(headerRes))
    if limit <= 0:
        return Err[int32]("vpn proxy: udp payload limit invalid")
    return Ok[int32](limit)

fn VpnProxyUdpSocketSend(fd: int32,
                           payload: Bytes,
                           toAddr: udp.UdpSockAddr): Result[bool] =
    let sendRes: Result[int32] = udp.UdpSendTo(fd, payload, toAddr)
    if IsErr(sendRes):
        return Err[bool](ErrorText(sendRes))
    if Value(sendRes) != bytesLen(payload):
        return Err[bool]("vpn proxy: udp short send")
    return Ok[bool](true)

fn VpnProxyUdpBindSocket(host: str,
                           port: int32,
                           isV6: bool,
                           outSocket: var udp.UdpSocketHandle,
                           outSockName: var udp.UdpSockAddr): Result[bool] =
    var isV6Flag: int32
    if isV6:
        isV6Flag = 1
    let fd: int32 = os.udpBindFdBridge(host, port, isV6Flag)
    if fd < 0:
        return Err[bool]("udp syscall: bind failed")
    let sockNameRes: Result[bool] = udp.UdpGetSockName(fd, outSockName)
    if IsErr(sockNameRes):
        udp.UdpSocketClose(fd)
        return Err[bool](ErrorText(sockNameRes))
    outSocket = udp.UdpSocketHandle(fd: fd,
                                    family: outSockName.family,
                                    isV6: outSockName.isV6)
    return Ok[bool](true)

fn VpnProxyUdpBoundSocketOpen(host: str,
                                isV6: bool): Result[VpnProxyUdpBoundSocket] =
    var sockName: udp.UdpSockAddr
    var socket: udp.UdpSocketHandle
    let bindRes: Result[bool] = VpnProxyUdpBindSocket(host, 0, isV6, socket, sockName)
    if IsErr(bindRes):
        return Err[VpnProxyUdpBoundSocket](ErrorText(bindRes))
    var out: VpnProxyUdpBoundSocket
    out.socket = socket
    out.bindTarget = VpnProxyUdpTargetFromSockAddr(sockName)
    return Ok[VpnProxyUdpBoundSocket](out)

fn VpnProxyUdpSocketPairClose(pair: var VpnProxyUdpSocketPair) =
    if pair.v4Open:
        udp.UdpSocketClose(pair.v4.fd)
        pair.v4Open = false
    if pair.v6Open:
        udp.UdpSocketClose(pair.v6.fd)
        pair.v6Open = false

fn VpnProxyUdpSocketPairEnsure(pair: var VpnProxyUdpSocketPair,
                                 isV6: bool): Result[udp.UdpSocketHandle] =
    if isV6:
        if pair.v6Open:
            return Ok[udp.UdpSocketHandle](pair.v6)
        var sockName: udp.UdpSockAddr
        var socket: udp.UdpSocketHandle
        let bindRes: Result[bool] = VpnProxyUdpBindSocket("", 0, true, socket, sockName)
        if IsErr(bindRes):
            return Err[udp.UdpSocketHandle](ErrorText(bindRes))
        pair.v6 = socket
        pair.v6Open = true
        return Ok[udp.UdpSocketHandle](pair.v6)
    if pair.v4Open:
        return Ok[udp.UdpSocketHandle](pair.v4)
    var sockName: udp.UdpSockAddr
    var socket: udp.UdpSocketHandle
    let bindRes: Result[bool] = VpnProxyUdpBindSocket("", 0, false, socket, sockName)
    if IsErr(bindRes):
        return Err[udp.UdpSocketHandle](ErrorText(bindRes))
    pair.v4 = socket
    pair.v4Open = true
    return Ok[udp.UdpSocketHandle](pair.v4)

fn VpnProxyProtocolId(): lptypes.Libp2pProtocolId =
    return lptypes.Libp2pProtocolProxyTcp

fn VpnProxyTextSlice(text: str, start: int32, count: int32): str =
    if count <= 0:
        return ""
    return strings.SliceBytes(text, start, count)

fn VpnProxyEnsureParentDir(path: str): bool =
    if len(path) <= 0:
        return true
    let parts: os.SplitFileResult = os.SplitFile(path)
    if len(parts.dir) <= 0:
        return true
    return chengpath.MkdirP("", parts.dir)

fn VpnProxyWriteReadyPort(path: str, port: int32): bool =
    if len(path) <= 0:
        return true
    if !VpnProxyEnsureParentDir(path):
        return false
    return chengpath.WriteTextFile("", path, intToStr(port) + "\n")

fn VpnProxyWriteBytesFile(path: str, data: Bytes): bool =
    if !VpnProxyEnsureParentDir(path):
        return false
    let file: os.File = os.Open(path, os.FmWrite)
    if file == nil:
        return false
    let total: int32 = bytesLen(data)
    if total <= 0:
        os.Close(file)
        return true
    let wrote: int32 = os.C_fwrite(data.data, 1, int64(total), file)
    os.Close(file)
    return wrote == total

fn VpnProxyLoadBytesFile(path: str): Result[Bytes] =
    let raw = filebytes.ReadFileBytes(path)
    if raw.len <= 0 || raw.data == nil:
        return Err[Bytes]("vpn proxy: failed to read file: " + path)
    let out: Bytes = bytesAlloc(raw.len)
    for i in 0..<raw.len:
        bytesSet(out, i, filebytes.BufByteAt(raw, i))
    return Ok[Bytes](out)

fn VpnProxyParseConfigTextForTest(configText: str): Result[VpnProxyConfig] =
    return config.VpnProxyParseConfigTextForTest(configText)

fn VpnProxyLoadConfig(configPathRaw: str): Result[VpnProxyConfig] =
    return config.VpnProxyLoadConfig(configPathRaw)

fn VpnProxyResolvePath(baseDir: str, pathRaw: str): str =
    let trimmed: str = strutil.Strip(pathRaw)
    if len(trimmed) <= 0:
        return ""
    return chengpath.PathAbsolute(baseDir, trimmed)

fn VpnProxyLoadLeafKeyKind(certDer: Bytes): Result[x509.X509PublicKeyKind] =
    var cert = x509.initX509Certificate()
    let parseRes: Result[bool] = x509.x509ParseCertificateInto(cert, certDer)
    if IsErr(parseRes):
        return Err[x509.X509PublicKeyKind](ErrorText(parseRes))
    if cert.publicKey.kind == x509.X509KeyUnknown:
        return Err[x509.X509PublicKeyKind]("vpn proxy: certificate public key kind missing")
    return Ok[x509.X509PublicKeyKind](cert.publicKey.kind)

fn VpnProxyLoadIdentity(baseDir: str,
                          cfg: VpnProxyIdentityConfig,
                          requireListen: bool): Result[VpnProxyLoadedIdentity] =
    if requireListen && len(cfg.listen) <= 0:
        return Err[VpnProxyLoadedIdentity]("vpn proxy config: listen missing")
    if len(cfg.certDer) <= 0 || len(cfg.keyPk8Der) <= 0 || len(cfg.trustRootDer) <= 0:
        return Err[VpnProxyLoadedIdentity]("vpn proxy config: cert_der/key_pk8_der/trust_root_der required")
    var out = VpnProxyLoadedIdentity()
    let leafPath: str = VpnProxyResolvePath(baseDir, cfg.certDer)
    let leafRes: Result[Bytes] = VpnProxyLoadBytesFile(leafPath)
    if IsErr(leafRes):
        return Err[VpnProxyLoadedIdentity](ErrorText(leafRes))
    add(out.certs, Value(leafRes))
    for i in 0..<cfg.certChainDer.len:
        let path: str = VpnProxyResolvePath(baseDir, cfg.certChainDer[i])
        let certRes: Result[Bytes] = VpnProxyLoadBytesFile(path)
        if IsErr(certRes):
            return Err[VpnProxyLoadedIdentity](ErrorText(certRes))
        add(out.certs, Value(certRes))
    let keyPath: str = VpnProxyResolvePath(baseDir, cfg.keyPk8Der)
    let keyRes: Result[Bytes] = VpnProxyLoadBytesFile(keyPath)
    if IsErr(keyRes):
        return Err[VpnProxyLoadedIdentity](ErrorText(keyRes))
    out.privateKey = Value(keyRes)
    let kindRes: Result[x509.X509PublicKeyKind] = VpnProxyLoadLeafKeyKind(out.certs[0])
    if IsErr(kindRes):
        return Err[VpnProxyLoadedIdentity](ErrorText(kindRes))
    out.leafKeyKind = Value(kindRes)
    let trustPath: str = VpnProxyResolvePath(baseDir, cfg.trustRootDer)
    let trustRes: Result[Bytes] = VpnProxyLoadBytesFile(trustPath)
    if IsErr(trustRes):
        return Err[VpnProxyLoadedIdentity](ErrorText(trustRes))
    add(out.trustRoots, Value(trustRes))
    for i in 0..<cfg.trustRootsDer.len:
        let path: str = VpnProxyResolvePath(baseDir, cfg.trustRootsDer[i])
        let rootRes: Result[Bytes] = VpnProxyLoadBytesFile(path)
        if IsErr(rootRes):
            return Err[VpnProxyLoadedIdentity](ErrorText(rootRes))
        add(out.trustRoots, Value(rootRes))
    return Ok[VpnProxyLoadedIdentity](out)

fn VpnProxyBuildPolicy(identity: VpnProxyLoadedIdentity,
                         serverName: str): Result[qpolicy.MsQuicTlsPolicy] =
    var out = qpolicy.initMsQuicTlsPolicy()
    qpolicy.msquicTlsPolicySetServerName(out, serverName)
    out.certPrivateKey = identity.privateKey
    out.certLeafKeyKind = identity.leafKeyKind
    for i in 0..<identity.certs.len:
        let addRes: Result[bool] = qpolicy.msquicTlsPolicyAddCert(out, identity.certs[i])
        if IsErr(addRes):
            return Err[qpolicy.MsQuicTlsPolicy](ErrorText(addRes))
    for i in 0..<identity.trustRoots.len:
        let addRes: Result[bool] = qpolicy.msquicTlsPolicyAddTrustRoot(out, identity.trustRoots[i])
        if IsErr(addRes):
            return Err[qpolicy.MsQuicTlsPolicy](ErrorText(addRes))
    return Ok[qpolicy.MsQuicTlsPolicy](out)

fn VpnProxyLoadedIdentityPresent(identity: VpnProxyLoadedIdentity): bool =
    return identity.certs.len > 0 &&
           bytesLen(identity.privateKey) > 0 &&
           identity.leafKeyKind != x509.X509KeyUnknown &&
           identity.trustRoots.len > 0

fn VpnProxyCloseQuicLink(link: var VpnProxyQuicLink) =
    if link.streamOpen:
        hy2sess.VpnProxyHy2TcpStreamClose(link.stream)
        link.streamOpen = false
    if link.conn.open:
        qconn.ConnClose(link.conn)
    link.exitIndex = -1

fn VpnProxyDialExit(exitCfg: VpnProxyExitConfig,
                      identity: VpnProxyLoadedIdentity,
                      handshakeTimeoutMs: int32,
                      exitIndex: int32): Result[VpnProxyQuicLink] =
    let addrRes = quic_transport.Libp2pQuicAddrFromHostPort(exitCfg.host, exitCfg.port)
    if IsErr(addrRes):
        return Err[VpnProxyQuicLink](ErrorText(addrRes))
    let policyRes: Result[qpolicy.MsQuicTlsPolicy] = VpnProxyBuildPolicy(identity, exitCfg.serverName)
    if IsErr(policyRes):
        return Err[VpnProxyQuicLink](ErrorText(policyRes))
    var settings = qruntime.initMsQuicSettings()
    settings.handshakeIdleTimeoutMs = int64(handshakeTimeoutMs)
    var transport = qtransport.InitMsQuicTransport()
    let settingsRes: Result[bool] = qtransport.setMsQuicTransportSettings(transport, settings)
    if IsErr(settingsRes):
        return Err[VpnProxyQuicLink](ErrorText(settingsRes))
    let tlsRes: Result[bool] = qtransport.setMsQuicTransportTlsPolicy(transport, Value(policyRes))
    if IsErr(tlsRes):
        return Err[VpnProxyQuicLink](ErrorText(tlsRes))
    let dialRes = qtransport.dial(transport, Value(addrRes))
    if IsErr(dialRes):
        return Err[VpnProxyQuicLink](ErrorText(dialRes))
    var conn = Value(dialRes)
    let selectRes = quic_transport.Libp2pQuicClientSelectProtocol(transport, conn, VpnProxyProtocolId())
    if IsErr(selectRes):
        qconn.ConnClose(conn)
        return Err[VpnProxyQuicLink](ErrorText(selectRes))
    var out: VpnProxyQuicLink
    out.transport = transport
    out.conn = conn
    out.streamOpen = false
    out.exitIndex = exitIndex
    return Ok[VpnProxyQuicLink](out)

fn VpnProxyExitAuthority(exitCfg: VpnProxyExitConfig): str =
    let authorityText: str = strutil.Strip(exitCfg.authority)
    if len(authorityText) > 0:
        return authorityText
    return strutil.Strip(exitCfg.serverName)

fn VpnProxyServerCcRxText(serverCfg: VpnProxyIdentityConfig): str =
    let text: str = strutil.Strip(serverCfg.ccRxText)
    if len(text) > 0:
        return text
    return "auto"

fn VpnProxyRequireExitHy2Config(exitCfg: VpnProxyExitConfig): Result[bool] =
    let authText: str = strutil.Strip(exitCfg.auth)
    let authLen: int32 = len(authText)
    if authLen <= 0:
        return Err[bool]("vpn proxy: exit auth missing")
    let authorityText: str = VpnProxyExitAuthority(exitCfg)
    let authorityLen: int32 = len(authorityText)
    if authorityLen <= 0:
        return Err[bool]("vpn proxy: exit authority missing")
    if exitCfg.ccRx <= 0:
        return Err[bool]("vpn proxy: exit cc_rx invalid")
    return Ok[bool](true)

fn VpnProxyRequireServerHy2Config(serverCfg: VpnProxyIdentityConfig): Result[bool] =
    let expectedAuthText: str = strutil.Strip(serverCfg.expectedAuth)
    let expectedAuthLen: int32 = len(expectedAuthText)
    if expectedAuthLen <= 0:
        return Err[bool]("vpn proxy: server expected_auth missing")
    return Ok[bool](true)

fn VpnProxyTargetAddress(target: VpnProxyTarget): str =
    if strings.StrContains(target.host, ":"):
        return "[" + target.host + "]:" + intToStr(target.port)
    return target.host + ":" + intToStr(target.port)

fn VpnProxyTargetFromAddress(address: str): Result[VpnProxyTarget] =
    let parsedRes: Result[listen.VpnProxyListenAddress] = listen.VpnProxyParseListenAddress(address)
    if IsErr(parsedRes):
        return Err[VpnProxyTarget](ErrorText(parsedRes))
    let parsed: listen.VpnProxyListenAddress = Value(parsedRes)
    var out: VpnProxyTarget
    out.host = parsed.host
    out.port = parsed.port
    return Ok[VpnProxyTarget](out)

fn VpnProxyHy2ClientHandshake(base: qconn.Connection,
                                exitCfg: VpnProxyExitConfig): Result[Hysteria2AuthResponse] =
    let cfgRes: Result[bool] = VpnProxyRequireExitHy2Config(exitCfg)
    if IsErr(cfgRes):
        return Err[Hysteria2AuthResponse](ErrorText(cfgRes))
    let preambleWriteRes: Result[bool] = hy2sess.VpnProxyHy2ClientSendPreamble(base)
    if IsErr(preambleWriteRes):
        return Err[Hysteria2AuthResponse](ErrorText(preambleWriteRes))
    let preambleReadRes: Result[bool] = hy2sess.VpnProxyHy2ClientExpectServerPreamble(base)
    if IsErr(preambleReadRes):
        return Err[Hysteria2AuthResponse](ErrorText(preambleReadRes))
    let authRes = hy2sess.VpnProxyHy2ClientAuth(base,
                                                  VpnProxyExitAuthority(exitCfg),
                                                  exitCfg.auth,
                                                  int64(exitCfg.ccRx),
                                                  "")
    if IsErr(authRes):
        return Err[Hysteria2AuthResponse](ErrorText(authRes))
    let authResp = Value(authRes)
    if authResp.statusCode != VpnProxyHy2AuthOkStatus:
        return Err[Hysteria2AuthResponse]("vpn proxy: exit auth rejected")
    return Ok[Hysteria2AuthResponse](authResp)

fn VpnProxyHy2OpenTargetStream(base: qconn.Connection,
                                 target: VpnProxyTarget): Result[VpnProxyHy2TcpStream] =
    let streamRes: Result[VpnProxyHy2TcpStream] = hy2sess.VpnProxyHy2OpenTcpStream(base, VpnProxyHy2TcpStreamId)
    if IsErr(streamRes):
        return Err[VpnProxyHy2TcpStream](ErrorText(streamRes))
    var stream = Value(streamRes)
    var emptyPadding: Bytes
    emptyPadding.data = nil
    emptyPadding.len = 0
    let reqWriteRes: Result[bool] = hy2sess.VpnProxyHy2TcpStreamWriteRequest(stream,
                                                                               VpnProxyTargetAddress(target),
                                                                               emptyPadding)
    if IsErr(reqWriteRes):
        return Err[VpnProxyHy2TcpStream](ErrorText(reqWriteRes))
    let respRes = hy2sess.VpnProxyHy2TcpStreamReadResponse(stream)
    if IsErr(respRes):
        return Err[VpnProxyHy2TcpStream](ErrorText(respRes))
    let resp = Value(respRes)
    if !resp.ok:
        let messageText: str = strutil.Strip(resp.message)
        if len(messageText) > 0:
            return Err[VpnProxyHy2TcpStream](messageText)
        return Err[VpnProxyHy2TcpStream]("vpn proxy: remote target open failed")
    return Ok[VpnProxyHy2TcpStream](stream)

fn VpnProxyHy2Probe(base: qconn.Connection): Result[bool] =
    var emptyPadding: Bytes
    emptyPadding.data = nil
    emptyPadding.len = 0
    let reqWriteRes: Result[bool] = hy2sess.VpnProxyHy2ClientWriteTcpRequest(base,
                                                                                VpnProxyHy2TcpStreamId,
                                                                                VpnProxyHy2ProbeAddress,
                                                                                emptyPadding)
    if IsErr(reqWriteRes):
        return Err[bool](ErrorText(reqWriteRes))
    let respRes = hy2sess.VpnProxyHy2ClientReadTcpResponse(base, VpnProxyHy2TcpStreamId)
    if IsErr(respRes):
        return Err[bool](ErrorText(respRes))
    let resp = Value(respRes).resp
    if !resp.ok:
        let messageText: str = strutil.Strip(resp.message)
        if len(messageText) > 0:
            return Err[bool](messageText)
        return Err[bool]("vpn proxy: exit probe rejected")
    return Ok[bool](true)

fn VpnProxyHy2ServerAuth(base: qconn.Connection,
                           serverCfg: VpnProxyIdentityConfig): Result[bool] =
    let cfgRes: Result[bool] = VpnProxyRequireServerHy2Config(serverCfg)
    if IsErr(cfgRes):
        return Err[bool](ErrorText(cfgRes))
    let preambleWriteRes: Result[bool] = hy2sess.VpnProxyHy2ServerSendPreamble(base)
    if IsErr(preambleWriteRes):
        return Err[bool](ErrorText(preambleWriteRes))
    let preambleReadRes: Result[bool] = hy2sess.VpnProxyHy2ServerExpectClientPreamble(base)
    if IsErr(preambleReadRes):
        return Err[bool](ErrorText(preambleReadRes))
    let authReqRes = hy2sess.VpnProxyHy2ServerReadAuth(base)
    if IsErr(authReqRes):
        return Err[bool](ErrorText(authReqRes))
    let authReq = Value(authReqRes)
    let expectedAuthorityText: str = strutil.Strip(serverCfg.expectedAuthority)
    if authReq.auth != strutil.Strip(serverCfg.expectedAuth) ||
       (len(expectedAuthorityText) > 0 && authReq.authority != expectedAuthorityText):
        let _ = hy2sess.VpnProxyHy2ServerWriteAuthResponse(base,
                                                             VpnProxyHy2AuthRejectStatus,
                                                             false,
                                                             VpnProxyServerCcRxText(serverCfg),
                                                             "")
        return Err[bool]("vpn proxy exit: auth rejected")
    let authRespRes: Result[bool] = hy2sess.VpnProxyHy2ServerWriteAuthResponse(base,
                                                                                  VpnProxyHy2AuthOkStatus,
                                                                                  true,
                                                                                  VpnProxyServerCcRxText(serverCfg),
                                                                                  "")
    if IsErr(authRespRes):
        return Err[bool](ErrorText(authRespRes))
    return Ok[bool](true)

fn VpnProxyWouldBlockQuic(err: str): bool =
    return err == "msquic udp: queue empty" || err == "pipe: empty" || err == "connection: empty"

fn VpnProxyTcpReadExact(conn: var tcp.TcpConnectionHandle, count: int32): Result[Bytes] =
    let out: Bytes = bytesAlloc(count)
    var filled: int32
    while filled < count:
        let dstPtr: ptr = rawmem_support.RawmemPtrAdd(out.data, filled)
        let readRes: Result[int32] = tcp.TcpRecvRaw(conn, dstPtr, count - filled)
        if IsErr(readRes):
            return Err[Bytes](ErrorText(readRes))
        let got: int32 = Value(readRes)
        if got <= 0:
            return Err[Bytes]("vpn proxy: unexpected tcp eof")
        filled = filled + got
    return Ok[Bytes](out)

fn VpnProxyTcpWriteAll(conn: var tcp.TcpConnectionHandle, data: var Bytes): Result[int32] =
    return tcp.TcpSendRaw(conn, data.data, bytesLen(data))

fn VpnProxySocksReply(code: int32): Bytes =
    return socks.VpnProxySocksReply(code)

fn VpnProxySocksMethodHandshake(conn: var tcp.TcpConnectionHandle): Result[bool] =
    let headerRes: Result[Bytes] = VpnProxyTcpReadExact(conn, 2)
    if IsErr(headerRes):
        return Err[bool](ErrorText(headerRes))
    let header = Value(headerRes)
    let methodCount: int32 = bytesGet(header, 1)
    let methodsRes: Result[Bytes] = VpnProxyTcpReadExact(conn, methodCount)
    if IsErr(methodsRes):
        return Err[bool](ErrorText(methodsRes))
    let methods = Value(methodsRes)
    let request: Bytes = bytesConcat(header, methods)
    let replyRes: Result[Bytes] = socks.VpnProxySocksMethodReplyFor(request)
    if IsErr(replyRes):
        let errText: str = ErrorText(replyRes)
        if ErrorText(replyRes) == "vpn proxy socks5: no supported auth method":
            var rejectWire: Bytes = bytesFromString("\x05\xff")
            let _ = VpnProxyTcpWriteAll(conn, rejectWire)
        return Err[bool](errText)
    var replyWire: Bytes = Value(replyRes)
    let writeRes = VpnProxyTcpWriteAll(conn, replyWire)
    if IsErr(writeRes):
        return Err[bool](ErrorText(writeRes))
    return Ok[bool](true)

fn VpnProxySocksReadRequest(conn: var tcp.TcpConnectionHandle): Result[VpnProxySocksRequest] =
    let headRes: Result[Bytes] = VpnProxyTcpReadExact(conn, 4)
    if IsErr(headRes):
        return Err[VpnProxySocksRequest](ErrorText(headRes))
    let head = Value(headRes)
    let atyp: int32 = bytesGet(head, 3)
    var tail: Bytes = bytesAlloc(0)
    if atyp == VpnProxySocksAtypIpv4:
        let addrRes = VpnProxyTcpReadExact(conn, 4)
        if IsErr(addrRes):
            return Err[VpnProxySocksRequest](ErrorText(addrRes))
        tail = Value(addrRes)
    elif atyp == VpnProxySocksAtypDomain:
        let lenRes = VpnProxyTcpReadExact(conn, 1)
        if IsErr(lenRes):
            return Err[VpnProxySocksRequest](ErrorText(lenRes))
        let hostLenByte: Bytes = Value(lenRes)
        let hostLen: int32 = bytesGet(hostLenByte, 0)
        let hostRes = VpnProxyTcpReadExact(conn, hostLen)
        if IsErr(hostRes):
            return Err[VpnProxySocksRequest](ErrorText(hostRes))
        tail = bytesConcat(hostLenByte, Value(hostRes))
    elif atyp == VpnProxySocksAtypIpv6:
        let addrRes = VpnProxyTcpReadExact(conn, 16)
        if IsErr(addrRes):
            return Err[VpnProxySocksRequest](ErrorText(addrRes))
        tail = Value(addrRes)
    else:
        var replyWire: Bytes = VpnProxySocksReply(VpnProxySocksReplyAddressUnsupported)
        let _ = VpnProxyTcpWriteAll(conn, replyWire)
        return Err[VpnProxySocksRequest]("vpn proxy socks5: unsupported address type")
    let portRes = VpnProxyTcpReadExact(conn, 2)
    if IsErr(portRes):
        return Err[VpnProxySocksRequest](ErrorText(portRes))
    let wire: Bytes = bytesConcat3(head, tail, Value(portRes))
    let parseRes: Result[VpnProxySocksRequest] = socks.VpnProxySocksParseRequestWire(wire)
    if IsErr(parseRes):
        let err: str = ErrorText(parseRes)
        if err == "vpn proxy socks5: unsupported command" ||
           err == "vpn proxy socks5: invalid command":
            var replyWire: Bytes = VpnProxySocksReply(VpnProxySocksReplyCommandUnsupported)
            let _ = VpnProxyTcpWriteAll(conn, replyWire)
        elif err == "vpn proxy socks5: unsupported address type":
            var replyWire: Bytes = VpnProxySocksReply(VpnProxySocksReplyAddressUnsupported)
            let _ = VpnProxyTcpWriteAll(conn, replyWire)
        return Err[VpnProxySocksRequest](err)
    return parseRes

fn VpnProxyProbeExit(state: var VpnProxyExitState,
                       identity: VpnProxyLoadedIdentity,
                       timeoutMs: int32): bool =
    let beginMs: int64 = VpnProxyMonoNowMs()
    let dialRes: Result[VpnProxyQuicLink] = VpnProxyDialExit(state.cfg, identity, timeoutMs, -1)
    if IsErr(dialRes):
        routing.VpnProxyMarkProbeFailure(state, beginMs, ErrorText(dialRes))
        return false
    var link = Value(dialRes)
    let authRes: Result[Hysteria2AuthResponse] = VpnProxyHy2ClientHandshake(link.conn, state.cfg)
    if IsErr(authRes):
        VpnProxyCloseQuicLink(link)
        routing.VpnProxyMarkProbeFailure(state, beginMs, ErrorText(authRes))
        return false
    let probeRes: Result[bool] = VpnProxyHy2Probe(link.conn)
    if IsErr(probeRes):
        VpnProxyCloseQuicLink(link)
        routing.VpnProxyMarkProbeFailure(state, beginMs, ErrorText(probeRes))
        return false
    let endMs: int64 = VpnProxyMonoNowMs()
    VpnProxyCloseQuicLink(link)
    routing.VpnProxyMarkSuccess(state, endMs, endMs - beginMs)
    return true

fn VpnProxyProbeAll(states: var VpnProxyExitState[],
                      identity: VpnProxyLoadedIdentity,
                      timeoutMs: int32) =
    for i in 0..<states.len:
        let _ok: bool = VpnProxyProbeExit(states[i], identity, timeoutMs)

fn VpnProxyEnsureFreshExits(states: var VpnProxyExitState[],
                              identity: VpnProxyLoadedIdentity,
                              probeIntervalMs: int32,
                              probeTimeoutMs: int32) =
    let nowMs: int64 = VpnProxyMonoNowMs()
    for i in 0..<states.len:
        let state: VpnProxyExitState = states[i]
        if state.lastProbeMs <= 0 || nowMs - state.lastProbeMs >= int64(probeIntervalMs):
            let _ok: bool = VpnProxyProbeExit(states[i], identity, probeTimeoutMs)

fn VpnProxyOpenRemoteAttempt(states: var VpnProxyExitState[],
                               identity: VpnProxyLoadedIdentity,
                               target: VpnProxyTarget,
                               idx: int32): Result[VpnProxyQuicLink] =
    if idx < 0 || idx >= states.len:
        return Err[VpnProxyQuicLink]("vpn proxy: invalid exit index")
    let dialRes: Result[VpnProxyQuicLink] = VpnProxyDialExit(states[idx].cfg,
                                                                 identity,
                                                                 VpnProxyConnectTimeoutMs,
                                                                 idx)
    if IsErr(dialRes):
        routing.VpnProxyRecordOpenFailure(states[idx], VpnProxyMonoNowMs(), ErrorText(dialRes))
        return Err[VpnProxyQuicLink](ErrorText(dialRes))
    var link = Value(dialRes)
    let authRes: Result[Hysteria2AuthResponse] = VpnProxyHy2ClientHandshake(link.conn, states[idx].cfg)
    if IsErr(authRes):
        VpnProxyCloseQuicLink(link)
        routing.VpnProxyRecordOpenFailure(states[idx], VpnProxyMonoNowMs(), ErrorText(authRes))
        return Err[VpnProxyQuicLink](ErrorText(authRes))
    let streamRes: Result[VpnProxyHy2TcpStream] = VpnProxyHy2OpenTargetStream(link.conn, target)
    if IsErr(streamRes):
        VpnProxyCloseQuicLink(link)
        routing.VpnProxyRecordOpenFailure(states[idx], VpnProxyMonoNowMs(), ErrorText(streamRes))
        return Err[VpnProxyQuicLink](ErrorText(streamRes))
    link.stream = Value(streamRes)
    link.streamOpen = true
    link.exitIndex = idx
    return Ok[VpnProxyQuicLink](link)

fn VpnProxyOpenRemoteDatagramAttempt(states: var VpnProxyExitState[],
                                       identity: VpnProxyLoadedIdentity,
                                       idx: int32): Result[VpnProxyQuicLink] =
    if idx < 0 || idx >= states.len:
        return Err[VpnProxyQuicLink]("vpn proxy: invalid exit index")
    let dialRes: Result[VpnProxyQuicLink] = VpnProxyDialExit(states[idx].cfg,
                                                                 identity,
                                                                 VpnProxyConnectTimeoutMs,
                                                                 idx)
    if IsErr(dialRes):
        routing.VpnProxyRecordOpenFailure(states[idx], VpnProxyMonoNowMs(), ErrorText(dialRes))
        return Err[VpnProxyQuicLink](ErrorText(dialRes))
    var link = Value(dialRes)
    let authRes: Result[Hysteria2AuthResponse] = VpnProxyHy2ClientHandshake(link.conn, states[idx].cfg)
    if IsErr(authRes):
        VpnProxyCloseQuicLink(link)
        routing.VpnProxyRecordOpenFailure(states[idx], VpnProxyMonoNowMs(), ErrorText(authRes))
        return Err[VpnProxyQuicLink](ErrorText(authRes))
    if !Value(authRes).udpEnabled:
        VpnProxyCloseQuicLink(link)
        routing.VpnProxyRecordOpenFailure(states[idx], VpnProxyMonoNowMs(), "vpn proxy: exit udp disabled")
        return Err[VpnProxyQuicLink]("vpn proxy: exit udp disabled")
    link.exitIndex = idx
    return Ok[VpnProxyQuicLink](link)

fn VpnProxyOpenRemote(states: var VpnProxyExitState[],
                        identity: VpnProxyLoadedIdentity,
                        target: VpnProxyTarget,
                        probeIntervalMs: int32,
                        probeTimeoutMs: int32): Result[VpnProxyQuicLink] =
    VpnProxyEnsureFreshExits(states, identity, probeIntervalMs, probeTimeoutMs)
    let firstIndex: int32 = routing.VpnProxyBestHealthyExit(states, -1)
    if firstIndex < 0:
        return Err[VpnProxyQuicLink]("vpn proxy: no healthy exit")
    let secondIndex: int32 = routing.VpnProxyBestHealthyExit(states, firstIndex)
    let firstRes: Result[VpnProxyQuicLink] = VpnProxyOpenRemoteAttempt(states, identity, target, firstIndex)
    let firstErr: str = if IsErr(firstRes): ErrorText(firstRes) else: ""
    if IsOk(firstRes):
        return firstRes
    if secondIndex >= 0:
        let secondRes: Result[VpnProxyQuicLink] = VpnProxyOpenRemoteAttempt(states, identity, target, secondIndex)
        let secondErr: str = if IsErr(secondRes): ErrorText(secondRes) else: ""
        if IsOk(secondRes):
            return secondRes
        return Err[VpnProxyQuicLink]("vpn proxy: open failed on all exits: " + firstErr + " | " + secondErr)
    return Err[VpnProxyQuicLink]("vpn proxy: open failed on all exits: " + firstErr)

fn VpnProxyOpenRemoteDatagram(states: var VpnProxyExitState[],
                                identity: VpnProxyLoadedIdentity,
                                probeIntervalMs: int32,
                                probeTimeoutMs: int32): Result[VpnProxyQuicLink] =
    VpnProxyEnsureFreshExits(states, identity, probeIntervalMs, probeTimeoutMs)
    let firstIndex: int32 = routing.VpnProxyBestHealthyExit(states, -1)
    if firstIndex < 0:
        return Err[VpnProxyQuicLink]("vpn proxy: no healthy exit")
    let secondIndex: int32 = routing.VpnProxyBestHealthyExit(states, firstIndex)
    let firstRes: Result[VpnProxyQuicLink] = VpnProxyOpenRemoteDatagramAttempt(states, identity, firstIndex)
    let firstErr: str = if IsErr(firstRes): ErrorText(firstRes) else: ""
    if IsOk(firstRes):
        return firstRes
    if secondIndex >= 0:
        let secondRes: Result[VpnProxyQuicLink] = VpnProxyOpenRemoteDatagramAttempt(states, identity, secondIndex)
        let secondErr: str = if IsErr(secondRes): ErrorText(secondRes) else: ""
        if IsOk(secondRes):
            return secondRes
        return Err[VpnProxyQuicLink]("vpn proxy: open failed on all exits: " + firstErr + " | " + secondErr)
    return Err[VpnProxyQuicLink]("vpn proxy: open failed on all exits: " + firstErr)

fn VpnProxyRelayTcpQuic(conn: var tcp.TcpConnectionHandle,
                          quicStream: var VpnProxyHy2TcpStream): Result[bool] =
    let nbRes = tcp.TcpSetNonblocking(conn, true)
    if IsErr(nbRes):
        return Err[bool](ErrorText(nbRes))
    var tcpPendingWrite: Bytes = bytesAlloc(0)
    var tcpReadClosed = false
    var tcpWriteClosed = false
    var quicReadClosed = false
    var quicWriteClosed = false
    while true:
        var progressed = false
        if !tcpReadClosed:
            let tcpReadBuf: Bytes = bytesAlloc(VpnProxyRelayChunkBytes)
            let readRes: Result[int32] = tcp.TcpRecvRawNonblocking(conn, tcpReadBuf.data, bytesLen(tcpReadBuf))
            if IsErr(readRes):
                if ErrorText(readRes) != "tcp syscall: would block":
                    return Err[bool](ErrorText(readRes))
            else:
                let got: int32 = Value(readRes)
                if got <= 0:
                    tcpReadClosed = true
                    if !quicWriteClosed:
                        let closeRes: Result[bool] = hy2sess.VpnProxyHy2TcpStreamShutdownWrite(quicStream)
                        if IsErr(closeRes):
                            return Err[bool](ErrorText(closeRes))
                        quicWriteClosed = true
                    progressed = true
                else:
                    let chunk: Bytes = bytesSlice(tcpReadBuf, 0, got)
                    let writeRes: Result[int32] = hy2sess.VpnProxyHy2TcpStreamWrite(quicStream, chunk)
                    if IsErr(writeRes):
                        return Err[bool](ErrorText(writeRes))
                    progressed = true
        while true:
            let readRes: Result[Bytes] = hy2sess.VpnProxyHy2TcpStreamReadNonblocking(quicStream,
                                                                                        VpnProxyRelayChunkBytes)
            if IsErr(readRes):
                let err: str = ErrorText(readRes)
                if VpnProxyWouldBlockQuic(err):
                    break
                if err == "msquic: stream closed" ||
                   err == "msquic: pipe closed" ||
                   err == "connection: closed":
                    quicReadClosed = true
                    break
                return Err[bool](err)
            let chunk: Bytes = Value(readRes)
            if bytesLen(chunk) <= 0:
                break
            VpnProxyBytesAppend(tcpPendingWrite, chunk)
            progressed = true
        if bytesLen(tcpPendingWrite) > 0:
            let sendRes: Result[int32] = tcp.TcpSendRawNonblocking(conn, tcpPendingWrite.data, bytesLen(tcpPendingWrite))
            if IsErr(sendRes):
                return Err[bool](ErrorText(sendRes))
            let sent: int32 = Value(sendRes)
            if sent > 0:
                tcpPendingWrite = VpnProxyBytesDropPrefix(tcpPendingWrite, sent)
                progressed = true
        if quicReadClosed && bytesLen(tcpPendingWrite) <= 0 && !tcpWriteClosed:
            let shutdownRes: Result[bool] = tcp.TcpShutdownWrite(conn)
            if IsErr(shutdownRes):
                return Err[bool](ErrorText(shutdownRes))
            tcpWriteClosed = true
        if tcpReadClosed && quicReadClosed && bytesLen(tcpPendingWrite) <= 0:
            return Ok[bool](true)
        if !progressed:
            os.SleepMs(10)
        if !conn.open || !quicStream.conn.open:
            if bytesLen(tcpPendingWrite) <= 0:
                return Ok[bool](true)
        if quicReadClosed && bytesLen(tcpPendingWrite) <= 0 && tcpReadClosed:
            return Ok[bool](true)
    return Ok[bool](true)

fn VpnProxyRelayLocalUdp(conn: var tcp.TcpConnectionHandle,
                           relaySocket: VpnProxyUdpBoundSocket,
                           link: var VpnProxyQuicLink): Result[bool] =
    let nbRes: Result[bool] = tcp.TcpSetNonblocking(conn, true)
    if IsErr(nbRes):
        return Err[bool](ErrorText(nbRes))
    let controlBuf: Bytes = bytesAlloc(1)
    var clientPeerSet: bool
    var clientPeer: udp.UdpSockAddr
    var clientPacketId: int32
    var remoteFrags: VpnProxyUdpFragState[]
    while true:
        var progressed: bool
        let controlRes: Result[int32] = tcp.TcpRecvRawNonblocking(conn, controlBuf.data, 1)
        if IsErr(controlRes):
            if ErrorText(controlRes) != "tcp syscall: would block":
                return Err[bool](ErrorText(controlRes))
        else:
            let got: int32 = Value(controlRes)
            if got == 0:
                return Ok[bool](true)
            return Err[bool]("vpn proxy socks5: udp associate control stream invalid")
        var localRecv: udp.UdpRecvResult
        let localRecvRes: Result[bool] = udp.UdpRecvFromNonblock(relaySocket.socket.fd,
                                                                 VpnProxyUdpRelayChunkBytes,
                                                                 localRecv)
        if IsErr(localRecvRes):
            if !VpnProxyWouldBlockUdp(ErrorText(localRecvRes)):
                return Err[bool](ErrorText(localRecvRes))
        else:
            if !clientPeerSet:
                clientPeer = localRecv.fromAddr
                clientPeerSet = true
            if !VpnProxyUdpSocketAddrEq(clientPeer, localRecv.fromAddr):
                progressed = true
            else:
                let udpReqRes: Result[VpnProxySocksUdpDatagram] = socks.VpnProxySocksDecodeUdpDatagram(localRecv.data)
                if IsErr(udpReqRes):
                    return Err[bool](ErrorText(udpReqRes))
                let udpReq: VpnProxySocksUdpDatagram = Value(udpReqRes)
                if udpReq.fragmentId != 0:
                    return Err[bool]("vpn proxy: socks udp fragmentation unsupported")
                let targetText: str = VpnProxyTargetAddress(udpReq.target)
                let payloadLimitRes: Result[int32] = VpnProxyHy2UdpPayloadLimit(link.transport, targetText)
                if IsErr(payloadLimitRes):
                    return Err[bool](ErrorText(payloadLimitRes))
                let packetId: int32 = VpnProxyUdpPacketNext(clientPacketId)
                let msg: Hysteria2UdpMessage = hy2.Hysteria2MakeUdpMessage(VpnProxyHy2UdpSessionId,
                                                                               packetId,
                                                                               0,
                                                                               1,
                                                                               targetText,
                                                                               udpReq.payload)
                let fragmentsRes: Result[Hysteria2UdpMessage[]] = hy2.Hysteria2FragmentUdpMessage(msg,
                                                                                                       Value(payloadLimitRes))
                if IsErr(fragmentsRes):
                    return Err[bool](ErrorText(fragmentsRes))
                let fragments: Hysteria2UdpMessage[] = Value(fragmentsRes)
                for i in 0..<fragments.len:
                    let wireRes: Result[Bytes] = hy2.Hysteria2EncodeUdpMessage(fragments[i])
                    if IsErr(wireRes):
                        return Err[bool](ErrorText(wireRes))
                    let writeRes: Result[int32] = qtransport.msquicTransportDatagramWrite(link.transport,
                                                                                           link.conn,
                                                                                           Value(wireRes))
                    if IsErr(writeRes):
                        return Err[bool](ErrorText(writeRes))
                progressed = true
        let remoteReadRes: Result[Bytes] = qtransport.msquicTransportDatagramRead(link.transport, link.conn)
        if IsErr(remoteReadRes):
            let err: str = ErrorText(remoteReadRes)
            if !VpnProxyWouldBlockQuic(err):
                return Err[bool](err)
        else:
            let msgRes: Result[Hysteria2UdpMessage] = hy2.Hysteria2DecodeUdpMessage(Value(remoteReadRes))
            if IsErr(msgRes):
                return Err[bool](ErrorText(msgRes))
            let msg: Hysteria2UdpMessage = Value(msgRes)
            if msg.sessionId != VpnProxyHy2UdpSessionId:
                return Err[bool]("vpn proxy: udp session mismatch")
            var fullMsg: Hysteria2UdpMessage
            let fullRes: Result[bool] = VpnProxyUdpFragFeed(remoteFrags, msg, fullMsg)
            if IsErr(fullRes):
                return Err[bool](ErrorText(fullRes))
            if Value(fullRes):
                if !clientPeerSet:
                    return Err[bool]("vpn proxy: udp client peer missing")
                let sourceTargetRes: Result[VpnProxyTarget] = VpnProxyTargetFromAddress(fullMsg.address)
                if IsErr(sourceTargetRes):
                    return Err[bool](ErrorText(sourceTargetRes))
                var socksDatagram: VpnProxySocksUdpDatagram
                socksDatagram.fragmentId = 0
                socksDatagram.target = Value(sourceTargetRes)
                socksDatagram.payload = fullMsg.payload
                let socksWireRes: Result[Bytes] = socks.VpnProxySocksEncodeUdpDatagram(socksDatagram)
                if IsErr(socksWireRes):
                    return Err[bool](ErrorText(socksWireRes))
                let sendRes: Result[bool] = VpnProxyUdpSocketSend(relaySocket.socket.fd,
                                                                    Value(socksWireRes),
                                                                    clientPeer)
                if IsErr(sendRes):
                    return Err[bool](ErrorText(sendRes))
            progressed = true
        if !progressed:
            os.SleepMs(VpnProxyUdpRelaySleepMs)
    return Ok[bool](true)

fn VpnProxyHandleLocalConnect(states: var VpnProxyExitState[],
                                identity: VpnProxyLoadedIdentity,
                                probeIntervalMs: int32,
                                probeTimeoutMs: int32,
                                conn: var tcp.TcpConnectionHandle,
                                target: VpnProxyTarget): Result[bool] =
    let openRes: Result[VpnProxyQuicLink] = VpnProxyOpenRemote(states,
                                                                   identity,
                                                                   target,
                                                                   probeIntervalMs,
                                                                   probeTimeoutMs)
    if IsErr(openRes):
        var replyWire: Bytes = VpnProxySocksReply(VpnProxySocksReplyConnectionRefused)
        let _ = VpnProxyTcpWriteAll(conn, replyWire)
        return Err[bool](ErrorText(openRes))
    var link = Value(openRes)
    var okWire: Bytes = VpnProxySocksReply(0)
    let okRes = VpnProxyTcpWriteAll(conn, okWire)
    if IsErr(okRes):
        VpnProxyCloseQuicLink(link)
        return Err[bool](ErrorText(okRes))
    let relayRes = VpnProxyRelayTcpQuic(conn, link.stream)
    VpnProxyCloseQuicLink(link)
    if IsErr(relayRes):
        return Err[bool](ErrorText(relayRes))
    return Ok[bool](true)

fn VpnProxyHandleLocalUdpAssociate(states: var VpnProxyExitState[],
                                     identity: VpnProxyLoadedIdentity,
                                     probeIntervalMs: int32,
                                     probeTimeoutMs: int32,
                                     conn: var tcp.TcpConnectionHandle): Result[bool] =
    let openRes: Result[VpnProxyQuicLink] = VpnProxyOpenRemoteDatagram(states,
                                                                            identity,
                                                                            probeIntervalMs,
                                                                            probeTimeoutMs)
    if IsErr(openRes):
        var replyWire: Bytes = VpnProxySocksReply(VpnProxySocksReplyConnectionRefused)
        let _ = VpnProxyTcpWriteAll(conn, replyWire)
        return Err[bool](ErrorText(openRes))
    var link = Value(openRes)
    let socketRes: Result[VpnProxyUdpBoundSocket] = VpnProxyUdpBoundSocketOpen(conn.localAddr.host,
                                                                                    conn.localAddr.isV6)
    if IsErr(socketRes):
        VpnProxyCloseQuicLink(link)
        var replyWire: Bytes = VpnProxySocksReply(VpnProxySocksReplyGeneralFailure)
        let _ = VpnProxyTcpWriteAll(conn, replyWire)
        return Err[bool](ErrorText(socketRes))
    let relaySocket: VpnProxyUdpBoundSocket = Value(socketRes)
    let replyRes: Result[Bytes] = socks.VpnProxySocksReplyForTarget(0, relaySocket.bindTarget)
    if IsErr(replyRes):
        udp.UdpSocketClose(relaySocket.socket.fd)
        VpnProxyCloseQuicLink(link)
        return Err[bool](ErrorText(replyRes))
    var replyWire: Bytes = Value(replyRes)
    let writeRes: Result[int32] = VpnProxyTcpWriteAll(conn, replyWire)
    if IsErr(writeRes):
        udp.UdpSocketClose(relaySocket.socket.fd)
        VpnProxyCloseQuicLink(link)
        return Err[bool](ErrorText(writeRes))
    let relayRes: Result[bool] = VpnProxyRelayLocalUdp(conn, relaySocket, link)
    udp.UdpSocketClose(relaySocket.socket.fd)
    VpnProxyCloseQuicLink(link)
    if IsErr(relayRes):
        return Err[bool](ErrorText(relayRes))
    return Ok[bool](true)

fn VpnProxyHandleLocalClient(states: var VpnProxyExitState[],
                               identity: VpnProxyLoadedIdentity,
                               probeIntervalMs: int32,
                               probeTimeoutMs: int32,
                               conn: var tcp.TcpConnectionHandle): Result[bool] =
    let methodRes = VpnProxySocksMethodHandshake(conn)
    if IsErr(methodRes):
        return Err[bool](ErrorText(methodRes))
    let requestRes: Result[VpnProxySocksRequest] = VpnProxySocksReadRequest(conn)
    if IsErr(requestRes):
        return Err[bool](ErrorText(requestRes))
    let request: VpnProxySocksRequest = Value(requestRes)
    if request.cmd == VpnProxySocksCmdConnect:
        return VpnProxyHandleLocalConnect(states,
                                            identity,
                                            probeIntervalMs,
                                            probeTimeoutMs,
                                            conn,
                                            request.target)
    if request.cmd == VpnProxySocksCmdUdpAssoc:
        return VpnProxyHandleLocalUdpAssociate(states,
                                                 identity,
                                                 probeIntervalMs,
                                                 probeTimeoutMs,
                                                 conn)
    return Err[bool]("vpn proxy socks5: unsupported command")

fn VpnProxyLocal(rootDir: str, args: str[]): int32 =
    rootDir
    let opts: VpnProxyCliOptions = cli.VpnProxyOptions(args)
    let configRes: Result[VpnProxyConfig] = VpnProxyLoadConfig(opts.configPath)
    if IsErr(configRes):
        VpnProxyPrintErr(ErrorText(configRes))
        return 1
    let config = Value(configRes)
    if config.exits.len <= 0:
        VpnProxyPrintErr("vpn proxy config: exits[] missing")
        return 1
    let identityRes = VpnProxyLoadIdentity(config.configDir, config.client, true)
    if IsErr(identityRes):
        VpnProxyPrintErr(ErrorText(identityRes))
        return 1
    let identity = Value(identityRes)
    for i in 0..<config.exits.len:
        let hy2CfgRes: Result[bool] = VpnProxyRequireExitHy2Config(config.exits[i])
        if IsErr(hy2CfgRes):
            VpnProxyPrintErr(ErrorText(hy2CfgRes))
            return 1
    var listenHost = ""
    var listenPort: int32
    let listenText: str = strutil.Strip(config.client.listen)
    if len(listenText) <= 0:
        VpnProxyPrintErr("vpn proxy: empty listen address")
        return 1
    let listenParsedRes: Result[listen.VpnProxyListenAddress] = listen.VpnProxyParseListenAddress(listenText)
    if IsErr(listenParsedRes):
        VpnProxyPrintErr(ErrorText(listenParsedRes))
        return 1
    let listenParsed: listen.VpnProxyListenAddress = Value(listenParsedRes)
    listenHost = listenParsed.host
    listenPort = listenParsed.port
    var states: VpnProxyExitState[]
    states = routing.VpnProxyInitExitStates(config.exits)
    let listenTcpRes = tcp.TcpListen(listenHost, listenPort, strings.StrContains(listenHost, ":"))
    if IsErr(listenTcpRes):
        VpnProxyPrintErr(ErrorText(listenTcpRes))
        return 1
    var listener = Value(listenTcpRes)
    VpnProxyProbeAll(states, identity, opts.probeTimeoutMs)
    if !VpnProxyWriteReadyPort(opts.readyPath, listener.addr.port):
        VpnProxyPrintErr("vpn proxy: failed to write ready path")
        tcp.TcpListenerClose(listener)
        return 1
    VpnProxyPrintLine("vpn-proxy local listening " + listenHost + ":" + intToStr(listener.addr.port))
    var served: int32
    var lastIdleProbeMs: int64 = VpnProxyMonoNowMs()
    while opts.acceptCount <= 0 || served < opts.acceptCount:
        let nowMs: int64 = VpnProxyMonoNowMs()
        if opts.probeIntervalMs > 0 && nowMs - lastIdleProbeMs >= int64(opts.probeIntervalMs):
            VpnProxyProbeAll(states, identity, opts.probeTimeoutMs)
            lastIdleProbeMs = nowMs
        let waitMs: int32 = VpnProxyLocalAcceptWaitMs(opts.probeIntervalMs, lastIdleProbeMs, nowMs)
        let waitRes: Result[bool] = tcp.TcpListenerWaitReadable(listener, waitMs)
        if IsErr(waitRes):
            VpnProxyPrintErr(ErrorText(waitRes))
            tcp.TcpListenerClose(listener)
            return 1
        if !Value(waitRes):
            continue
        let acceptRes = tcp.TcpAccept(listener)
        if IsErr(acceptRes):
            VpnProxyPrintErr(ErrorText(acceptRes))
            tcp.TcpListenerClose(listener)
            return 1
        var conn = Value(acceptRes)
        let handleRes = VpnProxyHandleLocalClient(states,
                                                    identity,
                                                    opts.probeIntervalMs,
                                                    opts.probeTimeoutMs,
                                                    conn)
        tcp.TcpClose(conn)
        if IsErr(handleRes):
            VpnProxyPrintErr(ErrorText(handleRes))
        served = served + 1
    tcp.TcpListenerClose(listener)
    return 0

fn VpnProxyHandleExitTcpStream(stream: var VpnProxyHy2TcpStream,
                                 req: hy2.Hysteria2TcpRequest): Result[bool] =
    if req.address == VpnProxyHy2ProbeAddress:
        var emptyPadding: Bytes
        emptyPadding.data = nil
        emptyPadding.len = 0
        let probeOkRes: Result[bool] = hy2sess.VpnProxyHy2TcpStreamWriteResponse(stream,
                                                                                    true,
                                                                                    "",
                                                                                    emptyPadding)
        if IsErr(probeOkRes):
            return Err[bool](ErrorText(probeOkRes))
        return Ok[bool](true)
    let targetWireRes: Result[VpnProxyTarget] = VpnProxyTargetFromAddress(req.address)
    if IsErr(targetWireRes):
        var emptyPadding: Bytes
        emptyPadding.data = nil
        emptyPadding.len = 0
        let _ = hy2sess.VpnProxyHy2TcpStreamWriteResponse(stream,
                                                            false,
                                                            ErrorText(targetWireRes),
                                                            emptyPadding)
        return Err[bool](ErrorText(targetWireRes))
    let targetIsV6: bool = strings.StrContains(Value(targetWireRes).host, ":")
    let targetRes = tcp.TcpConnect(Value(targetWireRes).host, Value(targetWireRes).port, targetIsV6)
    if IsErr(targetRes):
        var emptyPadding: Bytes
        emptyPadding.data = nil
        emptyPadding.len = 0
        let _ = hy2sess.VpnProxyHy2TcpStreamWriteResponse(stream,
                                                            false,
                                                            ErrorText(targetRes),
                                                            emptyPadding)
        return Err[bool](ErrorText(targetRes))
    var targetConn = Value(targetRes)
    var emptyPadding: Bytes
    emptyPadding.data = nil
    emptyPadding.len = 0
    let okRes: Result[bool] = hy2sess.VpnProxyHy2TcpStreamWriteResponse(stream,
                                                                          true,
                                                                          "",
                                                                          emptyPadding)
    if IsErr(okRes):
        tcp.TcpClose(targetConn)
        return Err[bool](ErrorText(okRes))
    let relayRes = VpnProxyRelayTcpQuic(targetConn, stream)
    tcp.TcpClose(targetConn)
    hy2sess.VpnProxyHy2TcpStreamClose(stream)
    if IsErr(relayRes):
        return Err[bool](ErrorText(relayRes))
    return Ok[bool](true)

fn VpnProxyHandleExitUdpConnCore(listener: var qtransport.MsQuicTransport,
                                   conn: var qconn.Connection,
                                   firstMsg: Hysteria2UdpMessage,
                                   sockets: var VpnProxyUdpSocketPair): Result[bool] =
    var clientFrags: VpnProxyUdpFragState[]
    var exitPacketId: int32
    var pendingMsg: Hysteria2UdpMessage = firstMsg
    var hasPending: bool = true
    while true:
        var progressed: bool
        if hasPending:
            hasPending = false
            if pendingMsg.sessionId != VpnProxyHy2UdpSessionId:
                return Err[bool]("vpn proxy: udp session mismatch")
            var fullMsg: Hysteria2UdpMessage
            let fullRes: Result[bool] = VpnProxyUdpFragFeed(clientFrags, pendingMsg, fullMsg)
            if IsErr(fullRes):
                return Err[bool](ErrorText(fullRes))
            if Value(fullRes):
                let targetRes: Result[VpnProxyTarget] = VpnProxyTargetFromAddress(fullMsg.address)
                if IsErr(targetRes):
                    return Err[bool](ErrorText(targetRes))
                let targetIsV6: bool = strings.StrContains(Value(targetRes).host, ":")
                let socketRes: Result[udp.UdpSocketHandle] = VpnProxyUdpSocketPairEnsure(sockets, targetIsV6)
                if IsErr(socketRes):
                    return Err[bool](ErrorText(socketRes))
                let socket: udp.UdpSocketHandle = Value(socketRes)
                var targetAddr: udp.UdpSockAddr
                let literalRes: Result[bool] = VpnProxyUdpLiteralTarget(Value(targetRes), socket.family, targetAddr)
                if IsErr(literalRes):
                    return Err[bool]("vpn proxy: udp target host literal required")
                let sendRes: Result[bool] = VpnProxyUdpSocketSend(socket.fd, fullMsg.payload, targetAddr)
                if IsErr(sendRes):
                    return Err[bool](ErrorText(sendRes))
            progressed = true
        let remoteReadRes: Result[Bytes] = qtransport.msquicTransportDatagramRead(listener, conn)
        if IsErr(remoteReadRes):
            let err: str = ErrorText(remoteReadRes)
            if !VpnProxyWouldBlockQuic(err):
                if err == "msquic: pipe closed":
                    return Ok[bool](true)
                if err == "msquic: connection closed" ||
                   err == "connection: closed":
                    return Ok[bool](true)
                return Err[bool](err)
        else:
            let msgRes: Result[Hysteria2UdpMessage] = hy2.Hysteria2DecodeUdpMessage(Value(remoteReadRes))
            if IsErr(msgRes):
                return Err[bool](ErrorText(msgRes))
            pendingMsg = Value(msgRes)
            hasPending = true
            progressed = true
        if sockets.v4Open:
            var recv4: udp.UdpRecvResult
            let recvRes4: Result[bool] = udp.UdpRecvFromNonblock(sockets.v4.fd, VpnProxyUdpRelayChunkBytes, recv4)
            if IsErr(recvRes4):
                if !VpnProxyWouldBlockUdp(ErrorText(recvRes4)):
                    return Err[bool](ErrorText(recvRes4))
            else:
                let sourceTarget: VpnProxyTarget = VpnProxyUdpTargetFromSockAddr(recv4.fromAddr)
                let sourceText: str = VpnProxyTargetAddress(sourceTarget)
                let payloadLimitRes: Result[int32] = VpnProxyHy2UdpPayloadLimit(listener, sourceText)
                if IsErr(payloadLimitRes):
                    return Err[bool](ErrorText(payloadLimitRes))
                let packetId: int32 = VpnProxyUdpPacketNext(exitPacketId)
                let msg: Hysteria2UdpMessage = hy2.Hysteria2MakeUdpMessage(VpnProxyHy2UdpSessionId,
                                                                               packetId,
                                                                               0,
                                                                               1,
                                                                               sourceText,
                                                                               recv4.data)
                let fragmentsRes: Result[Hysteria2UdpMessage[]] = hy2.Hysteria2FragmentUdpMessage(msg,
                                                                                                       Value(payloadLimitRes))
                if IsErr(fragmentsRes):
                    return Err[bool](ErrorText(fragmentsRes))
                let fragments: Hysteria2UdpMessage[] = Value(fragmentsRes)
                for i in 0..<fragments.len:
                    let wireRes: Result[Bytes] = hy2.Hysteria2EncodeUdpMessage(fragments[i])
                    if IsErr(wireRes):
                        return Err[bool](ErrorText(wireRes))
                    let writeRes: Result[int32] = qtransport.msquicTransportDatagramWrite(listener,
                                                                                           conn,
                                                                                           Value(wireRes))
                    if IsErr(writeRes):
                        return Err[bool](ErrorText(writeRes))
                progressed = true
        if sockets.v6Open:
            var recv6: udp.UdpRecvResult
            let recvRes6: Result[bool] = udp.UdpRecvFromNonblock(sockets.v6.fd, VpnProxyUdpRelayChunkBytes, recv6)
            if IsErr(recvRes6):
                if !VpnProxyWouldBlockUdp(ErrorText(recvRes6)):
                    return Err[bool](ErrorText(recvRes6))
            else:
                let sourceTarget: VpnProxyTarget = VpnProxyUdpTargetFromSockAddr(recv6.fromAddr)
                let sourceText: str = VpnProxyTargetAddress(sourceTarget)
                let payloadLimitRes: Result[int32] = VpnProxyHy2UdpPayloadLimit(listener, sourceText)
                if IsErr(payloadLimitRes):
                    return Err[bool](ErrorText(payloadLimitRes))
                let packetId: int32 = VpnProxyUdpPacketNext(exitPacketId)
                let msg: Hysteria2UdpMessage = hy2.Hysteria2MakeUdpMessage(VpnProxyHy2UdpSessionId,
                                                                               packetId,
                                                                               0,
                                                                               1,
                                                                               sourceText,
                                                                               recv6.data)
                let fragmentsRes: Result[Hysteria2UdpMessage[]] = hy2.Hysteria2FragmentUdpMessage(msg,
                                                                                                       Value(payloadLimitRes))
                if IsErr(fragmentsRes):
                    return Err[bool](ErrorText(fragmentsRes))
                let fragments: Hysteria2UdpMessage[] = Value(fragmentsRes)
                for i in 0..<fragments.len:
                    let wireRes: Result[Bytes] = hy2.Hysteria2EncodeUdpMessage(fragments[i])
                    if IsErr(wireRes):
                        return Err[bool](ErrorText(wireRes))
                    let writeRes: Result[int32] = qtransport.msquicTransportDatagramWrite(listener,
                                                                                           conn,
                                                                                           Value(wireRes))
                    if IsErr(writeRes):
                        return Err[bool](ErrorText(writeRes))
                progressed = true
        if !progressed:
            os.SleepMs(VpnProxyUdpRelaySleepMs)
    return Ok[bool](true)

fn VpnProxyHandleExitUdpConn(listener: var qtransport.MsQuicTransport,
                               conn: var qconn.Connection,
                               firstMsg: Hysteria2UdpMessage): Result[bool] =
    var sockets: VpnProxyUdpSocketPair
    let relayRes: Result[bool] = VpnProxyHandleExitUdpConnCore(listener, conn, firstMsg, sockets)
    VpnProxyUdpSocketPairClose(sockets)
    return relayRes

fn VpnProxyHandleExitConn(listener: var qtransport.MsQuicTransport,
                            conn: var qconn.Connection,
                            serverCfg: VpnProxyIdentityConfig): Result[bool] =
    let selectRes = quic_transport.Libp2pQuicServerSelectProtocol(listener, conn, VpnProxyProtocolId())
    if IsErr(selectRes):
        return Err[bool](ErrorText(selectRes))
    let authRes: Result[bool] = VpnProxyHy2ServerAuth(conn, serverCfg)
    if IsErr(authRes):
        return Err[bool](ErrorText(authRes))
    let streamRes: Result[VpnProxyHy2TcpStream] = hy2sess.VpnProxyHy2OpenTcpStream(conn, VpnProxyHy2TcpStreamId)
    if IsErr(streamRes):
        return Err[bool](ErrorText(streamRes))
    var stream = Value(streamRes)
    var requestStreamClosed: bool
    while true:
        let datagramRes: Result[Bytes] = qtransport.msquicTransportDatagramRead(listener, conn)
        if IsErr(datagramRes):
            let err: str = ErrorText(datagramRes)
            if !VpnProxyWouldBlockQuic(err):
                if err == "msquic: connection closed" ||
                   err == "connection: closed":
                    return Ok[bool](true)
                return Err[bool](err)
        else:
            let msgRes: Result[Hysteria2UdpMessage] = hy2.Hysteria2DecodeUdpMessage(Value(datagramRes))
            if IsErr(msgRes):
                return Err[bool](ErrorText(msgRes))
            return VpnProxyHandleExitUdpConn(listener, conn, Value(msgRes))
        if !requestStreamClosed:
            var req: hy2.Hysteria2TcpRequest
            let reqRes: Result[bool] = hy2sess.VpnProxyHy2TcpStreamTryReadRequest(stream, req)
            if IsErr(reqRes):
                let err: str = ErrorText(reqRes)
                if err == "msquic: stream closed" ||
                   err == "msquic: pipe closed":
                    requestStreamClosed = true
                elif err == "connection: closed":
                    return Ok[bool](true)
                else:
                    return Err[bool](err)
            elif Value(reqRes):
                return VpnProxyHandleExitTcpStream(stream, req)
        os.SleepMs(VpnProxyUdpRelaySleepMs)
    return Ok[bool](true)

fn VpnProxyExit(rootDir: str, args: str[]): int32 =
    rootDir
    let opts: VpnProxyCliOptions = cli.VpnProxyOptions(args)
    let configRes: Result[VpnProxyConfig] = VpnProxyLoadConfig(opts.configPath)
    if IsErr(configRes):
        VpnProxyPrintErr(ErrorText(configRes))
        return 1
    let config = Value(configRes)
    let identityRes = VpnProxyLoadIdentity(config.configDir, config.server, true)
    if IsErr(identityRes):
        VpnProxyPrintErr(ErrorText(identityRes))
        return 1
    let identity = Value(identityRes)
    if !VpnProxyLoadedIdentityPresent(identity):
        VpnProxyPrintErr("vpn proxy: server identity incomplete")
        return 1
    let hy2CfgRes: Result[bool] = VpnProxyRequireServerHy2Config(config.server)
    if IsErr(hy2CfgRes):
        VpnProxyPrintErr(ErrorText(hy2CfgRes))
        return 1
    var listenHost = ""
    var listenPort: int32
    let listenText: str = strutil.Strip(config.server.listen)
    if len(listenText) <= 0:
        VpnProxyPrintErr("vpn proxy: empty listen address")
        return 1
    let listenParsedRes: Result[listen.VpnProxyListenAddress] = listen.VpnProxyParseListenAddress(listenText)
    if IsErr(listenParsedRes):
        VpnProxyPrintErr(ErrorText(listenParsedRes))
        return 1
    let listenParsed: listen.VpnProxyListenAddress = Value(listenParsedRes)
    listenHost = listenParsed.host
    listenPort = listenParsed.port
    let policyRes = VpnProxyBuildPolicy(identity, "vpn-proxy.exit")
    if IsErr(policyRes):
        VpnProxyPrintErr(ErrorText(policyRes))
        return 1
    let addrRes = quic_transport.Libp2pQuicAddrFromHostPort(listenHost, listenPort)
    if IsErr(addrRes):
        VpnProxyPrintErr(ErrorText(addrRes))
        return 1
    var listener = qtransport.InitMsQuicTransport()
    let tlsRes = qtransport.setMsQuicTransportTlsPolicy(listener, Value(policyRes))
    if IsErr(tlsRes):
        VpnProxyPrintErr(ErrorText(tlsRes))
        return 1
    qtransport.start(listener, Value(addrRes))
    if !listener.running:
        VpnProxyPrintErr(listener.lastError)
        return 1
    let boundPort: int32 = quic_transport.Libp2pQuicBoundPort(listener.listenAddr)
    if !VpnProxyWriteReadyPort(opts.readyPath, boundPort):
        VpnProxyPrintErr("vpn proxy: failed to write ready path")
        qtransport.Stop(listener)
        return 1
    VpnProxyPrintLine("vpn-proxy exit listening " + listenHost + ":" + intToStr(boundPort))
    var served: int32
    while opts.acceptCount <= 0 || served < opts.acceptCount:
        let acceptRes = qtransport.AcceptTimed(listener, 1000)
        if IsErr(acceptRes):
            let err: str = ErrorText(acceptRes)
            if err == "msquic: accept timeout" ||
               strutil.StartsWith(err, "msquic native: accept handshake ! ready") ||
               strutil.StartsWith(err, "msquic native: handshake ! ready") ||
               strutil.StartsWith(err, "msquic native: session ! ready") ||
               strutil.StartsWith(err, "msquic native: pipe read timeout"):
                continue
            VpnProxyPrintErr(err)
            qtransport.Stop(listener)
            return 1
        var conn = Value(acceptRes)
        let handleRes = VpnProxyHandleExitConn(listener, conn, config.server)
        qconn.ConnClose(conn)
        if IsErr(handleRes):
            VpnProxyPrintErr(ErrorText(handleRes))
        served = served + 1
    qtransport.Stop(listener)
    return 0

fn VpnProxyStatus(rootDir: str, args: str[]): int32 =
    rootDir
    let opts: VpnProxyCliOptions = cli.VpnProxyOptions(args)
    let configRes: Result[VpnProxyConfig] = VpnProxyLoadConfig(opts.configPath)
    if IsErr(configRes):
        VpnProxyPrintErr(ErrorText(configRes))
        return 1
    let config = Value(configRes)
    VpnProxyPrintLine("vpn-proxy status")
    if config.exits.len > 0:
        let identityRes = VpnProxyLoadIdentity(config.configDir, config.client, false)
        if IsErr(identityRes):
            VpnProxyPrintErr(ErrorText(identityRes))
            return 1
        let identity = Value(identityRes)
        var states: VpnProxyExitState[]
        states = routing.VpnProxyInitExitStates(config.exits)
        VpnProxyProbeAll(states, identity, opts.probeTimeoutMs)
        let bestIndex: int32 = routing.VpnProxyBestHealthyExit(states, -1)
        if len(config.client.listen) > 0:
            VpnProxyPrintLine("client.listen=" + config.client.listen)
        if bestIndex >= 0:
            VpnProxyPrintLine("best_exit=" + states[bestIndex].cfg.name)
        else:
            VpnProxyPrintLine("best_exit=")
        for i in 0..<states.len:
            let state: VpnProxyExitState = states[i]
            VpnProxyPrintLine("exit." + intToStr(i) + ".name=" + state.cfg.name)
            VpnProxyPrintLine("exit." + intToStr(i) + ".healthy=" + (state.healthy ? "true" : "false"))
            VpnProxyPrintLine("exit." + intToStr(i) + ".ewma_ms=" + int64ToStr(state.ewmaMs))
            VpnProxyPrintLine("exit." + intToStr(i) + ".last_error=" + state.lastError)
        return 0
    if len(config.server.listen) > 0:
        VpnProxyPrintLine("server.listen=" + config.server.listen)
        return 0
    VpnProxyPrintErr("vpn proxy status: config missing client exits or server.listen")
    return 1

fn VpnProxyMain(rootDir: str, args: str[]): int32 =
    if args.len <= 0:
        VpnProxyUsage()
        return 1
    let cmd: str = args[0]
    let rest: str[] = cli.VpnProxyCollectArgsFrom(args, 1)
    if cmd == "help" || cmd == "--help" || cmd == "-h":
        VpnProxyUsage()
        return 0
    if cmd == "local":
        return VpnProxyLocal(rootDir, rest)
    if cmd == "exit":
        return VpnProxyExit(rootDir, rest)
    if cmd == "status":
        return VpnProxyStatus(rootDir, rest)
    VpnProxyPrintErr("vpn proxy: unknown subcommand: " + cmd)
    VpnProxyUsage()
    return 1
