import std/cmdline as cmdline
import std/os
import std/strutils as strutil
import cheng/core/tooling/bootstrap_contracts as contracts
import cheng/core/tooling/host_ops as hostops
import cheng/core/tooling/path as chengpath

fn VpnProxyToolPrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn VpnProxyToolPrintErr(text: str) =
    os.WriteLine(os.Get_stderr(), text)

fn VpnProxyToolUsage() =
    VpnProxyToolPrintLine("usage: cheng vpn-proxy <local|exit|status> --config:<path>")
    VpnProxyToolPrintLine("local flags: --ready-path:<path> --accept-count:<n> --probe-interval-ms:<n> --probe-timeout-ms:<n>")
    VpnProxyToolPrintLine("exit flags: --ready-path:<path> --accept-count:<n>")
    VpnProxyToolPrintLine("status flags: --probe-timeout-ms:<n>")

fn VpnProxyToolRoot(): str =
    let envRoot: str = os.GetEnv("CHENG_ROOT")
    if len(envRoot) > 0:
        return envRoot
    return os.GetCurrentDir()

fn VpnProxyToolCollectArgsFrom(startIndex: int32,
                                 count: int32): str[] =
    var out: str[]
    if startIndex > count:
        return out
    for i in startIndex..count:
        let arg: str = cmdline.ParamStr(i)
        if len(arg) > 0:
            add(out, arg)
    return out

fn VpnProxyToolHostTarget(): str =
    let detected: str = contracts.BootstrapDetectHostTarget()
    if len(detected) > 0:
        return detected
    return contracts.BootstrapDefaultTarget()

fn VpnProxyToolCompiler(rootDir: str): str =
    let envCompilerRaw: str = os.GetEnvDefault("CHENG_VPN_PROXY_COMPILER", "")
    let envCompiler: str = strutil.Strip(envCompilerRaw)
    if len(envCompiler) > 0:
        return chengpath.PathAbsolute(rootDir, envCompiler)
    let backendDriver: str = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver/cheng")
    if chengpath.FileExistsNonEmpty(rootDir, backendDriver):
        return backendDriver
    let stage3Path: str = chengpath.PathAbsolute(rootDir, "artifacts/bootstrap/cheng.stage3")
    if chengpath.FileExistsNonEmpty(rootDir, stage3Path):
        return stage3Path
    return ""

fn VpnProxyToolRunFailed(context: str,
                           run: hostops.LoggedRun): bool =
    if run.exitCode == 0:
        return false
    VpnProxyToolPrintErr(context + " rc=" + intToStr(run.exitCode) + " log=" + run.logPath)
    let outputText: str = strutil.Strip(run.output)
    if len(outputText) > 0:
        VpnProxyToolPrintErr(outputText)
    return true

fn VpnProxyToolRunRuntime(rootDir: str,
                            args: str[]): int32 =
    let compilerPath: str = VpnProxyToolCompiler(rootDir)
    if len(compilerPath) <= 0:
        VpnProxyToolPrintErr("vpn proxy: missing compiler path")
        return 1
    let outDir: str = chengpath.PathAbsolute(rootDir, "artifacts/backend_driver_tools/vpn_proxy_runtime_tool")
    if !chengpath.MkdirP(rootDir, outDir):
        VpnProxyToolPrintErr("vpn proxy: failed to create runtime tool dir")
        return 1
    let outBin: str = os.JoinPath(outDir, "vpn_proxy_runtime_tool")
    let reportPath: str = os.JoinPath(outDir, "vpn_proxy_runtime_tool.report.txt")
    let compileLogPath: str = os.JoinPath(outDir, "vpn_proxy_runtime_tool.compile.log")
    let runLogPath: str = os.JoinPath(outDir, "vpn_proxy_runtime_tool.run.log")
    let sourcePath: str = chengpath.PathAbsolute(rootDir, "src/apps/vpn_proxy/vpn_proxy_runtime_tool_main.cheng")
    let packageRoot: str = rootDir
    let compileArgs: str[] = [
        "system-link-exec",
        "--root:" + packageRoot,
        "--in:" + sourcePath,
        "--emit:exe",
        "--target:" + VpnProxyToolHostTarget(),
        "--out:" + outBin,
        "--report-out:" + reportPath
    ]
    let compileRun: hostops.LoggedRun = hostops.RunFileLogged(rootDir,
                                                                  "vpn_proxy_runtime_tool_compile",
                                                                  compilerPath,
                                                                  compileArgs,
                                                                  [],
                                                                  rootDir,
                                                                  300,
                                                                  compileLogPath)
    if VpnProxyToolRunFailed("vpn proxy: runtime tool compile", compileRun):
        return compileRun.exitCode
    if !chengpath.FileExistsNonEmpty(rootDir, outBin):
        VpnProxyToolPrintErr("vpn proxy: runtime tool output missing: " + outBin)
        return 1
    let run: hostops.LoggedRun = hostops.RunFileLogged(rootDir,
                                                           "vpn_proxy_runtime_tool_run",
                                                           outBin,
                                                           args,
                                                           [],
                                                           rootDir,
                                                           0,
                                                           runLogPath)
    let outputText: str = strutil.Strip(run.output)
    if len(outputText) > 0:
        if run.exitCode == 0:
            VpnProxyToolPrintLine(outputText)
        else:
            VpnProxyToolPrintErr(outputText)
    return run.exitCode

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.CaptureCmdLine(argc, argv)
    let rootDir: str = VpnProxyToolRoot()
    let count: int32 = cmdline.ParamCount()
    let args: str[] = VpnProxyToolCollectArgsFrom(1, count)
    if args.len <= 0:
        VpnProxyToolUsage()
        return 1
    let cmd: str = args[0]
    if cmd == "help" || cmd == "--help" || cmd == "-h":
        VpnProxyToolUsage()
        return 0
    if cmd == "local" || cmd == "exit" || cmd == "status":
        return VpnProxyToolRunRuntime(rootDir, args)
    VpnProxyToolPrintErr("vpn proxy: unknown subcommand: " + cmd)
    VpnProxyToolUsage()
    return 1
