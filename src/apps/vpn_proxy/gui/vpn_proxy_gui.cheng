import std/monotimes
import std/os
import std/os_host_process as hostos
import std/rawbytes
import std/result
import std/strings
import std/strutils as strutil
import std/net/transports/tcp_syscall as tcp
import cheng/core/tooling/path as v3path
import cheng/apps/vpn_proxy/vpn_proxy_cli as cli
import cheng/apps/vpn_proxy/vpn_proxy_config as config

type
    V3VpnProxyGuiFieldId = enum
        v3VpnGuiFieldConfigPath
        v3VpnGuiFieldListen
        v3VpnGuiFieldCertDer
        v3VpnGuiFieldKeyPk8Der
        v3VpnGuiFieldTrustRootDer
        v3VpnGuiFieldExitName
        v3VpnGuiFieldExitHost
        v3VpnGuiFieldExitPort
        v3VpnGuiFieldServerName
        v3VpnGuiFieldAuthority
        v3VpnGuiFieldAuth
        v3VpnGuiFieldCcRx

    V3VpnProxyGuiProc =
        running: bool
        pid: int64
        readFd: int32
        exitCode: int32
        stopRequested: bool
        stopRequestedAtMs: int64

    V3VpnProxyGuiState =
        rootDir: str
        title: str
        runtimeToolPath: str
        defaultConfigPath: str
        fields: str[]
        noticeText: str
        errorText: str
        statusText: str
        logText: str
        logVersion: int32
        proc: V3VpnProxyGuiProc
        quitRequested: bool

var v3VpnGuiGlobalState: V3VpnProxyGuiState

var v3VpnGuiGlobalListener: tcp.TcpListenerHandle

const
    v3VpnGuiFieldCount = 12
    v3VpnGuiSigTerm = 15
    v3VpnGuiSigKill = 9
    v3VpnGuiStopGraceMs = 1500
    v3VpnGuiMaxLogChars = 16000
    v3VpnGuiHttpMaxChars = 65536
    v3VpnGuiListenHost = "127.0.0.1"
    v3VpnGuiWebPort = 18443
    v3VpnGuiWaitMs = 200

fn v3VpnGuiPrintLine(text: str) =
    os.WriteLine(os.Get_stdout(), text)

fn v3VpnGuiMonoNowMs(): int64 =
    return monotimes.MonoTimeNs(monotimes.GetMonoTime()) / 1000000

fn v3VpnGuiFieldLabel(id: V3VpnProxyGuiFieldId): str =
    if id == v3VpnGuiFieldConfigPath:
        return "CONFIG PATH"
    if id == v3VpnGuiFieldListen:
        return "SOCKS LISTEN"
    if id == v3VpnGuiFieldCertDer:
        return "CLIENT CERT"
    if id == v3VpnGuiFieldKeyPk8Der:
        return "CLIENT KEY"
    if id == v3VpnGuiFieldTrustRootDer:
        return "TRUST ROOT"
    if id == v3VpnGuiFieldExitName:
        return "EXIT NAME"
    if id == v3VpnGuiFieldExitHost:
        return "EXIT HOST"
    if id == v3VpnGuiFieldExitPort:
        return "EXIT PORT"
    if id == v3VpnGuiFieldServerName:
        return "SERVER NAME"
    if id == v3VpnGuiFieldAuthority:
        return "AUTHORITY"
    if id == v3VpnGuiFieldAuth:
        return "AUTH TOKEN"
    return "CC RX"

fn v3VpnGuiDefaultRuntimeToolPath(rootDir: str): str =
    return v3path.V3PathAbsolute(rootDir, "artifacts/backend_driver_tools/vpn_proxy_runtime_tool/vpn_proxy_runtime_tool")

fn v3VpnGuiDefaultConfigPath(rootDir: str): str =
    let preferred: str = v3path.V3PathAbsolute(rootDir, "artifacts/hysteria2_deploy/local.json")
    if v3path.V3PathFileExists(preferred):
        return preferred
    return v3path.V3PathAbsolute(rootDir, "artifacts/hysteria2_gui/local.json")

fn v3VpnGuiAppendLog(state: var V3VpnProxyGuiState,
                     textRaw: str) =
    let text: str = textRaw
    if len(text) <= 0:
        return
    state.logText = state.logText + text
    let total: int32 = len(state.logText)
    if total > v3VpnGuiMaxLogChars:
        state.logText = v3path.V3TextSlice(state.logText, total - v3VpnGuiMaxLogChars, v3VpnGuiMaxLogChars)
    state.logVersion = state.logVersion + 1

fn v3VpnGuiOwnText(raw: str): str =
    return strutil.Strip(raw)

fn v3VpnGuiJsonQuote(raw: str): str =
    var out: str = "\""
    for i in 0..<len(raw):
        let ch = raw[i]
        if ch == '\\':
            out = out + "\\\\"
        elif ch == '"':
            out = out + "\\\""
        elif ch == '\n':
            out = out + "\\n"
        elif ch == '\r':
            out = out + "\\r"
        elif ch == '\t':
            out = out + "\\t"
        else:
            out = out + strings.CharToStr(ch)
    out = out + "\""
    return out

fn v3VpnGuiParseInt32Field(raw: str): Result[int32] =
    return cli.V3VpnProxyParseInt32(raw)

fn v3VpnGuiFieldsEnsureLen(fields: var str[]) =
    if fields.len >= v3VpnGuiFieldCount:
        return
    let missing: int32 = v3VpnGuiFieldCount - fields.len
    for i in 0..<missing:
        add(fields, "")

fn v3VpnGuiFieldGet(state: V3VpnProxyGuiState,
                    id: V3VpnProxyGuiFieldId): str =
    let idx: int32 = int32(id)
    if idx < 0 || idx >= state.fields.len:
        return ""
    return state.fields[idx]

fn v3VpnGuiFieldSet(state: var V3VpnProxyGuiState,
                    id: V3VpnProxyGuiFieldId,
                    value: str) =
    v3VpnGuiFieldsEnsureLen(state.fields)
    let idx: int32 = int32(id)
    if idx < 0 || idx >= state.fields.len:
        return
    state.fields[idx] = value

fn v3VpnGuiDefaultFieldValues(rootDir: str,
                              configPath: str): str[] =
    var out: str[]
    v3VpnGuiFieldsEnsureLen(out)
    out[int32(v3VpnGuiFieldConfigPath)] = configPath
    out[int32(v3VpnGuiFieldListen)] = "127.0.0.1:1086"
    rootDir
    out[int32(v3VpnGuiFieldCertDer)] = "certs/client.der"
    out[int32(v3VpnGuiFieldKeyPk8Der)] = "certs/client.key.pk8.der"
    out[int32(v3VpnGuiFieldTrustRootDer)] = "certs/ca.der"
    out[int32(v3VpnGuiFieldExitName)] = "v64"
    out[int32(v3VpnGuiFieldExitHost)] = "64.176.84.12"
    out[int32(v3VpnGuiFieldExitPort)] = "7443"
    out[int32(v3VpnGuiFieldServerName)] = "server.cheng-quic.internal"
    out[int32(v3VpnGuiFieldAuthority)] = "cheng-quic.internal"
    out[int32(v3VpnGuiFieldAuth)] = ""
    out[int32(v3VpnGuiFieldCcRx)] = "65535"
    return out

fn v3VpnGuiApplyLoadedConfig(state: var V3VpnProxyGuiState,
                             cfg: config.V3VpnProxyConfig) =
    v3VpnGuiFieldSet(state, v3VpnGuiFieldConfigPath, cfg.configPath)
    v3VpnGuiFieldSet(state, v3VpnGuiFieldListen, cfg.client.listen)
    v3VpnGuiFieldSet(state, v3VpnGuiFieldCertDer, cfg.client.certDer)
    v3VpnGuiFieldSet(state, v3VpnGuiFieldKeyPk8Der, cfg.client.keyPk8Der)
    v3VpnGuiFieldSet(state, v3VpnGuiFieldTrustRootDer, cfg.client.trustRootDer)
    if cfg.exits.len > 0:
        let exitCfg: config.V3VpnProxyExitConfig = cfg.exits[0]
        v3VpnGuiFieldSet(state, v3VpnGuiFieldExitName, exitCfg.name)
        v3VpnGuiFieldSet(state, v3VpnGuiFieldExitHost, exitCfg.host)
        v3VpnGuiFieldSet(state, v3VpnGuiFieldExitPort, intToStr(exitCfg.port))
        v3VpnGuiFieldSet(state, v3VpnGuiFieldServerName, exitCfg.serverName)
        v3VpnGuiFieldSet(state, v3VpnGuiFieldAuthority, exitCfg.authority)
        v3VpnGuiFieldSet(state, v3VpnGuiFieldAuth, exitCfg.auth)
        v3VpnGuiFieldSet(state, v3VpnGuiFieldCcRx, intToStr(exitCfg.ccRx))

fn v3VpnGuiLoadConfigIntoState(state: var V3VpnProxyGuiState): bool =
    let configPath: str = v3VpnGuiFieldGet(state, v3VpnGuiFieldConfigPath)
    if !v3path.V3PathFileExists(configPath):
        state.noticeText = "new config"
        state.errorText = ""
        return false
    let loadRes: Result[config.V3VpnProxyConfig] = config.V3VpnProxyLoadConfig(configPath)
    if IsErr(loadRes):
        state.errorText = ErrorText(loadRes)
        state.noticeText = ""
        return false
    v3VpnGuiApplyLoadedConfig(state, Value(loadRes))
    state.noticeText = "loaded"
    state.errorText = ""
    return true

fn v3VpnGuiStateInit(rootDir: str,
                     runtimeToolPathRaw: str,
                     configPathRaw: str): V3VpnProxyGuiState =
    var out: V3VpnProxyGuiState
    out.rootDir = rootDir
    out.title = "Cheng VPN GUI"
    if len(runtimeToolPathRaw) > 0:
        out.runtimeToolPath = v3path.V3PathAbsolute(rootDir, runtimeToolPathRaw)
    else:
        out.runtimeToolPath = v3VpnGuiDefaultRuntimeToolPath(rootDir)
    if len(configPathRaw) > 0:
        out.defaultConfigPath = v3path.V3PathAbsolute(rootDir, configPathRaw)
    else:
        out.defaultConfigPath = v3VpnGuiDefaultConfigPath(rootDir)
    out.fields = v3VpnGuiDefaultFieldValues(rootDir, out.defaultConfigPath)
    out.noticeText = "edit fields, save config, start local proxy"
    out.errorText = ""
    out.statusText = "idle"
    out.logText = ""
    out.logVersion = 0
    out.proc.running = false
    out.proc.pid = int64(-1)
    out.proc.readFd = -1
    out.proc.exitCode = -1
    out.proc.stopRequested = false
    out.proc.stopRequestedAtMs = int64(0)
    out.quitRequested = false
    let _ = v3VpnGuiLoadConfigIntoState(out)
    return out

fn v3VpnGuiInitGlobalState(rootDir: str,
                           runtimeToolPathRaw: str,
                           configPathRaw: str) =
    v3VpnGuiGlobalState.rootDir = rootDir
    v3VpnGuiGlobalState.title = "Cheng VPN GUI"
    if len(runtimeToolPathRaw) > 0:
        v3VpnGuiGlobalState.runtimeToolPath = v3path.V3PathAbsolute(rootDir, runtimeToolPathRaw)
    else:
        v3VpnGuiGlobalState.runtimeToolPath = v3VpnGuiDefaultRuntimeToolPath(rootDir)
    if len(configPathRaw) > 0:
        v3VpnGuiGlobalState.defaultConfigPath = v3path.V3PathAbsolute(rootDir, configPathRaw)
    else:
        v3VpnGuiGlobalState.defaultConfigPath = v3VpnGuiDefaultConfigPath(rootDir)
    v3VpnGuiGlobalState.fields = v3VpnGuiDefaultFieldValues(rootDir, v3VpnGuiGlobalState.defaultConfigPath)
    v3VpnGuiGlobalState.noticeText = "edit fields, save config, start local proxy"
    v3VpnGuiGlobalState.errorText = ""
    v3VpnGuiGlobalState.statusText = "idle"
    v3VpnGuiGlobalState.logText = ""
    v3VpnGuiGlobalState.logVersion = 0
    v3VpnGuiGlobalState.proc.running = false
    v3VpnGuiGlobalState.proc.pid = int64(-1)
    v3VpnGuiGlobalState.proc.readFd = -1
    v3VpnGuiGlobalState.proc.exitCode = -1
    v3VpnGuiGlobalState.proc.stopRequested = false
    v3VpnGuiGlobalState.proc.stopRequestedAtMs = int64(0)
    v3VpnGuiGlobalState.quitRequested = false
    let _ = v3VpnGuiLoadConfigIntoState(v3VpnGuiGlobalState)

fn V3VpnProxyGuiBuildConfigText(state: V3VpnProxyGuiState): Result[str] =
    let portRes: Result[int32] = v3VpnGuiParseInt32Field(v3VpnGuiFieldGet(state, v3VpnGuiFieldExitPort))
    if IsErr(portRes):
        return Err[str]("vpn gui: invalid exit port")
    let ccRxRes: Result[int32] = v3VpnGuiParseInt32Field(v3VpnGuiFieldGet(state, v3VpnGuiFieldCcRx))
    if IsErr(ccRxRes):
        return Err[str]("vpn gui: invalid cc_rx")
    let listen: str = v3VpnGuiOwnText(v3VpnGuiFieldGet(state, v3VpnGuiFieldListen))
    let certDer: str = v3VpnGuiOwnText(v3VpnGuiFieldGet(state, v3VpnGuiFieldCertDer))
    let keyPk8Der: str = v3VpnGuiOwnText(v3VpnGuiFieldGet(state, v3VpnGuiFieldKeyPk8Der))
    let trustRootDer: str = v3VpnGuiOwnText(v3VpnGuiFieldGet(state, v3VpnGuiFieldTrustRootDer))
    let exitName: str = v3VpnGuiOwnText(v3VpnGuiFieldGet(state, v3VpnGuiFieldExitName))
    let exitHost: str = v3VpnGuiOwnText(v3VpnGuiFieldGet(state, v3VpnGuiFieldExitHost))
    let serverName: str = v3VpnGuiOwnText(v3VpnGuiFieldGet(state, v3VpnGuiFieldServerName))
    if len(listen) <= 0 || len(certDer) <= 0 || len(keyPk8Der) <= 0 || len(trustRootDer) <= 0:
        return Err[str]("vpn gui: client fields must be non-empty")
    if len(exitName) <= 0 || len(exitHost) <= 0 || len(serverName) <= 0:
        return Err[str]("vpn gui: exit fields must be non-empty")
    var text: str = "{\n"
    text = text + "  \"client\": {\n"
    text = text + "    \"listen\": " + v3VpnGuiJsonQuote(listen) + ",\n"
    text = text + "    \"cert_der\": " + v3VpnGuiJsonQuote(certDer) + ",\n"
    text = text + "    \"key_pk8_der\": " + v3VpnGuiJsonQuote(keyPk8Der) + ",\n"
    text = text + "    \"trust_root_der\": " + v3VpnGuiJsonQuote(trustRootDer) + "\n"
    text = text + "  },\n"
    text = text + "  \"exits\": [\n"
    text = text + "    {\n"
    text = text + "      \"name\": " + v3VpnGuiJsonQuote(exitName) + ",\n"
    text = text + "      \"host\": " + v3VpnGuiJsonQuote(exitHost) + ",\n"
    text = text + "      \"port\": " + intToStr(Value(portRes)) + ",\n"
    text = text + "      \"server_name\": " + v3VpnGuiJsonQuote(serverName) + ",\n"
    text = text + "      \"authority\": " + v3VpnGuiJsonQuote(v3VpnGuiFieldGet(state, v3VpnGuiFieldAuthority)) + ",\n"
    text = text + "      \"auth\": " + v3VpnGuiJsonQuote(v3VpnGuiFieldGet(state, v3VpnGuiFieldAuth)) + ",\n"
    text = text + "      \"cc_rx\": " + intToStr(Value(ccRxRes)) + "\n"
    text = text + "    }\n"
    text = text + "  ]\n"
    text = text + "}\n"
    let parseRes: Result[config.V3VpnProxyConfig] = config.V3VpnProxyParseConfigTextForTest(text)
    if IsErr(parseRes):
        return Err[str](ErrorText(parseRes))
    return Ok[str](text)

fn V3VpnProxyGuiSaveConfig(state: var V3VpnProxyGuiState): bool =
    let configPath: str = v3VpnGuiFieldGet(state, v3VpnGuiFieldConfigPath)
    if len(configPath) <= 0:
        state.errorText = "vpn gui: config path is empty"
        state.noticeText = ""
        return false
    let buildRes: Result[str] = V3VpnProxyGuiBuildConfigText(state)
    if IsErr(buildRes):
        state.errorText = ErrorText(buildRes)
        state.noticeText = ""
        return false
    if !v3path.V3WriteTextFile("", configPath, Value(buildRes)):
        state.errorText = "vpn gui: failed to write config"
        state.noticeText = ""
        return false
    state.noticeText = "saved"
    state.errorText = ""
    return true

fn v3VpnGuiProcReset(state: var V3VpnProxyGuiState) =
    if state.proc.readFd >= 0:
        hostos.PtyClose(state.proc.readFd)
    state.proc.running = false
    state.proc.pid = int64(-1)
    state.proc.readFd = -1
    state.proc.stopRequested = false
    state.proc.stopRequestedAtMs = int64(0)

fn v3VpnGuiProcPoll(state: var V3VpnProxyGuiState) =
    if !state.proc.running:
        return
    if state.proc.readFd >= 0:
        let readRes: os.TextReadResult = hostos.FdReadWait(state.proc.readFd, 65536, 0)
        if len(readRes.text) > 0:
            v3VpnGuiAppendLog(state, readRes.text)
        if readRes.eof:
            hostos.PtyClose(state.proc.readFd)
            state.proc.readFd = -1
    let waitRes: os.PtyWaitResult = hostos.PtyWait(state.proc.pid)
    if waitRes.waitStatus == 1:
        let exitCode: int32 = waitRes.exitCode
        v3VpnGuiProcReset(state)
        state.proc.exitCode = exitCode
        state.statusText = "process exited rc=" + intToStr(exitCode)
        state.noticeText = state.statusText
        state.errorText = ""
        return
    if state.proc.stopRequested:
        let nowMs: int64 = v3VpnGuiMonoNowMs()
        if nowMs - state.proc.stopRequestedAtMs >= int64(v3VpnGuiStopGraceMs):
            let _ = hostos.ProcessSignal(state.proc.pid, v3VpnGuiSigKill)
            state.proc.stopRequestedAtMs = nowMs + int64(86400000)

fn V3VpnProxyGuiStartLocal(state: var V3VpnProxyGuiState): bool =
    if state.proc.running:
        state.noticeText = "proxy already running"
        state.errorText = ""
        return true
    if !V3VpnProxyGuiSaveConfig(state):
        return false
    if !v3path.V3FileExistsNonEmpty(state.rootDir, state.runtimeToolPath):
        state.errorText = "vpn gui: runtime tool missing"
        state.noticeText = ""
        return false
    let spawnRes: os.ExecFilePipeSpawnResult = hostos.ExecFilePipeSpawn(state.runtimeToolPath,
                                                                        ["local", "--config:" + v3VpnGuiFieldGet(state, v3VpnGuiFieldConfigPath)],
                                                                        [],
                                                                        state.rootDir)
    if !spawnRes.ok || spawnRes.pid <= 0 || spawnRes.readFd < 0:
        state.errorText = "vpn gui: failed to spawn local runtime"
        state.noticeText = ""
        return false
    if spawnRes.writeFd >= 0:
        hostos.PtyClose(spawnRes.writeFd)
    state.proc.running = true
    state.proc.pid = spawnRes.pid
    state.proc.readFd = spawnRes.readFd
    state.proc.exitCode = -1
    state.proc.stopRequested = false
    state.proc.stopRequestedAtMs = int64(0)
    state.statusText = "running pid=" + intToStr(int32(spawnRes.pid))
    state.noticeText = state.statusText
    state.errorText = ""
    return true

fn V3VpnProxyGuiStopLocal(state: var V3VpnProxyGuiState): bool =
    if !state.proc.running || state.proc.pid <= 0:
        state.noticeText = "proxy already stopped"
        state.errorText = ""
        return true
    let ok: bool = hostos.ProcessSignal(state.proc.pid, v3VpnGuiSigTerm)
    state.proc.stopRequested = true
    state.proc.stopRequestedAtMs = v3VpnGuiMonoNowMs()
    if ok:
        state.noticeText = "stop requested"
        state.errorText = ""
    else:
        state.errorText = "vpn gui: stop signal failed"
        state.noticeText = ""
    return ok

fn V3VpnProxyGuiReload(state: var V3VpnProxyGuiState): bool =
    let ok: bool = v3VpnGuiLoadConfigIntoState(state)
    if ok:
        state.statusText = "config reloaded"
    return ok

fn V3VpnProxyGuiStateForTest(rootDir: str,
                             runtimeToolPathRaw: str,
                             configPathRaw: str): V3VpnProxyGuiState =
    return v3VpnGuiStateInit(rootDir, runtimeToolPathRaw, configPathRaw)

fn v3VpnGuiHtmlEscape(raw: str): str =
    var out = ""
    for i in 0..<len(raw):
        let ch = raw[i]
        if ch == '&':
            out = out + "&amp;"
        elif ch == '<':
            out = out + "&lt;"
        elif ch == '>':
            out = out + "&gt;"
        elif ch == '"':
            out = out + "&quot;"
        elif ch == '\'':
            out = out + "&#39;"
        else:
            out = out + strings.CharToStr(ch)
    return out

fn v3VpnGuiFindChar(text: str,
                    want: char,
                    startAt: int32): int32 =
    var i: int32 = startAt
    if i < 0:
        i = 0
    while i < len(text):
        if text[i] == want:
            return i
        i = i + 1
    return -1

fn v3VpnGuiFindSub(text: str,
                   sub: str): int32 =
    if len(sub) <= 0:
        return 0
    if len(text) < len(sub):
        return -1
    for i in 0..<(len(text) - len(sub) + 1):
        var matched = true
        for j in 0..<len(sub):
            if text[i + j] != sub[j]:
                matched = false
                break
        if matched:
            return i
    return -1

fn v3VpnGuiHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn v3VpnGuiUrlDecode(raw: str): str =
    var out = ""
    var i: int32
    while i < len(raw):
        let ch = raw[i]
        if ch == '+':
            out = out + " "
        elif ch == '%' && i + 2 < len(raw):
            let hi: int32 = v3VpnGuiHexValue(raw[i + 1])
            let lo: int32 = v3VpnGuiHexValue(raw[i + 2])
            if hi >= 0 && lo >= 0:
                out = out + strings.CharToStr(char(hi * 16 + lo))
                i = i + 2
            else:
                out = out + strings.CharToStr(ch)
        else:
            out = out + strings.CharToStr(ch)
        i = i + 1
    return out

fn v3VpnGuiApplyQueryField(state: var V3VpnProxyGuiState,
                           key: str,
                           value: str) =
    if key == "config_path":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldConfigPath, value)
        return
    if key == "listen":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldListen, value)
        return
    if key == "cert_der":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldCertDer, value)
        return
    if key == "key_pk8_der":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldKeyPk8Der, value)
        return
    if key == "trust_root_der":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldTrustRootDer, value)
        return
    if key == "exit_name":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldExitName, value)
        return
    if key == "exit_host":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldExitHost, value)
        return
    if key == "exit_port":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldExitPort, value)
        return
    if key == "server_name":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldServerName, value)
        return
    if key == "authority":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldAuthority, value)
        return
    if key == "auth":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldAuth, value)
        return
    if key == "cc_rx":
        v3VpnGuiFieldSet(state, v3VpnGuiFieldCcRx, value)

fn v3VpnGuiApplyQueryString(state: var V3VpnProxyGuiState,
                            query: str) =
    if len(query) <= 0:
        return
    let pairs: str[] = strutil.Split(query, '&')
    for i in 0..<pairs.len:
        let item: str = pairs[i]
        if len(item) <= 0:
            continue
        let eq: int32 = v3VpnGuiFindChar(item, '=', 0)
        var keyRaw = item
        var valueRaw = ""
        if eq >= 0:
            keyRaw = strings.SliceBytes(item, 0, eq)
            valueRaw = strings.SliceBytes(item, eq + 1, len(item) - (eq + 1))
        let key: str = v3VpnGuiUrlDecode(keyRaw)
        let value: str = v3VpnGuiUrlDecode(valueRaw)
        v3VpnGuiApplyQueryField(state, key, value)

fn v3VpnGuiStatusBadgeClass(state: V3VpnProxyGuiState): str =
    if state.proc.running:
        return "ok"
    if len(state.errorText) > 0:
        return "err"
    return "idle"

fn v3VpnGuiProcessSummary(state: V3VpnProxyGuiState): str =
    if state.proc.running:
        return "running pid=" + intToStr(int32(state.proc.pid))
    if state.proc.exitCode >= 0:
        return "stopped rc=" + intToStr(state.proc.exitCode)
    return "stopped"

fn V3VpnProxyGuiStatusJsonForTest(state: V3VpnProxyGuiState,
                                  port: int32,
                                  url: str): str =
    var out = "{"
    out = out + "\"running\":"
    if state.proc.running:
        out = out + "true"
    else:
        out = out + "false"
    out = out + ",\"pid\":" + intToStr(int32(state.proc.pid))
    out = out + ",\"listen_url\":" + v3VpnGuiJsonQuote(url)
    out = out + ",\"web_port\":" + intToStr(port)
    out = out + ",\"config_path\":" + v3VpnGuiJsonQuote(v3VpnGuiFieldGet(state, v3VpnGuiFieldConfigPath))
    out = out + ",\"socks_listen\":" + v3VpnGuiJsonQuote(v3VpnGuiFieldGet(state, v3VpnGuiFieldListen))
    out = out + ",\"status\":" + v3VpnGuiJsonQuote(v3VpnGuiProcessSummary(state))
    out = out + ",\"notice\":" + v3VpnGuiJsonQuote(state.noticeText)
    out = out + ",\"error\":" + v3VpnGuiJsonQuote(state.errorText)
    out = out + "}"
    return out

fn v3VpnGuiAppendInput(out: var str,
                       label: str,
                       name: str,
                       value: str,
                       hint: str = "") =
    out = out + "<label class='field'>"
    out = out + "<span>" + v3VpnGuiHtmlEscape(label) + "</span>"
    out = out + "<input name='" + v3VpnGuiHtmlEscape(name) + "' value=\"" + v3VpnGuiHtmlEscape(value) + "\""
    if len(hint) > 0:
        out = out + " placeholder=\"" + v3VpnGuiHtmlEscape(hint) + "\""
    out = out + " />"
    out = out + "</label>"

fn V3VpnProxyGuiHtmlForTest(state: V3VpnProxyGuiState,
                            port: int32,
                            url: str): str =
    var out: str
    out = out + "<!doctype html><html><head><meta charset='utf-8'>"
    if state.proc.running:
        out = out + "<meta http-equiv='refresh' content='2'>"
    out = out + "<title>Cheng VPN GUI</title>"
    out = out + "<style>"
    out = out + "body{margin:0;background:linear-gradient(180deg,#eef5ff,#f8fbff);font-family:ui-sans-serif,-apple-system,BlinkMacSystemFont,'SF Pro Display','PingFang SC',sans-serif;color:#122033;}"
    out = out + ".shell{max-width:1080px;margin:0 auto;padding:28px 20px 36px;}"
    out = out + ".hero,.card{background:rgba(255,255,255,0.92);backdrop-filter:blur(10px);border:1px solid rgba(18,32,51,0.08);border-radius:20px;box-shadow:0 18px 50px rgba(23,55,94,0.08);}"
    out = out + ".hero{padding:24px 24px 18px;margin-bottom:18px;}"
    out = out + "h1{margin:0;font-size:28px;letter-spacing:-0.03em;}"
    out = out + ".sub{margin:10px 0 0;color:#58718d;font-size:14px;}"
    out = out + ".badges{display:flex;flex-wrap:wrap;gap:10px;margin-top:16px;}"
    out = out + ".badge{display:inline-flex;align-items:center;padding:8px 12px;border-radius:999px;font-size:13px;font-weight:600;}"
    out = out + ".badge.ok{background:#e8fff2;color:#0e6b3b;}"
    out = out + ".badge.err{background:#fff1f1;color:#9f2330;}"
    out = out + ".badge.idle{background:#eef3f8;color:#39516d;}"
    out = out + ".grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px;}"
    out = out + ".card{padding:20px;}"
    out = out + ".field{display:flex;flex-direction:column;gap:8px;margin-bottom:12px;}"
    out = out + ".field span{font-size:12px;font-weight:700;color:#4b6480;letter-spacing:0.05em;}"
    out = out + ".field input{height:42px;border:1px solid #d5e1ee;border-radius:12px;padding:0 14px;font-size:14px;background:#fbfdff;color:#102133;}"
    out = out + ".row{display:flex;flex-wrap:wrap;gap:10px;margin-top:8px;}"
    out = out + "button{height:42px;padding:0 16px;border:none;border-radius:12px;background:#0f6fff;color:white;font-weight:700;cursor:pointer;}"
    out = out + "button.secondary{background:#16324f;}"
    out = out + "button.ghost{background:#e9f1f9;color:#15314f;}"
    out = out + ".meta{font-size:13px;color:#5a738f;line-height:1.6;}"
    out = out + ".meta code{padding:2px 6px;border-radius:8px;background:#edf3fa;color:#19324b;}"
    out = out + "pre{margin:0;min-height:240px;max-height:420px;overflow:auto;padding:16px;border-radius:16px;background:#0d1723;color:#d7e5f6;font-size:12px;line-height:1.55;}"
    out = out + "@media(max-width:900px){.grid{grid-template-columns:1fr;}.shell{padding:16px 14px 24px;}}"
    out = out + "</style></head><body><div class='shell'>"
    out = out + "<section class='hero'>"
    out = out + "<h1>Cheng VPN GUI</h1>"
    out = out + "<p class='sub'>纯 Cheng 本地 Web 控制台。配置、启动、停止和日志都走现有 vpn_proxy 核心。</p>"
    out = out + "<div class='badges'>"
    out = out + "<span class='badge " + v3VpnGuiStatusBadgeClass(state) + "'>" + v3VpnGuiHtmlEscape(v3VpnGuiProcessSummary(state)) + "</span>"
    out = out + "<span class='badge idle'>web " + v3VpnGuiHtmlEscape(url) + "</span>"
    out = out + "<span class='badge idle'>socks " + v3VpnGuiHtmlEscape(v3VpnGuiFieldGet(state, v3VpnGuiFieldListen)) + "</span>"
    out = out + "</div></section>"
    out = out + "<div class='grid'>"
    out = out + "<section class='card'>"
    out = out + "<form method='get' action='/save'>"
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldConfigPath), "config_path", v3VpnGuiFieldGet(state, v3VpnGuiFieldConfigPath), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldListen), "listen", v3VpnGuiFieldGet(state, v3VpnGuiFieldListen), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldCertDer), "cert_der", v3VpnGuiFieldGet(state, v3VpnGuiFieldCertDer), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldKeyPk8Der), "key_pk8_der", v3VpnGuiFieldGet(state, v3VpnGuiFieldKeyPk8Der), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldTrustRootDer), "trust_root_der", v3VpnGuiFieldGet(state, v3VpnGuiFieldTrustRootDer), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldExitName), "exit_name", v3VpnGuiFieldGet(state, v3VpnGuiFieldExitName), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldExitHost), "exit_host", v3VpnGuiFieldGet(state, v3VpnGuiFieldExitHost), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldExitPort), "exit_port", v3VpnGuiFieldGet(state, v3VpnGuiFieldExitPort), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldServerName), "server_name", v3VpnGuiFieldGet(state, v3VpnGuiFieldServerName), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldAuthority), "authority", v3VpnGuiFieldGet(state, v3VpnGuiFieldAuthority), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldAuth), "auth", v3VpnGuiFieldGet(state, v3VpnGuiFieldAuth), "")
    v3VpnGuiAppendInput(out, v3VpnGuiFieldLabel(v3VpnGuiFieldCcRx), "cc_rx", v3VpnGuiFieldGet(state, v3VpnGuiFieldCcRx), "")
    out = out + "<div class='row'>"
    out = out + "<button type='submit' formaction='/save'>保存配置</button>"
    out = out + "<button type='submit' formaction='/start' class='secondary'>保存并启动</button>"
    out = out + "</div></form>"
    out = out + "</section>"
    out = out + "<section class='card'>"
    out = out + "<div class='meta'>"
    out = out + "<p><strong>运行时：</strong> <code>" + v3VpnGuiHtmlEscape(state.runtimeToolPath) + "</code></p>"
    out = out + "<p><strong>状态：</strong> " + v3VpnGuiHtmlEscape(state.statusText) + "</p>"
    out = out + "<p><strong>提示：</strong> " + v3VpnGuiHtmlEscape(state.noticeText) + "</p>"
    out = out + "<p><strong>错误：</strong> " + v3VpnGuiHtmlEscape(state.errorText) + "</p>"
    out = out + "<p><a href='/status.json'>status.json</a></p>"
    out = out + "</div>"
    out = out + "<div class='row'>"
    out = out + "<form method='get' action='/reload'><button class='ghost' type='submit'>从文件重载</button></form>"
    out = out + "<form method='get' action='/stop'><button class='ghost' type='submit'>停止本地代理</button></form>"
    out = out + "<form method='get' action='/quit'><button class='ghost' type='submit'>退出界面</button></form>"
    out = out + "</div>"
    out = out + "<div style='margin-top:18px'><pre>" + v3VpnGuiHtmlEscape(state.logText) + "</pre></div>"
    out = out + "</section>"
    out = out + "</div></div></body></html>"
    port
    return out

fn v3VpnGuiReadHttpRequest(conn: var tcp.TcpConnectionHandle): Result[str] =
    var requestText = ""
    for _ in 0..<32:
        let readRes: Result[Bytes] = tcp.TcpRecv(conn, 4096)
        if IsErr(readRes):
            return Err[str](ErrorText(readRes))
        let chunk: Bytes = Value(readRes)
        if bytesLen(chunk) <= 0:
            break
        requestText = requestText + bytesToString(chunk)
        if len(requestText) > v3VpnGuiHttpMaxChars:
            return Err[str]("vpn gui: http request too large")
        if v3VpnGuiFindSub(requestText, "\r\n\r\n") >= 0:
            return Ok[str](requestText)
    return Err[str]("vpn gui: incomplete http request")

fn v3VpnGuiParseRequestLine(requestText: str,
                            outMethod: var str,
                            outTarget: var str): bool =
    let lineEnd: int32 = v3VpnGuiFindSub(requestText, "\r\n")
    if lineEnd <= 0:
        return false
    let line: str = strings.SliceBytes(requestText, 0, lineEnd)
    let firstSpace: int32 = v3VpnGuiFindChar(line, char(32), 0)
    if firstSpace <= 0:
        return false
    let secondSpace: int32 = v3VpnGuiFindChar(line, char(32), firstSpace + 1)
    if secondSpace <= firstSpace + 1:
        outMethod = strutil.Strip(strings.SliceBytes(line, 0, firstSpace))
        outTarget = strutil.Strip(strings.SliceBytes(line, firstSpace + 1, len(line) - (firstSpace + 1)))
        return len(outMethod) > 0 && len(outTarget) > 0
    outMethod = strutil.Strip(strings.SliceBytes(line, 0, firstSpace))
    outTarget = strutil.Strip(strings.SliceBytes(line, firstSpace + 1, secondSpace - (firstSpace + 1)))
    return len(outMethod) > 0 && len(outTarget) > 0

fn v3VpnGuiSplitTarget(target: str,
                       outPath: var str,
                       outQuery: var str) =
    let q: int32 = v3VpnGuiFindChar(target, '?', 0)
    if q < 0:
        outPath = target
        outQuery = ""
        return
    outPath = strings.SliceBytes(target, 0, q)
    outQuery = strings.SliceBytes(target, q + 1, len(target) - (q + 1))

fn v3VpnGuiSendHttp(conn: var tcp.TcpConnectionHandle,
                    statusLine: str,
                    contentType: str,
                    body: str) =
    var response = "HTTP/1.1 " + statusLine + "\r\n"
    response = response + "Content-Type: " + contentType + "\r\n"
    response = response + "Cache-Control: no-store\r\n"
    response = response + "Content-Length: " + intToStr(len(body)) + "\r\n"
    response = response + "Connection: close\r\n\r\n"
    response = response + body
    let _ = tcp.TcpSend(conn, bytesFromString(response))

fn v3VpnGuiSendRedirect(conn: var tcp.TcpConnectionHandle,
                        location: str) =
    let body = "<html><body>redirecting to <a href=\"" + v3VpnGuiHtmlEscape(location) + "\">" + v3VpnGuiHtmlEscape(location) + "</a></body></html>"
    var response = "HTTP/1.1 303 See Other\r\n"
    response = response + "Location: " + location + "\r\n"
    response = response + "Cache-Control: no-store\r\n"
    response = response + "Content-Type: text/html; charset=utf-8\r\n"
    response = response + "Content-Length: " + intToStr(len(body)) + "\r\n"
    response = response + "Connection: close\r\n\r\n"
    response = response + body
    let _ = tcp.TcpSend(conn, bytesFromString(response))

fn v3VpnGuiHandleHttp(state: var V3VpnProxyGuiState,
                      conn: var tcp.TcpConnectionHandle,
                      port: int32,
                      url: str) =
    let requestRes: Result[str] = v3VpnGuiReadHttpRequest(conn)
    if IsErr(requestRes):
        v3VpnGuiSendHttp(conn, "400 Bad Request", "text/plain; charset=utf-8", ErrorText(requestRes) + "\n")
        return
    var method = ""
    var target = ""
    if !v3VpnGuiParseRequestLine(Value(requestRes), method, target):
        v3VpnGuiSendHttp(conn, "400 Bad Request", "text/plain; charset=utf-8", "vpn gui: invalid request line\n")
        return
    if method != "GET":
        v3VpnGuiSendHttp(conn, "405 Method Not Allowed", "text/plain; charset=utf-8", "vpn gui: GET only\n")
        return
    var path = ""
    var query = ""
    v3VpnGuiSplitTarget(target, path, query)
    if path == "/save":
        v3VpnGuiApplyQueryString(state, query)
        let _ = V3VpnProxyGuiSaveConfig(state)
        v3VpnGuiSendRedirect(conn, "/")
        return
    if path == "/start":
        v3VpnGuiApplyQueryString(state, query)
        let _ = V3VpnProxyGuiStartLocal(state)
        v3VpnGuiSendRedirect(conn, "/")
        return
    if path == "/stop":
        let _ = V3VpnProxyGuiStopLocal(state)
        v3VpnGuiSendRedirect(conn, "/")
        return
    if path == "/reload":
        let _ = V3VpnProxyGuiReload(state)
        v3VpnGuiSendRedirect(conn, "/")
        return
    if path == "/quit":
        state.quitRequested = true
        let body = "<html><body><h1>Cheng VPN GUI closed</h1><p>Local proxy process keeps its current state.</p></body></html>"
        v3VpnGuiSendHttp(conn, "200 OK", "text/html; charset=utf-8", body)
        return
    if path == "/status.json":
        let body = V3VpnProxyGuiStatusJsonForTest(state, port, url)
        v3VpnGuiSendHttp(conn, "200 OK", "application/json; charset=utf-8", body)
        return
    let body = V3VpnProxyGuiHtmlForTest(state, port, url)
    v3VpnGuiSendHttp(conn, "200 OK", "text/html; charset=utf-8", body)

fn v3VpnGuiTryOpenBrowser(rootDir: str,
                          url: str) =
    let macOpen: str = "/usr/bin/open"
    if v3path.V3PathFileExists(macOpen):
        let _ = hostos.ExecFileStatus(macOpen, [url], [], rootDir, 5)
        return
    let linuxOpen: str = "/usr/bin/xdg-open"
    if v3path.V3PathFileExists(linuxOpen):
        let _ = hostos.ExecFileStatus(linuxOpen, [url], [], rootDir, 5)

fn v3VpnGuiOpenGlobalListener(): Result[bool] =
    var listener: tcp.TcpListenerHandle
    let listenRes: Result[bool] = tcp.TcpListenFill(v3VpnGuiListenHost, v3VpnGuiWebPort, listener, false)
    if IsErr(listenRes):
        return Err[bool](ErrorText(listenRes))
    v3VpnGuiGlobalListener = listener
    return Ok[bool](true)

fn v3VpnGuiCloseGlobalListener() =
    if v3VpnGuiGlobalListener.fd >= 0:
        tcp.TcpListenerClose(v3VpnGuiGlobalListener)
        v3VpnGuiGlobalListener = tcp.TcpListenerHandle()

fn v3VpnGuiServeReadyOnce(port: int32,
                          url: str): Result[bool] =
    let acceptRes: Result[tcp.TcpConnectionHandle] = tcp.TcpAccept(v3VpnGuiGlobalListener)
    if IsErr(acceptRes):
        return Err[bool](ErrorText(acceptRes))
    var conn: tcp.TcpConnectionHandle = Value(acceptRes)
    v3VpnGuiHandleHttp(v3VpnGuiGlobalState, conn, port, url)
    tcp.TcpClose(conn)
    return Ok[bool](true)

fn V3VpnProxyGuiRun(rootDir: str,
                    runtimeToolPathRaw: str,
                    configPathRaw: str): int32 =
    v3VpnGuiInitGlobalState(rootDir, runtimeToolPathRaw, configPathRaw)
    let openRes: Result[bool] = v3VpnGuiOpenGlobalListener()
    if IsErr(openRes):
        v3VpnGuiPrintLine(ErrorText(openRes))
        return 1
    let nonblockingRes: Result[bool] = tcp.TcpListenerSetNonblocking(v3VpnGuiGlobalListener, true)
    if IsErr(nonblockingRes):
        let errText: str = ErrorText(nonblockingRes)
        v3VpnGuiCloseGlobalListener()
        v3VpnGuiPrintLine(errText)
        return 1
    let port: int32 = if v3VpnGuiGlobalListener.addr.port > 0: v3VpnGuiGlobalListener.addr.port else: v3VpnGuiWebPort
    let url: str = "http://" + v3VpnGuiListenHost + ":" + intToStr(port) + "/"
    v3VpnGuiPrintLine("vpn gui: open " + url)
    v3VpnGuiTryOpenBrowser(rootDir, url)
    var exitCode: int32
    while !v3VpnGuiGlobalState.quitRequested:
        v3VpnGuiProcPoll(v3VpnGuiGlobalState)
        let readyRes: Result[bool] = tcp.TcpListenerWaitReadable(v3VpnGuiGlobalListener, v3VpnGuiWaitMs)
        if IsErr(readyRes):
            v3VpnGuiGlobalState.errorText = ErrorText(readyRes)
            exitCode = 1
            break
        if !Value(readyRes):
            continue
        let serveRes: Result[bool] = v3VpnGuiServeReadyOnce(port, url)
        if IsErr(serveRes):
            v3VpnGuiGlobalState.errorText = ErrorText(serveRes)
            exitCode = 1
            break
    v3VpnGuiCloseGlobalListener()
    if exitCode != 0 && len(v3VpnGuiGlobalState.errorText) > 0:
        v3VpnGuiPrintLine(v3VpnGuiGlobalState.errorText)
    if v3VpnGuiGlobalState.proc.running:
        v3VpnGuiPrintLine("vpn gui: ui closed, local proxy still running pid=" + intToStr(int32(v3VpnGuiGlobalState.proc.pid)))
    return exitCode
