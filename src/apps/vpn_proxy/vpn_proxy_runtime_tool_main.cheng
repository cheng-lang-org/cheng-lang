import std/cmdline as cmdline
import std/os
import cheng/apps/vpn_proxy/vpn_proxy_main as vpnproxy

fn v3VpnProxyRuntimeToolRoot(): str =
    let envRoot: str = os.GetEnv("CHENG_ROOT")
    if len(envRoot) > 0:
        return envRoot
    return os.GetCurrentDir()

fn v3VpnProxyRuntimeToolCollectArgsFrom(startIndex: int32,
                                        count: int32): str[] =
    var out: str[]
    if startIndex > count:
        return out
    for i in startIndex..count:
        let arg: str = cmdline.ParamStr(i)
        if len(arg) > 0:
            add(out, arg)
    return out

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.__cheng_captureCmdLine(argc, argv)
    let rootDir: str = v3VpnProxyRuntimeToolRoot()
    let count: int32 = cmdline.ParamCount()
    let args: str[] = v3VpnProxyRuntimeToolCollectArgsFrom(1, count)
    return vpnproxy.v3VpnProxyMain(rootDir, args)
