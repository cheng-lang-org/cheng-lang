import std/result
import std/rawbytes
import std/times
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_plane as content
import cheng/chain/content_runtime as runtime
import cheng/chain/content_runtime_host as runtime_host
import cheng/libp2p/core/types
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/core/scheduler
import cheng/libp2p/host/host as host_base
import cheng/apps/tailnet/tailnet_train_island as island

fn TailnetTrainIslandPeerIdListContains(peerIds: types.Libp2pPeerId[],
                                          peerId: types.Libp2pPeerId): bool =
    for i in 0..<peerIds.len:
        if types.Libp2pPeerIdEqual(peerIds[i], peerId):
            return true
    return false

fn TailnetTrainIslandCandidateInsert(peerIds: var types.Libp2pPeerId[],
                                       endpoints: var ps.Libp2pPeerEndpoint[],
                                       scores: var scheduler.Libp2pPlacementScore[],
                                       request: scheduler.Libp2pWorkloadRequest,
                                       maxCount: int32,
                                       peerId: types.Libp2pPeerId,
                                       endpoint: ps.Libp2pPeerEndpoint,
                                       score: scheduler.Libp2pPlacementScore) =
    if maxCount <= 0 || TailnetTrainIslandPeerIdListContains(peerIds, peerId):
        return
    var insertPos = peerIds.len
    for i in 0..<peerIds.len:
        if scheduler.Libp2pPlacementScoreBetter(score,
                                                  scores[i],
                                                  request,
                                                  peerId,
                                                  peerIds[i]):
            insertPos = i
            break
    if peerIds.len >= maxCount && insertPos >= maxCount:
        return
    if peerIds.len < maxCount:
        add(peerIds, types.Libp2pPeerId())
        add(endpoints, ps.Libp2pPeerEndpoint())
        add(scores, scheduler.Libp2pPlacementScore())
        let iStart2 = peerIds.len - 1
        if iStart2 > insertPos:
            for iOffset2 in 0..<(iStart2 - insertPos):
                let i = iStart2 - iOffset2
                peerIds[i] = peerIds[i - 1]
                endpoints[i] = ps.Libp2pPeerEndpointClone(endpoints[i - 1])
                scores[i] = scores[i - 1]
    else:
        let iStart = peerIds.len - 1
        if iStart > insertPos:
            for iOffset in 0..<(iStart - insertPos):
                let i = iStart - iOffset
                peerIds[i] = peerIds[i - 1]
                endpoints[i] = ps.Libp2pPeerEndpointClone(endpoints[i - 1])
                scores[i] = scores[i - 1]
    peerIds[insertPos] = peerId
    endpoints[insertPos] = ps.Libp2pPeerEndpointClone(endpoint)
    scores[insertPos] = score

fn TailnetTrainIslandWorkerEndpointEligible(endpoint: ps.Libp2pPeerEndpoint,
                                              trustedOnly: bool): bool =
    if endpoint.addr.networkDomain != types.Libp2pNetworkDomainTailnet:
        return false
    if trustedOnly && endpoint.addr.visibility != types.Libp2pVisibilityTrustedOnly:
        return false
    return true

fn TailnetTrainIslandBuildWorkerGroup(out: var island.TailnetTrainWorkerGroup,
                                        trainIsland: island.TailnetTrainIsland,
                                        hostState: host_base.Libp2pHost,
                                        rendezvous: island.TailnetTrainRendezvous): Result[bool] =
    if trainIsland.trustedOnly && !hostState.trustedInfra:
        return Err[bool](" tailnet train island: coordinator trusted infra missing")
    var selectedPeerIds: types.Libp2pPeerId[]
    var selectedEndpoints: ps.Libp2pPeerEndpoint[]
    var selectedScores: scheduler.Libp2pPlacementScore[]
    selectedPeerIds = []
    selectedEndpoints = []
    selectedScores = []
    for i in 0..<hostState.peers.peers.len:
        let record = hostState.peers.peers[i]
        let trustedView = host_base.Libp2pHostTrustedView(hostState, record)
        var score: scheduler.Libp2pPlacementScore
        if !scheduler.Libp2pPeerPlacementScoreFill(score, record, trustedView, rendezvous.workload):
            continue
        var endpoint: ps.Libp2pPeerEndpoint
        if !ps.Libp2pPeerRecordSelectEndpoint(record, trustedView, endpoint):
            continue
        if !TailnetTrainIslandWorkerEndpointEligible(endpoint, trainIsland.trustedOnly):
            continue
        TailnetTrainIslandCandidateInsert(selectedPeerIds,
                                            selectedEndpoints,
                                            selectedScores,
                                            rendezvous.workload,
                                            rendezvous.requestedWorkerCount,
                                            record.peerId,
                                            endpoint,
                                            score)
    if selectedPeerIds.len != rendezvous.requestedWorkerCount:
        return Err[bool](" tailnet train island: worker group incomplete")
    out = island.TailnetTrainWorkerGroup()
    out.rendezvousCid = rendezvous.rendezvousCid
    out.leaderPeerId = selectedPeerIds[0]
    let now = times.EpochTimeSeconds()
    for i in 0..<selectedPeerIds.len:
        var member = island.TailnetTrainWorkerMember()
        member.peerId = selectedPeerIds[i]
        member.endpoint = ps.Libp2pPeerEndpointClone(selectedEndpoints[i])
        if i == 0:
            member.roleKind = island.TailnetTrainRoleLeader
        else:
            member.roleKind = island.TailnetTrainRoleWorker
        let pos = ps.Libp2pPeerstorePos(hostState.peers, selectedPeerIds[i])
        if pos >= 0:
            member.sampledAtEpochSeconds = hostState.peers.peers[pos].resources.sampledAtEpochSeconds
        member.joinedAtEpochSeconds = now
        add(out.members, member)
    out.memberCount = out.members.len
    return Ok[bool](true)

fn TailnetTrainIslandVersionStub(version: island.TailnetCheckpointVersion): content.ContentStub =
    var stub = content.ContentStub()
    stub.version = 1
    stub.bundleCid = version.jobBundleCid
    stub.blobSummaryCid = version.blobSummaryCid
    stub.manifestCid = version.manifestCid
    stub.payloadLen = version.payloadLen
    stub.stubCid = version.stubCid
    return stub

fn TailnetTrainIslandVersionParams(version: island.TailnetCheckpointVersion): swarm.ErasureEncodingParams =
    var params = swarm.ErasureEncodingParams()
    params.version = 1
    params.layoutKind = version.layoutKind
    params.dataShardCount = version.dataShardCount
    params.parityShardCount = version.parityShardCount
    params.shardPayloadBytes = version.shardPayloadBytes
    params.paramsCid = version.paramsCid
    return params

fn TailnetTrainIslandFetchCheckpointManifestFill(out: var swarm.ErasureShardManifest,
                                                   localHost: var host_base.Libp2pHost,
                                                   remoteHost: var host_base.Libp2pHost,
                                                   remotePeerId: types.Libp2pPeerId,
                                                   remoteRuntime: var runtime.ContentRuntime,
                                                   version: island.TailnetCheckpointVersion): Result[bool] =
    let stub = TailnetTrainIslandVersionStub(version)
    return runtime_host.ContentRuntimeRequestManifestFill(out,
                                                            localHost,
                                                            remoteHost,
                                                            remotePeerId,
                                                            remoteRuntime,
                                                            stub)

fn TailnetTrainIslandFetchCheckpointShards(out: var swarm.ErasureShardPullResponse[],
                                             localHost: var host_base.Libp2pHost,
                                             remoteHost: var host_base.Libp2pHost,
                                             remotePeerId: types.Libp2pPeerId,
                                             remoteRuntime: var runtime.ContentRuntime,
                                             manifest: swarm.ErasureShardManifest): Result[bool] =
    out = []
    for i in 0..<manifest.shardCount:
        let requestRes = swarm.ErasureShardPullRequestMake(manifest, manifest.shardIndices[i])
        if IsErr(requestRes):
            return Err[bool](Error(requestRes))
        let pullRes = runtime_host.ContentRuntimeRequestShardPull(localHost,
                                                                    remoteHost,
                                                                    remotePeerId,
                                                                    remoteRuntime,
                                                                    Value(requestRes))
        if IsErr(pullRes):
            return Err[bool](Error(pullRes))
        add(out, Value(pullRes))
    return Ok[bool](true)

fn TailnetTrainIslandRebuildCheckpoint(version: island.TailnetCheckpointVersion,
                                         manifest: swarm.ErasureShardManifest,
                                         responses: swarm.ErasureShardPullResponse[]): Result[Bytes] =
    let stub = TailnetTrainIslandVersionStub(version)
    let params = TailnetTrainIslandVersionParams(version)
    return runtime.ContentRuntimeRebuildBlobAgainstStub(stub,
                                                          manifest,
                                                          params,
                                                          responses)

fn TailnetTrainIslandShardResponsePos(responses: swarm.ErasureShardPullResponse[],
                                        shardIndex: int32): int32 =
    for i in 0..<responses.len:
        if responses[i].shardIndex == shardIndex:
            return i
    return -1

fn TailnetTrainIslandAssembleSystematicCheckpointFill(out: var Bytes,
                                                        manifest: swarm.ErasureShardManifest,
                                                        params: swarm.ErasureEncodingParams,
                                                        responses: swarm.ErasureShardPullResponse[]): Result[bool] =
    let manifestOk = swarm.ErasureManifestValidate(manifest, params)
    if IsErr(manifestOk):
        return Err[bool](Error(manifestOk))
    if params.layoutKind != swarm.ErasureLayoutRsSystematic:
        return Err[bool](" tailnet train island: checkpoint assemble layout")
    if params.parityShardCount != 0:
        return Err[bool](" tailnet train island: checkpoint assemble parity")
    out = bytesAlloc(manifest.blobByteLen)
    var next = 0
    for shardIndex in 0..<params.dataShardCount:
        let responsePos = TailnetTrainIslandShardResponsePos(responses, shardIndex)
        if responsePos < 0:
            return Err[bool](" tailnet train island: checkpoint assemble shard missing")
        let response = responses[responsePos]
        let requestRes = swarm.ErasureShardPullRequestMake(manifest, shardIndex)
        if IsErr(requestRes):
            return Err[bool](Error(requestRes))
        let responseOk = swarm.ErasureShardPullResponseValidate(response, Value(requestRes))
        if IsErr(responseOk):
            return Err[bool](Error(responseOk))
        for i in 0..<response.payloadLen:
            if next >= manifest.blobByteLen:
                break
            bytesSet(out, next, bytesGet(response.payload, i))
            next = next + 1
    if next != manifest.blobByteLen:
        return Err[bool](" tailnet train island: checkpoint assemble short blob")
    return Ok[bool](true)

fn TailnetTrainIslandCheckpointBlobCachedFill(out: var Bytes,
                                                runtimeState: runtime.ContentRuntime,
                                                version: island.TailnetCheckpointVersion): bool =
    return runtime.ContentRuntimeCachedBlob(runtimeState, version.blobCid, out)

fn TailnetTrainIslandFetchCheckpointBlobFill(out: var Bytes,
                                               localHost: var host_base.Libp2pHost,
                                               remoteHost: var host_base.Libp2pHost,
                                               remotePeerId: types.Libp2pPeerId,
                                               remoteRuntime: var runtime.ContentRuntime,
                                               version: island.TailnetCheckpointVersion): Result[bool] =
    var manifest = swarm.ErasureShardManifest()
    let manifestRes = TailnetTrainIslandFetchCheckpointManifestFill(manifest,
                                                                      localHost,
                                                                      remoteHost,
                                                                      remotePeerId,
                                                                      remoteRuntime,
                                                                      version)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    var responses: swarm.ErasureShardPullResponse[]
    let responsesRes = TailnetTrainIslandFetchCheckpointShards(responses,
                                                                 localHost,
                                                                 remoteHost,
                                                                 remotePeerId,
                                                                 remoteRuntime,
                                                                 manifest)
    if IsErr(responsesRes):
        return Err[bool](Error(responsesRes))
    let params = TailnetTrainIslandVersionParams(version)
    if params.layoutKind == swarm.ErasureLayoutRsSystematic && params.parityShardCount == 0:
        let assembleRes = TailnetTrainIslandAssembleSystematicCheckpointFill(out,
                                                                               manifest,
                                                                               params,
                                                                               responses)
        if IsErr(assembleRes):
            return Err[bool](Error(assembleRes))
    else:
        let blobRes = TailnetTrainIslandRebuildCheckpoint(version, manifest, responses)
        if IsErr(blobRes):
            return Err[bool](Error(blobRes))
        out = Value(blobRes)
    return Ok[bool](true)
