import std/result
import std/times
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/chain/dag_mempool as dag
import cheng/chain/content_plane as content
import cheng/chain/erasure_swarm as swarm
import cheng/chain/content_runtime as runtime
import cheng/libp2p/core/types
import cheng/libp2p/core/peer_id
import cheng/libp2p/core/peerstore as ps
import cheng/libp2p/core/scheduler

const
    TailnetTrainRoleLeader: int32 = 1
    TailnetTrainRoleWorker: int32 = 2
    TailnetTrainRoleCheckpoint: int32 = 3

type
    TailnetTrainWorkerRoleKind = int32

    TailnetTrainRendezvous =
        rendezvousCid: layout.FixedBytes32
        jobBundleCid: layout.FixedBytes32
        requestedWorkerCount: int32
        workload: scheduler.Libp2pWorkloadRequest
        openedAtEpochSeconds: int64
        deadlineEpochSeconds: int64
        closed: bool

    TailnetTrainWorkerMember =
        peerId: types.Libp2pPeerId
        endpoint: ps.Libp2pPeerEndpoint
        roleKind: TailnetTrainWorkerRoleKind
        sampledAtEpochSeconds: int64
        joinedAtEpochSeconds: int64

    TailnetTrainWorkerGroup =
        rendezvousCid: layout.FixedBytes32
        leaderPeerId: types.Libp2pPeerId
        memberCount: int32
        members: TailnetTrainWorkerMember[]
        sealed: bool

    TailnetTrainWorkerLease =
        rendezvousCid: layout.FixedBytes32
        peerId: types.Libp2pPeerId
        roleKind: TailnetTrainWorkerRoleKind
        parentVersionCid: layout.FixedBytes32
        globalStep: int32
        leasedAtEpochSeconds: int64
        expiresAtEpochSeconds: int64
        active: bool

    TailnetTrainStepBarrier =
        rendezvousCid: layout.FixedBytes32
        parentVersionCid: layout.FixedBytes32
        globalStep: int32
        expectedMemberCount: int32
        arrivedCount: int32
        arrivedPeerIds: types.Libp2pPeerId[]
        sealed: bool

    TailnetTrainMergeContribution =
        peerId: types.Libp2pPeerId
        parentVersionCid: layout.FixedBytes32
        globalStep: int32
        optimizerStateCid: layout.FixedBytes32
        optimizerPayloadLen: int32
        submittedAtEpochSeconds: int64

    TailnetTrainMergeRound =
        rendezvousCid: layout.FixedBytes32
        parentVersionCid: layout.FixedBytes32
        globalStep: int32
        expectedMemberCount: int32
        acceptedCount: int32
        contributions: TailnetTrainMergeContribution[]
        sealed: bool

    TailnetCheckpointVersion =
        versionCid: layout.FixedBytes32
        versionEpochSeconds: int64
        globalStep: int32
        publisherPeerId: types.Libp2pPeerId
        jobBundleCid: layout.FixedBytes32
        stubCid: layout.FixedBytes32
        blobSummaryCid: layout.FixedBytes32
        payloadLen: int32
        manifestCid: layout.FixedBytes32
        blobCid: layout.FixedBytes32
        paramsCid: layout.FixedBytes32
        layoutKind: int32
        dataShardCount: int32
        parityShardCount: int32
        shardPayloadBytes: int32
        optimizerStateCid: layout.FixedBytes32
        optimizerPayloadLen: int32
        prevVersionCid: layout.FixedBytes32

    TailnetCheckpointSurface =
        jobBundleCid: layout.FixedBytes32
        latestVersionCid: layout.FixedBytes32
        versionCount: int32
        latestVersion: TailnetCheckpointVersion
        versions: TailnetCheckpointVersion[]

    TailnetCheckpointDeltaChunk =
        offset: int32
        payloadLen: int32
        payload: Bytes

    TailnetCheckpointDelta =
        baseVersionCid: layout.FixedBytes32
        targetVersionCid: layout.FixedBytes32
        targetBlobCid: layout.FixedBytes32
        targetBlobSummaryCid: layout.FixedBytes32
        targetPayloadLen: int32
        targetShardPayloadBytes: int32
        chunkSpanBytes: int32
        chunkCount: int32
        chunks: TailnetCheckpointDeltaChunk[]

    TailnetCheckpointWriteback =
        versionCid: layout.FixedBytes32
        baseVersionCid: layout.FixedBytes32
        manifestCid: layout.FixedBytes32
        blobCid: layout.FixedBytes32
        payloadLen: int32
        shardCount: int32
        deltaChunkCount: int32
        writtenAtEpochSeconds: int64

    TailnetTrainIsland =
        islandId: layout.FixedBytes32
        coordinatorPeerId: types.Libp2pPeerId
        trustedOnly: bool
        rendezvouses: TailnetTrainRendezvous[]
        groups: TailnetTrainWorkerGroup[]
        workerLeases: TailnetTrainWorkerLease[]
        stepBarriers: TailnetTrainStepBarrier[]
        mergeRounds: TailnetTrainMergeRound[]
        checkpoints: TailnetCheckpointSurface[]
        writebacks: TailnetCheckpointWriteback[]

fn TailnetTrainIslandInit(seed: str): TailnetTrainIsland =
    var coordinatorPeerId: types.Libp2pPeerId
    peer_id.Libp2pPeerIdFillFromSeed(coordinatorPeerId, seed)
    return TailnetTrainIsland(
        islandId: coordinatorPeerId.value,
        coordinatorPeerId: coordinatorPeerId,
        trustedOnly: true,
        rendezvouses: [],
        groups: [],
        workerLeases: [],
        stepBarriers: [],
        mergeRounds: [],
        checkpoints: [],
        writebacks: []
    )

fn TailnetTrainIslandRendezvousPos(island: var TailnetTrainIsland,
                                     rendezvousCid: layout.FixedBytes32): int32 =
    if island.rendezvouses.len <= 0:
        return -1
    for i in 0..<island.rendezvouses.len:
        if layout.FixedBytes32Equal(island.rendezvouses[i].rendezvousCid, rendezvousCid):
            return i
    return -1

fn TailnetTrainIslandGroupPos(island: var TailnetTrainIsland,
                                rendezvousCid: layout.FixedBytes32): int32 =
    if island.groups.len <= 0:
        return -1
    for i in 0..<island.groups.len:
        if layout.FixedBytes32Equal(island.groups[i].rendezvousCid, rendezvousCid):
            return i
    return -1

fn TailnetTrainIslandWorkerLeasePos(island: var TailnetTrainIsland,
                                      rendezvousCid: layout.FixedBytes32,
                                      peerId: types.Libp2pPeerId): int32 =
    if island.workerLeases.len <= 0:
        return -1
    for i in 0..<island.workerLeases.len:
        if !layout.FixedBytes32Equal(island.workerLeases[i].rendezvousCid, rendezvousCid):
            continue
        if types.Libp2pPeerIdEqual(island.workerLeases[i].peerId, peerId):
            return i
    return -1

fn TailnetTrainIslandStepBarrierPos(island: var TailnetTrainIsland,
                                      rendezvousCid: layout.FixedBytes32,
                                      parentVersionCid: layout.FixedBytes32,
                                      globalStep: int32): int32 =
    if island.stepBarriers.len <= 0:
        return -1
    for i in 0..<island.stepBarriers.len:
        if !layout.FixedBytes32Equal(island.stepBarriers[i].rendezvousCid, rendezvousCid):
            continue
        if !layout.FixedBytes32Equal(island.stepBarriers[i].parentVersionCid, parentVersionCid):
            continue
        if island.stepBarriers[i].globalStep == globalStep:
            return i
    return -1

fn TailnetTrainIslandMergeRoundPos(island: var TailnetTrainIsland,
                                     rendezvousCid: layout.FixedBytes32,
                                     parentVersionCid: layout.FixedBytes32,
                                     globalStep: int32): int32 =
    if island.mergeRounds.len <= 0:
        return -1
    for i in 0..<island.mergeRounds.len:
        if !layout.FixedBytes32Equal(island.mergeRounds[i].rendezvousCid, rendezvousCid):
            continue
        if !layout.FixedBytes32Equal(island.mergeRounds[i].parentVersionCid, parentVersionCid):
            continue
        if island.mergeRounds[i].globalStep == globalStep:
            return i
    return -1

fn TailnetTrainIslandCheckpointSurfacePos(island: var TailnetTrainIsland,
                                            jobBundleCid: layout.FixedBytes32): int32 =
    if island.checkpoints.len <= 0:
        return -1
    for i in 0..<island.checkpoints.len:
        if layout.FixedBytes32Equal(island.checkpoints[i].jobBundleCid, jobBundleCid):
            return i
    return -1

fn TailnetTrainIslandCheckpointVersionPos(surface: TailnetCheckpointSurface,
                                            versionCid: layout.FixedBytes32): int32 =
    if surface.versions.len <= 0:
        return -1
    for i in 0..<surface.versions.len:
        if layout.FixedBytes32Equal(surface.versions[i].versionCid, versionCid):
            return i
    return -1

fn TailnetTrainIslandCheckpointWritebackPos(island: var TailnetTrainIsland,
                                              versionCid: layout.FixedBytes32): int32 =
    if island.writebacks.len <= 0:
        return -1
    for i in 0..<island.writebacks.len:
        if layout.FixedBytes32Equal(island.writebacks[i].versionCid, versionCid):
            return i
    return -1

fn TailnetTrainIslandWorkerGroupContainsPeer(group: TailnetTrainWorkerGroup,
                                               peerId: types.Libp2pPeerId): bool =
    for i in 0..<group.members.len:
        if types.Libp2pPeerIdEqual(group.members[i].peerId, peerId):
            return true
    return false

fn TailnetTrainWorkerLeaseActiveAt(lease: TailnetTrainWorkerLease, now: int64): bool =
    return lease.active && lease.expiresAtEpochSeconds > now

fn TailnetTrainStepBarrierReady(barrier: TailnetTrainStepBarrier): bool =
    return barrier.sealed && barrier.arrivedCount == barrier.expectedMemberCount

fn TailnetTrainMergeContributionPos(round: TailnetTrainMergeRound,
                                      peerId: types.Libp2pPeerId): int32 =
    for i in 0..<round.contributions.len:
        if types.Libp2pPeerIdEqual(round.contributions[i].peerId, peerId):
            return i
    return -1

fn TailnetTrainMergeRoundReady(round: TailnetTrainMergeRound): bool =
    return round.sealed && round.acceptedCount == round.expectedMemberCount

fn TailnetTrainIslandWorkerGroupMemberFill(out: var TailnetTrainWorkerMember,
                                             group: TailnetTrainWorkerGroup,
                                             peerId: types.Libp2pPeerId): bool =
    for i in 0..<group.members.len:
        if !types.Libp2pPeerIdEqual(group.members[i].peerId, peerId):
            continue
        out = group.members[i]
        return true
    out = TailnetTrainWorkerMember()
    return false

fn TailnetTrainStepBarrierHasPeer(barrier: TailnetTrainStepBarrier,
                                    peerId: types.Libp2pPeerId): bool =
    for i in 0..<barrier.arrivedPeerIds.len:
        if types.Libp2pPeerIdEqual(barrier.arrivedPeerIds[i], peerId):
            return true
    return false

fn TailnetTrainRendezvousCid(islandId: layout.FixedBytes32,
                               jobBundleCid: layout.FixedBytes32,
                               ordinal: int32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(128)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.tailnet.train.rendezvous"))
    lt.AppendFixed32(buf, islandId)
    lt.AppendFixed32(buf, jobBundleCid)
    lt.AppendU32BE(buf, ordinal)
    return lt.FixedCidFromBuf(buf)

fn TailnetCheckpointVersionCid(jobBundleCid: layout.FixedBytes32,
                                 globalStep: int32,
                                 publisherPeerId: types.Libp2pPeerId,
                                 stubCid: layout.FixedBytes32,
                                 manifestCid: layout.FixedBytes32,
                                 blobCid: layout.FixedBytes32,
                                 optimizerStateCid: layout.FixedBytes32,
                                 prevVersionCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf: layout.ByteBuf = layout.ByteBufInit(256)
    layout.ByteBufAppendBytes(buf, bytesFromString("cheng.tailnet.train.checkpoint"))
    lt.AppendFixed32(buf, jobBundleCid)
    lt.AppendU32BE(buf, globalStep)
    lt.AppendFixed32(buf, publisherPeerId.value)
    lt.AppendFixed32(buf, stubCid)
    lt.AppendFixed32(buf, manifestCid)
    lt.AppendFixed32(buf, blobCid)
    lt.AppendFixed32(buf, optimizerStateCid)
    lt.AppendFixed32(buf, prevVersionCid)
    return lt.FixedCidFromBuf(buf)

fn TailnetTrainIslandBytesRangeEqual(left: Bytes,
                                       leftOffset: int32,
                                       right: Bytes,
                                       rightOffset: int32,
                                       count: int32): bool =
    if count < 0:
        return false
    if leftOffset < 0 || rightOffset < 0:
        return false
    if (leftOffset + count) > bytesLen(left):
        return false
    if (rightOffset + count) > bytesLen(right):
        return false
    for i in 0..<count:
        if bytesGet(left, leftOffset + i) != bytesGet(right, rightOffset + i):
            return false
    return true

fn TailnetTrainIslandCheckpointDeltaChunkValidate(chunk: TailnetCheckpointDeltaChunk,
                                                    targetPayloadLen: int32): Result[bool] =
    if chunk.offset < 0:
        return Err[bool](" tailnet train island: delta chunk offset")
    if chunk.payloadLen <= 0:
        return Err[bool](" tailnet train island: delta chunk payload len")
    if bytesLen(chunk.payload) != chunk.payloadLen:
        return Err[bool](" tailnet train island: delta chunk payload bytes")
    if (chunk.offset + chunk.payloadLen) > targetPayloadLen:
        return Err[bool](" tailnet train island: delta chunk range")
    return Ok[bool](true)

fn TailnetTrainIslandCheckpointDeltaValidate(delta: TailnetCheckpointDelta): Result[bool] =
    if layout.FixedBytes32Equal(delta.targetVersionCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: delta target version missing")
    if layout.FixedBytes32Equal(delta.targetBlobCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: delta target blob missing")
    if layout.FixedBytes32Equal(delta.targetBlobSummaryCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: delta target summary missing")
    if delta.targetPayloadLen < 0:
        return Err[bool](" tailnet train island: delta target payload len")
    if delta.targetShardPayloadBytes <= 0:
        return Err[bool](" tailnet train island: delta shard payload bytes")
    if delta.chunkSpanBytes <= 0:
        return Err[bool](" tailnet train island: delta chunk span")
    if delta.chunkCount != delta.chunks.len:
        return Err[bool](" tailnet train island: delta chunk count")
    var nextOffset = 0
    for i in 0..<delta.chunks.len:
        let chunkOk = TailnetTrainIslandCheckpointDeltaChunkValidate(delta.chunks[i],
                                                                       delta.targetPayloadLen)
        if IsErr(chunkOk):
            return Err[bool](Error(chunkOk))
        if delta.chunks[i].offset < nextOffset:
            return Err[bool](" tailnet train island: delta chunk order")
        nextOffset = delta.chunks[i].offset + delta.chunks[i].payloadLen
    return Ok[bool](true)

fn TailnetTrainIslandCheckpointWritebackFill(out: var TailnetCheckpointWriteback,
                                               island: var TailnetTrainIsland,
                                               versionCid: layout.FixedBytes32): bool =
    let pos = TailnetTrainIslandCheckpointWritebackPos(island, versionCid)
    if pos < 0 || pos >= island.writebacks.len:
        out = TailnetCheckpointWriteback()
        return false
    out = island.writebacks[pos]
    return true

fn TailnetTrainIslandCheckpointVersionHasBase(version: TailnetCheckpointVersion): bool =
    return !layout.FixedBytes32Equal(version.prevVersionCid, layout.FixedBytes32())

fn TailnetTrainIslandCheckpointDeltaHasBase(delta: TailnetCheckpointDelta): bool =
    return !layout.FixedBytes32Equal(delta.baseVersionCid, layout.FixedBytes32())

fn TailnetTrainIslandWorkerLeaseFill(out: var TailnetTrainWorkerLease,
                                       island: var TailnetTrainIsland,
                                       rendezvousCid: layout.FixedBytes32,
                                       peerId: types.Libp2pPeerId): bool =
    let pos = TailnetTrainIslandWorkerLeasePos(island, rendezvousCid, peerId)
    if pos < 0 || pos >= island.workerLeases.len:
        out = TailnetTrainWorkerLease()
        return false
    out = island.workerLeases[pos]
    return true

fn TailnetTrainIslandStepBarrierFill(out: var TailnetTrainStepBarrier,
                                       island: var TailnetTrainIsland,
                                       rendezvousCid: layout.FixedBytes32,
                                       parentVersionCid: layout.FixedBytes32,
                                       globalStep: int32): bool =
    let pos = TailnetTrainIslandStepBarrierPos(island,
                                                 rendezvousCid,
                                                 parentVersionCid,
                                                 globalStep)
    if pos < 0 || pos >= island.stepBarriers.len:
        out = TailnetTrainStepBarrier()
        return false
    out = island.stepBarriers[pos]
    return true

fn TailnetTrainIslandMergeRoundFill(out: var TailnetTrainMergeRound,
                                      island: var TailnetTrainIsland,
                                      rendezvousCid: layout.FixedBytes32,
                                      parentVersionCid: layout.FixedBytes32,
                                      globalStep: int32): bool =
    let pos = TailnetTrainIslandMergeRoundPos(island,
                                                rendezvousCid,
                                                parentVersionCid,
                                                globalStep)
    if pos < 0 || pos >= island.mergeRounds.len:
        out = TailnetTrainMergeRound()
        return false
    out = island.mergeRounds[pos]
    return true

fn TailnetTrainIslandCheckpointParentValidate(island: var TailnetTrainIsland,
                                                group: TailnetTrainWorkerGroup,
                                                parentVersionCid: layout.FixedBytes32,
                                                globalStep: int32): Result[bool] =
    let rendezvousPos = TailnetTrainIslandRendezvousPos(island, group.rendezvousCid)
    if rendezvousPos < 0:
        return Err[bool](" tailnet train island: rendezvous missing")
    if !group.sealed:
        return Err[bool](" tailnet train island: worker group not sealed")
    let jobBundleCid = island.rendezvouses[rendezvousPos].jobBundleCid
    if layout.FixedBytes32Equal(jobBundleCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: job bundle cid missing")
    if layout.FixedBytes32Equal(parentVersionCid, layout.FixedBytes32()):
        if TailnetTrainIslandCheckpointSurfacePos(island, jobBundleCid) >= 0:
            return Err[bool](" tailnet train island: parent version missing")
        if globalStep <= 0:
            return Err[bool](" tailnet train island: global step")
        return Ok[bool](true)
    var parentVersion = TailnetCheckpointVersion()
    if !TailnetTrainIslandCheckpointVersionFill(parentVersion, island, parentVersionCid):
        return Err[bool](" tailnet train island: parent version missing")
    if !layout.FixedBytes32Equal(parentVersion.jobBundleCid, jobBundleCid):
        return Err[bool](" tailnet train island: parent job bundle mismatch")
    var latest = TailnetCheckpointVersion()
    if !TailnetTrainIslandCheckpointLatestFill(latest, island, jobBundleCid):
        return Err[bool](" tailnet train island: parent latest missing")
    if !layout.FixedBytes32Equal(latest.versionCid, parentVersionCid):
        return Err[bool](" tailnet train island: stale parent version")
    if globalStep <= parentVersion.globalStep:
        return Err[bool](" tailnet train island: global step")
    return Ok[bool](true)

fn TailnetTrainIslandBarrierExpectedMembers(island: var TailnetTrainIsland,
                                              group: TailnetTrainWorkerGroup,
                                              parentVersionCid: layout.FixedBytes32,
                                              globalStep: int32): int32 =
    let now = times.EpochTimeSeconds()
    var count = 0
    for i in 0..<group.members.len:
        let leasePos = TailnetTrainIslandWorkerLeasePos(island,
                                                          group.rendezvousCid,
                                                          group.members[i].peerId)
        if leasePos < 0:
            continue
        let lease = island.workerLeases[leasePos]
        if !layout.FixedBytes32Equal(lease.parentVersionCid, parentVersionCid):
            continue
        if lease.globalStep != globalStep:
            continue
        if !TailnetTrainWorkerLeaseActiveAt(lease, now):
            continue
        count = count + 1
    return count

fn TailnetTrainIslandCheckpointVersionParams(version: TailnetCheckpointVersion): swarm.ErasureEncodingParams =
    var params = swarm.ErasureEncodingParams()
    params.version = 1
    params.layoutKind = version.layoutKind
    params.dataShardCount = version.dataShardCount
    params.parityShardCount = version.parityShardCount
    params.shardPayloadBytes = version.shardPayloadBytes
    params.paramsCid = version.paramsCid
    return params

fn TailnetTrainIslandCheckpointBlobCachedFill(out: var Bytes,
                                                runtimeState: runtime.ContentRuntime,
                                                version: TailnetCheckpointVersion): bool =
    return runtime.ContentRuntimeCachedBlob(runtimeState, version.blobCid, out)

fn TailnetTrainIslandOpenRendezvousFill(out: var TailnetTrainRendezvous,
                                          island: var TailnetTrainIsland,
                                          jobBundleCid: layout.FixedBytes32,
                                          requestedWorkerCount: int32,
                                          workload: scheduler.Libp2pWorkloadRequest,
                                          deadlineEpochSeconds: int64): Result[bool] =
    if requestedWorkerCount <= 0:
        return Err[bool](" tailnet train island: requested worker count")
    if layout.FixedBytes32Equal(jobBundleCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: job bundle cid missing")
    let now = times.EpochTimeSeconds()
    if deadlineEpochSeconds <= now:
        return Err[bool](" tailnet train island: deadline expired")
    out = TailnetTrainRendezvous()
    out.rendezvousCid = TailnetTrainRendezvousCid(island.islandId,
                                                    jobBundleCid,
                                                    island.rendezvouses.len + 1)
    out.jobBundleCid = jobBundleCid
    out.requestedWorkerCount = requestedWorkerCount
    out.workload = workload
    out.openedAtEpochSeconds = now
    out.deadlineEpochSeconds = deadlineEpochSeconds
    add(island.rendezvouses, out)
    return Ok[bool](true)

fn TailnetTrainIslandSealWorkerGroup(island: var TailnetTrainIsland,
                                       group: TailnetTrainWorkerGroup): Result[bool] =
    let rendezvousPos = TailnetTrainIslandRendezvousPos(island, group.rendezvousCid)
    if rendezvousPos < 0:
        return Err[bool](" tailnet train island: rendezvous missing")
    if island.rendezvouses[rendezvousPos].closed:
        return Err[bool](" tailnet train island: rendezvous closed")
    if group.memberCount <= 0 || group.members.len != group.memberCount:
        return Err[bool](" tailnet train island: invalid worker group")
    if !TailnetTrainIslandWorkerGroupContainsPeer(group, group.leaderPeerId):
        return Err[bool](" tailnet train island: leader missing")
    var sealedGroup = group
    sealedGroup.sealed = true
    let groupPos = TailnetTrainIslandGroupPos(island, group.rendezvousCid)
    if groupPos >= 0:
        island.groups[groupPos] = sealedGroup
    else:
        add(island.groups, sealedGroup)
    island.rendezvouses[rendezvousPos].closed = true
    return Ok[bool](true)

fn TailnetTrainIslandGrantWorkerLeaseFill(out: var TailnetTrainWorkerLease,
                                            island: var TailnetTrainIsland,
                                            group: TailnetTrainWorkerGroup,
                                            peerId: types.Libp2pPeerId,
                                            parentVersionCid: layout.FixedBytes32,
                                            globalStep: int32,
                                            ttlSeconds: int64): Result[bool] =
    if ttlSeconds <= 0:
        return Err[bool](" tailnet train island: lease ttl")
    var groupPos = -1
    for i in 0..<island.groups.len:
        if layout.FixedBytes32Equal(island.groups[i].rendezvousCid, group.rendezvousCid):
            groupPos = i
            break
    if groupPos < 0:
        return Err[bool](" tailnet train island: worker group missing")
    if !island.groups[groupPos].sealed:
        return Err[bool](" tailnet train island: worker group not sealed")
    var member = TailnetTrainWorkerMember()
    if !TailnetTrainIslandWorkerGroupMemberFill(member, island.groups[groupPos], peerId):
        return Err[bool](" tailnet train island: worker peer missing")
    let parentOk = TailnetTrainIslandCheckpointParentValidate(island,
                                                                island.groups[groupPos],
                                                                parentVersionCid,
                                                                globalStep)
    if IsErr(parentOk):
        return Err[bool](Error(parentOk))
    out = TailnetTrainWorkerLease()
    out.rendezvousCid = island.groups[groupPos].rendezvousCid
    out.peerId = peerId
    out.roleKind = member.roleKind
    out.parentVersionCid = parentVersionCid
    out.globalStep = globalStep
    out.leasedAtEpochSeconds = times.EpochTimeSeconds()
    out.expiresAtEpochSeconds = out.leasedAtEpochSeconds + ttlSeconds
    out.active = true
    let leasePos = TailnetTrainIslandWorkerLeasePos(island, out.rendezvousCid, peerId)
    if leasePos >= 0:
        island.workerLeases[leasePos] = out
    else:
        add(island.workerLeases, out)
    return Ok[bool](true)

fn TailnetTrainIslandOpenStepBarrierFill(out: var TailnetTrainStepBarrier,
                                           island: var TailnetTrainIsland,
                                           rendezvousCid: layout.FixedBytes32,
                                           parentVersionCid: layout.FixedBytes32,
                                           globalStep: int32): Result[bool] =
    let groupPos = TailnetTrainIslandGroupPos(island, rendezvousCid)
    if groupPos < 0:
        return Err[bool](" tailnet train island: worker group missing")
    let parentOk = TailnetTrainIslandCheckpointParentValidate(island,
                                                                island.groups[groupPos],
                                                                parentVersionCid,
                                                                globalStep)
    if IsErr(parentOk):
        return Err[bool](Error(parentOk))
    if island.stepBarriers.len > 0:
        if TailnetTrainIslandStepBarrierPos(island,
                                              rendezvousCid,
                                              parentVersionCid,
                                              globalStep) >= 0:
            return Err[bool](" tailnet train island: step barrier duplicate")
    let expectedMemberCount = TailnetTrainIslandBarrierExpectedMembers(island,
                                                                         island.groups[groupPos],
                                                                         parentVersionCid,
                                                                         globalStep)
    if expectedMemberCount <= 0:
        return Err[bool](" tailnet train island: step barrier lease missing")
    out = TailnetTrainStepBarrier()
    out.rendezvousCid = rendezvousCid
    out.parentVersionCid = parentVersionCid
    out.globalStep = globalStep
    out.expectedMemberCount = expectedMemberCount
    add(island.stepBarriers, out)
    return Ok[bool](true)

fn TailnetTrainIslandOpenStepBarrier(out: var TailnetTrainStepBarrier,
                                       island: var TailnetTrainIsland,
                                       rendezvousCid: layout.FixedBytes32,
                                       parentVersionCid: layout.FixedBytes32,
                                       globalStep: int32): bool =
    let res = TailnetTrainIslandOpenStepBarrierFill(out,
                                                      island,
                                                      rendezvousCid,
                                                      parentVersionCid,
                                                      globalStep)
    return IsOk(res)

fn TailnetTrainIslandOpenMergeRoundFill(out: var TailnetTrainMergeRound,
                                          island: var TailnetTrainIsland,
                                          rendezvousCid: layout.FixedBytes32,
                                          parentVersionCid: layout.FixedBytes32,
                                          globalStep: int32): Result[bool] =
    let groupPos = TailnetTrainIslandGroupPos(island, rendezvousCid)
    if groupPos < 0:
        return Err[bool](" tailnet train island: worker group missing")
    let parentOk = TailnetTrainIslandCheckpointParentValidate(island,
                                                                island.groups[groupPos],
                                                                parentVersionCid,
                                                                globalStep)
    if IsErr(parentOk):
        return Err[bool](Error(parentOk))
    let barrierPos = TailnetTrainIslandStepBarrierPos(island,
                                                        rendezvousCid,
                                                        parentVersionCid,
                                                        globalStep)
    if barrierPos < 0:
        return Err[bool](" tailnet train island: step barrier missing")
    if !TailnetTrainStepBarrierReady(island.stepBarriers[barrierPos]):
        return Err[bool](" tailnet train island: step barrier not ready")
    if island.mergeRounds.len > 0:
        if TailnetTrainIslandMergeRoundPos(island,
                                             rendezvousCid,
                                             parentVersionCid,
                                             globalStep) >= 0:
            return Err[bool](" tailnet train island: merge round duplicate")
    out = TailnetTrainMergeRound()
    out.rendezvousCid = rendezvousCid
    out.parentVersionCid = parentVersionCid
    out.globalStep = globalStep
    out.expectedMemberCount = island.stepBarriers[barrierPos].expectedMemberCount
    add(island.mergeRounds, out)
    return Ok[bool](true)

fn TailnetTrainIslandOpenMergeRound(out: var TailnetTrainMergeRound,
                                      island: var TailnetTrainIsland,
                                      rendezvousCid: layout.FixedBytes32,
                                      parentVersionCid: layout.FixedBytes32,
                                      globalStep: int32): bool =
    let res = TailnetTrainIslandOpenMergeRoundFill(out,
                                                     island,
                                                     rendezvousCid,
                                                     parentVersionCid,
                                                     globalStep)
    return IsOk(res)

fn TailnetTrainIslandSubmitMergeContributionFill(out: var TailnetTrainMergeContribution,
                                                   island: var TailnetTrainIsland,
                                                   rendezvousCid: layout.FixedBytes32,
                                                   peerId: types.Libp2pPeerId,
                                                   parentVersionCid: layout.FixedBytes32,
                                                   globalStep: int32,
                                                   optimizerStateCid: layout.FixedBytes32,
                                                   optimizerPayloadLen: int32): Result[bool] =
    if layout.FixedBytes32Equal(optimizerStateCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: merge optimizer cid missing")
    if optimizerPayloadLen <= 0:
        return Err[bool](" tailnet train island: merge optimizer payload len")
    let groupPos = TailnetTrainIslandGroupPos(island, rendezvousCid)
    if groupPos < 0:
        return Err[bool](" tailnet train island: worker group missing")
    if !island.groups[groupPos].sealed:
        return Err[bool](" tailnet train island: worker group not sealed")
    if !TailnetTrainIslandWorkerGroupContainsPeer(island.groups[groupPos], peerId):
        return Err[bool](" tailnet train island: worker peer missing")
    let barrierPos = TailnetTrainIslandStepBarrierPos(island,
                                                        rendezvousCid,
                                                        parentVersionCid,
                                                        globalStep)
    if barrierPos < 0:
        return Err[bool](" tailnet train island: step barrier missing")
    if !TailnetTrainStepBarrierReady(island.stepBarriers[barrierPos]):
        return Err[bool](" tailnet train island: step barrier not ready")
    let leasePos = TailnetTrainIslandWorkerLeasePos(island, rendezvousCid, peerId)
    if leasePos < 0:
        return Err[bool](" tailnet train island: worker lease missing")
    let lease = island.workerLeases[leasePos]
    if !layout.FixedBytes32Equal(lease.parentVersionCid, parentVersionCid):
        return Err[bool](" tailnet train island: worker lease parent mismatch")
    if lease.globalStep != globalStep:
        return Err[bool](" tailnet train island: worker lease step mismatch")
    if !TailnetTrainWorkerLeaseActiveAt(lease, times.EpochTimeSeconds()):
        return Err[bool](" tailnet train island: worker lease expired")
    let roundPos = TailnetTrainIslandMergeRoundPos(island,
                                                     rendezvousCid,
                                                     parentVersionCid,
                                                     globalStep)
    if roundPos < 0:
        return Err[bool](" tailnet train island: merge round missing")
    var round = island.mergeRounds[roundPos]
    if round.sealed:
        return Err[bool](" tailnet train island: merge round sealed")
    if TailnetTrainMergeContributionPos(round, peerId) >= 0:
        return Err[bool](" tailnet train island: merge duplicate peer")
    out = TailnetTrainMergeContribution()
    out.peerId = peerId
    out.parentVersionCid = parentVersionCid
    out.globalStep = globalStep
    out.optimizerStateCid = optimizerStateCid
    out.optimizerPayloadLen = optimizerPayloadLen
    out.submittedAtEpochSeconds = times.EpochTimeSeconds()
    add(round.contributions, out)
    round.acceptedCount = round.contributions.len
    if round.acceptedCount == round.expectedMemberCount:
        round.sealed = true
    island.mergeRounds[roundPos] = round
    return Ok[bool](true)

fn TailnetTrainIslandSubmitMergeContribution(out: var TailnetTrainMergeContribution,
                                               island: var TailnetTrainIsland,
                                               rendezvousCid: layout.FixedBytes32,
                                               peerId: types.Libp2pPeerId,
                                               parentVersionCid: layout.FixedBytes32,
                                               globalStep: int32,
                                               optimizerStateCid: layout.FixedBytes32,
                                               optimizerPayloadLen: int32): bool =
    let res = TailnetTrainIslandSubmitMergeContributionFill(out,
                                                              island,
                                                              rendezvousCid,
                                                              peerId,
                                                              parentVersionCid,
                                                              globalStep,
                                                              optimizerStateCid,
                                                              optimizerPayloadLen)
    return IsOk(res)

fn TailnetTrainIslandArriveStepBarrierFill(out: var TailnetTrainStepBarrier,
                                             island: var TailnetTrainIsland,
                                             rendezvousCid: layout.FixedBytes32,
                                             peerId: types.Libp2pPeerId,
                                             parentVersionCid: layout.FixedBytes32,
                                             globalStep: int32): Result[bool] =
    let groupPos = TailnetTrainIslandGroupPos(island, rendezvousCid)
    if groupPos < 0:
        return Err[bool](" tailnet train island: worker group missing")
    if !TailnetTrainIslandWorkerGroupContainsPeer(island.groups[groupPos], peerId):
        return Err[bool](" tailnet train island: worker peer missing")
    let barrierPos = TailnetTrainIslandStepBarrierPos(island,
                                                        rendezvousCid,
                                                        parentVersionCid,
                                                        globalStep)
    if barrierPos < 0:
        return Err[bool](" tailnet train island: step barrier missing")
    var barrier = island.stepBarriers[barrierPos]
    if barrier.sealed:
        return Err[bool](" tailnet train island: step barrier sealed")
    let leasePos = TailnetTrainIslandWorkerLeasePos(island, rendezvousCid, peerId)
    if leasePos < 0:
        return Err[bool](" tailnet train island: worker lease missing")
    let lease = island.workerLeases[leasePos]
    if !layout.FixedBytes32Equal(lease.parentVersionCid, parentVersionCid):
        return Err[bool](" tailnet train island: worker lease parent mismatch")
    if lease.globalStep != globalStep:
        return Err[bool](" tailnet train island: worker lease step mismatch")
    if !TailnetTrainWorkerLeaseActiveAt(lease, times.EpochTimeSeconds()):
        return Err[bool](" tailnet train island: worker lease expired")
    if TailnetTrainStepBarrierHasPeer(barrier, peerId):
        return Err[bool](" tailnet train island: barrier duplicate peer")
    add(barrier.arrivedPeerIds, peerId)
    barrier.arrivedCount = barrier.arrivedPeerIds.len
    if barrier.arrivedCount == barrier.expectedMemberCount:
        barrier.sealed = true
    island.stepBarriers[barrierPos] = barrier
    out = barrier
    return Ok[bool](true)

fn TailnetTrainIslandArriveStepBarrier(out: var TailnetTrainStepBarrier,
                                         island: var TailnetTrainIsland,
                                         rendezvousCid: layout.FixedBytes32,
                                         peerId: types.Libp2pPeerId,
                                         parentVersionCid: layout.FixedBytes32,
                                         globalStep: int32): bool =
    let res = TailnetTrainIslandArriveStepBarrierFill(out,
                                                        island,
                                                        rendezvousCid,
                                                        peerId,
                                                        parentVersionCid,
                                                        globalStep)
    return IsOk(res)

fn TailnetTrainIslandStepBarrierAdvanceFill(out: var TailnetTrainStepBarrier,
                                              island: var TailnetTrainIsland,
                                              rendezvousCid: layout.FixedBytes32,
                                              parentVersionCid: layout.FixedBytes32,
                                              globalStep: int32,
                                              peerIds: types.Libp2pPeerId[]): Result[bool] =
    if peerIds.len <= 0:
        return Err[bool](" tailnet train island: step barrier peer ids missing")
    let openRes = TailnetTrainIslandOpenStepBarrierFill(out,
                                                          island,
                                                          rendezvousCid,
                                                          parentVersionCid,
                                                          globalStep)
    if IsErr(openRes):
        return Err[bool](Error(openRes))
    for i in 0..<peerIds.len:
        let arriveRes = TailnetTrainIslandArriveStepBarrierFill(out,
                                                                  island,
                                                                  rendezvousCid,
                                                                  peerIds[i],
                                                                  parentVersionCid,
                                                                  globalStep)
        if IsErr(arriveRes):
            return Err[bool](Error(arriveRes))
    if !TailnetTrainStepBarrierReady(out):
        return Err[bool](" tailnet train island: step barrier not ready")
    return Ok[bool](true)

fn TailnetTrainIslandMergeRoundAdvanceFill(out: var TailnetTrainMergeRound,
                                             island: var TailnetTrainIsland,
                                             rendezvousCid: layout.FixedBytes32,
                                             parentVersionCid: layout.FixedBytes32,
                                             globalStep: int32,
                                             peerIds: types.Libp2pPeerId[],
                                             optimizerStateCids: layout.FixedBytes32[],
                                             optimizerPayloadLens: int32[]): Result[bool] =
    if peerIds.len <= 0:
        return Err[bool](" tailnet train island: merge round peer ids missing")
    if peerIds.len != optimizerStateCids.len || peerIds.len != optimizerPayloadLens.len:
        return Err[bool](" tailnet train island: merge round contribution shape")
    let openRes = TailnetTrainIslandOpenMergeRoundFill(out,
                                                         island,
                                                         rendezvousCid,
                                                         parentVersionCid,
                                                         globalStep)
    if IsErr(openRes):
        return Err[bool](Error(openRes))
    var contribution = TailnetTrainMergeContribution()
    for i in 0..<peerIds.len:
        let contributeRes = TailnetTrainIslandSubmitMergeContributionFill(contribution,
                                                                            island,
                                                                            rendezvousCid,
                                                                            peerIds[i],
                                                                            parentVersionCid,
                                                                            globalStep,
                                                                            optimizerStateCids[i],
                                                                            optimizerPayloadLens[i])
        if IsErr(contributeRes):
            return Err[bool](Error(contributeRes))
    if !TailnetTrainMergeRoundReady(out):
        if !TailnetTrainIslandMergeRoundFill(out,
                                               island,
                                               rendezvousCid,
                                               parentVersionCid,
                                               globalStep):
            return Err[bool](" tailnet train island: merge round fetch missing")
        if !TailnetTrainMergeRoundReady(out):
            return Err[bool](" tailnet train island: merge round not ready")
    else:
        if !TailnetTrainIslandMergeRoundFill(out,
                                               island,
                                               rendezvousCid,
                                               parentVersionCid,
                                               globalStep):
            return Err[bool](" tailnet train island: merge round fetch missing")
    return Ok[bool](true)

fn TailnetTrainIslandCheckpointLatestFill(out: var TailnetCheckpointVersion,
                                            island: var TailnetTrainIsland,
                                            jobBundleCid: layout.FixedBytes32): bool =
    let surfacePos = TailnetTrainIslandCheckpointSurfacePos(island, jobBundleCid)
    if surfacePos < 0 || surfacePos >= island.checkpoints.len:
        out = TailnetCheckpointVersion()
        return false
    let surface = island.checkpoints[surfacePos]
    if surface.versionCount > 0 && surface.versions.len == surface.versionCount:
        out = surface.versions[surface.versions.len - 1]
        return true
    if surface.versionCount > 0 &&
       layout.FixedBytes32Equal(surface.latestVersion.versionCid, surface.latestVersionCid):
        out = surface.latestVersion
        return true
    if surface.versionCount > 0:
        out = surface.latestVersion
        return true
    out = TailnetCheckpointVersion()
    return false

fn TailnetTrainIslandCheckpointVersionAppend(island: var TailnetTrainIsland,
                                               version: TailnetCheckpointVersion): Result[bool] =
    if layout.FixedBytes32Equal(version.versionCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: checkpoint version cid missing")
    if layout.FixedBytes32Equal(version.jobBundleCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: checkpoint job bundle cid missing")
    if layout.FixedBytes32Equal(version.optimizerStateCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: checkpoint optimizer cid missing")
    if version.optimizerPayloadLen <= 0:
        return Err[bool](" tailnet train island: checkpoint optimizer payload len")
    let surfacePos = TailnetTrainIslandCheckpointSurfacePos(island, version.jobBundleCid)
    if surfacePos >= 0:
        var surface = island.checkpoints[surfacePos]
        if TailnetTrainIslandCheckpointVersionPos(surface, version.versionCid) >= 0:
            return Err[bool](" tailnet train island: checkpoint version duplicate")
        if surface.versionCount > 0:
            let latest = surface.versions[surface.versions.len - 1]
            if !layout.FixedBytes32Equal(version.prevVersionCid, latest.versionCid):
                return Err[bool](" tailnet train island: checkpoint lineage mismatch")
            if version.globalStep <= latest.globalStep:
                return Err[bool](" tailnet train island: checkpoint step not advancing")
        elif !layout.FixedBytes32Equal(version.prevVersionCid, layout.FixedBytes32()):
            return Err[bool](" tailnet train island: first checkpoint prev version set")
        add(surface.versions, version)
        surface.versionCount = surface.versions.len
        surface.latestVersionCid = version.versionCid
        surface.latestVersion = version
        island.checkpoints[surfacePos] = surface
        return Ok[bool](true)
    if !layout.FixedBytes32Equal(version.prevVersionCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: first checkpoint prev version set")
    var surface = TailnetCheckpointSurface()
    surface.jobBundleCid = version.jobBundleCid
    add(surface.versions, version)
    surface.versionCount = 1
    surface.latestVersionCid = version.versionCid
    surface.latestVersion = version
    add(island.checkpoints, surface)
    return Ok[bool](true)

fn TailnetTrainIslandCheckpointVersionFill(out: var TailnetCheckpointVersion,
                                             island: var TailnetTrainIsland,
                                             versionCid: layout.FixedBytes32): bool =
    for i in 0..<island.checkpoints.len:
        let pos = TailnetTrainIslandCheckpointVersionPos(island.checkpoints[i], versionCid)
        if pos < 0 || pos >= island.checkpoints[i].versions.len:
            continue
        out = island.checkpoints[i].versions[pos]
        return true
    out = TailnetCheckpointVersion()
    return false

fn TailnetTrainIslandCheckpointHistoryFill(out: var TailnetCheckpointVersion[],
                                             island: var TailnetTrainIsland,
                                             jobBundleCid: layout.FixedBytes32): bool =
    out = []
    let surfacePos = TailnetTrainIslandCheckpointSurfacePos(island, jobBundleCid)
    if surfacePos < 0 || surfacePos >= island.checkpoints.len:
        return false
    let surface = island.checkpoints[surfacePos]
    for i in 0..<surface.versions.len:
        add(out, surface.versions[i])
    return out.len > 0

fn TailnetTrainIslandCheckpointLineageFill(out: var TailnetCheckpointVersion[],
                                             island: var TailnetTrainIsland,
                                             versionCid: layout.FixedBytes32): Result[bool] =
    out = []
    var currentCid = versionCid
    if layout.FixedBytes32Equal(currentCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: lineage version cid missing")
    var remaining = 0
    for i in 0..<island.checkpoints.len:
        remaining = remaining + island.checkpoints[i].versionCount
    while !layout.FixedBytes32Equal(currentCid, layout.FixedBytes32()):
        if remaining <= 0:
            return Err[bool](" tailnet train island: checkpoint lineage cycle")
        var version = TailnetCheckpointVersion()
        if !TailnetTrainIslandCheckpointVersionFill(version, island, currentCid):
            return Err[bool](" tailnet train island: checkpoint lineage missing version")
        add(out, version)
        currentCid = version.prevVersionCid
        remaining = remaining - 1
    return Ok[bool](out.len > 0)

fn TailnetTrainIslandCheckpointLatestLineageFill(out: var TailnetCheckpointVersion[],
                                                   island: var TailnetTrainIsland,
                                                   jobBundleCid: layout.FixedBytes32): Result[bool] =
    var latest = TailnetCheckpointVersion()
    if !TailnetTrainIslandCheckpointLatestFill(latest, island, jobBundleCid):
        out = []
        return Err[bool](" tailnet train island: checkpoint latest missing")
    return TailnetTrainIslandCheckpointLineageFill(out, island, latest.versionCid)

fn TailnetTrainIslandCheckpointDeltaFill(out: var TailnetCheckpointDelta,
                                           baseVersionCid: layout.FixedBytes32,
                                           targetVersion: TailnetCheckpointVersion,
                                           baseBlob: Bytes,
                                           targetBlob: Bytes,
                                           chunkSpanBytes: int32): Result[bool] =
    if chunkSpanBytes <= 0:
        return Err[bool](" tailnet train island: delta chunk span")
    if layout.FixedBytes32Equal(targetVersion.versionCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: delta target version missing")
    if targetVersion.payloadLen != bytesLen(targetBlob):
        return Err[bool](" tailnet train island: delta target payload len mismatch")
    if targetVersion.shardPayloadBytes <= 0:
        return Err[bool](" tailnet train island: delta shard payload bytes")
    if !layout.FixedBytes32Equal(baseVersionCid, layout.FixedBytes32()) && bytesLen(baseBlob) <= 0:
        return Err[bool](" tailnet train island: delta base blob missing")
    let targetSummaryRes = dag.DagBlobSummaryFromBytes(targetBlob, targetVersion.shardPayloadBytes)
    if IsErr(targetSummaryRes):
        return Err[bool](Error(targetSummaryRes))
    let targetSummary = Value(targetSummaryRes)
    if !layout.FixedBytes32Equal(targetSummary.blobCid, targetVersion.blobCid):
        return Err[bool](" tailnet train island: delta target blob cid mismatch")
    if !layout.FixedBytes32Equal(targetSummary.summaryCid, targetVersion.blobSummaryCid):
        return Err[bool](" tailnet train island: delta target summary cid mismatch")
    out = TailnetCheckpointDelta()
    out.baseVersionCid = baseVersionCid
    out.targetVersionCid = targetVersion.versionCid
    out.targetBlobCid = targetVersion.blobCid
    out.targetBlobSummaryCid = targetVersion.blobSummaryCid
    out.targetPayloadLen = targetVersion.payloadLen
    out.targetShardPayloadBytes = targetVersion.shardPayloadBytes
    out.chunkSpanBytes = chunkSpanBytes
    var offset = 0
    while offset < targetVersion.payloadLen:
        var spanLen = chunkSpanBytes
        if offset + spanLen > targetVersion.payloadLen:
            spanLen = targetVersion.payloadLen - offset
        var sameAsBase = false
        if (offset + spanLen) <= bytesLen(baseBlob):
            sameAsBase = TailnetTrainIslandBytesRangeEqual(baseBlob,
                                                             offset,
                                                             targetBlob,
                                                             offset,
                                                             spanLen)
        if !sameAsBase:
            var chunk = TailnetCheckpointDeltaChunk()
            chunk.offset = offset
            chunk.payload = bytesSlice(targetBlob, offset, spanLen)
            chunk.payloadLen = bytesLen(chunk.payload)
            add(out.chunks, chunk)
        offset = offset + spanLen
    out.chunkCount = out.chunks.len
    return TailnetTrainIslandCheckpointDeltaValidate(out)

fn TailnetTrainIslandCheckpointMergeDeltaFill(out: var Bytes,
                                                delta: TailnetCheckpointDelta,
                                                baseBlob: Bytes): Result[bool] =
    let deltaOk = TailnetTrainIslandCheckpointDeltaValidate(delta)
    if IsErr(deltaOk):
        return Err[bool](Error(deltaOk))
    if !layout.FixedBytes32Equal(delta.baseVersionCid, layout.FixedBytes32()) && bytesLen(baseBlob) <= 0:
        return Err[bool](" tailnet train island: merge base blob missing")
    out = bytesAlloc(delta.targetPayloadLen)
    let baseCopyLen = if bytesLen(baseBlob) < delta.targetPayloadLen: bytesLen(baseBlob) else: delta.targetPayloadLen
    for i in 0..<baseCopyLen:
        bytesSet(out, i, bytesGet(baseBlob, i))
    for i in 0..<delta.chunks.len:
        let chunk = delta.chunks[i]
        for j in 0..<chunk.payloadLen:
            bytesSet(out, chunk.offset + j, bytesGet(chunk.payload, j))
    if !layout.FixedBytes32Equal(dag.DagBlobCidFromBytes(out), delta.targetBlobCid):
        return Err[bool](" tailnet train island: merge blob cid mismatch")
    let summaryRes = dag.DagBlobSummaryFromBytes(out, delta.targetShardPayloadBytes)
    if IsErr(summaryRes):
        return Err[bool](Error(summaryRes))
    let summary = Value(summaryRes)
    if summary.payloadLen != delta.targetPayloadLen:
        return Err[bool](" tailnet train island: merge payload len mismatch")
    if !layout.FixedBytes32Equal(summary.summaryCid, delta.targetBlobSummaryCid):
        return Err[bool](" tailnet train island: merge summary cid mismatch")
    return Ok[bool](true)

fn TailnetTrainIslandCheckpointWritebackRecord(out: var TailnetCheckpointWriteback,
                                                 island: var TailnetTrainIsland,
                                                 delta: TailnetCheckpointDelta,
                                                 version: TailnetCheckpointVersion,
                                                 manifest: swarm.ErasureShardManifest): Result[bool] =
    let deltaOk = TailnetTrainIslandCheckpointDeltaValidate(delta)
    if IsErr(deltaOk):
        return Err[bool](Error(deltaOk))
    if !layout.FixedBytes32Equal(delta.targetVersionCid, version.versionCid):
        return Err[bool](" tailnet train island: writeback version mismatch")
    if !layout.FixedBytes32Equal(delta.targetBlobCid, version.blobCid):
        return Err[bool](" tailnet train island: writeback blob mismatch")
    if !layout.FixedBytes32Equal(manifest.manifestCid, version.manifestCid):
        return Err[bool](" tailnet train island: writeback manifest mismatch")
    out = TailnetCheckpointWriteback()
    out.versionCid = version.versionCid
    out.baseVersionCid = delta.baseVersionCid
    out.manifestCid = manifest.manifestCid
    out.blobCid = manifest.blobCid
    out.payloadLen = manifest.blobByteLen
    out.shardCount = manifest.shardCount
    out.deltaChunkCount = delta.chunkCount
    out.writtenAtEpochSeconds = times.EpochTimeSeconds()
    let pos = TailnetTrainIslandCheckpointWritebackPos(island, out.versionCid)
    if pos >= 0:
        island.writebacks[pos] = out
    else:
        add(island.writebacks, out)
    return Ok[bool](true)

fn TailnetTrainIslandCheckpointWritebackApplyFill(out: var TailnetCheckpointWriteback,
                                                    mergedBlob: var Bytes,
                                                    island: var TailnetTrainIsland,
                                                    localRuntime: var runtime.ContentRuntime,
                                                    delta: TailnetCheckpointDelta): Result[bool] =
    let deltaOk = TailnetTrainIslandCheckpointDeltaValidate(delta)
    if IsErr(deltaOk):
        return Err[bool](Error(deltaOk))
    var version = TailnetCheckpointVersion()
    let versionFound = TailnetTrainIslandCheckpointVersionFill(version,
                                                                 island,
                                                                 delta.targetVersionCid)
    if !versionFound:
        return Err[bool](" tailnet train island: writeback target version missing")
    let deltaHasBase = TailnetTrainIslandCheckpointDeltaHasBase(delta)
    let versionHasBase = TailnetTrainIslandCheckpointVersionHasBase(version)
    if deltaHasBase != versionHasBase:
        return Err[bool](" tailnet train island: writeback base mismatch")
    if deltaHasBase && !layout.FixedBytes32Equal(delta.baseVersionCid, version.prevVersionCid):
        return Err[bool](" tailnet train island: writeback parent mismatch")
    var latest = TailnetCheckpointVersion()
    let latestFound = TailnetTrainIslandCheckpointLatestFill(latest,
                                                               island,
                                                               version.jobBundleCid)
    if !latestFound:
        return Err[bool](" tailnet train island: writeback latest missing")
    if !layout.FixedBytes32Equal(latest.versionCid, version.versionCid):
        return Err[bool](" tailnet train island: writeback target stale")
    var baseBlob = emptyBytes()
    if deltaHasBase:
        var baseVersion = TailnetCheckpointVersion()
        let baseVersionFound = TailnetTrainIslandCheckpointVersionFill(baseVersion,
                                                                         island,
                                                                         delta.baseVersionCid)
        if !baseVersionFound:
            return Err[bool](" tailnet train island: writeback base version missing")
        let baseBlobFound = TailnetTrainIslandCheckpointBlobCachedFill(baseBlob,
                                                                         localRuntime,
                                                                         baseVersion)
        if !baseBlobFound:
            return Err[bool](" tailnet train island: writeback base blob missing")
    let mergeRes = TailnetTrainIslandCheckpointMergeDeltaFill(mergedBlob, delta, baseBlob)
    if IsErr(mergeRes):
        return Err[bool](Error(mergeRes))
    let params = TailnetTrainIslandCheckpointVersionParams(version)
    let paramsOk = swarm.ErasureEncodingParamsValidate(params)
    if IsErr(paramsOk):
        return Err[bool](Error(paramsOk))
    let summaryRes = dag.DagBlobSummaryFromBytes(mergedBlob, params.shardPayloadBytes)
    if IsErr(summaryRes):
        return Err[bool](Error(summaryRes))
    let summary = Value(summaryRes)
    if !layout.FixedBytes32Equal(summary.blobCid, version.blobCid):
        return Err[bool](" tailnet train island: writeback blob cid mismatch")
    if !layout.FixedBytes32Equal(summary.summaryCid, version.blobSummaryCid):
        return Err[bool](" tailnet train island: writeback summary cid mismatch")
    let shardPayloadsRes = swarm.ErasureEncodeShardPayloads(mergedBlob, params)
    if IsErr(shardPayloadsRes):
        return Err[bool](Error(shardPayloadsRes))
    let shardPayloads = Value(shardPayloadsRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    for i in 0..<shardPayloads.len:
        add(shardPayloadCids, layout.FixedBytes32())
    for i in 0..<shardPayloads.len:
        shardPayloadCids[i] = swarm.ErasureShardPayloadCid(shardPayloads[i])
    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    if IsErr(manifestRes):
        return Err[bool](Error(manifestRes))
    let manifest = Value(manifestRes)
    if !layout.FixedBytes32Equal(manifest.manifestCid, version.manifestCid):
        return Err[bool](" tailnet train island: writeback manifest cid mismatch")
    let storeBlobRes = runtime.ContentRuntimeStoreBlobPayload(localRuntime, summary.blobCid, mergedBlob)
    if IsErr(storeBlobRes):
        return Err[bool](Error(storeBlobRes))
    let storeManifestRes = runtime.ContentRuntimeStoreManifest(localRuntime, manifest)
    if IsErr(storeManifestRes):
        return Err[bool](Error(storeManifestRes))
    for i in 0..<manifest.shardCount:
        let requestRes = swarm.ErasureShardPullRequestMake(manifest, manifest.shardIndices[i])
        if IsErr(requestRes):
            return Err[bool](Error(requestRes))
        let responseRes = swarm.ErasureShardPullResponseMake(Value(requestRes),
                                                               shardPayloads[manifest.shardIndices[i]])
        if IsErr(responseRes):
            return Err[bool](Error(responseRes))
        let storeShardRes = runtime.ContentRuntimeStoreShardResponse(localRuntime, Value(responseRes))
        if IsErr(storeShardRes):
            return Err[bool](Error(storeShardRes))
    return TailnetTrainIslandCheckpointWritebackRecord(out,
                                                         island,
                                                         delta,
                                                         version,
                                                         manifest)

fn TailnetTrainIslandCheckpointPublishFill(out: var TailnetCheckpointVersion,
                                             island: var TailnetTrainIsland,
                                             group: var TailnetTrainWorkerGroup,
                                             globalStep: int32,
                                             publisherPeerId: types.Libp2pPeerId,
                                             stub: var content.ContentStub,
                                             manifestCid: layout.FixedBytes32,
                                             blobCid: layout.FixedBytes32,
                                             params: swarm.ErasureEncodingParams,
                                             optimizerStateCid: layout.FixedBytes32,
                                             optimizerPayloadLen: int32): Result[bool] =
    if globalStep < 0:
        return Err[bool](" tailnet train island: global step")
    let jobBundleCid = stub.bundleCid
    if layout.FixedBytes32Equal(jobBundleCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: job bundle cid missing")
    if layout.FixedBytes32Equal(optimizerStateCid, layout.FixedBytes32()):
        return Err[bool](" tailnet train island: checkpoint optimizer cid missing")
    if optimizerPayloadLen <= 0:
        return Err[bool](" tailnet train island: checkpoint optimizer payload len")
    let groupPos = TailnetTrainIslandGroupPos(island, group.rendezvousCid)
    if groupPos < 0:
        return Err[bool](" tailnet train island: worker group missing")
    if !island.groups[groupPos].sealed:
        return Err[bool](" tailnet train island: worker group not sealed")
    var publisherPeerFound = false
    for i in 0..<island.groups[groupPos].members.len:
        if types.Libp2pPeerIdEqual(island.groups[groupPos].members[i].peerId, publisherPeerId):
            publisherPeerFound = true
            break
    if !publisherPeerFound:
        return Err[bool](" tailnet train island: publisher peer missing")
    var prevVersionCid = layout.FixedBytes32()
    var surfacePos = -1
    for i in 0..<island.checkpoints.len:
        if layout.FixedBytes32Equal(island.checkpoints[i].jobBundleCid, jobBundleCid):
            surfacePos = i
            break
    if surfacePos >= 0:
        let latest = island.checkpoints[surfacePos].latestVersion
        if !layout.FixedBytes32Equal(latest.versionCid, layout.FixedBytes32()):
            if globalStep <= latest.globalStep:
                return Err[bool](" tailnet train island: checkpoint step not advancing")
            prevVersionCid = latest.versionCid
        else:
            prevVersionCid = island.checkpoints[surfacePos].latestVersionCid
    if !layout.FixedBytes32Equal(prevVersionCid, layout.FixedBytes32()):
        if !types.Libp2pPeerIdEqual(island.groups[groupPos].leaderPeerId, publisherPeerId):
            return Err[bool](" tailnet train island: checkpoint publisher not leader")
        var barrierPos = -1
        for i in 0..<island.stepBarriers.len:
            if !layout.FixedBytes32Equal(island.stepBarriers[i].rendezvousCid,
                                         island.groups[groupPos].rendezvousCid):
                continue
            if !layout.FixedBytes32Equal(island.stepBarriers[i].parentVersionCid, prevVersionCid):
                continue
            if island.stepBarriers[i].globalStep == globalStep:
                barrierPos = i
                break
        if barrierPos < 0:
            return Err[bool](" tailnet train island: checkpoint step barrier missing")
        let barrier = island.stepBarriers[barrierPos]
        if !(barrier.sealed && barrier.arrivedCount == barrier.expectedMemberCount):
            return Err[bool](" tailnet train island: checkpoint step barrier not ready")
        var roundPos = -1
        for i in 0..<island.mergeRounds.len:
            if !layout.FixedBytes32Equal(island.mergeRounds[i].rendezvousCid,
                                         island.groups[groupPos].rendezvousCid):
                continue
            if !layout.FixedBytes32Equal(island.mergeRounds[i].parentVersionCid, prevVersionCid):
                continue
            if island.mergeRounds[i].globalStep == globalStep:
                roundPos = i
                break
        if roundPos < 0:
            return Err[bool](" tailnet train island: checkpoint merge round missing")
        let round = island.mergeRounds[roundPos]
        if !(round.sealed && round.acceptedCount == round.expectedMemberCount):
            return Err[bool](" tailnet train island: checkpoint merge round not ready")
        var leaderContributionFound = false
        for i in 0..<round.contributions.len:
            if types.Libp2pPeerIdEqual(round.contributions[i].peerId, publisherPeerId):
                leaderContributionFound = true
                break
        if !leaderContributionFound:
            return Err[bool](" tailnet train island: checkpoint leader contribution missing")
    out.versionEpochSeconds = times.EpochTimeSeconds()
    out.globalStep = globalStep
    out.publisherPeerId = publisherPeerId
    out.jobBundleCid = jobBundleCid
    out.stubCid = stub.stubCid
    out.blobSummaryCid = stub.blobSummaryCid
    out.payloadLen = stub.payloadLen
    out.manifestCid = manifestCid
    out.blobCid = blobCid
    out.paramsCid = params.paramsCid
    out.layoutKind = params.layoutKind
    out.dataShardCount = params.dataShardCount
    out.parityShardCount = params.parityShardCount
    out.shardPayloadBytes = params.shardPayloadBytes
    out.optimizerStateCid = optimizerStateCid
    out.optimizerPayloadLen = optimizerPayloadLen
    out.prevVersionCid = prevVersionCid
    out.versionCid = TailnetCheckpointVersionCid(jobBundleCid,
                                                   globalStep,
                                                   publisherPeerId,
                                                   out.stubCid,
                                                   manifestCid,
                                                   blobCid,
                                                   optimizerStateCid,
                                                   prevVersionCid)
    return TailnetTrainIslandCheckpointVersionAppend(island, out)

fn TailnetTrainIslandCheckpointPublish(out: var TailnetCheckpointVersion,
                                         island: var TailnetTrainIsland,
                                         group: var TailnetTrainWorkerGroup,
                                         globalStep: int32,
                                         publisherPeerId: types.Libp2pPeerId,
                                         stub: var content.ContentStub,
                                         manifestCid: layout.FixedBytes32,
                                         blobCid: layout.FixedBytes32,
                                         params: swarm.ErasureEncodingParams,
                                         optimizerStateCid: layout.FixedBytes32,
                                         optimizerPayloadLen: int32): bool =
    let res = TailnetTrainIslandCheckpointPublishFill(out,
                                                        island,
                                                        group,
                                                        globalStep,
                                                        publisherPeerId,
                                                        stub,
                                                        manifestCid,
                                                        blobCid,
                                                        params,
                                                        optimizerStateCid,
                                                        optimizerPayloadLen)
    return IsOk(res)

fn TailnetTrainIslandCheckpointPublishRejected(out: var TailnetCheckpointVersion,
                                                 island: var TailnetTrainIsland,
                                                 group: var TailnetTrainWorkerGroup,
                                                 globalStep: int32,
                                                 publisherPeerId: types.Libp2pPeerId,
                                                 stub: var content.ContentStub,
                                                 manifestCid: layout.FixedBytes32,
                                                 blobCid: layout.FixedBytes32,
                                                 params: swarm.ErasureEncodingParams,
                                                 optimizerStateCid: layout.FixedBytes32,
                                                 optimizerPayloadLen: int32): bool =
    let res = TailnetTrainIslandCheckpointPublishFill(out,
                                                        island,
                                                        group,
                                                        globalStep,
                                                        publisherPeerId,
                                                        stub,
                                                        manifestCid,
                                                        blobCid,
                                                        params,
                                                        optimizerStateCid,
                                                        optimizerPayloadLen)
    return IsErr(res)

fn TailnetTrainIslandSelfTestBlob(parts: Bytes[]): Bytes =
    var total = 0
    for i in 0..<parts.len:
        total = total + bytesLen(parts[i])
    var buf = layout.ByteBufInit(total)
    for i in 0..<parts.len:
        layout.ByteBufAppendBytes(buf, parts[i])
    return layout.ByteBufToBytes(buf)

fn TailnetTrainIslandSelfTestSeedCheckpointVersionFill(out: var TailnetCheckpointVersion,
                                                         runtimeState: var runtime.ContentRuntime,
                                                         jobBundleCid: layout.FixedBytes32,
                                                         publisherPeerId: types.Libp2pPeerId,
                                                         globalStep: int32,
                                                         prevVersionCid: layout.FixedBytes32,
                                                         blob: Bytes,
                                                         versionEpochSeconds: int64): Result[bool] =
    let paramsRes = swarm.ErasureEncodingParamsMake(swarm.ErasureLayoutRsSystematic, 4, 0, 8)
    if IsErr(paramsRes):
        echo(" tailnet train island seed: params")
        return Err[bool](Error(paramsRes))
    let params = Value(paramsRes)
    let summaryRes = dag.DagBlobSummaryFromBytes(blob, params.shardPayloadBytes)
    if IsErr(summaryRes):
        echo(" tailnet train island seed: summary")
        return Err[bool](Error(summaryRes))
    let summary = Value(summaryRes)
    let shardPayloadsRes = swarm.ErasureEncodeShardPayloads(blob, params)
    if IsErr(shardPayloadsRes):
        echo(" tailnet train island seed: encode shards")
        return Err[bool](Error(shardPayloadsRes))
    let shardPayloads = Value(shardPayloadsRes)
    var shardPayloadCids: layout.FixedBytes32[]
    shardPayloadCids = []
    for i in 0..<shardPayloads.len:
        add(shardPayloadCids, layout.FixedBytes32())
    for i in 0..<shardPayloads.len:
        shardPayloadCids[i] = swarm.ErasureShardPayloadCid(shardPayloads[i])
    let manifestRes = swarm.ErasureShardManifestMake(summary.blobCid,
                                                       summary.payloadLen,
                                                       params,
                                                       shardPayloadCids)
    if IsErr(manifestRes):
        echo(" tailnet train island seed: manifest")
        return Err[bool](Error(manifestRes))
    let manifest = Value(manifestRes)
    let storeBlobRes = runtime.ContentRuntimeStoreBlobPayload(runtimeState, summary.blobCid, blob)
    if IsErr(storeBlobRes):
        echo(" tailnet train island seed: store blob")
        return Err[bool](Error(storeBlobRes))
    let storeManifestRes = runtime.ContentRuntimeStoreManifest(runtimeState, manifest)
    if IsErr(storeManifestRes):
        echo(" tailnet train island seed: store manifest")
        return Err[bool](Error(storeManifestRes))
    for i in 0..<manifest.shardCount:
        let requestRes = swarm.ErasureShardPullRequestMake(manifest, manifest.shardIndices[i])
        if IsErr(requestRes):
            echo(" tailnet train island seed: request")
            return Err[bool](Error(requestRes))
        let responseRes = swarm.ErasureShardPullResponseMake(Value(requestRes),
                                                               shardPayloads[manifest.shardIndices[i]])
        if IsErr(responseRes):
            echo(" tailnet train island seed: response")
            return Err[bool](Error(responseRes))
        let storeShardRes = runtime.ContentRuntimeStoreShardResponse(runtimeState, Value(responseRes))
        if IsErr(storeShardRes):
            echo(" tailnet train island seed: store shard")
            return Err[bool](Error(storeShardRes))
    out = TailnetCheckpointVersion()
    out.versionEpochSeconds = versionEpochSeconds
    out.globalStep = globalStep
    out.publisherPeerId = publisherPeerId
    out.jobBundleCid = jobBundleCid
    out.stubCid = lt.HashInts("cheng.tailnet.train.stub", [globalStep, bytesLen(blob)])
    out.blobSummaryCid = summary.summaryCid
    out.payloadLen = summary.payloadLen
    out.manifestCid = manifest.manifestCid
    out.blobCid = summary.blobCid
    out.paramsCid = params.paramsCid
    out.layoutKind = params.layoutKind
    out.dataShardCount = params.dataShardCount
    out.parityShardCount = params.parityShardCount
    out.shardPayloadBytes = params.shardPayloadBytes
    out.prevVersionCid = prevVersionCid
    out.versionCid = TailnetCheckpointVersionCid(jobBundleCid,
                                                   globalStep,
                                                   publisherPeerId,
                                                   out.stubCid,
                                                   out.manifestCid,
                                                   out.blobCid,
                                                   out.optimizerStateCid,
                                                   prevVersionCid)
    return Ok[bool](true)

fn TailnetTrainIslandSelfTest(): int32 =
    let now = times.EpochTimeSeconds()
    let jobBundleCid = lt.HashInts("cheng.tailnet.train.job", [1])
    var island = TailnetTrainIslandInit("tailnet.train.selftest")
    var request: scheduler.Libp2pWorkloadRequest
    request.workloadKind = scheduler.Libp2pWorkloadTrain
    var rendezvous = TailnetTrainRendezvous()
    let rendezvousRes = TailnetTrainIslandOpenRendezvousFill(rendezvous,
                                                               island,
                                                               jobBundleCid,
                                                               2,
                                                               request,
                                                               now + 600)
    if IsErr(rendezvousRes):
        echo(" tailnet train island self-test: rendezvous")
        return 1
    var leaderPeerId: types.Libp2pPeerId
    peer_id.Libp2pPeerIdFillFromSeed(leaderPeerId, "tailnet.train.worker.a")
    var workerPeerId: types.Libp2pPeerId
    peer_id.Libp2pPeerIdFillFromSeed(workerPeerId, "tailnet.train.worker.b")
    var group = TailnetTrainWorkerGroup()
    group.rendezvousCid = rendezvous.rendezvousCid
    group.leaderPeerId = leaderPeerId
    var leaderMember = TailnetTrainWorkerMember()
    leaderMember.peerId = leaderPeerId
    leaderMember.roleKind = TailnetTrainRoleLeader
    leaderMember.joinedAtEpochSeconds = now
    add(group.members, leaderMember)
    var workerMember = TailnetTrainWorkerMember()
    workerMember.peerId = workerPeerId
    workerMember.roleKind = TailnetTrainRoleWorker
    workerMember.joinedAtEpochSeconds = now
    add(group.members, workerMember)
    group.memberCount = group.members.len
    let sealRes = TailnetTrainIslandSealWorkerGroup(island, group)
    if IsErr(sealRes):
        echo(" tailnet train island self-test: seal group")
        return 1
    let sealedGroup = island.groups[0]
    var leaderRuntime = runtime.ContentRuntimeInit()
    var workerRuntime = runtime.ContentRuntimeInit()
    let optim1 = bytesFromString("optim=1111")
    let optim1Cid = dag.DagBlobCidFromBytes(optim1)
    let optim1PayloadLen = bytesLen(optim1)
    let blob1 = TailnetTrainIslandSelfTestBlob([bytesFromString("step-10|"),
                                                  bytesFromString("weights=aaaa|"),
                                                  optim1])
    var version1 = TailnetCheckpointVersion()
    let seed1Res = TailnetTrainIslandSelfTestSeedCheckpointVersionFill(version1,
                                                                         leaderRuntime,
                                                                         jobBundleCid,
                                                                         leaderPeerId,
                                                                         10,
                                                                         layout.FixedBytes32(),
                                                                         blob1,
                                                                         now)
    if IsErr(seed1Res):
        echo(" tailnet train island self-test: seed version1")
        return 1
    version1.optimizerStateCid = optim1Cid
    version1.optimizerPayloadLen = optim1PayloadLen
    version1.versionCid = TailnetCheckpointVersionCid(jobBundleCid,
                                                        version1.globalStep,
                                                        version1.publisherPeerId,
                                                        version1.stubCid,
                                                        version1.manifestCid,
                                                        version1.blobCid,
                                                        version1.optimizerStateCid,
                                                        version1.prevVersionCid)
    let append1Res = TailnetTrainIslandCheckpointVersionAppend(island, version1)
    if IsErr(append1Res):
        echo(" tailnet train island self-test: append version1")
        return 1
    var lease20Leader = TailnetTrainWorkerLease()
    let lease20LeaderRes = TailnetTrainIslandGrantWorkerLeaseFill(lease20Leader,
                                                                    island,
                                                                    sealedGroup,
                                                                    leaderPeerId,
                                                                    version1.versionCid,
                                                                    20,
                                                                    120)
    if IsErr(lease20LeaderRes):
        echo(" tailnet train island self-test: lease20 leader")
        return 1
    var lease20Worker = TailnetTrainWorkerLease()
    let lease20WorkerRes = TailnetTrainIslandGrantWorkerLeaseFill(lease20Worker,
                                                                    island,
                                                                    sealedGroup,
                                                                    workerPeerId,
                                                                    version1.versionCid,
                                                                    20,
                                                                    120)
    if IsErr(lease20WorkerRes):
        echo(" tailnet train island self-test: lease20 worker")
        return 1
    var roundPeerIds: types.Libp2pPeerId[]
    roundPeerIds = [leaderPeerId, workerPeerId]
    let barrier20GroupPos = TailnetTrainIslandGroupPos(island, sealedGroup.rendezvousCid)
    if barrier20GroupPos < 0:
        echo(" tailnet train island self-test: barrier20 group")
        return 1
    let barrier20ParentRes = TailnetTrainIslandCheckpointParentValidate(island,
                                                                          sealedGroup,
                                                                          version1.versionCid,
                                                                          20)
    if IsErr(barrier20ParentRes):
        echo(" tailnet train island self-test: barrier20 parent")
        return 1
    if island.stepBarriers.len != 0:
        echo(" tailnet train island self-test: barrier20 stepBarriers len")
        return 1
    if island.mergeRounds.len != 0:
        echo(" tailnet train island self-test: barrier20 mergeRounds len")
        return 1
    if island.stepBarriers.len > 0:
        if TailnetTrainIslandStepBarrierPos(island,
                                              sealedGroup.rendezvousCid,
                                              version1.versionCid,
                                              20) >= 0:
            echo(" tailnet train island self-test: barrier20 duplicate")
            return 1
    let barrier20Expected = TailnetTrainIslandBarrierExpectedMembers(island,
                                                                       sealedGroup,
                                                                       version1.versionCid,
                                                                       20)
    if barrier20Expected <= 0:
        echo(" tailnet train island self-test: barrier20 lease missing")
        return 1
    var barrier20 = TailnetTrainStepBarrier()
    let openBarrier20Res = TailnetTrainIslandOpenStepBarrierFill(barrier20,
                                                                   island,
                                                                   sealedGroup.rendezvousCid,
                                                                   version1.versionCid,
                                                                   20)
    if IsErr(openBarrier20Res):
        echo(" tailnet train island self-test: barrier20 open")
        return 1
    let arriveBarrier20LeaderRes = TailnetTrainIslandArriveStepBarrierFill(barrier20,
                                                                              island,
                                                                              sealedGroup.rendezvousCid,
                                                                              leaderPeerId,
                                                                              version1.versionCid,
                                                                              20)
    if IsErr(arriveBarrier20LeaderRes):
        echo(" tailnet train island self-test: barrier20 leader")
        return 1
    let arriveBarrier20WorkerRes = TailnetTrainIslandArriveStepBarrierFill(barrier20,
                                                                              island,
                                                                              sealedGroup.rendezvousCid,
                                                                              workerPeerId,
                                                                              version1.versionCid,
                                                                              20)
    if IsErr(arriveBarrier20WorkerRes):
        echo(" tailnet train island self-test: barrier20 worker")
        return 1
    if !TailnetTrainStepBarrierReady(barrier20):
        echo(" tailnet train island self-test: barrier20 ready")
        return 1
    let round20LeaderOptim = bytesFromString("optim.workerA=2020")
    let round20LeaderOptimCid = dag.DagBlobCidFromBytes(round20LeaderOptim)
    let round20WorkerOptim = bytesFromString("optim.workerB=2020")
    let round20WorkerOptimCid = dag.DagBlobCidFromBytes(round20WorkerOptim)
    let optim2 = bytesFromString("optim=2222")
    let optim2Cid = dag.DagBlobCidFromBytes(optim2)
    let optim2PayloadLen = bytesLen(optim2)
    let blob2 = TailnetTrainIslandSelfTestBlob([bytesFromString("step-20|"),
                                                  bytesFromString("weights=aaZZ|"),
                                                  optim2])
    var version2 = TailnetCheckpointVersion()
    let seed2Res = TailnetTrainIslandSelfTestSeedCheckpointVersionFill(version2,
                                                                         leaderRuntime,
                                                                         jobBundleCid,
                                                                         leaderPeerId,
                                                                         20,
                                                                         version1.versionCid,
                                                                         blob2,
                                                                         now + 1)
    if IsErr(seed2Res):
        echo(" tailnet train island self-test: seed version2")
        return 1
    version2.optimizerStateCid = optim2Cid
    version2.optimizerPayloadLen = optim2PayloadLen
    version2.versionCid = TailnetCheckpointVersionCid(jobBundleCid,
                                                        version2.globalStep,
                                                        version2.publisherPeerId,
                                                        version2.stubCid,
                                                        version2.manifestCid,
                                                        version2.blobCid,
                                                        version2.optimizerStateCid,
                                                        version2.prevVersionCid)
    var merge20OptimizerCids: layout.FixedBytes32[]
    merge20OptimizerCids = [round20LeaderOptimCid, round20WorkerOptimCid]
    var merge20OptimizerLens: int32[]
    merge20OptimizerLens = [bytesLen(round20LeaderOptim), bytesLen(round20WorkerOptim)]
    var merge20 = TailnetTrainMergeRound()
    let merge20Res = TailnetTrainIslandMergeRoundAdvanceFill(merge20,
                                                               island,
                                                               sealedGroup.rendezvousCid,
                                                               version1.versionCid,
                                                               20,
                                                               roundPeerIds,
                                                               merge20OptimizerCids,
                                                               merge20OptimizerLens)
    if IsErr(merge20Res):
        echo(" tailnet train island self-test: merge20")
        return 1
    if types.Libp2pPeerIdEqual(workerPeerId, sealedGroup.leaderPeerId):
        echo(" tailnet train island self-test: non leader role")
        return 1
    let append2Res = TailnetTrainIslandCheckpointVersionAppend(island, version2)
    if IsErr(append2Res):
        echo(" tailnet train island self-test: append20")
        return 1
    var lease30Leader = TailnetTrainWorkerLease()
    let lease30LeaderRes = TailnetTrainIslandGrantWorkerLeaseFill(lease30Leader,
                                                                    island,
                                                                    sealedGroup,
                                                                    leaderPeerId,
                                                                    version2.versionCid,
                                                                    30,
                                                                    120)
    if IsErr(lease30LeaderRes):
        echo(" tailnet train island self-test: lease30 leader")
        return 1
    var lease30Worker = TailnetTrainWorkerLease()
    let lease30WorkerRes = TailnetTrainIslandGrantWorkerLeaseFill(lease30Worker,
                                                                    island,
                                                                    sealedGroup,
                                                                    workerPeerId,
                                                                    version2.versionCid,
                                                                    30,
                                                                    120)
    if IsErr(lease30WorkerRes):
        echo(" tailnet train island self-test: lease30 worker")
        return 1
    var barrier30 = TailnetTrainStepBarrier()
    let barrier30Res = TailnetTrainIslandStepBarrierAdvanceFill(barrier30,
                                                                  island,
                                                                  sealedGroup.rendezvousCid,
                                                                  version2.versionCid,
                                                                  30,
                                                                  roundPeerIds)
    if IsErr(barrier30Res):
        echo(" tailnet train island self-test: barrier30")
        return 1
    let round30LeaderOptim = bytesFromString("optim.workerA=3030")
    let round30LeaderOptimCid = dag.DagBlobCidFromBytes(round30LeaderOptim)
    let round30WorkerOptim = bytesFromString("optim.workerB=3030")
    let round30WorkerOptimCid = dag.DagBlobCidFromBytes(round30WorkerOptim)
    var merge30OptimizerCids: layout.FixedBytes32[]
    merge30OptimizerCids = [round30LeaderOptimCid, round30WorkerOptimCid]
    var merge30OptimizerLens: int32[]
    merge30OptimizerLens = [bytesLen(round30LeaderOptim), bytesLen(round30WorkerOptim)]
    var merge30 = TailnetTrainMergeRound()
    let merge30Res = TailnetTrainIslandMergeRoundAdvanceFill(merge30,
                                                               island,
                                                               sealedGroup.rendezvousCid,
                                                               version2.versionCid,
                                                               30,
                                                               roundPeerIds,
                                                               merge30OptimizerCids,
                                                               merge30OptimizerLens)
    if IsErr(merge30Res):
        echo(" tailnet train island self-test: merge30")
        return 1
    let optim3 = bytesFromString("optim=3333")
    let optim3Cid = dag.DagBlobCidFromBytes(optim3)
    let optim3PayloadLen = bytesLen(optim3)
    let blob3 = TailnetTrainIslandSelfTestBlob([bytesFromString("step-30|"),
                                                  bytesFromString("weights=bbYY|"),
                                                  optim3])
    var version3 = TailnetCheckpointVersion()
    let seed3Res = TailnetTrainIslandSelfTestSeedCheckpointVersionFill(version3,
                                                                         workerRuntime,
                                                                         jobBundleCid,
                                                                         leaderPeerId,
                                                                         30,
                                                                         version2.versionCid,
                                                                         blob3,
                                                                         now + 2)
    if IsErr(seed3Res):
        echo(" tailnet train island self-test: seed version3")
        return 1
    version3.optimizerStateCid = optim3Cid
    version3.optimizerPayloadLen = optim3PayloadLen
    version3.versionCid = TailnetCheckpointVersionCid(jobBundleCid,
                                                        version3.globalStep,
                                                        version3.publisherPeerId,
                                                        version3.stubCid,
                                                        version3.manifestCid,
                                                        version3.blobCid,
                                                        version3.optimizerStateCid,
                                                        version3.prevVersionCid)
    let append3Res = TailnetTrainIslandCheckpointVersionAppend(island, version3)
    if IsErr(append3Res):
        echo(" tailnet train island self-test: append30")
        return 1
    var history: TailnetCheckpointVersion[]
    if !TailnetTrainIslandCheckpointHistoryFill(history, island, jobBundleCid):
        echo(" tailnet train island self-test: history")
        return 1
    if history.len != 3:
        echo(" tailnet train island self-test: history len")
        return 1
    var latest = TailnetCheckpointVersion()
    if !TailnetTrainIslandCheckpointLatestFill(latest, island, jobBundleCid):
        echo(" tailnet train island self-test: latest")
        return 1
    if !layout.FixedBytes32Equal(latest.versionCid, version3.versionCid):
        echo(" tailnet train island self-test: latest version")
        return 1
    var lineage: TailnetCheckpointVersion[]
    let lineageRes = TailnetTrainIslandCheckpointLatestLineageFill(lineage, island, jobBundleCid)
    if IsErr(lineageRes):
        echo(" tailnet train island self-test: lineage")
        return 1
    if lineage.len != 3:
        echo(" tailnet train island self-test: lineage len")
        return 1
    let staleParentRes = TailnetTrainIslandCheckpointParentValidate(island,
                                                                      sealedGroup,
                                                                      version1.versionCid,
                                                                      40)
    if !IsErr(staleParentRes):
        echo(" tailnet train island self-test: stale parent")
        return 1
    echo(" tailnet_train_island_smoke ok")
    return 0
