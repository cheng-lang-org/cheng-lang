import std/system
import std/strings as strings
import cheng/apps/astrology/astrology_calendar_core as cal

type
    AstrologyBaziGuideProfile =
        dayGanIndex: int32
        monthZhiIndex: int32
        yearZhiIndex: int32
        dayMasterStrength: int32 = 1
        wuxingWood: int32
        wuxingFire: int32
        wuxingEarth: int32
        wuxingMetal: int32
        wuxingWater: int32

    AstrologyZiweiGuideProfile =
        mingGongIndex: int32
        shenGongIndex: int32
        juNumber: int32 = 4
        relationScore: int32
        careerScore: int32
        wealthScore: int32
        healthScore: int32
        learningScore: int32
        expressionScore: int32
        siHuaScore: int32

    AstrologyDailyGuide =
        hexagramIndex: int32
        hexagramName: str
        upperTrigramIndex: int32
        upperTrigramName: str
        lowerTrigramIndex: int32
        lowerTrigramName: str
        movingLine: int32 = 1
        changedHexagramIndex: int32
        changedHexagramName: str
        actionCode: str
        summary: str
        workAdvice: str
        relationAdvice: str
        moneyAdvice: str
        healthAdvice: str
        learningAdvice: str
        expressionAdvice: str
        riskAdvice: str
        bitPattern: str

fn AstrologyStemElementId(stemIndex: int32): int32 =
    let idx = cal.AstrologyNormalizeMod(stemIndex, 10)
    if idx == 0 || idx == 1: return 0
    if idx == 2 || idx == 3: return 1
    if idx == 4 || idx == 5: return 2
    if idx == 6 || idx == 7: return 3
    return 4

fn AstrologyBranchElementId(branchIndex: int32): int32 =
    let idx = cal.AstrologyNormalizeMod(branchIndex, 12)
    if idx == 2 || idx == 3: return 0
    if idx == 5 || idx == 6: return 1
    if idx == 4 || idx == 7 || idx == 1 || idx == 10: return 2
    if idx == 8 || idx == 9: return 3
    return 4

fn AstrologyElementSupportScore(dayElement: int32, otherElement: int32): int32 =
    let base = cal.AstrologyNormalizeMod(dayElement, 5)
    let other = cal.AstrologyNormalizeMod(otherElement, 5)
    if base == other:
        return 1
    if cal.AstrologyNormalizeMod(other + 1, 5) == base:
        return 2
    if cal.AstrologyNormalizeMod(other + 2, 5) == base:
        return -2
    if cal.AstrologyNormalizeMod(base + 1, 5) == other:
        return -1
    return 0

fn AstrologyBit(value: bool): int32 =
    return value ? 1 : 0

fn AstrologyTrigramName(index: int32): str =
    let idx = cal.AstrologyNormalizeMod(index, 8)
    if idx == 0: return "坤"
    if idx == 1: return "震"
    if idx == 2: return "坎"
    if idx == 3: return "兑"
    if idx == 4: return "艮"
    if idx == 5: return "离"
    if idx == 6: return "巽"
    return "乾"

fn AstrologyTrigramAction(index: int32): str =
    let idx = cal.AstrologyNormalizeMod(index, 8)
    if idx == 0: return "承接整理"
    if idx == 1: return "立即启动"
    if idx == 2: return "排险试探"
    if idx == 3: return "沟通成交"
    if idx == 4: return "止损收口"
    if idx == 5: return "公开表达"
    if idx == 6: return "渗透协商"
    return "定向决断"

fn AstrologyTrigramRisk(index: int32): str =
    let idx = cal.AstrologyNormalizeMod(index, 8)
    if idx == 0: return "拖延失界"
    if idx == 1: return "躁进惊动"
    if idx == 2: return "反复犹疑"
    if idx == 3: return "过度讨好"
    if idx == 4: return "僵住不动"
    if idx == 5: return "虚火上扬"
    if idx == 6: return "摇摆失焦"
    return "刚过其度"

