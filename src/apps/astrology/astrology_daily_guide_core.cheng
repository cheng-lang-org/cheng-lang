fn AstrologyBitPatternText(lowerBit0: int32,
                             lowerBit1: int32,
                             lowerBit2: int32,
                             upperBit0: int32,
                             upperBit1: int32,
                             upperBit2: int32): str =
    return strings.IntToStr(lowerBit0)
        + strings.IntToStr(lowerBit1)
        + strings.IntToStr(lowerBit2)
        + strings.IntToStr(upperBit0)
        + strings.IntToStr(upperBit1)
        + strings.IntToStr(upperBit2)

fn AstrologyDomainAdvice(score: int32, positiveText: str, cautiousText: str, defensiveText: str): str =
    if score >= 2:
        return positiveText + "，窗口明显偏开。"
    if score >= 0:
        return cautiousText + "，宜稳推不要抢节奏。"
    if score <= -2:
        return defensiveText + "，今天不要硬顶。"
    return "先保守推进，留缓冲和回旋。"

fn AstrologyDailyGuideCompute(calendarState: cal.AstrologyCalendarState,
                                bazi: AstrologyBaziGuideProfile,
                                ziwei: AstrologyZiweiGuideProfile): AstrologyDailyGuide =
    let dayElement = AstrologyStemElementId(bazi.dayGanIndex)
    let todayStemElement = AstrologyStemElementId(calendarState.dayGanzhiIndex)
    let todayBranchElement = AstrologyBranchElementId(calendarState.dayGanzhiIndex)
    let hourBranchElement = AstrologyBranchElementId(calendarState.hourGanzhiIndex)
    var todaySupportScore = 0
    todaySupportScore = todaySupportScore + AstrologyElementSupportScore(dayElement, todayStemElement)
    todaySupportScore = todaySupportScore + AstrologyElementSupportScore(dayElement, todayBranchElement)
    todaySupportScore = todaySupportScore + AstrologyElementSupportScore(dayElement, hourBranchElement)
    var relationScore = ziwei.relationScore
    relationScore = relationScore + bazi.wuxingWater + bazi.wuxingWood - bazi.wuxingMetal
    var careerScore = ziwei.careerScore
    careerScore = careerScore + bazi.wuxingWood + bazi.wuxingFire - bazi.wuxingWater
    var moneyScore = ziwei.wealthScore
    moneyScore = moneyScore + bazi.wuxingMetal + bazi.wuxingEarth - bazi.wuxingWood
    var healthBase = 1
    if bazi.dayMasterStrength <= 0:
        healthBase = -1
    var healthScore = ziwei.healthScore
    healthScore = healthScore + healthBase + bazi.wuxingEarth - bazi.wuxingFire
    var learningScore = ziwei.learningScore
    learningScore = learningScore + bazi.wuxingWater + bazi.wuxingMetal - bazi.wuxingFire
    var expressionScore = ziwei.expressionScore
    expressionScore = expressionScore + bazi.wuxingFire + bazi.wuxingWood - bazi.wuxingEarth
    var actionScore = careerScore + expressionScore
    actionScore = actionScore + todaySupportScore - healthScore - learningScore

    let lowerBit0 = AstrologyBit(bazi.dayMasterStrength >= 1)
    let lowerBit1 = AstrologyBit(todaySupportScore >= 0)
    let lowerBit2 = AstrologyBit(relationScore >= 0)
    let upperBit0 = AstrologyBit(careerScore >= 0)
    let upperBit1 = AstrologyBit(ziwei.siHuaScore >= 0)
    let upperBit2 = AstrologyBit(actionScore >= 0)

    let lowerTrigramIndex = lowerBit0 + lowerBit1 * 2 + lowerBit2 * 4
    let upperTrigramIndex = upperBit0 + upperBit1 * 2 + upperBit2 * 4
    let hexagramIndex = lowerTrigramIndex + upperTrigramIndex * 8
    var movingLineBase = calendarState.dayGanzhiIndex + calendarState.hourGanzhiIndex
    movingLineBase = movingLineBase + ziwei.mingGongIndex + ziwei.shenGongIndex
    movingLineBase = movingLineBase + bazi.yearZhiIndex
    let movingLine = cal.AstrologyNormalizeMod(movingLineBase, 6) + 1
    let changedHexagramIndex = hexagramIndex ^ (1 << (movingLine - 1))

    let upperName = AstrologyTrigramName(upperTrigramIndex)
    let lowerName = AstrologyTrigramName(lowerTrigramIndex)
    var primaryAction = "先" + AstrologyTrigramAction(lowerTrigramIndex) + "，再考虑" + AstrologyTrigramAction(upperTrigramIndex)
    if actionScore >= 0:
        primaryAction = AstrologyTrigramAction(upperTrigramIndex) + "，并配合" + AstrologyTrigramAction(lowerTrigramIndex)
    let primaryRisk = AstrologyTrigramRisk(upperTrigramIndex) + "与" + AstrologyTrigramRisk(lowerTrigramIndex)

    var out = AstrologyDailyGuide()
    out.hexagramIndex = hexagramIndex
    out.hexagramName = AstrologyHexagramName(hexagramIndex)
    out.upperTrigramIndex = upperTrigramIndex
    out.upperTrigramName = upperName
    out.lowerTrigramIndex = lowerTrigramIndex
    out.lowerTrigramName = lowerName
    out.movingLine = movingLine
    out.changedHexagramIndex = changedHexagramIndex
    out.changedHexagramName = AstrologyHexagramName(changedHexagramIndex)
    out.actionCode = "内收校准"
    if actionScore >= 0:
        out.actionCode = "外放推进"
    out.bitPattern = AstrologyBitPatternText(lowerBit0, lowerBit1, lowerBit2, upperBit0, upperBit1, upperBit2)
    var summaryText = "今日映射卦为" + out.hexagramName
    summaryText = summaryText + "（" + upperName + "上" + lowerName + "下），动爻第"
    summaryText = summaryText + strings.IntToStr(movingLine)
    summaryText = summaryText + "爻，变卦" + out.changedHexagramName
    summaryText = summaryText + "。宜" + primaryAction
    summaryText = summaryText + "；忌" + primaryRisk + "。"
    out.summary = summaryText
    out.workAdvice = AstrologyDomainAdvice(careerScore,
                                             "工作上可直接推进关键节点",
                                             "工作上先排优先级再推进",
                                             "工作上先止损复盘和补漏洞")
    out.relationAdvice = AstrologyDomainAdvice(relationScore,
                                                 "关系上适合谈清合作与边界",
                                                 "关系上宜柔和沟通",
                                                 "关系上少争高下，先降温")
    out.moneyAdvice = AstrologyDomainAdvice(moneyScore,
                                              "财务上可做确认成交与回款",
                                              "财务上先核对条款和现金流",
                                              "财务上避免激进下注和情绪交易")
    out.healthAdvice = AstrologyDomainAdvice(healthScore,
                                               "身体节律较顺，适合按计划执行",
                                               "身体节律一般，注意留体力",
                                               "身体节律偏紧，先睡眠和减压")
    out.learningAdvice = AstrologyDomainAdvice(learningScore,
                                                 "学习上适合集中啃硬点",
                                                 "学习上适合整理笔记和复盘",
                                                 "学习上不要贪多，先收口")
    out.expressionAdvice = AstrologyDomainAdvice(expressionScore,
                                                   "表达上适合公开发布和演示",
                                                   "表达上适合小范围试讲",
                                                   "表达上先改稿，避免正面硬碰")
    var riskText = "今日时间状态为" + calendarState.dayGanzhiText
    riskText = riskText + "日 " + calendarState.hourGanzhiText
    riskText = riskText + "时。重点风险：" + primaryRisk + "。"
    out.riskAdvice = riskText
    return out
