    if idx == 12: return "小过"
    if idx == 13: return "丰"
    if idx == 14: return "恒"
    if idx == 15: return "大壮"
    if idx == 16: return "比"
    if idx == 17: return "屯"
    if idx == 18: return "坎"
    if idx == 19: return "节"
    if idx == 20: return "蹇"
    if idx == 21: return "既济"
    if idx == 22: return "井"
    if idx == 23: return "需"
    if idx == 24: return "萃"
    if idx == 25: return "随"
    if idx == 26: return "困"
    if idx == 27: return "兑"
    if idx == 28: return "咸"
    if idx == 29: return "革"
    if idx == 30: return "大过"
    if idx == 31: return "夬"
    if idx == 32: return "剥"
    if idx == 33: return "颐"
    if idx == 34: return "蒙"
    if idx == 35: return "损"
    if idx == 36: return "艮"
    if idx == 37: return "贲"
    if idx == 38: return "蛊"
