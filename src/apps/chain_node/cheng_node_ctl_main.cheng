fn ChengNodeCtlOracleSubmitText(rootSeed: str,
                                  statePath: str): Result[str] =
    let roundRes = ChengNodeCtlRequireInt64Flag("--round")
    if IsErr(roundRes):
        return Err[str](Error(roundRes))
    let pairRes = ChengNodeCtlRequireTextFlag("--pair")
    if IsErr(pairRes):
        return Err[str](Error(pairRes))
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let submitRes = node.ChengNodeOracleSubmitFixtureRound(core, Value(roundRes))
    if IsErr(submitRes):
        return Err[str](Error(submitRes))
    let writeRes = state.ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    let queryRes = node.ChengNodeOracleQueryText(core, Value(pairRes), ChengNodeCtlWithDelta())
    if IsErr(queryRes):
        return Err[str](Error(queryRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + Value(queryRes)
    return Ok[str](out)

fn ChengNodeCtlOracleText(rootSeed: str,
                            statePath: str): Result[str] =
