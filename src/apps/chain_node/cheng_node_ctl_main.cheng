    var out = ""
    out = out + "report_path=" + ChengNodeCtlAbsolutePath(reportPath) + "\n"
    out = out + "state_path=" + ChengNodeCtlAbsolutePath(statePath) + "\n"
    out = out + "receipt_key=" + receiptKey + "\n"
    out = out + "target=" + receipt.targetTriple + "\n"
