fn ChengNodeCtlDilocoDeltaText(rootSeed: str,
                                 statePath: str): Result[str] =
    let jobRes = ChengNodeCtlRequireTextFlag("--job")
    if IsErr(jobRes):
        return Err[str](Error(jobRes))
    let peerSeedRes = ChengNodeCtlRequireTextFlag("--peer-seed")
    if IsErr(peerSeedRes):
        return Err[str](Error(peerSeedRes))
    let sampleRes = ChengNodeCtlRequireInt32Flag("--samples")
    if IsErr(sampleRes):
        return Err[str](Error(sampleRes))
    let tokenRes = ChengNodeCtlRequireInt32Flag("--tokens")
    if IsErr(tokenRes):
        return Err[str](Error(tokenRes))
    let innerStepsRes = ChengNodeCtlRequireInt32Flag("--inner-steps")
    if IsErr(innerStepsRes):
        return Err[str](Error(innerStepsRes))
    let weightNumRes = ChengNodeCtlRequireInt32Flag("--weight-num")
    if IsErr(weightNumRes):
        return Err[str](Error(weightNumRes))
    let weightDenRes = ChengNodeCtlRequireInt32Flag("--weight-den")
    if IsErr(weightDenRes):
        return Err[str](Error(weightDenRes))
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let deltaRes = node.ChengNodeDilocoSubmitOuterDelta(core,
                                                          Value(jobRes),
                                                          Value(peerSeedRes),
                                                          Value(sampleRes),
                                                          Value(tokenRes),
                                                          Value(innerStepsRes),
                                                          Value(weightNumRes),
                                                          Value(weightDenRes))
    if IsErr(deltaRes):
        return Err[str](Error(deltaRes))
    let writeRes = state.ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    let statusRes = node.ChengNodeDilocoStatusText(core, Value(jobRes))
    if IsErr(statusRes):
        return Err[str](Error(statusRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + Value(statusRes)
    return Ok[str](out)

fn ChengNodeCtlDilocoMergeText(rootSeed: str,
                                 statePath: str): Result[str] =
    let jobRes = ChengNodeCtlRequireTextFlag("--job")
    if IsErr(jobRes):
        return Err[str](Error(jobRes))
    var leaderSeed = ChengNodeCtlFlagOrDefault("--leader-seed", "")
    if len(leaderSeed) <= 0:
        leaderSeed = ChengNodeCtlFlagOrDefault("--peer-seed", "")
    if len(leaderSeed) <= 0:
        return Err[str]("cheng_node: missing --leader-seed")
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let mergeRes = node.ChengNodeDilocoPublishMerge(core,
                                                      Value(jobRes),
                                                      leaderSeed)
    if IsErr(mergeRes):
        return Err[str](Error(mergeRes))
    let writeRes = state.ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    let statusRes = node.ChengNodeDilocoStatusText(core, Value(jobRes))
    if IsErr(statusRes):
        return Err[str](Error(statusRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + Value(statusRes)
