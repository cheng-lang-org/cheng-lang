    return Ok[str](out)

fn ChengNodeCtlVerifyCompilerReceiptText(rootSeed: str,
                                           statePath: str,
                                           reportPath: str,
                                           receiptKey: str): Result[str] =
    let actualRes = ChengNodeCtlLoadRemoteNode(rootSeed, statePath)
    if IsErr(actualRes):
        return Err[str](Error(actualRes))
    var actual = Value(actualRes)
    return ChengNodeCtlVerifyCompilerReceiptOnNodeText(actual,
                                                         statePath,
                                                         reportPath,
                                                         receiptKey)

fn ChengNodeCtlAnnounceText(rootSeed: str,
                              statePath: str): Result[str] =
    let transportRes = ChengNodeCtlRequireTextFlag("--transport")
    if IsErr(transportRes):
        return Err[str](Error(transportRes))
    let hostRes = ChengNodeCtlRequireTextFlag("--host")
    if IsErr(hostRes):
        return Err[str](Error(hostRes))
    let portRes = ChengNodeCtlRequireInt32Flag("--port")
    if IsErr(portRes):
        return Err[str](Error(portRes))
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let announcePeerRes = node.ChengNodeAnnouncePeer(core,
                                                       Value(transportRes),
                                                       Value(hostRes),
                                                       Value(portRes))
    if IsErr(announcePeerRes):
        return Err[str](Error(announcePeerRes))
    let topicText = ChengNodeCtlFlagOrDefault("--topic", "")
    if len(topicText) > 0:
        let announceTopicRes = node.ChengNodeAnnounceDiscovery(core,
                                                                 "topic",
                                                                 topicText,
                                                                 Value(transportRes),
                                                                 Value(hostRes),
                                                                 Value(portRes),
                                                                 "public",
                                                                 "public",
                                                                 100)
        if IsErr(announceTopicRes):
            return Err[str](Error(announceTopicRes))
    let capabilityText = ChengNodeCtlFlagOrDefault("--capability", "")
    if len(capabilityText) > 0:
        let announceCapabilityRes = node.ChengNodeAnnounceDiscovery(core,
                                                                      "capability",
                                                                      capabilityText,
                                                                      Value(transportRes),
                                                                      Value(hostRes),
                                                                      Value(portRes),
                                                                      "public",
                                                                      "public",
                                                                      100)
        if IsErr(announceCapabilityRes):
            return Err[str](Error(announceCapabilityRes))
    let writeRes = state.ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + "peer_id=" + node.ChengNodeLocalPeerIdText(core) + "\n"
    out = out + node.ChengNodeBootstrapSummaryText(core)
    return Ok[str](out)

fn ChengNodeCtlDiscoverKindAndKey(): Result[str[]] =
    let peerText = ChengNodeCtlFlagOrDefault("--peer", "")
    if len(peerText) > 0:
        return Ok[str[]](["peer", peerText])
    let topicText = ChengNodeCtlFlagOrDefault("--topic", "")
    if len(topicText) > 0:
        return Ok[str[]](["topic", topicText])
    let capabilityText = ChengNodeCtlFlagOrDefault("--capability", "")
    if len(capabilityText) > 0:
        return Ok[str[]](["capability", capabilityText])
    return Err[str[]]("cheng_node: missing --peer or --topic or --capability")

fn ChengNodeCtlDiscoverText(rootSeed: str,
                              statePath: str): Result[str] =
    let kindKeyRes = ChengNodeCtlDiscoverKindAndKey()
    if IsErr(kindKeyRes):
        return Err[str](Error(kindKeyRes))
    let kindKey = Value(kindKeyRes)
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let remoteStatePath = ChengNodeCtlFlagOrDefault("--remote-state", "")
    if len(remoteStatePath) > 0:
        let remoteRes = ChengNodeCtlLoadRemoteNode(ChengNodeCtlRemoteRootSeed(), remoteStatePath)
        if IsErr(remoteRes):
            return Err[str](Error(remoteRes))
        var remote = Value(remoteRes)
        let syncRes = node.ChengNodeSyncDiscoveryFromRemote(core, remote, kindKey[0], kindKey[1])
        if IsErr(syncRes):
            return Err[str](Error(syncRes))
        let writeRes = state.ChengNodeWriteState(statePath, core)
        if IsErr(writeRes):
            return Err[str](Error(writeRes))
    return node.ChengNodeKeyedQueryText(core,
                                          "discovery",
                                          kindKey[0],
                                          kindKey[1],
                                          ChengNodeCtlWithDelta())

fn ChengNodeCtlStreamText(rootSeed: str,
                            statePath: str): Result[str] =
    let protocolRes = ChengNodeCtlRequireTextFlag("--protocol")
    if IsErr(protocolRes):
        return Err[str](Error(protocolRes))
    let remoteStateRes = ChengNodeCtlRequireTextFlag("--remote-state")
    if IsErr(remoteStateRes):
        return Err[str](Error(remoteStateRes))
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let remoteRes = ChengNodeCtlLoadRemoteNode(ChengNodeCtlRemoteRootSeed(), Value(remoteStateRes))
    if IsErr(remoteRes):
        return Err[str](Error(remoteRes))
    var remote = Value(remoteRes)
    return node.ChengNodeStreamText(core, remote, Value(protocolRes))

fn ChengNodeCtlVpnPeerText(rootSeed: str,
                             statePath: str): Result[str] =
    let peerRes = ChengNodeCtlRequireTextFlag("--peer")
    if IsErr(peerRes):
        return Err[str](Error(peerRes))
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    var session: tsnet.Libp2pTailnetPeerSession
    session.peerId = Value(peerRes)
    session.remoteTailnetIp = ChengNodeCtlFlagOrDefault("--tailnet-ip", "")
    session.directReachable = ChengNodeCtlFlagOrDefault("--direct", "0") == "1"
    session.relayAllowed = ChengNodeCtlFlagOrDefault("--relay", "0") == "1"
    session.relayOnly = ChengNodeCtlFlagOrDefault("--relay-only", "0") == "1"
    session.derpRegionCode = ChengNodeCtlFlagOrDefault("--derp-region", "")
    session.signedPreface = ChengNodeCtlFlagOrDefault("--signed-preface", "")
    session.boundAddrText = ChengNodeCtlFlagOrDefault("--bound-addr", "")
    session.lastError = ChengNodeCtlFlagOrDefault("--last-error", "")
    let upsertRes = node.ChengNodeVpnUpsertPeer(core, session)
    if IsErr(upsertRes):
        return Err[str](Error(upsertRes))
    let writeRes = state.ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + node.ChengNodeVpnStatusReportText(core)
    return Ok[str](out)

fn ChengNodeCtlVpnRouteText(rootSeed: str,
                              statePath: str): Result[str] =
    let modeRes = ChengNodeCtlRequireTextFlag("--mode")
    if IsErr(modeRes):
        return Err[str](Error(modeRes))
    let keyRes = ChengNodeCtlRequireTextFlag("--key")
    if IsErr(keyRes):
        return Err[str](Error(keyRes))
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    if Value(modeRes) == "overlay":
        let addrTextRes = ChengNodeCtlRequireTextFlag("--addr")
        if IsErr(addrTextRes):
            return Err[str](Error(addrTextRes))
        let addrRes = multiaddr.Libp2pMultiaddrParse(Value(addrTextRes))
        if IsErr(addrRes):
            return Err[str](Error(addrRes))
        let upsertRes = node.ChengNodeVpnUpsertOverlayRoute(core, Value(keyRes), Value(addrRes))
        if IsErr(upsertRes):
            return Err[str](Error(upsertRes))
    else:
        let nameRes = ChengNodeCtlRequireTextFlag("--name")
        if IsErr(nameRes):
            return Err[str](Error(nameRes))
        let hostRes = ChengNodeCtlRequireTextFlag("--host")
        if IsErr(hostRes):
            return Err[str](Error(hostRes))
        let portRes = ChengNodeCtlRequireInt32Flag("--port")
        if IsErr(portRes):
            return Err[str](Error(portRes))
        let serverNameRes = ChengNodeCtlRequireTextFlag("--server-name")
        if IsErr(serverNameRes):
            return Err[str](Error(serverNameRes))
        var cfg: vpncfg.VpnProxyExitConfig
        cfg.name = Value(nameRes)
        cfg.host = Value(hostRes)
        cfg.port = Value(portRes)
        cfg.serverName = Value(serverNameRes)
        let upsertRes = node.ChengNodeVpnUpsertExitRoute(core, Value(keyRes), cfg)
        if IsErr(upsertRes):
            return Err[str](Error(upsertRes))
    let writeRes = state.ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + node.ChengNodeVpnStatusReportText(core)
    return Ok[str](out)

fn ChengNodeCtlVpnStatusText(rootSeed: str,
                               statePath: str): Result[str] =
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadStateInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    return Ok[str](node.ChengNodeVpnStatusReportText(core))

fn ChengNodeCtlPrintUsageAndReturn(code: int32): int32 =
    echo(ChengNodeCtlUsageText())
    return code

fn ChengNodeCtlChainPrintUsageAndReturn(code: int32): int32 =
    echo(ChengNodeCtlChainUsageText())
    return code

fn ChengNodeCtlLibp2pPrintUsageAndReturn(code: int32): int32 =
    echo(ChengNodeCtlLibp2pUsageText())
    return code

fn ChengNodeCtlPrintResultAndReturn(textRes: Result[str]): int32 =
    if IsErr(textRes):
        echo(Error(textRes))
        return 1
    echo(Value(textRes))
    return 0

fn ChengNodeCtlChainCommandAt(commandIndex: int32): int32 =
    let subcmd = ChengNodeCtlWordAt(commandIndex)
    if subcmd == "" || subcmd == "--help" || subcmd == "-h" || subcmd == "help":
        return ChengNodeCtlChainPrintUsageAndReturn(0)
    if subcmd == "init":
        return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlChainInitText())
    if subcmd == "mint":
        return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlChainMintText())
    if subcmd == "transfer":
        return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlChainTransferText())
    if subcmd == "balance":
        return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlChainBalanceText())
    if subcmd == "state":
        let stateSubcmd = ChengNodeCtlWordAt(commandIndex + 1)
        if stateSubcmd == "show":
            return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlChainShowStateText())
        return ChengNodeCtlChainPrintUsageAndReturn(2)
    if subcmd == "snapshot":
        let snapshotSubcmd = ChengNodeCtlWordAt(commandIndex + 1)
        if snapshotSubcmd == "dump":
            return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlChainDumpSnapshotText())
        return ChengNodeCtlChainPrintUsageAndReturn(2)
    if subcmd == "daemon":
        let daemonSubcmd = ChengNodeCtlWordAt(commandIndex + 1)
        if daemonSubcmd == "serve":
            return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlChainServeText())
        if daemonSubcmd == "sync":
            return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlChainSyncText())
        return ChengNodeCtlChainPrintUsageAndReturn(2)
    if subcmd == "self":
        let selfSubcmd = ChengNodeCtlWordAt(commandIndex + 1)
        if selfSubcmd == "test":
            return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlChainSelfTestText())
        return ChengNodeCtlChainPrintUsageAndReturn(2)
    return ChengNodeCtlChainPrintUsageAndReturn(2)

fn ChengNodeCtlLibp2pCommandAt(commandIndex: int32): int32 =
    let subcmd = ChengNodeCtlWordAt(commandIndex)
    if subcmd == "" || subcmd == "--help" || subcmd == "-h" || subcmd == "help":
        return ChengNodeCtlLibp2pPrintUsageAndReturn(0)
    if subcmd == "surface":
        return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlLibp2pSurfaceText(ChengNodeCtlRootSeed(),
                                                                                   ChengNodeCtlStatePath()))
    if subcmd == "head":
        return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlHeadText(ChengNodeCtlRootSeed(),
                                                                          ChengNodeCtlStatePath()))
    if subcmd == "announce":
        return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlAnnounceText(ChengNodeCtlRootSeed(),
                                                                              ChengNodeCtlStatePath()))
    if subcmd == "discover":
        return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlDiscoverText(ChengNodeCtlRootSeed(),
                                                                              ChengNodeCtlStatePath()))
    if subcmd == "stream":
        return ChengNodeCtlPrintResultAndReturn(ChengNodeCtlStreamText(ChengNodeCtlRootSeed(),
                                                                            ChengNodeCtlStatePath()))
    return ChengNodeCtlLibp2pPrintUsageAndReturn(2)

fn ChengNodeCommandAt(commandIndex: int32): int32 =
    let count = cmdline.ParamCount()
    if count < commandIndex:
        return ChengNodeCtlPrintUsageAndReturn(0)
    let subcmd = cmdline.ParamStr(commandIndex)
    if subcmd == "--help" || subcmd == "-h" || subcmd == "help":
        return ChengNodeCtlPrintUsageAndReturn(0)
    if subcmd == "identity":
        let textRes = ChengNodeCtlIdentityText(ChengNodeCtlRootSeed())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "bootstrap":
        let textRes = ChengNodeCtlBootstrapText(ChengNodeCtlRootSeed())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "required-surface":
        let textRes = ChengNodeCtlRequiredSurfaceText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "compiler":
        return compiler_domain.ChengNodeCompilerCommandAt(commandIndex + 1)
    if subcmd == "libp2p":
        return ChengNodeCtlLibp2pCommandAt(commandIndex + 1)
    if subcmd == "chain":
        return ChengNodeCtlChainCommandAt(commandIndex + 1)
    if subcmd == "head":
        let textRes = ChengNodeCtlHeadText(ChengNodeCtlRootSeed(),
                                             ChengNodeCtlStatePath())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "announce":
        let textRes = ChengNodeCtlAnnounceText(ChengNodeCtlRootSeed(),
                                                 ChengNodeCtlStatePath())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "discover":
        let textRes = ChengNodeCtlDiscoverText(ChengNodeCtlRootSeed(),
                                                 ChengNodeCtlStatePath())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "stream":
        let textRes = ChengNodeCtlStreamText(ChengNodeCtlRootSeed(),
                                               ChengNodeCtlStatePath())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "query":
        let groupRes = ChengNodeCtlRequireTextFlag("--group")
        if IsErr(groupRes):
            echo(Error(groupRes))
            return 1
        let kindRes = ChengNodeCtlRequireTextFlag("--kind")
        if IsErr(kindRes):
            echo(Error(kindRes))
            return 1
        let keyRes = ChengNodeCtlRequireTextFlag("--key")
        if IsErr(keyRes):
            echo(Error(keyRes))
            return 1
        let textRes = ChengNodeCtlQueryText(ChengNodeCtlRootSeed(),
                                              ChengNodeCtlStatePath(),
                                              Value(groupRes),
                                              Value(kindRes),
                                              Value(keyRes),
                                              ChengNodeCtlWithDelta())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "balance":
        let assetRes = ChengNodeCtlRequireInt32Flag("--asset")
        if IsErr(assetRes):
            echo(Error(assetRes))
            return 1
        let accountRes = ChengNodeCtlRequireInt32Flag("--account")
        if IsErr(accountRes):
            echo(Error(accountRes))
            return 1
        let textRes = ChengNodeCtlBalanceText(ChengNodeCtlRootSeed(),
                                                ChengNodeCtlStatePath(),
                                                Value(assetRes),
                                                Value(accountRes),
                                                ChengNodeCtlWithDelta())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "did":
        let didSubcmd = ChengNodeCtlWordAt(commandIndex + 1)
        if didSubcmd == "" || didSubcmd == "--help" || didSubcmd == "-h" || didSubcmd == "help":
            return ChengNodeCtlPrintUsageAndReturn(0)
        if didSubcmd == "subject":
            let subjectRes = ChengNodeCtlRequireTextFlag("--subject")
            if IsErr(subjectRes):
                echo(Error(subjectRes))
                return 1
            let textRes = ChengNodeCtlQueryText(ChengNodeCtlRootSeed(),
                                                  ChengNodeCtlStatePath(),
                                                  "did",
                                                  "subject",
                                                  Value(subjectRes),
                                                  ChengNodeCtlWithDelta())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if didSubcmd == "operator":
            let operatorRes = ChengNodeCtlRequireTextFlag("--operator")
            if IsErr(operatorRes):
                echo(Error(operatorRes))
                return 1
            let textRes = ChengNodeCtlQueryText(ChengNodeCtlRootSeed(),
                                                  ChengNodeCtlStatePath(),
                                                  "did_operator",
                                                  "operator",
                                                  Value(operatorRes),
                                                  ChengNodeCtlWithDelta())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        return ChengNodeCtlPrintUsageAndReturn(2)
    if subcmd == "mint":
        let assetRes = ChengNodeCtlRequireInt32Flag("--asset")
        if IsErr(assetRes):
            echo(Error(assetRes))
            return 1
        let accountRes = ChengNodeCtlRequireInt32Flag("--account")
        if IsErr(accountRes):
            echo(Error(accountRes))
            return 1
        let amountRes = ChengNodeCtlRequireInt64Flag("--amount")
        if IsErr(amountRes):
            echo(Error(amountRes))
            return 1
        let textRes = ChengNodeCtlMintText(ChengNodeCtlRootSeed(),
                                             ChengNodeCtlStatePath(),
                                             Value(assetRes),
                                             Value(accountRes),
                                             Value(amountRes))
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "transfer":
        let assetRes = ChengNodeCtlRequireInt32Flag("--asset")
        if IsErr(assetRes):
            echo(Error(assetRes))
            return 1
        let fromRes = ChengNodeCtlRequireInt32Flag("--from")
        if IsErr(fromRes):
            echo(Error(fromRes))
            return 1
        let toRes = ChengNodeCtlRequireInt32Flag("--to")
        if IsErr(toRes):
            echo(Error(toRes))
            return 1
        let amountRes = ChengNodeCtlRequireInt64Flag("--amount")
        if IsErr(amountRes):
            echo(Error(amountRes))
            return 1
        let textRes = ChengNodeCtlTransferText(ChengNodeCtlRootSeed(),
                                                 ChengNodeCtlStatePath(),
                                                 Value(assetRes),
                                                 Value(fromRes),
                                                 Value(toRes),
                                                 Value(amountRes))
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "sync-did":
        let textRes = ChengNodeCtlSyncDidText(ChengNodeCtlRootSeed(),
                                                ChengNodeCtlStatePath())
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "oracle":
        let oracleSubcmd = ChengNodeCtlWordAt(commandIndex + 1)
        if oracleSubcmd == "" || oracleSubcmd == "--help" || oracleSubcmd == "-h" || oracleSubcmd == "help":
            return ChengNodeCtlPrintUsageAndReturn(0)
        if oracleSubcmd == "submit":
            let textRes = ChengNodeCtlOracleSubmitText(ChengNodeCtlRootSeed(),
                                                         ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if oracleSubcmd == "query":
            let textRes = ChengNodeCtlOracleText(ChengNodeCtlRootSeed(),
                                                   ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        return ChengNodeCtlPrintUsageAndReturn(2)
    if subcmd == "diloco":
        let dilocoSubcmd = ChengNodeCtlWordAt(commandIndex + 1)
        if dilocoSubcmd == "" || dilocoSubcmd == "--help" || dilocoSubcmd == "-h" || dilocoSubcmd == "help":
            return ChengNodeCtlPrintUsageAndReturn(0)
        if dilocoSubcmd == "open":
            let textRes = ChengNodeCtlDilocoOpenText(ChengNodeCtlRootSeed(),
                                                       ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if dilocoSubcmd == "join":
            let textRes = ChengNodeCtlDilocoJoinText(ChengNodeCtlRootSeed(),
                                                       ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if dilocoSubcmd == "lease":
            let textRes = ChengNodeCtlDilocoLeaseText(ChengNodeCtlRootSeed(),
                                                        ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if dilocoSubcmd == "barrier":
            let textRes = ChengNodeCtlDilocoBarrierText(ChengNodeCtlRootSeed(),
                                                          ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if dilocoSubcmd == "delta":
            let textRes = ChengNodeCtlDilocoDeltaText(ChengNodeCtlRootSeed(),
                                                        ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if dilocoSubcmd == "merge":
            let textRes = ChengNodeCtlDilocoMergeText(ChengNodeCtlRootSeed(),
                                                        ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if dilocoSubcmd == "status":
            let textRes = ChengNodeCtlDilocoStatusText(ChengNodeCtlRootSeed(),
                                                         ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        return ChengNodeCtlPrintUsageAndReturn(2)
    if subcmd == "vpn":
        let vpnSubcmd = ChengNodeCtlWordAt(commandIndex + 1)
        if vpnSubcmd == "" || vpnSubcmd == "--help" || vpnSubcmd == "-h" || vpnSubcmd == "help":
            return ChengNodeCtlPrintUsageAndReturn(0)
        if vpnSubcmd == "peer":
            let textRes = ChengNodeCtlVpnPeerText(ChengNodeCtlRootSeed(),
                                                    ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if vpnSubcmd == "route":
            let textRes = ChengNodeCtlVpnRouteText(ChengNodeCtlRootSeed(),
                                                     ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if vpnSubcmd == "status":
            let textRes = ChengNodeCtlVpnStatusText(ChengNodeCtlRootSeed(),
                                                      ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        return ChengNodeCtlPrintUsageAndReturn(2)
    if subcmd == "evomap":
        let evomapSubcmd = ChengNodeCtlWordAt(commandIndex + 1)
        if evomapSubcmd == "" || evomapSubcmd == "--help" || evomapSubcmd == "-h" || evomapSubcmd == "help":
            return ChengNodeCtlPrintUsageAndReturn(0)
        if evomapSubcmd == "agent":
            let textRes = ChengNodeCtlEvoMapAgentText(ChengNodeCtlRootSeed(),
                                                        ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if evomapSubcmd == "task":
            let textRes = ChengNodeCtlEvoMapTaskText(ChengNodeCtlRootSeed(),
                                                       ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if evomapSubcmd == "capsule":
            let textRes = ChengNodeCtlEvoMapCapsuleText(ChengNodeCtlRootSeed(),
                                                          ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        if evomapSubcmd == "status":
            let textRes = ChengNodeCtlEvoMapStatusText(ChengNodeCtlRootSeed(),
                                                         ChengNodeCtlStatePath())
            if IsErr(textRes):
                echo(Error(textRes))
                return 1
            echo(Value(textRes))
            return 0
        return ChengNodeCtlPrintUsageAndReturn(2)
    if subcmd == "migration":
        let migrationAction = ChengNodeCtlWordAt(commandIndex + 1)
        let migrationKind = ChengNodeCtlWordAt(commandIndex + 2)
        if migrationAction == "" || migrationAction == "--help" || migrationAction == "-h" || migrationAction == "help":
            return ChengNodeCtlPrintUsageAndReturn(0)
        if migrationAction == "import":
            if migrationKind == "legacy-chain":
                let legacyPathRes = ChengNodeCtlRequireTextFlag("--legacy-state")
                if IsErr(legacyPathRes):
                    echo(Error(legacyPathRes))
                    return 1
                let textRes = ChengNodeCtlImportLegacyChainText(ChengNodeCtlRootSeed(),
                                                                  Value(legacyPathRes),
                                                                  ChengNodeCtlOutPath())
                if IsErr(textRes):
                    echo(Error(textRes))
                    return 1
                echo(Value(textRes))
                return 0
            if migrationKind == "legacy-oracle":
                let legacyPathRes = ChengNodeCtlRequireTextFlag("--legacy-state")
                if IsErr(legacyPathRes):
                    echo(Error(legacyPathRes))
                    return 1
                let textRes = ChengNodeCtlImportLegacyOracleText(ChengNodeCtlRootSeed(),
                                                                   ChengNodeCtlStatePath(),
                                                                   Value(legacyPathRes))
                if IsErr(textRes):
                    echo(Error(textRes))
                    return 1
                echo(Value(textRes))
                return 0
            if migrationKind == "compiler-package":
                let reportPathRes = ChengNodeCtlRequireTextFlag("--report")
                if IsErr(reportPathRes):
                    echo(Error(reportPathRes))
                    return 1
                let textRes = ChengNodeCtlImportCompilerPackageText(ChengNodeCtlRootSeed(),
                                                                      ChengNodeCtlStatePath(),
                                                                      Value(reportPathRes))
                if IsErr(textRes):
                    echo(Error(textRes))
                    return 1
                echo(Value(textRes))
                return 0
            if migrationKind == "compiler-world":
                let reportPathRes = ChengNodeCtlRequireTextFlag("--report")
                if IsErr(reportPathRes):
                    echo(Error(reportPathRes))
                    return 1
                let textRes = ChengNodeCtlImportCompilerWorldText(ChengNodeCtlRootSeed(),
                                                                    ChengNodeCtlStatePath(),
                                                                    Value(reportPathRes))
                if IsErr(textRes):
                    echo(Error(textRes))
                    return 1
                echo(Value(textRes))
                return 0
            if migrationKind == "compiler-receipt":
                let reportPathRes = ChengNodeCtlRequireTextFlag("--report")
                if IsErr(reportPathRes):
                    echo(Error(reportPathRes))
                    return 1
                let receiptKeyRes = ChengNodeCtlRequireTextFlag("--receipt-key")
                if IsErr(receiptKeyRes):
                    echo(Error(receiptKeyRes))
                    return 1
                let textRes = ChengNodeCtlImportCompilerReceiptText(ChengNodeCtlRootSeed(),
                                                                      ChengNodeCtlStatePath(),
                                                                      Value(reportPathRes),
                                                                      Value(receiptKeyRes))
                if IsErr(textRes):
                    echo(Error(textRes))
                    return 1
                echo(Value(textRes))
                return 0
            return ChengNodeCtlPrintUsageAndReturn(2)
        if migrationAction == "verify":
            if migrationKind == "legacy-chain":
                let legacyPathRes = ChengNodeCtlRequireTextFlag("--legacy-state")
                if IsErr(legacyPathRes):
                    echo(Error(legacyPathRes))
                    return 1
                let textRes = ChengNodeCtlVerifyLegacyChainText(ChengNodeCtlRootSeed(),
                                                                  ChengNodeCtlStatePath(),
                                                                  Value(legacyPathRes))
                if IsErr(textRes):
                    echo(Error(textRes))
                    return 1
                echo(Value(textRes))
                return 0
            if migrationKind == "legacy-oracle":
                let legacyPathRes = ChengNodeCtlRequireTextFlag("--legacy-state")
                if IsErr(legacyPathRes):
                    echo(Error(legacyPathRes))
                    return 1
                let textRes = ChengNodeCtlVerifyLegacyOracleText(ChengNodeCtlRootSeed(),
                                                                   ChengNodeCtlStatePath(),
                                                                   Value(legacyPathRes))
                if IsErr(textRes):
                    echo(Error(textRes))
                    return 1
                echo(Value(textRes))
                return 0
            if migrationKind == "compiler-package":
                let reportPathRes = ChengNodeCtlRequireTextFlag("--report")
                if IsErr(reportPathRes):
                    echo(Error(reportPathRes))
                    return 1
                let textRes = ChengNodeCtlVerifyCompilerPackageText(ChengNodeCtlRootSeed(),
                                                                      ChengNodeCtlStatePath(),
                                                                      Value(reportPathRes))
                if IsErr(textRes):
                    echo(Error(textRes))
                    return 1
                echo(Value(textRes))
                return 0
            if migrationKind == "compiler-world":
                let reportPathRes = ChengNodeCtlRequireTextFlag("--report")
                if IsErr(reportPathRes):
                    echo(Error(reportPathRes))
                    return 1
                let textRes = ChengNodeCtlVerifyCompilerWorldText(ChengNodeCtlRootSeed(),
                                                                    ChengNodeCtlStatePath(),
                                                                    Value(reportPathRes))
                if IsErr(textRes):
                    echo(Error(textRes))
                    return 1
                echo(Value(textRes))
                return 0
            if migrationKind == "compiler-receipt":
                let reportPathRes = ChengNodeCtlRequireTextFlag("--report")
                if IsErr(reportPathRes):
                    echo(Error(reportPathRes))
                    return 1
                let receiptKeyRes = ChengNodeCtlRequireTextFlag("--receipt-key")
                if IsErr(receiptKeyRes):
                    echo(Error(receiptKeyRes))
                    return 1
                let textRes = ChengNodeCtlVerifyCompilerReceiptText(ChengNodeCtlRootSeed(),
                                                                      ChengNodeCtlStatePath(),
                                                                      Value(reportPathRes),
                                                                      Value(receiptKeyRes))
                if IsErr(textRes):
                    echo(Error(textRes))
                    return 1
                echo(Value(textRes))
                return 0
            return ChengNodeCtlPrintUsageAndReturn(2)
        return ChengNodeCtlPrintUsageAndReturn(2)
    return ChengNodeCtlPrintUsageAndReturn(2)

fn ChengNodeCommand(): int32 =
    return ChengNodeCommandAt(1)
