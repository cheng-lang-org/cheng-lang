fn ChengNodeCtlBalanceText(rootSeed: str,
                             statePath: str,
                             assetId: int32,
                             accountId: int32,
                             withDelta: bool): Result[str] =
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadStateInto(core, statePath, rootSeed)
