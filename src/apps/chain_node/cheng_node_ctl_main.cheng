fn ChengNodeCtlVerifyIndexedStoredText(core: var node.ChengNode,
                                         indexGroup: str,
                                         lookupKind: str,
                                         keyText: str,
                                         expectedKind: str,
                                         expectedText: str): Result[str] =
    let entryRes = cindex.ChengNodeIndexGet(core.indices, indexGroup, lookupKind, keyText)
    if IsErr(entryRes):
        return Err[str](Error(entryRes))
    let entry = Value(entryRes)
    let objectRes = cobject.ChengNodeObjectStoreGet(core.objects, entry.valueCid)
    if IsErr(objectRes):
        return Err[str](Error(objectRes))
    let objectEntry = Value(objectRes)
    if objectEntry.objectKind != expectedKind:
        return Err[str]("cheng_node: verify object kind mismatch")
    if objectEntry.text != expectedText:
        return Err[str]("cheng_node: verify object text mismatch")
    var out = ""
    out = out + "verified=1\n"
    out = out + "index_group=" + indexGroup + "\n"
    out = out + "lookup_kind=" + lookupKind + "\n"
    out = out + "key_text=" + keyText + "\n"
    out = out + "payload_kind=" + objectEntry.objectKind + "\n"
    out = out + "value_cid=" + layout.fixedBytes32Hex(entry.valueCid)
    return Ok[str](out)

fn ChengNodeCtlVerifyIndexedObjectText(core: var node.ChengNode,
                                         indexGroup: str,
                                         lookupKind: str,
                                         keyText: str,
                                         expectedKind: str,
                                         expectedText: str,
                                         verifyProofDelta: bool): Result[str] =
    if verifyProofDelta:
        let queryRes = node.ChengNodeKeyedQueryText(core,
                                                      indexGroup,
                                                      lookupKind,
                                                      keyText,
                                                      true)
        if IsErr(queryRes):
            return Err[str](Error(queryRes))
        let queryText = Value(queryRes)
        let foundRes = ChengNodeCtlRequireContains(queryText, "found=1", "found=1")
        if IsErr(foundRes):
            return Err[str](Error(foundRes))
        let proofRes = ChengNodeCtlRequireContains(queryText, "proof_cid=", "proof_cid")
        if IsErr(proofRes):
            return Err[str](Error(proofRes))
        let snapshotRes = ChengNodeCtlRequireContains(queryText, "snapshot_cid=", "snapshot_cid")
        if IsErr(snapshotRes):
            return Err[str](Error(snapshotRes))
        let payloadRes = ChengNodeCtlRequireContains(queryText, "payload_present=1", "payload_present")
        if IsErr(payloadRes):
            return Err[str](Error(payloadRes))
        let deltaRes = ChengNodeCtlRequireContains(queryText, "delta_count=1", "delta_count")
        if IsErr(deltaRes):
            return Err[str](Error(deltaRes))
    return ChengNodeCtlVerifyIndexedStoredText(core,
                                                 indexGroup,
                                                 lookupKind,
                                                 keyText,
                                                 expectedKind,
                                                 expectedText)

fn ChengNodeCtlVerifyExpectedGroupCount(actual: var node.ChengNode,
                                          expected: var node.ChengNode,
                                          groupName: str): Result[int32] =
    var verifiedCount = 0
    var proofVerified = false
    for i in 0..<expected.indices.entries.len:
        let entry = expected.indices.entries[i]
        if !entry.active || entry.groupName != groupName:
            continue
        let objectRes = cobject.ChengNodeObjectStoreGet(expected.objects, entry.valueCid)
        if IsErr(objectRes):
            return Err[int32](Error(objectRes))
        let verifyRes = ChengNodeCtlVerifyIndexedObjectText(actual,
                                                              entry.groupName,
                                                              entry.lookupKind,
                                                              entry.keyText,
                                                              Value(objectRes).objectKind,
                                                              Value(objectRes).text,
                                                              !proofVerified)
        if IsErr(verifyRes):
            return Err[int32](Error(verifyRes))
        proofVerified = true
        verifiedCount = verifiedCount + 1
    return Ok[int32](verifiedCount)

fn ChengNodeCtlVerifyLegacyChainOnNodeText(actual: var node.ChengNode,
                                             rootSeed: str,
                                             statePath: str,
                                             legacyStatePath: str): Result[str] =
    let nodeRes = node.ChengNodeInit(rootSeed)
    if IsErr(nodeRes):
        return Err[str](Error(nodeRes))
    var expected = Value(nodeRes)
    var snapshot: chain.ChainNodeServeSnapshot
    let loadLegacyRes = state.ChengNodeLoadLegacyChainSnapshotInto(snapshot, legacyStatePath)
    if IsErr(loadLegacyRes):
        return Err[str](Error(loadLegacyRes))
    let importRes = node.ChengNodeImportChainSnapshot(expected, snapshot)
    if IsErr(importRes):
        return Err[str](Error(importRes))
    let balanceCountRes = ChengNodeCtlVerifyExpectedGroupCount(actual, expected, "balance")
    if IsErr(balanceCountRes):
        return Err[str](Error(balanceCountRes))
    let didCountRes = ChengNodeCtlVerifyExpectedGroupCount(actual, expected, "did")
    if IsErr(didCountRes):
        return Err[str](Error(didCountRes))
    let operatorCountRes = ChengNodeCtlVerifyExpectedGroupCount(actual, expected, "did_operator")
    if IsErr(operatorCountRes):
        return Err[str](Error(operatorCountRes))
    var out = ""
    out = out + "legacy_state_path=" + ChengNodeCtlAbsolutePath(legacyStatePath) + "\n"
    out = out + "state_path=" + ChengNodeCtlAbsolutePath(statePath) + "\n"
    out = out + "balance_verified_count=" + intToStr(Value(balanceCountRes)) + "\n"
    out = out + "did_verified_count=" + intToStr(Value(didCountRes)) + "\n"
    out = out + "did_operator_verified_count=" + intToStr(Value(operatorCountRes)) + "\n"
    out = out + "verified=1"
    return Ok[str](out)

