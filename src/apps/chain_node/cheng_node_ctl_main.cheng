fn ChengNodeCtlMintText(rootSeed: str,
                          statePath: str,
                          assetId: int32,
                          accountId: int32,
                          amount: int64): Result[str] =
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let mintRes = node.ChengNodeChainMint(core, assetId, accountId, amount)
    if IsErr(mintRes):
        return Err[str](Error(mintRes))
    let writeRes = state.ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    let balanceRes = node.ChengNodeBalanceQueryText(core, assetId, accountId, false)
    if IsErr(balanceRes):
        return Err[str](Error(balanceRes))
    out = out + Value(balanceRes)
    return Ok[str](out)

fn ChengNodeCtlTransferText(rootSeed: str,
                              statePath: str,
                              assetId: int32,
                              fromAccount: int32,
                              toAccount: int32,
                              amount: int64): Result[str] =
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let transferRes = node.ChengNodeChainTransfer(core,
                                                    assetId,
                                                    fromAccount,
                                                    toAccount,
                                                    amount)
    if IsErr(transferRes):
        return Err[str](Error(transferRes))
    let writeRes = state.ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    let fromBalanceRes = node.ChengNodeBalanceQueryText(core, assetId, fromAccount, false)
    if IsErr(fromBalanceRes):
        return Err[str](Error(fromBalanceRes))
    let toBalanceRes = node.ChengNodeBalanceQueryText(core, assetId, toAccount, false)
    if IsErr(toBalanceRes):
        return Err[str](Error(toBalanceRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + "from_result_begin\n"
    out = out + Value(fromBalanceRes) + "\n"
    out = out + "from_result_end\n"
    out = out + "to_result_begin\n"
    out = out + Value(toBalanceRes) + "\n"
    out = out + "to_result_end"
    return Ok[str](out)

