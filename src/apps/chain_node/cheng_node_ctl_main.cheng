    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadStateInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    return node.ChengNodeOracleQueryText(core, Value(pairRes), ChengNodeCtlWithDelta())

fn ChengNodeCtlDilocoOpenText(rootSeed: str,
                                statePath: str): Result[str] =
    let jobRes = ChengNodeCtlRequireTextFlag("--job")
    if IsErr(jobRes):
        return Err[str](Error(jobRes))
    let workersRes = ChengNodeCtlRequireInt32Flag("--workers")
    if IsErr(workersRes):
        return Err[str](Error(workersRes))
    let innerStepsRes = ChengNodeCtlRequireInt32Flag("--inner-steps")
    if IsErr(innerStepsRes):
        return Err[str](Error(innerStepsRes))
    let timeoutRes = ChengNodeCtlRequireInt32Flag("--timeout")
    if IsErr(timeoutRes):
        return Err[str](Error(timeoutRes))
    var core: node.ChengNode
    let loadRes = state.ChengNodeLoadOrInitInto(core, statePath, rootSeed)
    if IsErr(loadRes):
        return Err[str](Error(loadRes))
    let openRes = node.ChengNodeDilocoOpenJob(core,
                                                Value(jobRes),
                                                Value(workersRes),
                                                Value(innerStepsRes),
                                                Value(timeoutRes))
    if IsErr(openRes):
        return Err[str](Error(openRes))
    let writeRes = state.ChengNodeWriteState(statePath, core)
    if IsErr(writeRes):
        return Err[str](Error(writeRes))
    let statusRes = node.ChengNodeDilocoStatusText(core, Value(jobRes))
    if IsErr(statusRes):
        return Err[str](Error(statusRes))
    var out = ""
    out = out + "state_path=" + Value(writeRes) + "\n"
    out = out + Value(statusRes)
    return Ok[str](out)

