fn ChengNodeCompilerStatusText(): str =
    var out = ""
    out = strutil.Join([out, "cheng_node.compiler_domain\n"], "")
    out = strutil.Join([out, "version=cheng.compiler_runtime.v1\n"], "")
    out = strutil.Join([out, "execution=argv_control_plane\n"], "")
    out = strutil.Join([out, "bootstrap_mode=selfhost\n"], "")
    out = strutil.Join([out, "ordinary_command=system-link-exec\n"], "")
    out = strutil.Join([out, "ordinary_pipeline=node_control_plane_bridge_handoff_until_selfhost_native_codegen\n"], "")
    out = strutil.Join([out, "root=", ChengNodeCompilerRoot()], "")
    return out

fn ChengNodeCompilerBuildPlan(): Result[sexec.SystemLinkExecPlan] =
    let reqRes = ChengNodeCompilerRequest()
    if IsErr(reqRes):
        return Err[sexec.SystemLinkExecPlan](Error(reqRes))
    let requestedWorldHead = strutil.Strip(cmdline.readFlagOrDefault("--world-head", ""))
    let lockPath = strutil.Strip(cmdline.readFlagOrDefault("--lock", ""))
    let baselineSurfacePath = strutil.Strip(cmdline.readFlagOrDefault("--baseline-surface", ""))
    let channelRaw = strutil.Strip(cmdline.readFlagOrDefault("--channel", "stable"))
    return sexec.BuildSystemLinkExecPlanWithWorldAndChannel(ChengNodeCompilerRoot(),
                                                              Value(reqRes),
                                                              requestedWorldHead,
                                                              lockPath,
                                                              baselineSurfacePath,
                                                              channelRaw)

fn ChengNodeCompilerBuildPlanText(): Result[str] =
    let planRes = ChengNodeCompilerBuildPlan()
    if IsErr(planRes):
        return Err[str](Error(planRes))
    return Ok[str](sexec.SystemLinkExecPlanReport(Value(planRes)))

fn ChengNodeCompilerSystemLinkExecText(): Result[str] =
    let reqRes = ChengNodeCompilerRequest()
    if IsErr(reqRes):
        return Err[str](Error(reqRes))
    let planRes = ChengNodeCompilerBuildPlan()
    if IsErr(planRes):
        return Err[str](Error(planRes))
    let req = Value(reqRes)
    let plan = Value(planRes)
    let rootDir = ChengNodeCompilerRoot()
    let report = sexec.SystemLinkExecPlanReport(plan)
    if !ChengNodeCompilerWriteOptionalReport(rootDir, req.reportPath, report):
        return Err[str](strutil.Join(["cheng_node compiler: failed to write report: ", req.reportPath], ""))
    var bridgeMaterializeErr = ""
    if !ChengNodeCompilerMaterializeBrowserBridgeOutputs(rootDir, plan, bridgeMaterializeErr):
        if len(bridgeMaterializeErr) > 0:
            return Err[str](bridgeMaterializeErr)
        return Err[str]("cheng_node compiler: failed to materialize browser bridge outputs")
    let bridgeCompiler = ChengNodeCompilerBridgeCompilerPath(rootDir)
    if len(bridgeCompiler) > 0:
        let bridgeArgsRes = ChengNodeCompilerSystemLinkExecArgs(req, plan)
        if IsErr(bridgeArgsRes):
            return Err[str](Error(bridgeArgsRes))
        var forwardArgv: str[]
        add(forwardArgv, "system-link-exec")
        let bridgeArgs = Value(bridgeArgsRes)
        for i in 0..<bridgeArgs.len:
            add(forwardArgv, bridgeArgs[i])
        var bridgeOutput = ""
        let bridgeRc = ChengNodeCompilerRunBridgeCapture(rootDir,
                                                           bridgeCompiler,
                                                           forwardArgv,
                                                           ["CHENG_NO_BACKEND_DRIVER_HANDOFF=1"],
                                                           bridgeOutput)
        if bridgeRc != 0:
            var err = "cheng_node compiler: bridge compiler failed"
            if len(bridgeOutput) > 0:
                err = bridgeOutput
            if len(report) > 0:
                err = strutil.Join([err, "\n", report], "")
            return Err[str](err)
        bridgeMaterializeErr = ""
        if !ChengNodeCompilerMaterializeBrowserBridgeOutputs(rootDir, plan, bridgeMaterializeErr):
            if len(bridgeMaterializeErr) > 0:
                return Err[str](bridgeMaterializeErr)
            return Err[str]("cheng_node compiler: failed to restore browser bridge outputs")
        if len(req.reportPath) > 0 && chengpath.PathFileExists(chengpath.PathAbsolute(rootDir, req.reportPath)):
            return Ok[str](strutil.Strip(chengpath.ReadTextFile(rootDir, req.reportPath)))
        if len(bridgeOutput) > 0:
            return Ok[str](bridgeOutput)
        return Ok[str](report)
    if sexec.SystemLinkExecPlanReady(plan):
        return Err[str](strutil.Join(["cheng_node compiler: missing live Cheng bridge for system-link-exec\n", report], ""))
    if plan.primaryObjectPlan.missingReasons.len > 0:
        return Err[str](strutil.Join(["cheng_node compiler: primary object machine code not emitted\n", report], ""))
    return Err[str](strutil.Join(["cheng_node compiler: ordinary pipeline blocked\n", report], ""))

fn ChengNodeCompilerCsgText(): Result[str] =
    let planRes = ChengNodeCompilerBuildPlan()
    if IsErr(planRes):
        return Err[str](Error(planRes))
    return Ok[str](ccsg.CompilerCsgReport(Value(planRes).compilerCsg))

fn ChengNodeCompilerSurfaceReportText(): Result[str] =
    let planRes = ChengNodeCompilerBuildPlan()
    if IsErr(planRes):
        return Err[str](Error(planRes))
    return Ok[str](ccsg.CompilerExportSurfaceReport(Value(planRes).exportSurface))

fn ChengNodeCompilerReceiptText(): Result[str] =
    let planRes = ChengNodeCompilerBuildPlan()
    if IsErr(planRes):
        return Err[str](Error(planRes))
    return Ok[str](ccsg.CompileReceiptReport(Value(planRes).compileReceipt))

fn ChengNodeCompilerWorldSyncText(): Result[str] =
    let sourcePathRes = ChengNodeCompilerRequireFlag("--in")
    if IsErr(sourcePathRes):
        return Err[str](Error(sourcePathRes))
    let outputPathRes = ChengNodeCompilerRequireFlag("--out")
    if IsErr(outputPathRes):
        return Err[str](Error(outputPathRes))
    return cwlp.CompilerWorldSyncSmokeReport(ChengNodeCompilerRoot(),
                                               Value(sourcePathRes),
                                               Value(outputPathRes))

fn ChengNodeCompilerMaterializeWorldMirrorsText(): Result[str] =
    let bundlePrefixRes = ChengNodeCompilerRequireFlag("--in")
    if IsErr(bundlePrefixRes):
        return Err[str](Error(bundlePrefixRes))
    let materializeRes = cwlp.CompilerWorldMaterializeManagedMirrorBundlesFromBundlePrefix(ChengNodeCompilerRoot(),
                                                                                             Value(bundlePrefixRes))
    if IsErr(materializeRes):
        return Err[str](Error(materializeRes))
    return Ok[str](cwlp.CompilerWorldManagedMirrorMaterializeReport(Value(bundlePrefixRes),
                                                                      Value(materializeRes)))

fn ChengNodeCompilerFreshNodeSelfhostText(): Result[str] =
