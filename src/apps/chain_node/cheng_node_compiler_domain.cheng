                                                       Value(reqRes),
                                                       Value(planRes))

fn ChengNodeCompilerEquivalenceProofText(): Result[str] =
    let baselineCsgRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-csg", ""))
    if IsErr(baselineCsgRes):
        return Err[str](Error(baselineCsgRes))
    let migratedCsgRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-csg", ""))
    if IsErr(migratedCsgRes):
        return Err[str](Error(migratedCsgRes))
    let baselineSurfaceRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-surface", ""))
    if IsErr(baselineSurfaceRes):
        return Err[str](Error(baselineSurfaceRes))
    let migratedSurfaceRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-surface", ""))
    if IsErr(migratedSurfaceRes):
        return Err[str](Error(migratedSurfaceRes))
    let baselineReceiptRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-receipt", ""))
    if IsErr(baselineReceiptRes):
        return Err[str](Error(baselineReceiptRes))
    let migratedReceiptRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-receipt", ""))
    if IsErr(migratedReceiptRes):
        return Err[str](Error(migratedReceiptRes))
    let packageIdRes = ChengNodeCompilerRequireFlag("--package")
    if IsErr(packageIdRes):
        return Err[str](Error(packageIdRes))
    let channelRaw = strutil.Strip(cmdline.readFlagOrDefault("--channel", "stable"))
    var baselineGraphCid = layout.FixedBytes32()
    var migratedGraphCid = layout.FixedBytes32()
    var baselineSurfaceCid = layout.FixedBytes32()
    var migratedSurfaceCid = layout.FixedBytes32()
    var baselineReceiptCid = layout.FixedBytes32()
    var migratedReceiptCid = layout.FixedBytes32()
    var graphEquivalent = 0
    var exportSurfaceCompatible = 0
    var compileReceiptEquivalent = 0
    var targetTriple = ""
    let graphRes = ceq.CompilerEquivalenceGraphCompareTexts(Value(baselineCsgRes),
                                                              Value(migratedCsgRes),
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[str](Error(graphRes))
    let surfaceRes = ceq.CompilerEquivalenceSurfaceCompareTexts(Value(baselineSurfaceRes),
                                                                  Value(migratedSurfaceRes),
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[str](Error(surfaceRes))
    let receiptRes = ceq.CompilerEquivalenceReceiptCompareTexts(Value(baselineReceiptRes),
                                                                  Value(migratedReceiptRes),
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[str](Error(receiptRes))
    var proof: ceq.CompilerEquivalenceProof
    let proofRes = ceq.CompilerEquivalenceProofMake(Value(packageIdRes),
                                                      channelRaw,
                                                      baselineGraphCid,
                                                      migratedGraphCid,
                                                      baselineSurfaceCid,
                                                      migratedSurfaceCid,
                                                      baselineReceiptCid,
                                                      migratedReceiptCid,
                                                      targetTriple,
                                                      graphEquivalent,
                                                      exportSurfaceCompatible,
                                                      compileReceiptEquivalent,
                                                      proof)
    if IsErr(proofRes):
        return Err[str](Error(proofRes))
    return Ok[str](ceq.CompilerEquivalenceProofReport(proof))

fn ChengNodeCompilerPublishCheckText(): Result[str] =
    let proofTextRes = ChengNodeCompilerEquivalenceProofText()
    if IsErr(proofTextRes):
        return Err[str](Error(proofTextRes))
    proofTextRes
    let worldHeadCidRes = layout.FixedBytes32FromHex(cmdline.readFlagOrDefault("--world-head-cid", ""))
    if IsErr(worldHeadCidRes):
        return Err[str]("cheng_node compiler: invalid --world-head-cid")
    let baselineCsgRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-csg", ""))
    if IsErr(baselineCsgRes):
        return Err[str](Error(baselineCsgRes))
    let migratedCsgRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-csg", ""))
    if IsErr(migratedCsgRes):
        return Err[str](Error(migratedCsgRes))
    let baselineSurfaceRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-surface", ""))
    if IsErr(baselineSurfaceRes):
        return Err[str](Error(baselineSurfaceRes))
    let migratedSurfaceRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-surface", ""))
    if IsErr(migratedSurfaceRes):
        return Err[str](Error(migratedSurfaceRes))
    let baselineReceiptRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--baseline-receipt", ""))
    if IsErr(baselineReceiptRes):
        return Err[str](Error(baselineReceiptRes))
    let migratedReceiptRes = ChengNodeCompilerReadText(cmdline.readFlagOrDefault("--migrated-receipt", ""))
    if IsErr(migratedReceiptRes):
        return Err[str](Error(migratedReceiptRes))
    let packageIdRes = ChengNodeCompilerRequireFlag("--package")
    if IsErr(packageIdRes):
        return Err[str](Error(packageIdRes))
    let channelRaw = strutil.Strip(cmdline.readFlagOrDefault("--channel", "stable"))
    var baselineGraphCid = layout.FixedBytes32()
    var migratedGraphCid = layout.FixedBytes32()
    var baselineSurfaceCid = layout.FixedBytes32()
    var migratedSurfaceCid = layout.FixedBytes32()
    var baselineReceiptCid = layout.FixedBytes32()
    var migratedReceiptCid = layout.FixedBytes32()
    var graphEquivalent = 0
    var exportSurfaceCompatible = 0
    var compileReceiptEquivalent = 0
    var targetTriple = ""
    let graphRes = ceq.CompilerEquivalenceGraphCompareTexts(Value(baselineCsgRes),
                                                              Value(migratedCsgRes),
                                                              baselineGraphCid,
                                                              migratedGraphCid,
                                                              graphEquivalent)
    if IsErr(graphRes):
        return Err[str](Error(graphRes))
    let surfaceRes = ceq.CompilerEquivalenceSurfaceCompareTexts(Value(baselineSurfaceRes),
                                                                  Value(migratedSurfaceRes),
                                                                  baselineSurfaceCid,
                                                                  migratedSurfaceCid,
                                                                  exportSurfaceCompatible)
    if IsErr(surfaceRes):
        return Err[str](Error(surfaceRes))
    let receiptRes = ceq.CompilerEquivalenceReceiptCompareTexts(Value(baselineReceiptRes),
                                                                  Value(migratedReceiptRes),
                                                                  baselineReceiptCid,
                                                                  migratedReceiptCid,
                                                                  targetTriple,
                                                                  compileReceiptEquivalent)
    if IsErr(receiptRes):
        return Err[str](Error(receiptRes))
    var proof: ceq.CompilerEquivalenceProof
    let proofRes = ceq.CompilerEquivalenceProofMake(Value(packageIdRes),
                                                      channelRaw,
                                                      baselineGraphCid,
                                                      migratedGraphCid,
                                                      baselineSurfaceCid,
                                                      migratedSurfaceCid,
                                                      baselineReceiptCid,
                                                      migratedReceiptCid,
                                                      targetTriple,
                                                      graphEquivalent,
                                                      exportSurfaceCompatible,
                                                      compileReceiptEquivalent,
                                                      proof)
    if IsErr(proofRes):
        return Err[str](Error(proofRes))
    var channel = ""
    var stableGateRequired = 0
    var equivalenceCheckedFlag = 0
    var equivalencePassed = 0
    var publishAllowed = 0
    var proofCid = layout.FixedBytes32()
    let decisionRes = cpub.CompilerPublishDecisionEvaluate(channelRaw,
                                                             Value(worldHeadCidRes),
                                                             true,
                                                             proof,
                                                             channel,
                                                             stableGateRequired,
                                                             equivalenceCheckedFlag,
                                                             equivalencePassed,
                                                             publishAllowed,
                                                             proofCid)
    if IsErr(decisionRes):
        return Err[str](Error(decisionRes))
    return Ok[str](cpub.CompilerPublishDecisionReport(channel,
                                                        stableGateRequired,
                                                        equivalenceCheckedFlag,
                                                        equivalencePassed,
                                                        publishAllowed,
                                                        Value(worldHeadCidRes),
                                                        proofCid))

fn ChengNodeCompilerPrintForwardResult(subcmd: str,
                                         commandIndex: int32): int32 =
    let textRes = ChengNodeCompilerForwardSubcommandText(subcmd, commandIndex)
    if IsErr(textRes):
        echo(Error(textRes))
        return 1
    let text = Value(textRes)
    if len(text) > 0:
        echo(text)
    return 0

fn ChengNodeCompilerCommandAt(commandIndex: int32): int32 =
    let count = cmdline.ParamCount()
    if count < commandIndex:
        echo(ChengNodeCompilerUsageText())
        return 0
    let subcmd = cmdline.ParamStr(commandIndex)
    if subcmd == "--help" || subcmd == "-h" || subcmd == "help":
        echo(ChengNodeCompilerUsageText())
        return 0
    if subcmd == "surface":
        echo(ChengNodeCompilerSurfaceText())
        return 0
    if subcmd == "status":
        echo(ChengNodeCompilerStatusText())
        return 0
    if subcmd == "system-link-exec":
        let textRes = ChengNodeCompilerSystemLinkExecText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "debug-report":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-symbols":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-line-map":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-object":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-elf":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-asm":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "profile-run":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "profile-report":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "crash-report":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "print-build-plan":
        let textRes = ChengNodeCompilerBuildPlanText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "emit-csg":
        let textRes = ChengNodeCompilerCsgText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "migrate-csg":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "emit-surface":
        let textRes = ChengNodeCompilerSurfaceReportText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "emit-receipt":
        let textRes = ChengNodeCompilerReceiptText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "verify-world":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "world-sync":
        let textRes = ChengNodeCompilerWorldSyncText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "materialize-world-mirrors":
        let textRes = ChengNodeCompilerMaterializeWorldMirrorsText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "prove-migration":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "publish-world":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "fresh-node-selfhost":
        let textRes = ChengNodeCompilerFreshNodeSelfhostText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "follow-world":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "selfhost-build":
        return ChengNodeCompilerPrintForwardResult(subcmd, commandIndex)
    if subcmd == "prove-equivalence":
        let textRes = ChengNodeCompilerEquivalenceProofText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    if subcmd == "publish-check":
        let textRes = ChengNodeCompilerPublishCheckText()
        if IsErr(textRes):
            echo(Error(textRes))
            return 1
        echo(Value(textRes))
        return 0
    echo(ChengNodeCompilerUsageText())
    return 2
