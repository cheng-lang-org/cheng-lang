import std/result
import std/system as system
import cheng/std/bytes_layout as layout
import cheng/apps/chain_node/cheng_node_map as cmap

type
    ChengNodeObjectEntry =
        cidHex: str
        objectKind: str
        text: str

    ChengNodeObjectStore =
        entryIndex: cmap.ChengNodeStrIntMap
        entries: ChengNodeObjectEntry[]

fn ChengNodeObjectOwnText(text: str): str =
    return system.SystemToStringStr(text)

fn ChengNodeObjectStoreInitInPlace(out: var ChengNodeObjectStore) =
    out.entries = []
    cmap.ChengNodeStrIntMapInitInPlace(out.entryIndex, 128)

fn ChengNodeObjectStorePut(store: var ChengNodeObjectStore,
                             payloadCid: layout.FixedBytes32,
                             objectKind: str,
                             text: str): Result[bool] =
    let cidHex = layout.FixedBytes32Hex(payloadCid)
    if len(cidHex) <= 0:
        return Err[bool]("cheng_node object: empty cid")
    var found = false
    let raw = cmap.ChengNodeStrIntMapGet(store.entryIndex, cidHex, found)
    if found && raw > 0:
        let slot = raw - 1
        store.entries[slot].objectKind = ChengNodeObjectOwnText(objectKind)
        store.entries[slot].text = ChengNodeObjectOwnText(text)
        return Ok[bool](false)
    let entry = ChengNodeObjectEntry(cidHex: ChengNodeObjectOwnText(cidHex),
                                       objectKind: ChengNodeObjectOwnText(objectKind),
                                       text: ChengNodeObjectOwnText(text))
    add(store.entries, entry)
    cmap.ChengNodeStrIntMapPut(store.entryIndex, cidHex, store.entries.len)
    return Ok[bool](true)

fn ChengNodeObjectStoreGet(store: ChengNodeObjectStore,
                             payloadCid: layout.FixedBytes32): Result[ChengNodeObjectEntry] =
    let cidHex = layout.FixedBytes32Hex(payloadCid)
    var found = false
    let raw = cmap.ChengNodeStrIntMapGet(store.entryIndex, cidHex, found)
    if !found || raw <= 0:
        return Err[ChengNodeObjectEntry]("cheng_node object: cid not found")
    return Ok[ChengNodeObjectEntry](store.entries[raw - 1])

fn ChengNodeObjectCount(store: ChengNodeObjectStore): int32 =
    return store.entries.len
