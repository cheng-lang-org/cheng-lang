@importc("get_stdout")
fn ChainNodeCliStdoutBridge(): os.File
@importc("get_stderr")
fn ChainNodeCliStderrBridge(): os.File
@importc("paramCount")
fn ChainNodeCliParamCountBridge(): int32
@importc("cheng_exit")
fn ChainNodeCliExitBridge(code: int32)

const
    ChainNodeCliStateMagic: str = "cheng.chain_node.state.v1"

fn ChainNodeCliPrintLine(text: str) =
    os.WriteLine(ChainNodeCliStdoutBridge(), text)

fn ChainNodeCliPrintErr(text: str) =
    os.WriteLine(ChainNodeCliStderrBridge(), text)

fn ChainNodeCliExit(code: int32): int32 =
    ChainNodeCliExitBridge(code)
    return code

fn ChainNodeCliPrintBlock(text: str) =
    var start: int32
    var i: int32
    while i < text.len:
        if text[i] != '\n':
            i = i + 1
            continue
        let line: str = strings.SliceBytes(text, start, i - start)
        ChainNodeCliPrintLine(line)
        start = i + 1
        i = i + 1
    if start < text.len:
        let tail: str = strings.SliceBytes(text, start, text.len - start)
        ChainNodeCliPrintLine(tail)

fn ChainNodeCliIsSpace(ch: char): bool =
    let code = int32(ch)
    if code == 32:
        return true
    if code == 9:
        return true
    if code == 10:
        return true
    if code == 13:
        return true
    return false

fn ChainNodeCliTrimAscii(raw: str): str =
    if len(raw) <= 0:
        return ""
    let n = len(raw)
    var start = 0
    while start < n && ChainNodeCliIsSpace(raw[start]):
        start = start + 1
    if start >= n:
        return ""
    var stop = n
    while stop > start && ChainNodeCliIsSpace(raw[stop - 1]):
        stop = stop - 1
    if start == 0 && stop == n:
        return raw
    return strings.SliceBytes(raw, start, stop - start)

fn ChainNodeCliParamCount(): int32 =
    return ChainNodeCliParamCountBridge()

fn ChainNodeCliFlagInlineValue(arg: str,
                                 key: str,
                                 outValue: var str): bool =
    outValue = ""
    let keyLen = len(key)
    let argLen = len(arg)
    if keyLen <= 0 || argLen <= keyLen:
        return false
    var matched = true
    var i = 0
    while i < keyLen:
        if arg[i] != key[i]:
            matched = false
            break
        i = i + 1
    if !matched:
        return false
    let sep = arg[keyLen]
    if sep != ':' && sep != '=':
        return false
    outValue = strings.SliceBytes(arg, keyLen + 1, argLen - keyLen - 1)
    return true

fn ChainNodeCliHasFlag(flag: str): bool =
    let count = ChainNodeCliParamCount()
    var i = 1
    while i <= count:
        if cmdline.ParamStr(i) == flag:
            return true
        i = i + 1
    return false

fn ChainNodeCliReadFlag(key: str, defaultValue: str): str =
    var out = ""
    if ChainNodeCliReadFlagValue(key, out):
        return out
    return defaultValue

fn ChainNodeCliReadFlagValue(key: str, outValue: var str): bool =
    outValue = ""
    let count = ChainNodeCliParamCount()
    var i = 1
    while i <= count:
        let arg = cmdline.ParamStr(i)
        if ChainNodeCliFlagInlineValue(arg, key, outValue):
            return true
        if arg == key:
            if i >= count:
                return false
            outValue = cmdline.ParamStr(i + 1)
            return true
        i = i + 1
    return false

fn ChainNodeCliReadInt32FlagOrDefault(key: str, defaultValue: int32): int32 =
    let raw = ChainNodeCliReadFlag(key, "")
    if len(raw) <= 0:
        return defaultValue
    let parsedRes = ChainNodeCliParseInt32Text(raw)
    if IsErr(parsedRes):
        return defaultValue
    return Value(parsedRes)

fn ChainNodeCliParseInt64Text(raw: str): Result[int64] =
    var text = ""
    text = ChainNodeCliTrimAscii(raw)
    if len(text) <= 0:
        return Err[int64](strutil.Join([" chain_node: invalid integer: ", raw], ""))
    var sign: int64 = int64(1)
    var i: int32
    if text[0] == '+':
        i = 1
    elif text[0] == '-':
        sign = int64(-1)
        i = 1
    if i >= len(text):
        return Err[int64](strutil.Join([" chain_node: invalid integer: ", raw], ""))
    var value: int64 = int64(0)
    while i < len(text):
        let ch = text[i]
        if ch < '0' || ch > '9':
            return Err[int64](strutil.Join([" chain_node: invalid integer: ", raw], ""))
        let digit = int64(int32(ch) - int32('0'))
        value = value * int64(10) + digit
        i = i + 1
    return Ok[int64](value * sign)

fn ChainNodeCliParseInt32Text(raw: str): Result[int32] =
    let parsedRes = ChainNodeCliParseInt64Text(raw)
    if IsErr(parsedRes):
        return Err[int32](Error(parsedRes))
    let value64 = Value(parsedRes)
    if value64 < int64(-2147483648) || value64 > int64(2147483647):
        return Err[int32](strutil.Join([" chain_node: invalid int32: ", raw], ""))
    return Ok[int32](int32(value64))

fn ChainNodeCliReadRequiredFlag(key: str,
                                  outValue: var str): Result[bool] =
    outValue = ""
    if !ChainNodeCliReadFlagValue(key, outValue):
        return Err[bool](strutil.Join([" chain_node: missing ", key], ""))
    outValue = ChainNodeCliTrimAscii(outValue)
    if len(outValue) <= 0:
        return Err[bool](strutil.Join([" chain_node: missing ", key], ""))
    return Ok[bool](true)

fn ChainNodeCliReadRequiredInt64Flag(key: str,
                                       outValue: var int64): Result[bool] =
    outValue = int64(0)
    var raw: str
    raw = ""
    let readRes = ChainNodeCliReadRequiredFlag(key, raw)
    if IsErr(readRes):
        return Err[bool](Error(readRes))
    let parsedRes = ChainNodeCliParseInt64Text(raw)
    if IsErr(parsedRes):
        return Err[bool](strutil.Join([" chain_node: invalid integer for ", key, ": ", raw], ""))
    outValue = Value(parsedRes)
    return Ok[bool](true)

fn ChainNodeCliHexValue(ch: char): int32 =
    if ch >= '0' && ch <= '9':
        return int32(ch) - int32('0')
    if ch >= 'a' && ch <= 'f':
        return 10 + int32(ch) - int32('a')
    if ch >= 'A' && ch <= 'F':
        return 10 + int32(ch) - int32('A')
    return -1

fn ChainNodeCliBytesFromHex(text: str): Result[Bytes] =
    if (len(text) % 2) != 0:
        return Err[Bytes](" chain_node: invalid hex length")
    var out: Bytes
    out = bytesAlloc(len(text) / 2)
    var i: int32
    while i < len(text):
        let hi = ChainNodeCliHexValue(text[i])
        let lo = ChainNodeCliHexValue(text[i + 1])
        if hi < 0 || lo < 0:
            return Err[Bytes](" chain_node: invalid hex")
        bytesSet(out, i / 2, (hi << 4) | lo)
        i = i + 2
    return Ok[Bytes](out)

fn ChainNodeCliCurrentDir(): str =
    var out = ""
    out = os.GetCurrentDir()
    return out

fn ChainNodeCliPathIsAbsolute(pathRaw: str): bool =
    let path = ChainNodeCliTrimAscii(pathRaw)
    if len(path) <= 0:
        return false
    if path[0] == '/' || path[0] == '\\':
        return true
    if len(path) > 1 && path[1] == char(58):
        return true
    return false

fn ChainNodeCliEnsureDir(pathRaw: str): bool =
    let path = ChainNodeCliTrimAscii(pathRaw)
    if len(path) <= 0:
        return false
    if os.DirExists(path):
        return true
    let parent = os.ParentDir(path)
    if len(parent) > 0 && parent != path && !os.DirExists(parent):
        if !ChainNodeCliEnsureDir(parent):
            return false
    if !os.DirExists(path):
        os.CreateDir(path)
    return os.DirExists(path)

fn ChainNodeCliAbsolutePath(pathRaw: str): str =
    var path = ""
    path = ChainNodeCliTrimAscii(pathRaw)
    if len(path) <= 0:
        return ""
    if ChainNodeCliPathIsAbsolute(path):
        return path
    var cwd = ""
    cwd = ChainNodeCliCurrentDir()
    if len(cwd) <= 0:
        return path
    return os.JoinPath(cwd, path)

fn ChainNodeCliFileExists(pathRaw: str): bool =
    var path = ""
    path = ChainNodeCliAbsolutePath(pathRaw)
    if len(path) <= 0:
        return false
    return os.FileExists(path)

fn ChainNodeCliTextEmpty(text: str): bool =
    return len(text) <= 0

fn ChainNodeCliStateText(snapshot: node.ChainNodeServeSnapshot): str =
    let payload = net.ChainNodeLibp2pEncodeSnapshot(snapshot)
    return strutil.Join([ChainNodeCliStateMagic, "\n", "node_id=", snapshot.nodeId, "\n", "payload_hex=", bytesToHex(payload), "\n"], "")

fn ChainNodeCliReadFileTextInto(outText: var str, path: str): bool =
    outText = ""
    if len(path) <= 0:
        return false
    let size64 = os.FileSize(path)
    if size64 < int64(0) || size64 > int64(2147483647):
        return false
    let file = os.openRead(path)
    if file == nil:
        return false
    let size = int32(size64)
    if size <= 0:
        os.Close(file)
        return true
    outText = newStringAlloc(size)
    let outPtr = rawmemAsVoid(outText)
    if outPtr == nil:
        os.Close(file)
        outText = ""
        return false
    let got = os.c_fread(outPtr, 1, int64(size), file)
    os.Close(file)
    if got != size:
        outText = ""
        return false
    return true

fn ChainNodeCliCloneText(text: str): str =
    let textLen: int32 = len(text)
    if textLen <= 0:
        return ""
    let out: str = newStringAlloc(textLen)
    let outPtr: ptr = rawmemAsVoid(out)
    if outPtr == nil:
        return ""
    rawmem_support.RawmemCopy(outPtr, rawmemAsVoid(text), textLen)
    return out

fn ChainNodeCliWriteState(pathRaw: str,
                            snapshot: node.ChainNodeServeSnapshot): bool =
    var path = ""
    path = ChainNodeCliAbsolutePath(pathRaw)
    if len(path) <= 0:
        return false
    var parent = ""
    parent = os.ParentDir(path)
    if len(parent) > 0 && !ChainNodeCliEnsureDir(parent):
        return false
    let payload = net.ChainNodeLibp2pEncodeSnapshot(snapshot)
    let payloadHex = bytesToHex(payload)
    let file = os.Open(path, os.fmWrite)
    if file == nil:
        return false
    let magicText = ChainNodeCliStateMagic
    let nodeIdLine = strutil.Join(["node_id=", snapshot.nodeId], "")
    let payloadLine = strutil.Join(["payload_hex=", payloadHex], "")
    os.WriteLine(file, magicText)
    os.WriteLine(file, nodeIdLine)
    os.WriteLine(file, payloadLine)
    os.Close(file)
    return os.FileExists(path)

fn ChainNodeCliExtractStateText(text: str,
                                  outNodeId: var str,
                                  outPayloadHex: var str): bool =
    outNodeId = ""
    outPayloadHex = ""
    var phase: int32
    var start: int32
    var i: int32
    while i < len(text):
        if text[i] != '\n':
            i = i + 1
            continue
        let line = ChainNodeCliTrimAscii(strings.SliceBytes(text, start, i - start))
        if len(line) <= 0:
            start = i + 1
            i = i + 1
            continue
        if phase == 0:
            if line != ChainNodeCliStateMagic:
                return false
            phase = 1
            start = i + 1
            i = i + 1
            continue
        if phase == 1:
            if len(line) <= 8 || strings.SliceBytes(line, 0, 8) != "node_id=":
                return false
            outNodeId = ChainNodeCliTrimAscii(strings.SliceBytes(line, 8, len(line) - 8))
            phase = 2
            start = i + 1
            i = i + 1
            continue
        if phase == 2:
            if len(line) <= 12 || strings.SliceBytes(line, 0, 12) != "payload_hex=":
                return false
            outPayloadHex = ChainNodeCliTrimAscii(strings.SliceBytes(line, 12, len(line) - 12))
            phase = 3
            start = i + 1
            i = i + 1
            continue
        return false
    if start < len(text):
        let line = ChainNodeCliTrimAscii(strings.SliceBytes(text, start, len(text) - start))
        if len(line) > 0:
            if phase == 0:
                if line != ChainNodeCliStateMagic:
                    return false
                phase = 1
            elif phase == 1:
                if len(line) <= 8 || strings.SliceBytes(line, 0, 8) != "node_id=":
                    return false
                outNodeId = ChainNodeCliTrimAscii(strings.SliceBytes(line, 8, len(line) - 8))
                phase = 2
            elif phase == 2:
                if len(line) <= 12 || strings.SliceBytes(line, 0, 12) != "payload_hex=":
                    return false
                outPayloadHex = ChainNodeCliTrimAscii(strings.SliceBytes(line, 12, len(line) - 12))
                phase = 3
            else:
                return false
    if phase != 3:
        return false
    if len(outNodeId) <= 0:
        return false
    if len(outPayloadHex) <= 0:
        return false
    return true

fn ChainNodeCliLoadStateInto(out: var node.ChainNode, pathRaw: str): Result[bool] =
    var path = ""
    path = ChainNodeCliAbsolutePath(pathRaw)
    var text = ""
    if len(path) <= 0 || !ChainNodeCliReadFileTextInto(text, path) || len(text) <= 0:
        return Err[bool](strutil.Join([" chain_node: missing or empty state file: ", path], ""))
    var nodeId: str
    var payloadHex: str
    nodeId = ""
    payloadHex = ""
    if !ChainNodeCliExtractStateText(text, nodeId, payloadHex):
        return Err[bool](strutil.Join([" chain_node: invalid state file: ", path], ""))
    let payloadRes = ChainNodeCliBytesFromHex(payloadHex)
    if IsErr(payloadRes):
        return Err[bool](Error(payloadRes))
    var snapshot: node.ChainNodeServeSnapshot
    let snapshotRes = net.ChainNodeLibp2pDecodeSnapshotInto(Value(payloadRes), snapshot)
    if IsErr(snapshotRes):
        return Err[bool](Error(snapshotRes))
    let replayRes = node.ChainNodeReplayFromSnapshotInto(out,
                                                           nodeId,
                                                           snapshot.address,
                                                           snapshot)
    if IsErr(replayRes):
        return Err[bool](Error(replayRes))
    return Ok[bool](true)

fn ChainNodeCliLoadOrInitForSyncInto(out: var node.ChainNode, statePath: str): Result[bool] =
    return ChainNodeCliLoadOrInitForSyncWithIdentityInto(out,
                                                           statePath,
                                                           ChainNodeCliReadFlag("--node-id", ""),
                                                           ChainNodeCliReadFlag("--address-seed", ""))

fn ChainNodeCliLoadOrInitForSyncWithIdentityInto(out: var node.ChainNode,
                                                   statePath: str,
                                                   nodeId: str,
                                                   addressSeed: str): Result[bool] =
    if ChainNodeCliFileExists(statePath):
        return ChainNodeCliLoadStateInto(out, statePath)
    let trimmedNodeId = ChainNodeCliTrimAscii(nodeId)
    if len(trimmedNodeId) <= 0:
        return Err[bool](" chain_node: sync-once missing state; require --node-id and --address-seed")
    let trimmedAddressSeed = ChainNodeCliTrimAscii(addressSeed)
    if len(trimmedAddressSeed) <= 0:
        return Err[bool](" chain_node: sync-once missing state; require --node-id and --address-seed")
    return node.ChainNodeInitInto(out, trimmedNodeId, trimmedAddressSeed)

fn ChainNodeCliLoadBioDidStateInto(out: var bio_did.BioDidChainState,
                                     pathRaw: str): Result[bool] =
    var loadedNode: node.ChainNode
    let loadRes = ChainNodeCliLoadStateInto(loadedNode, pathRaw)
    if IsErr(loadRes):
        return Err[bool](Error(loadRes))
    return bio_did.BioDidChainStateFromNodeInto(out, loadedNode)

fn ChainNodeCliBioDidOperatorLookupJson(statePath: str,
                                          operatorIdHex: str): Result[str] =
    var emptyKinds: str[]
    emptyKinds.len = 0
    return ChainNodeCliBioDidOperatorLookupJsonWithKinds(statePath, operatorIdHex, emptyKinds)

fn ChainNodeCliBioDidOperatorLookupJsonWithKinds(statePath: str,
                                                   operatorIdHex: str,
                                                   preferredKinds: str[]): Result[str] =
    var loadedNode: node.ChainNode
    let loadNodeRes = ChainNodeCliLoadStateInto(loadedNode, statePath)
    if IsErr(loadNodeRes):
        return Err[str](Error(loadNodeRes))
    var state: bio_did.BioDidChainState
    let stateRes = bio_did.BioDidChainStateFromNodeInto(state, loadedNode)
    if IsErr(stateRes):
        return Err[str](Error(stateRes))
    return Ok[str](bio_did.BioDidOperatorLookupJsonFromStateWithKinds(state,
                                                                        operatorIdHex,
                                                                        preferredKinds))

fn ChainNodeCliSnapshotReport(snapshot: node.ChainNodeServeSnapshot): str =
    var out: str
    out = ""
    out = strutil.Join([out, "node_id=", snapshot.nodeId, "\n"], "")
    out = strutil.Join([out, "serve_count=", intToStr(snapshot.serveCount), "\n"], "")
    out = strutil.Join([out, "event_count=", intToStr(snapshot.events.len), "\n"], "")
    out = strutil.Join([out, "tip_event_cid=", layout.FixedBytes32Hex(snapshot.tipEventCid), "\n"], "")
    out = strutil.Join([out, "forest_cid=", layout.FixedBytes32Hex(snapshot.forest.forestCid), "\n"], "")
    out = strutil.Join([out, "signature_event_count=", intToStr(snapshot.signature.eventCount), "\n"], "")
    out = strutil.Join([out, "signature_account_count=", intToStr(snapshot.signature.accountCount)], "")
    return out

fn ChainNodeCliPrintSnapshotReport(snapshot: node.ChainNodeServeSnapshot) =
    ChainNodeCliPrintLine(strutil.Join(["node_id=", snapshot.nodeId], ""))
    ChainNodeCliPrintLine(strutil.Join(["serve_count=", intToStr(snapshot.serveCount)], ""))
    ChainNodeCliPrintLine(strutil.Join(["event_count=", intToStr(snapshot.events.len)], ""))
    ChainNodeCliPrintLine(strutil.Join(["tip_event_cid=", layout.FixedBytes32Hex(snapshot.tipEventCid)], ""))
    ChainNodeCliPrintLine(strutil.Join(["forest_cid=", layout.FixedBytes32Hex(snapshot.forest.forestCid)], ""))
    ChainNodeCliPrintLine(strutil.Join(["signature_event_count=", intToStr(snapshot.signature.eventCount)], ""))
    ChainNodeCliPrintLine(strutil.Join(["signature_account_count=", intToStr(snapshot.signature.accountCount)], ""))

fn ChainNodeCliLoadSnapshotInto(outSnapshot: var node.ChainNodeServeSnapshot,
                                  pathRaw: str): Result[bool] =
    var path = ""
    path = ChainNodeCliAbsolutePath(pathRaw)
    var text = ""
    if len(path) <= 0 || !ChainNodeCliReadFileTextInto(text, path) || len(text) <= 0:
        return Err[bool](strutil.Join([" chain_node: missing or empty state file: ", path], ""))
    var nodeId: str
    var payloadHex: str
    nodeId = ""
    payloadHex = ""
    if !ChainNodeCliExtractStateText(text, nodeId, payloadHex):
        return Err[bool](strutil.Join([" chain_node: invalid state file: ", path], ""))
    let payloadRes = ChainNodeCliBytesFromHex(payloadHex)
    if IsErr(payloadRes):
        return Err[bool](Error(payloadRes))
    let snapshotRes = net.ChainNodeLibp2pDecodeSnapshotInto(Value(payloadRes), outSnapshot)
    if IsErr(snapshotRes):
        return Err[bool](Error(snapshotRes))
    outSnapshot.nodeId = ChainNodeCliCloneText(nodeId)
    return Ok[bool](true)

fn ChainNodeCliPrintStateReport(snapshot: node.ChainNodeServeSnapshot) =
    ChainNodeCliPrintLine(strutil.Join(["node_id=", snapshot.nodeId], ""))
    ChainNodeCliPrintLine(strutil.Join(["serve_count=", intToStr(snapshot.serveCount + 1)], ""))
    ChainNodeCliPrintLine(strutil.Join(["event_count=", intToStr(snapshot.events.len)], ""))
    ChainNodeCliPrintLine(strutil.Join(["tip_event_cid=", layout.FixedBytes32Hex(snapshot.tipEventCid)], ""))
    ChainNodeCliPrintLine(strutil.Join(["forest_cid=", layout.FixedBytes32Hex(snapshot.forest.forestCid)], ""))
    ChainNodeCliPrintLine(strutil.Join(["signature_event_count=", intToStr(snapshot.signature.eventCount)], ""))
    ChainNodeCliPrintLine(strutil.Join(["signature_account_count=", intToStr(snapshot.signature.accountCount)], ""))

fn ChainNodeCliSnapshotBalanceValue(snapshot: node.ChainNodeServeSnapshot,
                                      assetId: int32,
                                      accountId: int32): int64 =
    var balance: int64 = int64(0)
    for i in 0..<snapshot.events.len:
        let event = snapshot.events[i]
        if event.assetId != assetId:
            continue
        if event.kind == consensus.ConsensusKindMint:
            if event.toAccount == accountId:
                balance = balance + event.amount
            continue
        if event.kind != consensus.ConsensusKindTransferCommit:
            continue
        if event.fromAccount == accountId:
            balance = balance - event.amount
        if event.toAccount == accountId:
            balance = balance + event.amount
    return balance

fn ChainNodeCliBalanceFromStatePath(pathRaw: str,
                                      assetId: int32,
                                      accountId: int32,
                                      outBalance: var int64): Result[bool] =
    outBalance = int64(0)
    if assetId <= 0:
        return Err[bool](" chain_node: invalid balance target")
    if accountId <= 0:
        return Err[bool](" chain_node: invalid balance target")
    var snapshot: node.ChainNodeServeSnapshot
    let loadRes = ChainNodeCliLoadSnapshotInto(snapshot, pathRaw)
    if IsErr(loadRes):
        return Err[bool](Error(loadRes))
    outBalance = ChainNodeCliSnapshotBalanceValue(snapshot, assetId, accountId)
    return Ok[bool](true)

fn ChainNodeCliPrintStateReportFromPath(pathRaw: str): Result[bool] =
    var snapshot: node.ChainNodeServeSnapshot
    let loadRes = ChainNodeCliLoadSnapshotInto(snapshot, pathRaw)
    if IsErr(loadRes):
        return Err[bool](Error(loadRes))
    ChainNodeCliPrintStateReport(snapshot)
    return Ok[bool](true)

fn ChainNodeCliRequireText(raw: str, flagName: str): Result[str] =
    var text = ""
    text = ChainNodeCliTrimAscii(raw)
    if len(text) <= 0:
        return Err[str](strutil.Join([" chain_node: missing ", flagName], ""))
    return Ok[str](text)

fn ChainNodeCliRequireTextInto(outText: var str,
                                 raw: str,
                                 flagName: str): Result[bool] =
    outText = ""
    let textRes = ChainNodeCliRequireText(raw, flagName)
    if IsErr(textRes):
        return Err[bool](Error(textRes))
    outText = ChainNodeCliCloneText(Value(textRes))
    return Ok[bool](true)

fn ChainNodeCliRequirePositiveInt32(raw: str, flagName: str): Result[int32] =
    let textRes = ChainNodeCliRequireText(raw, flagName)
    if IsErr(textRes):
        return Err[int32](Error(textRes))
    let parsedRes = ChainNodeCliParseInt32Text(Value(textRes))
    if IsErr(parsedRes):
        return Err[int32](strutil.Join([" chain_node: invalid integer for ", flagName, ": ", raw], ""))
    let value = Value(parsedRes)
    if value <= 0:
        return Err[int32](strutil.Join([" chain_node: invalid integer for ", flagName, ": ", raw], ""))
    return Ok[int32](value)

fn ChainNodeCliRequireInt64(raw: str, flagName: str): Result[int64] =
    let textRes = ChainNodeCliRequireText(raw, flagName)
    if IsErr(textRes):
        return Err[int64](Error(textRes))
    let parsedRes = ChainNodeCliParseInt64Text(Value(textRes))
    if IsErr(parsedRes):
        return Err[int64](strutil.Join([" chain_node: invalid integer for ", flagName, ": ", raw], ""))
    return Ok[int64](Value(parsedRes))

fn ChainNodeCliAppendCsvKinds(out: var str[], csvText: str) =
    var trimmed = ""
    trimmed = ChainNodeCliTrimAscii(csvText)
    if len(trimmed) <= 0:
        return
    var start = 0
    var i = 0
    while i <= len(trimmed):
        let atEnd = i >= len(trimmed)
        var stop = false
        if atEnd:
            stop = true
        elif trimmed[i] == ',':
            stop = true
        if !stop:
            i = i + 1
            continue
        let part = ChainNodeCliTrimAscii(strings.SliceBytes(trimmed, start, i - start))
        if len(part) > 0:
            add(out, part)
        start = i + 1
        i = i + 1

fn ChainNodeCmdSelfTestMain(): int32 =
    var server: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(server, "node-a", "chain-node-a")),
           " chain_node cli: init server")
    var client: node.ChainNode
    assert(IsOk(node.ChainNodeInitInto(client, "node-b", "chain-node-b")),
           " chain_node cli: init client")
    let mintCidRes = node.ChainNodeMint(server, 7, 1001, int64(100))
    assert(mintCidRes.ok, " chain_node cli: mint")
    let transferCidRes = node.ChainNodeTransfer(server, 7, 1001, 2002, int64(40))
    assert(transferCidRes.ok, " chain_node cli: transfer")
    var served: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(served, server)
    let syncRes = node.ChainNodeSyncOnce(client, served)
    assert(syncRes.ok, " chain_node cli: sync result")
    assert(syncRes.value, " chain_node cli: sync changed")
    let aliceClientRes = node.ChainNodeBalance(client, 7, 1001)
    let bobClientRes = node.ChainNodeBalance(client, 7, 2002)
    assert(aliceClientRes.ok, " chain_node cli: alice balance")
    assert(bobClientRes.ok, " chain_node cli: bob balance")
    assert(aliceClientRes.value == int64(60), " chain_node cli: alice 60")
    assert(bobClientRes.value == int64(40), " chain_node cli: bob 40")
    var clientServed: node.ChainNodeServeSnapshot
    node.ChainNodeServeOnceInto(clientServed, client)
    let servedTipCid = served.tipEventCid
    let clientTipCid = clientServed.tipEventCid
    assert(layout.FixedBytes32Equal(servedTipCid, clientTipCid), " chain_node cli: tip")
    let servedForestCid = served.forest.forestCid
    let clientForestCid = clientServed.forest.forestCid
    assert(layout.FixedBytes32Equal(servedForestCid, clientForestCid), " chain_node cli: forest")
    let servedSignature = served.signature
    let clientSignature = clientServed.signature
    assert(anti.AntiEntropySignatureEqual(servedSignature, clientSignature), " chain_node cli: signature")
    ChainNodeCliPrintLine("cheng chain_node self-test ok")
    return 0
