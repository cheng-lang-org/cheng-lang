import std/result
import std/system as system
import std/rawbytes
import std/strings as strings
import std/strutils as strutil
import cheng/std/bytes_layout as layout
import cheng/chain/lsmr_types as lt
import cheng/oracle/oracle_types as oracle_types
import cheng/oracle/oracle_bft_state_machine as oracle_bft
import cheng/oracle/oracle_fixture
import cheng/DiLoCo/core/diloco as diloco
import cheng/DiLoCo/protocol/wire as diloco_wire
import cheng/libp2p/identity/did
import cheng/libp2p/core/types as libtypes
import cheng/libp2p/core/peer_id
import cheng/apps/unimaker/unimaker_edge_types as evotypes
import cheng/evomap/unimaker_evomap_protocol as evo

type
    ChengNodeOracleDomain =
        machine: oracle_bft.OracleBftStateMachine

    ChengNodeDilocoDomain =
        state: diloco.DiLoCoState

    ChengNodeEvoMapDomain =
        agentKeys: str[]
        agents: evo.EvoMapA2AHello[]
        taskKeys: str[]
        tasks: evo.EvoMapA2ATask[]
        capsuleKeys: str[]
        capsules: evotypes.EvoCapsule[]

fn ChengNodeDomainOwnText(text: str): str =
    return system.SystemToStringStr(text)

fn ChengNodeDomainAppendText(buf: var layout.ByteBuf,
                               text: str) =
    lt.AppendU32BE(buf, len(text))
    let raw = bytesFromString(text)
    layout.ByteBufAppendBytes(buf, raw)

fn ChengNodeDomainHashTextCid(tag: str,
                                text: str): layout.FixedBytes32 =
    var buf = layout.ByteBufInit(192)
    ChengNodeDomainAppendText(buf, tag)
    ChengNodeDomainAppendText(buf, text)
    return lt.FixedCidFromBuf(buf)

fn ChengNodeDomainLineValue(text: str,
                              key: str): str =
    let prefix = strutil.Join([key, "="], "")
    var lineStart: int32
    let n = strings.Len(text)
    while lineStart < n:
        var lineEnd: int32 = lineStart
        while lineEnd < n:
            if text[lineEnd] == '\n':
                break
            lineEnd = lineEnd + 1
        let lineLen = lineEnd - lineStart
        if lineLen >= strings.Len(prefix):
            let line = strings.SliceBytes(text, lineStart, lineLen)
            if strings.SliceBytes(line, 0, strings.Len(prefix)) == prefix:
                return strings.SliceBytes(line,
                                          strings.Len(prefix),
                                          strings.Len(line) - strings.Len(prefix))
        lineStart = lineEnd + 1
    return ""

fn ChengNodeDomainRequireText(text: str,
                                key: str): Result[str] =
    let value = ChengNodeDomainLineValue(text, key)
    if len(value) <= 0:
        return Err[str](strutil.Join(["cheng_node domain: missing ", key], ""))
    return Ok[str](value)

fn ChengNodeDomainRequireInt32(text: str,
                                 key: str): Result[int32] =
    let valueRes = ChengNodeDomainRequireText(text, key)
    if IsErr(valueRes):
        return Err[int32](Error(valueRes))
    return Ok[int32](int32(parseInt(Value(valueRes))))

fn ChengNodeDomainRequireInt64(text: str,
                                 key: str): Result[int64] =
    let valueRes = ChengNodeDomainRequireText(text, key)
    if IsErr(valueRes):
        return Err[int64](Error(valueRes))
    return Ok[int64](int64(parseInt(Value(valueRes))))

fn ChengNodeDomainRequireBool(text: str,
                                key: str): Result[bool] =
    let valueRes = ChengNodeDomainRequireText(text, key)
    if IsErr(valueRes):
        return Err[bool](Error(valueRes))
    let value = Value(valueRes)
    if value == "1":
        return Ok[bool](true)
    if value == "0":
        return Ok[bool](false)
    return Err[bool](strutil.Join(["cheng_node domain: invalid bool ", key], ""))

fn ChengNodeDomainRequireFixed32(text: str,
                                   key: str): Result[layout.FixedBytes32] =
    let valueRes = ChengNodeDomainRequireText(text, key)
    if IsErr(valueRes):
        return Err[layout.FixedBytes32](Error(valueRes))
    return layout.FixedBytes32FromHex(Value(valueRes))

fn ChengNodeDomainBoolText(value: bool): str =
    if value:
        return "1"
    return "0"

fn ChengNodeOracleCommittee(): oracle_types.OracleCommitteeConfig =
    var pubKeys: layout.FixedBytes65[]
    pubKeys = []
    add(pubKeys, oracle_fixture.oracleSmokePubKey(1))
    add(pubKeys, oracle_fixture.oracleSmokePubKey(2))
    add(pubKeys, oracle_fixture.oracleSmokePubKey(3))
    let committeeRes = oracle_types.OracleCommitteeConfigMake(1, pubKeys, 3)
    if IsErr(committeeRes):
        panic(Error(committeeRes))
    return Value(committeeRes)

fn ChengNodeOracleDomainInit(): ChengNodeOracleDomain =
    var out: ChengNodeOracleDomain
    out.machine = oracle_bft.OracleBftStateMachineInit("cheng_node.oracle",
                                                         ChengNodeOracleCommittee())
    return out

fn ChengNodeOracleAssetText(assetId: int32): str =
    if assetId == oracle_types.OracleAssetBtc:
        return "BTC"
    if assetId == oracle_types.OracleAssetEth:
        return "ETH"
    if assetId == oracle_types.OracleAssetSol:
        return "SOL"
    if assetId == oracle_types.OracleAssetBnb:
        return "BNB"
    if assetId == oracle_types.OracleAssetXau:
        return "XAU"
    if assetId == oracle_types.OracleAssetXag:
        return "XAG"
    if assetId == oracle_types.OracleAssetXpt:
        return "XPT"
    if assetId == oracle_types.OracleAssetXpd:
        return "XPD"
    return ""

fn ChengNodeOracleQuoteText(quoteId: int32): str =
    if quoteId == oracle_types.OracleQuoteUsd:
        return "USD"
    if quoteId == oracle_types.OracleQuoteCny:
        return "CNY"
    if quoteId == oracle_types.OracleQuoteEur:
        return "EUR"
    if quoteId == oracle_types.OracleQuoteHkd:
        return "HKD"
    return ""

fn ChengNodeOraclePairKeyFromPairId(pairId: int32): str =
    if !oracle_types.OraclePairValid(pairId):
        return ""
    let pairIndex = pairId - 1
    let assetId = (pairIndex / oracle_types.OracleQuoteCount) + 1
    let quoteId = (pairIndex % oracle_types.OracleQuoteCount) + 1
    let assetText = ChengNodeOracleAssetText(assetId)
    let quoteText = ChengNodeOracleQuoteText(quoteId)
    if len(assetText) <= 0 || len(quoteText) <= 0:
        return ""
    return strutil.Join([assetText, "/", quoteText], "")

fn ChengNodeOracleResolvePair(pairTextRaw: str,
                                outPairId: var int32,
                                outPairKey: var str): Result[bool] =
    outPairId = 0
    outPairKey = ""
    var slashPos = -1
    var i = 0
    while i < len(pairTextRaw):
        if pairTextRaw[i] == '/':
            slashPos = i
            break
        i = i + 1
    if slashPos <= 0 || slashPos >= len(pairTextRaw) - 1:
        return Err[bool]("cheng_node oracle: invalid pair")
    let assetText = strutil.Strip(strings.SliceBytes(pairTextRaw, 0, slashPos))
    let quoteText = strutil.Strip(strings.SliceBytes(pairTextRaw,
                                                     slashPos + 1,
                                                     len(pairTextRaw) - slashPos - 1))
    var assetId = 0
    if assetText == "BTC":
        assetId = oracle_types.OracleAssetBtc
    elif assetText == "ETH":
        assetId = oracle_types.OracleAssetEth
    elif assetText == "SOL":
        assetId = oracle_types.OracleAssetSol
    elif assetText == "BNB":
        assetId = oracle_types.OracleAssetBnb
    elif assetText == "XAU":
        assetId = oracle_types.OracleAssetXau
    elif assetText == "XAG":
        assetId = oracle_types.OracleAssetXag
    elif assetText == "XPT":
        assetId = oracle_types.OracleAssetXpt
    elif assetText == "XPD":
        assetId = oracle_types.OracleAssetXpd
    var quoteId = 0
    if quoteText == "USD":
        quoteId = oracle_types.OracleQuoteUsd
    elif quoteText == "CNY":
        quoteId = oracle_types.OracleQuoteCny
    elif quoteText == "EUR":
        quoteId = oracle_types.OracleQuoteEur
    elif quoteText == "HKD":
        quoteId = oracle_types.OracleQuoteHkd
    if assetId <= 0 || quoteId <= 0:
        return Err[bool]("cheng_node oracle: unsupported pair")
    let pairRes = oracle_types.OraclePairIdFromAssetQuote(assetId, quoteId)
    if IsErr(pairRes):
        return Err[bool](Error(pairRes))
    outPairId = Value(pairRes)
    outPairKey = strutil.Join([assetText, "/", quoteText], "")
    return Ok[bool](true)

fn ChengNodeOracleHistoryStart(pairState: oracle_types.OraclePairState): int32 =
    let raw = pairState.historyHead - pairState.historyLen
    if raw >= 0:
        return raw
    return raw + oracle_types.OracleHistoryMax

fn ChengNodeOracleMachineStateText(domain: ChengNodeOracleDomain): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "version", "1")
    out = did.DidStoreAppendLine(out, "kind", "oracle_machine")
    out = did.DidStoreAppendLine(out, "has_finalized", ChengNodeDomainBoolText(domain.machine.hasFinalized))
    out = did.DidStoreAppendLine(out, "last_finalized_round_id", int64ToStr(domain.machine.lastFinalizedRoundId))
    out = did.DidStoreAppendLine(out, "last_finalized_height", int64ToStr(domain.machine.lastFinalizedHeight))
    out = did.DidStoreAppendLine(out, "last_commit_app_hash", layout.FixedBytes32Hex(domain.machine.lastCommitAppHash))
    out = did.DidStoreAppendLine(out, "app_hash", layout.FixedBytes32Hex(oracle_bft.OracleBftStateMachineQueryAppHash(domain.machine)))
    return out

fn ChengNodeOraclePairStateText(domain: ChengNodeOracleDomain,
                                  pairId: int32): Result[str] =
    let stateRes = oracle_bft.OracleBftLatestState(domain.machine, pairId)
    if IsErr(stateRes):
        return Err[str](Error(stateRes))
    let pairState = Value(stateRes)
    let pairKey = ChengNodeOraclePairKeyFromPairId(pairId)
    if len(pairKey) <= 0:
        return Err[str]("cheng_node oracle: pair key missing")
    var out = ""
    out = did.DidStoreAppendLine(out, "version", "1")
    out = did.DidStoreAppendLine(out, "kind", "oracle_pair")
    out = did.DidStoreAppendLine(out, "pair_key", pairKey)
    out = did.DidStoreAppendLine(out, "pair_id", intToStr(pairId))
    out = did.DidStoreAppendLine(out, "available", ChengNodeDomainBoolText(pairState.available))
    out = did.DidStoreAppendLine(out, "latest_round_id", int64ToStr(pairState.latestRoundId))
    out = did.DidStoreAppendLine(out, "latest_price_e8", int64ToStr(pairState.latestPriceE8))
    out = did.DidStoreAppendLine(out, "history_count", intToStr(pairState.historyLen))
    out = did.DidStoreAppendLine(out, "reporter_count", intToStr(domain.machine.committee.quorum))
    out = did.DidStoreAppendLine(out, "height", int64ToStr(domain.machine.lastFinalizedHeight))
    out = did.DidStoreAppendLine(out, "app_hash", layout.FixedBytes32Hex(oracle_bft.OracleBftStateMachineQueryAppHash(domain.machine)))
    let start = ChengNodeOracleHistoryStart(pairState)
    var historyPos = 0
    while historyPos < pairState.historyLen:
        let idx = (start + historyPos) % oracle_types.OracleHistoryMax
        let prefix = strutil.Join(["history.", intToStr(historyPos)], "")
        out = did.DidStoreAppendLine(out, strutil.Join([prefix, ".round_id"], ""), int64ToStr(pairState.historyRoundIds[idx]))
        out = did.DidStoreAppendLine(out, strutil.Join([prefix, ".price_e8"], ""), int64ToStr(pairState.historyPricesE8[idx]))
        historyPos = historyPos + 1
    return Ok[str](out)

fn ChengNodeOracleApplyMachineText(domain: var ChengNodeOracleDomain,
                                     text: str): Result[bool] =
    let hasFinalizedRes = ChengNodeDomainRequireBool(text, "has_finalized")
    if IsErr(hasFinalizedRes):
        return Err[bool](Error(hasFinalizedRes))
    let roundRes = ChengNodeDomainRequireInt64(text, "last_finalized_round_id")
    if IsErr(roundRes):
        return Err[bool](Error(roundRes))
    let heightRes = ChengNodeDomainRequireInt64(text, "last_finalized_height")
    if IsErr(heightRes):
        return Err[bool](Error(heightRes))
    let lastCommitRes = ChengNodeDomainRequireFixed32(text, "last_commit_app_hash")
    if IsErr(lastCommitRes):
        return Err[bool](Error(lastCommitRes))
    domain.machine.hasFinalized = Value(hasFinalizedRes)
    domain.machine.lastFinalizedRoundId = Value(roundRes)
    domain.machine.lastFinalizedHeight = Value(heightRes)
    domain.machine.lastCommitAppHash = Value(lastCommitRes)
    return Ok[bool](true)

fn ChengNodeOracleApplyPairText(domain: var ChengNodeOracleDomain,
                                  text: str): Result[bool] =
    let pairIdRes = ChengNodeDomainRequireInt32(text, "pair_id")
    if IsErr(pairIdRes):
        return Err[bool](Error(pairIdRes))
    let pairId = Value(pairIdRes)
    if !oracle_types.OraclePairValid(pairId):
        return Err[bool]("cheng_node oracle: invalid pair id")
    let historyCountRes = ChengNodeDomainRequireInt32(text, "history_count")
    if IsErr(historyCountRes):
        return Err[bool](Error(historyCountRes))
    let availableRes = ChengNodeDomainRequireBool(text, "available")
    if IsErr(availableRes):
        return Err[bool](Error(availableRes))
    var pairState = oracle_types.OraclePairState()
    var historyPos = 0
    while historyPos < Value(historyCountRes):
        let prefix = strutil.Join(["history.", intToStr(historyPos)], "")
        let roundRes = ChengNodeDomainRequireInt64(text, strutil.Join([prefix, ".round_id"], ""))
        if IsErr(roundRes):
            return Err[bool](Error(roundRes))
        let priceRes = ChengNodeDomainRequireInt64(text, strutil.Join([prefix, ".price_e8"], ""))
        if IsErr(priceRes):
            return Err[bool](Error(priceRes))
        oracle_bft.OracleBftPairStatePush(pairState, Value(roundRes), Value(priceRes))
        historyPos = historyPos + 1
    if !Value(availableRes):
        pairState = oracle_types.OraclePairState()
    domain.machine.pairStates[oracle_types.OraclePairIndex(pairId)] = pairState
    return Ok[bool](true)

fn ChengNodeOracleFinalizeFixtureRound(domain: var ChengNodeOracleDomain,
                                         roundId: int64): Result[oracle_bft.OracleBftBlockSummary] =
    if roundId <= int64(0):
        return Err[oracle_bft.OracleBftBlockSummary]("cheng_node oracle: invalid round")
    var batch = oracle_bft.OracleBftTxBatch()
    oracle_bft.OracleBftTxBatchAdd(batch, oracle_fixture.oracleSmokeBatch(roundId, 1))
    oracle_bft.OracleBftTxBatchAdd(batch, oracle_fixture.oracleSmokeBatch(roundId, 2))
    oracle_bft.OracleBftTxBatchAdd(batch, oracle_fixture.oracleSmokeBatch(roundId, 3))
    var summary = oracle_bft.OracleBftBlockSummaryZero(roundId)
    let timeHint = oracle_types.OracleRoundEndMs(roundId) + int64(1)
    let context = oracle_bft.OracleBftBlockContextMake(roundId,
                                                         0,
                                                         timeHint,
                                                         layout.FixedBytes32())
    oracle_bft.OracleBftStateMachineFinalizeBatchSummaryWithContext(domain.machine,
                                                                      context,
                                                                      batch,
                                                                      summary)
    if summary.finalizedRoundCount <= 0:
        return Err[oracle_bft.OracleBftBlockSummary]("cheng_node oracle: round not finalized")
    let _commit = oracle_bft.OracleBftStateMachineCommit(domain.machine)
    return Ok[oracle_bft.OracleBftBlockSummary](summary)

fn ChengNodeOracleLatestReportText(domain: ChengNodeOracleDomain,
                                     pairId: int32): Result[str] =
    let nowMs = oracle_types.OracleRoundEndMs(domain.machine.lastFinalizedRoundId) + int64(1)
    let latest = oracle_bft.OracleBftStateMachineQueryLatest(domain.machine, pairId, nowMs)
    if latest.code != oracle_bft.OracleBftCodeOk:
        return Err[str]("cheng_node oracle: latest unavailable")
    var out = ""
    out = did.DidStoreAppendLine(out, "pair_id", intToStr(pairId))
    out = did.DidStoreAppendLine(out, "pair_key", ChengNodeOraclePairKeyFromPairId(pairId))
    out = did.DidStoreAppendLine(out, "round_id", int64ToStr(latest.roundId))
    out = did.DidStoreAppendLine(out, "price_e8", int64ToStr(latest.priceE8))
    out = did.DidStoreAppendLine(out, "reporter_count", intToStr(latest.reporterCount))
    out = did.DidStoreAppendLine(out, "height", int64ToStr(latest.height))
    out = did.DidStoreAppendLine(out, "app_hash", layout.FixedBytes32Hex(latest.appHash))
    return Ok[str](out)

fn ChengNodeDilocoTrimJob(state: var diloco.DiLoCoState,
                            jobBundleCid: layout.FixedBytes32) =
    var nextJobs: diloco.DiLoCoJob[]
    nextJobs = []
    for i in 0..<state.jobs.len:
        if layout.FixedBytes32Equal(state.jobs[i].jobBundleCid, jobBundleCid):
            continue
        add(nextJobs, state.jobs[i])
    state.jobs = nextJobs
    var nextBarriers: diloco.DiLoCoBarrier[]
    nextBarriers = []
    for i in 0..<state.barriers.len:
        if layout.FixedBytes32Equal(state.barriers[i].jobBundleCid, jobBundleCid):
            continue
        add(nextBarriers, state.barriers[i])
    state.barriers = nextBarriers
    var nextDeltas: diloco.DiLoCoOuterDelta[]
    nextDeltas = []
    for i in 0..<state.deltas.len:
        if layout.FixedBytes32Equal(state.deltas[i].jobBundleCid, jobBundleCid):
            continue
        add(nextDeltas, state.deltas[i])
    state.deltas = nextDeltas
    var nextCommits: diloco.DiLoCoMergeCommit[]
    nextCommits = []
    for i in 0..<state.commits.len:
        if layout.FixedBytes32Equal(state.commits[i].jobBundleCid, jobBundleCid):
            continue
        add(nextCommits, state.commits[i])
    state.commits = nextCommits
    var nextVersions: diloco.DiLoCoGlobalVersion[]
    nextVersions = []
    for i in 0..<state.versions.len:
        if layout.FixedBytes32Equal(state.versions[i].jobBundleCid, jobBundleCid):
            continue
        add(nextVersions, state.versions[i])
    state.versions = nextVersions

fn ChengNodeDilocoTrimCohort(state: var diloco.DiLoCoState,
                               jobBundleCid: layout.FixedBytes32) =
    var next: diloco.DiLoCoCohort[]
    next = []
    for i in 0..<state.cohorts.len:
        if layout.FixedBytes32Equal(state.cohorts[i].jobBundleCid, jobBundleCid):
            continue
        add(next, state.cohorts[i])
    state.cohorts = next

fn ChengNodeDilocoTrimLease(state: var diloco.DiLoCoState,
                              jobBundleCid: layout.FixedBytes32,
                              peerId: libtypes.Libp2pPeerId) =
    var next: diloco.DiLoCoLease[]
    next = []
    for i in 0..<state.leases.len:
        if layout.FixedBytes32Equal(state.leases[i].jobBundleCid, jobBundleCid) &&
           libtypes.Libp2pPeerIdEqual(state.leases[i].peerId, peerId):
            continue
        add(next, state.leases[i])
    state.leases = next

fn ChengNodeDilocoDomainInit(): ChengNodeDilocoDomain =
    var out: ChengNodeDilocoDomain
    out.state = diloco.DiLoCoStateInit("cheng_node.diloco")
    return out

fn ChengNodeDilocoJobBundleCid(jobKey: str): layout.FixedBytes32 =
    let fixedRes = layout.FixedBytes32FromHex(jobKey)
    if IsOk(fixedRes):
        return Value(fixedRes)
    return ChengNodeDomainHashTextCid("cheng_node.diloco.job", jobKey)

fn ChengNodeDilocoPeerIdFromSeed(seed: str): libtypes.Libp2pPeerId =
    return peer_id.Libp2pPeerIdFromSeed(strutil.Join(["cheng_node.diloco.peer|", seed], ""))

fn ChengNodeDilocoPeerTextFromSeed(seed: str): str =
    return peer_id.Libp2pPeerIdText(ChengNodeDilocoPeerIdFromSeed(seed))

fn ChengNodeDilocoArtifactRef(jobBundleCid: layout.FixedBytes32,
                                tag: str): Result[diloco.DiLoCoArtifactRef] =
    var out = diloco.DiLoCoArtifactRef()
    let payloadText = strutil.Join(["cheng_node.diloco.artifact|", tag], "")
    let res = diloco.DiLoCoArtifactRefFromBytesFill(out,
                                                      jobBundleCid,
                                                      bytesFromString(payloadText),
                                                      256,
                                                      tag)
    if IsErr(res):
        return Err[diloco.DiLoCoArtifactRef](Error(res))
    return Ok[diloco.DiLoCoArtifactRef](out)

fn ChengNodeDilocoCurrentDeltas(state: diloco.DiLoCoState,
                                  job: diloco.DiLoCoJob): diloco.DiLoCoOuterDelta[] =
    var out: diloco.DiLoCoOuterDelta[]
    out = []
    for i in 0..<state.deltas.len:
        let delta = state.deltas[i]
        if !layout.FixedBytes32Equal(delta.jobBundleCid, job.jobBundleCid):
            continue
        if !layout.FixedBytes32Equal(delta.baseVersionCid, job.currentGlobalVersionCid):
            continue
        if delta.outerStep != job.currentOuterStep:
            continue
        add(out, delta)
    return out

fn ChengNodeDilocoCurrentBarrier(state: diloco.DiLoCoState,
                                   job: diloco.DiLoCoJob,
                                   outBarrier: var diloco.DiLoCoBarrier): bool =
    let pos = diloco.DiLoCoBarrierPos(state,
                                        job.jobBundleCid,
                                        job.currentGlobalVersionCid,
                                        job.currentOuterStep)
    if pos < 0:
        outBarrier = diloco.DiLoCoBarrier()
        return false
    outBarrier = diloco.DiLoCoBarrier()
    diloco.DiLoCoBarrierCopyFill(outBarrier, state.barriers[pos])
    return true

fn ChengNodeDilocoCurrentCommit(state: diloco.DiLoCoState,
                                  job: diloco.DiLoCoJob,
                                  outCommit: var diloco.DiLoCoMergeCommit): bool =
    let pos = diloco.DiLoCoCommitPos(state,
                                       job.jobBundleCid,
                                       job.currentGlobalVersionCid,
                                       job.currentOuterStep)
    if pos < 0:
        outCommit = diloco.DiLoCoMergeCommit()
        return false
    outCommit = diloco.DiLoCoMergeCommit()
    diloco.DiLoCoMergeCommitCopyFill(outCommit, state.commits[pos])
    return true

fn ChengNodeDilocoJobStateText(domain: ChengNodeDilocoDomain,
                                 jobKey: str,
                                 jobBundleCid: layout.FixedBytes32): Result[str] =
    let jobPos = diloco.DiLoCoJobPos(domain.state, jobBundleCid)
    if jobPos < 0:
        return Err[str]("cheng_node diloco: job missing")
    let job = domain.state.jobs[jobPos]
    var status = diloco.DiLoCoStepStatus()
    let statusRes = diloco.DiLoCoFetchStepStatusFill(status, domain.state, jobBundleCid)
    if IsErr(statusRes):
        return Err[str](Error(statusRes))
    var lineage: diloco.DiLoCoGlobalVersion[]
    let lineageRes = diloco.DiLoCoFetchLineageFill(lineage, domain.state, jobBundleCid)
    if IsErr(lineageRes):
        return Err[str](Error(lineageRes))
    var barrier = diloco.DiLoCoBarrier()
    let hasBarrier = ChengNodeDilocoCurrentBarrier(domain.state, job, barrier)
    let deltas = ChengNodeDilocoCurrentDeltas(domain.state, job)
    var commit = diloco.DiLoCoMergeCommit()
    let hasCommit = ChengNodeDilocoCurrentCommit(domain.state, job, commit)
    var out = ""
    out = did.DidStoreAppendLine(out, "version", "1")
    out = did.DidStoreAppendLine(out, "kind", "diloco_job")
    out = did.DidStoreAppendLine(out, "job_key", jobKey)
    out = diloco_wire.DiLoCoWireAppendJob(out, "job", job)
    out = diloco_wire.DiLoCoWireAppendStepStatus(out, "status", status)
    out = diloco_wire.DiLoCoWireAppendGlobalVersionArray(out, "versions", lineage)
    out = did.DidStoreAppendLine(out, "barrier_present", ChengNodeDomainBoolText(hasBarrier))
    if hasBarrier:
        out = diloco_wire.DiLoCoWireAppendBarrier(out, "barrier", barrier)
    out = did.DidStoreAppendLine(out, "delta_count", intToStr(deltas.len))
    for i in 0..<deltas.len:
        out = diloco_wire.DiLoCoWireAppendOuterDelta(out, strutil.Join(["delta.", intToStr(i)], ""), deltas[i])
    out = did.DidStoreAppendLine(out, "commit_present", ChengNodeDomainBoolText(hasCommit))
    if hasCommit:
        out = diloco_wire.DiLoCoWireAppendMergeCommit(out, "commit", commit)
    return Ok[str](out)

fn ChengNodeDilocoCohortStateText(jobKey: str,
                                    cohort: diloco.DiLoCoCohort): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "version", "1")
    out = did.DidStoreAppendLine(out, "kind", "diloco_cohort")
    out = did.DidStoreAppendLine(out, "job_key", jobKey)
    out = diloco_wire.DiLoCoWireAppendCohort(out, "cohort", cohort)
    return out

fn ChengNodeDilocoLeaseStateText(jobKey: str,
                                   leaseKey: str,
                                   lease: diloco.DiLoCoLease): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "version", "1")
    out = did.DidStoreAppendLine(out, "kind", "diloco_lease")
    out = did.DidStoreAppendLine(out, "job_key", jobKey)
    out = did.DidStoreAppendLine(out, "lease_key", leaseKey)
    out = diloco_wire.DiLoCoWireAppendLease(out, "lease", lease)
    return out

fn ChengNodeDilocoApplyJobText(domain: var ChengNodeDilocoDomain,
                                 text: str): Result[bool] =
    var job = diloco.DiLoCoJob()
    let jobRes = diloco_wire.DiLoCoWireParseJobFill(job, text, "job")
    if IsErr(jobRes):
        return Err[bool](Error(jobRes))
    var lineage: diloco.DiLoCoGlobalVersion[]
    let lineageRes = diloco_wire.DiLoCoWireParseGlobalVersionArrayFill(lineage, text, "versions")
    if IsErr(lineageRes):
        return Err[bool](Error(lineageRes))
    let barrierPresentRes = ChengNodeDomainRequireBool(text, "barrier_present")
    if IsErr(barrierPresentRes):
        return Err[bool](Error(barrierPresentRes))
    var barrier = diloco.DiLoCoBarrier()
    if Value(barrierPresentRes):
        let barrierRes = diloco_wire.DiLoCoWireParseBarrierFill(barrier, text, "barrier")
        if IsErr(barrierRes):
            return Err[bool](Error(barrierRes))
    let deltaCountRes = ChengNodeDomainRequireInt32(text, "delta_count")
    if IsErr(deltaCountRes):
        return Err[bool](Error(deltaCountRes))
    var deltas: diloco.DiLoCoOuterDelta[]
    deltas = []
    var deltaIndex = 0
    while deltaIndex < Value(deltaCountRes):
        add(deltas, diloco.DiLoCoOuterDelta())
        let deltaRes = diloco_wire.DiLoCoWireParseOuterDeltaFill(deltas[deltas.len - 1],
                                                                   text,
                                                                   strutil.Join(["delta.", intToStr(deltaIndex)], ""))
        if IsErr(deltaRes):
            return Err[bool](Error(deltaRes))
        deltaIndex = deltaIndex + 1
    let commitPresentRes = ChengNodeDomainRequireBool(text, "commit_present")
    if IsErr(commitPresentRes):
        return Err[bool](Error(commitPresentRes))
    var commit = diloco.DiLoCoMergeCommit()
    if Value(commitPresentRes):
        let commitRes = diloco_wire.DiLoCoWireParseMergeCommitFill(commit, text, "commit")
        if IsErr(commitRes):
            return Err[bool](Error(commitRes))
    ChengNodeDilocoTrimJob(domain.state, job.jobBundleCid)
    add(domain.state.jobs, job)
    for i in 0..<lineage.len:
        add(domain.state.versions, lineage[i])
    if Value(barrierPresentRes):
        add(domain.state.barriers, barrier)
    for i in 0..<deltas.len:
        add(domain.state.deltas, deltas[i])
    if Value(commitPresentRes):
        add(domain.state.commits, commit)
    return Ok[bool](true)

fn ChengNodeDilocoApplyCohortText(domain: var ChengNodeDilocoDomain,
                                    text: str): Result[bool] =
    var cohort = diloco.DiLoCoCohort()
    let cohortRes = diloco_wire.DiLoCoWireParseCohortFill(cohort, text, "cohort")
    if IsErr(cohortRes):
        return Err[bool](Error(cohortRes))
    ChengNodeDilocoTrimCohort(domain.state, cohort.jobBundleCid)
    add(domain.state.cohorts, cohort)
    return Ok[bool](true)

fn ChengNodeDilocoApplyLeaseText(domain: var ChengNodeDilocoDomain,
                                   text: str): Result[bool] =
    var lease = diloco.DiLoCoLease()
    let leaseRes = diloco_wire.DiLoCoWireParseLeaseFill(lease, text, "lease")
    if IsErr(leaseRes):
        return Err[bool](Error(leaseRes))
    ChengNodeDilocoTrimLease(domain.state, lease.jobBundleCid, lease.peerId)
    add(domain.state.leases, lease)
    return Ok[bool](true)

fn ChengNodeDilocoStatusReportText(domain: ChengNodeDilocoDomain,
                                     jobKey: str): Result[str] =
    let jobBundleCid = ChengNodeDilocoJobBundleCid(jobKey)
    let jobPos = diloco.DiLoCoJobPos(domain.state, jobBundleCid)
    if jobPos < 0:
        return Err[str]("cheng_node diloco: job missing")
    var status = diloco.DiLoCoStepStatus()
    let statusRes = diloco.DiLoCoFetchStepStatusFill(status, domain.state, jobBundleCid)
    if IsErr(statusRes):
        return Err[str](Error(statusRes))
    var version = diloco.DiLoCoGlobalVersion()
    let versionRes = diloco.DiLoCoFetchGlobalVersionFill(version, domain.state, jobBundleCid)
    if IsErr(versionRes):
        return Err[str](Error(versionRes))
    var lineage: diloco.DiLoCoGlobalVersion[]
    let lineageRes = diloco.DiLoCoFetchLineageFill(lineage, domain.state, jobBundleCid)
    if IsErr(lineageRes):
        return Err[str](Error(lineageRes))
    var out = ""
    out = did.DidStoreAppendLine(out, "job_key", jobKey)
    out = did.DidStoreAppendLine(out, "job_bundle_cid", layout.FixedBytes32Hex(jobBundleCid))
    out = diloco_wire.DiLoCoWireAppendJob(out, "job", domain.state.jobs[jobPos])
    out = diloco_wire.DiLoCoWireAppendStepStatus(out, "status", status)
    out = diloco_wire.DiLoCoWireAppendGlobalVersion(out, "current_version", version)
    out = diloco_wire.DiLoCoWireAppendGlobalVersionArray(out, "lineage", lineage)
    out = did.DidStoreAppendLine(out, "cohort_count", intToStr(domain.state.cohorts.len))
    out = did.DidStoreAppendLine(out, "lease_count", intToStr(domain.state.leases.len))
    return Ok[str](out)

fn ChengNodeEvoMapDomainInit(): ChengNodeEvoMapDomain =
    var out: ChengNodeEvoMapDomain
    out.agentKeys = []
    out.agents = []
    out.taskKeys = []
    out.tasks = []
    out.capsuleKeys = []
    out.capsules = []
    return out

fn ChengNodeEvoMapHeadCid(domain: ChengNodeEvoMapDomain): layout.FixedBytes32 =
    if domain.capsules.len <= 0:
        return layout.FixedBytes32()
    return evotypes.UnimakerGraphHeadCid(domain.capsules)

fn ChengNodeEvoMapMaxSequence(domain: ChengNodeEvoMapDomain): int32 =
    var out = 0
    for i in 0..<domain.capsules.len:
        if domain.capsules[i].sequence > out:
            out = domain.capsules[i].sequence
    return out

fn ChengNodeEvoMapIdentity(evomapKey: layout.FixedBytes32,
                             didText: str,
                             peerText: str,
                             deviceLabel: str): evotypes.AgentIdentity =
    var out = evotypes.AgentIdentity()
    out.didText = ChengNodeDomainOwnText(didText)
    out.peerIdText = ChengNodeDomainOwnText(peerText)
    out.deviceLabel = ChengNodeDomainOwnText(deviceLabel)
    let keyHex = layout.FixedBytes32Hex(evomapKey)
    out.signatureCid = evotypes.UnimakerHashText("cheng.cheng_node.evomap.signature",
                                                   [keyHex,
                                                    out.didText,
                                                    out.peerIdText,
                                                    out.deviceLabel])
    out.identityCid = evotypes.UnimakerHashText("cheng.unimaker.identity",
                                                  [out.didText,
                                                   out.peerIdText,
                                                   out.deviceLabel,
                                                   layout.FixedBytes32Hex(out.signatureCid)])
    return out

fn ChengNodeEvoMapAgentPos(domain: ChengNodeEvoMapDomain,
                             keyText: str): int32 =
    for i in 0..<domain.agentKeys.len:
        if domain.agentKeys[i] == keyText:
            return i
    return -1

fn ChengNodeEvoMapTaskPos(domain: ChengNodeEvoMapDomain,
                            keyText: str): int32 =
    for i in 0..<domain.taskKeys.len:
        if domain.taskKeys[i] == keyText:
            return i
    return -1

fn ChengNodeEvoMapCapsulePos(domain: ChengNodeEvoMapDomain,
                               keyText: str): int32 =
    for i in 0..<domain.capsuleKeys.len:
        if domain.capsuleKeys[i] == keyText:
            return i
    return -1

fn ChengNodeEvoMapAgentText(hello: evo.EvoMapA2AHello): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "version", "1")
    out = did.DidStoreAppendLine(out, "kind", "evomap_agent")
    out = did.DidStoreAppendLine(out, "peer_key", hello.identity.peerIdText)
    out = did.DidStoreAppendLine(out, "payload_json", evo.UnimakerProtocolEncodeHello(hello))
    return out

fn ChengNodeEvoMapTaskText(taskValue: evo.EvoMapA2ATask): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "version", "1")
    out = did.DidStoreAppendLine(out, "kind", "evomap_task")
    out = did.DidStoreAppendLine(out, "task_key", taskValue.task.taskId)
    out = did.DidStoreAppendLine(out, "payload_json", evo.UnimakerProtocolEncodeTask(taskValue))
    return out

fn ChengNodeEvoMapCapsuleText(capsule: evotypes.EvoCapsule): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "version", "1")
    out = did.DidStoreAppendLine(out, "kind", "evomap_capsule")
    out = did.DidStoreAppendLine(out, "capsule_key", layout.FixedBytes32Hex(capsule.capsuleCid))
    out = did.DidStoreAppendLine(out, "payload_json", evo.UnimakerProtocolEncodeCapsuleNode(capsule))
    return out

fn ChengNodeEvoMapApplyAgentText(domain: var ChengNodeEvoMapDomain,
                                   text: str): Result[bool] =
    let payloadRes = ChengNodeDomainRequireText(text, "payload_json")
    if IsErr(payloadRes):
        return Err[bool](Error(payloadRes))
    let helloRes = evo.UnimakerProtocolDecodeHello(Value(payloadRes))
    if IsErr(helloRes):
        return Err[bool](Error(helloRes))
    let hello = Value(helloRes)
    let pos = ChengNodeEvoMapAgentPos(domain, hello.identity.peerIdText)
    if pos >= 0:
        domain.agents[pos] = hello
    else:
        add(domain.agentKeys, ChengNodeDomainOwnText(hello.identity.peerIdText))
        add(domain.agents, hello)
    return Ok[bool](true)

fn ChengNodeEvoMapApplyTaskText(domain: var ChengNodeEvoMapDomain,
                                  text: str): Result[bool] =
    let payloadRes = ChengNodeDomainRequireText(text, "payload_json")
    if IsErr(payloadRes):
        return Err[bool](Error(payloadRes))
    let taskRes = evo.UnimakerProtocolDecodeTask(Value(payloadRes))
    if IsErr(taskRes):
        return Err[bool](Error(taskRes))
    let taskValue = Value(taskRes)
    let pos = ChengNodeEvoMapTaskPos(domain, taskValue.task.taskId)
    if pos >= 0:
        domain.tasks[pos] = taskValue
    else:
        add(domain.taskKeys, ChengNodeDomainOwnText(taskValue.task.taskId))
        add(domain.tasks, taskValue)
    return Ok[bool](true)

fn ChengNodeEvoMapApplyCapsuleText(domain: var ChengNodeEvoMapDomain,
                                     text: str): Result[bool] =
    let payloadRes = ChengNodeDomainRequireText(text, "payload_json")
    if IsErr(payloadRes):
        return Err[bool](Error(payloadRes))
    let nodeRes = evo.UnimakerProtocolParseText(Value(payloadRes))
    if IsErr(nodeRes):
        return Err[bool](Error(nodeRes))
    let capsuleRes = evo.UnimakerProtocolDecodeCapsuleNode(Value(nodeRes))
    if IsErr(capsuleRes):
        return Err[bool](Error(capsuleRes))
    let capsule = Value(capsuleRes)
    let keyText = layout.FixedBytes32Hex(capsule.capsuleCid)
    let pos = ChengNodeEvoMapCapsulePos(domain, keyText)
    if pos >= 0:
        domain.capsules[pos] = capsule
    else:
        add(domain.capsuleKeys, ChengNodeDomainOwnText(keyText))
        add(domain.capsules, capsule)
    return Ok[bool](true)

fn ChengNodeEvoMapStatusReportText(domain: ChengNodeEvoMapDomain): str =
    var out = ""
    out = did.DidStoreAppendLine(out, "agent_count", intToStr(domain.agents.len))
    out = did.DidStoreAppendLine(out, "task_count", intToStr(domain.tasks.len))
    out = did.DidStoreAppendLine(out, "capsule_count", intToStr(domain.capsules.len))
    out = did.DidStoreAppendLine(out, "head_cid", layout.FixedBytes32Hex(ChengNodeEvoMapHeadCid(domain)))
    out = did.DidStoreAppendLine(out, "next_sequence", intToStr(ChengNodeEvoMapMaxSequence(domain) + 1))
    return out
