import std/result
import std/system as system
import std/rawbytes
import std/crypto/hkdf
import cheng/std/bytes_layout as layout

const
    ChengNodeIdentityVersion: int32 = 1
    ChengNodeIdentityDomainTotal: int32 = 10
    ChengNodeIdentityTagRootId: int32 = 1
    ChengNodeIdentityTagChain: int32 = 2
    ChengNodeIdentityTagDid: int32 = 3
    ChengNodeIdentityTagLibp2p: int32 = 4
    ChengNodeIdentityTagDiscovery: int32 = 5
    ChengNodeIdentityTagOracle: int32 = 6
    ChengNodeIdentityTagDiloco: int32 = 7
    ChengNodeIdentityTagEvoMap: int32 = 8
    ChengNodeIdentityTagVpn: int32 = 9
    ChengNodeIdentityTagCompiler: int32 = 10
    ChengNodeIdentityTagAdmin: int32 = 11
    ChengNodeIdentityFixedBytes32Size: int32 = 32

type
    ChengNodeIdentity =
        version: int32
        rootId: layout.FixedBytes32
        rootKey: layout.FixedBytes32
        chainKey: layout.FixedBytes32
        didKey: layout.FixedBytes32
        libp2pKey: layout.FixedBytes32
        discoveryKey: layout.FixedBytes32
        oracleKey: layout.FixedBytes32
        dilocoKey: layout.FixedBytes32
        evomapKey: layout.FixedBytes32
        vpnKey: layout.FixedBytes32
        compilerKey: layout.FixedBytes32
        adminKey: layout.FixedBytes32

fn ChengNodeIdentityOwnText(text: str): str =
    return system.SystemToStringStr(text)

fn ChengNodeIdentityOwnBytes(text: str): Bytes =
    let owned = ChengNodeIdentityOwnText(text)
    return BytesSlice(BytesFromString(owned), 0, len(owned))

fn ChengNodeIdentitySaltBytes(): Bytes =
    return ChengNodeIdentityOwnBytes("cheng_node.identity.salt.v1")

fn ChengNodeIdentityTaggedBytes(rootKey: layout.FixedBytes32,
                                  tagId: int32): Bytes =
    var out = BytesAlloc(ChengNodeIdentityFixedBytes32Size + 4)
    for i in 0..<ChengNodeIdentityFixedBytes32Size:
        BytesSet(out, i, int32(rootKey.data[i]) & 255)
    BytesSet(out, ChengNodeIdentityFixedBytes32Size + 0, (tagId >> 24) & 255)
    BytesSet(out, ChengNodeIdentityFixedBytes32Size + 1, (tagId >> 16) & 255)
    BytesSet(out, ChengNodeIdentityFixedBytes32Size + 2, (tagId >> 8) & 255)
    BytesSet(out, ChengNodeIdentityFixedBytes32Size + 3, tagId & 255)
    return out

fn ChengNodeIdentityDomainTag(label: str): Result[int32] =
    if label == "chain":
        return Ok[int32](ChengNodeIdentityTagChain)
    if label == "did":
        return Ok[int32](ChengNodeIdentityTagDid)
    if label == "libp2p":
        return Ok[int32](ChengNodeIdentityTagLibp2p)
    if label == "discovery":
        return Ok[int32](ChengNodeIdentityTagDiscovery)
    if label == "oracle":
        return Ok[int32](ChengNodeIdentityTagOracle)
    if label == "diloco":
        return Ok[int32](ChengNodeIdentityTagDiloco)
    if label == "evomap":
        return Ok[int32](ChengNodeIdentityTagEvoMap)
    if label == "vpn":
        return Ok[int32](ChengNodeIdentityTagVpn)
    if label == "compiler":
        return Ok[int32](ChengNodeIdentityTagCompiler)
    if label == "admin":
        return Ok[int32](ChengNodeIdentityTagAdmin)
    return Err[int32]("cheng_node identity: unknown domain label")

fn ChengNodeIdentityDeriveRootKey(rootSeed: str): Result[layout.FixedBytes32] =
    if len(rootSeed) <= 0:
        return Err[layout.FixedBytes32]("cheng_node identity: empty root seed")
    let seedBytes = ChengNodeIdentityOwnBytes(rootSeed)
    let saltBytes = ChengNodeIdentitySaltBytes()
    let rootBytes = hkdf.hkdfExtractSha256(seedBytes, saltBytes)
    return layout.FixedBytes32FromBytes(rootBytes)

fn ChengNodeIdentityDeriveFromRootKey(rootKey: layout.FixedBytes32,
                                        label: str): Result[layout.FixedBytes32] =
    if len(label) <= 0:
        return Err[layout.FixedBytes32]("cheng_node identity: empty domain label")
    let tagRes = ChengNodeIdentityDomainTag(label)
    if IsErr(tagRes):
        return Err[layout.FixedBytes32](Error(tagRes))
    let combined = ChengNodeIdentityTaggedBytes(rootKey, Value(tagRes))
    let saltBytes = ChengNodeIdentitySaltBytes()
    let derivedBytes = hkdf.hkdfExtractSha256(combined, saltBytes)
    return layout.FixedBytes32FromBytes(derivedBytes)

fn ChengNodeIdentityDeriveRootId(rootKey: layout.FixedBytes32): Result[layout.FixedBytes32] =
    let combined = ChengNodeIdentityTaggedBytes(rootKey, ChengNodeIdentityTagRootId)
    let saltBytes = ChengNodeIdentitySaltBytes()
    let derivedBytes = hkdf.hkdfExtractSha256(combined, saltBytes)
    return layout.FixedBytes32FromBytes(derivedBytes)

fn ChengNodeIdentityDomainCount(): int32 =
    return ChengNodeIdentityDomainTotal

fn ChengNodeIdentityDomainNames(): str[] =
    var out: str[]
    out = []
    add(out, "chain")
    add(out, "did")
    add(out, "libp2p")
    add(out, "discovery")
    add(out, "oracle")
    add(out, "diloco")
    add(out, "evomap")
    add(out, "vpn")
    add(out, "compiler")
    add(out, "admin")
    return out

fn ChengNodeIdentityDomainKey(identity: ChengNodeIdentity,
                                domain: str): Result[layout.FixedBytes32] =
    if domain == "chain":
        return Ok[layout.FixedBytes32](identity.chainKey)
    if domain == "did":
        return Ok[layout.FixedBytes32](identity.didKey)
    if domain == "libp2p":
        return Ok[layout.FixedBytes32](identity.libp2pKey)
    if domain == "discovery":
        return Ok[layout.FixedBytes32](identity.discoveryKey)
    if domain == "oracle":
        return Ok[layout.FixedBytes32](identity.oracleKey)
    if domain == "diloco":
        return Ok[layout.FixedBytes32](identity.dilocoKey)
    if domain == "evomap":
        return Ok[layout.FixedBytes32](identity.evomapKey)
    if domain == "vpn":
        return Ok[layout.FixedBytes32](identity.vpnKey)
    if domain == "compiler":
        return Ok[layout.FixedBytes32](identity.compilerKey)
    if domain == "admin":
        return Ok[layout.FixedBytes32](identity.adminKey)
    return Err[layout.FixedBytes32]("cheng_node identity: unknown domain")

fn ChengNodeIdentityDerive(rootSeed: str): Result[ChengNodeIdentity] =
    let rootKeyRes = ChengNodeIdentityDeriveRootKey(rootSeed)
    if IsErr(rootKeyRes):
        return Err[ChengNodeIdentity](Error(rootKeyRes))
    let rootKey = Value(rootKeyRes)
    let rootIdRes = ChengNodeIdentityDeriveRootId(rootKey)
    if IsErr(rootIdRes):
        return Err[ChengNodeIdentity](Error(rootIdRes))
    let chainKeyRes = ChengNodeIdentityDeriveFromRootKey(rootKey, "chain")
    if IsErr(chainKeyRes):
        return Err[ChengNodeIdentity](Error(chainKeyRes))
    let didKeyRes = ChengNodeIdentityDeriveFromRootKey(rootKey, "did")
    if IsErr(didKeyRes):
        return Err[ChengNodeIdentity](Error(didKeyRes))
    let libp2pKeyRes = ChengNodeIdentityDeriveFromRootKey(rootKey, "libp2p")
    if IsErr(libp2pKeyRes):
        return Err[ChengNodeIdentity](Error(libp2pKeyRes))
    let discoveryKeyRes = ChengNodeIdentityDeriveFromRootKey(rootKey, "discovery")
    if IsErr(discoveryKeyRes):
        return Err[ChengNodeIdentity](Error(discoveryKeyRes))
    let oracleKeyRes = ChengNodeIdentityDeriveFromRootKey(rootKey, "oracle")
    if IsErr(oracleKeyRes):
        return Err[ChengNodeIdentity](Error(oracleKeyRes))
    let dilocoKeyRes = ChengNodeIdentityDeriveFromRootKey(rootKey, "diloco")
    if IsErr(dilocoKeyRes):
        return Err[ChengNodeIdentity](Error(dilocoKeyRes))
    let evomapKeyRes = ChengNodeIdentityDeriveFromRootKey(rootKey, "evomap")
    if IsErr(evomapKeyRes):
        return Err[ChengNodeIdentity](Error(evomapKeyRes))
    let vpnKeyRes = ChengNodeIdentityDeriveFromRootKey(rootKey, "vpn")
    if IsErr(vpnKeyRes):
        return Err[ChengNodeIdentity](Error(vpnKeyRes))
    let compilerKeyRes = ChengNodeIdentityDeriveFromRootKey(rootKey, "compiler")
    if IsErr(compilerKeyRes):
        return Err[ChengNodeIdentity](Error(compilerKeyRes))
    let adminKeyRes = ChengNodeIdentityDeriveFromRootKey(rootKey, "admin")
    if IsErr(adminKeyRes):
        return Err[ChengNodeIdentity](Error(adminKeyRes))
    var out: ChengNodeIdentity
    out.version = ChengNodeIdentityVersion
    out.rootId = Value(rootIdRes)
    out.rootKey = rootKey
    out.chainKey = Value(chainKeyRes)
    out.didKey = Value(didKeyRes)
    out.libp2pKey = Value(libp2pKeyRes)
    out.discoveryKey = Value(discoveryKeyRes)
    out.oracleKey = Value(oracleKeyRes)
    out.dilocoKey = Value(dilocoKeyRes)
    out.evomapKey = Value(evomapKeyRes)
    out.vpnKey = Value(vpnKeyRes)
    out.compilerKey = Value(compilerKeyRes)
    out.adminKey = Value(adminKeyRes)
    return Ok[ChengNodeIdentity](out)
