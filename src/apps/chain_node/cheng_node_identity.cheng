import std/result
import std/system as system
import std/rawbytes
import std/crypto/hkdf
import cheng/std/bytes_layout as layout

const
    v3ChengNodeIdentityVersion: int32 = 1
    v3ChengNodeIdentityDomainTotal: int32 = 10
    v3ChengNodeIdentityTagRootId: int32 = 1
    v3ChengNodeIdentityTagChain: int32 = 2
    v3ChengNodeIdentityTagDid: int32 = 3
    v3ChengNodeIdentityTagLibp2p: int32 = 4
    v3ChengNodeIdentityTagDiscovery: int32 = 5
    v3ChengNodeIdentityTagOracle: int32 = 6
    v3ChengNodeIdentityTagDiloco: int32 = 7
    v3ChengNodeIdentityTagEvoMap: int32 = 8
    v3ChengNodeIdentityTagVpn: int32 = 9
    v3ChengNodeIdentityTagCompiler: int32 = 10
    v3ChengNodeIdentityTagAdmin: int32 = 11
    v3ChengNodeIdentityFixedBytes32Size: int32 = 32

type
    V3ChengNodeIdentity =
        version: int32
        rootId: layout.FixedBytes32
        rootKey: layout.FixedBytes32
        chainKey: layout.FixedBytes32
        didKey: layout.FixedBytes32
        libp2pKey: layout.FixedBytes32
        discoveryKey: layout.FixedBytes32
        oracleKey: layout.FixedBytes32
        dilocoKey: layout.FixedBytes32
        evomapKey: layout.FixedBytes32
        vpnKey: layout.FixedBytes32
        compilerKey: layout.FixedBytes32
        adminKey: layout.FixedBytes32

fn v3ChengNodeIdentityOwnText(text: str): str =
    return system.SystemToStringStr(text)

fn v3ChengNodeIdentityOwnBytes(text: str): Bytes =
    let owned = v3ChengNodeIdentityOwnText(text)
    return bytesSlice(bytesFromString(owned), 0, len(owned))

fn v3ChengNodeIdentitySaltBytes(): Bytes =
    return v3ChengNodeIdentityOwnBytes("cheng_node.identity.salt.v1")

fn v3ChengNodeIdentityTaggedBytes(rootKey: layout.FixedBytes32,
                                  tagId: int32): Bytes =
    var out = bytesAlloc(v3ChengNodeIdentityFixedBytes32Size + 4)
    for i in 0..<v3ChengNodeIdentityFixedBytes32Size:
        bytesSet(out, i, int32(rootKey.data[i]) & 255)
    bytesSet(out, v3ChengNodeIdentityFixedBytes32Size + 0, (tagId >> 24) & 255)
    bytesSet(out, v3ChengNodeIdentityFixedBytes32Size + 1, (tagId >> 16) & 255)
    bytesSet(out, v3ChengNodeIdentityFixedBytes32Size + 2, (tagId >> 8) & 255)
    bytesSet(out, v3ChengNodeIdentityFixedBytes32Size + 3, tagId & 255)
    return out

fn v3ChengNodeIdentityDomainTag(label: str): Result[int32] =
    if label == "chain":
        return Ok[int32](v3ChengNodeIdentityTagChain)
    if label == "did":
        return Ok[int32](v3ChengNodeIdentityTagDid)
    if label == "libp2p":
        return Ok[int32](v3ChengNodeIdentityTagLibp2p)
    if label == "discovery":
        return Ok[int32](v3ChengNodeIdentityTagDiscovery)
    if label == "oracle":
        return Ok[int32](v3ChengNodeIdentityTagOracle)
    if label == "diloco":
        return Ok[int32](v3ChengNodeIdentityTagDiloco)
    if label == "evomap":
        return Ok[int32](v3ChengNodeIdentityTagEvoMap)
    if label == "vpn":
        return Ok[int32](v3ChengNodeIdentityTagVpn)
    if label == "compiler":
        return Ok[int32](v3ChengNodeIdentityTagCompiler)
    if label == "admin":
        return Ok[int32](v3ChengNodeIdentityTagAdmin)
    return Err[int32]("cheng_node identity: unknown domain label")

fn v3ChengNodeIdentityDeriveRootKey(rootSeed: str): Result[layout.FixedBytes32] =
    if len(rootSeed) <= 0:
        return Err[layout.FixedBytes32]("cheng_node identity: empty root seed")
    let seedBytes = v3ChengNodeIdentityOwnBytes(rootSeed)
    let saltBytes = v3ChengNodeIdentitySaltBytes()
    let rootBytes = hkdf.hkdfExtractSha256(seedBytes, saltBytes)
    return layout.fixedBytes32FromBytes(rootBytes)

fn v3ChengNodeIdentityDeriveFromRootKey(rootKey: layout.FixedBytes32,
                                        label: str): Result[layout.FixedBytes32] =
    if len(label) <= 0:
        return Err[layout.FixedBytes32]("cheng_node identity: empty domain label")
    let tagRes = v3ChengNodeIdentityDomainTag(label)
    if IsErr(tagRes):
        return Err[layout.FixedBytes32](Error(tagRes))
    let combined = v3ChengNodeIdentityTaggedBytes(rootKey, Value(tagRes))
    let saltBytes = v3ChengNodeIdentitySaltBytes()
    let derivedBytes = hkdf.hkdfExtractSha256(combined, saltBytes)
    return layout.fixedBytes32FromBytes(derivedBytes)

fn v3ChengNodeIdentityDeriveRootId(rootKey: layout.FixedBytes32): Result[layout.FixedBytes32] =
    let combined = v3ChengNodeIdentityTaggedBytes(rootKey, v3ChengNodeIdentityTagRootId)
    let saltBytes = v3ChengNodeIdentitySaltBytes()
    let derivedBytes = hkdf.hkdfExtractSha256(combined, saltBytes)
    return layout.fixedBytes32FromBytes(derivedBytes)

fn v3ChengNodeIdentityDomainCount(): int32 =
    return v3ChengNodeIdentityDomainTotal

fn v3ChengNodeIdentityDomainNames(): str[] =
    var out: str[]
    out = []
    add(out, "chain")
    add(out, "did")
    add(out, "libp2p")
    add(out, "discovery")
    add(out, "oracle")
    add(out, "diloco")
    add(out, "evomap")
    add(out, "vpn")
    add(out, "compiler")
    add(out, "admin")
    return out

fn v3ChengNodeIdentityDomainKey(identity: V3ChengNodeIdentity,
                                domain: str): Result[layout.FixedBytes32] =
    if domain == "chain":
        return Ok[layout.FixedBytes32](identity.chainKey)
    if domain == "did":
        return Ok[layout.FixedBytes32](identity.didKey)
    if domain == "libp2p":
        return Ok[layout.FixedBytes32](identity.libp2pKey)
    if domain == "discovery":
        return Ok[layout.FixedBytes32](identity.discoveryKey)
    if domain == "oracle":
        return Ok[layout.FixedBytes32](identity.oracleKey)
    if domain == "diloco":
        return Ok[layout.FixedBytes32](identity.dilocoKey)
    if domain == "evomap":
        return Ok[layout.FixedBytes32](identity.evomapKey)
    if domain == "vpn":
        return Ok[layout.FixedBytes32](identity.vpnKey)
    if domain == "compiler":
        return Ok[layout.FixedBytes32](identity.compilerKey)
    if domain == "admin":
        return Ok[layout.FixedBytes32](identity.adminKey)
    return Err[layout.FixedBytes32]("cheng_node identity: unknown domain")

fn V3ChengNodeIdentityDerive(rootSeed: str): Result[V3ChengNodeIdentity] =
    let rootKeyRes = v3ChengNodeIdentityDeriveRootKey(rootSeed)
    if IsErr(rootKeyRes):
        return Err[V3ChengNodeIdentity](Error(rootKeyRes))
    let rootKey = Value(rootKeyRes)
    let rootIdRes = v3ChengNodeIdentityDeriveRootId(rootKey)
    if IsErr(rootIdRes):
        return Err[V3ChengNodeIdentity](Error(rootIdRes))
    let chainKeyRes = v3ChengNodeIdentityDeriveFromRootKey(rootKey, "chain")
    if IsErr(chainKeyRes):
        return Err[V3ChengNodeIdentity](Error(chainKeyRes))
    let didKeyRes = v3ChengNodeIdentityDeriveFromRootKey(rootKey, "did")
    if IsErr(didKeyRes):
        return Err[V3ChengNodeIdentity](Error(didKeyRes))
    let libp2pKeyRes = v3ChengNodeIdentityDeriveFromRootKey(rootKey, "libp2p")
    if IsErr(libp2pKeyRes):
        return Err[V3ChengNodeIdentity](Error(libp2pKeyRes))
    let discoveryKeyRes = v3ChengNodeIdentityDeriveFromRootKey(rootKey, "discovery")
    if IsErr(discoveryKeyRes):
        return Err[V3ChengNodeIdentity](Error(discoveryKeyRes))
    let oracleKeyRes = v3ChengNodeIdentityDeriveFromRootKey(rootKey, "oracle")
    if IsErr(oracleKeyRes):
        return Err[V3ChengNodeIdentity](Error(oracleKeyRes))
    let dilocoKeyRes = v3ChengNodeIdentityDeriveFromRootKey(rootKey, "diloco")
    if IsErr(dilocoKeyRes):
        return Err[V3ChengNodeIdentity](Error(dilocoKeyRes))
    let evomapKeyRes = v3ChengNodeIdentityDeriveFromRootKey(rootKey, "evomap")
    if IsErr(evomapKeyRes):
        return Err[V3ChengNodeIdentity](Error(evomapKeyRes))
    let vpnKeyRes = v3ChengNodeIdentityDeriveFromRootKey(rootKey, "vpn")
    if IsErr(vpnKeyRes):
        return Err[V3ChengNodeIdentity](Error(vpnKeyRes))
    let compilerKeyRes = v3ChengNodeIdentityDeriveFromRootKey(rootKey, "compiler")
    if IsErr(compilerKeyRes):
        return Err[V3ChengNodeIdentity](Error(compilerKeyRes))
    let adminKeyRes = v3ChengNodeIdentityDeriveFromRootKey(rootKey, "admin")
    if IsErr(adminKeyRes):
        return Err[V3ChengNodeIdentity](Error(adminKeyRes))
    var out: V3ChengNodeIdentity
    out.version = v3ChengNodeIdentityVersion
    out.rootId = Value(rootIdRes)
    out.rootKey = rootKey
    out.chainKey = Value(chainKeyRes)
    out.didKey = Value(didKeyRes)
    out.libp2pKey = Value(libp2pKeyRes)
    out.discoveryKey = Value(discoveryKeyRes)
    out.oracleKey = Value(oracleKeyRes)
    out.dilocoKey = Value(dilocoKeyRes)
    out.evomapKey = Value(evomapKeyRes)
    out.vpnKey = Value(vpnKeyRes)
    out.compilerKey = Value(compilerKeyRes)
    out.adminKey = Value(adminKeyRes)
    return Ok[V3ChengNodeIdentity](out)
