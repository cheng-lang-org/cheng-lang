import std/system as system

type
    ChengNodeStrIntMap =
        keys: str[]
        values: int32[]
        states: bool[]
        mask: int32
        used: int32

fn ChengNodeMapOwnText(text: str): str =
    return system.SystemToStringStr(text)

fn ChengNodeMapNextPow2(cap0: int32): int32 =
    var cap = 8
    while cap < cap0:
        cap = cap * 2
    return cap

fn ChengNodeStrIntMapInitInPlace(out: var ChengNodeStrIntMap, cap0: int32) =
    var cap: int32 = 8
    while cap < cap0:
        cap = cap * 2
    out.keys = []
    out.values = []
    out.states = []
    for i in 0..<cap:
        add(out.keys, "")
        add(out.values, 0)
        add(out.states, false)
    out.mask = cap - 1
    out.used = 0

fn ChengNodeStrIntMapHash(key: str): int32 =
    var hash: int64 = int64(2166136261)
    for i in 0..<len(key):
        hash = hash ^ int64(int32(key[i]) & 255)
        hash = (hash * int64(16777619)) & int64(0x7fffffff)
    return int32(hash)

fn ChengNodeStrIntMapFindSlot(map: ChengNodeStrIntMap,
                                key: str,
                                allowInsert: bool): int32 =
    if map.mask < 0:
        return -1
    if len(key) <= 0:
        return -1
    var slot = ChengNodeStrIntMapHash(key) & map.mask
    var scanned: int32
    for scanned in scanned..<= map.mask:
        if !map.states[slot]:
            if allowInsert:
                return slot
            return -1
        if map.keys[slot] == key:
            return slot
        slot = (slot + 1) & map.mask
    return -1

fn ChengNodeStrIntMapGrow(map: var ChengNodeStrIntMap) =
    var nextMap: ChengNodeStrIntMap
    ChengNodeStrIntMapInitInPlace(nextMap, (map.mask + 1) * 2)
    for i in 0..map.mask:
        if !map.states[i]:
            continue
        let slot = ChengNodeStrIntMapFindSlot(nextMap, map.keys[i], true)
        nextMap.keys[slot] = ChengNodeMapOwnText(map.keys[i])
        nextMap.values[slot] = map.values[i]
        nextMap.states[slot] = true
        nextMap.used = nextMap.used + 1
    map.keys = nextMap.keys
    map.values = nextMap.values
    map.states = nextMap.states
    map.mask = nextMap.mask
    map.used = nextMap.used

fn ChengNodeStrIntMapPut(map: var ChengNodeStrIntMap,
                           key: str,
                           value: int32) =
    if (map.used * 2) >= (map.mask + 1):
        ChengNodeStrIntMapGrow(map)
    let slot = ChengNodeStrIntMapFindSlot(map, key, true)
    if !map.states[slot]:
        map.used = map.used + 1
    map.keys[slot] = ChengNodeMapOwnText(key)
    map.values[slot] = value
    map.states[slot] = true

fn ChengNodeStrIntMapGet(map: ChengNodeStrIntMap,
                           key: str,
                           found: var bool): int32 =
    let slot = ChengNodeStrIntMapFindSlot(map, key, false)
    if slot < 0:
        found = false
        return 0
    found = true
    return map.values[slot]
