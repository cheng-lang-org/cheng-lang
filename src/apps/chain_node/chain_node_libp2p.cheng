import std/result
import std/rawbytes
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/binary_types as binary
import cheng/chain/codec_binary as codec
import cheng/chain/consensus
import cheng/chain/lsmr_types as lt
import cheng/overlay/contracts as overlay
import cheng/overlay/libp2p_bridge as bridge
import cheng/libp2p/core/types as core
import cheng/libp2p/host/host
import cheng/apps/chain_node/chain_node

const
    ChainNodeLibp2pSnapshotVersion: int32 = 1
    ChainNodeLibp2pSnapshotMagic: str = "cheng.chain_node.libp2p.snapshot"
    ChainNodeLibp2pSnapshotMagicLen: int32 = 29
    ChainNodeLibp2pSnapshotWireMinLen: int32 = 33

fn ChainNodeLibp2pAppendText(buf: var layout.ByteBuf, text: str) =
    for i in 0..<len(text):
        layout.ByteBufAppendByte(buf, int32(text[i]) & 255)

fn ChainNodeLibp2pAppendSnapshotMagic(buf: var layout.ByteBuf) =
    layout.ByteBufAppendByte(buf, int32('v'))
    layout.ByteBufAppendByte(buf, int32('3'))
    layout.ByteBufAppendByte(buf, int32('.'))
    layout.ByteBufAppendByte(buf, int32('c'))
    layout.ByteBufAppendByte(buf, int32('h'))
    layout.ByteBufAppendByte(buf, int32('a'))
    layout.ByteBufAppendByte(buf, int32('i'))
    layout.ByteBufAppendByte(buf, int32('n'))
    layout.ByteBufAppendByte(buf, int32('_'))
    layout.ByteBufAppendByte(buf, int32('n'))
    layout.ByteBufAppendByte(buf, int32('o'))
    layout.ByteBufAppendByte(buf, int32('d'))
    layout.ByteBufAppendByte(buf, int32('e'))
    layout.ByteBufAppendByte(buf, int32('.'))
    layout.ByteBufAppendByte(buf, int32('l'))
    layout.ByteBufAppendByte(buf, int32('i'))
    layout.ByteBufAppendByte(buf, int32('b'))
    layout.ByteBufAppendByte(buf, int32('p'))
    layout.ByteBufAppendByte(buf, int32('2'))
    layout.ByteBufAppendByte(buf, int32('p'))
    layout.ByteBufAppendByte(buf, int32('.'))
    layout.ByteBufAppendByte(buf, int32('s'))
    layout.ByteBufAppendByte(buf, int32('n'))
    layout.ByteBufAppendByte(buf, int32('a'))
    layout.ByteBufAppendByte(buf, int32('p'))
    layout.ByteBufAppendByte(buf, int32('s'))
    layout.ByteBufAppendByte(buf, int32('h'))
    layout.ByteBufAppendByte(buf, int32('o'))
    layout.ByteBufAppendByte(buf, int32('t'))

fn ChainNodeLibp2pPayloadHasSnapshotMagic(payload: Bytes): bool =
    if bytesLen(payload) < ChainNodeLibp2pSnapshotMagicLen:
        return false
    if bytesGet(payload, 0) != int32('v'):
        return false
    if bytesGet(payload, 1) != int32('3'):
        return false
    if bytesGet(payload, 2) != int32('.'):
        return false
    if bytesGet(payload, 3) != int32('c'):
        return false
    if bytesGet(payload, 4) != int32('h'):
        return false
    if bytesGet(payload, 5) != int32('a'):
        return false
    if bytesGet(payload, 6) != int32('i'):
        return false
    if bytesGet(payload, 7) != int32('n'):
        return false
    if bytesGet(payload, 8) != int32('_'):
        return false
    if bytesGet(payload, 9) != int32('n'):
        return false
    if bytesGet(payload, 10) != int32('o'):
        return false
    if bytesGet(payload, 11) != int32('d'):
        return false
    if bytesGet(payload, 12) != int32('e'):
        return false
    if bytesGet(payload, 13) != int32('.'):
        return false
    if bytesGet(payload, 14) != int32('l'):
        return false
    if bytesGet(payload, 15) != int32('i'):
        return false
    if bytesGet(payload, 16) != int32('b'):
        return false
    if bytesGet(payload, 17) != int32('p'):
        return false
    if bytesGet(payload, 18) != int32('2'):
        return false
    if bytesGet(payload, 19) != int32('p'):
        return false
    if bytesGet(payload, 20) != int32('.'):
        return false
    if bytesGet(payload, 21) != int32('s'):
        return false
    if bytesGet(payload, 22) != int32('n'):
        return false
    if bytesGet(payload, 23) != int32('a'):
        return false
    if bytesGet(payload, 24) != int32('p'):
        return false
    if bytesGet(payload, 25) != int32('s'):
        return false
    if bytesGet(payload, 26) != int32('h'):
        return false
    if bytesGet(payload, 27) != int32('o'):
        return false
    if bytesGet(payload, 28) != int32('t'):
        return false
    return true

fn ChainNodeLibp2pAppendI64BE(buf: var layout.ByteBuf, value: int64) =
    codec.BufAppendU32BE(buf, int64((value >> 32) & int64(0xffffffff)))
    codec.BufAppendU32BE(buf, int64(value & int64(0xffffffff)))

fn ChainNodeLibp2pReadI64BE(span: layout.ByteSpan, offset: int32): Result[int64] =
    let hiRes = codec.ReadU32BE(span, offset)
    if IsErr(hiRes):
        return Err[int64](Error(hiRes))
    let loRes = codec.ReadU32BE(span, offset + 4)
    if IsErr(loRes):
        return Err[int64](Error(loRes))
    let hi = int32(Value(hiRes))
    let lo = Value(loRes)
    return Ok[int64]((int64(hi) << 32) | (lo & int64(0xffffffff)))

fn ChainNodeLibp2pPayloadCid(payload: Bytes): layout.FixedBytes32 =
    var span: layout.ByteSpan
    span = layout.ByteSpanFromBytes(payload)
    var out: layout.FixedBytes32
    out = hash256.sha256Fixed(span)
    return out

fn ChainNodeLibp2pFillIngress(out: var overlay.IngressEnvelope,
                                sourcePeerId: core.Libp2pPeerId,
                                address: binary.LsmrAddress,
                                payload: Bytes,
                                stampEpoch: int32,
                                stampGanzhi: int32) =
    out.sourcePeerId = sourcePeerId.value
    out.topicScope = overlay.OverlayScopeCell
    chain_node.ChainNodeCopyAddress(out.address, address)
    out.payloadKind = 0
    out.payload = payload
    out.payloadCid = ChainNodeLibp2pPayloadCid(payload)
    out.payloadLen = bytesLen(payload)
    out.stampEpoch = stampEpoch
    out.stampGanzhi = stampGanzhi

fn ChainNodeLibp2pAppendSignature(buf: var layout.ByteBuf,
                                    signature: lt.AntiEntropySignature) =
    codec.BufAppendU32BE(buf, signature.stampEpoch)
    codec.BufAppendU32BE(buf, signature.stampGanzhi)
    codec.BufAppendU32BE(buf, signature.eventCount)
    codec.BufAppendU32BE(buf, signature.accountCount)
    codec.BufAppendFixed32(buf, signature.stateForestCid)
    codec.BufAppendU32BE(buf, signature.layerCount)
    for i in 0..<signature.layerCount:
        codec.BufAppendU32BE(buf, signature.layerSummaries[i].layerId)
        codec.BufAppendFixed32(buf, signature.layerSummaries[i].treeCid)
        codec.BufAppendU32BE(buf, signature.layerSummaries[i].nodeCount)
        codec.BufAppendU32BE(buf, signature.layerSummaries[i].entryCount)
    codec.BufAppendU32BE(buf, signature.rootCount)
    for i in 0..<signature.rootCount:
        codec.BufAppendU32BE(buf, signature.rootSummaries[i].layerId)
        codec.BufAppendU32BE(buf, signature.rootSummaries[i].baguaId)
        codec.BufAppendFixed32(buf, signature.rootSummaries[i].nodeCid)
        codec.BufAppendU32BE(buf, signature.rootSummaries[i].entryDescCount)

fn ChainNodeLibp2pDecodeSignature(span: layout.ByteSpan,
                                    offset0: int32,
                                    out: var lt.AntiEntropySignature): Result[int32] =
    var offset = offset0
    let epochRes = codec.ReadU32BE(span, offset)
    if IsErr(epochRes):
        return Err[int32](Error(epochRes))
    offset = offset + 4
    let ganzhiRes = codec.ReadU32BE(span, offset)
    if IsErr(ganzhiRes):
        return Err[int32](Error(ganzhiRes))
    offset = offset + 4
    let eventCountRes = codec.ReadU32BE(span, offset)
    if IsErr(eventCountRes):
        return Err[int32](Error(eventCountRes))
    offset = offset + 4
    let accountCountRes = codec.ReadU32BE(span, offset)
    if IsErr(accountCountRes):
        return Err[int32](Error(accountCountRes))
    offset = offset + 4
    let forestCidRes = codec.ReadFixed32(span, offset)
    if IsErr(forestCidRes):
        return Err[int32](Error(forestCidRes))
    offset = offset + 32
    let layerCountRes = codec.ReadU32BE(span, offset)
    if IsErr(layerCountRes):
        return Err[int32](Error(layerCountRes))
    offset = offset + 4

    out = lt.AntiEntropySignature()
    out.stampEpoch = int32(Value(epochRes))
    out.stampGanzhi = int32(Value(ganzhiRes))
    out.eventCount = int32(Value(eventCountRes))
    out.accountCount = int32(Value(accountCountRes))
    out.stateForestCid = Value(forestCidRes)
    out.layerCount = int32(Value(layerCountRes))
    if out.layerCount < 0 || out.layerCount > 3:
        return Err[int32](" chain_node libp2p: invalid signature layer count")
    for i in 0..<out.layerCount:
        let layerIdRes = codec.ReadU32BE(span, offset)
        if IsErr(layerIdRes):
            return Err[int32](Error(layerIdRes))
        offset = offset + 4
        let treeCidRes = codec.ReadFixed32(span, offset)
        if IsErr(treeCidRes):
            return Err[int32](Error(treeCidRes))
        offset = offset + 32
        let nodeCountRes = codec.ReadU32BE(span, offset)
        if IsErr(nodeCountRes):
            return Err[int32](Error(nodeCountRes))
        offset = offset + 4
        let entryCountRes = codec.ReadU32BE(span, offset)
        if IsErr(entryCountRes):
            return Err[int32](Error(entryCountRes))
        offset = offset + 4
        var summary: lt.StateLayerSummary
        summary.layerId = int32(Value(layerIdRes))
        summary.treeCid = Value(treeCidRes)
        summary.nodeCount = int32(Value(nodeCountRes))
        summary.entryCount = int32(Value(entryCountRes))
        out.layerSummaries[i] = summary
    let rootCountRes = codec.ReadU32BE(span, offset)
    if IsErr(rootCountRes):
        return Err[int32](Error(rootCountRes))
    offset = offset + 4
    out.rootCount = int32(Value(rootCountRes))
    if out.rootCount < 0 || out.rootCount > lt.BaguaRootSummaryMax:
        return Err[int32](" chain_node libp2p: invalid signature root count")
    for i in 0..<out.rootCount:
        let layerIdRes = codec.ReadU32BE(span, offset)
        if IsErr(layerIdRes):
            return Err[int32](Error(layerIdRes))
        offset = offset + 4
        let baguaIdRes = codec.ReadU32BE(span, offset)
        if IsErr(baguaIdRes):
            return Err[int32](Error(baguaIdRes))
        offset = offset + 4
        let nodeCidRes = codec.ReadFixed32(span, offset)
        if IsErr(nodeCidRes):
            return Err[int32](Error(nodeCidRes))
        offset = offset + 32
        let entryDescCountRes = codec.ReadU32BE(span, offset)
        if IsErr(entryDescCountRes):
            return Err[int32](Error(entryDescCountRes))
        offset = offset + 4
        var root: lt.BaguaRootSummary
        root.layerId = int32(Value(layerIdRes))
        root.baguaId = int32(Value(baguaIdRes))
        root.nodeCid = Value(nodeCidRes)
        root.entryDescCount = int32(Value(entryDescCountRes))
        out.rootSummaries[i] = root
    return Ok[int32](offset)

fn ChainNodeLibp2pAppendEvent(buf: var layout.ByteBuf,
                                eventCid: layout.FixedBytes32,
                                event: consensus.ChainEvent) =
    codec.BufAppendFixed32(buf, eventCid)
    codec.BufAppendU32BE(buf, event.version)
    codec.BufAppendU32BE(buf, event.kind)
    codec.BufAppendU32BE(buf, event.assetId)
    codec.BufAppendU32BE(buf, event.fromAccount)
    codec.BufAppendU32BE(buf, event.toAccount)
    codec.BufAppendFixed32(buf, event.fromParentCid)
    codec.BufAppendFixed32(buf, event.toParentCid)
    codec.BufAppendFixed32(buf, event.bodyCid)
    ChainNodeLibp2pAppendI64BE(buf, event.amount)
    codec.BufAppendU32BE(buf, event.epoch)
    codec.BufAppendU32BE(buf, event.ganzhiIndex)
    codec.BufAppendU32BE(buf, event.spaceSlot)
    ChainNodeLibp2pAppendI64BE(buf, event.tick)
    codec.BufAppendU32BE(buf, event.stem)
    codec.BufAppendU32BE(buf, event.branch)

fn ChainNodeLibp2pDecodeEvent(span: layout.ByteSpan,
                                offset0: int32,
                                eventCid: var layout.FixedBytes32,
                                event: var consensus.ChainEvent): Result[int32] =
    var offset = offset0
    let eventCidRes = codec.ReadFixed32(span, offset)
    if IsErr(eventCidRes):
        return Err[int32](Error(eventCidRes))
    offset = offset + 32
    let versionRes = codec.ReadU32BE(span, offset)
    if IsErr(versionRes):
        return Err[int32](Error(versionRes))
    offset = offset + 4
    let kindRes = codec.ReadU32BE(span, offset)
    if IsErr(kindRes):
        return Err[int32](Error(kindRes))
    offset = offset + 4
    let assetIdRes = codec.ReadU32BE(span, offset)
    if IsErr(assetIdRes):
        return Err[int32](Error(assetIdRes))
    offset = offset + 4
    let fromAccountRes = codec.ReadU32BE(span, offset)
    if IsErr(fromAccountRes):
        return Err[int32](Error(fromAccountRes))
    offset = offset + 4
    let toAccountRes = codec.ReadU32BE(span, offset)
    if IsErr(toAccountRes):
        return Err[int32](Error(toAccountRes))
    offset = offset + 4
    let fromParentRes = codec.ReadFixed32(span, offset)
    if IsErr(fromParentRes):
        return Err[int32](Error(fromParentRes))
    offset = offset + 32
    let toParentRes = codec.ReadFixed32(span, offset)
    if IsErr(toParentRes):
        return Err[int32](Error(toParentRes))
    offset = offset + 32
    let bodyCidRes = codec.ReadFixed32(span, offset)
    if IsErr(bodyCidRes):
        return Err[int32](Error(bodyCidRes))
    offset = offset + 32
    let amountRes = ChainNodeLibp2pReadI64BE(span, offset)
    if IsErr(amountRes):
        return Err[int32](Error(amountRes))
    offset = offset + 8
    let epochRes = codec.ReadU32BE(span, offset)
    if IsErr(epochRes):
        return Err[int32](Error(epochRes))
    offset = offset + 4
    let ganzhiRes = codec.ReadU32BE(span, offset)
    if IsErr(ganzhiRes):
        return Err[int32](Error(ganzhiRes))
    offset = offset + 4
    let slotRes = codec.ReadU32BE(span, offset)
    if IsErr(slotRes):
        return Err[int32](Error(slotRes))
    offset = offset + 4
    let tickRes = ChainNodeLibp2pReadI64BE(span, offset)
    if IsErr(tickRes):
        return Err[int32](Error(tickRes))
    offset = offset + 8
    let stemRes = codec.ReadU32BE(span, offset)
    if IsErr(stemRes):
        return Err[int32](Error(stemRes))
    offset = offset + 4
    let branchRes = codec.ReadU32BE(span, offset)
    if IsErr(branchRes):
        return Err[int32](Error(branchRes))
    offset = offset + 4

    var outEvent: consensus.ChainEvent
    outEvent.version = int32(Value(versionRes))
    outEvent.kind = int32(Value(kindRes))
    outEvent.assetId = int32(Value(assetIdRes))
    outEvent.fromAccount = int32(Value(fromAccountRes))
    outEvent.toAccount = int32(Value(toAccountRes))
    outEvent.fromParentCid = Value(fromParentRes)
    outEvent.toParentCid = Value(toParentRes)
    outEvent.bodyCid = Value(bodyCidRes)
    outEvent.amount = Value(amountRes)
    outEvent.epoch = int32(Value(epochRes))
    outEvent.ganzhiIndex = int32(Value(ganzhiRes))
    outEvent.spaceSlot = int32(Value(slotRes))
    outEvent.tick = Value(tickRes)
    outEvent.stem = int32(Value(stemRes))
    outEvent.branch = int32(Value(branchRes))
    if !layout.FixedBytes32Equal(outEvent.bodyCid, consensus.ChainEventBodyCid(outEvent)):
        return Err[int32](" chain_node libp2p: invalid event body cid")
    if !layout.FixedBytes32Equal(Value(eventCidRes), consensus.ChainEventCid(outEvent)):
        return Err[int32](" chain_node libp2p: invalid event cid")
    eventCid = Value(eventCidRes)
    event = outEvent
    return Ok[int32](offset)

fn ChainNodeLibp2pEncodeSnapshotFromParts(address: var binary.LsmrAddress,
                                            serveCount: int32,
                                            tipEventCid: layout.FixedBytes32,
                                            signature: var lt.AntiEntropySignature,
                                            eventCids: layout.FixedBytes32[],
                                            events: consensus.ChainEvent[]): Bytes =
    var buf: layout.ByteBuf = layout.ByteBufInit(2048)
    var tipEventCidCopy: layout.FixedBytes32
    tipEventCidCopy = tipEventCid
    var signatureCopy: lt.AntiEntropySignature
    chain_node.ChainNodeCopySignature(signatureCopy, signature)
    ChainNodeLibp2pAppendSnapshotMagic(buf)
    codec.BufAppendU32BE(buf, ChainNodeLibp2pSnapshotVersion)
    lt.AppendAddress(buf, address)
    codec.BufAppendU32BE(buf, serveCount)
    codec.BufAppendFixed32(buf, tipEventCidCopy)
    ChainNodeLibp2pAppendSignature(buf, signatureCopy)
    codec.BufAppendU32BE(buf, eventCids.len)
    for i in 0..<eventCids.len:
        var eventCid: layout.FixedBytes32
        eventCid = eventCids[i]
        var event: consensus.ChainEvent
        event = events[i]
        ChainNodeLibp2pAppendEvent(buf, eventCid, event)
    return layout.ByteBufToBytes(buf)

fn ChainNodeLibp2pEncodeSnapshot(snapshot: var chain_node.ChainNodeServeSnapshot): Bytes =
    return ChainNodeLibp2pEncodeSnapshotFromParts(snapshot.address,
                                                   snapshot.serveCount,
                                                   snapshot.tipEventCid,
                                                   snapshot.signature,
                                                   snapshot.eventCids,
                                                   snapshot.events)

fn ChainNodeLibp2pPayloadIsSnapshot(payload: Bytes): bool =
    return ChainNodeLibp2pPayloadHasSnapshotMagic(payload)

fn ChainNodeLibp2pDecodeSnapshotFill(payload: Bytes,
                                       out: var chain_node.ChainNodeServeSnapshot): Result[bool] =
    if bytesLen(payload) < ChainNodeLibp2pSnapshotWireMinLen:
        return Err[bool](" chain_node libp2p: short snapshot payload")
    if !ChainNodeLibp2pPayloadHasSnapshotMagic(payload):
        return Err[bool](" chain_node libp2p: bad snapshot magic")
    let span = layout.ByteSpanFromBytes(payload)
    var offset = ChainNodeLibp2pSnapshotMagicLen
    let versionRes = codec.ReadU32BE(span, offset)
    if IsErr(versionRes):
        return Err[bool](Error(versionRes))
    offset = offset + 4
    if int32(Value(versionRes)) != ChainNodeLibp2pSnapshotVersion:
        return Err[bool](" chain_node libp2p: bad snapshot version")
    var address: binary.LsmrAddress
    let addressRes = codec.ReadAddressFill(span, offset, address)
    if IsErr(addressRes):
        return Err[bool](Error(addressRes))
    offset = offset + 36
    let serveCountRes = codec.ReadU32BE(span, offset)
    if IsErr(serveCountRes):
        return Err[bool](Error(serveCountRes))
    offset = offset + 4
    let tipEventCidRes = codec.ReadFixed32(span, offset)
    if IsErr(tipEventCidRes):
        return Err[bool](Error(tipEventCidRes))
    offset = offset + 32
    let signatureNextOffsetRes = ChainNodeLibp2pDecodeSignature(span, offset, out.signature)
    if IsErr(signatureNextOffsetRes):
        return Err[bool](Error(signatureNextOffsetRes))
    offset = int32(Value(signatureNextOffsetRes))
    let eventCountRes = codec.ReadU32BE(span, offset)
    if IsErr(eventCountRes):
        return Err[bool](Error(eventCountRes))
    offset = offset + 4
    let eventCount = int32(Value(eventCountRes))
    if eventCount < 0:
        return Err[bool](" chain_node libp2p: invalid event count")
    out.eventCids = []
    out.events = []
    for i in 0..<eventCount:
        var eventCid: layout.FixedBytes32
        var event: consensus.ChainEvent
        let eventNextOffsetRes = ChainNodeLibp2pDecodeEvent(span, offset, eventCid, event)
        if IsErr(eventNextOffsetRes):
            return Err[bool](Error(eventNextOffsetRes))
        offset = int32(Value(eventNextOffsetRes))
        add(out.eventCids, eventCid)
        add(out.events, event)
    out.nodeId = ""
    chain_node.ChainNodeCopyAddress(out.address, address)
    out.serveCount = int32(Value(serveCountRes))
    out.tipEventCid = Value(tipEventCidRes)
    out.forest = lt.StateLayerForest()
    out.forest.forestCid = out.signature.stateForestCid
    return Ok[bool](true)

fn ChainNodeLibp2pDecodeSnapshotInto(payload: Bytes,
                                       out: var chain_node.ChainNodeServeSnapshot): Result[bool] =
    return ChainNodeLibp2pDecodeSnapshotFill(payload, out)

fn ChainNodeLibp2pSnapshotIngressInto(out: var overlay.IngressEnvelope,
                                        hostState: host.Libp2pHost,
                                        snapshot: var chain_node.ChainNodeServeSnapshot) =
    let payload = ChainNodeLibp2pEncodeSnapshotFromParts(snapshot.address,
                                                          snapshot.serveCount,
                                                          snapshot.tipEventCid,
                                                          snapshot.signature,
                                                          snapshot.eventCids,
                                                          snapshot.events)
    ChainNodeLibp2pFillIngress(out,
                                 hostState.selfPeerId,
                                 snapshot.address,
                                 payload,
                                 snapshot.signature.stampEpoch,
                                 snapshot.signature.stampGanzhi)

fn ChainNodeLibp2pAdvertiseIngressInto(out: var overlay.IngressEnvelope,
                                         hostState: host.Libp2pHost,
                                         snapshot: var chain_node.ChainNodeServeSnapshot): Result[bool] =
    let advertise = binary.AdvertisePayloadMake(
        hostState.selfPeerId.value,
        snapshot.forest.forestCid,
        snapshot.tipEventCid,
        snapshot.signature.accountCount,
        snapshot.signature.eventCount,
        snapshot.signature.stampEpoch,
        snapshot.signature.stampGanzhi
    )
    let frameRes = codec.EncodeAdvertiseFrame(advertise,
                                                snapshot.signature.stampEpoch,
                                                snapshot.signature.stampGanzhi)
    if IsErr(frameRes):
        return Err[bool](Error(frameRes))
    ChainNodeLibp2pFillIngress(out,
                                 hostState.selfPeerId,
                                 snapshot.address,
                                 Value(frameRes),
                                 snapshot.signature.stampEpoch,
                                 snapshot.signature.stampGanzhi)
    return Ok[bool](true)

fn ChainNodeLibp2pServeOnce(nodeState: var chain_node.ChainNode,
                              hostState: var host.Libp2pHost): Result[bool] =
    var snapshot: chain_node.ChainNodeServeSnapshot
    chain_node.ChainNodeServeOnceInto(snapshot, nodeState)
    var advertiseIngress: overlay.IngressEnvelope
    let advertiseIngressRes = ChainNodeLibp2pAdvertiseIngressInto(advertiseIngress,
                                                                    hostState,
                                                                    snapshot)
    if IsErr(advertiseIngressRes):
        return Err[bool](Error(advertiseIngressRes))
    bridge.Libp2pRelayPublish(hostState, advertiseIngress)
    var snapshotIngress: overlay.IngressEnvelope
    ChainNodeLibp2pSnapshotIngressInto(snapshotIngress, hostState, snapshot)
    host.Libp2pStorePut(hostState, snapshotIngress)
    host.Libp2pKadProvide(hostState, snapshot.tipEventCid)
    host.Libp2pKadProvide(hostState, snapshot.forest.forestCid)
    return Ok[bool](true)

fn ChainNodeLibp2pStampLess(leftEpoch: int32,
                              leftGanzhi: int32,
                              rightEpoch: int32,
                              rightGanzhi: int32): bool =
    if leftEpoch != rightEpoch:
        return leftEpoch < rightEpoch
    return leftGanzhi < rightGanzhi

fn ChainNodeLibp2pSnapshotQueryFill(out: var overlay.StoreQuery,
                                      address: binary.LsmrAddress) =
    out = overlay.StoreQuery()
    out.topicScope = overlay.OverlayScopeCell
    out.address = address

fn ChainNodeLibp2pCopyIngress(out: var overlay.IngressEnvelope,
                                ingress: overlay.IngressEnvelope) =
    out.sourcePeerId = ingress.sourcePeerId
    out.topicScope = ingress.topicScope
    out.address.depth = ingress.address.depth
    for i in 0..<binary.LsmrMaxDepth:
        out.address.digits[i] = ingress.address.digits[i]
    out.payloadKind = ingress.payloadKind
    out.payload = bytesSlice(ingress.payload, 0, bytesLen(ingress.payload))
    out.payloadCid = ingress.payloadCid
    out.payloadLen = ingress.payloadLen
    out.stampEpoch = ingress.stampEpoch
    out.stampGanzhi = ingress.stampGanzhi

fn ChainNodeLibp2pLatestSnapshotIndexFromIngresses(entries: overlay.IngressEnvelope[],
                                                     address: binary.LsmrAddress): Result[int32] =
    var bestIndex = -1
    for i in 0..<entries.len:
        if entries[i].topicScope != overlay.OverlayScopeCell:
            continue
        if !binary.LsmrAddressEqual(entries[i].address, address):
            continue
        if !ChainNodeLibp2pPayloadIsSnapshot(entries[i].payload):
            continue
        if bestIndex < 0:
            bestIndex = i
            continue
        if ChainNodeLibp2pStampLess(entries[bestIndex].stampEpoch,
                                      entries[bestIndex].stampGanzhi,
                                      entries[i].stampEpoch,
                                      entries[i].stampGanzhi):
            bestIndex = i
    if bestIndex < 0:
        return Err[int32](" chain_node libp2p: snapshot missing")
    return Ok[int32](bestIndex)

fn ChainNodeLibp2pLatestSnapshotHostIndex(remoteHost: host.Libp2pHost,
                                            address: binary.LsmrAddress): Result[int32] =
    var bestIndex = -1
    for i in 0..<remoteHost.storeEntries.len:
        if remoteHost.storeEntries[i].ingress.topicScope != overlay.OverlayScopeCell:
            continue
        if !binary.LsmrAddressEqual(remoteHost.storeEntries[i].ingress.address, address):
            continue
        if !ChainNodeLibp2pPayloadIsSnapshot(remoteHost.storeEntries[i].ingress.payload):
            continue
        if bestIndex < 0:
            bestIndex = i
            continue
        if ChainNodeLibp2pStampLess(remoteHost.storeEntries[bestIndex].ingress.stampEpoch,
                                      remoteHost.storeEntries[bestIndex].ingress.stampGanzhi,
                                      remoteHost.storeEntries[i].ingress.stampEpoch,
                                      remoteHost.storeEntries[i].ingress.stampGanzhi):
            bestIndex = i
    if bestIndex < 0:
        return Err[int32](" chain_node libp2p: snapshot missing")
    return Ok[int32](bestIndex)

fn ChainNodeLibp2pLatestSnapshotFromIngressesInto(entries: overlay.IngressEnvelope[],
                                                    address: binary.LsmrAddress,
                                                    out: var overlay.IngressEnvelope): Result[int32] =
    let bestIndexRes = ChainNodeLibp2pLatestSnapshotIndexFromIngresses(entries, address)
    if IsErr(bestIndexRes):
        return Err[int32](Error(bestIndexRes))
    ChainNodeLibp2pCopyIngress(out, entries[Value(bestIndexRes)])
    return Ok[int32](Value(bestIndexRes))

fn ChainNodeLibp2pLatestSnapshotInto(remoteHost: host.Libp2pHost,
                                       address: binary.LsmrAddress,
                                       out: var overlay.IngressEnvelope): Result[int32] =
    let bestIndexRes = ChainNodeLibp2pLatestSnapshotHostIndex(remoteHost, address)
    if IsErr(bestIndexRes):
        return Err[int32](Error(bestIndexRes))
    ChainNodeLibp2pCopyIngress(out, remoteHost.storeEntries[Value(bestIndexRes)].ingress)
    return Ok[int32](Value(bestIndexRes))

fn ChainNodeLibp2pDecodeLatestSnapshotFill(entries: overlay.IngressEnvelope[],
                                             address: binary.LsmrAddress,
                                             out: var chain_node.ChainNodeServeSnapshot): Result[bool] =
    var ingress: overlay.IngressEnvelope
    let bestIndexRes = ChainNodeLibp2pLatestSnapshotIndexFromIngresses(entries, address)
    if IsErr(bestIndexRes):
        return Err[bool](Error(bestIndexRes))
    let bestIndex = Value(bestIndexRes)
    let bestIngress = entries[bestIndex]
    ChainNodeLibp2pCopyIngress(ingress, bestIngress)
    return ChainNodeLibp2pDecodeSnapshotFill(ingress.payload, out)

fn ChainNodeLibp2pDecodeLatestSnapshotFromHostFill(remoteHost: host.Libp2pHost,
                                                     address: binary.LsmrAddress,
                                                     out: var chain_node.ChainNodeServeSnapshot): Result[bool] =
    var ingress: overlay.IngressEnvelope
    let bestIndexRes = ChainNodeLibp2pLatestSnapshotHostIndex(remoteHost, address)
    if IsErr(bestIndexRes):
        return Err[bool](Error(bestIndexRes))
    let bestIndex = Value(bestIndexRes)
    let bestEntry = remoteHost.storeEntries[bestIndex]
    ChainNodeLibp2pCopyIngress(ingress, bestEntry.ingress)
    return ChainNodeLibp2pDecodeSnapshotFill(ingress.payload, out)
