import std/result
import std/system as system
import cheng/std/bytes_layout as layout
import cheng/std/crypto/hash256
import cheng/chain/lsmr_types as lt

type
    ChengNodeEventRecord =
        seq: int32
        actorName: str
        objectKind: str
        indexGroup: str
        lookupKind: str
        keyText: str
        payloadCid: layout.FixedBytes32
        prevEventCid: layout.FixedBytes32
        eventCid: layout.FixedBytes32

    ChengNodeSnapshotSegment =
        snapshotVersion: int32
        startSeq: int32
        endSeq: int32
        snapshotCid: layout.FixedBytes32
        segmentCid: layout.FixedBytes32

    ChengNodeManifest =
        version: int32
        headSeq: int32
        headEventCid: layout.FixedBytes32
        snapshotVersion: int32
        snapshotCid: layout.FixedBytes32
        segmentSnapshotVersions: int32[]
        segmentStartSeqs: int32[]
        segmentEndSeqs: int32[]
        segmentCids: layout.FixedBytes32[]
        headCid: layout.FixedBytes32

    ChengNodeProofBundle =
        version: int32
        indexGroup: str
        lookupKind: str
        keyText: str
        valueCid: layout.FixedBytes32
        eventCid: layout.FixedBytes32
        manifestHeadCid: layout.FixedBytes32
        snapshotVersion: int32
        snapshotCid: layout.FixedBytes32
        proofCid: layout.FixedBytes32

    ChengNodeLedger =
        manifest: ChengNodeManifest
        events: ChengNodeEventRecord[]
        segments: ChengNodeSnapshotSegment[]
        proofs: ChengNodeProofBundle[]

fn ChengNodeLedgerOwnText(text: str): str =
    return system.SystemToStringStr(text)

fn ChengNodeLedgerAppendText(buf: var layout.ByteBuf, text: str) =
    lt.AppendU32BE(buf, len(text))
    for i in 0..<len(text):
        layout.ByteBufAppendByte(buf, int32(text[i]) & 255)

fn ChengNodeLedgerAppendFixed32(buf: var layout.ByteBuf, value: layout.FixedBytes32) =
    lt.AppendFixed32(buf, value)

fn ChengNodeLedgerBufCid(buf: var layout.ByteBuf): layout.FixedBytes32 =
    let data = layout.ByteBufToBytes(buf)
    return hash256.Sha256Fixed(layout.ByteSpanFromBytes(data))

fn ChengNodeLedgerEventCid(event: ChengNodeEventRecord): layout.FixedBytes32 =
    var buf = layout.ByteBufInit(256)
    ChengNodeLedgerAppendText(buf, "cheng_node.event")
    lt.AppendU32BE(buf, event.seq)
    ChengNodeLedgerAppendText(buf, event.actorName)
    ChengNodeLedgerAppendText(buf, event.objectKind)
    ChengNodeLedgerAppendText(buf, event.indexGroup)
    ChengNodeLedgerAppendText(buf, event.lookupKind)
    ChengNodeLedgerAppendText(buf, event.keyText)
    ChengNodeLedgerAppendFixed32(buf, event.payloadCid)
    ChengNodeLedgerAppendFixed32(buf, event.prevEventCid)
    return ChengNodeLedgerBufCid(buf)

fn ChengNodeLedgerSegmentCid(segment: ChengNodeSnapshotSegment,
                               headEventCid: layout.FixedBytes32): layout.FixedBytes32 =
    var buf = layout.ByteBufInit(192)
    ChengNodeLedgerAppendText(buf, "cheng_node.snapshot_segment")
    lt.AppendU32BE(buf, segment.snapshotVersion)
    lt.AppendU32BE(buf, segment.startSeq)
    lt.AppendU32BE(buf, segment.endSeq)
    ChengNodeLedgerAppendFixed32(buf, segment.snapshotCid)
    ChengNodeLedgerAppendFixed32(buf, headEventCid)
    return ChengNodeLedgerBufCid(buf)

fn ChengNodeLedgerRefreshManifestHead(manifest: var ChengNodeManifest) =
    if manifest.segmentSnapshotVersions.len != manifest.segmentCids.len:
        panic "cheng_node ledger: manifest snapshot version count mismatch"
    if manifest.segmentStartSeqs.len != manifest.segmentCids.len:
        panic "cheng_node ledger: manifest segment start count mismatch"
    if manifest.segmentEndSeqs.len != manifest.segmentCids.len:
        panic "cheng_node ledger: manifest segment end count mismatch"
    if manifest.segmentCids.len > 4096:
        panic "cheng_node ledger: manifest segment count overflow"
    var buf = layout.ByteBufInit(256)
    ChengNodeLedgerAppendText(buf, "cheng_node.manifest")
    lt.AppendU32BE(buf, manifest.version)
    lt.AppendU32BE(buf, manifest.headSeq)
    ChengNodeLedgerAppendFixed32(buf, manifest.headEventCid)
    lt.AppendU32BE(buf, manifest.snapshotVersion)
    ChengNodeLedgerAppendFixed32(buf, manifest.snapshotCid)
    lt.AppendU32BE(buf, manifest.segmentCids.len)
    for i in 0..<manifest.segmentCids.len:
        lt.AppendU32BE(buf, manifest.segmentSnapshotVersions[i])
        lt.AppendU32BE(buf, manifest.segmentStartSeqs[i])
        lt.AppendU32BE(buf, manifest.segmentEndSeqs[i])
        ChengNodeLedgerAppendFixed32(buf, manifest.segmentCids[i])
    if layout.ByteBufLen(buf) > 4096:
        panic "cheng_node ledger: manifest head wire overflow"
    manifest.headCid = ChengNodeLedgerBufCid(buf)

fn ChengNodeLedgerInit(): ChengNodeLedger =
    var out: ChengNodeLedger
    out.events = []
    out.segments = []
    out.proofs = []
    out.manifest.version = 1
    out.manifest.headSeq = 0
    out.manifest.headEventCid = layout.FixedBytes32()
    out.manifest.snapshotVersion = 0
    out.manifest.snapshotCid = layout.FixedBytes32()
    out.manifest.segmentSnapshotVersions = []
    out.manifest.segmentStartSeqs = []
    out.manifest.segmentEndSeqs = []
    out.manifest.segmentCids = []
    ChengNodeLedgerRefreshManifestHead(out.manifest)
    return out

fn ChengNodeLedgerAppend(ledger: var ChengNodeLedger,
                           actorName: str,
                           objectKind: str,
                           indexGroup: str,
                           lookupKind: str,
                           keyText: str,
                           payloadCid: layout.FixedBytes32): Result[ChengNodeEventRecord] =
    if len(actorName) <= 0:
        return Err[ChengNodeEventRecord]("cheng_node ledger: empty actor")
    if len(indexGroup) <= 0:
        return Err[ChengNodeEventRecord]("cheng_node ledger: empty index group")
    let prevEventCid = ledger.manifest.headEventCid
    var event: ChengNodeEventRecord
    event.seq = ledger.events.len + 1
    event.actorName = ChengNodeLedgerOwnText(actorName)
    event.objectKind = ChengNodeLedgerOwnText(objectKind)
    event.indexGroup = ChengNodeLedgerOwnText(indexGroup)
    event.lookupKind = ChengNodeLedgerOwnText(lookupKind)
    event.keyText = ChengNodeLedgerOwnText(keyText)
    event.payloadCid = payloadCid
    event.prevEventCid = prevEventCid
    event.eventCid = ChengNodeLedgerEventCid(event)
    add(ledger.events, event)
    ledger.manifest.headSeq = event.seq
    ledger.manifest.headEventCid = event.eventCid
    ChengNodeLedgerRefreshManifestHead(ledger.manifest)
    return Ok[ChengNodeEventRecord](event)

fn ChengNodeLedgerSealSnapshot(ledger: var ChengNodeLedger,
                                 snapshotVersion: int32,
                                 snapshotCid: layout.FixedBytes32): Result[ChengNodeSnapshotSegment] =
    if snapshotVersion <= 0:
        return Err[ChengNodeSnapshotSegment]("cheng_node ledger: invalid snapshot version")
    var segment: ChengNodeSnapshotSegment
    segment.snapshotVersion = snapshotVersion
    if ledger.segments.len > 0:
        segment.startSeq = ledger.segments[ledger.segments.len - 1].endSeq + 1
    else:
        segment.startSeq = ledger.manifest.headSeq > 0 ? 1 : 0
    segment.endSeq = ledger.manifest.headSeq
    segment.snapshotCid = snapshotCid
    segment.segmentCid = ChengNodeLedgerSegmentCid(segment, ledger.manifest.headEventCid)
    add(ledger.segments, segment)
    add(ledger.manifest.segmentSnapshotVersions, segment.snapshotVersion)
    add(ledger.manifest.segmentStartSeqs, segment.startSeq)
    add(ledger.manifest.segmentEndSeqs, segment.endSeq)
    add(ledger.manifest.segmentCids, segment.segmentCid)
    ledger.manifest.snapshotVersion = snapshotVersion
    ledger.manifest.snapshotCid = snapshotCid
    ChengNodeLedgerRefreshManifestHead(ledger.manifest)
    return Ok[ChengNodeSnapshotSegment](segment)

fn ChengNodeLedgerBuildProof(ledger: var ChengNodeLedger,
                               indexGroup: str,
                               lookupKind: str,
                               keyText: str,
                               valueCid: layout.FixedBytes32,
                               eventCid: layout.FixedBytes32): Result[ChengNodeProofBundle] =
    var proof: ChengNodeProofBundle
    proof.version = 1
    proof.indexGroup = ChengNodeLedgerOwnText(indexGroup)
    proof.lookupKind = ChengNodeLedgerOwnText(lookupKind)
    proof.keyText = ChengNodeLedgerOwnText(keyText)
    proof.valueCid = valueCid
    proof.eventCid = eventCid
    proof.manifestHeadCid = ledger.manifest.headCid
    proof.snapshotVersion = ledger.manifest.snapshotVersion
    proof.snapshotCid = ledger.manifest.snapshotCid
    var buf = layout.ByteBufInit(256)
    ChengNodeLedgerAppendText(buf, "cheng_node.proof")
    ChengNodeLedgerAppendText(buf, proof.indexGroup)
    ChengNodeLedgerAppendText(buf, proof.lookupKind)
    ChengNodeLedgerAppendText(buf, proof.keyText)
    ChengNodeLedgerAppendFixed32(buf, proof.valueCid)
    ChengNodeLedgerAppendFixed32(buf, proof.eventCid)
    ChengNodeLedgerAppendFixed32(buf, proof.manifestHeadCid)
    lt.AppendU32BE(buf, proof.snapshotVersion)
    ChengNodeLedgerAppendFixed32(buf, proof.snapshotCid)
    proof.proofCid = ChengNodeLedgerBufCid(buf)
    add(ledger.proofs, proof)
    return Ok[ChengNodeProofBundle](proof)
