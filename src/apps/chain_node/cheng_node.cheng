                                                 receiptKey,
                                                 receipt.receiptCid)

fn ChengNodeBundleCidFromMoqBuild(build: moq.MoqFountainBuildResult): layout.FixedBytes32 =
    let bundleCidRes = layout.FixedBytes32FromHex(build.bundleCid)
    if IsOk(bundleCidRes):
        return Value(bundleCidRes)
    return ChengNodeHashTextCid("content.moq_fountain.bundle", build.bundleCid)

fn ChengNodeAnchorMoqBuild(node: var ChengNode,
                             build: moq.MoqFountainBuildResult): Result[ledger.ChengNodeProofBundle] =
    let buildText = ChengNodeMoqBuildText(build)
    let capabilityProofRes = ChengNodeAnchorIndexedText(node,
                                                          "content_moq_fountain",
                                                          "discovery",
                                                          "capability",
                                                          "content.moq_fountain",
                                                          "moq_fountain_capability",
                                                          buildText)
    if IsErr(capabilityProofRes):
        return Err[ledger.ChengNodeProofBundle](Error(capabilityProofRes))
    return ChengNodeAnchorIndexedText(node,
                                        "content_moq_fountain",
                                        "discovery",
                                        "topic",
                                        build.catalogKey,
                                        "moq_fountain_catalog",
                                        buildText)

fn ChengNodeRequiredIndexCount(node: ChengNode): int32 =
    return cindex.ChengNodeIndexRequiredGroupCount(node.indices)

fn ChengNodeCapabilityActorCount(node: ChengNode): int32 =
    return actor.ChengNodeActorCount(node.actors)

fn ChengNodeActiveIndexCount(node: ChengNode,
                               groupName: str): int32 =
    var count = 0
    for i in 0..<node.indices.entries.len:
        let entry = node.indices.entries[i]
        if entry.active && entry.groupName == groupName:
            count = count + 1
    return count

fn ChengNodeProofBundleByCid(node: ChengNode,
                               proofCid: layout.FixedBytes32): Result[ledger.ChengNodeProofBundle] =
    for i in 0..<node.ledger.proofs.len:
        let proof = node.ledger.proofs[i]
        if layout.FixedBytes32Equal(proof.proofCid, proofCid):
            return Ok[ledger.ChengNodeProofBundle](proof)
    return Err[ledger.ChengNodeProofBundle]("cheng_node: proof not found")

fn ChengNodeSnapshotSegmentByVersion(node: ChengNode,
                                       snapshotVersion: int32): Result[ledger.ChengNodeSnapshotSegment] =
    for i in 0..<node.ledger.segments.len:
        let segment = node.ledger.segments[i]
        if segment.snapshotVersion == snapshotVersion:
            return Ok[ledger.ChengNodeSnapshotSegment](segment)
    return Err[ledger.ChengNodeSnapshotSegment]("cheng_node: snapshot segment not found")

fn ChengNodeHeadManifestText(node: ChengNode): str =
    var out = ""
    out = strutil.Join([out, "version=", intToStr(node.ledger.manifest.version), "\n"], "")
    out = strutil.Join([out, "head_seq=", intToStr(node.ledger.manifest.headSeq), "\n"], "")
    out = strutil.Join([out, "head_event_cid=", layout.FixedBytes32Hex(node.ledger.manifest.headEventCid), "\n"], "")
    out = strutil.Join([out, "snapshot_version=", intToStr(node.ledger.manifest.snapshotVersion), "\n"], "")
    out = strutil.Join([out, "snapshot_cid=", layout.FixedBytes32Hex(node.ledger.manifest.snapshotCid), "\n"], "")
    out = strutil.Join([out, "manifest_head_cid=", layout.FixedBytes32Hex(node.ledger.manifest.headCid)], "")
    return out

fn ChengNodeKeyedQueryText(node: ChengNode,
                             indexGroup: str,
                             lookupKind: str,
                             keyText: str,
                             withDelta: bool): Result[str] =
    var out = ""
    out = strutil.Join([out, "manifest_head_cid=", layout.FixedBytes32Hex(node.ledger.manifest.headCid), "\n"], "")
    out = strutil.Join([out, "index_group=", indexGroup, "\n"], "")
    out = strutil.Join([out, "lookup_kind=", lookupKind, "\n"], "")
    out = strutil.Join([out, "key_text_hex=", bytesToHex(bytesFromString(keyText)), "\n"], "")
    let entryRes = cindex.ChengNodeIndexGet(node.indices, indexGroup, lookupKind, keyText)
    if IsErr(entryRes):
        out = strutil.Join([out, "found=0\n"], "")
        if withDelta:
            out = strutil.Join([out, "delta_count=0\n"], "")
        return Ok[str](out)
    let entry = Value(entryRes)
    let proofRes = ChengNodeProofBundleByCid(node, entry.proofCid)
    if IsErr(proofRes):
        return Err[str](Error(proofRes))
    let proof = Value(proofRes)
    out = strutil.Join([out, "found=1\n"], "")
    out = strutil.Join([out, "event_seq=", intToStr(entry.eventSeq), "\n"], "")
    out = strutil.Join([out, "value_cid=", layout.FixedBytes32Hex(entry.valueCid), "\n"], "")
    out = strutil.Join([out, "proof_cid=", layout.FixedBytes32Hex(entry.proofCid), "\n"], "")
    out = strutil.Join([out, "event_cid=", layout.FixedBytes32Hex(proof.eventCid), "\n"], "")
    out = strutil.Join([out, "snapshot_version=", intToStr(proof.snapshotVersion), "\n"], "")
    out = strutil.Join([out, "snapshot_cid=", layout.FixedBytes32Hex(proof.snapshotCid), "\n"], "")
    let objectRes = cobject.ChengNodeObjectStoreGet(node.objects, entry.valueCid)
    if IsOk(objectRes):
        let objectEntry = Value(objectRes)
        out = strutil.Join([out, "payload_present=1\n"], "")
        out = strutil.Join([out, "payload_kind=", objectEntry.objectKind, "\n"], "")
        out = strutil.Join([out, "payload_text_hex=", bytesToHex(bytesFromString(objectEntry.text)), "\n"], "")
    else:
        out = strutil.Join([out, "payload_present=0\n"], "")
    if withDelta:
        let segmentRes = ChengNodeSnapshotSegmentByVersion(node, proof.snapshotVersion)
        if IsErr(segmentRes):
            return Err[str](Error(segmentRes))
        let segment = Value(segmentRes)
        out = strutil.Join([out, "delta_count=1\n"], "")
        out = strutil.Join([out, "delta.segment_snapshot_version=", intToStr(segment.snapshotVersion), "\n"], "")
        out = strutil.Join([out, "delta.segment_start_seq=", intToStr(segment.startSeq), "\n"], "")
        out = strutil.Join([out, "delta.segment_end_seq=", intToStr(segment.endSeq), "\n"], "")
        out = strutil.Join([out, "delta.segment_cid=", layout.FixedBytes32Hex(segment.segmentCid), "\n"], "")
    return Ok[str](out)

fn ChengNodeBalanceQueryText(node: ChengNode,
                               assetId: int32,
                               accountId: int32,
                               withDelta: bool): Result[str] =
    let keyText = cindex.ChengNodeBalanceKey(assetId, accountId)
    let queryRes = ChengNodeKeyedQueryText(node,
                                             "balance",
                                             "asset_account",
                                             keyText,
                                             withDelta)
    if IsErr(queryRes):
        return Err[str](Error(queryRes))
    var out = ""
    out = strutil.Join([out, "asset_id=", intToStr(assetId), "\n"], "")
    out = strutil.Join([out, "account_id=", intToStr(accountId), "\n"], "")
    let entryRes = cindex.ChengNodeIndexGet(node.indices, "balance", "asset_account", keyText)
    if IsErr(entryRes):
        out = strutil.Join([out, "balance=0\n"], "")
        out = strutil.Join([out, Value(queryRes)], "")
        return Ok[str](out)
    let entry = Value(entryRes)
    let objectRes = cobject.ChengNodeObjectStoreGet(node.objects, entry.valueCid)
    if IsErr(objectRes):
        return Err[str](Error(objectRes))
    let balance = ChengNodeBalanceValueFromText(Value(objectRes).text)
    out = strutil.Join([out, "balance=", int64ToStr(balance), "\n"], "")
    out = strutil.Join([out, Value(queryRes)], "")
    return Ok[str](out)

fn ChengNodeRequiredSurfaceText(node: ChengNode): str =
    var out = ""
    out = strutil.Join([out, "required_indexes=", intToStr(node.indices.specs.len), "\n"], "")
    for i in 0..<node.indices.specs.len:
        out = strutil.Join([out, "index.", intToStr(i), "=", node.indices.specs[i]], "")strutil.Join([.groupName, "\n"], "")
    out = strutil.Join([out, "actors=", intToStr(node.actors.actors.len), "\n"], "")
    for i in 0..<node.actors.actors.len:
        out = strutil.Join([out, "actor.", intToStr(i), "=", node.actors.actors[i]], "")strutil.Join([.name, "\n"], "")
    return out

fn ChengNodeBootstrapSummaryText(node: ChengNode): str =
    var out = ""
    out = strutil.Join([out, "root_id=", layout.FixedBytes32Hex(node.identity.rootId), "\n"], "")
    out = strutil.Join([out, "required_index_count=", intToStr(ChengNodeRequiredIndexCount(node)), "\n"], "")
    out = strutil.Join([out, "actor_count=", intToStr(ChengNodeCapabilityActorCount(node)), "\n"], "")
    out = strutil.Join([out, "object_count=", intToStr(cobject.ChengNodeObjectCount(node.objects)), "\n"], "")
    out = strutil.Join([out, "balance_index_count=", intToStr(ChengNodeActiveIndexCount(node, "balance")), "\n"], "")
    out = strutil.Join([out, "did_index_count=", intToStr(ChengNodeActiveIndexCount(node, "did")), "\n"], "")
    out = strutil.Join([out, "did_operator_index_count=", intToStr(ChengNodeActiveIndexCount(node, "did_operator")), "\n"], "")
    out = strutil.Join([out, "discovery_index_count=", intToStr(ChengNodeActiveIndexCount(node, "discovery")), "\n"], "")
    out = strutil.Join([out, "oracle_index_count=", intToStr(ChengNodeActiveIndexCount(node, "oracle")), "\n"], "")
    out = strutil.Join([out, "diloco_job_index_count=", intToStr(ChengNodeActiveIndexCount(node, "diloco_job")), "\n"], "")
    out = strutil.Join([out, "diloco_cohort_index_count=", intToStr(ChengNodeActiveIndexCount(node, "diloco_cohort")), "\n"], "")
    out = strutil.Join([out, "diloco_lease_index_count=", intToStr(ChengNodeActiveIndexCount(node, "diloco_lease")), "\n"], "")
    out = strutil.Join([out, "evomap_index_count=", intToStr(ChengNodeActiveIndexCount(node, "evomap")), "\n"], "")
    out = strutil.Join([out, "vpn_peer_index_count=", intToStr(ChengNodeActiveIndexCount(node, "vpn_peer")), "\n"], "")
    out = strutil.Join([out, "vpn_route_index_count=", intToStr(ChengNodeActiveIndexCount(node, "vpn_route")), "\n"], "")
    out = strutil.Join([out, "manifest_head_seq=", intToStr(node.ledger.manifest.headSeq), "\n"], "")
    out = strutil.Join([out, "manifest_head_cid=", layout.FixedBytes32Hex(node.ledger.manifest.headCid), "\n"], "")
    out = strutil.Join([out, "chain_tip_event_cid=", layout.FixedBytes32Hex(node.chainState.tipEventCid), "\n"], "")
    out = strutil.Join([out, "chain_event_count=", intToStr(node.chainState.events.len), "\n"], "")
    out = strutil.Join([out, "transport_peer_id=", ctransport.ChengNodeTransportPeerIdText(node.transport)], "")
    return out
