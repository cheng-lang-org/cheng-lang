fn ChengNodeAnchorCompilerBuildReceiptReport(node: var ChengNode,
                                               receiptKey: str,
                                               receipt: ccsg.CompileReceipt): Result[ledger.ChengNodeProofBundle] =
    let targetProofRes = ChengNodeAnchorIndexedText(node,
                                                      "compiler",
                                                      "compiler",
                                                      "target",
                                                      receipt.targetTriple,
                                                      "compiler_target_receipt",
                                                      ChengNodeCompilerTargetReceiptText(receiptKey, receipt))
