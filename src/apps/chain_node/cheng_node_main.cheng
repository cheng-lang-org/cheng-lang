import std/cmdline as cmdline
import cheng/apps/chain_node/cheng_node_ctl_main as nodecmd

fn main(argc: int32, argv: str*): int32 =
    argc
    argv
    cmdline.CaptureCmdLine(argc, argv)
    let count = cmdline.ParamCount()
    if count <= 0:
        return nodecmd.ChengNodeCommandAt(1)
    let cmd = cmdline.ParamStr(1)
    if cmd == "ctl":
        return nodecmd.ChengNodeCommandAt(2)
    return nodecmd.ChengNodeCommandAt(1)
