import std/result
import std/system as system
import cheng/std/bytes_layout as layout
import cheng/apps/chain_node/cheng_node_map as cmap
import std/strutils as strutil

type
    ChengNodeIndexSpec =
        groupName: str
        lookupKinds: str[]

    ChengNodeIndexEntry =
        groupName: str
        lookupKind: str
        keyText: str
        valueCid: layout.FixedBytes32
        eventSeq: int32
        proofCid: layout.FixedBytes32
        active: bool

    ChengNodeIndexRegistry =
        specs: ChengNodeIndexSpec[]
        specIndex: cmap.ChengNodeStrIntMap
        entryIndex: cmap.ChengNodeStrIntMap
        entries: ChengNodeIndexEntry[]

fn ChengNodeIndexOwnText(text: str): str =
    return system.SystemToStringStr(text)

fn ChengNodeIndexLookupKinds(values: str[]): str[] =
    var out: str[]
    out = []
    for i in 0..<values.len:
        add(out, ChengNodeIndexOwnText(values[i]))
    return out

fn ChengNodeIndexCanonicalKey(groupName: str,
                                lookupKind: str,
                                keyText: str): str =
    return strutil.Join([groupName, "|", lookupKind, "|", keyText], "")

fn ChengNodeIndexLookupKindAllowed(spec: ChengNodeIndexSpec,
                                     lookupKind: str): bool =
    for i in 0..<spec.lookupKinds.len:
        if spec.lookupKinds[i] == lookupKind:
            return true
    return false

fn ChengNodeIndexRegisterGroup(registry: var ChengNodeIndexRegistry,
                                 groupName: str,
                                 lookupKinds: str[]) =
    let groupNameOwned = ChengNodeIndexOwnText(groupName)
    let spec = ChengNodeIndexSpec(groupName: groupNameOwned,
                                    lookupKinds: ChengNodeIndexLookupKinds(lookupKinds))
    add(registry.specs, spec)
    cmap.ChengNodeStrIntMapPut(registry.specIndex, groupNameOwned, registry.specs.len)

fn ChengNodeIndexRegisterRequiredGroups(registry: var ChengNodeIndexRegistry) =
    ChengNodeIndexRegisterGroup(registry, "balance", ["asset_account"])
    ChengNodeIndexRegisterGroup(registry, "did", ["subject"])
    ChengNodeIndexRegisterGroup(registry, "did_operator", ["operator"])
    ChengNodeIndexRegisterGroup(registry, "discovery", ["peer", "topic", "capability"])
    ChengNodeIndexRegisterGroup(registry, "snapshot", ["head", "version"])
    ChengNodeIndexRegisterGroup(registry, "oracle", ["pair"])
    ChengNodeIndexRegisterGroup(registry, "diloco_job", ["job"])
    ChengNodeIndexRegisterGroup(registry, "diloco_cohort", ["cohort"])
    ChengNodeIndexRegisterGroup(registry, "diloco_lease", ["lease"])
    ChengNodeIndexRegisterGroup(registry, "evomap", ["agent", "task", "capsule"])
    ChengNodeIndexRegisterGroup(registry, "vpn_peer", ["peer"])
    ChengNodeIndexRegisterGroup(registry, "vpn_route", ["route"])
    ChengNodeIndexRegisterGroup(registry, "compiler", ["world_head", "package", "target", "build_receipt"])

fn ChengNodeIndexRegistryInitInPlace(out: var ChengNodeIndexRegistry) =
    out.specs = []
    out.entries = []
    cmap.ChengNodeStrIntMapInitInPlace(out.specIndex, 32)
    cmap.ChengNodeStrIntMapInitInPlace(out.entryIndex, 128)
    ChengNodeIndexRegisterRequiredGroups(out)

fn ChengNodeIndexRequiredGroupCount(registry: ChengNodeIndexRegistry): int32 =
    return registry.specs.len

fn ChengNodeIndexSpecSlot(registry: ChengNodeIndexRegistry,
                            groupName: str): int32 =
    var found = false
    let raw = cmap.ChengNodeStrIntMapGet(registry.specIndex, groupName, found)
    if !found || raw <= 0:
        return -1
    return raw - 1

fn ChengNodeIndexUpsert(registry: var ChengNodeIndexRegistry,
                          groupName: str,
                          lookupKind: str,
                          keyText: str,
                          valueCid: layout.FixedBytes32,
                          eventSeq: int32,
                          proofCid: layout.FixedBytes32): Result[bool] =
    let specSlot = ChengNodeIndexSpecSlot(registry, groupName)
    if specSlot < 0:
        return Err[bool]("cheng_node index: unknown group")
    let spec = registry.specs[specSlot]
    if !ChengNodeIndexLookupKindAllowed(spec, lookupKind):
        return Err[bool]("cheng_node index: unsupported lookup kind")
    if len(keyText) <= 0:
        return Err[bool]("cheng_node index: empty key text")
    let canonicalKey = ChengNodeIndexCanonicalKey(groupName, lookupKind, keyText)
    var found = false
    let raw = cmap.ChengNodeStrIntMapGet(registry.entryIndex, canonicalKey, found)
    if found && raw > 0:
        let slot = raw - 1
        registry.entries[slot].groupName = ChengNodeIndexOwnText(groupName)
        registry.entries[slot].lookupKind = ChengNodeIndexOwnText(lookupKind)
        registry.entries[slot].keyText = ChengNodeIndexOwnText(keyText)
        registry.entries[slot].valueCid = valueCid
        registry.entries[slot].eventSeq = eventSeq
        registry.entries[slot].proofCid = proofCid
        registry.entries[slot].active = true
        return Ok[bool](false)
    let entry = ChengNodeIndexEntry(groupName: ChengNodeIndexOwnText(groupName),
                                      lookupKind: ChengNodeIndexOwnText(lookupKind),
                                      keyText: ChengNodeIndexOwnText(keyText),
                                      valueCid: valueCid,
                                      eventSeq: eventSeq,
                                      proofCid: proofCid,
                                      active: true)
    add(registry.entries, entry)
    cmap.ChengNodeStrIntMapPut(registry.entryIndex, canonicalKey, registry.entries.len)
    return Ok[bool](true)

fn ChengNodeIndexRemove(registry: var ChengNodeIndexRegistry,
                          groupName: str,
                          lookupKind: str,
                          keyText: str,
                          eventSeq: int32,
                          proofCid: layout.FixedBytes32): Result[bool] =
    let canonicalKey = ChengNodeIndexCanonicalKey(groupName, lookupKind, keyText)
    var found = false
    let raw = cmap.ChengNodeStrIntMapGet(registry.entryIndex, canonicalKey, found)
    if !found || raw <= 0:
        return Err[bool]("cheng_node index: key not found")
    let slot = raw - 1
    registry.entries[slot].valueCid = layout.FixedBytes32()
    registry.entries[slot].eventSeq = eventSeq
    registry.entries[slot].proofCid = proofCid
    registry.entries[slot].active = false
    return Ok[bool](true)

fn ChengNodeIndexGet(registry: ChengNodeIndexRegistry,
                       groupName: str,
                       lookupKind: str,
                       keyText: str): Result[ChengNodeIndexEntry] =
    let canonicalKey = ChengNodeIndexCanonicalKey(groupName, lookupKind, keyText)
    var found = false
    let raw = cmap.ChengNodeStrIntMapGet(registry.entryIndex, canonicalKey, found)
    if !found || raw <= 0:
        return Err[ChengNodeIndexEntry]("cheng_node index: key not found")
    let entry = registry.entries[raw - 1]
    if !entry.active:
        return Err[ChengNodeIndexEntry]("cheng_node index: key tombstoned")
    return Ok[ChengNodeIndexEntry](entry)

fn ChengNodeBalanceKey(assetId: int32,
                         accountId: int32): str =
    return strutil.Join([IntToStr(assetId), "/", IntToStr(accountId)], "")
